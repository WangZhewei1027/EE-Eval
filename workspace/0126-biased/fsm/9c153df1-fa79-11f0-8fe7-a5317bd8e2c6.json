      "els.autoSnapshotToggleBtn.onclick = toggleAutoSnapshot;",
      "els.undoBtn.onclick = undo;",
      "els.redoBtn.onclick = redo;",
      "els.switchToBtn.onclick = ()=> { const id = (store.activeContextId) ? store.activeContextId : Object.keys(store.contexts)[0]; const ids = getSelectedContextIds(); if (ids.length!==1) { alert('Select exactly one context (via checkbox) to Switch To'); return; } switchToContext(ids[0]); };",
      "els.pushBtn.onclick = ()=> { const ids = getSelectedContextIds(); if (ids.length !== 1) { alert('Select exactly one context to push & switch'); return; } pushAndSwitch(ids[0]); };",
      "els.popBtn.onclick = popBack;",
      "els.stashBtn.onclick = ()=> { const ids = getSelectedContextIds(); if (ids.length !== 1) { alert('Select exactly one context to stash & switch'); return; } stashAndSwitch(ids[0]); };",
      "els.startSimBtn.onclick = startSimulation;",
      "els.stopSimBtn.onclick = stopSimulation;",
