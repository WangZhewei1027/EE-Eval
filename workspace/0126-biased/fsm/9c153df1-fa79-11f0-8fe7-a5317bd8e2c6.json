      "els.newContextBtn.onclick = ()=> { const name = prompt('Context name', 'Context ' + (Object.keys(store.contexts).length+1)); const ctx = makeContext(name); store.contexts[ctx.id] = ctx; store.order.push(ctx.id); selectContext(ctx.id); renderContextsList(); log('Created new context ' + ctx.name); };",
      "els.duplicateContextBtn.onclick = duplicateSelected;",
      "els.deleteContextBtn.onclick = deleteSelected;",
      "els.pinToggleBtn.onclick = ()=> { const id = store.activeContextId; if (!id) return; store.contexts[id].pinned = !store.contexts[id].pinned; renderContextsList(); renderBranches(id); log('Toggled pin for ' + store.contexts[id].name); };",
      "els.filterInput.oninput = renderContextsList;",
      "els.sortSelect.onchange = renderContextsList;",
      "els.exportAllBtn.onclick = exportAll;",
      "els.importBtn.onclick = ()=> els.importFile.click();",
      "els.clearAllBtn.onclick = clearAll;",
