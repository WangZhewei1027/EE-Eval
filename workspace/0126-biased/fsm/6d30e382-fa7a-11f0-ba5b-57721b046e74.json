  "events": [
    {
      "id": "RebuildTree",
      "event_type": "click",
      "description": "Rebuild the B-Tree with a new order",
      "trigger_selectors": [
        "#rebuildTree"
      ],
      "evidence": [
        "document.getElementById('rebuildTree').addEventListener('click', () => { const newOrder = parseInt(document.getElementById('orderSlider').textContent); this.tree = new BTree(newOrder); this.renderTree(); });"
      ],
      "confidence": 1
    },
    {
      "id": "InsertValue",
      "event_type": "click",
      "description": "Insert a value into the B-Tree",
      "trigger_selectors": [
        "#insertBtn"
      ],
      "evidence": [
        "document.getElementById('insertBtn').addEventListener('click', () => { const value = parseInt(document.getElementById('insertValue').value); if (!isNaN(value)) { this.tree.insert(value); this.renderTree(); document.getElementById('insertValue').value = ''; } });"
      ],
      "confidence": 1
    },
    {
      "id": "DeleteValue",
      "event_type": "click",
      "description": "Delete a value from the B-Tree",
      "trigger_selectors": [
        "#deleteBtn"
      ],
      "evidence": [
        "document.getElementById('deleteBtn').addEventListener('click', () => { const value = parseInt(document.getElementById('deleteValue').value); if (!isNaN(value)) { this.tree.delete(value); this.renderTree(); document.getElementById('deleteValue').value = ''; } });"
      ],
      "confidence": 1
    },
    {
      "id": "SearchValue",
      "event_type": "click",
      "description": "Search for a value in the B-Tree",
      "trigger_selectors": [
        "#searchBtn"
      ],
      "evidence": [
        "document.getElementById('searchBtn').addEventListener('click', () => { const value = parseInt(document.getElementById('searchValue').value); if (!isNaN(value)) { this.tree.clearHighlights(); const result = this.tree.root ? this.tree.root.search(value) : null; if (result) { this.tree.highlightNode(result.node); } this.renderTree(); setTimeout(() => { this.tree.clearHighlights(); this.renderTree(); }, 2000); } });"
      ],
      "confidence": 1
    },
    {
      "id": "ShowAllNodes",
      "event_type": "click",
      "description": "Show all nodes in the B-Tree",
      "trigger_selectors": [
        "#showAll"
      ],
      "evidence": [
        "document.getElementById('showAll').addEventListener('click', () => { this.tree.traverse(node => node.collapsed = false); this.renderTree(); });"
      ],
      "confidence": 1
    },
    {
      "id": "CollapseAllNodes",
      "event_type": "click",
      "description": "Collapse all nodes in the B-Tree",
      "trigger_selectors": [
        "#collapseAll"
      ],
      "evidence": [
        "document.getElementById('collapseAll').addEventListener('click', () => { this.tree.traverse(node => { if (!node.isLeaf) node.collapsed = true; }); this.renderTree(); });"
      ],
      "confidence": 1
    },
    {
      "id": "BulkInsert",
      "event_type": "click",
      "description": "Insert multiple values into the B-Tree",
      "trigger_selectors": [
        "#bulkInsert"
      ],
      "evidence": [
        "document.getElementById('bulkInsert').addEventListener('click', () => { const values = document.getElementById('bulkValues').value.split(',').map(v => parseInt(v.trim())).filter(v => !isNaN(v)); values.forEach(v => this.tree.insert(v)); this.renderTree(); document.getElementById('bulkValues').value = ''; });"
      ],
      "confidence": 1
    },
    {
      "id": "GenerateRandomTree",
      "event_type": "click",
      "description": "Generate a random B-Tree",
      "trigger_selectors": [
        "#randomTree"
      ],
      "evidence": [
        "document.getElementById('randomTree').addEventListener('click', () => { const count = parseInt(document.getElementById('randomCount').value) || 10; this.tree = new BTree(parseInt(document.getElementById('orderValue').textContent)); for (let i = 0; i < count; i++) { const value = Math.floor(Math.random() * 100); this.tree.insert(value); } this.renderTree(); });"
      ],
      "confidence": 1
    }
