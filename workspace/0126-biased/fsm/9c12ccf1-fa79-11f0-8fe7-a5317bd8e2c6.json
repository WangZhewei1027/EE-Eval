      "document.getElementById('listType').addEventListener('change', function(){ setType(this.value); });",
      "document.getElementById('buildBtn').addEventListener('click', function(){ const raw = document.getElementById('buildInput').value; const arr = parseCSV(raw); buildFromArray(arr, true); });",
      "document.getElementById('appendArrayBtn').addEventListener('click', function(){ const raw = document.getElementById('buildInput').value; const arr = parseCSV(raw); buildFromArray(arr, false); });",
      "document.getElementById('clearBtn').addEventListener('click', function(){ clearList(); });",
      "document.getElementById('randomFillBtn').addEventListener('click', function(){ const n = Number(document.getElementById('randomCount').value) || 0; randomFill(n); });",
      "document.getElementById('insertBtn').addEventListener('click', function(){ const value = document.getElementById('insertValue').value; const pos = document.getElementById('insertPosition').value; const idx = Number(document.getElementById('insertIndex').value); insertAt(value, pos, idx); });",
      "document.getElementById('deleteBtn').addEventListener('click', function(){ const pos = document.getElementById('deletePosition').value; const idx = Number(document.getElementById('deleteIndex').value); const val = document.getElementById('deleteValue').value; deleteAt(pos, idx, val); });",
      "document.getElementById('updateBtn').addEventListener('click', function(){ const idx = Number(document.getElementById('updateIndex').value); const val = document.getElementById('updateValue').value; updateAt(idx, val); });",
      "document.getElementById('searchBtn').addEventListener('click', function(){ const v = document.getElementById('searchValue').value; snapshotPush('Search full for ' + v); const indices = []; state.nodes.forEach((n,i)=>{ if(String(n.value) === String(v)) indices.push(i); }); if(indices.length === 0) pushHistory('Search: no matches for ' + v); else pushHistory('Search: matches at ' + indices.join(', ')); state.cursorIndex = indices.length>0?indices[0]:null; render(); });",
      "document.getElementById('reverseBtn').addEventListener('click', function(){ snapshotPush('Reverse full'); state.nodes = state.nodes.slice().reverse(); render(); });",
      "document.getElementById('rotateLeft').addEventListener('click', function(){ const k = Number(document.getElementById('rotateK').value) || 0; rotateLeft(k); });",
      "document.getElementById('rotateRight').addEventListener('click', function(){ const k = Number(document.getElementById('rotateK').value) || 0; rotateRight(k); });",
      "document.getElementById('mergeBtn').addEventListener('click', function(){ const arr = parseCSV(document.getElementById('mergeInput').value); mergeArray(arr, false); });",
      "document.getElementById('mergeAsNewBtn').addEventListener('click', function(){ const arr = parseCSV(document.getElementById('mergeInput').value); mergeArray(arr, true); });",
      "document.getElementById('copyBtn').addEventListener('click', function(){ cloneList(); });",
      "document.getElementById('exportBtn').addEventListener('click', exportJSON);",
      "document.getElementById('importBtn').addEventListener('click', function(){ importJSON(true); });",
      "document.getElementById('importAppendBtn').addEventListener('click', function(){ importJSON(false); });",
      "document.getElementById('saveBookmark').addEventListener('click', function(){ const name = document.getElementById('bookmarkName').value; saveBookmark(name); });",
      "document.getElementById('loadBookmark').addEventListener('click', function(){ const sel = document.getElementById('bookmarkList'); loadBookmark(sel.value); });",
      "document.getElementById('delBookmark').addEventListener('click', function(){ const sel = document.getElementById('bookmarkList'); deleteBookmark(sel.value); });",
      "document.getElementById('undoBtn').addEventListener('click', undo);",
      "document.getElementById('redoBtn').addEventListener('click', redo);",
      "document.getElementById('startTransaction').addEventListener('click', startTransaction);",
      "document.getElementById('commitTransaction').addEventListener('click', commitTransaction);",
      "document.getElementById('rollbackTransaction').addEventListener('click', rollbackTransaction);",
      "document.getElementById('showRawBtn').addEventListener('click', function(){ inspector.textContent = 'Raw state:\\n' + JSON.stringify(state, null, 2); });",
      "document.getElementById('inspectMemoryBtn').addEventListener('click', function(){ inspector.textContent = 'Memory (nodes):\\n' + state.nodes.map((n,i)=> i + ': id=' + n.id + ' val=' + n.value).join('\\n'); });",
