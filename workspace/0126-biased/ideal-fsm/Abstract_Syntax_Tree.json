{
  "meta": {
    "concept": "AbstractSyntaxTree",
    "topic": "Abstract Syntax Tree Visualization",
    "educational_goal": "Demonstrate AST construction and traversal",
    "expected_interactions": [
      "construct",
      "traverse",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderAST()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_ConstructStart",
      "label": "ConstructStart",
      "type": "atomic",
      "entry_actions": [
        "readInputExpression()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingExpression",
      "label": "ValidatingExpression",
      "type": "atomic",
      "entry_actions": [
        "validateExpression()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ConstructingAST",
      "label": "ConstructingAST",
      "type": "atomic",
      "entry_actions": [
        "parseExpression()",
        "createASTNodes()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingAST",
      "label": "DrawingAST",
      "type": "atomic",
      "entry_actions": [
        "updateASTVisualization()",
        "animateConstruction()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ASTResetting",
      "label": "ASTResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllNodes()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksConstruct",
      "event_type": "user_action",
      "description": "User clicks the Construct button"
    },
    {
      "id": "UserEntersExpression",
      "event_type": "user_action",
      "description": "User enters expression in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ExpressionValidationComplete",
      "event_type": "system_event",
      "description": "Expression validation completes successfully"
    },
    {
      "id": "ExpressionValidationFailed",
      "event_type": "system_event",
      "description": "Expression validation fails"
    },
    {
      "id": "ASTConstructionComplete",
      "event_type": "system_event",
      "description": "AST construction and visualization complete"
    },
    {
      "id": "ASTResetComplete",
      "event_type": "system_event",
      "description": "AST reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_ConstructStart",
      "event": "UserClicksConstruct",
      "guard": "expressionNotEmpty",
      "actions": [
        "captureExpression()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputExpression",
        "dom:constructButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_ConstructStart",
      "to": "S2_ValidatingExpression",
      "event": "ExpressionValidationComplete",
      "guard": "expressionIsValid",
      "actions": [
        "validateExpression()",
        "prepareConstruction()"
      ],
      "expected_observables": [
        "dom:expressionValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingExpression",
      "to": "S4_ConstructingAST",
      "event": "ExpressionValidationComplete",
      "guard": "validExpression",
      "actions": [
        "parseExpression()",
        "beginConstruction()"
      ],
      "expected_observables": [
        "dom:astCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_ConstructStart",
      "to": "S3_ErrorAlert",
      "event": "ExpressionValidationFailed",
      "guard": "expressionIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ConstructingAST",
      "to": "S5_DrawingAST",
      "event": "ASTConstructionComplete",
      "guard": "astConstructedSuccessfully",
      "actions": [
        "updateASTStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:astStructureChanged",
        "dom:newNodesVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingAST",
      "to": "S0_Idle",
      "event": "ASTConstructionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ASTResetting",
      "event": "UserClicksReset",
      "guard": "astNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ASTResetting",
      "to": "S0_Idle",
      "event": "ASTResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:astCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "construct",
    "reset",
    "ast_visualization"
  ]
}