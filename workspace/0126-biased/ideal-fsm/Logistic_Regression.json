{
  "meta": {
    "concept": "LogisticRegression",
    "topic": "Logistic Regression Model Training and Prediction",
    "educational_goal": "Teach the basics of logistic regression including data input, model training, and prediction",
    "expected_interactions": [
      "input_data",
      "train_model",
      "make_prediction",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderUI()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputData",
      "label": "InputData",
      "type": "atomic",
      "entry_actions": [
        "captureDataInput()",
        "highlightDataInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_TrainingModel",
      "label": "TrainingModel",
      "type": "atomic",
      "entry_actions": [
        "validateData()",
        "startTraining()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_MakingPrediction",
      "label": "MakingPrediction",
      "type": "atomic",
      "entry_actions": [
        "preparePrediction()",
        "executePrediction()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearModel()",
        "resetUI()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsData",
      "event_type": "user_action",
      "description": "User inputs data for training"
    },
    {
      "id": "UserClicksTrain",
      "event_type": "user_action",
      "description": "User clicks the Train button"
    },
    {
      "id": "UserClicksPredict",
      "event_type": "user_action",
      "description": "User clicks the Predict button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DataValidationComplete",
      "event_type": "system_event",
      "description": "Data validation completes successfully"
    },
    {
      "id": "DataValidationFailed",
      "event_type": "system_event",
      "description": "Data validation fails"
    },
    {
      "id": "ModelTrainingComplete",
      "event_type": "system_event",
      "description": "Model training completes successfully"
    },
    {
      "id": "PredictionComplete",
      "event_type": "system_event",
      "description": "Prediction completes successfully"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputData",
      "event": "UserInputsData",
      "guard": "dataNotEmpty",
      "actions": [
        "captureInputData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:dataInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputData",
      "to": "S2_TrainingModel",
      "event": "UserClicksTrain",
      "guard": "dataIsValid",
      "actions": [
        "validateData()",
        "beginTraining()"
      ],
      "expected_observables": [
        "dom:trainingStarted"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_TrainingModel",
      "to": "S4_MakingPrediction",
      "event": "ModelTrainingComplete",
      "guard": "modelTrainedSuccessfully",
      "actions": [
        "prepareForPrediction()",
        "enablePrediction()"
      ],
      "expected_observables": [
        "dom:modelTrained"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputData",
      "to": "S3_ErrorAlert",
      "event": "DataValidationFailed",
      "guard": "dataIsInvalid",
      "actions": [
        "showError()",
        "focusDataInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetDataInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_MakingPrediction",
      "to": "S0_Idle",
      "event": "PredictionComplete",
      "guard": "predictionSuccessful",
      "actions": [
        "displayPredictionResult()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:predictionResultDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "modelOrDataExists",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetDataInput()"
      ],
      "expected_observables": [
        "dom:resetComplete"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "data_input",
    "train_button",
    "predict_button",
    "reset_button",
    "model_visualization"
  ]
}