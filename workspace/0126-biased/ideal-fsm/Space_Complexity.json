{
  "meta": {
    "concept": "Space Complexity",
    "topic": "Understanding Space Complexity in Algorithms",
    "educational_goal": "Explain and visualize space complexity of algorithms",
    "expected_interactions": [
      "input_algorithm",
      "calculate_space",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputAlgorithm",
      "label": "InputAlgorithm",
      "type": "atomic",
      "entry_actions": [
        "readAlgorithmInput()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_CalculatingSpace",
      "label": "CalculatingSpace",
      "type": "operation",
      "entry_actions": [
        "computeSpaceComplexity()",
        "showCalculationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_DisplayResult",
      "label": "DisplayResult",
      "type": "atomic",
      "entry_actions": [
        "updateResultVisualization()",
        "animateResultDisplay()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearInputField()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsAlgorithm",
      "event_type": "user_action",
      "description": "User inputs algorithm in the input field"
    },
    {
      "id": "UserClicksCalculate",
      "event_type": "user_action",
      "description": "User clicks the Calculate button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CalculationComplete",
      "event_type": "system_event",
      "description": "Space complexity calculation completes successfully"
    },
    {
      "id": "CalculationFailed",
      "event_type": "system_event",
      "description": "Space complexity calculation fails"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputAlgorithm",
      "event": "UserInputsAlgorithm",
      "guard": "inputNotEmpty",
      "actions": [
        "captureAlgorithmInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:algorithmInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputAlgorithm",
      "to": "S2_CalculatingSpace",
      "event": "UserClicksCalculate",
      "guard": "inputIsValid",
      "actions": [
        "validateAlgorithmInput()",
        "startCalculation()"
      ],
      "expected_observables": [
        "dom:calculationStarted"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_CalculatingSpace",
      "to": "S4_DisplayResult",
      "event": "CalculationComplete",
      "guard": "calculationSuccessful",
      "actions": [
        "displayCalculationResult()",
        "triggerResultAnimation()"
      ],
      "expected_observables": [
        "dom:resultDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputAlgorithm",
      "to": "S3_ErrorAlert",
      "event": "CalculationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_DisplayResult",
      "to": "S0_Idle",
      "event": "CalculationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInputField()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "inputNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:inputFieldCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "calculate",
    "reset",
    "result_visualization"
  ]
}