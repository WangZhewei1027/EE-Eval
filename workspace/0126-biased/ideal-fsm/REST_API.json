{
  "meta": {
    "concept": "REST API",
    "topic": "REST API Interaction",
    "educational_goal": "Demonstrate basic REST API operations",
    "expected_interactions": [
      "sendRequest",
      "receiveResponse",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderUI()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_PreparingRequest",
      "label": "PreparingRequest",
      "type": "atomic",
      "entry_actions": [
        "readInputValues()",
        "highlightInputFields()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_SendingRequest",
      "label": "SendingRequest",
      "type": "atomic",
      "entry_actions": [
        "sendHTTPRequest()",
        "showLoadingIndicator()"
      ],
      "exit_actions": [
        "hideLoadingIndicator()"
      ]
    },
    {
      "id": "S3_ReceivingResponse",
      "label": "ReceivingResponse",
      "type": "atomic",
      "entry_actions": [
        "processResponse()",
        "displayResponseData()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllFields()",
        "resetUI()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksSend",
      "event_type": "user_action",
      "description": "User clicks the Send Request button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters values in input fields"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "RequestSent",
      "event_type": "system_event",
      "description": "HTTP request is successfully sent"
    },
    {
      "id": "ResponseReceived",
      "event_type": "system_event",
      "description": "HTTP response is received"
    },
    {
      "id": "RequestFailed",
      "event_type": "system_event",
      "description": "HTTP request failed"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_PreparingRequest",
      "event": "UserClicksSend",
      "guard": "inputFieldsNotEmpty",
      "actions": [
        "captureInputValues()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:sendButtonClicked",
        "dom:inputValuesCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_PreparingRequest",
      "to": "S2_SendingRequest",
      "event": "RequestSent",
      "guard": "requestPrepared",
      "actions": [
        "initiateHTTPRequest()"
      ],
      "expected_observables": [
        "dom:requestInitiated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_SendingRequest",
      "to": "S3_ReceivingResponse",
      "event": "ResponseReceived",
      "guard": "responseValid",
      "actions": [
        "parseResponseData()",
        "displayResponse()"
      ],
      "expected_observables": [
        "dom:responseDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_SendingRequest",
      "to": "S4_ErrorAlert",
      "event": "RequestFailed",
      "guard": "true",
      "actions": [
        "showError()",
        "focusInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "fieldsNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:fieldsCleared",
        "dom:uiReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "send",
    "reset",
    "response_display"
  ]
}