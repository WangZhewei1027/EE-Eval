{
  "meta": {
    "concept": "DynamicProgramming",
    "topic": "Dynamic Programming Problem Solving",
    "educational_goal": "Teach dynamic programming approach for optimization problems",
    "expected_interactions": [
      "define_problem",
      "solve_problem",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_DefineProblem",
      "label": "DefineProblem",
      "type": "atomic",
      "entry_actions": [
        "captureProblemInput()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingProblem",
      "label": "ValidatingProblem",
      "type": "atomic",
      "entry_actions": [
        "validateProblemInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_SolvingProblem",
      "label": "SolvingProblem",
      "type": "operation",
      "entry_actions": [
        "executeDynamicProgramming()",
        "updateSolutionVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ProblemSolved",
      "label": "ProblemSolved",
      "type": "atomic",
      "entry_actions": [
        "displaySolution()",
        "enableControls()"
      ],
      "exit_actions": [
        "clearInput()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearProblemData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksDefine",
      "event_type": "user_action",
      "description": "User clicks the Define Problem button"
    },
    {
      "id": "UserEntersProblemInput",
      "event_type": "user_action",
      "description": "User enters problem details in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ProblemValidationComplete",
      "event_type": "system_event",
      "description": "Problem input validation completes successfully"
    },
    {
      "id": "ProblemValidationFailed",
      "event_type": "system_event",
      "description": "Problem input validation fails"
    },
    {
      "id": "ProblemSolvingComplete",
      "event_type": "system_event",
      "description": "Dynamic programming solution complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_DefineProblem",
      "event": "UserClicksDefine",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:problemInputCaptured",
        "dom:defineButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_DefineProblem",
      "to": "S2_ValidatingProblem",
      "event": "ProblemValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateProblemDetails()",
        "prepareSolution()"
      ],
      "expected_observables": [
        "dom:problemValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingProblem",
      "to": "S4_SolvingProblem",
      "event": "ProblemValidationComplete",
      "guard": "validProblem",
      "actions": [
        "parseProblemInput()",
        "beginSolving()"
      ],
      "expected_observables": [
        "dom:solutionProcessStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_DefineProblem",
      "to": "S3_ErrorAlert",
      "event": "ProblemValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_SolvingProblem",
      "to": "S5_ProblemSolved",
      "event": "ProblemSolvingComplete",
      "guard": "solutionFound",
      "actions": [
        "updateSolutionDisplay()",
        "triggerSolutionVisualization()"
      ],
      "expected_observables": [
        "dom:solutionDisplayed",
        "dom:solutionVisualizationComplete"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ProblemSolved",
      "to": "S0_Idle",
      "event": "ProblemSolvingComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "problemDefined",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:problemDataCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "define",
    "reset",
    "solution_visualization"
  ]
}