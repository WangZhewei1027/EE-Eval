{
  "meta": {
    "concept": "CPU Scheduling",
    "topic": "CPU Scheduling Algorithms Visualization",
    "educational_goal": "Demonstrate process scheduling and execution order",
    "expected_interactions": [
      "add_process",
      "start_scheduling",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderScheduler()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddingProcess",
      "label": "AddingProcess",
      "type": "atomic",
      "entry_actions": [
        "readProcessInput()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingProcess",
      "label": "ValidatingProcess",
      "type": "atomic",
      "entry_actions": [
        "validateProcessInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_SchedulingProcesses",
      "label": "SchedulingProcesses",
      "type": "atomic",
      "entry_actions": [
        "executeSchedulingAlgorithm()",
        "updateProcessOrder()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_VisualizationComplete",
      "label": "VisualizationComplete",
      "type": "atomic",
      "entry_actions": [
        "displayExecutionOrder()",
        "animateProcessExecution()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingScheduler",
      "label": "ResettingScheduler",
      "type": "atomic",
      "entry_actions": [
        "clearAllProcesses()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAddProcess",
      "event_type": "user_action",
      "description": "User clicks the Add Process button"
    },
    {
      "id": "UserEntersProcessInput",
      "event_type": "user_action",
      "description": "User enters process details in input field"
    },
    {
      "id": "UserClicksStartScheduling",
      "event_type": "user_action",
      "description": "User clicks the Start Scheduling button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ProcessValidationComplete",
      "event_type": "system_event",
      "description": "Process input validation completes successfully"
    },
    {
      "id": "ProcessValidationFailed",
      "event_type": "system_event",
      "description": "Process input validation fails"
    },
    {
      "id": "SchedulingComplete",
      "event_type": "system_event",
      "description": "Scheduling algorithm execution complete"
    },
    {
      "id": "SchedulerResetComplete",
      "event_type": "system_event",
      "description": "Scheduler reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddingProcess",
      "event": "UserClicksAddProcess",
      "guard": "inputNotEmpty",
      "actions": [
        "captureProcessInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readProcessInput",
        "dom:addProcessButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddingProcess",
      "to": "S2_ValidatingProcess",
      "event": "ProcessValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateProcessDetails()",
        "prepareScheduling()"
      ],
      "expected_observables": [
        "dom:processInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingProcess",
      "to": "S4_SchedulingProcesses",
      "event": "ProcessValidationComplete",
      "guard": "validProcessDetails",
      "actions": [
        "parseProcessInput()",
        "beginScheduling()"
      ],
      "expected_observables": [
        "dom:schedulingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AddingProcess",
      "to": "S3_ErrorAlert",
      "event": "ProcessValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_SchedulingProcesses",
      "to": "S5_VisualizationComplete",
      "event": "SchedulingComplete",
      "guard": "schedulingSuccessful",
      "actions": [
        "updateProcessVisualization()",
        "triggerExecutionAnimation()"
      ],
      "expected_observables": [
        "dom:processOrderUpdated",
        "dom:executionOrderVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_VisualizationComplete",
      "to": "S0_Idle",
      "event": "SchedulingComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingScheduler",
      "event": "UserClicksReset",
      "guard": "schedulerNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingScheduler",
      "to": "S0_Idle",
      "event": "SchedulerResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:schedulerCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "add_process",
    "start_scheduling",
    "reset",
    "scheduler_visualization"
  ]
}