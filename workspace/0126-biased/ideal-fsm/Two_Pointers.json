{
  "meta": {
    "concept": "Two Pointers",
    "topic": "Two Pointers Technique",
    "educational_goal": "Demonstrate how to use two pointers for array manipulation",
    "expected_interactions": [
      "setPointers",
      "movePointers",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SettingPointers",
      "label": "SettingPointers",
      "type": "atomic",
      "entry_actions": [
        "readPointerValues()",
        "highlightPointers()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_MovingPointers",
      "label": "MovingPointers",
      "type": "atomic",
      "entry_actions": [
        "movePointers()",
        "updatePointerPositions()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearPointers()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSetsPointers",
      "event_type": "user_action",
      "description": "User sets initial positions of the pointers"
    },
    {
      "id": "UserMovesPointers",
      "event_type": "user_action",
      "description": "User moves the pointers"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PointerSettingComplete",
      "event_type": "system_event",
      "description": "Pointers are set successfully"
    },
    {
      "id": "PointerSettingFailed",
      "event_type": "system_event",
      "description": "Pointer setting fails"
    },
    {
      "id": "PointerMovementComplete",
      "event_type": "system_event",
      "description": "Pointers have been moved successfully"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SettingPointers",
      "event": "UserSetsPointers",
      "guard": "validPointerPositions",
      "actions": [
        "capturePointerValues()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:pointerValuesCaptured",
        "dom:setPointersButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SettingPointers",
      "to": "S2_MovingPointers",
      "event": "PointerSettingComplete",
      "guard": "pointersSetCorrectly",
      "actions": [
        "validatePointerPositions()",
        "preparePointerMovement()"
      ],
      "expected_observables": [
        "dom:pointersValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_SettingPointers",
      "to": "S3_ErrorAlert",
      "event": "PointerSettingFailed",
      "guard": "invalidPointerPositions",
      "actions": [
        "showError()",
        "focusPointerInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetPointerInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S2_MovingPointers",
      "to": "S0_Idle",
      "event": "PointerMovementComplete",
      "guard": "movementSuccessful",
      "actions": [
        "updateArrayState()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:pointerPositionsUpdated",
        "dom:arrayStateChanged"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "pointersNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetPointerInputField()"
      ],
      "expected_observables": [
        "dom:pointersCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "set_pointers",
    "move_pointers",
    "reset",
    "array_visualization"
  ]
}