{
  "meta": {
    "concept": "Semaphore",
    "topic": "Semaphore Mechanism Visualization",
    "educational_goal": "Demonstrate semaphore operations and synchronization",
    "expected_interactions": [
      "initialize",
      "wait",
      "signal",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderSemaphore()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InitializeStart",
      "label": "InitializeStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_WaitOperation",
      "label": "WaitOperation",
      "type": "atomic",
      "entry_actions": [
        "decrementSemaphore()",
        "updateVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SignalOperation",
      "label": "SignalOperation",
      "type": "atomic",
      "entry_actions": [
        "incrementSemaphore()",
        "updateVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_ResettingSemaphore",
      "label": "ResettingSemaphore",
      "type": "atomic",
      "entry_actions": [
        "resetSemaphore()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInitialize",
      "event_type": "user_action",
      "description": "User clicks the Initialize button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters initial value in input field"
    },
    {
      "id": "UserClicksWait",
      "event_type": "user_action",
      "description": "User clicks the Wait button"
    },
    {
      "id": "UserClicksSignal",
      "event_type": "user_action",
      "description": "User clicks the Signal button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "WaitOperationComplete",
      "event_type": "system_event",
      "description": "Wait operation completes successfully"
    },
    {
      "id": "SignalOperationComplete",
      "event_type": "system_event",
      "description": "Signal operation completes successfully"
    },
    {
      "id": "SemaphoreResetComplete",
      "event_type": "system_event",
      "description": "Semaphore reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InitializeStart",
      "event": "UserClicksInitialize",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:initializeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InitializeStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValue()",
        "prepareInitialization()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S0_Idle",
      "event": "InputValidationComplete",
      "guard": "validNumber",
      "actions": [
        "initializeSemaphore()",
        "renderSemaphore()"
      ],
      "expected_observables": [
        "dom:semaphoreInitialized"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InitializeStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S4_WaitOperation",
      "event": "UserClicksWait",
      "guard": "semaphorePositive",
      "actions": [
        "performWait()",
        "updateVisualization()"
      ],
      "expected_observables": [
        "dom:waitButtonClicked",
        "dom:semaphoreDecremented"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_WaitOperation",
      "to": "S0_Idle",
      "event": "WaitOperationComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:waitOperationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_SignalOperation",
      "event": "UserClicksSignal",
      "guard": "true",
      "actions": [
        "performSignal()",
        "updateVisualization()"
      ],
      "expected_observables": [
        "dom:signalButtonClicked",
        "dom:semaphoreIncremented"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_SignalOperation",
      "to": "S0_Idle",
      "event": "SignalOperationComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:signalOperationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingSemaphore",
      "event": "UserClicksReset",
      "guard": "semaphoreInitialized",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingSemaphore",
      "to": "S0_Idle",
      "event": "SemaphoreResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:semaphoreCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "initialize",
    "wait",
    "signal",
    "reset",
    "semaphore_visualization"
  ]
}