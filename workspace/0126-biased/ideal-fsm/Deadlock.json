{
  "meta": {
    "concept": "Deadlock",
    "topic": "Deadlock Detection and Resolution",
    "educational_goal": "Demonstrate deadlock detection and resolution strategies",
    "expected_interactions": [
      "detect",
      "resolve",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderSystemState()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_DetectingDeadlock",
      "label": "DetectingDeadlock",
      "type": "atomic",
      "entry_actions": [
        "analyzeResourceAllocation()",
        "highlightPotentialDeadlock()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_DeadlockDetected",
      "label": "DeadlockDetected",
      "type": "atomic",
      "entry_actions": [
        "showDeadlockAlert()",
        "highlightDeadlockProcesses()"
      ],
      "exit_actions": [
        "clearDeadlockHighlight()"
      ]
    },
    {
      "id": "S3_ResolvingDeadlock",
      "label": "ResolvingDeadlock",
      "type": "atomic",
      "entry_actions": [
        "selectResolutionStrategy()",
        "applyResolution()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_DeadlockResolved",
      "label": "DeadlockResolved",
      "type": "atomic",
      "entry_actions": [
        "updateSystemState()",
        "showResolutionSuccess()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_SystemResetting",
      "label": "SystemResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllProcesses()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksDetect",
      "event_type": "user_action",
      "description": "User clicks the Detect button"
    },
    {
      "id": "DeadlockDetectionComplete",
      "event_type": "system_event",
      "description": "Deadlock detection process completes"
    },
    {
      "id": "UserClicksResolve",
      "event_type": "user_action",
      "description": "User clicks the Resolve button"
    },
    {
      "id": "DeadlockResolutionComplete",
      "event_type": "system_event",
      "description": "Deadlock resolution process completes"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_DetectingDeadlock",
      "event": "UserClicksDetect",
      "guard": "systemHasProcesses",
      "actions": [
        "disableControls()",
        "startDetection()"
      ],
      "expected_observables": [
        "dom:detectButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_DetectingDeadlock",
      "to": "S2_DeadlockDetected",
      "event": "DeadlockDetectionComplete",
      "guard": "deadlockDetected",
      "actions": [
        "highlightDeadlock()",
        "notifyUser()"
      ],
      "expected_observables": [
        "dom:deadlockAlertShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_DeadlockDetected",
      "to": "S3_ResolvingDeadlock",
      "event": "UserClicksResolve",
      "guard": "resolutionPossible",
      "actions": [
        "disableControls()",
        "beginResolution()"
      ],
      "expected_observables": [
        "dom:resolveButtonClicked"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_ResolvingDeadlock",
      "to": "S4_DeadlockResolved",
      "event": "DeadlockResolutionComplete",
      "guard": "resolutionSuccessful",
      "actions": [
        "updateVisualization()",
        "notifyResolution()"
      ],
      "expected_observables": [
        "dom:resolutionSuccessShown"
      ],
      "timeout": 2000
    },
    {
      "from": "S4_DeadlockResolved",
      "to": "S0_Idle",
      "event": "DeadlockResolutionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:controlsEnabled"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_SystemResetting",
      "event": "UserClicksReset",
      "guard": "systemNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_SystemResetting",
      "to": "S0_Idle",
      "event": "DeadlockResolutionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:systemCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "detect",
    "resolve",
    "reset",
    "system_visualization"
  ]
}