{
  "meta": {
    "concept": "Support Vector Machine",
    "topic": "Support Vector Machine Visualization",
    "educational_goal": "Demonstrate SVM classification and margin visualization",
    "expected_interactions": [
      "add_point",
      "classify",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderSVM()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddingPoint",
      "label": "AddingPoint",
      "type": "atomic",
      "entry_actions": [
        "capturePointCoordinates()",
        "highlightPointArea()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Classifying",
      "label": "Classifying",
      "type": "atomic",
      "entry_actions": [
        "runSVMClassification()",
        "showClassificationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Visualizing",
      "label": "Visualizing",
      "type": "atomic",
      "entry_actions": [
        "updateVisualization()",
        "animateMargin()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllPoints()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAddPoint",
      "event_type": "user_action",
      "description": "User clicks to add a point"
    },
    {
      "id": "UserClicksClassify",
      "event_type": "user_action",
      "description": "User clicks the Classify button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PointAdded",
      "event_type": "system_event",
      "description": "Point successfully added to the dataset"
    },
    {
      "id": "ClassificationComplete",
      "event_type": "system_event",
      "description": "SVM classification completes successfully"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddingPoint",
      "event": "UserClicksAddPoint",
      "guard": "pointAreaSelected",
      "actions": [
        "capturePoint()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:pointAdded"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddingPoint",
      "to": "S2_Classifying",
      "event": "PointAdded",
      "guard": "pointValid",
      "actions": [
        "validatePoint()",
        "prepareClassification()"
      ],
      "expected_observables": [
        "dom:pointValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Classifying",
      "to": "S4_Visualizing",
      "event": "ClassificationComplete",
      "guard": "classificationSuccessful",
      "actions": [
        "updateSVMModel()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:classificationComplete"
      ],
      "timeout": 3000
    },
    {
      "from": "S1_AddingPoint",
      "to": "S3_ErrorAlert",
      "event": "PointAdded",
      "guard": "pointInvalid",
      "actions": [
        "showError()",
        "focusPointArea()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetPointArea()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Visualizing",
      "to": "S0_Idle",
      "event": "ClassificationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearPointArea()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "pointsExist",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetPointArea()"
      ],
      "expected_observables": [
        "dom:pointsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "point_area",
    "classify",
    "reset",
    "svm_visualization"
  ]
}