{
  "meta": {
    "concept": "Bellman-Ford Algorithm",
    "topic": "Shortest Path Finding in Graphs",
    "educational_goal": "Demonstrate the Bellman-Ford algorithm for finding shortest paths",
    "expected_interactions": [
      "input_graph",
      "run_algorithm",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputGraph",
      "label": "InputGraph",
      "type": "atomic",
      "entry_actions": [
        "readGraphInput()",
        "highlightInputFields()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingGraph",
      "label": "ValidatingGraph",
      "type": "atomic",
      "entry_actions": [
        "validateGraphInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_RunningAlgorithm",
      "label": "RunningAlgorithm",
      "type": "operation",
      "entry_actions": [
        "initializeAlgorithm()",
        "iterateEdges()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingGraph",
      "label": "UpdatingGraph",
      "type": "atomic",
      "entry_actions": [
        "updateGraphVisualization()",
        "animateEdgeRelaxation()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraphData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksRun",
      "event_type": "user_action",
      "description": "User clicks the Run Algorithm button"
    },
    {
      "id": "UserEntersGraphInput",
      "event_type": "user_action",
      "description": "User enters graph data in input fields"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "GraphValidationComplete",
      "event_type": "system_event",
      "description": "Graph input validation completes successfully"
    },
    {
      "id": "GraphValidationFailed",
      "event_type": "system_event",
      "description": "Graph input validation fails"
    },
    {
      "id": "AlgorithmRunComplete",
      "event_type": "system_event",
      "description": "Algorithm execution and graph update complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputGraph",
      "event": "UserEntersGraphInput",
      "guard": "inputFieldsNotEmpty",
      "actions": [
        "captureGraphInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:graphInputCaptured",
        "dom:runButtonEnabled"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputGraph",
      "to": "S2_ValidatingGraph",
      "event": "GraphValidationComplete",
      "guard": "graphInputIsValid",
      "actions": [
        "validateGraphData()",
        "prepareAlgorithmRun()"
      ],
      "expected_observables": [
        "dom:graphValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingGraph",
      "to": "S4_RunningAlgorithm",
      "event": "GraphValidationComplete",
      "guard": "validGraphStructure",
      "actions": [
        "startAlgorithm()",
        "beginEdgeRelaxation()"
      ],
      "expected_observables": [
        "dom:algorithmStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputGraph",
      "to": "S3_ErrorAlert",
      "event": "GraphValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_RunningAlgorithm",
      "to": "S5_UpdatingGraph",
      "event": "AlgorithmRunComplete",
      "guard": "algorithmExecutedSuccessfully",
      "actions": [
        "updateGraphStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:graphStructureUpdated",
        "dom:edgeRelaxationVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingGraph",
      "to": "S0_Idle",
      "event": "AlgorithmRunComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInputFields()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "run_algorithm",
    "reset",
    "graph_visualization"
  ]
}