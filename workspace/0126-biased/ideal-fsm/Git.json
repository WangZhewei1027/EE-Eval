{
  "meta": {
    "concept": "Git",
    "topic": "Git Version Control",
    "educational_goal": "Demonstrate basic Git operations",
    "expected_interactions": [
      "commit",
      "branch",
      "merge",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderRepository()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CommitStart",
      "label": "CommitStart",
      "type": "atomic",
      "entry_actions": [
        "readCommitMessage()",
        "highlightCommitInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCommit",
      "label": "ValidatingCommit",
      "type": "atomic",
      "entry_actions": [
        "validateCommitMessage()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CommittingChanges",
      "label": "CommittingChanges",
      "type": "atomic",
      "entry_actions": [
        "stageChanges()",
        "createCommit()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Branching",
      "label": "Branching",
      "type": "atomic",
      "entry_actions": [
        "createBranch()",
        "updateBranchList()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_Merging",
      "label": "Merging",
      "type": "atomic",
      "entry_actions": [
        "selectBranchesToMerge()",
        "performMerge()"
      ],
      "exit_actions": [
        "resolveConflicts()"
      ]
    },
    {
      "id": "S7_ResettingRepository",
      "label": "ResettingRepository",
      "type": "atomic",
      "entry_actions": [
        "clearChanges()",
        "resetToCommit()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCommit",
      "event_type": "user_action",
      "description": "User clicks the Commit button"
    },
    {
      "id": "UserEntersCommitMessage",
      "event_type": "user_action",
      "description": "User enters commit message in input field"
    },
    {
      "id": "UserClicksBranch",
      "event_type": "user_action",
      "description": "User clicks the Branch button"
    },
    {
      "id": "UserClicksMerge",
      "event_type": "user_action",
      "description": "User clicks the Merge button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CommitValidationComplete",
      "event_type": "system_event",
      "description": "Commit message validation completes successfully"
    },
    {
      "id": "CommitValidationFailed",
      "event_type": "system_event",
      "description": "Commit message validation fails"
    },
    {
      "id": "CommitComplete",
      "event_type": "system_event",
      "description": "Commit operation complete"
    },
    {
      "id": "BranchCreationComplete",
      "event_type": "system_event",
      "description": "Branch creation complete"
    },
    {
      "id": "MergeComplete",
      "event_type": "system_event",
      "description": "Merge operation complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Repository reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CommitStart",
      "event": "UserClicksCommit",
      "guard": "changesStaged",
      "actions": [
        "captureCommitMessage()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readCommitMessage",
        "dom:commitButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CommitStart",
      "to": "S2_ValidatingCommit",
      "event": "CommitValidationComplete",
      "guard": "messageIsValid",
      "actions": [
        "validateMessage()",
        "prepareCommit()"
      ],
      "expected_observables": [
        "dom:commitMessageValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingCommit",
      "to": "S4_CommittingChanges",
      "event": "CommitValidationComplete",
      "guard": "validMessage",
      "actions": [
        "parseCommitMessage()",
        "beginCommit()"
      ],
      "expected_observables": [
        "dom:commitCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CommitStart",
      "to": "S3_ErrorAlert",
      "event": "CommitValidationFailed",
      "guard": "messageIsEmpty",
      "actions": [
        "showError()",
        "focusCommitInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetCommitInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CommittingChanges",
      "to": "S0_Idle",
      "event": "CommitComplete",
      "guard": "commitSuccessful",
      "actions": [
        "updateRepository()",
        "clearCommitInput()"
      ],
      "expected_observables": [
        "dom:repositoryUpdated",
        "dom:commitComplete"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Branching",
      "event": "UserClicksBranch",
      "guard": "true",
      "actions": [
        "captureBranchName()",
        "createBranch()"
      ],
      "expected_observables": [
        "dom:branchButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_Branching",
      "to": "S0_Idle",
      "event": "BranchCreationComplete",
      "guard": "branchCreatedSuccessfully",
      "actions": [
        "updateBranchList()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:branchListUpdated"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Merging",
      "event": "UserClicksMerge",
      "guard": "branchesSelected",
      "actions": [
        "selectBranches()",
        "performMerge()"
      ],
      "expected_observables": [
        "dom:mergeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S6_Merging",
      "to": "S0_Idle",
      "event": "MergeComplete",
      "guard": "mergeSuccessful",
      "actions": [
        "resolveConflicts()",
        "updateRepository()"
      ],
      "expected_observables": [
        "dom:repositoryUpdated",
        "dom:mergeComplete"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S7_ResettingRepository",
      "event": "UserClicksReset",
      "guard": "repositoryNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_ResettingRepository",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetRepositoryView()"
      ],
      "expected_observables": [
        "dom:repositoryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "commit_input",
    "commit",
    "branch",
    "merge",
    "reset",
    "repository_visualization"
  ]
}