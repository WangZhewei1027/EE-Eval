{
  "meta": {
    "concept": "IntegrationTesting",
    "topic": "Integration Testing Process",
    "educational_goal": "Demonstrate integration testing steps and execution",
    "expected_interactions": [
      "selectModules",
      "configureTest",
      "runTest",
      "viewResults",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SelectingModules",
      "label": "SelectingModules",
      "type": "atomic",
      "entry_actions": [
        "highlightModuleSelection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ConfiguringTest",
      "label": "ConfiguringTest",
      "type": "atomic",
      "entry_actions": [
        "displayConfigurationOptions()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_RunningTest",
      "label": "RunningTest",
      "type": "operation",
      "entry_actions": [
        "executeTestSuite()",
        "showProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_ViewingResults",
      "label": "ViewingResults",
      "type": "atomic",
      "entry_actions": [
        "displayTestResults()"
      ],
      "exit_actions": [
        "clearResultsDisplay()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllSelections()",
        "resetInterface()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsModules",
      "event_type": "user_action",
      "description": "User selects modules for testing"
    },
    {
      "id": "UserConfiguresTest",
      "event_type": "user_action",
      "description": "User configures test parameters"
    },
    {
      "id": "UserRunsTest",
      "event_type": "user_action",
      "description": "User initiates the test run"
    },
    {
      "id": "TestExecutionComplete",
      "event_type": "system_event",
      "description": "Test execution completes"
    },
    {
      "id": "UserViewsResults",
      "event_type": "user_action",
      "description": "User views the test results"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SelectingModules",
      "event": "UserSelectsModules",
      "guard": "modulesAvailable",
      "actions": [
        "captureModuleSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:modulesSelected"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SelectingModules",
      "to": "S2_ConfiguringTest",
      "event": "UserConfiguresTest",
      "guard": "validConfiguration",
      "actions": [
        "applyConfiguration()",
        "prepareTestRun()"
      ],
      "expected_observables": [
        "dom:configurationApplied"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ConfiguringTest",
      "to": "S3_RunningTest",
      "event": "UserRunsTest",
      "guard": "configurationComplete",
      "actions": [
        "startTestExecution()"
      ],
      "expected_observables": [
        "dom:testRunning"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_RunningTest",
      "to": "S4_ViewingResults",
      "event": "TestExecutionComplete",
      "guard": "testSuccessful",
      "actions": [
        "fetchResults()",
        "displayResults()"
      ],
      "expected_observables": [
        "dom:resultsDisplayed"
      ],
      "timeout": 2000
    },
    {
      "from": "S4_ViewingResults",
      "to": "S0_Idle",
      "event": "UserViewsResults",
      "guard": "resultsViewed",
      "actions": [
        "clearResults()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:resultsCleared"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "testConfigured",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetSelections()"
      ],
      "expected_observables": [
        "dom:interfaceReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "module_selector",
    "configuration_panel",
    "run_button",
    "results_display",
    "reset_button"
  ]
}