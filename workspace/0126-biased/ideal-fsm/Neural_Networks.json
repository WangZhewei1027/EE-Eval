{
  "meta": {
    "concept": "Neural Networks",
    "topic": "Neural Network Visualization",
    "educational_goal": "Demonstrate neural network training and inference",
    "expected_interactions": [
      "train",
      "infer",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderNetwork()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_TrainingStart",
      "label": "TrainingStart",
      "type": "atomic",
      "entry_actions": [
        "readTrainingData()",
        "highlightTrainingInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingData",
      "label": "ValidatingData",
      "type": "atomic",
      "entry_actions": [
        "validateData()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_TrainingNetwork",
      "label": "TrainingNetwork",
      "type": "atomic",
      "entry_actions": [
        "initializeTraining()",
        "updateWeights()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_VisualizingTraining",
      "label": "VisualizingTraining",
      "type": "atomic",
      "entry_actions": [
        "updateNetworkVisualization()",
        "animateTrainingProgress()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_NetworkResetting",
      "label": "NetworkResetting",
      "type": "atomic",
      "entry_actions": [
        "clearNetworkState()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksTrain",
      "event_type": "user_action",
      "description": "User clicks the Train button"
    },
    {
      "id": "UserEntersTrainingData",
      "event_type": "user_action",
      "description": "User enters training data in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DataValidationComplete",
      "event_type": "system_event",
      "description": "Training data validation completes successfully"
    },
    {
      "id": "DataValidationFailed",
      "event_type": "system_event",
      "description": "Training data validation fails"
    },
    {
      "id": "TrainingComplete",
      "event_type": "system_event",
      "description": "Network training and update complete"
    },
    {
      "id": "NetworkResetComplete",
      "event_type": "system_event",
      "description": "Network reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_TrainingStart",
      "event": "UserClicksTrain",
      "guard": "dataNotEmpty",
      "actions": [
        "captureTrainingData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readTrainingData",
        "dom:trainButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_TrainingStart",
      "to": "S2_ValidatingData",
      "event": "DataValidationComplete",
      "guard": "dataIsValid",
      "actions": [
        "validateTrainingData()",
        "prepareTraining()"
      ],
      "expected_observables": [
        "dom:dataValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingData",
      "to": "S4_TrainingNetwork",
      "event": "DataValidationComplete",
      "guard": "validDataFormat",
      "actions": [
        "parseTrainingData()",
        "beginTraining()"
      ],
      "expected_observables": [
        "dom:trainingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_TrainingStart",
      "to": "S3_ErrorAlert",
      "event": "DataValidationFailed",
      "guard": "dataIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_TrainingNetwork",
      "to": "S5_VisualizingTraining",
      "event": "TrainingComplete",
      "guard": "trainingSuccessful",
      "actions": [
        "updateNetworkStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:networkStructureChanged",
        "dom:trainingProgressVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_VisualizingTraining",
      "to": "S0_Idle",
      "event": "TrainingComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_NetworkResetting",
      "event": "UserClicksReset",
      "guard": "networkNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_NetworkResetting",
      "to": "S0_Idle",
      "event": "NetworkResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:networkCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "train",
    "reset",
    "network_visualization"
  ]
}