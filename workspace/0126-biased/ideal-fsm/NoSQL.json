{
  "meta": {
    "concept": "NoSQL",
    "topic": "NoSQL Database Operations",
    "educational_goal": "Demonstrate basic NoSQL operations like insert, query, and delete",
    "expected_interactions": [
      "insert",
      "query",
      "delete",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderDatabase()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InsertStart",
      "label": "InsertStart",
      "type": "atomic",
      "entry_actions": [
        "readInputData()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInputData()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_InsertingData",
      "label": "InsertingData",
      "type": "atomic",
      "entry_actions": [
        "prepareDataInsertion()",
        "executeInsert()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_QueryingData",
      "label": "QueryingData",
      "type": "atomic",
      "entry_actions": [
        "prepareQuery()",
        "executeQuery()"
      ],
      "exit_actions": [
        "showQueryResults()"
      ]
    },
    {
      "id": "S6_DeletingData",
      "label": "DeletingData",
      "type": "atomic",
      "entry_actions": [
        "prepareDeletion()",
        "executeDelete()"
      ],
      "exit_actions": []
    },
    {
      "id": "S7_ResettingDatabase",
      "label": "ResettingDatabase",
      "type": "atomic",
      "entry_actions": [
        "clearDatabase()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInsert",
      "event_type": "user_action",
      "description": "User clicks the Insert button"
    },
    {
      "id": "UserClicksQuery",
      "event_type": "user_action",
      "description": "User clicks the Query button"
    },
    {
      "id": "UserClicksDelete",
      "event_type": "user_action",
      "description": "User clicks the Delete button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "DataInsertionComplete",
      "event_type": "system_event",
      "description": "Data insertion complete"
    },
    {
      "id": "QueryExecutionComplete",
      "event_type": "system_event",
      "description": "Query execution complete"
    },
    {
      "id": "DataDeletionComplete",
      "event_type": "system_event",
      "description": "Data deletion complete"
    },
    {
      "id": "DatabaseResetComplete",
      "event_type": "system_event",
      "description": "Database reset complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InsertStart",
      "event": "UserClicksInsert",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInputData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputData",
        "dom:insertButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InsertStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateData()",
        "prepareDataInsertion()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_InsertingData",
      "event": "InputValidationComplete",
      "guard": "validData",
      "actions": [
        "parseInputData()",
        "beginDataInsertion()"
      ],
      "expected_observables": [
        "dom:dataInsertionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InsertStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_InsertingData",
      "to": "S0_Idle",
      "event": "DataInsertionComplete",
      "guard": "dataInsertedSuccessfully",
      "actions": [
        "updateDatabase()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:dataInserted",
        "dom:visualizationUpdated"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S5_QueryingData",
      "event": "UserClicksQuery",
      "guard": "queryNotEmpty",
      "actions": [
        "captureQuery()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:queryButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_QueryingData",
      "to": "S0_Idle",
      "event": "QueryExecutionComplete",
      "guard": "queryExecutedSuccessfully",
      "actions": [
        "showQueryResults()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:queryResultsDisplayed"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S6_DeletingData",
      "event": "UserClicksDelete",
      "guard": "dataExists",
      "actions": [
        "confirmDeletion()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:deleteButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S6_DeletingData",
      "to": "S0_Idle",
      "event": "DataDeletionComplete",
      "guard": "dataDeletedSuccessfully",
      "actions": [
        "updateDatabase()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:dataDeleted",
        "dom:visualizationUpdated"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S7_ResettingDatabase",
      "event": "UserClicksReset",
      "guard": "databaseNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_ResettingDatabase",
      "to": "S0_Idle",
      "event": "DatabaseResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:databaseCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "insert",
    "query",
    "delete",
    "reset",
    "database_visualization"
  ]
}