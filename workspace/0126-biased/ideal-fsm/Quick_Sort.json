{
  "meta": {
    "concept": "QuickSort",
    "topic": "Quick Sort Algorithm Visualization",
    "educational_goal": "Demonstrate the Quick Sort algorithm process",
    "expected_interactions": [
      "start_sort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SortStart",
      "label": "SortStart",
      "type": "atomic",
      "entry_actions": [
        "readArrayInput()",
        "highlightArray()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Partitioning",
      "label": "Partitioning",
      "type": "operation",
      "entry_actions": [
        "selectPivot()",
        "partitionArray()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_SortingSubarrays",
      "label": "SortingSubarrays",
      "type": "operation",
      "entry_actions": [
        "sortLeftSubarray()",
        "sortRightSubarray()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_DrawingSortedArray",
      "label": "DrawingSortedArray",
      "type": "atomic",
      "entry_actions": [
        "updateArrayVisualization()",
        "animateSorting()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ArrayResetting",
      "label": "ArrayResetting",
      "type": "atomic",
      "entry_actions": [
        "clearArray()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStartSort",
      "event_type": "user_action",
      "description": "User clicks the Start Sort button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PartitionComplete",
      "event_type": "system_event",
      "description": "Partitioning of array complete"
    },
    {
      "id": "SubarraySortComplete",
      "event_type": "system_event",
      "description": "Sorting of subarrays complete"
    },
    {
      "id": "ArrayResetComplete",
      "event_type": "system_event",
      "description": "Array reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SortStart",
      "event": "UserClicksStartSort",
      "guard": "arrayNotEmpty",
      "actions": [
        "captureArrayInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startSortButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SortStart",
      "to": "S2_Partitioning",
      "event": "PartitionComplete",
      "guard": "pivotSelected",
      "actions": [
        "performPartition()",
        "highlightPivot()"
      ],
      "expected_observables": [
        "dom:pivotHighlighted"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_Partitioning",
      "to": "S3_SortingSubarrays",
      "event": "SubarraySortComplete",
      "guard": "subarraysReady",
      "actions": [
        "sortSubarrays()",
        "updateVisualization()"
      ],
      "expected_observables": [
        "dom:subarraysSorted"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_SortingSubarrays",
      "to": "S4_DrawingSortedArray",
      "event": "SubarraySortComplete",
      "guard": "sortingComplete",
      "actions": [
        "finalizeSort()",
        "triggerFinalVisualization()"
      ],
      "expected_observables": [
        "dom:arraySorted"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_DrawingSortedArray",
      "to": "S0_Idle",
      "event": "SubarraySortComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ArrayResetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ArrayResetting",
      "to": "S0_Idle",
      "event": "ArrayResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "start_sort",
    "reset",
    "array_visualization"
  ]
}