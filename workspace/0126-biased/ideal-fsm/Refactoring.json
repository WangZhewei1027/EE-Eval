{
  "meta": {
    "concept": "Refactoring",
    "topic": "Code Refactoring Process",
    "educational_goal": "Teach the steps and benefits of code refactoring",
    "expected_interactions": [
      "select_code",
      "apply_refactor",
      "review_changes",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderCode()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SelectingCode",
      "label": "SelectingCode",
      "type": "atomic",
      "entry_actions": [
        "highlightCodeSection()",
        "showSelectionOptions()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ApplyingRefactor",
      "label": "ApplyingRefactor",
      "type": "atomic",
      "entry_actions": [
        "applyRefactor()",
        "showRefactorFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ReviewingChanges",
      "label": "ReviewingChanges",
      "type": "atomic",
      "entry_actions": [
        "displayChanges()",
        "highlightDifferences()"
      ],
      "exit_actions": [
        "clearDifferences()"
      ]
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllChanges()",
        "resetCodeView()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsCode",
      "event_type": "user_action",
      "description": "User selects a section of code"
    },
    {
      "id": "UserClicksRefactor",
      "event_type": "user_action",
      "description": "User clicks the Refactor button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "RefactorApplied",
      "event_type": "system_event",
      "description": "Refactor operation completes successfully"
    },
    {
      "id": "RefactorFailed",
      "event_type": "system_event",
      "description": "Refactor operation fails"
    },
    {
      "id": "ChangesReviewed",
      "event_type": "system_event",
      "description": "User reviews the changes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SelectingCode",
      "event": "UserSelectsCode",
      "guard": "codeSectionSelected",
      "actions": [
        "captureSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:codeSectionHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SelectingCode",
      "to": "S2_ApplyingRefactor",
      "event": "UserClicksRefactor",
      "guard": "selectionValid",
      "actions": [
        "validateSelection()",
        "executeRefactor()"
      ],
      "expected_observables": [
        "dom:refactorButtonClicked"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ApplyingRefactor",
      "to": "S3_ReviewingChanges",
      "event": "RefactorApplied",
      "guard": "refactorSuccess",
      "actions": [
        "updateCodeView()",
        "showChanges()"
      ],
      "expected_observables": [
        "dom:codeUpdated"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_ApplyingRefactor",
      "to": "S4_ErrorAlert",
      "event": "RefactorFailed",
      "guard": "refactorError",
      "actions": [
        "showError()",
        "focusCode()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S3_ReviewingChanges",
      "to": "S0_Idle",
      "event": "ChangesReviewed",
      "guard": "reviewComplete",
      "actions": [
        "enableControls()",
        "clearSelection()"
      ],
      "expected_observables": [
        "dom:reviewComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "changesMade",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetCodeView()"
      ],
      "expected_observables": [
        "dom:codeReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "code_view",
    "refactor",
    "reset",
    "change_visualization"
  ]
}