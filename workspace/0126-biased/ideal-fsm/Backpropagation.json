{
  "meta": {
    "concept": "Backpropagation",
    "topic": "Neural Network Training",
    "educational_goal": "Demonstrate the process of backpropagation in neural networks",
    "expected_interactions": [
      "initialize",
      "forward_pass",
      "backward_pass",
      "update_weights",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderNetwork()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_Initialize",
      "label": "Initialize",
      "type": "atomic",
      "entry_actions": [
        "initializeNetwork()",
        "showInitializationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S2_ForwardPass",
      "label": "ForwardPass",
      "type": "atomic",
      "entry_actions": [
        "performForwardPass()",
        "displayForwardResults()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_BackwardPass",
      "label": "BackwardPass",
      "type": "atomic",
      "entry_actions": [
        "performBackwardPass()",
        "displayBackwardResults()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_UpdateWeights",
      "label": "UpdateWeights",
      "type": "atomic",
      "entry_actions": [
        "updateWeights()",
        "showWeightUpdateFeedback()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "resetNetwork()",
        "clearVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInitialize",
      "event_type": "user_action",
      "description": "User clicks the Initialize button"
    },
    {
      "id": "UserClicksForwardPass",
      "event_type": "user_action",
      "description": "User clicks the Forward Pass button"
    },
    {
      "id": "UserClicksBackwardPass",
      "event_type": "user_action",
      "description": "User clicks the Backward Pass button"
    },
    {
      "id": "UserClicksUpdateWeights",
      "event_type": "user_action",
      "description": "User clicks the Update Weights button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InitializationComplete",
      "event_type": "system_event",
      "description": "Network initialization completes"
    },
    {
      "id": "ForwardPassComplete",
      "event_type": "system_event",
      "description": "Forward pass completes"
    },
    {
      "id": "BackwardPassComplete",
      "event_type": "system_event",
      "description": "Backward pass completes"
    },
    {
      "id": "WeightUpdateComplete",
      "event_type": "system_event",
      "description": "Weights update completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Network reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_Initialize",
      "event": "UserClicksInitialize",
      "guard": "true",
      "actions": [
        "disableControls()",
        "startInitialization()"
      ],
      "expected_observables": [
        "dom:initializeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_Initialize",
      "to": "S2_ForwardPass",
      "event": "InitializationComplete",
      "guard": "true",
      "actions": [
        "enableForwardPass()"
      ],
      "expected_observables": [
        "dom:networkInitialized"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ForwardPass",
      "to": "S3_BackwardPass",
      "event": "ForwardPassComplete",
      "guard": "true",
      "actions": [
        "enableBackwardPass()"
      ],
      "expected_observables": [
        "dom:forwardPassComplete"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_BackwardPass",
      "to": "S4_UpdateWeights",
      "event": "BackwardPassComplete",
      "guard": "true",
      "actions": [
        "enableWeightUpdate()"
      ],
      "expected_observables": [
        "dom:backwardPassComplete"
      ],
      "timeout": 1500
    },
    {
      "from": "S4_UpdateWeights",
      "to": "S0_Idle",
      "event": "WeightUpdateComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:weightsUpdated"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "networkNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:networkCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "initialize",
    "forward_pass",
    "backward_pass",
    "update_weights",
    "reset",
    "network_visualization"
  ]
}