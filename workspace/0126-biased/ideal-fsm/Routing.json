{
  "meta": {
    "concept": "Routing",
    "topic": "Network Routing Visualization",
    "educational_goal": "Demonstrate packet routing and pathfinding",
    "expected_interactions": [
      "add_node",
      "add_link",
      "send_packet",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderNetwork()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddingNode",
      "label": "AddingNode",
      "type": "atomic",
      "entry_actions": [
        "highlightNodeInput()",
        "readNodeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_AddingLink",
      "label": "AddingLink",
      "type": "atomic",
      "entry_actions": [
        "highlightLinkInput()",
        "readLinkInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_SendingPacket",
      "label": "SendingPacket",
      "type": "atomic",
      "entry_actions": [
        "highlightPacketInput()",
        "readPacketInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_UpdatingNetwork",
      "label": "UpdatingNetwork",
      "type": "atomic",
      "entry_actions": [
        "updateNetworkVisualization()",
        "animateUpdate()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_NetworkResetting",
      "label": "NetworkResetting",
      "type": "atomic",
      "entry_actions": [
        "clearNetwork()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAddNode",
      "event_type": "user_action",
      "description": "User clicks the Add Node button"
    },
    {
      "id": "UserClicksAddLink",
      "event_type": "user_action",
      "description": "User clicks the Add Link button"
    },
    {
      "id": "UserClicksSendPacket",
      "event_type": "user_action",
      "description": "User clicks the Send Packet button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "NodeAdditionComplete",
      "event_type": "system_event",
      "description": "Node addition and network update complete"
    },
    {
      "id": "LinkAdditionComplete",
      "event_type": "system_event",
      "description": "Link addition and network update complete"
    },
    {
      "id": "PacketSentComplete",
      "event_type": "system_event",
      "description": "Packet sent and pathfinding complete"
    },
    {
      "id": "NetworkResetComplete",
      "event_type": "system_event",
      "description": "Network reset operation complete"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddingNode",
      "event": "UserClicksAddNode",
      "guard": "inputNotEmpty",
      "actions": [
        "captureNodeInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readNodeInput",
        "dom:addNodeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S0_Idle",
      "to": "S2_AddingLink",
      "event": "UserClicksAddLink",
      "guard": "inputNotEmpty",
      "actions": [
        "captureLinkInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readLinkInput",
        "dom:addLinkButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S0_Idle",
      "to": "S3_SendingPacket",
      "event": "UserClicksSendPacket",
      "guard": "inputNotEmpty",
      "actions": [
        "capturePacketInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readPacketInput",
        "dom:sendPacketButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddingNode",
      "to": "S5_UpdatingNetwork",
      "event": "NodeAdditionComplete",
      "guard": "nodeAddedSuccessfully",
      "actions": [
        "updateNetworkStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:networkStructureChanged",
        "dom:newNodeVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S2_AddingLink",
      "to": "S5_UpdatingNetwork",
      "event": "LinkAdditionComplete",
      "guard": "linkAddedSuccessfully",
      "actions": [
        "updateNetworkStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:networkStructureChanged",
        "dom:newLinkVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_SendingPacket",
      "to": "S5_UpdatingNetwork",
      "event": "PacketSentComplete",
      "guard": "packetSentSuccessfully",
      "actions": [
        "updateNetworkStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:pathFound",
        "dom:packetVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S1_AddingNode",
      "to": "S4_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_AddingLink",
      "to": "S4_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_SendingPacket",
      "to": "S4_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S5_UpdatingNetwork",
      "to": "S0_Idle",
      "event": "NodeAdditionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S5_UpdatingNetwork",
      "to": "S0_Idle",
      "event": "LinkAdditionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S5_UpdatingNetwork",
      "to": "S0_Idle",
      "event": "PacketSentComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_NetworkResetting",
      "event": "UserClicksReset",
      "guard": "networkNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_NetworkResetting",
      "to": "S0_Idle",
      "event": "NetworkResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:networkCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "node_input",
    "link_input",
    "packet_input",
    "add_node",
    "add_link",
    "send_packet",
    "reset",
    "network_visualization"
  ]
}