{
  "meta": {
    "concept": "Query Optimization",
    "topic": "SQL Query Optimization Visualization",
    "educational_goal": "Demonstrate optimization techniques for SQL queries",
    "expected_interactions": [
      "input_query",
      "optimize",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderQueryArea()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputQuery",
      "label": "InputQuery",
      "type": "atomic",
      "entry_actions": [
        "readQueryInput()",
        "highlightQueryInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingQuery",
      "label": "ValidatingQuery",
      "type": "atomic",
      "entry_actions": [
        "validateQuery()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_OptimizingQuery",
      "label": "OptimizingQuery",
      "type": "atomic",
      "entry_actions": [
        "applyOptimizationTechniques()",
        "generateOptimizedPlan()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ShowingOptimizedQuery",
      "label": "ShowingOptimizedQuery",
      "type": "atomic",
      "entry_actions": [
        "updateQueryVisualization()",
        "displayOptimizedQuery()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingQuery",
      "label": "ResettingQuery",
      "type": "atomic",
      "entry_actions": [
        "clearQueryInput()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsQuery",
      "event_type": "user_action",
      "description": "User inputs SQL query in the input field"
    },
    {
      "id": "UserClicksOptimize",
      "event_type": "user_action",
      "description": "User clicks the Optimize button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "QueryValidationComplete",
      "event_type": "system_event",
      "description": "Query validation completes successfully"
    },
    {
      "id": "QueryValidationFailed",
      "event_type": "system_event",
      "description": "Query validation fails"
    },
    {
      "id": "OptimizationComplete",
      "event_type": "system_event",
      "description": "Query optimization and visualization update complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Query reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputQuery",
      "event": "UserInputsQuery",
      "guard": "queryNotEmpty",
      "actions": [
        "captureQueryInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readQueryInput",
        "dom:queryInputFieldFocused"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputQuery",
      "to": "S2_ValidatingQuery",
      "event": "QueryValidationComplete",
      "guard": "queryIsValid",
      "actions": [
        "validateQuerySyntax()",
        "prepareOptimization()"
      ],
      "expected_observables": [
        "dom:queryValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingQuery",
      "to": "S4_OptimizingQuery",
      "event": "QueryValidationComplete",
      "guard": "validSQL",
      "actions": [
        "parseQueryInput()",
        "beginOptimization()"
      ],
      "expected_observables": [
        "dom:optimizationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputQuery",
      "to": "S3_ErrorAlert",
      "event": "QueryValidationFailed",
      "guard": "queryIsEmpty",
      "actions": [
        "showError()",
        "focusQueryInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetQueryInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_OptimizingQuery",
      "to": "S5_ShowingOptimizedQuery",
      "event": "OptimizationComplete",
      "guard": "optimizationSuccessful",
      "actions": [
        "updateQueryVisualization()",
        "displayOptimizedQuery()"
      ],
      "expected_observables": [
        "dom:queryVisualizationUpdated",
        "dom:optimizedQueryVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ShowingOptimizedQuery",
      "to": "S0_Idle",
      "event": "OptimizationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearQueryInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingQuery",
      "event": "UserClicksReset",
      "guard": "queryNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingQuery",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetQueryInputField()"
      ],
      "expected_observables": [
        "dom:queryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "query_input",
    "optimize",
    "reset",
    "query_visualization"
  ]
}