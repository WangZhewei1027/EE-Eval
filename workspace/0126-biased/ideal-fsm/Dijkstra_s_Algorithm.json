{
  "meta": {
    "concept": "Dijkstra's Algorithm",
    "topic": "Shortest Path Visualization",
    "educational_goal": "Demonstrate finding shortest paths using Dijkstra's algorithm",
    "expected_interactions": [
      "set_start",
      "set_end",
      "calculate",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SettingStartNode",
      "label": "SettingStartNode",
      "type": "atomic",
      "entry_actions": [
        "highlightStartNodeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_SettingEndNode",
      "label": "SettingEndNode",
      "type": "atomic",
      "entry_actions": [
        "highlightEndNodeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_CalculatingPath",
      "label": "CalculatingPath",
      "type": "operation",
      "entry_actions": [
        "runDijkstraAlgorithm()",
        "showCalculationProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_DisplayShortestPath",
      "label": "DisplayShortestPath",
      "type": "atomic",
      "entry_actions": [
        "updatePathVisualization()",
        "highlightShortestPath()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraph()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSetsStartNode",
      "event_type": "user_action",
      "description": "User sets the start node"
    },
    {
      "id": "UserSetsEndNode",
      "event_type": "user_action",
      "description": "User sets the end node"
    },
    {
      "id": "UserClicksCalculate",
      "event_type": "user_action",
      "description": "User clicks the Calculate button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PathCalculationComplete",
      "event_type": "system_event",
      "description": "Path calculation completes successfully"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SettingStartNode",
      "event": "UserSetsStartNode",
      "guard": "startNodeSelected",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startNodeInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SettingStartNode",
      "to": "S2_SettingEndNode",
      "event": "UserSetsEndNode",
      "guard": "endNodeSelected",
      "actions": [
        "captureEndNode()",
        "prepareCalculation()"
      ],
      "expected_observables": [
        "dom:endNodeInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_SettingEndNode",
      "to": "S3_CalculatingPath",
      "event": "UserClicksCalculate",
      "guard": "nodesValid",
      "actions": [
        "beginPathCalculation()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:calculationStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_CalculatingPath",
      "to": "S4_DisplayShortestPath",
      "event": "PathCalculationComplete",
      "guard": "pathFound",
      "actions": [
        "displayShortestPath()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:pathDisplayed",
        "dom:shortestPathHighlighted"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start_node_input",
    "end_node_input",
    "calculate",
    "reset",
    "graph_visualization"
  ]
}