{
  "meta": {
    "concept": "RuntimeEnvironment",
    "topic": "Understanding Runtime Environments",
    "educational_goal": "Explain the components and behavior of a runtime environment",
    "expected_interactions": [
      "configure",
      "execute",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderEnvironment()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_Configuring",
      "label": "Configuring",
      "type": "atomic",
      "entry_actions": [
        "readConfigurationInput()",
        "highlightConfiguration()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingConfiguration",
      "label": "ValidatingConfiguration",
      "type": "atomic",
      "entry_actions": [
        "validateConfiguration()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Executing",
      "label": "Executing",
      "type": "atomic",
      "entry_actions": [
        "executeProgram()",
        "monitorExecution()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ExecutionComplete",
      "label": "ExecutionComplete",
      "type": "atomic",
      "entry_actions": [
        "showExecutionResults()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_EnvironmentResetting",
      "label": "EnvironmentResetting",
      "type": "atomic",
      "entry_actions": [
        "clearConfiguration()",
        "resetEnvironment()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksConfigure",
      "event_type": "user_action",
      "description": "User clicks the Configure button"
    },
    {
      "id": "UserEntersConfiguration",
      "event_type": "user_action",
      "description": "User enters configuration settings"
    },
    {
      "id": "UserClicksExecute",
      "event_type": "user_action",
      "description": "User clicks the Execute button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ConfigurationValidationComplete",
      "event_type": "system_event",
      "description": "Configuration validation completes successfully"
    },
    {
      "id": "ConfigurationValidationFailed",
      "event_type": "system_event",
      "description": "Configuration validation fails"
    },
    {
      "id": "ExecutionComplete",
      "event_type": "system_event",
      "description": "Program execution completes"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_Configuring",
      "event": "UserClicksConfigure",
      "guard": "configurationInputNotEmpty",
      "actions": [
        "captureConfigurationInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readConfigurationInput",
        "dom:configureButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_Configuring",
      "to": "S2_ValidatingConfiguration",
      "event": "ConfigurationValidationComplete",
      "guard": "configurationIsValid",
      "actions": [
        "validateConfigurationSettings()",
        "prepareExecution()"
      ],
      "expected_observables": [
        "dom:configurationValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingConfiguration",
      "to": "S4_Executing",
      "event": "ConfigurationValidationComplete",
      "guard": "validConfiguration",
      "actions": [
        "parseConfigurationSettings()",
        "beginExecution()"
      ],
      "expected_observables": [
        "dom:executionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_Configuring",
      "to": "S3_ErrorAlert",
      "event": "ConfigurationValidationFailed",
      "guard": "configurationIsInvalid",
      "actions": [
        "showError()",
        "focusConfigurationInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetConfigurationInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Executing",
      "to": "S5_ExecutionComplete",
      "event": "ExecutionComplete",
      "guard": "executionSuccessful",
      "actions": [
        "updateExecutionResults()",
        "triggerResultDisplay()"
      ],
      "expected_observables": [
        "dom:executionResultsDisplayed"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ExecutionComplete",
      "to": "S0_Idle",
      "event": "ExecutionComplete",
      "guard": "resultsDisplayed",
      "actions": [
        "enableControls()",
        "clearConfigurationInput()"
      ],
      "expected_observables": [
        "dom:resultsDisplayComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_EnvironmentResetting",
      "event": "UserClicksReset",
      "guard": "environmentConfigured",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_EnvironmentResetting",
      "to": "S0_Idle",
      "event": "ExecutionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetConfigurationInputField()"
      ],
      "expected_observables": [
        "dom:environmentCleared",
        "dom:environmentReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "configuration_input",
    "configure",
    "execute",
    "reset",
    "execution_visualization"
  ]
}