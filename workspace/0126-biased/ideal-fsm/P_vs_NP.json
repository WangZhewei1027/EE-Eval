{
  "meta": {
    "concept": "P vs NP",
    "topic": "Complexity Theory",
    "educational_goal": "Explore the distinction between P and NP problems",
    "expected_interactions": [
      "classify",
      "compare",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderProblemList()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_ClassifyingProblem",
      "label": "ClassifyingProblem",
      "type": "atomic",
      "entry_actions": [
        "readProblemSelection()",
        "highlightSelection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ComparingComplexity",
      "label": "ComparingComplexity",
      "type": "atomic",
      "entry_actions": [
        "compareComplexity()",
        "showComparisonFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearSelections()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsProblem",
      "event_type": "user_action",
      "description": "User selects a problem from the list"
    },
    {
      "id": "UserClicksCompare",
      "event_type": "user_action",
      "description": "User clicks the Compare button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ClassificationComplete",
      "event_type": "system_event",
      "description": "Problem classification completes successfully"
    },
    {
      "id": "ClassificationFailed",
      "event_type": "system_event",
      "description": "Problem classification fails"
    },
    {
      "id": "ComparisonComplete",
      "event_type": "system_event",
      "description": "Complexity comparison complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_ClassifyingProblem",
      "event": "UserSelectsProblem",
      "guard": "selectionNotEmpty",
      "actions": [
        "captureSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:problemSelected"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_ClassifyingProblem",
      "to": "S2_ComparingComplexity",
      "event": "ClassificationComplete",
      "guard": "classificationIsValid",
      "actions": [
        "validateClassification()",
        "prepareComparison()"
      ],
      "expected_observables": [
        "dom:classificationValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_ClassifyingProblem",
      "to": "S3_ErrorAlert",
      "event": "ClassificationFailed",
      "guard": "selectionIsEmpty",
      "actions": [
        "showError()",
        "focusSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S2_ComparingComplexity",
      "to": "S0_Idle",
      "event": "ComparisonComplete",
      "guard": "comparisonSuccessful",
      "actions": [
        "enableControls()",
        "clearSelection()"
      ],
      "expected_observables": [
        "dom:comparisonComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "selectionNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetSelectionField()"
      ],
      "expected_observables": [
        "dom:selectionsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "problem_list",
    "compare",
    "reset",
    "visualization_area"
  ]
}