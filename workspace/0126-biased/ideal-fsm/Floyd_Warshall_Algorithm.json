{
  "meta": {
    "concept": "Floyd-Warshall Algorithm",
    "topic": "Floyd-Warshall Algorithm Visualization",
    "educational_goal": "Demonstrate all-pairs shortest path computation",
    "expected_interactions": [
      "inputGraph",
      "computePaths",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputGraph",
      "label": "InputGraph",
      "type": "atomic",
      "entry_actions": [
        "readGraphInput()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingGraph",
      "label": "ValidatingGraph",
      "type": "atomic",
      "entry_actions": [
        "validateGraphInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ComputingPaths",
      "label": "ComputingPaths",
      "type": "operation",
      "entry_actions": [
        "initializeAlgorithm()",
        "computeShortestPaths()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingPaths",
      "label": "DrawingPaths",
      "type": "atomic",
      "entry_actions": [
        "updatePathVisualization()",
        "animatePathUpdates()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraphData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsGraph",
      "event_type": "user_action",
      "description": "User inputs graph data"
    },
    {
      "id": "UserClicksCompute",
      "event_type": "user_action",
      "description": "User clicks the Compute button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "GraphValidationComplete",
      "event_type": "system_event",
      "description": "Graph validation completes successfully"
    },
    {
      "id": "GraphValidationFailed",
      "event_type": "system_event",
      "description": "Graph validation fails"
    },
    {
      "id": "PathComputationComplete",
      "event_type": "system_event",
      "description": "Path computation and visualization update complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputGraph",
      "event": "UserInputsGraph",
      "guard": "inputNotEmpty",
      "actions": [
        "captureGraphInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:graphInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputGraph",
      "to": "S2_ValidatingGraph",
      "event": "GraphValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateGraphData()",
        "prepareComputation()"
      ],
      "expected_observables": [
        "dom:graphValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingGraph",
      "to": "S4_ComputingPaths",
      "event": "GraphValidationComplete",
      "guard": "validGraphStructure",
      "actions": [
        "parseGraphData()",
        "beginComputation()"
      ],
      "expected_observables": [
        "dom:computationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputGraph",
      "to": "S3_ErrorAlert",
      "event": "GraphValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ComputingPaths",
      "to": "S5_DrawingPaths",
      "event": "PathComputationComplete",
      "guard": "computationSuccessful",
      "actions": [
        "updateGraphStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:graphStructureUpdated",
        "dom:pathsVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingPaths",
      "to": "S0_Idle",
      "event": "PathComputationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "compute",
    "reset",
    "graph_visualization"
  ]
}