{
  "meta": {
    "concept": "Trie",
    "topic": "Trie Data Structure Visualization",
    "educational_goal": "Demonstrate Trie insertion and search operations",
    "expected_interactions": [
      "insert",
      "search",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderTrie()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InsertStart",
      "label": "InsertStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_InsertingWord",
      "label": "InsertingWord",
      "type": "atomic",
      "entry_actions": [
        "findInsertPosition()",
        "createNewNodes()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingTrie",
      "label": "DrawingTrie",
      "type": "atomic",
      "entry_actions": [
        "updateTrieVisualization()",
        "animateInsertion()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_SearchingWord",
      "label": "SearchingWord",
      "type": "atomic",
      "entry_actions": [
        "highlightSearchPath()",
        "showSearchResult()"
      ],
      "exit_actions": [
        "clearSearchHighlight()"
      ]
    },
    {
      "id": "S7_TrieResetting",
      "label": "TrieResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllNodes()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInsert",
      "event_type": "user_action",
      "description": "User clicks the Insert button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters word in input field"
    },
    {
      "id": "UserClicksSearch",
      "event_type": "user_action",
      "description": "User clicks the Search button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "WordInsertionComplete",
      "event_type": "system_event",
      "description": "Word insertion and trie update complete"
    },
    {
      "id": "SearchComplete",
      "event_type": "system_event",
      "description": "Search operation complete"
    },
    {
      "id": "TrieResetComplete",
      "event_type": "system_event",
      "description": "Trie reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InsertStart",
      "event": "UserClicksInsert",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:insertButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InsertStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateWord()",
        "prepareInsertion()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_InsertingWord",
      "event": "InputValidationComplete",
      "guard": "validWord",
      "actions": [
        "parseInputValue()",
        "beginInsertion()"
      ],
      "expected_observables": [
        "dom:nodeCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InsertStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_InsertingWord",
      "to": "S5_DrawingTrie",
      "event": "WordInsertionComplete",
      "guard": "wordInsertedSuccessfully",
      "actions": [
        "updateTrieStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:trieStructureChanged",
        "dom:newNodesVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingTrie",
      "to": "S0_Idle",
      "event": "WordInsertionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_SearchingWord",
      "event": "UserClicksSearch",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:searchButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S6_SearchingWord",
      "to": "S0_Idle",
      "event": "SearchComplete",
      "guard": "true",
      "actions": [
        "showSearchResult()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:searchResultDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S7_TrieResetting",
      "event": "UserClicksReset",
      "guard": "trieNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_TrieResetting",
      "to": "S0_Idle",
      "event": "TrieResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:trieCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "insert",
    "search",
    "reset",
    "trie_visualization"
  ]
}