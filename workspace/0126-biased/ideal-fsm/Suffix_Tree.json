{
  "meta": {
    "concept": "SuffixTree",
    "topic": "Suffix Tree Construction and Visualization",
    "educational_goal": "Illustrate suffix tree construction and pattern matching",
    "expected_interactions": [
      "construct",
      "search",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderTree()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_ConstructStart",
      "label": "ConstructStart",
      "type": "atomic",
      "entry_actions": [
        "readInputString()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInputString()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ConstructingTree",
      "label": "ConstructingTree",
      "type": "atomic",
      "entry_actions": [
        "initializeSuffixTree()",
        "buildSuffixTree()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingTree",
      "label": "DrawingTree",
      "type": "atomic",
      "entry_actions": [
        "updateTreeVisualization()",
        "animateConstruction()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_TreeResetting",
      "label": "TreeResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllNodes()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksConstruct",
      "event_type": "user_action",
      "description": "User clicks the Construct button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters string in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "TreeConstructionComplete",
      "event_type": "system_event",
      "description": "Suffix tree construction and update complete"
    },
    {
      "id": "TreeResetComplete",
      "event_type": "system_event",
      "description": "Tree reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_ConstructStart",
      "event": "UserClicksConstruct",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputString",
        "dom:constructButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_ConstructStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateString()",
        "prepareConstruction()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_ConstructingTree",
      "event": "InputValidationComplete",
      "guard": "validString",
      "actions": [
        "parseInputString()",
        "beginConstruction()"
      ],
      "expected_observables": [
        "dom:treeConstructionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_ConstructStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ConstructingTree",
      "to": "S5_DrawingTree",
      "event": "TreeConstructionComplete",
      "guard": "treeConstructedSuccessfully",
      "actions": [
        "updateTreeStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:treeStructureChanged",
        "dom:newTreeVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingTree",
      "to": "S0_Idle",
      "event": "TreeConstructionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_TreeResetting",
      "event": "UserClicksReset",
      "guard": "treeNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_TreeResetting",
      "to": "S0_Idle",
      "event": "TreeResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:treeCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "construct",
    "reset",
    "tree_visualization"
  ]
}