{
  "meta": {
    "concept": "Mutex",
    "topic": "Mutex Lock Mechanism",
    "educational_goal": "Demonstrate mutex locking and unlocking",
    "expected_interactions": [
      "lock",
      "unlock",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderMutex()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_LockStart",
      "label": "LockStart",
      "type": "atomic",
      "entry_actions": [
        "readLockRequest()",
        "highlightLockButton()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingLock",
      "label": "ValidatingLock",
      "type": "atomic",
      "entry_actions": [
        "validateLockRequest()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_LockingMutex",
      "label": "LockingMutex",
      "type": "atomic",
      "entry_actions": [
        "performLockOperation()",
        "updateMutexState()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Unlocked",
      "label": "Unlocked",
      "type": "atomic",
      "entry_actions": [
        "updateMutexVisualization()",
        "animateUnlock()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingMutex",
      "label": "ResettingMutex",
      "type": "atomic",
      "entry_actions": [
        "clearMutexState()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksLock",
      "event_type": "user_action",
      "description": "User clicks the Lock button"
    },
    {
      "id": "UserClicksUnlock",
      "event_type": "user_action",
      "description": "User clicks the Unlock button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "LockValidationComplete",
      "event_type": "system_event",
      "description": "Lock validation completes successfully"
    },
    {
      "id": "LockValidationFailed",
      "event_type": "system_event",
      "description": "Lock validation fails"
    },
    {
      "id": "MutexLockComplete",
      "event_type": "system_event",
      "description": "Mutex lock operation complete"
    },
    {
      "id": "MutexUnlockComplete",
      "event_type": "system_event",
      "description": "Mutex unlock operation complete"
    },
    {
      "id": "MutexResetComplete",
      "event_type": "system_event",
      "description": "Mutex reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_LockStart",
      "event": "UserClicksLock",
      "guard": "mutexUnlocked",
      "actions": [
        "captureLockRequest()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:lockButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_LockStart",
      "to": "S2_ValidatingLock",
      "event": "LockValidationComplete",
      "guard": "lockRequestValid",
      "actions": [
        "validateLock()",
        "prepareLockOperation()"
      ],
      "expected_observables": [
        "dom:lockValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingLock",
      "to": "S4_LockingMutex",
      "event": "LockValidationComplete",
      "guard": "validLockRequest",
      "actions": [
        "beginLockOperation()",
        "updateMutexState()"
      ],
      "expected_observables": [
        "dom:mutexLockStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_LockStart",
      "to": "S3_ErrorAlert",
      "event": "LockValidationFailed",
      "guard": "lockRequestInvalid",
      "actions": [
        "showError()",
        "focusLockButton()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetLockRequest()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_LockingMutex",
      "to": "S5_Unlocked",
      "event": "MutexLockComplete",
      "guard": "lockSuccessful",
      "actions": [
        "updateMutexVisualization()",
        "triggerUnlockAnimation()"
      ],
      "expected_observables": [
        "dom:mutexStateChanged",
        "dom:mutexLocked"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_Unlocked",
      "to": "S0_Idle",
      "event": "MutexUnlockComplete",
      "guard": "unlockSuccessful",
      "actions": [
        "enableControls()",
        "clearLockRequest()"
      ],
      "expected_observables": [
        "dom:unlockAnimationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingMutex",
      "event": "UserClicksReset",
      "guard": "mutexLocked",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingMutex",
      "to": "S0_Idle",
      "event": "MutexResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetLockRequest()"
      ],
      "expected_observables": [
        "dom:mutexCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "lock",
    "unlock",
    "reset",
    "mutex_visualization"
  ]
}