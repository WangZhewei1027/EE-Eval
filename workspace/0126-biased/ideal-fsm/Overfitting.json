{
  "meta": {
    "concept": "Overfitting",
    "topic": "Machine Learning Model Overfitting",
    "educational_goal": "Demonstrate the concept of overfitting in machine learning models",
    "expected_interactions": [
      "train",
      "evaluate",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_TrainingStart",
      "label": "TrainingStart",
      "type": "atomic",
      "entry_actions": [
        "readTrainingParameters()",
        "highlightParameters()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_TrainingModel",
      "label": "TrainingModel",
      "type": "atomic",
      "entry_actions": [
        "trainModel()",
        "showTrainingProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_EvaluatingModel",
      "label": "EvaluatingModel",
      "type": "atomic",
      "entry_actions": [
        "evaluateModel()",
        "displayEvaluationResults()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearModel()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksTrain",
      "event_type": "user_action",
      "description": "User clicks the Train button"
    },
    {
      "id": "UserClicksEvaluate",
      "event_type": "user_action",
      "description": "User clicks the Evaluate button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TrainingComplete",
      "event_type": "system_event",
      "description": "Model training completes"
    },
    {
      "id": "EvaluationComplete",
      "event_type": "system_event",
      "description": "Model evaluation completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_TrainingStart",
      "event": "UserClicksTrain",
      "guard": "parametersValid",
      "actions": [
        "captureParameters()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:trainButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_TrainingStart",
      "to": "S2_TrainingModel",
      "event": "TrainingComplete",
      "guard": "trainingStarted",
      "actions": [
        "startTrainingProcess()"
      ],
      "expected_observables": [
        "dom:trainingStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S2_TrainingModel",
      "to": "S3_EvaluatingModel",
      "event": "TrainingComplete",
      "guard": "modelTrained",
      "actions": [
        "beginEvaluation()"
      ],
      "expected_observables": [
        "dom:evaluationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_EvaluatingModel",
      "to": "S0_Idle",
      "event": "EvaluationComplete",
      "guard": "evaluationDone",
      "actions": [
        "showResults()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:evaluationResultsDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "modelExists",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetParameters()"
      ],
      "expected_observables": [
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "train",
    "evaluate",
    "reset",
    "graph_visualization"
  ]
}