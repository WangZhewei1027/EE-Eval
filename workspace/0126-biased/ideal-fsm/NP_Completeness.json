{
  "meta": {
    "concept": "NP-Completeness",
    "topic": "Understanding NP-Completeness",
    "educational_goal": "Explain the concept of NP-Completeness and its implications",
    "expected_interactions": [
      "define",
      "example",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderExplanation()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_DefineStart",
      "label": "DefineStart",
      "type": "atomic",
      "entry_actions": [
        "highlightDefinitionSection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ShowingDefinition",
      "label": "ShowingDefinition",
      "type": "atomic",
      "entry_actions": [
        "displayDefinition()",
        "showComplexityClasses()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ShowingExample",
      "label": "ShowingExample",
      "type": "atomic",
      "entry_actions": [
        "displayExampleProblem()",
        "highlightExample()"
      ],
      "exit_actions": [
        "clearExampleHighlight()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllSections()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksDefine",
      "event_type": "user_action",
      "description": "User clicks the Define button"
    },
    {
      "id": "UserClicksExample",
      "event_type": "user_action",
      "description": "User clicks the Example button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DefinitionDisplayed",
      "event_type": "system_event",
      "description": "Definition of NP-Completeness displayed"
    },
    {
      "id": "ExampleDisplayed",
      "event_type": "system_event",
      "description": "Example problem displayed"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_DefineStart",
      "event": "UserClicksDefine",
      "guard": "true",
      "actions": [
        "disableControls()",
        "prepareDefinition()"
      ],
      "expected_observables": [
        "dom:defineButtonClicked"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_DefineStart",
      "to": "S2_ShowingDefinition",
      "event": "DefinitionDisplayed",
      "guard": "true",
      "actions": [
        "showDefinitionContent()",
        "highlightComplexityClasses()"
      ],
      "expected_observables": [
        "dom:definitionDisplayed"
      ],
      "timeout": 2000
    },
    {
      "from": "S0_Idle",
      "to": "S3_ShowingExample",
      "event": "UserClicksExample",
      "guard": "true",
      "actions": [
        "disableControls()",
        "prepareExample()"
      ],
      "expected_observables": [
        "dom:exampleButtonClicked"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ShowingExample",
      "to": "S0_Idle",
      "event": "ExampleDisplayed",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearExampleHighlight()"
      ],
      "expected_observables": [
        "dom:exampleDisplayed"
      ],
      "timeout": 2000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetVisualization()"
      ],
      "expected_observables": [
        "dom:sectionsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "define",
    "example",
    "reset",
    "visualization_area"
  ]
}