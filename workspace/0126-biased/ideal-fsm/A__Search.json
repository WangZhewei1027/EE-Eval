{
  "meta": {
    "concept": "A* Search",
    "topic": "A* Search Algorithm Visualization",
    "educational_goal": "Illustrate the A* search process and pathfinding",
    "expected_interactions": [
      "set_start",
      "set_goal",
      "add_obstacle",
      "run_search",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGrid()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SettingStart",
      "label": "SettingStart",
      "type": "atomic",
      "entry_actions": [
        "highlightStartCell()",
        "awaitStartSelection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_SettingGoal",
      "label": "SettingGoal",
      "type": "atomic",
      "entry_actions": [
        "highlightGoalCell()",
        "awaitGoalSelection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_AddingObstacle",
      "label": "AddingObstacle",
      "type": "atomic",
      "entry_actions": [
        "highlightObstacleCell()",
        "awaitObstaclePlacement()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S4_RunningSearch",
      "label": "RunningSearch",
      "type": "operation",
      "entry_actions": [
        "initializeSearch()",
        "executeSearchStep()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SearchComplete",
      "label": "SearchComplete",
      "type": "atomic",
      "entry_actions": [
        "displayPath()",
        "showCompletionMessage()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingGrid",
      "label": "ResettingGrid",
      "type": "atomic",
      "entry_actions": [
        "clearGrid()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksSetStart",
      "event_type": "user_action",
      "description": "User clicks the Set Start button"
    },
    {
      "id": "UserClicksSetGoal",
      "event_type": "user_action",
      "description": "User clicks the Set Goal button"
    },
    {
      "id": "UserClicksAddObstacle",
      "event_type": "user_action",
      "description": "User clicks the Add Obstacle button"
    },
    {
      "id": "UserClicksRunSearch",
      "event_type": "user_action",
      "description": "User clicks the Run Search button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "StartPositionSet",
      "event_type": "system_event",
      "description": "Start position is set on the grid"
    },
    {
      "id": "GoalPositionSet",
      "event_type": "system_event",
      "description": "Goal position is set on the grid"
    },
    {
      "id": "ObstacleAdded",
      "event_type": "system_event",
      "description": "Obstacle is added to the grid"
    },
    {
      "id": "SearchExecutionComplete",
      "event_type": "system_event",
      "description": "A* search execution completes"
    },
    {
      "id": "GridResetComplete",
      "event_type": "system_event",
      "description": "Grid reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SettingStart",
      "event": "UserClicksSetStart",
      "guard": "true",
      "actions": [
        "disableControls()",
        "awaitStartSelection()"
      ],
      "expected_observables": [
        "dom:setStartButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SettingStart",
      "to": "S0_Idle",
      "event": "StartPositionSet",
      "guard": "true",
      "actions": [
        "markStartPosition()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:startPositionMarked"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S2_SettingGoal",
      "event": "UserClicksSetGoal",
      "guard": "true",
      "actions": [
        "disableControls()",
        "awaitGoalSelection()"
      ],
      "expected_observables": [
        "dom:setGoalButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_SettingGoal",
      "to": "S0_Idle",
      "event": "GoalPositionSet",
      "guard": "true",
      "actions": [
        "markGoalPosition()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:goalPositionMarked"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_AddingObstacle",
      "event": "UserClicksAddObstacle",
      "guard": "true",
      "actions": [
        "disableControls()",
        "awaitObstaclePlacement()"
      ],
      "expected_observables": [
        "dom:addObstacleButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S3_AddingObstacle",
      "to": "S0_Idle",
      "event": "ObstacleAdded",
      "guard": "true",
      "actions": [
        "markObstacle()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:obstacleMarked"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_RunningSearch",
      "event": "UserClicksRunSearch",
      "guard": "startAndGoalSet",
      "actions": [
        "disableControls()",
        "beginSearchExecution()"
      ],
      "expected_observables": [
        "dom:runSearchButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_RunningSearch",
      "to": "S5_SearchComplete",
      "event": "SearchExecutionComplete",
      "guard": "pathFound",
      "actions": [
        "displayPath()",
        "showCompletionMessage()"
      ],
      "expected_observables": [
        "dom:pathDisplayed",
        "dom:completionMessageShown"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_SearchComplete",
      "to": "S0_Idle",
      "event": "SearchExecutionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingGrid",
      "event": "UserClicksReset",
      "guard": "gridNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingGrid",
      "to": "S0_Idle",
      "event": "GridResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:gridCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "grid",
    "set_start",
    "set_goal",
    "add_obstacle",
    "run_search",
    "reset"
  ]
}