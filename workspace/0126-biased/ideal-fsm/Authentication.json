{
  "meta": {
    "concept": "Authentication",
    "topic": "User Authentication Process",
    "educational_goal": "Demonstrate user login and logout functionality",
    "expected_interactions": [
      "login",
      "logout",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderLoginForm()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_EnteringCredentials",
      "label": "EnteringCredentials",
      "type": "atomic",
      "entry_actions": [
        "highlightInputFields()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCredentials",
      "label": "ValidatingCredentials",
      "type": "atomic",
      "entry_actions": [
        "validateCredentials()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Authenticated",
      "label": "Authenticated",
      "type": "atomic",
      "entry_actions": [
        "displayWelcomeMessage()",
        "enableLogout()"
      ],
      "exit_actions": [
        "clearWelcomeMessage()"
      ]
    },
    {
      "id": "S5_LoggingOut",
      "label": "LoggingOut",
      "type": "atomic",
      "entry_actions": [
        "performLogout()",
        "showLogoutFeedback()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksLogin",
      "event_type": "user_action",
      "description": "User clicks the Login button"
    },
    {
      "id": "UserEntersCredentials",
      "event_type": "user_action",
      "description": "User enters username and password"
    },
    {
      "id": "UserClicksLogout",
      "event_type": "user_action",
      "description": "User clicks the Logout button"
    },
    {
      "id": "CredentialsValidationComplete",
      "event_type": "system_event",
      "description": "Credentials validation completes successfully"
    },
    {
      "id": "CredentialsValidationFailed",
      "event_type": "system_event",
      "description": "Credentials validation fails"
    },
    {
      "id": "LogoutComplete",
      "event_type": "system_event",
      "description": "Logout operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_EnteringCredentials",
      "event": "UserClicksLogin",
      "guard": "inputFieldsNotEmpty",
      "actions": [
        "captureCredentials()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:loginButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_EnteringCredentials",
      "to": "S2_ValidatingCredentials",
      "event": "CredentialsValidationComplete",
      "guard": "credentialsAreValid",
      "actions": [
        "validateCredentials()",
        "prepareAuthentication()"
      ],
      "expected_observables": [
        "dom:credentialsValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_EnteringCredentials",
      "to": "S3_ErrorAlert",
      "event": "CredentialsValidationFailed",
      "guard": "credentialsAreInvalid",
      "actions": [
        "showError()",
        "focusInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S2_ValidatingCredentials",
      "to": "S4_Authenticated",
      "event": "CredentialsValidationComplete",
      "guard": "authenticationSuccessful",
      "actions": [
        "grantAccess()",
        "displayWelcome()"
      ],
      "expected_observables": [
        "dom:welcomeMessageDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S4_Authenticated",
      "to": "S5_LoggingOut",
      "event": "UserClicksLogout",
      "guard": "true",
      "actions": [
        "initiateLogout()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:logoutButtonClicked"
      ],
      "timeout": 1000
    },
    {
      "from": "S5_LoggingOut",
      "to": "S0_Idle",
      "event": "LogoutComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearSession()"
      ],
      "expected_observables": [
        "dom:loggedOut",
        "dom:sessionCleared"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "login",
    "logout",
    "error_alert",
    "welcome_message"
  ]
}