{
  "meta": {
    "concept": "Agile Methodology",
    "topic": "Agile Project Management",
    "educational_goal": "Demonstrate Agile principles and practices",
    "expected_interactions": [
      "startSprint",
      "addTask",
      "completeTask",
      "reviewSprint",
      "resetBoard"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderBoard()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SprintPlanning",
      "label": "SprintPlanning",
      "type": "atomic",
      "entry_actions": [
        "startSprint()",
        "highlightSprintBoard()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_AddingTask",
      "label": "AddingTask",
      "type": "atomic",
      "entry_actions": [
        "readTaskInput()",
        "showTaskInputFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_TaskCompletion",
      "label": "TaskCompletion",
      "type": "atomic",
      "entry_actions": [
        "markTaskComplete()",
        "updateBoard()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SprintReview",
      "label": "SprintReview",
      "type": "atomic",
      "entry_actions": [
        "reviewSprintProgress()",
        "showReviewFeedback()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_BoardResetting",
      "label": "BoardResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllTasks()",
        "resetBoardVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserStartsSprint",
      "event_type": "user_action",
      "description": "User starts a new sprint"
    },
    {
      "id": "UserAddsTask",
      "event_type": "user_action",
      "description": "User adds a task to the sprint"
    },
    {
      "id": "UserCompletesTask",
      "event_type": "user_action",
      "description": "User marks a task as complete"
    },
    {
      "id": "UserReviewsSprint",
      "event_type": "user_action",
      "description": "User reviews the sprint progress"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TaskInputValidationComplete",
      "event_type": "system_event",
      "description": "Task input validation completes successfully"
    },
    {
      "id": "TaskInputValidationFailed",
      "event_type": "system_event",
      "description": "Task input validation fails"
    },
    {
      "id": "TaskCompletionConfirmed",
      "event_type": "system_event",
      "description": "Task completion confirmed and board updated"
    },
    {
      "id": "BoardResetComplete",
      "event_type": "system_event",
      "description": "Board reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SprintPlanning",
      "event": "UserStartsSprint",
      "guard": "true",
      "actions": [
        "initializeSprint()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:sprintStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SprintPlanning",
      "to": "S2_AddingTask",
      "event": "UserAddsTask",
      "guard": "taskInputNotEmpty",
      "actions": [
        "captureTaskInput()",
        "validateTaskInput()"
      ],
      "expected_observables": [
        "dom:taskInputCaptured"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_AddingTask",
      "to": "S4_TaskCompletion",
      "event": "TaskInputValidationComplete",
      "guard": "taskInputIsValid",
      "actions": [
        "addTaskToBoard()",
        "updateTaskList()"
      ],
      "expected_observables": [
        "dom:taskAdded"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_AddingTask",
      "to": "S3_ErrorAlert",
      "event": "TaskInputValidationFailed",
      "guard": "taskInputIsInvalid",
      "actions": [
        "showError()",
        "focusTaskInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetTaskInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_TaskCompletion",
      "to": "S5_SprintReview",
      "event": "TaskCompletionConfirmed",
      "guard": "taskCompletedSuccessfully",
      "actions": [
        "updateBoardVisualization()",
        "triggerReview()"
      ],
      "expected_observables": [
        "dom:taskCompleted",
        "dom:boardUpdated"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_SprintReview",
      "to": "S0_Idle",
      "event": "UserReviewsSprint",
      "guard": "reviewComplete",
      "actions": [
        "enableControls()",
        "clearTaskInput()"
      ],
      "expected_observables": [
        "dom:reviewComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_BoardResetting",
      "event": "UserClicksReset",
      "guard": "boardNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_BoardResetting",
      "to": "S0_Idle",
      "event": "BoardResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetTaskInputField()"
      ],
      "expected_observables": [
        "dom:boardCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "task_input",
    "start_sprint",
    "complete_task",
    "review_sprint",
    "reset_board",
    "board_visualization"
  ]
}