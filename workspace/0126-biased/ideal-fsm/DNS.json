{
  "meta": {
    "concept": "DNS",
    "topic": "Domain Name System Visualization",
    "educational_goal": "Illustrate DNS query resolution process",
    "expected_interactions": [
      "query",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderDNSDiagram()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_QueryStart",
      "label": "QueryStart",
      "type": "atomic",
      "entry_actions": [
        "readDomainInput()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingDomain",
      "label": "ValidatingDomain",
      "type": "atomic",
      "entry_actions": [
        "validateDomain()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ResolvingDNS",
      "label": "ResolvingDNS",
      "type": "atomic",
      "entry_actions": [
        "initiateDNSQuery()",
        "animateQueryProcess()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingResolution",
      "label": "DrawingResolution",
      "type": "atomic",
      "entry_actions": [
        "updateDNSVisualization()",
        "animateResolution()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingDiagram",
      "label": "ResettingDiagram",
      "type": "atomic",
      "entry_actions": [
        "clearDNSDiagram()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksQuery",
      "event_type": "user_action",
      "description": "User clicks the Query button"
    },
    {
      "id": "UserEntersDomain",
      "event_type": "user_action",
      "description": "User enters domain name in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DomainValidationComplete",
      "event_type": "system_event",
      "description": "Domain validation completes successfully"
    },
    {
      "id": "DomainValidationFailed",
      "event_type": "system_event",
      "description": "Domain validation fails"
    },
    {
      "id": "DNSResolutionComplete",
      "event_type": "system_event",
      "description": "DNS resolution and diagram update complete"
    },
    {
      "id": "DiagramResetComplete",
      "event_type": "system_event",
      "description": "Diagram reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_QueryStart",
      "event": "UserClicksQuery",
      "guard": "inputNotEmpty",
      "actions": [
        "captureDomainInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readDomainInput",
        "dom:queryButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_QueryStart",
      "to": "S2_ValidatingDomain",
      "event": "DomainValidationComplete",
      "guard": "domainIsValid",
      "actions": [
        "validateDomainName()",
        "prepareDNSResolution()"
      ],
      "expected_observables": [
        "dom:domainValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingDomain",
      "to": "S4_ResolvingDNS",
      "event": "DomainValidationComplete",
      "guard": "validDomainName",
      "actions": [
        "parseDomainInput()",
        "beginDNSResolution()"
      ],
      "expected_observables": [
        "dom:dnsResolutionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_QueryStart",
      "to": "S3_ErrorAlert",
      "event": "DomainValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ResolvingDNS",
      "to": "S5_DrawingResolution",
      "event": "DNSResolutionComplete",
      "guard": "resolutionSuccessful",
      "actions": [
        "updateDNSDiagram()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:dnsDiagramUpdated",
        "dom:resolutionVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingResolution",
      "to": "S0_Idle",
      "event": "DNSResolutionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingDiagram",
      "event": "UserClicksReset",
      "guard": "diagramNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingDiagram",
      "to": "S0_Idle",
      "event": "DiagramResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:diagramCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "query",
    "reset",
    "dns_visualization"
  ]
}