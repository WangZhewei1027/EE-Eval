{
  "meta": {
    "concept": "Prim's Algorithm",
    "topic": "Minimum Spanning Tree Visualization",
    "educational_goal": "Demonstrate Prim's algorithm for finding MST",
    "expected_interactions": [
      "start",
      "step",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AlgorithmStart",
      "label": "AlgorithmStart",
      "type": "atomic",
      "entry_actions": [
        "initializeAlgorithm()",
        "highlightStartNode()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_StepExecution",
      "label": "StepExecution",
      "type": "atomic",
      "entry_actions": [
        "executeStep()",
        "updateGraphVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AlgorithmComplete",
      "label": "AlgorithmComplete",
      "type": "atomic",
      "entry_actions": [
        "finalizeVisualization()",
        "showCompletionMessage()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraph()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserClicksStep",
      "event_type": "user_action",
      "description": "User clicks the Step button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "StepExecutionComplete",
      "event_type": "system_event",
      "description": "Step execution completes successfully"
    },
    {
      "id": "AlgorithmCompletion",
      "event_type": "system_event",
      "description": "Algorithm completes successfully"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AlgorithmStart",
      "event": "UserClicksStart",
      "guard": "graphNotEmpty",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startButtonClicked",
        "dom:startNodeHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AlgorithmStart",
      "to": "S2_StepExecution",
      "event": "UserClicksStep",
      "guard": "stepAvailable",
      "actions": [
        "prepareStepExecution()",
        "highlightNextEdge()"
      ],
      "expected_observables": [
        "dom:stepButtonClicked",
        "dom:nextEdgeHighlighted"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_StepExecution",
      "to": "S4_AlgorithmComplete",
      "event": "AlgorithmCompletion",
      "guard": "algorithmFinished",
      "actions": [
        "completeAlgorithm()",
        "displayMST()"
      ],
      "expected_observables": [
        "dom:completionMessageShown",
        "dom:MSTDisplayed"
      ],
      "timeout": 3000
    },
    {
      "from": "S2_StepExecution",
      "to": "S3_ErrorAlert",
      "event": "StepExecutionComplete",
      "guard": "stepFailed",
      "actions": [
        "showError()",
        "focusGraph()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetGraph()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "step",
    "reset",
    "graph_visualization"
  ]
}