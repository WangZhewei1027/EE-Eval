{
  "meta": {
    "concept": "HeapSort",
    "topic": "Heap Sort Visualization",
    "educational_goal": "Demonstrate heap sort algorithm",
    "expected_interactions": [
      "buildHeap",
      "sort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_BuildingHeap",
      "label": "BuildingHeap",
      "type": "operation",
      "entry_actions": [
        "readInputArray()",
        "highlightArray()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_HeapBuilt",
      "label": "HeapBuilt",
      "type": "atomic",
      "entry_actions": [
        "showHeapStructure()",
        "enableSortButton()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_SortingHeap",
      "label": "SortingHeap",
      "type": "operation",
      "entry_actions": [
        "performHeapSort()",
        "animateSorting()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_SortedArray",
      "label": "SortedArray",
      "type": "atomic",
      "entry_actions": [
        "displaySortedArray()",
        "enableResetButton()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearArray()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksBuildHeap",
      "event_type": "user_action",
      "description": "User clicks the Build Heap button"
    },
    {
      "id": "UserClicksSort",
      "event_type": "user_action",
      "description": "User clicks the Sort button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "HeapBuildComplete",
      "event_type": "system_event",
      "description": "Heap building completes successfully"
    },
    {
      "id": "SortComplete",
      "event_type": "system_event",
      "description": "Heap sort completes successfully"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_BuildingHeap",
      "event": "UserClicksBuildHeap",
      "guard": "inputArrayNotEmpty",
      "actions": [
        "captureArrayInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:buildHeapButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_BuildingHeap",
      "to": "S2_HeapBuilt",
      "event": "HeapBuildComplete",
      "guard": "heapBuiltSuccessfully",
      "actions": [
        "updateHeapStructure()",
        "enableSortButton()"
      ],
      "expected_observables": [
        "dom:heapStructureVisible"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_HeapBuilt",
      "to": "S3_SortingHeap",
      "event": "UserClicksSort",
      "guard": "heapReadyForSort",
      "actions": [
        "beginHeapSort()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:sortButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S3_SortingHeap",
      "to": "S4_SortedArray",
      "event": "SortComplete",
      "guard": "arraySortedSuccessfully",
      "actions": [
        "displaySortedArray()",
        "enableResetButton()"
      ],
      "expected_observables": [
        "dom:sortedArrayVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_SortedArray",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "buildHeap",
    "sort",
    "reset",
    "array_visualization"
  ]
}