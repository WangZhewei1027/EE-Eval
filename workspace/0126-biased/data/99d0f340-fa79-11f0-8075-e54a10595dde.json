    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Garbage Collection Simulation</title>\n    <script>\n        let objects = [];\n        let maxObjects = 10;\n\n        function createObject() {\n            if (objects.length < maxObjects) {\n                objects.push({ id: objects.length + 1, value: Math.random() });\n                updateDisplay();\n            } else {\n                alert('Maximum object limit reached.');\n            }\n        }\n\n        function collectGarbage() {\n            objects = objects.filter(obj => obj.value > 0.5);\n            updateDisplay();\n        }\n\n        function modifyObject(id) {\n            const obj = objects.find(o => o.id === id);\n            if (obj) {\n                obj.value = Math.random();\n                updateDisplay();\n            }\n        }\n\n        function updateDisplay() {\n            const list = document.getElementById('objectList');\n            list.innerHTML = '';\n            objects.forEach(obj => {\n                const item = document.createElement('div');\n                item.textContent = `Object ${obj.id}: ${obj.value.toFixed(2)}`;\n                const button = document.createElement('button');\n                button.textContent = 'Modify';\n                button.onclick = () => modifyObject(obj.id);\n                item.appendChild(button);\n                list.appendChild(item);\n            });\n            document.getElementById('objectCount').textContent = `Objects in memory: ${objects.length}`;\n        }\n\n        function clearAllObjects() {\n            objects = [];\n            updateDisplay();\n        }\n\n        function setMaxObjects(value) {\n            maxObjects = value;\n            document.getElementById('maxObjectCount').textContent = `Max objects: ${maxObjects}`;\n        }\n    </script>\n</head>\n<body>\n    <h1>Garbage Collection Simulation</h1>\n    <div>\n        <button onclick=\"createObject()\">Create Object</button>\n        <button onclick=\"collectGarbage()\">Collect Garbage</button>\n        <button onclick=\"clearAllObjects()\">Clear All Objects</button>\n    </div>\n    <div>\n        <label for=\"maxObjectsInput\">Set Max Objects: </label>\n        <input type=\"number\" id=\"maxObjectsInput\" min=\"1\" value=\"10\" onchange=\"setMaxObjects(this.value)\">\n    </div>\n    <div id=\"objectCount\">Objects in memory: 0</div>\n    <div id=\"maxObjectCount\">Max objects: 10</div>\n    <div id=\"objectList\"></div>\n</body>\n</html>"
