on:hover {\n            transform: scale(1.1);\n        }\n        .connection {\n            position: absolute;\n            width: 3px;\n            background: #4a90e2;\n            transform-origin: top;\n            transition: height 0.5s;\n        }\n        button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background: #4a90e2;\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            opacity: 0.8;\n            transition: opacity 0.3s;\n        }\n        button:hover {\n            opacity: 1;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Backpropagation Visualization</h1>\n\n    <div class=\"container\">\n        <div class=\"neural-network\">\n            <div class=\"layer\">\n                <div class=\"neuron\" style=\"background: #ff4d4d;\"></div>\n                <div class=\"neuron\" style=\"background: #ff4d4d;\"></div>\n            </div>\n            <div class=\"layer\">\n                <div class=\"neuron\"></div>\n                <div class=\"neuron\"></div>\n                <div class=\"neuron\"></div>\n            </div>\n            <div class=\"layer\">\n                <div class=\"neuron\" style=\"background: #ffcc00;\"></div>\n            </div>\n        </div>\n    </div>\n\n    <button onclick=\"animateBackpropagation()\">Start Backpropagation</button>\n\n    <script>\n        function animateBackpropagation() {\n            const neuronEffects = document.querySelectorAll('.neuron');\n            const connections = [];\n\n            for (let i = 0; i < neuronEffects.length; i++) {\n                if (i < neuronEffects.length - 1) {\n                    const connection = document.createElement('div');\n                    const from = neuronEffects[i];\n                    const to = neuronEffects[i + 1];\n                    const height = 100;\n                    connection.classList.add('connection');\n                    connection.style.height = `${height}px`;\n                    connection.style.left = `${from.offsetLeft + from.offsetWidth / 2}px`;\n                    connection.style.top = `${from.offsetTop + from.offsetHeight}px`;\n                    document.body.appendChild(connection);\n                    connections.push(connection);\n                }\n            }\n\n            setTimeout(() => {\n                connections.forEach((conn, index) => {\n                    conn.style.height = `${Math.random() * 150 + 50}px`;\n                });\n            }, 500);\n        }\n    </script>\n</body>\n</html>"
