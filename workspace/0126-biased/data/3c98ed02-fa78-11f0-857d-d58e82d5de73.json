    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Amortized Analysis — Visualized Elegantly</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+Pro:wght@300;600&display=swap');\n\n  /* Reset and base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin: 0; padding: 0; height: 100%;\n    background: linear-gradient(135deg, #1e2a47 0%, #283e6f 40%, #4b7cbf 100%);\n    color: #f0f4fb;\n    font-family: 'Source Sans Pro', sans-serif;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    overflow-x: hidden;\n  }\n\n  /* Wrapper */\n  main {\n    min-height: 100vh;\n    padding: 3rem 2rem 5rem;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 3rem;\n    align-items: center;\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  /* Header */\n  header {\n    grid-column: 1 / -1;\n    text-align: center;\n    margin-bottom: 2rem;\n  }\n  header h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.7rem;\n    line-height: 1.1;\n    color: #EFF3FB;\n    letter-spacing: 0.04em;\n    user-select: none;\n    margin: 0;\n    text-shadow: 0 0 15px rgba(255 255 255 / 0.15), 0 4px 12px rgba(0 0 0 / 0.3);\n  }\n  header p.subtitle {\n    margin-top: 0.4rem;\n    font-weight: 300;\n    font-size: 1.3rem;\n    color: #dae4f7cc;\n    letter-spacing: 0.06em;\n    font-style: italic;\n  }\n\n  /* Left panel: Explanation text */\n  section.explanation {\n    font-size: 1.15rem;\n    line-height: 1.7;\n    color: #cbd6f4;\n    background: rgba(255 255 255 / 0.07);\n    border-radius: 1.1rem;\n    padding: 2rem 2.6rem;\n    box-shadow:\n      inset 0 0 8px 1px rgba(255 255 255 / 0.15),\n      0 10px 30px 0 rgba(0 0 0 / 0.35);\n    user-select: none;\n    position: relative;\n  }\n  section.explanation::-webkit-scrollbar {\n    width: 8px;\n  }\n  section.explanation::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  section.explanation::-webkit-scrollbar-thumb {\n    background: rgba(255 255 255 / 0.12);\n    border-radius: 4px;\n  }\n  section.explanation strong {\n    color: #a0bef7ee;\n  }\n  section.explanation em {\n    color: #7697ebdd;\n  }\n  section.explanation ul {\n    margin: 1.1rem 0 1.5rem 1.5rem;\n  }\n  section.explanation ul li {\n    margin: 0.7rem 0;\n  }\n\n  /* Right panel: Visual canvas */\n  section.visualizer {\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Canvas styles */\n  canvas#animation {\n    width: 100%;\n    height: auto;\n    border-radius: 2rem;\n    box-shadow:\n      0 15px 50px 0 rgba(75 124 191 / 0.75),\n      inset 0 0 40px 10px rgba(75 124 191 / 0.4);\n    background: radial-gradient(ellipse at center, #2c4483 45%, #1e2a47 95%);\n    display: block;\n    user-select: none;\n  }\n\n  /* Controls container */\n  .controls {\n    margin-top: 1.8rem;\n    text-align: center;\n  }\n  button {\n    background: linear-gradient(135deg, #607ddb 0%, #3950a0 100%);\n    border: none;\n    border-radius: 3rem;\n    color: #d1dcfc;\n    padding: 0.75rem 2.4rem;\n    font-size: 1.15rem;\n    font-weight: 600;\n    box-shadow: 0 6px 16px rgba(75 124 191 / 0.65);\n    cursor: pointer;\n    user-select: none;\n    transition:\n      background 0.4s cubic-bezier(0.22, 0.61, 0.36, 1),\n      box-shadow 0.4s cubic-bezier(0.22, 0.61, 0.36, 1),\n      transform 0.2s ease;\n    letter-spacing: 0.03em;\n  }\n  button:hover, button:focus {\n    background: linear-gradient(135deg, #3950a0 0%, #607ddb 100%);\n    box-shadow: 0 8px 22px rgba(60 91 160 / 0.85);\n    outline: none;\n    transform: translateY(-3px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow: 0 5px 14px rgba(45 70 120 / 0.7);\n  }\n\n  /* Footer - subtle decorative */\n  footer {\n    text-align: center;\n    padding: 1rem 0 2rem;\n    font-size: 0.85rem;\n    color: #7890c9aa;\n    font-style: italic;\n    user-select: none;\n    font-family: 'Source Sans Pro', sans-serif;\n  }\n\n  /* Tooltip style for special terms (not interactive, just style) */\n  .term {\n    cursor: default;\n    border-bottom: 1.5px dotted #8aa2f9cc;\n    font-weight: 600;\n    position: relative;\n  }\n  .term::after {\n    content: attr(data-tooltip);\n    position: absolute;\n    bottom: 110%; left: 50%;\n    transform: translateX(-50%);\n    background: #5d6fa277;\n    color: #e3e9ffcc;\n    padding: 0.3rem 0.65rem;\n    border-radius: 0.5rem;\n    opacity: 0;\n    pointer-events: none;\n    font-size: 0.75rem;\n    white-space: nowrap;\n    line-height: 1.2;\n    transition: opacity 0.3s cubic-bezier(0.4,0,0.2,1);\n  }\n  .term:hover::after {\n    opacity: 1;\n  }\n\n  /* Subtle glowing animation for the \"amortized cost\" circle */\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n        0 0 8px 2px rgba(44,140,255,0.6),\n        0 0 24px 6px rgba(44,140,255,0.4);\n      transform: scale(1);\n    }\n    50% {\n      box-shadow:\n        0 0 14px 4px rgba(44,140,255,0.9),\n        0 0 30px 10px rgba(44,140,255,0.6);\n      transform: scale(1.06);\n    }\n  }\n\n  /* Logo text inside canvas */\n  .canvas-label {\n    font-family: 'Playfair Display', serif;\n    fill: #aac7ff;\n    user-select: none;\n    pointer-events: none;\n    filter: drop-shadow(0 0 5px rgba(60,90,160,0.8));\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Amortized Analysis</h1>\n  <p class=\"subtitle\">A smooth journey from occasional expense to elegant average cost</p>\n</header>\n\n<main>\n  <section class=\"explanation\" aria-label=\"Explanation of Amortized Analysis\">\n    <p>\n      <strong>Amortized analysis</strong> is a powerful tool in algorithm analysis that helps us understand the <em>average cost</em> per operation over a worst-case sequence, rather than focusing on individual operation spikes. Instead of analyzing the worst-case cost for each single operation, it evaluates the <span class=\"term\" data-tooltip=\"Sum of all operation costs divided by the number of operations\">overall cost</span> divided evenly, smoothing out occasional expensive operations into small, manageable increments.\n    </p>\n    <p>\n      Consider a dynamic array that doubles in size when full:\n    </p>\n    <ul>\n      <li>Most insertions are cheap: just placing an item (O(1) time).</li>\n      <li>Occasionally, an insertion triggers resizing and copying all elements to a new array (O(n) time).</li>\n      <li><strong>Amortized analysis</strong> averages out these occasional expensive operations over the total number of insertions, demonstrating that the <em>amortized cost</em> per insertion remains <code>O(1)</code>.</li>\n    </ul>\n    <p>\n      This perspective ensures a tighter, realistic upper bound on the cost, reassuring us that expensive steps, although impactful individually, don't degrade average performance drastically.\n    </p>\n  </section>\n\n  <section class=\"visualizer\" aria-label=\"Amortized cost visualization\">\n    <canvas id=\"animation\" width=\"600\" height=\"420\" aria-hidden=\"true\" role=\"img\"></canvas>\n    <div class=\"controls\">\n      <button id=\"btnStartPause\" aria-pressed=\"false\" aria-label=\"Play or pause the amortized cost animation\">Play ▶️</button>\n    </div>\n  </section>\n</main>\n\n<footer>\n  &copy; 2024 — Designed for elegance &amp; clarity by AI\n</footer>\n\n<script>\n(() => {\n  const canvas = document.getElementById('animation');\n  const ctx = canvas.getContext('2d');\n\n  const W = canvas.width;\n  const H = canvas.height;\n  const centerX = W/2;\n  const baseY = 360;\n\n  // Animation state\n  let running = false;\n  let lastTimestamp = 0;\n\n  // Parameters for the dynamic array insertion simulation\n  // We simulate a sequence of 20 operations:\n  // - Most cheap, cost = 1 unit of time\n  // - On power-of-2 indices, a resize occurs: cost = n (current size)\n  // Amortized cost averaged over all operations.\n\n  // We'll visualize cost bars rising per operation on left side,\n  // and a large pulse circle representing amortized cost on right.\n\n  // Configs\n  const totalOps = 20;\n  const barWidth = 22;\n  const spacing = 14;\n  const leftMargin = 60;\n\n  // Store operation costs\n  // Precompute costs for the sequence\n  const opsCosts = [];\n  for(let i=1; i <= totalOps; i++){\n    if((i & (i - 1)) === 0){ // power of two => resize: cost = i (copying i elements)\n      opsCosts.push(i);\n    } else {\n      opsCosts.push(1);\n    }\n  }\n\n  // Calculate amortized cost after each step\n  const amortizedCosts = opsCosts.map((cost, idx) => {\n    const sum = opsCosts.slice(0, idx+1).reduce((a,b) => a+b,0);\n    return sum/(idx+1);\n  });\n\n  // Visual dimensions\n  const maxCost = Math.max(...opsCosts) * 1.2;\n\n  // Color palette\n  const colorCheap = '#89baff';  // light pastel blue\n  const colorExpensive = '#f48fb1'; // pinkish red for resize spikes\n  const colorAmortized = '#54c7ff'; // bright cyan blue\n\n  // Animation helpers\n  let animProgress = 0;\n  const animDuration = 2800; // ms per full cycle thru all operations\n  const opsAnimationDuration = animDuration / totalOps; // ms per operation bar animation\n\n  // Controls\n  const btnStartPause = document.getElementById('btnStartPause');\n\n  btnStartPause.addEventListener('click', () => {\n    running = !running;\n    if(running){\n      btnStartPause.textContent = 'Pause ⏸';\n      btnStartPause.setAttribute('aria-pressed', 'true');\n      lastTimestamp = performance.now();\n      requestAnimationFrame(animate);\n    } else {\n      btnStartPause.textContent = 'Play ▶️';\n      btnStartPause.setAttribute('aria-pressed', 'false');\n    }\n  });\n\n  // Drawing functions\n  function drawBackground(){\n    // Background gradient is done via CSS on the canvas element\n    // We'll just clear with global alpha for smooth redraw\n    ctx.clearRect(0,0,W,H);\n  }\n\n  function drawGrid(){\n    ctx.save();\n    ctx.strokeStyle = 'rgba(255 255 255 / 0.12)';\n    ctx.lineWidth = 1;\n    ctx.shadowColor = 'rgba(255 255 255 / 0.04)';\n    ctx.shadowBlur = 2;\n    ctx.font = '14px Source Sans Pro, sans-serif';\n    ctx.fillStyle = 'rgba(255 255 255 / 0.16)';\n    ctx.textAlign = 'right';\n\n    // Horizontal lines with labels for cost values\n    const lines = 5;\n    for(let i=1; i<=lines; i++){\n      const y = baseY - (maxCost/lines)*i * (260/maxCost);\n      ctx.beginPath();\n      ctx.moveTo(leftMargin-10, y);\n      ctx.lineTo(leftMargin + (totalOps*(barWidth + spacing)) + 12, y);\n      ctx.stroke();\n      ctx.fillText(Math.round((maxCost/lines)*i), leftMargin-15, y+5);\n    }\n    ctx.restore();\n  }\n\n  function drawBars(progress){\n    ctx.save();\n\n    // Draw title above bars\n    ctx.fillStyle = \"#aac7ffdd\";\n    ctx.textAlign = \"left\";\n    ctx.font = \"600 20px 'Playfair Display', serif\";\n    ctx.fillText('Operations Cost', leftMargin, baseY - 280);\n\n    for(let i=0; i<totalOps; i++){\n      const opX = leftMargin + i*(barWidth + spacing);\n      const cost = opsCosts[i];\n      // Animate how tall the bar is growing on partial progress of current op\n      let animOpProgress;\n      if(progress < (i / totalOps)) animOpProgress = 0;\n      else if(progress >= ((i+1) / totalOps)) animOpProgress = 1;\n      else animOpProgress = (progress - (i / totalOps)) * totalOps;\n\n      const barHeight = (cost / maxCost) * 260 * animOpProgress;\n      const barY = baseY - barHeight;\n\n      // Shadow and glow for expensive ops\n      if(cost > 4){\n        ctx.fillStyle = colorExpensive;\n        ctx.shadowColor = 'rgba(244,143,177,0.8)';\n        ctx.shadowBlur = 12;\n      }\n      else {\n        ctx.fillStyle = colorCheap;\n        ctx.shadowColor = 'rgba(137,186,255,0.75)';\n        ctx.shadowBlur = 8;\n      }\n\n      // Draw bar with slight rounded corners\n      const radius = 6 * animOpProgress;\n      roundedRect(ctx, opX, barY, barWidth, barHeight, radius);\n      ctx.fill();\n\n      // Draw operation index on base\n      ctx.shadowColor = 'transparent';\n\n      ctx.fillStyle = '#aac7ffcc';\n      ctx.font = '600 14px \"Source Sans Pro\", sans-serif';\n      ctx.textAlign = 'center';\n      ctx.fillText(i + 1, opX + barWidth/2, baseY + 24);\n    }\n    ctx.restore();\n  }\n\n  // Draw a large glowing circle for amortized cost, pulsing subtly\n  function drawAmortizedCircle(progress){\n    ctx.save();\n\n    // Position on right side\n    const circleX = W - 160;\n    const circleY = baseY - 100;\n\n    // Determine which operation progress corresponds\n    const opIndex = Math.min(Math.floor(progress * totalOps), totalOps -1);\n    const opProgressInternal = (progress * totalOps) - opIndex;\n    const cost = amortizedCosts[opIndex];\n\n    // Pulsing glow intensity with sine wave\n    const pulse = 0.6 + 0.4 * Math.sin(progress * Math.PI * 4);\n\n    // Circle radius scaled by the amortized cost relative to maxCost\n    const baseRadius = 70;\n    const radius = baseRadius * (cost / maxCost);\n\n    // Glow shadows for layered effect\n    ctx.shadowColor = `rgba(84,199,255,${0.9 * pulse})`;\n    ctx.shadowBlur = 30;\n    ctx.shadowOffsetX = 0;\n    ctx.shadowOffsetY = 0;\n\n    // Main circle\n    const gradient = ctx.createRadialGradient(circleX, circleY, radius * 0.3, circleX, circleY, radius);\n    gradient.addColorStop(0, `rgba(84,199,255,0.9)`);\n    gradient.addColorStop(1, `rgba(21,117,154,0.15)`);\n\n    ctx.fillStyle = gradient;\n    ctx.beginPath();\n    ctx.ellipse(circleX, circleY, radius, radius * 0.9, 0, 0, Math.PI * 2);\n    ctx.fill();\n\n    // Inner circle with subtle pulsation (scale)\n    const innerRadius = radius * (0.55 + 0.1 * Math.cos(progress*8*Math.PI));\n    const innerGradient = ctx.createRadialGradient(circleX, circleY, innerRadius*0.7, circleX, circleY, innerRadius);\n    innerGradient.addColorStop(0, `rgba(173,226,255,0.95)`);\n    innerGradient.addColorStop(1, `rgba(84,199,255,0.3)`);\n    ctx.fillStyle = innerGradient;\n    ctx.beginPath();\n    ctx.ellipse(circleX, circleY, innerRadius, innerRadius*0.8, 0, 0, Math.PI*2);\n    ctx.fill();\n\n    // Text label: Amortized Cost\n    ctx.fillStyle = '#bbe3ffdd';\n    ctx.font = `700 24px 'Playfair Display', serif`;\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n    ctx.shadowColor = 'rgba(15,45,80,0.9)';\n    ctx.shadowBlur = 8;\n    ctx.fillText('Amortized Cost', circleX, circleY - radius*1.25);\n\n    // Display current amortized cost numeric (rounded)\n    ctx.font = `600 36px 'Source Sans Pro', sans-serif`;\n    ctx.fillStyle = '#d7e9ffcc';\n    ctx.shadowColor = 'rgba(15,45,80,0.9)';\n    ctx.shadowBlur = 10;\n    const displayCost = cost.toFixed(2);\n    ctx.fillText(displayCost, circleX, circleY);\n\n    ctx.restore();\n  }\n\n  // Helper for rounded rectangle\n  function roundedRect(ctx,x,y,w,h,r){\n    ctx.beginPath();\n    ctx.moveTo(x + r, y);\n    ctx.lineTo(x + w - r, y);\n    ctx.quadraticCurveTo(x + w, y, x + w, y + r);\n    ctx.lineTo(x + w, y + h - r);\n    ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);\n    ctx.lineTo(x + r, y + h);\n    ctx.quadraticCurveTo(x, y + h, x, y + h - r);\n    ctx.lineTo(x, y + r);\n    ctx.quadraticCurveTo(x, y, x + r, y);\n    ctx.closePath();\n  }\n\n  // Draw decorative title for right visualization\n  function drawRightTitle(){\n    ctx.save();\n    ctx.fillStyle = '#aac7ffcc';\n    ctx.font = '700 22px \"Playfair Display\", serif';\n    ctx.textAlign = 'center';\n    ctx.fillText('Dynamic Array Resizing:', W - 160, baseY - 190);\n    ctx.font = '500 17px Source Sans Pro, sans-serif';\n    ctx.fillText('Cost averaging over operations', W - 160, baseY - 160);\n    ctx.restore();\n  }\n\n  // Main animation frame\n  function animate(ts=0){\n    if(!running) return;\n\n    if(!lastTimestamp) lastTimestamp = ts;\n    const delta = ts - lastTimestamp;\n    lastTimestamp = ts;\n\n    animProgress += delta/animDuration;\n    if(animProgress > 1) animProgress = 0;\n\n    drawBackground();\n    drawGrid();\n    drawBars(animProgress);\n    drawAmortizedCircle(animProgress);\n    drawRightTitle();\n\n    requestAnimationFrame(animate);\n  }\n\n  // Initialize with static render:\n  drawBackground();\n  drawGrid();\n  drawBars(0);\n  drawAmortizedCircle(0);\n  drawRightTitle();\n\n  // Bonus: subtle glow pulse on explanation background\n  const explanationEl = document.querySelector('.explanation');\n  let glowState = 0;\n  let glowDir = 1;\n  function pulseGlowExp(){\n    glowState += 0.008*glowDir;\n    if(glowState >= 0.22) glowDir = -1;\n    else if(glowState <= 0) glowDir = 1;\n    explanationEl.style.boxShadow = `\n      inset 0 0 12px 2px rgba(255 255 255 / ${0.12 + glowState}),\n      0 12px 36px 0 rgba(0 0 60 / ${0.2 + glowState * 2})\n    `;\n    requestAnimationFrame(pulseGlowExp);\n  }\n  pulseGlowExp();\n})();\n</script>\n</body>\n</html>"
  },
