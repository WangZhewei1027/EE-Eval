    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Merge Sort Explorer - Interactive</title>\n<style>\n  /* Extremely minimal visual styling - basic layout only */\n  body { font-family: Arial, sans-serif; color: #000; background: #fff; margin: 10px; }\n  .row { display: flex; gap: 10px; margin-bottom: 8px; align-items: center; }\n  .col { display: flex; flex-direction: column; gap: 6px; }\n  label { font-size: 13px; }\n  input[type=\"range\"] { width: 160px; }\n  button, select, input[type=\"text\"], input[type=\"number\"], textarea { font-size: 13px; }\n  #arrayView { display:flex; gap:4px; flex-wrap:wrap; padding:6px; border:1px solid #000; min-height:36px; }\n  .cell { padding:6px 8px; border:1px solid #000; cursor:pointer; user-select:none; }\n  .cell.highlight { background: #fff; } /* no color change to adhere to plain design */\n  #bufferView { display:flex; gap:4px; padding:6px; border:1px solid #000; min-height:36px; }\n  #recursionTree, #callStack, #log { padding:6px; border:1px solid #000; min-height:60px; white-space:pre-wrap; overflow:auto; }\n  #controls { border:1px solid #000; padding:6px; }\n  #timeline { width:100%; }\n  textarea { width:100%; height:60px; }\n  .small { font-size:12px; }\n  .muted { font-size:12px; }\n  .spaced { margin-right:8px; }\n  #main { display:flex; gap:12px; }\n  #leftPane { flex:1; }\n  #rightPane { width:360px; }\n</style>\n</head>\n<body>\n<h3>Merge Sort Explorer (Interactive)</h3>\n\n<div id=\"controls\">\n  <div class=\"row\">\n    <div class=\"col\" style=\"min-width:320px;\">\n      <label>Array size: <input id=\"sizeInput\" type=\"number\" min=\"1\" max=\"200\" value=\"10\" style=\"width:60px;\"></label>\n      <label>Min value: <input id=\"minVal\" type=\"number\" value=\"0\" style=\"width:60px;\"></label>\n      <label>Max value: <input id=\"maxVal\" type=\"number\" value=\"99\" style=\"width:60px;\"></label>\n      <button id=\"genRandom\">Generate Random</button>\n      <button id=\"genSorted\">Generate Sorted</button>\n      <button id=\"genReversed\">Generate Reversed</button>\n      <button id=\"genDuplicates\">Generate Duplicates</button>\n    </div>\n\n    <div class=\"col\">\n      <label>Algorithm:\n        <select id=\"algoSelect\">\n          <option value=\"topdown\">Top-Down Recursive</option>\n          <option value=\"bottomup\">Bottom-Up Iterative</option>\n        </select>\n      </label>\n      <label>Direction:\n        <select id=\"dirSelect\">\n          <option value=\"asc\">Ascending</option>\n          <option value=\"desc\">Descending</option>\n        </select>\n      </label>\n      <label><input id=\"autoTrace\" type=\"checkbox\" checked> Auto-generate trace on change</label>\n    </div>\n  </div>\n\n  <div class=\"row\">\n    <div style=\"flex:1;\">\n      <label>Custom array (comma or space separated):</label><br>\n      <textarea id=\"customArrayInput\" placeholder=\"e.g. 5,1,9,2,2\"></textarea>\n      <div class=\"row\">\n        <button id=\"applyCustom\">Apply Custom Array</button>\n        <button id=\"clearArray\">Clear</button>\n      </div>\n    </div>\n\n    <div style=\"width:380px;\">\n      <label>Trace controls:</label>\n      <div class=\"row\">\n        <button id=\"generateTrace\">Generate Trace</button>\n        <button id=\"exportTrace\">Export Trace JSON</button>\n        <button id=\"importTraceBtn\">Import Trace JSON</button>\n        <input id=\"importTraceInput\" type=\"file\" accept=\".json\">\n      </div>\n\n      <div class=\"row\">\n        <label>Play speed: <input id=\"speedRange\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\"></label>\n        <label class=\"small\">ms/step</label>\n      </div>\n\n      <div class=\"row\">\n        <label><input id=\"showRec\" type=\"checkbox\" checked> Show recursion tree</label>\n        <label><input id=\"showStack\" type=\"checkbox\" checked> Show call stack</label>\n        <label><input id=\"showLog\" type=\"checkbox\" checked> Show log</label>\n      </div>\n    </div>\n  </div>\n\n  <hr>\n\n  <div class=\"row\">\n    <div class=\"col\" style=\"flex:1;\">\n      <div class=\"row\">\n        <button id=\"stepPrev\">⟸ Prev</button>\n        <button id=\"stepNext\">Next ⟹</button>\n        <button id=\"stepInto\">Step Into</button>\n        <button id=\"stepOver\">Step Over</button>\n        <button id=\"stepOut\">Step Out</button>\n        <button id=\"playPause\">Play</button>\n        <button id=\"resetBtn\">Reset</button>\n      </div>\n      <div class=\"row\">\n        <label>Jump to step: <input id=\"gotoStep\" type=\"number\" min=\"0\" value=\"0\" style=\"width:80px;\"></label>\n        <button id=\"gotoBtn\">Go</button>\n        <label>Detail level:\n          <input id=\"detailRange\" type=\"range\" min=\"0\" max=\"3\" value=\"2\">\n        </label>\n      </div>\n    </div>\n\n    <div style=\"width:380px;\">\n      <label>Breakpoints (by call id or depth):</label>\n      <div class=\"row\">\n        <label>ID: <input id=\"bpId\" type=\"number\" style=\"width:80px;\"></label>\n        <label>Depth: <input id=\"bpDepth\" type=\"number\" style=\"width:80px;\"></label>\n        <button id=\"setBp\">Set</button>\n        <button id=\"clearBp\">Clear</button>\n      </div>\n      <div class=\"row\">\n        <button id=\"saveSnapshot\">Save Snapshot</button>\n        <button id=\"loadSnapshot\">Load Snapshot</button>\n        <select id=\"snapshotsList\"></select>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div id=\"main\">\n  <div id=\"leftPane\">\n    <h4>Array</h4>\n    <div id=\"arrayView\" title=\"Click a cell to edit\"></div>\n    <h4>Auxiliary / Buffer</h4>\n    <div id=\"bufferView\"></div>\n    <div class=\"row\">\n      <label>Timeline: <input id=\"timeline\" type=\"range\" min=\"0\" max=\"0\" value=\"0\"></label>\n      <span id=\"stepLabel\" class=\"muted\">Step 0 / 0</span>\n    </div>\n    <h4>Current Operation</h4>\n    <div id=\"opDetail\" style=\"border:1px solid #000;padding:6px;min-height:40px;\"></div>\n  </div>\n\n  <div id=\"rightPane\">\n    <h4>Recursion Tree</h4>\n    <div id=\"recursionTree\"></div>\n    <h4>Call Stack</h4>\n    <div id=\"callStack\"></div>\n    <h4>Operation Log</h4>\n    <div id=\"log\"></div>\n  </div>\n</div>\n\n<script>\n/*\n  Merge Sort Explorer - Interactive\n  - Generates a trace of events representing a merge sort execution (top-down or bottom-up).\n  - Allows step-by-step navigation, step into/over/out, play/pause, breakpoints.\n  - Shows recursion tree and call stack and a detailed log.\n  - Minimal visuals intentionally.\n*/\n\n(function(){\n\n// Utility\nfunction clamp(v,a,b){return Math.max(a,Math.min(b,v));}\nfunction copyArr(a){ return a.slice(); }\nfunction parseArrayInput(str) {\n  if (!str) return [];\n  const tokens = str.trim().split(/[\\s,;]+/).filter(Boolean);\n  const nums = tokens.map(t => {\n    const n = Number(t);\n    return isNaN(n) ? 0 : n;\n  });\n  return nums;\n}\n\n// DOM Elements\nconst sizeInput = document.getElementById('sizeInput');\nconst minVal = document.getElementById('minVal');\nconst maxVal = document.getElementById('maxVal');\nconst genRandom = document.getElementById('genRandom');\nconst genSorted = document.getElementById('genSorted');\nconst genReversed = document.getElementById('genReversed');\nconst genDuplicates = document.getElementById('genDuplicates');\nconst algoSelect = document.getElementById('algoSelect');\nconst dirSelect = document.getElementById('dirSelect');\nconst autoTrace = document.getElementById('autoTrace');\n\nconst customArrayInput = document.getElementById('customArrayInput');\nconst applyCustom = document.getElementById('applyCustom');\nconst clearArray = document.getElementById('clearArray');\n\nconst generateTraceBtn = document.getElementById('generateTrace');\nconst exportTraceBtn = document.getElementById('exportTrace');\nconst importTraceBtn = document.getElementById('importTraceBtn');\nconst importTraceInput = document.getElementById('importTraceInput');\n\nconst showRec = document.getElementById('showRec');\nconst showStack = document.getElementById('showStack');\nconst showLog = document.getElementById('showLog');\n\nconst stepPrev = document.getElementById('stepPrev');\nconst stepNext = document.getElementById('stepNext');\nconst stepInto = document.getElementById('stepInto');\nconst stepOver = document.getElementById('stepOver');\nconst stepOut = document.getElementById('stepOut');\nconst playPause = document.getElementById('playPause');\nconst resetBtn = document.getElementById('resetBtn');\n\nconst gotoStep = document.getElementById('gotoStep');\nconst gotoBtn = document.getElementById('gotoBtn');\nconst detailRange = document.getElementById('detailRange');\n\nconst bpIdInput = document.getElementById('bpId');\nconst bpDepthInput = document.getElementById('bpDepth');\nconst setBp = document.getElementById('setBp');\nconst clearBp = document.getElementById('clearBp');\n\nconst saveSnapshotBtn = document.getElementById('saveSnapshot');\nconst loadSnapshotBtn = document.getElementById('loadSnapshot');\nconst snapshotsList = document.getElementById('snapshotsList');\n\nconst arrayView = document.getElementById('arrayView');\nconst bufferView = document.getElementById('bufferView');\nconst recursionTree = document.getElementById('recursionTree');\nconst callStackDiv = document.getElementById('callStack');\nconst logDiv = document.getElementById('log');\nconst opDetail = document.getElementById('opDetail');\n\nconst timeline = document.getElementById('timeline');\nconst stepLabel = document.getElementById('stepLabel');\nconst speedRange = document.getElementById('speedRange');\n\nconst importTraceFile = importTraceInput;\n\n// State\nlet array = [];\nlet initialArray = [];\nlet trace = [];    // array of events\nlet states = [];   // snapshots per event\nlet currentStep = 0;\nlet playing = false;\nlet playTimer = null;\nlet callBoundaries = {}; // callId => {startIndex, endIndex}\nlet callTree = []; // nodes\nlet breakpoint = { id: null, depth: null };\nlet snapshotStoreKey = 'mergeSortExplorerSnapshots_v1';\n\n// Setup default\nfunction randomInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\nfunction genRandomArray(size, min, max) {\n  const a = [];\n  for (let i=0;i<size;i++) a.push(randomInt(min,max));\n  return a;\n}\n\nfunction setArray(a, doGenerateTrace=true) {\n  array = copyArr(a);\n  initialArray = copyArr(a);\n  renderArrayEditable();\n  if (autoTrace.checked && doGenerateTrace) {\n    generateTrace();\n  } else {\n    resetPlayer();\n  }\n}\n\n// Render array as clickable/editable cells\nfunction renderArrayEditable() {\n  arrayView.innerHTML = '';\n  array.forEach((v,i) => {\n    const span = document.createElement('div');\n    span.className = 'cell';\n    span.textContent = String(v);\n    span.title = 'Click to edit';\n    span.dataset.index = i;\n    span.addEventListener('click', () => editCell(i));\n    arrayView.appendChild(span);\n  });\n  bufferView.innerHTML = '';\n  opDetail.textContent = 'Array set. Use Generate Trace to produce instrumentation if Auto-generate disabled.';\n}\n\n// Edit cell inline\nfunction editCell(index) {\n  const old = array[index];\n  const val = prompt('Edit element at index '+index, String(old));\n  if (val === null) return;\n  const n = Number(val);\n  if (isNaN(n)) {\n    alert('Invalid number');\n    return;\n  }\n  array[index] = n;\n  renderArrayEditable();\n  if (autoTrace.checked) generateTrace();\n}\n\n// Trace event structure:\n// {type: 'call'|'return'|'mergeStart'|'compare'|'copy'|'mergeEnd'|'overwrite',\n//  callId, parentCallId, left, mid, right, depth, i,j,k, values, message}\n// We'll also produce states: snapshots of array, buffer, highlights, stack\n\nlet callIdCounter = 1;\n\nfunction newCallId(){ return callIdCounter++; }\n\n// Generate trace for top-down recursive merge sort\nfunction generateTraceTopDown(arr, ascending=true) {\n  trace = [];\n  states = [];\n  callBoundaries = {};\n  callIdCounter = 1;\n  const a = arr.slice();\n  const buffer = new Array(a.length);\n  const cmp = ascending ? ((x,y)=>x<=y) : ((x,y)=>x>=y);\n\n  function pushEvent(ev) {\n    trace.push(ev);\n    // We'll not push states here; we will produce states inline when we simulate to allow stepable copy\n  }\n\n  function recordState(ev, arrSnapshot, bufSnapshot, stackSnapshot, msg) {\n    const st = {\n      event: ev,\n      array: arrSnapshot.slice(),\n      buffer: bufSnapshot.slice(),\n      stack: stackSnapshot.slice(),\n      message: msg || ''\n    };\n    states.push(st);\n    return st;\n  }\n\n  // We'll maintain a stack of call descriptors for stack snapshots\n  const callStack = [];\n\n  function ms(left, right, parentCallId, depth) {\n    const callId = newCallId();\n    const callNode = {callId, parentCallId, left, right, depth};\n    // mark call start\n    pushEvent({type:'call', callId, parentCallId, left, right, depth});\n    callStack.push({callId,left,right,depth});\n    recordState(trace[trace.length-1], a, buffer, callStack, 'Call start');\n\n    if (left >= right) {\n      // immediate return\n      pushEvent({type:'return', callId, left, right, depth});\n      // record state\n      recordState(trace[trace.length-1], a, buffer, callStack, 'Return (single element)');\n      callStack.pop();\n      callBoundaries[callId] = {startIndex: trace.findIndex(e=>e.callId===callId && e.type==='call'), endIndex: trace.length-1};\n      return;\n    }\n    const mid = Math.floor((left+right)/2);\n    // split\n    pushEvent({type:'split', callId, left, mid, right, depth});\n    recordState(trace[trace.length-1], a, buffer, callStack, 'Split');\n\n    ms(left, mid, callId, depth+1);\n    ms(mid+1, right, callId, depth+1);\n\n    // Begin merge\n    pushEvent({type:'mergeStart', callId, left, mid, right, depth});\n    recordState(trace[trace.length-1], a, buffer, callStack, 'Merge start');\n\n    // Merge process with trace of comparisons and copies\n    let i = left, j = mid+1, k = left;\n    while (i <= mid && j <= right) {\n      pushEvent({type:'compare', callId, left, mid, right, depth, i, j, k, values:[a[i], a[j]]});\n      recordState(trace[trace.length-1], a, buffer, callStack, 'Compare elements');\n\n      if (cmp(a[i], a[j])) {\n        pushEvent({type:'copy', callId, left, mid, right, depth, from:i, to:k, value:a[i]});\n        buffer[k] = a[i];\n        recordState(trace[trace.length-1], a, buffer, callStack, 'Copy left to buffer');\n        i++; k++;\n      } else {\n        pushEvent({type:'copy', callId, left, mid, right, depth, from:j, to:k, value:a[j]});\n        buffer[k] = a[j];\n        recordState(trace[trace.length-1], a, buffer, callStack, 'Copy right to buffer');\n        j++; k++;\n      }\n    }\n    while (i <= mid) {\n      pushEvent({type:'copy', callId, left, mid, right, depth, from:i, to:k, value:a[i]});\n      buffer[k] = a[i];\n      recordState(trace[trace.length-1], a, buffer, callStack, 'Copy remaining left');\n      i++; k++;\n    }\n    while (j <= right) {\n      pushEvent({type:'copy', callId, left, mid, right, depth, from:j, to:k, value:a[j]});\n      buffer[k] = a[j];\n      recordState(trace[trace.length-1], a, buffer, callStack, 'Copy remaining right');\n      j++; k++;\n    }\n\n    // Write buffer back to a and emit overwrite events\n    for (let idx = left; idx <= right; idx++) {\n      pushEvent({type:'overwrite', callId, left, mid, right, depth, index:idx, value:buffer[idx]});\n      a[idx] = buffer[idx];\n      recordState(trace[trace.length-1], a, buffer, callStack, 'Overwrite array from buffer');\n    }\n\n    pushEvent({type:'mergeEnd', callId, left, mid, right, depth});\n    recordState(trace[trace.length-1], a, buffer, callStack, 'Merge end');\n\n    pushEvent({type:'return', callId, left, right, depth});\n    recordState(trace[trace.length-1], a, buffer, callStack, 'Return from call');\n\n    callStack.pop();\n    callBoundaries[callId] = {startIndex: trace.findIndex(e=>e.callId===callId && e.type==='call'), endIndex: trace.findIndex((e,i)=>i>0 && e.callId===callId && e.type==='return')};\n  }\n\n  if (a.length>0) ms(0, a.length-1, null, 0);\n  // States produced inline; convert to consistent structure for player\n  return {trace, states, callBoundaries};\n}\n\n// Bottom-up iterative merge sort trace generator\nfunction generateTraceBottomUp(arr, ascending=true) {\n  trace = [];\n  states = [];\n  callBoundaries = {};\n  callIdCounter = 1;\n  const a = arr.slice();\n  const n = a.length;\n  const buffer = new Array(n);\n  const cmp = ascending ? ((x,y)=>x<=y) : ((x,y)=>x>=y);\n\n  const callStack = [];\n  function push(ev) {\n    trace.push(ev);\n    recordState(ev, a, buffer, callStack, ev.message || '');\n  }\n  function recordState(ev, arrSnapshot, bufSnapshot, stackSnapshot, msg) {\n    const st = {\n      event: ev,\n      array: arrSnapshot.slice(),\n      buffer: bufSnapshot.slice(),\n      stack: stackSnapshot.slice(),\n      message: msg || ''\n    };\n    states.push(st);\n    return st;\n  }\n\n  // We'll treat each merge operation as a \"call\" node with unique id and depth approximated by log2(size)\n  let width = 1;\n  while (width < n) {\n    for (let left=0; left < n; left += 2*width) {\n      const mid = Math.min(left+width-1, n-1);\n      const right = Math.min(left+2*width-1, n-1);\n      if (mid >= right) continue;\n      const callId = newCallId();\n      const depth = Math.max(0, Math.floor(Math.log2(width)));\n      push({type:'call', callId, left, mid, right, depth});\n      callStack.push({callId,left,mid,right,depth});\n      push({type:'mergeStart', callId, left, mid, right, depth});\n      // merge\n      let i = left, j = mid+1, k = left;\n      while (i <= mid && j <= right) {\n        push({type:'compare', callId, left, mid, right, depth, i, j, k, values:[a[i], a[j]]});\n        if (cmp(a[i], a[j])) {\n          push({type:'copy', callId, left, mid, right, depth, from:i, to:k, value:a[i]});\n          buffer[k] = a[i]; i++; k++;\n        } else {\n          push({type:'copy', callId, left, mid, right, depth, from:j, to:k, value:a[j]});\n          buffer[k] = a[j]; j++; k++;\n        }\n      }\n      while (i <= mid) { push({type:'copy', callId, left, mid, right, depth, from:i, to:k, value:a[i]}); buffer[k]=a[i]; i++; k++; }\n      while (j <= right) { push({type:'copy', callId, left, mid, right, depth, from:j, to:k, value:a[j]}); buffer[k]=a[j]; j++; k++; }\n      for (let idx=left; idx<=right; idx++) {\n        push({type:'overwrite', callId, left, mid, right, depth, index:idx, value:buffer[idx]});\n        a[idx] = buffer[idx];\n      }\n      push({type:'mergeEnd', callId, left, mid, right, depth});\n      push({type:'return', callId, left, mid, right, depth});\n      callStack.pop();\n      callBoundaries[callId] = {startIndex: trace.findIndex(e=>e.callId===callId && e.type==='call'), endIndex: trace.findIndex((e,i)=>i>0 && e.callId===callId && e.type==='return')};\n    }\n    width *= 2;\n  }\n  return {trace, states, callBoundaries};\n}\n\n// After generating trace and states, prepare player structures\nfunction preparePlayer(generated) {\n  trace = generated.trace;\n  states = generated.states;\n  callBoundaries = generated.callBoundaries || {};\n  // Build call tree from trace events (call events)\n  callTree = [];\n  const callMap = {};\n  trace.forEach((ev, idx) => {\n    if (ev.type === 'call') {\n      callMap[ev.callId] = {callId:ev.callId, left:ev.left, right:ev.right, depth:ev.depth, parent:ev.parentCallId || ev.parent, start: idx, end: null};\n    } else if (ev.type === 'return') {\n      if (callMap[ev.callId]) callMap[ev.callId].end = idx;\n    }\n  });\n  // Build tree\n  for (const id in callMap) {\n    const node = callMap[id];\n    node.children = [];\n    callTree.push(node);\n  }\n  const treeIndex = {};\n  callTree.forEach(n => treeIndex[n.callId] = n);\n  const roots = [];\n  callTree.forEach(n => {\n    if (n.parent == null || n.parent === undefined) roots.push(n);\n    else {\n      const p = treeIndex[n.parent];\n      if (p) p.children.push(n);\n      else roots.push(n);\n    }\n  });\n  callTree = roots;\n  // Fill timeline slider\n  timeline.max = Math.max(0, states.length-1);\n  timeline.value = 0;\n  currentStep = 0;\n  renderAll();\n}\n\n// Generate trace wrapper\nfunction generateTrace() {\n  stopPlaying();\n  const arr = array.slice();\n  const ascending = dirSelect.value === 'asc';\n  let generated;\n  try {\n    if (algoSelect.value === 'topdown') {\n      generated = generateTraceTopDown(arr, ascending);\n    } else {\n      generated = generateTraceBottomUp(arr, ascending);\n    }\n    preparePlayer(generated);\n    log('Trace generated: ' + trace.length + ' events, ' + states.length + ' states.');\n  } catch (e) {\n    alert('Error generating trace: ' + e.message);\n    console.error(e);\n  }\n}\n\n// Render functions\nfunction renderAll() {\n  renderArrayState();\n  renderBufferState();\n  renderRecursionTree();\n  renderCallStack();\n  renderLog();\n  renderOpDetail();\n  timeline.value = currentStep;\n  stepLabel.textContent = 'Step ' + currentStep + ' / ' + Math.max(0, states.length-1);\n  gotoStep.value = currentStep;\n}\n\nfunction renderArrayState() {\n  arrayView.innerHTML = '';\n  const st = states[currentStep];\n  const arr = st ? st.array : array;\n  arr.forEach((v,i) => {\n    const div = document.createElement('div');\n    div.className = 'cell';\n    div.textContent = String(v);\n    // highlight according to current event\n    const ev = st ? st.event : null;\n    if (ev) {\n      if (ev.type === 'compare' && (i === ev.i || i === ev.j || i===ev.i || i===ev.j)) {\n        div.style.fontWeight = 'bold';\n      }\n      if (ev.type === 'copy' && i === ev.to) {\n        div.style.outline = '1px solid';\n      }\n      if (ev.type === 'overwrite' && i === ev.index) {\n        div.style.outline = '1px dashed';\n      }\n    }\n    // allow edit while not playing\n    div.addEventListener('click', () => {\n      if (playing) return;\n      const val = prompt('Edit element at index '+i, String(arr[i]));\n      if (val === null) return;\n      const n = Number(val);\n      if (isNaN(n)) { alert('Invalid number'); return; }\n      array[i] = n;\n      initialArray = array.slice();\n      if (autoTrace.checked) generateTrace();\n      else renderAll();\n    });\n    arrayView.appendChild(div);\n  });\n}\n\nfunction renderBufferState() {\n  bufferView.innerHTML = '';\n  const st = states[currentStep];\n  const buf = st ? st.buffer : [];\n  if (!buf) return;\n  for (let i=0;i<buf.length;i++){\n    const div = document.createElement('div');\n    div.className = 'cell';\n    div.textContent = (buf[i] === undefined ? '' : String(buf[i]));\n    bufferView.appendChild(div);\n  }\n}\n\nfunction renderRecursionTree() {\n  recursionTree.style.display = showRec.checked ? 'block' : 'none';\n  recursionTree.innerHTML = '';\n  if (!showRec.checked) return;\n  if (!trace || trace.length===0) { recursionTree.textContent = '(no trace)'; return; }\n  // build simple textual tree from call boundaries\n  // We'll reconstruct parent-child relationships from trace 'call' parentCallId fields if present\n  // Fallback: list calls by depth and left-right\n  const calls = trace.filter(e=>e.type==='call').map(e=>({id:e.callId,left:e.left,right:e.right,depth:e.depth,parent:e.parentCallId||e.parent}));\n  if (calls.length===0) { recursionTree.textContent='(no calls)'; return; }\n  // Build by depth ordering\n  calls.sort((a,b)=> (a.depth - b.depth) || (a.left - b.left));\n  const lines = [];\n  function pad(n){ return '  '.repeat(Math.max(0,n)); }\n  calls.forEach(c => {\n    lines.push(pad(c.depth) + 'Call ' + c.id + ' ['+c.left+','+c.right+'] depth='+c.depth + (c.parent ? ' parent='+c.parent : ''));\n  });\n  recursionTree.textContent = lines.join('\\n');\n}\n\nfunction renderCallStack() {\n  callStackDiv.style.display = showStack.checked ? 'block' : 'none';\n  callStackDiv.innerHTML = '';\n  if (!showStack.checked) return;\n  const st = states[currentStep];\n  if (!st) { callStackDiv.textContent = '(no state)'; return; }\n  const stack = st.stack || [];\n  if (!stack.length) { callStackDiv.textContent = '(stack empty)'; return; }\n  const lines = stack.slice().reverse().map(s => 'Call '+ (s.callId||s.callId) + ' ['+(s.left!==undefined? s.left:'?')+','+(s.right!==undefined? s.right:'?')+'] depth='+(s.depth!==undefined? s.depth:'?'));\n  callStackDiv.textContent = lines.join('\\n');\n}\n\nfunction renderLog() {\n  logDiv.style.display = showLog.checked ? 'block' : 'none';\n  logDiv.innerHTML = '';\n  if (!showLog.checked) return;\n  // show last N states upto detail level\n  const detail = Number(detailRange.value);\n  const maxLines = 200;\n  const start = Math.max(0, currentStep - 100);\n  const lines = [];\n  for (let i = start; i <= currentStep; i++) {\n    const st = states[i];\n    if (!st) continue;\n    const ev = st.event;\n    let s = i + ': ' + (ev.type || '[state]') + ' ';\n    if (ev.type === 'call') s += 'CallId=' + ev.callId + ' ['+ev.left+','+ev.right+']';\n    else if (ev.type === 'compare') s += 'compare i='+ev.i+' j='+ev.j+' vals='+JSON.stringify(ev.values);\n    else if (ev.type === 'copy') s += 'copy from='+ev.from+' to='+ev.to+' val='+ev.value;\n    else if (ev.type === 'overwrite') s += 'overwrite idx='+ev.index+' val='+ev.value;\n    else s += JSON.stringify(ev);\n    if (i === currentStep) s = '> ' + s;\n    lines.push(s);\n    if (lines.length > maxLines) break;\n  }\n  logDiv.textContent = lines.join('\\n');\n}\n\nfunction renderOpDetail() {\n  const st = states[currentStep];\n  if (!st) { opDetail.textContent = '(no operation)'; return; }\n  const ev = st.event;\n  let text = 'Step: ' + currentStep + '\\n';\n  text += 'Event type: ' + (ev.type || '') + '\\n';\n  if (ev.callId) text += 'CallId: ' + ev.callId + '\\n';\n  if (ev.left !== undefined) text += 'Left: ' + ev.left + (ev.mid!==undefined? ('  Mid: '+ev.mid):'') + (ev.right!==undefined?('  Right: '+ev.right):'') + '\\n';\n  if (ev.type === 'compare') text += 'Compare indices: i=' + ev.i + ' j=' + ev.j + ' values=' + JSON.stringify(ev.values) + '\\n';\n  if (ev.type === 'copy') text += 'Copy from ' + ev.from + ' to ' + ev.to + ' value=' + ev.value + '\\n';\n  if (ev.type === 'overwrite') text += 'Overwrite index ' + ev.index + ' with ' + ev.value + '\\n';\n  if (st.message) text += 'Message: ' + st.message + '\\n';\n  opDetail.textContent = text;\n}\n\n// Player controls\nfunction setStep(idx) {\n  if (!states || states.length===0) { currentStep = 0; renderAll(); return; }\n  currentStep = clamp(Math.floor(idx), 0, states.length-1);\n  renderAll();\n}\n\nfunction stepForward() {\n  if (!states || states.length===0) return;\n  if (currentStep < states.length-1) {\n    currentStep++;\n    renderAll();\n    // breakpoints\n    const ev = states[currentStep].event;\n    if ((breakpoint.id !== null && ev.callId === breakpoint.id) || (breakpoint.depth !== null && ev.depth === breakpoint.depth)) {\n      stopPlaying();\n      log('Hit breakpoint at step '+currentStep);\n    }\n  } else {\n    stopPlaying();\n  }\n}\n\nfunction stepBackward() {\n  if (!states || states.length===0) return;\n  if (currentStep > 0) {\n    currentStep--;\n    renderAll();\n  }\n}\n\nfunction stepIntoFn() {\n  // just next step\n  stepForward();\n}\n\nfunction stepOverFn() {\n  // If current event is a call, jump to its return index\n  const st = states[currentStep];\n  if (!st) { stepForward(); return; }\n  const ev = st.event;\n  const callId = ev.callId || ev.callId;\n  if (ev.type === 'call' && callId && callBoundaries[callId]) {\n    const endIndex = callBoundaries[callId].endIndex;\n    if (endIndex !== undefined) {\n      setStep(endIndex+1);\n      return;\n    }\n  }\n  // Otherwise step to next event that is not part of same call depth (try to find enclosing call end)\n  // Find nearest call in stack\n  const stack = st.stack || [];\n  if (stack.length) {\n    const topCall = stack[stack.length-1];\n    const end = callBoundaries[topCall.callId] ? callBoundaries[topCall.callId].endIndex : null;\n    if (end !== null) { setStep(end+1); return; }\n  }\n  stepForward();\n}\n\nfunction stepOutFn() {\n  // Jump to return of enclosing call (not current call)\n  const st = states[currentStep];\n  if (!st) { stepForward(); return; }\n  const stack = st.stack || [];\n  if (!stack.length) { setStep(states.length-1); return; }\n  const currentCall = stack[stack.length-1];\n  const end = callBoundaries[currentCall.callId] ? callBoundaries[currentCall.callId].endIndex : null;\n  if (end !== null) {\n    setStep(end+1);\n    return;\n  }\n  stepForward();\n}\n\nfunction playToggle() {\n  if (playing) stopPlaying(); else startPlaying();\n}\n\nfunction startPlaying() {\n  if (!states || states.length===0) return;\n  playing = true;\n  playPause.textContent = 'Pause';\n  const interval = Number(speedRange.value) || 400;\n  playTimer = setInterval(() => {\n    if (currentStep >= states.length-1) { stopPlaying(); return; }\n    stepForward();\n  }, interval);\n}\n\nfunction stopPlaying() {\n  playing = false;\n  playPause.textContent = 'Play';\n  if (playTimer) clearInterval(playTimer);\n  playTimer = null;\n}\n\nfunction resetPlayer() {\n  stopPlaying();\n  trace = [];\n  states = [];\n  currentStep = 0;\n  timeline.max = 0;\n  timeline.value = 0;\n  stepLabel.textContent = 'Step 0 / 0';\n  arrayView.innerHTML = '';\n  bufferView.innerHTML = '';\n  recursionTree.innerHTML = '';\n  callStackDiv.innerHTML = '';\n  logDiv.innerHTML = '';\n  opDetail.textContent = '';\n}\n\n// Logging utility\nfunction log(msg) {\n  const now = new Date();\n  const line = '[' + now.toLocaleTimeString() + '] ' + msg;\n  const prev = logDiv.textContent || '';\n  logDiv.textContent = (prev ? prev + '\\n' : '') + line;\n  logDiv.scrollTop = logDiv.scrollHeight;\n}\n\n// Breakpoint controls\nsetBp.addEventListener('click', () => {\n  const id = bpIdInput.value ? Number(bpIdInput.value) : null;\n  const depth = bpDepthInput.value ? Number(bpDepthInput.value) : null;\n  breakpoint.id = (isNaN(id) ? null : id);\n  breakpoint.depth = (isNaN(depth) ? null : depth);\n  log('Breakpoint set: id=' + breakpoint.id + ' depth=' + breakpoint.depth);\n});\nclearBp.addEventListener('click', () => {\n  breakpoint = {id:null, depth:null};\n  bpIdInput.value = '';\n  bpDepthInput.value = '';\n  log('Breakpoints cleared');\n});\n\n// Snapshots (localStorage)\nfunction loadSnapshots() {\n  const raw = localStorage.getItem(snapshotStoreKey);\n  const list = raw ? JSON.parse(raw) : {};\n  snapshotsList.innerHTML = '';\n  for (const name in list) {\n    const opt = document.createElement('option');\n    opt.value = name;\n    opt.textContent = name;\n    snapshotsList.appendChild(opt);\n  }\n}\nsaveSnapshotBtn.addEventListener('click', () => {\n  const name = prompt('Snapshot name:');\n  if (!name) return;\n  const raw = localStorage.getItem(snapshotStoreKey);\n  const list = raw ? JSON.parse(raw) : {};\n  list[name] = {array: initialArray, algo: algoSelect.value, dir: dirSelect.value};\n  localStorage.setItem(snapshotStoreKey, JSON.stringify(list));\n  loadSnapshots();\n});\nloadSnapshotBtn.addEventListener('click', () => {\n  const name = snapshotsList.value;\n  if (!name) { alert('Select a snapshot'); return; }\n  const raw = localStorage.getItem(snapshotStoreKey);\n  const list = raw ? JSON.parse(raw) : {};\n  const snap = list[name];\n  if (!snap) { alert('Snapshot missing'); return; }\n  array = snap.array.slice();\n  initialArray = array.slice();\n  algoSelect.value = snap.algo || algoSelect.value;\n  dirSelect.value = snap.dir || dirSelect.value;\n  renderArrayEditable();\n  if (autoTrace.checked) generateTrace();\n});\nloadSnapshots();\n\n// Event handlers\ngenRandom.addEventListener('click', () => {\n  const size = clamp(Number(sizeInput.value)||10,1,200);\n  const min = Number(minVal.value)||0;\n  const max = Number(maxVal.value)||99;\n  array = genRandomArray(size, Math.min(min,max), Math.max(min,max));\n  setArray(array);\n});\n\ngenSorted.addEventListener('click', () => {\n  const size = clamp(Number(sizeInput.value)||10,1,200);\n  const min = Number(minVal.value)||0;\n  const max = Number(maxVal.value)||99;\n  const a = [];\n  for (let i=0;i<size;i++) a.push(min + Math.floor((max-min)*(i/(Math.max(1,size-1)))));\n  setArray(a);\n});\n\ngenReversed.addEventListener('click', () => {\n  const size = clamp(Number(sizeInput.value)||10,1,200);\n  const min = Number(minVal.value)||0;\n  const max = Number(maxVal.value)||99;\n  const a = [];\n  for (let i=0;i<size;i++) a.push(max - Math.floor((max-min)*(i/(Math.max(1,size-1)))));\n  setArray(a);\n});\n\ngenDuplicates.addEventListener('click', () => {\n  const size = clamp(Number(sizeInput.value)||10,1,200);\n  const vals = [];\n  for (let i=0;i<Math.max(2,Math.floor(size/3));i++) vals.push(randomInt(Number(minVal.value)||0, Number(maxVal.value)||99));\n  const a = [];\n  for (let i=0;i<size;i++) a.push(vals[i % vals.length]);\n  setArray(a);\n});\n\napplyCustom.addEventListener('click', () => {\n  const parsed = parseArrayInput(customArrayInput.value);\n  if (!parsed.length) { alert('No numbers parsed'); return; }\n  setArray(parsed);\n});\n\nclearArray.addEventListener('click', () => {\n  array = [];\n  initialArray = [];\n  renderArrayEditable();\n  resetPlayer();\n});\n\ngenerateTraceBtn.addEventListener('click', generateTrace);\n\nexportTraceBtn.addEventListener('click', () => {\n  if (!trace || trace.length===0) { alert('No trace to export'); return; }\n  const exportObj = {initialArray, algo: algoSelect.value, dir: dirSelect.value, trace, states};\n  const blob = new Blob([JSON.stringify(exportObj)], {type: 'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'merge_sort_trace.json';\n  document.body.appendChild(a);\n  a.click();\n  document.body.removeChild(a);\n  URL.revokeObjectURL(url);\n});\n\nimportTraceInput.addEventListener('change', (ev) => {\n  const file = ev.target.files[0];\n  if (!file) return;\n  const reader = new FileReader();\n  reader.onload = function(e) {\n    try {\n      const obj = JSON.parse(e.target.result);\n      if (!obj || !obj.states || !obj.trace) {\n        alert('Invalid trace file');\n        return;\n      }\n      initialArray = obj.initialArray || obj.array || [];\n      array = initialArray.slice();\n      trace = obj.trace;\n      states = obj.states;\n      callBoundaries = obj.callBoundaries || {};\n      preparePlayer({trace, states, callBoundaries});\n    } catch (err) { alert('Error parsing file: '+err.message); }\n  };\n  reader.readAsText(file);\n});\n\n// Playback controls\nstepPrev.addEventListener('click', stepBackward);\nstepNext.addEventListener('click', stepForward);\nstepInto.addEventListener('click', stepIntoFn);\nstepOver.addEventListener('click', stepOverFn);\nstepOut.addEventListener('click', stepOutFn);\nplayPause.addEventListener('click', playToggle);\nresetBtn.addEventListener('click', () => {\n  stopPlaying();\n  setArray(initialArray, false);\n  generateTrace();\n});\n\n// timeline and goto\ntimeline.addEventListener('input', (e) => {\n  setStep(Number(e.target.value));\n});\ngotoBtn.addEventListener('click', () => {\n  const idx = Number(gotoStep.value);\n  if (isNaN(idx)) return;\n  setStep(idx);\n});\n\n// dynamic options\nspeedRange.addEventListener('input', () => {\n  if (playing) {\n    stopPlaying();\n    startPlaying();\n  }\n});\ndetailRange.addEventListener('input', renderLog);\nshowRec.addEventListener('change', renderRecursionTree);\nshowStack.addEventListener('change', renderCallStack);\nshowLog.addEventListener('change', renderLog);\n\n// keyboard shortcuts\nwindow.addEventListener('keydown', (e) => {\n  if (e.key === 'ArrowRight') stepForward();\n  if (e.key === 'ArrowLeft') stepBackward();\n  if (e.key === ' ') { e.preventDefault(); playToggle(); }\n});\n\n// Initialize with random array\nsetArray(genRandomArray(10,0,99));\n\n// Small help in console\nconsole.log('Merge Sort Explorer ready. Use controls in the page to explore the trace.');\n\n/* End */\n})();\n</script>\n</body>\n</html>"
