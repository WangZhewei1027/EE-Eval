  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Digital Signatures Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input[type=text], input[type=password], select {\n    width: 100%;\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  button {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n  #log {\n    white-space: pre-wrap;\n    background: #eee;\n    padding: 0.5em;\n    height: 150px;\n    overflow-y: auto;\n    border: 1px solid #ccc;\n    font-size: 0.9em;\n  }\n  .hidden {\n    display: none;\n  }\n</style>\n</head>\n<body>\n<h1>Digital Signatures Interactive Demo</h1>\n\n<p>This demo allows you to explore digital signatures by:</p>\n<ul>\n  <li>Generating key pairs with selectable algorithm parameters</li>\n  <li>Signing arbitrary messages</li>\n  <li>Verifying signatures</li>\n  <li>Exploring the internals of keys, signatures, and hash values</li>\n  <li>Exporting/importing keys and signatures in various formats</li>\n  <li>Adjusting hash functions and encoding formats</li>\n</ul>\n\n<fieldset>\n  <legend>1. Choose Signature Algorithm Parameters</legend>\n\n  <label for=\"algoSelect\">Algorithm:</label>\n  <select id=\"algoSelect\" aria-label=\"Select signature algorithm\">\n    <option value=\"RSASSA-PKCS1-v1_5\">RSA PKCS#1 v1.5</option>\n    <option value=\"RSA-PSS\">RSA-PSS</option>\n    <option value=\"ECDSA\">ECDSA</option>\n  </select>\n\n  <label for=\"modulusLength\" id=\"labelModulusLength\">RSA modulus length (bits):</label>\n  <input type=\"range\" id=\"modulusLength\" min=\"512\" max=\"4096\" step=\"256\" value=\"2048\" aria-valuemin=\"512\" aria-valuemax=\"4096\" aria-valuenow=\"2048\" />\n  <span id=\"modulusLengthValue\">2048</span>\n\n  <label for=\"publicExponent\" id=\"labelPublicExponent\">RSA public exponent (hex):</label>\n  <input type=\"text\" id=\"publicExponent\" value=\"010001\" aria-label=\"RSA public exponent in hex\" />\n\n  <label for=\"namedCurve\" id=\"labelNamedCurve\" class=\"hidden\">ECDSA named curve:</label>\n  <select id=\"namedCurve\" class=\"hidden\" aria-label=\"ECDSA named curve\">\n    <option value=\"P-256\">P-256</option>\n    <option value=\"P-384\">P-384</option>\n    <option value=\"P-521\">P-521</option>\n  </select>\n\n  <label for=\"hashAlgo\">Hash Algorithm:</label>\n  <select id=\"hashAlgo\" aria-label=\"Hash Algorithm\">\n    <option value=\"SHA-256\">SHA-256</option>\n    <option value=\"SHA-384\">SHA-384</option>\n    <option value=\"SHA-512\">SHA-512</option>\n  </select>\n\n  <button id=\"generateKeysBtn\">Generate Key Pair</button>\n  <button id=\"exportKeysBtn\" disabled>Export Keys (PEM/JSON)</button>\n\n  <div id=\"keyDetails\" class=\"hidden\">\n    <h3>Key Details</h3>\n    <textarea id=\"publicKeyArea\" rows=\"6\" readonly aria-label=\"Public Key\"></textarea>\n    <textarea id=\"privateKeyArea\" rows=\"6\" readonly aria-label=\"Private Key\"></textarea>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>2. Compose Message to Sign</legend>\n  <textarea id=\"messageInput\" rows=\"5\" aria-label=\"Message to sign\">Hello, this is a test message for digital signature.</textarea>\n  <label><input type=\"checkbox\" id=\"inputIsHex\" /> Input message as HEX (ASCII if unchecked)</label>\n</fieldset>\n\n<fieldset>\n  <legend>3. Sign Message</legend>\n  <button id=\"signMessageBtn\" disabled>Sign Message</button>\n  <label><input type=\"checkbox\" id=\"encodeSigBase64\" checked /> Encode signature as Base64 (unchecked: hex)</label>\n  <label><input type=\"checkbox\" id=\"showSignatureDetails\" /> Show signature internals</label>\n  <div id=\"signatureDetails\" class=\"hidden\"></div>\n  <textarea id=\"signatureArea\" rows=\"4\" readonly aria-label=\"Signature\"></textarea>\n</fieldset>\n\n<fieldset>\n  <legend>4. Verify Signature</legend>\n  <label for=\"verifyMessageInput\">Message for verification:</label>\n  <textarea id=\"verifyMessageInput\" rows=\"4\" aria-label=\"Message for signature verification\">Hello, this is a test message for digital signature.</textarea>\n  <label><input type=\"checkbox\" id=\"verifyInputIsHex\" /> Input verification message as HEX (ASCII if unchecked)</label>\n\n  <label for=\"signatureInput\">Signature to verify:</label>\n  <textarea id=\"signatureInput\" rows=\"4\" aria-label=\"Signature input\"></textarea>\n  <label><input type=\"checkbox\" id=\"verifySigIsBase64\" checked /> Signature input is Base64 (unchecked: hex)</label>\n\n  <fieldset>\n    <legend>Verification Key Input</legend>\n    <label><input type=\"radio\" name=\"verifyKeySource\" value=\"pubkey\" checked /> Paste Public Key</label>\n    <label><input type=\"radio\" name=\"verifyKeySource\" value=\"privkey\" /> Paste Private Key (extract Pubkey)</label>\n    <label><input type=\"radio\" name=\"verifyKeySource\" value=\"generate\" /> Use Generated Key (if exists)</label>\n\n    <textarea id=\"verifyKeyArea\" rows=\"6\" aria-label=\"Verification key area\" placeholder=\"Paste public or private key here\"></textarea>\n  </fieldset>\n\n  <button id=\"verifySignatureBtn\">Verify Signature</button>\n  <div id=\"verifyResult\" aria-live=\"polite\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>5. Deep Exploration / Internals</legend>\n  <button id=\"showKeyInternalsBtn\" disabled>Show Key Internals</button>\n  <button id=\"showHashInternalsBtn\" disabled>Show Hash of Last Signed Message</button>\n\n  <pre id=\"internalsDisplay\" style=\"border: 1px solid #ccc; padding: 0.5em; max-height: 300px; overflow-y: auto;\"></pre>\n</fieldset>\n\n<fieldset>\n  <legend>6. Controls & Logs</legend>\n  <button id=\"clearAllBtn\">Reset All</button>\n\n  <h3>Event Log (latest events)</h3>\n  <div id=\"log\" aria-live=\"polite\" aria-atomic=\"false\"></div>\n</fieldset>\n\n<script>\n// Helper utilities\nfunction safeLog(msg) {\n  const logEl = document.getElementById('log');\n  const time = new Date().toLocaleTimeString();\n  logEl.textContent += `[${time}] ${msg}\\n`;\n  logEl.scrollTop = logEl.scrollHeight;\n}\n\nfunction ab2hex(buffer) {\n  let hex = '';\n  const view = new Uint8Array(buffer);\n  for (let i = 0; i < view.length; i++) {\n    hex += ('00' + view[i].toString(16)).slice(-2);\n  }\n  return hex;\n}\n\nfunction hex2ab(hex) {\n  if (hex.length % 2 !== 0) throw new Error('Invalid hex string');\n  const len = hex.length / 2;\n  const arr = new Uint8Array(len);\n  for (let i = 0; i < len; i++) {\n    arr[i] = parseInt(hex.substr(i * 2, 2), 16);\n    if (isNaN(arr[i])) throw new Error('Invalid hex string');\n  }\n  return arr.buffer;\n}\n\nfunction b64toArrayBuffer(base64) {\n  const binary_string = atob(base64);\n  const len = binary_string.length;\n  const bytes = new Uint8Array(len);\n  for (let i = 0; i < len; i++) {\n    bytes[i] = binary_string.charCodeAt(i);\n  }\n  return bytes.buffer;\n}\n\nfunction arrayBufferToBase64(buffer) {\n  let binary = '';\n  const bytes = new Uint8Array(buffer);\n  const len = bytes.byteLength;\n  for (let i = 0; i < len; i++) {\n    binary += String.fromCharCode(bytes[i]);\n  }\n  return btoa(binary);\n}\n\nfunction str2ab(str) {\n  const buf = new ArrayBuffer(str.length);\n  const bufView = new Uint8Array(buf);\n  for (let i=0, strLen=str.length; i < strLen; i++) {\n    bufView[i] = str.charCodeAt(i);\n  }\n  return buf;\n}\n\nfunction ab2str(buf) {\n  return String.fromCharCode.apply(null, new Uint8Array(buf));\n}\n\nasync function importRSAPublicKey(pem, algorithmName) {\n  // Remove header/footer and newlines\n  const cleanPem = pem.replace(/-----.*-----|\\s/g, '');\n  const binaryDerString = atob(cleanPem);\n  const binaryDer = new Uint8Array(binaryDerString.length);\n  for (let i = 0; i < binaryDerString.length; i++) {\n    binaryDer[i] = binaryDerString.charCodeAt(i);\n  }\n  try {\n    return await crypto.subtle.importKey(\n      'spki',\n      binaryDer.buffer,\n      {name: algorithmName, hash: {name: 'SHA-256'}},\n      true,\n      ['verify']\n    );\n  } catch (e) {\n    throw new Error('Invalid RSA public key format or unsupported algorithm.');\n  }\n}\n\nasync function importRSAPrivateKey(pem, algorithmName, usages) {\n  // Remove header/footer and newlines\n  const cleanPem = pem.replace(/-----.*-----|\\s/g, '');\n  const binaryDerString = atob(cleanPem);\n  const binaryDer = new Uint8Array(binaryDerString.length);\n  for (let i = 0; i < binaryDerString.length; i++) {\n    binaryDer[i] = binaryDerString.charCodeAt(i);\n  }\n  try {\n    return await crypto.subtle.importKey(\n      'pkcs8',\n      binaryDer.buffer,\n      {name: algorithmName, hash: {name: 'SHA-256'}},\n      true,\n      usages\n    );\n  } catch (e) {\n    throw new Error('Invalid RSA private key format or unsupported algorithm.');\n  }\n}\n\nasync function importECDSAPublicKey(pem, namedCurve) {\n  const cleanPem = pem.replace(/-----.*-----|\\s/g, '');\n  const binaryDerString = atob(cleanPem);\n  const binaryDer = new Uint8Array(binaryDerString.length);\n  for (let i = 0; i < binaryDerString.length; i++) {\n    binaryDer[i] = binaryDerString.charCodeAt(i);\n  }\n  try {\n    return await crypto.subtle.importKey(\n      'spki',\n      binaryDer.buffer,\n      {name: 'ECDSA', namedCurve: namedCurve},\n      true,\n      ['verify']\n    );\n  } catch (e) {\n    throw new Error('Invalid ECDSA public key format or unsupported algorithm.');\n  }\n}\n\nasync function importECDSAPrivateKey(pem, namedCurve) {\n  const cleanPem = pem.replace(/-----.*-----|\\s/g, '');\n  const binaryDerString = atob(cleanPem);\n  const binaryDer = new Uint8Array(binaryDerString.length);\n  for (let i = 0; i < binaryDerString.length; i++) {\n    binaryDer[i] = binaryDerString.charCodeAt(i);\n  }\n  try {\n    return await crypto.subtle.importKey(\n      'pkcs8',\n      binaryDer.buffer,\n      {name: 'ECDSA', namedCurve: namedCurve},\n      true,\n      ['sign']\n    );\n  } catch (e) {\n    throw new Error('Invalid ECDSA private key format or unsupported algorithm.');\n  }\n}\n\nfunction pemEncode(buffer, label) {\n  const base64Str = arrayBufferToBase64(buffer);\n  let pem = '-----BEGIN ' + label + '-----\\n';\n  for(let i=0; i<base64Str.length; i+=64) {\n    pem += base64Str.substr(i, 64) + '\\n';\n  }\n  pem += '-----END ' + label + '-----\\n';\n  return pem;\n}\n\nfunction parseHexInput(input) {\n  try { return hex2ab(input.trim().replace(/\\s+/g, '')); }\n  catch (e) { throw new Error('Invalid hex input'); }\n}\n\nfunction parseMessageInput(text, isHex) {\n  if(isHex) {\n    return parseHexInput(text);\n  }\n  else {\n    return str2ab(text);\n  }\n}\n\nfunction abEquals(a, b) {\n  if(a.byteLength !== b.byteLength) return false;\n  let viewA = new Uint8Array(a);\n  let viewB = new Uint8Array(b);\n  for(let i=0; i<viewA.length; i++) {\n    if(viewA[i] !== viewB[i]) return false;\n  }\n  return true;\n}\n\n// State\nlet currentKeyPair = null; // CryptoKeyPair\nlet lastSignedMessage = null; // ArrayBuffer\nlet lastSignature = null; // ArrayBuffer\nlet lastHash = null; // ArrayBuffer\nlet lastKeyDetails = null; // Object with decoded info\n\n// UI Elements\nconst algoSelect = document.getElementById('algoSelect');\nconst modulusLength = document.getElementById('modulusLength');\nconst modulusLengthValue = document.getElementById('modulusLengthValue');\nconst publicExponent = document.getElementById('publicExponent');\nconst namedCurve = document.getElementById('namedCurve');\nconst labelNamedCurve = document.getElementById('labelNamedCurve');\nconst labelModulusLength = document.getElementById('labelModulusLength');\nconst labelPublicExponent = document.getElementById('labelPublicExponent');\nconst hashAlgo = document.getElementById('hashAlgo');\nconst generateKeysBtn = document.getElementById('generateKeysBtn');\nconst exportKeysBtn = document.getElementById('exportKeysBtn');\nconst keyDetails = document.getElementById('keyDetails');\nconst publicKeyArea = document.getElementById('publicKeyArea');\nconst privateKeyArea = document.getElementById('privateKeyArea');\n\nconst messageInput = document.getElementById('messageInput');\nconst inputIsHex = document.getElementById('inputIsHex');\n\nconst signMessageBtn = document.getElementById('signMessageBtn');\nconst encodeSigBase64 = document.getElementById('encodeSigBase64');\nconst showSignatureDetails = document.getElementById('showSignatureDetails');\nconst signatureDetails = document.getElementById('signatureDetails');\nconst signatureArea = document.getElementById('signatureArea');\n\nconst verifyMessageInput = document.getElementById('verifyMessageInput');\nconst verifyInputIsHex = document.getElementById('verifyInputIsHex');\nconst signatureInput = document.getElementById('signatureInput');\nconst verifySigIsBase64 = document.getElementById('verifySigIsBase64');\nconst verifySignatureBtn = document.getElementById('verifySignatureBtn');\nconst verifyResult = document.getElementById('verifyResult');\nconst verifyKeyArea = document.getElementById('verifyKeyArea');\nconst verifyKeySourceButtons = document.getElementsByName('verifyKeySource');\n\nconst showKeyInternalsBtn = document.getElementById('showKeyInternalsBtn');\nconst showHashInternalsBtn = document.getElementById('showHashInternalsBtn');\nconst internalsDisplay = document.getElementById('internalsDisplay');\n\nconst clearAllBtn = document.getElementById('clearAllBtn');\n\n// UI State logic\nfunction updateAlgoControls(){\n  const algo = algoSelect.value;\n  if(algo === 'ECDSA'){\n    modulusLength.classList.add('hidden');\n    publicExponent.parentElement.classList.add('hidden');\n    labelModulusLength.classList.add('hidden');\n    labelPublicExponent.classList.add('hidden');\n    namedCurve.classList.remove('hidden');\n    labelNamedCurve.classList.remove('hidden');\n  }\n  else {\n    modulusLength.classList.remove('hidden');\n    publicExponent.parentElement.classList.remove('hidden');\n    labelModulusLength.classList.remove('hidden');\n    labelPublicExponent.classList.remove('hidden');\n    namedCurve.classList.add('hidden');\n    labelNamedCurve.classList.add('hidden');\n  }\n}\nfunction updateModulusLengthLabel(){\n  modulusLengthValue.textContent = modulusLength.value;\n  modulusLength.setAttribute('aria-valuenow', modulusLength.value);\n}\n\nalgoSelect.addEventListener('change', ()=>{\n  updateAlgoControls();\n  updateModulusLengthLabel();\n  resetKeyState();\n  safeLog(`Algorithm changed to ${algoSelect.value}`);\n});\nmodulusLength.addEventListener('input', updateModulusLengthLabel);\n\nfunction resetKeyState(){\n  currentKeyPair = null;\n  lastSignedMessage = null;\n  lastSignature = null;\n  lastHash = null;\n  lastKeyDetails = null;\n  keyDetails.classList.add('hidden');\n  publicKeyArea.value = '';\n  privateKeyArea.value = '';\n  signatureArea.value = '';\n  signatureDetails.classList.add('hidden');\n  signatureDetails.textContent = '';\n  showKeyInternalsBtn.disabled = true;\n  showHashInternalsBtn.disabled = true;\n  exportKeysBtn.disabled = true;\n  signMessageBtn.disabled = true;\n  safeLog('State reset.');\n}\nclearAllBtn.addEventListener('click', () => {\n  resetKeyState();\n  messageInput.value = '';\n  inputIsHex.checked = false;\n  verifyMessageInput.value = '';\n  verifyInputIsHex.checked = false;\n  signatureInput.value = '';\n  verifySigIsBase64.checked = true;\n  verifyKeyArea.value = '';\n  verifyResult.textContent = '';\n  internalsDisplay.textContent = '';\n  safeLog('All fields reset.');\n})\n\n// Key Generation\nasync function generateKeys(){\n  try {\n    const algo = algoSelect.value;\n    let algorithmParameters = null;\n    const hashName = hashAlgo.value;\n\n    if(algo === \"RSASSA-PKCS1-v1_5\"){\n      // Parse modulus length and public exponent\n      const mods = Number(modulusLength.value);\n      if(mods < 512 || mods > 4096) throw new Error('Invalid modulus length range');\n      let pubExpText = publicExponent.value.trim();\n      if(!/^[0-9a-fA-F]+$/.test(pubExpText)) throw new Error('Public exponent must be hex');\n      const pubExpBytes = hex2ab(pubExpText);\n      if (pubExpBytes.byteLength > 4) throw new Error(\"Public exponent too large\");\n      // Convert pubExpBytes to number\n      const pubExpView = new Uint8Array(pubExpBytes);\n      let pubExpNumber = 0;\n      for (let i=0; i<pubExpView.length; i++) {\n        pubExpNumber = (pubExpNumber<<8) + pubExpView[i];\n      }\n      if(pubExpNumber < 3) throw new Error('Public exponent too small');\n\n      algorithmParameters = {\n        name: algo,\n        modulusLength: mods,\n        publicExponent: new Uint8Array(pubExpBytes),\n        hash: {name: hashName}\n      };\n    } else if (algo === \"RSA-PSS\") {\n      // For RSA PSS we allow same params as RSASSA-PKCS1-v1_5\n      const mods = Number(modulusLength.value);\n      if(mods < 512 || mods > 4096) throw new Error('Invalid modulus length range');\n      let pubExpText = publicExponent.value.trim();\n      if(!/^[0-9a-fA-F]+$/.test(pubExpText)) throw new Error('Public exponent must be hex');\n      const pubExpBytes = hex2ab(pubExpText);\n      if (pubExpBytes.byteLength > 4) throw new Error(\"Public exponent too large\");\n      // Convert pubExpBytes to number\n      const pubExpView = new Uint8Array(pubExpBytes);\n      let pubExpNumber = 0;\n      for (let i=0; i<pubExpView.length; i++) {\n        pubExpNumber = (pubExpNumber<<8) + pubExpView[i];\n      }\n      if(pubExpNumber < 3) throw new Error('Public exponent too small');\n      algorithmParameters = {\n        name: algo,\n        modulusLength: mods,\n        publicExponent: new Uint8Array(pubExpBytes),\n        hash: {name: hashName}\n      };\n    } else if (algo === \"ECDSA\") {\n      const curveName = namedCurve.value;\n      algorithmParameters = {\n        name: \"ECDSA\",\n        namedCurve: curveName\n      };\n    } else {\n      throw new Error('Unsupported algorithm');\n    }\n\n    safeLog(`Generating key pair for ${algo} with hash ${hashName}...`);\n    currentKeyPair = await crypto.subtle.generateKey(\n      algorithmParameters,\n      true,\n      [\"sign\", \"verify\"]\n    );\n    safeLog('Key pair generated.');\n    showKeyPairDetails();\n    signMessageBtn.disabled = false;\n    exportKeysBtn.disabled = false;\n    showKeyInternalsBtn.disabled = false;\n  } catch (e){\n    alert(\"Key generation failed: \"+e.message);\n    safeLog('Key generation failed - ' + e.message);\n  }\n}\n\ngenerateKeysBtn.addEventListener('click', generateKeys);\n\nasync function exportCryptoKey(key){\n  if(!key) return null;\n  let format='pkcs8';\n  let label='';\n  let exportFormat='pem';\n  if(key.type === 'private') {\n    format='pkcs8';\n    label = key.algorithm.name === 'ECDSA' ? 'EC PRIVATE KEY' : 'PRIVATE KEY';\n  }\n  else if(key.type === 'public') {\n    format='spki';\n    label = key.algorithm.name === 'ECDSA' ? 'PUBLIC KEY' : 'PUBLIC KEY';\n  } else {\n    return null;\n  }\n  try {\n    const exported = await crypto.subtle.exportKey(format, key);\n    return pemEncode(exported, label);\n  } catch(e) {\n    return null;\n  }\n}\n\nasync function showKeyPairDetails(){\n  if(!currentKeyPair) return;\n  try {\n    const pubPem = await exportCryptoKey(currentKeyPair.public);\n    const privPem = await exportCryptoKey(currentKeyPair.private);\n    publicKeyArea.value = pubPem || '(Could not export public key)';\n    privateKeyArea.value = privPem || '(Could not export private key)';\n    keyDetails.classList.remove('hidden');\n  } catch(e) {\n    publicKeyArea.value = '(Error exporting public key)';\n    privateKeyArea.value = '(Error exporting private key)';\n    keyDetails.classList.remove('hidden');\n  }\n}\nexportKeysBtn.addEventListener('click', () => {\n  if(currentKeyPair){\n    alert(\"You can copy keys from the textareas under Key Details section.\");\n  }\n});\n\n// Signing\nasync function signMessage(){\n  if(!currentKeyPair){\n    alert('No key pair generated.');\n    return;\n  }\n  try {\n    const msgArrayBuffer = parseMessageInput(messageInput.value, inputIsHex.checked);\n    lastSignedMessage = msgArrayBuffer;\n    const algo = algoSelect.value;\n    const hashName = hashAlgo.value;\n\n    let signParams;\n\n    if(algo === 'RSASSA-PKCS1-v1_5') {\n      signParams = {name: \"RSASSA-PKCS1-v1_5\"};\n    } else if (algo === 'RSA-PSS') {\n      signParams = {\n        name: \"RSA-PSS\",\n        saltLength: 32\n      };\n    } else if (algo === 'ECDSA') {\n      signParams = {\n        name: 'ECDSA',\n        hash: {name: hashName}\n      };\n    } else {\n      throw new Error('Unsupported signing algorithm');\n    }\n\n    safeLog(`Signing message with ${algo} / ${hashName}...`);\n    const signature = await crypto.subtle.sign(\n      signParams,\n      currentKeyPair.private,\n      msgArrayBuffer\n    );\n    lastSignature = signature;\n\n    // Hash message for internals\n    lastHash = await crypto.subtle.digest(hashName, msgArrayBuffer);\n\n    let sigText;\n    if(encodeSigBase64.checked){\n      sigText = arrayBufferToBase64(signature);\n    } else {\n      sigText = ab2hex(signature);\n    }\n    signatureArea.value = sigText;\n    safeLog('Message signed.');\n\n    // Show signature internals if requested\n    if(showSignatureDetails.checked){\n      showSignatureInternalDetails(signature);\n    } else {\n      signatureDetails.classList.add('hidden');\n      signatureDetails.textContent = '';\n    }\n    showHashInternalsBtn.disabled = false;\n  } catch (e){\n    alert('Signing failed: '+e.message);\n    safeLog('Signing failed - ' + e.message);\n  }\n}\n\nsignMessageBtn.addEventListener('click', signMessage);\n\nfunction showSignatureInternalDetails(signature){\n  // For RSA and ECDSA signatures are just byte arrays,\n  // but ECDSA sig in DER; we can parse ECDSA signature r,s for exploration.\n\n  const algo = algoSelect.value;\n  if(algo === 'ECDSA'){\n    try {\n      const der = new Uint8Array(signature);\n\n      // Parse ASN.1 DER sequence to extract r and s\n      // Basic checks for DER sequence\n      if(der[0] !== 0x30) throw new Error('Not a valid DER sequence');\n      let length = der[1];\n      if(length & 0x80){ // long form length\n        const numOfLengthBytes = length & 0x7F;\n        length = 0;\n        for(let i=0; i<numOfLengthBytes; i++){\n          length = (length << 8) | der[2+i];\n        }\n      }\n      // The r and s integers follow\n      // Simple parse: 0x02 (integer), length, value\n\n      let offset = 2;\n      if((der[1]&0x80)!==0){\n        offset += (der[1]&0x7F);\n      }\n      if(der[offset] !== 0x02) throw new Error('Expected INTEGER for r');\n      let rLen = der[offset+1];\n      let r = der.slice(offset+2, offset+2+rLen);\n      offset += 2 + rLen;\n      if(der[offset] !== 0x02) throw new Error('Expected INTEGER for s');\n      let sLen = der[offset+1];\n      let s = der.slice(offset+2, offset+2+sLen);\n\n      signatureDetails.textContent = `ECDSA Signature components:\\nr (hex): ${Array.from(r).map(b=>b.toString(16).padStart(2,'0')).join('')}\\ns (hex): ${Array.from(s).map(b=>b.toString(16).padStart(2,'0')).join('')}`;\n      signatureDetails.classList.remove('hidden');\n    } catch (e) {\n      signatureDetails.textContent = 'Could not parse ECDSA signature internals: '+e.message;\n      signatureDetails.classList.remove('hidden');\n    }\n  } else if(algo === \"RSASSA-PKCS1-v1_5\" || algo === \"RSA-PSS\"){\n    signatureDetails.textContent = `Signature length: ${signature.byteLength} bytes\\nSignature (hex):\\n${ab2hex(signature)}`;\n    signatureDetails.classList.remove('hidden');\n  } else {\n    signatureDetails.textContent = 'No internals available for this algorithm.';\n    signatureDetails.classList.remove('hidden');\n  }\n}\n\n// Verification\nasync function verifySignature(){\n  try {\n    // Message input\n    const verifyMsgBuf = parseMessageInput(verifyMessageInput.value, verifyInputIsHex.checked);\n\n    // Signature input\n    let sigText = signatureInput.value.trim().replace(/\\s+/g, '');\n    if(sigText === '') {\n      alert('Please provide a signature to verify.');\n      return;\n    }\n    let sigBuf;\n    if(verifySigIsBase64.checked){\n      sigBuf = b64toArrayBuffer(sigText);\n    }\n    else {\n      sigBuf = parseHexInput(sigText);\n    }\n\n    // Choose verification key\n    let keySource = [...verifyKeySourceButtons].find(b => b.checked).value;\n\n    let verifyKey = null;\n    const algo = algoSelect.value;\n    const hashName = hashAlgo.value;\n\n    safeLog(`Starting signature verification using key source ${keySource}`);\n\n    if(keySource === \"generate\") {\n      if(!currentKeyPair){\n        alert('No generated key pair available for verification.');\n        return;\n      }\n      verifyKey = currentKeyPair.public;\n    } else {\n      let keyText = verifyKeyArea.value.trim();\n      if(!keyText) {\n        alert('Please provide a key in the key area.');\n        return;\n      }\n\n      if(algo === \"RSASSA-PKCS1-v1_5\" || algo === \"RSA-PSS\") {\n        if(keySource === \"pubkey\") {\n          // Import public key\n          verifyKey = await importRSAPublicKey(keyText, algo);\n        }\n        else if(keySource === \"privkey\") {\n          // Import private key, export public part (signatures cannot verify with private key alone)\n          let privKey = await importRSAPrivateKey(keyText, algo, ['sign']);\n          // Web Crypto currently does not provide exporting public key from privateKey, so we reject\n          alert('Verification using private key paste is not supported for RSA (please paste public key or generate keys).');\n          return;\n        }\n      } else if (algo === \"ECDSA\"){\n        if(keySource === \"pubkey\"){\n          verifyKey = await importECDSAPublicKey(keyText, namedCurve.value);\n        } else if (keySource === \"privkey\"){\n          alert('Verification using private key paste is not supported for ECDSA (please paste public key or generate keys).');\n          return;\n        }\n      }\n    }\n\n    if(!verifyKey){\n      alert('Verification key import failed or unsupported option selected.');\n      return;\n    }\n\n    // Determine verify params\n    let verifyParams;\n    if(algo === 'RSASSA-PKCS1-v1_5') {\n      verifyParams = {\n        name: \"RSASSA-PKCS1-v1_5\",\n      };\n    } else if (algo === 'RSA-PSS') {\n      verifyParams = {\n        name: \"RSA-PSS\",\n        saltLength: 32\n      };\n    } else if (algo === 'ECDSA') {\n      verifyParams = {\n        name: \"ECDSA\",\n        hash: {name: hashName}\n      };\n    } else {\n      throw new Error('Unsupported algorithm for verification.');\n    }\n\n    safeLog(`Verifying signature ...`);\n    const valid = await crypto.subtle.verify(\n      verifyParams,\n      verifyKey,\n      sigBuf,\n      verifyMsgBuf\n    );\n    verifyResult.textContent = valid ? \"Signature is VALID.\" : \"Signature is INVALID.\";\n\n    safeLog(`Verification result: ${valid ? \"VALID\" : \"INVALID\"}`);\n  }\n  catch(e){\n    alert('Verification error: ' + e.message);\n    safeLog('Verification failed: ' + e.message);\n    verifyResult.textContent = 'Verification failed: '+ e.message;\n  }\n}\n\nverifySignatureBtn.addEventListener('click', verifySignature);\n\n// Internals Exploration Buttons\nshowKeyInternalsBtn.addEventListener('click', async ()=> {\n  internalsDisplay.textContent = '';\n  if(!currentKeyPair) {\n    internalsDisplay.textContent = 'No key generated.';\n    return;\n  }\n  // Show key details internals\n  try {\n    internalsDisplay.textContent = 'Public Key (JWK):\\n';\n    const pubJwk = await crypto.subtle.exportKey('jwk', currentKeyPair.public);\n    internalsDisplay.textContent += JSON.stringify(pubJwk, null, 2) +'\\n\\n';\n    internalsDisplay.textContent += 'Private Key (JWK):\\n';\n    const privJwk = await crypto.subtle.exportKey('jwk', currentKeyPair.private);\n    internalsDisplay.textContent += JSON.stringify(privJwk, null, 2);\n  } catch(e) {\n    internalsDisplay.textContent = 'Error exporting keys as JWK: '+e.message;\n  }\n});\n\nshowHashInternalsBtn.addEventListener('click', () => {\n  internalsDisplay.textContent = '';\n  if(!lastHash){\n    internalsDisplay.textContent = 'No hash available. Sign a message first.';\n    return;\n  }\n  const hashHex = ab2hex(lastHash);\n  internalsDisplay.textContent = `Hash (${hashAlgo.value}) of last signed message:\\n${hashHex}`;\n});\n\n// Enable or disable buttons based on state\nmessageInput.addEventListener('input', () => {\n  signMessageBtn.disabled = !currentKeyPair || messageInput.value.trim() === '';\n});\n\ninputIsHex.addEventListener('change', () => {\n  // No direct effect on controls but reset signature display\n  signatureArea.value = '';\n  signatureDetails.classList.add('hidden');\n  signatureDetails.textContent = '';\n});\n\nencodeSigBase64.addEventListener('change', () => {\n  // If signature exists, re-encode & show\n  if(lastSignature){\n    if(encodeSigBase64.checked){\n      signatureArea.value = arrayBufferToBase64(lastSignature);\n    } else {\n      signatureArea.value = ab2hex(lastSignature);\n    }\n  }\n});\n\nshowSignatureDetails.addEventListener('change', () => {\n  if(showSignatureDetails.checked && lastSignature){\n    showSignatureInternalDetails(lastSignature);\n  } else {\n    signatureDetails.classList.add('hidden');\n    signatureDetails.textContent = '';\n  }\n});\n\nwindow.addEventListener('load', ()=> {\n  updateAlgoControls();\n  updateModulusLengthLabel();\n  resetKeyState();\n});\n</script>\n</body>\n</html>"
  },
