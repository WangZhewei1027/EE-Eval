    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Multiset Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        input, button, select {\n            margin-top: 10px;\n            margin-bottom: 10px;\n            padding: 5px;\n        }\n        #multisetView {\n            border-top: 1px solid black;\n            margin-top: 20px;\n            padding-top: 10px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Multiset Interactive Demo</h1>\n\n<h3>Add Item</h3>\n<input type=\"text\" id=\"itemInput\" placeholder=\"Enter item name\">\n<input type=\"number\" id=\"countInput\" value=\"1\" min=\"1\" placeholder=\"Count\">\n<button onclick=\"addItem()\">Add</button>\n\n<h3>Remove Item</h3>\n<input type=\"text\" id=\"removeItemInput\" placeholder=\"Enter item to remove\">\n<input type=\"number\" id=\"removeCountInput\" value=\"1\" min=\"1\" placeholder=\"Count\">\n<button onclick=\"removeItem()\">Remove</button>\n\n<h3>Current Multiset</h3>\n<div id=\"multisetView\"></div>\n\n<h3>Search Item</h3>\n<input type=\"text\" id=\"searchInput\" placeholder=\"Enter item to search\">\n<button onclick=\"searchItem()\">Search</button>\n<div id=\"searchResult\"></div>\n\n<h3>Clear Multiset</h3>\n<button onclick=\"clearMultiset()\">Clear All</button>\n\n<script>\n    let multiset = {};\n\n    function addItem() {\n        const itemName = document.getElementById('itemInput').value.trim();\n        const itemCount = parseInt(document.getElementById('countInput').value);\n        if (itemName && itemCount > 0) {\n            if (multiset[itemName]) {\n                multiset[itemName] += itemCount;\n            } else {\n                multiset[itemName] = itemCount;\n            }\n            updateMultisetView();\n            document.getElementById('itemInput').value = '';\n            document.getElementById('countInput').value = '1';\n        }\n    }\n\n    function removeItem() {\n        const itemName = document.getElementById('removeItemInput').value.trim();\n        const itemCount = parseInt(document.getElementById('removeCountInput').value);\n        if (itemName && itemCount > 0 && multiset[itemName]) {\n            multiset[itemName] -= itemCount;\n            if (multiset[itemName] <= 0) {\n                delete multiset[itemName];\n            }\n            updateMultisetView();\n            document.getElementById('removeItemInput').value = '';\n            document.getElementById('removeCountInput').value = '1';\n        }\n    }\n\n    function searchItem() {\n        const searchTerm = document.getElementById('searchInput').value.trim();\n        const result = multiset[searchTerm] !== undefined ? multiset[searchTerm] : 0;\n        document.getElementById('searchResult').innerText = `Count: ${result}`;\n    }\n\n    function clearMultiset() {\n        multiset = {};\n        updateMultisetView();\n    }\n\n    function updateMultisetView() {\n        const display = Object.entries(multiset)\n            .map(([key, value]) => `${key}: ${value}`)\n            .join(', ') || 'Multiset is empty';\n        document.getElementById('multisetView').innerText = display;\n    }\n</script>\n\n</body>\n</html>"
