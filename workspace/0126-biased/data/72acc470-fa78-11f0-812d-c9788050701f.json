    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Version Control | Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #6e48aa;\n            --secondary: #9d50bb;\n            --accent: #4776e6;\n            --dark: #1a1a2e;\n            --light: #f8f9fa;\n            --success: #4cc9f0;\n            --warning: #f72585;\n            --font-main: 'Inter', system-ui, sans-serif;\n            --font-display: 'Space Grotesk', sans-serif;\n        }\n\n        @font-face {\n            font-family: 'Inter';\n            font-style: normal;\n            font-weight: 300 700;\n            font-display: swap;\n            src: url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n        }\n\n        @font-face {\n            font-family: 'Space Grotesk';\n            font-style: normal;\n            font-weight: 400 700;\n            font-display: swap;\n            src: url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: var(--font-main);\n            background: linear-gradient(135deg, var(--dark) 0%, #16213e 100%);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            line-height: 1.6;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n\n        h1 {\n            font-family: var(--font-display);\n            font-size: 3.5rem;\n            font-weight: 700;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            line-height: 1.2;\n        }\n\n        .subtitle {\n            font-size: 1.25rem;\n            color: rgba(255, 255, 255, 0.7);\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .visualization {\n            display: grid;\n            grid-template-columns: 1fr;\n            gap: 4rem;\n            margin-top: 4rem;\n        }\n\n        .timeline {\n            position: relative;\n            height: 500px;\n            overflow: hidden;\n            border-radius: 16px;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.2);\n            padding: 2rem;\n        }\n\n        .timeline-line {\n            position: absolute;\n            left: 120px;\n            top: 0;\n            bottom: 0;\n            width: 4px;\n            background: linear-gradient(to bottom, var(--primary), var(--secondary));\n            border-radius: 2px;\n        }\n\n        .commit {\n            position: absolute;\n            left: 100px;\n            width: 40px;\n            height: 40px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, var(--accent), var(--primary));\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            box-shadow: 0 8px 20px rgba(110, 72, 170, 0.4);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            z-index: 2;\n        }\n\n        .commit::after {\n            content: '';\n            position: absolute;\n            left: 50px;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 600px;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.1);\n        }\n\n        .commit-details {\n            position: absolute;\n            left: 160px;\n            right: 2rem;\n            top: 50%;\n            transform: translateY(-50%);\n            opacity: 0;\n            pointer-events: none;\n            transition: all 0.4s ease;\n            padding: 1.5rem;\n            border-radius: 12px;\n            background: rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .commit:hover .commit-details {\n            opacity: 1;\n        }\n\n        .commit:hover {\n            transform: scale(1.2);\n        }\n\n        .commit-title {\n            font-family: var(--font-display);\n            font-size: 1.25rem;\n            margin-bottom: 0.5rem;\n            color: white;\n        }\n\n        .commit-meta {\n            display: flex;\n            gap: 1rem;\n            font-size: 0.85rem;\n            color: rgba(255, 255, 255, 0.7);\n            margin-bottom: 1rem;\n        }\n\n        .commit-desc {\n            font-size: 0.95rem;\n            line-height: 1.5;\n        }\n\n        .branch {\n            position: absolute;\n            left: 120px;\n            width: 4px;\n            background: var(--warning);\n            border-radius: 2px;\n            z-index: 1;\n        }\n\n        .branch-label {\n            position: absolute;\n            left: 130px;\n            font-family: var(--font-display);\n            font-weight: 600;\n            color: var(--warning);\n            font-size: 0.9rem;\n            padding: 0.25rem 0.75rem;\n            background: rgba(247, 37, 133, 0.2);\n            border-radius: 20px;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 3rem;\n        }\n\n        button {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.75rem 2rem;\n            font-family: var(--font-display);\n            font-weight: 600;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 10px 20px rgba(110, 72, 170, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 15px 30px rgba(110, 72, 170, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .animate-in {\n            animation: fadeInUp 0.8s ease forwards;\n        }\n\n        @keyframes fadeInUp {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        .git-graph {\n            display: flex;\n            justify-content: center;\n            margin-top: 4rem;\n            position: relative;\n            height: 400px;\n        }\n\n        .git-node {\n            position: absolute;\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            background: var(--success);\n            box-shadow: 0 0 0 4px rgba(76, 201, 240, 0.3);\n            transition: all 0.4s ease;\n        }\n\n        .git-connection {\n            position: absolute;\n            height: 2px;\n            background: rgba(76, 201, 240, 0.5);\n            transform-origin: left center;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            padding: 2rem 0;\n            color: rgba(255, 255, 255, 0.5);\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header class=\"animate-in\" style=\"animation-delay: 0.1s;\">\n            <h1>Version Control</h1>\n            <p class=\"subtitle\">A visual journey through the evolution of code, where every change tells a story and every commit preserves a moment in your project's history.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"timeline animate-in\" style=\"animation-delay: 0.3s;\">\n                <div class=\"timeline-line\"></div>\n                \n                <!-- Main branch -->\n                <div class=\"branch\" style=\"top: 80px; height: 340px;\"></div>\n                <div class=\"branch-label\" style=\"top: 80px;\">main</div>\n                \n                <!-- Commits -->\n                <div class=\"commit\" style=\"top: 80px;\">\n                    <span>1</span>\n                    <div class=\"commit-details\">\n                        <h3 class=\"commit-title\">Initial commit</h3>\n                        <div class=\"commit-meta\">\n                            <span>Author: Dev Designer</span>\n                            <span>Date: 2 days ago</span>\n                        </div>\n                        <p class=\"commit-desc\">Created project structure with basic configuration files and initial design concepts.</p>\n                    </div>\n                </div>\n                \n                <div class=\"commit\" style=\"top: 160px;\">\n                    <span>2</span>\n                    <div class=\"commit-details\">\n                        <h3 class=\"commit-title\">Added UI components</h3>\n                        <div class=\"commit-meta\">\n                            <span>Author: Dev Designer</span>\n                            <span>Date: 1 day ago</span>\n                        </div>\n                        <p class=\"commit-desc\">Implemented core UI components including navigation, buttons, and card layouts with responsive design.</p>\n                    </div>\n                </div>\n                \n                <div class=\"commit\" style=\"top: 240px;\">\n                    <span>3</span>\n                    <div class=\"commit-details\">\n                        <h3 class=\"commit-title\">Feature branch</h3>\n                        <div class=\"commit-meta\">\n                            <span>Author: Dev Designer</span>\n                            <span>Date: 12 hours ago</span>\n                        </div>\n                        <p class=\"commit-desc\">Created new feature branch to implement timeline visualization component without affecting main branch.</p>\n                    </div>\n                </div>\n                \n                <!-- Feature branch -->\n                <div class=\"branch\" style=\"top: 240px; height: 160px; background: var(--warning); left: 124px;\"></div>\n                <div class=\"branch-label\" style=\"top: 240px;\">feature/timeline</div>\n                \n                <div class=\"commit\" style=\"top: 280px; left: 124px;\">\n                    <span>4</span>\n                    <div class=\"commit-details\">\n                        <h3 class=\"commit-title\">Timeline styles</h3>\n                        <div class=\"commit-meta\">\n                            <span>Author: Dev Designer</span>\n                            <span>Date: 8 hours ago</span>\n                        </div>\n                        <p class=\"commit-desc\">Designed timeline visualization with smooth animations and interactive commit details.</p>\n                    </div>\n                </div>\n                \n                <div class=\"commit\" style=\"top: 360px; left: 124px;\">\n                    <span>5</span>\n                    <div class=\"commit-details\">\n                        <h3 class=\"commit-title\">Merge to main</h3>\n                        <div class=\"commit-meta\">\n                            <span>Author: Dev Designer</span>\n                            <span>Date: 1 hour ago</span>\n                        </div>\n                        <p class=\"commit-desc\">Completed timeline feature and merged changes back to main branch after code review.</p>\n                    </div>\n                </div>\n                \n                <div class=\"commit\" style=\"top: 420px;\">\n                    <span>6</span>\n                    <div class=\"commit-details\">\n                        <h3 class=\"commit-title\">Final polish</h3>\n                        <div class=\"commit-meta\">\n                            <span>Author: Dev Designer</span>\n                            <span>Date: Just now</span>\n                        </div>\n                        <p class=\"commit-desc\">Added finishing touches to the visualization, improved performance, and fixed minor UI issues.</p>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"git-graph animate-in\" style=\"animation-delay: 0.5s;\" id=\"gitGraph\">\n                <!-- Nodes will be added via JavaScript -->\n            </div>\n        </div>\n\n        <div class=\"controls animate-in\" style=\"animation-delay: 0.7s;\">\n            <button id=\"animateBtn\">Animate Graph</button>\n        </div>\n    </div>\n\n    <footer class=\"animate-in\" style=\"animation-delay: 0.9s;\">\n        Visualizing Version Control with Elegance\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create git graph visualization\n            const gitGraph = document.getElementById('gitGraph');\n            const width = gitGraph.offsetWidth;\n            const height = gitGraph.offsetHeight;\n            \n            // Main branch nodes\n            const mainNodes = [\n                { x: width * 0.2, y: height * 0.2, id: 'm1' },\n                { x: width * 0.35, y: height * 0.35, id: 'm2' },\n                { x: width * 0.5, y: height * 0.5, id: 'm3' },\n                { x: width * 0.65, y: height * 0.65, id: 'm4' },\n                { x: width * 0.8, y: height * 0.8, id: 'm5' }\n            ];\n            \n            // Feature branch nodes\n            const featureNodes = [\n                { x: width * 0.5, y: height * 0.5, id: 'f0' },\n                { x: width * 0.6, y: height * 0.4, id: 'f1' },\n                { x: width * 0.7, y: height * 0.3, id: 'f2' },\n                { x: width * 0.8, y: height * 0.4, id: 'f3' },\n                { x: width * 0.8, y: height * 0.8, id: 'f4' }\n            ];\n            \n            // Connections\n            const connections = [\n                { from: 'm1', to: 'm2', color: '#6e48aa' },\n                { from: 'm2', to: 'm3', color: '#6e48aa' },\n                { from: 'm3', to: 'f0', color: '#f72585' },\n                { from: 'f0', to: 'f1', color: '#f72585' },\n                { from: 'f1', to: 'f2', color: '#f72585' },\n                { from: 'f2', to: 'f3', color: '#f72585' },\n                { from: 'f3', to: 'f4', color: '#f72585' },\n                { from: 'm3', to: 'm4', color: '#6e48aa' },\n                { from: 'm4', to: 'm5', color: '#6e48aa' }\n            ];\n            \n            // Create nodes\n            [...mainNodes, ...featureNodes].forEach(node => {\n                const el = document.createElement('div');\n                el.className = 'git-node';\n                el.id = node.id;\n                el.style.left = `${node.x}px`;\n                el.style.top = `${node.y}px`;\n                el.style.opacity = '0';\n                gitGraph.appendChild(el);\n            });\n            \n            // Create connections\n            connections.forEach(conn => {\n                const fromEl = document.getElementById(conn.from);\n                const toEl = document.getElementById(conn.to);\n                \n                if (fromEl && toEl) {\n                    const fromRect = fromEl.getBoundingClientRect();\n                    const toRect = toEl.getBoundingClientRect();\n                    const graphRect = gitGraph.getBoundingClientRect();\n                    \n                    const fromX = fromRect.left + fromRect.width/2 - graphRect.left;\n                    const fromY = fromRect.top + fromRect.height/2 - graphRect.top;\n                    const toX = toRect.left + toRect.width/2 - graphRect.left;\n                    const toY = toRect.top + toRect.height/2 - graphRect.top;\n                    \n                    const length = Math.sqrt(Math.pow(toX - fromX, 2) + Math.pow(toY - fromY, 2));\n                    const angle = Math.atan2(toY - fromY, toX - fromX) * 180 / Math.PI;\n                    \n                    const connEl = document.createElement('div');\n                    connEl.className = 'git-connection';\n                    connEl.style.width = `${length}px`;\n                    connEl.style.left = `${fromX}px`;\n                    connEl.style.top = `${fromY}px`;\n                    connEl.style.transform = `rotate(${angle}deg)`;\n                    connEl.style.backgroundColor = conn.color;\n                    connEl.style.opacity = '0';\n                    gitGraph.appendChild(connEl);\n                }\n            });\n            \n            // Animate button\n            document.getElementById('animateBtn').addEventListener('click', function() {\n                animateGraph();\n                this.disabled = true;\n                setTimeout(() => {\n                    this.disabled = false;\n                }, 3000);\n            });\n            \n            // Initial animation\n            setTimeout(() => {\n                animateGraph();\n            }, 1500);\n            \n            function animateGraph() {\n                // Animate nodes\n                document.querySelectorAll('.git-node').forEach((node, i) => {\n                    setTimeout(() => {\n                        node.style.opacity = '1';\n                        node.style.transform = 'scale(1)';\n                    }, i * 150);\n                });\n                \n                // Animate connections\n                document.querySelectorAll('.git-connection').forEach((conn, i) => {\n                    setTimeout(() => {\n                        conn.style.opacity = '1';\n                        conn.style.width = conn.style.width;\n                    }, i * 150 + 300);\n                });\n            }\n        });\n    </script>\n</body>\n</html>"
