    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visualizing Sets</title>\n    <style>\n        :root {\n            --primary: #6a1b9a;\n            --secondary: #ffab00;\n            --tertiary: #00acc1;\n            --background: #f8f9fa;\n            --text: #212529;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', system-ui, sans-serif;\n            background-color: var(--background);\n            color: var(--text);\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            text-align: center;\n            color: var(--primary);\n            letter-spacing: -1px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            text-align: center;\n            margin-bottom: 3rem;\n            font-weight: 300;\n            color: #666;\n        }\n        \n        .visualization {\n            position: relative;\n            height: 70vh;\n            width: 100%;\n            margin-bottom: 3rem;\n        }\n        \n        .set {\n            position: absolute;\n            border-radius: 50%;\n            opacity: 0.8;\n            mix-blend-mode: multiply;\n            transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);\n            box-shadow: 0 20px 40px rgba(0,0,0,0.1);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            color: white;\n            text-shadow: 0 2px 4px rgba(0,0,0,0.2);\n        }\n        \n        .set-a {\n            background-color: var(--primary);\n            width: 300px;\n            height: 300px;\n            top: 50%;\n            left: 35%;\n            transform: translate(-50%, -50%);\n            z-index: 1;\n        }\n        \n        .set-b {\n            background-color: var(--secondary);\n            width: 280px;\n            height: 280px;\n            top: 50%;\n            left: 65%;\n            transform: translate(-50%, -50%);\n            z-index: 2;\n        }\n        \n        .intersection {\n            position: absolute;\n            background-color: var(--tertiary);\n            opacity: 0;\n            border-radius: 50%;\n            width: 0px;\n            height: 0px;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            z-index: 3;\n            transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);\n            box-shadow: 0 20px 40px rgba(0,0,0,0.1);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            text-shadow: 0 2px 4px rgba(0,0,0,0.2);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            padding: 0.8rem 1.6rem;\n            background: linear-gradient(135deg, var(--primary), #9c27b0);\n            color: white;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 15px rgba(0,0,0,0.15);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        button.secondary {\n            background: linear-gradient(135deg, #666, #888);\n        }\n        \n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n        }\n        \n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n        \n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n        }\n        \n        .footer {\n            text-align: center;\n            margin-top: 4rem;\n            color: #666;\n            font-size: 0.9rem;\n        }\n        \n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n        \n        .element {\n            position: absolute;\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            background-color: white;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            box-shadow: 0 4px 8px rgba(0,0,0,0.1);\n            transition: all 0.6s ease;\n            z-index: 10;\n        }\n        \n        /* Set animation states */\n        .show-intersection .intersection {\n            opacity: 0.8;\n            width: 200px;\n            height: 200px;\n        }\n        \n        .show-intersection .set-a {\n            left: 30%;\n        }\n        \n        .show-intersection .set-b {\n            left: 70%;\n        }\n        \n        /* Floating animation for elements */\n        .element:nth-child(1) { top: 40%; left: 30%; animation: float 3s ease-in-out infinite; }\n        .element:nth-child(2) { top: 60%; left: 25%; animation: float 4s ease-in-out infinite 0.5s; }\n        .element:nth-child(3) { top: 55%; left: 40%; animation: float 3.5s ease-in-out infinite 0.2s; }\n        .element:nth-child(4) { top: 45%; left: 70%; animation: float 4.2s ease-in-out infinite 0.7s; }\n        .element:nth-child(5) { top: 60%; left: 75%; animation: float 3.8s ease-in-out infinite 0.3s; }\n        .element:nth-child(6) { top: 50%; left: 50%; animation: float 4.5s ease-in-out infinite; background-color: var(--tertiary); }\n        \n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .visualization {\n                height: 50vh;\n            }\n            \n            .set-a, .set-b {\n                width: 200px;\n                height: 200px;\n            }\n            \n            .show-intersection .intersection {\n                width: 150px;\n                height: 150px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Visualizing Sets</h1>\n        <p class=\"subtitle\">A beautiful demonstration of set theory concepts</p>\n        \n        <div class=\"visualization\" id=\"visualization\">\n            <div class=\"set set-a\">Set A</div>\n            <div class=\"set set-b\">Set B</div>\n            <div class=\"intersection\">A ∩ B</div>\n            \n            <div class=\"element\">1</div>\n            <div class=\"element\">2</div>\n            <div class=\"element\">3</div>\n            <div class=\"element\">4</div>\n            <div class=\"element\">5</div>\n            <div class=\"element\">6</div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"showIntersection\">Show Intersection</button>\n            <button class=\"secondary\" id=\"reset\">Reset</button>\n        </div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--primary);\"></div>\n                <span>Set A</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--secondary);\"></div>\n                <span>Set B</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--tertiary);\"></div>\n                <span>Intersection</span>\n            </div>\n        </div>\n        \n        <div class=\"footer\">\n            <p>An elegant visualization of set theory concepts</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const visualization = document.getElementById('visualization');\n            const showIntersectionBtn = document.getElementById('showIntersection');\n            const resetBtn = document.getElementById('reset');\n            \n            showIntersectionBtn.addEventListener('click', function() {\n                visualization.classList.add('show-intersection');\n                \n                // Animate elements to their proper sets\n                const elements = document.querySelectorAll('.element');\n                elements.forEach((el, index) => {\n                    if (index < 3) {\n                        el.style.backgroundColor = 'var(--primary)';\n                        el.style.color = 'white';\n                    } else if (index < 5) {\n                        el.style.backgroundColor = 'var(--secondary)';\n                        el.style.color = 'white';\n                    } else {\n                        el.style.backgroundColor = 'var(--tertiary)';\n                        el.style.color = 'white';\n                    }\n                });\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                visualization.classList.remove('show-intersection');\n                \n                // Reset elements\n                const elements = document.querySelectorAll('.element');\n                elements.forEach(el => {\n                    el.style.backgroundColor