  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Recursion Explorer — Interactive</title>\n<style>\n  /* Extremely minimal styling for layout and readability */\n  html,body{height:100%;margin:0;padding:8px;font-family:Arial,Helvetica,sans-serif;color:black;background:white;}\n  .row{display:flex;gap:8px;}\n  .col{flex:1;min-width:0;}\n  .panel{border:1px solid #000;padding:8px;margin-bottom:8px;}\n  label{display:block;margin-top:6px;}\n  input[type=number], select, textarea, input[type=text]{width:100%;}\n  button{margin-right:6px;margin-top:6px;}\n  .stack, .tree, .log{max-height:400px;overflow:auto;border:1px solid #000;padding:6px;margin-top:6px;white-space:pre-wrap;}\n  ul{margin:0;padding-left:18px;}\n  li{cursor:pointer;}\n  .node-selected{outline:1px dashed #000;}\n  .small{font-size:12px;}\n</style>\n</head>\n<body>\n<h2>Recursion Explorer (Interactive)</h2>\n<p class=\"small\">Demonstrate and explore recursion with many interactive controls. Use templates or enter a custom ternary-style recursive expression. The expression must be of the form: condition ? baseReturn : recursiveReturn, and use recurse(<expr>) inside the recursiveReturn. Parameter name: n. You may use Math.* and a branching variable b in generated templates.</p>\n\n<div class=\"row\">\n  <div class=\"col\">\n    <div class=\"panel\">\n      <strong>Controls</strong>\n      <label>Algorithm template\n        <select id=\"templateSelect\">\n          <option value=\"factorial\">Factorial</option>\n          <option value=\"fibonacci\">Fibonacci (naive)</option>\n          <option value=\"fibonacci-memo\">Fibonacci (memoizable variant)</option>\n          <option value=\"binary-tree\">Binary tree count (branching)</option>\n          <option value=\"k-ary-tree\">K-ary tree count (branching b)</option>\n          <option value=\"power\">Fast power (divide & conquer)</option>\n          <option value=\"custom\">Custom (enter expression)</option>\n        </select>\n      </label>\n\n      <label>Parameter n\n        <input type=\"number\" id=\"paramN\" value=\"6\" min=\"-10000\" step=\"1\">\n      </label>\n\n      <label>Branching factor (b) — used by k-ary templates\n        <input type=\"number\" id=\"branchB\" value=\"2\" min=\"1\" step=\"1\">\n      </label>\n\n      <label>Max allowed recursion depth (safety)\n        <input type=\"number\" id=\"maxDepth\" value=\"50\" min=\"1\" step=\"1\">\n      </label>\n\n      <label>Delay (ms) for auto-play\n        <input type=\"range\" id=\"delay\" min=\"0\" max=\"2000\" step=\"50\" value=\"300\">\n        <div class=\"small\">Delay: <span id=\"delayLabel\">300</span> ms</div>\n      </label>\n\n      <label><input type=\"checkbox\" id=\"memoize\"> Enable memoization (memo hits tracked)</label>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"fillTemplate\">Fill template into expression</button>\n        <button id=\"validateBtn\">Validate expression</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"runBtn\">Run (full)</button>\n        <button id=\"stepBtn\">Step (next)</button>\n        <button id=\"autoBtn\">Auto Run</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <button id=\"backBtn\">Back (rewind one step)</button>\n        <button id=\"resetBtn\">Reset</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"buildTreeBtn\">Build full recursion tree (no stepping)</button>\n        <button id=\"exportBtn\">Export tree JSON</button>\n        <button id=\"importBtn\">Import tree JSON</button>\n        <input type=\"file\" id=\"fileInput\" style=\"display:none\">\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Recursive Expression (ternary)</strong>\n      <p class=\"small\">Format: &lt;condition&gt; ? &lt;baseReturn&gt; : &lt;recursiveReturn&gt; — use recurse(...) inside recursiveReturn</p>\n      <textarea id=\"expr\" rows=\"4\">n<=1?1:n*recurse(n-1)</textarea>\n      <div style=\"margin-top:6px;\">\n        <label>Quick examples:\n          <button data-example=\"n<=1?1:n*recurse(n-1)\" class=\"exampleBtn\">Factorial</button>\n          <button data-example=\"n<=1?n:recurse(n-1)+recurse(n-2)\" class=\"exampleBtn\">Fibonacci</button>\n          <button data-example=\"n<=0?1:recurse(n-1)+recurse(n-1)\" class=\"exampleBtn\">Binary tree count</button>\n          <button data-example=\"n<=0?1:recurse(Math.floor(n/2)) + recurse(Math.floor(n/2))\" class=\"exampleBtn\">Divide & conquer (2)</button>\n        </label>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Interactive hints</strong>\n      <ul>\n        <li>Use Step to move one significant event at a time (entering a call, creating a child, or returning a call).</li>\n        <li>Auto Run will proceed at the delay above. Pause will stop it.</li>\n        <li>Back rewinds one snapshot (state before last event).</li>\n        <li>Build full recursion tree bypasses stepping and quickly constructs the whole tree, useful for large trees (respecting max depth).</li>\n        <li>Export/Import tree JSON to save and explore later.</li>\n      </ul>\n    </div>\n\n  </div>\n\n  <div class=\"col\">\n    <div class=\"panel\">\n      <strong>Call Stack (frames)</strong>\n      <div class=\"stack\" id=\"stackView\"></div>\n      <div class=\"small\" id=\"stats\">Calls: 0 | Returns: 0 | Max depth: 0 | Memo hits: 0</div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Recursion Tree (click nodes to inspect)</strong>\n      <div class=\"tree\" id=\"treeView\"></div>\n      <div class=\"small\">Click a node to select it, see details and optionally force its return value on the right.</div>\n    </div>\n\n  </div>\n\n  <div class=\"col\">\n    <div class=\"panel\">\n      <strong>Selected Node Details</strong>\n      <div id=\"nodeDetails\" class=\"small\">No node selected.</div>\n      <div style=\"margin-top:6px;\">\n        <label>Force return value for selected node (applies if stepping paused): \n          <input type=\"text\" id=\"forceReturn\">\n        </label>\n        <div style=\"margin-top:6px;\">\n          <button id=\"applyForce\">Apply forced return</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Trace Log</strong>\n      <div class=\"log\" id=\"logView\"></div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Raw Function Pseudocode</strong>\n      <pre id=\"pseudocode\" class=\"small\"></pre>\n    </div>\n\n  </div>\n</div>\n\n<script>\n(function(){\n  // Minimal but feature-rich recursion exploration engine.\n  // State containers\n  let state = {\n    frames: [], // all frames by id\n    rootId: null,\n    stack: [], // call stack ids (current active path)\n    history: [], // snapshots for rewind\n    nextId: 1,\n    stats: {calls:0, returns:0, maxDepth:0, memoHits:0},\n    memo: {},\n    selectedNode: null,\n    running: false,\n    auto: false,\n    autoDelay: 300,\n    pausedResolve: null,\n    maxDepthLimit: 50\n  };\n\n  // DOM references\n  const templateSelect = document.getElementById('templateSelect');\n  const paramN = document.getElementById('paramN');\n  const branchB = document.getElementById('branchB');\n  const maxDepthInput = document.getElementById('maxDepth');\n  const delayEl = document.getElementById('delay');\n  const delayLabel = document.getElementById('delayLabel');\n  const memoizeCheck = document.getElementById('memoize');\n  const exprEl = document.getElementById('expr');\n  const stackView = document.getElementById('stackView');\n  const treeView = document.getElementById('treeView');\n  const logView = document.getElementById('logView');\n  const statsView = document.getElementById('stats');\n  const pseudocode = document.getElementById('pseudocode');\n  const runBtn = document.getElementById('runBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const autoBtn = document.getElementById('autoBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const backBtn = document.getElementById('backBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const buildTreeBtn = document.getElementById('buildTreeBtn');\n  const exportBtn = document.getElementById('exportBtn');\n  const importBtn = document.getElementById('importBtn');\n  const fileInput = document.getElementById('fileInput');\n  const fillTemplate = document.getElementById('fillTemplate');\n  const validateBtn = document.getElementById('validateBtn');\n  const exampleBtns = document.querySelectorAll('.exampleBtn');\n  const nodeDetails = document.getElementById('nodeDetails');\n  const forceReturn = document.getElementById('forceReturn');\n  const applyForce = document.getElementById('applyForce');\n\n  // Utility: deep clone via JSON (frames do not contain functions)\n  function cloneSnapshot(){\n    return JSON.parse(JSON.stringify({\n      frames: state.frames,\n      rootId: state.rootId,\n      stack: state.stack,\n      stats: state.stats,\n      memo: state.memo\n    }));\n  }\n  function restoreSnapshot(snap){\n    state.frames = snap.frames;\n    state.rootId = snap.rootId;\n    state.stack = snap.stack;\n    state.stats = snap.stats;\n    state.memo = snap.memo;\n    renderAll();\n  }\n\n  // Event wiring\n  delayEl.addEventListener('input', ()=>{ state.autoDelay = Number(delayEl.value); delayLabel.textContent = delayEl.value; });\n  maxDepthInput.addEventListener('change', ()=>{ state.maxDepthLimit = Number(maxDepthInput.value); });\n  fillTemplate.addEventListener('click', ()=> fillSelectedTemplate());\n  validateBtn.addEventListener('click', ()=> {\n    try { parseTernary(exprEl.value); alert('Expression parsed successfully.'); }\n    catch(e){ alert('Parse error: ' + e.message); }\n  });\n\n  runBtn.addEventListener('click', ()=> { startRun({auto:false, stepMode:false}); });\n  stepBtn.addEventListener('click', ()=> { startRun({auto:false, stepMode:true}); });\n  autoBtn.addEventListener('click', ()=> { startRun({auto:true, stepMode:false}); });\n  pauseBtn.addEventListener('click', ()=> { pauseRun(); });\n  backBtn.addEventListener('click', ()=> { rewindOne(); });\n  resetBtn.addEventListener('click', ()=> { resetState(); });\n\n  buildTreeBtn.addEventListener('click', ()=> { buildFullTreeQuick(); });\n\n  exportBtn.addEventListener('click', ()=> {\n    if(!state.rootId){ alert('No tree to export. Run something first.'); return; }\n    const dataStr = \"data:text/json;charset=utf-8,\" + encodeURIComponent(JSON.stringify({frames:state.frames,rootId:state.rootId}));\n    const dl = document.createElement('a'); dl.setAttribute('href', dataStr); dl.setAttribute('download','recursion_tree.json'); dl.click();\n  });\n  importBtn.addEventListener('click', ()=> { fileInput.click(); });\n  fileInput.addEventListener('change', (e)=> {\n    const file = e.target.files[0]; if(!file) return;\n    const reader = new FileReader();\n    reader.onload = ()=> {\n      try {\n        const obj = JSON.parse(reader.result);\n        state.frames = obj.frames || [];\n        state.rootId = obj.rootId || null;\n        state.stack = [];\n        state.history = [];\n        state.stats = {calls:0,returns:0,maxDepth:0,memoHits:0};\n        renderAll();\n      } catch(err){ alert('Import failed: '+err.message); }\n    };\n    reader.readAsText(file);\n  });\n\n  exampleBtns.forEach(btn=> btn.addEventListener('click', (e)=> { exprEl.value = e.target.getAttribute('data-example'); }));\n\n  treeView.addEventListener('click', (e)=> {\n    const li = e.target.closest('li');\n    if(!li) return;\n    const id = Number(li.dataset.id);\n    selectNode(id);\n  });\n\n  applyForce.addEventListener('click', ()=> { applyForcedReturn(); });\n\n  // Templates\n  function fillSelectedTemplate(){\n    const t = templateSelect.value;\n    const b = Number(branchB.value) || 2;\n    let s = '';\n    if(t === 'factorial') s = 'n<=1?1:n*recurse(n-1)';\n    else if(t === 'fibonacci') s = 'n<=1?n:recurse(n-1)+recurse(n-2)';\n    else if(t === 'fibonacci-memo') s = 'n<=1?n:recurse(n-1)+recurse(n-2)';\n    else if(t === 'binary-tree') s = 'n<=0?1:recurse(n-1)+recurse(n-1)';\n    else if(t === 'k-ary-tree') {\n      // generate recursive return with b calls\n      let calls = new Array(b).fill('recurse(n-1)').join('+');\n      s = 'n<=0?1:' + calls;\n    } else if(t === 'power') {\n      s = 'n===0?1:(n%2===0?recurse(Math.floor(n/2))*recurse(Math.floor(n/2)):recurse(Math.floor(n/2))*recurse(Math.floor(n/2))*2)';\n      // simpler: fast power variant (not perfect)\n    } else s = exprEl.value;\n    exprEl.value = s;\n    updatePseudocode();\n  }\n\n  templateSelect.addEventListener('change', ()=> {\n    // auto update expression for convenience\n    fillSelectedTemplate();\n  });\n\n  function updatePseudocode(){\n    const txt = 'function f(n) {\\n  return ' + exprEl.value + ';\\n}\\n\\n// Use recurse(...) inside the expression to call f recursively.\\n// This tool simulates evaluation step-by-step and builds a call tree.';\n    pseudocode.textContent = txt;\n  }\n  updatePseudocode();\n\n  // Parsing utility: parse top-level ternary into {cond, baseReturn, recursiveReturn}\n  function parseTernary(s){\n    // Remove outer spacing\n    const str = String(s).trim();\n    // Find top-level '?' and matching ':'\n    let depth = 0, qPos = -1, colonPos = -1;\n    for(let i=0;i<str.length;i++){\n      const ch = str[i];\n      if(ch === '(') depth++;\n      else if(ch === ')') depth--;\n      else if(ch === '?' && depth === 0){ qPos = i; break; }\n    }\n    if(qPos === -1) throw new Error('No top-level ? found in ternary expression.');\n    // find matching colon at depth 0 after qPos\n    depth = 0;\n    for(let i=qPos+1;i<str.length;i++){\n      const ch = str[i];\n      if(ch === '(') depth++;\n      else if(ch === ')') depth--;\n      else if(ch === ':' && depth === 0){ colonPos = i; break; }\n    }\n    if(colonPos === -1) throw new Error('No matching : found for ternary expression.');\n    const cond = str.slice(0,qPos).trim();\n    const base = str.slice(qPos+1, colonPos).trim();\n    const rec = str.slice(colonPos+1).trim();\n    if(!cond) throw new Error('Empty condition.');\n    if(!base) throw new Error('Empty baseReturn.');\n    if(!rec) throw new Error('Empty recursiveReturn.');\n    return {cond, base, rec};\n  }\n\n  // Find occurrences of recurse(...) at top-level of recursiveReturn (we will find all)\n  function findRecurseCalls(recStr){\n    const res = [];\n    for(let i=0;i<recStr.length;i++){\n      if(recStr.startsWith('recurse', i)){\n        // expect '(' next\n        let j = i+7;\n        while(j<recStr.length && recStr[j] === ' ') j++;\n        if(recStr[j] !== '(') { i = j; continue; }\n        let start = j;\n        // parse balanced parentheses\n        let depth = 0;\n        let k = j;\n        while(k<recStr.length){\n          const ch = recStr[k];\n          if(ch === '(') depth++;\n          else if(ch === ')') depth--;\n          k++;\n          if(depth === 0) break;\n        }\n        if(depth !== 0) throw new Error('Unbalanced parentheses in recurse call.');\n        const end = k; // exclusive\n        const inner = recStr.slice(start+1, end-1).trim();\n        res.push({start, end, inner, text: recStr.slice(i, end), index: i});\n        i = end-1;\n      }\n    }\n    return res;\n  }\n\n  // Safe evaluator helper: allow Math and n and b variables\n  function safeEval(expr, context){\n    // context: object with n, b\n    const n = context && context.n;\n    const b = context && context.b;\n    // Build function: limit characters? For simplicity we just evaluate; user is local.\n    try {\n      const fn = new Function('n','b','Math','return (' + expr + ')');\n      return fn(n,b,Math);\n    } catch(e){\n      throw new Error('Evaluation error: ' + e.message + ' (expr: ' + expr + ')');\n    }\n  }\n\n  // Frame creation\n  function createFrame(nValue, parentId, callExpr){\n    const id = state.nextId++;\n    const frame = {\n      id:id,\n      n: nValue,\n      parent: parentId || null,\n      callExpr: callExpr || null,\n      state: 'new', // new | entered | waitingChildren | returned\n      cond: null,\n      baseReturn: null,\n      recursiveReturn: null,\n      childPlaceholders: [], // {childId, innerExpr, childArgExpr}\n      result: undefined,\n      forced: false,\n      depth: parentId ? (getFrame(parentId).depth + 1) : 1\n    };\n    if(frame.depth > state.maxDepthLimit) throw new Error('Exceeded max depth limit (' + state.maxDepthLimit + '). Aborting to avoid runaway recursion.');\n    state.frames.push(frame);\n    state.stats.calls++;\n    if(frame.depth > state.stats.maxDepth) state.stats.maxDepth = frame.depth;\n    return frame;\n  }\n  function getFrame(id){ return state.frames.find(f=>f.id===id); }\n\n  // Render functions\n  function renderStack(){\n    const sb = [];\n    // show stack as current path to deepest active new/evaluating frame\n    const active = state.stack.slice();\n    if(active.length === 0) sb.push('(no active frames)');\n    else {\n      for(let i=active.length-1;i>=0;i--){ // show top first\n        const f = getFrame(active[i]);\n        if(!f) continue;\n        sb.push('#' + f.id + ' n=' + f.n + ' depth=' + f.depth + ' state=' + f.state + (f.result!==undefined ? ' result=' + JSON.stringify(f.result) : ''));\n      }\n    }\n    stackView.textContent = sb.join('\\n');\n  }\n\n  function buildTreeHtml(){\n    if(!state.rootId) { treeView.innerHTML = '(no tree)'; return; }\n    const root = getFrame(state.rootId);\n    function renderNode(f){\n      const li = document.createElement('li');\n      li.textContent = '#' + f.id + ' n=' + f.n + (f.result!==undefined ? ' => ' + JSON.stringify(f.result) : '') ;\n      li.dataset.id = f.id;\n      if(state.selectedNode === f.id) li.classList.add('node-selected');\n      if(f.childPlaceholders && f.childPlaceholders.length>0){\n        const ul = document.createElement('ul');\n        for(const ph of f.childPlaceholders){\n          const child = getFrame(ph.childId);\n          if(child) ul.appendChild(renderNode(child));\n        }\n        li.appendChild(ul);\n      }\n      return li;\n    }\n    const container = document.createElement('ul');\n    container.appendChild(renderNode(root));\n    treeView.innerHTML = '';\n    treeView.appendChild(container);\n  }\n\n  function renderLog(){\n    logView.textContent = state.log ? state.log.join('\\n') : '';\n  }\n\n  function renderStats(){\n    statsView.textContent = 'Calls: ' + state.stats.calls + ' | Returns: ' + state.stats.returns + ' | Max depth: ' + state.stats.maxDepth + ' | Memo hits: ' + state.stats.memoHits;\n  }\n\n  function renderSelectedDetails(){\n    if(!state.selectedNode){ nodeDetails.textContent = 'No node selected.'; return; }\n    const f = getFrame(state.selectedNode);\n    if(!f){ nodeDetails.textContent = 'Selected node not found.'; return; }\n    const lines = [];\n    lines.push('Frame #' + f.id);\n    lines.push('n = ' + f.n);\n    lines.push('depth = ' + f.depth);\n    lines.push('state = ' + f.state);\n    if(f.callExpr) lines.push('call expression: ' + f.callExpr);\n    if(f.cond!==null) lines.push('condition: ' + f.cond);\n    if(f.baseReturn!==null) lines.push('baseReturn: ' + f.baseReturn);\n    if(f.recursiveReturn!==null) lines.push('recursiveReturn: ' + f.recursiveReturn);\n    if(f.childPlaceholders && f.childPlaceholders.length>0){\n      lines.push('children: ' + f.childPlaceholders.map(c=>('#'+c.childId+' arg='+c.childArgExpr)).join(', '));\n    }\n    if(f.result !== undefined) lines.push('result: ' + JSON.stringify(f.result));\n    nodeDetails.textContent = lines.join('\\n');\n  }\n\n  function renderAll(){\n    renderStack();\n    buildTreeHtml();\n    renderLog();\n    renderStats();\n    renderSelectedDetails();\n    updatePseudocode();\n  }\n\n  // Logging helper\n  function logEvent(s){\n    if(!state.log) state.log = [];\n    const t = new Date().toISOString().split('T')[1].replace('Z','');\n    state.log.push('['+t+'] ' + s);\n    if(state.log.length > 1000) state.log.shift();\n  }\n\n  // Controller for stepping / auto-run\n  function waitForNext(){\n    return new Promise((resolve)=>{\n      if(state.auto){\n        // auto-run: resolve after delay\n        setTimeout(resolve, state.autoDelay);\n      } else {\n        // step mode or paused: set resolve to be called by user\n        state.pausedResolve = resolve;\n      }\n    }).then(()=>{ state.pausedResolve = null; });\n  }\n  function nextStep(){\n    if(state.pausedResolve) { state.pausedResolve(); state.pausedResolve = null; }\n  }\n\n  // Rewind: restore last snapshot if exists\n  function rewindOne(){\n    if(state.history.length <= 1){ alert('No earlier snapshot available.'); return; }\n    // remove last snapshot and restore previous\n    state.history.pop();\n    const snap = state.history[state.history.length-1];\n    restoreSnapshot(snap);\n    logEvent('Rewind one step.');\n  }\n\n  // Reset\n  function resetState(){\n    state.frames = [];\n    state.rootId = null;\n    state.stack = [];\n    state.history = [];\n    state.nextId = 1;\n    state.stats = {calls:0,returns:0,maxDepth:0,memoHits:0};\n    state.memo = {};\n    state.selectedNode = null;\n    state.log = [];\n    state.running = false;\n    state.auto = false;\n    if(state.pausedResolve) { state.pausedResolve(); state.pausedResolve = null; }\n    renderAll();\n  }\n  resetState();\n\n  // Node selection\n  function selectNode(id){\n    state.selectedNode = id;\n    renderAll();\n  }\n\n  // Apply forced return to selected node (only works if node is not yet returned and stepping paused)\n  function applyForcedReturn(){\n    if(!state.selectedNode){ alert('Select a node first.'); return; }\n    const f = getFrame(state.selectedNode);\n    if(!f) { alert('Selected node not found.'); return; }\n    if(f.state === 'returned'){ alert('Selected node already returned. Forced return can only apply to pending frames while stepping.'); return; }\n    const valStr = forceReturn.value;\n    if(!valStr){ alert('Enter a value to force.'); return; }\n    let v;\n    try { v = JSON.parse(valStr); } catch(e) {\n      // try evaluate as expression\n      try { v = safeEval(valStr, {n: f.n, b: Number(branchB.value)}); }\n      catch(err){ v = valStr; }\n    }\n    f.result = v;\n    f.forced = true;\n    f.state = 'returned';\n    state.stats.returns++;\n    // remove from stack if exists\n    const idx = state.stack.indexOf(f.id);\n    if(idx !== -1) state.stack.splice(idx,1);\n    logEvent('Forced return for #' + f.id + ' value=' + JSON.stringify(v));\n    // If parent waiting, substitute child into parent placeholder values\n    const parent = f.parent ? getFrame(f.parent) : null;\n    if(parent){\n      // find child's placeholder and mark as returned; parent evaluation will pick up it\n    }\n    // snapshot after forced return\n    state.history.push(cloneSnapshot());\n    renderAll();\n  }\n\n  // Engine to run simulation step-by-step using manual stack simulation\n  async function startRun(opts){\n    if(state.running && !opts.stepMode && !opts.auto){ /* if already running and user requested full run, ignore */ }\n    // Prepare new run\n    if(!state.running){\n      // Reset state for a fresh run\n      state.frames = [];\n      state.stack = [];\n      state.nextId = 1;\n      state.stats = {calls:0,returns:0,maxDepth:0,memoHits:0};\n      state.memo = {};\n      state.history = [];\n      state.log = [];\n      state.selectedNode = null;\n      state.rootId = null;\n      state.running = true;\n      state.auto = (!!opts.auto);\n      state.autoDelay = Number(delayEl.value);\n      state.maxDepthLimit = Number(maxDepthInput.value);\n      // Parse expression\n      let parsed;\n      try { parsed = parseTernary(exprEl.value); }\n      catch(e){ alert('Cannot start: ' + e.message); state.running = false; return; }\n      state.parsed = parsed;\n      // initial frame\n      const n0 = Number(paramN.value);\n      try {\n        const root = createFrame(n0, null, exprEl.value);\n        state.rootId = root.id;\n        // assign parsed parts to root (and will to all frames)\n        // push snapshot\n        state.history.push(cloneSnapshot());\n        logEvent('Run started. root n=' + n0 + ' parsed cond/base/rec set.');\n      } catch(e){ alert('Cannot create initial frame: ' + e.message); state.running = false; return; }\n    } else {\n      // If already running, update auto flag\n      state.auto = !!opts.auto;\n    }\n\n    renderAll();\n\n    // Execution loop: depth-first simulated evaluation with event steps\n    try {\n      await evaluateFrameDepthFirst(state.rootId, {stepMode: !!opts.stepMode});\n    } catch(e){\n      logEvent('Run aborted: ' + e.message);\n      alert('Run aborted: ' + e.message);\n    } finally {\n      state.running = false;\n      state.auto = false;\n      renderAll();\n    }\n  }\n\n  async function evaluateFrameDepthFirst(rootId, options){\n    // We'll maintain an explicit processing stack for frames to evaluate.\n    // Algorithm: push root, then loop:\n    // For top frame:\n    //  - if state === new: enter it -> evaluate condition; if base => set result return; else create child frames for each recurse(...) then continue (children pushed)\n    //  - if state === waitingChildren: check children; if all returned -> evaluate recursiveReturn with children substituted and set result\n    // Each significant action (enter, create child, child returned, parent returned) will produce a snapshot and possibly pause for step.\n    const maxSteps = 1000000;\n    let steps = 0;\n    const parsedRoot = state.parsed;\n    // helper to evaluate a frame's cond and prepare children\n    function prepareFrame(frame){\n      frame.callExpr = exprEl.value;\n      frame.cond = parsedRoot.cond;\n      frame.baseReturn = parsedRoot.base;\n      frame.recursiveReturn = parsedRoot.rec;\n    }\n\n    // We'll implement a custom stack that holds frame ids to process; but state.frames contains created frames.\n    const processStack = [rootId];\n\n    while(processStack.length > 0){\n      if(steps++ > maxSteps) throw new Error('Exceeded step limit.');\n      const currentId = processStack[processStack.length - 1];\n      const frame = getFrame(currentId);\n      if(!frame) { processStack.pop(); continue; }\n\n      // If frame is newly created, \"enter\" it.\n      if(frame.state === 'new'){\n        // Snapshot before action\n        prepareFrame(frame);\n        frame.state = 'entered';\n        state.stack.push(frame.id);\n        logEvent('Enter frame #' + frame.id + ' n=' + frame.n + ' depth=' + frame.depth);\n        // push snapshot after entering\n        state.history.push(cloneSnapshot());\n        renderAll();\n        // pause after entry\n        await waitForNext();\n\n        // Evaluate condition\n        let condResult;\n        try {\n          condResult = safeEval(frame.cond, {n: frame.n, b: Number(branchB.value)});\n        } catch(e){ throw new Error('Cond eval error in frame #' + frame.id + ': ' + e.message); }\n        // If cond true => evaluate baseReturn and return\n        if(condResult){\n          let val;\n          try { val = safeEval(frame.baseReturn, {n:frame.n, b: Number(branchB.value)}); }\n          catch(e){ throw new Error('Base return eval error in frame #' + frame.id + ': ' + e.message); }\n          frame.result = val;\n          frame.state = 'returned';\n          state.stats.returns++;\n          // pop from stack\n          const idx = state.stack.indexOf(frame.id); if(idx!==-1) state.stack.splice(idx,1);\n          logEvent('Frame #' + frame.id + ' base case -> result=' + JSON.stringify(val));\n          state.history.push(cloneSnapshot());\n          renderAll();\n          await waitForNext();\n          // after return, continue to next item (which is parent's frame)\n          processStack.pop();\n          continue;\n        } else {\n          // Not base case: find recurse(...) occurrences and create children\n          const recStr = frame.recursiveReturn;\n          const calls = findRecurseCalls(recStr);\n          frame.childPlaceholders = [];\n          if(calls.length === 0){\n            // No recurse found: we treat as error (cannot evaluate), but try to eval expression directly\n            let val;\n            try { val = safeEval(recStr, {n:frame.n, b: Number(branchB.value)}); }\n            catch(e){ throw new Error('No recurse found: cannot evaluate recursiveReturn in frame #' + frame.id + ': ' + e.message); }\n            frame.result = val;\n            frame.state = 'returned';\n            state.stats.returns++;\n            const idx = state.stack.indexOf(frame.id); if(idx!==-1) state.stack.splice(idx,1);\n            logEvent('Frame #' + frame.id + ' no recurse -> computed result=' + JSON.stringify(val));\n            state.history.push(cloneSnapshot());\n            renderAll();\n            await waitForNext();\n            processStack.pop();\n            continue;\n          }\n          // For each recurse(...) create child frames but push them so that first child is processed next (depth-first)\n          // We'll store placeholders in order of appearance\n          for(let i=0;i<calls.length;i++){\n            const call = calls[i];\n            // Evaluate argument expression into numeric value\n            let argVal;\n            try { argVal = safeEval(call.inner, {n: frame.n, b: Number(branchB.value)}); }\n            catch(e){ throw new Error('Child arg eval error in frame #' + frame.id + ': ' + e.message); }\n            // Memoization check\n            if(memoizeCheck.checked && state.memo.hasOwnProperty(String(argVal))){\n              // Create a synthetic child frame that is marked returned immediately using memo\n              const child = createFrame(argVal, frame.id, 'memoized');\n              child.state = 'returned';\n              child.result = state.memo[String(argVal)];\n              // push placeholder\n              frame.childPlaceholders.push({childId: child.id, childArgExpr: call.inner, returned:true});\n              state.stats.memoHits++;\n              logEvent('Memo hit for arg=' + argVal + ' used in parent #' + frame.id + ' -> child #' + child.id + ' result=' + JSON.stringify(child.result));\n              // snapshot\n              state.history.push(cloneSnapshot());\n            } else {\n              const child = createFrame(argVal, frame.id, call.text);\n              frame.childPlaceholders.push({childId: child.id, childArgExpr: call.inner, returned:false});\n              // push child to process stack\n              processStack.push(child.id);\n              logEvent('Created child #' + child.id + ' for parent #' + frame.id + ' arg=' + argVal);\n              state.history.push(cloneSnapshot());\n            }\n          }\n          frame.state = 'waitingChildren';\n          renderAll();\n          await waitForNext();\n          continue;\n        }\n      } else if(frame.state === 'waitingChildren'){\n        // Check if all children returned\n        let allReturned = true;\n        for(const ph of frame.childPlaceholders){\n          const child = getFrame(ph.childId);\n          if(!child || child.state !== 'returned'){\n            allReturned = false;\n            break;\n          }\n        }\n        if(!allReturned){\n          // Find the next child that is not returned, push it to processStack if not already\n          for(const ph of frame.childPlaceholders){\n            const child = getFrame(ph.childId);\n            if(child && child.state !== 'returned'){\n              // ensure it's on top of processStack\n              if(processStack[processStack.length-1] !== child.id) processStack.push(child.id);\n              break;\n            }\n          }\n          // loop continues\n          continue;\n        } else {\n          // All children returned: substitute their results into recursiveReturn and evaluate\n          let recExpr = frame.recursiveReturn;\n          // We'll replace each recurse(...) occurrence in order with a token, then substitute tokens with values.\n          const calls = findRecurseCalls(recExpr);\n          if(calls.length !== frame.childPlaceholders.length){\n            // This can happen if some children were memo or missing; but we will rebuild calls from placeholders\n            // Reconstruct by mapping placeholders order\n            // For safety, we replace occurrences sequentially by placeholder order.\n            let idx = 0;\n            for(const ph of frame.childPlaceholders){\n              const child = getFrame(ph.childId);\n              // replace first occurrence of recurse(...) with child result JSON string\n              recExpr = replaceFirstRecurse(recExpr, JSON.stringify(child.result));\n              idx++;\n            }\n          } else {\n            // Replace each call with its corresponding child result value (string)\n            // We'll replace from left to right\n            for(let i=0;i<calls.length;i++){\n              const ph = frame.childPlaceholders[i];\n              const child = getFrame(ph.childId);\n              // Replace the exact substring calls[i].text with child's JSON result\n              recExpr = recExpr.replace(calls[i].text, JSON.stringify(child.result));\n            }\n          }\n          // Now evaluate recExpr\n          let val;\n          try { val = safeEval(recExpr, {n: frame.n, b: Number(branchB.value)}); }\n          catch(e){ throw new Error('Recursive return eval error in frame #' + frame.id + ': ' + e.message); }\n          frame.result = val;\n          frame.state = 'returned';\n          state.stats.returns++;\n          // store to memo if enabled\n          if(memoizeCheck.checked) state.memo[String(frame.n)] = val;\n          // pop from stack\n          const idx = state.stack.indexOf(frame.id); if(idx!==-1) state.stack.splice(idx,1);\n          logEvent('Frame #' + frame.id + ' children returned -> result=' + JSON.stringify(val));\n          state.history.push(cloneSnapshot());\n          renderAll();\n          await waitForNext();\n          processStack.pop();\n          continue;\n        }\n      } else if(frame.state === 'returned'){\n        // nothing to do; pop\n        processStack.pop();\n        continue;\n      } else {\n        // unknown state: pop\n        processStack.pop();\n        continue;\n      }\n    }\n    // Completed evaluation\n    logEvent('Evaluation completed. Root result = ' + JSON.stringify(getFrame(rootId).result));\n    renderAll();\n  }\n\n  // Helper to replace first occurrence of recurse(...) with replacement\n  function replaceFirstRecurse(recExpr, replacement){\n    const calls = findRecurseCalls(recExpr);\n    if(calls.length === 0) return recExpr;\n    const first = calls[0];\n    return recExpr.slice(0, first.index) + replacement + recExpr.slice(first.end);\n  }\n\n  // Quick full tree builder (no step waiting) - iterative version that respects depth limit and memoization\n  function buildFullTreeQuick(){\n    resetState();\n    // parse\n    let parsed;\n    try { parsed = parseTernary(exprEl.value); }\n    catch(e){ alert('Cannot build: ' + e.message); return; }\n    state.parsed = parsed;\n    const n0 = Number(paramN.value);\n    try {\n      const root = createFrame(n0, null, exprEl.value);\n      state.rootId = root.id;\n    } catch(e){ alert('Cannot create root: ' + e.message); return; }\n    // Build recursively (but iterative stack)\n    const stack = [state.rootId];\n    while(stack.length){\n      const id = stack.pop();\n      const f = getFrame(id);\n      prepareFrameForQuick(f);\n      // Evaluate cond\n      let isBase;\n      try { isBase = safeEval(f.cond, {n: f.n, b: Number(branchB.value)}); }\n      catch(e){ alert('Eval error: ' + e.message); return; }\n      if(isBase){\n        try { f.result = safeEval(f.baseReturn, {n: f.n, b: Number(branchB.value)}); }\n        catch(e){ alert('Eval error base: ' + e.message); return; }\n        f.state = 'returned';\n        state.stats.returns++;\n        continue;\n      } else {\n        // find recurse calls\n        const calls = findRecurseCalls(f.recursiveReturn);\n        if(calls.length === 0){\n          try { f.result = safeEval(f.recursiveReturn, {n: f.n, b: Number(branchB.value)}); }\n          catch(e){ alert('Eval error rec: ' + e.message); return; }\n          f.state = 'returned';\n          state.stats.returns++;\n          continue;\n        }\n        // create children and push them\n        f.childPlaceholders = [];\n        for(const call of calls){\n          let arg;\n          try { arg = safeEval(call.inner, {n: f.n, b: Number(branchB.value)}); }\n          catch(e){ alert('Error evaluating child arg: ' + e.message); return; }\n          if(memoizeCheck.checked && state.memo.hasOwnProperty(String(arg))){\n            const child = createFrame(arg, f.id, 'memoized');\n            child.state = 'returned';\n            child.result = state.memo[String(arg)];\n            f.childPlaceholders.push({childId: child.id, childArgExpr: call.inner, returned:true});\n            state.stats.memoHits++;\n          } else {\n            const child = createFrame(arg, f.id, call.text);\n            f.childPlaceholders.push({childId: child.id, childArgExpr: call.inner, returned:false});\n            // push to stack for processing\n            stack.push(child.id);\n          }\n        }\n        // after children created, mark as waiting; we'll evaluate later when children done\n        f.state = 'waitingChildren';\n      }\n    }\n\n    // After all frames created, compute return values bottom-up\n    // Keep iterating until all frames returned\n    let progress = true;\n    while(progress){\n      progress = false;\n      for(const f of state.frames.slice()){\n        if(f.state === 'waitingChildren'){\n          const allReturned = f.childPlaceholders.every(ph=> {\n            const c=getFrame(ph.childId); return c && c.state==='returned';\n          });\n          if(allReturned){\n            // substitute\n            let recExpr = f.recursiveReturn;\n            const calls = findRecurseCalls(recExpr);\n            if(calls.length === f.childPlaceholders.length){\n              for(let i=0;i<calls.length;i++){\n                const child = getFrame(f.childPlaceholders[i].childId);\n                recExpr = recExpr.replace(calls[i].text, JSON.stringify(child.result));\n              }\n            } else {\n              // fallback sequential replacement\n              for(const ph of f.childPlaceholders){\n                const child = getFrame(ph.childId);\n                recExpr = replaceFirstRecurse(recExpr, JSON.stringify(child.result));\n              }\n            }\n            try { f.result = safeEval(recExpr, {n: f.n, b: Number(branchB.value)}); }\n            catch(e){ alert('Eval error while finalizing frame #' + f.id + ': ' + e.message); return; }\n            f.state = 'returned';\n            state.stats.returns++;\n            if(memoizeCheck.checked) state.memo[String(f.n)] = f.result;\n            progress = true;\n          }\n        } else if(f.state === 'new'){\n          // Might happen for isolated frames created but not processed; handle as enter+base\n          prepareFrameForQuick(f);\n          // Evaluate cond\n          let condRes;\n          try { condRes = safeEval(f.cond, {n: f.n, b: Number(branchB.value)}); }\n          catch(e){ alert('Eval error: ' + e.message); return; }\n          if(condRes){\n            try { f.result = safeEval(f.baseReturn, {n: f.n, b: Number(branchB.value)}); }\n            catch(e){ alert('Eval error base: ' + e.message); return; }\n            f.state = 'returned';\n            state.stats.returns++;\n            progress = true;\n          } else {\n            // create children if none\n            const calls = findRecurseCalls(f.recursiveReturn);\n            if(calls.length === 0){\n              try { f.result = safeEval(f.recursiveReturn, {n: f.n, b: Number(branchB.value)}); }\n              catch(e){ alert('Eval error rec: ' + e.message); return; }\n              f.state = 'returned';\n              state.stats.returns++;\n              progress = true;\n            } else {\n              f.childPlaceholders = [];\n              for(const call of calls){\n                let arg;\n                try { arg = safeEval(call.inner, {n: f.n, b: Number(branchB.value)}); }\n                catch(e){ alert('Error evaluating child arg: ' + e.message); return; }\n                if(memoizeCheck.checked && state.memo.hasOwnProperty(String(arg))){\n                  const child = createFrame(arg, f.id, 'memoized');\n                  child.state = 'returned';\n                  child.result = state.memo[String(arg)];\n                  f.childPlaceholders.push({childId: child.id, childArgExpr: call.inner, returned:true});\n                  state.stats.memoHits++;\n                } else {\n                  const child = createFrame(arg, f.id, call.text);\n                  f.childPlaceholders.push({childId: child.id, childArgExpr: call.inner, returned:false});\n                }\n              }\n              f.state = 'waitingChildren';\n              progress = true;\n            }\n          }\n        }\n      }\n    }\n\n    // Completed quick build\n    logEvent('Full recursion tree built. Root result = ' + JSON.stringify(getFrame(state.rootId).result));\n    state.history.push(cloneSnapshot());\n    renderAll();\n\n    function prepareFrameForQuick(f){\n      f.callExpr = exprEl.value;\n      f.cond = state.parsed.cond;\n      f.baseReturn = state.parsed.base;\n      f.recursiveReturn = state.parsed.rec;\n    }\n  }\n\n  // small helper to set parsed fields on frames (used earlier)\n  function prepareFrame(frame){\n    frame.cond = state.parsed.cond;\n    frame.baseReturn = state.parsed.base;\n    frame.recursiveReturn = state.parsed.rec;\n  }\n\n  // Pause run\n  function pauseRun(){\n    state.auto = false;\n    if(state.pausedResolve){ /* nothing to do - wait for next click */ }\n    logEvent('Run paused.');\n  }\n\n  // Keyboard shortcuts for stepping\n  document.addEventListener('keydown', (e)=>{\n    if(e.key === ' '){ // space to step\n      e.preventDefault();\n      nextStep();\n    } else if(e.key === 'ArrowRight'){\n      nextStep();\n    } else if(e.key === 'ArrowLeft'){\n      rewindOne();\n    }\n  });\n\n  // Expose next-step button behaviour\n  stepBtn.addEventListener('click', ()=> { nextStep(); });\n  autoBtn.addEventListener('click', ()=> { state.auto = true; logEvent('Auto-run on.'); });\n  pauseBtn.addEventListener('click', ()=> { state.auto = false; });\n\n  // Initialize UI\n  fillSelectedTemplate();\n  renderAll();\n\n})();\n</script>\n</body>\n</html>"
