    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>AVL Tree Interactive Demo</title>\n<style>\n  /* Extremely minimal styling: black text on white background, basic layout only */\n  html,body { margin: 8px; padding: 0; font-family: monospace; color: black; background: white; }\n  .row { display: flex; gap: 12px; align-items: flex-start; }\n  .col { display: flex; flex-direction: column; gap: 6px; }\n  label { font-size: 13px; }\n  input[type=\"text\"], input[type=\"number\"], textarea, select { font-family: monospace; font-size: 13px; }\n  button { font-size: 13px; }\n  #visual { border: 0px solid black; }\n  .log { width: 100%; height: 160px; overflow: auto; white-space: pre-wrap; border: 1px solid black; padding: 6px; background: white; }\n  .controls { border: 0px solid black; padding: 6px; }\n  .small { font-size: 12px; }\n  .info { font-size: 13px; border: 1px solid black; padding: 6px; background: white; }\n  /* Keep visuals plain: no colors or fancy styles */\n</style>\n</head>\n<body>\n<h2>AVL Tree — Interactive Demo</h2>\n\n<div class=\"row\">\n  <div class=\"col\" style=\"min-width:360px;max-width:540px;\">\n    <div class=\"controls\">\n      <div>\n        <label>Value (integer): <input id=\"valueInput\" type=\"number\" value=\"10\" /></label>\n        <button id=\"insertBtn\">Insert</button>\n        <button id=\"deleteBtn\">Delete</button>\n        <button id=\"findBtn\">Find</button>\n        <button id=\"selectFoundBtn\">Select Found</button>\n      </div>\n\n      <div>\n        <label>Bulk CSV (comma/space/newline):</label><br>\n        <textarea id=\"bulkInput\" rows=\"3\"></textarea><br>\n        <button id=\"bulkInsertBtn\">Bulk Insert</button>\n        <button id=\"clearBtn\">Clear Tree</button>\n      </div>\n\n      <div>\n        <label>Random count: <input id=\"randomCount\" type=\"range\" min=\"1\" max=\"50\" value=\"10\" /> <span id=\"randomCountLabel\">10</span></label>\n        <button id=\"randomGenBtn\">Generate Random & Insert</button>\n      </div>\n\n      <div>\n        <label>Mode: \n          <select id=\"modeSelect\">\n            <option value=\"live\">Live (apply immediately)</option>\n            <option value=\"step\">Step (generate detailed steps)</option>\n          </select>\n        </label>\n        <label class=\"small\">Show node heights/balance: <input id=\"showHB\" type=\"checkbox\" /></label>\n      </div>\n\n      <div>\n        <button id=\"stepPrevBtn\">Step Prev</button>\n        <button id=\"stepNextBtn\">Step Next</button>\n        <button id=\"stepAutoBtn\">Auto Play</button>\n        <button id=\"stepApplyAllBtn\">Apply All</button>\n        <button id=\"stepCancelBtn\">Cancel Steps</button>\n        <label class=\"small\">Speed: <input id=\"stepSpeed\" type=\"range\" min=\"100\" max=\"2000\" step=\"100\" value=\"600\" /> <span id=\"speedLabel\">600ms</span></label>\n      </div>\n\n      <div>\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n        <button id=\"exportBtn\">Export JSON</button>\n        <button id=\"importBtn\">Import JSON</button>\n        <input id=\"importArea\" placeholder=\"Paste JSON here\" style=\"width:100%\" />\n      </div>\n\n      <div>\n        <label>Manual rotate at value: <input id=\"rotateValue\" type=\"number\" /></label>\n        <button id=\"rotateLeftBtn\">Rotate Left</button>\n        <button id=\"rotateRightBtn\">Rotate Right</button>\n      </div>\n\n      <div>\n        <label>Traversal output (choose): \n          <select id=\"traversalSelect\">\n            <option value=\"inorder\">Inorder</option>\n            <option value=\"preorder\">Preorder</option>\n            <option value=\"postorder\">Postorder</option>\n            <option value=\"level\">Level order</option>\n          </select>\n        </label>\n        <button id=\"traverseBtn\">Traverse</button>\n      </div>\n\n      <div>\n        <label>Visualization mode:\n          <select id=\"vizMode\">\n            <option value=\"svg\">SVG tree</option>\n            <option value=\"text\">Text overview</option>\n          </select>\n        </label>\n      </div>\n    </div>\n\n    <div class=\"info\">\n      <div>Size: <span id=\"sizeLabel\">0</span> | Height: <span id=\"heightLabel\">0</span></div>\n      <div>Selected node: <span id=\"selectedLabel\">none</span> | Found: <span id=\"foundLabel\">none</span></div>\n    </div>\n\n    <div style=\"margin-top:8px;\">\n      <div id=\"visualContainer\">\n        <svg id=\"visual\" width=\"720\" height=\"380\"></svg>\n        <pre id=\"textView\" style=\"display:none; border:1px solid black; padding:8px; white-space:pre-wrap;\"></pre>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"col\" style=\"flex:1;min-width:300px;\">\n    <div class=\"info\" style=\"flex:1;\">\n      <div><strong>Step log / Messages</strong></div>\n      <div class=\"log\" id=\"log\"></div>\n      <div style=\"margin-top:6px;\">\n        <strong>Current step:</strong> <span id=\"stepIndex\">0</span> / <span id=\"stepCount\">0</span>\n      </div>\n    </div>\n\n    <div style=\"margin-top:8px;\">\n      <div class=\"info\">\n        <div><strong>Tree details</strong></div>\n        <div>Inorder: <span id=\"inorderLabel\"></span></div>\n        <div>Preorder: <span id=\"preorderLabel\"></span></div>\n        <div>Postorder: <span id=\"postorderLabel\"></span></div>\n        <div>Level-order: <span id=\"levelLabel\"></span></div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n/*\n  AVL Tree interactive demo\n  - Minimal visual style: black text on white background\n  - Many controls: insert, delete, find, bulk, random, step mode with detailed snapshots, manual rotations, undo/redo, export/import, traversals\n  - Visualization: simple SVG layout or textual\n  - Steps capture important algorithmic moments (insertion point, height updates, rotation pre/post)\n*/\n\n/* Data structures and utility functions */\n\nfunction Node(val) {\n  this.val = val;\n  this.left = null;\n  this.right = null;\n  this.height = 1;\n}\nfunction cloneNode(n) {\n  if (!n) return null;\n  const c = new Node(n.val);\n  c.height = n.height;\n  c.left = cloneNode(n.left);\n  c.right = cloneNode(n.right);\n  return c;\n}\n\n/* Compute height and balance */\nfunction height(n) {\n  return n ? n.height : 0;\n}\nfunction updateHeight(n) {\n  if (!n) return 0;\n  n.height = Math.max(height(n.left), height(n.right)) + 1;\n  return n.height;\n}\nfunction balanceFactor(n) {\n  return n ? height(n.left) - height(n.right) : 0;\n}\n\n/* Rotations */\nfunction rotateRight(y) {\n  const x = y.left;\n  const T2 = x.right;\n  x.right = y;\n  y.left = T2;\n  updateHeight(y);\n  updateHeight(x);\n  return x;\n}\nfunction rotateLeft(x) {\n  const y = x.right;\n  const T2 = y.left;\n  y.left = x;\n  x.right = T2;\n  updateHeight(x);\n  updateHeight(y);\n  return y;\n}\n\n/* Utility: clone whole root */\nfunction cloneRoot(root) { return cloneNode(root); }\n\n/* Global application state */\nlet root = null;\nlet historyStack = [];\nlet redoStack = [];\nlet selectedValue = null;\nlet foundValue = null;\n\n/* Step mode state */\nlet steps = []; // array of {root: snapshot, msg:string, highlight: array of values}\nlet currentStep = -1;\nlet autoPlayTimer = null;\n\n/* Logging utility */\nfunction logLine(s) {\n  const el = document.getElementById('log');\n  el.textContent = (el.textContent ? el.textContent + \"\\n\" : \"\") + s;\n  el.scrollTop = el.scrollHeight;\n}\n\n/* Save state for undo */\nfunction pushHistory() {\n  historyStack.push(cloneRoot(root));\n  if (historyStack.length > 200) historyStack.shift();\n  redoStack = [];\n  updateUndoRedoButtons();\n}\n\n/* Undo / Redo */\nfunction undo() {\n  if (historyStack.length === 0) return;\n  redoStack.push(cloneRoot(root));\n  root = historyStack.pop();\n  clearSteps();\n  updateAll();\n  logLine(\"Undo performed.\");\n  updateUndoRedoButtons();\n}\nfunction redo() {\n  if (redoStack.length === 0) return;\n  historyStack.push(cloneRoot(root));\n  root = redoStack.pop();\n  clearSteps();\n  updateAll();\n  logLine(\"Redo performed.\");\n  updateUndoRedoButtons();\n}\nfunction updateUndoRedoButtons() {\n  document.getElementById('undoBtn').disabled = historyStack.length === 0;\n  document.getElementById('redoBtn').disabled = redoStack.length === 0;\n}\n\n/* Find node and path (for highlighting) */\nfunction findWithPath(val) {\n  let node = root, path = [];\n  while (node) {\n    path.push(node.val);\n    if (val === node.val) return {found: true, path: path};\n    node = val < node.val ? node.left : node.right;\n  }\n  return {found: false, path: path};\n}\n\n/* Traversals */\nfunction inorderArr(n, out=[]) { if (!n) return out; inorderArr(n.left,out); out.push(n.val); inorderArr(n.right,out); return out; }\nfunction preorderArr(n, out=[]) { if (!n) return out; out.push(n.val); preorderArr(n.left,out); preorderArr(n.right,out); return out; }\nfunction postorderArr(n, out=[]) { if (!n) return out; postorderArr(n.left,out); postorderArr(n.right,out); out.push(n.val); return out; }\nfunction levelOrderArr(n) {\n  if (!n) return [];\n  const q=[n], out=[];\n  while(q.length){ const x=q.shift(); out.push(x.val); if(x.left) q.push(x.left); if(x.right) q.push(x.right); }\n  return out;\n}\n\n/* Insert with step capture (detailed) */\nfunction avlInsertWithSteps(rootNode, key, stepsArr) {\n  function insertRec(node) {\n    if (!node) {\n      const newNode = new Node(key);\n      stepsArr.push({root: cloneRoot(rootAfterInsertion(newNode)), msg: \"Inserted new node \" + key, highlight:[key]});\n      return newNode;\n    }\n    if (key === node.val) {\n      // duplicates not inserted\n      stepsArr.push({root: cloneRoot(rootAfterInsertion(null)), msg: \"Key \" + key + \" already exists; no insertion\", highlight:[node.val]});\n      return node;\n    }\n    if (key < node.val) {\n      node.left = insertRec(node.left);\n    } else {\n      node.right = insertRec(node.right);\n    }\n    updateHeight(node);\n    stepsArr.push({root: cloneRoot(rootAfterInsertion(null)), msg: \"Updated height at node \" + node.val + \" -> h=\" + node.height + \" (balance=\" + balanceFactor(node) + \")\", highlight:[node.val]});\n\n    const b = balanceFactor(node);\n    // Left Left\n    if (b > 1 && key < node.left.val) {\n      stepsArr.push({root: cloneRoot(rootBeforeRotation(node, \"right\")), msg: \"Left-Left case at \" + node.val + \" -> rotate right\", highlight:[node.val]});\n      const r = rotateRight(node);\n      stepsArr.push({root: cloneRoot(rootAfterRotation(r)), msg: \"After rotate right at \" + r.val, highlight:[r.val]});\n      return r;\n    }\n    // Right Right\n    if (b < -1 && key > node.right.val) {\n      stepsArr.push({root: cloneRoot(rootBeforeRotation(node, \"left\")), msg: \"Right-Right case at \" + node.val + \" -> rotate left\", highlight:[node.val]});\n      const r = rotateLeft(node);\n      stepsArr.push({root: cloneRoot(rootAfterRotation(r)), msg: \"After rotate left at \" + r.val, highlight:[r.val]});\n      return r;\n    }\n    // Left Right\n    if (b > 1 && key > node.left.val) {\n      stepsArr.push({root: cloneRoot(rootBeforeRotation(node, \"left-right\")), msg: \"Left-Right case at \" + node.val + \" -> rotate left at \" + node.left.val + \" then right at \" + node.val, highlight:[node.val,node.left.val]});\n      node.left = rotateLeft(node.left);\n      stepsArr.push({root: cloneRoot(rootAfterRotation(node.left)), msg: \"After rotate left at \" + node.left.val, highlight:[node.left.val]});\n      const r = rotateRight(node);\n      stepsArr.push({root: cloneRoot(rootAfterRotation(r)), msg: \"After rotate right at \" + r.val, highlight:[r.val]});\n      return r;\n    }\n    // Right Left\n    if (b < -1 && key < node.right.val) {\n      stepsArr.push({root: cloneRoot(rootBeforeRotation(node, \"right-left\")), msg: \"Right-Left case at \" + node.val + \" -> rotate right at \" + node.right.val + \" then left at \" + node.val, highlight:[node.val,node.right.val]});\n      node.right = rotateRight(node.right);\n      stepsArr.push({root: cloneRoot(rootAfterRotation(node.right)), msg: \"After rotate right at \" + node.right.val, highlight:[node.right.val]});\n      const r = rotateLeft(node);\n      stepsArr.push({root: cloneRoot(rootAfterRotation(r)), msg: \"After rotate left at \" + r.val, highlight:[r.val]});\n      return r;\n    }\n    return node;\n  }\n\n  // Helpers for descriptive snapshots: insertions occur in full tree context\n  function rootAfterInsertion(newNode) {\n    // We will clone the entire original root, but we want snapshots to reflect state as if insertion happened.\n    // To keep things consistent, we will generate snapshots based on actual current root variable plus newNode inserted in place.\n    // For simplicity snapshots refer to the global root plus any changes applied so far. We'll just return the current global root clone\n    // followed by applying the newNode at the end: but easier is to return the current global root clone (root) and modifications occur by recursion capturing actual node objects.\n    // This is a simplification: steps are informative sequence of tree clones; they are generated by cloning the tree variable as mutated by recursion.\n    return root; \n  }\n  function rootBeforeRotation(node, kind) { return root; }\n  function rootAfterRotation(newRootPart) { return root; }\n\n  // Because we want snapshot clones reflecting mutations as they happen, we'll mutate the actual \"root\" inside insert process.\n  // So to do that, we will call insertRec on the actual root variable and allow side effects.\n  const beforeClone = cloneRoot(root);\n  root = insertRec(root);\n  // Ensure heights updated for whole path already accounted by recursion\n  return;\n}\n\n/* Delete with steps - instrumented for steps similar style */\nfunction avlDeleteWithSteps(key, stepsArr) {\n  function minValueNode(node) {\n    let current = node;\n    while (current.left) current = current.left;\n    return current;\n  }\n  function deleteRec(node) {\n    if (!node) {\n      stepsArr.push({root: cloneRoot(root), msg:\"Key \"+key+\" not found for deletion\", highlight:[]});\n      return null;\n    }\n    if (key < node.val) {\n      node.left = deleteRec(node.left);\n    } else if (key > node.val) {\n      node.right = deleteRec(node.right);\n    } else {\n      // Node found\n      stepsArr.push({root: cloneRoot(root), msg:\"Deleting node \"+node.val, highlight:[node.val]});\n      if (!node.left || !node.right) {\n        const temp = node.left ? node.left : node.right;\n        if (!temp) {\n          // no child\n          node = null;\n          return null;\n        } else {\n          node = temp;\n        }\n      } else {\n        const temp = minValueNode(node.right);\n        const succVal = temp.val;\n        node.val = succVal;\n        stepsArr.push({root: cloneRoot(root), msg:\"Replaced value with inorder successor \"+succVal, highlight:[succVal]});\n        node.right = deleteRec(node.right);\n      }\n    }\n    if (!node) return node;\n    updateHeight(node);\n    stepsArr.push({root: cloneRoot(root), msg:\"Updated height at node \"+node.val+\" -> h=\"+node.height+\" (balance=\"+balanceFactor(node)+\")\", highlight:[node.val]});\n    const b = balanceFactor(node);\n    // Left Left\n    if (b > 1 && balanceFactor(node.left) >= 0) {\n      stepsArr.push({root: cloneRoot(root), msg:\"Left-Left case at \"+node.val+\" -> rotate right\", highlight:[node.val]});\n      const r = rotateRight(node);\n      stepsArr.push({root: cloneRoot(root), msg:\"After rotate right at \"+r.val, highlight:[r.val]});\n      return r;\n    }\n    // Left Right\n    if (b > 1 && balanceFactor(node.left) < 0) {\n      stepsArr.push({root: cloneRoot(root), msg:\"Left-Right case at \"+node.val+\" -> rotate left at \"+node.left.val+\" then right\", highlight:[node.val,node.left.val]});\n      node.left = rotateLeft(node.left);\n      stepsArr.push({root: cloneRoot(root), msg:\"After rotate left at \"+node.left.val, highlight:[node.left.val]});\n      const r = rotateRight(node);\n      stepsArr.push({root: cloneRoot(root), msg:\"After rotate right at \"+r.val, highlight:[r.val]});\n      return r;\n    }\n    // Right Right\n    if (b < -1 && balanceFactor(node.right) <= 0) {\n      stepsArr.push({root: cloneRoot(root), msg:\"Right-Right case at \"+node.val+\" -> rotate left\", highlight:[node.val]});\n      const r = rotateLeft(node);\n      stepsArr.push({root: cloneRoot(root), msg:\"After rotate left at \"+r.val, highlight:[r.val]});\n      return r;\n    }\n    // Right Left\n    if (b < -1 && balanceFactor(node.right) > 0) {\n      stepsArr.push({root: cloneRoot(root), msg:\"Right-Left case at \"+node.val+\" -> rotate right at \"+node.right.val+\" then left\", highlight:[node.val,node.right.val]});\n      node.right = rotateRight(node.right);\n      stepsArr.push({root: cloneRoot(root), msg:\"After rotate right at \"+node.right.val, highlight:[node.right.val]});\n      const r = rotateLeft(node);\n      stepsArr.push({root: cloneRoot(root), msg:\"After rotate left at \"+r.val, highlight:[r.val]});\n      return r;\n    }\n    return node;\n  }\n  root = deleteRec(root);\n}\n\n/* Manual rotation at node value (operate on ancestor pointer) */\nfunction manualRotateAt(val, dir) {\n  // dir: 'left' or 'right' apply rotation at node with value val (if exist)\n  // We need to find parent pointer to change subtree\n  function rotateAt(node, val) {\n    if (!node) return node;\n    if (val < node.val) node.left = rotateAt(node.left, val);\n    else if (val > node.val) node.right = rotateAt(node.right, val);\n    else {\n      // perform rotation at this node\n      if (dir === 'left') {\n        if (!node.right) {\n          logLine(\"Cannot rotate left at \" + val + \" because it has no right child.\");\n          return node;\n        }\n        const newRoot = rotateLeft(node);\n        logLine(\"Manual rotate left at \" + val + \" -> new root of subtree \" + newRoot.val);\n        return newRoot;\n      } else {\n        if (!node.left) {\n          logLine(\"Cannot rotate right at \" + val + \" because it has no left child.\");\n          return node;\n        }\n        const newRoot = rotateRight(node);\n        logLine(\"Manual rotate right at \" + val + \" -> new root of subtree \" + newRoot.val);\n        return newRoot;\n      }\n    }\n    updateHeight(node);\n    return node;\n  }\n  pushHistory();\n  root = rotateAt(root, val);\n  updateAll();\n}\n\n/* UI update functions: visualization and labels */\nfunction updateAll() {\n  document.getElementById('sizeLabel').textContent = inorderArr(root).length;\n  document.getElementById('heightLabel').textContent = root ? root.height : 0;\n  document.getElementById('selectedLabel').textContent = selectedValue === null ? 'none' : selectedValue;\n  document.getElementById('foundLabel').textContent = foundValue === null ? 'none' : foundValue;\n  updateTraversals();\n  renderTree();\n  updateUndoRedoButtons();\n}\n\n/* Render tree either as SVG or text */\nfunction renderTree(snapshotRoot, highlight=[]) {\n  const mode = document.getElementById('vizMode').value;\n  const showHB = document.getElementById('showHB').checked;\n  const svg = document.getElementById('visual');\n  const textView = document.getElementById('textView');\n  if (mode === 'text') {\n    svg.style.display = 'none';\n    textView.style.display = 'block';\n    const r = snapshotRoot !== undefined ? snapshotRoot : root;\n    textView.textContent = treeToASCII(r, showHB);\n    document.getElementById('visualContainer').scrollIntoView();\n    return;\n  }\n  // SVG mode\n  textView.style.display = 'none';\n  svg.style.display = 'block';\n  while (svg.firstChild) svg.removeChild(svg.firstChild);\n  const r = snapshotRoot !== undefined ? snapshotRoot : root;\n  if (!r) return;\n  // compute inorder positions\n  const nodes = [];\n  function inorderAssign(n, depth) {\n    if (!n) return;\n    inorderAssign(n.left, depth+1);\n    nodes.push({val:n.val, depth:depth, node:n});\n    inorderAssign(n.right, depth+1);\n  }\n  inorderAssign(r, 0);\n  // map to x positions by index\n  const indexMap = {};\n  nodes.forEach((item,i)=> indexMap[item.val]=i);\n  const spacingX = 60;\n  const spacingY = 70;\n  const padding = 30;\n  const width = Math.max(300, nodes.length * spacingX + padding*2);\n  const maxDepth = Math.max(...nodes.map(n=>n.depth))+1;\n  const height = Math.max(200, maxDepth*spacingY + padding*2);\n  svg.setAttribute('width', Math.min(1200, width));\n  svg.setAttribute('height', height);\n\n  // build positions by walking tree\n  const pos = {};\n  function assignPos(n, depth) {\n    if (!n) return;\n    assignPos(n.left, depth+1);\n    const i = indexMap[n.val];\n    pos[n.val] = {x: padding + i*spacingX + 10, y: padding + depth*spacingY};\n    assignPos(n.right, depth+1);\n  }\n  assignPos(r, 0);\n\n  // draw lines\n  function drawLines(n) {\n    if (!n) return;\n    if (n.left) {\n      const p = pos[n.val], c = pos[n.left.val];\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      line.setAttribute('x1', p.x);\n      line.setAttribute('y1', p.y);\n      line.setAttribute('x2', c.x);\n      line.setAttribute('y2', c.y);\n      line.setAttribute('stroke','black');\n      line.setAttribute('stroke-width', '1');\n      svg.appendChild(line);\n    }\n    if (n.right) {\n      const p = pos[n.val], c = pos[n.right.val];\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      line.setAttribute('x1', p.x);\n      line.setAttribute('y1', p.y);\n      line.setAttribute('x2', c.x);\n      line.setAttribute('y2', c.y);\n      line.setAttribute('stroke','black');\n      line.setAttribute('stroke-width', '1');\n      svg.appendChild(line);\n    }\n    drawLines(n.left); drawLines(n.right);\n  }\n  drawLines(r);\n\n  // draw nodes\n  function drawNodes(n) {\n    if (!n) return;\n    const p = pos[n.val];\n    const g = document.createElementNS(\"http://www.w3.org/2000/svg\",\"g\");\n    g.setAttribute('transform','translate('+p.x+','+p.y+')');\n    // circle\n    const circle = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n    circle.setAttribute('cx',0);\n    circle.setAttribute('cy',0);\n    circle.setAttribute('r',14);\n    circle.setAttribute('fill','white');\n    circle.setAttribute('stroke','black');\n    circle.setAttribute('stroke-width', highlight.includes(n.val) || n.val===selectedValue ? '3' : '1');\n    circle.style.cursor = \"pointer\";\n    circle.addEventListener('click', function(evt){\n      selectedValue = n.val;\n      document.getElementById('selectedLabel').textContent = selectedValue;\n      document.getElementById('rotateValue').value = selectedValue;\n      renderTree();\n    });\n    g.appendChild(circle);\n    // text\n    const txt = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n    txt.setAttribute('x',0);\n    txt.setAttribute('y',5);\n    txt.setAttribute('text-anchor','middle');\n    txt.setAttribute('font-size','11');\n    txt.textContent = n.val;\n    g.appendChild(txt);\n    // heights/balance\n    if (showHB) {\n      const hb = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n      hb.setAttribute('x',0);\n      hb.setAttribute('y',22);\n      hb.setAttribute('text-anchor','middle');\n      hb.setAttribute('font-size','9');\n      hb.textContent = \"h=\"+n.height+\"/b=\"+balanceFactor(n);\n      g.appendChild(hb);\n    }\n    svg.appendChild(g);\n    drawNodes(n.left); drawNodes(n.right);\n  }\n  drawNodes(r);\n}\n\n/* Create a simple ASCII tree representation */\nfunction treeToASCII(rootNode, showHB) {\n  if (!rootNode) return \"(empty)\";\n  // produce lines with positions\n  const lines = [];\n  function helper(n, prefix, isLeft) {\n    if (!n) return;\n    const line = prefix + (isLeft ? \"├─ \" : \"└─ \") + n.val + (showHB ? \" (h=\"+n.height+\",b=\"+balanceFactor(n)+\")\" : \"\");\n    lines.push(line);\n    const childPrefix = prefix + (isLeft ? \"│  \" : \"   \");\n    if (n.left || n.right) {\n      if (n.left) helper(n.left, childPrefix, true);\n      else if (n.right) lines.push(childPrefix + \"├─ \" + \"(null)\");\n      if (n.right) helper(n.right, childPrefix, false);\n      else if (n.left) lines.push(childPrefix + \"└─ \" + \"(null)\");\n    }\n  }\n  helper(rootNode, \"\", false);\n  return lines.join(\"\\n\");\n}\n\n/* Step control functions */\nfunction clearSteps() {\n  steps = [];\n  currentStep = -1;\n  stopAutoPlay();\n  updateStepUI();\n}\nfunction setStepsAndStart(newSteps) {\n  steps = newSteps;\n  currentStep = -1;\n  updateStepUI();\n  logLine(\"Generated \" + steps.length + \" step(s). Use Next/Prev to browse.\");\n}\nfunction showStep(index) {\n  if (index < 0 || index >= steps.length) return;\n  currentStep = index;\n  const s = steps[index];\n  document.getElementById('log').textContent = \"\"; // replace log while stepping to focus on step messages\n  logLine(\"Step \" + (index+1) + \": \" + s.msg);\n  // Render snapshot root clone if available; else render current root\n  if (s.root) renderTree(cloneNodeTreeForRender(s.root), s.highlight || []);\n  else renderTree(null, s.highlight || []);\n  document.getElementById('stepIndex').textContent = index+1;\n  document.getElementById('stepCount').textContent = steps.length;\n  // also show snapshot traversal info\n  const snapRoot = s.root ? cloneNodeTreeForRender(s.root) : root;\n  document.getElementById('inorderLabel').textContent = inorderArr(snapRoot).join(\",\");\n  document.getElementById('preorderLabel').textContent = preorderArr(snapRoot).join(\",\");\n  document.getElementById('postorderLabel').textContent = postorderArr(snapRoot).join(\",\");\n  document.getElementById('levelLabel').textContent = levelOrderArr(snapRoot).join(\",\");\n}\nfunction cloneNodeTreeForRender(node) {\n  // When steps were recorded we referred to global root clones or used root variable; to be safe clone nodes deeply\n  return cloneNode(node);\n}\nfunction stepNext() {\n  if (steps.length === 0) return;\n  if (currentStep < steps.length-1) {\n    showStep(currentStep+1);\n  } else {\n    logLine(\"Already at last step.\");\n  }\n}\nfunction stepPrev() {\n  if (steps.length === 0) return;\n  if (currentStep > 0) {\n    showStep(currentStep-1);\n  } else {\n    logLine(\"Already at first step.\");\n  }\n}\nfunction stepApplyAll() {\n  if (steps.length === 0) return;\n  pushHistory();\n  // Apply last snapshot (if contains a root clone) or leave root as is\n  const last = steps[steps.length-1];\n  if (last && last.root) {\n    root = cloneNode(last.root);\n    logLine(\"Applied final step to main tree.\");\n  } else {\n    logLine(\"Final step had no snapshot to apply.\");\n  }\n  clearSteps();\n  updateAll();\n}\nfunction stepCancel() {\n  clearSteps();\n  logLine(\"Steps cancelled.\");\n}\n\n/* Auto play */\nfunction autoPlayToggle() {\n  if (autoPlayTimer) { stopAutoPlay(); return; }\n  if (steps.length === 0) return;\n  autoPlayTimer = setInterval(function(){\n    if (currentStep >= steps.length-1) { stopAutoPlay(); return; }\n    stepNext();\n  }, parseInt(document.getElementById('stepSpeed').value,10));\n  document.getElementById('stepAutoBtn').textContent = \"Stop\";\n}\nfunction stopAutoPlay() {\n  if (autoPlayTimer) clearInterval(autoPlayTimer);\n  autoPlayTimer = null;\n  document.getElementById('stepAutoBtn').textContent = \"Auto Play\";\n}\n\n/* UI: update traversals display for current root */\nfunction updateTraversals() {\n  document.getElementById('inorderLabel').textContent = inorderArr(root).join(\",\");\n  document.getElementById('preorderLabel').textContent = preorderArr(root).join(\",\");\n  document.getElementById('postorderLabel').textContent = postorderArr(root).join(\",\");\n  document.getElementById('levelLabel').textContent = levelOrderArr(root).join(\",\");\n}\n\n/* Event handlers for controls */\ndocument.getElementById('insertBtn').addEventListener('click', function(){\n  const val = parseInt(document.getElementById('valueInput').value,10);\n  if (isNaN(val)) { logLine(\"Invalid value for insertion.\"); return; }\n  const mode = document.getElementById('modeSelect').value;\n  if (mode === 'live') {\n    pushHistory();\n    // Insert normally with AVL balancing\n    root = avlInsertLive(root, val);\n    logLine(\"Inserted \" + val + \" (live).\");\n    updateAll();\n  } else {\n    // step mode: generate steps\n    const stepArr = [];\n    // We will perform instrumented insert which mutates root and collects steps\n    avlInsertWithStepsCloneIndependent(val, stepArr);\n    setStepsAndStart(stepArr);\n    if (stepArr.length>0) stepNext();\n  }\n});\ndocument.getElementById('deleteBtn').addEventListener('click', function(){\n  const val = parseInt(document.getElementById('valueInput').value,10);\n  if (isNaN(val)) { logLine(\"Invalid value for deletion.\"); return; }\n  const mode = document.getElementById('modeSelect').value;\n  if (mode === 'live') {\n    pushHistory();\n    root = avlDeleteLive(root, val);\n    logLine(\"Deleted \" + val + \" (live).\");\n    updateAll();\n  } else {\n    const stepArr = [];\n    avlDeleteWithStepsCloneIndependent(val, stepArr);\n    setStepsAndStart(stepArr);\n    if (stepArr.length>0) stepNext();\n  }\n});\ndocument.getElementById('findBtn').addEventListener('click', function(){\n  const val = parseInt(document.getElementById('valueInput').value,10);\n  if (isNaN(val)) return;\n  const res = findWithPath(val);\n  foundValue = res.found ? val : null;\n  document.getElementById('foundLabel').textContent = foundValue === null ? 'none' : foundValue;\n  logLine(\"Find \" + val + \": \" + (res.found ? \"found\" : \"not found\") + \". Path: \" + res.path.join(\" -> \"));\n  // highlight path by rendering a temporary snapshot\n  renderTree(null, res.path);\n});\ndocument.getElementById('selectFoundBtn').addEventListener('click', function(){\n  if (foundValue !== null) {\n    selectedValue = foundValue;\n    document.getElementById('selectedLabel').textContent = selectedValue;\n    document.getElementById('rotateValue').value = selectedValue;\n    renderTree();\n  }\n});\ndocument.getElementById('bulkInsertBtn').addEventListener('click', function(){\n  const text = document.getElementById('bulkInput').value;\n  if (!text) return;\n  const arr = text.trim().split(/[\\s,]+/).map(s=>parseInt(s,10)).filter(n=>!isNaN(n));\n  if (arr.length === 0) { logLine(\"No valid integers in bulk input.\"); return; }\n  const mode = document.getElementById('modeSelect').value;\n  if (mode === 'live') {\n    pushHistory();\n    for (const v of arr) root = avlInsertLive(root, v);\n    logLine(\"Bulk inserted \" + arr.length + \" values (live).\");\n    updateAll();\n  } else {\n    // generate steps for each insertion and concatenate\n    const masterSteps = [];\n    for (const v of arr) {\n      const s = [];\n      avlInsertWithStepsCloneIndependent(v, s);\n      if (s.length>0) {\n        masterSteps.push({root: cloneRoot(root), msg:\"Before inserting \"+v, highlight:[]});\n        for (const item of s) masterSteps.push(item);\n      }\n    }\n    setStepsAndStart(masterSteps);\n    if (masterSteps.length>0) stepNext();\n  }\n});\ndocument.getElementById('clearBtn').addEventListener('click', function(){\n  pushHistory();\n  root = null;\n  selectedValue = null;\n  foundValue = null;\n  logLine(\"Cleared tree.\");\n  updateAll();\n});\ndocument.getElementById('randomGenBtn').addEventListener('click', function(){\n  const count = parseInt(document.getElementById('randomCount').value,10);\n  const arr = [];\n  for (let i=0;i<count;i++) arr.push(Math.floor(Math.random()*200)-100);\n  pushHistory();\n  for (const v of arr) root = avlInsertLive(root, v);\n  logLine(\"Inserted \" + count + \" random values.\");\n  updateAll();\n});\ndocument.getElementById('randomCount').addEventListener('input', function(){\n  document.getElementById('randomCountLabel').textContent = this.value;\n});\ndocument.getElementById('modeSelect').addEventListener('change', function(){\n  clearSteps();\n  logLine(\"Mode changed to \" + this.value);\n});\ndocument.getElementById('showHB').addEventListener('change', function(){ renderTree(); });\ndocument.getElementById('stepPrevBtn').addEventListener('click', stepPrev);\ndocument.getElementById('stepNextBtn').addEventListener('click', stepNext);\ndocument.getElementById('stepAutoBtn').addEventListener('click', autoPlayToggle);\ndocument.getElementById('stepApplyAllBtn').addEventListener('click', stepApplyAll);\ndocument.getElementById('stepCancelBtn').addEventListener('click', stepCancel);\ndocument.getElementById('stepSpeed').addEventListener('input', function(){ document.getElementById('speedLabel').textContent = this.value + \"ms\"; });\ndocument.getElementById('undoBtn').addEventListener('click', undo);\ndocument.getElementById('redoBtn').addEventListener('click', redo);\ndocument.getElementById('exportBtn').addEventListener('click', function(){\n  const json = JSON.stringify(root, function(key, value){\n    if (key === 'left' || key === 'right' || key === 'val' || key === 'height') return value;\n    return value;\n  }, 2);\n  const w = window.open(\"\", \"_blank\");\n  w.document.write(\"<pre>\"+escapeHtml(json)+\"</pre>\");\n  logLine(\"Exported tree JSON to new window.\");\n});\ndocument.getElementById('importBtn').addEventListener('click', function(){\n  const txt = document.getElementById('importArea').value;\n  if (!txt) { logLine(\"No JSON to import.\"); return; }\n  try {\n    const obj = JSON.parse(txt);\n    root = rebuildFromObject(obj);\n    pushHistory();\n    logLine(\"Imported tree from JSON.\");\n    updateAll();\n  } catch (e) {\n    logLine(\"Import failed: \" + e.message);\n  }\n});\ndocument.getElementById('rotateLeftBtn').addEventListener('click', function(){\n  const v = parseInt(document.getElementById('rotateValue').value,10);\n  if (isNaN(v)) return;\n  manualRotateAt(v, 'left');\n});\ndocument.getElementById('rotateRightBtn').addEventListener('click', function(){\n  const v = parseInt(document.getElementById('rotateValue').value,10);\n  if (isNaN(v)) return;\n  manualRotateAt(v, 'right');\n});\ndocument.getElementById('traverseBtn').addEventListener('click', function(){\n  const t = document.getElementById('traversalSelect').value;\n  let out;\n  if (t === 'inorder') out = inorderArr(root);\n  else if (t === 'preorder') out = preorderArr(root);\n  else if (t === 'postorder') out = postorderArr(root);\n  else out = levelOrderArr(root);\n  logLine(t + \": \" + out.join(\",\"));\n});\ndocument.getElementById('vizMode').addEventListener('change', function(){ renderTree(); });\n\n\n/* Core AVL live operations (without step capture) */\nfunction avlInsertLive(node, key) {\n  if (!node) return new Node(key);\n  if (key < node.val) node.left = avlInsertLive(node.left, key);\n  else if (key > node.val) node.right = avlInsertLive(node.right, key);\n  else return node;\n  updateHeight(node);\n  const b = balanceFactor(node);\n  if (b > 1 && key < node.left.val) return rotateRight(node);\n  if (b < -1 && key > node.right.val) return rotateLeft(node);\n  if (b > 1 && key > node.left.val) {\n    node.left = rotateLeft(node.left);\n    return rotateRight(node);\n  }\n  if (b < -1 && key < node.right.val) {\n    node.right = rotateRight(node.right);\n    return rotateLeft(node);\n  }\n  return node;\n}\nfunction avlDeleteLive(node, key) {\n  if (!node) return node;\n  if (key < node.val) node.left = avlDeleteLive(node.left, key);\n  else if (key > node.val) node.right = avlDeleteLive(node.right, key);\n  else {\n    if (!node.left || !node.right) {\n      const temp = node.left ? node.left : node.right;\n      if (!temp) {\n        node = null;\n        return null;\n      } else node = temp;\n    } else {\n      const temp = minValueNode(node.right);\n      node.val = temp.val;\n      node.right = avlDeleteLive(node.right, temp.val);\n    }\n  }\n  if (!node) return node;\n  updateHeight(node);\n  const b = balanceFactor(node);\n  if (b > 1 && balanceFactor(node.left) >= 0) return rotateRight(node);\n  if (b > 1 && balanceFactor(node.left) < 0) {\n    node.left = rotateLeft(node.left);\n    return rotateRight(node);\n  }\n  if (b < -1 && balanceFactor(node.right) <= 0) return rotateLeft(node);\n  if (b < -1 && balanceFactor(node.right) > 0) {\n    node.right = rotateRight(node.right);\n    return rotateLeft(node);\n  }\n  return node;\n}\nfunction minValueNode(node) { let current=node; while(current.left) current=current.left; return current; }\n\n/* Step-mode clone-independent insertion: we want to generate steps without mutating main root until apply.\n   We'll build a temporary tree (clone of current root), perform instrumented insert on that copy, and record snapshots of that temporary tree at each step.\n*/\nfunction avlInsertWithStepsCloneIndependent(key, stepsArr) {\n  let tempRoot = cloneRoot(root);\n  function rec(node) {\n    if (!node) {\n      const newN = new Node(key);\n      tempRoot = insertIntoTemp(tempRoot, key); // ensure root points to updated tempRoot for snapshots\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Inserted new node \"+key, highlight:[key]});\n      return newN;\n    }\n    if (key === node.val) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Key \"+key+\" already exists; no insertion\", highlight:[node.val]});\n      return node;\n    }\n    if (key < node.val) {\n      node.left = rec(node.left);\n    } else {\n      node.right = rec(node.right);\n    }\n    updateHeight(node);\n    stepsArr.push({root: cloneRoot(tempRoot), msg:\"Updated heights at node \"+node.val+\" -> h=\"+node.height+\" (b=\"+balanceFactor(node)+\")\", highlight:[node.val]});\n    const b = balanceFactor(node);\n    // handle rotations on temp structure\n    if (b > 1 && key < node.left.val) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Left-Left at \"+node.val+\" -> rotate right\", highlight:[node.val]});\n      // perform rotation on tempRoot subtree\n      tempRoot = rotateRightAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate right\", highlight:[]});\n      return findNode(tempRoot, node.left ? node.left.val : node.val); // best effort return\n    }\n    if (b < -1 && key > node.right.val) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Right-Right at \"+node.val+\" -> rotate left\", highlight:[node.val]});\n      tempRoot = rotateLeftAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate left\", highlight:[]});\n      return findNode(tempRoot, node.right ? node.right.val : node.val);\n    }\n    if (b > 1 && key > node.left.val) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Left-Right at \"+node.val+\" -> rotate left then right\", highlight:[node.val]});\n      tempRoot = rotateLeftAt(tempRoot, node.left.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate left on left child\", highlight:[]});\n      tempRoot = rotateRightAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate right\", highlight:[]});\n      return findNode(tempRoot, node.left ? node.left.val : node.val);\n    }\n    if (b < -1 && key < node.right.val) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Right-Left at \"+node.val+\" -> rotate right then left\", highlight:[node.val]});\n      tempRoot = rotateRightAt(tempRoot, node.right.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate right on right child\", highlight:[]});\n      tempRoot = rotateLeftAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate left\", highlight:[]});\n      return findNode(tempRoot, node.right ? node.right.val : node.val);\n    }\n    return node;\n  }\n  // helper to insert into tempRoot (for initial base)\n  function insertIntoTemp(rootClone, v) {\n    function ins(n) {\n      if (!n) return new Node(v);\n      if (v < n.val) n.left = ins(n.left);\n      else if (v > n.val) n.right = ins(n.right);\n      updateHeight(n);\n      const b = balanceFactor(n);\n      if (b > 1 && v < n.left.val) return rotateRight(n);\n      if (b < -1 && v > n.right.val) return rotateLeft(n);\n      if (b > 1 && v > n.left.val) { n.left = rotateLeft(n.left); return rotateRight(n); }\n      if (b < -1 && v < n.right.val) { n.right = rotateRight(n.right); return rotateLeft(n); }\n      return n;\n    }\n    return ins(rootClone);\n  }\n  // helpers to find node by value\n  function findNode(r, v) { if (!r) return null; if (r.val === v) return r; if (v < r.val) return findNode(r.left, v); return findNode(r.right, v); }\n  // rotation helpers that operate by locating the node and performing rotation at that node; they return a new tempRoot\n  function rotateRightAt(r, val) {\n    function rec(n) {\n      if (!n) return n;\n      if (val < n.val) n.left = rec(n.left);\n      else if (val > n.val) n.right = rec(n.right);\n      else {\n        if (!n.left) return n;\n        const newRoot = rotateRight(n);\n        return newRoot;\n      }\n      updateHeight(n);\n      return n;\n    }\n    return rec(r);\n  }\n  function rotateLeftAt(r, val) {\n    function rec(n) {\n      if (!n) return n;\n      if (val < n.val) n.left = rec(n.left);\n      else if (val > n.val) n.right = rec(n.right);\n      else {\n        if (!n.right) return n;\n        const newRoot = rotateLeft(n);\n        return newRoot;\n      }\n      updateHeight(n);\n      return n;\n    }\n    return rec(r);\n  }\n\n  // Start the process:\n  tempRoot = cloneRoot(root);\n  if (!tempRoot) {\n    tempRoot = new Node(key);\n    stepsArr.push({root: cloneRoot(tempRoot), msg:\"Inserted new root \"+key, highlight:[key]});\n    return;\n  }\n  // We will run a BST insert with instrumentation on the temp copy directly to build accurate snapshots\n  // Simpler approach: call insertIntoTemp which itself performs rotations and updates and returns final tree - but we lost per-node step granularity.\n  // The previous recursive rec will mutate nodes but also update tempRoot when rotations occur.\n  rec(tempRoot);\n  // ensure final snapshot\n  stepsArr.push({root: cloneRoot(tempRoot), msg:\"Final tree after insertion of \"+key, highlight:[key]});\n}\n\n/* Similar clone-independent delete steps */\nfunction avlDeleteWithStepsCloneIndependent(key, stepsArr) {\n  let tempRoot = cloneRoot(root);\n  if (!tempRoot) {\n    stepsArr.push({root: cloneRoot(tempRoot), msg:\"Tree empty; nothing to delete\", highlight:[]});\n    return;\n  }\n  function minNode(n) { let cur=n; while(cur.left) cur=cur.left; return cur; }\n  function rec(node) {\n    if (!node) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Key \"+key+\" not found\", highlight:[]});\n      return null;\n    }\n    if (key < node.val) node.left = rec(node.left);\n    else if (key > node.val) node.right = rec(node.right);\n    else {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Deleting node \"+node.val, highlight:[node.val]});\n      if (!node.left || !node.right) {\n        const temp = node.left ? node.left : node.right;\n        if (!temp) {\n          node = null;\n          return null;\n        } else node = temp;\n      } else {\n        const temp = minNode(node.right);\n        node.val = temp.val;\n        stepsArr.push({root: cloneRoot(tempRoot), msg:\"Replaced with successor \"+temp.val, highlight:[temp.val]});\n        node.right = rec(node.right); // delete successor in right subtree\n      }\n    }\n    if (!node) return node;\n    updateHeight(node);\n    stepsArr.push({root: cloneRoot(tempRoot), msg:\"Updated height at \"+node.val+\" -> h=\"+node.height+\" (b=\"+balanceFactor(node)+\")\", highlight:[node.val]});\n    const b = balanceFactor(node);\n    if (b > 1 && balanceFactor(node.left) >= 0) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Left-Left at \"+node.val+\" -> rotate right\", highlight:[node.val]});\n      tempRoot = rotateRightAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate right\", highlight:[]});\n      return findNode(tempRoot, node.val);\n    }\n    if (b > 1 && balanceFactor(node.left) < 0) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Left-Right at \"+node.val, highlight:[node.val]});\n      tempRoot = rotateLeftAt(tempRoot, node.left.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate left on left child\", highlight:[]});\n      tempRoot = rotateRightAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate right\", highlight:[]});\n      return findNode(tempRoot, node.val);\n    }\n    if (b < -1 && balanceFactor(node.right) <= 0) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Right-Right at \"+node.val+\" -> rotate left\", highlight:[node.val]});\n      tempRoot = rotateLeftAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate left\", highlight:[]});\n      return findNode(tempRoot, node.val);\n    }\n    if (b < -1 && balanceFactor(node.right) > 0) {\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"Right-Left at \"+node.val, highlight:[node.val]});\n      tempRoot = rotateRightAt(tempRoot, node.right.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate right on right child\", highlight:[]});\n      tempRoot = rotateLeftAt(tempRoot, node.val);\n      stepsArr.push({root: cloneRoot(tempRoot), msg:\"After rotate left\", highlight:[]});\n      return findNode(tempRoot, node.val);\n    }\n    return node;\n  }\n  function findNode(r, v) { if (!r) return null; if (r.val===v) return r; if (v<r.val) return findNode(r.left, v); return findNode(r.right, v); }\n  function rotateLeftAt(r, val) {\n    function rec(n) {\n      if (!n) return n;\n      if (val < n.val) n.left = rec(n.left);\n      else if (val > n.val) n.right = rec(n.right);\n      else {\n        if (!n.right) return n;\n        const nr = rotateLeft(n);\n        return nr;\n      }\n      updateHeight(n);\n      return n;\n    }\n    return rec(r);\n  }\n  function rotateRightAt(r, val) {\n    function rec(n) {\n      if (!n) return n;\n      if (val < n.val) n.left = rec(n.left);\n      else if (val > n.val) n.right = rec(n.right);\n      else {\n        if (!n.left) return n;\n        const nr = rotateRight(n);\n        return nr;\n      }\n      updateHeight(n);\n      return n;\n    }\n    return rec(r);\n  }\n  tempRoot = cloneRoot(root);\n  rec(tempRoot);\n  stepsArr.push({root: cloneRoot(tempRoot), msg:\"Final tree after deletion attempt of \"+key, highlight:[]});\n}\n\n/* Utilities: rebuild from imported object */\nfunction rebuildFromObject(obj) {\n  if (!obj) return null;\n  const n = new Node(obj.val);\n  n.height = obj.height || 1;\n  n.left = rebuildFromObject(obj.left);\n  n.right = rebuildFromObject(obj.right);\n  updateHeight(n);\n  return n;\n}\n\n/* Escape HTML for export window */\nfunction escapeHtml(s) { return s.replace(/[&<>]/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;'}[c]; }); }\n\n/* Keyboard shortcuts for stepping */\ndocument.addEventListener('keydown', function(e){\n  if (e.key === 'ArrowRight') stepNext();\n  if (e.key === 'ArrowLeft') stepPrev();\n});\n\n/* Initial update */\nupdateAll();\n\n/* Extra helper: a simpler insert that pushes history and uses live insertion */\nfunction quickInsert(val) { pushHistory(); root = avlInsertLive(root, val); updateAll(); }\n\n/* Seed demonstration content (optional) - keep off by default */\n// quickInsert(30); quickInsert(20); quickInsert(40); quickInsert(10); quickInsert(25);\n// logLine(\"Seeded example values.\");\n\n</script>\n</body>\n</html>"
