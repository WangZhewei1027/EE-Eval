    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Context Switching | Cognitive Flow Visualization</title>\n    <style>\n        /* Base Styles */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        @font-face {\n            font-family: 'Inter';\n            src: url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n        }\n\n        body {\n            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);\n            color: #e6f1ff;\n            min-height: 100vh;\n            overflow-x: hidden;\n            perspective: 1000px;\n        }\n\n        /* Main Container */\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            position: relative;\n        }\n\n        /* Header */\n        .header {\n            text-align: center;\n            margin-bottom: 4rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;\n        }\n\n        .header h1 {\n            font-size: 3.5rem;\n            font-weight: 700;\n            letter-spacing: -0.03em;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, #64f4ac 0%, #5fd3ff 100%);\n            -webkit-background-clip: text;\n            background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .header p {\n            font-size: 1.2rem;\n            line-height: 1.6;\n            max-width: 700px;\n            margin: 0 auto;\n            color: rgba(230, 241, 255, 0.8);\n        }\n\n        /* Visualization Area */\n        .visualization {\n            position: relative;\n            height: 500px;\n            margin: 3rem 0;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n\n        /* Task Cards */\n        .task-container {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-bottom: 3rem;\n            position: relative;\n            z-index: 2;\n        }\n\n        .task-card {\n            width: 180px;\n            height: 220px;\n            background: rgba(255, 255, 255, 0.08);\n            border-radius: 16px;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            padding: 1.5rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            text-align: center;\n            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);\n            position: relative;\n            overflow: hidden;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);\n            opacity: 0;\n            transform: translateY(40px);\n        }\n\n        .task-card:nth-child(1) {\n            animation: fadeIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards;\n        }\n        .task-card:nth-child(2) {\n            animation: fadeIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1s forwards;\n        }\n        .task-card:nth-child(3) {\n            animation: fadeIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1.2s forwards;\n        }\n\n        .task-card:hover {\n            transform: translateY(-10px) scale(1.03);\n            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);\n        }\n\n        .task-card h3 {\n            font-size: 1.1rem;\n            margin-bottom: 0.8rem;\n            font-weight: 600;\n            color: #fff;\n        }\n\n        .task-card p {\n            font-size: 0.9rem;\n            line-height: 1.5;\n            color: rgba(255, 255, 255, 0.7);\n            margin-bottom: 1.2rem;\n        }\n\n        .task-icon {\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n\n        .task-card:nth-child(1) .task-icon {\n            background: linear-gradient(135deg, #64f4ac 0%, #5fd3ff 100%);\n        }\n\n        .task-card:nth-child(2) .task-icon {\n            background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);\n        }\n\n        .task-card:nth-child(3) .task-icon {\n            background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);\n        }\n\n        /* Focus Beam */\n        .focus-beam {\n            position: absolute;\n            width: 180px;\n            height: 220px;\n            background: linear-gradient(90deg, rgba(100, 244, 172, 0.2) 0%, rgba(95, 211, 255, 0.05) 100%);\n            border-radius: 16px;\n            top: 0;\n            left: calc(50% - 90px);\n            z-index: 1;\n            transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);\n            transform-origin: center;\n            opacity: 0;\n            box-shadow: 0 0 60px rgba(100, 244, 172, 0.3);\n        }\n\n        /* Context Switch Lines */\n        .context-lines {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 0;\n        }\n\n        .line {\n            position: absolute;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.1);\n            transform-origin: left center;\n            top: 50%;\n            left: 50%;\n            width: 0;\n        }\n\n        /* Control Button */\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s cubic-bezier(0.22, 1, 0.36, 1) 1.8s forwards;\n        }\n\n        .btn {\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            border: none;\n            font-size: 1rem;\n            font-weight: 500;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            background: linear-gradient(90deg, #64f4ac 0%, #5fd3ff 100%);\n            color: #16213e;\n            box-shadow: 0 4px 20px rgba(100, 244, 172, 0.3);\n        }\n\n        .btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 24px rgba(100, 244, 172, 0.4);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        /* Floating Particles */\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        .particle {\n            position: absolute;\n            border-radius: 50%;\n            background: rgba(255, 255, 255, 0.15);\n            animation: float 15s infinite linear;\n        }\n\n        /* Animations */\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes float {\n            0% {\n                transform: translateY(0) translateX(0) rotate(0deg);\n                opacity: 0;\n            }\n            10% {\n                opacity: 1;\n            }\n            90% {\n                opacity: 1;\n            }\n            100% {\n                transform: translateY(-300px) translateX(100px) rotate(360deg);\n                opacity: 0;\n            }\n        }\n\n        /* Footer */\n        .footer {\n            text-align: center;\n            margin-top: 4rem;\n            opacity: 0;\n            animation: fadeIn 1s cubic-bezier(0.22, 1, 0.36, 1) 2s forwards;\n        }\n\n        .footer p {\n            color: rgba(230, 241, 255, 0.5);\n            font-size: 0.9rem;\n        }\n\n        /* Responsive */\n        @media (max-width: 768px) {\n            .header h1 {\n                font-size: 2.5rem;\n            }\n            \n            .task-container {\n                flex-direction: column;\n                align-items: center;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- Header -->\n        <div class=\"header\">\n            <h1>Context Switching</h1>\n            <p>Visualizing the cognitive cost of shifting between multiple tasks and thought processes in a modern workflow.</p>\n        </div>\n\n        <!-- Visualization Area -->\n        <div class=\"visualization\">\n            <!-- Focus Beam -->\n            <div class=\"focus-beam\" id=\"focusBeam\"></div>\n            \n            <!-- Context Lines -->\n            <div class=\"context-lines\" id=\"contextLines\"></div>\n\n            <!-- Task Cards -->\n            <div class=\"task-container\">\n                <div class=\"task-card\" data-task=\"1\">\n                    <div class=\"task-icon\">💻</div>\n                    <h3>Coding</h3>\n                    <p>Deep programming work requiring focus and problem-solving</p>\n                </div>\n                <div class=\"task-card\" data-task=\"2\">\n                    <div class=\"task-icon\">📧</div>\n                    <h3>Emails</h3>\n                    <p>Communication and information processing</p>\n                </div>\n                <div class=\"task-card\" data-task=\"3\">\n                    <div class=\"task-icon\">📊</div>\n                    <h3>Analysis</h3>\n                    <p>Data review and strategic decision making</p>\n                </div>\n            </div>\n        </div>\n\n        <!-- Controls -->\n        <div class=\"controls\">\n            <button class=\"btn\" id=\"switchBtn\">Trigger Context Switch</button>\n        </div>\n\n        <!-- Footer -->\n        <div class=\"footer\">\n            <p>Visualization of cognitive flow and mental state transitions</p>\n        </div>\n    </div>\n\n    <!-- Floating Particles -->\n    <div class=\"particles\" id=\"particles\"></div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create floating particles\n            const particlesContainer = document.getElementById('particles');\n            for (let i = 0; i < 20; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                particle.style.width = `${Math.random() * 10 + 5}px`;\n                particle.style.height = particle.style.width;\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100 + 100}%`;\n                particle.style.animationDelay = `${Math.random() * 15}s`;\n                particle.style.animationDuration = `${Math.random() * 10 + 10}s`;\n                particlesContainer.appendChild(particle);\n            }\n\n            // Context switching animation\n            const focusBeam = document.getElementById('focusBeam');\n            const contextLines = document.getElementById('contextLines');\n            const switchBtn = document.getElementById('switchBtn');\n            const taskCards = document.querySelectorAll('.task-card');\n            \n            let currentTask = 1;\n            let isAnimating = false;\n            \n            // Initial focus\n            focusBeam.style.left = taskCards[0].offsetLeft + 'px';\n            focusBeam.style.opacity = '1';\n            \n            // Create context lines\n            for (let i = 0; i < 5; i++) {\n                const line = document.createElement('div');\n                line.classList.add('line');\n                line.style.transform = `rotate(${i * 72}deg)`;\n                line.style.top = `${50 + Math.random() * 10 - 5}%`;\n                contextLines.appendChild(line);\n            }\n            \n            // Context switch function\n            function switchContext() {\n                if (isAnimating) return;\n                isAnimating = true;\n                \n                // Fade out focus beam\n                focusBeam.style.opacity = '0';\n                \n                // Animate context lines\n                const lines = document.querySelectorAll('.line');\n                lines.forEach(line => {\n                    line.style.width = `${Math.random() * 300 + 100}px`;\n                    line.style.transition = 'width 0.8s cubic-bezier(0.16, 1, 0.3, 1)';\n                    line.style.background = 'rgba(255, 255, 255, 0.3)';\n                });\n                \n                // After delay, move focus to new task\n                setTimeout(() => {\n                    currentTask = currentTask % 3 + 1;\n                    const targetTask = document.querySelector(`.task-card[data-task=\"${currentTask}\"]`);\n                    \n                    // Reset lines\n                    lines.forEach(line => {\n                        line.style.width = '0';\n                        line.style.background = 'rgba(255, 255, 255, 0.1)';\n                    });\n                    \n                    // Move focus beam\n                    focusBeam.style.left = targetTask.offsetLeft + 'px';\n                    focusBeam.style.opacity = '1';\n                    \n                    isAnimating = false;\n                }, 1000);\n            }\n            \n            // Button click handler\n            switchBtn.addEventListener('click', switchContext);\n            \n            // Auto-switch every 8 seconds\n            setInterval(switchContext, 8000);\n        });\n    </script>\n</body>\n</html>"
