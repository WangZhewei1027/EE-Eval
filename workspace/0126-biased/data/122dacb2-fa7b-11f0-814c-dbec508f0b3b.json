    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Patterns</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n        }\n        \n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        \n        .slider {\n            width: 50%;\n            margin: 20px auto;\n            padding: 10px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        \n        .input-field {\n            padding: 10px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        \n        .button:hover, .slider:hover, .input-field:hover {\n            background-color: #ccc;\n        }\n        \n        .error-message {\n            color: red;\n            font-size: 14px;\n            margin-bottom: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Design Patterns</h1>\n        <p>This example demonstrates several design patterns in a simple interactive interface.</p>\n        \n        <div class=\"button-group\">\n            <button class=\"button\" onclick=\"addPerson()\">Add Person</button>\n            <button class=\"button\" onclick=\"deletePerson()\">Delete Person</button>\n        </div>\n        \n        <div class=\"slider\">\n            <input type=\"range\" id=\"personSlider\" min=\"1\" max=\"10\" value=\"5\">\n            <label for=\"personSlider\">Person Slider:</label>\n        </div>\n        \n        <div class=\"input-field\">\n            <label for=\"name\">Name:</label>\n            <input type=\"text\" id=\"name\" name=\"name\" value=\"John\">\n            <span id=\"errorMessage\"></span>\n        </div>\n        \n        <div class=\"button-group\">\n            <button class=\"button\" onclick=\"saveData()\">Save Data</button>\n            <button class=\"button\" onclick=\"clearData()\">Clear Data</button>\n        </div>\n    </div>\n    \n    <script>\n        function addPerson() {\n            var name = document.getElementById(\"name\").value;\n            if (name.length < 2) {\n                document.getElementById(\"errorMessage\").innerHTML = \"Name must be at least 2 characters.\";\n            } else {\n                document.getElementById(\"errorMessage\").innerHTML = \"\";\n                // Add person to data storage\n            }\n        }\n        \n        function deletePerson() {\n            var name = document.getElementById(\"name\").value;\n            if (name.length < 2) {\n                document.getElementById(\"errorMessage\").innerHTML = \"Name must be at least 2 characters.\";\n            } else {\n                // Delete person from data storage\n            }\n        }\n        \n        function saveData() {\n            var data = {\n                name: document.getElementById(\"name\").value,\n                age: parseInt(document.getElementById(\"age\").value)\n            };\n            // Save data to storage\n        }\n        \n        function clearData() {\n            document.getElementById(\"name\").value = \"\";\n            document.getElementById(\"age\").value = \"\";\n        }\n    </script>\n</body>\n</html>"
