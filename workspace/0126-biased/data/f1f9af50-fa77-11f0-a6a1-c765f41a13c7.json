    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Encryption — Visual Concept</title>\n<style>\n  :root{\n    --bg1:#071023;\n    --bg2:#08122b;\n    --accent:#7dd3fc;\n    --accent2:#a78bfa;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.65);\n    --card: rgba(255,255,255,0.03);\n    --glass-strong: rgba(255,255,255,0.09);\n  }\n\n  /* Page reset */\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body,#app{height:100%}\n  body{\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,58,237,0.08), transparent 6%),\n                radial-gradient(900px 400px at 90% 90%, rgba(14,165,233,0.06), transparent 4%),\n                linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle particle canvas covers full screen */\n  #particleCanvas{\n    position:fixed;inset:0;width:100%;height:100%;z-index:0;mix-blend-mode:screen;opacity:0.45;\n    filter: blur(10px) saturate(120%);\n    pointer-events:none;\n  }\n\n  /* Main layout */\n  .stage{\n    position:relative;z-index:1;height:100vh;display:flex;align-items:center;justify-content:center;padding:48px;\n  }\n\n  .panel{\n    width:min(1100px,96vw);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    display:flex;\n    gap:28px;\n    align-items:center;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(6px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.03);\n    overflow:hidden;\n  }\n\n  /* Left visual */\n  .visual{\n    width:44%;\n    min-width:320px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    padding:18px;\n  }\n\n  .orb{\n    width:280px;height:280px;border-radius:50%;\n    background: radial-gradient(circle at 30% 25%, rgba(167,139,250,0.18), transparent 20%),\n                radial-gradient(circle at 70% 75%, rgba(125,211,252,0.08), transparent 14%),\n                linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:grid;place-items:center;\n    box-shadow: 0 20px 60px rgba(5,8,20,0.6), 0 2px 12px rgba(12,34,67,0.25);\n    border: 1px solid rgba(255,255,255,0.04);\n    position:relative;\n    overflow:visible;\n  }\n\n  /* Animated ring around orb */\n  .ring{\n    position:absolute;inset: -22px;display:block;border-radius:50%;\n    background: conic-gradient(from 120deg, rgba(124,58,237,0.35), rgba(14,165,233,0.35), rgba(124,58,237,0.35));\n    filter: blur(22px);\n    opacity:0.9;transform:rotate(0deg);\n    animation: spin 18s linear infinite;\n    z-index: -1;\n  }\n  @keyframes spin { to{ transform:rotate(360deg) } }\n\n  /* Lock glyph */\n  .lock{\n    width:160px;height:160px;border-radius:22px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.006));\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    box-shadow: 0 12px 40px rgba(3,6,16,0.5), inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;overflow:visible;\n  }\n\n  .lock .shackle{\n    width:82px;height:56px;border-radius:40px;border:6px solid rgba(255,255,255,0.06);\n    border-bottom-color:transparent;transform:translateY(-16px);\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    box-shadow: 0 8px 20px rgba(7,9,20,0.5) inset;\n    transition:transform 600ms cubic-bezier(.22,.9,.3,1);\n  }\n\n  .lock .body{\n    width:96px;height:80px;border-radius:12px;background:linear-gradient(180deg, rgba(124,58,237,0.18), rgba(14,165,233,0.08));\n    margin-top:-6px;display:grid;place-items:center;position:relative;\n    box-shadow: inset 0 -6px 20px rgba(2,6,23,0.35), 0 10px 30px rgba(3,8,20,0.45);\n  }\n\n  .lock .keyhole{\n    width:18px;height:28px;border-radius:6px;background:#08122b;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.03);\n    position:relative;\n  }\n  .lock .keyhole:after{\n    content:'';position:absolute;left:50%;transform:translateX(-50%);bottom:-8px;width:6px;height:8px;background:#08122b;border-radius:4px;\n  }\n\n  .lock.locked .shackle{ transform: translateY(0px) }\n  .lock.locked .body{ transform: translateY(0) }\n  .lock.unlocking .shackle{ transform: translateY(-8px) rotate(-6deg) }\n  .lock.unlocking .ringGlow{\n    box-shadow: 0 0 36px 12px rgba(167,139,250,0.12), 0 0 90px 24px rgba(125,211,252,0.06);\n  }\n\n  /* Glow highlights on orb */\n  .ringGlow{\n    position:absolute;inset:0;border-radius:50%;\n    transition: box-shadow 600ms ease;\n    pointer-events:none;\n  }\n\n  /* Right content */\n  .content{\n    width:56%;\n    padding:10px 8px;\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n  }\n\n  h1{\n    font-weight:700;\n    font-size:28px;\n    letter-spacing:1px;\n    color: white;\n    display:flex;align-items:center;gap:14px;\n  }\n\n  .titleAccent{\n    background: linear-gradient(90deg,var(--accent),var(--accent2));\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n    font-weight:800;font-size:18px;padding:6px 12px;border-radius:999px;\n    box-shadow: 0 6px 20px rgba(124,58,237,0.06);\n  }\n\n  p.lead{\n    color:var(--muted);font-size:14px;line-height:1.5;\n    max-width:48ch;\n  }\n\n  /* Glass window for strings */\n  .terminal{\n    margin-top:8px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:18px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 30px rgba(3,8,20,0.45);\n    display:flex;flex-direction:column;gap:12px;\n  }\n\n  .row{\n    display:flex;align-items:center;justify-content:space-between;gap:12px;\n  }\n\n  .label{\n    color:rgba(255,255,255,0.6);font-size:12px;font-weight:600;\n  }\n\n  .box{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.008));\n    border-radius:10px;padding:12px 14px;min-width:220px;\n    display:flex;align-items:center;gap:10px;justify-content:space-between;\n    border:1px solid rgba(255,255,255,0.02);\n    box-shadow: inset 0 -6px 18px rgba(0,0,0,0.45);\n  }\n\n  .plaintext{\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n    color: #dbeafe;letter-spacing:1px;font-weight:700;\n    font-size:16px;\n  }\n  .ciphertext{\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n    color: #9be7ff;letter-spacing:0.8px;font-weight:700;font-size:16px;\n    transition: color 320ms ease;\n  }\n\n  .mutedSmall{font-size:12px;color:rgba(255,255,255,0.5)}\n\n  /* Buttons */\n  .controls{display:flex;gap:12px;margin-top:8px}\n  .btn{\n    padding:12px 18px;border-radius:12px;border:none;cursor:pointer;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.006));\n    color:var(--muted);font-weight:700;font-size:13px;\n    box-shadow: 0 8px 18px rgba(2,6,23,0.5);\n    border:1px solid rgba(255,255,255,0.03);\n    display:inline-flex;gap:8px;align-items:center;justify-content:center;\n    transition: transform 200ms ease, box-shadow 200ms ease, background 200ms ease;\n  }\n  .btn:active{ transform: translateY(1px) }\n  .btn.primary{\n    background: linear-gradient(90deg, rgba(125,211,252,0.12), rgba(167,139,250,0.12));\n    color: white;\n    box-shadow: 0 14px 40px rgba(124,58,237,0.12);\n  }\n\n  .btn.secondary{\n    background:transparent;color:var(--muted);border:1px dashed rgba(255,255,255,0.03);\n  }\n\n  /* Key reveal overlay */\n  .keycard{\n    position:absolute;right:18px;top:18px;padding:12px 14px;border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);backdrop-filter: blur(6px);\n    display:flex;align-items:center;gap:12px;box-shadow: 0 8px 24px rgba(3,8,20,0.6);\n    transform-origin:top right;transition: transform 260ms cubic-bezier(.16,.84,.2,1), opacity 260ms ease;\n    opacity:0;pointer-events:none;\n  }\n  .keycard.show{\n    opacity:1;transform: translateY(0);pointer-events:auto;\n  }\n  .keyVisual{\n    width:56px;height:36px;border-radius:8px;background:linear-gradient(90deg,#7dd3fc44,#a78bfa44);\n    display:grid;place-items:center;font-weight:700;color:white;font-family:ui-monospace, monospace;font-size:12px;\n    box-shadow: 0 8px 30px rgba(124,58,237,0.06);\n  }\n  .keyString{\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n    color:#d1f7ff;font-weight:700;letter-spacing:1px;\n    font-size:13px;\n  }\n\n  /* micro animations */\n  .glint{\n    position: absolute; left: -40px; top: -20px; width: 120px; height: 120px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02), rgba(255,255,255,0));\n    transform: rotate(30deg) translateX(-20px);\n    filter: blur(20px);\n    opacity:0.6;\n    mix-blend-mode:screen;pointer-events:none;\n    animation: floaty 6s ease-in-out infinite;\n  }\n  @keyframes floaty{\n    0%{ transform: rotate(30deg) translateY(0) }\n    50%{ transform: rotate(40deg) translateY(-6px) }\n    100%{ transform: rotate(30deg) translateY(0) }\n  }\n\n  /* Responsive */\n  @media (max-width:900px){\n    .panel{flex-direction:column;align-items:stretch;padding:20px}\n    .visual,.content{width:100%}\n    .visual{order:2}\n    .content{order:1}\n  }\n\n  /* tiny sparkle */\n  .sparkle{\n    position:absolute;width:6px;height:6px;border-radius:50%;background:linear-gradient(90deg,#fff,#a7f0ff);\n    filter: blur(2px);opacity:0.95;box-shadow:0 0 18px #a7f0ff;\n    transform:translate(-50%,-50%);pointer-events:none;\n  }\n\n</style>\n</head>\n<body>\n<canvas id=\"particleCanvas\"></canvas>\n<div id=\"app\" class=\"stage\" aria-hidden=\"false\">\n  <div class=\"panel\" role=\"region\" aria-label=\"Encryption demonstration\">\n    <div class=\"visual\" aria-hidden=\"true\">\n      <div class=\"orb\" id=\"orb\">\n        <div class=\"ring\" aria-hidden=\"true\"></div>\n        <div class=\"glint\" aria-hidden=\"true\"></div>\n        <div class=\"lock locked\" id=\"lock\">\n          <div class=\"shackle\"></div>\n          <div class=\"body\">\n            <div class=\"keyhole\"></div>\n          </div>\n        </div>\n        <div class=\"ringGlow\" aria-hidden=\"true\"></div>\n        <div class=\"sparkle\" style=\"left:18%;top:24%;opacity:0.9\"></div>\n        <div class=\"sparkle\" style=\"left:82%;top:72%;opacity:0.7;width:8px;height:8px\"></div>\n      </div>\n    </div>\n\n    <div class=\"content\" aria-hidden=\"false\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n        <div>\n          <h1><span class=\"titleAccent\">ENCRYPTION</span></h1>\n          <p class=\"lead\">A refined visual exploration of encryption: conceal, transform and secure information. Watch plaintext dissolve into ciphertext as the lock tightens.</p>\n        </div>\n      </div>\n\n      <div class=\"terminal\" role=\"region\" aria-label=\"Plaintext and Ciphertext\">\n        <div class=\"row\">\n          <div>\n            <div class=\"label\">PLAINTEXT</div>\n            <div class=\"box\">\n              <div class=\"plaintext\" id=\"plaintext\">HELLO, WORLD</div>\n            </div>\n          </div>\n          <div style=\"text-align:right\">\n            <div class=\"label\">ALGORITHM</div>\n            <div class=\"mutedSmall\">Symmetric • Simulated • Aesthetic</div>\n          </div>\n        </div>\n\n        <div class=\"row\">\n          <div style=\"width:100%\">\n            <div class=\"label\">CIPHERTEXT</div>\n            <div class=\"box\" aria-live=\"polite\">\n              <div class=\"ciphertext\" id=\"ciphertext\">— — — — — — — — —</div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"controls\" style=\"justify-content:space-between;align-items:center;\">\n          <div>\n            <button class=\"btn primary\" id=\"encryptBtn\" aria-pressed=\"false\" title=\"Animate encryption\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M12 3v3\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><rect x=\"4\" y=\"6\" width=\"16\" height=\"12\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"1.6\"/></svg>\n              Encrypt\n            </button>\n            <button class=\"btn secondary\" id=\"replayBtn\" aria-pressed=\"false\" title=\"Play subtle replay\">\n              Replay\n            </button>\n          </div>\n\n          <div style=\"display:flex;gap:12px;align-items:center;\">\n            <div class=\"mutedSmall\">Key</div>\n            <button class=\"btn\" id=\"revealKeyBtn\" aria-pressed=\"false\" title=\"Reveal encryption key\">Reveal</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"keycard\" id=\"keycard\" role=\"dialog\" aria-hidden=\"true\" aria-label=\"Encryption key\">\n        <div class=\"keyVisual\">KEY</div>\n        <div>\n          <div class=\"mutedSmall\">Symmetric Key</div>\n          <div class=\"keyString\" id=\"keyString\">•••• •••• •••• ••••</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n/* Particle network: aesthetic, low-interaction */\n(() => {\n  const canvas = document.getElementById('particleCanvas');\n  const ctx = canvas.getContext('2d');\n  let w = canvas.width = innerWidth;\n  let h = canvas.height = innerHeight;\n  const hueA = 200, hueB = 270;\n\n  const particles = [];\n  const count = Math.max(28, Math.floor((w*h)/75000));\n  for(let i=0;i<count;i++){\n    particles.push({\n      x: Math.random()*w,\n      y: Math.random()*h,\n      vx: (Math.random()-0.5)*0.18,\n      vy: (Math.random()-0.5)*0.18,\n      r: 0.6 + Math.random()*1.8,\n      hue: hueA + Math.random()*(hueB-hueA),\n    });\n  }\n\n  function resize(){\n    w = canvas.width = innerWidth;\n    h = canvas.height = innerHeight;\n  }\n  addEventListener('resize', resize);\n\n  function draw(){\n    ctx.clearRect(0,0,w,h);\n    // gradient backdrop soft overlay\n    const g = ctx.createLinearGradient(0,0,w,h);\n    g.addColorStop(0, 'rgba(10,18,40,0.0)');\n    g.addColorStop(1, 'rgba(10,18,40,0.0)');\n    ctx.fillStyle = g;\n    ctx.fillRect(0,0,w,h);\n\n    // draw lines\n    for(let i=0;i<particles.length;i++){\n      const p = particles[i];\n      for(let j=i+1;j<particles.length;j++){\n        const q = particles[j];\n        const dx = p.x-q.x, dy = p.y-q.y;\n        const d = Math.sqrt(dx*dx+dy*dy);\n        if(d<120){\n          ctx.beginPath();\n          ctx.strokeStyle = `rgba(140,200,255,${0.02 + (120-d)/600})`;\n          ctx.lineWidth = 0.8;\n          ctx.moveTo(p.x,p.y);\n          ctx.lineTo(q.x,q.y);\n          ctx.stroke();\n        }\n      }\n    }\n\n    // draw particles\n    for(const p of particles){\n      ctx.beginPath();\n      const g2 = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*7);\n      g2.addColorStop(0, `hsla(${p.hue},90%,72%,0.9)`);\n      g2.addColorStop(0.8, `hsla(${p.hue},80%,62%,0.08)`);\n      g2.addColorStop(1, 'rgba(255,255,255,0)');\n      ctx.fillStyle = g2;\n      ctx.arc(p.x,p.y,p.r*6,0,Math.PI*2);\n      ctx.fill();\n\n      p.x += p.vx; p.y += p.vy;\n      if(p.x<0) p.x = w;\n      if(p.x>w) p.x = 0;\n      if(p.y<0) p.y = h;\n      if(p.y>h) p.y = 0;\n    }\n\n    requestAnimationFrame(draw);\n  }\n  draw();\n})();\n\n/* Encryption simulation: one button triggers transformation */\n(() => {\n  const encryptBtn = document.getElementById('encryptBtn');\n  const replayBtn = document.getElementById('replayBtn');\n  const revealBtn = document.getElementById('revealKeyBtn');\n  const keycard = document.getElementById('keycard');\n  const keyString = document.getElementById('keyString');\n  const lock = document.getElementById('lock');\n  const orb = document.getElementById('orb');\n  const ciphertext = document.getElementById('ciphertext');\n  const plaintext = document.getElementById('plaintext');\n\n  let animating = false;\n  let currentKey = generateKey();\n\n  function generateKey(){\n    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\n    let k=''; for(let i=0;i<24;i++) k += chars.charAt(Math.floor(Math.random()*chars.length));\n    return k.match(/.{1,4}/g).join(' ');\n  }\n\n  keyString.textContent = currentKey.replace(/[A-Za-z0-9]/g,'•');\n\n  function simulateEncryption(){\n    if(animating) return;\n    animating = true;\n    encryptBtn.setAttribute('aria-pressed','true');\n    encryptBtn.style.transform = 'translateY(0)';\n    ciphertext.style.color = '#9be7ff';\n    // lock unlock animation sequence\n    lock.classList.remove('locked');\n    lock.classList.add('unlocking');\n    orb.querySelector('.ringGlow').style.boxShadow = '0 0 36px 12px rgba(167,139,250,0.18), 0 0 90px 24px rgba(125,211,252,0.08)';\n    // phase 1: scramble plaintext visually\n    const plain = plaintext.textContent;\n    const duration = 2200;\n    const start = performance.now();\n    const scrambleChars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=';\n\n    function frame(t){\n      const elapsed = t - start;\n      const progress = Math.min(1, elapsed / duration);\n\n      // Scramble effect: progressively obfuscate characters\n      const vis = Math.floor(progress * plain.length);\n      let out = '';\n      for(let i=0;i<plain.length;i++){\n        if(i<vis){\n          out += scrambleChars.charAt(Math.floor(Math.random()*scrambleChars.length));\n        } else {\n          out += plain[i];\n        }\n      }\n      // show in ciphertext area as scrambling then finalize\n      ciphertext.textContent = out.split('').map(ch => {\n        if(/\\s/.test(ch)) return ' ';\n        return ch;\n      }).join('');\n\n      // subtle color shift\n      ciphertext.style.color = `hsl(${200 + progress*60}, 90%, ${55 - progress*12}%)`;\n\n      // orbital glow pulse\n      orb.style.transform = `translateY(${Math.sin(progress * Math.PI * 2) * 2}px) scale(${1 + progress*0.01})`;\n\n      if(progress < 1){\n        requestAnimationFrame(frame);\n      } else {\n        // finalize ciphertext as pseudo-base64 string\n        const final = generateCiphertext(plain);\n        // quick flicker\n        ciphertext.style.opacity = '0.2';\n        setTimeout(()=>{ ciphertext.textContent = final; ciphertext.style.opacity = '1'; }, 120);\n        ciphertext.style.transition = 'color 480ms ease, opacity 160ms ease';\n        // lock closes\n        setTimeout(()=> {\n          lock.classList.remove('unlocking');\n          lock.classList.add('locked');\n          orb.querySelector('.ringGlow').style.boxShadow = '';\n        }, 360);\n\n        // reveal generated key masked briefly\n        currentKey = generateKey();\n        keyString.textContent = currentKey.replace(/[A-Za-z0-9]/g,'•');\n\n        // finish\n        setTimeout(()=> {\n          animating = false;\n          encryptBtn.setAttribute('aria-pressed','false');\n        }, 380);\n      }\n    }\n\n    requestAnimationFrame(frame);\n  }\n\n  function generateCiphertext(plain){\n    // simulate: produce a base64-like string derived from plain length and a random salt\n    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';\n    const len = Math.max(16, plain.length*4 + 6);\n    let out = '';\n    for(let i=0;i<len;i++){\n      out += chars.charAt((plain.charCodeAt(i%plain.length) + i*13 + (Math.floor(Math.random()*97))) % chars.length);\n      if((i+1)%4===0 && i < len-1) out += ' ';\n    }\n    return out;\n  }\n\n  encryptBtn.addEventListener('click', simulateEncryption);\n  replayBtn.addEventListener('click', () => {\n    // subtle micro replay: quick shimmer of ciphertext (no re-generate)\n    if(animating) return;\n    ciphertext.style.transition = 'transform 320ms cubic-bezier(.16,.84,.2,1), opacity 220ms';\n    ciphertext.style.transform = 'translateY(-4px)';\n    ciphertext.style.opacity = '0.7';\n    setTimeout(()=>{ ciphertext.style.transform='translateY(0)'; ciphertext.style.opacity='1'; }, 320);\n  });\n\n  // Reveal key toggle: limited interactivity\n  let keyVisible = false;\n  revealBtn.addEventListener('click', ()=>{\n    keyVisible = !keyVisible;\n    revealBtn.setAttribute('aria-pressed', keyVisible ? 'true' : 'false');\n    if(keyVisible){\n      keycard.classList.add('show');\n      keycard.setAttribute('aria-hidden','false');\n      // reveal real key after a short rumble\n      setTimeout(()=> keyString.textContent = currentKey, 260);\n    } else {\n      keycard.classList.remove('show');\n      keycard.setAttribute('aria-hidden','true');\n      setTimeout(()=> keyString.textContent = currentKey.replace(/[A-Za-z0-9]/g,'•'), 200);\n    }\n  });\n\n  // initial subtle animated demo on load\n  setTimeout(()=> {\n    // small entrance effects\n    document.querySelector('.panel').style.transform = 'translateY(0)';\n    // auto-trigger a gentle animation to show concept (non-invasive)\n    simulateEncryption();\n  }, 900);\n\n})();\n\n/* Tiny decorative sparkles around the orb (pure CSS-like via JS) */\n(() => {\n  const orb = document.getElementById('orb');\n  for(let i=0;i<6;i++){\n    const s = document.createElement('div');\n    s.className='sparkle';\n    s.style.left = (10 + Math.random()*80) + '%';\n    s.style.top = (10 + Math.random()*80) + '%';\n    s.style.opacity = 0.6 + Math.random()*0.4;\n    s.style.transform = 'translate(-50%,-50%) scale('+ (0.6+Math.random()*1.2) +')';\n    orb.appendChild(s);\n    animateSparkle(s);\n  }\n\n  function animateSparkle(el){\n    let t = 0;\n    const r = 1200 + Math.random()*1800;\n    function tick(){\n      t += 16;\n      const p = (Math.sin(t/r*Math.PI*2)+1)/2;\n      el.style.opacity = 0.3 + p*0.9;\n      el.style.transform = `translate(-50%,-50%) scale(${0.6 + p*1.6}) translateY(${ -6 + p*12 }px)`;\n      requestAnimationFrame(tick);\n    }\n    tick();\n  }\n})();\n</script>\n</body>\n</html>"
