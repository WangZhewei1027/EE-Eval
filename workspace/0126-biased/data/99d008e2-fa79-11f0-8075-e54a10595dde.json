    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Paging Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 0;\n        }\n        #content {\n            margin-bottom: 20px;\n        }\n        input, button, select {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Paging Example</h1>\n\n    <div id=\"controls\">\n        <label for=\"itemsPerPage\">Items per Page:</label>\n        <input type=\"number\" id=\"itemsPerPage\" value=\"5\" min=\"1\" onchange=\"updateItemsPerPage()\"><br>\n        \n        <label for=\"totalItems\">Total Items:</label>\n        <input type=\"number\" id=\"totalItems\" value=\"50\" min=\"1\" onchange=\"updateTotalItems()\"><br>\n        \n        <button onclick=\"goToPage(1)\">First Page</button>\n        <button onclick=\"goToPreviousPage()\">Previous Page</button>\n        <button onclick=\"goToNextPage()\">Next Page</button>\n        <button onclick=\"goToPage(totalPages)\">Last Page</button>\n\n        <label for=\"goToPage\">Go to Page:</label>\n        <input type=\"number\" id=\"goToPageInput\" value=\"1\" min=\"1\" onchange=\"goToPage(parseInt(this.value))\"><br>\n\n        <div id=\"pageInfo\"></div>\n    </div>\n\n    <div id=\"content\"></div>\n\n    <script>\n        let currentPage = 1;\n        let itemsPerPage = 5;\n        let totalItems = 50;\n        let totalPages = Math.ceil(totalItems / itemsPerPage);\n\n        function updateItemsPerPage() {\n            itemsPerPage = parseInt(document.getElementById(\"itemsPerPage\").value);\n            totalPages = Math.ceil(totalItems / itemsPerPage);\n            currentPage = Math.min(currentPage, totalPages);\n            render();\n        }\n\n        function updateTotalItems() {\n            totalItems = parseInt(document.getElementById(\"totalItems\").value);\n            totalPages = Math.ceil(totalItems / itemsPerPage);\n            currentPage = Math.min(currentPage, totalPages);\n            render();\n        }\n\n        function goToPreviousPage() {\n            if (currentPage > 1) {\n                currentPage--;\n                render();\n            }\n        }\n\n        function goToNextPage() {\n            if (currentPage < totalPages) {\n                currentPage++;\n                render();\n            }\n        }\n\n        function goToPage(page) {\n            if (page >= 1 && page <= totalPages) {\n                currentPage = page;\n                render();\n            }\n        }\n\n        function render() {\n            document.getElementById(\"pageInfo\").innerText = `Page ${currentPage} of ${totalPages}`;\n            const content = document.getElementById(\"content\");\n            content.innerHTML = '';\n\n            const start = (currentPage - 1) * itemsPerPage;\n            const end = Math.min(start + itemsPerPage, totalItems);\n\n            for (let i = start + 1; i <= end; i++) {\n                const item = document.createElement('div');\n                item.textContent = `Item ${i}`;\n                content.appendChild(item);\n            }\n\n            document.getElementById(\"goToPageInput\").max = totalPages;\n        }\n\n        render();\n    </script>\n</body>\n</html>"
