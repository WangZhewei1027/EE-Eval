    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Means Clustering Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #canvas { border: 1px solid black; }\n        #controls { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>K-Means Clustering Simulation</h1>\n<canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n<div id=\"controls\">\n    <label for=\"k-input\">Number of Clusters (K): </label>\n    <input type=\"number\" id=\"k-input\" value=\"3\" min=\"1\" max=\"10\" />\n    <button id=\"generate-data\">Generate Data</button>\n    <button id=\"cluster\">Run K-Means</button>\n    <button id=\"clear\">Clear</button>\n</div>\n\n<script>\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n    let dataPoints = [];\n    let centroids = [];\n    let k = 3;\n\n    document.getElementById('k-input').addEventListener('input', (event) => {\n        k = parseInt(event.target.value);\n    });\n\n    document.getElementById('generate-data').addEventListener('click', () => {\n        dataPoints = [];\n        for (let i = 0; i < 50; i++) {\n            dataPoints.push({\n                x: Math.random() * canvas.width,\n                y: Math.random() * canvas.height\n            });\n        }\n        drawPoints();\n    });\n\n    document.getElementById('cluster').addEventListener('click', () => {\n        centroids = [];\n        for (let i = 0; i < k; i++) {\n            centroids.push({\n                x: Math.random() * canvas.width,\n                y: Math.random() * canvas.height\n            });\n        }\n        let clusters;\n        for (let iteration = 0; iteration < 10; iteration++) {\n            clusters = Array.from({ length: k }, () => []);\n            for (const point of dataPoints) {\n                let closestCentroid = 0;\n                let minDistance = Infinity;\n                centroids.forEach((centroid, index) => {\n                    const distance = Math.sqrt((point.x - centroid.x) ** 2 + (point.y - centroid.y) ** 2);\n                    if (distance < minDistance) {\n                        minDistance = distance;\n                        closestCentroid = index;\n                    }\n                });\n                clusters[closestCentroid].push(point);\n            }\n            for (let i = 0; i < k; i++) {\n                if (clusters[i].length > 0) {\n                    centroids[i] = {\n                        x: clusters[i].reduce((sum, p) => sum + p.x, 0) / clusters[i].length,\n                        y: clusters[i].reduce((sum, p) => sum + p.y, 0) / clusters[i].length,\n                    };\n                }\n            }\n        }\n        drawClusters(clusters);\n    });\n\n    document.getElementById('clear').addEventListener('click', () => {\n        dataPoints = [];\n        centroids = [];\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n    });\n\n    function drawPoints() {\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n        ctx.fillStyle = 'black';\n        dataPoints.forEach(point => {\n            ctx.fillRect(point.x, point.y, 2, 2);\n        });\n    }\n\n    function drawClusters(clusters) {\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n        ctx.fillStyle = 'black';\n        clusters.forEach((cluster, index) => {\n            ctx.fillStyle = index === 0 ? 'red' : index === 1 ? 'green' : 'blue';\n            cluster.forEach(point => {\n                ctx.fillRect(point.x, point.y, 2, 2);\n            });\n            ctx.fillStyle = 'black';\n            const centroid = centroids[index];\n            ctx.fillRect(centroid.x, centroid.y, 5, 5);\n        });\n    }\n</script>\n\n</body>\n</html>"
