  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Load Balancing Simulator</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #ccc; padding: 15px; }\n        .server { border: 1px solid #000; padding: 10px; margin: 5px; }\n        .active { background-color: #f0f0f0; }\n        .overloaded { border-color: red; }\n        .underutilized { border-color: orange; }\n        .stats { margin-top: 10px; font-size: 0.9em; }\n        button { margin: 5px; padding: 5px 10px; }\n        input, select { margin: 5px; }\n        .hidden { display: none; }\n        #visualization { height: 200px; border: 1px solid #000; position: relative; }\n        .request { position: absolute; width: 10px; height: 10px; background: black; border-radius: 50%; }\n    </style>\n</head>\n<body>\n    <h1>Load Balancing Simulator</h1>\n    \n    <div class=\"container\">\n        <div class=\"panel\">\n            <h2>Configuration</h2>\n            <div>\n                <label>Number of Servers: <input type=\"number\" id=\"serverCount\" min=\"1\" max=\"10\" value=\"3\"></label>\n                <button id=\"setupServers\">Setup Servers</button>\n            </div>\n            <div>\n                <label>Load Balancer Algorithm:\n                    <select id=\"algorithm\">\n                        <option value=\"roundRobin\">Round Robin</option>\n                        <option value=\"leastConnections\">Least Connections</option>\n                        <option value=\"random\">Random</option>\n                        <option value=\"ipHash\">IP Hash</option>\n                        <option value=\"weighted\">Weighted</option>\n                    </select>\n                </label>\n            </div>\n            <div id=\"weightControls\" class=\"hidden\">\n                <h3>Server Weights</h3>\n                <div id=\"weightInputs\"></div>\n            </div>\n        </div>\n\n        <div class=\"panel\">\n            <h2>Traffic Generator</h2>\n            <div>\n                <label>Requests per second: <input type=\"range\" id=\"requestRate\" min=\"1\" max=\"20\" value=\"5\"></label>\n                <span id=\"requestRateValue\">5</span>\n            </div>\n            <div>\n                <label>Request duration (ms): <input type=\"range\" id=\"requestDuration\" min=\"50\" max=\"2000\" value=\"500\"></label>\n                <span id=\"requestDurationValue\">500</span>\n            </div>\n            <div>\n                <label>Traffic pattern:\n                    <select id=\"trafficPattern\">\n                        <option value=\"steady\">Steady</option>\n                        <option value=\"bursty\">Bursty</option>\n                        <option value=\"spiky\">Spiky</option>\n                    </select>\n                </label>\n            </div>\n            <button id=\"startTraffic\">Start Traffic</button>\n            <button id=\"stopTraffic\" disabled>Stop Traffic</button>\n            <button id=\"singleRequest\">Send Single Request</button>\n        </div>\n\n        <div class=\"panel\">\n            <h2>Server Status</h2>\n            <div id=\"serversContainer\"></div>\n        </div>\n\n        <div class=\"panel\">\n            <h2>Visualization</h2>\n            <div id=\"visualization\"></div>\n            <div>\n                <button id=\"toggleView\">Toggle Detailed View</button>\n                <button id=\"resetStats\">Reset Statistics</button>\n            </div>\n        </div>\n\n        <div class=\"panel\">\n            <h2>Statistics</h2>\n            <div id=\"statsContainer\">\n                <div>Total Requests: <span id=\"totalRequests\">0</span></div>\n                <div>Requests in Progress: <span id=\"activeRequests\">0</span></div>\n                <div>Average Response Time: <span id=\"avgResponseTime\">0</span>ms</div>\n                <div>Load Balancer Efficiency: <span id=\"efficiency\">0</span>%</div>\n                <div id=\"detailedStats\" class=\"hidden\">\n                    <h3>Per-Server Stats</h3>\n                    <div id=\"serverStats\"></div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let servers = [];\n        let requests = [];\n        let requestInterval;\n        let lastRequestTime = 0;\n        let totalRequests = 0;\n        let stats = {\n            totalRequests: 0,\n            completedRequests: 0,\n            totalResponseTime: 0,\n            serverStats: {}\n        };\n\n        // DOM elements\n        const serverCountInput = document.getElementById('serverCount');\n        const setupServersBtn = document.getElementById('setupServers');\n        const algorithmSelect = document.getElementById('algorithm');\n        const weightControls = document.getElementById('weightControls');\n        const weightInputs = document.getElementById('weightInputs');\n        const requestRateInput = document.getElementById('requestRate');\n        const requestRateValue = document.getElementById('requestRateValue');\n        const requestDurationInput = document.getElementById('requestDuration');\n        const requestDurationValue = document.getElementById('requestDurationValue');\n        const trafficPatternSelect = document.getElementById('trafficPattern');\n        const startTrafficBtn = document.getElementById('startTraffic');\n        const stopTrafficBtn = document.getElementById('stopTraffic');\n        const singleRequestBtn = document.getElementById('singleRequest');\n        const serversContainer = document.getElementById('serversContainer');\n        const visualization = document.getElementById('visualization');\n        const toggleViewBtn = document.getElementById('toggleView');\n        const resetStatsBtn = document.getElementById('resetStats');\n        const totalRequestsSpan = document.getElementById('totalRequests');\n        const activeRequestsSpan = document.getElementById('activeRequests');\n        const avgResponseTimeSpan = document.getElementById('avgResponseTime');\n        const efficiencySpan = document.getElementById('efficiency');\n        const detailedStats = document.getElementById('detailedStats');\n        const serverStats = document.getElementById('serverStats');\n\n        // Event listeners\n        setupServersBtn.addEventListener('click', setupServers);\n        algorithmSelect.addEventListener('change', handleAlgorithmChange);\n        requestRateInput.addEventListener('input', () => requestRateValue.textContent = requestRateInput.value);\n        requestDurationInput.addEventListener('input', () => requestDurationValue.textContent = requestDurationInput.value);\n        startTrafficBtn.addEventListener('click', startTraffic);\n        stopTrafficBtn.addEventListener('click', stopTraffic);\n        singleRequestBtn.addEventListener('click', sendSingleRequest);\n        toggleViewBtn.addEventListener('click', toggleDetailedView);\n        resetStatsBtn.addEventListener('click', resetStats);\n\n        // Initialize\n        setupServers();\n\n        function setupServers() {\n            const count = parseInt(serverCountInput.value);\n            servers = [];\n            serversContainer.innerHTML = '';\n            stats.serverStats = {};\n            \n            for (let i = 0; i < count; i++) {\n                const server = {\n                    id: i,\n                    activeRequests: 0,\n                    totalRequests: 0,\n                    totalProcessingTime: 0,\n                    weight: 1\n                };\n                servers.push(server);\n                stats.serverStats[i] = { requestsHandled: 0, totalTime: 0 };\n                \n                const serverEl = document.createElement('div');\n                serverEl.className = 'server';\n                serverEl.id = `server-${i}`;\n                serverEl.innerHTML = `\n                    <h3>Server ${i}</h3>\n                    <div>Active requests: <span class=\"active-count\">0</span></div>\n                    <div>Total requests: <span class=\"total-count\">0</span></div>\n                    <div>Avg. time: <span class=\"avg-time\">0</span>ms</div>\n                    <div class=\"stats hidden\">\n                        <div>Capacity: <span class=\"capacity\">10</span></div>\n                        <div>Health: <span class=\"health\">100</span>%</div>\n                    </div>\n                `;\n                serversContainer.appendChild(serverEl);\n            }\n            \n            updateWeightControls();\n            updateVisualization();\n        }\n\n        function handleAlgorithmChange() {\n            if (algorithmSelect.value === 'weighted') {\n                weightControls.classList.remove('hidden');\n            } else {\n                weightControls.classList.add('hidden');\n            }\n        }\n\n        function updateWeightControls() {\n            weightInputs.innerHTML = '';\n            servers.forEach(server => {\n                const div = document.createElement('div');\n                div.innerHTML = `\n                    <label>Server ${server.id} weight: \n                        <input type=\"number\" class=\"server-weight\" data-server=\"${server.id}\" \n                               min=\"1\" max=\"10\" value=\"${server.weight}\">\n                    </label>\n                `;\n                weightInputs.appendChild(div);\n            });\n            \n            document.querySelectorAll('.server-weight').forEach(input => {\n                input.addEventListener('change', (e) => {\n                    const serverId = parseInt(e.target.dataset.server);\n                    servers[serverId].weight = parseInt(e.target.value);\n                });\n            });\n        }\n\n        function startTraffic() {\n            stopTraffic();\n            startTrafficBtn.disabled = true;\n            stopTrafficBtn.disabled = false;\n            \n            const rate = parseInt(requestRateInput.value);\n            const duration = parseInt(requestDurationInput.value);\n            const pattern = trafficPatternSelect.value;\n            \n            let delay;\n            if (pattern === 'steady') {\n                delay = 1000 / rate;\n                requestInterval = setInterval(() => sendRequest(duration), delay);\n            } else if (pattern === 'bursty') {\n                // Bursts of 5 seconds with varying intensity\n                let burstCount = 0;\n                requestInterval = setInterval(() => {\n                    burstCount++;\n                    const burstRate = (burstCount % 10 < 5) ? rate * 2 : rate / 2;\n                    for (let i = 0; i < burstRate / 5; i++) {\n                        sendRequest(duration);\n                    }\n                }, 200);\n            } else if (pattern === 'spiky') {\n                // Random spikes\n                requestInterval = setInterval(() => {\n                    const r = Math.random();\n                    const spikeIntensity = r > 0.9 ? rate * 3 : r > 0.7 ? rate * 1.5 : rate;\n                    for (let i = 0; i < spikeIntensity / 5; i++) {\n                        sendRequest(duration);\n                    }\n                }, 200);\n            }\n        }\n\n        function stopTraffic() {\n            clearInterval(requestInterval);\n            startTrafficBtn.disabled = false;\n            stopTrafficBtn.disabled = true;\n        }\n\n        function sendSingleRequest() {\n            const duration = parseInt(requestDurationInput.value);\n            sendRequest(duration);\n        }\n\n        function sendRequest(duration) {\n            const server = selectServer();\n            if (!server) return;\n            \n            const request = {\n                id: totalRequests++,\n                serverId: server.id,\n                startTime: Date.now(),\n                duration: duration,\n                completed: false\n            };\n            \n            server.activeRequests++;\n            server.totalRequests++;\n            stats.serverStats[server.id].requestsHandled++;\n            stats.totalRequests++;\n            \n            requests.push(request);\n            updateServerDisplay(server);\n            updateStats();\n            visualizeRequest(request);\n            \n            setTimeout(() => {\n                request.completed = true;\n                server.activeRequests--;\n                const responseTime = Date.now() - request.startTime;\n                server.totalProcessingTime += responseTime;\n                stats.serverStats[server.id].totalTime += responseTime;\n                stats.totalResponseTime += responseTime;\n                stats.completedRequests++;\n                \n                updateServerDisplay(server);\n                updateStats();\n                removeVisualizedRequest(request);\n            }, duration);\n        }\n\n        function selectServer() {\n            const algorithm = algorithmSelect.value;\n            \n            if (algorithm === 'roundRobin') {\n                // Simple round robin\n                const lastServerId = requests.length > 0 ? requests[requests.length - 1].serverId : -1;\n                const nextIndex = (lastServerId + 1) % servers.length;\n                return servers[nextIndex];\n            } else if (algorithm === 'leastConnections') {\n                // Least connections\n                return servers.reduce((min, server) => \n                    server.activeRequests < min.activeRequests ? server : min, servers[0]);\n            } else if (algorithm === 'random') {\n                // Random selection\n                return servers[Math.floor(Math.random() * servers.length)];\n            } else if (algorithm === 'ipHash') {\n                // Simulate IP hash by hashing request count\n                return servers[totalRequests % servers.length];\n            } else if (algorithm === 'weighted') {\n                // Weighted round robin\n                const totalWeight = servers.reduce((sum, server) => sum + server.weight, 0);\n                let random = Math.random() * totalWeight;\n                for (const server of servers) {\n                    if (random < server.weight) {\n                        return server;\n                    }\n                    random -= server.weight;\n                }\n                return servers[0];\n            }\n        }\n\n        function updateServerDisplay(server) {\n            const serverEl = document.getElementById(`server-${server.id}`);\n            serverEl.querySelector('.active-count').textContent = server.activeRequests;\n            serverEl.querySelector('.total-count').textContent = server.totalRequests;\n            \n            const avgTime = server.totalRequests > 0 \n                ? Math.round(server.totalProcessingTime / server.totalRequests) \n                : 0;\n            serverEl.querySelector('.avg-time').textContent = avgTime;\n            \n            // Update server status classes\n            serverEl.classList.remove('overloaded', 'underutilized', 'active');\n            if (server.activeRequests > 5) {\n                serverEl.classList.add('overloaded');\n            } else if (server.activeRequests === 0) {\n                serverEl.classList.add('underutilized');\n            } else {\n                serverEl.classList.add('active');\n            }\n        }\n\n        function updateStats() {\n            totalRequestsSpan.textContent = stats.totalRequests;\n            activeRequestsSpan.textContent = requests.filter(r => !r.completed).length;\n            \n            const avgResponseTime = stats.completedRequests > 0 \n                ? Math.round(stats.totalResponseTime / stats.completedRequests) \n                : 0;\n            avgResponseTimeSpan.textContent = avgResponseTime;\n            \n            // Calculate efficiency (how well distributed the load is)\n            let efficiency = 0;\n            if (stats.totalRequests > 0) {\n                const avgLoad = stats.totalRequests / servers.length;\n                let variance = 0;\n                for (const server of servers) {\n                    variance += Math.pow(server.totalRequests - avgLoad, 2);\n                }\n                efficiency = Math.max(0, 100 - (Math.sqrt(variance / servers.length) / avgLoad * 100));\n            }\n            efficiencySpan.textContent = Math.round(efficiency);\n            \n            // Update detailed stats if visible\n            if (!detailedStats.classList.contains('hidden')) {\n                updateDetailedStats();\n            }\n        }\n\n        function updateDetailedStats() {\n            serverStats.innerHTML = '';\n            servers.forEach(server => {\n                const stat = stats.serverStats[server.id];\n                const avgTime = stat.requestsHandled > 0 \n                    ? Math.round(stat.totalTime / stat.requestsHandled) \n                    : 0;\n                \n                const div = document.createElement('div');\n                div.innerHTML = `\n                    <h4>Server ${server.id}</h4>\n                    <div>Requests handled: ${stat.requestsHandled}</div>\n                    <div>Average time: ${avgTime}ms</div>\n                    <div>Current load: ${server.activeRequests}</div>\n                `;\n                serverStats.appendChild(div);\n            });\n        }\n\n        function visualizeRequest(request) {\n            const requestEl = document.createElement('div');\n            requestEl.className = 'request';\n            requestEl.id = `request-${request.id}`;\n            requestEl.style.left = `${Math.random() * 90 + 5}%`;\n            requestEl.style.top = `${Math.random() * 90 + 5}%`;\n            visualization.appendChild(requestEl);\n            \n            // Animate to server\n            setTimeout(() => {\n                const serverEl = document.getElementById(`server-${request.serverId}`);\n                const serverRect = serverEl.getBoundingClientRect();\n                const visRect = visualization.getBoundingClientRect();\n                \n                const x = (serverRect.left + serverRect.width/2 - visRect.left) / visRect.width * 100;\n                const y = (serverRect.top + serverRect.height/2 - visRect.top) / visRect.height * 100;\n                \n                requestEl.style.transition = 'all 0.5s linear';\n                requestEl.style.left = `${x}%`;\n                requestEl.style.top = `${y}%`;\n            }, 100);\n        }\n\n        function removeVisualizedRequest(request) {\n            const requestEl = document.getElementById(`request-${request.id}`);\n            if (requestEl) {\n                requestEl.style.opacity = '0';\n                setTimeout(() => requestEl.remove(), 500);\n            }\n        }\n\n        function toggleDetailedView() {\n            detailedStats.classList.toggle('hidden');\n            document.querySelectorAll('.server .stats').forEach(el => {\n                el.classList.toggle('hidden');\n            });\n            \n            if (!detailedStats.classList.contains('hidden')) {\n                updateDetailedStats();\n            }\n        }\n\n        function resetStats() {\n            stopTraffic();\n            stats = {\n                totalRequests: 0,\n                completedRequests: 0,\n                totalResponseTime: 0,\n                serverStats: {}\n            };\n            \n            servers.forEach(server => {\n                server.activeRequests = 0;\n                server.totalRequests = 0;\n                server.totalProcessingTime = 0;\n                stats.serverStats[server.id] = { requestsHandled: 0, totalTime: 0 };\n                updateServerDisplay(server);\n            });\n            \n            requests = [];\n            totalRequests = 0;\n            updateStats();\n            visualization.innerHTML = '';\n        }\n\n        function updateVisualization() {\n            visualization.innerHTML = '';\n            \n            // Draw servers in visualization\n            servers.forEach(server => {\n                const serverEl = document.createElement('div');\n                serverEl.className = 'server-vis';\n                serverEl.textContent = `S${server.id}`;\n                serverEl.style.position = 'absolute';\n                serverEl.style.left = `${(server.id + 1) * (100 / (servers.length + 1))}%`;\n                serverEl.style.top = '50%';\n                serverEl.style.transform = 'translate(-50%, -50%)';\n                serverEl.style.border = '1px solid black';\n                serverEl.style.padding = '5px';\n                visualization.appendChild(serverEl);\n            });\n        }\n    </script>\n</body>\n</html>"
  },
