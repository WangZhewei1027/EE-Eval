    "content": "<html>\n<head>\n    <title>HTTPS Interactive Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .panel {\n            border: 1px solid #000;\n            padding: 15px;\n            margin-bottom: 20px;\n        }\n        button, select, input {\n            margin: 5px;\n            padding: 5px;\n        }\n        .hidden {\n            display: none;\n        }\n        .connection-status {\n            font-weight: bold;\n        }\n        .certificate-details {\n            font-family: monospace;\n            white-space: pre;\n        }\n        .tab {\n            cursor: pointer;\n            padding: 5px 10px;\n            border: 1px solid #000;\n            display: inline-block;\n        }\n        .active-tab {\n            background-color: #eee;\n        }\n    </style>\n</head>\n<body>\n    <h1>HTTPS Interactive Explorer</h1>\n    \n    <div class=\"panel\">\n        <h2>Connection Simulator</h2>\n        <div>\n            <label>Website URL: </label>\n            <input type=\"text\" id=\"urlInput\" value=\"https://example.com\" size=\"40\">\n            <button id=\"connectBtn\">Connect</button>\n        </div>\n        \n        <div id=\"connectionStatus\" class=\"connection-status\">Not connected</div>\n        \n        <div id=\"connectionDetails\" class=\"hidden\">\n            <h3>Connection Details</h3>\n            <div>\n                <label>Protocol: </label>\n                <span id=\"protocol\">-</span>\n            </div>\n            <div>\n                <label>Encryption: </label>\n                <span id=\"encryption\">-</span>\n            </div>\n            <div>\n                <label>Key Exchange: </label>\n                <span id=\"keyExchange\">-</span>\n            </div>\n            <div>\n                <label>Data Integrity: </label>\n                <span id=\"dataIntegrity\">-</span>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Handshake Simulator</h2>\n        <div>\n            <button id=\"startHandshakeBtn\">Start TLS Handshake</button>\n            <button id=\"resetHandshakeBtn\" disabled>Reset</button>\n        </div>\n        \n        <div id=\"handshakeSteps\" class=\"hidden\">\n            <h3>Handshake Steps</h3>\n            <ol>\n                <li id=\"step1\">Client Hello <span class=\"status\">(Pending)</span></li>\n                <li id=\"step2\">Server Hello <span class=\"status\">(Pending)</span></li>\n                <li id=\"step3\">Certificate Exchange <span class=\"status\">(Pending)</span></li>\n                <li id=\"step4\">Key Exchange <span class=\"status\">(Pending)</span></li>\n                <li id=\"step5\">Finished <span class=\"status\">(Pending)</span></li>\n            </ol>\n            \n            <div>\n                <label>Simulate Attack: </label>\n                <select id=\"attackType\">\n                    <option value=\"none\">No attack</option>\n                    <option value=\"mitm\">Man-in-the-Middle</option>\n                    <option value=\"expired\">Expired Certificate</option>\n                    <option value=\"selfsigned\">Self-Signed Certificate</option>\n                </select>\n                <button id=\"simulateAttackBtn\">Simulate</button>\n            </div>\n            \n            <div id=\"attackResult\" class=\"hidden\">\n                <h4>Attack Result</h4>\n                <div id=\"attackMessage\"></div>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Certificate Inspector</h2>\n        <div>\n            <button id=\"viewCertBtn\">View Certificate</button>\n            <button id=\"generateCertBtn\">Generate New Certificate</button>\n        </div>\n        \n        <div id=\"certificateDetails\" class=\"hidden certificate-details\">\n            <h3>Certificate Information</h3>\n            <div>\n                <label>Issuer: </label>\n                <span id=\"certIssuer\">-</span>\n            </div>\n            <div>\n                <label>Valid From: </label>\n                <span id=\"certValidFrom\">-</span>\n            </div>\n            <div>\n                <label>Valid To: </label>\n                <span id=\"certValidTo\">-</span>\n            </div>\n            <div>\n                <label>Public Key: </label>\n                <span id=\"certPublicKey\">-</span>\n            </div>\n            <div>\n                <label>Signature Algorithm: </label>\n                <span id=\"certSignature\">-</span>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Encryption Playground</h2>\n        <div>\n            <div>\n                <label>Message: </label>\n                <input type=\"text\" id=\"messageInput\" value=\"Hello, secure world!\" size=\"40\">\n                <button id=\"encryptBtn\">Encrypt</button>\n                <button id=\"decryptBtn\" disabled>Decrypt</button>\n            </div>\n            \n            <div>\n                <label>Encryption Type: </label>\n                <select id=\"encryptionType\">\n                    <option value=\"aes\">AES-256</option>\n                    <option value=\"rsa\">RSA</option>\n                </select>\n            </div>\n            \n            <div id=\"encryptionResults\" class=\"hidden\">\n                <h3>Encryption Process</h3>\n                <div>\n                    <label>Original: </label>\n                    <span id=\"originalMessage\">-</span>\n                </div>\n                <div>\n                    <label>Encrypted: </label>\n                    <span id=\"encryptedMessage\">-</span>\n                </div>\n                <div>\n                    <label>Decrypted: </label>\n                    <span id=\"decryptedMessage\">-</span>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>HTTPS vs HTTP Comparison</h2>\n        <div>\n            <div class=\"tab active-tab\" data-tab=\"https\">HTTPS</div>\n            <div class=\"tab\" data-tab=\"http\">HTTP</div>\n        </div>\n        \n        <div id=\"httpsTab\" class=\"tab-content\">\n            <h3>HTTPS Advantages</h3>\n            <ul>\n                <li>Encrypted communication</li>\n                <li>Data integrity protection</li>\n                <li>Authentication of the server</li>\n                <li>Protection against eavesdropping</li>\n                <li>Protection against tampering</li>\n            </ul>\n            \n            <div>\n                <label>Simulate secure request: </label>\n                <button id=\"secureRequestBtn\">Make Secure Request</button>\n                <div id=\"secureRequestResult\" class=\"hidden\">\n                    <p>Request completed securely. Data was encrypted in transit.</p>\n                </div>\n            </div>\n        </div>\n        \n        <div id=\"httpTab\" class=\"tab-content hidden\">\n            <h3>HTTP Risks</h3>\n            <ul>\n                <li>Data sent in plain text</li>\n                <li>No encryption</li>\n                <li>No server authentication</li>\n                <li>Vulnerable to MITM attacks</li>\n                <li>Data can be modified in transit</li>\n            </ul>\n            \n            <div>\n                <label>Simulate insecure request: </label>\n                <button id=\"insecureRequestBtn\">Make Insecure Request</button>\n                <div id=\"insecureRequestResult\" class=\"hidden\">\n                    <p>Request intercepted! Your data was visible to attackers.</p>\n                    <div id=\"interceptedData\"></div>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        // Connection Simulator\n        document.getElementById('connectBtn').addEventListener('click', function() {\n            const url = document.getElementById('urlInput').value;\n            const connectionStatus = document.getElementById('connectionStatus');\n            const connectionDetails = document.getElementById('connectionDetails');\n            \n            if (url.startsWith('https://')) {\n                connectionStatus.textContent = 'Connected securely via HTTPS';\n                connectionStatus.style.color = 'green';\n                \n                // Show connection details\n                connectionDetails.classList.remove('hidden');\n                document.getElementById('protocol').textContent = 'TLS 1.3';\n                document.getElementById('encryption').textContent = 'AES-256-GCM';\n                document.getElementById('keyExchange').textContent = 'ECDHE';\n                document.getElementById('dataIntegrity').textContent = 'SHA-256';\n                \n                // Enable handshake simulator\n                document.getElementById('startHandshakeBtn').disabled = false;\n            } else {\n                connectionStatus.textContent = 'Insecure connection (HTTP)';\n                connectionStatus.style.color = 'red';\n                connectionDetails.classList.add('hidden');\n                document.getElementById('startHandshakeBtn').disabled = true;\n            }\n        });\n        \n        // Handshake Simulator\n        document.getElementById('startHandshakeBtn').addEventListener('click', function() {\n            const steps = document.querySelectorAll('#handshakeSteps li');\n            const handshakeSteps = document.getElementById('handshakeSteps');\n            const resetBtn = document.getElementById('resetHandshakeBtn');\n            \n            handshakeSteps.classList.remove('hidden');\n            this.disabled = true;\n            resetBtn.disabled = false;\n            \n            // Simulate handshake steps with delays\n            steps[0].querySelector('.status').textContent = '(Completed)';\n            \n            setTimeout(() => {\n                steps[1].querySelector('.status').textContent = '(Completed)';\n                \n                setTimeout(() => {\n                    steps[2].querySelector('.status').textContent = '(Completed)';\n                    \n                    setTimeout(() => {\n                        steps[3].querySelector('.status').textContent = '(Completed)';\n                        \n                        setTimeout(() => {\n                            steps[4].querySelector('.status').textContent = '(Completed)';\n                        }, 800);\n                    }, 800);\n                }, 800);\n            }, 800);\n        });\n        \n        document.getElementById('resetHandshakeBtn').addEventListener('click', function() {\n            const steps = document.querySelectorAll('#handshakeSteps li .status');\n            steps.forEach(step => {\n                step.textContent = '(Pending)';\n            });\n            document.getElementById('startHandshakeBtn').disabled = false;\n            this.disabled = true;\n            document.getElementById('attackResult').classList.add('hidden');\n        });\n        \n        // Attack Simulator\n        document.getElementById('simulateAttackBtn').addEventListener('click', function() {\n            const attackType = document.getElementById('attackType').value;\n            const attackResult = document.getElementById('attackResult');\n            const attackMessage = document.getElementById('attackMessage');\n            \n            attackResult.classList.remove('hidden');\n            \n            switch(attackType) {\n                case 'mitm':\n                    attackMessage.textContent = 'MITM attack detected! The certificate doesn\\'t match the expected server. Connection terminated.';\n                    break;\n                case 'expired':\n                    attackMessage.textContent = 'Certificate expired! The certificate validity period has ended. Connection terminated.';\n                    break;\n                case 'selfsigned':\n                    attackMessage.textContent = 'Self-signed certificate detected! The certificate is not trusted by your system. Connection terminated.';\n                    break;\n                default:\n                    attackMessage.textContent = 'No attack detected. Connection is secure.';\n            }\n        });\n        \n        // Certificate Inspector\n        document.getElementById('viewCertBtn').addEventListener('click', function() {\n            const certDetails = document.getElementById('certificateDetails');\n            certDetails.classList.remove('hidden');\n            \n            document.getElementById('certIssuer').textContent = 'Let\\'s Encrypt Authority X3';\n            document.getElementById('certValidFrom').textContent = '2023-01-01';\n            document.getElementById('certValidTo').textContent = '2023-04-01';\n            document.getElementById('certPublicKey').textContent = 'RSA 2048 bits';\n            document.getElementById('certSignature').textContent = 'SHA-256 with RSA';\n        });\n        \n        document.getElementById('generateCertBtn').addEventListener('click', function() {\n            const certDetails = document.getElementById('certificateDetails');\n            certDetails.classList.remove('hidden');\n            \n            // Generate random dates\n            const fromDate = new Date();\n            const toDate = new Date();\n            toDate.setMonth(toDate.getMonth() + 3);\n            \n            document.getElementById('certIssuer').textContent = 'Custom CA';\n            document.getElementById('certValidFrom').textContent = fromDate.toISOString().split('T')[0];\n            document.getElementById('certValidTo').textContent = toDate.toISOString().split('T')[0];\n            document.getElementById('certPublicKey').textContent = 'ECDSA 256 bits';\n            document.getElementById('certSignature').textContent = 'SHA-384 with ECDSA';\n        });\n        \n        // Encryption Playground\n        document.getElementById('encryptBtn').addEventListener('click', function() {\n            const message = document.getElementById('messageInput').value;\n            const encryptionType = document.getElementById('encryptionType').value;\n            const results = document.getElementById('encryptionResults');\n            \n            results.classList.remove('hidden');\n            document.getElementById('originalMessage').textContent = message;\n            \n            // Simulate encryption\n            let encrypted;\n            if (encryptionType === 'aes') {\n                encrypted = 'AES:' + btoa(message).split('').reverse().join('');\n            } else {\n                encrypted = 'RSA:' + btoa(message).replace(/=/g, '!');\n            }\n            \n            document.getElementById('encryptedMessage').textContent = encrypted;\n            document.getElementById('decryptBtn').disabled = false;\n        });\n        \n        document.getElementById('decryptBtn').addEventListener('click', function() {\n            const encrypted = document.getElementById('encryptedMessage').textContent;\n            let decrypted;\n            \n            if (encrypted.startsWith('AES:')) {\n                const data = encrypted.substring(4).split('').reverse().join('');\n                decrypted = atob(data);\n            } else {\n                const data = encrypted.substring(4).replace(/!/g, '=');\n                decrypted = atob(data);\n            }\n            \n            document.getElementById('decryptedMessage').textContent = decrypted;\n        });\n        \n        // Tab system\n        document.querySelectorAll('.tab').forEach(tab => {\n            tab.addEventListener('click', function() {\n                // Remove active class from all tabs\n                document.querySelectorAll('.tab').forEach(t => {\n                    t.classList.remove('active-tab');\n                });\n                \n                // Add active class to clicked tab\n                this.classList.add('active-tab');\n                \n                // Hide all tab contents\n                document.querySelectorAll('.tab-content').forEach(content => {\n                    content.classList.add('hidden');\n                });\n                \n                // Show selected tab content\n                const tabId = this.getAttribute('data-tab') + 'Tab';\n                document.getElementById(tabId).classList.remove('hidden');\n            });\n        });\n        \n        // Request simulations\n        document.getElementById('secureRequestBtn').addEventListener('click', function() {\n            document.getElementById('secureRequestResult').classList.remove('hidden');\n        });\n        \n        document.getElementById('insecureRequestBtn').addEventListener('click', function() {\n            const result = document.getElementById('insecureRequestResult');\n            const intercepted = document.getElementById('interceptedData');\n            \n            result.classList.remove('hidden');\n            intercepted.textContent = 'Intercepted: username=user123&password=secret123&creditcard=4111111111111111';\n        });\n    </script>\n</body>\n</html>"
