    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Context Switching Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #ffffff, #e0e0e0);\n            margin: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            color: #333;\n            overflow: hidden;\n            transition: background 0.5s ease;\n        }\n\n        .container {\n            position: relative;\n            width: 80%;\n            max-width: 800px;\n            height: 500px;\n            background: #fff;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n            border-radius: 15px;\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .scene {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            opacity: 0.8;\n            transition: transform 0.5s ease-in-out;\n        }\n\n        .scene-1 {\n            background: url('https://source.unsplash.com/random/800x500/?nature') center/cover no-repeat;\n            z-index: 1;\n        }\n\n        .scene-2 {\n            background: url('https://source.unsplash.com/random/800x500/?city') center/cover no-repeat;\n            transform: translateX(100%);\n        }\n\n        .button {\n            background-color: #007BFF;\n            color: #fff;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background 0.3s ease;\n            position: absolute;\n            bottom: 20px;\n        }\n\n        .button:hover {\n            background-color: #0056b3;\n        }\n\n        h1 {\n            position: absolute;\n            top: 20px;\n            left: 20px;\n            font-size: 2em;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Context Switching</h1>\n        <div class=\"scene scene-1\"></div>\n        <div class=\"scene scene-2\"></div>\n        <button class=\"button\" id=\"switchScene\">Switch Scene</button>\n    </div>\n\n    <script>\n        const button = document.getElementById('switchScene');\n        let sceneIndex = 0;\n        \n        button.addEventListener('click', () => {\n            const scene1 = document.querySelector('.scene-1');\n            const scene2 = document.querySelector('.scene-2');\n\n            if (sceneIndex === 0) {\n                scene1.style.transform = 'translateX(-100%)';\n                scene2.style.transform = 'translateX(0)';\n                sceneIndex = 1;\n            } else {\n                scene1.style.transform = 'translateX(0)';\n                scene2.style.transform = 'translateX(100%)';\n                sceneIndex = 0;\n            }\n        });\n    </script>\n</body>\n</html>"
