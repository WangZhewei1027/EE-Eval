    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling Visualizer</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #dfe6e9;\n            --success: #00b894;\n            --warning: #fdcb6e;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization-container {\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            margin-bottom: 3rem;\n            overflow: hidden;\n            position: relative;\n            transition: all 0.3s ease;\n        }\n\n        .visualization-container:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.15);\n        }\n\n        .cpu {\n            height: 80px;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            border-radius: 10px;\n            margin-bottom: 2rem;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.5rem;\n            position: relative;\n            overflow: hidden;\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n        }\n\n        .cpu::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(90deg, \n                rgba(255,255,255,0) 0%, \n                rgba(255,255,255,0.3) 50%, \n                rgba(255,255,255,0) 100%);\n            animation: shine 3s infinite;\n        }\n\n        .process-queue {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            min-height: 120px;\n            align-items: flex-end;\n            padding: 1rem;\n            background-color: rgba(223, 230, 233, 0.3);\n            border-radius: 10px;\n            position: relative;\n        }\n\n        .process {\n            width: 60px;\n            background: var(--accent);\n            border-radius: 8px 8px 0 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: flex-end;\n            color: white;\n            font-weight: bold;\n            transition: all 0.3s ease;\n            position: relative;\n            box-shadow: 0 5px 15px rgba(253, 121, 168, 0.3);\n            cursor: pointer;\n        }\n\n        .process:hover {\n            transform: translateY(-5px);\n        }\n\n        .process-id {\n            background: rgba(0, 0, 0, 0.2);\n            width: 100%;\n            text-align: center;\n            padding: 0.5rem 0;\n            border-radius: 8px 8px 0 0;\n        }\n\n        .process-burst {\n            height: 0;\n            background: var(--success);\n            width: 100%;\n            border-radius: 0 0 8px 8px;\n            transition: height 0.5s ease;\n        }\n\n        .timeline {\n            display: flex;\n            gap: 0;\n            margin-top: 2rem;\n            position: relative;\n        }\n\n        .time-unit {\n            flex: 1;\n            height: 60px;\n            border-right: 1px dashed rgba(45, 52, 54, 0.2);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: flex-end;\n            position: relative;\n        }\n\n        .time-unit:last-child {\n            border-right: none;\n        }\n\n        .time-label {\n            position: absolute;\n            bottom: -25px;\n            font-size: 0.8rem;\n            color: var(--dark);\n            opacity: 0.7;\n        }\n\n        .process-execution {\n            position: absolute;\n            top: 10px;\n            height: 30px;\n            border-radius: 15px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 0.9rem;\n            animation: pulse 2s infinite;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            font-weight: bold;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .algorithm-info {\n            background: white;\n            border-radius: 20px;\n            padding: 2rem;\n            margin-top: 3rem;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);\n        }\n\n        .algorithm-info h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n\n        .algorithm-info p {\n            line-height: 1.6;\n            margin-bottom: 1rem;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes shine {\n            0% { transform: translateX(-100%); }\n            100% { transform: translateX(100%); }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .floating-circles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            z-index: -1;\n            pointer-events: none;\n        }\n\n        .floating-circles li {\n            position: absolute;\n            display: block;\n            list-style: none;\n            width: 20px;\n            height: 20px;\n            background: rgba(108, 92, 231, 0.1);\n            border-radius: 50%;\n            animation: float 25s linear infinite;\n            bottom: -150px;\n        }\n\n        .floating-circles li:nth-child(1) {\n            left: 25%;\n            width: 80px;\n            height: 80px;\n            animation-delay: 0s;\n        }\n\n        .floating-circles li:nth-child(2) {\n            left: 10%;\n            width: 20px;\n            height: 20px;\n            animation-delay: 2s;\n            animation-duration: 12s;\n        }\n\n        .floating-circles li:nth-child(3) {\n            left: 70%;\n            width: 20px;\n            height: 20px;\n            animation-delay: 4s;\n        }\n\n        .floating-circles li:nth-child(4) {\n            left: 40%;\n            width: 60px;\n            height: 60px;\n            animation-delay: 0s;\n            animation-duration: 18s;\n        }\n\n        .floating-circles li:nth-child(5) {\n            left: 65%;\n            width: 20px;\n            height: 20px;\n            animation-delay: 0s;\n        }\n\n        .floating-circles li:nth-child(6) {\n            left: 75%;\n            width: 110px;\n            height: 110px;\n            animation-delay: 3s;\n        }\n\n        .floating-circles li:nth-child(7) {\n            left: 35%;\n            width: 150px;\n            height: 150px;\n            animation-delay: 7s;\n        }\n\n        .floating-circles li:nth-child(8) {\n            left: 50%;\n            width: 25px;\n            height: 25px;\n            animation-delay: 15s;\n            animation-duration: 45s;\n        }\n\n        .floating-circles li:nth-child(9) {\n            left: 20%;\n            width: 15px;\n            height: 15px;\n            animation-delay: 2s;\n            animation-duration: 35s;\n        }\n\n        .floating-circles li:nth-child(10) {\n            left: 85%;\n            width: 150px;\n            height: 150px;\n            animation-delay: 0s;\n            animation-duration: 11s;\n        }\n\n        @keyframes float {\n            0% {\n                transform: translateY(0) rotate(0deg);\n                opacity: 1;\n                border-radius: 0;\n            }\n            100% {\n                transform: translateY(-1000px) rotate(720deg);\n                opacity: 0;\n                border-radius: 50%;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"floating-circles\">\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n        <li></li>\n    </div>\n\n    <div class=\"container\">\n        <header>\n            <h1>CPU Scheduling Visualizer</h1>\n            <p class=\"subtitle\">A beautiful visualization of how operating systems manage process execution using various scheduling algorithms to maximize CPU utilization and throughput.</p>\n        </header>\n\n        <div class=\"visualization-container\">\n            <div class=\"cpu\">CPU Core</div>\n            \n            <div class=\"process-queue\" id=\"ready-queue\">\n                <!-- Processes will be added here by JavaScript -->\n            </div>\n\n            <div class=\"timeline\" id=\"timeline\">\n                <!-- Timeline units will be added here by JavaScript -->\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"start-btn\">Start Simulation</button>\n            <button id=\"reset-btn\">Reset</button>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--accent);\"></div>\n                <span>Process</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--success);\"></div>\n                <span>Execution</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--warning);\"></div>\n                <span>Waiting</span>\n            </div>\n        </div>\n\n        <div class=\"algorithm-info\">\n            <h2>Round Robin Scheduling</h2>\n            <p>Round Robin is a preemptive algorithm where each process is assigned a fixed time slot (time quantum) in cyclic order. It's simple, fair, and starvation-free, making it one of the most commonly used scheduling algorithms in time-sharing systems.</p>\n            <p>In this visualization, each process gets a time quantum of 2 units. The scheduler cycles through the ready queue, allocating the CPU to each process for the time quantum. If a process completes before its time quantum expires, the CPU is immediately allocated to the next process.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const readyQueue = document.getElementById('ready-queue');\n            const timeline = document.getElementById('timeline');\n            const startBtn = document.getElementById('start-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            \n            // Create processes\n            const processes = [\n                { id: 'P1', burstTime: 5, arrivalTime: 0 },\n                { id: 'P2', burstTime: 3, arrivalTime: 1 },\n                { id: 'P3', burstTime: 8, arrivalTime: 2 },\n                { id: 'P4', burstTime: 4, arrivalTime: 3 }\n            ];\n            \n            // Create timeline units\n            for (let i = 0; i < 20; i++) {\n                const timeUnit = document.createElement('div');\n                timeUnit.className = 'time-unit';\n                const timeLabel = document.createElement('div');\n                timeLabel.className = 'time-label';\n                timeLabel.textContent = i;\n                timeUnit.appendChild(timeLabel);\n                timeline.appendChild(timeUnit);\n            }\n            \n            // Render processes in ready queue\n            function renderProcesses() {\n                readyQueue.innerHTML = '';\n                processes.forEach(process => {\n                    const processEl = document.createElement('div');\n                    processEl.className = 'process';\n                    processEl.dataset.id = process.id;\n                    \n                    const processId = document.createElement('div');\n                    processId.className = 'process-id';\n                    processId.textContent = process.id;\n                    \n                    const processBurst = document.createElement('div');\n                    processBurst.className = 'process-burst';\n                    processBurst.style.height = `${(process.burstTime / 10) * 100}px`;\n                    \n                    processEl.appendChild(processId);\n                    processEl.appendChild(processBurst);\n                    readyQueue.appendChild(processEl);\n                });\n            }\n            \n            // Simulate Round Robin scheduling\n            function simulateRoundRobin() {\n                let time = 0;\n                const quantum = 2;\n                let remainingProcesses = [...processes];\n                let currentProcessIndex = 0;\n                \n                const interval = setInterval(() => {\n                    if (time >= 20 || remainingProcesses.length === 0) {\n                        clearInterval(interval);\n                        return;\n                    }\n                    \n                    // Get current process\n                    const currentProcess = remainingProcesses[currentProcessIndex];\n                    \n                    // Create execution visualization\n                    const executionEl = document.createElement('div');\n                    executionEl.className = 'process-execution';\n                    executionEl.style.background = getRandomColor();\n                    executionEl.style.left = `${(time / 20) * 100}%`;\n                    executionEl.style.width = `${(Math.min(quantum, currentProcess.burstTime) / 20) * 100}%`;\n                    executionEl.textContent = currentProcess.id;\n                    \n                    // Find the corresponding time unit and append execution\n                    const timeUnits = document.querySelectorAll('.time-unit');\n                    if (timeUnits[time]) {\n                        timeUnits[time].appendChild(executionEl);\n                    }\n                    \n                    // Update process burst time\n                    currentProcess.burstTime -= quantum;\n                    \n                    // If process is completed, remove it\n                    if (currentProcess.burstTime <= 0) {\n                        remainingProcesses.splice(currentProcessIndex, 1);\n                        if (remainingProcesses.length === 0) {\n                            clearInterval(interval);\n                            return;\n                        }\n                        // Adjust index if we removed the last process\n                        if (currentProcessIndex >= remainingProcesses.length) {\n                            currentProcessIndex = 0;\n                        }\n                    } else {\n                        // Move to next process\n                        currentProcessIndex = (currentProcessIndex + 1) % remainingProcesses.length;\n                    }\n                    \n                    time += quantum;\n                    \n                }, 1000);\n            }\n            \n            // Helper function to generate random colors\n            function getRandomColor() {\n                const colors = ['#6c5ce7', '#00b894', '#fd79a8', '#fdcb6e', '#0984e3', '#e17055'];\n                return colors[Math.floor(Math.random() * colors.length)];\n            }\n            \n            // Event listeners\n            startBtn.addEventListener('click', function() {\n                renderProcesses();\n                simulateRoundRobin();\n                startBtn.disabled = true;\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                // Reset processes\n                processes.forEach(process => {\n                    process.burstTime = process.originalBurstTime || \n                        (process.id === 'P1' ? 5 : \n                         process.id === 'P2' ? 3 : \n                         process.id === 'P3' ? 8 : 4);\n                });\n                \n                // Clear timeline\n                document.querySelectorAll('.process-execution').forEach(el => el.remove());\n                startBtn.disabled = false;\n                renderProcesses();\n            });\n            \n            // Initial render\n            renderProcesses();\n        });\n    </script>\n</body>\n</html>"
