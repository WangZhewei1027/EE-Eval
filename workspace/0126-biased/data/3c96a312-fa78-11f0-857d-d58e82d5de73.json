    "content": "<html lang=\"en\" >\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Graph (Undirected) — Aesthetic Visualization</title>\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;500&display=swap');\n\n    /* Reset and base */\n    * {\n      box-sizing: border-box;\n      user-select: none;\n    }\n    body {\n      margin: 0;\n      min-height: 100vh;\n      background: radial-gradient(ellipse at center, #0b0f29 0%, #050813 90%);\n      font-family: 'Poppins', sans-serif;\n      color: #e0e6f4;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      overflow: hidden;\n      padding: 40px 20px 80px;\n    }\n\n    h1 {\n      font-weight: 500;\n      font-size: 3.2rem;\n      letter-spacing: 0.12em;\n      margin: 0 0 20px 0;\n      user-select: none;\n      text-transform: uppercase;\n      color: #b3c7ff;\n      text-shadow:\n        0 0 12px #a4b8ff88,\n        0 0 20px #8eabffcc;\n    }\n    h2 {\n      font-weight: 300;\n      font-size: 1.15rem;\n      margin: 0 0 55px;\n      color: #8d9ae8cc;\n      letter-spacing: 0.08em;\n      font-style: italic;\n      user-select: none;\n    }\n\n    .container {\n      position: relative;\n      width: 680px;\n      max-width: 95vw;\n      aspect-ratio: 1 / 1;\n      background: radial-gradient(ellipse at center, #112152 32%, #1c2953 85%);\n      border-radius: 28px;\n      box-shadow:\n        0 8px 20px -3px rgba(49,71,146,0.85),\n        inset 0 0 40px #5062f745;\n      padding: 24px;\n      overflow: visible;\n      user-select: none;\n    }\n\n    svg {\n      width: 100%;\n      height: 100%;\n      display: block;\n      overflow: visible;\n      filter:\n        drop-shadow(0 0 3px #a5aafe80)\n        drop-shadow(0 0 10px #7788fcaa);\n    }\n\n    /* Node Styling */\n    .node {\n      fill: #7f92ffcc;\n      stroke: #fbfbffdd;\n      stroke-width: 1.7;\n      filter:\n        drop-shadow(0 0 4px #697affaa);\n      transition: fill 0.3s ease, r 0.3s ease;\n      cursor: default;\n      transform-origin: center center;\n      pointer-events: auto;\n    }\n    .node.highlighted {\n      fill: #a4b8ffff;\n      r: 14;\n      filter:\n        drop-shadow(0 0 12px #ced8ffff);\n    }\n\n    /* Edge Styling */\n    .edge {\n      stroke: #99aaffcc;\n      stroke-width: 2.4;\n      stroke-linecap: round;\n      transition:\n        stroke 0.25s ease,\n        stroke-width 0.25s ease;\n      filter: drop-shadow(0 0 4px #aabbffcc);\n    }\n    .edge.highlighted {\n      stroke: #e0eaffff;\n      stroke-width: 4;\n      filter: drop-shadow(0 0 10px #eff7ffff);\n    }\n\n    /* Labels */\n    .label {\n      font-size: 14px;\n      fill: #a3a9ffdd;\n      font-weight: 500;\n      text-shadow:\n        0 0 3px #2d2d7855;\n      user-select: none;\n      pointer-events: none;\n      font-family: 'Poppins', sans-serif;\n    }\n\n    /* Glow pulse animation for nodes */\n    @keyframes nodeGlowPulse {\n      0%, 100% {\n        filter: drop-shadow(0 0 5px #839dffcc);\n      }\n      50% {\n        filter: drop-shadow(0 0 18px #a6b6ffff);\n      }\n    }\n    .glow-pulse {\n      animation: nodeGlowPulse 3s ease-in-out infinite;\n    }\n\n    /* UI Controls */\n    .ui-controls {\n      margin-top: 48px;\n      display: flex;\n      gap: 18px;\n    }\n\n    button {\n      background: linear-gradient(145deg, #7984ef, #5c67d2);\n      border: none;\n      outline: none;\n      padding: 14px 28px;\n      border-radius: 14px;\n      box-shadow:\n        0 4px 8px #4954c2cc,\n        inset 0 2px 10px #9da9ffcc;\n      cursor: pointer;\n      font-weight: 600;\n      font-size: 1rem;\n      color: #e4e8ff;\n      letter-spacing: 0.05em;\n      user-select: none;\n      transition:\n        background 0.3s ease,\n        box-shadow 0.3s ease,\n        transform 0.2s ease;\n      font-family: 'Poppins', sans-serif;\n      text-transform: uppercase;\n    }\n    button:hover {\n      background: linear-gradient(150deg, #8ea1ff, #7181dd);\n      box-shadow:\n        0 8px 16px #7e8affcc,\n        inset 0 4px 16px #c1c9ffdd;\n      transform: translateY(-2.5px);\n    }\n    button:active {\n      transform: translateY(1px);\n      box-shadow:\n        0 2px 6px #4b54b2cc,\n        inset 0 1px 5px #8a9fe8cc;\n    }\n\n    /* Tooltip */\n    .tooltip {\n      position: absolute;\n      background: #2d367ddd;\n      backdrop-filter: blur(6px);\n      padding: 6px 14px;\n      border-radius: 10px;\n      font-size: 13px;\n      font-weight: 500;\n      color: #cdd3ff;\n      pointer-events: none;\n      user-select: none;\n      opacity: 0;\n      transform: translate(-50%, -10px) scale(0.85);\n      transition: opacity 0.3s ease, transform 0.3s ease;\n      box-shadow:\n        0 4px 14px -2px #4a5290cc;\n      white-space: nowrap;\n      font-family: 'Poppins', sans-serif;\n      z-index: 100;\n    }\n    .tooltip.visible {\n      opacity: 1;\n      transform: translate(-50%, -20px) scale(1);\n    }\n\n  </style>\n</head>\n<body>\n  <h1>Graph (Undirected)</h1>\n  <h2>An elegant visualization of an undirected graph</h2>\n\n  <div class=\"container\" aria-label=\"Undirected graph visualization\">\n    <svg aria-hidden=\"true\" viewBox=\"0 0 680 680\" role=\"img\" >\n      <!-- Edges -->\n      <line id=\"e0\" class=\"edge\" x1=\"340\" y1=\"120\" x2=\"520\" y2=\"250\" />\n      <line id=\"e1\" class=\"edge\" x1=\"520\" y1=\"250\" x2=\"440\" y2=\"440\" />\n      <line id=\"e2\" class=\"edge\" x1=\"440\" y1=\"440\" x2=\"230\" y2=\"440\" />\n      <line id=\"e3\" class=\"edge\" x1=\"230\" y1=\"440\" x2=\"130\" y2=\"250\" />\n      <line id=\"e4\" class=\"edge\" x1=\"130\" y1=\"250\" x2=\"340\" y2=\"120\" />\n\n      <line id=\"e5\" class=\"edge\" x1=\"340\" y1=\"120\" x2=\"340\" y2=\"520\" />\n      <line id=\"e6\" class=\"edge\" x1=\"340\" y1=\"520\" x2=\"230\" y2=\"440\" />\n      <line id=\"e7\" class=\"edge\" x1=\"340\" y1=\"520\" x2=\"440\" y2=\"440\" />\n      <line id=\"e8\" class=\"edge\" x1=\"130\" y1=\"250\" x2=\"230\" y2=\"440\" />\n\n      <!-- Nodes -->\n      <circle id=\"n0\" class=\"node glow-pulse\" cx=\"340\" cy=\"120\" r=\"14\" />\n      <circle id=\"n1\" class=\"node glow-pulse\" cx=\"520\" cy=\"250\" r=\"14\" />\n      <circle id=\"n2\" class=\"node glow-pulse\" cx=\"440\" cy=\"440\" r=\"14\" />\n      <circle id=\"n3\" class=\"node glow-pulse\" cx=\"230\" cy=\"440\" r=\"14\" />\n      <circle id=\"n4\" class=\"node glow-pulse\" cx=\"130\" cy=\"250\" r=\"14\" />\n      <circle id=\"n5\" class=\"node glow-pulse\" cx=\"340\" cy=\"520\" r=\"14\" />\n\n      <!-- Labels -->\n      <text class=\"label\" x=\"340\" y=\"115\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">A</text>\n      <text class=\"label\" x=\"520\" y=\"245\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">B</text>\n      <text class=\"label\" x=\"440\" y=\"435\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">C</text>\n      <text class=\"label\" x=\"230\" y=\"435\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">D</text>\n      <text class=\"label\" x=\"130\" y=\"245\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">E</text>\n      <text class=\"label\" x=\"340\" y=\"515\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">F</text>\n    </svg>\n  </div>\n\n  <div class=\"ui-controls\" role=\"group\" aria-label=\"Graph controls\">\n    <button id=\"btnHighlightEdges\" aria-pressed=\"false\" aria-label=\"Toggle highlight edges\">Toggle Highlight Edges</button>\n    <button id=\"btnPulseNodes\" aria-pressed=\"true\" aria-label=\"Toggle nodes glowing pulse\">Toggle Node Pulse</button>\n  </div>\n\n  <div class=\"tooltip\" id=\"tooltip\" role=\"tooltip\" aria-hidden=\"true\"></div>\n\n  <script>\n    (() => {\n      const edges = [...document.querySelectorAll('.edge')];\n      const nodes = [...document.querySelectorAll('.node')];\n      const btnHighlightEdges = document.getElementById('btnHighlightEdges');\n      const btnPulseNodes = document.getElementById('btnPulseNodes');\n      const tooltip = document.getElementById('tooltip');\n      const container = document.querySelector('.container');\n      \n      // Edge highlighting toggle state\n      let edgesHighlighted = false;\n      // Pulse toggle state\n      let pulseActive = true;\n\n      // Setup node labels mapping for tooltip info\n      const nodeLabels = {\n        'n0': 'Node A',\n        'n1': 'Node B',\n        'n2': 'Node C',\n        'n3': 'Node D',\n        'n4': 'Node E',\n        'n5': 'Node F'\n      };\n\n      // Button: Toggle highlight on edges\n      btnHighlightEdges.addEventListener('click', () => {\n        edgesHighlighted = !edgesHighlighted;\n        edges.forEach(edge => {\n          if (edgesHighlighted) edge.classList.add('highlighted');\n          else edge.classList.remove('highlighted');\n        });\n        btnHighlightEdges.setAttribute('aria-pressed', edgesHighlighted);\n      });\n\n      // Button: Toggle node pulse animation\n      btnPulseNodes.addEventListener('click', () => {\n        pulseActive = !pulseActive;\n        nodes.forEach(node => {\n          if (pulseActive) {\n            node.classList.add('glow-pulse');\n          } else {\n            node.classList.remove('glow-pulse');\n          }\n        });\n        btnPulseNodes.setAttribute('aria-pressed', pulseActive);\n      });\n\n      // Simple tooltip for nodes: show node label on hover\n      nodes.forEach(node => {\n        node.addEventListener('mouseenter', (e) => {\n          const label = nodeLabels[node.id] || 'Node';\n          tooltip.innerText = label;\n          tooltip.style.opacity = '1';\n          tooltip.setAttribute('aria-hidden', 'false');\n          positionTooltip(e);\n        });\n        node.addEventListener('mousemove', (e) => {\n          positionTooltip(e);\n        });\n        node.addEventListener('mouseleave', () => {\n          tooltip.style.opacity = '0';\n          tooltip.setAttribute('aria-hidden', 'true');\n        });\n        node.addEventListener('focus', (e) => {\n          const label = nodeLabels[node.id] || 'Node';\n          tooltip.innerText = label;\n          tooltip.style.opacity = '1';\n          tooltip.setAttribute('aria-hidden', 'false');\n          const rect = e.target.getBoundingClientRect();\n          tooltip.style.left = `${rect.left + rect.width / 2}px`;\n          tooltip.style.top = `${rect.top - 14}px`;\n        });\n        node.addEventListener('blur', () => {\n          tooltip.style.opacity = '0';\n          tooltip.setAttribute('aria-hidden', 'true');\n        });\n      });\n\n      function positionTooltip(e) {\n        const rect = container.getBoundingClientRect();\n        const x = e.clientX - rect.left;\n        const y = e.clientY - rect.top;\n        tooltip.style.left = `${x}px`;\n        tooltip.style.top = `${y - 18}px`;\n      }\n\n      // Accessibility: keyboard focus outlines for nodes\n      nodes.forEach(node => {\n        node.setAttribute('tabindex', '0');\n      });\n\n    })();\n  </script>\n</body>\n</html>"
