    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Cosmic Compiler | A Visual Journey</title>\n    <style>\n        :root {\n            --primary: #6e00ff;\n            --secondary: #ff00b3;\n            --dark: #0a0a20;\n            --light: #f1f1ff;\n            --accent: #00ffcc;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n        \n        body {\n            background-color: var(--dark);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            background-image: \n                radial-gradient(circle at 25% 30%, rgba(110, 0, 255, 0.15) 0%, transparent 40%),\n                radial-gradient(circle at 75% 70%, rgba(255, 0, 179, 0.15) 0%, transparent 40%);\n        }\n        \n        @font-face {\n            font-family: 'Inter';\n            src: url('https://rsms.me/inter/inter.css');\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            position: relative;\n        }\n        \n        header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 4rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            line-height: 1.1;\n            max-width: 800px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: rgba(241, 241, 255, 0.7);\n            margin-top: 1rem;\n            max-width: 600px;\n            line-height: 1.6;\n        }\n        \n        .compiler-visualization {\n            position: relative;\n            height: 500px;\n            margin: 5rem 0;\n            overflow: hidden;\n        }\n        \n        .code-panel {\n            position: absolute;\n            width: 40%;\n            height: 320px;\n            background: rgba(15, 15, 35, 0.8);\n            backdrop-filter: blur(10px);\n            border-radius: 12px;\n            padding: 1.5rem;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n            transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);\n        }\n        \n        .source-code {\n            top: 0;\n            left: 0;\n            transform-origin: left center;\n            animation: slideInLeft 1s ease-out;\n        }\n        \n        .ast-panel {\n            top: 50px;\n            left: 30%;\n            z-index: 2;\n            animation: floatUp 1.2s ease-out 0.3s both;\n        }\n        \n        .ir-panel {\n            top: 100px;\n            left: 60%;\n            z-index: 1;\n            animation: floatUp 1.2s ease-out 0.6s both;\n        }\n        \n        .assembly-panel {\n            bottom: 0;\n            right: 0;\n            transform-origin: right center;\n            animation: slideInRight 1s ease-out 0.9s both;\n        }\n        \n        .panel-title {\n            font-size: 0.9rem;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            margin-bottom: 1rem;\n            color: var(--accent);\n            display: flex;\n            align-items: center;\n        }\n        \n        .panel-title span {\n            margin-right: 0.5rem;\n        }\n        \n        .code {\n            font-family: 'SF Mono', 'Roboto Mono', monospace;\n            font-size: 0.9rem;\n            line-height: 1.6;\n            color: rgba(241, 241, 255, 0.8);\n            white-space: pre;\n            overflow: hidden;\n        }\n        \n        .code .keyword {\n            color: #ff7eee;\n        }\n        \n        .code .type {\n            color: #00e1ff;\n        }\n        \n        .code .string {\n            color: #a5ff90;\n        }\n        \n        .code .comment {\n            color: rgba(241, 241, 255, 0.3);\n        }\n        \n        .code .number {\n            color: #ffcc66;\n        }\n        \n        .connection {\n            position: absolute;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            height: 2px;\n            transform-origin: left center;\n            z-index: 0;\n            opacity: 0.5;\n        }\n        \n        .connection-1 {\n            width: 120px;\n            top: 160px;\n            left: 28%;\n            animation: stretchRight 0.8s ease-out 1s both;\n        }\n        \n        .connection-2 {\n            width: 120px;\n            top: 210px;\n            left: 48%;\n            animation: stretchRight 0.8s ease-out 1.3s both;\n        }\n        \n        .connection-3 {\n            width: 160px;\n            bottom: 160px;\n            right: 36%;\n            animation: stretchLeft 0.8s ease-out 1.6s both;\n        }\n        \n        .connection-dot {\n            position: absolute;\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            background: var(--accent);\n            z-index: 3;\n        }\n        \n        .connection-dot-1 {\n            top: 158px;\n            left: 28%;\n            animation: pulse 2s infinite 1.5s;\n        }\n        \n        .connection-dot-2 {\n            top: 208px;\n            left: 48%;\n            animation: pulse 2s infinite 1.8s;\n        }\n        \n        .connection-dot-3 {\n            bottom: 158px;\n            right: 36%;\n            animation: pulse 2s infinite 2.1s;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 3rem;\n            animation: fadeIn 1s ease-out 1.5s both;\n        }\n        \n        .compile-btn {\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 1rem 2rem;\n            font-size: 1rem;\n            font-weight: 600;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 10px 30px rgba(110, 0, 255, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .compile-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 15px 40px rgba(110, 0, 255, 0.4);\n        }\n        \n        .compile-btn:active {\n            transform: translateY(0);\n        }\n        \n        .compile-btn::after {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n        \n        .compile-btn:hover::after {\n            opacity: 1;\n        }\n        \n        .particles {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: -1;\n        }\n        \n        .particle {\n            position: absolute;\n            background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary));\n            border-radius: 50%;\n            opacity: 0.5;\n            filter: blur(1px);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideInLeft {\n            from { transform: translateX(-50px) rotateY(30deg); opacity: 0; }\n            to { transform: translateX(0) rotateY(0); opacity: 1; }\n        }\n        \n        @keyframes slideInRight {\n            from { transform: translateX(50px) rotateY(-30deg); opacity: 0; }\n            to { transform: translateX(0) rotateY(0); opacity: 1; }\n        }\n        \n        @keyframes floatUp {\n            from { transform: translateY(50px); opacity: 0; }\n            to { transform: translateY(0); opacity: 1; }\n        }\n        \n        @keyframes stretchRight {\n            from { transform: scaleX(0); }\n            to { transform: scaleX(1); }\n        }\n        \n        @keyframes stretchLeft {\n            from { transform: scaleX(0); transform-origin: right center; }\n            to { transform: scaleX(1); transform-origin: right center; }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); opacity: 1; }\n            50% { transform: scale(1.5); opacity: 0.7; }\n            100% { transform: scale(1); opacity: 1; }\n        }\n        \n        @keyframes glow {\n            0% { box-shadow: 0 0 10px rgba(110, 0, 255, 0.5); }\n            50% { box-shadow: 0 0 20px rgba(110, 0, 255, 0.8); }\n            100% { box-shadow: 0 0 10px rgba(110, 0, 255, 0.5); }\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            color: rgba(241, 241, 255, 0.4);\n            font-size: 0.9rem;\n            animation: fadeIn 1s ease-out 2s both;\n        }\n        \n        /* Responsive adjustments */\n        @media (max-width: 900px) {\n            .compiler-visualization {\n                height: 800px;\n            }\n            \n            .code-panel {\n                width: 80%;\n            }\n            \n            .source-code {\n                top: 0;\n                left: 10%;\n            }\n            \n            .ast-panel {\n                top: 340px;\n                left: 10%;\n            }\n            \n            .ir-panel {\n                top: 680px;\n                left: 10%;\n            }\n            \n            .assembly-panel {\n                bottom: 0;\n                right: 10%;\n            }\n            \n            .connection-1, .connection-2, .connection-3 {\n                display: none;\n            }\n            \n            .connection-dot-1, .connection-dot-2, .connection-dot-3 {\n                display: none;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <div>\n                <h1>The Cosmic Compiler</h1>\n                <p class=\"subtitle\">A visual journey through the transformation of code, from human-readable syntax to machine-executable instructions.</p>\n            </div>\n        </header>\n        \n        <div class=\"compiler-visualization\">\n            <div class=\"particles\" id=\"particles\"></div>\n            \n            <div class=\"code-panel source-code\">\n                <div class=\"panel-title\">\n                    <span>✏️</span> Source Code\n                </div>\n                <div class=\"code\">\n<span class=\"keyword\">function</span> <span class=\"type\">fibonacci</span>(n) {\n  <span class=\"keyword\">if</span> (n &lt; 2) {\n    <span class=\"keyword\">return</span> n;\n  }\n  \n  <span class=\"keyword\">return</span> <span class=\"type\">fibonacci</span>(n - 1) + \n         <span class=\"type\">fibonacci</span>(n - 2);\n}\n\n<span class=\"comment\">// Calculate 10th Fibonacci number</span>\n<span class=\"type\">console</span>.<span class=\"type\">log</span>(<span class=\"type\">fibonacci</span>(<span class=\"number\">10</span>));\n                </div>\n            </div>\n            \n            <div class=\"code-panel ast-panel\">\n                <div class=\"panel-title\">\n                    <span>🌳</span> Abstract Syntax Tree\n                </div>\n                <div class=\"code\">\nFunctionDeclaration\n├── Identifier (fibonacci)\n├── Parameters\n│   └── Identifier (n)\n└── BlockStatement\n    ├── IfStatement\n    │   ├── BinaryExpression (&lt;)\n    │   │   ├── Identifier (n)\n    │   │   └── Literal (2)\n    │   └── ReturnStatement\n    │       └── Identifier (n)\n    └── ReturnStatement\n        └── BinaryExpression (+)\n            ├── CallExpression\n            │   ├── Identifier (fibonacci)\n            │   └── BinaryExpression (-)\n            │       ├── Identifier (n)\n            │       └── Literal (1)\n            └── CallExpression\n                ├── Identifier (fibonacci)\n                └── BinaryExpression (-)\n                    ├── Identifier (n)\n                    └── Literal (2)\n                </div>\n            </div>\n            \n            <div class=\"code-panel ir-panel\">\n                <div class=\"panel-title\">\n                    <span>🔧</span> Intermediate Representation\n                </div>\n                <div class=\"code\">\ndefine i32 @fibonacci(i32 %n) {\nentry:\n  %cmp = icmp slt i32 %n, 2\n  br i1 %cmp, label %ret_n, label %recursive\n  \nret_n:\n  ret i32 %n\n  \nrecursive:\n  %n1 = sub i32 %n, 1\n  %fib1 = call i32 @fibonacci(i32 %n1)\n  \n  %n2 = sub i32 %n, 2\n  %fib2 = call i32 @fibonacci(i32 %n2)\n  \n  %result = add i32 %fib1, %fib2\n  ret i32 %result\n}\n                </div>\n            </div>\n            \n            <div class=\"code-panel assembly-panel\">\n                <div class=\"panel-title\">\n                    <span>⚙️</span> Machine Code\n                </div>\n                <div class=\"code\">\nfibonacci:\n  cmp rdi, 2\n  jge .LBB0_2\n  mov rax, rdi\n  ret\n.LBB0_2:\n  push rbx\n  mov rbx, rdi\n  dec rdi\n  call fibonacci\n  mov rdi, rbx\n  add rdi, -2\n  mov rbx, rax\n  call fibonacci\n  add rax, rbx\n  pop rbx\n  ret\n                </div>\n            </div>\n            \n            <div class=\"connection connection-1\"></div>\n            <div class=\"connection connection-2\"></div>\n            <div class=\"connection connection-3\"></div>\n            \n            <div class=\"connection-dot connection-dot-1\"></div>\n            <div class=\"connection-dot connection-dot-2\"></div>\n            <div class=\"connection-dot connection-dot-3\"></div>\n        </div>\n        \n        <div class=\"controls\">\n            <button class=\"compile-btn\" id=\"compileBtn\">Animate Compilation</button>\n        </div>\n        \n        <footer>\n            <p>A visual demonstration of compilation phases | Not an actual compiler</p>\n        </footer>\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            const particlesContainer = document.getElementById('particles');\n            const particleCount = 30;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 5 + 1;\n                const x = Math.random() * 100;\n                const y = Math.random() * 100;\n                const duration = Math.random() * 20 + 10;\n                const delay = Math.random() * 5;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${x}%`;\n                particle.style.top = `${y}%`;\n                particle.style.animation = `float ${duration}s linear ${delay}s infinite`;\n                \n                particlesContainer.appendChild(particle);\n            }\n            \n            // Add float animation for particles\n            const style = document.createElement('style');\n            style.textContent = `\n                @keyframes float {\n                    0% { transform: translate(0, 0); opacity: 0; }\n                    10% { opacity: 0.5; }\n                    90% { opacity: 0.5; }\n                    100% { transform: translate(${Math.random() * 100 - 50}px, ${Math.random() * 100 - 50}px); opacity: 0; }\n                }\n            `;\n            document.head.appendChild(style);\n            \n            // Simple button interaction\n            const compileBtn = document.getElementById('compileBtn');\n            const panels = document.querySelectorAll('.code-panel');\n            const connections = document.querySelectorAll('.connection');\n            const dots = document.querySelectorAll('.connection-dot');\n            \n            compileBtn.addEventListener('click', function() {\n                // Reset animations\n                panels.forEach(panel => {\n                    panel.style.animation = 'none';\n                    void panel.offsetWidth; // Trigger reflow\n                });\n                \n                connections.forEach(conn => {\n                    conn.style.animation = 'none';\n                    void conn.offsetWidth;\n                });\n                \n                dots.forEach(dot => {\n                    dot.style.animation = 'none';\n                    void dot.offsetWidth;\n                });\n                \n                // Reapply animations\n                document.querySelector('.source-code').style.animation = 'glow 2s ease infinite';\n                setTimeout(() => {\n                    document.querySelector('.ast-panel').style.animation = 'glow 2s ease infinite 0.3s';\n                }, 300);\n                setTimeout(() => {\n                    document.querySelector('.ir-panel').style.animation = 'glow 2s ease infinite 0.6s';\n                }, 600);\n                setTimeout(() => {\n                    document.querySelector('.assembly-panel').style.animation = 'glow 2s ease infinite 0.9s';\n                }, 900);\n                \n                // Animation for connections\n                connections[0].style.animation = 'stretchRight 0.8s ease-out, glow 2s ease infinite 1s';\n                connections[1].style.animation = 'stretchRight 0.8s ease-out 0.3s, glow 2s ease infinite 1.3s';\n                connections[2].style.animation = 'stretchLeft 0.8s ease-out 0.6s, glow 2s ease infinite 1.6s';\n                \n                // Animation for dots\n                dots[0].style.animation = 'pulse 2s infinite 1.5s';\n                dots[1].style.animation = 'pulse 2s infinite 1.8s';\n                dots[2].style.animation = 'pulse 2s infinite 2.1s';\n            });\n        });\n    </script>\n</body>\n</html>"
