  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Big-O Notation Interactive Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 15px;\n        }\n        .control-group {\n            margin-right: 20px;\n        }\n        button, select, input {\n            padding: 5px 10px;\n        }\n        .graph-container {\n            width: 100%;\n            height: 300px;\n            border: 1px solid #000;\n            position: relative;\n            overflow: hidden;\n        }\n        .graph-line {\n            position: absolute;\n            height: 2px;\n            background-color: black;\n            transform-origin: 0 0;\n        }\n        .complexity-info {\n            margin-top: 20px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin-top: 10px;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        .code-example {\n            font-family: monospace;\n            white-space: pre;\n            background-color: #f5f5f5;\n            padding: 10px;\n            margin: 10px 0;\n        }\n        .comparison-table {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Big-O Notation Interactive Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Complexity Graph</h2>\n            <div class=\"controls\">\n                <div class=\"control-group\">\n                    <label>Select Algorithm:</label>\n                    <select id=\"algorithm-select\">\n                        <option value=\"constant\">O(1) - Constant</option>\n                        <option value=\"logarithmic\">O(log n) - Logarithmic</option>\n                        <option value=\"linear\">O(n) - Linear</option>\n                        <option value=\"linearithmic\">O(n log n) - Linearithmic</option>\n                        <option value=\"quadratic\">O(n²) - Quadratic</option>\n                        <option value=\"cubic\">O(n³) - Cubic</option>\n                        <option value=\"exponential\">O(2ⁿ) - Exponential</option>\n                        <option value=\"factorial\">O(n!) - Factorial</option>\n                    </select>\n                </div>\n                <div class=\"control-group\">\n                    <label>Input Size (n):</label>\n                    <input type=\"range\" id=\"input-size\" min=\"1\" max=\"50\" value=\"10\">\n                    <span id=\"input-size-value\">10</span>\n                </div>\n                <div class=\"control-group\">\n                    <label>Compare with:</label>\n                    <select id=\"compare-select\">\n                        <option value=\"none\">None</option>\n                        <option value=\"constant\">O(1)</option>\n                        <option value=\"logarithmic\">O(log n)</option>\n                        <option value=\"linear\">O(n)</option>\n                        <option value=\"linearithmic\">O(n log n)</option>\n                        <option value=\"quadratic\">O(n²)</option>\n                        <option value=\"cubic\">O(n³)</option>\n                        <option value=\"exponential\">O(2ⁿ)</option>\n                        <option value=\"factorial\">O(n!)</option>\n                    </select>\n                </div>\n                <button id=\"add-to-comparison\">Add to Comparison</button>\n                <button id=\"reset-comparison\">Reset Comparison</button>\n            </div>\n            \n            <div class=\"graph-container\" id=\"graph\"></div>\n            \n            <div class=\"complexity-info\">\n                <h3>Current Complexity: <span id=\"current-complexity\">O(1)</span></h3>\n                <p>Operations: <span id=\"operations-count\">1</span></p>\n                <p id=\"complexity-description\">Description: Constant time - The algorithm takes the same amount of time regardless of input size.</p>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Algorithm Examples</h2>\n            <div class=\"controls\">\n                <button id=\"show-example\">Show Example Code</button>\n                <button id=\"run-example\">Run Example</button>\n                <button id=\"step-through\">Step Through</button>\n                <span id=\"step-counter\"></span>\n            </div>\n            \n            <div class=\"code-example\" id=\"code-example\">\n                // Select an algorithm to see example code\n            </div>\n            \n            <div id=\"execution-output\" class=\"code-example\" style=\"display: none;\">\n                Execution output will appear here...\n            </div>\n        </div>\n        \n        <div class=\"panel comparison-table\">\n            <h2>Complexity Comparison</h2>\n            <table id=\"comparison-table\">\n                <thead>\n                    <tr>\n                        <th>Complexity</th>\n                        <th>n=1</th>\n                        <th>n=10</th>\n                        <th>n=100</th>\n                        <th>n=1000</th>\n                        <th>Description</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>O(1)</td>\n                        <td>1</td>\n                        <td>1</td>\n                        <td>1</td>\n                        <td>1</td>\n                        <td>Constant time</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Complexity Calculator</h2>\n            <div class=\"controls\">\n                <div class=\"control-group\">\n                    <label>Your Algorithm's Operations:</label>\n                    <input type=\"text\" id=\"custom-operations\" placeholder=\"e.g., 3n² + 2n + 1\">\n                </div>\n                <button id=\"calculate-complexity\">Calculate Big-O</button>\n            </div>\n            <div id=\"calculation-result\">\n                <p>Enter your algorithm's operation count to determine its Big-O complexity.</p>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // DOM elements\n        const algorithmSelect = document.getElementById('algorithm-select');\n        const inputSizeSlider = document.getElementById('input-size');\n        const inputSizeValue = document.getElementById('input-size-value');\n        const compareSelect = document.getElementById('compare-select');\n        const addToComparisonBtn = document.getElementById('add-to-comparison');\n        const resetComparisonBtn = document.getElementById('reset-comparison');\n        const graphContainer = document.getElementById('graph');\n        const currentComplexity = document.getElementById('current-complexity');\n        const operationsCount = document.getElementById('operations-count');\n        const complexityDescription = document.getElementById('complexity-description');\n        const showExampleBtn = document.getElementById('show-example');\n        const runExampleBtn = document.getElementById('run-example');\n        const stepThroughBtn = document.getElementById('step-through');\n        const stepCounter = document.getElementById('step-counter');\n        const codeExample = document.getElementById('code-example');\n        const executionOutput = document.getElementById('execution-output');\n        const comparisonTable = document.getElementById('comparison-table');\n        const customOperationsInput = document.getElementById('custom-operations');\n        const calculateComplexityBtn = document.getElementById('calculate-complexity');\n        const calculationResult = document.getElementById('calculation-result');\n        \n        // State\n        let currentAlgorithm = 'constant';\n        let currentN = 10;\n        let comparisonAlgorithms = [];\n        let exampleExecutionSteps = 0;\n        let exampleMaxSteps = 0;\n        let exampleInterval = null;\n        \n        // Complexity functions\n        const complexityFunctions = {\n            constant: n => 1,\n            logarithmic: n => Math.log2(n),\n            linear: n => n,\n            linearithmic: n => n * Math.log2(n),\n            quadratic: n => n * n,\n            cubic: n => n * n * n,\n            exponential: n => Math.pow(2, n),\n            factorial: n => {\n                let result = 1;\n                for (let i = 2; i <= n; i++) {\n                    result *= i;\n                }\n                return result;\n            }\n        };\n        \n        // Complexity descriptions\n        const complexityDescriptions = {\n            constant: \"Constant time - The algorithm takes the same amount of time regardless of input size.\",\n            logarithmic: \"Logarithmic time - The algorithm's time grows logarithmically with input size (very efficient).\",\n            linear: \"Linear time - The algorithm's time grows linearly with input size.\",\n            linearithmic: \"Linearithmic time - The algorithm's time grows in proportion to n log n (common in efficient sorting algorithms).\",\n            quadratic: \"Quadratic time - The algorithm's time grows with the square of the input size.\",\n            cubic: \"Cubic time - The algorithm's time grows with the cube of the input size.\",\n            exponential: \"Exponential time - The algorithm's time doubles with each addition to the input size (very inefficient).\",\n            factorial: \"Factorial time - The algorithm's time grows factorially with input size (extremely inefficient).\"\n        };\n        \n        // Example code snippets\n        const exampleCode = {\n            constant: `// Accessing an array element by index\nfunction getFirstElement(arr) {\n    return arr[0];  // O(1) - single operation\n}`,\n            logarithmic: `// Binary search\nfunction binarySearch(arr, target) {\n    let left = 0;\n    let right = arr.length - 1;\n    \n    while (left <= right) {  // O(log n) - halves search space each iteration\n        const mid = Math.floor((left + right) / 2);\n        if (arr[mid] === target) return mid;\n        if (arr[mid] < target) left = mid + 1;\n        else right = mid - 1;\n    }\n    return -1;\n}`,\n            linear: `// Linear search\nfunction linearSearch(arr, target) {\n    for (let i = 0; i < arr.length; i++) {  // O(n) - one operation per element\n        if (arr[i] === target) return i;\n    }\n    return -1;\n}`,\n            linearithmic: `// Merge sort\nfunction mergeSort(arr) {\n    if (arr.length <= 1) return arr;\n    \n    const mid = Math.floor(arr.length / 2);\n    const left = mergeSort(arr.slice(0, mid));  // O(n log n) - divide and conquer\n    const right = mergeSort(arr.slice(mid));\n    \n    return merge(left, right);\n}\n\nfunction merge(left, right) {\n    let result = [];\n    while (left.length && right.length) {\n        result.push(left[0] < right[0] ? left.shift() : right.shift());\n    }\n    return result.concat(left, right);\n}`,\n            quadratic: `// Bubble sort\nfunction bubbleSort(arr) {\n    for (let i = 0; i < arr.length; i++) {        // O(n²) - nested loops\n        for (let j = 0; j < arr.length - i - 1; j++) {\n            if (arr[j] > arr[j + 1]) {\n                [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];\n            }\n        }\n    }\n    return arr;\n}`,\n            cubic: `// 3 nested loops example\nfunction findTriplets(arr) {\n    const triplets = [];\n    for (let i = 0; i < arr.length; i++) {        // O(n³) - three nested loops\n        for (let j = i + 1; j < arr.length; j++) {\n            for (let k = j + 1; k < arr.length; k++) {\n                if (arr[i] + arr[j] + arr[k] === 0) {\n                    triplets.push([arr[i], arr[j], arr[k]]);\n                }\n            }\n        }\n    }\n    return triplets;\n}`,\n            exponential: `// Recursive Fibonacci (naive implementation)\nfunction fibonacci(n) {\n    if (n <= 1) return n;                         // O(2ⁿ) - recursive tree\n    return fibonacci(n - 1) + fibonacci(n - 2);\n}`,\n            factorial: `// Generating all permutations\nfunction getPermutations(arr) {\n    if (arr.length <= 1) return [arr];            // O(n!) - factorial growth\n    \n    const result = [];\n    for (let i = 0; i < arr.length; i++) {\n        const current = arr[i];\n        const remaining = [...arr.slice(0, i), ...arr.slice(i + 1)];\n        const remainingPerms = getPermutations(remaining);\n        \n        for (const perm of remainingPerms) {\n            result.push([current, ...perm]);\n        }\n    }\n    return result;\n}`\n        };\n        \n        // Initialize\n        updateGraph();\n        updateComplexityInfo();\n        updateComparisonTable();\n        \n        // Event listeners\n        algorithmSelect.addEventListener('change', () => {\n            currentAlgorithm = algorithmSelect.value;\n            updateGraph();\n            updateComplexityInfo();\n            codeExample.textContent = exampleCode[currentAlgorithm];\n            resetExampleExecution();\n        });\n        \n        inputSizeSlider.addEventListener('input', () => {\n            currentN = parseInt(inputSizeSlider.value);\n            inputSizeValue.textContent = currentN;\n            updateGraph();\n            updateComplexityInfo();\n        });\n        \n        addToComparisonBtn.addEventListener('click', () => {\n            const algo = compareSelect.value;\n            if (algo !== 'none' && !comparisonAlgorithms.includes(algo)) {\n                comparisonAlgorithms.push(algo);\n                updateGraph();\n                updateComparisonTable();\n            }\n        });\n        \n        resetComparisonBtn.addEventListener('click', () => {\n            comparisonAlgorithms = [];\n            updateGraph();\n            updateComparisonTable();\n        });\n        \n        showExampleBtn.addEventListener('click', () => {\n            codeExample.textContent = exampleCode[currentAlgorithm];\n            executionOutput.style.display = 'none';\n            resetExampleExecution();\n        });\n        \n        runExampleBtn.addEventListener('click', () => {\n            executionOutput.style.display = 'block';\n            executionOutput.textContent = `Running ${currentAlgorithm} example with n=${currentN}...\\n`;\n            \n            // Simulate execution based on algorithm\n            switch(currentAlgorithm) {\n                case 'constant':\n                    executionOutput.textContent += `Result: ${complexityFunctions.constant(currentN)}`;\n                    break;\n                case 'logarithmic':\n                    executionOutput.textContent += `Result: ${Math.round(complexityFunctions.logarithmic(currentN) * 100) / 100}`;\n                    break;\n                case 'linear':\n                    executionOutput.textContent += `Result: ${complexityFunctions.linear(currentN)}`;\n                    break;\n                case 'linearithmic':\n                    executionOutput.textContent += `Result: ${Math.round(complexityFunctions.linearithmic(currentN) * 100) / 100}`;\n                    break;\n                case 'quadratic':\n                    executionOutput.textContent += `Result: ${complexityFunctions.quadratic(currentN)}`;\n                    break;\n                case 'cubic':\n                    executionOutput.textContent += `Result: ${complexityFunctions.cubic(currentN)}`;\n                    break;\n                case 'exponential':\n                    executionOutput.textContent += `Result: ${complexityFunctions.exponential(currentN)}`;\n                    break;\n                case 'factorial':\n                    executionOutput.textContent += `Result: ${complexityFunctions.factorial(currentN)}`;\n                    break;\n            }\n        });\n        \n        stepThroughBtn.addEventListener('click', () => {\n            if (exampleInterval) {\n                clearInterval(exampleInterval);\n                exampleInterval = null;\n                stepThroughBtn.textContent = 'Step Through';\n                return;\n            }\n            \n            executionOutput.style.display = 'block';\n            executionOutput.textContent = `Stepping through ${currentAlgorithm} example with n=${currentN}...\\n\\n`;\n            \n            exampleMaxSteps = currentN;\n            exampleExecutionSteps = 0;\n            \n            stepThroughBtn.textContent = 'Stop Stepping';\n            \n            exampleInterval = setInterval(() => {\n                if (exampleExecutionSteps >= exampleMaxSteps) {\n                    clearInterval(exampleInterval);\n                    exampleInterval = null;\n                    stepThroughBtn.textContent = 'Step Through';\n                    return;\n                }\n                \n                exampleExecutionSteps++;\n                stepCounter.textContent = `Step ${exampleExecutionSteps} of ${exampleMaxSteps}`;\n                \n                // Simulate step\n                switch(currentAlgorithm) {\n                    case 'constant':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Operation completed in constant time\\n`;\n                        break;\n                    case 'logarithmic':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Halved search space to ${Math.ceil(currentN / Math.pow(2, exampleExecutionSteps))} elements\\n`;\n                        break;\n                    case 'linear':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Processed element ${exampleExecutionSteps}\\n`;\n                        break;\n                    case 'linearithmic':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Divided and processed subset\\n`;\n                        break;\n                    case 'quadratic':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Compared element ${exampleExecutionSteps} with others\\n`;\n                        break;\n                    case 'cubic':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Processed triple ${exampleExecutionSteps}\\n`;\n                        break;\n                    case 'exponential':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Expanded recursive tree level ${exampleExecutionSteps}\\n`;\n                        break;\n                    case 'factorial':\n                        executionOutput.textContent += `Step ${exampleExecutionSteps}: Generated ${exampleExecutionSteps} permutations\\n`;\n                        break;\n                }\n                \n                // Scroll to bottom\n                executionOutput.scrollTop = executionOutput.scrollHeight;\n            }, 500);\n        });\n        \n        calculateComplexityBtn.addEventListener('click', () => {\n            const expression = customOperationsInput.value.trim();\n            if (!expression) return;\n            \n            // Very simplified complexity calculation\n            if (expression.includes('n!')) {\n                calculationResult.innerHTML = `<p>Big-O: O(n!) - Factorial complexity</p>`;\n            } else if (expression.includes('2^n') || expression.includes('2**n')) {\n                calculationResult.innerHTML = `<p>Big-O: O(2ⁿ) - Exponential complexity</p>`;\n            } else if (expression.includes('n^3') || expression.includes('n**3')) {\n                calculationResult.innerHTML = `<p>Big-O: O(n³) - Cubic complexity</p>`;\n            } else if (expression.includes('n^2') || expression.includes('n**2')) {\n                calculationResult.innerHTML = `<p>Big-O: O(n²) - Quadratic complexity</p>`;\n            } else if (expression.includes('n log n')) {\n                calculationResult.innerHTML = `<p>Big-O: O(n log n) - Linearithmic complexity</p>`;\n            } else if (expression.includes('n')) {\n                calculationResult.innerHTML = `<p>Big-O: O(n) - Linear complexity</p>`;\n            } else if (expression.includes('log n')) {\n                calculationResult.innerHTML = `<p>Big-O: O(log n) - Logarithmic complexity</p>`;\n            } else {\n                calculationResult.innerHTML = `<p>Big-O: O(1) - Constant complexity</p>`;\n            }\n            \n            calculationResult.innerHTML += `<p>Note: This is a simplified estimation. For accurate analysis, consider the dominant term and drop coefficients/constants.</p>`;\n        });\n        \n        // Helper functions\n        function updateGraph() {\n            // Clear previous graph\n            graphContainer.innerHTML = '';\n            \n            const width = graphContainer.clientWidth;\n            const height = graphContainer.clientHeight;\n            const maxN = 50;\n            const maxOperations = complexityFunctions.factorial(maxN);\n            \n            // Draw axes\n            const xAxis = document.createElement('div');\n            xAxis.className = 'graph-line';\n            xAxis.style.width = width + 'px';\n            xAxis.style.left = '0px';\n            xAxis.style.bottom = '0px';\n            graphContainer.appendChild(xAxis);\n            \n            const yAxis = document.createElement('div');\n            yAxis.className = 'graph-line';\n            yAxis.style.height = height + 'px';\n            yAxis.style.left = '0px';\n            yAxis.style.bottom = '0px';\n            yAxis.style.transform = 'rotate(90deg)';\n            graphContainer.appendChild(yAxis);\n            \n            // Draw current algorithm line\n            drawComplexityLine(currentAlgorithm, 'black', width, height, maxN, maxOperations);\n            \n            // Draw comparison lines\n            comparisonAlgorithms.forEach((algo, index) => {\n                const colors = ['red', 'blue', 'green', 'purple', 'orange'];\n                drawComplexityLine(algo, colors[index % colors.length], width, height, maxN, maxOperations);\n            });\n            \n            // Draw current n marker\n            const marker = document.createElement('div');\n            marker.style.position = 'absolute';\n            marker.style.width = '2px';\n            marker.style.height = '10px';\n            marker.style.backgroundColor = 'black';\n            marker.style.left = (currentN / maxN * width) + 'px';\n            marker.style.bottom = '0px';\n            graphContainer.appendChild(marker);\n        }\n        \n        function drawComplexityLine(algorithm, color, width, height, maxN, maxOperations) {\n            const line = document.createElement('div');\n            line.className = 'graph-line';\n            line.style.backgroundColor = color;\n            \n            let path = '';\n            for (let n = 1; n <= maxN; n++) {\n                const operations = complexityFunctions[algorithm](n);\n                const x = n / maxN * width;\n                const y = (1 - operations / maxOperations) * height;\n                \n                if (n === 1) {\n                    path += `M ${x} ${y} `;\n                } else {\n                    path += `L ${x} ${y} `;\n                }\n            }\n            \n            // Create a simple line approximation (since we're not using SVG)\n            const lineSegments = [];\n            for (let n = 1; n <= maxN; n++) {\n                const operations = complexityFunctions[algorithm](n);\n                const x = n / maxN * width;\n                const y = (1 - operations / maxOperations) * height;\n                lineSegments.push({x, y});\n            }\n            \n            for (let i = 1; i < lineSegments.length; i++) {\n                const segment = document.createElement('div');\n                segment.className = 'graph-line';\n                segment.style.backgroundColor = color;\n                segment.style.left = lineSegments[i-1].x + 'px';\n                segment.style.bottom = lineSegments[i-1].y + 'px';\n                \n                const dx = lineSegments[i].x - lineSegments[i-1].x;\n                const dy = lineSegments[i].y - lineSegments[i-1].y;\n                const length = Math.sqrt(dx*dx + dy*dy);\n                const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n                \n                segment.style.width = length + 'px';\n                segment.style.transform = `rotate(${angle}deg)`;\n                segment.style.transformOrigin = '0 0';\n                \n                graphContainer.appendChild(segment);\n            }\n        }\n        \n        function updateComplexityInfo() {\n            const operations = complexityFunctions[currentAlgorithm](currentN);\n            currentComplexity.textContent = `O(${getComplexityNotation(currentAlgorithm)})`;\n            operationsCount.textContent = typeof operations === 'number' ? \n                Math.round(operations * 100) / 100 : \n                operations.toString();\n            complexityDescription.textContent = complexityDescriptions[currentAlgorithm];\n        }\n        \n        function getComplexityNotation(algo) {\n            switch(algo) {\n                case 'constant': return '1';\n                case 'logarithmic': return 'log n';\n                case 'linear': return 'n';\n                case 'linearithmic': return 'n log n';\n                case 'quadratic': return 'n²';\n                case 'cubic': return 'n³';\n                case 'exponential': return '2ⁿ';\n                case 'factorial': return 'n!';\n                default: return '1';\n            }\n        }\n        \n        function updateComparisonTable() {\n            const tbody = comparisonTable.querySelector('tbody');\n            tbody.innerHTML = '';\n            \n            // Add current algorithm\n            addComplexityToTable(tbody, currentAlgorithm);\n            \n            // Add comparison algorithms\n            comparisonAlgorithms.forEach(algo => {\n                addComplexityToTable(tbody, algo);\n            });\n        }\n        \n        function addComplexityToTable(tbody, algorithm) {\n            const row = document.createElement('tr');\n            \n            const notationCell = document.createElement('td');\n            notationCell.textContent = `O(${getComplexityNotation(algorithm)})`;\n            row.appendChild(notationCell);\n            \n            [1, 10, 100, 1000].forEach(n => {\n                const cell = document.createElement('td');\n                const operations = complexityFunctions[algorithm](n);\n                cell.textContent = typeof operations === 'number' ? \n                    Math.round(operations * 100) / 100 : \n                    operations.toString();\n                row.appendChild(cell);\n            });\n            \n            const descCell = document.createElement('td');\n            descCell.textContent = complexityDescriptions[algorithm].split(' - ')[1];\n            row.appendChild(descCell);\n            \n            tbody.appendChild(row);\n        }\n        \n        function resetExampleExecution() {\n            if (exampleInterval) {\n                clearInterval(exampleInterval);\n                exampleInterval = null;\n            }\n            executionOutput.style.display = 'none';\n            stepThroughBtn.textContent = 'Step Through';\n            stepCounter.textContent = '';\n        }\n    </script>\n</body>\n</html>"
  },
