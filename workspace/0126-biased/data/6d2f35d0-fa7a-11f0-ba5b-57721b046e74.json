  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Recursion Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .control-panel {\n            border: flex;\n            padding: 10px;\n            margin-bottom: 20px;\n        }\n        .visualization {\n            min-height: 300px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            font-family: monospace;\n            white-space: pre;\n            overflow: auto;\n        }\n        .stack-trace {\n            min-height: 200px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            font-family: monospace;\n            overflow: auto;\n        }\n        button, select {\n            margin-right: 10px;\n            margin-bottom: 10px;\n        }\n        input[type=\"range\"] {\n            width: 200px;\n        }\n        .function-selector {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Recursion Explorer</h1>\n    \n    <div class=\"container\">\n        <div class=\"control-panel\">\n            <div class=\"function-selector\">\n                <h3>Select Recursive Function:</h3>\n                <select id=\"functionSelect\">\n                    <option value=\"factorial\">Factorial</option>\n                    <option value=\"fibonacci\">Fibonacci</option>\n                    <option value=\"sum\">Sum of Digits</option>\n                    <option value=\"power\">Power</option>\n                    <option value=\"gcd\">GCD</option>\n                    <option value=\"hanoi\">Tower of Hanoi</option>\n                </select>\n                <button id=\"updateFunction\">Update Function</button>\n            </div>\n            \n            <div id=\"parameterControls\">\n                <h3>Parameters:</h3>\n                <div id=\"param1Control\">\n                    <label for=\"param1\">n:</label>\n                    <input type=\"range\" id=\"param1\" min=\"0\" max=\"10\" value=\"5\">\n                    <span id=\"param1Value\">5</span>\n                </div>\n                <div id=\"param2Control\" style=\"display:none;\">\n                    <label for=\"param2\">m:</label>\n                    <input type=\"range\" id=\"param2\" min=\"1\" max=\"10\" value=\"3\">\n                    <span id=\"param2Value\">3</span>\n                </div>\n            </div>\n            \n            <div>\n                <h3>Execution Control:</h3>\n                <button id=\"runFull\">Run Full Recursion</button>\n                <button id=\"stepForward\">Step Forward</button>\n                <button id=\"stepBackward\">Step Backward</button>\n                <button id=\"reset\">Reset</button>\n                <label>\n                    <input type=\"checkbox\" id=\"showStack\" checked> Show Call Stack\n                </label>\n                <label>\n                    <input type=\"checkbox\" id=\"showTree\" checked> Show Recursion Tree\n                </label>\n                <label>\n                    Delay (ms): <input type=\"number\" id=\"delay\" min=\"500\" max=\"3000\" value=\"1000\">\n                </label>\n            </div>\n        </div>\n        \n        <div class=\"visualization\" id=\"recursionTree\"></div>\n        \n        <div class=\"stack-trace\" id=\"callStack\"></div>\n        \n        <div id=\"codeDisplay\">\n            <h3>Current Function Code:</h3>\n            <pre id=\"functionCode\"></pre>\n        </div>\n    </div>\n\n    <script>\n        // State management\n        const state = {\n            currentFunction: 'factorial',\n            param1: 5,\n            param2: 3,\n            executionStack: [],\n            currentStep: -1,\n            steps: [],\n            isRunning: false,\n            showStack: true,\n            showTree: true,\n            delay: 1000\n        };\n\n        // Function definitions\n        const functions = {\n            factorial: {\n                name: 'factorial',\n                params: ['n'],\n                code: `function factorial(n) {\n    if (n <= 1) return 1;\n    return n * factorial(n - 1);\n}`,\n                func: function(n) {\n                    if (n <= 1) return {value: 1, depth: 0};\n                    const child = this.func(n - 1);\n                    return {value: n * child.value, depth: child.depth + 1};\n                }\n            },\n            fibonacci: {\n                name: 'fibonacci',\n                params: ['n'],\n                code: `function fibonacci(n) {\n    if (n <= 1) return n;\n    return fibonacci(n - 1) + fibonacci(n - 2);\n}`,\n                func: function(n) {\n                    if (n <= 1) return {value: n, depth: 0};\n                    const child1 = this.func(n - 1);\n                    const child2 = this.func(n - 2);\n                    return {value: child1.value + child2.value, depth: Math.max(child1.depth, child2.depth) + 1};\n                }\n            },\n            sum: {\n                name: 'sum',\n                params: ['n'],\n                code: `function sum(n) {\n    if (n < 10) return n;\n    return (n % 10) + sum(Math.floor(n / 10));\n}`,\n                func: function(n) {\n                    if (n < 10) return {value: n, depth: 0};\n                    const child = this.func(Math.floor(n / 10));\n                    return {value: (n % 10) + child.value, depth: child.depth + 1};\n                }\n            },\n            power: {\n                name: 'power',\n                params: ['base', 'exp'],\n                code: `function power(base, exp) {\n    if (exp === 0) return 1;\n    return base * power(base, exp - 1);\n}`,\n                func: function(base, exp) {\n                    if (exp === 0) return {value: 1, depth: 0};\n                    const child = this.func(base, exp - 1);\n                    return {value: base * child.value, depth: child.depth + 1};\n                }\n            },\n            gcd: {\n                name: 'gcd',\n                params: ['a', 'b'],\n                code: `function gcd(a, b) {\n    if (b === 0) return a;\n    return gcd(b, a % b);\n}`,\n                func: function(a, b) {\n                    if (b === 0) return {value: a, depth: 0};\n                    const child = this.func(b, a % b);\n                    return {value: child.value, depth: child.depth + 1};\n                }\n            },\n            hanoi: {\n                name: 'hanoi',\n                params: ['n'],\n                code: `function hanoi(n, from, to, aux) {\n    if (n === 1) {\n        return [[from, to]];\n    }\n    const moves1 = hanoi(n - 1, from, aux, to);\n    const moves2 = [[from, to]];\n    const moves3 = hanoi(n - 1, aux, to, from);\n    return [...moves1, ...moves2, ...moves3];\n}`,\n                func: function(n, from = 'A', to = 'C', aux = 'B') {\n                    if (n === 1) {\n                        return {value: [[from, to]], depth: 0};\n                    }\n                    const child1 = this.func(n - 1, from, aux, to);\n                    const child2 = this.func(n - 1, aux, to, from);\n                    const moves = [...child1.value, [from, to], ...child2.value];\n                    return {value: moves, depth: Math.max(child1.depth, child2.depth) + 1};\n                }\n            }\n        };\n\n        // DOM elements\n        const elements = {\n            functionSelect: document.getElementById('functionSelect'),\n            updateFunction: document.getElementById('updateFunction'),\n            param1Control: document.getElementById('param1Control'),\n            param1: document.getElementById('param1'),\n            param1Value: document.getElementById('param1Value'),\n            param2Control: document.getElementById('param2Control'),\n            param2: document.getElementById('param2'),\n            param2Value: document.getElementById('param2Value'),\n            runFull: document.getElementById('runFull'),\n            stepForward: document.getElementById('stepForward'),\n            stepBackward: document.getElementById('stepBackward'),\n            reset: document.getElementById('reset'),\n            showStack: document.getElementById('showStack'),\n            showTree: document.getElementById('showTree'),\n            delay: document.getElementById('delay'),\n            recursionTree: document.getElementById('recursionTree'),\n            callStack: document.getElementById('callStack'),\n            functionCode: document.getElementById('functionCode')\n        };\n\n        // Event listeners\n        elements.updateFunction.addEventListener('click', updateFunction);\n        elements.param1.addEventListener('input', updateParam1);\n        elements.param2.addEventListener('input', updateParam2);\n        elements.runFull.addEventListener('click', runFullRecursion);\n        elements.stepForward.addEventListener('click', stepForward);\n        elements.stepBackward.addEventListener('click', stepBackward);\n        elements.reset.addEventListener('click', reset);\n        elements.showStack.addEventListener('change', toggleStackVisibility);\n        elements.showTree.addEventListener('change', toggleTreeVisibility);\n        elements.delay.addEventListener('change', updateDelay);\n\n        // Initialize\n        updateFunction();\n        updateCodeDisplay();\n        reset();\n\n        function updateFunction() {\n            state.currentFunction = elements.functionSelect.value;\n            const func = functions[state.currentFunction];\n            \n            // Update parameter controls\n            if (func.params.length > 1) {\n                elements.param2Control.style.display = 'block';\n            } else {\n                elements.param2Control.style.display = 'none';\n            }\n            \n            updateCodeDisplay();\n            reset();\n        }\n\n        function updateParam1() {\n            state.param1 = parseInt(elements.param1.value);\n            elements.param1Value.textContent = state.param1;\n            reset();\n        }\n\n        function updateParam2() {\n            state.param2 = parseInt(elements.param2.value);\n            elements.param2Value.textContent = state.param2;\n            reset();\n        }\n\n        function updateDelay() {\n            state.delay = parseInt(elements.delay.value);\n        }\n\n        function toggleStackVisibility() {\n            state.showStack = elements.showStack.checked;\n            updateVisualization();\n        }\n\n        function toggleTreeVisibility() {\n            state.showTree = elements.showTree.checked;\n            updateVisualization();\n        }\n\n        function updateCodeDisplay() {\n            elements.functionCode.textContent = functions[state.currentFunction].code;\n        }\n\n        function reset() {\n            state.executionStack = [];\n            state.steps = [];\n            state.currentStep = -1;\n            const func = functions[state.currentFunction];\n            \n            // Initialize the execution\n            if (func.params.length > 1) {\n                state.steps = buildSteps(func.func(state.param1, state.param2));\n            } else {\n                state.steps = buildSteps(func.func(state.param1));\n            }\n            \n            updateVisualization();\n        }\n\n        function buildSteps(result, prefix = '', depth = 0) {\n            const steps = [];\n            \n            if (result.depth === 0) {\n                // Base case\n                steps.push({\n                    action: 'base',\n                    value: result.value,\n                    prefix: prefix,\n                    depth: depth\n                });\n            } else {\n                // Recursive case\n                steps.push({\n                    action: 'enter',\n                    prefix: prefix,\n                    depth: depth\n                });\n                \n                if (Array.isArray(result.children)) {\n                    // For functions with multiple recursive calls (like fibonacci)\n                    result.children.forEach((child, i) => {\n                        steps.push(...buildSteps(child, prefix + i + '.', depth + 1));\n                    });\n                } else {\n                    // For functions with single recursive call\n                    steps.push(...buildSteps(result.child, prefix + '1.', depth + 1));\n                }\n                \n                steps.push({\n                    action: 'exit',\n                    value: result.value,\n                    prefix: prefix,\n                    depth: depth\n                });\n            }\n            \n            return steps;\n        }\n\n        function runFullRecursion() {\n            if (state.isRunning) return;\n            state.isRunning = true;\n            \n            state.currentStep = -1;\n            const totalSteps = state.steps.length;\n            \n            const interval = setInterval(() => {\n                state.currentStep++;\n                updateVisualization();\n                \n                if (state.currentStep >= totalSteps - 1) {\n                    clearInterval(interval);\n                    state.isRunning = false;\n                }\n            }, state.delay);\n        }\n\n        function stepForward() {\n            if (state.currentStep < state.steps.length - 1) {\n                state.currentStep++;\n                updateVisualization();\n            }\n        }\n\n        function stepBackward() {\n            if (state.currentStep > 0) {\n                state.currentStep--;\n                updateVisualization();\n            }\n        }\n\n        function updateVisualization() {\n            // Clear previous visualization\n            elements.recursionTree.innerHTML = '';\n            elements.callStack.innerHTML = '';\n            \n            if (state.showTree) {\n                // Build recursion tree visualization\n                const treeDiv = document.createElement('div');\n                \n                for (let i = 0; i <= state.currentStep; i++) {\n                    const step = state.steps[i];\n                    const line = document.createElement('div');\n                    line.style.marginLeft = (step.depth * 20) + 'px';\n                    \n                    if (step.action === 'enter') {\n                        line.textContent = `${step.prefix} Calling ${state.currentFunction}(${getCurrentParams(step.depth)})`;\n                    } else if (step.action === 'exit') {\n                        line.textContent = `${step.prefix} ${state.currentFunction}(${getCurrentParams(step.depth)}) returned ${step.value}`;\n                        line.style.fontWeight = 'bold';\n                    } else if (step.action === 'base') {\n                        line.textContent = `${step.prefix} Base case reached: returned ${step.value}`;\n                        line.style.color = '#666';\n                    }\n                    \n                    treeDiv.appendChild(line);\n                }\n                \n                elements.recursionTree.appendChild(treeDiv);\n            }\n            \n            if (state.showStack) {\n                // Build call stack visualization\n                const stackDiv = document.createElement('div');\n                const currentDepth = state.currentStep >= 0 ? state.steps[state.currentStep].depth : -1;\n                \n                for (let depth = currentDepth; depth >= 0; depth--) {\n                    // Find the most recent step at this depth\n                    let step;\n                    for (let i = state.currentStep; i >= 0; i--) {\n                        if (state.steps[i].depth === depth) {\n                            step = state.steps[i];\n                            break;\n                        }\n                    }\n                    \n                    if (step) {\n                        const frame = document.createElement('div');\n                        frame.style.padding = '5px';\n                        frame.style.margin = '2px 0';\n                        frame.style.borderBottom = '1px solid #ccc';\n                        \n                        if (step.action === 'enter') {\n                            frame.textContent = `${state.currentFunction}(${getCurrentParams(depth)})`;\n                        } else if (step.action === 'exit') {\n                            frame.textContent = `${state.currentFunction}(${getCurrentParams(depth)}) → ${step.value}`;\n                            frame.style.fontWeight = 'bold';\n                        } else if (step.action === 'base') {\n                            frame.textContent = `${state.currentFunction}(${getCurrentParams(depth)}) → ${step.value} (base case)`;\n                            frame.style.color = '#666';\n                        }\n                        \n                        stackDiv.appendChild(frame);\n                    }\n                }\n                \n                elements.callStack.appendChild(stackDiv);\n            }\n        }\n\n        function getCurrentParams(depth) {\n            // This is a simplified version - in a real app you'd track parameters at each depth\n            const func = functions[state.currentFunction];\n            if (func.params.length > 1) {\n                return `${state.param1 - depth}, ${state.param2 - depth}`;\n            } else {\n                return state.param1 - depth;\n            }\n        }\n    </script>\n</body>\n</html>"
