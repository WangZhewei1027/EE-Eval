    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Heap Sort — Visualized</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071028;\n    --card:#0b1320aa;\n    --accent:#6ee7b7;\n    --accent-2:#7cc0ff;\n    --muted:#9aa7b2;\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    --neon: 0 6px 30px rgba(110,231,183,0.12);\n    --duration: 620ms;\n    --ease: cubic-bezier(.21,.9,.32,1);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(124,58,237,0.12), transparent 8%),\n                radial-gradient(900px 500px at 90% 80%, rgba(34,211,238,0.06), transparent 10%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #e6eef6;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:40px;\n  }\n\n  .card{\n    width: 100%;\n    max-width:1100px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:hidden;\n  }\n\n  .header{\n    display:flex;\n    align-items:center;\n    gap:20px;\n    margin-bottom:18px;\n  }\n\n  .logo{\n    width:72px;\n    height:72px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(124,58,237,0.18), rgba(34,211,238,0.08));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: var(--neon);\n    flex-shrink:0;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .logo svg{filter: drop-shadow(0 6px 18px rgba(34,211,238,0.06));}\n\n  h1{\n    margin:0;\n    font-weight:800;\n    letter-spacing: -0.02em;\n    font-size:20px;\n    color: linear-gradient(#fff,#aaf);\n  }\n  .subtitle{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n    font-weight:500;\n    margin-top:6px;\n  }\n\n  .controls{\n    margin-left:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 16px;\n    border-radius:12px;\n    color:#06202a;\n    font-weight:700;\n    cursor:pointer;\n    font-size:13px;\n    transition:transform .18s var(--ease), box-shadow .18s var(--ease);\n    box-shadow: 0 6px 18px rgba(3,8,23,0.45);\n    user-select:none;\n  }\n  .btn:active{transform:translateY(1px) scale(.997)}\n  .btn.primary{\n    background: linear-gradient(180deg,var(--accent), #4bd2a7);\n  }\n  .btn.ghost{\n    background: transparent;\n    color: var(--accent-2);\n    border: 1px solid rgba(124,58,237,0.12);\n    backdrop-filter: blur(4px);\n  }\n\n  .arena{\n    margin-top:18px;\n    height:360px;\n    position:relative;\n    border-radius:14px;\n    overflow:visible;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:22px;\n  }\n\n  .stage{\n    width:100%;\n    max-width:980px;\n    height:220px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:14px;\n    position:relative;\n    padding:20px;\n    display:block;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Items row */\n  .row{\n    position:absolute;\n    left:20px;\n    right:20px;\n    bottom:28px;\n    top:28px;\n    display:block;\n    pointer-events:none;\n  }\n\n  .items{\n    position:relative;\n    height:100%;\n    width:100%;\n    overflow:visible;\n  }\n\n  .node{\n    position:absolute;\n    bottom:14px;\n    width:62px;\n    height:62px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:#e6f9f0;\n    font-weight:800;\n    font-size:18px;\n    box-shadow: 0 8px 28px rgba(2,6,23,0.55), inset 0 1px 0 rgba(255,255,255,0.03);\n    transition: left var(--duration) var(--ease), transform var(--duration) var(--ease), background-color 280ms linear, box-shadow 280ms linear;\n    will-change: left, transform;\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n\n  .node::after{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    mix-blend-mode: screen;\n    pointer-events:none;\n  }\n\n  .node .value{\n    z-index:2;\n    display:block;\n    text-shadow: 0 4px 22px rgba(34,211,238,0.06);\n  }\n  .node .idx{\n    position:absolute;\n    top:6px;\n    right:8px;\n    font-size:11px;\n    color:var(--muted);\n    font-weight:600;\n  }\n\n  .node.highlight{\n    transform: translateY(-18px) scale(1.06);\n    box-shadow: 0 18px 48px rgba(110,231,183,0.12), inset 0 1px 0 rgba(255,255,255,0.04);\n    background: linear-gradient(180deg, rgba(110,231,183,0.14), rgba(34,211,238,0.06));\n    color:#022827;\n  }\n  .node.compare{\n    transform: translateY(-8px) scale(1.03);\n    box-shadow: 0 14px 38px rgba(124,58,237,0.08);\n    background: linear-gradient(180deg, rgba(124,58,237,0.12), rgba(124,58,237,0.04));\n  }\n  .node.sorted{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--muted);\n    transform: translateY(0) scale(.98);\n    box-shadow: none;\n    opacity:0.78;\n    border: 1px dashed rgba(255,255,255,0.03);\n  }\n\n  svg.links{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    overflow:visible;\n  }\n  .link{\n    fill:none;\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:2.2;\n    filter: drop-shadow(0 6px 22px rgba(34,211,238,0.04));\n    transition: stroke 260ms linear, stroke-width 260ms linear;\n  }\n  .link.active{\n    stroke: linear-gradient(#6ee7b7,#7cc0ff);\n    stroke: rgba(124,58,237,0.85);\n    stroke-width:2.8;\n    stroke: rgba(110,231,183,0.86);\n    stroke-linecap:round;\n  }\n  .link.pulse{\n    stroke: #7cc0ff;\n    stroke-width:3.4;\n    filter: drop-shadow(0 8px 26px rgba(124,58,237,0.08));\n  }\n\n  .legend{\n    display:flex;\n    gap:12px;\n    margin-top:14px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .badge{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    color:var(--muted);\n    font-weight:700;\n    font-size:12px;\n    background: var(--glass-2);\n    padding:8px 10px;\n    border-radius:10px;\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n  .dot{\n    width:10px;\n    height:10px;\n    border-radius:10px;\n    background: linear-gradient(180deg,var(--accent), #4bd2a7);\n    box-shadow: 0 6px 16px rgba(110,231,183,0.12);\n    flex-shrink:0;\n  }\n\n  .micro{\n    font-size:12px;\n    color:var(--muted);\n    margin-left:8px;\n  }\n\n  /* small responsive tweaks */\n  @media (max-width:700px){\n    .node{width:52px;height:52px}\n    .logo{width:56px;height:56px}\n    .header{gap:12px}\n    .card{padding:16px}\n    .arena{padding:12px}\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"card\" role=\"main\" aria-label=\"Heap Sort visualization\">\n    <div class=\"header\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <!-- Decorative logo -->\n        <svg width=\"44\" height=\"44\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7cc0ff\"/>\n              <stop offset=\"1\" stop-color=\"#6ee7b7\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"12\" fill=\"url(#g1)\" opacity=\"0.12\"/>\n          <g transform=\"translate(8,8)\">\n            <path d=\"M12 20 L20 8 L28 20 Z\" fill=\"#7cc0ff\" opacity=\"0.92\"/>\n            <rect x=\"10\" y=\"24\" width=\"20\" height=\"6\" rx=\"3\" fill=\"#6ee7b7\" opacity=\"0.92\"/>\n          </g>\n        </svg>\n      </div>\n      <div style=\"min-width:0\">\n        <h1>Heap Sort</h1>\n        <p class=\"subtitle\">A refined, animated demonstration of the heap sort algorithm — watch the heap build, sift and sort in elegant motion.</p>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"shuffle\" class=\"btn ghost\" title=\"Shuffle values\">Shuffle</button>\n        <button id=\"start\" class=\"btn primary\" title=\"Start the heap sort animation\">Start</button>\n      </div>\n    </div>\n\n    <div class=\"arena\">\n      <div class=\"stage\" id=\"stage\">\n        <svg class=\"links\" id=\"links\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n        <div class=\"row\">\n          <div class=\"items\" id=\"items\" aria-hidden=\"true\"></div>\n        </div>\n      </div>\n\n      <div style=\"position:absolute; left:28px; bottom:18px; right:28px; display:flex; justify-content:space-between; align-items:center;\">\n        <div class=\"legend\">\n          <div class=\"badge\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#7cc0ff,#6ee7b7)\"></span> Heap node</div>\n          <div class=\"badge\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#7c58ed,#7cc0ff)\"></span> Active comparison</div>\n          <div class=\"micro\">Observe the sequence — limited controls: shuffle or start</div>\n        </div>\n        <div style=\"color:var(--muted); font-size:13px; font-weight:700\">Array size: <span id=\"sizeLabel\">12</span></div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(() => {\n  const config = {\n    size: 12,\n    minVal: 12,\n    maxVal: 98,\n    itemW: 62,\n    gap: 16,\n    leftPadding: 14,\n    transition: 620, // ms\n    ease: 'cubic-bezier(.21,.9,.32,1)'\n  };\n\n  let data = [];\n  const itemsEl = document.getElementById('items');\n  const linksSvg = document.getElementById('links');\n  const startBtn = document.getElementById('start');\n  const shuffleBtn = document.getElementById('shuffle');\n  const sizeLabel = document.getElementById('sizeLabel');\n  const stage = document.getElementById('stage');\n\n  sizeLabel.textContent = config.size;\n\n  // Initialize\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n  function createArray(n){\n    const arr = [];\n    for(let i=0;i<n;i++){\n      arr.push(randInt(config.minVal, config.maxVal));\n    }\n    return arr;\n  }\n\n  function clearElems(){\n    itemsEl.innerHTML = '';\n    linksSvg.innerHTML = '';\n  }\n\n  function setupElements(){\n    clearElems();\n    const n = data.length;\n    // compute row width to center items\n    const totalW = n * config.itemW + Math.max(0, n-1) * config.gap;\n    const containerW = Math.max(stage.clientWidth - 40, totalW);\n    const startX = (stage.clientWidth - totalW)/2;\n\n    for(let i=0;i<n;i++){\n      const el = document.createElement('div');\n      el.className = 'node';\n      el.setAttribute('data-index', i);\n      el.style.left = `${startX + i*(config.itemW + config.gap)}px`;\n      el.style.width = config.itemW + 'px';\n      el.style.height = config.itemW + 'px';\n      el.style.transitionTimingFunction = config.ease;\n      el.style.transitionDuration = config.transition + 'ms';\n\n      el.innerHTML = `<span class=\"value\">${data[i]}</span><span class=\"idx\">${i}</span>`;\n      itemsEl.appendChild(el);\n    }\n    drawLinks(n);\n  }\n\n  // draw arcs from parent to children to represent heap edges\n  function drawLinks(heapSize){\n    linksSvg.innerHTML = '';\n    const n = data.length;\n    for(let i=0;i<heapSize;i++){\n      const left = 2*i+1;\n      const right = 2*i+2;\n      if(left < heapSize) linksSvg.appendChild(linkPath(i,left));\n      if(right < heapSize) linksSvg.appendChild(linkPath(i,right));\n    }\n  }\n\n  function linkPath(p,c){\n    const path = document.createElementNS(\"http://www.w3.org/2000/svg\",'path');\n    path.classList.add('link');\n    path.setAttribute('data-from', p);\n    path.setAttribute('data-to', c);\n    path.setAttribute('d', computePathD(p,c));\n    return path;\n  }\n\n  function computePathD(p,c){\n    const a = getCenter(p);\n    const b = getCenter(c);\n    const mx = (a.x + b.x)/2;\n    const my = Math.min(a.y, b.y) - 62 - Math.abs(a.x - b.x)*0.08;\n    // Quadratic bezier\n    return `M ${a.x} ${a.y} Q ${mx} ${my} ${b.x} ${b.y}`;\n  }\n\n  function getCenter(index){\n    const el = itemsEl.querySelector(`.node[data-index=\"${index}\"]`);\n    if(!el) return {x:0,y:0};\n    const rect = el.getBoundingClientRect();\n    const svgRect = linksSvg.getBoundingClientRect();\n    const x = rect.left + rect.width/2 - svgRect.left;\n    const y = rect.top + rect.height/2 - svgRect.top;\n    return {x,y};\n  }\n\n  // Update all paths positions (useful during transitions)\n  function refreshLinks(){\n    const paths = linksSvg.querySelectorAll('path.link');\n    paths.forEach(p => {\n      const from = parseInt(p.getAttribute('data-from'));\n      const to = parseInt(p.getAttribute('data-to'));\n      p.setAttribute('d', computePathD(from,to));\n    });\n  }\n\n  // Helpers to highlight nodes and links\n  function setNodeClass(idx, cls, add=true){\n    const el = itemsEl.querySelector(`.node[data-index=\"${idx}\"]`);\n    if(!el) return;\n    if(add) el.classList.add(cls); else el.classList.remove(cls);\n  }\n  function setLinkClass(from,to,cls, add=true){\n    const p = linksSvg.querySelector(`path[data-from=\"${from}\"][data-to=\"${to}\"]`);\n    if(!p) return;\n    if(add) p.classList.add(cls); else p.classList.remove(cls);\n  }\n\n  // swap elements visually and in data array\n  function swapNodes(i,j){\n    return new Promise(resolve => {\n      if(i===j){ resolve(); return; }\n      const a = itemsEl.querySelector(`.node[data-index=\"${i}\"]`);\n      const b = itemsEl.querySelector(`.node[data-index=\"${j}\"]`);\n      if(!a||!b){ resolve(); return; }\n      // swap left\n      const leftA = a.style.left;\n      const leftB = b.style.left;\n      // mark swapping style\n      a.classList.add('compare'); b.classList.add('compare');\n      let transCount = 0;\n      function onEnd(e){\n        if(e.propertyName !== 'left') return;\n        transCount++;\n        if(transCount>=2){\n          a.removeEventListener('transitionend', onEnd);\n          b.removeEventListener('transitionend', onEnd);\n          // swap data-index attributes and inner idx labels\n          const ai = a.getAttribute('data-index'), bi = b.getAttribute('data-index');\n          a.setAttribute('data-index', bi);\n          b.setAttribute('data-index', ai);\n          a.querySelector('.idx').textContent = b.getAttribute('data-index');\n          b.querySelector('.idx').textContent = a.getAttribute('data-index');\n          // replace highlight classes\n          a.classList.remove('compare');\n          b.classList.remove('compare');\n          // refresh link positions\n          refreshLinks();\n          resolve();\n        }\n      }\n      a.addEventListener('transitionend', onEnd);\n      b.addEventListener('transitionend', onEnd);\n      // trigger swap of left positions\n      a.style.left = leftB;\n      b.style.left = leftA;\n      // swap DOM order for visual clarity (not necessary but keeps structure)\n      // update data array\n      const tmp = data[i]; data[i] = data[j]; data[j] = tmp;\n      // After small guard time, ensure resolution if transitionend missed\n      setTimeout(()=>{ if(transCount<2){ a.removeEventListener('transitionend', onEnd); b.removeEventListener('transitionend', onEnd); refreshLinks(); resolve(); } }, config.transition + 80);\n    });\n  }\n\n  // Update numeric values displayed on nodes to match data array order\n  function refreshValues(){\n    const nodes = Array.from(itemsEl.querySelectorAll('.node'));\n    nodes.forEach(n=>{\n      const idx = parseInt(n.getAttribute('data-index'));\n      n.querySelector('.value').textContent = data[idx];\n      n.querySelector('.idx').textContent = idx;\n    });\n  }\n\n  // Utility to pulse link and nodes for comparison\n  function pulseComparison(i, j){\n    setNodeClass(i,'highlight',true);\n    setNodeClass(j,'compare',true);\n    setLinkClass(i,j,'active', true);\n    return new Promise(res=>{\n      setTimeout(()=>{ setNodeClass(i,'highlight',false); setNodeClass(j,'compare',false); setLinkClass(i,j,'active',false); res(); }, 420);\n    });\n  }\n\n  // SiftDown algorithm with animation\n  async function siftDown(start, heapSize){\n    let root = start;\n    while(true){\n      const childLeft = 2*root + 1;\n      if(childLeft >= heapSize) break;\n      let swapIdx = root;\n      // compare root and left\n      await pulseComparison(swapIdx, childLeft);\n      if(data[swapIdx] < data[childLeft]) swapIdx = childLeft;\n      const childRight = childLeft + 1;\n      if(childRight < heapSize){\n        await pulseComparison(swapIdx, childRight);\n        if(data[swapIdx] < data[childRight]) swapIdx = childRight;\n      }\n      if(swapIdx !== root){\n        // animate swap between root and swapIdx\n        await animateSwapAndReindex(root, swapIdx);\n        root = swapIdx;\n      } else {\n        break;\n      }\n    }\n  }\n\n  // Animate swap and ensure DOM indexes match data indexes\n  async function animateSwapAndReindex(i,j){\n    // find nodes by their current data-index (not by DOM order)\n    // For swapNodes, it expects indices in the data array (positions). We'll use them directly.\n    // Add emphasis\n    const a = itemsEl.querySelector(`.node[data-index=\"${i}\"]`);\n    const b = itemsEl.querySelector(`.node[data-index=\"${j}\"]`);\n    if(a) a.classList.add('compare');\n    if(b) b.classList.add('compare');\n\n    // Begin a raf loop to update links while transition occurs\n    let active = true;\n    const raf = () => {\n      if(!active) return;\n      refreshLinks();\n      requestAnimationFrame(raf);\n    };\n    requestAnimationFrame(raf);\n\n    await swapNodes(i,j);\n\n    active = false;\n    refreshValues(); // update displayed values to reflect new mapping\n    // mark swapped briefly\n    const nodeA = itemsEl.querySelector(`.node[data-index=\"${j}\"]`);\n    const nodeB = itemsEl.querySelector(`.node[data-index=\"${i}\"]`);\n    if(nodeA) nodeA.classList.add('highlight');\n    if(nodeB) nodeB.classList.add('highlight');\n    setTimeout(()=>{\n      if(nodeA) nodeA.classList.remove('highlight');\n      if(nodeB) nodeB.classList.remove('highlight');\n    }, 420);\n  }\n\n  // Build heap (max-heap)\n  async function buildHeap(){\n    const n = data.length;\n    for(let i = Math.floor(n/2)-1; i>=0; i--){\n      // highlight starting node\n      setNodeClass(i,'highlight',true);\n      await sleep(160);\n      await siftDown(i, n);\n      setNodeClass(i,'highlight',false);\n      await sleep(120);\n    }\n  }\n\n  // Sorting phase\n  async function heapSortAnimate(){\n    const n = data.length;\n    await buildHeap();\n    for(let end = n-1; end>0; end--){\n      // swap root with end\n      // highlight\n      setNodeClass(0,'highlight',true);\n      setNodeClass(end,'compare',true);\n      await sleep(160);\n      // animate swap positions in UI and data\n      await animateSwapAndReindex(0, end);\n      // mark end as sorted\n      const node = itemsEl.querySelector(`.node[data-index=\"${0}\"]`); // after swap, the node at index 0 is the original end\n      const sortedNode = itemsEl.querySelector(`.node[data-index=\"${end}\"]`);\n      // The sorted element is the node with data-index == end (value moved there)\n      if(sortedNode) sortedNode.classList.add('sorted');\n      // remove highlights\n      setNodeClass(0,'highlight',false);\n      setNodeClass(end,'compare',false);\n      // rebuild links with reduced heap size\n      drawLinks(end);\n      await siftDown(0, end);\n      await sleep(120);\n    }\n    // finally mark first element sorted\n    const remaining = itemsEl.querySelectorAll('.node');\n    remaining.forEach(n=> n.classList.add('sorted'));\n  }\n\n  function sleep(ms){ return new Promise(r=>setTimeout(r, ms)); }\n\n  // Shuffle and reset\n  function resetData(newData){\n    data = newData.slice();\n    setupElements();\n    refreshValues();\n  }\n\n  // Entry: Shuffle\n  function shuffleAction(){\n    // generate array with more aesthetic spread by mixing two ranges\n    const arr = createArray(config.size);\n    // ensure variety by shuffling a bit\n    for(let i=arr.length-1;i>0;i--){\n      const j = Math.floor(Math.random()*(i+1));\n      [arr[i],arr[j]] = [arr[j],arr[i]];\n    }\n    resetData(arr);\n  }\n\n  // Start animation\n  let busy = false;\n  async function startAction(){\n    if(busy) return;\n    busy = true;\n    startBtn.disabled = true;\n    shuffleBtn.disabled = true;\n    startBtn.textContent = 'Running...';\n    // ensure previous visuals clean\n    const nodes = itemsEl.querySelectorAll('.node');\n    nodes.forEach(n=>{ n.classList.remove('sorted','highlight','compare'); });\n    await heapSortAnimate();\n    // done\n    startBtn.textContent = 'Start';\n    startBtn.disabled = false;\n    shuffleBtn.disabled = false;\n    busy = false;\n  }\n\n  // Responsive adjustments\n  window.addEventListener('resize', () => {\n    // reposition nodes to be centered\n    const nodes = Array.from(itemsEl.querySelectorAll('.node'));\n    const n = nodes.length;\n    const totalW = n * config.itemW + Math.max(0, n-1) * config.gap;\n    const startX = (stage.clientWidth - totalW)/2;\n    nodes.forEach((el, i) => {\n      el.style.left = `${startX + i*(config.itemW + config.gap)}px`;\n      el.style.transitionDuration = config.transition + 'ms';\n    });\n    // redraw links after resize\n    setTimeout(refreshLinks, 80);\n  });\n\n  // initialize default data\n  data = createArray(config.size);\n  resetData(data);\n\n  // Buttons\n  startBtn.addEventListener('click', startAction);\n  shuffleBtn.addEventListener('click', () => {\n    if(busy) return;\n    shuffleAction();\n  });\n\n  // small initial motion for delight\n  (function introPulse(){\n    const nodes = Array.from(itemsEl.querySelectorAll('.node'));\n    nodes.forEach((n,i)=>{\n      n.style.transform = 'translateY(6px) scale(0.98)';\n      setTimeout(()=> n.style.transform = '', 220 + i*18);\n    });\n    setTimeout(()=> refreshLinks(), 420);\n  })();\n\n  // keyboard frills: pressing space starts (but keeping interactivity limited)\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){ e.preventDefault(); startAction(); }\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
