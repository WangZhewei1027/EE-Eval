  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Kruskal's Algorithm Interactive</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        #graph-container {\n            border: 1px solid #000;\n            width: 600px;\n            height: 400px;\n            position: relative;\n            margin-bottom: 20px;\n        }\n        .node {\n            position: absolute;\n            width: 30px;\n            height: 30px;\n            border-radius: 15px;\n            border: 1px solid #000;\n            background: #fff;\n            text-align: center;\n            line-height: 30px;\n            cursor: move;\n        }\n        .edge {\n            position: absolute;\n            height: 2px;\n            background: #000;\n            transform-origin: 0 0;\n        }\n        .edge-weight {\n            position: absolute;\n            background: white;\n            padding: 2px;\n            font-size: 12px;\n        }\n        .selected {\n            border: 2px solid red;\n        }\n        .in-mst {\n            background: #ccc;\n        }\n        .controls {\n            margin-bottom: 20px;\n        }\n        .control-group {\n            margin-bottom: 10px;\n        }\n        table {\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n        th, td {\n            border: 1px solid #000;\n            padding: 5px;\n            text-align: left;\n        }\n        #status {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <h1>Kruskal's Algorithm Interactive</h1>\n    \n    <div class=\"controls\">\n        <div class=\"control-group\">\n            <button id=\"add-node\">Add Node</button>\n            <button id=\"add-edge\">Add Edge (select 2 nodes)</button>\n            <button id=\"clear\">Clear Graph</button>\n            <button id=\"random-graph\">Generate Random Graph</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Nodes: <input type=\"number\" id=\"node-count\" min=\"3\" max=\"15\" value=\"5\"></label>\n            <label>Edge Density: <input type=\"range\" id=\"density\" min=\"0\" max=\"100\" value=\"50\"></label>\n        </div>\n        \n        <div class=\"control-group\">\n            <button id=\"start-kruskal\">Start Kruskal's Algorithm</button>\n            <button id=\"next-step\">Next Step</button>\n            <button id=\"reset-algo\">Reset Algorithm</button>\n            <label>Speed: <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\"></label>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Edge Weight Range: \n                <input type=\"number\" id=\"min-weight\" min=\"1\" max=\"100\" value=\"1\"> to \n                <input type=\"number\" id=\"max-weight\" min=\"1\" max=\"100\" value=\"10\">\n            </label>\n        </div>\n    </div>\n    \n    <div id=\"graph-container\"></div>\n    \n    <div class=\"control-group\">\n        <h3>Edge List (sorted by weight)</h3>\n        <table id=\"edge-list\">\n            <thead>\n                <tr>\n                    <th>Edge</th>\n                    <th>Weight</th>\n                    <th>Action</th>\n                </tr>\n            </thead>\n            <tbody></tbody>\n        </table>\n    </div>\n    \n    <div class=\"control-group\">\n        <h3>Disjoint Set Status</h3>\n        <table id=\"set-status\">\n            <thead>\n                <tr>\n                    <th>Node</th>\n                    <th>Parent</th>\n                    <th>Rank</th>\n                </tr>\n            </thead>\n            <tbody></tbody>\n        </table>\n    </div>\n    \n    <div id=\"status\">Ready</div>\n    \n    <script>\n        // Graph state\n        let nodes = [];\n        let edges = [];\n        let selectedNodes = [];\n        let nextNodeId = 1;\n        let nextEdgeId = 1;\n        \n        // Algorithm state\n        let sortedEdges = [];\n        let mstEdges = [];\n        let disjointSet = {};\n        let currentStep = 0;\n        let autoStepInterval = null;\n        \n        // DOM elements\n        const graphContainer = document.getElementById('graph-container');\n        const addNodeBtn = document.getElementById('add-node');\n        const addEdgeBtn = document.getElementById('add-edge');\n        const clearBtn = document.getElementById('clear');\n        const randomGraphBtn = document.getElementById('random-graph');\n        const startKruskalBtn = document.getElementById('start-kruskal');\n        const nextStepBtn = document.getElementById('next-step');\n        const resetAlgoBtn = document.getElementById('reset-algo');\n        const nodeCountInput = document.getElementById('node-count');\n        const densityInput = document.getElementById('density');\n        const speedInput = document.getElementById('speed');\n        const minWeightInput = document.getElementById('min-weight');\n        const maxWeightInput = document.getElementById('max-weight');\n        const edgeListTbody = document.querySelector('#edge-list tbody');\n        const setStatusTbody = document.querySelector('#set-status tbody');\n        const statusDiv = document.getElementById('status');\n        \n        // Initialize\n        initEventListeners();\n        \n        function initEventListeners() {\n            addNodeBtn.addEventListener('click', addRandomNode);\n            addEdgeBtn.addEventListener('click', startEdgeCreation);\n            clearBtn.addEventListener('click', clearGraph);\n            randomGraphBtn.addEventListener('click', generateRandomGraph);\n            startKruskalBtn.addEventListener('click', startKruskal);\n            nextStepBtn.addEventListener('click', performNextStep);\n            resetAlgoBtn.addEventListener('click', resetAlgorithm);\n            \n            graphContainer.addEventListener('click', handleGraphClick);\n        }\n        \n        function addRandomNode() {\n            const x = nextNodeId * 50 % 550 + 25;\n            const y = Math.floor(nextNodeId / 10) * 50 + 25;\n            addNode(x, y);\n        }\n        \n        function addNode(x, y) {\n            const node = {\n                id: nextNodeId++,\n                x: x,\n                y: y\n            };\n            nodes.push(node);\n            renderNode(node);\n            resetAlgorithm();\n        }\n        \n        function renderNode(node) {\n            const nodeElement = document.createElement('div');\n            nodeElement.className = 'node';\n            nodeElement.id = `node-${node.id}`;\n            nodeElement.textContent = node.id;\n            nodeElement.style.left = `${node.x - 15}px`;\n            nodeElement.style.top = `${node.y - 15}px`;\n            \n            nodeElement.addEventListener('click', (e) => {\n                e.stopPropagation();\n                handleNodeClick(node.id);\n            });\n            \n            graphContainer.appendChild(nodeElement);\n        }\n            \n            function handleNodeClick(nodeId) {\n                if (document.getElementById('add-edge').classList.contains('active')) {\n                    // Edge creation mode\n                    const nodeElement = document.getElementById(`node-${nodeId}`);\n                    \n                    if (selectedNodes.includes(nodeId)) {\n                        // Deselect\n                        selectedNodes = selectedNodes.filter(id => id !== nodeId);\n                        nodeElement.classList.remove('selected');\n                    } else {\n                        // Select\n                        if (selectedNodes.length < 2) {\n                            selectedNodes.push(nodeId);\n                            nodeElement.classList.add('selected');\n                        }\n                        \n                        if (selectedNodes.length === 2) {\n                            // Create edge\n                            const weight = Math.floor(Math.random() * (maxWeightInput.value - minWeightInput.value + 1)) + parseInt(minWeightInput.value);\n                            addEdge(selectedNodes[0], selectedNodes[1], weight);\n                            \n                            // Reset selection\n                            selectedNodes.forEach(id => {\n                                document.getElementById(`node-${id}`).classList.remove('selected');\n                            });\n                            selectedNodes = [];\n                            document.getElementById('add-edge').classList.remove('active');\n                        }\n                    }\n                }\n            }\n            \n            function startEdgeCreation() {\n                if (nodes.length < 2) {\n                    alert('Need at least 2 nodes to create an edge');\n                    return;\n                }\n                \n                document.getElementById('add-edge').classList.add('active');\n                statusDiv.textContent = 'Select two nodes to connect';\n            }\n            \n            function addEdge(node1Id, node2Id, weight) {\n                // Check if edge already exists\n                const existingEdge = edges.find(edge => \n                    (edge.node1 === node1Id && edge.node2 === node2Id) || \n                    (edge.node1 === node2Id && edge.node2 === node1Id));\n                \n                if (existingEdge) {\n                    alert('Edge already exists between these nodes');\n                    return;\n                }\n                \n                const node1 = nodes.find(n => n.id === node1Id);\n                const node2 = nodes.find(n => n.id === node2Id);\n                \n                const edge = {\n                    id: nextEdgeId++,\n                    node1: node1Id,\n                    node2: node2Id,\n                    weight: weight,\n                    x1: node1.x,\n                    y1: node1.y,\n                    x2: node2.x,\n                    y2: node2.y\n                };\n                \n                edges.push(edge);\n                renderEdge(edge);\n                resetAlgorithm();\n            }\n            \n            function renderEdge(edge) {\n                const edge line\n                const edgeElement = document.createElement('div');\n                edgeElement.className = 'edge';\n                edgeElement.id = `edge-${edge.id}`;\n                \n                // Calculate position and angle\n                const dx = edge.x2 - edge.x1;\n                const dy = edge.y2 - edge.y1;\n                const length = Math.sqrt(dx * dx + dy * dy);\n                const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n                \n                edgeElement.style.width = `${length}px`;\n                edgeElement.style.left = `${edge.x1}px`;\n                edgeElement.style.top = `${edge.y1}px`;\n                edgeElement.style.transform = `rotate(${angle}deg)`;\n                \n                // edge weight label\n                const weightElement = document.createElement('div');\n                weightElement.className = 'edge-weight';\n                weightElement.textContent = edge.weight;\n                weightElement.style.left = `${edge.x1 + dx/2 - 10}px`;\n                weightElement.style.top = `${edge.y1 + dy/2 - 10}px`;\n                weightElement.id = `edge-weight-${edge.id}`;\n                \n                graphContainer.appendChild(edgeElement);\n                graphContainer.appendChild(weightElement);\n            }\n            \n            function handleGraphClick(e) {\n                if (e.target === graphContainer && document.getElementById('add-edge').classList.contains('active')) {\n                    // Clicked on empty space while in edge creation mode\n                    selectedNodes.forEach(id => {\n                        document.getElementById(`node-${id}`).classList.remove('selected');\n                    });\n                    selectedNodes = [];\n                    document.getElementById('add-edge').classList.remove('active');\n                    statusDiv.textContent = 'Ready';\n                }\n            }\n            \n            function clearGraph() {\n                nodes = [];\n                edges = [];\n                selectedNodes = [];\n                nextNodeId = 1;\n                nextEdgeId = 1;\n                graphContainer.innerHTML = '';\n                edgeListTbody.innerHTML = '';\n                setStatusTbody.innerHTML = '';\n                resetAlgorithm();\n                statusDiv.textContent = 'Graph cleared';\n            }\n            \n            function generateRandomGraph() {\n                clearGraph();\n                \n                const nodeCount = parseInt(nodeCountInput.value);\n                const density = parseInt(densityInput.value) / 100;\n                const minWeight = parseInt(minWeightInput.value);\n                const maxWeight = parseInt(maxWeightInput.value);\n                \n                // Add nodes in a circle\n                const centerX = 300;\n                const centerY = 200;\n                const radius = 150;\n                \n                for (let i = 0; i < nodeCount; i++) {\n                    const angle = (i * 2 * Math.PI / nodeCount) - Math.PI/2;\n                    const x = centerX + radius * Math.cos(angle);\n                    const y = centerY + radius * Math.sin(angle);\n                    addNode(x, y);\n                }\n                \n                // Add edges\n                const maxEdges = nodeCount * (nodeCount - 1) / 2;\n                const targetEdges = Math.floor(maxEdges * density);\n                \n                // Ensure the graph is connected\n                for (let i = 1; i < nodeCount; i++) {\n                    const weight = Math.floor(Math.random() * (maxWeight - minWeight + 1)) + minWeight;\n                    addEdge(i, i + 1, weight);\n                }\n                \n                // Add remaining edges randomly\n                let addedEdges = nodeCount - 1;\n                while (addedEdges < targetEdges) {\n                    const node1 = Math.floor(Math.random() * nodeCount) + 1;\n                    let node2 = Math.floor(Math.random() * nodeCount) + 1;\n                    \n                    if (node1 !== node2) {\n                        const edgeExists = edges.some(edge => \n                            (edge.node1 === node1 && edge.node2 === node2) || \n                            (edge.node1 === node2 && edge.node2 === node1));\n                        \n                        if (!edgeExists) {\n                            const weight = Math.floor(Math.random() * (maxWeight - minWeight + 1)) + minWeight;\n                            addEdge(node1, node2, weight);\n                            addedEdges++;\n                        }\n                    }\n                }\n                \n                statusDiv.textContent = `Random graph generated with ${nodeCount} nodes and ${edges.length} edges`;\n            }\n            \n            function startKruskal() {\n                if (edges.length === 0) {\n                    alert('Graph has no edges');\n                    return;\n                }\n                \n                // Initialize disjoint set\n                disjointSet = {};\n                nodes.forEach(node => {\n                    disjointSet[node.id] = {\n                        parent: node.id,\n                        rank: 0\n                    };\n                });\n                \n                // Sort edges by weight\n                sortedEdges = [...edges].sort((a, b) => a.weight - b.weight);\n                mstEdges = [];\n                currentStep = 0;\n                \n                // Update UI\n                updateEdgeList();\n                updateSetStatus();\n                statusDiv.textContent = 'Starting Kruskal\\'s algorithm';\n                \n                // Enable next step button\n                nextStepBtn.disabled = false;\n                \n                // Start auto-stepping\n                if (autoStepInterval) clearInterval(autoStepInterval);\n                autoStepInterval = setInterval(performNextStep, speedInput.value);\n            }\n            \n            function performNextStep() {\n                if (currentStep >= sortedEdges.length) {\n                    clearInterval(autoStepInterval);\n                    autoStepInterval = null;\n                    statusDiv.textContent = 'Algorithm complete - MST found';\n                    return;\n                }\n                \n                const edge = sortedEdges[currentStep];\n                const root1 = find(edge.node1);\n                const root2 = find(edge.node2);\n                \n                // Highlight current edge\n                edges.forEach(e => {\n                    document.getElementById(`edge-${e.id}`).classList.remove('selected');\n                });\n                document.getElementById(`edge-${edge.id}`).classList.add('selected');\n                \n                if (root1 !== root2) {\n                    // Add to MST\n                    union(root1, root2);\n                    mstEdges.push(edge);\n                    document.getElementById(`edge-${edge.id}`).classList.add('in-mst');\n                    statusDiv.textContent = `Adding edge ${edge.node1}-${edge.node2} (weight ${edge.weight}) to MST`;\n                } else {\n                    statusDiv.textContent = `Skipping edge ${edge.node1}-${edge.node2} - would create cycle`;\n                }\n                \n                currentStep++;\n                updateEdgeList();\n                updateSetStatus();\n                \n                if (currentStep >= sortedEdges.length) {\n                    clearInterval(autoStepInterval);\n                    autoStepInterval = null;\n                    statusDiv.textContent = 'Algorithm complete - MST found';\n                }\n            }\n            \n            function find(nodeId) {\n                if (disjointSet[nodeId].parent !== nodeId) {\n                    disjointSet[nodeId].parent = find(disjointSet[nodeId].parent);\n                }\n                return disjointSet[nodeId].parent;\n            }\n            \n            function union(root1, root2) {\n                if (disjointSet[root1].rank > disjointSet[root2].rank) {\n                    disjointSet[root2].parent = root1;\n                } else if (disjointSet[root1].rank < disjointSet[root2].rank) {\n                    disjointSet[root1].parent = root2;\n                } else {\n                    disjointSet[root2].parent = root1;\n                    disjointSet[root1].rank++;\n                }\n            }\n            \n            function updateEdgeList() {\n                edgeListTbody.innerHTML = '';\n                \n                sortedEdges.forEach((edge, index) => {\n                    const row = document.createElement('tr');\n                    if (index < currentStep) {\n                        if (mstEdges.includes(edge)) {\n                            row.style.backgroundColor = '#eee';\n                        }\n                    }\n                    \n                    const edgeCell = document.createElement('td');\n                    edgeCell.textContent = `${edge.node1}-${edge.node2}`;\n                    \n                    const weightCell = document.createElement('td');\n                    weightCell.textContent = edge.weight;\n                    \n                    const actionCell = document.createElement('td');\n                    if (index < currentStep) {\n                        if (mstEdges.includes(edge)) {\n                            actionCell.textContent = 'Added to MST';\n                        } else {\n                            actionCell.textContent = 'Skipped (cycle)';\n                        }\n                    } else if (index === currentStep) {\n                        actionCell.textContent = 'Processing...';\n                        row.style.fontWeight = 'bold';\n                    } else {\n                        actionCell.textContent = 'Pending';\n                    }\n                    \n                    row.appendChild(edgeCell);\n                    row.appendChild(weightCell);\n                    row.appendChild(actionCell);\n                    edgeListTbody.appendChild(row);\n                });\n            }\n            \n            function updateSetStatus() {\n                setStatusTbody.innerHTML = '';\n                \n                nodes.forEach(node => {\n                    const row = document.createElement('tr');\n                    \n                    const nodeCell = document.createElement('td');\n                    nodeCell.textContent = node.id;\n                    \n                    const parentCell = document.createElement('td');\n                    parentCell.textContent = disjointSet[node.id].parent;\n                    \n                    const rankCell = document.createElement('td');\n                    rankCell.textContent = disjointSet[node.id].rank;\n                    \n                    row.appendChild(nodeCell);\n                    row.appendChild(parentCell);\n                    row.appendChild(rankCell);\n                    setStatusTbody.appendChild(row);\n                });\n            }\n            \n            function resetAlgorithm() {\n                if (autoStepInterval) {\n                    clearInterval(autoStepInterval);\n                    autoStepInterval = null;\n                }\n                \n                sortedEdges = [];\n                mstEdges = [];\n                disjointSet = {};\n                currentStep = 0;\n                \n                // Reset edge visuals\n                edges.forEach(edge => {\n                    document.getElementById(`edge-${edge.id}`).classList.remove('selected', 'in-mst');\n                });\n                \n                edgeListTbody.innerHTML = '';\n                setStatusTbody.innerHTML = '';\n                statusDiv.textContent = 'Algorithm reset';\n            }\n            \n            // Speed control\n            speedInput.addEventListener('input', () => {\n                if (autoStepInterval) {\n                    clearInterval(autoStepInterval);\n                    autoStepInterval = setInterval(performNextStep, speedInput.value);\n                }\n            });\n    </script>\n</body>\n</html>"
  },
