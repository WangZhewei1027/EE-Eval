g: 15px 30px;\n            font-size: 1.2em;\n            cursor: pointer;\n            transition: background-color 0.3s, transform 0.3s;\n        }\n\n        .explore-button:hover {\n            background-color: #357ab8;\n            transform: scale(1.05);\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n            }\n            to {\n                opacity: 1;\n            }\n        }\n\n        .fade-in {\n            animation: fadeIn 1s ease-in forwards;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header fade-in\">\n        <h1>Design Patterns</h1>\n        <p>Explore and appreciate the beauty of design principles.</p>\n    </div>\n    <div class=\"content fade-in\">\n        <div class=\"pattern-box\">\n            <div class=\"pattern-header\">Singleton</div>\n            <div class=\"pattern-body\">\n                Ensures a class has only one instance and provides a global point of access to it.\n            </div>\n        </div>\n        <div class=\"pattern-box\">\n            <div class=\"pattern-header\">Observer</div>\n            <div class=\"pattern-body\">\n                Defines a one-to-many dependency between objects so that when one object changes state, all its dependents are notified.\n            </div>\n        </div>\n        <div class=\"pattern-box\">\n            <div class=\"pattern-header\">Factory</div>\n            <div class=\"pattern-body\">\n                Defines an interface for creating an object, but let subclasses alter the type of created objects.\n            </div>\n        </div>\n        <div class=\"pattern-box\">\n            <div class=\"pattern-header\">Strategy</div>\n            <div class=\"pattern-body\">\n                Defines a family of algorithms, encapsulates each one, and makes them interchangeable.\n            </div>\n        </div>\n    </div>\n    <div class=\"button-container fade-in\">\n        <button class=\"explore-button\" on