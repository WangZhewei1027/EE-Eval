    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Insertion Sort Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #arrayDisplay { margin: 10px 0; }\n    </style>\n</head>\n<body>\n    <h1>Insertion Sort Demo</h1>\n    <label for=\"arrayInput\">Enter numbers (comma separated): </label>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g., 5,2,9,1,5,6\">\n    \n    <button onclick=\"generateArray()\">Generate Array</button>\n    <button onclick=\"startInsertionSort()\">Start Insertion Sort</button>\n    <button onclick=\"reset()\">Reset</button>\n\n    <div id=\"arrayDisplay\">Array: </div>\n    \n    <div>\n        <label for=\"speed\">Set Speed (ms): </label>\n        <input type=\"number\" id=\"speed\" value=\"500\" min=\"100\">\n    </div>\n\n    <script>\n        let array = [];\n        let timer;\n\n        function generateArray() {\n            const input = document.getElementById('arrayInput').value;\n            array = input.split(',').map(Number);\n            document.getElementById('arrayDisplay').innerText = 'Array: ' + array.join(', ');\n        }\n\n        function startInsertionSort() {\n            if (array.length === 0) return;\n            resetSort();\n            insertionSort(array);\n        }\n\n        function insertionSort(arr) {\n            let i = 1;\n            let interval = document.getElementById('speed').value;\n            const display = document.getElementById('arrayDisplay');\n\n            function sortStep() {\n                if (i >= arr.length) {\n                    clearInterval(timer);\n                    return;\n                }\n                let key = arr[i];\n                let j = i - 1;\n\n                display.innerText = 'Array: ' + arr.join(', ') + ' | Key: ' + key + ' | j: ' + j;\n\n                while (j >= 0 && arr[j] > key) {\n                    arr[j + 1] = arr[j];\n                    j--;\n                }\n                arr[j + 1] = key;\n                display.innerText = 'Array: ' + arr.join(', ') + ' | Key Inserted: ' + key;\n                i++;\n            }\n\n            clearInterval(timer);\n            timer = setInterval(sortStep, interval);\n        }\n\n        function reset() {\n            clearInterval(timer);\n            array = [];\n            document.getElementById('arrayInput').value = '';\n            document.getElementById('arrayDisplay').innerText = 'Array: ';\n        }\n\n        document.getElementById('arrayInput').addEventListener('keypress', function(event) {\n            if (event.key === 'Enter') {\n                generateArray();\n            }\n        });\n    </script>\n</body>\n</html>"
