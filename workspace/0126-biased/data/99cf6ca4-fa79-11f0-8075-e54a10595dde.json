    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Two Pointers Interactive Demo</title>\n    <style>\n        /* Minimal CSS for basic layout */\n        body { font-family: Arial, sans-serif; }\n        .control { margin: 10px 0; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Two Pointers Interactive Demo</h1>\n    \n    <div class=\"control\">\n        <label for=\"arraySize\">Array Size:</label>\n        <input type=\"number\" id=\"arraySize\" min=\"2\" max=\"100\" value=\"5\">\n        <button onclick=\"generateArray()\">Generate Array</button>\n    </div>\n    \n    <div class=\"control\">\n        <label for=\"target\">Target Sum:</label>\n        <input type=\"number\" id=\"target\" value=\"10\">\n    </div>\n    \n    <div class=\"control\">\n        <button onclick=\"findPairs()\">Find Pairs</button>\n    </div>\n\n    <div id=\"output\"></div>\n        \n    <script>\n        let arr = [];\n\n        function generateArray() {\n            const size = document.getElementById(\"arraySize\").value;\n            arr = Array.from({length: size}, () => Math.floor(Math.random() * 20));\n            document.getElementById(\"output\").innerText = \"Generated Array: \" + arr.join(\", \");\n        }\n\n        function findPairs() {\n            const target = parseInt(document.getElementById(\"target\").value);\n            const result = [];\n            let left = 0;\n            let right = arr.length - 1;\n            let sortedArray = [...arr].sort((a, b) => a - b);\n            document.getElementById(\"output\").innerText += \"\\nSorted Array: \" + sortedArray.join(\", \");\n\n            while (left < right) {\n                const currentSum = sortedArray[left] + sortedArray[right];\n                if (currentSum === target) {\n                    result.push([sortedArray[left], sortedArray[right]]);\n                    left++;\n                    right--;\n                } else if (currentSum < target) {\n                    left++;\n                } else {\n                    right--;\n                }\n            }\n\n            if (result.length > 0) {\n                document.getElementById(\"output\").innerText += \"\\nFound Pairs: \" + result.map(pair => pair.join(\", \")).join(\" | \");\n            } else {\n                document.getElementById(\"output\").innerText += \"\\nNo Pairs Found.\";\n            }\n        }\n    </script>\n</body>\n</html>"
