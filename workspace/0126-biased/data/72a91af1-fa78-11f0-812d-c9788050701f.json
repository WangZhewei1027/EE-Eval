    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>AVL Tree Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --background: #f8f9fa;\n            --text: #2d3436;\n            --node: #00b894;\n            --highlight: #ffeaa7;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background-color: var(--background);\n            color: var(--text);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s ease-out 0.5s forwards;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--secondary);\n            font-weight: 300;\n            margin-bottom: 1rem;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out 1s forwards;\n        }\n\n        button {\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .visualization {\n            width: 100%;\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        .tree-container {\n            position: relative;\n            width: 100%;\n            min-height: 60vh;\n            overflow: visible;\n        }\n\n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            background-color: var(--node);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            box-shadow: 0 4px 20px rgba(0, 184, 148, 0.3);\n            transition: all 0.5s ease;\n            z-index: 2;\n        }\n\n        .node.highlight {\n            background-color: var(--accent);\n            transform: scale(1.1);\n            box-shadow: 0 4px 25px rgba(253, 121, 168, 0.4);\n        }\n\n        .edge {\n            position: absolute;\n            height: 2px;\n            background-color: var(--secondary);\n            transform-origin: 0 0;\n            z-index: 1;\n            opacity: 0.6;\n            transition: all 0.5s ease;\n        }\n\n        .info-panel {\n            background: white;\n            border-radius: 15px;\n            padding: 2rem;\n            margin-top: 2rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            max-width: 800px;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out 2s forwards;\n            line-height: 1.6;\n        }\n\n        .info-panel h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-weight: 400;\n        }\n\n        .info-panel p {\n            margin-bottom: 1rem;\n        }\n\n        .balance-factor {\n            position: absolute;\n            top: -15px;\n            right: -15px;\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            background-color: var(--highlight);\n            color: var(--text);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 0.8rem;\n            font-weight: bold;\n            box-shadow: 0 2px 10px rgba(255, 234, 167, 0.5);\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes pulse {\n            0%, 100% {\n                transform: scale(1);\n            }\n            50% {\n                transform: scale(1.05);\n            }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite ease-in-out;\n        }\n\n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--secondary);\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 2.5s forwards;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>AVL Tree</h1>\n        <p class=\"subtitle\">A Self-Balancing Binary Search Tree</p>\n    </header>\n\n    <div class=\"controls\">\n        <button id=\"insertBtn\">Insert Random Node</button>\n        <button id=\"resetBtn\">Reset Tree</button>\n    </div>\n\n    <div class=\"visualization\">\n        <div class=\"tree-container\" id=\"treeContainer\"></div>\n    </div>\n\n    <div class=\"info-panel\">\n        <h2>About AVL Trees</h2>\n        <p>An AVL tree is a self-balancing binary search tree where the difference between heights of left and right subtrees (the balance factor) cannot be more than one for all nodes.</p>\n        <p>This visualization demonstrates how AVL trees maintain their balance through rotations when nodes are inserted. The balance factor for each node is displayed in the yellow circle above the node.</p>\n        <p>Notice how the tree automatically rebalances itself to maintain optimal height, ensuring O(log n) time complexity for search, insert, and delete operations.</p>\n    </div>\n\n    <footer>\n        <p>Visualization of a balanced binary search tree with elegant animations</p>\n    </footer>\n\n    <script>\n        class AVLNode {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n                this.height = 1;\n                this.id = Math.random().toString(36).substr(2, 9);\n            }\n        }\n\n        class AVLTree {\n            constructor() {\n                this.root = null;\n                this.nodePositions = {};\n            }\n\n            getHeight(node) {\n                return node ? node.height : 0;\n            }\n\n            getBalanceFactor(node) {\n                return node ? this.getHeight(node.left) - this.getHeight(node.right) : 0;\n            }\n\n            rightRotate(y) {\n                const x = y.left;\n                const T2 = x.right;\n\n                x.right = y;\n                y.left = T2;\n\n                y.height = Math.max(this.getHeight(y.left), this.getHeight(y.right)) + 1;\n                x.height = Math.max(this.getHeight(x.left), this.getHeight(x.right)) + 1;\n\n                return x;\n            }\n\n            leftRotate(x) {\n                const y = x.right;\n                const T2 = y.left;\n\n                y.left = x;\n                x.right = T2;\n\n                x.height = Math.max(this.getHeight(x.left), this.getHeight(x.right)) + 1;\n                y.height = Math.max(this.getHeight(y.left), this.getHeight(y.right)) + 1;\n\n                return y;\n            }\n\n            insert(node, value) {\n                if (!node) return new AVLNode(value);\n\n                if (value < node.value) {\n                    node.left = this.insert(node.left, value);\n                } else if (value > node.value) {\n                    node.right = this.insert(node.right, value);\n                } else {\n                    return node; // Duplicates not allowed\n                }\n\n                node.height = 1 + Math.max(this.getHeight(node.left), this.getHeight(node.right));\n\n                const balance = this.getBalanceFactor(node);\n\n                // Left Left Case\n                if (balance > 1 && value < node.left.value) {\n                    return this.rightRotate(node);\n                }\n\n                // Right Right Case\n                if (balance < -1 && value > node.right.value) {\n                    return this.leftRotate(node);\n                }\n\n                // Left Right Case\n                if (balance > 1 && value > node.left.value) {\n                    node.left = this.leftRotate(node.left);\n                    return this.rightRotate(node);\n                }\n\n                // Right Left Case\n                if (balance < -1 && value < node.right.value) {\n                    node.right = this.rightRotate(node.right);\n                    return this.leftRotate(node);\n                }\n\n                return node;\n            }\n\n            insertValue(value) {\n                this.root = this.insert(this.root, value);\n            }\n        }\n\n        class AVLVisualizer {\n            constructor(containerId) {\n                this.container = document.getElementById(containerId);\n                this.tree = new AVLTree();\n                this.nodeElements = {};\n                this.edgeElements = {};\n                this.levelHeights = {};\n                this.animating = false;\n                this.nodeSize = 60;\n                this.levelHeight = 120;\n\n                // Initial tree with some nodes\n                for (let i = 0; i < 5; i++) {\n                    this.tree.insertValue(Math.floor(Math.random() * 50) + 1);\n                }\n                this.updateVisualization();\n            }\n\n            calculatePositions(node, level = 0, position = 0) {\n                if (!node) return { count: 0 };\n\n                // Calculate left subtree positions\n                const left = this.calculatePositions(node.left, level + 1, position);\n                const leftCount = left.count;\n\n                // Current node's position\n                const nodePosition = position + leftCount;\n                this.nodePositions[node.id] = { \n                    x: nodePosition * this.nodeSize * 2.5, \n                    y: level * this.levelHeight + 100 \n                };\n\n                // Calculate right subtree positions\n                const right = this.calculatePositions(node.right, level + 1, nodePosition + 1);\n                const rightCount = right.count;\n\n                return { count: leftCount + rightCount + 1 };\n            }\n\n            updateVisualization() {\n                this.nodePositions = {};\n                this.calculatePositions(this.tree.root);\n\n                // Clear existing edges first\n                Object.keys(this.edgeElements).forEach(id => {\n                    if (document.getElementById(id)) {\n                        document.getElementById(id).remove();\n                    }\n                });\n                this.edgeElements = {};\n\n                if (this.tree.root) {\n                    this.visualizeNode(this.tree.root);\n                    this.visualizeEdges(this.tree.root);\n                } else {\n                    this.container.innerHTML = '';\n                }\n            }\n\n            visualizeNode(node) {\n                if (!node) return;\n\n                // Create or update node element\n                let nodeElement = this.nodeElements[node.id];\n                if (!nodeElement) {\n                    nodeElement = document.createElement('div');\n                    nodeElement.className = 'node';\n                    nodeElement.id = `node-${node.id}`;\n                    this.container.appendChild(nodeElement);\n                    this.nodeElements[node.id] = nodeElement;\n\n                    // Add balance factor display\n                    const balanceFactor = document.createElement('div');\n                    balanceFactor.className = 'balance-factor';\n                    balanceFactor.textContent = this.tree.getBalanceFactor(node);\n                    nodeElement.appendChild(balanceFactor);\n\n                    // Initial animation\n                    nodeElement.style.opacity = '0';\n                    nodeElement.style.transform = 'scale(0.5)';\n                    setTimeout(() => {\n                        nodeElement.style.transition = 'all 0.5s ease';\n                        nodeElement.style.opacity = '1';\n                        nodeElement.style.transform = 'scale(1)';\n                    }, 50);\n                }\n\n                // Update node position and value\n                const pos = this.nodePositions[node.id];\n                nodeElement.style.left = `${pos.x - this.nodeSize / 2}px`;\n                nodeElement.style.top = `${pos.y - this.nodeSize / 2}px`;\n                nodeElement.textContent = node.value;\n\n                // Update balance factor\n                const balanceFactor = this.tree.getBalanceFactor(node);\n                nodeElement.querySelector('.balance-factor').textContent = balanceFactor;\n\n                // Highlight if unbalanced\n                if (Math.abs(balanceFactor) > 1) {\n                    nodeElement.classList.add('highlight', 'pulse');\n                } else {\n                    nodeElement.classList.remove('highlight', 'pulse');\n                }\n\n                // Recursively visualize children\n                this.visualizeNode(node.left);\n                this.visualizeNode(node.right);\n            }\n\n            visualizeEdges(node) {\n                if (!node) return;\n\n                if (node.left) {\n                    const edgeId = `edge-${node.id}-${node.left.id}`;\n                    if (!this.edgeElements[edgeId]) {\n                        const edge = document.createElement('div');\n                        edge.className = 'edge';\n                        edge.id = edgeId;\n                        this.container.appendChild(edge);\n                        this.edgeElements[edgeId] = edge;\n                    }\n\n                    this.updateEdgePosition(node, node.left, this.edgeElements[edgeId]);\n                    this.visualizeEdges(node.left);\n                }\n\n                if (node.right) {\n                    const edgeId = `edge-${node.id}-${node.right.id}`;\n                    if (!this.edgeElements[edgeId]) {\n                        const edge = document.createElement('div');\n                        edge.className = 'edge';\n                        edge.id = edgeId;\n                        this.container.appendChild(edge);\n                        this.edgeElements[edgeId] = edge;\n                    }\n\n                    this.updateEdgePosition(node, node.right, this.edgeElements[edgeId]);\n                    this.visualizeEdges(node.right);\n                }\n            }\n\n            updateEdgePosition(parent, child, edgeElement) {\n                const parentPos = this.nodePositions[parent.id];\n                const childPos = this.nodePositions[child.id];\n\n                const length = Math.sqrt(\n                    Math.pow(childPos.x - parentPos.x, 2) + \n                    Math.pow(childPos.y - parentPos.y, 2)\n                );\n\n                const angle = Math.atan2(\n                    childPos.y - parentPos.y,\n                    childPos.x - parentPos.x\n                );\n\n                edgeElement.style.width = `${length}px`;\n                edgeElement.style.left = `${parentPos.x}px`;\n                edgeElement.style.top = `${parentPos.y}px`;\n                edgeElement.style.transform = `rotate(${angle}rad)`;\n            }\n\n            insertRandomNode() {\n                if (this.animating) return;\n                this.animating = true;\n\n                const value = Math.floor(Math.random() * 100) + 1;\n                this.tree.insertValue(value);\n                this.updateVisualization();\n\n                setTimeout(() => {\n                    this.animating = false;\n                }, 1000);\n            }\n\n            resetTree() {\n                if (this.animating) return;\n                this.animating = true;\n\n                this.tree = new AVLTree();\n                this.nodeElements = {};\n                this.edgeElements = {};\n                this.updateVisualization();\n\n                setTimeout(() => {\n                    this.animating = false;\n                }, 500);\n            }\n        }\n\n        // Initialize visualizer when DOM is loaded\n        document.addEventListener('DOMContentLoaded', () => {\n            const visualizer = new AVLVisualizer('treeContainer');\n\n            document.getElementById('insertBtn').addEventListener('click', () => {\n                visualizer.insertRandomNode();\n            });\n\n            document.getElementById('resetBtn').addEventListener('click', () => {\n                visualizer.resetTree();\n            });\n        });\n    </script>\n</body>\n</html>"
  },
