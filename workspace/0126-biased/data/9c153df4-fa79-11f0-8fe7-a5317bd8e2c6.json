  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Mutex Simulator - Interactive</title>\n<style>\n/* Minimal styling only to keep layout readable; otherwise plain elements */\nbody { font-family: Arial, sans-serif; margin: 10px; color: #000; background: #fff; }\nsection { margin-bottom: 12px; padding: 6px; border: 1px solid #000; }\nlabel { display: inline-block; width: 160px; }\ninput[type=\"text\"], input[type=\"number\"], select, textarea { width: 320px; }\ntextarea { height: 80px; }\n.small { width: 60px; }\n.mono { font-family: monospace; white-space: pre-wrap; }\n.inline { display: inline-block; vertical-align: middle; }\n</style>\n</head>\n<body>\n<h1>Mutex Simulator</h1>\n\n<section>\n  <strong>Overview</strong>\n  <div>\n    This simulator models mutexes and threads. You can create threads and locks, write small thread scripts, pick scheduling policies, and explore behaviors: contention, starvation, priority inversion, reentrancy, try-locks, timed locks, nested locks, deadlocks, and more. Use Start/Step/Run to control execution. Logs and metrics update live.\n  </div>\n</section>\n\n<section>\n  <strong>Simulation Controls</strong><br>\n  <label>Tick interval (ms):</label><input id=\"tickInterval\" type=\"number\" value=\"200\" class=\"small\"> \n  <label>Run speed slider:</label><input id=\"speedSlider\" type=\"range\" min=\"50\" max=\"1000\" value=\"200\"><br><br>\n\n  <button id=\"startBtn\">Start</button>\n  <button id=\"pauseBtn\">Pause</button>\n  <button id=\"stepBtn\">Step</button>\n  <button id=\"resetBtn\">Reset</button>\n  <button id=\"randomizeBtn\">Randomize Threads</button>\n  <label>Seed:</label><input id=\"seedInput\" type=\"text\" value=\"42\" class=\"small\">\n  <br><br>\n\n  <label>Scheduler:</label>\n  <select id=\"schedulerSelect\">\n    <option value=\"rr\">Round-Robin (cooperative)</option>\n    <option value=\"preemptive-rr\">Preemptive Round-Robin</option>\n    <option value=\"priority\">Priority-based (preemptive)</option>\n    <option value=\"cooperative\">Cooperative</option>\n  </select>\n  <label>Enable Preemption:</label><input type=\"checkbox\" id=\"preemptCheck\"><br>\n\n  <label>Enable Priority Inheritance:</label><input type=\"checkbox\" id=\"priorityInheritance\">\n  <label>Detect Deadlock Automatically:</label><input type=\"checkbox\" id=\"deadlockDetect\" checked><br>\n\n  <label>Auto-detect starvation (threshold ms):</label><input id=\"starveMs\" type=\"number\" value=\"5000\" class=\"small\">\n</section>\n\n<section>\n  <strong>Locks</strong><br>\n  <label>Lock name:</label><input id=\"newLockName\" type=\"text\" value=\"L1\">\n  <label>Type:</label>\n  <select id=\"lockTypeSelect\">\n    <option value=\"mutex\">Mutex (binary)</option>\n    <option value=\"recursive\">Recursive Mutex</option>\n    <option value=\"ticket\">Ticket Lock (FIFO)</option>\n    <option value=\"spin\">Spinlock</option>\n    <option value=\"rw\">Read-Write Lock (read-pref)</option>\n  </select>\n  <button id=\"addLockBtn\">Add Lock</button>\n  <button id=\"clearLocksBtn\">Clear Locks</button>\n  <div id=\"locksList\"></div>\n</section>\n\n<section>\n  <strong>Threads</strong><br>\n  <label>Thread name:</label><input id=\"newThreadName\" type=\"text\" value=\"T1\">\n  <label>Priority (higher = chooses first):</label><input id=\"newThreadPriority\" type=\"number\" value=\"1\" class=\"small\">\n  <label>Behavior:</label>\n  <select id=\"behaviorSelect\">\n    <option value=\"script\">Custom Script</option>\n    <option value=\"random\">Stochastic</option>\n    <option value=\"busy\">Busy Worker</option>\n    <option value=\"reader\">Reader (for RW lock)</option>\n  </select>\n  <button id=\"addThreadBtn\">Add Thread</button>\n  <button id=\"clearThreadsBtn\">Clear Threads</button>\n  <div id=\"threadsList\"></div>\n  <br>\n  <label>Default script template:</label><br>\n  <textarea id=\"scriptTemplate\">acquire L1\nhold 300\nrelease L1\nsleep 200\nacquire L1\nhold 200\nrelease L1\nend</textarea>\n  <button id=\"applyTemplateBtn\">Apply Template to Selected</button>\n</section>\n\n<section>\n  <strong>Thread Script Language</strong>\n  <div>\n    Simple commands (one per line). Parameters separated by spaces.\n    Commands:\n    acquire LOCKNAME - blocks until lock obtained (or respects try/timeout if specified)\n    tryacq LOCKNAME - try-lock, does not block\n    timeacq LOCKNAME ms - try to acquire with timeout (ms)\n    release LOCKNAME\n    hold ms - simulate working inside critical section or outside\n    sleep ms - non-CPU wait (yields)\n    yield - voluntarily yield scheduler\n    nested - placeholder for nested acquisitions in script\n    setprio N - change this thread's priority\n    end - thread terminates\n    Comments start with #\n  </div>\n</section>\n\n<section>\n  <strong>Thread Inspector & Controls</strong>\n  <div id=\"threadInspector\"></div>\n</section>\n\n<section>\n  <strong>Execution & Manual Controls</strong><br>\n  <button id=\"stepSelectedBtn\">Step Selected Thread</button>\n  <button id=\"resumeSelectedBtn\">Resume Selected Thread</button>\n  <button id=\"suspendSelectedBtn\">Suspend Selected Thread</button>\n  <button id=\"killSelectedBtn\">Kill Selected Thread</button>\n  <label>Force acquire (bypass) lock:</label><input id=\"forceLockSelect\" type=\"text\" class=\"small\" placeholder=\"L1\">\n  <button id=\"forceAcquireBtn\">Force Acquire</button>\n  <button id=\"forceReleaseBtn\">Force Release</button>\n</section>\n\n<section>\n  <strong>Metrics & Analyzer</strong><br>\n  <button id=\"showWaitStatsBtn\">Compute Wait Stats</button>\n  <button id=\"detectDeadlocksBtn\">Detect Deadlocks Now</button>\n  <div id=\"metricsArea\" class=\"mono\"></div>\n</section>\n\n<section>\n  <strong>Logs & Timeline</strong><br>\n  <label>Max log lines:</label><input id=\"maxLogLines\" type=\"number\" value=\"500\" class=\"small\">\n  <button id=\"clearLogBtn\">Clear Log</button>\n  <div id=\"logArea\" class=\"mono\" style=\"height:200px; overflow:auto; border:1px solid #000; padding:4px;\"></div>\n</section>\n\n<script>\n/*\n  Mutex Simulator JavaScript\n  - Supports multiple locks (mutex, recursive, ticket, spinlock, rw)\n  - Multiple threads with simple script language\n  - Scheduler options: rr, preemptive-rr, priority, cooperative\n  - Priority inheritance simulation\n  - Deadlock detection and metrics\n  - Manual control per-thread\n*/\n\n/* Utility PRNG for deterministic runs */\nfunction makeRNG(seedStr) {\n  let seed = 0;\n  for (let i=0;i<seedStr.length;i++) seed = (seed*31 + seedStr.charCodeAt(i))|0;\n  return function() {\n    seed = (seed ^ 0x6D2B79F5) + ((seed << 5) | 0);\n    seed = seed | 0;\n    return Math.abs(seed) / 0x7FFFFFFF;\n  }\n}\n\n/* Global simulation state */\nconst Sim = {\n  ticks: 0,\n  running: false,\n  intervalId: null,\n  tickInterval: 200,\n  speedMs: 200,\n  scheduler: 'rr',\n  preempt: false,\n  threads: [],\n  locks: {},\n  nextThreadId: 1,\n  nextLockId: 1,\n  logLines: [],\n  maxLog: 500,\n  rng: makeRNG(\"42\"),\n  seed: \"42\",\n  priorityInheritance: false,\n  deadlockDetect: true,\n  starveMs: 5000\n};\n\n/* Logging */\nfunction log(msg) {\n  const t = Sim.ticks;\n  const line = '['+t+'] ' + msg;\n  Sim.logLines.push(line);\n  if (Sim.logLines.length > Sim.maxLog) Sim.logLines.shift();\n  const area = document.getElementById('logArea');\n  area.textContent = Sim.logLines.join(\"\\n\");\n  area.scrollTop = area.scrollHeight;\n}\n\n/* Thread model */\nclass Thread {\n  constructor(name, priority=1, scriptText=\"\", behavior=\"script\") {\n    this.id = Sim.nextThreadId++;\n    this.name = name || (\"T\"+this.id);\n    this.priority = priority;\n    this.basePriority = priority;\n    this.state = \"ready\"; // ready, running, blocked, sleeping, finished, suspended\n    this.blockedOn = null; // lock name or null\n    this.holdUntilTick = 0; // for sleeping or holding\n    this.scriptText = scriptText;\n    this.actions = parseScript(scriptText);\n    this.pc = 0;\n    this.stats = {\n      acquired: {}, // per lock counts\n      waitTotal: {}, // total wait ms per lock\n      lastWaitStart: null\n    };\n    this.behavior = behavior;\n    this.recentAction = \"\";\n    this.waitingSinceTick = null;\n    this.suspended = false;\n  }\n\n  nameTag() { return this.name + \" (p=\"+this.priority+\")\"; }\n\n  currentAction() {\n    return this.actions[this.pc];\n  }\n\n  isFinished() { return this.state === \"finished\"; }\n}\n\n/* Lock implementations */\nclass LockBase {\n  constructor(name, type) {\n    this.name = name;\n    this.type = type;\n    this.owner = null; // for mutexes: thread id\n    this.queue = []; // waiting thread ids FIFO\n    this.recursiveCount = 0;\n    this.ticketNext = 0;\n    this.ticketNow = 0;\n    this.rwReaders = new Set();\n    this.rwWriter = null;\n    this.stats = {\n      acquisitions: 0,\n      contentions: 0,\n      waitTotalMs: 0,\n      lastAcquiredTick: null\n    };\n  }\n\n  info() {\n    return {\n      name: this.name,\n      type: this.type,\n      owner: this.owner,\n      queue: this.queue.slice(),\n      recursiveCount: this.recursiveCount,\n      ticketNext: this.ticketNext,\n      ticketNow: this.ticketNow\n    }\n  }\n}\n\n/* Script parsing */\nfunction parseScript(text) {\n  const lines = text.split(/\\r?\\n/).map(l=>l.trim()).filter(l=>l && !l.startsWith(\"#\"));\n  const actions = [];\n  for (let ln of lines) {\n    const parts = ln.split(/\\s+/);\n    const cmd = parts[0].toLowerCase();\n    if (cmd === 'acquire') actions.push({cmd:'acquire', lock:parts[1]});\n    else if (cmd === 'tryacq') actions.push({cmd:'tryacq', lock:parts[1]});\n    else if (cmd === 'timeacq') actions.push({cmd:'timeacq', lock:parts[1], ms:Math.max(0, parseInt(parts[2]||0))});\n    else if (cmd === 'release') actions.push({cmd:'release', lock:parts[1]});\n    else if (cmd === 'hold') actions.push({cmd:'hold', ms:Math.max(0, parseInt(parts[1]||0))});\n    else if (cmd === 'sleep') actions.push({cmd:'sleep', ms:Math.max(0, parseInt(parts[1]||0))});\n    else if (cmd === 'yield') actions.push({cmd:'yield'});\n    else if (cmd === 'setprio') actions.push({cmd:'setprio', n:parseInt(parts[1]||0)});\n    else if (cmd === 'end') actions.push({cmd:'end'});\n    else actions.push({cmd:'noop', raw:ln});\n  }\n  return actions;\n}\n\n/* Lock utilities */\nfunction addLock(name, type) {\n  if (!name) name = \"L\"+Sim.nextLockId++;\n  if (Sim.locks[name]) {\n    log(\"Lock \" + name + \" already exists\");\n    return null;\n  }\n  Sim.locks[name] = new LockBase(name, type);\n  log(\"Created lock \" + name + \" (\" + type + \")\");\n  refreshUI();\n  return Sim.locks[name];\n}\n\nfunction clearLocks() {\n  Sim.locks = {};\n  log(\"Cleared all locks\");\n  refreshUI();\n}\n\n/* Thread utilities */\nfunction addThread(name, priority=1, script=\"\", behavior=\"script\") {\n  const t = new Thread(name, priority, script, behavior);\n  Sim.threads.push(t);\n  log(\"Added thread \" + t.nameTag());\n  refreshUI();\n  return t;\n}\n\nfunction clearThreads() {\n  Sim.threads = [];\n  Sim.nextThreadId = 1;\n  log(\"Cleared threads\");\n  refreshUI();\n}\n\n/* Scheduler choices - decide which thread runs next */\nfunction pickNextThread() {\n  const runnable = Sim.threads.filter(t => !t.suspended && (t.state==='ready' || t.state==='running'));\n  if (runnable.length === 0) return null;\n  if (Sim.scheduler === 'rr' || Sim.scheduler === 'cooperative' || Sim.scheduler === 'preemptive-rr') {\n    // simple round-robin order by id but rotate starting with last chosen\n    if (!Sim._rrIndex || Sim._rrIndex >= runnable.length) Sim._rrIndex = 0;\n    const t = runnable[Sim._rrIndex % runnable.length];\n    Sim._rrIndex = (Sim._rrIndex + 1) % runnable.length;\n    return t;\n  } else if (Sim.scheduler === 'priority') {\n    // highest effective priority first; break ties by id\n    const sorted = runnable.slice().sort((a,b)=> (b.priority - a.priority) || (a.id - b.id));\n    return sorted[0];\n  }\n  return runnable[0];\n}\n\n/* Attempt to acquire a lock for a thread (blocking behavior) */\nfunction attemptAcquire(thread, lockName, options={try:false, timeout:null}) {\n  const lock = Sim.locks[lockName];\n  if (!lock) {\n    log(thread.nameTag() + \" attempted acquire on unknown lock \" + lockName);\n    return {success:false, reason:'no-such-lock'};\n  }\n  const type = lock.type;\n  if (type === 'rw') {\n    // simple read-pref: acquire as write if thread requests exclusive (script uses acquire)\n    // For simplicity, treat acquire as write; tryacq as try write.\n    if (lock.rwWriter === null && lock.rwReaders.size === 0) {\n      lock.rwWriter = thread.id;\n      lock.stats.acquisitions++;\n      lock.stats.lastAcquiredTick = Sim.ticks;\n      thread.stats.acquired[lockName] = (thread.stats.acquired[lockName]||0) + 1;\n      log(thread.nameTag() + \" acquired writer lock \" + lockName);\n      return {success:true};\n    } else {\n      // blocked\n      if (options.try) {\n        log(thread.nameTag() + \" tryacq failed on \" + lockName);\n        return {success:false};\n      }\n      if (options.timeout === 0) {\n        log(thread.nameTag() + \" timeacq(0) immediate fail on \" + lockName);\n        return {success:false};\n      }\n      // enqueue\n      if (!lock.queue.includes(thread.id)) lock.queue.push(thread.id);\n      lock.stats.contentions++;\n      thread.state = 'blocked';\n      thread.blockedOn = lockName;\n      thread.waitingSinceTick = Sim.ticks;\n      log(thread.nameTag() + \" blocked waiting for writer lock \" + lockName);\n      if (options.timeout != null) {\n        thread._acqTimeoutTick = Sim.ticks + Math.ceil(options.timeout / Sim.tickInterval);\n      }\n      return {success:false, blocked:true};\n    }\n  } else if (type === 'recursive') {\n    if (lock.owner === null || lock.owner === thread.id) {\n      lock.owner = thread.id;\n      lock.recursiveCount = (lock.recursiveCount||0) + 1;\n      lock.stats.acquisitions++;\n      lock.stats.lastAcquiredTick = Sim.ticks;\n      thread.stats.acquired[lockName] = (thread.stats.acquired[lockName]||0) + 1;\n      log(thread.nameTag() + \" acquired recursive lock \" + lockName + \" (count=\"+lock.recursiveCount+\")\");\n      return {success:true};\n    } else {\n      if (options.try) {\n        log(thread.nameTag() + \" tryacq failed on \" + lockName);\n        return {success:false};\n      }\n      if (!lock.queue.includes(thread.id)) lock.queue.push(thread.id);\n      lock.stats.contentions++;\n      thread.state = 'blocked';\n      thread.blockedOn = lockName;\n      thread.waitingSinceTick = Sim.ticks;\n      log(thread.nameTag() + \" blocked waiting for recursive lock \" + lockName);\n      if (options.timeout != null) {\n        thread._acqTimeoutTick = Sim.ticks + Math.ceil(options.timeout / Sim.tickInterval);\n      }\n      return {success:false, blocked:true};\n    }\n  } else if (type === 'ticket') {\n    // FIFO ticket lock\n    const myTicket = lock.ticketNext++;\n    if (myTicket === lock.ticketNow && lock.owner === null) {\n      lock.owner = thread.id;\n      lock.stats.acquisitions++;\n      lock.stats.lastAcquiredTick = Sim.ticks;\n      thread.stats.acquired[lockName] = (thread.stats.acquired[lockName]||0) + 1;\n      log(thread.nameTag() + \" acquired ticket lock \" + lockName + \" ticket=\" + myTicket);\n      return {success:true};\n    } else {\n      if (options.try) {\n        log(thread.nameTag() + \" tryacq failed on ticket \" + lockName);\n        return {success:false};\n      }\n      lock.queue.push(thread.id);\n      lock.stats.contentions++;\n      thread.state = 'blocked';\n      thread.blockedOn = lockName;\n      thread.waitingSinceTick = Sim.ticks;\n      log(thread.nameTag() + \" queued for ticket lock \" + lockName + \" ticket=\" + myTicket);\n      if (options.timeout != null) {\n        thread._acqTimeoutTick = Sim.ticks + Math.ceil(options.timeout / Sim.tickInterval);\n      }\n      return {success:false, blocked:true};\n    }\n  } else if (type === 'spin') {\n    // spinlock: if free, acquire; if not, either block or spin (we simulate as blocking to avoid busy loop)\n    if (lock.owner === null) {\n      lock.owner = thread.id;\n      lock.stats.acquisitions++;\n      lock.stats.lastAcquiredTick = Sim.ticks;\n      thread.stats.acquired[lockName] = (thread.stats.acquired[lockName]||0) + 1;\n      log(thread.nameTag() + \" acquired spinlock \" + lockName);\n      return {success:true};\n    } else {\n      if (options.try) {\n        log(thread.nameTag() + \" tryacq failed on \" + lockName);\n        return {success:false};\n      }\n      lock.queue.push(thread.id);\n      lock.stats.contentions++;\n      thread.state = 'blocked';\n      thread.blockedOn = lockName;\n      thread.waitingSinceTick = Sim.ticks;\n      log(thread.nameTag() + \" blocked (spin) waiting for \" + lockName);\n      if (options.timeout != null) {\n        thread._acqTimeoutTick = Sim.ticks + Math.ceil(options.timeout / Sim.tickInterval);\n      }\n      return {success:false, blocked:true};\n    }\n  } else { // default mutex\n    if (lock.owner === null) {\n      lock.owner = thread.id;\n      lock.stats.acquisitions++;\n      lock.stats.lastAcquiredTick = Sim.ticks;\n      thread.stats.acquired[lockName] = (thread.stats.acquired[lockName]||0) + 1;\n      log(thread.nameTag() + \" acquired mutex \" + lockName);\n      return {success:true};\n    } else {\n      if (options.try) {\n        log(thread.nameTag() + \" tryacq failed on \" + lockName);\n        return {success:false};\n      }\n      if (!lock.queue.includes(thread.id)) lock.queue.push(thread.id);\n      lock.stats.contentions++;\n      thread.state = 'blocked';\n      thread.blockedOn = lockName;\n      thread.waitingSinceTick = Sim.ticks;\n      log(thread.nameTag() + \" blocked waiting for \" + lockName);\n      if (options.timeout != null) {\n        thread._acqTimeoutTick = Sim.ticks + Math.ceil(options.timeout / Sim.tickInterval);\n      }\n      return {success:false, blocked:true};\n    }\n  }\n}\n\n/* Release lock */\nfunction releaseLock(thread, lockName) {\n  const lock = Sim.locks[lockName];\n  if (!lock) {\n    log(thread.nameTag() + \" attempted release on unknown lock \" + lockName);\n    return false;\n  }\n  const type = lock.type;\n  if (type === 'rw') {\n    if (lock.rwWriter === thread.id) {\n      lock.rwWriter = null;\n      lock.stats.lastAcquiredTick = null;\n      log(thread.nameTag() + \" released writer lock \" + lockName);\n      wakeNext(lock);\n      return true;\n    } else if (lock.rwReaders.has(thread.id)) {\n      lock.rwReaders.delete(thread.id);\n      log(thread.nameTag() + \" released reader lock \" + lockName);\n      if (lock.rwReaders.size === 0) wakeNext(lock);\n      return true;\n    } else {\n      log(thread.nameTag() + \" attempted to release rw lock \" + lockName + \" but not owner\");\n      return false;\n    }\n  } else if (type === 'recursive') {\n    if (lock.owner === thread.id) {\n      lock.recursiveCount = Math.max(0, lock.recursiveCount-1);\n      if (lock.recursiveCount === 0) {\n        lock.owner = null;\n        log(thread.nameTag() + \" released recursive lock \" + lockName);\n        wakeNext(lock);\n      } else {\n        log(thread.nameTag() + \" released recursive lock \" + lockName + \" (count=\"+lock.recursiveCount+\")\");\n      }\n      return true;\n    } else {\n      log(thread.nameTag() + \" attempted to release recursive lock \" + lockName + \" but not owner\");\n      return false;\n    }\n  } else if (type === 'ticket') {\n    if (lock.owner === thread.id) {\n      lock.owner = null;\n      lock.ticketNow++;\n      log(thread.nameTag() + \" released ticket lock \" + lockName);\n      wakeNext(lock);\n      return true;\n    } else {\n      log(thread.nameTag() + \" attempted to release ticket lock \" + lockName + \" but not owner\");\n      return false;\n    }\n  } else {\n    if (lock.owner === thread.id) {\n      lock.owner = null;\n      log(thread.nameTag() + \" released mutex \" + lockName);\n      wakeNext(lock);\n      return true;\n    } else {\n      log(thread.nameTag() + \" attempted to release lock \" + lockName + \" but not owner\");\n      return false;\n    }\n  }\n}\n\n/* Wake next waiting thread according to lock type */\nfunction wakeNext(lock) {\n  if (!lock) return;\n  if (lock.type === 'rw') {\n    // prefer readers: wake all readers until writer in queue? For simplicity, if first queued thread exists and is a writer (we don't annotate), grab next\n    if (lock.queue.length === 0) return;\n    const nid = lock.queue.shift();\n    const t = Sim.threads.find(x=>x.id===nid);\n    if (!t) return;\n    // grant writer\n    lock.rwWriter = nid;\n    t.state = 'ready';\n    t.blockedOn = null;\n    t.waitingSinceTick = null;\n    log(\"Woke \" + t.nameTag() + \" as writer for \" + lock.name);\n    return;\n  } else if (lock.type === 'ticket') {\n    // find the queued thread whose ticket equals ticketNow\n    if (lock.queue.length === 0) return;\n    const nid = lock.queue.shift();\n    lock.owner = nid;\n    const t = Sim.threads.find(x=>x.id===nid);\n    if (t) {\n      t.state = 'ready';\n      t.blockedOn = null;\n      t.waitingSinceTick = null;\n      log(\"Woke \" + t.nameTag() + \" (ticket) for \" + lock.name);\n    }\n    return;\n  } else {\n    // regular mutex or spin or recursive\n    if (lock.queue.length === 0) return;\n    const nid = lock.queue.shift();\n    lock.owner = nid;\n    lock.recursiveCount = (lock.type==='recursive') ? 1 : 0;\n    const t = Sim.threads.find(x=>x.id===nid);\n    if (t) {\n      t.state = 'ready';\n      t.blockedOn = null;\n      t.waitingSinceTick = null;\n      log(\"Woke \" + t.nameTag() + \" for \" + lock.name);\n    }\n    return;\n  }\n}\n\n/* Force acquire (bypass) */\nfunction forceAcquire(thread, lockName) {\n  const lock = Sim.locks[lockName];\n  if (!lock) { log(\"No such lock \"+lockName); return; }\n  lock.owner = thread.id;\n  lock.recursiveCount = 1;\n  lock.queue = lock.queue.filter(id=>id!==thread.id);\n  thread.stats.acquired[lockName] = (thread.stats.acquired[lockName]||0) + 1;\n  log(thread.nameTag() + \" force-acquired \" + lockName);\n  refreshUI();\n}\n\n/* Force release */\nfunction forceReleaseLock(lockName) {\n  const lock = Sim.locks[lockName];\n  if (!lock) { log(\"No such lock \"+lockName); return; }\n  lock.owner = null;\n  lock.recursiveCount = 0;\n  log(\"Force-released \" + lockName);\n  wakeNext(lock);\n  refreshUI();\n}\n\n/* Scheduler tick - one step */\nfunction tickOnce() {\n  Sim.ticks++;\n  // check sleeping/holding threads\n  for (let t of Sim.threads) {\n    if (t.state === 'sleeping' && Sim.ticks >= t.holdUntilTick) {\n      t.state = 'ready';\n      log(t.nameTag() + \" finished sleeping\");\n    }\n    if ((t.state === 'running' || t.state === 'ready') && t.holdUntilTick && Sim.ticks >= t.holdUntilTick) {\n      // finishing hold\n      t.holdUntilTick = 0;\n      // nothing special; if it was running it will continue\n    }\n    // timeouts for blocked acquisitions\n    if (t.state === 'blocked' && t._acqTimeoutTick != null && Sim.ticks >= t._acqTimeoutTick) {\n      // timeout occurred\n      const lockName = t.blockedOn;\n      t.state = 'ready';\n      t.blockedOn = null;\n      t._acqTimeoutTick = null;\n      // remove from lock queue\n      const lock = Sim.locks[lockName];\n      if (lock) lock.queue = lock.queue.filter(id=>id!==t.id);\n      log(t.nameTag() + \" acquisition timeout on \" + lockName);\n    }\n  }\n\n  // deadlock detection optional\n  if (Sim.deadlockDetect) {\n    if (Sim.ticks % 10 === 0) { // check periodically\n      const cycles = detectDeadlocks();\n      if (cycles.length > 0) {\n        for (const c of cycles) {\n          log(\"Deadlock detected: \" + c.map(id=>threadById(id)?.name||id).join(\" -> \"));\n        }\n      }\n    }\n  }\n\n  // pick thread to run\n  const choose = pickNextThread();\n  if (!choose) return;\n  // set running state\n  Sim.threads.forEach(t=>{ if (t !== choose && t.state==='running') t.state='ready'; });\n  if (choose.state !== 'blocked' && !choose.suspended && choose.state !== 'finished') choose.state = 'running';\n  // process one action for the chosen thread\n  processThreadAction(choose);\n  refreshUI();\n}\n\n/* Process one action from thread's script */\nfunction processThreadAction(thread) {\n  if (thread.state === 'blocked' || thread.suspended || thread.state === 'finished') return;\n  // for other behaviors: random, busy, reader\n  if (thread.behavior === 'random') {\n    // random attempt to acquire random lock occasionally\n    if (Object.keys(Sim.locks).length === 0) return;\n    const keys = Object.keys(Sim.locks);\n    if (Math.random() < 0.3) {\n      const ln = keys[Math.floor(Math.random()*keys.length)];\n      attemptAcquire(thread, ln, {});\n    } else {\n      // do some hold\n      thread.holdUntilTick = Sim.ticks + Math.ceil((100 + Math.random()*400) / Sim.tickInterval);\n      thread.state = 'sleeping';\n    }\n    return;\n  } else if (thread.behavior === 'busy') {\n    // busy worker: continually hold CPU for some ticks\n    thread.holdUntilTick = Sim.ticks + Math.ceil(100/Sim.tickInterval);\n    thread.state = 'sleeping';\n    return;\n  } else if (thread.behavior === 'reader') {\n    // attempt to read from first rw lock, else sleep\n    const rw = Object.values(Sim.locks).find(l=>l.type==='rw');\n    if (rw) {\n      // as a read, grant if no writer\n      if (rw.rwWriter === null) {\n        rw.rwReaders.add(thread.id);\n        log(thread.nameTag() + \" acquired reader for \" + rw.name);\n        thread.holdUntilTick = Sim.ticks + Math.ceil(200/Sim.tickInterval);\n        thread.state = 'sleeping';\n        // release after hold end when sleeping finishes we must release; but we mark to release by setting a flag\n        thread._pendingRelease = rw.name;\n      } else {\n        // blocked\n        thread.state = 'blocked';\n        thread.blockedOn = rw.name;\n        log(thread.nameTag() + \" blocked wanting reader for \" + rw.name);\n      }\n    } else {\n      thread.state = 'sleeping';\n      thread.holdUntilTick = Sim.ticks + Math.ceil(200/Sim.tickInterval);\n    }\n    return;\n  }\n\n  // script mode\n  const action = thread.actions[thread.pc];\n  if (!action) {\n    thread.state = 'finished';\n    log(thread.nameTag() + \" finished (end of script)\");\n    return;\n  }\n  thread.recentAction = action.cmd;\n  switch (action.cmd) {\n    case 'acquire':\n      {\n        const res = attemptAcquire(thread, action.lock, {});\n        if (res.success) {\n          thread.pc++;\n        } else {\n          // blocked or failed; do not advance pc\n        }\n      }\n      break;\n    case 'tryacq':\n      {\n        const res = attemptAcquire(thread, action.lock, {try:true});\n        if (res.success) {\n          thread.pc++;\n        } else {\n          thread.pc++;\n        }\n      }\n      break;\n    case 'timeacq':\n      {\n        const res = attemptAcquire(thread, action.lock, {timeout: action.ms});\n        if (res.success) thread.pc++;\n        // else blocked and pc stays\n      }\n      break;\n    case 'release':\n      {\n        releaseLock(thread, action.lock);\n        thread.pc++;\n      }\n      break;\n    case 'hold':\n      {\n        // hold ms - simulate busy work blocking for ms\n        thread.holdUntilTick = Sim.ticks + Math.ceil(action.ms/Sim.tickInterval);\n        thread.state = 'sleeping';\n        thread.pc++;\n      }\n      break;\n    case 'sleep':\n      {\n        thread.holdUntilTick = Sim.ticks + Math.ceil(action.ms/Sim.tickInterval);\n        thread.state = 'sleeping';\n        thread.pc++;\n      }\n      break;\n    case 'yield':\n      {\n        // voluntarily yield: move to next but maintain ready state\n        thread.state = 'ready';\n        thread.pc++;\n      }\n      break;\n    case 'setprio':\n      {\n        thread.priority = action.n;\n        thread.basePriority = action.n;\n        log(thread.nameTag() + \" set priority to \" + action.n);\n        thread.pc++;\n      }\n      break;\n    case 'end':\n      {\n        thread.state = 'finished';\n        log(thread.nameTag() + \" reached end and terminated\");\n        thread.pc++;\n      }\n      break;\n    default:\n      {\n        // noop or unknown\n        thread.pc++;\n      }\n      break;\n  }\n}\n\n/* Thread by id */\nfunction threadById(id) {\n  return Sim.threads.find(t=>t.id===id);\n}\n\n/* UI Refresh */\nfunction refreshUI() {\n  // Locks list\n  const ll = document.getElementById('locksList');\n  ll.innerHTML = '';\n  for (const [name, lock] of Object.entries(Sim.locks)) {\n    const owner = lock.owner ? (threadById(lock.owner)?.name||lock.owner) : '-';\n    const qnames = lock.queue.map(id => threadById(id)?.name || id).join(', ');\n    const info = document.createElement('div');\n    info.textContent = name + \" [\" + lock.type + \"] owner: \" + owner + \" queue: [\" + qnames + \"]\";\n    const btnInfo = document.createElement('button');\n    btnInfo.textContent = \"Info\";\n    btnInfo.onclick = ()=>{ alert(JSON.stringify(lock.info(), null, 2)); };\n    const btnRelease = document.createElement('button');\n    btnRelease.textContent = \"Release\";\n    btnRelease.onclick = ()=>{ forceReleaseLock(name); };\n    info.appendChild(btnInfo);\n    info.appendChild(btnRelease);\n    ll.appendChild(info);\n  }\n\n  // Threads list\n  const tl = document.getElementById('threadsList');\n  tl.innerHTML = '';\n  for (const t of Sim.threads) {\n    const d = document.createElement('div');\n    d.textContent = t.nameTag() + \" state:\" + t.state + \" pc:\" + t.pc + \" action:\" + (t.currentAction()?t.currentAction().cmd:'-') + (t.blockedOn?(\" blockedOn:\"+t.blockedOn):\"\");\n    const sel = document.createElement('input');\n    sel.type='radio'; sel.name='selectedThread'; sel.value=t.id;\n    sel.onclick = ()=>{ showThreadInspector(t.id); };\n    d.prepend(sel);\n    tl.appendChild(d);\n  }\n\n  // Thread inspector maybe update\n  const ins = document.getElementById('threadInspector');\n  ins.innerHTML = '';\n  for (const t of Sim.threads) {\n    const line = document.createElement('div');\n    line.textContent = t.nameTag() + \" | state:\" + t.state + \" | pc:\" + t.pc + \" | scriptLen:\" + t.actions.length;\n    ins.appendChild(line);\n  }\n\n  // metrics area update minimal\n  const metrics = document.getElementById('metricsArea');\n  const mlines = [];\n  mlines.push(\"Ticks: \" + Sim.ticks + \" Threads: \" + Sim.threads.length + \" Locks: \" + Object.keys(Sim.locks).length);\n  for (const [lname, lock] of Object.entries(Sim.locks)) {\n    mlines.push(\"Lock \" + lname + \": owner=\" + (lock.owner?threadById(lock.owner)?.name: '-') + \" queue=[\" + lock.queue.map(id=>threadById(id)?.name||id).join(\", \") + \"]\");\n  }\n  metrics.textContent = mlines.join(\"\\n\");\n}\n\n/* UI bindings */\ndocument.getElementById('tickInterval').addEventListener('input', (e)=>{\n  Sim.tickInterval = Math.max(20, parseInt(e.target.value)||200);\n  Sim.speedMs = Sim.tickInterval;\n});\n\ndocument.getElementById('speedSlider').addEventListener('input', (e)=>{\n  Sim.tickInterval = parseInt(e.target.value);\n  Sim.speedMs = Sim.tickInterval;\n  document.getElementById('tickInterval').value = Sim.tickInterval;\n});\n\ndocument.getElementById('startBtn').addEventListener('click', ()=>{\n  if (Sim.running) return;\n  Sim.running = true;\n  Sim.seed = document.getElementById('seedInput').value || \"42\";\n  Sim.rng = makeRNG(Sim.seed);\n  Sim.tickInterval = Math.max(20, parseInt(document.getElementById('tickInterval').value)||200);\n  Sim.priorityInheritance = document.getElementById('priorityInheritance').checked;\n  Sim.deadlockDetect = document.getElementById('deadlockDetect').checked;\n  Sim.starveMs = Math.max(1000, parseInt(document.getElementById('starveMs').value)||5000);\n  Sim.scheduler = document.getElementById('schedulerSelect').value;\n  Sim.preempt = document.getElementById('preemptCheck').checked;\n  Sim.maxLog = parseInt(document.getElementById('maxLogLines').value) || 500;\n  Sim.intervalId = setInterval(()=>{ tickOnce(); }, Sim.tickInterval);\n  log(\"Simulation started. Scheduler: \" + Sim.scheduler);\n});\n\ndocument.getElementById('pauseBtn').addEventListener('click', ()=>{\n  if (!Sim.running) return;\n  Sim.running = false;\n  clearInterval(Sim.intervalId);\n  Sim.intervalId = null;\n  log(\"Simulation paused\");\n});\n\ndocument.getElementById('stepBtn').addEventListener('click', ()=>{\n  tickOnce();\n});\n\ndocument.getElementById('resetBtn').addEventListener('click', ()=>{\n  if (Sim.intervalId) clearInterval(Sim.intervalId);\n  Sim.running = false;\n  Sim.ticks = 0;\n  Sim.threads = [];\n  Sim.locks = {};\n  Sim.nextThreadId = 1;\n  Sim.nextLockId = 1;\n  Sim.logLines = [];\n  document.getElementById('logArea').textContent = '';\n  document.getElementById('locksList').innerHTML = '';\n  document.getElementById('threadsList').innerHTML = '';\n  document.getElementById('metricsArea').textContent = '';\n  log(\"Simulation reset\");\n});\n\ndocument.getElementById('randomizeBtn').addEventListener('click', ()=>{\n  // create random threads and locks\n  clearThreads();\n  clearLocks();\n  const nlocks = 1 + Math.floor(Math.random()*3);\n  for (let i=0;i<nlocks;i++) addLock(\"L\"+(i+1), [\"mutex\",\"recursive\",\"ticket\",\"spin\",\"rw\"][Math.floor(Math.random()*5)]);\n  const nthreads = 2 + Math.floor(Math.random()*6);\n  for (let i=0;i<nthreads;i++) {\n    const b = Math.random() < 0.3 ? \"random\" : \"script\";\n    addThread(\"T\"+(i+1), Math.floor(Math.random()*3)+1, document.getElementById('scriptTemplate').value, b);\n  }\n});\n\ndocument.getElementById('addLockBtn').addEventListener('click', ()=>{\n  const nm = document.getElementById('newLockName').value || (\"L\"+Sim.nextLockId);\n  const tp = document.getElementById('lockTypeSelect').value;\n  addLock(nm, tp);\n});\n\ndocument.getElementById('clearLocksBtn').addEventListener('click', ()=>{\n  clearLocks();\n});\n\ndocument.getElementById('addThreadBtn').addEventListener('click', ()=>{\n  const nm = document.getElementById('newThreadName').value || (\"T\"+Sim.nextThreadId);\n  const pr = parseInt(document.getElementById('newThreadPriority').value) || 1;\n  const beh = document.getElementById('behaviorSelect').value;\n  let script = document.getElementById('scriptTemplate').value;\n  addThread(nm, pr, script, beh);\n});\n\ndocument.getElementById('clearThreadsBtn').addEventListener('click', ()=>{\n  clearThreads();\n});\n\ndocument.getElementById('applyTemplateBtn').addEventListener('click', ()=>{\n  const r = document.querySelector('input[name=\"selectedThread\"]:checked');\n  if (!r) { alert(\"Select a thread to apply template\"); return; }\n  const t = threadById(parseInt(r.value));\n  if (!t) return;\n  t.scriptText = document.getElementById('scriptTemplate').value;\n  t.actions = parseScript(t.scriptText);\n  t.pc = 0;\n  log(\"Applied template to \" + t.name);\n});\n\nfunction showThreadInspector(id) {\n  const t = threadById(id);\n  if (!t) return;\n  const area = document.getElementById('threadInspector');\n  area.innerHTML = '';\n  const header = document.createElement('div');\n  header.textContent = \"Inspecting \" + t.nameTag();\n  area.appendChild(header);\n  const st = document.createElement('div');\n  st.textContent = \"State: \" + t.state + \" BlockedOn:\" + (t.blockedOn||'-') + \" PC:\" + t.pc;\n  area.appendChild(st);\n  const act = document.createElement('textarea');\n  act.value = t.scriptText;\n  act.rows = 8;\n  act.cols = 60;\n  area.appendChild(act);\n  const saveBtn = document.createElement('button');\n  saveBtn.textContent = \"Save Script\";\n  saveBtn.onclick = ()=>{ t.scriptText = act.value; t.actions = parseScript(act.value); t.pc = 0; log(\"Saved script for \" + t.name); };\n  area.appendChild(saveBtn);\n  const suspend = document.createElement('button');\n  suspend.textContent = t.suspended ? \"Resume\" : \"Suspend\";\n  suspend.onclick = ()=>{ t.suspended = !t.suspended; refreshUI(); log((t.suspended?\"Suspended \":\"Resumed \") + t.name); showThreadInspector(t.id); };\n  area.appendChild(suspend);\n  const kill = document.createElement('button');\n  kill.textContent = \"Kill\";\n  kill.onclick = ()=>{ t.state='finished'; log(\"Killed \" + t.name); refreshUI(); showThreadInspector(t.id); };\n  area.appendChild(kill);\n  const stepBtn = document.createElement('button');\n  stepBtn.textContent = \"Step\";\n  stepBtn.onclick = ()=>{ processThreadAction(t); refreshUI(); showThreadInspector(t.id); };\n  area.appendChild(stepBtn);\n}\n\n/* Manual control buttons */\ndocument.getElementById('stepSelectedBtn').addEventListener('click', ()=>{\n  const sel = document.querySelector('input[name=\"selectedThread\"]:checked');\n  if (!sel) { alert(\"Select a thread\"); return; }\n  const t = threadById(parseInt(sel.value));\n  processThreadAction(t);\n  refreshUI();\n});\n\ndocument.getElementById('resumeSelectedBtn').addEventListener('click', ()=>{\n  const sel = document.querySelector('input[name=\"selectedThread\"]:checked');\n  if (!sel) { alert(\"Select a thread\"); return; }\n  const t = threadById(parseInt(sel.value));\n  t.suspended = false;\n  t.state = 'ready';\n  log(\"Resumed \" + t.name);\n  refreshUI();\n});\n\ndocument.getElementById('suspendSelectedBtn').addEventListener('click', ()=>{\n  const sel = document.querySelector('input[name=\"selectedThread\"]:checked');\n  if (!sel) { alert(\"Select a thread\"); return; }\n  const t = threadById(parseInt(sel.value));\n  t.suspended = true;\n  t.state = 'ready';\n  log(\"Suspended \" + t.name);\n  refreshUI();\n});\n\ndocument.getElementById('killSelectedBtn').addEventListener('click', ()=>{\n  const sel = document.querySelector('input[name=\"selectedThread\"]:checked');\n  if (!sel) { alert(\"Select a thread\"); return; }\n  const t = threadById(parseInt(sel.value));\n  t.state = 'finished';\n  log(\"Killed \" + t.name);\n  refreshUI();\n});\n\ndocument.getElementById('forceAcquireBtn').addEventListener('click', ()=>{\n  const sel = document.querySelector('input[name=\"selectedThread\"]:checked');\n  const lockName = document.getElementById('forceLockSelect').value;\n  if (!sel) { alert(\"Select a thread\"); return; }\n  if (!lockName) { alert(\"Specify lock name\"); return; }\n  const t = threadById(parseInt(sel.value));\n  forceAcquire(t, lockName);\n});\n\ndocument.getElementById('forceReleaseBtn').addEventListener('click', ()=>{\n  const lockName = document.getElementById('forceLockSelect').value;\n  if (!lockName) { alert(\"Specify lock name\"); return; }\n  forceReleaseLock(lockName);\n});\n\ndocument.getElementById('showWaitStatsBtn').addEventListener('click', ()=>{\n  const stats = {};\n  for (const t of Sim.threads) {\n    for (const [lname, count] of Object.entries(t.stats.acquired)) {\n      stats[lname] = stats[lname] || {acq:0};\n      stats[lname].acq += count;\n    }\n  }\n  let out = \"Acquisitions per lock:\\n\";\n  for (const [k,v] of Object.entries(stats)) out += k + \": \" + v.acq + \"\\n\";\n  document.getElementById('metricsArea').textContent = out;\n});\n\ndocument.getElementById('detectDeadlocksBtn').addEventListener('click', ()=>{\n  const cycles = detectDeadlocks();\n  if (cycles.length === 0) alert(\"No cycles detected\");\n  else alert(\"Deadlocks cycles:\\n\" + cycles.map(c=>c.join(\" -> \")).join(\"\\n\"));\n});\n\ndocument.getElementById('clearLogBtn').addEventListener('click', ()=>{\n  Sim.logLines = [];\n  document.getElementById('logArea').textContent = '';\n});\n\n/* Deadlock detection - wait-for graph cycle detection */\nfunction detectDeadlocks() {\n  const graph = {}; // thread id -> set of thread ids it waits for\n  for (const t of Sim.threads) {\n    if (t.state === 'blocked' && t.blockedOn) {\n      const lock = Sim.locks[t.blockedOn];\n      if (lock) {\n        const owners = [];\n        if (lock.owner) owners.push(lock.owner);\n        if (lock.type === 'rw') {\n          for (const r of lock.rwReaders) owners.push(r);\n        }\n        graph[t.id] = new Set(owners.filter(o=>o !== null && o !== undefined));\n      } else {\n        graph[t.id] = new Set();\n      }\n    } else {\n      graph[t.id] = new Set();\n    }\n  }\n  // detect cycles using DFS\n  const cycles = [];\n  const visited = {};\n  const stack = {};\n  function dfs(u, path) {\n    visited[u] = true;\n    stack[u] = true;\n    path.push(u);\n    for (const v of graph[u]) {\n      if (!visited[v]) {\n        dfs(v, path);\n      } else if (stack[v]) {\n        // cycle found, extract path\n        const idx = path.indexOf(v);\n        if (idx >= 0) {\n          cycles.push(path.slice(idx));\n        } else {\n          cycles.push([v]);\n        }\n      }\n    }\n    path.pop();\n    stack[u] = false;\n  }\n  for (const nid of Object.keys(graph).map(x=>parseInt(x))) {\n    if (!visited[nid]) dfs(nid, []);\n  }\n  return cycles;\n}\n\n/* Init small demo */\n(function initDemo(){\n  addLock(\"L1\",\"mutex\");\n  addLock(\"L2\",\"mutex\");\n  addThread(\"T1\", 1, \"acquire L1\\nhold 200\\nacquire L2\\nhold 200\\nrelease L2\\nrelease L1\\nend\", \"script\");\n  addThread(\"T2\", 2, \"sleep 100\\nacquire L2\\nhold 400\\nrelease L2\\nend\", \"script\");\n  refreshUI();\n  log(\"Initialized demo: two threads and two locks (possible deadlock if order reversed).\");\n})();\n</script>\n</body>\n</html>"
