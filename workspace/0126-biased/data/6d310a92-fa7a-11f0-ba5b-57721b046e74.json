  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Query Optimization Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .panel { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }\n        .query-plan { font-family: monospace; white-space: pre; }\n        .hidden { display: none; }\n        table { border-collapse: collapse; width: 100%; }\n        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }\n        button { margin: 2px; }\n        input, select { margin: 2px; }\n        .slider-container { width: 300px; margin: 10px 0; }\n        .cost-display { font-weight: bold; }\n    </style>\n</head>\n<body>\n    <h1>Query Optimization Explorer</h1>\n    \n    <div class=\"panel\">\n        <h2>Database Schema</h2>\n        <div>\n            <h3>Tables</h3>\n            <select id=\"table-selector\">\n                <option value=\"customers\">Customers (100,000 rows)</option>\n                <option value=\"orders\">Orders (1,000,000 rows)</option>\n                <option value=\"products\">Products (10,000 rows)</option>\n                <option value=\"order_items\">Order Items (3,000,000 rows)</option>\n            </select>\n            <button id=\"show-schema-btn\">Show Schema</button>\n            <div id=\"schema-display\" class=\"query-plan\"></div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Query Builder</h2>\n        <div>\n            <h3>Tables to Query</h3>\n            <div id=\"selected-tables\">\n                <label><input type=\"checkbox\" name=\"query-table\" value=\"customers\" checked> Customers</label>\n                <label><input type=\"checkbox\" name=\"query-table\" value=\"orders\"> Orders</label>\n                <label><input type=\"checkbox\" name=\"query-table\" value=\"products\"> Products</label>\n                <label><input type=\"checkbox\" name=\"query-table\" value=\"order_items\"> Order Items</label>\n            </div>\n            \n            <h3>Join Conditions</h3>\n            <div id=\"join-conditions\">\n                <div>\n                    <select class=\"join-table1\">\n                        <option value=\"customers\">customers</option>\n                        <option value=\"orders\">orders</option>\n                    </select>\n                    <select class=\"join-column1\">\n                        <option value=\"id\">id</option>\n                        <option value=\"customer_id\">customer_id</option>\n                    </select>\n                    =\n                    <select class=\"join-table2\">\n                        <option value=\"orders\">orders</option>\n                        <option value=\"customers\">customers</option>\n                    </select>\n                    <select class=\"join-column2\">\n                        <option value=\"customer_id\">customer_id</option>\n                        <option value=\"id\">id</option>\n                    </select>\n                    <button class=\"add-join-btn\">Add Join</button>\n                </div>\n            </div>\n            \n            <h3>Filters</h3>\n            <div id=\"filter-conditions\">\n                <div>\n                    <select class=\"filter-table\">\n                        <option value=\"customers\">customers</option>\n                        <option value=\"orders\">orders</option>\n                    </select>\n                    <select class=\"filter-column\">\n                        <option value=\"status\">status</option>\n                        <option value=\"amount\">amount</option>\n                    </select>\n                    <select class=\"filter-operator\">\n                        <option value=\"=\">=</option>\n                        <option value=\">\">></option>\n                        <option value=\"<\"><</option>\n                        <option value=\"LIKE\">LIKE</option>\n                    </select>\n                    <input type=\"text\" class=\"filter-value\" placeholder=\"value\">\n                    <button class=\"add-filter-btn\">Add Filter</button>\n                </div>\n            </div>\n            \n            <button id=\"generate-query-btn\">Generate Query</button>\n            <div id=\"generated-query\" class=\"query-plan\"></div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Optimization Controls</h2>\n        <div>\n            <h3>Execution Plan Options</h3>\n            <div>\n                <label><input type=\"checkbox\" id=\"use-indexes\" checked> Use Indexes</label>\n                <label><input type=\"checkbox\" id=\"enable-join-reorder\"> Enable Join Reordering</label>\n                <label><input type=\"checkbox\" id=\"enable-parallel\" checked> Parallel Execution</label>\n            </div>\n            \n            <h3>Join Algorithm</h3>\n            <select id=\"join-algorithm\">\n                <option value=\"nested_loop\">Nested Loop Join</option>\n                <option value=\"hash\">Hash Join</option>\n                <option value=\"merge\">Merge Join</option>\n            </select>\n            \n            <h3>Memory Allocation</h3>\n            <div class=\"slider-container\">\n                Work Memory: <input type=\"range\" id=\"work-mem\" min=\"1\" max=\"100\" value=\"50\"> <span id=\"work-mem-value\">50 MB</span>\n            </div>\n            \n            <button id=\"explain-btn\">Explain Query</button>\n            <button id=\"execute-btn\">Execute Query</button>\n        </div>\n    </div>\n    \n    <div class=\"results-panel panel\">\n        <h2>Results</h2>\n        <div>\n            <h3>Execution Plan</h3>\n            <div id=\"execution-plan\" class=\"query-plan\"></div>\n            \n            <h3>Performance Metrics</h3>\n            <div id=\"performance-metrics\">\n                <p>Estimated Cost: <span id=\"estimated-cost\" class=\"cost-display\">-</span></p>\n                <p>Actual Execution Time: <span id=\"execution-time\" class=\"cost-display\">-</span> ms</p>\n                <p>Rows Processed: <span id=\"rows-processed\" class=\"cost-display\">-</span></p>\n            </div>\n            \n            <h3>Result Data (First 10 Rows)</h3>\n            <div id=\"result-data\"></div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Optimization Experiments</h2>\n        <div>\n            <h3>Compare Plans</h3>\n            <button id=\"save-plan-btn\">Save Current Plan</button>\n            <button id=\"compare-plans-btn\">Compare Saved Plans</button>\n            <div id=\"plan-comparison\"></div>\n            \n            <h3>Index Advisor</h3>\n            <button id=\"analyze-query-btn\">Analyze Query for Indexes</button>\n            <div id=\"index-recommendations\"></div>\n        </div>\n    </div>\n    \n    <script>\n        // Database schema information\n        const schemas = {\n            customers: {\n                columns: ['id', 'name', 'email', 'join_date', 'status', 'region'],\n                indexes: ['id (PK)', 'email', 'region'],\n                stats: { rows: 100000, size: '25MB' }\n            },\n            orders: {\n                columns: ['id', 'customer_id', 'order_date', 'status', 'amount'],\n                indexes: ['id (PK)', 'customer_id', 'order_date'],\n                stats: { rows: 1000000, size: '150MB' }\n            },\n            products: {\n                columns: ['id', 'name', 'category', 'price', 'stock'],\n                indexes: ['id (PK)', 'category'],\n                stats: { rows: 10000, size: '5MB' }\n            },\n            order_items: {\n                columns: ['id', 'order_id', 'product_id', 'quantity', 'price'],\n                indexes: ['id (PK)', 'order_id', 'product_id'],\n                stats: { rows: 3000000, size: '200MB' }\n            }\n        };\n        \n        // Sample data for results\n        const sampleResults = {\n            customers: [\n                { id: 1, name: 'John Doe', email: 'john@example.com', join_date: '2020-01-15', status: 'active', region: 'West' },\n                { id: 2, name: 'Jane Smith', email: 'jane@example.com', join_date: '2020-02-20', status: 'active', region: 'East' }\n            ],\n            orders: [\n                { id: 1001, customer_id: 1, order_date: '2021-05-10', status: 'completed', amount: 125.50 },\n                { id: 1002, customer_id: 2, order_date: '2021-05-12', status: 'shipped', amount: 89.99 }\n            ]\n        };\n        \n        // State\n        let currentQuery = null;\n        let savedPlans = [];\n        // DOM elements\n        const schemaDisplay = document.getElementById('schema-display');\n        const tableSelector = document.getElementById('table-selector');\n        const showSchemaBtn = document.getElementById('show-schema-btn');\n        const generateQueryBtn = document.getElementById('generate-query-btn');\n        const generatedQuery = document.getElementById('generated-query');\n        const explainBtn = document.getElementById('explain-btn');\n        const executeBtn = document.getElementById('execute-btn');\n        const executionPlan = document.getElementById('execution-plan');\n        const resultData = document.getElementById('result-data');\n        const savePlanBtn = document.getElementById('save-plan-btn');\n        const comparePlansBtn = document.getElementById('compare-plans-btn');\n        const planComparison = document.getElementById('plan-comparison');\n        const analyzeQueryBtn = document.getElementById('analyze-query-btn');\n        const indexRecommendations = document.getElementById('index-recommendations');\n        const workMemSlider = document.getElementById('work-mem');\n        const workMemValue = document.getElementById('work-mem-value');\n        \n        // Event listeners\n        showSchemaBtn.addEventListener('click', showSchema);\n        generateQueryBtn.addEventListener('click', generateQuery);\n        explainBtn.addEventListener('click', explainQuery);\n        executeBtn.addEventListener('click', executeQuery);\n        savePlanBtn.addEventListener('click', savePlan);\n        comparePlansBtn.addEventListener('click', comparePlans);\n        analyzeQueryBtn.addEventListener('click', analyzeForIndexes);\n        workMemSlider.addEventListener('input', updateWorkMemDisplay);\n        \n        // Initialize\n        updateWorkMemDisplay();\n        \n        // Functions\n        function showSchema() {\n            const table = tableSelector.value;\n            const schema = schemas[table];\n            \n            let displayText = `Table: ${table}\\n`;\n            displayText += `Columns: ${schema.columns.join(', ')}\\n`;\n            displayText += `Indexes: ${schema.indexes.join(', ')}\\n`;\n            displayText += `Statistics: ${schema.stats.rows} rows, ${schema.stats.size}`;\n            \n            schemaDisplay.textContent = displayText;\n        }\n        \n        function generateQuery() {\n            const selectedTables = Array.from(document.querySelectorAll('input[name=\"query-table\"]:checked'))\n                .map(el => el.value);\n            \n            if (selectedTables.length === 0) {\n                generatedQuery.textContent = \"Please select at least one table\";\n                return;\n            }\n            \n            // Simple query generation\n            let query = \"SELECT \";\n            if (selectedTables.length > 1) {\n                query += \"*\\nFROM \" + selectedTables.join(\", \");\n            } else {\n                query += \"*\\nFROM \" + selectedTables[0];\n            }\n            \n            // Add joins if multiple tables\n            if (selectedTables.length > 1) {\n                // This is simplified - real implementation would use the join conditions\n                query += \"\\nWHERE customers.id = orders.customer_id\";\n                if (selectedTables.includes('order_items')) {\n                    query += \" AND orders.id = order_items.order_id\";\n                }\n                if (selectedTables.includes('products')) {\n                    query += \" AND order_items.product_id = products.id\";\n                }\n            }\n            \n            currentQuery = query;\n            generatedQuery.textContent = query;\n        }\n        \n        function explainQuery() {\n            if (!currentQuery) {\n                executionPlan.textContent = \"Please generate a query first\";\n                return;\n            }\n            \n            const useIndexes = document.getElementById('use-indexes').checked;\n            const joinAlgorithm = document.getElementById('join-algorithm').value;\n            const workMem = workMemSlider.value;\n            \n            let plan = \"QUERY PLAN\\n\";\n            plan += \"------------------------------------------------------------\\n\";\n            plan += `Cost settings: work_mem=${workMem}MB, join=${joinAlgorithm}\\n`;\n            if (useIndexes) {\n                plan += \"Using available indexes\\n\";\n            } else {\n                plan += \"Not using indexes (seq scans)\\n\";\n            }\n            \n            if (currentQuery.includes(\"customers\") && currentQuery.includes(\"orders\")) {\n                plan += \"\\nNested Loop Join (cost=1000.00..1500.00 rows=50000 width=100)\\n\";\n                plan += \"  ->  Seq Scan on customers (cost=0.00..100.00 rows=1000 width=50)\\n\";\n                if (useIndexes) {\n                    plan += \"  ->  Index Scan using orders_customer_id_idx on orders (cost=0.00..1.20 rows=50 width=50)\\n\";\n                } else {\n                    plan += \"  ->  Seq Scan on orders (cost=0.00..1000.00 rows=50000 width=50)\\n\";\n                }\n            } else if (currentQuery.includes(\"customers\")) {\n                if (useIndexes) {\n                    plan += \"Index Scan using customers_pkey on customers (cost=0.00..50.00 rows=1000 width=50)\\n\";\n                } else {\n                    plan += \"Seq Scan on customers (cost=0.00..100.00 rows=1000 width=50)\\n\";\n                }\n            }\n            \n            // Update performance metrics\n            document.getElementById('estimated-cost').textContent = \"1500.00\";\n            document.getElementById('execution-time').textContent = \"-\";\n            document.getElementById('rows-processed').textContent = \"50000\";\n            \n            executionPlan.textContent = plan;\n        }\n        \n        function executeQuery() {\n            if (!currentQuery) {\n                resultData.textContent = \"Please generate a query first\";\n                return;\n            }\n            \n            explainQuery(); // Show plan first\n            \n            // Simulate execution\n            const startTime = performance.now();\n            \n            // Simulate different execution times based on query complexity\n            let executionTime = 50;\n            if (currentQuery.includes(\"customers\") && currentQuery.includes(\"orders\")) {\n                executionTime = 150;\n            }\n            if (currentQuery.includes(\"order_items\")) {\n                executionTime = 300;\n            }\n            \n            // Simulate delay\n            setTimeout(() => {\n                const endTime = performance.now();\n                const actualTime = (endTime - startTime).toFixed(2);\n                \n                document.getElementById('execution-time').textContent = actualTime;\n                \n                // Show sample results\n                let resultHTML = \"<table><tr>\";\n                \n                // Add headers\n                if (currentQuery.includes(\"customers\")) {\n                    Object.keys(sampleResults.customers[0]).forEach(col => {\n                        resultHTML += `<th>${col}</th>`;\n                    });\n                }\n                if (currentQuery.includes(\"orders\")) {\n                    Object.keys(sampleResults.orders[0]).forEach(col => {\n                        resultHTML += `<th>${col}</th>`;\n                    });\n                }\n                \n                resultHTML += \"</tr>\";\n                \n                // Add data\n                for (let i = 0; i < 2; i++) {\n                    resultHTML += \"<tr>\";\n                    if (currentQuery.includes(\"customers\")) {\n                        Object.values(sampleResults.customers[i]).forEach(val => {\n                            resultHTML += `<td>${val}</td>`;\n                        });\n                    }\n                    if (currentQuery.includes(\"orders\")) {\n                        Object.values(sampleResults.orders[i]).forEach(val => {\n                            resultHTML += `<td>${val}</td>`;\n                        });\n                    }\n                    resultHTML += \"</tr>\";\n                }\n                \n                resultHTML += \"</table>\";\n                resultData.innerHTML = resultHTML;\n            }, executionTime);\n        }\n        \n        function savePlan() {\n            if (!executionPlan.textContent || executionPlan.textContent.includes(\"Please generate\")) {\n                alert(\"No execution plan to save\");\n                return;\n            }\n            \n            const planInfo = {\n                query: currentQuery,\n                plan: executionPlan.textContent,\n                cost: document.getElementById('estimated-cost').textContent,\n                time: document.getElementById('execution-time').textContent,\n                settings: {\n                    useIndexes: document.getElementById('use-indexes').checked,\n                    joinAlgorithm: document.getElementById('join-algorithm').value,\n                    workMem: workMemSlider.value\n                }\n            };\n            \n            savedPlans.push(planInfo);\n            alert(`Plan saved (${savedPlans.length} plans stored)`);\n        }\n        \n        function comparePlans() {\n            if (savedPlans.length < 2) {\n                planComparison.textContent = \"Need at least 2 saved plans to compare\";\n                return;\n            }\n            \n            let comparison = \"PLAN COMPARISON\\n\";\n            comparison += \"------------------------------------------------\\n\";\n            \n            savedPlans.forEach((plan, i) => {\n                comparison += `PLAN ${i+1}:\\n`;\n                comparison += `Query: ${plan.query.split('\\n')[0]}...\\n`;\n                comparison += `Cost: ${plan.cost}\\n`;\n                comparison += `Time: ${plan.time} ms\\n`;\n                comparison += `Settings: ${JSON.stringify(plan.settings)}\\n\\n`;\n            });\n            \n            // Find best plan\n            const bestPlan = savedPlans.reduce((best, current) => {\n                return parseFloat(current.cost) < parseFloat(best.cost) ? current : best;\n            }, savedPlans[0]);\n            \n            comparison += `BEST PLAN: #${savedPlans.indexOf(bestPlan)+1} with cost ${bestPlan.cost}`;\n            \n            planComparison.textContent = comparison;\n        }\n        \n        function analyzeForIndexes() {\n            if (!currentQuery) {\n                indexRecommendations.textContent = \"Please generate a query first\";\n                return;\n            }\n            \n            let recommendations = \"INDEX RECOMMENDATIONS\\n\";\n            recommendations += \"------------------------------------------------\\n\";\n            \n            if (currentQuery.includes(\"customers\") && currentQuery.includes(\"status\")) {\n                recommendations += \"- Consider adding an index on customers(status)\\n\";\n            }\n            \n            if (currentQuery.includes(\"orders\") && currentQuery.includes(\"customer_id\")) {\n                recommendations += \"- Index on orders(customer_id) already exists\\n\";\n            }\n            \n            if (currentQuery.includes(\"orders\") && currentQuery.includes(\"amount\")) {\n                recommendations += \"- Consider adding a partial index on orders(amount) WHERE amount > 100\\n\";\n            }\n            \n            if (recommendations === \"INDEX RECOMMENDATIONS\\n------------------------------------------------\\n\") {\n                recommendations += \"No specific index recommendations for this query\";\n            }\n            \n            indexRecommendations.textContent = recommendations;\n        }\n        \n        function updateWorkMemDisplay() {\n            workMemValue.textContent = `${workMemSlider.value} MB`;\n        }\n        \n        // Helper for join conditions (simplified)\n        document.querySelector('.add-join-btn').addEventListener('click', function() {\n            const table1 = this.parentElement.querySelector('.join-table1').value;\n            const col1 = this.parentElement.querySelector('.join-column1').value;\n            const table2 = this.parentElement.querySelector('.join-table2').value;\n            const col2 = this.parentElement.querySelector('.join-column2').value;\n            \n            alert(`Added join condition: ${table1}.${col1} = ${table2}.${col2}\\n(Note: This demo simulates the UI - actual join logic would be implemented in a real application)`);\n        });\n        \n        // Helper for filter conditions (simplified)\n        document.querySelector('.add-filter-btn').addEventListener('click', function() {\n            const table = this.parentElement.querySelector('.filter-table').value;\n            const col = this.parentElement.querySelector('.filter-column').value;\n            const op = this.parentElement.querySelector('.filter-operator').value;\n            const value = this.parentElement.querySelector('.filter-value').value;\n            \n            alert(`Added filter: ${table}.${col} ${op} ${value}\\n(Note: This demo simulates the UI - actual filter logic would be implemented in a real application)`);\n        });\n    </script>\n</body>\n</html>"
  },
