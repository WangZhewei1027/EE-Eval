    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Static Typing — Visual Exploration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #081127;\n      --bg-2: #071424;\n      --accent-a: #6EE7B7; /* mint */\n      --accent-b: #7C83FF; /* violet */\n      --accent-c: #FFD36E; /* warm gold */\n      --glass: rgba(255,255,255,0.06);\n      --muted: rgba(255,255,255,0.55);\n      --danger: #FF6B6B;\n      --success: #6EE7B7;\n      --card-radius: 18px;\n      color-scheme: dark;\n    }\n\n    /* Page layout */\n    html,body{height:100%;margin:0;background:linear-gradient(160deg,var(--bg-1),var(--bg-2));font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    *{box-sizing:border-box}\n    .stage{\n      min-height:100vh;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n      position:relative;\n      overflow:hidden;\n    }\n\n    /* Particle/ambient blobs */\n    .ambient{\n      position:absolute;inset:0;\n      pointer-events:none;\n      background:\n        radial-gradient(600px 400px at 10% 10%, rgba(124,131,255,0.12), transparent 12%),\n        radial-gradient(500px 300px at 90% 90%, rgba(110,231,183,0.08), transparent 14%),\n        radial-gradient(400px 260px at 50% 30%, rgba(255,211,110,0.05), transparent 10%);\n      mix-blend-mode:screen;\n      opacity:0.9;\n      animation: ambientShift 18s linear infinite;\n    }\n    @keyframes ambientShift{\n      0%{transform:translateY(0) scale(1)}\n      50%{transform:translateY(-18px) scale(1.02)}\n      100%{transform:translateY(0) scale(1)}\n    }\n\n    /* Main card */\n    .card{\n      width:1100px;\n      max-width:calc(100% - 64px);\n      background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border-radius:calc(var(--card-radius) + 4px);\n      padding:36px;\n      box-shadow:\n        0 12px 40px rgba(2,6,23,0.72),\n        0 1px 0 rgba(255,255,255,0.02) inset;\n      border:1px solid rgba(255,255,255,0.04);\n      display:flex;\n      gap:28px;\n      align-items:stretch;\n      position:relative;\n      overflow:visible;\n    }\n\n    /* Header area */\n    .header{\n      position:absolute;\n      left:40px;top:-34px;\n      display:flex;\n      gap:18px;\n      align-items:center;\n      backdrop-filter: blur(6px);\n      padding:10px 14px;\n      border-radius:12px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border:1px solid rgba(255,255,255,0.04);\n      box-shadow:0 6px 22px rgba(2,6,23,0.6);\n    }\n    .logo{\n      width:56px;height:56px;border-radius:12px;\n      display:grid;place-items:center;\n      background:linear-gradient(135deg,var(--accent-b),var(--accent-a));\n      color:#081127;font-weight:800;font-family:Space Mono,monospace;\n      box-shadow:0 8px 30px rgba(124,131,255,0.16), inset 0 -6px 18px rgba(0,0,0,0.12);\n      transform:rotate(-6deg);\n    }\n    .title-wrap{color:var(--muted)}\n    .title{font-weight:800;color:#fff;font-size:18px;letter-spacing:-0.02em}\n    .subtitle{font-size:12px;color:rgba(255,255,255,0.6);margin-top:2px}\n\n    /* Controls */\n    .controls{\n      margin-left:auto;display:flex;gap:10px;align-items:center;\n    }\n    .btn{\n      appearance:none;border:0;padding:10px 14px;border-radius:10px;font-weight:600;font-size:13px;\n      color:#061223;background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border:1px solid rgba(255,255,255,0.04);cursor:pointer;backdrop-filter: blur(6px);\n      display:inline-flex;gap:10px;align-items:center;\n      transition:transform .18s ease, box-shadow .18s ease;\n      box-shadow:0 6px 18px rgba(2,6,23,0.45);\n    }\n    .btn:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(2,6,23,0.6)}\n    .btn.ghost{background:transparent;border:1px solid rgba(255,255,255,0.06);color:var(--accent-c)}\n    .switch{\n      padding:8px;border-radius:10px;background:linear-gradient(90deg,#0f1b2b,#071324);display:inline-flex;gap:8px;align-items:center;\n    }\n    .dot{\n      width:12px;height:12px;border-radius:50%;background:linear-gradient(180deg,var(--accent-a),#3ad8a1);box-shadow:0 6px 20px rgba(110,231,179,0.12);\n    }\n\n    /* Layout internal split */\n    .left, .right{flex:1;min-width:0}\n    .left{display:flex;flex-direction:column;gap:18px;align-items:flex-start;justify-content:center;padding:6px 0 6px 6px}\n    .right{display:flex;align-items:center;justify-content:center;padding:8px 0 8px 12px}\n\n    /* Big headline */\n    .big{\n      font-weight:800;color:white;font-size:40px;line-height:1;letter-spacing:-0.02em;font-family:Space Mono,monospace;\n      text-shadow:0 6px 28px rgba(124,131,255,0.14), 0 2px 12px rgba(10,15,30,0.6);\n      display:flex;gap:14px;align-items:center;\n    }\n    .tagline{font-size:14px;color:rgba(255,255,255,0.72);margin-top:6px;max-width:520px}\n\n    /* Visual network (left side) */\n    .network{\n      margin-top:10px;width:100%;height:260px;position:relative;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:14px;padding:18px;border:1px solid rgba(255,255,255,0.03);\n      display:flex;gap:12px;align-items:center;justify-content:center;overflow:visible;\n      box-shadow:inset 0 -6px 18px rgba(0,0,0,0.18);\n    }\n\n    /* Type nodes */\n    .node{\n      width:130px;height:72px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:#fff;padding:12px;display:flex;flex-direction:column;justify-content:center;gap:6px;\n      border:1px solid rgba(255,255,255,0.04);box-shadow:0 8px 28px rgba(9,12,22,0.55);\n      transform:translateZ(0);\n    }\n    .node .n-head{font-size:12px;color:var(--accent-c);font-weight:700;letter-spacing:0.06em;}\n    .node .n-body{font-weight:800;font-family:Space Mono,monospace;color:#fff;font-size:18px}\n    .node.pulse{animation:float 6s ease-in-out infinite}\n    @keyframes float{0%{transform:translateY(0)}50%{transform:translateY(-8px)}100%{transform:translateY(0)}}\n\n    .net-grid{\n      width:100%;display:grid;grid-template-columns:repeat(3,1fr);gap:18px;padding:6px 10px;\n      align-items:center;justify-items:center;\n    }\n\n    /* Connections using SVG overlay */\n    .network svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;overflow:visible}\n    .path{\n      stroke:rgba(124,131,255,0.28);stroke-width:2;fill:none;filter:drop-shadow(0 8px 24px rgba(124,131,255,0.06));\n      mix-blend-mode:screen;\n    }\n    .path.active{stroke:linear-gradient(90deg,var(--accent-b),var(--accent-a));stroke:rgba(110,231,183,0.9);stroke-width:3;opacity:1}\n    .spark{\n      width:10px;height:10px;border-radius:50%;position:absolute;background:radial-gradient(circle,var(--accent-a),rgba(124,131,255,0.18));box-shadow:0 6px 20px rgba(124,131,255,0.2);\n    }\n\n    /* Right code panel */\n    .code-card{\n      width:460px;background:linear-gradient(180deg, rgba(14,20,34,0.9), rgba(5,12,22,0.86));\n      border-radius:14px;padding:18px;border:1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 12px 50px rgba(2,6,23,0.7), inset 0 -8px 20px rgba(0,0,0,0.25);\n      font-family:Space Mono,monospace;color:#cfeffd;position:relative;overflow:hidden;\n    }\n    .code-header{display:flex;align-items:center;gap:12px;margin-bottom:12px}\n    .lights{display:flex;gap:8px}\n    .light{width:12px;height:12px;border-radius:50%;background:rgba(255,255,255,0.06);box-shadow:inset 0 -2px 6px rgba(0,0,0,0.3)}\n    .file-title{font-weight:700;color:rgba(255,255,255,0.9);margin-left:auto;font-size:13px}\n\n    .code-lines{display:flex;flex-direction:column;gap:10px;padding:8px 6px;position:relative;}\n    .line{display:flex;gap:12px;align-items:center;padding:8px;border-radius:10px;transition:background .28s ease, transform .18s cubic-bezier(.2,.9,.2,1);}\n    .gutter{width:36px;color:rgba(255,255,255,0.22);text-align:right;padding-right:6px;font-size:13px;user-select:none}\n    .content{flex:1;font-size:14px;color:rgba(255,255,255,0.92)}\n    .muted{color:rgba(255,255,255,0.4)}\n    .keyword{color: #7C83FF;font-weight:700}\n    .type{color:var(--accent-a);font-weight:700}\n    .string{color:#FFD36E;font-weight:700}\n    .error{background:linear-gradient(90deg, rgba(255,107,107,0.06), rgba(255,107,107,0.02));border:1px solid rgba(255,107,107,0.12);box-shadow:0 6px 28px rgba(255,107,107,0.04) inset}\n    .ok{background:linear-gradient(90deg, rgba(110,231,179,0.04), rgba(124,131,255,0.02));border:1px solid rgba(110,231,179,0.06)}\n    .hint{font-size:12px;color:rgba(255,255,255,0.6);margin-top:8px}\n\n    /* Scan animation overlay */\n    .scanner{\n      position:absolute;left:0;right:0;height:4px;background:linear-gradient(90deg,transparent, rgba(124,131,255,0.24), transparent);\n      top:0;transform:translateY(-20px);opacity:0;transition:opacity .18s ease, transform .4s cubic-bezier(.2,.9,.2,1);\n      box-shadow:0 10px 28px rgba(124,131,255,0.06);\n    }\n    .scanner.run{transform:translateY(0);opacity:1;animation:scan 1.6s linear forwards}\n    @keyframes scan{\n      0%{left:-10%;right:100%}\n      100%{left:0%;right:-10%}\n    }\n\n    /* Result badges */\n    .badge{\n      display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;font-weight:700;font-size:13px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.04);\n    }\n    .badge.ok{color:var(--success);box-shadow:0 10px 30px rgba(110,231,179,0.06)}\n    .badge.err{color:var(--danger);box-shadow:0 10px 30px rgba(255,107,107,0.06)}\n\n    /* Footer note */\n    .note{margin-top:12px;color:rgba(255,255,255,0.6);font-size:13px;max-width:420px}\n\n    /* Small responsive tweaks */\n    @media (max-width:1000px){\n      .card{flex-direction:column;align-items:stretch;padding:22px}\n      .header{left:22px;top:-26px}\n      .right{order:2}\n      .left{order:1}\n      .code-card{width:100%}\n      .big{font-size:32px}\n      .network{height:220px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\">\n    <div class=\"ambient\" aria-hidden=\"true\"></div>\n    <div class=\"card\" role=\"region\" aria-label=\"Static Typing Visual Demonstration\">\n      <div class=\"header\">\n        <div class=\"logo\">ST</div>\n        <div class=\"title-wrap\">\n          <div class=\"title\">Static Typing</div>\n          <div class=\"subtitle\">Compile-time guarantees, expressed visually</div>\n        </div>\n\n        <div class=\"controls\">\n          <div class=\"switch\" title=\"Strict Mode\">\n            <div class=\"dot\" id=\"strictDot\"></div>\n            <div style=\"color:rgba(255,255,255,0.6);font-size:13px;font-weight:700;margin-left:6px\" id=\"strictLabel\">Relaxed</div>\n          </div>\n          <button class=\"btn\" id=\"runBtn\" title=\"Run a quick static check\">Run Typecheck</button>\n        </div>\n      </div>\n\n      <div class=\"left\">\n        <div class=\"big\">Static Typing</div>\n        <div class=\"tagline\">Types are contracts the compiler verifies before your code runs — catching mismatches early, clarifying intent, and enabling safer refactors.</div>\n\n        <div class=\"network\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 1000 300\" preserveAspectRatio=\"none\" id=\"connectionSVG\">\n            <!-- paths will be updated by JS -->\n            <path class=\"path\" id=\"p1\" d=\"M120 210 C 200 180, 360 70, 500 120\" stroke-linecap=\"round\"/>\n            <path class=\"path\" id=\"p2\" d=\"M500 120 C 620 170, 740 90, 840 160\" stroke-linecap=\"round\"/>\n            <path class=\"path\" id=\"p3\" d=\"M120 80 C 240 40, 380 110, 500 80\" stroke-linecap=\"round\" opacity=\"0.18\"/>\n          </svg>\n\n          <div class=\"net-grid\" style=\"z-index:2\">\n            <div class=\"node pulse\" style=\"width:180px\">\n              <div class=\"n-head\">Variable</div>\n              <div class=\"n-body\" id=\"varNode\">let count: number</div>\n            </div>\n\n            <div class=\"node\" style=\"width:160px;background:linear-gradient(180deg, rgba(124,131,255,0.06), rgba(110,231,183,0.02));border:1px solid rgba(124,131,255,0.12)\">\n              <div class=\"n-head\">Type</div>\n              <div class=\"n-body\" id=\"typeNode\">number</div>\n            </div>\n\n            <div class=\"node\" style=\"width:170px;background:linear-gradient(180deg, rgba(255,211,110,0.04), rgba(124,131,255,0.02));border:1px solid rgba(255,211,110,0.08)\">\n              <div class=\"n-head\">Function</div>\n              <div class=\"n-body\">sum(a: number, b: number) → number</div>\n            </div>\n          </div>\n\n          <!-- floating spark -->\n          <div class=\"spark\" id=\"spark\" style=\"left:40%;top:30%;opacity:0.9\"></div>\n        </div>\n\n        <div class=\"note\">Watch the code on the right: clicking Run Typecheck animates the analysis. Toggle strict to see how additional constraints produce more checks.</div>\n      </div>\n\n      <div class=\"right\">\n        <div class=\"code-card\" role=\"article\" aria-label=\"Example code\">\n          <div class=\"scanner\" id=\"scanner\"></div>\n          <div class=\"code-header\">\n            <div class=\"lights\" aria-hidden=\"true\"><span class=\"light\"></span><span class=\"light\"></span><span class=\"light\"></span></div>\n            <div class=\"file-title\">example.ts</div>\n          </div>\n\n          <div class=\"code-lines\" id=\"codeLines\">\n            <div class=\"line\" data-index=\"1\">\n              <div class=\"gutter\">1</div>\n              <div class=\"content\"><span class=\"keyword\">let</span> <span class=\"muted\">count</span><span style=\"color:rgba(255,255,255,0.55)\">:</span> <span class=\"type\">number</span> <span style=\"color:rgba(255,255,255,0.55)\">=</span> <span class=\"string\">5</span>;</div>\n            </div>\n\n            <div class=\"line\" data-index=\"2\">\n              <div class=\"gutter\">2</div>\n              <div class=\"content\"><span class=\"muted\">count</span> <span style=\"color:rgba(255,255,255,0.55)\">=</span> <span class=\"string\">\"hello\"</span>;</div>\n            </div>\n\n            <div class=\"line\" data-index=\"3\">\n              <div class=\"gutter\">3</div>\n              <div class=\"content\"><span class=\"keyword\">function</span> <span style=\"font-weight:700\">inc</span>(<span class=\"muted\">n</span><span style=\"color:rgba(255,255,255,0.55)\">:</span> <span class=\"type\">number</span>) <span style=\"color:rgba(255,255,255,0.55)\">{</span> <span class=\"muted\">return</span> <span class=\"muted\">n</span> <span style=\"color:rgba(255,255,255,0.55)\">+</span> <span class=\"string\">1</span>; <span style=\"color:rgba(255,255,255,0.55)\">}</span></div>\n            </div>\n\n            <div class=\"line\" data-index=\"4\">\n              <div class=\"gutter\">4</div>\n              <div class=\"content\"><span class=\"muted\">const</span> <span style=\"font-weight:700\">result</span> <span style=\"color:rgba(255,255,255,0.55)\">=</span> <span class=\"muted\">inc</span>(<span class=\"muted\">count</span>);</div>\n            </div>\n\n          </div>\n\n          <div style=\"display:flex;gap:12px;align-items:center;margin-top:12px\">\n            <div class=\"badge\" id=\"statusBadge\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\"><path d=\"M5 13l4 4L19 7\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg> Idle</div>\n            <div style=\"margin-left:auto\" id=\"explain\" class=\"hint\">Static analysis examines types before runtime — errors are caught early.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n  // Extremely limited interactivity: two controls only.\n  const runBtn = document.getElementById('runBtn');\n  const scanner = document.getElementById('scanner');\n  const statusBadge = document.getElementById('statusBadge');\n  const codeLines = document.getElementById('codeLines');\n  const spark = document.getElementById('spark');\n  const strictDot = document.getElementById('strictDot');\n  const strictLabel = document.getElementById('strictLabel');\n  let strictMode = false;\n\n  // Simple helper to clear statuses\n  function resetLines() {\n    document.querySelectorAll('.line').forEach(l=>{\n      l.classList.remove('error','ok');\n      l.style.transform = '';\n    });\n    statusBadge.classList.remove('ok','err');\n    statusBadge.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\"><path d=\"M5 13l4 4L19 7\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg> Idle';\n    spark.style.transition = 'transform 900ms cubic-bezier(.2,.9,.2,1), opacity 600ms';\n    spark.style.opacity = 0.9;\n  }\n\n  // Animate a scanning pass and then show results\n  runBtn.addEventListener('click', ()=>{\n    resetLines();\n\n    // Begin scan\n    scanner.classList.remove('run');\n    void scanner.offsetWidth;\n    scanner.classList.add('run');\n    statusBadge.innerHTML = 'Analyzing...';\n    statusBadge.style.opacity = '0.9';\n\n    // Animate spark along a path (approximate)\n    spark.style.transform = 'translateX(-30px) translateY(-6px) scale(1.0)';\n    spark.style.transition = 'transform 1400ms cubic-bezier(.22,.9,.2,1)';\n    setTimeout(()=>{ spark.style.transform = 'translateX(180px) translateY(0) scale(0.9)'; }, 80);\n\n    // After scan completes, show typed errors\n    setTimeout(()=> {\n      // Determine errors based on strict mode\n      const errorLines = strictMode ? [2,4] : [2]; // if strict, assigning string to number (2) and passing possibly wrong variable to inc (4)\n      document.querySelectorAll('.line').forEach(l=>{\n        const idx = Number(l.dataset.index);\n        if (errorLines.includes(idx)) {\n          l.classList.add('error');\n          // subtle shake for errors\n          l.style.transform = 'translateX(-2px)';\n          setTimeout(()=> l.style.transform = 'translateX(2px)', 80);\n          setTimeout(()=> l.style.transform = 'translateX(-1px)', 160);\n          setTimeout(()=> l.style.transform = 'translateX(0)', 240);\n        } else {\n          l.classList.add('ok');\n          l.style.transform = 'translateX(0)';\n        }\n      });\n\n      // Update badge\n      if (errorLines.length > 0) {\n        statusBadge.classList.add('err');\n        statusBadge.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.95\"><path d=\"M12 9v4\" stroke=\"rgba(255,107,107,0.98)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M12 17h.01\" stroke=\"rgba(255,107,107,0.98)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg> ' + (strictMode ? 'Errors (strict)' : 'Type errors');\n      } else {\n        statusBadge.classList.add('ok');\n        statusBadge.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.95\"><path d=\"M5 13l4 4L19 7\" stroke=\"rgba(110,231,179,0.98)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg> All good';\n      }\n\n      // spark fade\n      spark.style.opacity = 0;\n      scanner.classList.remove('run');\n\n      // Animate connection highlight\n      pulseConnections(errorLines.length > 0);\n    }, 1600);\n  });\n\n  // Toggle strict mode when clicking the switch area (dot & label)\n  strictLabel.parentElement.previousElementSibling?.addEventListener?.('click', ()=>{}); // noop to be safe\n\n  // We attach click event to the whole header switch element indirectly\n  const switchEl = document.querySelector('.switch');\n  switchEl.addEventListener('click', ()=>{\n    strictMode = !strictMode;\n    if (strictMode) {\n      strictDot.style.background = 'linear-gradient(180deg,#FFD36E,#FFB86B)';\n      strictLabel.textContent = 'Strict';\n      strictLabel.style.color = 'rgba(255,211,110,0.95)';\n      // subtle network color shift\n      document.querySelectorAll('.path').forEach(p=> p.style.stroke='rgba(255,211,110,0.18)');\n      document.getElementById('varNode').textContent = 'let count: number';\n      document.getElementById('typeNode').textContent = 'number';\n    } else {\n      strictDot.style.background = 'linear-gradient(180deg,var(--accent-a),#3ad8a1)';\n      strictLabel.textContent = 'Relaxed';\n      strictLabel.style.color = 'rgba(255,255,255,0.6)';\n      document.querySelectorAll('.path').forEach(p=> p.style.stroke='rgba(124,131,255,0.28)');\n      document.getElementById('varNode').textContent = 'let count: number';\n      document.getElementById('typeNode').textContent = 'number';\n    }\n    // tiny feedback pulse\n    switchEl.animate([{transform:'scale(1)'},{transform:'scale(1.06)'},{transform:'scale(1)'}],{duration:280,easing:'cubic-bezier(.2,.9,.2,1)'});\n  });\n\n  // Visual pulse for connections when errors present\n  function pulseConnections(hasError){\n    const p1 = document.getElementById('p1');\n    const p2 = document.getElementById('p2');\n    if (hasError) {\n      p1.style.transition = 'stroke 320ms ease, stroke-width 320ms ease, opacity 320ms ease';\n      p2.style.transition = 'stroke 320ms ease, stroke-width 320ms ease, opacity 320ms ease';\n      p1.style.stroke = 'rgba(255,107,107,0.36)';\n      p2.style.stroke = 'rgba(255,107,107,0.26)';\n      p1.style.strokeWidth = '3.5';\n      p2.style.strokeWidth = '2.8';\n      setTimeout(()=>{\n        p1.style.stroke = 'rgba(124,131,255,0.28)';\n        p2.style.stroke = 'rgba(124,131,255,0.28)';\n        p1.style.strokeWidth = '2';\n        p2.style.strokeWidth = '2';\n      },1200);\n    } else {\n      p1.style.stroke = 'rgba(110,231,179,0.36)';\n      p2.style.stroke = 'rgba(124,131,255,0.28)';\n      p1.style.strokeWidth = '3';\n      setTimeout(()=>{\n        p1.style.stroke = 'rgba(124,131,255,0.28)';\n        p1.style.strokeWidth = '2';\n      },1000);\n    }\n  }\n\n  // Small initialization pulse for ambient spark\n  document.addEventListener('DOMContentLoaded', ()=>{\n    setTimeout(()=> {\n      spark.animate([{transform:'translateY(0) scale(1)'},{transform:'translateY(-8px) scale(1.05)'},{transform:'translateY(0) scale(1)'}],{duration:2200,iterations:Infinity,easing:'ease-in-out'});\n    },300);\n    resetLines();\n  });\n\n  // Accessibility: keyboard shortcut (very light) to run typecheck with Enter on Run button focused.\n  runBtn.addEventListener('keydown', (e)=>{ if (e.key === 'Enter') runBtn.click(); });\n\n  // Ensure the switch is clickable by keyboard\n  switchEl.tabIndex = 0;\n  switchEl.addEventListener('keydown', (e)=>{ if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); switchEl.click(); } });\n\n</script>\n</body>\n</html>"
