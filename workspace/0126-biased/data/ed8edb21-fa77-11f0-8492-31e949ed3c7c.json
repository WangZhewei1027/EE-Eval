    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Virtual Memory Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background-color: #0c1c27;\n            color: #ffffff;\n            overflow: hidden;\n        }\n        header {\n            text-align: center;\n            padding: 20px;\n            background-color: #183d4d;\n        }\n        h1 {\n            font-size: 3em;\n            margin: 0;\n            color: #00bcd4;\n            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.5);\n        }\n        h2 {\n            font-size: 1.5em;\n            color: #94d0e1;\n        }\n        .canvas-container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 70vh;\n            position: relative;\n        }\n        #memoryCanvas {\n            border: 3px solid #00bcd4;\n            border-radius: 10px;\n            box-shadow: 0 0 20px rgba(0, 0, 0, 0.7);\n        }\n        .controls {\n            text-align: center;\n            margin-top: 20px;\n        }\n        button {\n            background-color: #00bcd4;\n            color: white;\n            border: none;\n            padding: 10px 20px;\n            font-size: 1em;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s, transform 0.3s;\n        }\n        button:hover {\n            background-color: #0097a7;\n            transform: scale(1.05);\n        }\n        footer {\n            text-align: center;\n            padding: 10px;\n            position: absolute;\n            bottom: 0;\n            width: 100%;\n            background-color: #183d4d;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Virtual Memory Concept</h1>\n        <h2>Observe the Allocation and Paging Process</h2>\n    </header>\n    <div class=\"canvas-container\">\n        <canvas id=\"memoryCanvas\" width=\"800\" height=\"400\"></canvas>\n    </div>\n    <div class=\"controls\">\n        <button id=\"startAnimation\">Start Animation</button>\n    </div>\n    <footer>\n        <p>&copy; 2023 Virtual Memory Visualization</p>\n    </footer>\n    <script>\n        const canvas = document.getElementById('memoryCanvas');\n        const ctx = canvas.getContext('2d');\n        let pages = [];\n        let animationInterval;\n\n        // Initialize pages\n        for(let i = 0; i < 8; i++) {\n            pages.push({ id: i + 1, loaded: false });\n        }\n\n        function drawMemory() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            ctx.fillStyle = '#1f3d48';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n            const pageWidth = canvas.width / pages.length;\n            pages.forEach((page, index) => {\n                if (page.loaded) {\n                    ctx.fillStyle = '#00bcd4';\n                    ctx.fillRect(index * pageWidth, 0, pageWidth, canvas.height);\n                    ctx.fillStyle = '#ffffff';\n                    ctx.font = '20px Arial';\n                    ctx.fillText(`Page ${page.id}`, index * pageWidth + pageWidth / 3, canvas.height / 2);\n                } else {\n                    ctx.fillStyle = '#4e4e4e';\n                    ctx.fillRect(index * pageWidth, 0, pageWidth, canvas.height);\n                    ctx.fillStyle = '#cccccc';\n                    ctx.fillText(`Page ${page.id}`, index * pageWidth + pageWidth / 3, canvas.height / 2);\n                }\n            });\n        }\n\n        function animatePages() {\n            let currentPage = 0;\n            animationInterval = setInterval(() => {\n                if (currentPage < pages.length) {\n                    pages[currentPage].loaded = true;\n                    currentPage++;\n                } else {\n                    clearInterval(animationInterval);\n                }\n                drawMemory();\n            }, 1000);\n        }\n\n        document.getElementById('startAnimation').addEventListener('click', () => {\n            pages.forEach(page => page.loaded = false); // Reset pages\n            animatePages();\n        });\n\n        drawMemory(); // Initial drawing\n    </script>\n</body>\n</html>"
