  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Mutex Interactive Explorer</title>\n<style>\n  body { font-family: monospace, monospace; background: white; color: black; margin: 1em; }\n  button, input[type=number], input[type=text], select { margin: 0.2em 0; }\n  #log { white-space: pre-wrap; border: 1px solid black; height: 200px; overflow-y: scroll; padding: 0.2em; margin-top: 1em; }\n  fieldset { margin-bottom: 1em; }\n  legend { font-weight: bold; }\n</style>\n</head>\n<body>\n\n<h1>Mutex Interactive Explorer</h1>\n\n<p>This interactive tool simulates multiple threads contending for one or more mutexes (locks) with various behaviors. You can create threads, create mutexes, let threads lock/unlock, try to lock, attempt timeouts, queue policies, and see detailed state transitions.</p>\n\n<fieldset>\n  <legend>Create Mutex</legend>\n  <label for=\"mutexNameCreate\">Mutex Name (unique): </label>\n  <input type=\"text\" id=\"mutexNameCreate\" aria-label=\"Mutex Name for creation\" />\n  <button id=\"btnCreateMutex\">Create Mutex</button>\n</fieldset>\n\n<fieldset>\n  <legend>Create Thread</legend>\n  <label for=\"threadNameCreate\">Thread Name (unique): </label>\n  <input type=\"text\" id=\"threadNameCreate\" aria-label=\"Thread Name for creation\" />\n  <button id=\"btnCreateThread\">Create Thread</button>\n</fieldset>\n\n<fieldset>\n  <legend>Threads and Mutexes Status</legend>\n  <button id=\"btnShowStatus\">Show Current Status</button>\n  <pre id=\"statusOutput\" style=\"border:1px solid black; padding:5px; height:180px; overflow-y:scroll;\"></pre>\n</fieldset>\n\n<fieldset>\n  <legend>Simulate Thread Actions on Mutex</legend>\n\n  <label for=\"selectThread\">Select Thread:</label>\n  <select id=\"selectThread\" aria-label=\"Select Thread\"></select><br />\n\n  <label for=\"selectMutex\">Select Mutex:</label>\n  <select id=\"selectMutex\" aria-label=\"Select Mutex\"></select><br />\n\n  <label for=\"actionSelect\">Action:</label>\n  <select id=\"actionSelect\" aria-label=\"Select Action on Mutex\">\n    <option value=\"lock\">Lock (blocking)</option>\n    <option value=\"tryLock\">Try Lock (non-blocking)</option>\n    <option value=\"unlock\">Unlock</option>\n  </select><br />\n  \n  <label for=\"timeoutInput\">Timeout (ms, for lock with timeout; 0 = infinite):</label>\n  <input type=\"number\" id=\"timeoutInput\" min=\"0\" value=\"0\" aria-label=\"Timeout in milliseconds for lock action\" /><br/>\n  \n  <label for=\"priorityInput\">Thread Priority (integer, higher = more priority):</label>\n  <input type=\"number\" id=\"priorityInput\" min=\"-1000\" max=\"1000\" value=\"0\" aria-label=\"Thread priority number\" /><br/>\n  \n  <button id=\"btnPerformAction\">Perform Action</button>\n</fieldset>\n\n<fieldset>\n  <legend>Global Controls</legend>\n  <button id=\"btnReset\">Reset All (clear mutexes and threads)</button><br />\n  <button id=\"btnAdvanceTime\">Advance Simulated Time by 100ms</button> (Triggers timeout attempts)\n  <button id=\"btnAdvanceCustomTime\">Advance Custom Time (ms):</button>\n  <input type=\"number\" id=\"customTimeAdvance\" min=\"1\" value=\"100\" aria-label=\"Custom time advance in ms\" />\n  <button id=\"btnAdvanceCustomTimeSubmit\">Advance</button>\n</fieldset>\n\n<fieldset>\n  <legend>Log / Events</legend>\n  <div id=\"log\"></div>\n  <button id=\"btnClearLog\">Clear Log</button>\n</fieldset>\n\n<script>\n(() => {\n  // Data Model\n\n  // Mutexes:\n  //  { name: string\n  //    lockedBy: threadName|null,\n  //    queue: [ {threadName, timestamp, timeoutMs, priority, timerExpired} ],\n  //    lockCount: number // for recursive lock demonstration\n  //  }\n  //\n  // Threads:\n  //   { name: string,\n  //     priority: number,\n  //     holding: Set<mutexName>,\n  //     blockedOn: mutexName|null,\n  //     state: \"running\"|\"blocked\"|\"waiting\"\n  //   }\n  //\n  // Time:\n  //   Simulated timestamp in ms.\n\n  let state = {\n    mutexes: {},\n    threads: {},\n    time: 0\n  };\n\n  // Log system\n  const logDiv = document.getElementById('log');\n  function log(msg){\n    const now = state.time.toString().padStart(6,' ') + \"ms\";\n    logDiv.textContent += \"[\" + now + \"] \" + msg + \"\\n\";\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n  function clearLog(){\n    logDiv.textContent = \"\";\n  }\n\n  // UI Elements\n  const mutexNameCreateInput = document.getElementById('mutexNameCreate');\n  const btnCreateMutex = document.getElementById('btnCreateMutex');\n\n  const threadNameCreateInput = document.getElementById('threadNameCreate');\n  const btnCreateThread = document.getElementById('btnCreateThread');\n\n  const selectThread = document.getElementById('selectThread');\n  const selectMutex = document.getElementById('selectMutex');\n  const actionSelect = document.getElementById('actionSelect');\n  const timeoutInput = document.getElementById('timeoutInput');\n  const priorityInput = document.getElementById('priorityInput');\n\n  const btnPerformAction = document.getElementById('btnPerformAction');\n\n  const btnShowStatus = document.getElementById('btnShowStatus');\n  const statusOutput = document.getElementById('statusOutput');\n\n  const btnReset = document.getElementById('btnReset');\n\n  const btnAdvanceTime = document.getElementById('btnAdvanceTime');\n  const btnAdvanceCustomTimeSubmit = document.getElementById('btnAdvanceCustomTimeSubmit');\n  const customTimeAdvanceInput = document.getElementById('customTimeAdvance');\n\n  const btnClearLog = document.getElementById('btnClearLog');\n\n  // Utility Functions\n\n  function updateThreadSelect(){\n    while(selectThread.options.length) selectThread.remove(0);\n    Object.keys(state.threads).forEach(tname => {\n      const o = document.createElement('option');\n      o.value = tname;\n      o.text = tname;\n      selectThread.appendChild(o);\n    });\n  }\n  function updateMutexSelect(){\n    while(selectMutex.options.length) selectMutex.remove(0);\n    Object.keys(state.mutexes).forEach(mname => {\n      const o = document.createElement('option');\n      o.value = mname;\n      o.text = mname;\n      selectMutex.appendChild(o);\n    });\n  }\n\n  function threadExists(name){\n    return !!state.threads[name];\n  }\n  function mutexExists(name){\n    return !!state.mutexes[name];\n  }\n\n  // Add Mutex\n  btnCreateMutex.onclick = () => {\n    const name = mutexNameCreateInput.value.trim();\n    if(!name){\n      alert(\"Mutex name cannot be empty.\");\n      return;\n    }\n    if(mutexExists(name)){\n      alert(\"Mutex with that name already exists.\");\n      return;\n    }\n    state.mutexes[name] = {\n      name,\n      lockedBy: null,\n      queue: [],\n      lockCount: 0 // for future recursive lock support\n    };\n    log(`Mutex '${name}' created.`);\n    mutexNameCreateInput.value = \"\";\n    updateMutexSelect();\n  };\n\n  // Add Thread\n  btnCreateThread.onclick = () => {\n    const name = threadNameCreateInput.value.trim();\n    if(!name){\n      alert(\"Thread name cannot be empty.\");\n      return;\n    }\n    if(threadExists(name)){\n      alert(\"Thread with that name already exists.\");\n      return;\n    }\n    state.threads[name] = {\n      name,\n      priority: 0,\n      holding: new Set(),\n      blockedOn: null,\n      state: \"running\"\n    };\n    log(`Thread '${name}' created.`);\n    threadNameCreateInput.value = \"\";\n    updateThreadSelect();\n  };\n\n  // Show Status\n  btnShowStatus.onclick = () => {\n    let out = `Simulated Time: ${state.time} ms\\n\\n=== Mutexes ===\\n`;\n    for(const mname in state.mutexes){\n      const m = state.mutexes[mname];\n      out += `Mutex '${mname}':\\n`;\n      if(m.lockedBy)\n        out += `  Locked By: ${m.lockedBy} (lock count: ${m.lockCount})\\n`;\n      else\n        out += `  Free\\n`;\n      out += `  Queue (${m.queue.length} waiting):\\n`;\n      m.queue.forEach((req,i) => {\n        out += `   [${i}] Thread '${req.threadName}', priority=${req.priority}, timeoutMs=${req.timeoutMs}, waited=${state.time - req.timestamp}ms\\n`;\n      });\n    }\n    out += `\\n=== Threads ===\\n`;\n    for(const tname in state.threads){\n      const t = state.threads[tname];\n      out += `Thread '${tname}':\\n`;\n      out += `  State: ${t.state}\\n`;\n      out += `  Priority: ${t.priority}\\n`;\n      out += `  Holding locks: ${Array.from(t.holding).join(\", \") || \"(none)\"}\\n`;\n      out += `  Blocked on mutex: ${t.blockedOn || \"(none)\"}\\n`;\n    }\n    statusOutput.textContent = out;\n  };\n\n  // Core Mutex Locking Simulation\n\n  // Lock action for thread :\n  // Options:\n  // lock(timeout=0 = infinite) => thread blocks if busy, else lock gained immediately\n  // tryLock: if free -> lock gained else fail immediately\n  // unlock: must be holding to unlock\n  //\n  // Note:\n  // Implements priority queuing: higher priority thread gets priority to acquire lock.\n  // When unlocking, next in queue (priority order) gets lock.\n  // Timeouts remove thread from queue if timed out.\n  //\n  // We also implement recursive locks for the same thread (lockCount to track).\n\n  function performLock(threadName, mutexName, timeoutMs, priority){\n    /*\n    -> If mutex is free, lock granted instantly\n    -> If already locked by same thread, increase lockCount (recursive lock)\n    -> If locked by another thread:\n       a) If timeout 0 (infinite), block thread until unlock\n       b) If timeout > 0, wait up to timeout\n    */\n    const thread = state.threads[threadName];\n    const mutex = state.mutexes[mutexName];\n\n    if(!thread || !mutex){\n      log(`ERROR: Invalid thread or mutex for locking.`);\n      return;\n    }\n    if(thread.state === \"blocked\"){\n      log(`Thread '${threadName}' is blocked and cannot initiate lock.`);\n      return;\n    }\n\n    // Update thread priority in data structure for queue use\n    thread.priority = priority;\n\n    if(mutex.lockedBy === null){\n      // free mutex\n      mutex.lockedBy = threadName;\n      mutex.lockCount = 1;\n      thread.holding.add(mutexName);\n      thread.state = \"running\";\n      thread.blockedOn = null;\n      log(`Thread '${threadName}' acquired lock '${mutexName}' immediately.`);\n    } else if(mutex.lockedBy === threadName){\n      // recursive lock\n      mutex.lockCount++;\n      thread.state = \"running\";\n      log(`Thread '${threadName}' recursively locked '${mutexName}'. Lock count is now ${mutex.lockCount}.`);\n    } else {\n      // locked by another thread; must queue and block if timeout > 0 or infinite (0)\n      const timestamp = state.time;\n      // Check if \"tryLock\" with timeout=0 means non-blocking\n      if(timeoutMs === 0){\n        // infinite wait, block thread and enqueue\n        mutex.queue.push({\n          threadName,\n          timestamp,\n          timeoutMs,\n          priority,\n          timerExpired: false\n        });\n        // sort queue by priority (desc), then by timestamp asc\n        mutex.queue.sort((a,b) => {\n          if(b.priority !== a.priority) return b.priority - a.priority;\n          return a.timestamp - b.timestamp;\n        });\n        thread.state = \"blocked\";\n        thread.blockedOn = mutexName;\n        log(`Thread '${threadName}' blocked on mutex '${mutexName}' indefinitely (no timeout). Added to wait queue.`);\n      } else {\n        // timeout > 0 => wait\n        mutex.queue.push({\n          threadName,\n          timestamp,\n          timeoutMs,\n          priority,\n          timerExpired: false\n        });\n        mutex.queue.sort((a,b) => {\n          if(b.priority !== a.priority) return b.priority - a.priority;\n          return a.timestamp - b.timestamp;\n        });\n        thread.state = \"blocked\";\n        thread.blockedOn = mutexName;\n        log(`Thread '${threadName}' blocked on mutex '${mutexName}' with timeout ${timeoutMs} ms. Added to wait queue.`);\n      }\n    }\n  }\n\n  function performTryLock(threadName, mutexName, priority){\n    const thread = state.threads[threadName];\n    const mutex = state.mutexes[mutexName];\n\n    if(!thread || !mutex){\n      log(`ERROR: Invalid thread or mutex for tryLock.`);\n      return;\n    }\n    if(thread.state === \"blocked\"){\n      log(`Thread '${threadName}' is currently blocked and cannot perform tryLock.`);\n      return;\n    }\n    thread.priority = priority;\n\n    if(mutex.lockedBy === null){\n      mutex.lockedBy = threadName;\n      mutex.lockCount = 1;\n      thread.holding.add(mutexName);\n      thread.state = \"running\";\n      thread.blockedOn = null;\n      log(`Thread '${threadName}' successfully performed tryLock on '${mutexName}'. Lock acquired.`);\n    } else if(mutex.lockedBy === threadName){\n      // recursive lock as above\n      mutex.lockCount++;\n      log(`Thread '${threadName}' recursively tryLock'ed '${mutexName}'. Lock count now ${mutex.lockCount}.`);\n    } else {\n      log(`Thread '${threadName}' tryLock on '${mutexName}' failed immediately (locked by '${mutex.lockedBy}').`);\n    }\n  }\n\n  function performUnlock(threadName, mutexName){\n    const thread = state.threads[threadName];\n    const mutex = state.mutexes[mutexName];\n    if(!thread || !mutex){\n      log(`ERROR: Invalid thread or mutex for unlock.`);\n      return;\n    }\n    if(mutex.lockedBy !== threadName){\n      log(`Thread '${threadName}' cannot unlock '${mutexName}' because it does not hold the lock.`);\n      return;\n    }\n    // Decrement lockCount for recursive lock support\n    mutex.lockCount--;\n    if(mutex.lockCount > 0){\n      log(`Thread '${threadName}' released one recursive lock on '${mutexName}'. Remaining lock count: ${mutex.lockCount}.`);\n      return;\n    }\n    // Fully unlock mutex\n    mutex.lockedBy = null;\n    mutex.lockCount = 0;\n    thread.holding.delete(mutexName);\n    log(`Thread '${threadName}' fully unlocked mutex '${mutexName}'.`);\n    // Wake next thread in queue by priority order\n    if(mutex.queue.length > 0){\n      // Remove any timed out threads before selecting next\n      cleanupExpiredWaitingThreads(mutexName);\n\n      if(mutex.queue.length === 0){\n        log(`No waiting threads to wake up for mutex '${mutexName}'.`);\n        return;\n      }\n\n      // Sort queue by priority desc, timestamp asc\n      mutex.queue.sort((a,b) => {\n        if(b.priority !== a.priority) return b.priority - a.priority;\n        return a.timestamp - b.timestamp;\n      });\n      const next = mutex.queue.shift();\n      const nextThread = state.threads[next.threadName];\n      // Grant lock to next thread\n      mutex.lockedBy = next.threadName;\n      mutex.lockCount = 1;\n      nextThread.holding.add(mutexName);\n      nextThread.state = \"running\";\n      nextThread.blockedOn = null;\n      log(`Thread '${next.threadName}' acquired lock '${mutexName}' from wait queue.`);\n\n      // Re-validate queue because some threads might have timed out meanwhile\n      cleanupExpiredWaitingThreads(mutexName);\n    }\n  }\n\n  function cleanupExpiredWaitingThreads(mutexName){\n    const mutex = state.mutexes[mutexName];\n    if(!mutex) return;\n\n    let changed = false;\n    const now = state.time;\n    const stillWaiting = [];\n\n    for(const req of mutex.queue){\n      if(req.timeoutMs === 0){\n        // infinite wait, does not expire\n        stillWaiting.push(req);\n        continue;\n      }\n      const waited = now - req.timestamp;\n      if(waited >= req.timeoutMs){\n        // timeout expired\n        const thread = state.threads[req.threadName];\n        if(thread && thread.blockedOn === mutexName && thread.state === \"blocked\"){\n          thread.state = \"running\";\n          thread.blockedOn = null;\n          log(`Timeout expired: Thread '${req.threadName}' removed from wait queue on mutex '${mutexName}'.`);\n        }\n        changed = true;\n      } else {\n        stillWaiting.push(req);\n      }\n    }\n    if(changed){\n      mutex.queue = stillWaiting;\n    }\n  }\n\n  function advanceTime(ms){\n    if(ms <= 0) return;\n    for(let i=0; i<ms; i++){\n      state.time++;\n    }\n    // After time advances check timeouts on all mutexes\n    for(const mname in state.mutexes){\n      cleanupExpiredWaitingThreads(mname);\n    }\n  }\n\n  // Perform action button logic\n  btnPerformAction.onclick = () => {\n    const threadName = selectThread.value;\n    const mutexName = selectMutex.value;\n    const action = actionSelect.value;\n    const timeoutMsRaw = timeoutInput.value;\n    const priorityRaw = priorityInput.value;\n    if(!threadName || !mutexName || !action){\n      alert(\"Please select a thread, mutex, and action.\");\n      return;\n    }\n    const timeoutMs = Number(timeoutMsRaw);\n    if(isNaN(timeoutMs) || timeoutMs < 0){\n      alert(\"Timeout must be a number >= 0.\");\n      return;\n    }\n    const priority = Number(priorityRaw);\n    if(isNaN(priority)){\n      alert(\"Priority must be a number.\");\n      return;\n    }\n    if(!threadExists(threadName)){\n      alert(`Thread '${threadName}' no longer exists.`);\n      updateThreadSelect();\n      return;\n    }\n    if(!mutexExists(mutexName)){\n      alert(`Mutex '${mutexName}' no longer exists.`);\n      updateMutexSelect();\n      return;\n    }\n\n    if(action === \"lock\"){\n      performLock(threadName, mutexName, timeoutMs, priority);\n    } else if(action === \"tryLock\"){\n      performTryLock(threadName, mutexName, priority);\n    } else if(action === \"unlock\"){\n      performUnlock(threadName, mutexName);\n    }\n  };\n\n  btnReset.onclick = () => {\n    if(!confirm(\"Are you sure you want to reset and clear all mutexes and threads?\")){\n      return;\n    }\n    state.mutexes = {};\n    state.threads = {};\n    state.time = 0;\n    updateMutexSelect();\n    updateThreadSelect();\n    statusOutput.textContent = \"\";\n    clearLog();\n  };\n\n  btnAdvanceTime.onclick = () => {\n    advanceTime(100);\n    log(\"Advanced simulated time by 100 ms.\");\n  };\n\n  btnAdvanceCustomTimeSubmit.onclick = () => {\n    const ms = Number(customTimeAdvanceInput.value);\n    if(isNaN(ms) || ms < 1){\n      alert(\"Enter a valid positive number of milliseconds.\");\n      return;\n    }\n    advanceTime(ms);\n    log(`Advanced simulated time by ${ms} ms.`);\n  };\n\n  btnClearLog.onclick = () => {\n    clearLog();\n  };\n\n  // Initialization\n\n  // For demonstration, pre-create some mutexes and threads for user to interact with:\n\n  function seedInitialData(){\n    // Create a Mutex \"mutexA\"\n    state.mutexes[\"mutexA\"] = {name:\"mutexA\", lockedBy:null, queue:[], lockCount:0};\n    // Create Threads \"T1\", \"T2\", \"T3\"\n    state.threads[\"T1\"] = {name:\"T1\", priority:0, holding:new Set(), blockedOn:null, state:\"running\"};\n    state.threads[\"T2\"] = {name:\"T2\", priority:0, holding:new Set(), blockedOn:null, state:\"running\"};\n    state.threads[\"T3\"] = {name:\"T3\", priority:0, holding:new Set(), blockedOn:null, state:\"running\"};\n\n    updateMutexSelect();\n    updateThreadSelect();\n    log(\"Seeded initial mutex 'mutexA' and threads 'T1', 'T2', 'T3'.\");\n  }\n\n  seedInitialData();\n\n})();\n</script>\n\n</body>\n</html>"
