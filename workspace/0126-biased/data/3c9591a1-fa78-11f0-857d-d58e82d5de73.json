    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Stack Visualization – Elegant Concept Demo</title>\n<style>\n  /* Reset & base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin:0; \n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Fira Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n    display: flex; \n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    color: #e1e7f0;\n    overflow: hidden;\n    user-select:none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  h1 {\n    font-weight: 800;\n    font-size: 2.8rem;\n    margin-bottom: 0.2em;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    color: #a0cdfc;\n    text-shadow: 0 0 8px #77aaff99;\n  }\n  p.subheading {\n    margin-top: 0;\n    margin-bottom: 2.4rem;\n    color: #b6c8d9cc;\n    font-style: italic;\n    font-weight: 500;\n    font-size: 1.1rem;\n    letter-spacing: 0.07em;\n  }\n\n  /* Container for stack and controls */\n  .container {\n    width: 320px;\n    max-width: 90vw;\n    background: rgba(28, 40, 51, 0.65);\n    border-radius: 24px;\n    box-shadow:\n      0 6px 18px rgba(20,45,75,0.35),\n      inset 0 0 30px 6px rgba(30, 100, 210, 0.15);\n    padding: 2rem 2rem 3rem 2rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* Stack area */\n  .stack {\n    position: relative;\n    width: 240px;\n    min-height: 300px;\n    background: linear-gradient(145deg, #203a43, #2c5364);\n    border-radius: 1.4rem;\n    box-shadow:\n      inset 0 0 30px 4px #1b2c3e,\n      0 8px 24px rgba(15, 30, 50, 0.9);\n    overflow: visible;\n    padding-top: 20px;\n    perspective: 900px;\n  }\n\n  /* Stack blocks */\n  .block {\n    position: absolute;\n    left: 50%;\n    width: 200px;\n    height: 48px;\n    margin-left: -100px;\n    background: linear-gradient(135deg, #3268f1, #4a97ff);\n    border-radius: 12px;\n    box-shadow:\n      0 8px 15px #1f43d4cc,\n      inset 0 -4px 8px #635fe1c9,\n      inset 0 4px 10px #aacbffcc;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 700;\n    font-size: 1.22rem;\n    letter-spacing: 0.06em;\n    color: #e9edff;\n    text-shadow: 0 1px 3px rgba(0,0,0,0.4);\n    backdrop-filter: blur(6px);\n    transition:\n      transform 0.65s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.4s ease;\n    user-select:none;\n  }\n\n  /* Dynamic stacking: each block up by 58px + slight 3d tilt */\n  .block:nth-child(1) {\n    bottom: 20px;\n    transform-origin: bottom center;\n    transform: translateY(0) rotateX(0deg);\n    z-index: 10;\n  }\n  .block:nth-child(2) {\n    bottom: 78px;\n    transform-origin: bottom center;\n    transform: translateY(0) rotateX(4deg);\n    z-index: 9;\n    filter: drop-shadow(0 2px 1px #1a2c50cc);\n  }\n  .block:nth-child(3) {\n    bottom: 136px;\n    transform-origin: bottom center;\n    transform: translateY(0) rotateX(8deg);\n    z-index: 8;\n    filter: drop-shadow(0 4px 2px #162649bb);\n  }\n  .block:nth-child(4) {\n    bottom: 194px;\n    transform-origin: bottom center;\n    transform: translateY(0) rotateX(12deg);\n    z-index: 7;\n    filter: drop-shadow(0 6px 3px #12203b99);\n  }\n  .block:nth-child(5) {\n    bottom: 252px;\n    transform-origin: bottom center;\n    transform: translateY(0) rotateX(16deg);\n    z-index: 6;\n    filter: drop-shadow(0 8px 4px #0e1a3188);\n  }\n\n  /* Glow accent behind stack for depth */\n  .stack::before {\n    content: \"\";\n    position: absolute;\n    bottom: 12px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 180px;\n    height: 20px;\n    background: radial-gradient(ellipse at center, rgba(70,140,255,0.4), transparent 70%);\n    filter: blur(12px);\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  /* Buttons container */\n  .controls {\n    margin-top: 2.4rem;\n    display: flex;\n    gap: 1.4rem;\n  }\n\n  /* Elegant buttons */\n  button {\n    position: relative;\n    background:\n      linear-gradient(145deg, #274eaa, #416de9);\n    border: none;\n    border-radius: 12px;\n    color: #ddefff;\n    font-weight: 600;\n    font-family: 'Fira Sans', sans-serif;\n    font-size: 1.1rem;\n    padding: 0.72rem 1.6rem;\n    cursor: pointer;\n    box-shadow:\n      0 5px 12px #3e6de520,\n      inset 0 -3px 6px #224d9e;\n    transition:\n      box-shadow 0.25s ease,\n      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),\n      color 0.25s ease;\n    user-select:none;\n  }\n  button:focus {\n    outline: none;\n    box-shadow:\n      0 0 16px 3px #79a5ffcc,\n      inset 0 -3px 6px #224d9e;\n  }\n  button:hover {\n    color: #c9e0ff;\n    box-shadow:\n      0 10px 22px #5d89ff55,\n      inset 0 -4px 8px #335ecf;\n    transform: translateY(-1.8px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow:\n      0 4px 8px #3160d6cc,\n      inset 0 -3px 6px #2b4fcc;\n  }\n\n  /* Subtle info note */\n  .info-note {\n    margin-top: 1.8rem;\n    font-size: 0.9rem;\n    color: #9bb2ceaa;\n    letter-spacing: 0.05em;\n    font-style: italic;\n    text-align: center;\n    max-width: 280px;\n    user-select:none;\n  }\n\n  /* Hide scrollbar if any */\n  ::-webkit-scrollbar {\n    display: none;\n  }\n</style>\n</head>\n<body>\n  <h1>STACK</h1>\n  <p class=\"subheading\">Visualizing the Last-In, First-Out Data Structure</p>\n\n  <div class=\"container\" aria-label=\"Stack demonstration container\">\n\n    <div class=\"stack\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\" role=\"list\" id=\"stack\" tabindex=\"0\">\n      <!-- Stack blocks will be dynamically rendered by JS -->\n    </div>\n\n    <div class=\"controls\" role=\"group\" aria-label=\"Stack controls\">\n      <button id=\"push\" aria-describedby=\"infoPush\" title=\"Push a new element onto the stack\">Push</button>\n      <button id=\"pop\" aria-describedby=\"infoPop\" title=\"Pop the top element off the stack\">Pop</button>\n    </div>\n    <div class=\"info-note\" aria-live=\"polite\" id=\"infoPush\">Click 'Push' to add a new block to the stack.</div>\n  </div>\n\n<script>\n  (() => {\n    // Minimal stack logic to show effect visually with nice smooth animations.\n    const stackEl = document.getElementById('stack');\n    const pushBtn = document.getElementById('push');\n    const popBtn = document.getElementById('pop');\n\n    // Maximum blocks to display to keep aesthetics\n    const MAX_BLOCKS = 5;\n\n    // Keep a simple array representing stack data\n    const stackData = [];\n\n    // Generate a subtle progressive palette for blocks - blue shades with neon glow\n    // Base color: #3268f1, we brighten for newest blocks\n    function blockColor(idx) {\n      // idx 0 is bottom block, newest at top (max idx length-1)\n      const max = MAX_BLOCKS - 1;\n      const lightness = 70 - idx*7; // from 70% to ~38%\n      const saturation = 85 - idx*10;\n      return `hsl(215, ${saturation}%, ${lightness}%)`;\n    }\n\n    // Create block element with styling & text\n    function createBlock(label, idx) {\n      const block = document.createElement('div');\n      block.className = 'block';\n      block.textContent = label;\n      block.style.background = `linear-gradient(135deg, ${blockColor(idx)}, hsl(215, 80%, 45%))`;\n      block.style.boxShadow = `\n        0 8px 15px ${hslToRGBA(215, 0.7 - idx*0.1, 0.8)},\n        inset 0 -4px 8px ${hslToRGBA(215, 0.5 - idx*0.1, 0.5)},\n        inset 0 4px 10px ${hslToRGBA(215, 0.2, 1)}\n      `;\n      block.setAttribute('role', 'listitem');\n      block.setAttribute('aria-label', `Stack block ${label}`);\n      return block;\n    }\n\n    // Convert hsl hue and alpha to rgba string for shadows\n    // alpha from 0 to 1\n    function hslToRGBA(h, alpha, lightness) {\n      // h saturation lightness to rgb \n      // simple, fixed saturation 90%\n      const s = 90;\n      const l = lightness*100;\n      return `hsla(${h}, ${s}%, ${l}%, ${alpha})`;\n    }\n\n    // Render the entire stack\n    function renderStack() {\n      // Clear current\n      stackEl.innerHTML = '';\n      for (let i = 0; i < stackData.length; i++) {\n        // bottom zero index, top last index\n        const idx = stackData.length - 1 - i;\n        const block = createBlock(stackData[i], idx);\n        stackEl.appendChild(block);\n      }\n    }\n\n    // Animate pushing new element\n    function pushElement() {\n      if (stackData.length >= MAX_BLOCKS) return;\n      const newVal = `#${stackData.length + 1}`;\n      stackData.push(newVal);\n      animateStackChange('push');\n    }\n\n    // Animate popping top element\n    function popElement() {\n      if (stackData.length === 0) return;\n      animateStackChange('pop');\n    }\n\n    // Animate stack modification\n    function animateStackChange(action) {\n      if(action === 'push'){\n        // Create new block separately and animate from above down\n        const newVal = stackData[stackData.length - 1];\n        const newBlock = createBlock(newVal, 0);\n        newBlock.style.bottom = '320px';\n        newBlock.style.opacity = '0';\n        newBlock.style.transformOrigin = 'bottom center';\n        newBlock.style.transform = 'translateY(-40px) rotateX(12deg)';\n        stackEl.appendChild(newBlock);\n\n        // Animate fade & slide in\n        requestAnimationFrame(() => {\n          newBlock.style.transition = 'transform 0.8s cubic-bezier(0.4,0,0.2,1), opacity 0.6s ease-out';\n          newBlock.style.opacity = '1';\n          newBlock.style.bottom = '20px';\n          newBlock.style.transform = 'translateY(0) rotateX(0deg)';\n        });\n\n        // After animation, re-render stack to reset z-index and order\n        setTimeout(() => {\n          renderStack();\n        }, 850);\n      }\n      else if(action === 'pop'){\n        // Animate the top block sliding up and fading\n        const topBlock = stackEl.querySelector('.block');\n        if(!topBlock) return;\n\n        topBlock.style.transition = 'transform 0.7s cubic-bezier(0.4,0,0.2,1), opacity 0.5s ease-out';\n        topBlock.style.transformOrigin = 'bottom center';\n        topBlock.style.transform = 'translateY(-80px) rotateX(-12deg)';\n        topBlock.style.opacity = '0';\n\n        setTimeout(() => {\n          stackData.pop();\n          renderStack();\n        }, 700);\n      }\n    }\n\n    // Initial sample stack with 3 elements\n    for(let i=1; i<=3; i++) stackData.push(`#${i}`);\n    renderStack();\n\n    pushBtn.addEventListener('click', () => {\n      pushElement();\n      speakInfo('Pushed ' + (stackData[stackData.length-1] || 'element'));\n    });\n    popBtn.addEventListener('click', () => {\n      if(stackData.length === 0) {\n        speakInfo('Stack is empty, cannot pop');\n        return;\n      }\n      speakInfo('Popped ' + stackData[stackData.length-1]);\n      popElement();\n    });\n\n    // Accessibility: spoken updates\n    const infoNote = document.querySelector('.info-note');\n    function speakInfo(text){\n      // Quick text update for screen readers\n      infoNote.textContent = text;\n    }\n\n  })();\n</script>\n</body>\n</html>"
