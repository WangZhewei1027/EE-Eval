    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Nearest Neighbors</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        #knn-container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #knn-container h2 {\n            margin-top: 0;\n        }\n        #knn-container input {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        #knn-container button {\n            width: 100%;\n            padding: 10px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #knn-container button:hover {\n            background-color: #3e8e41;\n        }\n        #knn-table {\n            width: 100%;\n            border-collapse: collapse;\n        }\n        #knn-table th, #knn-table td {\n            border: 1px solid #ddd;\n            padding: 10px;\n            text-align: left;\n        }\n        #knn-table th {\n            background-color: #f0f0f0;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"knn-container\">\n        <h2>K-Nearest Neighbors</h2>\n        <form id=\"knn-form\">\n            <label for=\"feature1\">Feature 1:</label>\n            <input type=\"text\" id=\"feature1\" name=\"feature1\" value=\"Feature 1\">\n            <br>\n            <label for=\"feature2\">Feature 2:</label>\n            <input type=\"text\" id=\"feature2\" name=\"feature2\" value=\"Feature 2\">\n            <br>\n            <label for=\"feature3\">Feature 3:</label>\n            <input type=\"text\" id=\"feature3\" name=\"feature3\" value=\"Feature 3\">\n            <br>\n            <button id=\"knn-button\">KNN</button>\n            <button id=\"knn-clear\">Clear</button>\n            <table id=\"knn-table\">\n                <thead>\n                    <tr>\n                        <th>Feature</th>\n                        <th>Value</th>\n                    </tr>\n                </thead>\n                <tbody id=\"knn-data\">\n                </tbody>\n            </table>\n        </form>\n        <div id=\"knn-output\"></div>\n    </div>\n\n    <script>\n        const knnButton = document.getElementById('knn-button');\n        const knnClearButton = document.getElementById('knn-clear');\n        const knnDataContainer = document.getElementById('knn-data');\n        const knnOutputContainer = document.getElementById('knn-output');\n        const feature1Input = document.getElementById('feature1');\n        const feature2Input = document.getElementById('feature2');\n        const feature3Input = document.getElementById('feature3');\n        const knnButtonInput = document.getElementById('knn-button');\n        const knnClearButtonInput = document.getElementById('knn-clear');\n\n        const knnData = [];\n\n        knnButton.addEventListener('click', () => {\n            const feature1 = feature1Input.value;\n            const feature2 = feature2Input.value;\n            const feature3 = feature3Input.value;\n\n            knnDataContainer.innerHTML = '';\n\n            knnData.push({\n                feature1,\n                feature2,\n                feature3,\n                value: Math.random() * 100\n            });\n\n            knnData.sort((a, b) => b.value - a.value);\n\n            const table = document.createElement('table');\n            knnData.forEach((data, index) => {\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${data.feature1}</td>\n                    <td>${data.feature2}</td>\n                    <td>${data.feature3}</td>\n                    <td>${data.value}</td>\n                `;\n                table.appendChild(row);\n            });\n            knnDataContainer.appendChild(table);\n\n            knnClearButtonInput.addEventListener('click', () => {\n                knnData = [];\n                knnDataContainer.innerHTML = '';\n            });\n        });\n\n        knnClearButton.addEventListener('click', () => {\n            knnData = [];\n            knnDataContainer.innerHTML = '';\n        });\n\n        knnButton.addEventListener('click', () => {\n            const feature1 = feature1Input.value;\n            const feature2 = feature2Input.value;\n            const feature3 = feature3Input.value;\n\n            knnDataContainer.innerHTML = '';\n\n            knnData.push({\n                feature1,\n                feature2,\n                feature3,\n                value: Math.random() * 100\n            });\n\n            knnData.sort((a, b) => b.value - a.value);\n\n            const table = document.createElement('table');\n            knnData.forEach((data, index) => {\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${data.feature1}</td>\n                    <td>${data.feature2}</td>\n                    <td>${data.feature3}</td>\n                    <td>${data.value}</td>\n                `;\n                table.appendChild(row);\n            });\n            knnDataContainer.appendChild(table);\n\n            knnButtonInput.value = 'KNN';\n        });\n\n        knnButtonInput.addEventListener('input', () => {\n            knnButton.textContent = knnButtonInput.value;\n        });\n    </script>\n</body>\n</html>"
