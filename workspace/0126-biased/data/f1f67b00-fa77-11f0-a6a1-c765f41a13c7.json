    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Topological Sort — Visual Demonstration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #081224;\n      --bg-2: #0b1b2b;\n      --accent-1: #7ee0d6;\n      --accent-2: #7a8cff;\n      --muted: #9bb0d8;\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.02);\n      --success: #6ee7b7;\n      --danger: #ff8aa3;\n      --card-radius: 20px;\n    }\n\n    /* Reset & base */\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,var(--bg-1) 0%, var(--bg-2) 70%);\n      color: #e6eefb;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Ambient decorative blobs */\n    .ambient{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n    }\n    .blob{\n      position:absolute;\n      filter: blur(60px) saturate(120%);\n      opacity:0.45;\n      transform: translate3d(0,0,0);\n      mix-blend-mode: screen;\n    }\n    .blob.one{width:520px;height:520px;background:radial-gradient(circle at 30% 30%, #5ef6d3 0%, rgba(122,140,255,0.8) 50%, transparent 70%); left:-160px; top:-100px; animation: drift1 18s ease-in-out infinite alternate;}\n    .blob.two{width:420px;height:420px;background:radial-gradient(circle at 70% 70%, #7a8cff 0%, rgba(126,224,214,0.75) 40%, transparent 65%); right:-120px; bottom:-140px; animation: drift2 22s ease-in-out infinite alternate;}\n    .blob.three{width:260px;height:260px;background:radial-gradient(circle at 50% 50%, rgba(255,138,163,0.9) 0%, rgba(122,140,255,0.25) 50%, transparent 80%); left:10%; bottom:20%; filter: blur(80px) saturate(140%); opacity:0.18; animation: drift3 24s ease-in-out infinite alternate;}\n\n    @keyframes drift1{from{transform:translateY(0) translateX(0)} to{transform:translateY(30px) translateX(20px)}}\n    @keyframes drift2{from{transform:translateY(0) translateX(0)} to{transform:translateY(-30px) translateX(-40px)}}\n    @keyframes drift3{from{transform:translateY(0) translateX(0)} to{transform:translateY(40px) translateX(10px)}}\n\n    /* App layout */\n    .wrap{\n      position:relative;\n      width:1200px;\n      max-width:95%;\n      margin:48px auto;\n      z-index:1;\n      display:grid;\n      grid-template-columns: 1fr 380px;\n      gap:28px;\n      align-items:stretch;\n    }\n\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border-radius: var(--card-radius);\n      padding:28px;\n      box-shadow: 0 10px 40px rgba(3,8,19,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(8px) saturate(120%);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n\n    /* Left: visualization */\n    .visual{\n      min-height:620px;\n      position:relative;\n      overflow:hidden;\n    }\n\n    .visual-header{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      margin-bottom:14px;\n    }\n    .title{\n      display:flex;\n      gap:14px;\n      align-items:center;\n    }\n    .logo{\n      width:56px;height:56px;border-radius:14px;\n      background: linear-gradient(135deg,var(--accent-1), var(--accent-2));\n      display:flex;align-items:center;justify-content:center;\n      box-shadow: 0 8px 30px rgba(122,140,255,0.18);\n      font-family: 'Playfair Display', serif;\n      font-weight:700;\n      color:#04243a;\n      font-size:18px;\n      transform:rotate(-8deg);\n    }\n    h1{\n      margin:0;\n      font-family: 'Playfair Display', serif;\n      font-size:20px;\n      letter-spacing: -0.02em;\n      color: #f6fbff;\n    }\n    p.lead{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    /* SVG area styling */\n    .stage{\n      width:100%;\n      height:560px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(7,16,30,0.45), rgba(5,11,20,0.6));\n      border:1px solid rgba(255,255,255,0.02);\n      position:relative;\n      overflow:hidden;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:18px;\n    }\n\n    svg{\n      width:100%;\n      height:100%;\n      overflow:visible;\n    }\n\n    /* Nodes */\n    .node{\n      cursor:default;\n      transition: transform 450ms cubic-bezier(.2,.9,.3,1), opacity 350ms ease, filter 350ms ease;\n      transform-origin:center center;\n    }\n    .circle{\n      fill: linear-gradient(180deg,#11354b,#0f2432);\n      fill:#071627;\n      stroke: url(#gradStroke);\n      stroke-width:2.2;\n      filter: drop-shadow(0 6px 18px rgba(7,18,34,0.6));\n      transition: fill 320ms ease, stroke-width 240ms ease, r 240ms ease;\n    }\n    .label{\n      font-weight:600;\n      font-size:13px;\n      fill: #eaf6ff;\n      pointer-events:none;\n      text-anchor:middle;\n      dominant-baseline:central;\n      font-family:Inter, system-ui, sans-serif;\n    }\n    .sub{\n      font-size:10px;\n      fill:var(--muted);\n      opacity:0.9;\n    }\n\n    .node .halo{\n      fill: none;\n      stroke: rgba(126,224,214,0.18);\n      stroke-width:14;\n      stroke-linecap:round;\n      filter: blur(10px);\n      opacity:0;\n      transition: opacity 240ms ease;\n    }\n\n    .node.highlight .halo{opacity:1; transform-origin:center center;}\n    .node.highlight .circle{\n      stroke-width:3.6;\n      fill: linear-gradient(180deg, rgba(126,224,214,0.06), rgba(122,140,255,0.03));\n      filter: drop-shadow(0 10px 30px rgba(126,224,214,0.12));\n      transform: scale(1.06);\n    }\n\n    .node.removed{\n      opacity:0.12;\n      transform: scale(0.94);\n      filter: blur(0.4px);\n    }\n\n    /* Edges */\n    .edge{\n      fill:none;\n      stroke: rgba(255,255,255,0.09);\n      stroke-width:2.2;\n      transition: stroke 280ms ease, opacity 280ms ease, stroke-dashoffset 450ms ease;\n      stroke-linecap:round;\n    }\n    .edge.from-removed{ stroke: rgba(126,224,214,0.06); opacity:0.45; stroke-dasharray:6 6;}\n    .edge.faded{ opacity:0.06; stroke: rgba(255,255,255,0.03);}\n    .edge.pulse{\n      stroke: url(#edgeGrad);\n      stroke-width:3.6;\n      filter: drop-shadow(0 6px 18px rgba(122,140,255,0.12));\n      animation: pulse 900ms ease;\n    }\n    @keyframes pulse{\n      from{ stroke-dashoffset:20 }\n      to{ stroke-dashoffset:0 }\n    }\n\n    /* Right panel */\n    .panel{\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      min-height:620px;\n    }\n    .panel h2{\n      margin:0;\n      font-family: 'Playfair Display', serif;\n      font-size:20px;\n      color:#fff;\n    }\n    .meta{\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:6px;\n    }\n\n    .btn{\n      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      border-radius:12px;\n      padding:10px 14px;\n      color: #e8f8ff;\n      font-weight:600;\n      border: 1px solid rgba(255,255,255,0.04);\n      cursor:pointer;\n      transition: transform 180ms ease, box-shadow 200ms ease, opacity 180ms ease;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      font-size:14px;\n      box-shadow: 0 8px 30px rgba(2,8,20,0.45);\n    }\n    .btn:active{ transform: translateY(1px) scale(0.997) }\n    .btn.play{\n      background: linear-gradient(90deg, rgba(126,224,214,0.12), rgba(122,140,255,0.12));\n      border: 1px solid rgba(126,224,214,0.12);\n      color: #dffaf4;\n    }\n\n    .legend{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      color:var(--muted);\n      font-size:13px;\n      margin-top:6px;\n    }\n\n    .chips{\n      display:flex;\n      gap:10px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n\n    .result-strip{\n      margin-top:auto;\n      padding:12px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.02);\n      min-height:86px;\n      display:flex;\n      align-items:center;\n      gap:12px;\n      flex-wrap:wrap;\n    }\n\n    .chip{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:10px;\n      padding:8px 12px;\n      font-weight:700;\n      color:#e9fbff;\n      font-size:13px;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 6px 18px rgba(3,11,25,0.45);\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      min-width:54px;\n      justify-content:center;\n      opacity:0;\n      transform: translateY(8px) scale(0.98);\n      transition: opacity 320ms cubic-bezier(.2,.9,.3,1), transform 320ms cubic-bezier(.2,.9,.3,1);\n    }\n\n    .chip.visible{ opacity:1; transform:translateY(0) scale(1); }\n\n    .chip-num{\n      width:28px;height:28px;border-radius:8px;\n      display:inline-flex;align-items:center;justify-content:center;\n      background: linear-gradient(180deg,var(--accent-1), var(--accent-2));\n      color:#012c36;font-weight:800;\n      font-size:13px;\n      box-shadow: 0 8px 22px rgba(122,140,255,0.14);\n    }\n\n    .explain{\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.55;\n    }\n\n    /* footer small */\n    .small{\n      font-size:12px;color:var(--muted);\n      margin-top:8px;\n    }\n\n    /* responsive */\n    @media (max-width:980px){\n      .wrap{ grid-template-columns: 1fr; padding: 16px; gap:18px;}\n      .panel{ order:2 }\n      .visual{ order:1 }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <div class=\"blob one\"></div>\n    <div class=\"blob two\"></div>\n    <div class=\"blob three\"></div>\n  </div>\n\n  <div class=\"wrap\" role=\"main\" aria-label=\"Topological Sort visualization\">\n    <div class=\"card visual\">\n      <div class=\"visual-header\">\n        <div class=\"title\">\n          <div class=\"logo\">TS</div>\n          <div>\n            <h1>Topological Sort</h1>\n            <p class=\"lead\">Order the tasks of a directed acyclic graph so each edge u → v has u before v.</p>\n          </div>\n        </div>\n        <div class=\"meta\">DAG illustration • Smooth step-by-step reveal</div>\n      </div>\n\n      <div class=\"stage\" id=\"stage\">\n        <!-- SVG Graph -->\n        <svg id=\"svg\" viewBox=\"0 0 1200 560\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Graph visualization\">\n          <defs>\n            <linearGradient id=\"gradStroke\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7ee0d6\"/>\n              <stop offset=\"1\" stop-color=\"#7a8cff\"/>\n            </linearGradient>\n            <linearGradient id=\"edgeGrad\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7ee0d6\" stop-opacity=\"0.95\"/>\n              <stop offset=\"1\" stop-color=\"#7a8cff\" stop-opacity=\"0.95\"/>\n            </linearGradient>\n            <filter id=\"shadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feDropShadow dx=\"0\" dy=\"12\" stdDeviation=\"22\" flood-color=\"#071025\" flood-opacity=\"0.6\"/>\n            </filter>\n          </defs>\n\n          <!-- Edges will be generated dynamically -->\n          <!-- Nodes definition -->\n          <!-- Layout coordinates -->\n          <!-- Coordinates chosen to create visually pleasing layout -->\n          <!-- Node groups -->\n          <g id=\"edges\"></g>\n\n          <g id=\"nodes\">\n            <!-- Node A -->\n            <g class=\"node\" id=\"node-A\" transform=\"translate(160,120)\" data-id=\"A\" aria-label=\"Node A\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">A</text>\n            </g>\n\n            <g class=\"node\" id=\"node-B\" transform=\"translate(160,420)\" data-id=\"B\" aria-label=\"Node B\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">B</text>\n            </g>\n\n            <g class=\"node\" id=\"node-C\" transform=\"translate(420,80)\" data-id=\"C\" aria-label=\"Node C\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"-2\">C</text>\n            </g>\n\n            <g class=\"node\" id=\"node-D\" transform=\"translate(420,260)\" data-id=\"D\" aria-label=\"Node D\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">D</text>\n            </g>\n\n            <g class=\"node\" id=\"node-E\" transform=\"translate(700,140)\" data-id=\"E\" aria-label=\"Node E\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">E</text>\n            </g>\n\n            <g class=\"node\" id=\"node-F\" transform=\"translate(700,340)\" data-id=\"F\" aria-label=\"Node F\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">F</text>\n            </g>\n\n            <g class=\"node\" id=\"node-G\" transform=\"translate(980,180)\" data-id=\"G\" aria-label=\"Node G\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">G</text>\n            </g>\n\n            <g class=\"node\" id=\"node-H\" transform=\"translate(980,380)\" data-id=\"H\" aria-label=\"Node H\" role=\"img\">\n              <circle class=\"halo\" r=\"44\"></circle>\n              <circle class=\"circle\" r=\"28\"></circle>\n              <text class=\"label\" y=\"0\">H</text>\n            </g>\n          </g>\n        </svg>\n\n        <!-- subtle timeline at bottom -->\n        <div style=\"position:absolute;left:18px;right:18px;bottom:18px;height:36px;display:flex;align-items:center;justify-content:center;pointer-events:none\">\n          <div style=\"width:90%;height:6px;border-radius:6px;background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\">\n            <div id=\"progress\" style=\"height:6px;width:0%;border-radius:6px;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));transition:width 450ms ease;\"></div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <aside class=\"card panel\" aria-label=\"Information panel\">\n      <div>\n        <h2>How it works</h2>\n        <div class=\"meta\">Kahn's algorithm (step-by-step)</div>\n\n        <div class=\"controls\" style=\"margin-top:12px\">\n          <button class=\"btn play\" id=\"playBtn\" aria-pressed=\"false\" title=\"Play the topological sort\">\n            ▶ Animate\n          </button>\n          <div class=\"legend\" style=\"margin-left:6px\">\n            <div style=\"display:flex;gap:8px;align-items:center\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"6\" fill=\"#7ee0d6\" opacity=\"0.14\"/><circle cx=\"12\" cy=\"12\" r=\"3\" fill=\"#7ee0d6\"/></svg>\n              <div style=\"font-size:13px;color:var(--muted)\">Zero indegree set</div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px\" class=\"explain\" id=\"explain\">\n          Click \"Animate\" to watch Kahn's algorithm gradually reveal a valid topological order. Nodes with zero incoming edges are highlighted, then removed, and their outgoing edges are relaxed. The order appears on the strip below.\n        </div>\n\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <div class=\"meta\">Graph (example)</div>\n        <div style=\"margin-top:8px;color:var(--muted);font-size:13px\">\n          A → C, A → D, B → D, C → E, D → F, E → F, E → G, F → H, G → H\n        </div>\n      </div>\n\n      <div style=\"margin-top:18px\" class=\"result-strip\" aria-live=\"polite\" aria-atomic=\"true\">\n        <div style=\"flex:0 0 10%; color:var(--muted);font-size:13px\">Order</div>\n        <div id=\"resultChips\" class=\"chips\" style=\"flex:1\"></div>\n      </div>\n\n      <div class=\"small\">This demonstration focuses on clarity and aesthetics. Interaction is intentionally minimal: press play to observe the algorithm.</div>\n    </aside>\n  </div>\n\n  <script>\n    // Graph structure\n    const nodes = ['A','B','C','D','E','F','G','H'];\n    const edges = [\n      ['A','C'],\n      ['A','D'],\n      ['B','D'],\n      ['C','E'],\n      ['D','F'],\n      ['E','F'],\n      ['E','G'],\n      ['F','H'],\n      ['G','H']\n    ];\n\n    // Map node to element & coords\n    const nodeElems = {};\n    nodes.forEach(id=>{\n      nodeElems[id] = document.querySelector(`#node-${id}`);\n    });\n\n    // Draw edges as smooth cubic bezier paths between center points\n    const svg = document.getElementById('svg');\n    const edgesGroup = document.getElementById('edges');\n\n    function getNodeCenter(id){\n      const g = nodeElems[id];\n      const transform = g.getAttribute('transform'); // translate(x,y)\n      const match = /translate\\(([-\\d.]+),\\s*([-\\d.]+)\\)/.exec(transform);\n      if(match){\n        return {x: parseFloat(match[1]), y: parseFloat(match[2])};\n      }\n      return {x:0,y:0};\n    }\n\n    // Create edge elements\n    const edgeElems = [];\n    edges.forEach((e, idx)=>{\n      const [s,t] = e;\n      const start = getNodeCenter(s);\n      const end = getNodeCenter(t);\n\n      // compute simple cubic bezier control points for pleasing curves\n      const dx = (end.x - start.x);\n      const dy = (end.y - start.y);\n      const cx1 = start.x + dx*0.30;\n      const cy1 = start.y - 40 + dy*0.10;\n      const cx2 = start.x + dx*0.70;\n      const cy2 = end.y + 40 - dy*0.10;\n\n      const pathStr = `M ${start.x} ${start.y} C ${cx1} ${cy1}, ${cx2} ${cy2}, ${end.x} ${end.y}`;\n      const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n      path.setAttribute('d', pathStr);\n      path.setAttribute('class','edge');\n      path.setAttribute('data-source', s);\n      path.setAttribute('data-target', t);\n      path.setAttribute('id', `edge-${s}-${t}`);\n      path.setAttribute('stroke-linejoin','round');\n      // dashed animation prep\n      path.style.strokeDasharray = 0;\n      edgesGroup.appendChild(path);\n      edgeElems.push(path);\n    });\n\n    // Utility to get incoming counts\n    function computeIndegrees(){\n      const indeg = {};\n      nodes.forEach(n => indeg[n] = 0);\n      edges.forEach(([u,v])=>{\n        indeg[v]++;\n      });\n      return indeg;\n    }\n\n    // Kahn's algorithm but we also capture steps where multiple zero indegree nodes exist concurrently\n    function kahnSteps(){\n      const indeg = computeIndegrees();\n      const adj = {};\n      nodes.forEach(n => adj[n] = []);\n      edges.forEach(([u,v])=> adj[u].push(v));\n\n      const steps = [];\n      const q = [];\n      Object.keys(indeg).forEach(n => {\n        if(indeg[n] === 0) q.push(n);\n      });\n      // deterministic order: sort letters at each step\n      while(q.length){\n        q.sort(); // keep reproducible order, but will highlight them together\n        const cur = q.splice(0,q.length); // take all current zeros\n        steps.push(cur.slice());\n        // remove them\n        cur.forEach(u=>{\n          adj[u].forEach(v=>{\n            indeg[v]--;\n            if(indeg[v] === 0){\n              q.push(v);\n            }\n          });\n        });\n      }\n\n      // if nodes remain with indegree > 0, graph had cycles (not in this demo)\n      return steps;\n    }\n\n    const steps = kahnSteps(); // e.g. [['A','B'],['C','D'],['E'],['F','G'],['H']]\n    // Prepare result chip container\n    const resultContainer = document.getElementById('resultChips');\n\n    // Create placeholders for chips to animate later\n    const chipMap = {}; // id -> chip element\n    let orderCounter = 0;\n\n    function createChip(nodeId, order){\n      const chip = document.createElement('div');\n      chip.className = 'chip';\n      const num = document.createElement('div');\n      num.className = 'chip-num';\n      num.textContent = order;\n      const txt = document.createElement('div');\n      txt.textContent = nodeId;\n      chip.appendChild(num);\n      chip.appendChild(txt);\n      resultContainer.appendChild(chip);\n      // force layout then animate in\n      requestAnimationFrame(()=> {\n        chip.classList.add('visible');\n      });\n      return chip;\n    }\n\n    // Animation sequence\n    let animating = false;\n    const playBtn = document.getElementById('playBtn');\n    const explain = document.getElementById('explain');\n    const progressBar = document.getElementById('progress');\n\n    function resetVisual(){\n      // reset nodes\n      nodes.forEach(id=>{\n        const el = nodeElems[id];\n        el.classList.remove('highlight','removed');\n        el.style.transition = 'none';\n        el.style.opacity = 1;\n      });\n      // reset edges\n      edgeElems.forEach(path=>{\n        path.classList.remove('from-removed','pulse','faded');\n        path.style.strokeDasharray = '';\n        path.style.strokeDashoffset = '';\n      });\n      // clear result chips\n      resultContainer.innerHTML = '';\n      orderCounter = 0;\n      progressBar.style.width = '0%';\n      explain.textContent = 'Click \"Animate\" to watch Kahn\\'s algorithm gradually reveal a valid topological order. Nodes with zero incoming edges are highlighted, then removed, and their outgoing edges are relaxed. The order appears on the strip below.';\n    }\n\n    resetVisual();\n\n    function highlightSet(set){\n      set.forEach(id=>{\n        nodeElems[id].classList.add('highlight');\n      });\n      // pulse outgoing edges\n      edges.forEach(([u,v])=>{\n        if(set.includes(u)){\n          const path = document.getElementById(`edge-${u}-${v}`);\n          path.classList.add('pulse');\n          // set dash effect for pulse\n          path.style.strokeDasharray = '8 6';\n          path.style.strokeDashoffset = '18';\n        }\n      });\n    }\n\n    function removeSet(set, stepIndex, totalSteps){\n      // fade edges from these nodes, mark nodes removed, push chips\n      set.forEach(id=>{\n        // mark node removed\n        const g = nodeElems[id];\n        g.classList.remove('highlight');\n        g.classList.add('removed');\n        // set chip\n        orderCounter++;\n        const chip = createChip(id, orderCounter);\n        chipMap[id] = chip;\n      });\n\n      // Update edges: outgoing edges fade or transform to 'from-removed'\n      edges.forEach(([u,v])=>{\n        if(set.includes(u)){\n          const path = document.getElementById(`edge-${u}-${v}`);\n          path.classList.remove('pulse');\n          path.classList.add('from-removed');\n          // animate to faded after a short delay\n          setTimeout(()=> {\n            path.classList.add('faded');\n            path.style.opacity = '0.08';\n          }, 500);\n        }\n      });\n\n      // update progress bar\n      const progressPct = Math.round(( ( (stepIndex+1) / totalSteps) * 100));\n      progressBar.style.width = progressPct + '%';\n    }\n\n    // main orchestrator\n    async function runAnimation(){\n      if(animating) return;\n      animating = true;\n      playBtn.setAttribute('aria-pressed','true');\n      playBtn.textContent = '⟳ Replay';\n      explain.textContent = 'Animating…';\n\n      // compute steps again (fresh)\n      const localSteps = kahnSteps();\n      const totalSteps = localSteps.length;\n      resetVisual(); // ensure clean\n      // small delay for dramatic effect\n      await wait(400);\n\n      for(let i=0;i<localSteps.length;i++){\n        const set = localSteps[i];\n        // highlight\n        highlightSet(set);\n        explain.textContent = `Step ${i+1}: Highlighting ${set.join(', ')} (zero indegree)`;\n        await wait(900);\n\n        // remove\n        removeSet(set, i, totalSteps);\n        explain.textContent = `Removed ${set.join(', ')}; relaxing outgoing edges`;\n        await wait(750);\n      }\n\n      explain.textContent = 'Done — a valid topological order has been revealed.';\n      animating = false;\n    }\n\n    function wait(ms){ return new Promise(res=>setTimeout(res, ms)); }\n\n    // Attach play button\n    playBtn.addEventListener('click', async ()=>{\n      if(animating) return;\n      await runAnimation();\n    });\n\n    // Small UX: press space to play (non-mandatory), keep interaction minimal\n    window.addEventListener('keydown', (e)=>{\n      if(e.code === 'Space'){\n        e.preventDefault();\n        if(!animating) runAnimation();\n      }\n    });\n\n    // Initial gentle entrance animation\n    window.addEventListener('load', ()=>{\n      // cascade appear nodes\n      nodes.forEach((id,i)=>{\n        const g = nodeElems[id];\n        g.style.opacity = 0;\n        g.style.transform = 'translateY(8px) scale(0.98)';\n        setTimeout(()=> {\n          g.style.transition = 'opacity 540ms cubic-bezier(.2,.9,.3,1), transform 540ms cubic-bezier(.2,.9,.3,1)';\n          g.style.opacity = 1;\n          g.style.transform = 'translateY(0) scale(1)';\n        }, 120 + i*60);\n      });\n\n      // edges fade in slightly later\n      edgeElems.forEach((p,i)=>{\n        p.style.opacity = 0;\n        setTimeout(()=> {\n          p.style.transition = 'opacity 640ms ease, stroke 640ms ease';\n          p.style.opacity = 1;\n        }, 300 + i*40);\n      });\n\n      // button subtle attention\n      setTimeout(()=> {\n        playBtn.animate([\n          { transform: 'translateY(0) scale(1)', boxShadow: '0 8px 30px rgba(2,8,20,0.45)' },\n          { transform: 'translateY(-4px) scale(1.01)', boxShadow: '0 20px 40px rgba(122,140,255,0.12)' },\n          { transform: 'translateY(0) scale(1)', boxShadow: '0 8px 30px rgba(2,8,20,0.45)' }\n        ], { duration: 1200, easing: 'cubic-bezier(.2,.9,.3,1)', iterations: 1 });\n      }, 900);\n    });\n\n  </script>\n</body>\n</html>"
