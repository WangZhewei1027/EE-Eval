  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Binary Search Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  textarea, input[type=number], input[type=text] {\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  button {\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  .panel {\n    margin-bottom: 1em;\n  }\n  label {\n    display: inline-block;\n    min-width: 110px;\n  }\n  pre {\n    border: 1px solid black;\n    padding: 0.5em;\n    white-space: pre-wrap;\n    max-height: 200px;\n    overflow-y: auto;\n  }\n  table {\n    border-collapse: collapse;\n  }\n  td {\n    border: 1px solid black;\n    padding: 0.2em 0.4em;\n    text-align: center;\n    min-width: 25px;\n  }\n  td.pointer {\n    border-color: black;\n    font-weight: bold;\n  }\n  td.low, td.high {\n    border-style: double;\n  }\n  td.mid {\n    border-style: dotted;\n  }\n  td.found {\n    background: none;\n    font-weight: bold;\n  }\n</style>\n</head>\n<body>\n\n<h1>Binary Search Interactive Explorer</h1>\n\n<div class=\"panel\">\n  <label for=\"arrayInput\">Array elements (sorted, comma separated):</label><br />\n  <textarea id=\"arrayInput\" rows=\"3\" cols=\"80\" spellcheck=\"false\" aria-label=\"Array input\"></textarea><br />\n  <button id=\"loadArrayBtn\">Load Array</button>\n</div>\n\n<div class=\"panel\">\n  <label for=\"targetInput\">Target value:</label>\n  <input type=\"text\" id=\"targetInput\" aria-label=\"Target value input\" />\n  <button id=\"setTargetBtn\">Set Target</button>\n</div>\n\n<div class=\"panel\">\n  <label for=\"stepDelayInput\">Step delay (ms auto-step):</label>\n  <input type=\"number\" id=\"stepDelayInput\" min=\"100\" max=\"5000\" step=\"100\" value=\"1000\" aria-label=\"Automatic step delay milliseconds\" />\n  <button id=\"autoStepToggleBtn\" disabled>Start Auto-Step</button>\n  <button id=\"stepForwardBtn\" disabled>Step Forward</button>\n  <button id=\"stepBackwardBtn\" disabled>Step Backward</button>\n  <button id=\"resetSearchBtn\" disabled>Reset Search</button>\n</div>\n\n<div class=\"panel\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions\">\n  <label>Binary Search State:</label><br/>\n  <pre id=\"stateOutput\">(Load array and set target to start)</pre>\n</div>\n\n<div class=\"panel\">\n  <label>Array visualization:</label><br />\n  <div id=\"arrayVis\" role=\"list\" aria-label=\"Array elements visualization\"></div>\n</div>\n\n<div class=\"panel\">\n  <label for=\"manualCompareInput\">Manual compare current middle with target:</label>\n  <select id=\"manualCompareInput\" aria-label=\"Manual comparison\">\n    <option value=\"unset\">-- Select --</option>\n    <option value=\"less\">Middle value less than target (&lt;)</option>\n    <option value=\"equal\">Middle value equals target (=)</option>\n    <option value=\"greater\">Middle value greater than target (&gt;)</option>\n  </select>\n  <button id=\"manualCompareBtn\" disabled>Submit Comparison</button>\n</div>\n\n<hr/>\n\n<div class=\"panel\">\n  <button id=\"exploreAllBtn\" disabled>Explore All Search Paths (Exhaustive)</button>\n  <button id=\"showSummaryBtn\" disabled>Show Search Summary</button>\n</div>\n\n<div class=\"panel\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions\">\n  <label>Search Logs and Exploration Output:</label><br />\n  <pre id=\"logOutput\" style=\"max-height:300px; overflow-y:auto;\"></pre>\n</div>\n\n<script>\n(() => {\n  // State and helper functions for binary search interactive exploration\n  const arrayInput = document.getElementById('arrayInput');\n  const loadArrayBtn = document.getElementById('loadArrayBtn');\n  const targetInput = document.getElementById('targetInput');\n  const setTargetBtn = document.getElementById('setTargetBtn');\n  const stepDelayInput = document.getElementById('stepDelayInput');\n  const autoStepToggleBtn = document.getElementById('autoStepToggleBtn');\n  const stepForwardBtn = document.getElementById('stepForwardBtn');\n  const stepBackwardBtn = document.getElementById('stepBackwardBtn');\n  const resetSearchBtn = document.getElementById('resetSearchBtn');\n  const stateOutput = document.getElementById('stateOutput');\n  const arrayVis = document.getElementById('arrayVis');\n  const manualCompareInput = document.getElementById('manualCompareInput');\n  const manualCompareBtn = document.getElementById('manualCompareBtn');\n  const exploreAllBtn = document.getElementById('exploreAllBtn');\n  const showSummaryBtn = document.getElementById('showSummaryBtn');\n  const logOutput = document.getElementById('logOutput');\n\n  // Internal state\n  let array = [];\n  let target = null;\n  let sorted = false;\n\n  // Search session state: logs each step {low, high, mid, midVal, comparison} to reconstruct\n  let searchSteps = [];\n\n  // Current step index for walkthrough\n  let currentStepIndex = -1;\n\n  // Auto-step timer and running flag\n  let autoStepTimer = null;\n  let autoStepRunning = false;\n\n  // EXACT binary search algorithm simulation state and control\n  // For extra user control, we do NOT assume automatic comparison,\n  // instead user feeds comparison result manually.\n  // That means user controls the logic branch with manual input.\n\n  // Current low, high for binary search\n  // We will reset these on new start\n  let low = 0;\n  let high = -1;\n  // mid always recomputed: mid = Math.floor((low+high)/2)\n\n  // Flag indicating search ended (found or empty range)\n  let searchEnded = false;\n\n  // Result storage for the index found or -1\n  let foundIndex = -1;\n\n  // -------------------\n  // Utility Functions\n  // -------------------\n\n  // Display the array visually, marking low, mid, high indexes, highlight found index.\n  function renderArrayVis(lowIndex, midIndex, highIndex, foundIdx) {\n    if (array.length === 0) {\n      arrayVis.textContent = '(Array empty)';\n      return;\n    }\n    const fragment = document.createDocumentFragment();\n\n    // Create a table to show array visually with labels\n    // 3 rows: elements, pointers labels below, highlights in styles with borders\n    const tbl = document.createElement('table');\n    tbl.setAttribute('role', 'list');\n\n    // First row: elements with possible highlights\n    const trEls = document.createElement('tr');\n    for (let i = 0; i < array.length; i++) {\n      const td = document.createElement('td');\n      td.textContent = array[i];\n      if (i === lowIndex) td.classList.add('low');\n      if (i === midIndex) td.classList.add('mid');\n      if (i === highIndex) td.classList.add('high');\n      if (i === foundIdx) td.classList.add('found');\n      trEls.appendChild(td);\n    }\n    tbl.appendChild(trEls);\n\n    // Second row: pointer labels below the elements\n    const trLabels = document.createElement('tr');\n    for (let i = 0; i < array.length; i++) {\n      const td = document.createElement('td');\n      const labels = [];\n      if (i === lowIndex) labels.push('low');\n      if (i === midIndex) labels.push('mid');\n      if (i === highIndex) labels.push('high');\n      if (labels.length > 0) {\n        td.textContent = labels.join(', ');\n        td.classList.add('pointer');\n      } else {\n        td.textContent = '';\n      }\n      trLabels.appendChild(td);\n    }\n    tbl.appendChild(trLabels);\n\n    fragment.appendChild(tbl);\n    while (arrayVis.firstChild) arrayVis.removeChild(arrayVis.firstChild);\n    arrayVis.appendChild(fragment);\n  }\n\n  // Output current binary search state and progress info\n  function updateStateOutput() {\n    if (array.length === 0) {\n      stateOutput.textContent = '(Load array to start)';\n      return;\n    }\n    if (target === null) {\n      stateOutput.textContent = 'Target not set.';\n      return;\n    }\n    if (searchEnded) {\n      if (foundIndex >= 0) {\n        stateOutput.textContent = `Search ended: target ${target} found at index ${foundIndex}.`;\n      } else {\n        stateOutput.textContent = `Search ended: target ${target} NOT found in array.`;\n      }\n      renderArrayVis(low, -1, high, foundIndex);\n      return;\n    }\n    if (low > high) {\n      stateOutput.textContent = `Range invalid (low > high), target not found: ${target}.`;\n      renderArrayVis(low, -1, high, -1);\n      return;\n    }\n    let mid = Math.floor((low + high) / 2);\n    stateOutput.textContent =\n`Current search state for target ${target}:\nLow index: ${low}, value: ${array[low]}\nHigh index: ${high}, value: ${array[high]}\nMid index: ${mid}, value: ${array[mid]}\n\nPlease compare middle value to target and submit comparison below.`;\n    renderArrayVis(low, mid, high, -1);\n  }\n\n  // Log messages with timestamps and scrolling\n  function addLog(message) {\n    const timestamp = new Date().toLocaleTimeString();\n    logOutput.textContent += `[${timestamp}] ${message}\\n`;\n    logOutput.scrollTop = logOutput.scrollHeight;\n  }\n\n  // Parse and validate input array\n  function parseInputArray(text) {\n    // Accept integers or floats, allow whitespace, ignore empty tokens\n    // Reject if not sorted ascending\n    let parts = text.split(',').map(s => s.trim()).filter(s => s.length > 0);\n    if (parts.length === 0) return null;\n    let nums = [];\n    for (const p of parts) {\n      if (!/^(-?\\d+(\\.\\d+)?|\\.\\d+)$/.test(p)) {\n        return null;\n      }\n      const n = Number(p);\n      if (Number.isNaN(n)) {\n        return null;\n      }\n      nums.push(n);\n    }\n    // Check sorted ascending (allow equal elements)\n    for (let i = 1; i < nums.length; i++) {\n      if (nums[i] < nums[i-1]) {\n        return null;\n      }\n    }\n    return nums;\n  }\n\n  // Reset all state to initial after new array loaded or target set\n  function resetSearchSession() {\n    low = 0;\n    high = array.length - 1;\n    searchEnded = false;\n    foundIndex = -1;\n    searchSteps = [];\n    currentStepIndex = -1;\n    autoStepRunning = false;\n    clearInterval(autoStepTimer);\n    autoStepTimer = null;\n    manualCompareInput.value = 'unset';\n    manualCompareBtn.disabled = false;\n    autoStepToggleBtn.disabled = false;\n    stepForwardBtn.disabled = false;\n    stepBackwardBtn.disabled = false;\n    resetSearchBtn.disabled = false;\n    exploreAllBtn.disabled = false;\n    showSummaryBtn.disabled = false;\n    updateStateOutput();\n    addLog(`Search session reset for target ${target}.`);\n  }\n\n  // Execute one step of binary search given a comparison result ('less', 'equal', 'greater')\n  // Returns true if continues and false if search ended\n  function stepBinarySearch(comparison) {\n    if (searchEnded) return false;\n    if (low > high) {\n      searchEnded = true;\n      foundIndex = -1;\n      addLog(`Search ended: target ${target} not found.`);\n      updateStateOutput();\n      return false;\n    }\n    let mid = Math.floor((low + high) / 2);\n    const midVal = array[mid];\n\n    searchSteps.push({\n      low, high, mid, midVal, comparison\n    });\n\n    addLog(`Step: low=${low} (${array[low]}), high=${high} (${array[high]}), mid=${mid} (${midVal}), comparison ${comparison}`);\n\n    if (comparison === 'equal') {\n      searchEnded = true;\n      foundIndex = mid;\n      addLog(`Target ${target} found at index ${mid}.`);\n      updateStateOutput();\n      return false;\n    }\n    else if (comparison === 'less') {\n      // midVal < target means target is right side -> low = mid+1\n      low = mid + 1;\n      if (low > high) {\n        searchEnded = true;\n        foundIndex = -1;\n        addLog(`Range exhausted, target ${target} not found.`);\n        updateStateOutput();\n        return false;\n      }\n    }\n    else if (comparison === 'greater') {\n      // midVal > target means target is left side -> high = mid-1\n      high = mid - 1;\n      if (low > high) {\n        searchEnded = true;\n        foundIndex = -1;\n        addLog(`Range exhausted, target ${target} not found.`);\n        updateStateOutput();\n        return false;\n      }\n    } else {\n      // invalid input; do nothing\n      addLog(`Invalid comparison value '${comparison}' received.`);\n      return false;\n    }\n    updateStateOutput();\n    return true;\n  }\n\n  // Step backward: pops last step and reverts low/high accordingly\n  function stepBinarySearchBackward() {\n    if (searchSteps.length === 0) {\n      addLog('No previous step to go back to.');\n      return;\n    }\n    if (searchEnded) {\n      searchEnded = false;\n      foundIndex = -1;\n    }\n\n    // Remove last step\n    searchSteps.pop();\n\n    // Recompute low/high from remaining steps, or set to start\n    if (searchSteps.length === 0) {\n      low = 0;\n      high = array.length -1;\n    } else {\n      const lastStep = searchSteps[searchSteps.length -1];\n      low = lastStep.low;\n      high = lastStep.high;\n      // Apply last step's comparison to determine next low/high for next step\n      let comp = lastStep.comparison;\n      let mid = lastStep.mid;\n      if (comp === 'equal') {\n        // We are stepping back from a found state => unset\n        searchEnded = false;\n        foundIndex = -1;\n      }\n      else if (comp === 'less') {\n        // previous step advanced low = mid+1\n        low = mid;\n        high = lastStep.high;\n      }\n      else if (comp === 'greater') {\n        // previous step set high=mid-1\n        low = lastStep.low;\n        high = mid;\n      }\n    }\n    updateStateOutput();\n    addLog('Stepped backward one step.');\n  }\n\n  // Auto-step toggle start/stop\n  function toggleAutoStep() {\n    if (!autoStepRunning) {\n      // Start auto-step process:\n      if (searchEnded) {\n        addLog('Search ended, cannot auto-step.');\n        return;\n      }\n      autoStepRunning = true;\n      autoStepToggleBtn.textContent = 'Stop Auto-Step';\n      manualCompareInput.disabled = true;\n      manualCompareBtn.disabled = true;\n      stepForwardBtn.disabled = true;\n      stepBackwardBtn.disabled = true;\n      resetSearchBtn.disabled = true;\n      exploreAllBtn.disabled = true;\n      showSummaryBtn.disabled = true;\n\n      addLog('Auto-step started: at each interval provide simulated compare prompt (user manual still required to input).');\n      // In this version, due to interactive manual input requirement, auto-step will pause at each step for user input.\n      // So auto-step here just repeatedly shows prompts but waits for manual input.\n      // For demo, auto-step disables buttons and auto-advances if user submits manual input quickly.\n\n      // Actually we can't auto advance without comparison input: how to implement?\n\n      // Simplify: auto-step repeatedly enables manual compare with a timer, user must input comparison to continue.\n\n      // So we do nothing here except enforcing timer to check if manualCompareInput is set and auto-advance if so.\n      autoStepTimer = setInterval(() => {\n        if (searchEnded) {\n          toggleAutoStep(); // stop timer\n          return;\n        }\n        if (manualCompareInput.value !== 'unset') {\n          const comp = manualCompareInput.value;\n          manualCompareInput.value = 'unset';\n          stepBinarySearch(comp);\n          if (searchEnded) {\n            toggleAutoStep();\n          }\n        }\n      }, Number(stepDelayInput.value) || 1000);\n\n    } else {\n      // Stop auto-step\n      autoStepRunning = false;\n      autoStepToggleBtn.textContent = 'Start Auto-Step';\n      manualCompareInput.disabled = false;\n      manualCompareBtn.disabled = false;\n      stepForwardBtn.disabled = false;\n      stepBackwardBtn.disabled = false;\n      resetSearchBtn.disabled = false;\n      exploreAllBtn.disabled = false;\n      showSummaryBtn.disabled = false;\n      clearInterval(autoStepTimer);\n      autoStepTimer = null;\n      addLog('Auto-step stopped.');\n    }\n  }\n\n  // Handle manual submit comparison button\n  function submitManualComparison() {\n    if (manualCompareInput.value === 'unset') {\n      addLog('No comparison selected, cannot proceed step.');\n      return;\n    }\n    if (!stepBinarySearch(manualCompareInput.value)) {\n      // search ended\n      manualCompareBtn.disabled = true;\n      manualCompareInput.disabled = true;\n      autoStepToggleBtn.disabled = true;\n      stepForwardBtn.disabled = true;\n    }\n    manualCompareInput.value = 'unset';\n  }\n\n  // Step forward in search by one (simulate user entering correct comparison automatically)\n  // Auto-generate correct comparison here for convenience to help exploration without manual user input every time\n  function autoStepForward() {\n    if (searchEnded) {\n      addLog('Search already ended, cannot step forward.');\n      return;\n    }\n    if (low > high) {\n      searchEnded = true;\n      foundIndex = -1;\n      updateStateOutput();\n      addLog('Range invalid, search ended not found.');\n      return;\n    }\n    let mid = Math.floor((low + high) / 2);\n    const midVal = array[mid];\n    let comp;\n    if (midVal < target) comp = 'less';\n    else if (midVal > target) comp = 'greater';\n    else comp = 'equal';\n    addLog(`Auto-step forward using comparison: middle value ${midVal} vs target ${target}: ${comp}`);\n    stepBinarySearch(comp);\n    if (searchEnded) {\n      manualCompareBtn.disabled = true;\n      manualCompareInput.disabled = true;\n      autoStepToggleBtn.disabled = true;\n      stepForwardBtn.disabled = true;\n    }\n  }\n\n  // Reset entire search, keep same array and target\n  function resetSearch() {\n    if (array.length === 0 || target === null) {\n      addLog('Cannot reset search: array or target not set.');\n      return;\n    }\n    resetSearchSession();\n  }\n\n  // Explore all possible search paths exhaustively\n  // This is a complex exploration that tries all valid compare branches at each step,\n  // builds a complete tree of searches states that might occur, displaying every path.\n  // Results: all sequences of low,high,mid,comparison steps ending with found or not found.\n\n  // To prevent UI freezing with very large arrays, cap max depth search\n  const MAX_PATHS = 10000; // max number of paths to explore before stopping\n  const MAX_DEPTH = 100; // cutoff depth\n\n  // Structure for path node state:\n  // {low, high, steps: [{low,high,mid,midVal,comparison},...]}\n  // Recursively explore left/right branches depending on comparison made\n  // For each node, try comparisions less, equal, greater (only equal ends search early)\n  // But possible comparisons constrained by real value relative to target:\n  // Since target is known, only legit comparison is the real one.\n  // However, this exploration will explore all hypothetical comparisons ignoring correctness,\n  // to simulate how binary search branches upon any input comparison.\n\n  // We support this \"deep exploration\" by exploring all possible compare choices at each step,\n  // even if comparison is nonsensical with respect to array value and target,\n  // to demonstrate concept of step-by-step binary search control flow.\n\n  // This is not a standard binary search but a conceptual exploration of all branches.\n\n  // We recursively build a tree and produce log summary.\n\n  // Node example:\n  // {low, high, steps: [...], ended: bool, foundIndex: int}\n\n  // Returns array of terminal nodes (search ended states)\n\n  function exploreAllPathsRecursive(node, pathsSoFar) {\n    if (pathsSoFar.length > MAX_PATHS) {\n      return null; // limit reached: abort exploration\n    }\n\n    const {low, high, steps} = node;\n    if (low > high) {\n      // Not found - end node\n      node.ended = true;\n      node.foundIndex = -1;\n      pathsSoFar.push(node);\n      return pathsSoFar;\n    }\n    if (steps.length >= MAX_DEPTH) {\n      node.ended = true;\n      node.foundIndex = -1;\n      pathsSoFar.push(node);\n      return pathsSoFar;\n    }\n\n    const mid = Math.floor((low + high) / 2);\n    const midVal = (mid >= 0 && mid < array.length) ? array[mid] : null;\n\n    // Branches for comparison: less, equal, greater\n    // Each creates a new node with updated low/high and added step\n\n    // 1) Equal branch - ends search found\n    const equalNode = {\n      low: low, high: high,\n      steps: steps.concat([{low,high,mid,midVal,comparison:'equal'}]),\n      ended: true,\n      foundIndex: mid\n    };\n    pathsSoFar.push(equalNode);\n\n    if (pathsSoFar.length > MAX_PATHS) return null;\n\n    // 2) Less branch: midVal < target => low = mid+1, else next step range shrinks from left\n    const lessNode = {\n      low: mid + 1, \n      high: high,\n      steps: steps.concat([{low,high,mid,midVal,comparison:'less'}]),\n      ended: false,\n      foundIndex: -1\n    };\n    let result = exploreAllPathsRecursive(lessNode, pathsSoFar);\n    if (result === null) return null;\n\n    // 3) Greater branch: midVal > target => high = mid -1, else next step range shrinks from right\n    const greaterNode = {\n      low: low,\n      high: mid -1,\n      steps: steps.concat([{low,high,mid,midVal,comparison:'greater'}]),\n      ended: false,\n      foundIndex: -1\n    };\n    result = exploreAllPathsRecursive(greaterNode, pathsSoFar);\n    if (result === null) return null;\n\n    return pathsSoFar;\n  }\n\n  // Start explore all paths\n  function exploreAllPaths() {\n    if (array.length === 0 || target === null) {\n      addLog('Cannot explore paths: array or target not set.');\n      return;\n    }\n    addLog('Starting exhaustive exploration of all binary search paths...');\n    exploreAllBtn.disabled = true;\n    showSummaryBtn.disabled = false;\n    let initialNode = {low:0, high: array.length-1, steps: [], ended:false, foundIndex:-1};\n    let allPaths = exploreAllPathsRecursive(initialNode, []);\n    if (allPaths === null) {\n      addLog(`Exploration aborted after reaching path limit (${MAX_PATHS}) or max depth (${MAX_DEPTH}).`);\n      searchExplorationResults = [];\n      exploreAllBtn.disabled = false;\n      return;\n    }\n    searchExplorationResults = allPaths;\n    addLog(`Exploration complete. Number of paths discovered: ${allPaths.length}.`);\n    exploreAllBtn.disabled = false;\n  }\n\n  // Global storage for exploration results array\n  let searchExplorationResults = [];\n\n  // Show summary of exploration results with counts and examples\n  function showExplorationSummary() {\n    if (!searchExplorationResults || searchExplorationResults.length === 0) {\n      addLog('No exploration results to show. Run exploration first.');\n      return;\n    }\n    let foundCount = 0;\n    let notFoundCount = 0;\n    for (const path of searchExplorationResults) {\n      if (path.foundIndex >= 0) foundCount++;\n      else notFoundCount++;\n    }\n    let out = '';\n    out += `EXPLORATION SUMMARY:\\nTotal paths: ${searchExplorationResults.length}\\nPaths where target found: ${foundCount}\\nPaths where not found: ${notFoundCount}\\n\\n`;\n    out += `EXAMPLES of found paths:\\n`;\n    let foundExampleCount = 0;\n    for (const path of searchExplorationResults) {\n      if (path.foundIndex >= 0) {\n        out += ` - Path length ${path.steps.length}, found at index ${path.foundIndex}\\n`;\n        if (foundExampleCount < 3) {\n          for (const step of path.steps) {\n            out += `   step: low=${step.low}, high=${step.high}, mid=${step.mid}, val=${step.midVal}, cmp=${step.comparison}\\n`;\n          }\n          foundExampleCount++;\n          out += '\\n';\n        }\n        if (foundExampleCount >= 3) break;\n      }\n    }\n    out += `EXAMPLES of not found paths:\\n`;\n    let notFoundExampleCount = 0;\n    for (const path of searchExplorationResults) {\n      if (path.foundIndex < 0) {\n        out += ` - Path length ${path.steps.length}\\n`;\n        if (notFoundExampleCount < 3) {\n          for (const step of path.steps) {\n            out += `   step: low=${step.low}, high=${step.high}, mid=${step.mid}, val=${step.midVal}, cmp=${step.comparison}\\n`;\n          }\n          notFoundExampleCount++;\n          out += '\\n';\n        }\n        if (notFoundExampleCount >= 3) break;\n      }\n    }\n    logOutput.textContent = out;\n  }\n\n  // --- EVENT LISTENERS ---\n\n  loadArrayBtn.addEventListener('click', () => {\n    const inputText = arrayInput.value;\n    const parsed = parseInputArray(inputText);\n    if (!parsed) {\n      addLog('Invalid input array. Ensure it is sorted ascending numbers separated by commas.');\n      return;\n    }\n    array = parsed;\n    arrayInput.value = array.join(', ');\n    sorted = true;\n    addLog(`Array loaded with ${array.length} elements.`);\n    target = null;\n    targetInput.value = '';\n    updateStateOutput();\n    resetSearchBtn.disabled = true;\n    autoStepToggleBtn.disabled = true;\n    stepForwardBtn.disabled = true;\n    stepBackwardBtn.disabled = true;\n    manualCompareBtn.disabled = true;\n    manualCompareInput.disabled = true;\n    exploreAllBtn.disabled = true;\n    showSummaryBtn.disabled = true;\n    foundIndex = -1;\n    searchEnded = false;\n    while (arrayVis.firstChild) arrayVis.removeChild(arrayVis.firstChild);\n  });\n\n  setTargetBtn.addEventListener('click', () => {\n    if (array.length === 0) {\n      addLog('Load an array before setting target.');\n      return;\n    }\n    const val = targetInput.value.trim();\n    if (val.length === 0) {\n      addLog('Empty target input.');\n      return;\n    }\n    let numTarget = Number(val);\n    if (Number.isNaN(numTarget)) {\n      addLog('Target must be a valid number.');\n      return;\n    }\n    target = numTarget;\n    addLog(`Target set to ${target}.`);\n    resetSearchSession();\n  });\n\n  manualCompareBtn.addEventListener('click', () => {\n    submitManualComparison();\n  });\n\n  stepForwardBtn.addEventListener('click', () => {\n    autoStepRunning = false;\n    clearInterval(autoStepTimer);\n    autoStepTimer = null;\n    autoStepToggleBtn.textContent = 'Start Auto-Step';\n    manualCompareInput.disabled = false;\n    manualCompareBtn.disabled = false;\n    stepBackwardBtn.disabled = false;\n    resetSearchBtn.disabled = false;\n    exploreAllBtn.disabled = false;\n    showSummaryBtn.disabled = false;\n    autoStepToggleBtn.disabled = false;\n    autoStepForward();\n  });\n\n  stepBackwardBtn.addEventListener('click', () => {\n    autoStepRunning = false;\n    clearInterval(autoStepTimer);\n    autoStepTimer = null;\n    autoStepToggleBtn.textContent = 'Start Auto-Step';\n    manualCompareInput.disabled = false;\n    manualCompareBtn.disabled = false;\n    stepForwardBtn.disabled = false;\n    resetSearchBtn.disabled = false;\n    exploreAllBtn.disabled = false;\n    showSummaryBtn.disabled = false;\n    autoStepToggleBtn.disabled = false;\n    stepBinarySearchBackward();\n  });\n\n  resetSearchBtn.addEventListener('click', () => {\n    autoStepRunning = false;\n    clearInterval(autoStepTimer);\n    autoStepTimer = null;\n    autoStepToggleBtn.textContent = 'Start Auto-Step';\n    manualCompareInput.disabled = false;\n    manualCompareBtn.disabled = false;\n    stepForwardBtn.disabled = false;\n    stepBackwardBtn.disabled = false;\n    exploreAllBtn.disabled = false;\n    showSummaryBtn.disabled = false;\n    autoStepToggleBtn.disabled = false;\n    resetSearch();\n  });\n\n  autoStepToggleBtn.addEventListener('click', toggleAutoStep);\n\n  exploreAllBtn.addEventListener('click', () => {\n    exploreAllPaths();\n  });\n\n  showSummaryBtn.addEventListener('click', () => {\n    showExplorationSummary();\n  });\n\n  // Keyboard shortcuts: Enter key on manualCompareInput triggers click on manualCompareBtn\n  manualCompareInput.addEventListener('keydown', (e) => {\n    if (e.key === 'Enter') {\n      e.preventDefault();\n      if (!manualCompareBtn.disabled) manualCompareBtn.click();\n    }\n  });\n\n})();\n</script>\n\n</body>\n</html>"
