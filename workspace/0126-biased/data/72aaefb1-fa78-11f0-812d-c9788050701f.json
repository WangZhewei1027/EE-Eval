    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>The Elegance of Greedy Algorithms</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Avenir Next', 'Segoe UI', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 4rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out forwards;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            font-weight: 600;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: -0.5px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization {\n            width: 100%;\n            height: 500px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.15);\n            position: relative;\n            overflow: hidden;\n            margin-bottom: 4rem;\n            opacity: 0;\n            transform: scale(0.95);\n            animation: scaleIn 1s ease-out 0.3s forwards;\n        }\n        \n        .node-container {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n        \n        .node {\n            position: absolute;\n            width: 70px;\n            height: 70px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: bold;\n            color: white;\n            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.2);\n            transform: scale(0);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            z-index: 2;\n        }\n        \n        .node.active {\n            transform: scale(1) !important;\n            box-shadow: 0 15px 40px -10px rgba(0, 0, 0, 0.3);\n        }\n        \n        .node.selected {\n            transform: scale(1.1);\n            box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.35);\n        }\n        \n        .path {\n            position: absolute;\n            height: 3px;\n            background: var(--secondary);\n            transform-origin: left center;\n            z-index: 1;\n            opacity: 0.6;\n            transition: all 0.5s ease-out;\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 3rem;\n        }\n        \n        button {\n            padding: 1rem 2rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            font-weight: 600;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 10px 20px -10px rgba(108, 92, 231, 0.4);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 15px 30px -10px rgba(108, 92, 231, 0.5);\n        }\n        \n        button:disabled {\n            opacity: 0.5;\n            transform: none !important;\n            box-shadow: none;\n            cursor: not-allowed;\n        }\n        \n        .explanation {\n            max-width: 800px;\n            margin: 0 auto;\n            text-align: center;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out 0.6s forwards;\n        }\n        \n        .explanation h2 {\n            font-size: 2rem;\n            margin-bottom: 1.5rem;\n            color: var(--primary);\n        }\n        \n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 2rem;\n            font-size: 1.1rem;\n            color: var(--dark);\n            opacity: 0.8;\n        }\n        \n        .features {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            margin-top: 4rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out 0.9s forwards;\n        }\n        \n        .feature {\n            background: white;\n            padding: 2rem;\n            border-radius: 15px;\n            box-shadow: 0 15px 40px -20px rgba(0, 0, 0, 0.1);\n            transition: all 0.3s ease;\n        }\n        \n        .feature:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.15);\n        }\n        \n        .feature h3 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.3rem;\n        }\n        \n        .feature p {\n            line-height: 1.6;\n            color: var(--dark);\n            opacity: 0.8;\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n        \n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes scaleIn {\n            to {\n                opacity: 1;\n                transform: scale(1);\n            }\n        }\n        \n        /* Particle background for the visualization */\n        .particle {\n            position: absolute;\n            border-radius: 50%;\n            background: rgba(162, 155, 254, 0.1);\n            pointer-events: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>The Elegance of Greedy Algorithms</h1>\n            <p class=\"subtitle\">A visual exploration of algorithmic strategies that make locally optimal choices at each stage with the hope of finding a global optimum.</p>\n        </header>\n        \n        <div class=\"visualization\" id=\"visualization\">\n            <div class=\"node-container\" id=\"nodeContainer\"></div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"startBtn\">Begin Visualization</button>\n            <button id=\"resetBtn\" disabled>Reset</button>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>How Greedy Algorithms Work</h2>\n            <p>A greedy algorithm builds up a solution piece by piece, always choosing the next piece that offers the most immediate benefit. This approach never reconsider choices once they're made, which differentiates it from other algorithmic approaches like divide and conquer or dynamic programming.</p>\n            <p>The visualization above demonstrates a greedy pathfinding approach where the algorithm always selects the nearest available node, building an approximate solution to the traveling salesman problem.</p>\n        </div>\n        \n        <div class=\"features\">\n            <div class=\"feature\">\n                <h3>Optimal Substructure</h3>\n                <p>A problem exhibits optimal substructure if an optimal solution to the problem contains within it optimal solutions to subproblems.</p>\n            </div>\n            <div class=\"feature\">\n                <h3>Greedy Choice Property</h3>\n                <p>We can make whatever choice seems best at the moment and then solve the subproblems that arise later.</p>\n            </div>\n            <div class=\"feature\">\n                <h3>When to Use</h3>\n                <p>Greedy algorithms work best when applied to problems with these properties and can often provide efficient approximate solutions.</p>\n            </div>\n        </div>\n        \n        <footer>\n            <p>An aesthetic exploration of algorithmic concepts | Greedy Algorithms Visualization</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Create particles for background\n            const visualization = document.getElementById('visualization');\n            for (let i = 0; i < 30; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 100 + 50;\n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                \n                const x = Math.random() * 100;\n                const y = Math.random() * 100;\n                particle.style.left = `${x}%`;\n                particle.style.top = `${y}%`;\n                \n                visualization.appendChild(particle);\n            }\n            \n            // Set up nodes for greedy algorithm visualization\n            const nodeContainer = document.getElementById('nodeContainer');\n            const nodes = [];\n            const colors = [\n                '#6c5ce7', '#a29bfe', '#74b9ff', '#55efc4', \n                '#00b894', '#ffeaa7', '#fab1a0', '#e17055'\n            ];\n            \n            // Create 8 nodes in a circular pattern\n            const radius = 180;\n            const centerX = visualization.offsetWidth / 2;\n            const centerY = visualization.offsetHeight / 2;\n            \n            for (let i = 0; i < 8; i++) {\n                const angle = (i / 8) * Math.PI * 2;\n                const x = centerX + radius * Math.cos(angle) - 35;\n                const y = centerY + radius * Math.sin(angle) - 35;\n                \n                const node = document.createElement('div');\n                node.classList.add('node');\n                node.textContent = i + 1;\n                node.style.left = `${x}px`;\n                node.style.top = `${y}px`;\n                node.style.background = colors[i];\n                node.dataset.index = i;\n                \n                nodeContainer.appendChild(node);\n                nodes.push({\n                    element: node,\n                    x: x + 35,\n                    y: y + 35,\n                    visited: false\n                });\n            }\n            \n            // Initialize all nodes as inactive\n            setTimeout(() => {\n                document.querySelectorAll('.node').forEach(node => {\n                    node.classList.add('active');\n                });\n            }, 500);\n            \n            // Greedy algorithm visualization\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let animationRunning = false;\n            let currentPath = [];\n            let paths = [];\n            \n            startBtn.addEventListener('click', () => {\n                if (animationRunning) return;\n                \n                startBtn.disabled = true;\n                resetBtn.disabled = false;\n                animationRunning = true;\n                \n                // Reset all nodes and paths\n                nodes.forEach(node => {\n                    node.visited = false;\n                    node.element.classList.remove('selected');\n                });\n                \n                paths.forEach(path => path.element.remove());\n                paths = [];\n                currentPath = [];\n                \n                // Start from random node\n                const startIndex = Math.floor(Math.random() * nodes.length);\n                const startNode = nodes[startIndex];\n                startNode.visited = true;\n                startNode.element.classList.add('selected');\n                currentPath.push(startNode);\n                \n                // Animate greedy selection\n                const greedyInterval = setInterval(() => {\n                    if (currentPath.length === nodes.length) {\n                        clearInterval(greedyInterval);\n                        animationRunning = false;\n                        return;\n                    }\n                    \n                    // Find nearest unvisited node\n                    let minDistance = Infinity;\n                    let nearestNode = null;\n                    let lastNode = currentPath[currentPath.length - 1];\n                    \n                    nodes.forEach(node => {\n                        if (!node.visited) {\n                            const dx = node.x - lastNode.x;\n                            const dy = node.y - lastNode.y;\n                            const distance = Math.sqrt(dx * dx + dy * dy);\n                            \n                            if (distance < minDistance) {\n                                minDistance = distance;\n                                nearestNode = node;\n                            }\n                        }\n                    });\n                    \n                    if (nearestNode) {\n                        // Create path\n                        const path = document.createElement('div');\n                        path.classList.add('path');\n                        \n                        const dx = nearestNode.x - lastNode.x;\n                        const dy = nearestNode.y - lastNode.y;\n                        const distance = Math.sqrt(dx * dx + dy * dy);\n                        const angle = Math.atan2(dy, dx);\n                        \n                        path.style.width = `${distance}px`;\n                        path.style.left = `${lastNode.x}px`;\n                        path.style.top = `${lastNode.y}px`;\n                        path.style.transform = `rotate(${angle}rad)`;\n                        \n                        nodeContainer.appendChild(path);\n                        paths.push({ element: path });\n                        \n                        // Mark node as visited\n                        nearestNode.visited = true;\n                        nearestNode.element.classList.add('selected');\n                        currentPath.push(nearestNode);\n                    }\n                }, 1000);\n            });\n            \n            resetBtn.addEventListener('click', () => {\n                if (animationRunning) return;\n                \n                startBtn.disabled = false;\n                resetBtn.disabled = true;\n                \n                nodes.forEach(node => {\n                    node.visited = false;\n                    node.element.classList.remove('selected');\n                });\n                \n                paths.forEach(path => path.element.remove());\n                paths = [];\n                currentPath = [];\n                \n                // Reset nodes to active state\n                document.querySelectorAll('.node').forEach(node => {\n                    node.classList.add('active');\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
