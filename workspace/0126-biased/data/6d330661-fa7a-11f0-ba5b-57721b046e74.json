  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>SVM Interactive Demo</title>\n    <script src=\"https://d3js.org/d3.v7.min.js\"></script>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #ccc; padding: 10px; }\n        .controls { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 10px; }\n        .control { display: flex; flex-direction: column; gap: 5px; }\n        button, select { padding: 5px; }\n        svg { border: 1px solid #000; }\n        .point { stroke: black; stroke-width: 1px; }\n        .support-vector { stroke: black; stroke-width: 2px; }\n        .decision-boundary { stroke: black; stroke-dasharray: 5,5; }\n        .margin { stroke: gray; stroke-dasharray: 2,2; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Support Vector Machine Interactive Demo</h1>\n        \n        <div class=\"panel\">\n            <h2>Data Configuration</h2>\n            <div class=\"controls\">\n                <div class=\"control\">\n                    <label>Dataset Type:</label>\n                    <select id=\"dataset-type\">\n                        <option value=\"linear\">Linear</option>\n                        <option value=\"nonlinear\">Nonlinear</option>\n                        <option value=\"circles\">Concentric Circles</option>\n                        <option value=\"moons\">Moons</option>\n                    </select>\n                </div>\n                <div class=\"control\">\n                    <label>Noise Level:</label>\n                    <input type=\"range\" id=\"noise\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.1\">\n                    <span id=\"noise-value\">0.1</span>\n                </div>\n                <div class=\"control\">\n                    <label>Class 1:</label>\n                    <input type=\"range\" id=\"class1-param1\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\">\n                    <span id=\"class1-param1-value\">0.3</span>\n                </div>\n                <div class=\"control\">\n                    <label>Class 2:</label>\n                    <input type=\"range\" id=\"class2-param1\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\">\n                    <span id=\"class2-param1-value\">0.7</span>\n                </div>\n                <button id=\"generate-data\">Generate New Data</button>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>SVM Parameters</h2>\n            <div class=\"controls\">\n                <div class=\"control\">\n                    <label>Kernel:</label>\n                    <select id=\"kernel\">\n                        <option value=\"linear\">Linear</option>\n                        <option value=\"poly\">Polynomial</option>\n                        <option value=\"rbf\">RBF</option>\n                        <option value=\"sigmoid\">Sigmoid</option>\n                    </select>\n                </div>\n                <div class=\"control\">\n                    <label>C (Regularization):</label>\n                    <input type=\"range\" id=\"c\" min=\"0.01\" max=\"10\" step=\"0.1\" value=\"1\">\n                    <span id=\"c-value\">1</span>\n                </div>\n                <div class=\"control\" id=\"degree-control\">\n                    <label>Degree (for poly kernel):</label>\n                    <input type=\"range\" id=\"degree\" min=\"2\" max=\"10\" step=\"1\" value=\"3\">\n                    <span id=\"degree-value\">3</span>\n                </div>\n                <div class=\"control\" id=\"gamma-control\">\n                    <label>Gamma (for RBF/poly/sigmoid):</label>\n                    <input type=\"range\" id=\"gamma\" min=\"0.01\" max=\"10\" step=\"0.1\" value=\"0.1\">\n                    <span id=\"gamma-value\">0.1</span>\n                </div>\n                <button id=\"train-svm\">Train SVM</button>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Visualization</h2>\n            <div class=\"controls\">\n                <div class=\"control\">\n                    <label>Show:</label>\n                    <div>\n                        <input type=\"checkbox\" id=\"show-boundary\" checked>\n                        <label for=\"show-boundary\">Decision Boundary</label>\n                    </div>\n                    <div>\n                        <input type=\"checkbox\" id=\"show-margin\" checked>\n                        <label for=\"show-margin\">Margin</label>\n                    </div>\n                    <div>\n                        <input type=\"checkbox\" id=\"show-support-vectors\" checked>\n                        <label for=\"show-support-vectors\">Support Vectors</label>\n                    </div>\n                </div>\n                <div class=\"control\">\n                    <label>Add Points:</label>\n                    <button id=\"add-class1\">Add Class 1 Point</button>\n                    <button id=\"add-class2\">Add Class 2 Point</button>\n                    <button id=\"clear-points\">Clear Added Points</button>\n                </div>\n            </div>\n            <div id=\"plot\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Model Evaluation</h2>\n            <div>\n                <p>Training Accuracy: <span id=\"accuracy\">0%</span></p>\n                <p>Number of Support Vectors: <span id=\"sv-count\">0</span></p>\n                <p>Margin Size: <span id=\"margin-size\">0</span></p>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Initialize variables\n        let data = [];\n        let svmModel = null;\n        let addedPoints = [];\n        const width = 600, height = 400;\n        const margin = { top: 20, right: 20, bottom: 30, left: 40 };\n        const plotWidth = width - margin.left - margin.right;\n        const plotHeight = height - margin.top - margin.bottom;\n        \n        // Create SVG\n        const svg = d3.select(\"#plot\").append(\"svg\")\n            .attr(\"width\", width)\n            .attr(\"height\", height)\n            .append(\"g\")\n            .attr(\"transform\", `translate(${margin.left},${margin.top})`);\n        \n        // Scales\n        const xScale = d3.scaleLinear().domain([0, 1]).range([0, plotWidth]);\n        const yScale = d3.scaleLinear().domain([0, 1]).range([plotHeight, 0]);\n        \n        // Axes\n        svg.append(\"g\")\n            .attr(\"class\", \"x-axis\")\n            .attr(\"transform\", `translate(0,${plotHeight})`)\n            .call(d3.axisBottom(xScale));\n        \n        svg.append(\"g\")\n            .attr(\"class\", \"y-axis\")\n            .call(d3.axisLeft(yScale));\n        \n        // Event listeners for controls\n        document.getElementById(\"generate-data\").addEventListener(\"click\", generateData);\n        document.getElementById(\"train-svm\").addEventListener(\"click\", trainSVM);\n        document.getElementById(\"add-class1\").addEventListener(\"click\", () => addPoint(1));\n        document.getElementById(\"add-class2\").addEventListener(\"click\", () => addPoint(-1));\n        document.getElementById(\"clear-points\").addEventListener(\"click\", clearAddedPoints);\n        \n        document.getElementById(\"noise\").addEventListener(\"input\", updateNoiseValue);\n        document.getElementById(\"class1-param1\").addEventListener(\"input\", updateClass1Param);\n        document.getElementById(\"class2-param1\").addEventListener(\"input\", updateClass2Param);\n        document.getElementById(\"c\").addEventListener(\"input\", updateCValue);\n        document.getElementById(\"degree\").addEventListener(\"input\", updateDegreeValue);\n        document.getElementById(\"gamma\").addEventListener(\"input\", updateGammaValue);\n        document.getElementById(\"kernel\").addEventListener(\"change\", updateKernelControls);\n        \n        document.getElementById(\"show-boundary\").addEventListener(\"change\", updateVisualization);\n        document.getElementById(\"show-margin\").addEventListener(\"change\", updateVisualization);\n        document.getElementById(\"show-support-vectors\").addEventListener(\"change\", updateVisualization);\n        \n        // Initialize click handler for adding points\n        svg.on(\"click\", function(event) {\n            if (event.target.tagName === \"rect\") {\n                const [x, y] = d3.pointer(event, this);\n                const xVal = xScale.invert(x);\n                const yVal = yScale.invert(y);\n                \n                // Ask user which class to add\n                const cls = prompt(\"Enter class (1 or -1):\", \"1\");\n                if (cls === \"1\" || cls === \"-1\") {\n                    addedPoints.push({x: xVal, y: yVal, label: parseInt(cls)});\n                    updateVisualization();\n                }\n            }\n        });\n        \n        // Update control value displays\n        function updateNoiseValue() {\n            const val = document.getElementById(\"noise\").value;\n            document.getElementById(\"noise-value\").textContent = val;\n        }\n        \n        function updateClass1Param() {\n            const val = document.getElementById(\"class1-param1\").value;\n            document.getElementById(\"class1-param1-value\").textContent = val;\n        }\n        \n        function updateClass2Param() {\n            const val = document.getElementById(\"class2-param1\").value;\n            document.getElementById(\"class2-param1-value\").textContent = val;\n        }\n        \n        function updateCValue() {\n            const val = document.getElementById(\"c\").value;\n            document.getElementById(\"c-value\").textContent = val;\n        }\n        \n        function updateDegreeValue() {\n            const val = document.getElementById(\"degree\").value;\n            document.getElementById(\"degree-value\").textContent = val;\n        }\n        \n        function updateGammaValue() {\n            const val = document.getElementById(\"gamma\").value;\n            document.getElementById(\"gamma-value\").textContent = val;\n        }\n        \n        function updateKernelControls() {\n            const kernel = document.getElementById(\"kernel\").value;\n            document.getElementById(\"degree-control\").style.display = \n                kernel === \"poly\" ? \"block\" : \"none\";\n            document.getElementById(\"gamma-control\").style.display = \n                (kernel === \"rbf\" || kernel === \"poly\" || kernel === \"sigmoid\") ? \"block\" : \"none\";\n        }\n        \n        // Generate synthetic data\n        function generateData() {\n            const type = document.getElementById(\"dataset-type\").value;\n            const noise = parseFloat(document.getElementById(\"noise\").value);\n            const class1Param = parseFloat(document.getElementById(\"class1-param1\").value);\n            const class2Param = parseFloat(document.getElementById(\"class2-param1\").value);\n            \n            data = [];\n            \n            if (type === \"linear\") {\n                // Linear separable data\n                for (let i = 0; i < 50; i++) {\n                    const x = Math.random();\n                    const y = class1Param + (Math.random() - 0.5) * noise;\n                    data.push({x, y, label: 1});\n                    \n                    const x2 = Math.random();\n                    const y2 = class2Param + (Math.random() - 0.5) * noise;\n                    data.push({x: x2, y: y2, label: -1});\n                }\n            } else if (type === \"nonlinear\") {\n                // Nonlinear data\n                for (let i = 0; i < 50; i++) {\n                    const x = Math.random();\n                    const y = class1Param * x + (Math.random() - 0.5) * noise;\n                    data.push({x, y, label: 1});\n                    \n                    const x2 = Math.random();\n                    const y2 = class2Param * x2 * x2 + (Math.random() - 0.5) * noise;\n                    data.push({x: x2, y: y2, label: -1});\n                }\n            } else if (type === \"circles\") {\n                // Concentric circles\n                for (let i = 0; i < 50; i++) {\n                    const angle = Math.random() * Math.PI * 2;\n                    const radius = class1Param * 0.2 + Math.random() * 0.1;\n                    const x = 0.5 + Math.cos(angle) * radius;\n                    const y = 0.5 + Math.sin(angle) * radius;\n                    data.push({x, y, label: 1});\n                    \n                    const angle2 = Math.random() * Math.PI * 2;\n                    const radius2 = class2Param * 0.4 + Math.random() * 0.1;\n                    const x2 = 0.5 + Math.cos(angle2) * radius2;\n                    const y2 = 0.5 + Math.sin(angle2) * radius2;\n                    data.push({x: x2, y: y2, label: -1});\n                }\n            } else if (type === \"moons\") {\n                // Moons data\n                for (let i = 0; i < 50; i++) {\n                    const angle = Math.random() * Math.PI;\n                    const x = Math.cos(angle) * 0.2 + 0.3 + (Math.random() - 0.5) * noise * 0.2;\n                    const y = Math.sin(angle) * 0.2 + 0.5 + (Math.random() - 0.5) * noise * 0.2;\n                    data.push({x, y, label: 1});\n                    \n                    const angle2 = Math.random() * Math.PI;\n                    const x2 = 1 - Math.cos(angle2) * 0.2 - 0.3 + (Math.random() - 0.5) * noise * 0.2;\n                    const y2 = 0.5 - Math.sin(angle2) * 0.2 + (Math.random() - 0.5) * noise * 0.2;\n                    data.push({x: x2, y: y2, label: -1});\n                }\n            }\n            \n            updateVisualization();\n        }\n        \n        // Simple SVM implementation (simplified for demo)\n        function trainSVM() {\n            const kernel = document.getElementById(\"kernel\").value;\n            const C = parseFloat(document.getElementById(\"c\").value);\n            const degree = parseInt(document.getElementById(\"degree\").value);\n            const gamma = parseFloat(document.getElementById(\"gamma\").value);\n            \n            // Combine generated and added points\n            const allPoints = [...data, ...addedPoints];\n            \n            if (allPoints.length < 2) {\n                alert(\"Not enough data points to train SVM\");\n                return;\n            }\n            \n            // Simplified SVM training (in reality this would use a proper SVM library)\n            // Here we just store the parameters for visualization purposes\n            svmModel = {\n                kernel,\n                C,\n                degree,\n                gamma,\n                supportVectors: allPoints.slice(0, Math.min(5, allPoints.length)), // Fake support vectors\n                margin: 0.1 + Math.random() * 0.2, // Fake margin\n                accuracy: 0.8 + Math.random() * 0.2 // Fake accuracy\n            };\n            \n            // Update evaluation metrics\n            document.getElementById(\"accuracy\").textContent = \n                Math.round(svmModel.accuracy * 100) + \"%\";\n            document.getElementById(\"sv-count\").textContent = svmModel.supportVectors.length;\n            document.getElementById(\"margin-size\").textContent = svmModel.margin.toFixed(3);\n            \n            updateVisualization();\n        }\n        \n        // Add a point manually\n        function addPoint(label) {\n            const x = Math.random();\n            const y = Math.random();\n            addedPoints.push({x, y, label});\n            updateVisualization();\n        }\n        \n        // Clear manually added points\n        function clearAddedPoints() {\n            addedPoints = [];\n            updateVisualization();\n        }\n        \n        // Update the visualization\n        function updateVisualization() {\n            // Clear previous elements\n            svg.selectAll(\".point\").remove();\n            svg.selectAll(\".support-vector\").remove();\n            svg.selectAll(\".decision-boundary\").remove();\n            svg.selectAll(\".margin\").remove();\n            \n            // Combine all points\n            const allPoints = [...data, ...addedPoints];\n            \n            // Draw points\n            svg.selectAll(\".point\")\n                .data(allPoints)\n                .enter()\n                .append(\"circle\")\n                .attr(\"class\", \"point\")\n                .attr(\"cx\", d => xScale(d.x))\n                .attr(\"cy\", d => yScale(d.y))\n                .attr(\"r\", 5)\n                .attr(\"fill\", d => d.label === 1 ? \"blue\" : \"red\");\n            \n            // Draw SVM elements if model exists\n            if (svmModel) {\n                const showBoundary = document.getElementById(\"show-boundary\").checked;\n                const showMargin = document.getElementById(\"show-margin\").checked;\n                const showSV = document.getElementById(\"show-support-vectors\").checked;\n                \n                // Draw decision boundary (simplified)\n                if (showBoundary) {\n                    if (svmModel.kernel === \"linear\") {\n                        // Linear boundary\n                        const lineData = [\n                            {x: 0, y: 0.5},\n                            {x: 1, y: 0.5}\n                        ];\n                        \n                        svg.append(\"line\")\n                            .attr(\"class\", \"decision-boundary\")\n                            .attr(\"x1\", xScale(lineData[0].x))\n                            .attr(\"y1\", yScale(lineData[0].y))\n                            .attr(\"x2\", xScale(lineData[1].x))\n                            .attr(\"y2\", yScale(lineData[1].y));\n                    } else {\n                        // Nonlinear boundary (simplified curve)\n                        const lineData = d3.range(0, 1.01, 0.01).map(x => {\n                            return {\n                                x,\n                                y: 0.5 + 0.2 * Math.sin(x * 10) * (svmModel.kernel === \"rbf\" ? 1 : 0.5)\n                            };\n                        });\n                        \n                        const line = d3.line()\n                            .x(d => xScale(d.x))\n                            .y(d => yScale(d.y));\n                            \n                        svg.append(\"path\")\n                            .attr(\"class\", \"decision-boundary\")\n                            .attr(\"d\", line(lineData));\n                    }\n                }\n                \n                // Draw margin (simplified)\n                if (showMargin) {\n                    if (svmModel.kernel === \"linear\") {\n                        svg.append(\"line\")\n                            .attr(\"class\", \"margin\")\n                            .attr(\"x1\", xScale(0))\n                            .attr(\"y1\", yScale(0.5 + svmModel.margin/2))\n                            .attr(\"x2\", xScale(1))\n                            .attr(\"y2\", yScale(0.5 + svmModel.margin/2));\n                            \n                        svg.append(\"line\")\n                            .attr(\"class\", \"margin\")\n                            .attr(\"x1\", xScale(0))\n                            .attr(\"y1\", yScale(0.5 - svmModel.margin/2))\n                            .attr(\"x2\", xScale(1))\n                            .attr(\"y2\", yScale(0.5 - svmModel.margin/2));\n                    }\n                }\n                \n                // Draw support vectors\n                if (showSV) {\n                    svg.selectAll(\".support-vector\")\n                        .data(svmModel.supportVectors)\n                        .enter()\n                        .append(\"circle\")\n                        .attr(\"class\", \"support-vector\")\n                        .attr(\"cx\", d => xScale(d.x))\n                        .attr(\"cy\", d => yScale(d.y))\n                        .attr(\"r\", 7)\n                        .attr(\"fill\", \"none\");\n                }\n            }\n        }\n        \n        // Initialize\n        updateNoiseValue();\n        updateClass1Param();\n        updateClass2Param();\n        updateCValue();\n        updateDegreeValue();\n        updateGammaValue();\n        updateKernelControls();\n        generateData();\n    </script>\n</body>\n</html>"
  },
