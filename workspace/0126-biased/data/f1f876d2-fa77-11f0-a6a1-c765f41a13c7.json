    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Version Control — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&family=Fira+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #071025;\n      --bg-2: #0f1630;\n      --accent-1: #6be7c3;\n      --accent-2: #7aa2ff;\n      --glass: rgba(255,255,255,0.04);\n      --muted: rgba(255,255,255,0.12);\n      --glass-2: rgba(255,255,255,0.02);\n      --shadow: 0 10px 30px rgba(2,6,23,0.6);\n      --glass-border: rgba(255,255,255,0.06);\n      --mono: \"Fira Mono\", monospace;\n      --ui-radius: 14px;\n    }\n\n    *{box-sizing:border-box}\n    html,body{\n      height:100%;\n      margin:0;\n      background:\n        radial-gradient(1200px 600px at 10% 10%, rgba(122,162,255,0.08), transparent 8%),\n        radial-gradient(800px 400px at 90% 90%, rgba(107,231,195,0.06), transparent 8%),\n        linear-gradient(180deg,var(--bg-1), var(--bg-2));\n      font-family: \"Poppins\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color: #e9f0ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding: 36px;\n    }\n\n    .frame{\n      max-width:1200px;\n      margin: 28px auto;\n      border-radius: 20px;\n      padding: 28px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: var(--shadow);\n      border: 1px solid rgba(255,255,255,0.03);\n      position: relative;\n      overflow: hidden;\n    }\n\n    header{\n      display:flex;\n      align-items: center;\n      gap:20px;\n      margin-bottom:18px;\n    }\n\n    .logo{\n      width:72px;\n      height:72px;\n      border-radius:16px;\n      display:grid;\n      place-items:center;\n      background: linear-gradient(135deg, rgba(122,162,255,0.14), rgba(107,231,195,0.12));\n      border: 1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 6px 24px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.02);\n      flex: 0 0 72px;\n    }\n    .logo svg{filter: drop-shadow(0 4px 10px rgba(122,162,255,0.08));}\n\n    h1{\n      font-weight:800;\n      letter-spacing:-0.02em;\n      margin:0;\n      font-size:28px;\n      line-height:1;\n      color: #f7fbff;\n    }\n    p.lead{\n      margin:4px 0 0 0;\n      color: rgba(255,255,255,0.6);\n      font-size:13px;\n    }\n\n    .layout{\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap:28px;\n      align-items:stretch;\n      margin-top:22px;\n    }\n\n    /* Left: Graph */\n    .graph-wrap{\n      position:relative;\n      height:520px;\n      border-radius: var(--ui-radius);\n      padding:28px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n      border:1px solid var(--glass-border);\n      overflow:hidden;\n      box-shadow: 0 8px 40px rgba(2,6,23,0.5);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    .graph-surface{\n      width:100%;\n      height:100%;\n      position:relative;\n      --node-size: 18px;\n    }\n\n    /* Background subtle grid */\n    .grid{\n      position:absolute;\n      inset:0;\n      background-image:\n        linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px),\n        linear-gradient(to bottom, rgba(255,255,255,0.01) 1px, transparent 1px);\n      background-size: 120px 120px, 120px 120px;\n      mix-blend-mode: overlay;\n      pointer-events:none;\n    }\n\n    /* SVG branch paths */\n    svg.branches{\n      position:absolute;\n      inset:0;\n      width:100%;\n      height:100%;\n      overflow:visible;\n      filter: drop-shadow(0 8px 30px rgba(10,30,60,0.6));\n      pointer-events:none;\n    }\n\n    .branch{\n      fill:none;\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:3;\n      stroke-linecap:round;\n      stroke-linejoin:round;\n    }\n    .branch.acc{\n      stroke: url(#gradA);\n      stroke-width:4;\n      mix-blend-mode: screen;\n      opacity:0.9;\n    }\n\n    /* commits (nodes) */\n    .node{\n      position:absolute;\n      display:flex;\n      align-items:center;\n      gap:12px;\n      transform-origin:center;\n      pointer-events:auto;\n      cursor: default;\n    }\n    .dot{\n      width:var(--node-size);\n      height:var(--node-size);\n      border-radius:50%;\n      background: linear-gradient(180deg,#e1f9ef,#6be7c3);\n      box-shadow: 0 6px 18px rgba(107,231,195,0.12), 0 0 12px rgba(122,162,255,0.06);\n      border: 2px solid rgba(255,255,255,0.12);\n      transform: scale(0.92);\n      transition: transform 220ms cubic-bezier(.2,.9,.3,1);\n    }\n    .node:hover .dot{ transform: scale(1.06) translateY(-2px) }\n\n    .tag{\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.04);\n      padding:8px 12px;\n      border-radius: 12px;\n      font-size:12px;\n      color: #dfefff;\n      box-shadow: 0 6px 18px rgba(3,10,30,0.5);\n      white-space:nowrap;\n      transform: translateY(-2px);\n    }\n\n    /* stagger in animations - initially hidden */\n    .node{ opacity:0; transform: translateY(20px) scale(0.96); }\n    .graph-running .node{\n      animation: popIn 620ms cubic-bezier(.16,.9,.24,1) forwards;\n    }\n    @keyframes popIn{\n      to { opacity:1; transform: translateY(0) scale(1); }\n    }\n\n    /* animate strokes */\n    .branch.acc{\n      stroke-dasharray: 1200;\n      stroke-dashoffset: 1200;\n      animation: drawLine 1600ms cubic-bezier(.2,.9,.2,1) forwards;\n      animation-delay: 240ms;\n    }\n    .graph-running .branch.acc{\n      /* triggered by class */\n    }\n    @keyframes drawLine{\n      to { stroke-dashoffset: 0; }\n    }\n\n    /* moving \"commit\" glow riding along main branch */\n    .glimmer{\n      position:absolute;\n      width:28px;\n      height:28px;\n      border-radius:50%;\n      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.6), rgba(122,162,255,0.18) 25%, transparent 60%);\n      filter: blur(6px);\n      mix-blend-mode: screen;\n      pointer-events:none;\n      opacity:0;\n      transform: translate(-50%,-50%);\n    }\n    .graph-running .glimmer{ animation: ride 2400ms linear forwards; opacity:1; }\n    @keyframes ride{\n      0% { transform: translate(-50%,-50%) translateX(-42% ) translateY(120px) scale(0.4); opacity:0.3; }\n      40% { opacity:1; transform: translate(-50%,-50%) translateX(0%) translateY(0px) scale(1.04); }\n      70% { transform: translate(-50%,-50%) translateX(52%) translateY(-12px) scale(0.9); }\n      100% { transform: translate(-50%,-50%) translateX(102%) translateY(-80px) scale(0.6); opacity:0.0; }\n    }\n\n    /* Right: Info / Code card */\n    .panel{\n      border-radius: 16px;\n      padding:20px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 12px 40px rgba(2,6,23,0.5);\n      height:520px;\n      display:flex;\n      flex-direction:column;\n      gap:16px;\n    }\n    .meta{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n    .commit-card{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .avatar{\n      width:56px;\n      height:56px;\n      border-radius:12px;\n      display:grid;\n      place-items:center;\n      background: linear-gradient(135deg, rgba(122,162,255,0.14), rgba(107,231,195,0.10));\n      border:1px solid rgba(255,255,255,0.04);\n      font-weight:700;\n      color: #f8fbff;\n      font-size:18px;\n      box-shadow: 0 6px 20px rgba(3,10,30,0.5);\n    }\n    .commit-info{ flex:1; }\n    .commit-info h3{ margin:0; font-size:15px; font-weight:700; color:#f3f8ff; }\n    .commit-info p{ margin:6px 0 0 0; color: rgba(255,255,255,0.55); font-size:13px; }\n\n    .badge{\n      font-size:12px;\n      padding:8px 10px;\n      border-radius:12px;\n      background: linear-gradient(90deg, rgba(122,162,255,0.12), rgba(107,231,195,0.06));\n      border:1px solid rgba(255,255,255,0.04);\n      color:#e8f9f1;\n    }\n\n    .code{\n      margin-top:6px;\n      flex:1;\n      border-radius:12px;\n      overflow:hidden;\n      background: linear-gradient(180deg, rgba(4,10,20,0.45), rgba(4,8,16,0.55));\n      border:1px solid rgba(255,255,255,0.02);\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n      padding:14px;\n      display:flex;\n      gap:12px;\n      font-family:var(--mono);\n      font-size:13px;\n      color:#dff8ff;\n    }\n\n    .gutter{\n      width:44px;\n      color: rgba(255,255,255,0.18);\n      user-select:none;\n      display:flex;\n      flex-direction:column;\n      gap:4px;\n      align-items:flex-end;\n      padding-right:6px;\n    }\n    .lines{ flex:1; display:flex; flex-direction:column; gap:4px; padding-right:6px; overflow:auto; }\n\n    .line{\n      padding:4px 8px;\n      border-radius:8px;\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n    .line .code-token{ color:#dff8ff; opacity:0.96; font-family:var(--mono); }\n\n    .line.add{ background: linear-gradient(90deg, rgba(29,166,112,0.12), rgba(29,166,112,0.06)); border-left:3px solid rgba(29,166,112,0.22); color: #bfffe3; }\n    .line.rem{ background: linear-gradient(90deg, rgba(226,89,103,0.08), rgba(226,89,103,0.03)); border-left:3px solid rgba(226,89,103,0.16); color: #ffdfe6; }\n    .line.ntr{ background: transparent; color: rgba(255,255,255,0.78); }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      justify-content:flex-end;\n    }\n    .btn{\n      padding:10px 14px;\n      border-radius:10px;\n      border:1px solid rgba(255,255,255,0.06);\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color: #e9f5ff;\n      font-weight:600;\n      cursor:pointer;\n      box-shadow: 0 6px 20px rgba(3,10,30,0.45);\n      transition: transform 160ms ease, box-shadow 160ms ease, opacity 140ms;\n      font-size:13px;\n    }\n    .btn:active{ transform: translateY(1px) scale(0.998); }\n    .btn.ghost{ background:transparent; border:1px solid rgba(255,255,255,0.04); color: rgba(255,255,255,0.88); }\n\n    .btn:disabled{ opacity:0.5; cursor:default; transform:none; }\n\n    /* footer tiny credits */\n    .foot{\n      margin-top:18px;\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      color: rgba(255,255,255,0.24);\n      font-size:13px;\n    }\n\n    /* small responsive */\n    @media (max-width:1024px){\n      .layout{ grid-template-columns:1fr; }\n      .panel{ height:460px; }\n      .graph-wrap{ height:420px; }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"frame\" role=\"main\" aria-label=\"Version Control Visual Concept\">\n    <header>\n      <div class=\"logo\" aria-hidden=\"true\">\n        <svg width=\"44\" height=\"44\" viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7AA2FF\"/>\n              <stop offset=\"1\" stop-color=\"#6BE7C3\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"10\" fill=\"url(#g1)\" opacity=\"0.14\"/>\n          <path d=\"M20 26 L28 20 L36 26 L44 20\" stroke=\"url(#g1)\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <circle cx=\"20\" cy=\"36\" r=\"2.4\" fill=\"#7AA2FF\" />\n          <circle cx=\"32\" cy=\"28\" r=\"2.8\" fill=\"#6BE7C3\" />\n          <circle cx=\"44\" cy=\"20\" r=\"2.4\" fill=\"#7AA2FF\" />\n        </svg>\n      </div>\n      <div>\n        <h1>Version Control</h1>\n        <p class=\"lead\">A refined visual concept — commits, branches, merges & diffs elegantly rendered.</p>\n      </div>\n      <div style=\"flex:1\"></div>\n      <div style=\"text-align:right\">\n        <div style=\"font-weight:700;color:rgba(255,255,255,0.75)\">Visual Prototype</div>\n        <div style=\"font-size:13px;color:rgba(255,255,255,0.35)\">Static demo — minimal interaction</div>\n      </div>\n    </header>\n\n    <div class=\"layout\">\n      <div class=\"graph-wrap\" aria-hidden=\"true\">\n        <div class=\"graph-surface\" id=\"graph\">\n          <div class=\"grid\" aria-hidden=\"true\"></div>\n\n          <svg class=\"branches\" viewBox=\"0 0 1200 600\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"gradA\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7AA2FF\"/>\n                <stop offset=\"1\" stop-color=\"#6BE7C3\"/>\n              </linearGradient>\n            </defs>\n            <!-- Main timeline curve -->\n            <path id=\"main\" class=\"branch acc\" d=\"M80 440 C260 330, 420 330, 540 280 C700 210, 840 240, 1020 160\" />\n            <!-- feature branch -->\n            <path class=\"branch\" d=\"M420 320 C460 300, 520 240, 560 220\" stroke-dasharray=\"8 6\" stroke-width=\"2.6\" />\n            <!-- parallel experiments -->\n            <path class=\"branch\" d=\"M300 360 C340 320, 380 300, 420 280\" stroke-dasharray=\"4 5\" stroke-width=\"2.2\" opacity=\"0.8\" />\n          </svg>\n\n          <!-- commits placed roughly along coordinates, converted to percent of container -->\n          <!-- Node template: style left/top in px relative to viewBox mapping (we use JS to position) -->\n          <div class=\"node\" data-delay=\"100\" style=\"left:80px; top:440px;\">\n            <div class=\"dot\"></div>\n            <div class=\"tag\">init • 2021-09-15</div>\n          </div>\n\n          <div class=\"node\" data-delay=\"220\" style=\"left:260px; top:330px;\">\n            <div class=\"dot\" style=\"background:linear-gradient(180deg,#e6f1ff,#7aa2ff)\"></div>\n            <div class=\"tag\">v0.1 • baseline</div>\n          </div>\n\n          <div class=\"node\" data-delay=\"320\" style=\"left:420px; top:330px;\">\n            <div class=\"dot\"></div>\n            <div class=\"tag\">feature/auth</div>\n          </div>\n\n          <div class=\"node\" data-delay=\"420\" style=\"left:540px; top:280px;\">\n            <div class=\"dot\" style=\"background:linear-gradient(180deg,#fff0d6,#ffd89b);\"></div>\n            <div class=\"tag\">experiment/ui</div>\n          </div>\n\n          <div class=\"node\" data-delay=\"520\" style=\"left:700px; top:210px;\">\n            <div class=\"dot\"></div>\n            <div class=\"tag\">merge • auth → main</div>\n          </div>\n\n          <div class=\"node\" data-delay=\"620\" style=\"left:840px; top:240px;\">\n            <div class=\"dot\" style=\"background:linear-gradient(180deg,#efe6ff,#d7c9ff)\"></div>\n            <div class=\"tag\">perf • optimize</div>\n          </div>\n\n          <div class=\"node\" data-delay=\"720\" style=\"left:1020px; top:160px;\">\n            <div class=\"dot\" style=\"background:linear-gradient(180deg,#dff9f7,#6be7c3)\"></div>\n            <div class=\"tag\">v1.0 • release</div>\n          </div>\n\n          <div class=\"glimmer\" id=\"glimmer\" aria-hidden=\"true\"></div>\n\n        </div>\n      </div>\n\n      <aside class=\"panel\" aria-label=\"Commit detail and diff\">\n        <div class=\"meta\">\n          <div class=\"commit-card\">\n            <div class=\"avatar\">VC</div>\n            <div class=\"commit-info\">\n              <h3>Release v1.0 — Harmonized Main</h3>\n              <p>Merge feature branches, squash trivial fixes, and finalize release artifacts.</p>\n            </div>\n          </div>\n\n          <div style=\"display:flex;flex-direction:column;gap:6px;align-items:flex-end;\">\n            <div class=\"badge\">main • protected</div>\n            <div style=\"font-size:12px;color:rgba(255,255,255,0.36)\">commits • 7</div>\n          </div>\n        </div>\n\n        <div class=\"code\" role=\"region\" aria-label=\"Code diff sample\">\n          <div class=\"gutter\" aria-hidden=\"true\">\n            <div>1</div>\n            <div>2</div>\n            <div>3</div>\n            <div>4</div>\n            <div>5</div>\n            <div>6</div>\n            <div>7</div>\n            <div>8</div>\n            <div>9</div>\n            <div>10</div>\n          </div>\n          <div class=\"lines\">\n            <div class=\"line ntr\"><span class=\"code-token\">const</span>&nbsp;<span class=\"code-token\">app</span>&nbsp;=&nbsp;<span class=\"code-token\">createApp</span>(<span class=\"code-token\">root</span>);</div>\n            <div class=\"line ntr\"><span class=\"code-token\">app</span>.<span class=\"code-token\">use</span>(<span class=\"code-token\">router</span>);</div>\n\n            <div class=\"line add\"><span class=\"code-token\">// Added: session persistence & enhanced error boundaries</span></div>\n            <div class=\"line add\"><span class=\"code-token\">app</span>.<span class=\"code-token\">provide</span>('session', <span class=\"code-token\">createSession()</span>);</div>\n\n            <div class=\"line rem\"><span class=\"code-token\">// Removed: legacy auth shim</span></div>\n            <div class=\"line ntr\"><span class=\"code-token\">app</span>.<span class=\"code-token\">mount</span>('#app');</div>\n\n            <div class=\"line add\"><span class=\"code-token\">export</span>&nbsp;<span class=\"code-token\">default</span>&nbsp;<span class=\"code-token\">app</span>;</div>\n            <div class=\"line ntr\"><span class=\"code-token\">// commit: 7c9f3b • merge: feature/auth</span></div>\n          </div>\n        </div>\n\n        <div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;\">\n          <div style=\"color:rgba(255,255,255,0.3);font-size:13px\">Rendered timeline with commits, branches & merge flow.</div>\n          <div class=\"controls\">\n            <button class=\"btn ghost\" id=\"resetBtn\" title=\"Reset view\">Reset</button>\n            <button class=\"btn\" id=\"playBtn\" title=\"Play timeline\">Play Timeline</button>\n          </div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"foot\">\n      <div>Concept • Minimal interaction • Aesthetic-first</div>\n      <div>© Visual Prototype</div>\n    </div>\n  </div>\n\n  <script>\n    // Minimal JS — controls two simple actions: Play Timeline and Reset\n    (function(){\n      const graph = document.getElementById('graph');\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const nodes = Array.from(graph.querySelectorAll('.node'));\n      const branches = Array.from(graph.querySelectorAll('.branch.acc'));\n      const glimmer = document.getElementById('glimmer');\n\n      // Map SVG viewBox coordinates to container coords on resize / init\n      function mapPositions(){\n        const svg = graph.querySelector('svg.branches');\n        if(!svg) return;\n        const vb = { w: 1200, h: 600 }; // based on viewBox used\n        const rect = graph.getBoundingClientRect();\n        // For each node with left/top specified (as px matching viewBox coordinates), convert to percent pixels\n        nodes.forEach(node=>{\n          const left = parseFloat(node.style.left || 0);\n          const top = parseFloat(node.style.top || 0);\n          // map viewBox coords to rect coords\n          const x = (left / vb.w) * rect.width;\n          const y = (top / vb.h) * rect.height;\n          node.style.left = (x) + 'px';\n          node.style.top = (y) + 'px';\n        });\n\n        // position glimmer initially off-left near start\n        const startLeft = (80 / vb.w) * rect.width;\n        const startTop = (440 / vb.h) * rect.height;\n        glimmer.style.left = startLeft + 'px';\n        glimmer.style.top = startTop + 'px';\n      }\n\n      // prepare animation delays using data-delay\n      function assignDelays(){\n        nodes.forEach((node,i)=>{\n          const d = node.getAttribute('data-delay') || (100 + i*120);\n          node.style.animationDelay = (d/1000)+'s';\n        });\n        branches.forEach((b,i)=>{\n          b.style.animationDelay = (0.24 + i*0.15) + 's';\n        });\n        // glimmer ride begins slightly after initial\n        glimmer.style.animationDelay = '0.28s';\n      }\n\n      // Start timeline animation\n      function start(){\n        // reset in case previously running\n        graph.classList.remove('graph-running');\n        // force reflow\n        void graph.offsetWidth;\n        assignDelays();\n        graph.classList.add('graph-running');\n        // disable play while running\n        playBtn.disabled = true;\n        resetBtn.disabled = false;\n        // re-enable play after sequence completes (approx)\n        clearTimeout(window._vc_timeout);\n        window._vc_timeout = setTimeout(()=>{\n          playBtn.disabled = false;\n        }, 2600);\n      }\n\n      // Reset to initial state (hide animated states)\n      function reset(){\n        clearTimeout(window._vc_timeout);\n        graph.classList.remove('graph-running');\n        // remove inline animation delays so nodes are hidden again (we will reassign when play)\n        nodes.forEach(node=>{\n          node.style.animationDelay = '0s';\n          node.style.opacity = 0;\n          node.style.transform = 'translateY(20px) scale(0.96)';\n        });\n        branches.forEach(b=>{\n          // reset stroke-dashoffset to initial\n          b.style.strokeDashoffset = b.getTotalLength ? b.getTotalLength() : '';\n          // For consistent reset, reflow trick\n          b.getBoundingClientRect();\n        });\n        glimmer.style.opacity = 0;\n        playBtn.disabled = false;\n        resetBtn.disabled = true;\n      }\n\n      // On first load, map positions & prepare\n      function init(){\n        mapPositions();\n        assignDelays();\n        // set branch dashoffset initial\n        branches.forEach(b=>{\n          const L = b.getTotalLength ? b.getTotalLength() : 1200;\n          b.style.strokeDasharray = L;\n          b.style.strokeDashoffset = L;\n        });\n        // initial state: small reveal of a few nodes to hint the layout\n        nodes.slice(0,2).forEach((node,i)=>{\n          node.style.opacity = 1;\n          node.style.transform = 'translateY(0) scale(1)';\n        });\n        resetBtn.disabled = true;\n      }\n\n      window.addEventListener('resize', ()=>{\n        // Recompute node positions on resize\n        // To prevent overwriting played positions, re-map only from data attributes if present.\n        // Since we mutated style.left earlier to px, we should restore original coordinates by reading element's dataset or data attributes.\n        // For simplicity, reload initial positions from the inline data attributes stored at start by cloning into dataset at initial parse.\n        // But to keep minimal, we simply re-run mapPositions by attempting to parse original numeric left values stored in dataset.\n        // If not present, ignore.\n        init();\n      });\n\n      playBtn.addEventListener('click', start);\n      resetBtn.addEventListener('click', reset);\n\n      // expose minimal keyboard shortcuts: Space = play\n      window.addEventListener('keydown', (e)=>{\n        if(e.code === 'Space'){\n          e.preventDefault();\n          if(playBtn.disabled) return;\n          start();\n        }\n      });\n\n      // Before mapping, preserve initial coords from inline attributes defined in HTML.\n      // We store them in dataset so mapping can use original viewBox numbers even after resize.\n      (function preserveInitial(){\n        nodes.forEach(node=>{\n          // the author defined left/top in px but those represented viewBox coords — store them via attr at runtime if not present\n          const leftAttr = node.getAttribute('style')?.match(/left\\s*:\\s*([0-9.]+)px/);\n          const topAttr = node.getAttribute('style')?.match(/top\\s*:\\s*([0-9.]+)px/);\n          if(leftAttr && topAttr){\n            node.dataset.vx = leftAttr[1];\n            node.dataset.vy = topAttr[1];\n          }\n        });\n        // override mapPositions to use dataset if available\n        const originalMap = mapPositions;\n        mapPositions = function(){\n          const svg = graph.querySelector('svg.branches');\n          if(!svg) return;\n          const vb = { w: 1200, h: 600 };\n          const rect = graph.getBoundingClientRect();\n          nodes.forEach(node=>{\n            const left = node.dataset.vx ? parseFloat(node.dataset.vx) : parseFloat(node.style.left || 0);\n            const top = node.dataset.vy ? parseFloat(node.dataset.vy) : parseFloat(node.style.top || 0);\n            const x = (left / vb.w) * rect.width;\n            const y = (top / vb.h) * rect.height;\n            node.style.left = (x) + 'px';\n            node.style.top = (y) + 'px';\n          });\n          const startLeft = (80 / vb.w) * rect.width;\n          const startTop = (440 / vb.h) * rect.height;\n          glimmer.style.left = startLeft + 'px';\n          glimmer.style.top = startTop + 'px';\n        };\n      })();\n\n      // initialize on load\n      init();\n    })();\n  </script>\n</body>\n</html>"
