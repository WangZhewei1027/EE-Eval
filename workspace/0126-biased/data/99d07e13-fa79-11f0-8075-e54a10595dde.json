    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Load Balancer Simulator</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .control-group {\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Load Balancer Simulator</h1>\n\n<div class=\"control-group\">\n    <label for=\"serverCount\">Number of Servers:</label>\n    <input type=\"number\" id=\"serverCount\" value=\"2\" min=\"1\" max=\"10\">\n</div>\n\n<div class=\"control-group\">\n    <label for=\"requestCount\">Number of Requests:</label>\n    <input type=\"number\" id=\"requestCount\" value=\"10\" min=\"1\" max=\"100\">\n</div>\n\n<div class=\"control-group\">\n    <label for=\"algorithm\">Select Load Balancing Algorithm:</label>\n    <select id=\"algorithm\">\n        <option value=\"roundRobin\">Round Robin</option>\n        <option value=\"leastConnections\">Least Connections</option>\n        <option value=\"random\">Random</option>\n    </select>\n</div>\n\n<div class=\"control-group\">\n    <button id=\"distributeButton\">Distribute Requests</button>\n</div>\n\n<div class=\"control-group\">\n    <label for=\"log\">Log:</label>\n    <textarea id=\"log\" rows=\"10\" cols=\"50\" readonly></textarea>\n</div>\n\n<script>\n    document.getElementById('distributeButton').addEventListener('click', function() {\n        const serverCount = parseInt(document.getElementById('serverCount').value);\n        const requestCount = parseInt(document.getElementById('requestCount').value);\n        const algorithm = document.getElementById('algorithm').value;\n        \n        const servers = Array.from({length: serverCount}, (_, i) => ({ id: i + 1, load: 0, requests: [] }));\n        const logArea = document.getElementById('log');\n        logArea.value = '';\n        \n        const distributeRequests = () => {\n            for (let i = 0; i < requestCount; i++) {\n                const requestId = i + 1;\n                let serverIndex;\n\n                if (algorithm === 'roundRobin') {\n                    serverIndex = i % serverCount;\n                } else if (algorithm === 'leastConnections') {\n                    serverIndex = servers.reduce((prev, curr, index) => curr.load < servers[prev].load ? index : prev, 0);\n                } else if (algorithm === 'random') {\n                    serverIndex = Math.floor(Math.random() * serverCount);\n                }\n\n                servers[serverIndex].load++;\n                servers[serverIndex].requests.push(requestId);\n                logArea.value += `Request ${requestId} assigned to Server ${servers[serverIndex].id}\\n`;\n            }\n\n            servers.forEach(server => {\n                logArea.value += `Server ${server.id} handled requests: ${server.requests.join(', ')} with load: ${server.load}\\n`;\n            });\n        };\n\n        distributeRequests();\n    });\n</script>\n\n</body>\n</html>"
