  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Hash Table — A Visual Exploration</title>\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071029;\n    --card-glow: rgba(123, 92, 255, 0.14);\n    --accent-1: #7B5CFF; /* violet */\n    --accent-2: #00E0C6; /* teal */\n    --muted: rgba(255,255,255,0.08);\n    --glass: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --text: rgba(255,255,255,0.95);\n    --soft: rgba(255,255,255,0.6);\n    --success: #4EE1A1;\n    --danger: #FF6B6B;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background:\n      radial-gradient(1200px 600px at 10% 10%, rgba(123,92,255,0.08), transparent 12%),\n      radial-gradient(800px 400px at 90% 90%, rgba(0,224,198,0.04), transparent 12%),\n      linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n    color:var(--text);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:40px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    overflow:hidden;\n  }\n\n  /* Subtle floating shapes */\n  .floating-shapes{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    overflow:hidden;\n  }\n  .blob{\n    position:absolute;\n    width:480px;height:480px;\n    filter: blur(60px) saturate(120%);\n    opacity:0.12;\n    transform:translate3d(0,0,0);\n    border-radius:50%;\n    mix-blend-mode:screen;\n    animation:float 12s ease-in-out infinite;\n  }\n  .blob.v1{left:-10%; top:-15%; background:linear-gradient(135deg,var(--accent-1), #3AB4FF); animation-delay:0s;}\n  .blob.v2{right:-20%; bottom:-10%; width:560px;height:560px; background:linear-gradient(45deg,var(--accent-2), #7B5CFF); animation-delay:4s; opacity:0.08;}\n  @keyframes float{\n    0%{transform:translateY(0) scale(1)}\n    50%{transform:translateY(30px) scale(1.05)}\n    100%{transform:translateY(0) scale(1)}\n  }\n\n  /* Main card */\n  .card{\n    position:relative;\n    width:1100px;\n    max-width:95vw;\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:28px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    box-shadow:\n      0 8px 30px rgba(2,6,23,0.6),\n      0 1px 0 rgba(255,255,255,0.02) inset;\n    border: 1px solid rgba(255,255,255,0.04);\n    backdrop-filter: blur(8px) saturate(120%);\n    z-index:1;\n    overflow:hidden;\n  }\n  .card::after{\n    content:\"\";\n    position:absolute;\n    inset:auto 0 0 0;\n    height:1px;\n    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02), transparent);\n    opacity:0.5;\n  }\n\n  .header{\n    grid-column:1 / -1;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:20px;\n    margin-bottom:8px;\n  }\n  .title{\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .logo{\n    width:68px;height:68px;border-radius:14px;\n    background:linear-gradient(135deg,var(--accent-1), var(--accent-2));\n    display:flex;align-items:center;justify-content:center;\n    color:white;font-weight:700;font-size:20px;\n    box-shadow: 0 6px 30px var(--card-glow), 0 1px 0 rgba(255,255,255,0.08);\n    transform:translateZ(0);\n  }\n  .hgroup{line-height:1}\n  .hgroup h1{\n    margin:0;font-size:20px;letter-spacing:-0.02em;\n    font-weight:600;\n  }\n  .hgroup p{\n    margin:0;color:var(--soft);font-size:13px;\n  }\n\n  /* Visualization area */\n  .visual{\n    padding:26px;\n    border-radius:14px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n    min-height:520px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .table-area{\n    position:relative;\n    inset:0;\n    width:100%;\n    height:100%;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Hash table row */\n  .buckets{\n    display:flex;\n    gap:12px;\n    align-items:flex-start;\n    justify-content:center;\n    padding:12px 16px;\n    transform:translateZ(0);\n  }\n  .bucket{\n    width:64px;\n    min-height:88px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.01));\n    border-radius:12px;\n    border:1px solid rgba(255,255,255,0.035);\n    box-shadow: 0 6px 18px rgba(7,8,18,0.55);\n    padding:8px;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:10px;\n    position:relative;\n    overflow:visible;\n  }\n  .bucket .idx{\n    width:36px;height:36px;border-radius:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;align-items:center;justify-content:center;\n    font-size:12px;color:var(--soft);border:1px solid rgba(255,255,255,0.03);\n  }\n  .bucket .slot{\n    width:100%;flex:1;\n    display:flex;align-items:flex-start;justify-content:center;\n    position:relative;\n    padding-top:6px;\n  }\n\n  /* Chain node style */\n  .chain{\n    position:absolute;\n    top:54px;\n    left:100%;\n    display:flex;\n    gap:8px;\n    align-items:center;\n    transform-origin:left center;\n    transition:opacity 400ms ease;\n  }\n  .node{\n    min-width:56px;\n    height:36px;\n    background:linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px;\n    padding:6px 10px;\n    display:flex;align-items:center;justify-content:center;\n    color:var(--soft);\n    font-weight:600;\n    font-size:13px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 24px rgba(2,6,23,0.55);\n    transform:translateY(0);\n  }\n  .node.lead{\n    background:linear-gradient(135deg, rgba(123,92,255,0.18), rgba(0,224,198,0.06));\n    color:white;\n    box-shadow:0 10px 28px rgba(123,92,255,0.12);\n  }\n  .arrow{\n    width:16px;height:12px;\n    display:inline-block;\n    transform:rotate(0.15turn);\n    opacity:0.6;\n  }\n\n  /* Animated key orbs moving into scene */\n  .key-orbs{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    z-index:3;\n  }\n  .orb{\n    position:absolute;\n    width:76px;height:76px;border-radius:18px;\n    display:flex;align-items:center;justify-content:center;\n    color:white;font-weight:700;font-size:18px;\n    box-shadow: 0 18px 54px rgba(2,6,23,0.65);\n    border: 1px solid rgba(255,255,255,0.06);\n    transform:translate3d(0,0,0);\n    transition:transform 700ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease;\n    will-change:transform, opacity;\n    z-index:5;\n  }\n\n  .info{\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  .panel{\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:12px;padding:16px;border:1px solid rgba(255,255,255,0.03);\n  }\n  .controls{\n    display:flex;\n    gap:10px;align-items:center;justify-content:flex-end;\n  }\n  .btn{\n    appearance:none;border:0;padding:10px 14px;border-radius:10px;font-weight:600;\n    color:white;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    box-shadow: 0 8px 30px rgba(123,92,255,0.12);\n    cursor:pointer;\n    transition:transform 160ms ease, box-shadow 160ms ease, opacity 160ms;\n  }\n  .btn.secondary{\n    background:transparent;color:var(--soft);border:1px solid rgba(255,255,255,0.04);\n    box-shadow:none;\n  }\n  .btn:active{transform:translateY(1px)}\n  .btn[disabled]{opacity:0.5;cursor:default; transform:none}\n\n  .formula{\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n    font-size:13px;color:var(--soft);\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);\n  }\n  .small{\n    font-size:13px;color:var(--soft);\n  }\n\n  /* Footer legend */\n  .legend{\n    margin-top:14px;\n    display:flex;gap:12px;align-items:center;flex-wrap:wrap;\n  }\n  .legend .item{\n    display:flex;gap:8px;align-items:center;color:var(--soft);\n    font-size:13px;\n  }\n  .legend .dot{\n    width:14px;height:14px;border-radius:4px;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    box-shadow: 0 6px 18px rgba(123,92,255,0.12);\n  }\n\n  /* subtle tails and guides */\n  .guide{\n    position:absolute;left:50%;top:0;bottom:0;width:2px;\n    transform:translateX(-50%);\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent 40%);\n    pointer-events:none;opacity:0.06;\n  }\n\n  /* Responsiveness */\n  @media (max-width:980px){\n    .card{grid-template-columns:1fr; padding:20px;}\n    .visual{min-height:420px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"floating-shapes\" aria-hidden=\"true\">\n    <div class=\"blob v1\"></div>\n    <div class=\"blob v2\"></div>\n  </div>\n\n  <main class=\"card\" role=\"main\" aria-label=\"Hash Table visualization\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <div class=\"logo\">HT</div>\n        <div class=\"hgroup\">\n          <h1>Hash Table</h1>\n          <p>Visualizing hashing (h(k) = k mod 11) and chaining collision resolution</p>\n        </div>\n      </div>\n      <div class=\"controls\">\n        <button id=\"animateBtn\" class=\"btn\">Animate Insertions</button>\n        <button id=\"resetBtn\" class=\"btn secondary\">Reset</button>\n      </div>\n    </div>\n\n    <section class=\"visual\" aria-hidden=\"false\">\n      <div class=\"table-area\" id=\"visualRoot\">\n        <!-- Buckets -->\n        <div style=\"width:100%;display:flex;justify-content:center;\">\n          <div class=\"buckets\" id=\"bucketsRow\" aria-hidden=\"true\"></div>\n        </div>\n        <!-- center labels and legend -->\n        <div style=\"width:86%;display:flex;justify-content:space-between;align-items:center;margin-top:6px;\">\n          <div class=\"small\" style=\"color:var(--soft)\">\n            Bucket indices 0 — 10. Keys animated into their bucket (chaining shown as nodes to the right).\n          </div>\n          <div class=\"legend\">\n            <div class=\"item\"><span class=\"dot\" style=\"width:16px;height:16px;border-radius:6px\"></span> Incoming keys</div>\n            <div class=\"item\"><svg width=\"18\" height=\"12\" viewBox=\"0 0 24 24\" class=\"item\" style=\"opacity:0.7\"><path fill=\"currentColor\" d=\"M10 17l5-5-5-5v10z\"/></svg> Chain pointer</div>\n          </div>\n        </div>\n\n        <!-- Moving orbs container -->\n        <div class=\"key-orbs\" id=\"orbsLayer\" aria-hidden=\"true\"></div>\n\n        <!-- subtle guide -->\n        <div class=\"guide\" aria-hidden=\"true\"></div>\n      </div>\n    </section>\n\n    <aside class=\"info\">\n      <div class=\"panel\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div>\n            <div style=\"font-weight:700;font-size:15px\">Hash Function</div>\n            <div class=\"formula\" style=\"margin-top:10px;\">h(k) = k mod 11</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div style=\"font-size:12px;color:var(--soft)\">Table size</div>\n            <div style=\"font-weight:700;font-size:20px;margin-top:6px\">11</div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px\" class=\"small\">\n          A hash table maps keys to bucket indices using a hash function. When multiple keys map to the same bucket, chaining stores collisions as a linked list (visual nodes).\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div>\n            <div style=\"font-weight:700\">Insertion sequence</div>\n            <div style=\"color:var(--soft);font-size:13px;margin-top:6px\">22, 41, 53, 46, 30, 13, 27, 59</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div style=\"font-weight:700;font-size:13px;color:var(--soft)\">Collisions illustrated</div>\n            <div style=\"font-size:12px;color:var(--soft)\">Chaining</div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:14px;display:flex;gap:8px;justify-content:flex-end;\">\n          <div class=\"small\" style=\"color:var(--soft)\">Tip: Click \"Animate Insertions\" to watch the keys flow into buckets.</div>\n        </div>\n      </div>\n\n    </aside>\n  </main>\n\n<script>\n(function(){\n  // Configuration\n  const TABLE_SIZE = 11;\n  const KEYS = [22, 41, 53, 46, 30, 13, 27, 59];\n  const ORB_COLORS = ['#7B5CFF','#00E0C6','#3AB4FF','#FF7AA2','#FFD166','#8BD3FF','#C792EA','#6BE5A1'];\n  const bucketsRow = document.getElementById('bucketsRow');\n  const orbsLayer = document.getElementById('orbsLayer');\n  const animateBtn = document.getElementById('animateBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Create buckets\n  const buckets = [];\n  for (let i=0;i<TABLE_SIZE;i++){\n    const b = document.createElement('div');\n    b.className = 'bucket';\n    b.dataset.idx = i;\n    b.innerHTML = `<div class=\"idx\">${i}</div><div class=\"slot\"></div>`;\n    bucketsRow.appendChild(b);\n    // create chain container\n    const chain = document.createElement('div');\n    chain.className = 'chain';\n    chain.style.opacity = '0';\n    b.appendChild(chain);\n    buckets.push({el:b, chainEl:chain, nodes:[]});\n  }\n\n  // Utility to compute hash\n  function hash(k){ return ((k % TABLE_SIZE)+TABLE_SIZE)%TABLE_SIZE; }\n\n  // Create orbs for keys (but keep offscreen initially)\n  const orbElements = KEYS.map((k,i)=>{\n    const orb = document.createElement('div');\n    orb.className = 'orb';\n    orb.style.background = `linear-gradient(135deg, ${ORB_COLORS[i%ORB_COLORS.length]}, rgba(255,255,255,0.05))`;\n    orb.style.left = `calc(50% - 40px)`; // start near center-top\n    orb.style.top = `12%`;\n    orb.style.opacity = '0';\n    orb.textContent = k;\n    orbsLayer.appendChild(orb);\n    return orb;\n  });\n\n  // Place orbs in initial staggered positions\n  function positionOrbsInitial(){\n    const baseX = window.innerWidth/2;\n    orbElements.forEach((orb,i)=>{\n      const dx = (i - (orbElements.length/2 - 0.5)) * 92;\n      orb.style.transition = 'none';\n      orb.style.transform = `translate3d(${dx}px, ${i*6}px, 0) scale(0.98)`;\n      orb.style.opacity = '0.96';\n      orb.dataset.index = i;\n      // gently introduce\n      requestAnimationFrame(()=> orb.style.transition = 'transform 700ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease');\n    });\n  }\n\n  // Reset visual state\n  function reset(){\n    // clear chain nodes\n    buckets.forEach(b=>{\n      b.nodes = [];\n      b.chainEl.innerHTML = '';\n      b.chainEl.style.opacity = '0';\n    });\n    // reset orbs positions\n    orbElements.forEach((orb,i)=>{\n      orb.style.transition = 'transform 700ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease';\n      orb.style.opacity = '0.96';\n      const dx = (i - (orbElements.length/2 - 0.5)) * 92;\n      orb.style.transform = `translate3d(${dx}px, ${i*6}px, 0) scale(0.98)`;\n      orb.style.left = '';\n      orb.style.top = '';\n      orb.style.position = 'absolute';\n      orb.style.willChange = 'transform';\n      orb.style.pointerEvents = 'none';\n      orb.dataset.placed = 'false';\n      orb.style.zIndex = 5;\n    });\n    animateBtn.disabled = false;\n  }\n\n  // Compute target coordinates for a new node in a bucket's chain\n  function getBucketChainTarget(bucketIndex){\n    const b = buckets[bucketIndex];\n    const rect = b.el.getBoundingClientRect();\n    const parentRect = orbsLayer.getBoundingClientRect();\n    // target position: near the chain container's first child position\n    const chainRect = b.chainEl.getBoundingClientRect();\n    // if chain is empty, place to the immediate right of bucket\n    let x = rect.right - parentRect.left + 12; // offset from left of orbsLayer\n    let y = rect.top - parentRect.top + 54; // near top of bucket\n    // if there are nodes, stack to the right\n    if (b.nodes.length > 0){\n      // compute existing nodes width\n      const last = b.nodes[b.nodes.length-1];\n      const lastRect = last.el.getBoundingClientRect();\n      x = lastRect.right - parentRect.left + 14;\n      y = lastRect.top - parentRect.top;\n    }\n    return {x,y};\n  }\n\n  // Create a chain node element (visual)\n  function createNodeElement(value, lead=false){\n    const node = document.createElement('div');\n    node.className = 'node' + (lead ? ' lead' : '');\n    node.textContent = value;\n    // small arrow to its left (except first, but we will add to chain container)\n    return {el:node, value};\n  }\n\n  // Animate orb to target coordinates and convert to a node attached to bucket chain\n  function animateOrbToBucket(orb, key, bucketIndex, idx){\n    return new Promise(resolve=>{\n      const orbRect = orb.getBoundingClientRect();\n      const parentRect = orbsLayer.getBoundingClientRect();\n      const target = getBucketChainTarget(bucketIndex);\n      // We'll compute a control point for a smooth curve path\n      const startX = orbRect.left - parentRect.left + orbRect.width/2;\n      const startY = orbRect.top - parentRect.top + orbRect.height/2;\n      const endX = target.x + 28; // node center approx\n      const endY = target.y + 18;\n      // create a motion via CSS transform to final translate, but we want an arc -> use translate + rotate\n      const dx = endX - startX;\n      const dy = endY - startY;\n      const midX = startX + dx * 0.5;\n      const midY = Math.min(startY, endY) - 80 - Math.abs(dx)*0.06; // arc height\n      // animate with a requestAnimationFrame timeline\n      const duration = 900;\n      let t0 = null;\n      orb.style.zIndex = 999;\n      orb.style.transition = 'opacity 200ms ease';\n      const anim = (ts)=>{\n        if (!t0) t0 = ts;\n        const elapsed = ts - t0;\n        const p = Math.min(1, elapsed / duration);\n        // quadratic Bezier interpolation\n        const qx = (1-p)*(1-p)*startX + 2*(1-p)*p*midX + p*p*endX;\n        const qy = (1-p)*(1-p)*startY + 2*(1-p)*p*midY + p*p*endY;\n        orb.style.transform = `translate3d(${qx - orbRect.width/2}px, ${qy - orbRect.height/2}px, 0) scale(${1 - 0.05*p})`;\n        if (p < 1) requestAnimationFrame(anim);\n        else {\n          // fade orb into node\n          orb.style.opacity = '0';\n          // create node element at target position inside chain container\n          const node = createNodeElement(key, buckets[bucketIndex].nodes.length===0);\n          const chain = buckets[bucketIndex].chainEl;\n          // append arrow except first\n          if (buckets[bucketIndex].nodes.length > 0){\n            const arrow = document.createElement('svg');\n            arrow.className = 'arrow';\n            arrow.setAttribute('viewBox','0 0 24 24');\n            arrow.innerHTML = '<path fill=\"currentColor\" d=\"M10 17l5-5-5-5v10z\"/>';\n            arrow.style.color = 'rgba(255,255,255,0.12)';\n            chain.appendChild(arrow);\n          }\n          chain.appendChild(node.el);\n          chain.style.opacity = '1';\n          buckets[bucketIndex].nodes.push({el:node.el, value:key});\n          // small pop animation\n          node.el.style.transform = 'translateY(10px)';\n          node.el.style.opacity = '0';\n          setTimeout(()=>{\n            node.el.style.transition = 'transform 280ms cubic-bezier(.2,.9,.2,1), opacity 240ms ease';\n            node.el.style.transform = 'translateY(0)';\n            node.el.style.opacity = '1';\n          },20);\n          setTimeout(()=> resolve(), 280);\n        }\n      };\n      requestAnimationFrame(anim);\n    });\n  }\n\n  // Main animation sequence\n  async function runAnimation(){\n    animateBtn.disabled = true;\n    resetBtn.disabled = true;\n    // place initial orbs\n    positionOrbsInitial();\n    await new Promise(r=>setTimeout(r,300));\n    for (let i=0;i<KEYS.length;i++){\n      const key = KEYS[i];\n      const orb = orbElements[i];\n      // compute hash and highlight bucket\n      const idx = hash(key);\n      // small pulse on target bucket\n      const bucketEl = buckets[idx].el;\n      bucketEl.style.transition = 'box-shadow 260ms ease, transform 260ms ease';\n      bucketEl.style.boxShadow = '0 12px 40px rgba(123,92,255,0.12)';\n      bucketEl.style.transform = 'translateY(-6px)';\n      await new Promise(r=>setTimeout(r,220));\n      // animate orb into bucket chain\n      await animateOrbToBucket(orb, key, idx, i);\n      // restore bucket style\n      bucketEl.style.transform = '';\n      bucketEl.style.boxShadow = '';\n      await new Promise(r=>setTimeout(r,240));\n    }\n    resetBtn.disabled = false;\n    animateBtn.disabled = true;\n  }\n\n  // Event bindings\n  animateBtn.addEventListener('click', ()=> runAnimation());\n  resetBtn.addEventListener('click', ()=> {\n    animateBtn.disabled = false;\n    resetBtn.disabled = false;\n    // remove all nodes, bring orbs back\n    reset();\n  });\n\n  // Initialize positions on load / resize\n  window.addEventListener('resize', ()=> positionOrbsInitial());\n  // prepare initial state\n  reset();\n\n  // Subtle entrance animation for card elements\n  requestAnimationFrame(()=>{\n    document.querySelectorAll('.bucket').forEach((b,i)=>{\n      b.style.opacity = '0';\n      b.style.transform = 'translateY(10px) scale(.995)';\n      setTimeout(()=>{ b.style.transition = 'transform 420ms cubic-bezier(.2,.9,.2,1), opacity 420ms ease'; b.style.opacity = '1'; b.style.transform = ''; }, 40 + i*20);\n    });\n  });\n\n  // Accessibility: keyboard activation\n  animateBtn.addEventListener('keyup', (e)=>{ if(e.key==='Enter' || e.key===' ') runAnimation(); });\n  resetBtn.addEventListener('keyup', (e)=>{ if(e.key==='Enter' || e.key===' ') reset(); });\n\n  // Minor floating micro-interactivity: hover shows computed bucket in tooltip (non-intrusive)\n  KEYS.forEach((k,i)=>{\n    const orb = orbElements[i];\n    orb.title = `key ${k} → bucket ${hash(k)}`;\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
