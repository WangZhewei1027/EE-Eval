    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Regression</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n            margin: 0;\n            padding: 0;\n        }\n        \n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .header {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px;\n            text-align: center;\n        }\n        \n        .header h1 {\n            font-size: 24px;\n            margin-bottom: 10px;\n        }\n        \n        .header p {\n            font-size: 18px;\n            margin-bottom: 20px;\n        }\n        \n        .body {\n            padding: 20px;\n        }\n        \n        .chart {\n            background-color: #fff;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .chart h2 {\n            font-size: 18px;\n            margin-bottom: 10px;\n        }\n        \n        .chart p {\n            font-size: 16px;\n            margin-bottom: 20px;\n        }\n        \n        .chart div {\n            font-size: 24px;\n            font-weight: bold;\n            margin-bottom: 10px;\n        }\n        \n        .chart button {\n            padding: 10px 20px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .chart button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Linear Regression</h1>\n            <p>Explore the relationship between two variables using linear regression.</p>\n        </div>\n        <div class=\"body\">\n            <h2>Dataset</h2>\n            <p>Our dataset consists of 1000 observations, with each observation represented by a point on a scatter plot.</p>\n            <div class=\"chart\">\n                <canvas id=\"scatter-chart\"></canvas>\n            </div>\n            <h2>Linear Regression Model</h2>\n            <p>Our linear regression model is a simple linear equation that predicts the value of one variable based on the value of another variable.</p>\n            <div class=\"chart\">\n                <canvas id=\"regression-chart\"></canvas>\n            </div>\n            <h2>Results</h2>\n            <p>Our model has a high R-squared value, indicating a strong positive relationship between the two variables.</p>\n            <div class=\"chart\">\n                <canvas id=\"r-squared-chart\"></canvas>\n            </div>\n            <h2>Interpretation</h2>\n            <p>The slope of the regression line represents the change in the dependent variable for a one-unit change in the independent variable, while holding all other variables constant.</p>\n            <div class=\"chart\">\n                <canvas id=\"slope-chart\"></canvas>\n            </div>\n        </div>\n        <div class=\"chart buttons\">\n            <button id=\"plot-button\">Plot Data</button>\n            <button id=\"fit-button\">Fit Model</button>\n        </div>\n    </div>\n\n    <script>\n        // Data\n        let data = {\n            x: [1, 2, 3, 4, 5],\n            y: [2, 3, 5, 7, 11]\n        };\n\n        // Scatter plot\n        const scatterChart = document.getElementById('scatter-chart');\n        const ctx = scatterChart.getContext('2d');\n        ctx.clearRect(0, 0, 400, 400);\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'red';\n        ctx.fill();\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'blue';\n        ctx.fill();\n        for (let i = 0; i < data.x.length; i++) {\n            ctx.beginPath();\n            ctx.arc(data.x[i], data.y[i], 5, 0, 2 * Math.PI);\n            ctx.fillStyle = 'green';\n            ctx.fill();\n        }\n        ctx.strokeStyle = 'black';\n        ctx.stroke();\n        ctx.strokeRect(0, 0, 400, 400);\n\n        // Regression plot\n        const regressionChart = document.getElementById('regression-chart');\n        const ctx = regressionChart.getContext('2d');\n        ctx.clearRect(0, 0, 400, 400);\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'red';\n        ctx.fill();\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'blue';\n        ctx.fill();\n        for (let i = 0; i < data.x.length; i++) {\n            ctx.beginPath();\n            ctx.arc(data.x[i], data.y[i], 5, 0, 2 * Math.PI);\n            ctx.fillStyle = 'green';\n            ctx.fill();\n        }\n        ctx.strokeStyle = 'black';\n        ctx.stroke();\n        ctx.strokeRect(0, 0, 400, 400);\n\n        // R-squared chart\n        const rSquaredChart = document.getElementById('r-squared-chart');\n        const ctx = rSquaredChart.getContext('2d');\n        ctx.clearRect(0, 0, 400, 400);\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'red';\n        ctx.fill();\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'blue';\n        ctx.fill();\n        for (let i = 0; i < data.x.length; i++) {\n            ctx.beginPath();\n            ctx.arc(data.x[i], data.y[i], 5, 0, 2 * Math.PI);\n            ctx.fillStyle = 'green';\n            ctx.fill();\n        }\n        ctx.strokeStyle = 'black';\n        ctx.stroke();\n        ctx.strokeRect(0, 0, 400, 400);\n\n        // Slope chart\n        const slopeChart = document.getElementById('slope-chart');\n        const ctx = slopeChart.getContext('2d');\n        ctx.clearRect(0, 0, 400, 400);\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'red';\n        ctx.fill();\n        ctx.beginPath();\n        ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n        ctx.fillStyle = 'blue';\n        ctx.fill();\n        for (let i = 0; i < data.x.length; i++) {\n            ctx.beginPath();\n            ctx.arc(data.x[i], data.y[i], 5, 0, 2 * Math.PI);\n            ctx.fillStyle = 'green';\n            ctx.fill();\n        }\n        ctx.strokeStyle = 'black';\n        ctx.stroke();\n        ctx.strokeRect(0, 0, 400, 400);\n\n        // Plot button\n        const plotButton = document.getElementById('plot-button');\n        plotButton.addEventListener('click', () => {\n            scatterChart.clear();\n            regressionChart.clear();\n            rSquaredChart.clear();\n            slopeChart.clear();\n            ctx.clearRect(0, 0, 400, 400);\n            ctx.beginPath();\n            ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.beginPath();\n            ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n            ctx.fillStyle = 'blue';\n            ctx.fill();\n            for (let i = 0; i < data.x.length; i++) {\n                ctx.beginPath();\n                ctx.arc(data.x[i], data.y[i], 5, 0, 2 * Math.PI);\n                ctx.fillStyle = 'green';\n                ctx.fill();\n            }\n            ctx.strokeStyle = 'black';\n            ctx.stroke();\n            ctx.strokeRect(0, 0, 400, 400);\n        });\n\n        // Fit button\n        const fitButton = document.getElementById('fit-button');\n        fitButton.addEventListener('click', () => {\n            const x = data.x;\n            const y = data.y;\n            const slope = (y[1] - y[0]) / (x[1] - x[0]);\n            const intercept = y[0] - slope * x[0];\n            console.log(`Slope: ${slope}, Intercept: ${intercept}`);\n        });\n\n        // Plot data button\n        const plotButton = document.getElementById('plot-button');\n        plotButton.addEventListener('click', () => {\n            const x = data.x;\n            const y = data.y;\n            const scatterChart = document.getElementById('scatter-chart');\n            const ctx = scatterChart.getContext('2d');\n            ctx.clearRect(0, 0, 400, 400);\n            ctx.beginPath();\n            ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.beginPath();\n            ctx.arc(200, 200, 100, 0, 2 * Math.PI);\n            ctx.fillStyle = 'blue';\n            ctx.fill();\n            for (let i = 0; i < x.length; i++) {\n                ctx.beginPath();\n                ctx.arc(x[i], y[i], 5, 0, 2 * Math.PI);\n                ctx.fillStyle = 'green';\n                ctx.fill();\n            }\n            ctx.strokeStyle = 'black';\n            ctx.stroke();\n            ctx.strokeRect(0, 0, 400, 400);\n        });\n\n        // Fit model button\n        const fitButton = document.getElementById('fit-button');\n        fitButton.addEventListener('click', () => {\n            const x = data.x;\n            const y = data.y;\n            const slope = (y[1] - y[0]) / (x[1] - x[0]);\n            const intercept = y[0] - slope * x[0];\n            console.log(`Slope: ${slope}, Intercept: ${intercept}`);\n        });\n    </script>\n</body>\n</html>"
