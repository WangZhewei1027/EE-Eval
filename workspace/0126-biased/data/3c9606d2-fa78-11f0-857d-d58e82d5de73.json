    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Multiset • Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Exo+2:wght@400;700&family=Montserrat:wght@400;600&display=swap');\n\n  /* Reset and base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Exo 2', sans-serif;\n    color: #f1f1f1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 3rem 2rem 5rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 3.6rem;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    margin: 0 0 0.4em;\n    background: linear-gradient(90deg, #6dd5fa, #2980b9);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    position: relative;\n    z-index: 2;\n  }\n  h2 {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 1.15rem;\n    color: #a0cde8cc;\n    margin: 0 0 3rem 0;\n    letter-spacing: 0.1em;\n  }\n\n  /* Container for visualization */\n  #container {\n    position: relative;\n    width: min(90vw, 700px);\n    aspect-ratio: 1 / 1;\n    background: radial-gradient(circle at center, #113355 0%, #021f3f 80%);\n    border-radius: 2rem;\n    box-shadow:\n      0 15px 30px rgba(20, 50, 90, 0.6),\n      inset 0 0 60px #1a406c;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    align-content: center;\n    padding: 3rem 3rem 4rem;\n    gap: 2.1rem 2.1rem;\n    user-select: none;\n    transition: box-shadow 0.8s ease;\n  }\n\n  /* Individual element circle */\n  .element {\n    --size: 72px;\n    position: relative;\n    width: var(--size);\n    height: var(--size);\n    border-radius: 50%;\n    background: radial-gradient(\n      circle at 35% 35%,\n      #4a83c1 0%,\n      #0b1b3f 75%\n    );\n    box-shadow:\n      inset 0 6px 8px #88b1ef99,\n      0 6px 15px #1d3f7a88;\n    color: #cde3ff;\n    font-family: 'Exo 2', monospace;\n    font-weight: 700;\n    font-size: 1.45rem;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    cursor: default;\n    backdrop-filter: contrast(160%) brightness(180%) saturate(200%);\n    transition:\n      transform 0.4s cubic-bezier(0.22,1,0.36,1),\n      box-shadow 0.3s ease,\n      background 0.35s ease;\n  }\n  /* subtle shine animation on element circle */\n  .element::before {\n    content: \"\";\n    position: absolute;\n    top: 15%;\n    left: 15%;\n    width: 60%;\n    height: 60%;\n    border-radius: 50%;\n    background: radial-gradient(circle at top left,\n      rgba(255 255 255 / 0.32),\n      transparent 85%);\n    filter: drop-shadow(0 0 3px rgba(150 200 255 / 0.25));\n    transform-origin: center;\n    animation: shineSpin 9s linear infinite;\n  }\n  @keyframes shineSpin {\n    0% { transform: rotate(0deg); }\n    100% { transform: rotate(360deg);}\n  }\n\n  .element:hover {\n    transform: scale(1.15);\n    box-shadow:\n      inset 0 8px 12px #b9d4fecc,\n      0 10px 25px #3e6fdccc;\n    background: radial-gradient(\n      circle at 40% 40%,\n      #7aa9f9 0%,\n      #12315d 85%\n    );\n  }\n  /* label + count stacked inside the circle */\n  .element-inner {\n    text-align: center;\n    line-height: 1.1;\n  }\n  .element-label {\n    font-size: 1.1rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: #d4e3ffdd;\n    mix-blend-mode: screen;\n    user-select: none;\n  }\n  .element-count {\n    font-size: 1.9rem;\n    font-weight: 800;\n    margin-top: -0.18rem;\n    color: #b5d2ff;\n    text-shadow:\n      0 0 4px #73a1fe,\n      0 0 10px #4176ffcc;\n    user-select: none;\n  }\n\n  /* Info text under the container */\n  #info {\n    max-width: 700px;\n    margin-top: 3rem;\n    font-family: 'Exo 2', sans-serif;\n    font-size: 1.1rem;\n    line-height: 1.5;\n    color: #b8d1ffcc;\n    text-align: center;\n    letter-spacing: 0.03em;\n    filter: drop-shadow(0px 0px 2px #040f23aa);\n    user-select: none;\n  }\n\n  /* Button styling */\n  #btnShuffle {\n    margin-top: 4rem;\n    font-family: 'Montserrat', sans-serif;\n    background: linear-gradient(145deg, #2a6cf0, #547de8);\n    border: none;\n    padding: 16px 36px;\n    font-weight: 700;\n    font-size: 1.15rem;\n    color: #e6f0ff;\n    border-radius: 34px;\n    box-shadow:\n      0 5px 12px rgb(48 88 235 / 0.75),\n      inset 0 2px 4px rgb(99 146 244 / 0.85);\n    cursor: pointer;\n    transition:\n      background 0.45s ease,\n      box-shadow 0.35s ease,\n      transform 0.3s cubic-bezier(0.22,1,0.36,1);\n    user-select: none;\n  }\n  #btnShuffle:hover {\n    background: linear-gradient(145deg, #658ef7, #3f69f2);\n    box-shadow:\n      0 9px 20px rgb(80 118 244 / 0.9),\n      inset 0 3px 6px rgb(159 178 255 / 0.95);\n    transform: scale(1.06);\n  }\n  #btnShuffle:active {\n    transform: scale(0.96);\n    box-shadow:\n      0 5px 10px rgb(48 88 235 / 0.8),\n      inset 0 1px 3px rgb(99 146 244 / 0.9);\n  }\n\n  /* Subtle glow background behind container */\n  #container::before {\n    content: \"\";\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 650px;\n    height: 650px;\n    background: radial-gradient(circle, #1f69d1cc 15%, transparent 80%);\n    border-radius: 50%;\n    filter: blur(64px);\n    transform: translate(-50%, -50%);\n    z-index: 0;\n    pointer-events: none;\n  }\n\n  /* Tooltip for each element */\n  .tooltip {\n    position: absolute;\n    background: #0c1a38dd;\n    border-radius: 0.38rem;\n    padding: 0.3rem 0.7rem;\n    font-size: 0.88rem;\n    font-weight: 600;\n    user-select: none;\n    pointer-events: none;\n    color: #9cbaffee;\n    backdrop-filter: blur(4px);\n    box-shadow:\n      0 0 8px #2e53a9cc,\n      inset 0 0 4px #3c6dcb88;\n    opacity: 0;\n    transition: opacity 0.26s ease;\n    z-index: 5;\n    white-space: nowrap;\n  }\n  .element:hover .tooltip {\n    opacity: 1;\n  }\n\n  /* Responsive text scaling */\n  @media (max-width:520px) {\n    h1 {\n      font-size: 2.8rem;\n    }\n    .element {\n      --size: 56px;\n      font-size: 1rem;\n    }\n    .element-count {\n      font-size: 1.4rem;\n    }\n  }\n</style>\n</head>\n<body>\n\n<h1>Multiset</h1>\n<h2>Visualizing Counting & Multiplicities</h2>\n\n<div id=\"container\" aria-label=\"Multiset visualization\" role=\"region\" tabindex=\"0\" aria-live=\"polite\">\n  <!-- Elements will be injected here -->\n</div>\n\n<button id=\"btnShuffle\" aria-label=\"Shuffle Elements\">Shuffle Elements</button>\n\n<div id=\"info\" aria-live=\"polite\">\n  A <strong>multiset</strong> is like a set, but allows multiple occurrences of elements. Each circle represents an element with its <em>multiplicity</em>, showing how many times it appears.\n</div>\n\n<script>\n  (() => {\n    // Multiset data: element label => count\n    const multisetData = [\n      { label: 'A', count: 4 },\n      { label: 'B', count: 2 },\n      { label: 'C', count: 1 },\n      { label: 'D', count: 3 },\n      { label: 'E', count: 5 },\n      { label: 'F', count: 2 },\n      { label: 'G', count: 1 },\n      { label: 'H', count: 3 },\n    ];\n\n    const container = document.getElementById('container');\n\n    function createElementCircle({ label, count }) {\n      const el = document.createElement('div');\n      el.className = 'element';\n      el.setAttribute('tabindex', '0');\n      el.setAttribute('aria-label', `${label} appears ${count} times`);\n\n      // Inner content container\n      const inner = document.createElement('div');\n      inner.className = 'element-inner';\n\n      const labelSpan = document.createElement('span');\n      labelSpan.className = 'element-label';\n      labelSpan.textContent = label;\n\n      const countSpan = document.createElement('span');\n      countSpan.className = 'element-count';\n      countSpan.textContent = count;\n\n      // Tooltip\n      const tooltip = document.createElement('span');\n      tooltip.className = 'tooltip';\n      tooltip.textContent = `Multiplicity: ${count}`;\n\n      inner.appendChild(labelSpan);\n      inner.appendChild(countSpan);\n      el.appendChild(inner);\n      el.appendChild(tooltip);\n      return el;\n    }\n\n    // Render all elements\n    function renderElements(data) {\n      container.innerHTML = '';\n      data.forEach(d => {\n        const el = createElementCircle(d);\n        container.appendChild(el);\n      });\n    }\n\n    // Shuffle utility\n    function shuffleArray(arr) {\n      let a = arr.slice();\n      for (let i = a.length - 1; i > 0; i--) {\n        const j = Math.floor(Math.random() * (i + 1));\n        [a[i], a[j]] = [a[j], a[i]];\n      }\n      return a;\n    }\n\n    // Animate shuffle by fade out and fade in with new order\n    function shuffleVisual() {\n      container.style.transition = 'opacity 0.5s ease';\n      container.style.opacity = '0';\n      setTimeout(() => {\n        const shuffled = shuffleArray(multisetData);\n        renderElements(shuffled);\n        container.style.opacity = '1';\n      }, 520);\n    }\n\n    // Initial render\n    renderElements(multisetData);\n\n    // Bind button\n    const btnShuffle = document.getElementById('btnShuffle');\n    btnShuffle.addEventListener('click', () => {\n      btnShuffle.disabled = true;\n      shuffleVisual();\n      setTimeout(() => {\n        btnShuffle.disabled = false;\n      }, 700);\n    });\n  })();\n</script>\n\n</body>\n</html>"
