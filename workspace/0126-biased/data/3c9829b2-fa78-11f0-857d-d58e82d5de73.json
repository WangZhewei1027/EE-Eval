    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Recursion | Visual Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Roboto+Slab:wght@300;600&display=swap');\n\n  /* Reset */\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  /* Colors */\n  :root {\n    --deep-indigo: #2e1a47;\n    --violet-light: #a48be8;\n    --violet-mid: #735fcf;\n    --violet-dark: #482d7d;\n    --accent: #ffc857;\n    --bg-dark: #11101d;\n    --text-light: #f5f3f7;\n    --shadow-glow: rgba(255, 200, 87, 0.25);\n  }\n\n  body {\n    background: var(--bg-dark);\n    font-family: 'Roboto Slab', serif;\n    color: var(--text-light);\n    overflow: hidden;\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    user-select: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    padding: 2rem;\n    text-align: center;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.8rem;\n    letter-spacing: 0.15em;\n    color: var(--accent);\n    text-shadow:\n      0 0 8px var(--accent),\n      0 0 16px var(--accent),\n      0 0 24px var(--accent);\n    margin-bottom: 0.2em;\n    user-select: text;\n  }\n\n  h2 {\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: var(--violet-light);\n    margin-bottom: 3rem;\n    font-style: italic;\n    text-shadow: 0 0 8px var(--violet-mid);\n  }\n\n  /* Container for recursion spiral */\n  #recursion-container {\n    position: relative;\n    width: 420px;\n    height: 420px;\n    filter:\n      drop-shadow(0 0 8px var(--violet-mid))\n      drop-shadow(0 0 12px var(--accent));\n    user-select: none;\n  }\n\n  svg {\n    display: block;\n    width: 100%;\n    height: 100%;\n  }\n\n  /* Recursive