    user-select: none;\n  }\n  button:hover, button:focus {\n    background: linear-gradient(145deg, #fbde79, #d4b23f);\n    box-shadow:\n      0 0 18px var(--accent),\n      inset 0 0 20px #ffda78;\n    outline: none;\n  }\n\n  /* Footer highlight with subtle recursion symbol */\n  footer {\n    font-family: 'Roboto Slab', serif;\n    font-size: 0.9rem;\n    color: var(--violet-mid);\n    margin-top: 3.8rem;\n    opacity: 0.75;\n    user-select: none;\n    letter-spacing: 0.06em;\n  }\n\n  /* Blink subtle \"exceptional\" accent */\n  #exceptional {\n    color: var(--accent);\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    animation: pulseAccent 3.8s ease-in-out infinite;\n  }\n  @keyframes pulseAccent {\n    0%, 100% { text-shadow: 0 0 20px var(--accent); }\n    50% { text-shadow: 0 0 40px #fff1b6; }\n  }\n\n  /* Responsive scaling */\n  @media (max-width: 480px) {\n    #recursion-container {\n      width: 90vw;\n      height: 90vw;\n    }\n    h1 {\n      font-size: 2.7rem;\n    }\n    h2 {\n      font-size: 1rem;\n    }\n  }\n</style>\n</head>\n<body>\n\n  <h1>RECURSION</h1>\n  <h2>Visualizing infinity through iterative echoes</h2>\n\n  <div id=\"recursion-container\" aria-label=\"Recursive spiraling circles animation\" role=\"img\" tabindex=\"0\">\n    <svg viewBox=\"0 0 420 420\" aria-hidden=\"true\" focusable=\"false\" >\n      <defs>\n        <radialGradient id=\"gradient\" cx=\"50%\" cy=\"50%\" r=\"70%\">\n          <stop offset=\"0%\" stop-color=\"var(--accent)\" stop-opacity=\"1\"/>\n          <stop offset=\"50%\" stop-color=\"var(--violet-mid)\" stop-opacity=\"0.6\"/>\n          <stop offset=\"100%\" stop-color=\"var(--violet-dark)\" stop-opacity=\"0.15\"/>\n        </radialGradient>\n      </defs>\n\n      <!-- Recursive circles -->\n\n      <!-- We will create nested circles decreasing in size and offset -->\n      <!-- Each circle is offset by rotation and scaling to simulate recursion -->\n\n      <g id=\"recursiveGroup\" transform=\"translate(210 210)\">\n        <!-- JavaScript will generate circles inside this group -->\n      </g>\n    </svg>\n  </div>\n\n  <div id=\"controls\" aria-label=\"Recursion controls\">\n    <button id=\"toggleAnimation\" aria-pressed=\"true\" aria-label=\"Pause recursion animation\">Pause</button>\n    <button id=\"resetAnimation\" aria-label=\"Reset recursion animation\">Reset</button>\n  </div>\n\n  <footer>\n    <span>Experience the </span><span id=\"exceptional\">EXCEPTIONAL</span><span> beauty of recursion — where patterns echo infinitely.</span>\n  </footer>\n\n<script>\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const group = document.getElementById('recursiveGroup');\n\n  // Parameters for recursion visuals\n  const baseRadius = 190; // max radius of largest circle\n  const minRadius = 30;   // smallest circle radius\n  const recursionCount = 8; // number of circles to draw (depth)\n\n  // Function to create circles and apply recursion-like scaling + rotation\n  function createRecursiveCircles() {\n    // Clear existing circles\n    while (group.firstChild) group.removeChild(group.firstChild);\n\n    // Recursion-like fractal scaling factor\n    const scaleStep = 0.72;\n    let currentScale = 1;\n\n    for(let i = 0; i < recursionCount; i++) {\n      const r = baseRadius * currentScale;\n      const circle = document.createElementNS(svgNS, 'circle');\n\n      circle.setAttribute('cx', 0);\n      circle.setAttribute('cy', 0);\n      circle.setAttribute('r', r);\n      circle.classList.add('recursive');\n\n      // Each circle rotated by i*20 degrees for a gentle swirl\n      const rotate = i * 20;\n\n      circle.style.transformOrigin = '0px 0px'; // Center of group\n      circle.style.transformBox = 'fill-box';\n\n      // Apply transform: rotate + scale to simulate recursive spiral\n      circle.style.transform = `rotate(${rotate}deg)`;\n      circle.style.animationDelay = `${i * 0.5}s`;\n\n      group.appendChild(circle);\n\n      currentScale *= scaleStep;\n      if (r * scaleStep < minRadius) break;\n    }\n  }\n\n  createRecursiveCircles();\n\n  // Animation control buttons\n  const toggleBtn = document.getElementById('toggleAnimation');\n  const resetBtn = document.getElementById('resetAnimation');\n\n  let animationRunning = true;\n\n  toggleBtn.addEventListener('click', () => {\n    animationRunning = !animationRunning;\n    const circles = group.querySelectorAll('circle.recursive');\n\n    if(animationRunning) {\n      circles.forEach(c => c.style.animationPlayState = 'running');\n      toggleBtn.textContent = 'Pause';\n      toggleBtn.setAttribute('aria-pressed', 'true');\n      toggleBtn.setAttribute('aria-label', 'Pause recursion animation');\n    } else {\n      circles.forEach(c => c.style.animationPlayState = 'paused');\n      toggleBtn.textContent = 'Play';\n      toggleBtn.setAttribute('aria-pressed', 'false');\n      toggleBtn.setAttribute('aria-label', 'Play recursion animation');\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    // Reset animation by forcing reflow\n    const circles = group.querySelectorAll('circle.recursive');\n    circles.forEach(c => {\n      c.style.animation = 'none';\n      void c.offsetWidth; // trigger reflow\n      c.style.animation = '';\n    });\n  });\n\n  // Initialize animation state (running)\n  toggleBtn.click(); // Toggle once to ensure proper ARIA, then toggle back\n  toggleBtn.click();\n\n</script>\n\n</body>\n</html>"
