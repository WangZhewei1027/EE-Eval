  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Priority Queue Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace, monospace;\n  }\n  input[type=number] {\n    width: 70px;\n  }\n  table, th, td {\n    border: 1px solid black;\n    border-collapse: collapse;\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  th, td {\n    padding: 2px 5px;\n    text-align: center;\n  }\n  #log {\n    width: 100%;\n    height: 180px;\n    font-family: monospace, monospace;\n    overflow-y: scroll;\n  }\n  section {\n    margin-bottom: 20px;\n  }\n  small {\n    font-style: italic;\n  }\n  button:disabled {\n    color: #aaa;\n  }\n</style>\n</head>\n<body>\n<h1>Priority Queue Interactive Demo</h1>\n<p><strong>Concept: Priority Queue</strong></p>\n\n<section aria-label=\"Priority queue selection and implementation control\">\n  <h2>Implementation Selection</h2>\n  <p>\n    Select the underlying implementation of the priority queue:\n  </p>\n  <label><input type=\"radio\" name=\"impl\" value=\"binaryHeap\" checked> Binary Heap (default)</label><br>\n  <label><input type=\"radio\" name=\"impl\" value=\"sortedArray\"> Sorted Array</label><br>\n  <label><input type=\"radio\" name=\"impl\" value=\"unsortedArray\"> Unsorted Array</label><br>\n  <label><input type=\"radio\" name=\"impl\" value=\"linkedList\"> Linked List (sorted)</label><br>\n  <button id=\"resetQueueBtn\">Reset / Clear Queue</button>\n  <p><small>Changing the implementation or resetting clears the queue.</small></p>\n</section>\n\n<section aria-label=\"Add elements to priority queue\">\n  <h2>Insert Elements</h2>\n  <p>\n    Insert one or multiple elements into the queue. Format: <code>value,priority</code><br>\n    Example: <code>task1,7</code> or multiple lines with one per element.\n  </p>\n  <textarea id=\"insertArea\" aria-label=\"Insert elements with value and priority\"></textarea><br />\n  <label for=\"defaultPriority\">Default priority if missing or invalid:</label>\n  <input type=\"number\" id=\"defaultPriority\" value=\"0\" step=\"1\" />\n  <button id=\"insertBtn\">Insert</button>\n  <button id=\"bulkRandomBtn\">Insert 10 Random Elements</button><br />\n  <small>Priority: higher numeric value = higher priority</small>\n</section>\n\n<section aria-label=\"Remove elements from priority queue\">\n  <h2>Remove Elements</h2>\n  <button id=\"extractMaxBtn\">Extract Max</button>\n  <button id=\"peekMaxBtn\">Peek Max</button>\n  <button id=\"clearQueueBtn\">Clear All</button><br />\n  <small>\n    Extract Max: removes and returns the element with highest priority<br />\n    Peek Max: returns without removing<br />\n    Clear All: empties the queue\n  </small>\n</section>\n\n<section aria-label=\"View and manipulate queue contents\">\n  <h2>Queue Contents & Operations</h2>\n  <button id=\"printQueueBtn\">Print All Elements (sorted by priority desc)</button>\n  <button id=\"printInternalBtn\">Print Internal Data Structure</button>\n  <button id=\"validateBtn\">Validate Queue Properties</button>\n  <button id=\"incrementPrioritiesBtn\">Increment All Priorities by 1</button>\n  <button id=\"decrementPrioritiesBtn\">Decrement All Priorities by 1</button><br />\n  <label for=\"changePriorityValue\">Change Priority of Value:</label>\n  <input type=\"text\" id=\"changePriorityValue\" aria-label=\"Value to change priority\" />\n  <label for=\"newPriority\">New Priority:</label>\n  <input type=\"number\" id=\"newPriority\" aria-label=\"New priority\" />\n  <button id=\"changePriorityBtn\">Change Priority</button><br />\n  <label for=\"removeByValueInput\">Remove By Value:</label>\n  <input type=\"text\" id=\"removeByValueInput\" aria-label=\"Value to remove\" />\n  <button id=\"removeByValueBtn\">Remove</button><br />\n  <small>\n    Changing priority or removing by value operates on the first matching value.<br />\n    Increment/Decrement adjust all priorities.<br />\n    Internal Data Structure print shows implementation-specific details.\n  </small>\n</section>\n\n<section aria-label=\"Bulk / advanced queue operations\">\n  <h2>Bulk & Advanced Operations</h2>\n  <label for=\"bulkInsertTxt\">Bulk Insert Random Elements:</label>\n  <input type=\"number\" id=\"bulkInsertCount\" value=\"100\" min=\"1\" max=\"10000\" aria-label=\"Number of random elements to insert\" />\n  <button id=\"bulkInsertStartBtn\">Bulk Insert</button>\n  <button id=\"bulkBenchmarkBtn\">Benchmark Insert & Extract Max (1000 items)</button><br />\n  <label for=\"searchValueInput\">Search by Value:</label>\n  <input type=\"text\" id=\"searchValueInput\" aria-label=\"Search value\" />\n  <button id=\"searchBtn\">Search</button>\n  <button id=\"searchHighlightBtn\">Highlight Matches</button><br />\n  <button id=\"exportJsonBtn\">Export Queue to JSON</button>\n  <button id=\"importJsonBtn\">Import Queue from JSON</button><br />\n  <textarea id=\"jsonArea\" placeholder=\"Paste JSON here to import or see export output\" aria-label=\"JSON import/export area\"></textarea>\n  <p><small>\n    Bulk insert and benchmark facilitate testing performance.<br />\n    Search finds all items with matching value.<br />\n    Export/import queue state for saving/loading.\n  </small></p>\n</section>\n\n<section aria-label=\"Output log and messages\">\n  <h2>Log / Output</h2>\n  <textarea id=\"log\" readonly></textarea>\n</section>\n\n<script>\n(() => {\n  // Priority queue implementations\n\n  // Element: {value: string, priority: number, insertCount: number}\n  // insertCount to resolve ties consistently (FIFO for equal priority)\n  // Higher priority number = higher priority.\n\n  let globalInsertCounter = 0;\n\n  // PriorityQueue Interface:\n  // insert(el): void\n  // extractMax(): element or null\n  // peekMax(): element or null\n  // size(): number\n  // clear(): void\n  // toArray(): array of elements sorted descending priority\n  // validate(): returns {valid:bool, message:string}\n  // incrementAll(delta): void\n  // changePriority(value, newPriority): bool (changed first one)\n  // removeByValue(value): bool (removed first one)\n  // printInternal(): string describing internal structure\n  // search(value): array of matching elements (by value)\n\n  class BinaryHeapPQ {\n    constructor() {\n      this.heap = [];\n    }\n\n    size() {\n      return this.heap.length;\n    }\n\n    clear() {\n      this.heap = [];\n    }\n\n    insert(el) {\n      this.heap.push(el);\n      this._siftUp(this.heap.length - 1);\n    }\n\n    peekMax() {\n      return this.heap.length ? this.heap[0] : null;\n    }\n\n    extractMax() {\n      if (!this.heap.length) return null;\n      const max = this.heap[0];\n      const end = this.heap.pop();\n      if (this.heap.length) {\n        this.heap[0] = end;\n        this._siftDown(0);\n      }\n      return max;\n    }\n\n    toArray() {\n      // Return a sorted copy descending by priority, tiebreak by insertCount asc\n      return [...this.heap].sort((a,b) => {\n        if(b.priority !== a.priority) return b.priority - a.priority;\n        return a.insertCount - b.insertCount;\n      });\n    }\n\n    _parent(i) { return Math.floor((i-1)/2);}\n    _left(i) { return i*2 +1;}\n    _right(i) {return i*2 +2;}\n\n    _compare(a,b) {\n      // a,b: elements; returns true if a has higher priority than b\n      if (a.priority !== b.priority) return a.priority > b.priority;\n      // Equal priority: earlier inserted higher priority (so lower insertCount)\n      return a.insertCount < b.insertCount;\n    }\n\n    _siftUp(i){\n      let current = i;\n      while(current > 0){\n        let p = this._parent(current);\n        if(this._compare(this.heap[current], this.heap[p])){\n          [this.heap[current], this.heap[p]] = [this.heap[p], this.heap[current]];\n          current = p;\n        } else {\n          break;\n        }\n      }\n    }\n\n    _siftDown(i){\n      let current = i;\n      const n = this.heap.length;\n      while(true){\n        let left = this._left(current);\n        let right = this._right(current);\n        let largest = current;\n        if(left < n && this._compare(this.heap[left], this.heap[largest])) largest = left;\n        if(right < n && this._compare(this.heap[right], this.heap[largest])) largest = right;\n        if(largest !== current){\n          [this.heap[current], this.heap[largest]] = [this.heap[largest], this.heap[current]];\n          current = largest;\n        } else {\n          break;\n        }\n      }\n    }\n\n    validate() {\n      // Check heap property holds for every node\n      for(let i=1; i<this.heap.length; i++){\n        let p = this._parent(i);\n        if(!this._compare(this.heap[p], this.heap[i]) && this.heap[p].priority !== this.heap[i].priority){\n          return {valid:false, message:`Heap property violated between parent index ${p} and child index ${i}`};\n        }\n      }\n      return {valid:true, message:\"Valid binary max-heap\"};\n    }\n\n    incrementAll(delta){\n      for(let el of this.heap){\n        el.priority += delta;\n      }\n      this._rebuildHeap();\n    }\n\n    _rebuildHeap(){\n      for(let i = Math.floor(this.heap.length/2) -1; i>=0; i--){\n        this._siftDown(i);\n      }\n    }\n\n    changePriority(value, newPriority){\n      for(let i=0; i<this.heap.length; i++){\n        if(this.heap[i].value === value){\n          this.heap[i].priority = newPriority;\n          this._rebuildHeap();\n          return true;\n        }\n      }\n      return false;\n    }\n\n    removeByValue(value){\n      for(let i=0; i<this.heap.length; i++){\n        if(this.heap[i].value === value){\n          let end = this.heap.pop();\n          if(i === this.heap.length) return true;\n          this.heap[i] = end;\n          this._rebuildHeap();\n          return true;\n        }\n      }\n      return false;\n    }\n\n    printInternal(){\n      // Show heap array indices, priorities, values\n      let lines = [\"Index | Priority | Insert# | Value\", \"------------------------------\"];\n      for(let i=0; i<this.heap.length; i++){\n        let el = this.heap[i];\n        lines.push(`${i.toString().padStart(5)} | ${el.priority.toString().padStart(8)} | ${el.insertCount.toString().padStart(7)} | ${el.value}`);\n      }\n      return lines.join(\"\\n\");\n    }\n\n    search(value){\n      return this.heap.filter(el => el.value.includes(value));\n    }\n  }\n\n  class SortedArrayPQ {\n    constructor() {\n      this.arr = [];\n    }\n\n    size() {\n      return this.arr.length;\n    }\n\n    clear() {\n      this.arr = [];\n    }\n\n    insert(el) {\n      // Insert by descending priority order; stable by insertCount ascending\n      let i=0;\n      while(i<this.arr.length && (this.arr[i].priority > el.priority || (this.arr[i].priority === el.priority && this.arr[i].insertCount < el.insertCount))){\n        i++;\n      }\n      this.arr.splice(i, 0, el);\n    }\n\n    peekMax() {\n      return this.arr.length ? this.arr[0] : null;\n    }\n\n    extractMax() {\n      return this.arr.shift() || null;\n    }\n\n    toArray() {\n      return [...this.arr];\n    }\n\n    validate() {\n      for(let i=1; i<this.arr.length; i++){\n        if(this.arr[i-1].priority < this.arr[i].priority) return {valid:false, message:`Sorted array order violation at index ${i-1} and ${i}`};\n        if(this.arr[i-1].priority === this.arr[i].priority && this.arr[i-1].insertCount > this.arr[i].insertCount) return {valid:false, message:`InsertCount order violation at index ${i-1} and ${i}`};\n      }\n      return {valid:true, message:\"Valid sorted array descending by priority\"};\n    }\n\n    incrementAll(delta){\n      for(let el of this.arr){\n        el.priority += delta;\n      }\n      this.arr.sort((a,b) => {\n        if(b.priority !== a.priority) return b.priority - a.priority;\n        return a.insertCount - b.insertCount;\n      });\n    }\n\n    changePriority(value, newPriority){\n      for(let i=0; i<this.arr.length; i++){\n        if(this.arr[i].value === value){\n          this.arr[i].priority = newPriority;\n          this.arr.sort((a,b) => {\n            if(b.priority !== a.priority) return b.priority - a.priority;\n            return a.insertCount - b.insertCount;\n          });\n          return true;\n        }\n      }\n      return false;\n    }\n\n    removeByValue(value){\n      let i = this.arr.findIndex(el => el.value === value);\n      if(i>=0){\n        this.arr.splice(i,1);\n        return true;\n      }\n      return false;\n    }\n\n    printInternal(){\n      let lines = [\"Index | Priority | Insert# | Value\", \"------------------------------\"];\n      for(let i=0; i<this.arr.length; i++){\n        let el = this.arr[i];\n        lines.push(`${i.toString().padStart(5)} | ${el.priority.toString().padStart(8)} | ${el.insertCount.toString().padStart(7)} | ${el.value}`);\n      }\n      return lines.join(\"\\n\");\n    }\n\n    search(value){\n      return this.arr.filter(el => el.value.includes(value));\n    }\n  }\n\n  class UnsortedArrayPQ {\n    constructor() {\n      this.arr = [];\n    }\n\n    size() {\n      return this.arr.length;\n    }\n\n    clear() {\n      this.arr = [];\n    }\n\n    insert(el) {\n      this.arr.push(el);\n    }\n\n    peekMax() {\n      if(this.arr.length === 0) return null;\n      return this.arr.reduce((max,el)=>{\n        if(el.priority > max.priority) return el;\n        if(el.priority === max.priority && el.insertCount < max.insertCount) return el;\n        return max;\n      }, this.arr[0]);\n    }\n\n    extractMax() {\n      if(this.arr.length === 0) return null;\n      let maxIndex = 0;\n      for(let i=1; i<this.arr.length; i++){\n        let el = this.arr[i];\n        let max = this.arr[maxIndex];\n        if(el.priority > max.priority) maxIndex = i;\n        else if(el.priority === max.priority && el.insertCount < max.insertCount) maxIndex = i;\n      }\n      return this.arr.splice(maxIndex,1)[0];\n    }\n\n    toArray() {\n      // Sort descending priority to show all\n      return [...this.arr].sort((a,b)=>{\n        if(b.priority !== a.priority) return b.priority - a.priority;\n        return a.insertCount - b.insertCount;\n      });\n    }\n\n    validate() {\n      // No internal ordering required\n      return {valid:true, message:\"Unsorted array - no internal order to validate\"};\n    }\n\n    incrementAll(delta){\n      for(let el of this.arr) el.priority += delta;\n    }\n\n    changePriority(value, newPriority){\n      for(let i=0; i<this.arr.length; i++){\n        if(this.arr[i].value === value){\n          this.arr[i].priority = newPriority;\n          return true;\n        }\n      }\n      return false;\n    }\n\n    removeByValue(value){\n      let i = this.arr.findIndex(el => el.value === value);\n      if(i>=0){\n        this.arr.splice(i,1);\n        return true;\n      }\n      return false;\n    }\n\n    printInternal(){\n      let lines = [\"Index | Priority | Insert# | Value\", \"------------------------------\"];\n      for(let i=0; i<this.arr.length; i++){\n        let el = this.arr[i];\n        lines.push(`${i.toString().padStart(5)} | ${el.priority.toString().padStart(8)} | ${el.insertCount.toString().padStart(7)} | ${el.value}`);\n      }\n      return lines.join(\"\\n\");\n    }\n\n    search(value){\n      return this.arr.filter(el => el.value.includes(value));\n    }\n  }\n\n  class LinkedListPQNode {\n    constructor(el, next = null) {\n      this.el = el;\n      this.next = next;\n    }\n  }\n\n  class LinkedListPQ {\n    constructor() {\n      // keep linked list sorted descending priority\n      this.head = null;\n      this._size = 0;\n    }\n\n    size() {\n      return this._size;\n    }\n\n    clear() {\n      this.head = null;\n      this._size = 0;\n    }\n\n    insert(el) {\n      let newNode = new LinkedListPQNode(el);\n      if(!this.head){\n        this.head = newNode;\n        this._size++;\n        return;\n      }\n      // insert maintaining descending priority & stable by insertCount\n      if(this._compare(newNode.el, this.head.el)){\n        // newNode higher priority than head\n        newNode.next = this.head;\n        this.head = newNode;\n        this._size++;\n        return;\n      }\n      // find position\n      let current = this.head;\n      while(current.next && (current.next.el.priority > el.priority || (current.next.el.priority === el.priority && current.next.el.insertCount < el.insertCount))){\n        current = current.next;\n      }\n      newNode.next = current.next;\n      current.next = newNode;\n      this._size++;\n    }\n\n    _compare(a,b){\n      if(a.priority !== b.priority) return a.priority > b.priority;\n      return a.insertCount < b.insertCount;\n    }\n\n    peekMax() {\n      return this.head ? this.head.el : null;\n    }\n\n    extractMax() {\n      if(!this.head) return null;\n      const el = this.head.el;\n      this.head = this.head.next;\n      this._size--;\n      return el;\n    }\n\n    toArray() {\n      let arr = [];\n      let current = this.head;\n      while(current){\n        arr.push(current.el);\n        current = current.next;\n      }\n      return arr;\n    }\n\n    validate(){\n      let current = this.head;\n      while(current && current.next){\n        if(current.el.priority < current.next.el.priority) return {valid:false, message:\"Linked list priority order violation\"};\n        if(current.el.priority === current.next.el.priority && current.el.insertCount > current.next.el.insertCount) return {valid:false, message:\"Linked list insertCount order violation\"};\n        current = current.next;\n      }\n      return {valid:true, message:\"Valid linked list sorted descending by priority\"};\n    }\n\n    incrementAll(delta){\n      let current = this.head;\n      while(current){\n        current.el.priority += delta;\n        current = current.next;\n      }\n      this._rebuildList();\n    }\n\n    _rebuildList(){\n      const arr = this.toArray();\n      arr.sort((a,b)=>{\n        if(b.priority !== a.priority) return b.priority - a.priority;\n        return a.insertCount - b.insertCount;\n      });\n      this.clear();\n      for(let el of arr){\n        this.insert(el);\n      }\n    }\n\n    changePriority(value, newPriority){\n      let current = this.head;\n      while(current){\n        if(current.el.value === value){\n          current.el.priority = newPriority;\n          this._rebuildList();\n          return true;\n        }\n        current = current.next;\n      }\n      return false;\n    }\n\n    removeByValue(value){\n      if(!this.head) return false;\n      if(this.head.el.value === value){\n        this.head = this.head.next;\n        this._size--;\n        return true;\n      }\n      let prev = this.head;\n      let current = this.head.next;\n      while(current){\n        if(current.el.value === value){\n          prev.next = current.next;\n          this._size--;\n          return true;\n        }\n        prev = current;\n        current = current.next;\n      }\n      return false;\n    }\n\n    printInternal(){\n      let lines = [\"Index | Priority | Insert# | Value\", \"------------------------------\"];\n      let idx=0;\n      let current = this.head;\n      while(current){\n        let el = current.el;\n        lines.push(`${idx.toString().padStart(5)} | ${el.priority.toString().padStart(8)} | ${el.insertCount.toString().padStart(7)} | ${el.value}`);\n        current = current.next;\n        idx++;\n      }\n      return lines.join(\"\\n\");\n    }\n\n    search(value){\n      let current = this.head;\n      let results = [];\n      while(current){\n        if(current.el.value.includes(value)) results.push(current.el);\n        current = current.next;\n      }\n      return results;\n    }\n  }\n\n  // Main controller and UI integration\n\n  let pq = null;\n  let currentImpl = \"binaryHeap\";\n  const logArea = document.getElementById(\"log\");\n\n  const implRadioButtons = document.querySelectorAll('input[name=\"impl\"]');\n  const resetQueueBtn = document.getElementById(\"resetQueueBtn\");\n  const insertArea = document.getElementById(\"insertArea\");\n  const defaultPriorityInput = document.getElementById(\"defaultPriority\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const bulkRandomBtn = document.getElementById(\"bulkRandomBtn\");\n  const extractMaxBtn = document.getElementById(\"extractMaxBtn\");\n  const peekMaxBtn = document.getElementById(\"peekMaxBtn\");\n  const clearQueueBtn = document.getElementById(\"clearQueueBtn\");\n  const printQueueBtn = document.getElementById(\"printQueueBtn\");\n  const printInternalBtn = document.getElementById(\"printInternalBtn\");\n  const validateBtn = document.getElementById(\"validateBtn\");\n  const incrementPrioritiesBtn = document.getElementById(\"incrementPrioritiesBtn\");\n  const decrementPrioritiesBtn = document.getElementById(\"decrementPrioritiesBtn\");\n  const changePriorityValue = document.getElementById(\"changePriorityValue\");\n  const newPriorityInput = document.getElementById(\"newPriority\");\n  const changePriorityBtn = document.getElementById(\"changePriorityBtn\");\n  const removeByValueInput = document.getElementById(\"removeByValueInput\");\n  const removeByValueBtn = document.getElementById(\"removeByValueBtn\");\n\n  const bulkInsertCountInput = document.getElementById(\"bulkInsertCount\");\n  const bulkInsertStartBtn = document.getElementById(\"bulkInsertStartBtn\");\n  const bulkBenchmarkBtn = document.getElementById(\"bulkBenchmarkBtn\");\n  const searchValueInput = document.getElementById(\"searchValueInput\");\n  const searchBtn = document.getElementById(\"searchBtn\");\n  const searchHighlightBtn = document.getElementById(\"searchHighlightBtn\");\n  const exportJsonBtn = document.getElementById(\"exportJsonBtn\");\n  const importJsonBtn = document.getElementById(\"importJsonBtn\");\n  const jsonArea = document.getElementById(\"jsonArea\");\n\n  function log(msg, isError = false) {\n    const timestamp = new Date().toLocaleTimeString();\n    logArea.value += `[${timestamp}] ${msg}\\n`;\n    logArea.scrollTop = logArea.scrollHeight;\n    if(isError) console.error(msg);\n  }\n\n  function createPQByImpl(impl) {\n    switch(impl){\n      case \"binaryHeap\": return new BinaryHeapPQ();\n      case \"sortedArray\": return new SortedArrayPQ();\n      case \"unsortedArray\": return new UnsortedArrayPQ();\n      case \"linkedList\": return new LinkedListPQ();\n      default: return new BinaryHeapPQ();\n    }\n  }\n\n  function resetPQ(){\n    globalInsertCounter = 0;\n    pq = createPQByImpl(currentImpl);\n    log(`Queue reset using implementation: ${currentImpl}`);\n  }\n\n  function parseInsertLines(text, defaultPriority){\n    let results = [];\n    let lines = text.split(/\\r?\\n/);\n    for(let line of lines){\n      line = line.trim();\n      if(!line) continue;\n      // parse: value,priority\n      let parts = line.split(\",\");\n      let val = parts[0].trim();\n      if(!val){\n        log(`Skipping line due to missing value: \"${line}\"`, true);\n        continue;\n      }\n      let prio = defaultPriority;\n      if(parts.length > 1){\n        let np = Number(parts[1]);\n        if(!isNaN(np)) prio = np;\n      }\n      results.push({value: val, priority: prio});\n    }\n    return results;\n  }\n\n  // Insert elements full routine\n  function insertElements(elements) {\n    for(const el of elements){\n      globalInsertCounter++;\n      pq.insert({value: el.value, priority: el.priority, insertCount: globalInsertCounter});\n    }\n    log(`Inserted ${elements.length} element(s). Queue size: ${pq.size()}`);\n  }\n\n  // Bulk random string generator for value\n  function randomString(length=6){\n    const chars = \"abcdefghijklmnopqrstuvwxyz\";\n    let s=\"\";\n    for(let i=0; i<length; i++){\n      s+= chars.charAt(Math.floor(Math.random()*chars.length));\n    }\n    return s;\n  }\n  function randomPriority(min=-100, max=100){\n    return Math.floor(Math.random()*(max-min+1)+min);\n  }\n\n  // UI event handlers\n\n  resetQueueBtn.addEventListener(\"click\", () => {\n    resetPQ();\n  });\n\n  implRadioButtons.forEach(rb => {\n    rb.addEventListener(\"change\", e => {\n      if(e.target.checked){\n        currentImpl = e.target.value;\n        resetPQ();\n      }\n    });\n  });\n\n  insertBtn.addEventListener(\"click\", () => {\n    let dp = Number(defaultPriorityInput.value);\n    if(isNaN(dp)) dp=0;\n    let els = parseInsertLines(insertArea.value, dp);\n    if(els.length === 0){\n      log(\"No valid elements to insert.\", true);\n      return;\n    }\n    insertElements(els);\n    insertArea.value = \"\";\n  });\n\n  bulkRandomBtn.addEventListener(\"click\", () => {\n    let els = [];\n    for(let i=0; i<10; i++){\n      els.push({value: randomString(), priority: randomPriority()});\n    }\n    insertElements(els);\n  });\n\n  extractMaxBtn.addEventListener(\"click\", () => {\n    let maxEl = pq.extractMax();\n    if(!maxEl){\n      log(\"Queue is empty; nothing extracted.\");\n      return;\n    }\n    log(`Extracted max: Value=\"${maxEl.value}\", Priority=${maxEl.priority}`);\n  });\n\n  peekMaxBtn.addEventListener(\"click\", () => {\n    let maxEl = pq.peekMax();\n    if(!maxEl){\n      log(\"Queue is empty; no max element.\");\n      return;\n    }\n    log(`Peek max: Value=\"${maxEl.value}\", Priority=${maxEl.priority}`);\n  });\n\n  clearQueueBtn.addEventListener(\"click\", () => {\n    pq.clear();\n    log(\"Queue cleared.\");\n  });\n\n  printQueueBtn.addEventListener(\"click\", () => {\n    const arr = pq.toArray();\n    if(arr.length === 0){\n      log(\"Queue is empty.\");\n      return;\n    }\n    let lines = [\"Value | Priority | Insert#\",\"---------------------\"];\n    for(let el of arr){\n      lines.push(`${el.value} | ${el.priority} | ${el.insertCount}`);\n    }\n    log(lines.join(\"\\n\"));\n  });\n\n  printInternalBtn.addEventListener(\"click\", () => {\n    let internalText = pq.printInternal();\n    if(!internalText){\n      log(\"No internal data structure to print.\");\n      return;\n    }\n    log(\"Internal Data Structure:\\n\" + internalText);\n  });\n\n  validateBtn.addEventListener(\"click\", () => {\n    let result = pq.validate();\n    if(result.valid){\n      log(\"Validation successful: \" + result.message);\n    } else {\n      log(\"Validation failed: \" + result.message, true);\n    }\n  });\n\n  incrementPrioritiesBtn.addEventListener(\"click\", () => {\n    pq.incrementAll(1);\n    log(\"Incremented all priorities by 1.\");\n  });\n\n  decrementPrioritiesBtn.addEventListener(\"click\", () => {\n    pq.incrementAll(-1);\n    log(\"Decremented all priorities by 1.\");\n  });\n\n  changePriorityBtn.addEventListener(\"click\", () => {\n    let val = changePriorityValue.value.trim();\n    if(val === \"\"){\n      log(\"Change priority failed: no value entered.\", true);\n      return;\n    }\n    let np = Number(newPriorityInput.value);\n    if(isNaN(np)){\n      log(\"Change priority failed: invalid new priority.\", true);\n      return;\n    }\n    let changed = pq.changePriority(val, np);\n    if(changed){\n      log(`Changed priority of first matching value \"${val}\" to ${np}.`);\n    } else {\n      log(`No element with value \"${val}\" found to change priority.`, true);\n    }\n  });\n\n  removeByValueBtn.addEventListener(\"click\", () => {\n    let val = removeByValueInput.value.trim();\n    if(val === \"\"){\n      log(\"Remove failed: no value entered.\", true);\n      return;\n    }\n    let removed = pq.removeByValue(val);\n    if(removed){\n      log(`Removed first matching element with value \"${val}\".`);\n    } else {\n      log(`No element with value \"${val}\" found to remove.`, true);\n    }\n  });\n\n  bulkInsertStartBtn.addEventListener(\"click\", () => {\n    let count = Number(bulkInsertCountInput.value);\n    if(isNaN(count) || count < 1 || count > 10000){\n      log(\"Invalid bulk insert count; must be 1 to 10000.\", true);\n      return;\n    }\n    let els = [];\n    for(let i=0; i<count; i++){\n      els.push({value: randomString(), priority: randomPriority()});\n    }\n    insertElements(els);\n  });\n\n  bulkBenchmarkBtn.addEventListener(\"click\", () => {\n    log(\"Starting benchmark for 1000 insert and extractMax operations...\");\n    resetPQ();\n    let start = performance.now();\n    for(let i=0; i<1000; i++){\n      globalInsertCounter++;\n      pq.insert({value: randomString(), priority:randomPriority()});\n    }\n    let mid = performance.now();\n    for(let i=0; i<1000; i++){\n      pq.extractMax();\n    }\n    let end = performance.now();\n    log(`Benchmark results:\\n Insert 1000: ${(mid-start).toFixed(2)} ms\\n Extract 1000: ${(end-mid).toFixed(2)} ms`);\n  });\n\n  searchBtn.addEventListener(\"click\", () => {\n    let val = searchValueInput.value.trim();\n    if(val === \"\"){\n      log(\"Search failed: no value entered.\", true);\n      return;\n    }\n    let found = pq.search(val);\n    if(found.length === 0){\n      log(`No elements containing \"${val}\" found.`);\n      return;\n    }\n    let lines = [`Found ${found.length} element(s) containing \"${val}\":`, \"Value | Priority | Insert#\",\"---------------------\"];\n    for(let el of found){\n      lines.push(`${el.value} | ${el.priority} | ${el.insertCount}`);\n    }\n    log(lines.join(\"\\n\"));\n  });\n\n  // Highlight matches:\n  // Because the default UI has no table with highlights, we will highlight by prefixing the log with special lines.\n  // We'll just print matches again with a prefix marker.\n  searchHighlightBtn.addEventListener(\"click\", () => {\n    let val = searchValueInput.value.trim();\n    if(val === \"\"){\n      log(\"Highlight failed: no value entered.\", true);\n      return;\n    }\n    let arr = pq.toArray();\n    if(arr.length === 0){\n      log(\"Queue empty; no highlights.\");\n      return;\n    }\n    let lines = [\"Queue elements with matches marked with '*' next to value (search substring: '\"+val+\"'):\", \"Value | Priority | Insert#\",\"---------------------\"];\n    for(let el of arr){\n      let mark = el.value.includes(val) ? \"*\" : \" \";\n      lines.push(`${mark}${el.value} | ${el.priority} | ${el.insertCount}`);\n    }\n    log(lines.join(\"\\n\"));\n  });\n\n  exportJsonBtn.addEventListener(\"click\", () => {\n    let arr = pq.toArray();\n    try {\n      jsonArea.value = JSON.stringify(arr, null, 2);\n      log(\"Exported queue state to JSON.\");\n    } catch(e){\n      log(\"Export to JSON failed: \"+e.message, true);\n    }\n  });\n\n  importJsonBtn.addEventListener(\"click\", () => {\n    let txt = jsonArea.value.trim();\n    if(txt === \"\"){\n      log(\"Import failed: JSON text area empty.\", true);\n      return;\n    }\n    try {\n      let arr = JSON.parse(txt);\n      if(!Array.isArray(arr)){\n        log(\"Import failed: JSON is not an array.\", true);\n        return;\n      }\n      pq.clear();\n      globalInsertCounter = 0;\n      for(let obj of arr){\n        if(typeof obj.value !== \"string\" || typeof obj.priority !== \"number\" || typeof obj.insertCount !== \"number\"){\n          log(\"Import failed: one or more elements have invalid properties.\", true);\n          return;\n        }\n        pq.insert({value: obj.value, priority: obj.priority, insertCount: obj.insertCount});\n        if(obj.insertCount > globalInsertCounter) globalInsertCounter = obj.insertCount;\n      }\n      log(`Imported queue from JSON with ${arr.length} elements.`);\n    } catch(e){\n      log(\"Import failed: \"+e.message, true);\n    }\n  });\n\n  // Initialization\n  resetPQ();\n\n  // Accessibility helpers: focus first control in sections for tab order\n  const allLabels = document.querySelectorAll(\"label\");\n  allLabels.forEach(label => {\n    if(label.control){\n      label.control.setAttribute(\"tabindex\", \"0\");\n    }\n  });\n})();\n</script>\n</body>\n</html>"
  },
