    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Array</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n        }\n        input[type=\"text\"] {\n            width: 50%;\n            padding: 10px;\n            margin-bottom: 20px;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>Dynamic Array</h1>\n    <div id=\"array\"></div>\n    <script>\n        let array = [];\n        const addButton = document.getElementById('addButton');\n        const removeButton = document.getElementById('removeButton');\n        const inputField = document.getElementById('inputField');\n        const buttonField = document.getElementById('buttonField');\n\n        function add() {\n            array.push(Math.floor(Math.random() * 100));\n            updateArray();\n        }\n\n        function remove() {\n            array = array.filter(x => x > 0);\n            updateArray();\n        }\n\n        function updateArray() {\n            const arrayString = array.map(x => x.toString()).join(', ');\n            document.getElementById('array').innerHTML = `<p>Array: ${arrayString}</p>`;\n        }\n\n        addButton.addEventListener('click', add);\n        removeButton.addEventListener('click', remove);\n        inputField.addEventListener('input', updateArray);\n\n        function printArray() {\n            console.log(array);\n        }\n\n        printArray();\n    </script>\n</body>\n</html>"
