    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Runtime Environment | Visual Exploration</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #3a86ff;\n            --secondary: #8338ec;\n            --accent: #ff006e;\n            --dark: #1a1a2e;\n            --light: #f8f9fa;\n            --transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--dark);\n            color: var(--light);\n            overflow-x: hidden;\n            min-height: 100vh;\n            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            position: relative;\n            z-index: 1;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 4rem;\n            position: relative;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            font-weight: 700;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease forwards 0.2s;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            font-weight: 300;\n            color: rgba(255, 255, 255, 0.7);\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease forwards 0.4s;\n        }\n        \n        .visualization {\n            position: relative;\n            height: 500px;\n            margin: 4rem 0;\n            overflow: hidden;\n            border-radius: 16px;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.2);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            opacity: 0;\n            transform: scale(0.95);\n            animation: fadeInScale 1s ease forwards 0.6s;\n        }\n        \n        .runtime-core {\n            position: absolute;\n            width: 150px;\n            height: 150px;\n            background: var(--primary);\n            border-radius: 50%;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            box-shadow: 0 0 60px rgba(58, 134, 255, 0.4);\n            z-index: 2;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            font-size: 1.2rem;\n        }\n        \n        .module {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            background: var(--secondary);\n            border-radius: 12px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            z-index: 1;\n            box-shadow: 0 10px 30px rgba(131, 56, 236, 0.3);\n            cursor: pointer;\n            transition: var(--transition);\n        }\n        \n        .module:hover {\n            transform: scale(1.1) !important;\n            box-shadow: 0 15px 40px rgba(131, 56, 236, 0.5);\n        }\n        \n        .connection {\n            position: absolute;\n            height: 2px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            transform-origin: left center;\n            z-index: 0;\n            transition: var(--transition);\n        }\n        \n        .memory-pool {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 120px;\n            background: rgba(255, 255, 255, 0.05);\n            border-top: 1px solid rgba(255, 255, 255, 0.1);\n            display: flex;\n            align-items: center;\n            padding: 0 2rem;\n            overflow: hidden;\n        }\n        \n        .memory-block {\n            width: 40px;\n            height: 40px;\n            background: rgba(255, 255, 255, 0.1);\n            margin-right: 10px;\n            border-radius: 4px;\n            transition: all 0.3s ease;\n        }\n        \n        .memory-block.active {\n            background: var(--accent);\n            transform: translateY(-10px);\n            box-shadow: 0 10px 20px rgba(255, 0, 110, 0.3);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease forwards 0.8s;\n        }\n        \n        .btn {\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            border: none;\n            color: white;\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 10px 20px rgba(58, 134, 255, 0.3);\n            margin: 0 1rem;\n        }\n        \n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 15px 30px rgba(58, 134, 255, 0.4);\n        }\n        \n        .btn:active {\n            transform: translateY(0);\n        }\n        \n        .btn-secondary {\n            background: rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(5px);\n        }\n        \n        .btn-secondary:hover {\n            background: rgba(255, 255, 255, 0.2);\n        }\n        \n        .status-bar {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 4px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));\n            transform-origin: left center;\n            animation: progress 8s linear infinite;\n        }\n        \n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes fadeInScale {\n            to {\n                opacity: 1;\n                transform: scale(1);\n            }\n        }\n        \n        @keyframes progress {\n            0% {\n                transform: scaleX(0);\n            }\n            100% {\n                transform: scaleX(1);\n            }\n        }\n        \n        .particle {\n            position: absolute;\n            width: 4px;\n            height: 4px;\n            background: white;\n            border-radius: 50%;\n            opacity: 0.3;\n            animation: float 6s infinite ease-in-out;\n        }\n        \n        @keyframes float {\n            0%, 100% {\n                transform: translateY(0) translateX(0);\n            }\n            50% {\n                transform: translateY(-20px) translateX(10px);\n            }\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            color: rgba(255, 255, 255, 0.4);\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Runtime Environment</h1>\n            <p class=\"subtitle\">A visual representation of the execution context where programs run, including memory allocation, modules, and system resources.</p>\n        </header>\n        \n        <div class=\"visualization\" id=\"runtimeViz\">\n            <div class=\"runtime-core\">Runtime Core</div>\n            <div class=\"memory-pool\" id=\"memoryPool\"></div>\n            <div class=\"status-bar\"></div>\n        </div>\n        \n        <div class=\"controls\">\n            <button class=\"btn\" id=\"runBtn\">Run Process</button>\n            <button class=\"btn btn-secondary\" id=\"resetBtn\">Reset</button>\n        </div>\n    </div>\n    \n    <footer>\n        <p>Visual Exploration of Runtime Environments © 2023</p>\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            const viz = document.getElementById('runtimeViz');\n            for (let i = 0; i < 30; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.animationDelay = `${Math.random() * 6}s`;\n                viz.appendChild(particle);\n            }\n            \n            // Create memory blocks\n            const memoryPool = document.getElementById('memoryPool');\n            for (let i = 0; i < 12; i++) {\n                const block = document.createElement('div');\n                block.classList.add('memory-block');\n                memoryPool.appendChild(block);\n            }\n            \n            // Create modules and connections\n            const positions = [\n                { top: '20%', left: '20%', name: 'Compiler' },\n                { top: '20%', left: '80%', name: 'I/O' },\n                { top: '60%', left: '10%', name: 'Security' },\n                { top: '60%', left: '90%', name: 'Network' },\n                { top: '80%', left: '50%', name: 'Storage' }\n            ];\n            \n            positions.forEach(pos => {\n                const module = document.createElement('div');\n                module.classList.add('module');\n                module.style.top = pos.top;\n                module.style.left = pos.left;\n                module.textContent = pos.name;\n                \n                // Connect to core\n                const coreRect = document.querySelector('.runtime-core').getBoundingClientRect();\n                const moduleRect = { \n                    top: parseFloat(pos.top) * viz.offsetHeight / 100,\n                    left: parseFloat(pos.left) * viz.offsetWidth / 100\n                };\n                \n                const coreCenter = {\n                    x: coreRect.left - viz.getBoundingClientRect().left + coreRect.width / 2,\n                    y: coreRect.top - viz.getBoundingClientRect().top + coreRect.height / 2\n                };\n                \n                const moduleCenter = {\n                    x: moduleRect.left,\n                    y: moduleRect.top\n                };\n                \n                const length = Math.sqrt(\n                    Math.pow(moduleCenter.x - coreCenter.x, 2) + \n                    Math.pow(moduleCenter.y - coreCenter.y, 2)\n                );\n                \n                const angle = Math.atan2(\n                    moduleCenter.y - coreCenter.y,\n                    moduleCenter.x - coreCenter.x\n                );\n                \n                const connection = document.createElement('div');\n                connection.classList.add('connection');\n                connection.style.width = `${length}px`;\n                connection.style.left = `${coreCenter.x}px`;\n                connection.style.top = `${coreCenter.y}px`;\n                connection.style.transform = `rotate(${angle}rad)`;\n                connection.style.opacity = '0.5';\n                \n                viz.appendChild(connection);\n                viz.appendChild(module);\n            });\n            \n            // Button interactions\n            const runBtn = document.getElementById('runBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const memoryBlocks = document.querySelectorAll('.memory-block');\n            \n            runBtn.addEventListener('click', function() {\n                // Animate modules\n                const modules = document.querySelectorAll('.module');\n                modules.forEach((mod, i) => {\n                    setTimeout(() => {\n                        mod.style.transform = 'scale(1.2)';\n                        setTimeout(() => {\n                            mod.style.transform = '';\n                        }, 500);\n                    }, i * 200);\n                });\n                \n                // Animate memory blocks\n                memoryBlocks.forEach((block, i) => {\n                    setTimeout(() => {\n                        block.classList.add('active');\n                        setTimeout(() => {\n                            block.classList.remove('active');\n                        }, 1000);\n                    }, i * 150);\n                });\n                \n                // Pulse core\n                const core = document.querySelector('.runtime-core');\n                core.style.boxShadow = '0 0 80px rgba(58, 134, 255, 0.8)';\n                setTimeout(() => {\n                    core.style.boxShadow = '0 0 60px rgba(58, 134, 255, 0.4)';\n                }, 1000);\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                memoryBlocks.forEach(block => {\n                    block.classList.remove('active');\n                });\n                \n                const core = document.querySelector('.runtime-core');\n                core.style.boxShadow = '0 0 60px rgba(58, 134, 255, 0.4)';\n            });\n        });\n    </script>\n</body>\n</html>"
