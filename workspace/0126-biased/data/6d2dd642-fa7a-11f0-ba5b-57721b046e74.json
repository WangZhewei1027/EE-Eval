    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Heap Sort</title>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            line-height: 1.5;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n            max-width: 1000px;\n            margin: 0 auto;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .array-container {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 5px;\n            margin-bottom: 20px;\n        }\n        .array-element {\n            border: 1px solid black;\n            padding: 10px;\n            min-width: 30px;\n            text-align: center;\n        }\n        .highlight {\n            background-color: #eee;\n        }\n        .swapping {\n            background-color: #ddd;\n        }\n        .heap-container {\n            margin-top: 30px;\n        }\n        .heap-level {\n            display: flex;\n            justify-content: center;\n            gap: 50px;\n            margin-bottom: 20px;\n        }\n        .heap-node {\n            border: 1px solid black;\n            padding: 10px;\n            min-width: 30px;\n            text-align: center;\n            position: relative;\n        }\n        .heap-node.highlight {\n            background-color: #eee;\n        }\n        .heap-node.swapping {\n            background-color: #ddd;\n        }\n        .heap-node::before, .heap-node::after {\n            content: '';\n            position: absolute;\n            top: 100%;\n            width: 50%;\n            height: 20px;\n            border-top: 1px solid black;\n        }\n        .heap-node::before {\n            left: 50%;\n            transform: translateX(-100%);\n        }\n        .heap-node::after {\n            left: 50%;\n        }\n        .heap-node:only-child::before, .heap-node:only-child::after,\n        .heap-node:last-child:nth-child(odd)::before,\n        .heap-node:last-child:nth-child(odd)::after {\n            display: none;\n        }\n        .explanation {\n            margin-top: 20px;\n            border-top: 1px solid #ccc;\n            padding-top: 10px;\n        }\n        button, input, select {\n            padding: 5px 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Heap Sort</h1>\n        \n        <div class=\"controls\">\n            <button id=\"generate-btn\">Generate New Array</button>\n            <input type=\"number\" id=\"array-size\" min=\"3\" max=\"20\" value=\"10\">\n            <select id=\"speed\">\n                <option value=\"1000\">Slow</option>\n                <option value=\"500\" selected>Medium</option>\n                <option value=\"100\">Fast</option>\n            </select>\n            <button id=\"build-heap-btn\">Build Max Heap</button>\n            <button id=\"sort-btn\">Sort Array</button>\n            <button id=\"step-btn\">Step Back</button>\n            <button id=\"step-btn\">Step Forward</button>\n            <button id=\"reset-btn\">Reset</button>\n        </div>\n        \n        <div>\n            <h3>Current Array:</h3>\n            <div id=\"array-display\" class=\"array-container\"></div>\n        </div>\n        \n        <div id=\"heap-display\" class=\"heap-container\">\n            <h3>Heap Visualization:</h3>\n            <div id=\"heap-levels\"></div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h3>Algorithm Steps:</h3>\n            <div id=\"steps-log\"></div>\n        </div>\n    </div>\n\n    <script>\n        let array = [];\n        let history = [];\n        let currentStep = 0;\n        let isSorting = false;\n        let speed = 500;\n        \n        // DOM elements\n        const arrayDisplay = document.getElementById('array-display');\n        const heapLevels = document.getElementById('heap-levels');\n        const stepsLog = document.getElementById('steps-log');\n        const generateBtn = document.getElementById('generate-btn');\n        const buildHeapBtn = document.getElementById('build-heap-btn');\n        const sortBtn = document.getElementById('sort-btn');\n        const stepBackBtn = document.querySelectorAll('#step-btn')[0];\n        const stepForwardBtn = document.querySelectorAll('#step-btn')[1];\n        const resetBtn = document.getElementById('reset-btn');\n        const arraySizeInput = document.getElementById('array-size');\n        const speedSelect = document.getElementById('speed');\n        \n        // Initialize\n        generateRandomArray();\n        updateDisplay();\n        \n        // Event listeners\n        generateBtn.addEventListener('click', () => {\n            generateRandomArray();\n            resetHistory();\n            updateDisplay();\n        });\n        \n        buildHeapBtn.addEventListener('click', async () => {\n            if (isSorting) return;\n            isSorting = true;\n            disableControls();\n            await buildMaxHeap();\n            isSorting = false;\n            enableControls();\n        });\n        \n        sortBtn.addEventListener('click', async () => {\n            if (isSorting) return;\n            isSorting = true;\n            disableControls();\n            await heapSort();\n            isSorting = false;\n            enableControls();\n        });\n        \n        stepBackBtn.addEventListener('click', () => {\n            if (currentStep > 0) {\n                currentStep--;\n                array = [...history[currentStep].array];\n                updateDisplay();\n                updateStepsLog(history[currentStep].action);\n            }\n        });\n        \n        stepForwardBtn.addEventListener('click', () => {\n            if (currentStep < history.length - 1) {\n                currentStep++;\n                array = [...history[currentStep].array];\n                updateDisplay();\n                updateStepsLog(history[currentStep].action);\n            }\n        });\n        \n        resetBtn.addEventListener('click', () => {\n            currentStep = 0;\n            array = [...history[0].array];\n            updateDisplay();\n            updateStepsLog(\"Reset to initial state\");\n        });\n        \n        arraySizeInput.addEventListener('change', () => {\n            generateRandomArray();\n            resetHistory();\n            updateDisplay();\n        });\n        \n        speedSelect.addEventListener('change', () => {\n            speed = parseInt(speedSelect.value);\n        });\n        \n        function disableControls() {\n            generateBtn.disabled = true;\n            buildHeapBtn.disabled = true;\n            sortBtn.disabled = true;\n            stepBackBtn.disabled = true;\n            stepForwardBtn.disabled = true;\n            resetBtn.disabled = true;\n            arraySizeInput.disabled = true;\n        }\n        \n        function enableControls() {\n            generateBtn.disabled = false;\n            buildHeapBtn.disabled = false;\n            sortBtn.disabled = false;\n            stepBackBtn.disabled = false;\n            stepForwardBtn.disabled = false;\n            resetBtn.disabled = false;\n            arraySizeInput.disabled = false;\n        }\n        \n        function generateRandomArray() {\n            const size = parseInt(arraySizeInput.value);\n            array = [];\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * 100) + 1);\n            }\n        }\n        \n        function resetHistory() {\n            history = [{ array: [...array], action: \"Initial array\" }];\n            currentStep = 0;\n        }\n        \n        function saveStep(action) {\n            history.push({ array: [...array], action });\n            currentStep = history.length - 1;\n        }\n        \n        function updateDisplay() {\n            // Update array display\n            arrayDisplay.innerHTML = '';\n            array.forEach((value, index) => {\n                const element = document.createElement('div');\n                element.className = 'array-element';\n                element.textContent = value;\n                arrayDisplay.appendChild(element);\n            });\n            \n            // Update heap display\n            updateHeapVisualization();\n        }\n        \n        function updateHeapVisualization() {\n            heapLevels.innerHTML = '';\n            \n            if (array.length === 0) return;\n            \n            let level = 0;\n            let start = 0;\n            let end = 0;\n            \n            while (start < array.length) {\n                const levelContainer = document.createElement('div');\n                levelContainer.className = 'heap-level';\n                \n                for (let i = start; i <= end && i < array.length; i++) {\n                    const node = document.createElement('div');\n                    node.className = 'heap-node';\n                    node.textContent = array[i];\n                    levelContainer.appendChild(node);\n                }\n                \n                heapLevels.appendChild(levelContainer);\n                \n                level++;\n                start = end + 1;\n                end = 2 * end + 2;\n            }\n        }\n        \n        function updateStepsLog(action) {\n            stepsLog.innerHTML = `<p><strong>Step ${currentStep}:</strong> ${action}</p>`;\n        }\n        \n        async function buildMaxHeap() {\n            const n = array.length;\n            \n            // Start from the last non-leaf node\n            for (let i = Math.floor(n / 2) - 1; i >= 0; i--) {\n                await heapify(n, i);\n            }\n            \n            saveStep(\"Max heap built\");\n            updateStepsLog(\"Max heap built\");\n        }\n        \n        async function heapSort() {\n            // First build the max heap\n            await buildMaxHeap();\n            \n            // One by one extract elements\n            for (let i = array.length - 1; i > 0; i--) {\n                // Move current root to end\n                await swap(0, i);\n                saveStep(`Swapped root (${array[i]}) with last element (${array[0]})`);\n                \n                // Call max heapify on the reduced heap\n                await heapify(i, 0);\n            }\n            \n            saveStep(\"Array sorted\");\n            updateStepsLog(\"Array sorted\");\n        }\n        \n        async function heapify(n, i) {\n            let largest = i;\n            const left = 2 * i + 1;\n            const right = 2 * i + 2;\n            \n            // Highlight the current node and its children\n            highlightNodes([i, left, right]);\n            saveStep(`Heapifying node ${i} (value: ${array[i]})`);\n            await delay(speed);\n            \n            // Compare with left child\n            if (left < n && array[left] > array[largest]) {\n                largest = left;\n            }\n            \n            // Compare with right child\n            if (right < n && array[right] > array[largest]) {\n                largest = right;\n            }\n            \n            // If largest is not root\n            if (largest !== i) {\n                await swap(i, largest);\n                saveStep(`Swapped ${array[i]} (index ${i}) with ${array[largest]} (index ${largest})`);\n                \n                // Recursively heapify the affected sub-tree\n                await heapify(n, largest);\n            }\n            \n            // Remove highlights\n            removeHighlights();\n        }\n        \n        async function swap(i, j) {\n            // Highlight elements being swapped\n            highlightNodes([i, j], 'swapping');\n            await delay(speed);\n            \n            // Perform the swap\n            [array[i], array[j]] = [array[j], array[i]];\n            \n            // Update display\n            updateDisplay();\n            await delay(speed);\n            \n            // Remove highlights\n            removeHighlights();\n        }\n        \n        function highlightNodes(indices, className = 'highlight') {\n            const arrayElements = document.querySelectorAll('.array-element');\n            const heapNodes = document.querySelectorAll('.heap-node');\n            \n            indices.forEach(index => {\n                if (index >= 0 && index < array.length) {\n                    arrayElements[index].classList.add(className);\n                    heapNodes[index].classList.add(className);\n                }\n            });\n        }\n        \n        function removeHighlights() {\n            document.querySelectorAll('.array-element').forEach(el => {\n                el.classList.remove('highlight', 'swapping');\n            });\n            document.querySelectorAll('.heap-node').forEach(el => {\n                el.classList.remove('highlight', 'swapping');\n            });\n        }\n        \n        function delay(ms) {\n            return new Promise(resolve => setTimeout(resolve, ms));\n        }\n    </script>\n</body>\n</html>"
