  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Suffix Tree Explorer</title>\n<style>\n  body { font-family: monospace, monospace; background: white; color: black; margin: 10px; }\n  textarea { width: 100%; height: 60px; font-family: monospace; font-size: 14px; }\n  input, button, select { font-family: monospace; font-size: 14px; margin: 2px 0; }\n  #treeDisplay { white-space: pre; font-family: monospace; font-size: 14px; border: 1px solid black; padding: 5px; max-height: 360px; overflow-y: auto; }\n  #log { white-space: pre-wrap; max-height: 120px; overflow-y: auto; border: 1px solid black; padding: 5px; margin-top: 6px; font-family: monospace; font-size: 13px; }\n  label { display: block; margin-top: 10px; }\n  #exploreControls > * { margin-right: 5px; margin-top: 4px; }\n</style>\n</head>\n<body>\n<h2>Interactive Suffix Tree Explorer</h2>\n\n<label for=\"inputStr\">Input String <small>(append '$' if not present)</small>:</label>\n<textarea id=\"inputStr\" placeholder=\"Enter a string (max 150 chars)\"></textarea>\n<button id=\"buildTreeBtn\">Build Suffix Tree</button>\n<button id=\"resetBtn\">Reset</button>\n\n<div id=\"status\" style=\"margin-top:4px;\"></div>\n\n<hr />\n\n<label>Suffix Tree View Mode:</label>\n<select id=\"viewModeSelect\" title=\"Choose how to view the tree representation\">\n  <option value=\"edges\">Edges (Compact)</option>\n  <option value=\"nodes\">Nodes & Edges (Explicit Labels)</option>\n  <option value=\"paths\">All Suffix Paths</option>\n</select>\n\n<label>Searched Substring (to highlight or find in tree):</label>\n<input type=\"text\" id=\"searchSubstring\" size=\"20\" placeholder=\"Enter substring\" autocomplete=\"off\" />\n<button id=\"searchBtn\">Search Substring in Tree</button>\n<button id=\"clearSearchBtn\">Clear Search</button>\n\n<div style=\"margin-top:10px;\">\n  <label>Explore Suffix Tree Stepwise Construction (Ukkonen's Algorithm):</label><br/>\n  <button id=\"stepNext\">Next Step</button>\n  <button id=\"stepPrev\">Previous Step</button>\n  <button id=\"autoPlay\">Auto Play</button>\n  <button id=\"pausePlay\" disabled>Pause</button>\n  <button id=\"resetSteps\">Reset Steps</button>\n\n  <label>\n    Auto-play Delay (ms):\n    <input type=\"number\" id=\"autoDelay\" value=\"1000\" min=\"100\" max=\"10000\" step=\"100\" />\n  </label>\n</div>\n\n<hr />\n\n<label>Tree Display:</label>\n<pre id=\"treeDisplay\"></pre>\n\n<hr />\n\n<label>Suffix Tree Internal State Log (Latest messages below):</label>\n<div id=\"log\"></div>\n\n<script>\n(function(){\n  'use strict';\n\n  // ============== Data Structures ==============\n\n  // Edge labeled suffix tree node for Ukkonen's suffix tree\n  // Using an explicit tree build method with suffix links\n  // Node structure:\n  // {\n  //   edges: Map<char, Edge>\n  //   suffixLink: Node | null\n  //   id: number\n  // }\n  // Edge structure:\n  // {\n  //   start: number (index in input)\n  //   end: { value: number } (Reference for end index for leaves)\n  //   node: Node (destination node)\n  // }\n\n  // Global unique node ID generator (for display)\n  let globalNodeId = 0;\n\n  class Node {\n    constructor() {\n      this.edges = new Map();\n      this.suffixLink = null;\n      this.id = globalNodeId++;\n    }\n  }\n\n  // Active Point for Ukkonen's algorithm\n  class ActivePoint {\n    constructor(root) {\n      this.node = root;      // Active node\n      this.edge = null;      // Active edge char\n      this.length = 0;       // Active length\n    }\n  }\n\n  // State of suffix tree for stepwise building\n  class SuffixTreeState {\n    constructor(input) {\n      this.input = input;\n      this.root = new Node();\n      this.root.suffixLink = this.root; // suffix link of root is root itself by convention\n      this.active = new ActivePoint(this.root);\n\n      this.remainingSuffixCount = 0;\n      this.leafEnd = { value: -1 };\n      this.size = input.length;\n\n      this.lastNewNode = null;\n\n      this.currentPhase = 0; // next character index to add\n      this.currentExtension = 0; // extension being processed in phase\n\n      // Track edges added or updated in step for logging\n      this.stepLog = [];\n\n      // Array tracking the state snapshot after each atomic extension step\n      this.states = [];\n\n      // Build to completion or stepwise\n      this.built = false;\n\n      this.log = [];\n\n      this.saveStateSnapshot();\n    }\n\n    edgeLength(edge) {\n      return edge.end.value - edge.start + 1;\n    }\n\n    nextChar(pos) {\n      return this.input[pos];\n    }\n\n    walkDown(edge) {\n      if (this.active.length >= this.edgeLength(edge)) {\n        this.active.edge = this.nextChar(edge.end.value + 1) || null;\n        this.active.length -= this.edgeLength(edge);\n        this.active.node = edge.node;\n        return true;\n      }\n      return false;\n    }\n\n    // Try to extend the suffix tree at current phase and extension\n    extendPhase() {\n      if (this.currentPhase >= this.size) {\n        this.built = true;\n        return false;\n      }\n\n      this.leafEnd.value = this.currentPhase;\n\n      this.remainingSuffixCount++;\n      this.lastNewNode = null;\n\n      while(this.remainingSuffixCount > 0) {\n\n        if (this.active.length === 0) {\n          this.active.edge = this.nextChar(this.currentPhase);\n        }\n        let edge = this.active.node.edges.get(this.active.edge);\n\n        if (!edge) {\n          // No edge starting with active.edge from active.node, create new leaf edge here\n          const leaf = new Node();\n          this.active.node.edges.set(this.active.edge, {\n            start: this.currentPhase,\n            end: this.leafEnd,\n            node: leaf\n          });\n          this.log.push(`Created leaf edge for '${this.active.edge}' at pos ${this.currentPhase} from node${this.active.node.id}`);\n\n          if (this.lastNewNode) {\n            this.lastNewNode.suffixLink = this.active.node;\n            this.log.push(`Suffix link from node${this.lastNewNode.id} to node${this.active.node.id}`);\n            this.lastNewNode = null;\n          }\n        } else {\n          // Edge exists, need to walk down or check next char on edge\n          let edgeLength = edge.end.value - edge.start + 1;\n          if (this.active.length >= edgeLength) {\n            this.active.edge = this.nextChar(edge.end.value + 1) || null;\n            this.active.length -= edgeLength;\n            this.active.node = edge.node;\n            continue;\n          }\n          // Next char to compare on edge\n          const nextCharOnEdge = this.input[edge.start + this.active.length];\n          if (nextCharOnEdge === this.input[this.currentPhase]) {\n            // Character already on edge, increment active length and break extension\n            this.active.length++;\n            if (this.lastNewNode) {\n              this.lastNewNode.suffixLink = this.active.node;\n              this.log.push(`Suffix link from node${this.lastNewNode.id} to node${this.active.node.id}`);\n              this.lastNewNode = null;\n            }\n            this.log.push(`Character '${this.input[this.currentPhase]}' is already on edge, incremented active length to ${this.active.length}`);\n            break;\n          }\n\n          // Need to split edge\n          const splitNode = new Node();\n          this.log.push(`Split edge at node${this.active.node.id} for char '${this.active.edge}'`);\n          const oldEdgeStart = edge.start;\n          const oldEdgeEnd = edge.end;\n\n          // Edge from splitNode with remainder from old edge\n          splitNode.edges.set(this.input[oldEdgeStart + this.active.length], {\n            start: oldEdgeStart + this.active.length,\n            end: oldEdgeEnd,\n            node: edge.node\n          });\n\n          // Update old edge to end at split point\n          edge.end = { value: oldEdgeStart + this.active.length - 1 };\n\n          // Update edge to point to splitNode\n          edge.node = splitNode;\n\n          // Create new leaf edge from splitNode for new char\n          const leaf = new Node();\n          splitNode.edges.set(this.input[this.currentPhase], {\n            start: this.currentPhase,\n            end: this.leafEnd,\n            node: leaf\n          });\n\n          this.log.push(`Created node${splitNode.id} by splitting; created leaf from split node for '${this.input[this.currentPhase]}'`);\n\n          if (this.lastNewNode) {\n            this.lastNewNode.suffixLink = splitNode;\n            this.log.push(`Suffix link from node${this.lastNewNode.id} to node${splitNode.id}`);\n          }\n          this.lastNewNode = splitNode;\n        }\n        this.remainingSuffixCount--;\n\n        if (this.active.node === this.root && this.active.length > 0) {\n          this.active.length--;\n          this.active.edge = this.input[this.currentPhase - this.remainingSuffixCount + 1];\n        } else if (this.active.node !== this.root) {\n          this.active.node = this.active.node.suffixLink || this.root;\n        }\n      }\n\n      this.currentPhase++;\n      this.saveStateSnapshot();\n      if (this.currentPhase === this.size) {\n        this.built = true;\n      }\n      return true;\n    }\n\n    saveStateSnapshot() {\n      // Deep clone the suffix tree structure for display and stepping back\n      // We will clone structure IDs and edges (start,end), suffix links by id\n      // active point also recorded\n\n      function cloneNode(node, clones = new Map()) {\n        if(clones.has(node.id)) return clones.get(node.id);\n        const cnode = {\n          id: node.id,\n          edges: new Map(),\n          suffixLinkId: node.suffixLink ? node.suffixLink.id : null\n        };\n        clones.set(node.id, cnode);\n        for(const [ch, edge] of node.edges.entries()) {\n          cnode.edges.set(ch, {\n            start: edge.start,\n            endValue: edge.end.value,\n            toId: edge.node.id\n          });\n          if (!clones.has(edge.node.id)) {\n            cloneNode(edge.node, clones);\n          }\n        }\n        return cnode;\n      }\n\n      // Active point snapshot\n      const activeSnapshot = {\n        nodeId: this.active.node.id,\n        edgeChar: this.active.edge,\n        length: this.active.length\n      };\n\n      // Prepare edges data\n      const rootCloned = cloneNode(this.root);\n      // We only keep a flat map nodeId -> node snapshot to reconstruct graph on display\n      let nodesMap = new Map();\n      function traverseToMap(cnode) {\n        if(nodesMap.has(cnode.id)) return;\n        nodesMap.set(cnode.id, cnode);\n        for(const edge of cnode.edges.values()) {\n          if(nodesMap.has(edge.toId)) continue;\n          traverseToMap(clones.get(edge.toId));\n        }\n      }\n      const clones = new Map();\n      cloneNode(this.root, clones);\n      // clones Map is nodeId->snapshot but clones are disconnected, gather all:\n      for(const cnode of clones.values()) nodesMap.set(cnode.id, cnode);\n\n      // Build suffix links (id->id) map for reference\n      const suffixLinks = {};\n      for(const node of nodesMap.values()) {\n        suffixLinks[node.id] = node.suffixLinkId;\n      }\n\n      // State snapshot object\n      const snap = {\n        currentPhase: this.currentPhase,\n        active: {...activeSnapshot},\n        remainingSuffixCount: this.remainingSuffixCount,\n        leafEndValue: this.leafEnd.value,\n        nodes: nodesMap,\n        suffixLinks: suffixLinks,\n        log: [...this.log]\n      };\n\n      // Push snapshot onto states stack\n      this.states.push(snap);\n      this.log = [];\n    }\n\n    resetStepwise() {\n      this.active = new ActivePoint(this.root);\n      this.remainingSuffixCount = 0;\n      this.leafEnd.value = -1;\n      this.currentPhase = 0;\n      this.built = false;\n      this.lastNewNode = null;\n      this.states = [];\n      this.log = [];\n      this.saveStateSnapshot();\n    }\n\n    // Build entire tree at once (without stepwise logs)\n    buildFullTree() {\n      while(!this.built) {\n        this.extendPhase();\n      }\n    }\n  }\n\n  // ============== DOM Elements ==============\n  const inputStrEl = document.getElementById('inputStr');\n  const buildTreeBtn = document.getElementById('buildTreeBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const treeDisplayEl = document.getElementById('treeDisplay');\n  const logEl = document.getElementById('log');\n  const viewModeSelect = document.getElementById('viewModeSelect');\n  const searchSubstringInput = document.getElementById('searchSubstring');\n  const searchBtn = document.getElementById('searchBtn');\n  const clearSearchBtn = document.getElementById('clearSearchBtn');\n  const stepNextBtn = document.getElementById('stepNext');\n  const stepPrevBtn = document.getElementById('stepPrev');\n  const autoPlayBtn = document.getElementById('autoPlay');\n  const pausePlayBtn = document.getElementById('pausePlay');\n  const resetStepsBtn = document.getElementById('resetSteps');\n  const autoDelayInput = document.getElementById('autoDelay');\n\n  // ============== Variables ==============\n  let currentSuffixTree = null;\n  let currentStepIndex = 0;\n  let autoplayHandle = null;\n\n  // ============== Helper Functions ==============\n\n  // Sanitize and validate input string (max 150 chars, all ascii or extended)\n  function sanitizeInput(str) {\n    let s = str.trim();\n    if (s.length === 0) return null;\n    if (s.length > 150) s = s.substring(0, 150);\n    return s;\n  }\n\n  // Check if string ends in unique terminal char, add '$' if not present\n  function ensureTerminalChar(str) {\n    if(str.length === 0) return '$';\n    let lastChar = str[str.length - 1];\n    // We use '$' as unique char, so append if missing or not unique\n    if (lastChar !== '$' && !str.includes('$')) {\n      return str + '$';\n    }\n    return str;\n  }\n\n  // Display tree recursively (compact edge-based)\n  // mode: \"edges\", \"nodes\", \"paths\"\n  // highlightSubstring: optional substring to highlight found positions\n\n  // We need to map node IDs to nodes for fast access\n  // nodesMap: Map<id, node snapshot object>\n  // suffixLinks: map id->id\n\n  // For edges mode: display each edge label with start-end indices and substring\n\n  function displayTreeCompact(statesnap, searchStr) {\n    // Show root and its edges, then recurse\n    let result = [];\n\n    const nodes = statesnap.nodes;\n    const input = currentSuffixTree.input;\n    function edgeLabel(edge) {\n      return input.substring(edge.start, edge.endValue + 1);\n    }\n\n    function indent(level) { return ' '.repeat(level * 2); }\n\n    function walk(nodeId, level) {\n      const node = nodes.get(nodeId);\n      if (!node) return;\n      for (const [ch, edge] of node.edges) {\n        const label = edgeLabel(edge);\n        const displayLabel = label;\n        result.push(indent(level) + `- '${ch}': [${edge.start},${edge.endValue}] \"${displayLabel}\" -> node${edge.toId}`);\n        walk(edge.toId, level + 1);\n      }\n    }\n    result.push(`Suffix Tree (Edges) for: \"${input}\"`);\n    result.push(`Root node${statesnap.currentPhase === 0 ? \"\" : \" (Phase: \"+statesnap.currentPhase+\")\"}`);\n    walk(0,1);\n    return result.join('\\n');\n  }\n\n  // Display tree nodes with suffix links visible and edges as explicit labels\n  // This will show nodes and edges distinctly.\n  function displayTreeNodesEdges(statesnap) {\n    let result = [];\n    const nodes = statesnap.nodes;\n    const input = currentSuffixTree.input;\n\n    function indent(level) { return ' '.repeat(level * 2); }\n\n    function edgeLabel(edge) {\n      return input.substring(edge.start, edge.endValue + 1);\n    }\n\n    for (const [id, node] of nodes) {\n      result.push(`node${id} (suffixLink: node${node.suffixLinkId !== null ? node.suffixLinkId : 'none'})`);\n      for (const [ch, edge] of node.edges) {\n        const label = edgeLabel(edge);\n        result.push(indent(1) + `edge '${ch}' to node${edge.toId} with label [${edge.start},${edge.endValue}]: \"${label}\"`);\n      }\n    }\n    return result.join('\\n');\n  }\n\n  // Display all suffix paths from root to leaves, one line per suffix\n  // Each suffix path: sequence of edge labels concatenated = suffix string\n  // We limit maximum 100 suffix paths to avoid browser freeze on huge input\n\n  function displayTreeSuffixPaths(statesnap) {\n    let result = [];\n    const nodes = statesnap.nodes;\n    const input = currentSuffixTree.input;\n\n    let suffixPaths = [];\n\n    function walk(nodeId, pathSoFar) {\n      const node = nodes.get(nodeId);\n      if (!node) return;\n      if (node.edges.size === 0) {\n        suffixPaths.push(pathSoFar);\n        return;\n      }\n      for (const edge of node.edges.values()) {\n        const label = input.substring(edge.start, edge.endValue+1);\n        walk(edge.toId, pathSoFar + label);\n      }\n    }\n\n    walk(0, '');\n    let displayCount = Math.min(suffixPaths.length, 100);\n    result.push(`All suffix paths (up to 100 shown): Total suffixes: ${suffixPaths.length}`);\n    for(let i=0; i<displayCount; i++) {\n      result.push(`Suffix ${i}: \"${suffixPaths[i]}\"`);\n    }\n    if (suffixPaths.length > 100) {\n      result.push(`...and ${suffixPaths.length - 100} more paths`);\n    }\n    return result.join('\\n');\n  }\n\n  // Display active point status from step state snapshot\n  function activePointToString(active) {\n    return `Active Point: Node${active.nodeId}, Edge: '${active.edgeChar || \"-\"}', Length: ${active.length}`;\n  }\n\n  // Display internal log from step state snapshot\n  function displayLog(logArr) {\n    if (!logArr || logArr.length === 0) return '(No recent log messages)';\n    if (logArr.length > 3000) return logArr.slice(-3000).join('\\n');\n    return logArr.join('\\n');\n  }\n\n  // Helper: get a node snapshot by id from snapshot\n  function getNode(statesnap, nodeId) {\n    return statesnap.nodes.get(nodeId) || null;\n  }\n\n  // Search substring in tree:\n  // Returns list of suffix positions where substring occurs (based on leaves' suffix indices)\n  // Because we do not store explicit suffix indices, we can find first node/edge matching substring and collect leaves in subtree.\n\n  // We need to reconstruct suffix indices by DFS leaves:\n  // A leaf edge's start index correspond to suffix beginning.\n\n  // Returns array of positions, or empty [] if not found.\n\n  function searchSubstringInTree(statesnap, substring) {\n    if (!substring || substring.length === 0) return [];\n    const input = currentSuffixTree.input;\n    const nodes = statesnap.nodes;\n\n    // DFS matching substring on edges starting from root\n    function dfsMatch(nodeId, strIndex) {\n      if (strIndex === substring.length) return [nodeId];\n      const node = nodes.get(nodeId);\n      if (!node) return [];\n\n      const ch = substring[strIndex];\n      const edge = node.edges.get(ch);\n      if (!edge) return [];\n\n      // Match as much as possible on edge label\n      const edgeLabel = input.substring(edge.start, edge.endValue+1);\n      let i=0;\n      while(i < edgeLabel.length && strIndex < substring.length) {\n        if(substring[strIndex] !== edgeLabel[i]) return [];\n        i++; strIndex++;\n      }\n      if(strIndex === substring.length) return [edge.toId];\n      return dfsMatch(edge.toId, strIndex);\n    }\n\n    // Collect all leaves under node Id\n    function collectLeaves(nodeId, acc) {\n      const node = nodes.get(nodeId);\n      if (!node) return;\n      if (node.edges.size === 0) {\n        // Leaf node - suffix index is start of leaf edge from parent, but we don't store parent in snapshot.\n        // We can approximate by scanning all edges in entire tree to find leaf edge with toId = nodeId and record start index.\n        // To avoid O(n^2), we map leaf starts from edges on demand once:\n\n        // We'll implement leaf start map once\n        if(!searchSubstringInTree.leafStartMap) {\n          searchSubstringInTree.leafStartMap = new Map();\n          for(const nd of nodes.values()) {\n            for(const edge of nd.edges.values()) {\n              if(nodes.get(edge.toId).edges.size === 0) {\n                searchSubstringInTree.leafStartMap.set(edge.toId, edge.start);\n              }\n            }\n          }\n        }\n        const suffixStart = searchSubstringInTree.leafStartMap.get(nodeId);\n        if (typeof suffixStart === \"number\") {\n          acc.push(suffixStart);\n        }\n        return;\n      }\n      for(const edge of node.edges.values()) {\n        collectLeaves(edge.toId, acc);\n      }\n    }\n\n    let matchedNodes = dfsMatch(0, 0);\n    if (matchedNodes.length === 0) return [];\n    let foundPositions = [];\n    for(const nid of matchedNodes) {\n      collectLeaves(nid, foundPositions);\n    }\n    foundPositions.sort((a,b)=>a-b);\n    return foundPositions;\n  }\n\n  // ============== UI Update Functions ==============\n\n  function displayCurrentStep() {\n    if(!currentSuffixTree || currentSuffixTree.states.length === 0) return;\n\n    const snap = currentSuffixTree.states[currentStepIndex];\n    if(!snap) return;\n\n    let treeText;\n    const mode = viewModeSelect.value;\n    switch(mode) {\n      case \"edges\": treeText = displayTreeCompact(snap); break;\n      case \"nodes\": treeText = displayTreeNodesEdges(snap); break;\n      case \"paths\": treeText = displayTreeSuffixPaths(snap); break;\n      default: treeText = displayTreeCompact(snap); break;\n    }\n    treeDisplayEl.textContent = treeText + \"\\n\\n\" + activePointToString(snap.active);\n\n    // Show log from last step\n    logEl.textContent = displayLog(snap.log);\n  }\n\n  function setStatus(msg) {\n    document.getElementById('status').textContent = msg;\n  }\n\n  function clearSearchHighlight() {\n    searchSubstringInput.value = \"\";\n  }\n\n  // ============== Event Handlers ==============\n\n  buildTreeBtn.addEventListener('click', function() {\n    let s = sanitizeInput(inputStrEl.value);\n    if (s === null) {\n      setStatus('Error: Input string is empty.');\n      return;\n    }\n    s = ensureTerminalChar(s);\n    if (s.length > 150) {\n      setStatus('Warning: input truncated to 150 characters.');\n    }\n    inputStrEl.value = s;\n\n    resetSteps();\n\n    setStatus('Building suffix tree for input: \"' + s + '\" ...');\n    try {\n      currentSuffixTree = new SuffixTreeState(s);\n      // build full tree directly (for instant display, preserve stepwise for exploration)\n      currentSuffixTree.buildFullTree();\n      // reset stepwise interface for controlling detailed step builds\n      currentSuffixTree.resetStepwise();\n\n      currentStepIndex = 0;\n      displayCurrentStep();\n\n      setStatus('Suffix tree initialized. Use step explorer to explore construction.');\n    } catch(e) {\n      setStatus('Error during suffix tree construction: ' + e.message);\n    }\n  });\n\n  resetBtn.addEventListener('click', function() {\n    inputStrEl.value = '';\n    currentSuffixTree = null;\n    treeDisplayEl.textContent = '';\n    logEl.textContent = '';\n    setStatus('Reset done.');\n    currentStepIndex = 0;\n    clearSearchHighlight();\n    stopAutoplay();\n  });\n\n  viewModeSelect.addEventListener('change', function() {\n    displayCurrentStep();\n  });\n\n  // Stepwise controls:\n\n  function stepNext() {\n    if(!currentSuffixTree) {\n      setStatus('Build suffix tree first.');\n      return;\n    }\n    if(currentStepIndex < currentSuffixTree.states.length -1) {\n      currentStepIndex++;\n      displayCurrentStep();\n      setStatus(`Moved to step ${currentStepIndex} / ${currentSuffixTree.states.length - 1}`);\n    } else {\n      // Try to extend one step if not built fully yet\n      if(!currentSuffixTree.built) {\n        const ok = currentSuffixTree.extendPhase();\n        if(ok) {\n          currentStepIndex = currentSuffixTree.states.length - 1;\n          displayCurrentStep();\n          setStatus(`Extended phase to ${currentSuffixTree.currentPhase}`);\n        } else {\n          setStatus('Suffix tree build complete. No more steps.');\n        }\n      } else {\n        setStatus('Already at last step of suffix tree.');\n      }\n    }\n  }\n\n  function stepPrev() {\n    if(!currentSuffixTree) {\n      setStatus('Build suffix tree first.');\n      return;\n    }\n    if(currentStepIndex > 0) {\n      currentStepIndex--;\n      displayCurrentStep();\n      setStatus(`Moved back to step ${currentStepIndex} / ${currentSuffixTree.states.length - 1}`);\n    } else {\n      setStatus('Already at first step.');\n    }\n  }\n\n  stepNextBtn.addEventListener('click', stepNext);\n  stepPrevBtn.addEventListener('click', stepPrev);\n\n  resetStepsBtn.addEventListener('click', function() {\n    if(!currentSuffixTree) {\n      setStatus('Build suffix tree first.');\n      return;\n    }\n    currentSuffixTree.resetStepwise();\n    currentStepIndex = 0;\n    displayCurrentStep();\n    setStatus('Stepwise build reset to initial state.');\n    stopAutoplay();\n  });\n\n  // Autoplay stepwise building:\n\n  autoPlayBtn.addEventListener('click', function() {\n    if(!currentSuffixTree) {\n      setStatus('Build suffix tree first.');\n      return;\n    }\n    if(autoplayHandle !== null) return; // already playing\n    autoPlayBtn.disabled = true;\n    pausePlayBtn.disabled = false;\n    stepNextBtn.disabled = true;\n    stepPrevBtn.disabled = true;\n    resetStepsBtn.disabled = true;\n\n    let delay = Number(autoDelayInput.value);\n    if(isNaN(delay) || delay < 100) delay = 100;\n\n    autoplayHandle = setInterval(() => {\n      if(currentStepIndex >= currentSuffixTree.states.length - 1) {\n        if(!currentSuffixTree.built) {\n          currentSuffixTree.extendPhase();\n        }\n        currentStepIndex = currentSuffixTree.states.length - 1;\n        displayCurrentStep();\n        if(currentSuffixTree.built && currentStepIndex === currentSuffixTree.states.length - 1) {\n          setStatus('Autoplay finished at final step.');\n          stopAutoplay();\n        }\n      } else {\n        currentStepIndex++;\n        displayCurrentStep();\n        setStatus(`Autoplay: step ${currentStepIndex} / ${currentSuffixTree.states.length - 1}`);\n      }\n    }, delay);\n  });\n\n  pausePlayBtn.addEventListener('click', stopAutoplay);\n\n  function stopAutoplay() {\n    if(autoplayHandle !== null) {\n      clearInterval(autoplayHandle);\n      autoplayHandle = null;\n      autoPlayBtn.disabled = false;\n      pausePlayBtn.disabled = true;\n      stepNextBtn.disabled = false;\n      stepPrevBtn.disabled = false;\n      resetStepsBtn.disabled = false;\n      setStatus('Autoplay paused.');\n    }\n  }\n\n  // Search substring actions\n  searchBtn.addEventListener('click', function(){\n    if(!currentSuffixTree) {\n      setStatus('Build suffix tree first.');\n      return;\n    }\n    const toSearch = searchSubstringInput.value.trim();\n    if(toSearch.length === 0) {\n      setStatus('Enter a substring to search.');\n      return;\n    }\n    const positions = searchSubstringInTree(currentSuffixTree.states[currentStepIndex], toSearch);\n    if(positions.length === 0) {\n      setStatus(`Substring \"${toSearch}\" not found in the tree.`);\n    } else {\n      setStatus(`Substring \"${toSearch}\" found at suffix indices: ${positions.join(', ')}`);\n    }\n  });\n\n  clearSearchBtn.addEventListener('click', function(){\n    clearSearchHighlight();\n    setStatus('Search cleared.');\n  });\n\n  // Prevent form submit on Enter in input fields\n  searchSubstringInput.addEventListener('keydown', function(ev){\n    if(ev.key === 'Enter') {\n      ev.preventDefault();\n      searchBtn.click();\n    }\n  });\n\n  inputStrEl.addEventListener('keydown', function(ev){\n    // Do nothing special, no submit\n  });\n\n  // Warn user when they close/refresh page with unsaved progress\n  window.addEventListener(\"beforeunload\", function (e) {\n    if(currentSuffixTree && !currentSuffixTree.built) {\n      e.preventDefault();\n      e.returnValue = '';\n    }\n  });\n\n  // ============== Initialization ==============\n\n  setStatus('Enter a string and press \"Build Suffix Tree\" to start.');\n\n})();\n</script>\n</body>\n</html>"
