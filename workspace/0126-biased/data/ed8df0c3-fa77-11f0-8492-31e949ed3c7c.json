    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive PageRank Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #191b24;\n            color: #f0f0f0;\n            margin: 0;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n        }\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 20px;\n            text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.5);\n        }\n        .graph {\n            width: 80vmin;\n            height: 80vmin;\n            border-radius: 50%;\n            position: relative;\n            overflow: hidden;\n            box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);\n        }\n        .node {\n            position: absolute;\n            border-radius: 50%;\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            transition: transform 0.3s ease, background-color 0.3s ease;\n            font-size: 1.2em;\n        }\n        .edge {\n            position: absolute;\n            height: 2px;\n            background-color: rgba(255, 255, 255, 0.4);\n            transition: opacity 0.3s ease;\n        }\n        button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #3498db;\n            color: white;\n            font-size: 1em;\n            cursor: pointer;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);\n            transition: background-color 0.3s ease, transform 0.2s ease;\n        }\n        button:hover {\n            background-color: #2980b9;\n            transform: translateY(-2px);\n        }\n    </style>\n</head>\n<body>\n\n<h1>PageRank Visualization</h1>\n<div class=\"graph\" id=\"graph\"></div>\n<button id=\"startButton\">Start Animation</button>\n\n<script>\n    const graphElement = document.getElementById('graph');\n    const startButton = document.getElementById('startButton');\n\n    const nodes = [\n        { id: 0, value: 10, angle: 0 },\n        { id: 1, value: 20, angle: Math.PI / 2 },\n        { id: 2, value: 40, angle: Math.PI },\n        { id: 3, value: 30, angle: (3 * Math.PI) / 2 }\n    ];\n\n    const edges = [\n        { source: 0, target: 1 },\n        { source: 1, target: 2 },\n        { source: 2, target: 3 },\n        { source: 3, target: 0 }\n    ];\n\n    function drawGraph() {\n        nodes.forEach(node => {\n            const x = 40 * Math.cos(node.angle) + 50;\n            const y = 40 * Math.sin(node.angle) + 50;\n\n            const nodeElement = document.createElement('div');\n            nodeElement.className = 'node';\n            nodeElement.style.width = `${node.value}px`;\n            nodeElement.style.height = `${node.value}px`;\n            nodeElement.style.backgroundColor = `hsl(${node.value * 5}, 70%, 50%)`;\n            nodeElement.style.left = `${x}vmin`;\n            nodeElement.style.top = `${y}vmin`;\n            nodeElement.textContent = node.id;\n\n            graphElement.appendChild(nodeElement);\n        });\n\n        edges.forEach(edge => {\n            const sourceNode = nodes[edge.source];\n            const targetNode = nodes[edge.target];\n\n            const x1 = 40 * Math.cos(sourceNode.angle) + 50;\n            const y1 = 40 * Math.sin(sourceNode.angle) + 50;\n            const x2 = 40 * Math.cos(targetNode.angle) + 50;\n            const y2 = 40 * Math.sin(targetNode.angle) + 50;\n\n            const edgeElement = document.createElement('div');\n            edgeElement.className = 'edge';\n            edgeElement.style.left = `${x1}vmin`;\n            edgeElement.style.top = `${y1}vmin`;\n            edgeElement.style.width = `${Math.hypot(x2 - x1, y2 - y1)}vmin`;\n            edgeElement.style.transform = `rotate(${Math.atan2(y2 - y1, x2 - x1)}rad)`;\n            edgeElement.style.opacity = 0.5;\n\n            graphElement.appendChild(edgeElement);\n        });\n    }\n\n    startButton.addEventListener('click', () => {\n        drawGraph();\n        startButton.disabled = true;\n    });\n</script>\n\n</body>\n</html>"
