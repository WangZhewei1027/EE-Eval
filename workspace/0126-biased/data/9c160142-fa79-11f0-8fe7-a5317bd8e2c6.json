    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>REST API Interactive Playground (Minimal UI)</title>\n  <style>\n    /* Intentionally minimal: default browser styles only */\n  </style>\n</head>\n<body>\n  <h1>REST API Interactive Playground</h1>\n  <p>Minimal interface demonstrating a mock REST API server and many interactive controls. Create requests, change server behavior, record sequences, run batches, explore auth, caching, rate-limits, errors, and more.</p>\n\n  <fieldset>\n    <legend>Request Builder</legend>\n\n    Method:\n    <select id=\"req-method\">\n      <option>GET</option>\n      <option>POST</option>\n      <option>PUT</option>\n      <option>PATCH</option>\n      <option>DELETE</option>\n      <option>OPTIONS</option>\n    </select>\n\n    URL:\n    <input id=\"req-url\" size=\"50\" value=\"/todos\" />\n\n    <div>\n      Query params (key=value, one per line):\n      <br>\n      <textarea id=\"req-query\" rows=\"3\" cols=\"60\"></textarea>\n    </div>\n\n    <div>\n      Headers (key:value, one per line):\n      <br>\n      <textarea id=\"req-headers\" rows=\"3\" cols=\"60\"></textarea>\n    </div>\n\n    <div>\n      Body (JSON or raw):\n      <br>\n      <textarea id=\"req-body\" rows=\"8\" cols=\"60\">{ \"title\": \"New item\" }</textarea>\n    </div>\n\n    <div>\n      Auth:\n      <select id=\"auth-mode\">\n        <option value=\"none\">None</option>\n        <option value=\"basic\">Basic (username/password)</option>\n        <option value=\"bearer\">Bearer token</option>\n      </select>\n      <span id=\"auth-basic\" style=\"display:none\">\n        Username: <input id=\"auth-user\" value=\"admin\">\n        Password: <input id=\"auth-pass\" value=\"password\">\n      </span>\n      <span id=\"auth-bearer\" style=\"display:none\">\n        Token: <input id=\"auth-token\" size=\"30\">\n        <button id=\"use-latest-token\">Use latest issued token</button>\n      </span>\n    </div>\n\n    <div>\n      File upload (simulated, will embed base64 into body as \"fileData\"):\n      <input type=\"file\" id=\"req-file\">\n      <button id=\"attach-file\">Attach file to body</button>\n    </div>\n\n    <div>\n      Delay (ms): <input type=\"range\" id=\"req-delay\" min=\"0\" max=\"5000\" value=\"0\"> <span id=\"req-delay-val\">0</span>\n      Error probability (%): <input type=\"range\" id=\"req-errp\" min=\"0\" max=\"100\" value=\"0\"> <span id=\"req-errp-val\">0</span>\n    </div>\n\n    <div>\n      <button id=\"send-request\">Send Request</button>\n      <button id=\"send-repeat\">Send + Retry with backoff (3)</button>\n      <button id=\"batch-open\">Open Batch Composer</button>\n      <button id=\"record-toggle\">Start Recording Sequence</button>\n      <button id=\"save-preset\">Save Preset</button>\n      <button id=\"load-preset\">Load Preset</button>\n      <button id=\"clear-history\">Clear History</button>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Response / Inspector</legend>\n    <div>\n      Status: <span id=\"res-status\">-</span>\n      | Time: <span id=\"res-time\">-</span> ms\n      | Size: <span id=\"res-size\">-</span> bytes\n    </div>\n    <div>\n      Headers:\n      <pre id=\"res-headers\">-</pre>\n    </div>\n    <div>\n      Body:\n      <pre id=\"res-body\">-</pre>\n    </div>\n    <div>\n      Timeline / Logs:\n      <pre id=\"res-log\" style=\"height:140px; overflow:auto\"></pre>\n    </div>\n\n    <div>\n      Generated code:\n      <select id=\"code-type\"><option>cURL</option><option>fetch</option><option>axios</option></select>\n      <button id=\"gen-code\">Generate Code</button>\n      <pre id=\"code-out\"></pre>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>History & Presets</legend>\n    <div>\n      Recent Requests:\n      <ul id=\"history-list\"></ul>\n    </div>\n    <div>\n      Presets stored locally:\n      <ul id=\"presets-list\"></ul>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Server Controls and Mock Database</legend>\n    <div>\n      Server state:\n      <select id=\"server-mode\">\n        <option value=\"normal\">normal</option>\n        <option value=\"maintenance\">maintenance</option>\n        <option value=\"broken\">broken</option>\n        <option value=\"offline\">offline</option>\n      </select>\n      <button id=\"restart-server\">Restart Server</button>\n      <span>Current: <b id=\"server-state\">normal</b></span>\n    </div>\n\n    <div>\n      Rate limit (requests per minute per token): <input id=\"server-ratelimit\" value=\"60\" size=\"5\">\n      Global error probability (%) <input id=\"server-errp-global\" value=\"0\" size=\"3\">\n    </div>\n\n    <div>\n      Caching: <input type=\"checkbox\" id=\"server-cache\" checked> Use ETag & If-None-Match\n      Concurrency <input type=\"checkbox\" id=\"server-concurrency\" checked> Use If-Match/versions\n    </div>\n\n    <div>\n      Collections:\n      <select id=\"collection-select\">\n        <option>todos</option>\n        <option>users</option>\n      </select>\n      <button id=\"view-collection\">View</button>\n      <button id=\"add-random\">Add Random Item</button>\n      <button id=\"clear-collection\">Clear Collection</button>\n      <div>\n        Collection contents:\n        <pre id=\"collection-contents\" style=\"height:140px; overflow:auto\"></pre>\n      </div>\n    </div>\n\n    <div>\n      Tokens:\n      <button id=\"issue-token\">Issue Token</button>\n      Token list:\n      <ul id=\"token-list\"></ul>\n    </div>\n\n    <div>\n      Custom route behaviors (define a simple mock response):\n      <div>\n        Method: <select id=\"custom-method\"><option>GET</option><option>POST</option><option>PUT</option><option>DELETE</option></select>\n        Path template: <input id=\"custom-path\" value=\"/greet/:name\" size=\"20\">\n        Status: <input id=\"custom-status\" value=\"200\" size=\"4\">\n      </div>\n      <div>\n        Response template (JSON, use {{param}}, {{query.q}}, {{body.x}} placeholders):\n        <br>\n        <textarea id=\"custom-template\" rows=\"4\" cols=\"60\">{ \"message\": \"Hello {{param.name}}\", \"echoQuery\": \"{{query.q}}\" }</textarea>\n      </div>\n      <button id=\"add-custom-route\">Add Route</button>\n      <div>\n        Defined routes:\n        <ul id=\"custom-routes\"></ul>\n      </div>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Batch Composer & Sequence Runner</legend>\n    <div id=\"batch-area\" style=\"display:none\">\n      <div>\n        Compose batch (each line JSON with {method,url,headers,body}):\n        <br>\n        <textarea id=\"batch-text\" rows=\"6\" cols=\"80\">[{\"method\":\"GET\",\"url\":\"/todos\"},{\"method\":\"POST\",\"url\":\"/todos\",\"body\":{\"title\":\"Batch added\"}}]</textarea>\n      </div>\n      <div>\n        <button id=\"run-batch\">Run Batch</button>\n        <button id=\"close-batch\">Close Batch Composer</button>\n      </div>\n      <div>\n        Batch results:\n        <pre id=\"batch-results\" style=\"height:140px; overflow:auto\"></pre>\n      </div>\n    </div>\n\n    <div id=\"sequence-area\">\n      Sequence recorder:\n      <div>\n        <ol id=\"sequence-list\"></ol>\n      </div>\n      <div>\n        <button id=\"play-sequence\">Play Sequence</button>\n        <button id=\"clear-sequence\">Clear Sequence</button>\n      </div>\n      <div>\n        Add a conditional step:\n        Condition (JS with 'res' variable): <input id=\"seq-cond\" size=\"50\" value=\"res.status === 201\">\n        If true, run request (JSON): <input id=\"seq-req\" size=\"80\" value='{\"method\":\"GET\",\"url\":\"/todos\"}'>\n        <button id=\"add-seq-step\">Add Step</button>\n      </div>\n    </div>\n  </fieldset>\n\n  <script>\n    // Mock REST server core\n    (function(){\n      // Utilities\n      function now(){ return Date.now(); }\n      function deepClone(x){ return JSON.parse(JSON.stringify(x)); }\n      function parseHeaders(text){\n        const lines = text.split('\\\\n').map(s=>s.trim()).filter(Boolean);\n        const obj = {};\n        lines.forEach(l=>{\n          const i = l.indexOf(':');\n          if(i>=0){\n            const k = l.slice(0,i).trim();\n            const v = l.slice(i+1).trim();\n            obj[k] = v;\n          }\n        });\n        return obj;\n      }\n      function parseQuery(text){\n        const lines = text.split('\\\\n').map(s=>s.trim()).filter(Boolean);\n        const q = {};\n        lines.forEach(l=>{\n          const i = l.indexOf('=');\n          if(i>=0){\n            const k = l.slice(0,i);\n            const v = l.slice(i+1);\n            q[k] = v;\n          }\n        });\n        return q;\n      }\n      function parseUrlQuery(url){\n        const q = {};\n        const idx = url.indexOf('?');\n        if(idx<0) return {path:url, query:{}};\n        const path = url.slice(0,idx);\n        const params = url.slice(idx+1).split('&').filter(Boolean);\n        params.forEach(p=>{\n          const [k,v=''] = p.split('=');\n          q[decodeURIComponent(k)] = decodeURIComponent(v||'');\n        });\n        return {path, query:q};\n      }\n      function uuid(){ return Math.random().toString(36).slice(2,10); }\n      function etagFor(obj){ try{ return '\"' + btoa(unescape(encodeURIComponent(JSON.stringify(obj)))).slice(0,12) + '\"'; }catch(e){ return '\"0\"'; } }\n      function matchPath(template, actual){\n        // template like /todos/:id/sub\n        const tA = template.split('/').filter(Boolean);\n        const aA = actual.split('/').filter(Boolean);\n        if(tA.length !== aA.length) return null;\n        const params = {};\n        for(let i=0;i<tA.length;i++){\n          if(tA[i].startsWith(':')){\n            params[tA[i].slice(1)] = decodeURIComponent(aA[i]);\n          } else if(tA[i] !== aA[i]) return null;\n        }\n        return params;\n      }\n\n      // In-memory DB\n      const DB = {\n        todos: [],\n        users: []\n      };\n\n      // Seed DB\n      for(let i=1;i<=5;i++){\n        DB.todos.push({ id: String(i), title: 'Todo #' + i, completed: i%2===0, version: 1, createdAt: Date.now() - i*100000 });\n      }\n      DB.users.push({ id: 'u1', name: 'Alice', role:'admin', version:1 });\n\n      // Server config and routes\n      const server = {\n        mode: 'normal', // normal, maintenance, broken, offline\n        rateLimitPerMin: 60,\n        globalErrorProbability: 0,\n        cache: true,\n        concurrency: true,\n        tokens: [], // {token,issued,expiresAt,limit,requests}\n        routes: [], // custom routes\n        logs: []\n      };\n\n      // Default helper routes\n      function findRoute(method, path){\n        // check custom routes first\n        for(let r of server.routes){\n          if(r.method === method){\n            const params = matchPath(r.path, path);\n            if(params) return { custom: r, params };\n          }\n        }\n        // built-in routes:\n        // /todos, /todos/:id, /users, /users/:id, /auth/login, /batch\n        const builtins = [\n          { method:'GET', path:'/todos' },\n          { method:'POST', path:'/todos' },\n          { method:'GET', path:'/todos/:id' },\n          { method:'PUT', path:'/todos/:id' },\n          { method:'PATCH', path:'/todos/:id' },\n          { method:'DELETE', path:'/todos/:id' },\n\n          { method:'GET', path:'/users' },\n          { method:'POST', path:'/users' },\n          { method:'GET', path:'/users/:id' },\n\n          { method:'POST', path:'/auth/login' },\n          { method:'POST', path:'/batch' }\n        ];\n        for(let b of builtins){\n          if(b.method === method){\n            const params = matchPath(b.path, path);\n            if(params) return { builtin: b.path, params };\n          }\n        }\n        return null;\n      }\n\n      // Logging helper\n      function log(...args){\n        server.logs.push({time:now(), msg: args.join(' ')});\n        if(server.logs.length>200) server.logs.shift();\n        renderLogs();\n      }\n\n      // Rate limiter reset interval\n      setInterval(()=>{ server.tokens.forEach(t=>t.requests=0); }, 60*1000);\n\n      // Expose server functions\n      window.MockServer = {\n        DB, server,\n        findRoute,\n        handleRequest: async function(request){\n          // request: {method, path, query, headers, body, authToken, clientDelay, errProb}\n          const start = now();\n          // Immediate offline check\n          if(server.mode === 'offline'){\n            await delay(10);\n            return {status:0, headers:{}, body:'Server offline', time: now()-start, size:0, log:'offline'};\n          }\n          // Maintenance vs broken\n          if(server.mode === 'maintenance'){\n            await delay(100);\n            return {status:503, headers:{'Retry-After':'60'}, body:{error:'maintenance'}, time: now()-start, size:0};\n          }\n          if(server.mode === 'broken'){\n            if(Math.random()<0.5) return {status:500, headers:{}, body:{error:'broken'}, time: now()-start, size:0};\n          }\n\n          // Global simulated error\n          const totalErrProb = Math.min(100, (server.globalErrorProbability||0) + (request.errProb||0));\n          if(Math.random()*100 < totalErrProb){\n            await delay(request.clientDelay || 0);\n            log('Injected error for', request.method, request.path);\n            return {status:500, headers:{}, body:{error:'injected error'}, time: now()-start, size:0};\n          }\n\n          // Rate limiting\n          if(request.authToken){\n            const t = server.tokens.find(x=>x.token===request.authToken);\n            if(t){\n              t.requests = (t.requests||0) + 1;\n              const limit = t.limit || server.rateLimitPerMin;\n              if((t.requests||0) > limit){\n                return {status:429, headers:{'X-RateLimit-Limit':String(limit), 'X-RateLimit-Remaining':'0'}, body:{error:'rate limit exceeded'}, time: now()-start, size:0};\n              }\n            } else {\n              // unknown token => 401\n              return {status:401, headers:{}, body:{error:'invalid token'}, time: now()-start, size:0};\n            }\n          } else {\n            // If endpoint requires auth (we can decide that POST/PUT/PATCH/DELETE require auth for todos)\n            if(['POST','PUT','PATCH','DELETE'].includes(request.method) && request.path.startsWith('/todos')){\n              return {status:401, headers:{}, body:{error:'auth required'}, time: now()-start, size:0};\n            }\n          }\n\n          // Check custom routes\n          const matched = findRoute(request.method, request.path);\n          if(matched && matched.custom){\n            // Render template with placeholders\n            const r = matched.custom;\n            const params = matched.params;\n            let outText = r.template;\n            // simple placeholder replacement\n            outText = outText.replace(/\\\\{\\\\{\\\\s*param\\\\.([a-zA-Z0-9_]+)\\\\s*\\\\}\\\\}/g, (_,k)=>params[k]||'');\n            outText = outText.replace(/\\\\{\\\\{\\\\s*query\\\\.([a-zA-Z0-9_]+)\\\\s*\\\\}\\\\}/g, (_,k)=>request.query[k]||'');\n            outText = outText.replace(/\\\\{\\\\{\\\\s*body\\\\.([a-zA-Z0-9_]+)\\\\s*\\\\}\\\\}/g, (_,k)=> (request.body && request.body[k]) ? request.body[k] : '' );\n            await delay(request.clientDelay || 0);\n            let parsed;\n            try{ parsed = JSON.parse(outText); }catch(e){ parsed = outText; }\n            return {status:Number(r.status), headers:{'Content-Type':'application/json'}, body:parsed, time: now()-start, size:JSON.stringify(parsed).length};\n          }\n\n          // Builtin handlers\n          if(matched && matched.builtin){\n            const pathTemplate = matched.builtin;\n            const pathParams = matched.params;\n            // Simulate time\n            await delay(request.clientDelay || 0);\n\n            // /auth/login\n            if(methodEquals(request.method,'POST') && pathTemplate === '/auth/login'){\n              const body = request.body || {};\n              if(body.username === 'admin' && body.password === 'password'){\n                const token = 'tkn_' + uuid();\n                const expires = now() + 60*60*1000;\n                const t = {token, issued: now(), expiresAt: expires, limit: server.rateLimitPerMin, requests:0};\n                server.tokens.push(t);\n                log('Issued token', token);\n                return {status:201, headers:{}, body:{token, expiresAt:expires}, time: now()-start, size:0};\n              } else {\n                return {status:401, headers:{}, body:{error:'bad credentials'}, time: now()-start, size:0};\n              }\n            }\n\n            // /batch\n            if(methodEquals(request.method,'POST') && pathTemplate === '/batch'){\n              // body should be array of request specs\n              const items = Array.isArray(request.body) ? request.body : [];\n              const results = [];\n              for(let it of items){\n                const rreq = {\n                  method: it.method || 'GET',\n                  path: it.url || '/',\n                  query: it.query || {},\n                  headers: it.headers || {},\n                  body: it.body || {},\n                  authToken: it.authToken || request.authToken,\n                  clientDelay: it.delay || 0,\n                  errProb: it.errProb || 0\n                };\n                const res = await window.MockServer.handleRequest(rreq);\n                results.push({status:res.status, body:res.body, headers:res.headers});\n              }\n              return {status:200, headers:{}, body:results, time: now()-start, size:JSON.stringify(results).length};\n            }\n\n            // Todos collection\n            if(pathTemplate.startsWith('/todos')){\n              if(methodEquals(request.method,'GET') && pathTemplate === '/todos'){\n                // support pagination & filter & sort via request.query\n                let items = DB.todos.slice();\n                // filters\n                if(request.query && request.query.filter){\n                  try{\n                    const f = JSON.parse(request.query.filter);\n                    items = items.filter(it=>{\n                      for(let k in f){ if(String(it[k]) !== String(f[k])) return false; }\n                      return true;\n                    });\n                  }catch(e){}\n                }\n                // search q\n                if(request.query && request.query.q){\n                  const q = request.query.q.toLowerCase();\n                  items = items.filter(it => JSON.stringify(it).toLowerCase().includes(q));\n                }\n                // sort\n                if(request.query && request.query.sort){\n                  const s = request.query.sort;\n                  items.sort((a,b)=> a[s] > b[s] ? 1 : -1);\n                }\n                // pagination\n                let page = Number(request.query.page) || 1;\n                let limit = Number(request.query.limit) || 10;\n                const total = items.length;\n                const startIdx = (page-1)*limit;\n                const pageItems = items.slice(startIdx, startIdx+limit);\n                // ETag support\n                const et = etagFor(pageItems);\n                if(server.cache && request.headers && request.headers['If-None-Match'] && request.headers['If-None-Match'] === et){\n                  return {status:304, headers:{ETag:et}, body:null, time: now()-start, size:0};\n                }\n                return {status:200, headers:{ETag:et, 'X-Total-Count':String(total)}, body:{items:pageItems, page, limit, total, _links:{self:request.path }}, time: now()-start, size:JSON.stringify(pageItems).length};\n              }\n\n              // GET /todos/:id\n              if(methodEquals(request.method,'GET') && pathTemplate === '/todos/:id'){\n                const id = pathParams.id;\n                const item = DB.todos.find(x=>x.id===id);\n                if(!item) return {status:404, headers:{}, body:{error:'not found'}};\n                const et = etagFor(item);\n                if(server.cache && request.headers && request.headers['If-None-Match'] && request.headers['If-None-Match'] === et){\n                  return {status:304, headers:{ETag:et}, body:null};\n                }\n                return {status:200, headers:{ETag:et}, body:item, time: now()-start, size:JSON.stringify(item).length};\n              }\n\n              // POST /todos\n              if(methodEquals(request.method,'POST') && pathTemplate === '/todos'){\n                // require auth already checked above\n                const body = request.body || {};\n                if(!body.title) return {status:422, headers:{}, body:{error:'title required'}};\n                const id = String(DB.todos.length ? (Number(DB.todos[DB.todos.length-1].id)+1) : 1);\n                const newItem = { id, title: body.title, completed: !!body.completed, version: 1, createdAt: now() };\n                DB.todos.push(newItem);\n                return {status:201, headers:{Location:'/todos/'+id}, body:newItem, time: now()-start, size:JSON.stringify(newItem).length};\n              }\n\n              // PUT /todos/:id or PATCH\n              if((methodEquals(request.method,'PUT') || methodEquals(request.method,'PATCH')) && pathTemplate === '/todos/:id'){\n                const id = pathParams.id;\n                const idx = DB.todos.findIndex(x=>x.id===id);\n                if(idx<0) return {status:404, headers:{}, body:{error:'not found'}};\n                const existing = DB.todos[idx];\n                // concurrency: If-Match header required if enabled\n                if(server.concurrency && request.headers && request.headers['If-Match']){\n                  const curET = etagFor(existing);\n                  if(request.headers['If-Match'] !== curET) return {status:412, headers:{}, body:{error:'etag mismatch, conflict'}};\n                }\n                const body = request.body || {};\n                const updated = methodEquals(request.method,'PUT') ? Object.assign({}, existing, body) : Object.assign({}, existing, body);\n                updated.version = (existing.version||1)+1;\n                DB.todos[idx] = updated;\n                return {status:200, headers:{ETag:etagFor(updated)}, body:updated, time: now()-start, size:JSON.stringify(updated).length};\n              }\n\n              // DELETE /todos/:id\n              if(methodEquals(request.method,'DELETE') && pathTemplate === '/todos/:id'){\n                const id = pathParams.id;\n                const idx = DB.todos.findIndex(x=>x.id===id);\n                if(idx<0) return {status:404, headers:{}, body:{error:'not found'}};\n                DB.todos.splice(idx,1);\n                return {status:204, headers:{}, body:null, time: now()-start, size:0};\n              }\n            } // end todos\n\n            // Users\n            if(pathTemplate.startsWith('/users')){\n              if(methodEquals(request.method,'GET') && pathTemplate === '/users'){\n                return {status:200, headers:{}, body:DB.users};\n              }\n              if(methodEquals(request.method,'POST') && pathTemplate === '/users'){\n                const b = request.body || {};\n                if(!b.name) return {status:422, body:{error:'name required'}};\n                const id = 'u' + (DB.users.length+1);\n                const u = {id, name: b.name, version:1};\n                DB.users.push(u);\n                return {status:201, headers:{Location:'/users/'+id}, body:u};\n              }\n              if(methodEquals(request.method,'GET') && pathTemplate === '/users/:id'){\n                const id = pathParams.id;\n                const u = DB.users.find(x=>x.id===id);\n                if(!u) return {status:404, body:{error:'not found'}};\n                return {status:200, body:u};\n              }\n            }\n\n          } // end builtin handling\n\n          // Unknown route\n          return {status:404, headers:{}, body:{error:'not found'}};\n        }\n      };\n\n      // Helper\n      function methodEquals(a,b){ return String(a).toUpperCase() === String(b).toUpperCase(); }\n\n      // Delay helper\n      function delay(ms){ return new Promise(res=>setTimeout(res, ms || 0)); }\n\n      // Expose functions to UI\n      window.MockServerAPI = {\n        DB,\n        server,\n        log,\n        issueToken: function(limitMinutes){\n          const token = 'tkn_' + uuid();\n          const t = {token, issued: now(), expiresAt: now() + 60*60*1000, limit: server.rateLimitPerMin, requests:0};\n          server.tokens.push(t);\n          log('Issued token', token);\n          renderTokens();\n          return t;\n        },\n        clearCollection: function(name){ DB[name] = []; renderCollection(); },\n        addRandom: function(name){\n          if(name === 'todos'){\n            const id = String(DB.todos.length ? (Number(DB.todos[DB.todos.length-1].id)+1) : 1);\n            DB.todos.push({id, title: 'Generated '+Math.random().toString(36).slice(2,6), completed: false, version:1, createdAt: now()});\n          } else if(name === 'users'){\n            const id = 'u'+(DB.users.length+1);\n            DB.users.push({id, name: 'User'+Math.random().toString(36).slice(2,4), version:1});\n          }\n          renderCollection();\n        },\n        addCustomRoute: function(method, path, status, template){\n          server.routes.push({method, path, status, template});\n          renderCustomRoutes();\n        },\n        getLogs: function(){ return server.logs.slice(); }\n      };\n\n      // UI wiring - declare elements\n      const el = id => document.getElementById(id);\n\n      // Request UI\n      el('req-delay').addEventListener('input', ()=> el('req-delay-val').textContent = el('req-delay').value);\n      el('req-errp').addEventListener('input', ()=> el('req-errp-val').textContent = el('req-errp').value);\n\n      el('auth-mode').addEventListener('change', ()=>{\n        const v = el('auth-mode').value;\n        el('auth-basic').style.display = v==='basic' ? '' : 'none';\n        el('auth-bearer').style.display = v==='bearer' ? '' : 'none';\n      });\n\n      el('use-latest-token').addEventListener('click', ()=>{\n        const t = server.tokens[server.tokens.length-1];\n        if(t) el('auth-token').value = t.token;\n      });\n\n      // Send request action\n      el('send-request').addEventListener('click', async ()=>{\n        const req = buildRequestFromUI();\n        await sendAndRender(req, {record:true});\n      });\n\n      el('send-repeat').addEventListener('click', async ()=>{\n        const req = buildRequestFromUI();\n        await retryWithBackoff(req, 3);\n      });\n\n      el('attach-file').addEventListener('click', ()=> {\n        const f = el('req-file').files[0];\n        if(!f) return alert('Choose a file first');\n        const reader = new FileReader();\n        reader.onload = function(e){\n          try{\n            const bodyText = el('req-body').value.trim();\n            let body = {};\n            try{ body = JSON.parse(bodyText); }catch(e){ body = {}; }\n            body.fileName = f.name;\n            body.fileData = e.target.result.split(',')[1]; // base64\n            el('req-body').value = JSON.stringify(body, null, 2);\n          }catch(e){ alert('Failed to attach file'); }\n        };\n        reader.readAsDataURL(f);\n      });\n\n      // File prefill\n      el('req-file').addEventListener('change', ()=>{ /* noop */ });\n\n      // Batch composer\n      el('batch-open').addEventListener('click', ()=> el('batch-area').style.display = '');\n      el('close-batch').addEventListener('click', ()=> el('batch-area').style.display = 'none');\n      el('run-batch').addEventListener('click', async ()=>{\n        let arr;\n        try{ arr = JSON.parse(el('batch-text').value); }catch(e){ return alert('Invalid JSON'); }\n        const req = { method:'POST', path:'/batch', body: arr, query:{}, headers:{}, authToken: null, clientDelay:0, errProb:0 };\n        // attach auth if chosen in UI\n        const am = el('auth-mode').value;\n        if(am==='bearer') req.authToken = el('auth-token').value;\n        const res = await window.MockServer.handleRequest(req);\n        el('batch-results').textContent = JSON.stringify(res, null, 2);\n      });\n\n      // History\n      const HISTORY_KEY = 'rest_play_history_v1';\n      let HISTORY = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');\n      function pushHistory(item){\n        HISTORY.unshift(Object.assign({time: now()}, item));\n        if(HISTORY.length>50) HISTORY.length = 50;\n        localStorage.setItem(HISTORY_KEY, JSON.stringify(HISTORY));\n        renderHistory();\n      }\n      function renderHistory(){\n        const ul = el('history-list'); ul.innerHTML = '';\n        HISTORY.forEach((h, idx)=>{\n          const li = document.createElement('li');\n          const t = new Date(h.time).toLocaleTimeString();\n          li.textContent = `[${t}] ${h.method} ${h.url} => ${h.response && h.response.status || '-'}`;\n          li.style.cursor = 'pointer';\n          li.addEventListener('click', ()=> {\n            // restore\n            el('req-method').value = h.method;\n            el('req-url').value = h.url;\n            el('req-headers').value = (h.requestHeadersText||'');\n            el('req-body').value = (h.requestBodyText||'');\n            el('req-query').value = (h.requestQueryText||'');\n          });\n          ul.appendChild(li);\n        });\n      }\n      renderHistory();\n\n      // Presets\n      const PRESETS_KEY = 'rest_play_presets_v1';\n      function savePreset(){\n        const p = {\n          method: el('req-method').value,\n          url: el('req-url').value,\n          headers: el('req-headers').value,\n          body: el('req-body').value,\n          query: el('req-query').value\n        };\n        const presets = JSON.parse(localStorage.getItem(PRESETS_KEY) || '[]');\n        presets.push({name: 'preset '+(new Date()).toLocaleTimeString(), data:p});\n        localStorage.setItem(PRESETS_KEY, JSON.stringify(presets));\n        renderPresets();\n      }\n      function renderPresets(){\n        const ul = el('presets-list'); ul.innerHTML='';\n        const presets = JSON.parse(localStorage.getItem(PRESETS_KEY) || '[]');\n        presets.forEach((p, idx)=>{\n          const li = document.createElement('li');\n          li.textContent = p.name;\n          const btn = document.createElement('button'); btn.textContent = 'Load';\n          btn.addEventListener('click', ()=>{\n            el('req-method').value = p.data.method;\n            el('req-url').value = p.data.url;\n            el('req-headers').value = p.data.headers;\n            el('req-body').value = p.data.body;\n            el('req-query').value = p.data.query;\n          });\n          li.appendChild(btn);\n          ul.appendChild(li);\n        });\n      }\n      renderPresets();\n      el('save-preset').addEventListener('click', savePreset);\n      el('load-preset').addEventListener('click', ()=> renderPresets());\n\n      el('clear-history').addEventListener('click', ()=> {\n        HISTORY = [];\n        localStorage.removeItem(HISTORY_KEY);\n        renderHistory();\n      });\n\n      // Server controls\n      el('server-mode').addEventListener('change', ()=> {\n        server.mode = el('server-mode').value;\n        el('server-state').textContent = server.mode;\n        log('Server mode changed to', server.mode);\n      });\n      el('restart-server').addEventListener('click', ()=> {\n        server.mode = 'normal';\n        el('server-mode').value = 'normal';\n        el('server-state').textContent = 'normal';\n        server.logs = [];\n        log('Server restarted');\n      });\n      el('server-ratelimit').addEventListener('change', ()=> { server.rateLimitPerMin = Number(el('server-ratelimit').value); });\n      el('server-errp-global').addEventListener('change', ()=> { server.globalErrorProbability = Number(el('server-errp-global').value); });\n      el('server-cache').addEventListener('change', ()=> { server.cache = el('server-cache').checked; });\n      el('server-concurrency').addEventListener('change', ()=> { server.concurrency = el('server-concurrency').checked; });\n\n      // Collections\n      function renderCollection(){\n        const sel = el('collection-select').value;\n        el('collection-contents').textContent = JSON.stringify(window.MockServer.DB[sel], null, 2);\n      }\n      el('view-collection').addEventListener('click', renderCollection);\n      el('add-random').addEventListener('click', ()=> {\n        window.MockServer.addRandom(el('collection-select').value);\n      });\n      el('clear-collection').addEventListener('click', ()=> {\n        const c = el('collection-select').value;\n        if(!confirm('Clear collection '+c+'?')) return;\n        window.MockServer.clearCollection(c);\n      });\n\n      // Tokens\n      function renderTokens(){\n        const ul = el('token-list'); ul.innerHTML='';\n        server.tokens.forEach(t=>{\n          const li = document.createElement('li');\n          li.textContent = t.token + ' (requests:'+ (t.requests||0) +')';\n          const btn = document.createElement('button'); btn.textContent='Revoke';\n          btn.addEventListener('click', ()=> {\n            server.tokens = server.tokens.filter(x=>x.token!==t.token);\n            renderTokens();\n            log('Revoked token', t.token);\n          });\n          li.appendChild(btn);\n          ul.appendChild(li);\n        });\n      }\n      el('issue-token').addEventListener('click', ()=> {\n        const t = window.MockServer.issueToken();\n        renderTokens();\n      });\n      renderTokens();\n\n      // Custom routes\n      function renderCustomRoutes(){\n        const ul = el('custom-routes'); ul.innerHTML='';\n        server.routes.forEach((r, idx)=>{\n          const li = document.createElement('li');\n          li.textContent = `${r.method} ${r.path} -> ${r.status}`;\n          const btn = document.createElement('button'); btn.textContent='Remove';\n          btn.addEventListener('click', ()=> { server.routes.splice(idx,1); renderCustomRoutes(); });\n          li.appendChild(btn);\n          ul.appendChild(li);\n        });\n      }\n      el('add-custom-route').addEventListener('click', ()=> {\n        const m = el('custom-method').value;\n        const p = el('custom-path').value.trim();\n        const s = el('custom-status').value;\n        const t = el('custom-template').value;\n        server.routes.push({method:m, path:p, status:s, template:t});\n        renderCustomRoutes();\n      });\n\n      // Logs rendering\n      function renderLogs(){\n        const logs = server.logs.slice(-200).map(l=> new Date(l.time).toLocaleTimeString() + ' ' + l.msg).join('\\\\n');\n        el('res-log').textContent = logs;\n      }\n      setInterval(renderLogs, 1000);\n\n      // Sequence recorder\n      let recording = false;\n      const SEQ_KEY = 'rest_play_sequence_v1';\n      let SEQUENCE = JSON.parse(localStorage.getItem(SEQ_KEY) || '[]');\n      function renderSequence(){\n        const ol = el('sequence-list'); ol.innerHTML='';\n        SEQUENCE.forEach((s, idx)=>{\n          const li = document.createElement('li');\n          li.textContent = `If (${s.cond}) then ${s.req.method} ${s.req.url}`;\n          const btn = document.createElement('button'); btn.textContent='Run';\n          btn.addEventListener('click', async ()=> {\n            const r = expandSeqReq(s.req);\n            const res = await window.MockServer.handleRequest(r);\n            el('res-body').textContent = JSON.stringify(res.body, null, 2);\n            el('res-status').textContent = res.status;\n          });\n          const del = document.createElement('button'); del.textContent='Del';\n          del.addEventListener('click', ()=> { SEQUENCE.splice(idx,1); localStorage.setItem(SEQ_KEY, JSON.stringify(SEQUENCE)); renderSequence(); });\n          li.appendChild(btn); li.appendChild(del);\n          ol.appendChild(li);\n        });\n      }\n      function expandSeqReq(reqRaw){\n        const req = JSON.parse(JSON.stringify(reqRaw));\n        req.path = req.url;\n        req.query = req.query || {};\n        req.headers = req.headers || {};\n        req.authToken = req.authToken || (el('auth-mode').value==='bearer' ? el('auth-token').value : null);\n        req.clientDelay = Number(el('req-delay').value) || 0;\n        return req;\n      }\n      el('record-toggle').addEventListener('click', ()=> {\n        recording = !recording;\n        el('record-toggle').textContent = recording ? 'Stop Recording Sequence' : 'Start Recording Sequence';\n      });\n      el('add-seq-step').addEventListener('click', ()=> {\n        const cond = el('seq-cond').value;\n        let req;\n        try{ req = JSON.parse(el('seq-req').value); }catch(e){ return alert('Invalid request JSON'); }\n        SEQUENCE.push({cond, req});\n        localStorage.setItem(SEQ_KEY, JSON.stringify(SEQUENCE));\n        renderSequence();\n      });\n      el('play-sequence').addEventListener('click', async ()=> {\n        for(let step of SEQUENCE){\n          // evaluate cond with last response in context\n          const lastRes = window._lastResponse || {status:0, body:null, headers:{}};\n          let ok = false;\n          try{ ok = !!(new Function('res', 'return ' + step.cond))(lastRes); }catch(e){ ok = false; }\n          if(ok){\n            const r = expandSeqReq(step.req);\n            const res = await window.MockServer.handleRequest(r);\n            window._lastResponse = res;\n            el('res-body').textContent = JSON.stringify(res.body, null, 2);\n            el('res-status').textContent = res.status;\n          }\n        }\n      });\n      el('clear-sequence').addEventListener('click', ()=> { SEQUENCE=[]; localStorage.removeItem(SEQ_KEY); renderSequence(); });\n      renderSequence();\n\n      // Sequence recording: when recording, every send will be appended\n      function recordStepFromRequest(req, res){\n        if(!recording) return;\n        // simple record: condition always true, request saved\n        SEQUENCE.push({cond: 'true', req: {method: req.method, url: req.path, body:req.body}});\n        localStorage.setItem(SEQ_KEY, JSON.stringify(SEQUENCE));\n        renderSequence();\n      }\n\n      // Send + render\n      async function sendAndRender(req, opts){\n        opts = opts || {};\n        const start = now();\n        renderRequestPreview(req);\n        try{\n          const res = await window.MockServer.handleRequest(req);\n          const duration = now()-start;\n          displayResponse(res, duration);\n          // push to history\n          pushHistory({\n            method: req.method,\n            url: req.path,\n            requestHeadersText: Object.entries(req.headers||{}).map(([k,v])=>k+': '+v).join('\\\\n'),\n            requestBodyText: typeof req.body === 'object' ? JSON.stringify(req.body) : (req.body||''),\n            requestQueryText: Object.entries(req.query||{}).map(([k,v])=>k+'='+v).join('\\\\n'),\n            response: res\n          });\n          recordStepFromRequest(req, res);\n        }catch(e){\n          el('res-body').textContent = 'Error: ' + String(e);\n        }\n      }\n\n      function renderRequestPreview(req){\n        el('res-log').textContent = 'Sending ' + req.method + ' ' + req.path + '\\\\n';\n      }\n\n      function displayResponse(res, duration){\n        el('res-status').textContent = res.status;\n        el('res-time').textContent = String(duration);\n        el('res-size').textContent = String(res.size||0);\n        el('res-headers').textContent = JSON.stringify(res.headers||{}, null, 2);\n        el('res-body').textContent = typeof res.body === 'object' ? JSON.stringify(res.body, null, 2) : String(res.body);\n        renderLogs();\n      }\n\n      // Build request from UI fields\n      function buildRequestFromUI(){\n        const method = el('req-method').value;\n        const rawUrl = el('req-url').value.trim();\n        const parsed = parseUrlQuery(rawUrl);\n        const path = parsed.path;\n        const queryFromUrl = parsed.query || {};\n        const qText = el('req-query').value.trim();\n        const qFromText = parseQuery(qText);\n        const query = Object.assign({}, queryFromUrl, qFromText);\n        const headers = parseHeaders(el('req-headers').value);\n        let body;\n        const bodyText = el('req-body').value.trim();\n        try{ body = bodyText ? JSON.parse(bodyText) : null; }catch(e){ body = bodyText; }\n        // auth\n        let authToken = null;\n        const am = el('auth-mode').value;\n        if(am === 'basic'){\n          const user = el('auth-user').value;\n          const pass = el('auth-pass').value;\n          headers['Authorization'] = 'Basic ' + btoa(user + ':' + pass);\n        } else if(am === 'bearer'){\n          authToken = el('auth-token').value;\n          headers['Authorization'] = 'Bearer ' + authToken;\n        }\n        // respect If-None-Match or If-Match if headers text contains them\n        const delayMS = Number(el('req-delay').value) || 0;\n        const errProb = Number(el('req-errp').value) || 0;\n        return { method, path, query, headers, body, authToken, clientDelay: delayMS, errProb };\n      }\n\n      // Retry with exponential backoff\n      async function retryWithBackoff(req, attempts){\n        let attempt = 0;\n        while(attempt < attempts){\n          attempt++;\n          const res = await window.MockServer.handleRequest(req);\n          displayResponse(res, 0);\n          if(res.status >=200 && res.status < 300) return res;\n          // if client or server error, retry with backoff\n          await new Promise(r => setTimeout(r, Math.pow(2, attempt) * 200));\n        }\n        alert('Retries exhausted');\n      }\n\n      // Code generation\n      el('gen-code').addEventListener('click', ()=>{\n        const type = el('code-type').value;\n        const req = buildRequestFromUI();\n        const url = req.path + (Object.keys(req.query||{}).length ? '?' + Object.entries(req.query).map(([k,v])=>encodeURIComponent(k)+'='+encodeURIComponent(v)).join('&') : '');\n        const headers = req.headers || {};\n        if(req.authToken && !headers['Authorization']) headers['Authorization'] = 'Bearer ' + req.authToken;\n        let out = '';\n        if(type === 'cURL'){\n          out = `curl -X ${req.method} \"${url}\"`;\n          for(let k in headers) out += ` -H \"${k}: ${headers[k]}\"`;\n          if(req.body) out += ` -d '${typeof req.body === 'string' ? req.body : JSON.stringify(req.body)}'`;\n        } else if(type === 'fetch'){\n          out = `fetch(\"${url}\", { method: \"${req.method}\", headers: ${JSON.stringify(headers)}, body: ${req.body ? JSON.stringify(req.body) : 'undefined'} }).then(r=>r.json()).then(console.log)`;\n        } else if(type === 'axios'){\n          out = `axios(${JSON.stringify({ url, method: req.method.toLowerCase(), headers, data: req.body }, null, 2)})`;\n        }\n        el('code-out').textContent = out;\n      });\n\n      // History restore / clickable items already handled\n\n      // Collection render initial\n      renderCollection();\n      renderTokens();\n      renderCustomRoutes();\n      renderLogs();\n\n      // Make MockServer accessible for debugging\n      window._MockServer = window.MockServer;\n    })();\n\n    // Small helpers used in UI functions that reference MockServer var\n    function renderTokens(){ if(window.MockServerAPI) window.MockServerAPI && window.MockServerAPI.server && renderTokensInternal(); }\n    function renderTokensInternal(){}\n  </script>\n</body>\n</html>"
  },
