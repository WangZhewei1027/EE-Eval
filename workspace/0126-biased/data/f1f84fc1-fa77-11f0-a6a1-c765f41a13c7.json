    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Routing — Visual Concept</title>\n<style>\n  :root{\n    --bg-1: #071028;\n    --bg-2: #081428;\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --accent-a: #00E0D2; /* teal */\n    --accent-b: #7C5CFF; /* violet */\n    --accent-c: #FF6BA6; /* rose */\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --white: #EAF6FF;\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    font-synthesis: none;\n  }\n\n  /* Base layout */\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.08), transparent 8%),\n                radial-gradient(800px 500px at 95% 90%, rgba(0,224,210,0.06), transparent 10%),\n                linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n    color:var(--white);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  .wrap{\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n    gap:32px;\n  }\n\n  /* Card */\n  .panel{\n    width:1100px;\n    max-width:calc(100vw - 64px);\n    height:680px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    box-shadow:var(--shadow);\n    position:relative;\n    overflow:hidden;\n    border: 1px solid rgba(255,255,255,0.04);\n    display:grid;\n    grid-template-columns: 380px 1fr;\n    gap:0;\n  }\n\n  /* Left descriptive column */\n  .side{\n    padding:40px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), transparent 40%), repeating-linear-gradient(45deg, rgba(255,255,255,0.006), rgba(255,255,255,0.006) 1px, transparent 1px, transparent 12px);\n    border-right: 1px solid rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n    gap:18px;\n  }\n\n  .title{\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  h1{\n    margin:0;\n    font-weight:700;\n    letter-spacing: -0.02em;\n    font-size:30px;\n    color:var(--white);\n  }\n  .tag{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    font-size:13px;\n    color:var(--muted);\n  }\n  .tag .dot{\n    width:10px;height:10px;border-radius:50%;\n    background: linear-gradient(180deg,var(--accent-a), var(--accent-b));\n    box-shadow: 0 6px 18px rgba(124,92,255,0.18), 0 2px 8px rgba(0,224,210,0.06);\n  }\n\n  p.lead{\n    margin:0;\n    color:rgba(234,246,255,0.82);\n    line-height:1.5;\n    font-size:14.5px;\n  }\n\n  .meta{\n    display:flex;\n    gap:12px;\n    margin-top:10px;\n    align-items:center;\n    flex-wrap:wrap;\n  }\n  .chip{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    padding:8px 12px;\n    border-radius:999px;\n    font-size:13px;\n    color:var(--muted);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    backdrop-filter: blur(6px);\n  }\n\n  .legend{\n    margin-top:18px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  .legend .item{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .legend .swatch{\n    width:12px;height:12px;border-radius:3px;\n    box-shadow: 0 4px 14px rgba(0,0,0,0.45);\n  }\n  .legend .label{\n    font-size:13px;\n    color:rgba(234,246,255,0.85);\n  }\n\n  .footer{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .byline{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .byline .badge{\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:8px 10px;\n    border-radius:8px;\n    font-weight:600;\n    color:var(--muted);\n    font-size:13px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Visualization area */\n  .canvas{\n    position:relative;\n    overflow:hidden;\n    background:\n      radial-gradient(circle at 70% 30%, rgba(124,92,255,0.06), transparent 6%),\n      radial-gradient(circle at 20% 80%, rgba(0,224,210,0.04), transparent 8%),\n      linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.01) 100%);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Glossy overlay */\n  .canvas::after{\n    content:'';\n    position:absolute;\n    inset:0;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.002));\n    pointer-events:none;\n  }\n\n  /* Info card on top */\n  .info-card{\n    position:absolute;\n    left:48px;\n    top:36px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:14px 16px;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.5);\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--white);\n    z-index:5;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    font-size:13px;\n  }\n\n  .info-card .core{\n    width:44px;height:44px;border-radius:10px;\n    background: linear-gradient(180deg, rgba(124,92,255,0.2), rgba(0,224,210,0.06));\n    display:grid;\n    place-items:center;\n    font-weight:700;\n    color:rgba(255,255,255,0.95);\n    box-shadow: 0 6px 18px rgba(124,92,255,0.08), inset 0 -6px 20px rgba(0,0,0,0.2);\n    border:1px solid rgba(255,255,255,0.03);\n    font-size:13px;\n  }\n  .info-card .desc{\n    display:flex;\n    flex-direction:column;\n    gap:4px;\n  }\n  .info-card .desc .h{\n    font-size:13px;\n    color:var(--white);\n    font-weight:600;\n  }\n  .info-card .desc .s{\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  /* Play/Pause button */\n  .control{\n    position:absolute;\n    right:22px;\n    bottom:22px;\n    z-index:12;\n    width:64px;\n    height:64px;\n    border-radius:18px;\n    display:grid;\n    place-items:center;\n    cursor:pointer;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 12px 30px rgba(2,6,23,0.6);\n    transition: transform .28s cubic-bezier(.2,.9,.2,1), box-shadow .28s;\n    backdrop-filter: blur(8px);\n  }\n  .control:active{ transform:scale(.98); }\n  .control .icon{\n    width:36px;height:36px;border-radius:10px;display:grid;place-items:center;\n    background: linear-gradient(90deg, rgba(124,92,255,0.12), rgba(0,224,210,0.06));\n    color:var(--white);\n    font-weight:700;\n    font-size:14px;\n    box-shadow: 0 8px 20px rgba(0,0,0,0.45), inset 0 -6px 14px rgba(0,0,0,0.12);\n  }\n\n  /* SVG styles */\n  svg{\n    width:100%;\n    height:100%;\n    display:block;\n  }\n\n  .node{\n    filter: drop-shadow(0 10px 26px rgba(2,6,23,0.6));\n    transition: transform .28s cubic-bezier(.2,.9,.2,1);\n  }\n  .node .coreNode{\n    fill: url(#gCore);\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1.5px;\n  }\n  .node .edgeNode{\n    fill: url(#gEdge);\n    stroke: rgba(255,255,255,0.04);\n    stroke-width:1px;\n  }\n\n  .route{\n    fill:none;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    stroke-width:3.6;\n    mix-blend-mode:screen;\n    filter: drop-shadow(0 10px 30px rgba(12,20,40,0.6));\n    transition: opacity .6s, stroke-width .36s;\n  }\n\n  /* subtle glowing highlight along route (animated via opacity) */\n  .glow{\n    opacity:0.85;\n    filter: blur(8px) saturate(1.2);\n    transition: opacity .4s, transform .4s;\n  }\n\n  /* small packet */\n  .packet{\n    pointer-events:none;\n    filter: drop-shadow(0 10px 26px rgba(2,6,23,0.5));\n    transition: transform .12s linear;\n  }\n\n  /* motion ambient lines */\n  .ambient-line{\n    stroke: rgba(255,255,255,0.02);\n    stroke-width:1;\n    stroke-dasharray:4 10;\n  }\n\n  /* Fade in animation */\n  .panel{ animation:panelIn .9s cubic-bezier(.2,.9,.2,1) both; }\n  @keyframes panelIn{\n    from{ transform: translateY(10px) scale(.995); opacity:0; }\n    to{ transform:none; opacity:1; }\n  }\n\n  /* small responsive tweaks */\n  @media (max-width:980px){\n    .panel{ grid-template-columns: 1fr; height:760px; width:calc(100vw - 48px); }\n    .side{ order:2; border-right:none; border-top: 1px solid rgba(255,255,255,0.02); }\n    .canvas{ order:1; min-height:420px; }\n    .info-card{ left:18px; top:18px; }\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"panel\" role=\"region\" aria-label=\"Routing visualization\">\n    <div class=\"side\">\n      <div>\n        <div class=\"title\">\n          <div class=\"tag\"><span class=\"dot\" aria-hidden=\"true\"></span><span style=\"font-weight:600;color:var(--white);\">Routing</span></div>\n          <h1>Routing — directing flow through paths</h1>\n        </div>\n        <p class=\"lead\">A visual interpretation of routing: how decisions guide packets along paths from edge nodes to a central core and onward. Layers of prioritized routes, dynamic selection, and graceful convergence — distilled into a calm, aesthetic representation.</p>\n\n        <div class=\"meta\" aria-hidden=\"true\">\n          <div class=\"chip\">Adaptive paths</div>\n          <div class=\"chip\">Priority rules</div>\n          <div class=\"chip\">Convergence & throughput</div>\n        </div>\n\n        <div class=\"legend\" aria-hidden=\"true\" style=\"margin-top:22px\">\n          <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,var(--accent-a),var(--accent-b))\"></div><div class=\"label\">Primary Route — Low latency</div></div>\n          <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,var(--accent-b),var(--accent-c))\"></div><div class=\"label\">Secondary Route — Balanced</div></div>\n          <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,var(--accent-c),var(--accent-a))\"></div><div class=\"label\">Fallback Route — Reliable</div></div>\n        </div>\n      </div>\n\n      <div class=\"footer\">\n        <div class=\"byline\">\n          <div class=\"badge\">Conceptual</div>\n          <div style=\"color:var(--muted)\">Observe the flow — one click to pause.</div>\n        </div>\n        <div style=\"color:var(--muted)\">v1.0</div>\n      </div>\n    </div>\n\n    <div class=\"canvas\" aria-hidden=\"false\">\n      <!-- Info card -->\n      <div class=\"info-card\" aria-hidden=\"true\">\n        <div class=\"core\">CORE</div>\n        <div class=\"desc\">\n          <div class=\"h\">Core Router</div>\n          <div class=\"s\">Aggregates routes and selects optimal paths</div>\n        </div>\n      </div>\n\n      <!-- Play/Pause control -->\n      <div class=\"control\" id=\"toggleBtn\" title=\"Pause animation\" role=\"button\" aria-label=\"Pause animation\">\n        <div class=\"icon\" id=\"toggleIcon\">||</div>\n      </div>\n\n      <!-- SVG visual -->\n      <svg viewBox=\"0 0 1200 720\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Routing network diagram\">\n        <defs>\n          <!-- gradients -->\n          <linearGradient id=\"gCore\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7C5CFF\" stop-opacity=\"0.95\"/>\n            <stop offset=\"1\" stop-color=\"#00E0D2\" stop-opacity=\"0.95\"/>\n          </linearGradient>\n          <linearGradient id=\"gEdge\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#0EA5A4\"/>\n            <stop offset=\"1\" stop-color=\"#7C5CFF\"/>\n          </linearGradient>\n\n          <!-- packet gradient -->\n          <radialGradient id=\"gPkt\" cx=\"50%\" cy=\"40%\" r=\"70%\">\n            <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.95\"/>\n            <stop offset=\"40%\" stop-color=\"#fff9\" stop-opacity=\"0.9\"/>\n            <stop offset=\"100%\" stop-color=\"#ffffff\" stop-opacity=\"0.15\"/>\n          </radialGradient>\n\n          <!-- soft glow -->\n          <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"10\" result=\"b\"/>\n            <feMerge>\n              <feMergeNode in=\"b\"/>\n              <feMergeNode in=\"SourceGraphic\"/>\n            </feMerge>\n          </filter>\n        </defs>\n\n        <!-- ambient background paths for subtle structure -->\n        <g opacity=\"0.08\">\n          <path class=\"ambient-line\" d=\"M80,620 C300,480 420,300 600,360\" stroke-width=\"1.2\"/>\n          <path class=\"ambient-line\" d=\"M1120,600 C920,460 780,280 600,340\" stroke-width=\"1.2\"/>\n        </g>\n\n        <!-- routes: three main paths connecting edges to core -->\n        <g id=\"routes\" transform=\"translate(0,0)\">\n\n          <!-- Primary route (teal -> violet) -->\n          <path id=\"route1\" class=\"route glow\" d=\"M160 120 C360 140 520 260 600 360\" stroke=\"url(#r1)\" stroke-width=\"4\">\n          </path>\n\n          <!-- Secondary route (violet -> rose) -->\n          <path id=\"route2\" class=\"route glow\" d=\"M1040 140 C840 160 700 260 640 360\" stroke=\"url(#r2)\" stroke-width=\"3.6\">\n          </path>\n\n          <!-- Fallback route (rose -> teal) -->\n          <path id=\"route3\" class=\"route glow\" d=\"M240 620 C420 520 780 520 940 420\" stroke=\"url(#r3)\" stroke-width=\"3.6\">\n          </path>\n        </g>\n\n        <!-- strokes are filled dynamically with gradients using stroke gradients -->\n        <defs>\n          <linearGradient id=\"r1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#00E0D2\"/>\n            <stop offset=\"100%\" stop-color=\"#7C5CFF\"/>\n          </linearGradient>\n          <linearGradient id=\"r2\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7C5CFF\"/>\n            <stop offset=\"100%\" stop-color=\"#FF6BA6\"/>\n          </linearGradient>\n          <linearGradient id=\"r3\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#FF6BA6\"/>\n            <stop offset=\"100%\" stop-color=\"#00E0D2\"/>\n          </linearGradient>\n        </defs>\n\n        <!-- glow overlay duplicates for soft blur -->\n        <g opacity=\"0.9\" filter=\"url(#softGlow)\">\n          <path id=\"route1glow\" class=\"route\" d=\"M160 120 C360 140 520 260 600 360\" stroke=\"url(#r1)\" stroke-width=\"12\" opacity=\"0.18\"></path>\n          <path id=\"route2glow\" class=\"route\" d=\"M1040 140 C840 160 700 260 640 360\" stroke=\"url(#r2)\" stroke-width=\"10\" opacity=\"0.12\"></path>\n          <path id=\"route3glow\" class=\"route\" d=\"M240 620 C420 520 780 520 940 420\" stroke=\"url(#r3)\" stroke-width=\"10\" opacity=\"0.12\"></path>\n        </g>\n\n        <!-- nodes -->\n        <g id=\"nodes\" aria-hidden=\"true\">\n          <!-- left-top edge -->\n          <g class=\"node edge\" transform=\"translate(160,120)\">\n            <rect x=\"-28\" y=\"-18\" width=\"56\" height=\"36\" rx=\"8\" class=\"edgeNode\"></rect>\n            <text x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.95)\" font-size=\"12\" font-weight=\"700\">A</text>\n          </g>\n\n          <!-- right-top edge -->\n          <g class=\"node edge\" transform=\"translate(1040,140)\">\n            <rect x=\"-28\" y=\"-18\" width=\"56\" height=\"36\" rx=\"8\" class=\"edgeNode\"></rect>\n            <text x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.95)\" font-size=\"12\" font-weight=\"700\">B</text>\n          </g>\n\n          <!-- left-bottom edge -->\n          <g class=\"node edge\" transform=\"translate(240,620)\">\n            <rect x=\"-28\" y=\"-18\" width=\"56\" height=\"36\" rx=\"8\" class=\"edgeNode\"></rect>\n            <text x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.95)\" font-size=\"12\" font-weight=\"700\">C</text>\n          </g>\n\n          <!-- core -->\n          <g class=\"node core\" transform=\"translate(600,360)\">\n            <rect x=\"-52\" y=\"-38\" width=\"104\" height=\"76\" rx=\"16\" class=\"coreNode\"></rect>\n            <text x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.98)\" font-size=\"13\" font-weight=\"800\">CORE</text>\n          </g>\n        </g>\n\n        <!-- packets (movable circles placed initially off-canvas) -->\n        <g id=\"packets\" aria-hidden=\"true\">\n          <circle id=\"pkt1\" class=\"packet\" r=\"7\" fill=\"url(#gPkt)\" stroke=\"rgba(0,224,210,0.15)\" stroke-width=\"1.2\" opacity=\"1\"></circle>\n          <circle id=\"pkt2\" class=\"packet\" r=\"6.2\" fill=\"url(#gPkt)\" stroke=\"rgba(124,92,255,0.14)\" stroke-width=\"1.2\" opacity=\"0.95\"></circle>\n          <circle id=\"pkt3\" class=\"packet\" r=\"6.6\" fill=\"url(#gPkt)\" stroke=\"rgba(255,107,166,0.14)\" stroke-width=\"1.2\" opacity=\"0.95\"></circle>\n        </g>\n\n      </svg>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function(){\n    // Minimal, high-quality animation: move three packets along three distinct routes.\n    // Interactivity limited: single play/pause button.\n    const btn = document.getElementById('toggleBtn');\n    const icon = document.getElementById('toggleIcon');\n\n    const svg = document.querySelector('svg');\n    const route1 = document.getElementById('route1');\n    const route2 = document.getElementById('route2');\n    const route3 = document.getElementById('route3');\n\n    const pkt1 = document.getElementById('pkt1');\n    const pkt2 = document.getElementById('pkt2');\n    const pkt3 = document.getElementById('pkt3');\n\n    // prepare path lengths\n    const paths = [\n      { path: route1, pkt: pkt1, speed: 0.025, offset: 0 },\n      { path: route2, pkt: pkt2, speed: 0.02, offset: 0.35 },\n      { path: route3, pkt: pkt3, speed: 0.018, offset: 0.7 }\n    ];\n\n    paths.forEach(p => {\n      p.len = p.path.getTotalLength();\n      // ensure stroke-linecap not interfering visually by minor offset\n      p.offset = (p.offset || 0) * p.len;\n    });\n\n    let playing = true;\n    let last = performance.now();\n\n    // easing to gently pulse route glows\n    const glowEls = [document.getElementById('route1glow'), document.getElementById('route2glow'), document.getElementById('route3glow')];\n\n    // subtle rhythm trackers for glow\n    const glowState = [\n      {phase:0, speed:0.0008, base:0.16},\n      {phase:0.6, speed:0.00075, base:0.12},\n      {phase:0.4, speed:0.0009, base:0.12}\n    ];\n\n    function placePacketOnPath(p, progress){\n      // progress from 0..1\n      const L = p.len;\n      const d = (p.offset + progress * L) % L;\n      const pt = p.path.getPointAtLength(d);\n      p.pkt.setAttribute('cx', pt.x);\n      p.pkt.setAttribute('cy', pt.y);\n      // subtle scale based on curvature (fake) using derivative approximation\n      const ahead = p.path.getPointAtLength((d + 6) % L);\n      const dx = ahead.x - pt.x;\n      const dy = ahead.y - pt.y;\n      const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n      p.pkt.style.transform = `translate(-50%,-50%) rotate(${angle}deg)`;\n      // alpha modulation\n      const alpha = 0.9 + 0.1 * Math.sin(progress * Math.PI * 2 + p.offset*0.01);\n      p.pkt.setAttribute('opacity', alpha);\n    }\n\n    // initialize positions\n    paths.forEach((p,i)=>{\n      placePacketOnPath(p, (i*0.33));\n    });\n\n    function animate(now){\n      const dt = Math.min(40, now - last);\n      last = now;\n\n      if (playing){\n        paths.forEach(p=>{\n          // progress increases by speed * dt\n          p.offset = (p.offset + p.speed * dt) % p.len;\n          // compute normalized progress for visual modulation\n          const progress = (p.offset % p.len) / p.len;\n          placePacketOnPath(p, progress);\n        });\n\n        // animate glow subtly\n        glowState.forEach((g, i)=>{\n          g.phase += g.speed * dt;\n          const pulse = (Math.sin(g.phase * Math.PI * 2) * 0.5 + 0.5);\n          const opacity = g.base + pulse * 0.14;\n          const el = glowEls[i];\n          el.setAttribute('opacity', opacity.toString());\n          // slightly modulate stroke-width\n          const baseW = i===0 ? 12 : 10;\n          el.setAttribute('stroke-width', (baseW + pulse*8).toString());\n        });\n      }\n\n      // gentle idle motion: rotate small rotation on core to imply activity\n      const core = document.querySelector('.node.core');\n      const rot = Math.sin(now/8000) * 2;\n      core && (core.style.transform = `rotate(${rot}deg)`);\n\n      requestAnimationFrame(animate);\n    }\n\n    let raf = requestAnimationFrame(animate);\n\n    // Toggle play/pause\n    function setPlaying(val){\n      playing = val;\n      if (playing){\n        icon.textContent = '||';\n        btn.title = 'Pause animation';\n        btn.setAttribute('aria-label','Pause animation');\n        last = performance.now();\n      } else {\n        icon.textContent = '▶';\n        btn.title = 'Resume animation';\n        btn.setAttribute('aria-label','Resume animation');\n      }\n      // subtle visual feedback\n      btn.style.boxShadow = playing ? '0 12px 30px rgba(2,6,23,0.6)' : '0 8px 18px rgba(2,6,23,0.45)';\n    }\n\n    btn.addEventListener('click', function(){\n      setPlaying(!playing);\n    });\n\n    // Start in playing state for an elegant entrance.\n    setPlaying(true);\n\n    // Accessibility: space/enter to toggle\n    btn.addEventListener('keydown', (e)=>{\n      if (e.key === ' ' || e.key === 'Enter'){ e.preventDefault(); setPlaying(!playing); }\n    });\n\n    // Respect reduced-motion if user prefers\n    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');\n    if (mq && mq.matches){\n      setPlaying(false);\n    }\n\n    // Resize handling to ensure packets are placed correctly after layout changes\n    window.addEventListener('resize', () => {\n      // recompute lengths\n      paths.forEach(p => {\n        p.len = p.path.getTotalLength();\n      });\n    });\n\n  })();\n</script>\n</body>\n</html>"
  },
