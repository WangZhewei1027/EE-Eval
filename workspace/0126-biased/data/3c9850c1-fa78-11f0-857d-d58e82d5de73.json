    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Dynamic Programming — Visualized Elegance</title>\n<style>\n  /* Import Google Fonts */\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Montserrat:wght@800&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #2a1a61 0%, #4d3e9e 40%, #1e244b 100%);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e0e0;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  /* Container */\n  .container {\n    max-width: 960px;\n    margin: 3rem auto;\n    padding: 0 1.5rem;\n    text-align: center;\n  }\n\n  /* Title */\n  h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 800;\n    font-size: 3.6rem;\n    letter-spacing: 0.18rem;\n    margin-bottom: 0.4rem;\n    color: #f3f0ff;\n    text-shadow:\n      0 0 12px #8c78c7,\n      0 0 18px #6e57eb,\n      0 0 30px #6641d9;\n    user-select: none;\n  }\n\n  /* Subtitle */\n  .subtitle {\n    font-weight: 300;\n    font-size: 1.3rem;\n    color: #b3a6ffdd;\n    margin-bottom: 3rem;\n    letter-spacing: 0.06rem;\n    font-style: italic;\n  }\n\n  /* Visual DP Grid Container */\n  .dp-visual {\n    position: relative;\n    margin: 0 auto 4rem;\n    width: 600px;\n    height: 600px;\n    background:\n      radial-gradient(circle at center, #4d3e9e 20%, #322470 90%);\n    border-radius: 32px;\n    box-shadow:\n      inset 0 0 30px 4px #725ddd66,\n      0 0 35px 6px #b1a3ff88;\n    backdrop-filter: blur(8px);\n    user-select: none;\n    overflow: visible;\n  }\n\n  /* Grid lines for DP table */\n  .dp-grid {\n    display: grid;\n    position: absolute;\n    top: 40px;\n    left: 52px;\n    grid-template-columns: repeat(8, 58px);\n    grid-template-rows: repeat(8, 58px);\n    gap: 6px;\n  }\n\n  /* Each DP cell */\n  .dp-cell {\n    background: linear-gradient(145deg, #5c4fbb, #3e2f8e);\n    border-radius: 14px;\n    box-shadow:\n      inset 0 5px 7px #7d6ac3,\n      inset 0 -5px 7px #2a1c6f,\n      0 8px 12px -3px #000000aa;\n    color: #d9d5ffcc;\n    font-weight: 600;\n    font-size: 1.4rem;\n    line-height: 56px;\n    text-shadow: 0 0 5px #9c8bf7;\n    user-select: none;\n    cursor: default;\n    transition:\n      background 0.3s ease,\n      color 0.25s ease,\n      box-shadow 0.4s ease;\n    transform-style: preserve-3d;\n  }\n\n  /* Highlighted updated DP cells */\n  .dp-cell.update {\n    background: linear-gradient(135deg, #a58df8 20%, #6d58f5 90%);\n    color: #fdfcff;\n    box-shadow:\n      0 0 18px 3px #b79fff,\n      inset 0 6px 10px #c1b5ffcc;\n    animation: pulseUpdate 1.4s ease forwards;\n  }\n  @keyframes pulseUpdate {\n    0% {\n      box-shadow:\n        0 0 30px 6px #bcaaffcc,\n        inset 0 10px 17px #d2c4ffcc;\n      color: #fff;\n      transform: scale(1.05);\n    }\n    70% {\n      box-shadow:\n        0 0 15px 3px #a192e0cc,\n        inset 0 6px 10px #c1b5ffcc;\n      transform: scale(1);\n      color: #e6e2ffcc;\n    }\n    100% {\n      box-shadow:\n        0 0 18px 3px #b79fff,\n        inset 0 6px 10px #c1b5ffcc;\n      transform: scale(1.02);\n      color: #fdfcff;\n    }\n  }\n\n  /* Axis labels */\n  .axis-labels {\n    position: absolute;\n    top: 8px; left: 52px;\n    display: flex;\n    width: 480px;\n    justify-content: space-between;\n    font-weight: 700;\n    font-size: 1.4rem;\n    letter-spacing: 0.1rem;\n    color: #a893ffcc;\n    user-select: none;\n  }\n  .axis-labels.y {\n    top: 40px; left: 10px;\n    height: 480px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    writing-mode: vertical-rl;\n    font-weight: 700;\n    font-size: 1.4rem;\n    letter-spacing: 0.1rem;\n    color: #a893ffcc;\n  }\n\n  /* Description panel */\n  .description {\n    background: rgba(47, 39, 89, 0.6);\n    padding: 2rem 2.5rem;\n    border-radius: 24px;\n    box-shadow:\n      0 0 36px 6px #725ddd99;\n    max-width: 700px;\n    margin: 0 auto 4rem;\n    font-weight: 300;\n    line-height: 1.65;\n    font-size: 1.12rem;\n    color: #cec9ffcc;\n    user-select: none;\n  }\n\n  /* Highlight words in description */\n  .highlight {\n    color: #d1c3ff;\n    font-weight: 600;\n    text-shadow: 0 0 8px #a195f7dd;\n  }\n\n  /* Buttons container */\n  .btn-group {\n    margin-top: 1rem;\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n  button {\n    cursor: pointer;\n    background: linear-gradient(145deg, #6859c6, #463db5);\n    border: none;\n    color: #f4f2ffdd;\n    font-weight: 600;\n    letter-spacing: 0.04rem;\n    font-size: 1.1rem;\n    padding: 0.6rem 1.6rem;\n    border-radius: 18px;\n    box-shadow:\n      0 5px 12px #362d7477,\n      inset 0 -3px 6px #251e4fbb;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.2s ease;\n    user-select: none;\n    user-drag: none;\n  }\n  button:hover, button:focus {\n    background: linear-gradient(135deg, #7262f5, #665cf9);\n    box-shadow:\n      0 8px 20px #6158ffbb,\n      inset 0 -4px 7px #3a35b0cc;\n    outline: none;\n    transform: translateY(-3px);\n  }\n  button:active {\n    box-shadow:\n      0 3px 7px #322f99cc,\n      inset 0 1px 2px #5348c9;\n    transform: translateY(0);\n  }\n\n  /* Footer */\n  footer {\n    color: #7b76b9cc;\n    font-size: 0.9rem;\n    text-align: center;\n    margin: 4rem 0 2rem;\n    user-select: none;\n  }\n\n  /* Fancy subtle background shapes (light shining effect) */\n  .light-spot {\n    position: absolute;\n    width: 600px;\n    height: 600px;\n    border-radius: 50%;\n    pointer-events: none;\n    filter: blur(150px);\n    opacity: 0.25;\n    mix-blend-mode: screen;\n    animation: floatLight 20s linear infinite;\n  }\n  .light-spot.one {\n    background: #9e90ff70;\n    top: -100px;\n    left: -120px;\n    animation-delay: 0s;\n  }\n  .light-spot.two {\n    background: #6a5fdb88;\n    bottom: -140px;\n    right: -130px;\n    animation-delay: 10s;\n  }\n  @keyframes floatLight {\n    0% { transform: translate(0,0) scale(1); }\n    50% { transform: translate(20px,15px) scale(1.1); }\n    100% { transform: translate(0,0) scale(1); }\n  }\n\n  /* Dynamic Programming Title Effect */\n  h1 span {\n    display: inline-block;\n    opacity: 0.9;\n    transform-origin: center bottom;\n    animation: shimmerText 3.6s ease-in-out infinite;\n    position: relative;\n  }\n  h1 span:nth-child(odd) {\n    animation-delay: calc(var(--i) * 0.12s);\n  }\n  @keyframes shimmerText {\n    0%, 100% {\n      opacity: 0.9;\n      transform: scale(1) translateY(0);\n      text-shadow:\n        0 0 16px #aa99ffcc,\n        0 0 24px #b192efcc;\n    }\n    50% {\n      opacity: 1;\n      transform: scale(1.1) translateY(-6px);\n      text-shadow:\n        0 0 32px #d2bfffdd,\n        0 0 42px #c4baffdd,\n        0 12px 16px #7b62cecc;\n    }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\" aria-label=\"Dynamic Programming demonstration\">\n\n    <h1 aria-label=\"Dynamic Programming\">\n      <span style=\"--i:0;\">D</span><span style=\"--i:1;\">y</span><span style=\"--i:2;\">n</span><span style=\"--i:3;\">a</span><span style=\"--i:4;\">m</span><span style=\"--i:5;\">i</span><span style=\"--i:6;\">c</span>\n      &nbsp;\n      <span style=\"--i:7;\">P</span><span style=\"--i:8;\">r</span><span style=\"--i:9;\">o</span><span style=\"--i:10;\">g</span><span style=\"--i:11;\">r</span><span style=\"--i:12;\">a</span><span style=\"--i:13;\">m</span><span style=\"--i:14;\">m</span><span style=\"--i:15;\">i</span><span style=\"--i:16;\">n</span><span style=\"--i:17;\">g</span>\n    </h1>\n    <p class=\"subtitle\">Optimal substructure & overlapping subproblems visualized as glowing matrices</p>\n\n    <div class=\"dp-visual\" aria-label=\"Visual demonstration of Dynamic Programming table\">\n      <div class=\"light-spot one\" aria-hidden=\"true\"></div>\n      <div class=\"light-spot two\" aria-hidden=\"true\"></div>\n\n      <div class=\"axis-labels x\" aria-hidden=\"true\" role=\"presentation\">\n        <div>0</div>\n        <div>1</div>\n        <div>2</div>\n        <div>3</div>\n        <div>4</div>\n        <div>5</div>\n        <div>6</div>\n        <div>7</div>\n      </div>\n      <div class=\"axis-labels y\" aria-hidden=\"true\" role=\"presentation\">\n        <div>0</div>\n        <div>1</div>\n        <div>2</div>\n        <div>3</div>\n        <div>4</div>\n        <div>5</div>\n        <div>6</div>\n        <div>7</div>\n      </div>\n\n      <div class=\"dp-grid\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions\">\n        <!-- 8x8 grid cells will be dynamically inserted here -->\n      </div>\n    </div>\n\n    <div class=\"description\" aria-label=\"Explanation of Dynamic Programming concept\" tabindex=\"0\">\n      <strong class=\"highlight\">Dynamic Programming</strong> is a method for solving complex problems by breaking them down into simpler, overlapping <em>subproblems</em> and storing their solutions to avoid redundant computations. It leverages the concept of <span class=\"highlight\">optimal substructure</span>—where an optimal solution can be constructed efficiently from optimal solutions of its subproblems. This visualization depicts a classic DP table where values update progressively, each <span class=\"highlight\">cell</span> representing a subproblem’s solution and glowing softly as it gets computed. Observe the cascading effect as results build upon one another, embodying the essence of <strong>overlapping subproblems</strong> and “divide & conquer” fused with memorization.\n    </div>\n\n    <div class=\"btn-group\" aria-label=\"Interactive controls for animation\">\n      <button id=\"startBtn\" aria-pressed=\"false\" aria-label=\"Start Dynamic Programming animation\">Start Animation</button>\n      <button id=\"resetBtn\" aria-label=\"Reset Dynamic Programming animation\">Reset</button>\n    </div>\n\n  </div>\n\n<script>\n  (() => {\n    const gridContainer = document.querySelector('.dp-grid');\n    const ROWS = 8;\n    const COLS = 8;\n\n    // DP matrix initialization\n    // For demonstration, we will fill with Fibonacci-like values from top-left\n    // Simple 2D bottom-up DP example: dp[i][j] = dp[i-1][j] + dp[i][j-1] (with edges=1)\n    const dp = [];\n    for (let i=0;i<ROWS;i++){\n      dp[i] = new Array(COLS).fill(0);\n    }\n\n    // Create cells in DOM\n    function createGrid(){\n      gridContainer.innerHTML = '';\n      for (let i=0; i<ROWS; i++){\n        for (let j=0; j<COLS; j++){\n          const cell = document.createElement('div');\n          cell.classList.add('dp-cell');\n          cell.setAttribute('data-row', i);\n          cell.setAttribute('data-col', j);\n          cell.setAttribute('aria-label', `Cell at row ${i}, column ${j}, value 0`);\n          cell.textContent = '0';\n          gridContainer.appendChild(cell);\n        }\n      }\n    }\n\n    // Update a cell with animation\n    function updateCell(r, c, val){\n      const cell = gridContainer.querySelector(`.dp-cell[data-row=\"${r}\"][data-col=\"${c}\"]`);\n      if(!cell) return;\n      cell.textContent = val;\n      cell.setAttribute('aria-label', `Cell at row ${r}, column ${c}, value ${val}`);\n      cell.classList.add('update');\n      setTimeout(() => {\n        cell.classList.remove('update');\n      }, 1400);\n    }\n\n    // Animation sequence for dp calculation\n    // We'll calculate dp row-wise covering all cells with a delay\n    // dp[i][j] = dp[i-1][j] + dp[i][j-1]; edges = 1\n    let animationTimeouts = [];\n    function startAnimation(){\n      clearAnimation();\n\n      // Initialize edges\n      for(let i=0; i<ROWS; i++){\n        dp[i][0] = 1;\n        updateCell(i,0,1);\n      }\n      for(let j=0; j<COLS; j++){\n        dp[0][j] = 1;\n        updateCell(0,j,1);\n      }\n\n      let step = 0;\n\n      // Calculate other cells with delay to simulate computation\n      for(let i=1; i<ROWS; i++){\n        for(let j=1; j<COLS; j++){\n          animationTimeouts.push(setTimeout(() => {\n            dp[i][j] = dp[i-1][j] + dp[i][j-1];\n            updateCell(i,j,dp[i][j]);\n          }, 600 + step * 330));\n          step++;\n        }\n      }\n    }\n\n    function clearAnimation(){\n      animationTimeouts.forEach(t => clearTimeout(t));\n      animationTimeouts = [];\n      // Reset all dp and cells\n      for(let i=0; i<ROWS; i++){\n        for(let j=0; j<COLS; j++){\n          dp[i][j] = 0;\n        }\n      }\n      // Reset grid display values\n      const cells = gridContainer.querySelectorAll('.dp-cell');\n      cells.forEach(c => {\n        c.textContent = '0';\n        c.classList.remove('update');\n        c.setAttribute('aria-label', `Cell at row ${c.dataset.row}, column ${c.dataset.col}, value 0`);\n      });\n\n      // Reset buttons state\n      startBtn.setAttribute('aria-pressed', 'false');\n      startBtn.textContent = 'Start Animation';\n    }\n\n    // Button elements\n    const startBtn = document.getElementById('startBtn');\n    const resetBtn = document.getElementById('resetBtn');\n\n    // Handler for start button\n    startBtn.addEventListener('click', () => {\n      if(startBtn.getAttribute('aria-pressed') === 'true'){\n        return; // Already running\n      }\n      startBtn.setAttribute('aria-pressed', 'true');\n      startBtn.textContent = 'Running...';\n      startAnimation();\n      // After last step, switch button text back after animation finish\n      setTimeout(() => {\n        startBtn.textContent = 'Animation Completed';\n      }, 600 + (ROWS-1)*(COLS-1)*330 + 1500);\n    });\n\n    // Handler for reset button\n    resetBtn.addEventListener('click', () => {\n      clearAnimation();\n    });\n\n    // Init grid on page load\n    createGrid();\n  })();\n</script>\n\n<footer>© 2024 Dynamic Programming Visualization</footer>\n</body>\n</html>"
  },
