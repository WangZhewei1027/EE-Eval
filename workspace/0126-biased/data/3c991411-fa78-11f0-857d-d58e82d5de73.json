    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Thread - Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Roboto+Slab&display=swap');\n\n  /* Reset and base */\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  html, body {\n    height: 100%;\n    background: radial-gradient(circle at center, #0a1f3d 0%, #050a12 90%);\n    font-family: 'Roboto Slab', serif;\n    overflow: hidden;\n    color: #fff;\n    user-select: none;\n  }\n\n  body {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 40px 20px;\n  }\n\n  .container {\n    max-width: 900px;\n    width: 100%;\n    text-align: center;\n  }\n\n  /* Header */\n  header {\n    margin-bottom: 50px;\n  }\n\n  header h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 3.8rem;\n    letter-spacing: 0.18em;\n    color: #88c0d0;\n    text-shadow:\n      0 0 12px #5e9fbf88,\n      0 0 20px #67bbf888,\n      0 0 30px #4ea4d888;\n    animation: glowPulse 4s ease-in-out infinite;\n    user-select: none;\n  }\n\n  @keyframes glowPulse {\n    0%, 100% {\n      text-shadow:\n        0 0 12px #5e9fbf88,\n        0 0 20px #67bbf888,\n        0 0 30px #4ea4d888;\n      color: #88c0d0;\n    }\n    50% {\n      text-shadow:\n        0 0 20px #a0d8f7cc,\n        0 0 35px #8ec9f7bb,\n        0 0 50px #6fbceeaa;\n      color: #a0d8f7;\n    }\n  }\n\n  /* Thread canvas wrapper */\n  .thread-visual {\n    position: relative;\n    width: 100%;\n    height: 420px;\n    border-radius: 28px;\n    background:\n      linear-gradient(135deg, #1a293f 0%, #243a59 100%);\n    box-shadow:\n      inset 0 0 25px #0c1725,\n      0 10px 50px rgba(31, 58, 84, 0.9);\n    overflow: visible;\n  }\n\n  canvas#threadCanvas {\n    display: block;\n    width: 100%;\n    height: 100%;\n    border-radius: 28px;\n  }\n\n  /* Caption */\n  .caption {\n    margin-top: 28px;\n    font-size: 1.2rem;\n    font-style: italic;\n    color: #b0c7d8;\n    letter-spacing: 0.05em;\n  }\n\n  /* Controls */\n  .controls {\n    margin-top: 40px;\n  }\n\n  .btn {\n    background: linear-gradient(145deg, #2b4969, #1e3044);\n    border: none;\n    border-radius: 18px;\n    padding: 14px 36px;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1rem;\n    color: #a8d0ff;\n    box-shadow:\n      3px 3px 7px #19304f,\n      -3px -3px 7px #3a6287;\n    cursor: pointer;\n    transition: all 0.35s cubic-bezier(.4,0,.2,1);\n    user-select: none;\n    margin: 0 12px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .btn:before {\n    content: \"\";\n    position: absolute;\n    left: 50%;\n    top: 50%;\n    width: 0%;\n    height: 300%;\n    background: rgba(136, 192, 208, 0.35);\n    transform: translate(-50%, -50%) rotate(25deg);\n    transition: width 0.5s ease;\n    z-index: 0;\n    border-radius: 50px;\n  }\n\n  .btn:hover:before {\n    width: 180%;\n  }\n\n  .btn:hover {\n    color: #d0e9ff;\n    box-shadow:\n      4px 4px 18px #79b2db,\n      -4px -4px 18px #a9d6ff;\n  }\n\n  .btn:focus {\n    outline: none;\n    box-shadow:\n      0 0 8px 3px #6fbceeaa;\n  }\n\n  /* FOOTER */\n  footer {\n    margin-top: 84px;\n    font-size: 0.85rem;\n    color: #345670bb;\n    letter-spacing: 0.12em;\n    font-style: italic;\n  }\n\n</style>\n</head>\n<body>\n\n  <div class=\"container\" role=\"main\" aria-label=\"Thread Concept Visual\">\n\n    <header>\n      <h1>THREAD</h1>\n    </header>\n\n    <div class=\"thread-visual\" aria-hidden=\"true\">\n      <canvas id=\"threadCanvas\" width=\"900\" height=\"420\"></canvas>\n    </div>\n\n    <div class=\"caption\">A seamless connection of intertwined strands, weaving complexity with elegance.</div>\n\n    <div class=\"controls\" aria-label=\"Thread visualization controls\">\n      <button class=\"btn\" id=\"toggleMotion\" aria-pressed=\"true\" aria-label=\"Pause or resume thread animation\">Pause Animation</button>\n      <button class=\"btn\" id=\"regenThread\" aria-label=\"Regenerate thread pattern for a new visual arrangement\">New Thread</button>\n    </div>\n\n    <footer>\n      Crafted with care by AI • Inspired by the beauty of complexity\n    </footer>\n\n  </div>\n\n<script>\n  (() => {\n    const canvas = document.getElementById('threadCanvas');\n    const ctx = canvas.getContext('2d');\n    let width = canvas.width;\n    let height = canvas.height;\n\n    // Resize support (keep ratio)\n    function resize() {\n      const containerWidth = canvas.parentElement.clientWidth;\n      const ratio = width / height;\n      let w = containerWidth;\n      let h = w / ratio;\n      if (h > 420) {\n        h = 420;\n        w = h * ratio;\n      }\n      canvas.style.width = w + 'px';\n      canvas.style.height = h + 'px';\n    }\n    window.addEventListener('resize', resize);\n    resize();\n\n    // Thread parameters\n    const NUM_THREADS = 12;\n    const POINTS_PER_THREAD = 80;\n    const THREAD_COLORS = [\n      '#88c0d0', '#81a1c1', '#5e81ac',\n      '#4b6a96', '#3a5677', '#2c4460',\n      '#266280', '#3a85b8', '#70b3e5',\n      '#4d9ed3', '#2f78b7', '#296491'\n    ];\n\n    // Each thread is a spline made of points oscillating smoothly\n    // We'll generate control points in vertical space with horizontal oscillations.\n\n    class Thread {\n      constructor(index, total) {\n        this.index = index;\n        this.total = total;\n        this.color = THREAD_COLORS[index % THREAD_COLORS.length];\n        this.points = [];\n        this.phaseOffsets = [];\n        this.amplitude = 16 + Math.random() * 12;\n        this.speed = 0.013 + Math.random() * 0.013;\n        this.baseY = height * 0.15 + (index / total) * (height * 0.7);\n        this.generateInitialPoints();\n      }\n\n      generateInitialPoints() {\n        this.points = [];\n        this.phaseOffsets = [];\n        const stepX = width / (POINTS_PER_THREAD - 1);\n        for (let i = 0; i < POINTS_PER_THREAD; i++) {\n          // X evenly spaced\n          let x = i * stepX;\n          // Y oscillates with phase offset\n          let phase = Math.random() * Math.PI * 2;\n          this.phaseOffsets.push(phase);\n          this.points.push({ x, y: this.baseY });\n        }\n      }\n\n      update(t) {\n        for (let i = 0; i < this.points.length; i++) {\n          // Sine oscillation horizontally\n          let phase = this.phaseOffsets[i];\n          let oscillation = Math.sin(t * this.speed * 1000 + phase + this.index) * this.amplitude;\n          this.points[i].y = this.baseY + oscillation + Math.sin(t * this.speed * 1500 + phase * 2) * (this.amplitude * 0.35);\n          // perturb x slightly for subtle twist effect\n          this.points[i].x = (i * (width / (POINTS_PER_THREAD - 1))) + Math.cos(t * this.speed * 800 + phase + this.index) * 4;\n        }\n      }\n\n      draw(ctx) {\n        // Path with smooth curve\n        ctx.beginPath();\n        ctx.lineWidth = 3.4;\n        let gradient = ctx.createLinearGradient(0, this.points[0].y, width, this.points[this.points.length-1].y);\n        gradient.addColorStop(0, this.color + 'ee');\n        gradient.addColorStop(1, '#111f2f00');\n\n        ctx.strokeStyle = gradient;\n        ctx.shadowColor = this.color + 'bb';\n        ctx.shadowBlur = 8;\n\n        // Draw smooth Catmull-Rom spline\n        const pts = this.points;\n        ctx.moveTo(pts[0].x, pts[0].y);\n\n        for (let i = 0; i < pts.length - 1; i++) {\n          const p0 = pts[Math.max(0, i - 1)];\n          const p1 = pts[i];\n          const p2 = pts[i + 1];\n          const p3 = pts[Math.min(pts.length - 1, i + 2)];\n\n          // Catmull-Rom spline control points\n          let cp1x = p1.x + (p2.x - p0.x) / 6;\n          let cp1y = p1.y + (p2.y - p0.y) / 6;\n\n          let cp2x = p2.x - (p3.x - p1.x) / 6;\n          let cp2y = p2.y - (p3.y - p1.y) / 6;\n\n          ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, p2.x, p2.y);\n        }\n        ctx.stroke();\n      }\n    }\n\n    let threads = [];\n    for(let i=0; i < NUM_THREADS; i++) {\n      threads.push(new Thread(i, NUM_THREADS));\n    }\n\n    let running = true;\n    let lastTime = null;\n\n    // Animation loop\n    function animate(time = 0) {\n      if (!lastTime) lastTime = time;\n      const delta = time - lastTime;\n      lastTime = time;\n\n      ctx.clearRect(0, 0, width, height);\n\n      // Draw subtle background sparkle\n      drawBackgroundSparkles(ctx, width, height);\n\n      // Draw threads from back to front for layering effect\n      for (let i = 0; i < threads.length; i++) {\n        threads[i].update(time);\n      }\n      for (let i = 0; i < threads.length; i++) {\n        threads[i].draw(ctx);\n      }\n\n      // Overlay soft light glow behind threads center\n      drawCenterGlow(ctx, width, height);\n\n      if (running) requestAnimationFrame(animate);\n    }\n\n    // Subtle sparkle background effect\n    const sparkleCount = 70;\n    const sparkles = [];\n    for(let i=0; i < sparkleCount; i++) {\n      sparkles.push({\n        x: Math.random() * width,\n        y: Math.random() * height,\n        radius: 0.8 + Math.random() * 1.5,\n        alpha: 0.1 + Math.random() * 0.2,\n        speed: 0.002 + Math.random() * 0.004,\n        phase: Math.random() * Math.PI * 2\n      });\n    }\n\n    function drawBackgroundSparkles(ctx, w, h) {\n      ctx.save();\n      for(let s of sparkles) {\n        s.phase += s.speed * 20;\n        let alpha = 0.15 + 0.15 * Math.sin(s.phase);\n        ctx.beginPath();\n        ctx.arc(s.x, s.y, s.radius, 0, Math.PI*2);\n        ctx.fillStyle = `rgba(136,192,208,${alpha.toFixed(3)})`;\n        ctx.shadowBlur = 6;\n        ctx.shadowColor = \"rgba(136,192,208,0.15)\";\n        ctx.fill();\n      }\n      ctx.restore();\n    }\n\n    // Central glowing ellipse under threads\n    function drawCenterGlow(ctx, w, h) {\n      const grd = ctx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/3);\n      grd.addColorStop(0, 'rgba(136,192,208, 0.32)');\n      grd.addColorStop(0.45, 'rgba(136,192,208, 0.12)');\n      grd.addColorStop(1, 'rgba(136,192,208, 0)');\n      ctx.save();\n      ctx.fillStyle = grd;\n      ctx.filter = 'blur(20px)';\n      ctx.beginPath();\n      ctx.ellipse(w/2, h/2 + 10, w / 3, h / 10, 0, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.restore();\n    }\n\n    // Controls & Actions\n    const toggleBtn = document.getElementById('toggleMotion');\n    const regenBtn = document.getElementById('regenThread');\n\n    toggleBtn.addEventListener('click', () => {\n      running = !running;\n      if (running) {\n        toggleBtn.textContent = 'Pause Animation';\n        toggleBtn.setAttribute('aria-pressed', 'true');\n        lastTime = null;\n        requestAnimationFrame(animate);\n      } else {\n        toggleBtn.textContent = 'Play Animation';\n        toggleBtn.setAttribute('aria-pressed', 'false');\n      }\n    });\n\n    regenBtn.addEventListener('click', () => {\n      for(let i=0; i < threads.length; i++) {\n        threads[i] = new Thread(i, NUM_THREADS);\n      }\n    });\n\n    // Initial animation start\n    requestAnimationFrame(animate);\n\n  })();\n</script>\n\n</body>\n</html>"
