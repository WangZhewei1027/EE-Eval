    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Decision Trees | Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --light: #f8f9fa;\n            --dark: #2d3436;\n            --success: #00b894;\n            --warning: #fdcb6e;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 1200px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 3rem;\n        }\n\n        .visualization {\n            width: 100%;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.2);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            transition: all 0.5s ease;\n            animation: slideUp 1s ease-out;\n        }\n\n        .visualization::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n        }\n\n        .tree-container {\n            width: 100%;\n            min-height: 500px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative;\n        }\n\n        .tree {\n            position: relative;\n            width: 100%;\n            height: 100%;\n        }\n\n        .node {\n            position: absolute;\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n            font-weight: 500;\n            color: white;\n            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.2);\n            transition: all 0.5s ease;\n            transform: scale(0);\n            animation: popIn 0.5s ease-out forwards;\n            cursor: default;\n            z-index: 2;\n        }\n\n        .node.root {\n            background: var(--primary);\n            top: 50px;\n            left: 50%;\n            transform: translateX(-50%) scale(0);\n            width: 140px;\n            height: 140px;\n            font-size: 1.2rem;\n            animation: popIn 0.5s ease-out 0.3s forwards;\n        }\n\n        .node.internal {\n            background: var(--secondary);\n            font-size: 1rem;\n        }\n\n        .node.leaf {\n            background: var(--success);\n            font-size: 0.9rem;\n        }\n\n        .branch {\n            position: absolute;\n            height: 2px;\n            background: var(--dark);\n            opacity: 0.2;\n            transform-origin: left center;\n            z-index: 1;\n        }\n\n        .branch-label {\n            position: absolute;\n            font-size: 0.8rem;\n            color: var(--dark);\n            opacity: 0.7;\n            padding: 0.2rem 0.5rem;\n            border-radius: 20px;\n            background: rgba(255, 255, 255, 0.7);\n            z-index: 3;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 1rem;\n            animation: fadeIn 1s ease-out 1s forwards;\n            opacity: 0;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: var(--primary);\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px -5px var(--primary);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px -5px var(--primary);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button.secondary {\n            background: white;\n            color: var(--primary);\n            border: 1px solid var(--primary);\n            box-shadow: none;\n        }\n\n        .explanation {\n            max-width: 800px;\n            text-align: center;\n            margin-top: 2rem;\n            line-height: 1.6;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n            opacity: 0;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes popIn {\n            0% { transform: scale(0); }\n            80% { transform: scale(1.1); }\n            100% { transform: scale(1); }\n        }\n\n        footer {\n            margin-top: 4rem;\n            text-align: center;\n            font-size: 0.9rem;\n            color: var(--dark);\n            opacity: 0.6;\n            animation: fadeIn 2s ease-out;\n        }\n\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .subtitle {\n                font-size: 1rem;\n            }\n            \n            .node {\n                width: 90px;\n                height: 90px;\n                font-size: 0.8rem;\n            }\n            \n            .node.root {\n                width: 110px;\n                height: 110px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Decision Trees</h1>\n        <p class=\"subtitle\">A visual exploration of hierarchical decision-making through elegant design</p>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"visualization\">\n            <div class=\"tree-container\">\n                <div class=\"tree\" id=\"tree\">\n                    <!-- Nodes will be added via JavaScript -->\n                </div>\n            </div>\n            <div class=\"controls\">\n                <button id=\"animateBtn\">Animate Tree</button>\n                <button class=\"secondary\" id=\"resetBtn\">Reset</button>\n            </div>\n        </div>\n\n        <p class=\"explanation\">\n            Decision trees are powerful machine learning models that make predictions by learning simple decision rules \n            inferred from data features. Each internal node represents a test on an attribute, each branch represents \n            the outcome of the test, and each leaf node represents a class label or decision. The paths from root to \n            leaf represent classification rules.\n        </p>\n    </div>\n\n    <footer>\n        © 2023 Visual Decision Trees | Designed for aesthetic appreciation\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const treeContainer = document.getElementById('tree');\n            const animateBtn = document.getElementById('animateBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            // Tree data structure\n            const treeData = {\n                name: \"Should I go outside?\",\n                children: [\n                    {\n                        name: \"Is it raining?\",\n                        children: [\n                            { name: \"Stay inside\" },\n                            { name: \"Is temperature > 20°C?\", \n                              children: [\n                                  { name: \"Go outside!\" },\n                                  { name: \"Wear jacket\" }\n                              ] \n                            }\n                        ]\n                    }\n                ]\n            };\n            \n            // Create the tree visualization\n            function createTree() {\n                clearTree();\n                \n                // Create root node\n                const rootNode = createNode(treeData.name, 'root', 50, 50);\n                treeContainer.appendChild(rootNode);\n                \n                // Position calculation variables\n                const levelHeight = 150;\n                let currentLevel = 1;\n                \n                // Create first level\n                if (treeData.children) {\n                    const childrenCount = treeData.children.length;\n                    const angleStep = 180 / (childrenCount + 1);\n                    let currentAngle = angleStep;\n                    \n                    treeData.children.forEach((child, index) => {\n                        const x = 50 + Math.sin(currentAngle * Math.PI / 180) * 30;\n                        const y = 50 + levelHeight;\n                        \n                        const childNode = createNode(child.name, 'internal', x, y);\n                        treeContainer.appendChild(childNode);\n                        \n                        // Create branch\n                        createBranch(50, 50, x, y, `Yes (${index + 1})`);\n                        \n                        // Create second level if exists\n                        if (child.children) {\n                            const grandChildrenCount = child.children.length;\n                            const grandAngleStep = 60 / (grandChildrenCount + 1);\n                            let grandCurrentAngle = currentAngle - 30;\n                            \n                            child.children.forEach((grandChild, grandIndex) => {\n                                const gx = x + Math.sin(grandCurrentAngle * Math.PI / 180) * 25;\n                                const gy = y + levelHeight;\n                                \n                                const grandChildNode = createNode(grandChild.name, \n                                    grandChild.children ? 'internal' : 'leaf', gx, gy);\n                                treeContainer.appendChild(grandChildNode);\n                                \n                                // Create branch\n                                createBranch(x, y, gx, gy, \n                                    grandIndex === 0 ? 'No' : `Yes (${grandIndex + 1})`);\n                                \n                                grandCurrentAngle += grandAngleStep;\n                            });\n                        }\n                        \n                        currentAngle += angleStep;\n                    });\n                }\n            }\n            \n            // Create a node element\n            function createNode(text, type, x, y, delay = 0) {\n                const node = document.createElement('div');\n                node.className = `node ${type}`;\n                node.textContent = text;\n                node.style.left = `${x}%`;\n                node.style.top = `${y}px`;\n                node.style.animationDelay = `${delay}s`;\n                return node;\n            }\n            \n            // Create a branch between nodes\n            function createBranch(x1, y1, x2, y2, label) {\n                // Calculate branch position and length\n                const left = Math.min(x1, x2);\n                const top = Math.min(y1, y2);\n                const width = Math.abs(x2 - x1);\n                const height = Math.abs(y2 - y1);\n                const length = Math.sqrt(width * width + height * height);\n                const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;\n                \n                // Create branch element\n                const branch = document.createElement('div');\n                branch.className = 'branch';\n                branch.style.width = `${length}%`;\n                branch.style.left = `${x1}%`;\n                branch.style.top = `${y1 + 60}px`;\n                branch.style.transform = `rotate(${angle}deg)`;\n                treeContainer.appendChild(branch);\n                \n                // Create branch label\n                if (label) {\n                    const labelX = (x1 + x2) / 2;\n                    const labelY = (y1 + y2) / 2;\n                    \n                    const branchLabel = document.createElement('div');\n                    branchLabel.className = 'branch-label';\n                    branchLabel.textContent = label;\n                    branchLabel.style.left = `${labelX}%`;\n                    branchLabel.style.top = `${labelY + 30}px`;\n                    treeContainer.appendChild(branchLabel);\n                }\n            }\n            \n            // Clear the tree\n            function clearTree() {\n                treeContainer.innerHTML = '';\n            }\n            \n            // Animate the tree\n            function animateTree() {\n                const nodes = document.querySelectorAll('.node');\n                const branches = document.querySelectorAll('.branch');\n                const labels = document.querySelectorAll('.branch-label');\n                \n                // Reset all elements\n                nodes.forEach(node => {\n                    node.style.transform = 'scale(0)';\n                });\n                branches.forEach(branch => {\n                    branch.style.width = '0';\n                });\n                labels.forEach(label => {\n                    label.style.opacity = '0';\n                });\n                \n                // Animate root node\n                setTimeout(() => {\n                    document.querySelector('.node.root').style.transform = 'scale(1)';\n                }, 300);\n                \n                // Animate first level\n                setTimeout(() => {\n                    document.querySelectorAll('.node.internal').forEach((node, index) => {\n                        setTimeout(() => {\n                            node.style.transform = 'scale(1)';\n                            // Animate branch\n                            branches[index].style.width = branches[index].getAttribute('data-length');\n                        }, index * 200);\n                    });\n                }, 800);\n                \n                // Animate second level\n                setTimeout(() => {\n                    document.querySelectorAll('.node.leaf, .node.internal:not(.root)').forEach((node, index) => {\n                        setTimeout(() => {\n                            node.style.transform = 'scale(1)';\n                            // Animate branch\n                            branches[index + 2].style.width = branches[index + 2].getAttribute('data-length');\n                        }, index * 200);\n                    });\n                }, 1600);\n                \n                // Animate labels\n                setTimeout(() => {\n                    labels.forEach(label => {\n                        label.style.opacity = '1';\n                    });\n                }, 2400);\n            }\n            \n            // Event listeners\n            animateBtn.addEventListener('click', animateTree);\n            resetBtn.addEventListener('click', createTree);\n            \n            // Initialize\n            createTree();\n        });\n    </script>\n</body>\n</html>"
