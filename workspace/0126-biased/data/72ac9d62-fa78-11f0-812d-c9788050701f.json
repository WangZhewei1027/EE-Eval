    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ethereal REST API Visualization</title>\n    <style>\n        :root {\n            --primary: #6e48aa;\n            --secondary: #9d50bb;\n            --accent: #4776e6;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --success: #4cc9f0;\n            --error: #f72585;\n            --warning: #ff9e00;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        @font-face {\n            font-family: 'Inter';\n            src: url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n        }\n\n        body {\n            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            perspective: 1000px;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            position: relative;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 4rem;\n            position: relative;\n            z-index: 10;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--success), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: -0.05em;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n            animation: fadeIn 1.5s ease-out 0.3s forwards;\n            opacity: 0;\n        }\n\n        .visualization {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 3rem;\n            margin-top: 4rem;\n            position: relative;\n        }\n\n        .client-side, .server-side {\n            position: relative;\n            padding: 2rem;\n            border-radius: 16px;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.1);\n        }\n\n        .client-side:hover, .server-side:hover {\n            transform: translateY(-5px) scale(1.01);\n            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);\n        }\n\n        .section-title {\n            font-size: 1.5rem;\n            margin-bottom: 1.5rem;\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            color: var(--light);\n        }\n\n        .section-title::before {\n            content: \"\";\n            display: block;\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            background: var(--success);\n        }\n\n        .client {\n            position: relative;\n            height: 300px;\n            margin-bottom: 2rem;\n        }\n\n        .request {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 100px;\n            height: 60px;\n            background: var(--accent);\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            box-shadow: 0 10px 30px rgba(71, 118, 230, 0.5);\n            cursor: pointer;\n            transition: all 0.3s ease;\n            z-index: 5;\n            animation: pulse 2s infinite;\n        }\n\n        .request:hover {\n            transform: translate(-50%, -50%) scale(1.05);\n        }\n\n        .server {\n            position: relative;\n            height: 300px;\n            margin-top: 2rem;\n        }\n\n        .database {\n            position: absolute;\n            bottom: 0;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 150px;\n            height: 80px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            box-shadow: 0 10px 30px rgba(110, 72, 170, 0.5);\n        }\n\n        .database::before {\n            content: \"\";\n            position: absolute;\n            top: -10px;\n            left: 10px;\n            right: 10px;\n            height: 20px;\n            background: linear-gradient(to right, #5a3e96, #8b45b8);\n            border-radius: 5px 5px 0 0;\n        }\n\n        .routes {\n            display: flex;\n            flex-direction: column;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        .route {\n            padding: 1rem;\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            gap: 1rem;\n            transition: all 0.3s ease;\n            cursor: default;\n        }\n\n        .route:hover {\n            background: rgba(255, 255, 255, 0.15);\n            transform: translateX(5px);\n        }\n\n        .method {\n            padding: 0.3rem 0.6rem;\n            border-radius: 4px;\n            font-weight: 600;\n            font-size: 0.8rem;\n            text-transform: uppercase;\n            min-width: 50px;\n            text-align: center;\n        }\n\n        .get { background: #4cc9f0; color: #0d1b2a; }\n        .post { background: #38b000; color: white; }\n        .put { background: #ff9e00; color: #0d1b2a; }\n        .delete { background: #f72585; color: white; }\n\n        .path {\n            font-family: 'Courier New', monospace;\n            opacity: 0.9;\n        }\n\n        .connection {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.1);\n            z-index: 1;\n        }\n\n        .connection::before {\n            content: \"\";\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 0;\n            height: 2px;\n            background: linear-gradient(to right, var(--accent), var(--success));\n            animation: connectionFlow 3s linear infinite;\n        }\n\n        .response {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 120px;\n            height: 70px;\n            background: var(--success);\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            box-shadow: 0 10px 30px rgba(76, 201, 240, 0.5);\n            opacity: 0;\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .particle {\n            position: absolute;\n            background: rgba(255, 255, 255, 0.5);\n            border-radius: 50%;\n            pointer-events: none;\n        }\n\n        .floating-icons {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .floating-icon {\n            position: absolute;\n            opacity: 0.1;\n            font-size: 2rem;\n            animation: float 20s infinite linear;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes pulse {\n            0% { box-shadow: 0 0 0 0 rgba(71, 118, 230, 0.7); }\n            70% { box-shadow: 0 0 0 15px rgba(71, 118, 230, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(71, 118, 230, 0); }\n        }\n\n        @keyframes connectionFlow {\n            0% { width: 0; left: 0; }\n            50% { width: 100%; left: 0; }\n            100% { width: 0; left: 100%; }\n        }\n\n        @keyframes float {\n            0% { transform: translate(0, 0) rotate(0deg); }\n            25% { transform: translate(50px, 50px) rotate(90deg); }\n            50% { transform: translate(100px, -20px) rotate(180deg); }\n            75% { transform: translate(-30px, 70px) rotate(270deg); }\n            100% { transform: translate(0, 0) rotate(360deg); }\n        }\n\n        .code-snippet {\n            background: rgba(0, 0, 0, 0.3);\n            padding: 1rem;\n            border-radius: 8px;\n            font-family: 'Courier New', monospace;\n            font-size: 0.9rem;\n            margin-top: 1rem;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .code-snippet::before {\n            content: \"\";\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 4px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--accent), var(--success));\n        }\n\n        .code-highlight {\n            color: var(--success);\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n\n        @media (max-width: 768px) {\n            .visualization {\n                grid-template-columns: 1fr;\n            }\n\n            h1 {\n                font-size: 2.5rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>REST API Architecture</h1>\n            <p class=\"subtitle\">A visual representation of Representational State Transfer – the foundation of modern web APIs</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"client-side\">\n                <h2 class=\"section-title\">Client</h2>\n                <div class=\"client\">\n                    <div class=\"connection\"></div>\n                    <div class=\"request\" id=\"sendRequest\">Send Request</div>\n                    <div class=\"response\" id=\"response\">Response</div>\n                    <div class=\"particles\" id=\"clientParticles\"></div>\n                </div>\n                \n                <div class=\"code-snippet\">\n                    fetch(<span class=\"code-highlight\">'https://api.example.com/data'</span>, {<br>\n                    &nbsp;&nbsp;method: <span class=\"code-highlight\">'GET'</span>,<br>\n                    &nbsp;&nbsp;headers: {<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;'Content-Type': <span class=\"code-highlight\">'application/json'</span><br>\n                    &nbsp;&nbsp;}<br>\n                    });\n                </div>\n            </div>\n\n            <div class=\"server-side\">\n                <h2 class=\"section-title\">Server</h2>\n                <div class=\"server\">\n                    <div class=\"connection\"></div>\n                    <div class=\"database\">Database</div>\n                    <div class=\"particles\" id=\"serverParticles\"></div>\n                </div>\n\n                <div class=\"routes\">\n                    <div class=\"route\">\n                        <span class=\"method get\">GET</span>\n                        <span class=\"path\">/api/users</span>\n                    </div>\n                    <div class=\"route\">\n                        <span class=\"method post\">POST</span>\n                        <span class=\"path\">/api/users</span>\n                    </div>\n                    <div class=\"route\">\n                        <span class=\"method get\">GET</span>\n                        <span class=\"path\">/api/users/:id</span>\n                    </div>\n                    <div class=\"route\">\n                        <span class=\"method put\">PUT</span>\n                        <span class=\"path\">/api/users/:id</span>\n                    </div>\n                    <div class=\"route\">\n                        <span class=\"method delete\">DELETE</span>\n                        <span class=\"path\">/api/users/:id</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <footer>\n            <p>Hover over elements to see subtle interactions. Click \"Send Request\" to simulate API call.</p>\n        </footer>\n    </div>\n\n    <div class=\"floating-icons\">\n        <div class=\"floating-icon\" style=\"top: 10%; left: 5%;\">{\" }</div>\n        <div class=\"floating-icon\" style=\"top: 30%; left: 80%;\">GET</div>\n        <div class=\"floating-icon\" style=\"top: 70%; left: 15%;\">POST</div>\n        <div class=\"floating-icon\" style=\"top: 20%; left: 60%;\">200</div>\n        <div class=\"floating-icon\" style=\"top: 80%; left: 70%;\">404</div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Create particles\n            createParticles('clientParticles', 15);\n            createParticles('serverParticles', 15);\n\n            // Set up request animation\n            const requestBtn = document.getElementById('sendRequest');\n            const response = document.getElementById('response');\n\n            requestBtn.addEventListener('click', () => {\n                // Animate request\n                requestBtn.style.transform = 'translate(-50%, -50%) scale(0.9)';\n                requestBtn.style.boxShadow = '0 5px 15px rgba(71, 118, 230, 0.3)';\n                \n                // Simulate request delay\n                setTimeout(() => {\n                    requestBtn.style.opacity = '0';\n                    \n                    // Show response\n                    setTimeout(() => {\n                        response.style.opacity = '1';\n                        response.style.transform = 'translate(-50%, -50%) scale(1.1)';\n                        \n                        // Return to original state\n                        setTimeout(() => {\n                            response.style.opacity = '0';\n                            response.style.transform = 'translate(-50%, -50%) scale(1)';\n                            \n                            setTimeout(() => {\n                                requestBtn.style.opacity = '1';\n                                requestBtn.style.transform = 'translate(-50%, -50%) scale(1)';\n                                requestBtn.style.boxShadow = '0 10px 30px rgba(71, 118, 230, 0.5)';\n                            }, 500);\n                        }, 2000);\n                    }, 300);\n                }, 500);\n            });\n\n            // Add hover effect to routes\n            const routes = document.querySelectorAll('.route');\n            routes.forEach(route => {\n                route.addEventListener('mouseenter', () => {\n                    const method = route.querySelector('.method');\n                    method.style.transform = 'scale(1.1)';\n                });\n                \n                route.addEventListener('mouseleave', () => {\n                    const method = route.querySelector('.method');\n                    method.style.transform = 'scale(1)';\n                });\n            });\n        });\n\n        function createParticles(containerId, count) {\n            const container = document.getElementById(containerId);\n            \n            for (let i = 0; i < count; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                // Random properties\n                const size = Math.random() * 3 + 1;\n                const posX = Math.random() * 100;\n                const posY = Math.random() * 100;\n                const opacity = Math.random() * 0.5 + 0.1;\n                const duration = Math.random() * 10 + 10;\n                const delay = Math.random() * 5;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.top = `${posY}%`;\n                particle.style.opacity = opacity;\n                particle.style.animation = `float ${duration}s ${delay}s infinite linear`;\n                \n                container.appendChild(particle);\n            }\n        }\n    </script>\n</body>\n</html>"
