    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Graph (Directed)</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #f0f0f0;\n        }\n\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .graph-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        .graph {\n            display: grid;\n            grid-template-columns: repeat(10, 1fr);\n            gap: 10px;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .graph-item {\n            background-color: #f7f7f7;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            cursor: pointer;\n        }\n\n        .graph-item:hover {\n            background-color: #e5e5e5;\n        }\n\n        .graph-item::before {\n            content: \"\";\n            display: inline-block;\n            width: 20px;\n            height: 20px;\n            background-color: #333;\n            border-radius: 50%;\n            margin-right: 10px;\n        }\n\n        .graph-item::after {\n            content: \"\";\n            display: inline-block;\n            width: 20px;\n            height: 20px;\n            background-color: #333;\n            border-radius: 50%;\n            margin-right: 10px;\n            transition: transform 0.2s ease;\n        }\n\n        .graph-item::after::before {\n            transform: rotate(45deg);\n        }\n\n        .graph-item::after::after {\n            transform: rotate(135deg);\n        }\n\n        .graph-item.selected {\n            background-color: #333;\n            color: #fff;\n            transform: scale(1.1);\n        }\n\n        .button-container {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-top: 20px;\n        }\n\n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 10px;\n            cursor: pointer;\n            transition: background-color 0.2s ease;\n        }\n\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"graph-container\">\n            <div class=\"graph\">\n                <div class=\"graph-item selected\" data-index=\"0\">Item 1</div>\n                <div class=\"graph-item\" data-index=\"1\">Item 2</div>\n                <div class=\"graph-item\" data-index=\"2\">Item 3</div>\n                <div class=\"graph-item\" data-index=\"3\">Item 4</div>\n                <div class=\"graph-item\" data-index=\"4\">Item 5</div>\n                <div class=\"graph-item\" data-index=\"5\">Item 6</div>\n                <div class=\"graph-item\" data-index=\"6\">Item 7</div>\n                <div class=\"graph-item\" data-index=\"7\">Item 8</div>\n                <div class=\"graph-item\" data-index=\"8\">Item 9</div>\n                <div class=\"graph-item\" data-index=\"9\">Item 10</div>\n                <div class=\"graph-item\" data-index=\"10\">Item 11</div>\n            </div>\n        </div>\n        <div class=\"button-container\">\n            <button class=\"button\" data-index=\"0\">Click me!</button>\n            <button class=\"button\" data-index=\"1\">Click me!</button>\n        </div>\n    </div>\n\n    <script>\n        const graph = document.querySelector('.graph');\n        const items = document.querySelectorAll('.graph-item');\n\n        items.forEach((item, index) => {\n            item.addEventListener('click', () => {\n                if (item.classList.contains('selected')) {\n                    items.forEach((otherItem) => {\n                        otherItem.classList.remove('selected');\n                    });\n                    item.classList.add('selected');\n                }\n            });\n        });\n\n        const button = document.querySelector('.button');\n        button.addEventListener('click', () => {\n            console.log('Button clicked!');\n        });\n    </script>\n</body>\n</html>"
