  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>TCP/IP — Visualized</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#071022;\n    --glass: rgba(255,255,255,0.06);\n    --accent:#7dd3fc;\n    --accent2:#60a5fa;\n    --muted: rgba(255,255,255,0.65);\n    --layer-app: linear-gradient(135deg, rgba(118,92,255,0.12), rgba(96,165,250,0.06));\n    --layer-trans: linear-gradient(135deg, rgba(96,165,250,0.06), rgba(99,102,241,0.06));\n    --layer-net: linear-gradient(135deg, rgba(34,197,94,0.04), rgba(99,102,241,0.04));\n    --layer-link: linear-gradient(135deg, rgba(236,72,153,0.03), rgba(234,179,8,0.03));\n  }\n\n  *{box-sizing:border-box}\n  html,body{height:100%;}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(96,165,250,0.06), transparent 8%),\n                radial-gradient(1000px 500px at 85% 80%, rgba(125,211,252,0.03), transparent 8%),\n                linear-gradient(180deg, var(--bg1), var(--bg2));\n    color:#e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  .app{\n    min-height:100vh;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    padding:48px 32px;\n    gap:28px;\n    position:relative;\n  }\n\n  header{\n    text-align:center;\n    max-width:980px;\n    z-index:3;\n    pointer-events:none;\n  }\n\n  h1{\n    margin:0;\n    font-weight:800;\n    letter-spacing:-1px;\n    font-size:clamp(28px,4vw,44px);\n    background:linear-gradient(90deg,#dbeafe,#7dd3fc 40%, #60a5fa 80%);\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    text-shadow:0 6px 30px rgba(2,6,23,0.6);\n  }\n  p.lead{\n    margin:10px 0 0;\n    color:var(--muted);\n    font-weight:400;\n    font-size:14px;\n    letter-spacing:0.2px;\n    pointer-events:none;\n  }\n\n  /* Stage */\n  .stage{\n    width:100%;\n    max-width:1200px;\n    height:560px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    margin-top:6px;\n    z-index:2;\n    perspective:1000px;\n  }\n\n  /* decorative grid / glow */\n  .stage::before{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,0.02), transparent 20%),\n      repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0 1px, transparent 1px 40px);\n    mix-blend-mode:overlay;\n    pointer-events:none;\n    border-radius:18px;\n    filter:blur(10px) saturate(1.1);\n  }\n\n  /* Devices */\n  .device{\n    width:220px;\n    height:380px;\n    border-radius:18px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(6px) saturate(1.1);\n    display:flex;\n    flex-direction:column;\n    padding:22px;\n    gap:18px;\n    color:var(--muted);\n    position:absolute;\n    top:50px;\n    transform-origin:center;\n    transition:transform .6s cubic-bezier(.2,.9,.2,1);\n  }\n\n  .device.left{ left:48px; transform:translateZ(40px) rotateY(8deg); }\n  .device.right{ right:48px; transform:translateZ(40px) rotateY(-8deg); }\n\n  .device .title{\n    font-weight:700;\n    color:#fff;\n    font-size:15px;\n    display:flex;\n    align-items:center;\n    gap:8px;\n  }\n  .dot{\n    width:10px;height:10px;border-radius:50%;\n    background:linear-gradient(180deg,var(--accent),var(--accent2));\n    box-shadow:0 4px 14px rgba(96,165,250,0.25);\n  }\n  .device .sub{\n    font-size:12px;color:var(--muted);margin-top:-4px;\n  }\n\n  /* Layers stack inside device */\n  .layers{\n    margin-top:auto;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    width:100%;\n  }\n  .layer{\n    height:64px;\n    border-radius:12px;\n    display:flex;\n    align-items:center;\n    padding:12px;\n    gap:12px;\n    color:rgba(255,255,255,0.9);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n    position:relative;\n    overflow:visible;\n    transition:transform .45s cubic-bezier(.2,.9,.2,1), box-shadow .3s;\n  }\n  .layer .lbl{\n    font-weight:600;font-size:13px;min-width:120px;\n    text-shadow: 0 4px 18px rgba(3,7,20,0.35);\n  }\n  .layer .desc{\n    font-weight:400;font-size:12px;color:rgba(255,255,255,0.8);\n  }\n\n  .layer.app{ background:var(--layer-app); border:1px solid rgba(125,211,252,0.06); }\n  .layer.trans{ background:var(--layer-trans); border:1px solid rgba(96,165,250,0.06); }\n  .layer.net{ background:var(--layer-net); border:1px solid rgba(34,197,94,0.04); }\n  .layer.link{ background:var(--layer-link); border:1px solid rgba(236,72,153,0.03); }\n\n  /* Center network ribbon */\n  .network{\n    width:58%;\n    height:220px;\n    background:linear-gradient(90deg, rgba(96,165,250,0.03), rgba(125,211,252,0.02));\n    border-radius:18px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 20px 60px rgba(3,7,18,0.6);\n    position:relative;\n    z-index:1;\n    transform:translateZ(-20px);\n  }\n\n  .net-core{\n    width:88%;\n    height:140px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(7,10,45,0.7), rgba(4,6,28,0.65));\n    border: 1px solid rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:space-around;\n    padding:16px;\n    position:relative;\n    overflow:visible;\n  }\n\n  .router{\n    width:120px;height:110px;border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    color:var(--muted); font-weight:700; font-size:13px; position:relative;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  .router::after{\n    content:\"\";\n    position:absolute;bottom:-14px;left:50%;transform:translateX(-50%);\n    width:86%;height:28px;border-radius:12px;background:linear-gradient(180deg, rgba(96,165,250,0.06), rgba(125,211,252,0.02));\n    filter:blur(12px);opacity:0.4;\n  }\n\n  .router .rings{\n    width:40px;height:40px;border-radius:50%;\n    border:2px solid rgba(125,211,252,0.08);\n    display:grid;place-items:center;\n  }\n\n  .net-lines{position:absolute;inset:0;pointer-events:none;}\n  /* animated subtle flow lines */\n  .flow{\n    position:absolute;top:0;left:0;right:0;bottom:0;opacity:0.14;mix-blend-mode:screen;\n    background:\n      radial-gradient(circle at 16% 34%, rgba(125,211,252,0.08) 0 2px, transparent 8%),\n      radial-gradient(circle at 82% 66%, rgba(96,165,250,0.06) 0 2px, transparent 8%);\n    filter:blur(20px);\n    transform:translateZ(-20px);\n  }\n\n  /* Packet element - centrally positioned and absolutely animated */\n  .packet{\n    --w:120px;\n    width:var(--w);\n    height:56px;\n    position:absolute;\n    left:60px; /* initial small offset; animation will override */\n    top:150px;\n    z-index:6;\n    transform-origin:center;\n    pointer-events:none;\n    will-change:transform, opacity;\n    filter:drop-shadow(0 10px 30px rgba(3,7,18,0.6));\n    display:flex;align-items:center;justify-content:center;\n  }\n\n  .packet .frame{\n    position:relative;\n    width:100%;\n    height:100%;\n    border-radius:10px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    display:flex;align-items:center;justify-content:center;\n    overflow:visible;\n  }\n\n  .hdr{\n    position:absolute;\n    border-radius:8px;\n    display:flex;align-items:center;justify-content:center;\n    font-weight:700;\n    font-size:11px;\n    color:rgba(255,255,255,0.96);\n    padding:6px 8px;\n    box-shadow:0 6px 20px rgba(2,6,23,0.6);\n    transform-origin:center;\n    opacity:0;\n    pointer-events:none;\n  }\n\n  .payload{\n    font-weight:800;\n    letter-spacing:1.2px;\n    font-size:12px;\n    color:#061127;\n    background:linear-gradient(90deg,#a7f3d0,#60a5fa);\n    padding:6px 14px;\n    border-radius:8px;\n    transform:scale(1);\n    transition:transform .3s;\n  }\n\n  .hdr.tcp{ width:88px; height:36px; left:16px; top:-26px; background:linear-gradient(90deg,#60a5fa,#7dd3fc); }\n  .hdr.ip{ width:108px; height:30px; left:-6px; top:-46px; background:linear-gradient(90deg,#34d399,#86efac); }\n  .hdr.frame{ width:130px; height:26px; left:-10px; top:-66px; background:linear-gradient(90deg,#f472b6,#facc15); }\n\n  /* Labels along path */\n  .path-label{\n    position:absolute;\n    font-size:12px;\n    font-weight:700;\n    padding:8px 12px;\n    border-radius:999px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    pointer-events:none;\n    backdrop-filter: blur(4px);\n  }\n\n  .label-client{ left:36px; top:36px; }\n  .label-server{ right:36px; top:36px; }\n\n  /* small footer controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    z-index:5;\n  }\n\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    color:#e6eef8;\n    border:1px solid rgba(255,255,255,0.04);\n    padding:10px 16px;\n    border-radius:12px;\n    font-weight:700;\n    font-size:13px;\n    cursor:pointer;\n    box-shadow: 0 8px 28px rgba(2,6,23,0.5);\n    transition:transform .18s cubic-bezier(.2,.9,.2,1), box-shadow .18s;\n  }\n  .btn:active{ transform:translateY(2px) }\n  .btn.ghost{\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.06);\n    color:var(--muted);\n    font-weight:600;\n  }\n\n  /* subtle decorative animated background elements */\n  .float-blob{\n    position:absolute;\n    width:320px;height:320px;border-radius:50%;\n    background: radial-gradient(circle at 30% 40%, rgba(125,211,252,0.08), rgba(96,165,250,0.02) 30%, transparent 40%);\n    filter: blur(42px) saturate(1.2);\n    left: -60px; top: -80px;\n    transform:translateZ(-80px);\n    z-index:0;\n  }\n  .float-blob.two{\n    width:260px;height:260px;\n    background: radial-gradient(circle at 70% 60%, rgba(99,102,241,0.06), rgba(34,197,94,0.02) 30%, transparent 40%);\n    right:-60px; bottom:-60px; left:auto; top:auto; transform:translateZ(-80px);\n  }\n\n  /* Animation keyframes controlling packet movement and header toggles */\n  @keyframes packetJourney {\n    /* 0-8s loop normalized */\n    0%{\n      transform: translate3d(0px, -6px, 0) scale(1);\n      left: 76px; top: 150px;\n      opacity:0;\n    }\n    4%{\n      opacity:1;\n    }\n    /* down through client stack */\n    14%{\n      left: 76px; top: 170px; transform:translate3d(0,8px,0) scale(1.02);\n    }\n    20%{\n      left: 76px; top: 250px; transform:translate3d(0,24px,0) scale(0.96);\n    }\n    /* across the network */\n    34%{\n      left: calc(50% - 60px); top: 300px; transform:translate3d(0,0,0) scale(1);\n    }\n    50%{\n      left: calc(74% - 60px); top: 300px; transform:translate3d(0,0,0) scale(1);\n    }\n    /* up into server */\n    62%{\n      left: calc(74% - 60px); top: 250px; transform:translate3d(0,-20px,0) scale(1.02);\n    }\n    70%{\n      left: calc(74% - 60px); top: 190px; transform:translate3d(0,-36px,0) scale(1.04);\n    }\n    86%{\n      left: calc(74% - 60px); top: 150px; transform:translate3d(0,-56px,0) scale(1.06);\n    }\n    95%{\n      opacity:0.92;\n      transform:translate3d(0,-58px,0) scale(1.08);\n    }\n    100%{\n      opacity:0;\n      transform:translate3d(0,-58px,0) scale(1.08);\n    }\n  }\n\n  /* header appearance sequencing */\n  @keyframes tcpHeader {\n    0%{ opacity:0; transform:translateY(6px) scale(.8) }\n    12%{ opacity:1; transform:translateY(0) scale(1) }\n    28%{ opacity:1; transform:translateY(0) scale(1) }\n    40%{ opacity:0.9; transform:translateY(0) scale(1) }\n    58%{ opacity:0.2; transform:translateY(-6px) scale(.9) }\n    72%{ opacity:0; transform:translateY(-12px) scale(.8) }\n    100%{ opacity:0 }\n  }\n\n  @keyframes ipHeader {\n    0%{ opacity:0; transform:translateY(10px) scale(.86) }\n    18%{ opacity:0.98; transform:translateY(0) scale(1) }\n    32%{ opacity:0.98; transform:translateY(0) scale(1) }\n    46%{ opacity:1; transform:translateY(0) scale(1) }\n    58%{ opacity:0.2; transform:translateY(-6px) scale(.9) }\n    76%{ opacity:0; transform:translateY(-14px) scale(.8) }\n    100%{ opacity:0 }\n  }\n\n  @keyframes frameHeader {\n    0%{ opacity:0; transform:translateY(12px) scale(.84) }\n    22%{ opacity:1; transform:translateY(0) scale(1) }\n    36%{ opacity:1; transform:translateY(0) scale(1) }\n    54%{ opacity:1; transform:translateY(0) scale(1) }\n    66%{ opacity:0.2; transform:translateY(-6px) scale(.9) }\n    86%{ opacity:0; transform:translateY(-16px) scale(.78) }\n    100%{ opacity:0 }\n  }\n\n  @keyframes payloadGlow {\n    0%{ transform:scale(1); box-shadow:0 6px 18px rgba(3,7,18,0.6)}\n    20%{ transform:scale(.96); }\n    32%{ transform:scale(.9); }\n    48%{ transform:scale(.92); }\n    68%{ transform:scale(.98); box-shadow:0 18px 40px rgba(96,165,250,0.12)}\n    86%{ transform:scale(1.02); box-shadow:0 22px 60px rgba(96,165,250,0.16)}\n    100%{ transform:scale(1); }\n  }\n\n  /* Play state control by applying .running to .stage */\n  .packet{\n    animation: packetJourney 8.8s linear infinite paused;\n  }\n  .hdr.tcp{\n    animation: tcpHeader 8.8s linear infinite paused;\n  }\n  .hdr.ip{\n    animation: ipHeader 8.8s linear infinite paused;\n  }\n  .hdr.frame{\n    animation: frameHeader 8.8s linear infinite paused;\n  }\n  .payload{\n    animation: payloadGlow 8.8s linear infinite paused;\n  }\n\n  .running .packet,\n  .running .hdr.tcp,\n  .running .hdr.ip,\n  .running .hdr.frame,\n  .running .payload {\n    animation-play-state: running;\n  }\n\n  /* small footer note */\n  .note{\n    margin-top:8px;\n    color:rgba(255,255,255,0.5);\n    font-size:12px;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width:1100px){\n    .stage{ height:520px; }\n    .device{ width:200px; height:360px; }\n    .network{ width:66%; height:200px; }\n    .packet{ --w:110px; height:52px; }\n  }\n  @media (max-width:760px){\n    .stage{ height:640px; flex-direction:column; padding:24px 0; align-items:stretch; }\n    .device.left{ left:50%; transform:translate3d(-280px,0,0) rotateY(0); top:18px; }\n    .device.right{ right:50%; transform:translate3d(280px,0,0) rotateY(0); top:18px; }\n    .network{ width:94%; margin:26px auto; height:220px; }\n    .packet{ display:block; left:50px !important; top:210px !important; }\n  }\n\n</style>\n</head>\n<body>\n<div class=\"app\" role=\"main\" aria-label=\"TCP/IP Visual Demonstration\">\n  <div class=\"float-blob\" aria-hidden=\"true\"></div>\n  <div class=\"float-blob two\" aria-hidden=\"true\"></div>\n\n  <header>\n    <h1>TCP/IP — Layered Flow & Encapsulation</h1>\n    <p class=\"lead\">A minimalist, elegant visualization of how data travels from an application's payload through TCP/IP layers, gets encapsulated into frames, traverses the network, and is decapsulated at the destination.</p>\n  </header>\n\n  <div class=\"stage\" id=\"stage\" aria-hidden=\"false\">\n    <!-- Left device (Client) -->\n    <div class=\"device left\" role=\"img\" aria-label=\"Client device showing TCP/IP stack\">\n      <div class=\"title\"><span class=\"dot\" aria-hidden=\"true\"></span> Client</div>\n      <div class=\"sub\">Source of application data</div>\n      <div class=\"layers\" aria-hidden=\"true\">\n        <div class=\"layer app\">\n          <div class=\"lbl\">Application</div>\n          <div class=\"desc\">HTTP / TLS / SMTP</div>\n        </div>\n        <div class=\"layer trans\">\n          <div class=\"lbl\">Transport (TCP)</div>\n          <div class=\"desc\">Segments, ports, reliability</div>\n        </div>\n        <div class=\"layer net\">\n          <div class=\"lbl\">Internet (IP)</div>\n          <div class=\"desc\">Addressing, routing</div>\n        </div>\n        <div class=\"layer link\">\n          <div class=\"lbl\">Link</div>\n          <div class=\"desc\">Ethernet frame, physical</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Network core -->\n    <div class=\"network\" aria-hidden=\"true\">\n      <div class=\"net-core\">\n        <div class=\"router\" aria-hidden=\"true\">\n          <div class=\"rings\">⤿</div>\n          <div style=\"font-size:12px;margin-top:8px;color:var(--muted)\">Router</div>\n        </div>\n\n        <div style=\"width:36%; display:flex; flex-direction:column; gap:8px; justify-content:center; align-items:flex-start;\">\n          <div style=\"font-weight:800;color:white;font-size:13px\">Network Fabric</div>\n          <div style=\"font-size:12px;color:var(--muted)\">IP routing • packets • best-effort delivery</div>\n        </div>\n\n        <div style=\"width:24%; display:flex; flex-direction:column; gap:8px; justify-content:center; align-items:flex-end;\">\n          <div style=\"font-weight:700;color:var(--muted);font-size:13px\">Medium</div>\n          <div style=\"font-size:12px;color:var(--muted)\">Ethernet • Wi‑Fi • Fiber</div>\n        </div>\n\n        <div class=\"flow\" aria-hidden=\"true\"></div>\n      </div>\n      <div class=\"net-lines\" aria-hidden=\"true\"></div>\n    </div>\n\n    <!-- Right device (Server) -->\n    <div class=\"device right\" role=\"img\" aria-label=\"Server device showing TCP/IP stack\">\n      <div class=\"title\"><span class=\"dot\" style=\"background:linear-gradient(90deg,#86efac,#34d399)\"></span> Server</div>\n      <div class=\"sub\">Destination that receives and responds</div>\n      <div class=\"layers\" aria-hidden=\"true\">\n        <div class=\"layer app\">\n          <div class=\"lbl\">Application</div>\n          <div class=\"desc\">Web server / API</div>\n        </div>\n        <div class=\"layer trans\">\n          <div class=\"lbl\">Transport (TCP)</div>\n          <div class=\"desc\">Reassembles segments</div>\n        </div>\n        <div class=\"layer net\">\n          <div class=\"lbl\">Internet (IP)</div>\n          <div class=\"desc\">Delivers datagrams</div>\n        </div>\n        <div class=\"layer link\">\n          <div class=\"lbl\">Link</div>\n          <div class=\"desc\">Decoding frames</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Path labels -->\n    <div class=\"path-label label-client\">Client</div>\n    <div class=\"path-label label-server\">Server</div>\n\n    <!-- Animated packet -->\n    <div class=\"packet\" id=\"packet\" aria-hidden=\"true\">\n      <div class=\"frame\" role=\"presentation\">\n        <div class=\"hdr frame\" aria-hidden=\"true\">Ethernet</div>\n        <div class=\"hdr ip\" aria-hidden=\"true\">IP</div>\n        <div class=\"hdr tcp\" aria-hidden=\"true\">TCP</div>\n        <div class=\"payload\" aria-hidden=\"true\">DATA</div>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"controls\" role=\"toolbar\" aria-label=\"Animation controls\">\n    <button class=\"btn\" id=\"toggleBtn\" aria-pressed=\"false\" title=\"Play animation\">Play</button>\n    <button class=\"btn ghost\" id=\"resetBtn\" title=\"Reset animation\">Reset</button>\n  </div>\n\n  <div class=\"note\" aria-hidden=\"true\">Tip: press \"Play\" to observe a full encapsulation & traversal cycle. Headers appear as the packet moves down, travel across the network, then are removed as it ascends at the server.</div>\n</div>\n\n<script>\n  // Minimal JS to control the animation: Play/Pause toggle and Reset\n  (function(){\n    const stage = document.getElementById('stage');\n    const btn = document.getElementById('toggleBtn');\n    const reset = document.getElementById('resetBtn');\n\n    let running = false;\n\n    function setRunning(state){\n      running = !!state;\n      if(running){\n        stage.classList.add('running');\n        btn.textContent = 'Pause';\n        btn.setAttribute('aria-pressed','true');\n        btn.title = 'Pause animation';\n      } else {\n        stage.classList.remove('running');\n        btn.textContent = 'Play';\n        btn.setAttribute('aria-pressed','false');\n        btn.title = 'Play animation';\n      }\n    }\n\n    btn.addEventListener('click', function(){\n      setRunning(!running);\n    });\n\n    reset.addEventListener('click', function(){\n      // Stop, then reflow, then restart paused at initial state (not running)\n      setRunning(false);\n      // To reset CSS animation to initial frame, we remove and reinsert the packet node\n      const packet = document.getElementById('packet');\n      const parent = packet.parentNode;\n      const next = document.createElement('div');\n      next.innerHTML = packet.outerHTML;\n      parent.removeChild(packet);\n      // slight delay to ensure reflow\n      setTimeout(() => {\n        parent.appendChild(next.firstElementChild);\n      }, 20);\n    });\n\n    // Prefers-reduced-motion: if user has it set, don't animate automatically\n    const media = window.matchMedia('(prefers-reduced-motion: reduce)');\n    if(media.matches){\n      // don't auto-start, keep accessible\n      setRunning(false);\n      btn.title = 'Play animation (reduced motion preferred)';\n    } else {\n      // nice UX: start paused but float the packet slightly to show it's ready\n      setRunning(false);\n    }\n\n    // Accessibility: keyboard shortcuts (Space toggles)\n    window.addEventListener('keydown', function(e){\n      if(e.code === 'Space' && document.activeElement.tagName.toLowerCase() !== 'button'){\n        e.preventDefault();\n        setRunning(!running);\n      }\n    });\n\n  })();\n</script>\n</body>\n</html>"
