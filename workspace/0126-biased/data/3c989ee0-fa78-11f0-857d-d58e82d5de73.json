eft-pointer);\n    font-style: normal;\n    font-weight: 700;\n  }\n\n  /* Array visualization container */\n  #array-visualization {\n    position: relative;\n    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent1) 100%);\n    border-radius: 20px;\n    padding: 3.8rem 3rem 5rem;\n    box-shadow:\n      inset 0 0 60px #f7b733aa,\n      0 12px 35px var(--color-shadow);\n    user-select: none;\n    perspective-origin: center center;\n  }\n\n  /* Array container */\n  #array {\n    display: flex;\n    justify-content: center;\n    gap: 1.3rem;\n  }\n\n  /* Each cell */\n  .cell {\n    position: relative;\n    background: var(--color-array-cell-bg);\n    border: 2.5px solid var(--color-array-cell-border);\n    border-radius: 12px;\n    width: 64px; height: 72px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.6rem;\n    color: var(--color-highlight-d);\n    box-shadow:\n      0 6px 15px rgba(0,0,0,0.4),\n      inset 0 -3px 8px #22364b,\n      inset 0 4px 1.5px #4b6d97;\n    transition: background-color 0.4s cubic-bezier(0.4,0,0.2,1), border-color 0.3s ease;\n    user-select: none;\n  }\n\n  /* Highlighted cells during pointers */\n  .cell.left-pointer {\n    background: var(--color-left-pointer);\n    border-color: #ff5039;\n    color: white;\n    box-shadow:\n      0 0 15px #ff6f61aa,\n      inset 0 0 10px #ff6f61cc;\n    transform: scale(1.12);\n    transition: transform 0.5s ease, background-color 0.5s ease;\n    z-index: 10;\n  }\n  .cell.right-pointer {\n    background: var(--color-right-pointer);\n    border-color: #f7b733dd;\n    color: #1b1107;\n    box-shadow:\n      0 0 16px #f7b733cc,\n      inset 0 0 15px #f7b733dd;\n    transform: scale(1.12);\n    transition: transform 0.5s ease, background-color 0.5s ease;\n    z-index: 10;\n  }\n\n  /* Pointer labels */\n  #left-pointer-label,\n  #right-pointer-label {\n    position: absolute;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1rem;\n    background: var(--color-left-pointer);\n    padding: 0.25rem 0.7rem;\n    border-radius: 12px 12px 0 0;\n    text-align: center;\n    color: #fff;\n    text-shadow: 0 0 6px #d84329;\n    user-select: none;\n    pointer-events: none;\n    filter: drop-shadow(0 1px 1px rgba(0,0,0,0.2));\n  }\n  #right-pointer-label {\n    background: var(--color-right-pointer);\n    color: #432800;\n    text-shadow: 0 0 6px #f7b713;\n  }\n\n  /* Position pointer labels on top of corresponding cells */\n  #left-pointer-label {\n    top: 1.1rem;\n    transition:\n      left 0.6s cubic-bezier(0.4,0,0.2,1),\n      opacity 0.5s ease;\n  }\n  #right-pointer-label {\n    top: 1.1rem;\n    transition:\n      left 0.6s cubic-bezier(0.4,0,0.2,1),\n      opacity 0.5s ease;\n  }\n\n  /* Buttons container */\n  #controls {\n    text-align: center;\n    margin-top: 1rem;\n  }\n\n  button {\n    background: linear-gradient(145deg, #f7b733, #ff6f61);\n    border: none;\n    border-radius: 40px;\n    box-shadow:\n      0 5px 15px #ff6049cc;\n    color: var(--color-highlight-d);\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.05rem;\n    padding: 0.8rem 2.4rem;\n    margin: 0 0.6rem;\n    cursor: pointer;\n    user-select: none;\n    transition:\n      box-shadow 0.4s ease,\n      transform 0.2s ease,\n      background 0.3s ease;\n  }\n  button:hover {\n    box-shadow:\n      0 9px 25px #f7b715dd,\n      0 0 12px #f7b715cc;\n    transform: scale(1.08);\n    background: linear-gradient(145deg, #ff8650, #f7b733);\n  }\n  button:active {\n    transform: scale(0.96);\n    box-shadow: none;\n  }\n\n  /* Subtle animated background swirl behind array */\n  #swirl-bg {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 380px;\n    height: 380px;\n    margin-left: -190px;\n    margin-top: -190px;\n    border-radius: 50%;\n    pointer-events: none;\n    user-select: none;\n    filter: blur(36px);\n    z-index: 0;\n    background:\n      radial-gradient(circle at 40% 40%, #ff6f61cc 20%, transparent 60%),\n      radial-gradient(circle at 70% 70%, #f7b733cc 18%, transparent 58%);\n    animation: swirlRotate 48s linear infinite;\n  }\n\n  @keyframes swirlRotate {\n    0% { transform: rotate(0deg) }\n    100% { transform: rotate(360deg) }\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    color: var(--color-accent2);\n    font-family: 'Roboto Slab', serif;\n    font-size: 0.9rem;\n    padding: 1rem 1rem 2rem;\n    user-select: none;\n    opacity: 0.65;\n  }\n\n  /* Responsive */\n  @media (max-width: 600px) {\n    #array {\n      gap: 0.8rem;\n    }\n    .cell {\n      width: 52px;\n      height: 58px;\n      font-size: 1.3rem;\n    }\n    #left-pointer-label,\n    #right-pointer-label {\n      font-size: 0.85rem;\n      padding: 0.2rem 0.6rem;\n      top: 0.8rem;\n    }\n  }\n</style>\n</head>\n<body>\n\n<header>Two Pointers Technique</header>\n\n<div id=\"container\">\n\n  <article class=\"explanation\" aria-label=\"Explanation of the Two Pointers technique\">\n    The <em>Two Pointers</em> technique is an elegant and efficient way to solve array and string problems by using two indices moving from different ends toward each other (or in the same direction). This approach often reduces the time complexity drastically by avoiding nested loops. Observe how two pointers, <span style=\"color:#ff6f61;font-weight:900;\"><em>left</em></span> and <span style=\"color:#f7b733;font-weight:900;\"><em>right</em></span>, move inward to find pairs or inspect elements visually.\n  </article>\n\n  <section id=\"array-visualization\" aria-label=\"Array visualization with two pointers\">\n\n    <div id=\"swirl-bg\" aria-hidden=\"true\"></div>\n\n    <div id=\"array\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <!-- Array cells will be generated here -->\n    </div>\n\n    <div id=\"left-pointer-label\" aria-hidden=\"true\">← left</div>\n    <div id=\"right-pointer-label\" aria-hidden=\"true\">right →</div>\n\n  </section>\n\n  <div id=\"controls\" aria-label=\"Controls\">\n    <button id=\"startBtn\" aria-pressed=\"false\" aria-label=\"Start animation of two pointers\">Start Animation</button>\n    <button id=\"resetBtn\" aria-label=\"Reset animation and pointers\">Reset</button>\n  </div>\n\n</div>\n\n<footer>\n  &copy; 2024 — Visualization by ChatGPT\n</footer>\n\n<script>\n(() => {\n  const arrayVals = [3, 7, 12, 5, 8, 9, 14, 11, 6, 4];\n  // e.g. visualize searching pairs (for example sum=15)\n  // but here just show two pointers moving inward with smooth animation\n\n  const arrayEl = document.getElementById('array');\n  const leftLabel = document.getElementById('left-pointer-label');\n  const rightLabel = document.getElementById('right-pointer-label');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  let left = 0;\n  let right = arrayVals.length - 1;\n  let intervalId = null;\n  let running = false;\n\n  // Create cells\n  function createCells() {\n    arrayEl.innerHTML = '';\n    arrayVals.forEach((val, i) => {\n      const cell = document.createElement('div');\n      cell.classList.add('cell');\n      cell.textContent = val;\n      cell.dataset.index = i;\n      arrayEl.appendChild(cell);\n    });\n  }\n\n  // Update pointer visuals\n  function updatePointers() {\n    // Remove all pointer classes first\n    const cells = arrayEl.querySelectorAll('.cell');\n    cells.forEach(cell => {\n      cell.classList.remove('left-pointer', 'right-pointer');\n    });\n    if (left <= right) {\n      const leftCell = cells[left];\n      const rightCell = cells[right];\n      if(leftCell) leftCell.classList.add('left-pointer');\n      if(rightCell && right !== left) rightCell.classList.add('right-pointer');\n    }\n\n    // Position pointer labels above the correct cells\n    const leftCell = cells[left];\n    const rightCell = cells[right];\n\n    if(leftCell) {\n      const rect = leftCell.getBoundingClientRect();\n      const parentRect = arrayEl.getBoundingClientRect();\n      leftLabel.style.left = `${leftCell.offsetLeft + leftCell.offsetWidth/2 - leftLabel.offsetWidth/2}px`;\n      leftLabel.style.opacity = '1';\n    } else {\n      leftLabel.style.opacity = '0';\n    }\n\n    if(rightCell && right !== left) {\n      rightLabel.style.left = `${rightCell.offsetLeft + rightCell.offsetWidth/2 - rightLabel.offsetWidth/2}px`;\n      rightLabel.style.opacity = '1';\n    } else {\n      rightLabel.style.opacity = '0';\n    }\n  }\n\n  // Animate pointers moving inward with delay\n  function startAnimation() {\n    if(running) return;\n    running = true;\n    startBtn.setAttribute('aria-pressed', 'true');\n    let steps = 0;\n    intervalId = setInterval(() => {\n      if(left >= right) {\n        clearInterval(intervalId);\n        running = false;\n        startBtn.setAttribute('aria-pressed', 'false');\n        // Highlight middle cell if pointers met\n        if(left === right) {\n          const centerCell = arrayEl.querySelector(`.cell[data-index=\"${left}\"]`);\n          if(centerCell) {\n            centerCell.classList.add('left-pointer');\n            centerCell.classList.add('right-pointer');\n            centerCell.style.background = 'linear-gradient(135deg, #ff6f6155, #f7b73355)';\n            centerCell.style.borderColor = 'transparent';\n            centerCell.style.color = '#ffffee';\n            centerCell.style.boxShadow = '0 0 24px #ffc05fcc, inset 0 0 30px #ffb743cc';\n          }\n        }\n        return;\n      }\n      updatePointers();\n      left++;\n      right--;\n      steps++;\n    }, 1200);\n  }\n\n  // Reset everything\n  function resetAnimation() {\n    clearInterval(intervalId);\n    running = false;\n    startBtn.setAttribute('aria-pressed', 'false');\n    left = 0;\n    right = arrayVals.length - 1;\n    createCells();\n    updatePointers();\n  }\n\n  // Initial setup\n  createCells();\n  updatePointers();\n\n  startBtn.addEventListener('click', startAnimation);\n  resetBtn.addEventListener('click', resetAnimation);\n\n  // On resize recalc label positions for pointer labels\n  window.addEventListener('resize', () => {\n    updatePointers();\n  });\n})();\n</script>\n\n</body>\n</html>"
