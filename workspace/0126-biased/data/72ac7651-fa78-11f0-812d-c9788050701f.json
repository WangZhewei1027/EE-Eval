    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>DNS: The Internet's Phonebook</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: -1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .dns-visualization {\n            position: relative;\n            height: 500px;\n            margin: 4rem 0;\n            background: rgba(255, 255, 255, 0.3);\n            backdrop-filter: blur(10px);\n            border-radius: 20px;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n            padding: 2rem;\n            animation: floatUp 1s ease-out;\n        }\n\n        .dns-flow {\n            position: relative;\n            height: 100%;\n            width: 100%;\n        }\n\n        .node {\n            position: absolute;\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-direction: column;\n            color: white;\n            font-weight: bold;\n            text-align: center;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s ease;\n            z-index: 2;\n            cursor: default;\n        }\n\n        .node:hover {\n            transform: scale(1.05);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);\n        }\n\n        .node i {\n            font-size: 2rem;\n            margin-bottom: 0.5rem;\n        }\n\n        .node-1 {\n            top: 50%;\n            left: 10%;\n            transform: translateY(-50%);\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n        }\n\n        .node-2 {\n            top: 20%;\n            left: 30%;\n            background: linear-gradient(135deg, #00cec9, #55efc4);\n        }\n\n        .node-3 {\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            background: linear-gradient(135deg, #fdcb6e, #e17055);\n            width: 140px;\n            height: 140px;\n        }\n\n        .node-4 {\n            top: 20%;\n            left: 70%;\n            background: linear-gradient(135deg, #a29bfe, #74b9ff);\n        }\n\n        .node-5 {\n            top: 50%;\n            left: 90%;\n            transform: translateY(-50%);\n            background: linear-gradient(135deg, var(--accent), #ff7675);\n        }\n\n        .connection {\n            position: absolute;\n            height: 4px;\n            background: var(--dark);\n            transform-origin: left center;\n            z-index: 1;\n            opacity: 0.2;\n        }\n\n        .connection.active {\n            background: var(--success);\n            opacity: 1;\n            box-shadow: 0 0 10px var(--success);\n        }\n\n        .connection-1 {\n            width: calc(20% - 60px);\n            top: 50%;\n            left: 16%;\n            transform: translateY(-50%);\n        }\n\n        .connection-2 {\n            width: calc(20% - 60px);\n            top: 35%;\n            left: 36%;\n            transform: rotate(15deg);\n        }\n\n        .connection-3 {\n            width: calc(20% - 60px);\n            top: 35%;\n            left: 56%;\n            transform: rotate(-15deg);\n        }\n\n        .connection-4 {\n            width: calc(20% - 60px);\n            top: 50%;\n            left: 76%;\n            transform: translateY(-50%);\n        }\n\n        .pulse {\n            position: absolute;\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n            background: var(--success);\n            z-index: 3;\n            opacity: 0;\n            box-shadow: 0 0 10px var(--success);\n        }\n\n        .explanation {\n            background: white;\n            border-radius: 20px;\n            padding: 2rem;\n            margin-top: 3rem;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            animation: fadeIn 1.5s ease-out 0.5s both;\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 2rem;\n        }\n\n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n            color: var(--dark);\n            opacity: 0.9;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            padding: 0.8rem 2rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            color: white;\n            font-weight: bold;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.6);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .highlight {\n            background: linear-gradient(90deg, var(--accent), #ff7675);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes floatUp {\n            from { transform: translateY(50px); opacity: 0; }\n            to { transform: translateY(0); opacity: 1; }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(0.5); opacity: 0.8; }\n            100% { transform: scale(1.5); opacity: 0; }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem;\n            color: var(--dark);\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n\n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .dns-visualization {\n                height: 400px;\n            }\n            \n            .node {\n                width: 80px;\n                height: 80px;\n                font-size: 0.8rem;\n            }\n            \n            .node i {\n                font-size: 1.5rem;\n            }\n            \n            .node-3 {\n                width: 100px;\n                height: 100px;\n            }\n        }\n    </style>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\">\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>DNS: The Internet's Phonebook</h1>\n            <p class=\"subtitle\">The Domain Name System translates human-friendly domain names into machine-readable IP addresses, enabling seamless navigation across the vast digital landscape.</p>\n        </header>\n\n        <div class=\"dns-visualization\">\n            <div class=\"dns-flow\">\n                <div class=\"connection connection-1\"></div>\n                <div class=\"connection connection-2\"></div>\n                <div class=\"connection connection-3\"></div>\n                <div class=\"connection connection-4\"></div>\n\n                <div class=\"node node-1\">\n                    <i class=\"fas fa-laptop\"></i>\n                    User Device\n                </div>\n                <div class=\"node node-2\">\n                    <i class=\"fas fa-search\"></i>\n                    Recursive Resolver\n                </div>\n                <div class=\"node node-3\">\n                    <i class=\"fas fa-sitemap\"></i>\n                    Root Nameserver\n                </div>\n                <div class=\"node node-4\">\n                    <i class=\"fas fa-flag\"></i>\n                    TLD Nameserver\n                </div>\n                <div class=\"node node-5\">\n                    <i class=\"fas fa-server\"></i>\n                    Authoritative Nameserver\n                </div>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"animateBtn\">Show DNS Lookup</button>\n            <button id=\"resetBtn\" class=\"highlight\">Reset Animation</button>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>How DNS Works</h2>\n            <p>When you type a website address into your browser, your device initiates a DNS lookup process to find the corresponding IP address. This elegant system operates behind the scenes through a hierarchical network of specialized servers.</p>\n            \n            <p>The journey begins with your device contacting a recursive resolver (typically operated by your ISP). If the resolver doesn't have the answer cached, it queries the root nameservers, which direct it to the appropriate Top-Level Domain (TLD) nameserver (like .com or .org). The TLD server then points to the authoritative nameserver for the specific domain, which finally provides the IP address needed to establish the connection.</p>\n            \n            <p>This entire process usually happens in milliseconds, creating the seamless web browsing experience we enjoy every day.</p>\n        </div>\n    </div>\n\n    <footer>\n        <p>© 2023 DNS Visualization | A beautiful demonstration of internet infrastructure</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const animateBtn = document.getElementById('animateBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const connections = document.querySelectorAll('.connection');\n            const nodes = document.querySelectorAll('.node');\n            const dnsFlow = document.querySelector('.dns-flow');\n            \n            let animationInProgress = false;\n            \n            animateBtn.addEventListener('click', function() {\n                if (animationInProgress) return;\n                animationInProgress = true;\n                \n                // Reset any previous animations\n                resetAnimation();\n                \n                // Animate connections one by one\n                connections.forEach((conn, index) => {\n                    setTimeout(() => {\n                        conn.classList.add('active');\n                        \n                        // Create pulse effect between nodes\n                        const fromNode = nodes[index];\n                        const toNode = nodes[index + 1];\n                        \n                        createPulse(fromNode, toNode);\n                        \n                        if (index === connections.length - 1) {\n                            setTimeout(() => {\n                                animationInProgress = false;\n                            }, 1000);\n                        }\n                    }, index * 1000);\n                });\n            });\n            \n            resetBtn.addEventListener('click', resetAnimation);\n            \n            function resetAnimation() {\n                connections.forEach(conn => {\n                    conn.classList.remove('active');\n                });\n                \n                // Remove any existing pulses\n                document.querySelectorAll('.pulse').forEach(pulse => {\n                    pulse.remove();\n                });\n                \n                animationInProgress = false;\n            }\n            \n            function createPulse(fromNode, toNode) {\n                const fromRect = fromNode.getBoundingClientRect();\n                const toRect = toNode.getBoundingClientRect();\n                \n                const fromX = fromRect.left + fromRect.width / 2;\n                const fromY = fromRect.top + fromRect.height / 2;\n                const toX = toRect.left + toRect.width / 2;\n                const toY = toRect.top + toRect.height / 2;\n                \n                const distance = Math.sqrt(Math.pow(toX - fromX, 2) + Math.pow(toY - fromY, 2));\n                const angle = Math.atan2(toY - fromY, toX - fromX);\n                \n                const pulse = document.createElement('div');\n                pulse.className = 'pulse';\n                pulse.style.left = `${fromX}px`;\n                pulse.style.top = `${fromY}px`;\n                document.body.appendChild(pulse);\n                \n                const duration = 1000; // ms\n                const startTime = Date.now();\n                \n                function animatePulse() {\n                    const elapsed = Date.now() - startTime;\n                    const progress = elapsed / duration;\n                    \n                    if (progress >= 1) {\n                        pulse.remove();\n                        return;\n                    }\n                    \n                    const currentX = fromX + progress * (toX - fromX);\n                    const currentY = fromY + progress * (toY - fromY);\n                    \n                    pulse.style.left = `${currentX}px`;\n                    pulse.style.top = `${currentY}px`;\n                    \n                    requestAnimationFrame(animatePulse);\n                }\n                \n                animatePulse();\n            }\n            \n            // Initial subtle animations for nodes\n            nodes.forEach((node, index) => {\n                setTimeout(() => {\n                    node.style.opacity = '1';\n                    node.style.transform = node.style.transform ? \n                        node.style.transform + ' scale(1.05)' : \n                        'scale(1.05)';\n                    \n                    setTimeout(() => {\n                        node.style.transform = node.style.transform.replace('scale(1.05)', '') || '';\n                    }, 300);\n                }, index * 200);\n            });\n        });\n    </script>\n</body>\n</html>"
