    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Dijkstra's Algorithm Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    background: white;\n    color: black;\n  }\n  input[type=number], input[type=text] {\n    width: 50px;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 10px;\n  }\n  td, th {\n    border: 1px solid black;\n    padding: 2px 4px;\n    text-align: center;\n  }\n  #graphTable td {\n    cursor: pointer;\n  }\n  .selected {\n    outline: 2px solid black;\n  }\n</style>\n</head>\n<body>\n\n<h1>Dijkstra's Algorithm Interactive Demonstration</h1>\n\n<div>\n  <h2>1. Define Graph</h2>\n  <p>\n    Number of nodes (1 to 26):\n    <input type=\"number\" id=\"nodeCount\" min=\"1\" max=\"26\" value=\"5\" />\n    <button id=\"createGraphBtn\">Create Graph</button>\n  </p>\n  <p>\n    Add or edit edges by clicking the cells in the adjacency matrix below.<br/>\n    Click a cell to edit weight (empty means no edge).<br/>\n    Directed edges only (from row node to column node).\n  </p>\n  <div id=\"graphContainer\"></div>\n</div>\n\n<hr/>\n\n<div>\n  <h2>2. Choose Start Node</h2>\n  <select id=\"startNodeSelect\" disabled>\n    <option value=\"\">-- Select Start Node --</option>\n  </select>\n  <button id=\"initializeBtn\" disabled>Initialize Dijkstra</button>\n</div>\n\n<hr/>\n\n<div>\n  <h2>3. Run Dijkstra's Algorithm Step-by-Step</h2>\n  <p>Current step status:</p>\n  <pre id=\"statusOutput\">No algorithm initialized.</pre>\n  <button id=\"nextStepBtn\" disabled>Next Step</button>\n  <button id=\"autoRunBtn\" disabled>Auto Run</button>\n  <button id=\"pauseAutoBtn\" disabled>Pause Auto Run</button>\n  <button id=\"resetAlgorithmBtn\" disabled>Reset Algorithm</button>\n</div>\n\n<hr/>\n\n<div>\n  <h2>4. Explore All States</h2>\n  <p>\n    Current node set: <span id=\"currentNodeSet\">N/A</span><br/>\n    <button id=\"showDistancesBtn\" disabled>Show Distances Table</button>\n    <button id=\"showPredecessorsBtn\" disabled>Show Predecessors Table</button>\n  </p>\n  <div id=\"tablesContainer\"></div>\n</div>\n\n<hr/>\n\n<div>\n  <h2>5. Custom Query</h2>\n  <p>\n    Enter destination node to find path from start:<br/>\n    <input type=\"text\" id=\"destinationInput\" maxlength=\"1\" style=\"width:30px;\" disabled />\n    <button id=\"findPathBtn\" disabled>Find Shortest Path</button>\n  </p>\n  <div id=\"pathOutput\"></div>\n</div>\n\n<hr/>\n\n<div>\n  <h2>6. Controls</h2>\n  <button id=\"clearAllBtn\">Clear All & Start Over</button>\n</div>\n\n\n<script>\n(function(){\n  // Variables for graph representation:\n  // Nodes labeled from 0 to n-1 corresponding to letters A-Z\n  let nodeCount = 0;\n  let adjacencyMatrix = []; // 2D array [nodeCount][nodeCount], numbers or null for no edge\n\n  // Algorithm state variables:\n  let distances = [];\n  let predecessors = [];\n  let visitedSet = new Set();\n  let unvisitedSet = new Set();\n  let startNode = null;\n\n  // For stepwise operation:\n  let algorithmInitialized = false;\n  let finished = false;\n\n  // Elements references\n  const nodeCountInput = document.getElementById('nodeCount');\n  const createGraphBtn = document.getElementById('createGraphBtn');\n  const graphContainer = document.getElementById('graphContainer');\n  const startNodeSelect = document.getElementById('startNodeSelect');\n  const initializeBtn = document.getElementById('initializeBtn');\n  const statusOutput = document.getElementById('statusOutput');\n  const nextStepBtn = document.getElementById('nextStepBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const pauseAutoBtn = document.getElementById('pauseAutoBtn');\n  const resetAlgorithmBtn = document.getElementById('resetAlgorithmBtn');\n  const currentNodeSetSpan = document.getElementById('currentNodeSet');\n  const showDistancesBtn = document.getElementById('showDistancesBtn');\n  const showPredecessorsBtn = document.getElementById('showPredecessorsBtn');\n  const tablesContainer = document.getElementById('tablesContainer');\n  const destinationInput = document.getElementById('destinationInput');\n  const findPathBtn = document.getElementById('findPathBtn');\n  const pathOutput = document.getElementById('pathOutput');\n  const clearAllBtn = document.getElementById('clearAllBtn');\n\n  // Auto run interval variable\n  let autoRunInterval = null;\n  const AUTO_RUN_SPEED_MS = 1000;\n\n  // Utility functions\n  function indexToNode(i){\n    return String.fromCharCode(65 + i);\n  }\n  function nodeToIndex(c){\n    return c.charCodeAt(0) - 65;\n  }\n\n  function createEmptyMatrix(size){\n    let mat = [];\n    for(let i=0;i<size;i++){\n      mat[i] = [];\n      for(let j=0;j<size;j++){\n        mat[i][j] = null;\n      }\n    }\n    return mat;\n  }\n\n  // Graph Input / Editing Functions\n\n  // Create matrix HTML table for adjacency matrix input\n  function createGraphTable(){\n    while(graphContainer.firstChild) graphContainer.removeChild(graphContainer.firstChild);\n    if(nodeCount < 1 || nodeCount > 26) return;\n\n    let table = document.createElement('table');\n    table.id = 'graphTable';\n\n    // Header row\n    let headerRow = document.createElement('tr');\n    headerRow.appendChild(document.createElement('th')); // empty corner cell\n    for(let j=0;j<nodeCount;j++){\n      let th = document.createElement('th');\n      th.textContent = indexToNode(j);\n      headerRow.appendChild(th);\n    }\n    table.appendChild(headerRow);\n\n    for(let i=0;i<nodeCount;i++){\n      let tr = document.createElement('tr');\n      let rowHeader = document.createElement('th');\n      rowHeader.textContent = indexToNode(i);\n      tr.appendChild(rowHeader);\n      for(let j=0;j<nodeCount;j++){\n        let td = document.createElement('td');\n        td.dataset.row = i;\n        td.dataset.col = j;\n        td.textContent = adjacencyMatrix[i][j] === null ? '' : adjacencyMatrix[i][j];\n        td.addEventListener('click', function(){\n          editEdgeWeight(i,j);\n        });\n        tr.appendChild(td);\n      }\n      table.appendChild(tr);\n    }\n\n    graphContainer.appendChild(table);\n  }\n\n  // Popup prompt for editing weight on edge from i to j\n  function editEdgeWeight(i,j){\n    let currentVal = adjacencyMatrix[i][j];\n    let promptText = 'Enter weight for edge ' + indexToNode(i) + ' → ' + indexToNode(j) + ' (empty = no edge, ≥ 0):';\n    let inp = prompt(promptText, currentVal === null ? '' : currentVal);\n    if(inp === null) return; // cancelled\n    inp = inp.trim();\n    if(inp === ''){\n      adjacencyMatrix[i][j] = null;\n    }else{\n      let w = Number(inp);\n      if(Number.isNaN(w) || w < 0 || !Number.isFinite(w)){\n        alert('Invalid weight. Must be a non-negative finite number or empty.');\n        return;\n      }\n      adjacencyMatrix[i][j] = w;\n    }\n    createGraphTable();\n    resetAlgorithmState();\n  }\n\n\n  // Populate startNodeSelect options:\n  function populateStartNodeSelect(){\n    while(startNodeSelect.options.length > 1){\n      startNodeSelect.remove(1);\n    }\n    for(let i=0;i<nodeCount;i++){\n      let opt = document.createElement('option');\n      opt.value = i;\n      opt.textContent = indexToNode(i);\n      startNodeSelect.appendChild(opt);\n    }\n    startNodeSelect.disabled = false;\n  }\n\n  // Initialize Dijkstra's Algorithm state variables\n  function initializeAlgorithm(){\n    distances = [];\n    predecessors = [];\n    visitedSet = new Set();\n    unvisitedSet = new Set();\n\n    for(let i=0;i<nodeCount;i++){\n      distances[i] = Infinity;\n      predecessors[i] = null;\n      unvisitedSet.add(i);\n    }\n    distances[startNode] = 0;\n\n    algorithmInitialized = true;\n    finished = false;\n    updateStatusOutput();\n    nextStepBtn.disabled = false;\n    autoRunBtn.disabled = false;\n    pauseAutoBtn.disabled = true;\n    resetAlgorithmBtn.disabled = false;\n    showDistancesBtn.disabled = false;\n    showPredecessorsBtn.disabled = false;\n    destinationInput.disabled = false;\n    findPathBtn.disabled = false;\n    currentNodeSetSpan.textContent = formatVisitedUnvisited();\n    tablesContainer.innerHTML = '';\n    pathOutput.textContent = '';\n  }\n\n  // Format visited and unvisited nodes as strings\n  function formatVisitedUnvisited(){\n    let visitedArr = Array.from(visitedSet).map(i=>indexToNode(i)).sort();\n    let unvisitedArr = Array.from(unvisitedSet).map(i=>indexToNode(i)).sort();\n    return 'Visited: {' + visitedArr.join(', ') + '} | Unvisited: {' + unvisitedArr.join(', ') + '}';\n  }\n\n  // Update the status text area reflecting current algorithm status\n  function updateStatusOutput(){\n    if(!algorithmInitialized){\n      statusOutput.textContent = 'No algorithm initialized.';\n      return;\n    }\n    if(finished){\n      statusOutput.textContent = 'Algorithm finished.\\n\\n' + distancesSummary();\n      currentNodeSetSpan.textContent = formatVisitedUnvisited();\n      return;\n    }\n\n    let currentNode = getCurrentClosestUnvisitedNode();\n    let stepDetails = '';\n\n    if(currentNode === null){\n      stepDetails += '(No reachable unvisited nodes remain.) Algorithm finished.\\n\\n';\n      finished = true;\n      nextStepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      pauseAutoBtn.disabled = true;\n    } else {\n      stepDetails += 'Next node chosen to visit: ' + indexToNode(currentNode) + '\\n';\n      stepDetails += 'Current distances:\\n';\n      stepDetails += distancesSummary() + '\\n';\n      stepDetails += '\\nVisited nodes: ' + Array.from(visitedSet).map(i=>indexToNode(i)).join(', ') + '\\n';\n      stepDetails += 'Unvisited nodes: ' + Array.from(unvisitedSet).map(i=>indexToNode(i)).join(', ');\n    }\n\n    statusOutput.textContent = stepDetails;\n    currentNodeSetSpan.textContent = formatVisitedUnvisited();\n  }\n\n  // Summary of distances array for output\n  function distancesSummary(){\n    let out = '';\n    for(let i=0;i<nodeCount;i++){\n      out += indexToNode(i) + ': ';\n      if(distances[i] === Infinity){\n        out += '∞';\n      } else {\n        out += distances[i];\n      }\n      if(predecessors[i] !== null){\n        out += ' (via ' + indexToNode(predecessors[i]) + ')';\n      }\n      out += '\\n';\n    }\n    return out;\n  }\n\n  // Helper: get unvisited node with smallest current distance\n  function getCurrentClosestUnvisitedNode(){\n    let minDist = Infinity;\n    let minNode = null;\n    for(let node of unvisitedSet){\n      if(distances[node] < minDist){\n        minDist = distances[node];\n        minNode = node;\n      }\n    }\n    return minNode;\n  }\n\n  // Perform a single step of Dijkstra's Algorithm\n  function stepAlgorithm(){\n    if(!algorithmInitialized || finished) return;\n\n    let current = getCurrentClosestUnvisitedNode();\n\n    if(current === null){\n      finished = true;\n      updateStatusOutput();\n      return;\n    }\n\n    // Explore neighbors of current node updating tentative distances\n    for(let neighbor=0;neighbor<nodeCount;neighbor++){\n      let edgeWeight = adjacencyMatrix[current][neighbor];\n      if(edgeWeight !== null && unvisitedSet.has(neighbor)){\n        let newDist = distances[current] + edgeWeight;\n        if(newDist < distances[neighbor]){\n          distances[neighbor] = newDist;\n          predecessors[neighbor] = current;\n        }\n      }\n    }\n\n    visitedSet.add(current);\n    unvisitedSet.delete(current);\n\n    updateStatusOutput();\n  }\n\n\n  // Auto run handlers\n  function startAutoRun(){\n    if(autoRunInterval) return;\n    autoRunBtn.disabled = true;\n    pauseAutoBtn.disabled = false;\n    nextStepBtn.disabled = true;\n    autoRunInterval = setInterval(()=>{\n      if(finished){\n        stopAutoRun();\n        return;\n      }\n      stepAlgorithm();\n    }, AUTO_RUN_SPEED_MS);\n  }\n\n  function stopAutoRun(){\n    if(autoRunInterval){\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n    }\n    autoRunBtn.disabled = false;\n    pauseAutoBtn.disabled = true;\n    nextStepBtn.disabled = false;\n  }\n\n\n  // Show tables for distances or predecessors\n  function generateTable(dataArray, title){\n    // dataArray is array length nodeCount\n    // title is string, 'Distances' or 'Predecessors'\n    let container = document.createElement('div');\n    container.tabIndex = 0;\n\n    let heading = document.createElement('h3');\n    heading.textContent = 'Table: ' + title;\n    container.appendChild(heading);\n\n    let table = document.createElement('table');\n    let headerRow = document.createElement('tr');\n    headerRow.appendChild(document.createElement('th'));\n    for(let i=0;i<nodeCount;i++){\n      let th = document.createElement('th');\n      th.textContent = indexToNode(i);\n      headerRow.appendChild(th);\n    }\n    table.appendChild(headerRow);\n\n    let tr = document.createElement('tr');\n    let firstCell = document.createElement('th');\n    firstCell.textContent = title;\n    tr.appendChild(firstCell);\n\n    for(let i=0;i<nodeCount;i++){\n      let td = document.createElement('td');\n      let val = dataArray[i];\n      if(title === 'Distances'){\n        td.textContent = val === Infinity ? '∞' : val;\n      } else if(title === 'Predecessors'){\n        td.textContent = val === null ? '-' : indexToNode(val);\n      }\n      tr.appendChild(td);\n    }\n    table.appendChild(tr);\n    container.appendChild(table);\n    return container;\n  }\n\n  // Find and display shortest path from startNode to destination node\n  function findPathToTarget(destIndex){\n    if(!algorithmInitialized){\n      pathOutput.textContent = 'Algorithm not initialized.';\n      return;\n    }\n    if(destIndex < 0 || destIndex >= nodeCount){\n      pathOutput.textContent = 'Invalid destination node.';\n      return;\n    }\n    if(distances[destIndex] === Infinity){\n      pathOutput.textContent = 'Destination node ' + indexToNode(destIndex) + ' is unreachable from start node ' + indexToNode(startNode) + '.';\n      return;\n    }\n\n    // Reconstruct path backward from destination\n    let path = [];\n    let current = destIndex;\n    while(current !== null){\n      path.push(indexToNode(current));\n      current = predecessors[current];\n    }\n    path.reverse();\n\n    let outputText = 'Shortest path from ' + indexToNode(startNode) + ' to ' + indexToNode(destIndex) + ':\\n';\n    outputText += path.join(' → ') + '\\n';\n    outputText += 'Total cost: ' + distances[destIndex];\n    pathOutput.textContent = outputText;\n  }\n\n  // Reset algorithm and UI\n  function resetAlgorithmState(){\n    algorithmInitialized = false;\n    finished = false;\n\n    distances = [];\n    predecessors = [];\n    visitedSet.clear();\n    unvisitedSet.clear();\n    startNode = null;\n\n    startNodeSelect.value = \"\";\n    startNodeSelect.disabled = nodeCount === 0;\n    initializeBtn.disabled = true;\n\n    statusOutput.textContent = 'No algorithm initialized.';\n    nextStepBtn.disabled = true;\n    autoRunBtn.disabled = true;\n    pauseAutoBtn.disabled = true;\n    resetAlgorithmBtn.disabled = true;\n    showDistancesBtn.disabled = true;\n    showPredecessorsBtn.disabled = true;\n    currentNodeSetSpan.textContent = 'N/A';\n    tablesContainer.innerHTML = '';\n    destinationInput.value = '';\n    destinationInput.disabled = true;\n    findPathBtn.disabled = true;\n    pathOutput.textContent = '';\n    stopAutoRun();\n  }\n\n  // Clear graph and all states from scratch\n  function clearAll(){\n    nodeCount = 0;\n    adjacencyMatrix = [];\n    graphContainer.innerHTML = '';\n    nodeCountInput.value = 5;\n    startNodeSelect.innerHTML = '<option value=\"\">-- Select Start Node --</option>';\n    startNodeSelect.disabled = true;\n    resetAlgorithmState();\n  }\n\n  // --- Event listeners ---\n\n  createGraphBtn.addEventListener('click', ()=>{\n    let val = Number(nodeCountInput.value);\n    if(!Number.isInteger(val) || val < 1 || val > 26){\n      alert('Please enter an integer node count between 1 and 26.');\n      return;\n    }\n    nodeCount = val;\n    adjacencyMatrix = createEmptyMatrix(nodeCount);\n    createGraphTable();\n    populateStartNodeSelect();\n    resetAlgorithmState();\n  });\n\n  startNodeSelect.addEventListener('change', ()=>{\n    let val = startNodeSelect.value;\n    if(val === ''){\n      initializeBtn.disabled = true;\n      startNode = null;\n    } else {\n      initializeBtn.disabled = false;\n      startNode = Number(val);\n    }\n  });\n\n  initializeBtn.addEventListener('click', ()=>{\n    if(startNode === null){\n      alert('Please select a start node to initialize.');\n      return;\n    }\n    initializeAlgorithm();\n  });\n\n  nextStepBtn.addEventListener('click', ()=>{\n    stepAlgorithm();\n  });\n\n  autoRunBtn.addEventListener('click', ()=>{\n    startAutoRun();\n  });\n\n  pauseAutoBtn.addEventListener('click', ()=>{\n    stopAutoRun();\n  });\n\n  resetAlgorithmBtn.addEventListener('click', ()=>{\n    resetAlgorithmState();\n  });\n\n  showDistancesBtn.addEventListener('click', ()=>{\n    if(!algorithmInitialized){\n      alert('Algorithm not initialized.');\n      return;\n    }\n    tablesContainer.innerHTML = '';\n    let distancesTable = generateTable(distances, 'Distances');\n    tablesContainer.appendChild(distancesTable);\n  });\n\n  showPredecessorsBtn.addEventListener('click', ()=>{\n    if(!algorithmInitialized){\n      alert('Algorithm not initialized.');\n      return;\n    }\n    tablesContainer.innerHTML = '';\n    let predecessorsTable = generateTable(predecessors, 'Predecessors');\n    tablesContainer.appendChild(predecessorsTable);\n  });\n\n  findPathBtn.addEventListener('click', ()=>{\n    if(!algorithmInitialized){\n      alert('Algorithm not initialized.');\n      return;\n    }\n    let val = destinationInput.value.trim().toUpperCase();\n    if(val.length !== 1 || val < 'A' || val >= String.fromCharCode(65 + nodeCount)){\n      alert('Please enter a valid destination node letter (A-' + indexToNode(nodeCount - 1) + ').');\n      return;\n    }\n    let destIdx = nodeToIndex(val);\n    findPathToTarget(destIdx);\n  });\n\n  clearAllBtn.addEventListener('click', ()=>{\n    if(confirm('Clear all data and start over?')){\n      clearAll();\n    }\n  });\n\n  // On load init\n  clearAll();\n  nodeCountInput.value = '5';\n\n})();\n</script>\n\n</body>\n</html>"
  },
