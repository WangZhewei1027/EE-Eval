    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sliding Window</title>\n    <style>\n        body {\n            margin: 0;\n            padding: 0;\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n        }\n\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            background-color: #fff;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .header {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n\n        .header h1 {\n            font-size: 24px;\n            margin-bottom: 10px;\n        }\n\n        .content {\n            padding: 20px;\n        }\n\n        .content h2 {\n            font-size: 18px;\n            margin-bottom: 10px;\n        }\n\n        .button-container {\n            text-align: center;\n            margin-top: 20px;\n        }\n\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            background-color: #4CAF50;\n            color: #fff;\n            transition: background-color 0.3s ease;\n        }\n\n        .button:hover {\n            background-color: #3e8e41;\n        }\n\n        .button:active {\n            background-color: #3e8e41;\n            transform: translateY(-2px);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Sliding Window</h1>\n        </div>\n        <div class=\"content\">\n            <h2>Sliding Window Example</h2>\n            <p>This is a sliding window example with a simple design.</p>\n            <p>It is designed to be visually appealing and easy to understand.</p>\n            <button class=\"button\">Click Me</button>\n        </div>\n        <div class=\"button-container\">\n            <button class=\"button\">Click Again</button>\n        </div>\n    </div>\n    <script>\n        let windowSize = {\n            width: 800,\n            height: 600\n        };\n\n        let x = 0;\n        let y = 0;\n\n        function updateWindow() {\n            x = Math.min(x + 20, windowSize.width - 20);\n            y = Math.min(y + 20, windowSize.height - 20);\n            document.getElementById(\"window\").style.left = x + \"px\";\n            document.getElementById(\"window\").style.top = y + \"px\";\n        }\n\n        function init() {\n            document.getElementById(\"window\").style.width = windowSize.width + \"px\";\n            document.getElementById(\"window\").style.height = windowSize.height + \"px\";\n            document.getElementById(\"window\").style.left = \"0px\";\n            document.getElementById(\"window\").style.top = \"0px\";\n            document.getElementById(\"window\").style.background = \"white\";\n            updateWindow();\n            window.addEventListener(\"resize\", init);\n        }\n\n        init();\n    </script>\n</body>\n</html>"
