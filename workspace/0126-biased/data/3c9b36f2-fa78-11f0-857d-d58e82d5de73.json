    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Abstract Syntax Tree - Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;600&display=swap');\n\n  :root {\n    --bg-dark: #0e1428;\n    --bg-gradient-start: #152238;\n    --bg-gradient-end: #0c183a;\n    --node-bg: #1e2a4a;\n    --node-bg-hover: #304a89;\n    --node-accent: #7ed6df;\n    --line-color: #7ed6df80;\n    --line-glow: #7ed6dfcc;\n    --text-primary: #d0e7f9;\n    --text-secondary: #a0b9db;\n    --btn-bg: #29537a;\n    --btn-bg-hover: #3a699c;\n    --btn-text: #d0e7f9;\n    --shadow: rgba(21,34,56,0.8);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0; min-height: 100vh;\n    background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));\n    font-family: 'Inter', sans-serif;\n    color: var(--text-primary);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1rem 3rem;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  header {\n    text-align: center;\n    margin-bottom: 2rem;\n    max-width: 700px;\n  }\n\n  header h1 {\n    font-family: 'Space Mono', monospace;\n    font-weight: 700;\n    font-size: 3rem;\n    line-height: 1.1;\n    letter-spacing: 0.05em;\n    color: var(--node-accent);\n    text-shadow: 0 0 10px var(--node-accent);\n    margin-bottom: 0.25rem;\n  }\n\n  header p {\n    font-size: 1.125rem;\n    font-weight: 400;\n    color: var(--text-secondary);\n    text-shadow: 0 0 3px var(--shadow);\n  }\n\n  main {\n    flex: 1;\n    max-width: 960px;\n    width: 100%;\n    overflow-x: auto;\n    padding-bottom: 1rem;\n  }\n\n  /* AST Container */\n  .ast-container {\n    display: flex;\n    justify-content: center;\n    padding: 1rem 0;\n  }\n\n  /* Tree styling */\n  .tree {\n    position: relative;\n    padding: 2rem 0 4rem 0;\n    font-family: 'Space Mono', monospace;\n    user-select: none;\n  }\n\n  .node {\n    position: relative;\n    background: var(--node-bg);\n    border-radius: 12px;\n    padding: 1rem 1.75rem;\n    color: var(--text-primary);\n    font-weight: 600;\n    font-size: 1rem;\n    white-space: nowrap;\n    box-shadow:\n      0 0 10px var(--node-accent),\n      inset 0 -4px 6px #173254;\n    cursor: default;\n    transition:\n      background 0.4s,\n      box-shadow 0.4s,\n      transform 0.3s;\n  }\n\n  .node:hover {\n    background: var(--node-bg-hover);\n    box-shadow:\n      0 0 25px var(--node-accent),\n      inset 0 -6px 8px #406dbd;\n    transform: scale(1.05);\n    z-index: 10;\n  }\n\n  /* Link lines using SVG */\n\n  svg.ast-links {\n    position: absolute;\n    top: 0; left: 50%; transform: translateX(-50%);\n    pointer-events: none;\n    overflow: visible;\n    filter: drop-shadow(0 0 3px var(--node-accent));\n  }\n\n  /* Layout for nodes - positioned manually with flex */\n\n  /* Vertical layers */\n  .level {\n    display: flex;\n    justify-content: center;\n    gap: 2.75rem;\n    margin-bottom: 3rem;\n  }\n\n  /* Child container for deeper layers */\n  .children {\n    display: flex;\n    justify-content: center;\n    gap: 2.75rem;\n  }\n\n  /* Node labels with subtle geometric shapes */\n  .node::before {\n    content: '';\n    position: absolute;\n    top: 50%; left: 12px;\n    width: 0.5rem; height: 0.5rem;\n    background: var(--node-accent);\n    border-radius: 0.25rem;\n    transform: translateY(-50%) rotate(45deg);\n    opacity: 0.4;\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 3rem;\n    font-size: 0.875rem;\n    color: var(--text-secondary);\n    font-family: 'Inter', sans-serif;\n    user-select: none;\n  }\n\n  /* Buttons container */\n  .buttons {\n    margin-top: 1rem;\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n\n  button {\n    background: var(--btn-bg);\n    border: none;\n    border-radius: 8px;\n    padding: 0.5rem 1.2rem;\n    font-family: 'Inter', sans-serif;\n    font-weight: 600;\n    color: var(--btn-text);\n    font-size: 1rem;\n    cursor: pointer;\n    box-shadow: 0 0 8px var(--btn-bg);\n    transition: background 0.35s, box-shadow 0.35s, transform 0.2s;\n    user-select: none;\n  }\n\n  button:hover {\n    background: var(--btn-bg-hover);\n    box-shadow: 0 0 16px var(--btn-bg-hover);\n    transform: translateY(-2px);\n  }\n\n  /* Smooth fade transitions for toggled states */\n  .fade {\n    transition: opacity 0.6s ease, transform 0.6s ease;\n  }\n\n  .fade.hidden {\n    opacity: 0;\n    transform: translateY(20px);\n    pointer-events: none;\n    height: 0;\n  }\n\n  /* Scrollbar styling */\n  ::-webkit-scrollbar {\n    height: 10px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--bg-gradient-end);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--node-accent);\n    border-radius: 8px;\n    box-shadow: inset 0 0 5px rgba(0,0,0,0.3);\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Abstract Syntax Tree</h1>\n  <p>Visualizing the core structure of source code with elegance.</p>\n  <div class=\"buttons\" aria-label=\"Toggle controls\">\n    <button id=\"toggleExpressions\" title=\"Toggle Expression Type\">Toggle Expr Type</button>\n    <button id=\"darken\" title=\"Toggle Darker Theme\">Toggle Darkness</button>\n  </div>\n</header>\n<main>\n  <div class=\"ast-container\" aria-label=\"Abstract Syntax Tree visualization\">\n    <svg id=\"links\" class=\"ast-links\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" focusable=\"false\"></svg>\n\n    <div id=\"tree\" class=\"tree\" role=\"tree\" aria-label=\"Abstract Syntax Tree\">\n      <!-- Level 0 -->\n      <div class=\"level\" role=\"group\">\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n0\">Program</div>\n      </div>\n      <!-- Level 1 -->\n      <div class=\"level\" role=\"group\">\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n1\">FunctionDeclaration</div>\n      </div>\n      <!-- Level 2 -->\n      <div class=\"level\" role=\"group\" style=\"gap: 3.8rem;\">\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n2\">Identifier <span class=\"expr-type\">myFunc</span></div>\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n3\">Parameters</div>\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n4\">BlockStatement</div>\n      </div>\n      <!-- Level 3 -->\n      <div class=\"level children\" style=\"gap: 3rem; max-width: 650px; margin: 0 auto;\">\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n5\">Identifier <span class=\"expr-type\">x</span></div>\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n6\">Identifier <span class=\"expr-type\">y</span></div>\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n7\" style=\"max-width: 300px;\">ReturnStatement</div>\n      </div>\n      <!-- Level 4 -->\n      <div class=\"level children\" style=\"gap: 2rem; max-width: 400px; margin: 0 auto;\">\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n8\">BinaryExpression</div>\n      </div>\n      <!-- Level 5 -->\n      <div class=\"level children\" style=\"gap: 2rem; max-width: 350px; margin: 0 auto;\">\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n9\">Identifier <span class=\"expr-type\">x</span></div>\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n10\">Operator <span class=\"expr-type\">+</span></div>\n        <div class=\"node\" role=\"treeitem\" tabindex=\"0\" data-id=\"n11\">Identifier <span class=\"expr-type\">y</span></div>\n      </div>\n    </div>\n  </div>\n</main>\n<footer>\n  &copy; 2024 &middot; Abstract Syntax Tree Visualization &middot; Designed with care &amp; code\n</footer>\n\n<script>\n  (() => {\n    const svg = document.getElementById('links');\n    const tree = document.getElementById('tree');\n\n    // Collect all nodes with data-id attribute\n    const nodes = [...tree.querySelectorAll('.node[data-id]')];\n\n    // Map data-id to DOM node\n    const nodeMap = new Map(nodes.map(n => [n.dataset.id, n]));\n\n    /*\n      Manually define edges to form AST lines:\n      Connect parent to children:\n\n      n0 => n1\n      n1 => n2, n3, n4\n      n3 => n5, n6, n7\n      n7 => n8\n      n8 => n9, n10, n11\n    */\n    const edges = [\n      ['n0', 'n1'],\n      ['n1', 'n2'], ['n1', 'n3'], ['n1', 'n4'],\n      ['n3', 'n5'], ['n3', 'n6'], ['n3', 'n7'],\n      ['n7', 'n8'],\n      ['n8', 'n9'], ['n8', 'n10'], ['n8', 'n11']\n    ];\n\n    // Create smooth cubic Bezier linking paths between nodes\n    function createPath(fromRect, toRect) {\n      const startX = fromRect.left + fromRect.width/2;\n      const startY = fromRect.bottom;\n      const endX = toRect.left + toRect.width/2;\n      const endY = toRect.top;\n\n      // Control points for a smooth vertical curve\n      const cp1X = startX;\n      const cp1Y = startY + 40;\n      const cp2X = endX;\n      const cp2Y = endY - 40;\n\n      return `M${startX},${startY} C${cp1X},${cp1Y} ${cp2X},${cp2Y} ${endX},${endY}`;\n    }\n\n    // Paint links\n    function drawLinks() {\n      // Clear SVG\n      while (svg.firstChild) svg.removeChild(svg.firstChild);\n      // Update width & height to cover all nodes horizontally & vertically\n      const allRects = nodes.map(n => n.getBoundingClientRect());\n      const leftMost = Math.min(...allRects.map(r => r.left));\n      const rightMost = Math.max(...allRects.map(r => r.right));\n      const topMost = Math.min(...allRects.map(r => r.top));\n      const bottomMost = Math.max(...allRects.map(r => r.bottom));\n\n      const padding = 40;\n      const width = rightMost - leftMost + padding * 2;\n      const height = bottomMost - topMost + padding * 2;\n\n      svg.style.width = width + 'px';\n      svg.style.height = height + 'px';\n      svg.style.top = (topMost - padding + window.scrollY) + 'px';\n      svg.style.left = (leftMost - padding + window.scrollX) + 'px';\n\n      svg.setAttribute('viewBox', `0 0 ${width} ${height}`);\n\n      edges.forEach(([parentId, childId]) => {\n        const parent = nodeMap.get(parentId);\n        const child = nodeMap.get(childId);\n        if (!parent || !child) return;\n        const fromRect = parent.getBoundingClientRect();\n        const toRect = child.getBoundingClientRect();\n\n        // Translate client coords to svg coords to draw properly inside svg viewport\n        const svgX = leftMost - padding;\n        const svgY = topMost - padding;\n\n        const startX = fromRect.left + fromRect.width/2 - svgX;\n        const startY = fromRect.bottom - svgY;\n        const endX = toRect.left + toRect.width/2 - svgX;\n        const endY = toRect.top - svgY;\n\n        const cp1X = startX;\n        const cp1Y = startY + 40;\n        const cp2X = endX;\n        const cp2Y = endY - 40;\n\n        const d = `M${startX},${startY} C${cp1X},${cp1Y} ${cp2X},${cp2Y} ${endX},${endY}`;\n\n        const path = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n        path.setAttribute(\"d\", d);\n        path.setAttribute(\"stroke\", \"url(#lineGradient)\");\n        path.setAttribute(\"stroke-width\", \"2.5\");\n        path.setAttribute(\"fill\", \"none\");\n        path.setAttribute(\"stroke-linecap\", \"round\");\n        path.style.filter = \"drop-shadow(0 0 4px #7ed6dfcc)\";\n        svg.appendChild(path);\n      });\n\n      // Gradient for lines\n      if (!svg.querySelector('defs')) {\n        const defs = document.createElementNS(\"http://www.w3.org/2000/svg\", \"defs\");\n        const linearGradient = document.createElementNS(\"http://www.w3.org/2000/svg\", \"linearGradient\");\n        linearGradient.setAttribute(\"id\", \"lineGradient\");\n        linearGradient.setAttribute(\"x1\", \"0%\");\n        linearGradient.setAttribute(\"y1\", \"0%\");\n        linearGradient.setAttribute(\"x2\", \"100%\");\n        linearGradient.setAttribute(\"y2\", \"100%\");\n\n        const stop1 = document.createElementNS(\"http://www.w3.org/2000/svg\", \"stop\");\n        stop1.setAttribute(\"offset\", \"0%\");\n        stop1.setAttribute(\"stop-color\", \"#7ed6dfcc\");\n        stop1.setAttribute(\"stop-opacity\", \"0.8\");\n\n        const stop2 = document.createElementNS(\"http://www.w3.org/2000/svg\", \"stop\");\n        stop2.setAttribute(\"offset\", \"100%\");\n        stop2.setAttribute(\"stop-color\", \"#4999aaee\");\n        stop2.setAttribute(\"stop-opacity\", \"1\");\n\n        linearGradient.appendChild(stop1);\n        linearGradient.appendChild(stop2);\n        defs.appendChild(linearGradient);\n        svg.appendChild(defs);\n      }\n    }\n\n    // Initial draw\n    function refresh() {\n      drawLinks();\n    }\n\n    window.addEventListener('resize', refresh);\n    window.addEventListener('scroll', refresh);\n    window.addEventListener('load', () => {\n      refresh();\n    });\n\n    // LIMITED INTERACTIVITY: Toggle expression text color (simulate expression types)\n    const exprSpans = document.querySelectorAll('.expr-type');\n\n    const colorsA = ['#7ed6df', '#ff6b6b', '#fbc531', '#f5a623'];\n    const colorsB = ['#a3d2ca', '#ff9a9e', '#ffb347', '#ffd97d'];\n\n    let toggled = false;\n\n    document.getElementById('toggleExpressions').addEventListener('click', () => {\n      toggled = !toggled;\n      exprSpans.forEach((span, i) => {\n        span.style.transition = 'color 0.8s ease';\n        span.style.color = toggled ? colorsB[i % colorsB.length] : colorsA[i % colorsA.length];\n      });\n    });\n\n    // LIMITED INTERACTIVITY: Toggle darker/lighter background theme modifier\n    const body = document.body;\n    let darkened = false;\n\n    document.getElementById('darken').addEventListener('click', () => {\n      darkened = !darkened;\n      if (darkened) {\n        body.style.background = 'linear-gradient(135deg, #0a0f19, #050a1c)';\n      } else {\n        body.style.background = 'linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end))';\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
  },
