    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Programming Visualized</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s 0.3s forwards;\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: -0.05em;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            background-color: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.15);\n            padding: 3rem;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: scale(0.95);\n            animation: scaleIn 0.8s 0.6s forwards;\n        }\n\n        @keyframes scaleIn {\n            to {\n                opacity: 1;\n                transform: scale(1);\n            }\n        }\n\n        .vis-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 2rem;\n        }\n\n        h2 {\n            font-size: 1.8rem;\n            color: var(--dark);\n            font-weight: 600;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n        }\n\n        button {\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .grid-container {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n        }\n\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(10, 1fr);\n            gap: 10px;\n        }\n\n        .cell {\n            width: 50px;\n            height: 50px;\n            background-color: white;\n            border-radius: 8px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: 600;\n            font-size: 1.2rem;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .cell::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, rgba(108, 92, 231, 0.1), rgba(253, 121, 168, 0.1));\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        .cell.active {\n            background-color: var(--primary);\n            color: white;\n            transform: scale(1.1);\n        }\n\n        .cell.active::before {\n            opacity: 1;\n        }\n\n        .cell.path {\n            background-color: var(--success);\n            color: white;\n        }\n\n        .cell.start {\n            background-color: var(--accent);\n            color: white;\n        }\n\n        .cell.end {\n            background-color: var(--accent);\n            color: white;\n        }\n\n        .matrix-legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 0.5s 1.4s forwards;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .code-section {\n            background-color: #282c34;\n            border-radius: 10px;\n            padding: 2rem;\n            color: #abb2bf;\n            font-family: 'Fira Code', monospace;\n            margin-top: 3rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .code-section::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 4px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--primary), var(--accent));\n        }\n\n        .code-header {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 1.5rem;\n        }\n\n        .code-title {\n            color: white;\n            font-weight: 600;\n            font-size: 1.2rem;\n        }\n\n        .code-tabs {\n            display: flex;\n            gap: 1rem;\n        }\n\n        .code-tab {\n            padding: 0.3rem 0.8rem;\n            background-color: rgba(255, 255, 255, 0.1);\n            border-radius: 4px;\n            font-size: 0.8rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n\n        .code-tab.active {\n            background-color: var(--primary);\n            color: white;\n        }\n\n        pre {\n            margin: 0;\n            line-height: 1.5;\n            font-size: 0.9rem;\n            overflow-x: auto;\n        }\n\n        .explanation {\n            margin-top: 3rem;\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n            opacity: 0;\n            animation: fadeIn 0.8s 1.6s forwards;\n        }\n\n        h3 {\n            font-size: 1.5rem;\n            margin-bottom: 1.5rem;\n            color: var(--dark);\n            font-weight: 600;\n        }\n\n        p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n            color: var(--dark);\n            opacity: 0.9;\n        }\n\n        .highlight {\n            background: linear-gradient(45deg, rgba(108, 92, 231, 0.2), rgba(253, 121, 168, 0.2));\n            padding: 0.2rem 0.4rem;\n            border-radius: 4px;\n            font-weight: 500;\n        }\n\n        .footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem 0;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .particle {\n            position: absolute;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            border-radius: 50%;\n            opacity: 0.3;\n        }\n\n        @media (max-width: 768px) {\n            .container {\n                padding: 1.5rem;\n            }\n\n            h1 {\n                font-size: 2.2rem;\n            }\n\n            .visualization {\n                padding: 1.5rem;\n            }\n\n            .grid {\n                gap: 6px;\n            }\n\n            .cell {\n                width: 35px;\n                height: 35px;\n                font-size: 1rem;\n            }\n\n            .code-section {\n                padding: 1.5rem;\n            }\n        }\n    </style>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Dynamic Programming</h1>\n            <p class=\"subtitle\">A visual exploration of breaking down complex problems into simpler subproblems and storing their solutions to avoid redundant computations.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"vis-header\">\n                <h2>Minimum Path Sum</h2>\n                <div class=\"controls\">\n                    <button id=\"visualize-btn\">Visualize</button>\n                    <button id=\"reset-btn\">Reset</button>\n                </div>\n            </div>\n            \n            <div class=\"grid-container\">\n                <div class=\"grid\" id=\"path-grid\"></div>\n            </div>\n\n            <div class=\"matrix-legend\">\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--accent);\"></div>\n                    <span>Start/End</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--primary);\"></div>\n                    <span>Active Cell</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--success);\"></div>\n                    <span>Optimal Path</span>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"code-section\">\n            <div class=\"code-header\">\n                <div class=\"code-title\">Dynamic Programming Solution</div>\n                <div class=\"code-tabs\">\n                    <div class=\"code-tab active\">Python</div>\n                    <div class=\"code-tab\">JavaScript</div>\n                </div>\n            </div>\n            <pre>\n<span style=\"color: #c678dd;\">def</span> <span style=\"color: #61afef;\">minPathSum</span>(<span style=\"color: #e06c75;\">grid</span>):\n    <span style=\"color: #56b6c2;\">m</span>, <span style=\"color: #56b6c2;\">n</span> = <span style=\"color: #56b6c2;\">len</span>(grid), <span style=\"color: #56b6c2;\">len</span>(grid[<span style=\"color: #d19a66;\">0</span>])\n    \n    <span style=\"color: #c678dd;\">for</span> <span style=\"color: #e06c75;\">i</span> <span style=\"color: #c678dd;\">in</span> <span style=\"color: #56b6c2;\">range</span>(<span style=\"color: #d19a66;\">1</span>, m):\n        grid[i][<span style=\"color: #d19a66;\">0</span>] += grid[i-<span style=\"color: #d19a66;\">1</span>][<span style=\"color: #d19a66;\">0</span>]\n        \n    <span style=\"color: #c678dd;\">for</span> <span style=\"color: #e06c75;\">j</span> <span style=\"color: #c678dd;\">in</span> <span style=\"color: #56b6c2;\">range</span>(<span style=\"color: #d19a66;\">1</span>, n):\n        grid[<span style=\"color: #d19a66;\">0</span>][j] += grid[<span style=\"color: #d19a66;\">0</span>][j-<span style=\"color: #d19a66;\">1</span>]\n        \n    <span style=\"color: #c678dd;\">for</span> <span style=\"color: #e06c75;\">i</span> <span style=\"color: #c678dd;\">in</span> <span style=\"color: #56b6c2;\">range</span>(<span style=\"color: #d19a66;\">1</span>, m):\n        <span style=\"color: #c678dd;\">for</span> <span style=\"color: #e06c75;\">j</span> <span style=\"color: #c678dd;\">in</span> <span style=\"color: #56b6c2;\">range</span>(<span style=\"color: #d19a66;\">1</span>, n):\n            grid[i][j] += <span style=\"color: #56b6c2;\">min</span>(grid[i-<span style=\"color: #d19a66;\">1</span>][j], grid[i][j-<span style=\"color: #d19a66;\">1</span>])\n            \n    <span style=\"color: #c678dd;\">return</span> grid[m-<span style=\"color: #d19a66;\">1</span>][n-<span style=\"color: #d19a66;\">1</span>]</pre>\n        </div>\n\n        <div class=\"explanation\">\n            <h3>Understanding Dynamic Programming</h3>\n            <p>Dynamic Programming (DP) is an algorithmic paradigm that solves complex problems by breaking them down into simpler subproblems and storing their solutions to avoid redundant computations. This technique is particularly useful for optimization problems where we seek the best solution among many possible solutions.</p>\n            \n            <p>The <span class=\"highlight\">Minimum Path Sum</span> problem demonstrated above is a classic DP problem. Given a grid filled with non-negative numbers, we need to find a path from the top-left to the bottom-right which minimizes the sum of all numbers along its path. We can only move either down or right at any point in time.</p>\n            \n            <p>The key insight is that the minimum path to any cell can be computed from the minimum paths to the cell above it and to the cell to its left. By storing these intermediate results (memoization), we avoid recalculating them repeatedly, leading to an efficient O(mn) solution.</p>\n        </div>\n\n        <div class=\"footer\">\n            <p>© 2023 Dynamic Programming Visualization | Designed for educational purposes</p>\n        </div>\n    </div>\n\n    <div class=\"particles\" id=\"particles\"></div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles for background\n            const particlesContainer = document.getElementById('particles');\n            for (let i = 0; i < 20; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 20 + 10;\n                const posX = Math.random() * 100;\n                const posY = Math.random() * 100;\n                const opacity = Math.random() * 0.4 + 0.1;\n                const delay = Math.random() * 5;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.top = `${posY}%`;\n                particle.style.opacity = opacity;\n                particle.style.animation = `float ${Math.random() * 10 + 10}s ${delay}s infinite alternate ease-in-out`;\n                \n                particlesContainer.appendChild(particle);\n            }\n\n            // Create grid\n            const grid = document.getElementById('path-grid');\n            const rows = 5;\n            const cols = 5;\n            let gridData = [];\n            \n            // Initialize grid data\n            for (let i = 0; i < rows; i++) {\n                gridData[i] = [];\n                for (let j = 0; j < cols; j++) {\n                    gridData[i][j] = Math.floor(Math.random() * 9) + 1;\n                }\n            }\n            \n            // Render grid\n            function renderGrid() {\n                grid.innerHTML = '';\n                for (let i = 0; i < rows; i++) {\n                    for (let j = 0; j < cols; j++) {\n                        const cell = document.createElement('div');\n                        cell.classList.add('cell');\n                        cell.textContent = gridData[i][j];\n                        cell.dataset.row = i;\n                        cell.dataset.col = j;\n                        \n                        if (i === 0 && j === 0) {\n                            cell.classList.add('start');\n                        }\n                        \n                        if (i === rows - 1 && j === cols - 1) {\n                            cell.classList.add('end');\n                        }\n                        \n                        grid.appendChild(cell);\n                    }\n                }\n            }\n            \n            renderGrid();\n            \n            // Visualize DP solution\n            document.getElementById('visualize-btn').addEventListener('click', async function() {\n                const cells = document.querySelectorAll('.cell');\n                \n                // Reset all cells\n                cells.forEach(cell => {\n                    cell.classList.remove('active', 'path');\n                });\n                \n                // Start cell\n                document.querySelector('.start').classList.add('path');\n                \n                // First row\n                for (let j = 1; j < cols; j++) {\n                    const cell = document.querySelector(`[data-row=\"0\"][data-col=\"${j}\"]`);\n                    await new Promise(resolve => {\n                        setTimeout(() => {\n                            cell.classList.add('active');\n                            setTimeout(() => {\n                                cell.classList.add('path');\n                                cell.classList.remove('active');\n                                resolve();\n                            }, 500);\n                        }, 300 * j);\n                    });\n                }\n                \n                // First column\n                for (let i = 1; i < rows; i++) {\n                    const cell = document.querySelector(`[data-row=\"${i}\"][data-col=\"0\"]`);\n                    await new Promise(resolve => {\n                        setTimeout(() => {\n                            cell.classList.add('active');\n                            setTimeout(() => {\n                                cell.classList.add('path');\n                                cell.classList.remove('active');\n                                resolve();\n                            }, 500);\n                        }, 300 * i);\n                    });\n                }\n                \n                // Fill rest of the grid\n                for (let i = 1; i < rows; i++) {\n                    for (let j = 1; j < cols; j++) {\n                        const cell = document.querySelector(`[data-row=\"${i}\"][data-col=\"${j}\"]`);\n                        await new Promise(resolve => {\n                            setTimeout(() => {\n                                cell.classList.add('active');\n                                setTimeout(() => {\n                                    cell.classList.add('path');\n                                    cell.classList.remove('active');\n                                    resolve();\n                                }, 500);\n                            }, 300 * (i + j));\n                        });\n                    }\n                }\n                \n                // Highlight optimal path\n                let i = rows - 1;\n                let j = cols - 1;\n                const path = [[i, j]];\n                \n                while (i > 0 || j > 0) {\n                    if (i === 0) {\n                        j--;\n                    } else if (j === 0) {\n                        i--;\n                    } else {\n                        const up = document.querySelector(`[data-row=\"${i-1}\"][data-col=\"${j}\"]`).textContent;\n                        const left = document.querySelector(`[data-row=\"${i}\"][data-col=\"${j-1}\"]`).textContent;\n                        \n                        if (parseInt(up) < parseInt(left)) {\n                            i--;\n                        } else {\n                            j--;\n                        }\n                    }\n                    path.push([i, j]);\n                }\n                \n                // Animate optimal path\n                for (let idx = path.length - 2; idx >= 0; idx--) {\n                    const [row, col] = path[idx];\n                    const cell = document.querySelector(`[data-row=\"${row}\"][data-col=\"${col}\"]`);\n                    await new Promise(resolve => {\n                        setTimeout(() => {\n                            cell.style.transform = 'scale(1.2)';\n                            cell.style.boxShadow = '0 0 20px rgba(0, 184, 148, 0.7)';\n                            setTimeout(() => {\n                                cell.style.transform = 'scale(1.1)';\n                                cell.style.boxShadow = 'none';\n                                resolve();\n                            }, 300);\n                        }, 150 * idx);\n                    });\n                }\n            });\n            \n            // Reset grid\n            document.getElementById('reset-btn').addEventListener('click', function() {\n                renderGrid();\n            });\n        });\n\n        // Add floating animation for particles\n        const style = document.createElement('style');\n        style.textContent = `\n            @keyframes float {\n                0% {\n                    transform: translate(0, 0) rotate(0deg);\n                }\n                50% {\n                    transform: translate(20px, 20px) rotate(180deg);\n                }\n                100% {\n                    transform: translate(0, 0) rotate(360deg);\n                }\n            }\n        `;\n        document.head.appendChild(style);\n    </script>\n</body>\n</html>"
