    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Stack Interaction Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #stackContainer { margin-top: 20px; }\n        #stackDisplay { margin-bottom: 20px; }\n    </style>\n</head>\n<body>\n\n<h2>Interactive Stack Demo</h2>\n\n<label for=\"inputValue\">Enter a value to push to the stack:</label>\n<input type=\"text\" id=\"inputValue\" />\n<button id=\"pushButton\">Push</button>\n<button id=\"popButton\">Pop</button>\n<button id=\"peekButton\">Peek</button>\n<button id=\"isEmptyButton\">Is Empty?</button>\n<button id=\"clearButton\">Clear Stack</button>\n\n<div id=\"stackContainer\">\n    <h3>Stack Display:</h3>\n    <div id=\"stackDisplay\"></div>\n</div>\n\n<script>\n    const stack = [];\n    const stackDisplay = document.getElementById(\"stackDisplay\");\n    const inputValue = document.getElementById(\"inputValue\");\n\n    function renderStack() {\n        stackDisplay.innerText = stack.length === 0 ? \"Stack is empty\" : stack.join(\", \");\n    }\n\n    document.getElementById(\"pushButton\").onclick = function() {\n        const value = inputValue.value;\n        if(value) {\n            stack.push(value);\n            inputValue.value = \"\";\n            renderStack();\n        } else {\n            alert(\"Please enter a value to push.\");\n        }\n    };\n\n    document.getElementById(\"popButton\").onclick = function() {\n        if (stack.length === 0) {\n            alert(\"Stack is already empty.\");\n        } else {\n            stack.pop();\n            renderStack();\n        }\n    };\n\n    document.getElementById(\"peekButton\").onclick = function() {\n        if (stack.length === 0) {\n            alert(\"Stack is empty. No top element.\");\n        } else {\n            alert(\"Top element: \" + stack[stack.length - 1]);\n        }\n    };\n\n    document.getElementById(\"isEmptyButton\").onclick = function() {\n        alert(stack.length === 0 ? \"Stack is empty.\" : \"Stack is not empty.\");\n    };\n\n    document.getElementById(\"clearButton\").onclick = function() {\n        stack.length = 0;\n        renderStack();\n    };\n</script>\n\n</body>\n</html>"
