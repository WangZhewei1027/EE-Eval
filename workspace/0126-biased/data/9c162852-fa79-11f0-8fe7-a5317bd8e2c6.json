  "question": "Agile Methodology",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Agile Methodology Interactive Simulator</title>\n<style>\n/* Minimal styling only to arrange elements; no colors, no fancy fonts, no animations */\nhtml,body{height:100%;margin:0;padding:0;font-family:system-ui,Segoe UI,Arial,sans-serif;color:black;background:white;}\n.container{display:flex;flex-direction:row;height:100vh;}\n.panel{padding:8px;box-sizing:border-box;overflow:auto;border-right:1px solid #ddd;}\n.left{width:320px;}\n.center{flex:1;min-width:420px;}\n.right{width:420px;}\n.section{margin-bottom:12px;}\n.label{display:block;margin-top:6px;margin-bottom:2px;}\n.controls input[type=\"text\"], .controls input[type=\"number\"], .controls select, .controls textarea {width:100%;box-sizing:border-box;padding:4px;}\n.controls button, button {padding:6px;margin:3px 0;}\n.board{display:flex;gap:8px;align-items:flex-start;}\n.column{min-width:160px;width:160px;border:1px solid #ccc;padding:6px;box-sizing:border-box;}\n.task{border:1px dashed #999;padding:6px;margin:6px 0;background:transparent;cursor:move;}\n.small{font-size:12px;}\n.log{height:150px;overflow:auto;border:1px solid #ccc;padding:6px;box-sizing:border-box;font-size:12px;}\n.table{width:100%;border-collapse:collapse;font-size:13px;}\n.table td, .table th{border:1px solid #ddd;padding:4px;}\n.canvasBox{border:1px solid #ccc;padding:6px;}\n.flex-row{display:flex;gap:6px;}\n.hidden{display:none;}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <div class=\"panel left\">\n    <h3>Backlog & Item Creation</h3>\n    <div class=\"section controls\">\n      <label class=\"label\">Title</label>\n      <input id=\"newTitle\" type=\"text\" placeholder=\"Short user story title\">\n      <label class=\"label\">Description</label>\n      <textarea id=\"newDesc\" rows=\"3\" placeholder=\"Acceptance criteria and notes\"></textarea>\n      <label class=\"label\">Estimate (story points)</label>\n      <input id=\"newPoints\" type=\"number\" value=\"3\" min=\"1\" max=\"100\">\n      <label class=\"label\">Priority</label>\n      <select id=\"newPriority\">\n        <option value=\"1\">1 - Highest</option>\n        <option value=\"2\">2</option>\n        <option value=\"3\" selected>3</option>\n        <option value=\"4\">4</option>\n        <option value=\"5\">5 - Lowest</option>\n      </select>\n      <label class=\"label\">Requires Code Review?</label>\n      <input id=\"newReview\" type=\"checkbox\">\n      <label class=\"label\">Requires QA?</label>\n      <input id=\"newQA\" type=\"checkbox\">\n      <div class=\"flex-row\">\n        <button id=\"addItem\">Add Item</button>\n        <button id=\"autoGen\">Auto-generate</button>\n      </div>\n      <div class=\"flex-row\">\n        <button id=\"sortPriority\">Sort Backlog by Priority</button>\n        <button id=\"shufflePriority\">Randomize Priority</button>\n      </div>\n    </div>\n\n    <h3>Team Management</h3>\n    <div class=\"section controls\">\n      <label class=\"label\">Member name</label>\n      <input id=\"memberName\" type=\"text\" placeholder=\"e.g. Alice\">\n      <label class=\"label\">Daily capacity (points/day)</label>\n      <input id=\"memberCap\" type=\"number\" value=\"3\" min=\"1\" max=\"20\">\n      <label class=\"label\">Skills (comma separated)</label>\n      <input id=\"memberSkills\" type=\"text\" placeholder=\"dev,qa,review\">\n      <div class=\"flex-row\">\n        <button id=\"addMember\">Add Member</button>\n        <button id=\"autoMembers\">Add Sample Team</button>\n      </div>\n      <div class=\"label\">Team</div>\n      <div id=\"teamList\" class=\"log\" style=\"height:120px;\"></div>\n    </div>\n\n    <h3>Workflow Columns</h3>\n    <div class=\"section controls\">\n      <label class=\"label\">Define columns (comma separated). Use order to set adjacency.</label>\n      <input id=\"columnsInput\" type=\"text\" value=\"Backlog,To Do,In Progress,Code Review,QA,Done\">\n      <div class=\"flex-row\">\n        <button id=\"applyColumns\">Apply</button>\n        <button id=\"resetColumns\">Reset</button>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"panel center\">\n    <h3>Kanban Board</h3>\n    <div id=\"board\" class=\"board\"></div>\n\n    <h3>Selected Item</h3>\n    <div id=\"selected\" class=\"section\">\n      <div id=\"noSelection\">No item selected. Click a task to view and edit details.</div>\n      <div id=\"selectedBox\" class=\"hidden\">\n        <label class=\"label\">ID</label><div id=\"selId\"></div>\n        <label class=\"label\">Title</label><input id=\"selTitle\" type=\"text\">\n        <label class=\"label\">Description</label><textarea id=\"selDesc\" rows=\"3\"></textarea>\n        <label class=\"label\">Estimate</label><input id=\"selPoints\" type=\"number\" min=\"1\">\n        <label class=\"label\">Priority</label><select id=\"selPriority\">\n          <option value=\"1\">1</option><option value=\"2\">2</option><option value=\"3\">3</option><option value=\"4\">4</option><option value=\"5\">5</option>\n        </select>\n        <label class=\"label\">Assigned</label>\n        <select id=\"selAssigned\"></select>\n        <label class=\"label\">Status</label>\n        <select id=\"selStatus\"></select>\n        <label class=\"label\">Blocked</label><input id=\"selBlocked\" type=\"checkbox\">\n        <label class=\"label\">Dependencies (comma separated IDs)</label>\n        <input id=\"selDeps\" type=\"text\">\n        <div class=\"flex-row\">\n          <button id=\"saveSel\">Save</button>\n          <button id=\"moveLeft\">Move Left</button>\n          <button id=\"moveRight\">Move Right</button>\n          <button id=\"cloneSel\">Clone</button>\n          <button id=\"deleteSel\">Delete</button>\n        </div>\n      </div>\n    </div>\n\n    <h3>Actions</h3>\n    <div class=\"section\">\n      <div class=\"flex-row\">\n        <button id=\"autoAssign\">Auto-assign unassigned</button>\n        <button id=\"splitTask\">Split selected task</button>\n        <button id=\"mergeSelected\">Merge selected (select two by ctrl/cmd)</button>\n        <button id=\"markDone\">Force Done</button>\n      </div>\n      <div class=\"label small\">Select tasks: click to select, ctrl/cmd+click to multi-select, drag to move.</div>\n    </div>\n\n    <h3>History / Undo</h3>\n    <div class=\"section\">\n      <div class=\"flex-row\">\n        <button id=\"undo\">Undo</button>\n        <button id=\"redo\">Redo</button>\n      </div>\n      <div class=\"log\" id=\"historyLog\"></div>\n    </div>\n  </div>\n\n  <div class=\"panel right\">\n    <h3>Sprint & Simulation Controls</h3>\n    <div class=\"section controls\">\n      <label class=\"label\">Sprint length (days)</label>\n      <input id=\"sprintDays\" type=\"number\" value=\"10\" min=\"1\" max=\"30\">\n      <label class=\"label\">Team target velocity (points)</label>\n      <input id=\"teamVelocity\" type=\"number\" value=\"20\" min=\"1\" max=\"200\">\n      <label class=\"label\">Simulation speed (ms per day when running)</label>\n      <input id=\"simSpeed\" type=\"number\" value=\"700\" min=\"50\" max=\"5000\">\n      <label class=\"label\">Random event chance per day (%)</label>\n      <input id=\"randomEvent\" type=\"number\" value=\"15\" min=\"0\" max=\"100\">\n      <div class=\"flex-row\">\n        <button id=\"startSprint\">Start Sprint</button>\n        <button id=\"pauseSprint\">Pause</button>\n        <button id=\"stepDay\">Step 1 Day</button>\n        <button id=\"endSprint\">End Sprint</button>\n      </div>\n      <div class=\"label\">Sprint status: <span id=\"sprintStatus\">Idle</span></div>\n      <div class=\"label\">Day: <span id=\"sprintDay\">0</span> / <span id=\"sprintLen\">0</span></div>\n      <div class=\"label\">Remaining points: <span id=\"remainingPoints\">0</span></div>\n    </div>\n\n    <h3>Burn-down</h3>\n    <div class=\"section canvasBox\">\n      <canvas id=\"burndown\" width=\"380\" height=\"150\"></canvas>\n      <div class=\"label\">Burn-down values (day, remaining)</div>\n      <table class=\"table\" id=\"burnTable\"><thead><tr><th>Day</th><th>Remaining</th></tr></thead><tbody></tbody></table>\n    </div>\n\n    <h3>Events & Logs</h3>\n    <div class=\"section\">\n      <div class=\"flex-row\">\n        <button id=\"addBlocker\">Add Random Blocker Now</button>\n        <button id=\"fixBlockers\">Fix All Blockers</button>\n      </div>\n      <div class=\"log\" id=\"eventsLog\"></div>\n    </div>\n\n    <h3>Retrospective</h3>\n    <div class=\"section\">\n      <button id=\"runRetro\">Run Retrospective</button>\n      <div id=\"retroOutput\" class=\"log\"></div>\n    </div>\n  </div>\n</div>\n\n<script>\n// Agile Methodology Interactive Simulator\n// Minimal visuals; heavy on interactivity and state transitions.\n\n// Data structures\nlet state = {\n  nextId: 1,\n  tasks: [], // {id,title,desc,points,remaining,priority,status,assigned,review,qa,blocked,deps:[],history:[]}\n  statuses: [\"Backlog\",\"To Do\",\"In Progress\",\"Code Review\",\"QA\",\"Done\"],\n  team: [], // {name,cap,skills}\n  selectedIds: new Set(),\n  history: [],\n  future: [],\n  sprint: {\n    running:false, day:0, length:0, burndown:[], timer:null\n  },\n  config: {\n    simSpeed:700,\n    randomEventChance:15\n  },\n  logs: []\n};\n\n// Utility functions\nfunction logEvent(msg){\n  const t = new Date().toISOString().substr(11,8);\n  state.logs.unshift(`[${t}] ${msg}`);\n  renderEvents();\n  pushHistoryState({type:'log',msg});\n}\n\nfunction pushHistoryState(action){\n  state.history.push(JSON.parse(JSON.stringify(action)));\n  state.future = []; // clear redo\n  renderHistory();\n}\nfunction popHistory(){\n  return state.history.pop();\n}\nfunction renderHistory(){\n  const el = document.getElementById('historyLog');\n  el.textContent = '';\n  state.history.slice().reverse().forEach((h,i)=>{\n    const d = document.createElement('div');\n    d.textContent = `${h.type} ${h.msg?'- '+h.msg:''}`;\n    el.appendChild(d);\n  });\n}\n\n// Core functions\nfunction addTask(data,opts){\n  const task = {\n    id: state.nextId++,\n    title: data.title || `Item ${state.nextId}`,\n    desc: data.desc || '',\n    points: Number(data.points)||1,\n    remaining: Number(data.points)||1,\n    priority: Number(data.priority)||3,\n    status: data.status || state.statuses[0],\n    assigned: data.assigned || null,\n    review: !!data.review,\n    qa: !!data.qa,\n    blocked: !!data.blocked,\n    deps: data.deps?Array.from(data.deps):[],\n    history: []\n  };\n  state.tasks.push(task);\n  pushHistoryState({type:'add', id:task.id, msg:task.title});\n  if(!opts || !opts.silent) logEvent(`Created task #${task.id} \"${task.title}\"`);\n  renderAll();\n  return task;\n}\n\nfunction deleteTask(id){\n  const idx = state.tasks.findIndex(t=>t.id===id);\n  if(idx>=0){\n    const t = state.tasks.splice(idx,1)[0];\n    // remove deps referencing\n    state.tasks.forEach(x=>x.deps = x.deps.filter(d=>d!==id));\n    pushHistoryState({type:'delete',id,msg:t.title});\n    logEvent(`Deleted task #${id} \"${t.title}\"`);\n    renderAll();\n  }\n}\n\nfunction updateTask(id, changes){\n  const t = state.tasks.find(x=>x.id===id);\n  if(!t) return;\n  Object.assign(t, changes);\n  if(changes.points!==undefined){\n    // adjust remaining proportionally if necessary\n    if(t.remaining > changes.points) t.remaining = changes.points;\n  }\n  pushHistoryState({type:'update',id,msg:t.title});\n  renderAll();\n}\n\nfunction cloneTask(id){\n  const t = state.tasks.find(x=>x.id===id);\n  if(!t) return;\n  addTask({\n    title: t.title + \" (clone)\",\n    desc: t.desc,\n    points: t.points,\n    priority: t.priority,\n    status: state.statuses[0],\n    review: t.review,\n    qa: t.qa,\n    blocked:false,\n    deps: []\n  });\n  logEvent(`Cloned task #${id}`);\n}\n\nfunction splitTask(id){\n  const t = state.tasks.find(x=>x.id===id);\n  if(!t) return;\n  if(t.points<=1){\n    alert('Cannot split a 1-point task further.');\n    return;\n  }\n  const left = Math.floor(t.points/2);\n  const right = t.points - left;\n  t.points = left;\n  t.remaining = Math.min(t.remaining,left);\n  const newTask = addTask({\n    title: t.title + \" (split)\",\n    desc: t.desc,\n    points: right,\n    priority: t.priority,\n    status: t.status,\n    review: t.review,\n    qa: t.qa,\n    blocked:false,\n    deps: []\n  }, {silent:true});\n  logEvent(`Split task #${id} into #${t.id} (${left}) and #${newTask.id} (${right})`);\n  pushHistoryState({type:'split',id,into:newTask.id});\n  renderAll();\n}\n\nfunction mergeTasks(ids){\n  if(ids.length<2) return;\n  const items = ids.map(id=>state.tasks.find(t=>t.id===id)).filter(Boolean);\n  if(items.length<2) return;\n  const primary = items[0];\n  for(let i=1;i<items.length;i++){\n    const t = items[i];\n    primary.points += t.points;\n    primary.remaining += t.remaining;\n    primary.desc += \"\\n\\nMerged from #\" + t.id + \": \" + t.desc;\n    deleteTask(t.id);\n  }\n  updateTask(primary.id, {points:primary.points});\n  logEvent(`Merged tasks into #${primary.id}`);\n  pushHistoryState({type:'merge',ids});\n  renderAll();\n}\n\n// Rendering\nfunction renderBoard(){\n  const board = document.getElementById('board');\n  board.innerHTML = '';\n  state.statuses.forEach((status, si)=>{\n    const col = document.createElement('div');\n    col.className = 'column';\n    col.dataset.status = status;\n    const title = document.createElement('div');\n    title.textContent = status;\n    col.appendChild(title);\n    col.addEventListener('dragover', ev=>{ ev.preventDefault(); });\n    col.addEventListener('drop', ev=>{\n      ev.preventDefault();\n      const id = Number(ev.dataTransfer.getData('text/plain'));\n      moveTaskToStatus(id, status);\n    });\n    const tasksHere = state.tasks.filter(t=>t.status===status).sort((a,b)=>a.priority - b.priority || a.id-b.id);\n    tasksHere.forEach(t=>{\n      const div = document.createElement('div');\n      div.className = 'task';\n      div.draggable = true;\n      div.dataset.id = t.id;\n      div.innerHTML = `<strong>#${t.id} - ${t.title}</strong>\n        <div class=\"small\">Pts:${t.points} Rem:${t.remaining} Pri:${t.priority} ${t.blocked? ' [BLOCKED]':''}</div>\n        <div class=\"small\">Assignee: ${t.assigned || '—'}</div>`;\n      div.addEventListener('click', ev=>{\n        if(ev.ctrlKey||ev.metaKey){\n          toggleSelect(t.id, div);\n        } else {\n          state.selectedIds.clear();\n          toggleSelect(t.id, div, true);\n        }\n        ev.stopPropagation();\n      });\n      div.addEventListener('dblclick', ()=>{selectTask(t.id);});\n      div.addEventListener('dragstart', ev=>{\n        ev.dataTransfer.setData('text/plain', String(t.id));\n      });\n      col.appendChild(div);\n    });\n    board.appendChild(col);\n  });\n}\n\nfunction toggleSelect(id, el, single){\n  if(single){\n    state.selectedIds.clear();\n  }\n  if(state.selectedIds.has(id)){\n    state.selectedIds.delete(id);\n    // remove highlight by re-render\n  } else {\n    state.selectedIds.add(id);\n  }\n  renderBoard();\n  // reapply selection highlights\n  state.selectedIds.forEach(sid=>{\n    const node = document.querySelector(`.task[data-id=\"${sid}\"]`);\n    if(node) node.style.outline = '2px solid #000';\n  });\n  renderSelected();\n}\n\nfunction moveTaskToStatus(id, status){\n  const t = state.tasks.find(x=>x.id===id);\n  if(!t) return;\n  const old = t.status;\n  t.status = status;\n  pushHistoryState({type:'move',id,from:old,to:status});\n  logEvent(`Moved #${id} from ${old} to ${status}`);\n  renderAll();\n}\n\nfunction renderSelected(){\n  const selBox = document.getElementById('selectedBox');\n  const noSel = document.getElementById('noSelection');\n  if(state.selectedIds.size===0){\n    selBox.classList.add('hidden');\n    noSel.style.display='block';\n    return;\n  }\n  noSel.style.display='none';\n  selBox.classList.remove('hidden');\n  const id = Array.from(state.selectedIds)[0];\n  const t = state.tasks.find(x=>x.id===id);\n  if(!t) return;\n  document.getElementById('selId').textContent = t.id;\n  document.getElementById('selTitle').value = t.title;\n  document.getElementById('selDesc').value = t.desc;\n  document.getElementById('selPoints').value = t.points;\n  document.getElementById('selPriority').value = t.priority;\n  const assigned = document.getElementById('selAssigned');\n  assigned.innerHTML = '<option value=\"\">— Unassigned —</option>' + state.team.map(m=>`<option value=\"${m.name}\">${m.name}</option>`).join('');\n  assigned.value = t.assigned || '';\n  const selStatus = document.getElementById('selStatus');\n  selStatus.innerHTML = state.statuses.map(s=>`<option value=\"${s}\">${s}</option>`).join('');\n  selStatus.value = t.status;\n  document.getElementById('selBlocked').checked = !!t.blocked;\n  document.getElementById('selDeps').value = t.deps.join(',');\n}\n\nfunction renderTeam(){\n  const el = document.getElementById('teamList');\n  el.innerHTML = '';\n  state.team.forEach(m=>{\n    const div = document.createElement('div');\n    div.textContent = `${m.name} — cap:${m.cap} — skills:${m.skills.join(',')}`;\n    const rem = document.createElement('button');\n    rem.textContent = 'Remove';\n    rem.style.float='right';\n    rem.addEventListener('click', ()=>{ state.team = state.team.filter(x=>x.name!==m.name); pushHistoryState({type:'teamRemove',name:m.name}); renderTeam(); renderAll(); logEvent(`Removed team member ${m.name}`); });\n    div.appendChild(rem);\n    el.appendChild(div);\n  });\n  renderSelected();\n}\n\nfunction renderEvents(){\n  const el = document.getElementById('eventsLog');\n  el.innerHTML = '';\n  state.logs.slice(0,200).forEach(l=>{\n    const d = document.createElement('div'); d.textContent = l;\n    el.appendChild(d);\n  });\n}\n\nfunction renderBurnTable(){\n  const tb = document.querySelector('#burnTable tbody');\n  tb.innerHTML = '';\n  state.sprint.burndown.forEach((v,i)=>{\n    const tr = document.createElement('tr');\n    const td1 = document.createElement('td'); td1.textContent = i;\n    const td2 = document.createElement('td'); td2.textContent = v;\n    tr.appendChild(td1); tr.appendChild(td2);\n    tb.appendChild(tr);\n  });\n  // draw canvas\n  const c = document.getElementById('burndown');\n  const ctx = c.getContext('2d');\n  ctx.clearRect(0,0,c.width,c.height);\n  const arr = state.sprint.burndown.slice();\n  if(arr.length===0) return;\n  const max = Math.max(...arr);\n  const pad = 10;\n  const w = c.width - pad*2;\n  const h = c.height - pad*2;\n  ctx.beginPath(); ctx.moveTo(pad, pad + (arr[0]/max)*h);\n  arr.forEach((v,i)=>{\n    const x = pad + (i/(arr.length-1 || 1))*w;\n    const y = pad + (v/max)*h;\n    ctx.lineTo(x, y);\n  });\n  ctx.strokeStyle = '#000';\n  ctx.stroke();\n  // ideal line\n  ctx.beginPath();\n  ctx.moveTo(pad, pad);\n  ctx.lineTo(pad + w, pad + h);\n  ctx.strokeStyle = '#000';\n  ctx.setLineDash([2,2]);\n  ctx.stroke();\n  ctx.setLineDash([]);\n}\n\nfunction renderAll(){\n  renderBoard();\n  renderTeam();\n  renderSelected();\n  document.getElementById('remainingPoints').textContent = totalRemainingPoints();\n  document.getElementById('sprintLen').textContent = state.sprint.length;\n  document.getElementById('sprintDay').textContent = state.sprint.day;\n  renderBurnTable();\n}\n\n// Helpers\nfunction totalRemainingPoints(){\n  return state.tasks.reduce((s,t)=>s + (t.remaining || 0),0);\n}\n\n// UI bindings\ndocument.getElementById('addItem').addEventListener('click', ()=>{\n  const title = document.getElementById('newTitle').value.trim() || `Item ${state.nextId}`;\n  addTask({\n    title,\n    desc: document.getElementById('newDesc').value,\n    points: Number(document.getElementById('newPoints').value) || 1,\n    priority: Number(document.getElementById('newPriority').value),\n    review: document.getElementById('newReview').checked,\n    qa: document.getElementById('newQA').checked\n  });\n  document.getElementById('newTitle').value='';\n  document.getElementById('newDesc').value='';\n});\n\ndocument.getElementById('autoGen').addEventListener('click', ()=>{\n  const n = Number(prompt('How many items to generate?', '5')) || 5;\n  for(let i=0;i<n;i++){\n    addTask({\n      title: `Auto story ${state.nextId}`,\n      desc: `Auto-generated acceptance criteria.`,\n      points: [1,2,3,5,8][Math.floor(Math.random()*5)],\n      priority: 1 + Math.floor(Math.random()*5),\n      review: Math.random()>0.5,\n      qa: Math.random()>0.4\n    }, {silent:true});\n  }\n  pushHistoryState({type:'autogen', msg:`Generated ${n} items`});\n  logEvent(`Auto-generated ${n} backlog items`);\n  renderAll();\n});\n\ndocument.getElementById('sortPriority').addEventListener('click', ()=>{\n  state.tasks.sort((a,b)=>a.priority - b.priority || a.points - b.points);\n  pushHistoryState({type:'sort',msg:'Sorted backlog by priority'});\n  renderAll();\n});\n\ndocument.getElementById('shufflePriority').addEventListener('click', ()=>{\n  state.tasks.forEach(t=>t.priority = 1 + Math.floor(Math.random()*5));\n  pushHistoryState({type:'shuffle',msg:'Randomized priorities'});\n  renderAll();\n});\n\n// Team\ndocument.getElementById('addMember').addEventListener('click', ()=>{\n  const name = document.getElementById('memberName').value.trim();\n  if(!name) return alert('Enter a name');\n  const cap = Number(document.getElementById('memberCap').value) || 3;\n  const skills = document.getElementById('memberSkills').value.split(',').map(s=>s.trim()).filter(Boolean);\n  state.team.push({name,cap,skills});\n  pushHistoryState({type:'teamAdd',name});\n  logEvent(`Added team member ${name}`);\n  document.getElementById('memberName').value='';\n  renderTeam();\n  renderAll();\n});\ndocument.getElementById('autoMembers').addEventListener('click', ()=>{\n  state.team = [\n    {name:'Alice',cap:4,skills:['dev','review']},\n    {name:'Bob',cap:3,skills:['dev']},\n    {name:'Cathy',cap:2,skills:['qa']},\n  ];\n  pushHistoryState({type:'teamAuto',msg:'Added sample team'});\n  logEvent('Added sample team: Alice, Bob, Cathy');\n  renderTeam();\n  renderAll();\n});\n\n// Columns\ndocument.getElementById('applyColumns').addEventListener('click', ()=>{\n  const raw = document.getElementById('columnsInput').value;\n  const cols = raw.split(',').map(s=>s.trim()).filter(Boolean);\n  if(cols.length<2) return alert('Define at least two columns');\n  state.statuses = cols;\n  pushHistoryState({type:'cols',msg:'Changed workflow columns'});\n  renderAll();\n});\ndocument.getElementById('resetColumns').addEventListener('click', ()=>{\n  state.statuses = [\"Backlog\",\"To Do\",\"In Progress\",\"Code Review\",\"QA\",\"Done\"];\n  document.getElementById('columnsInput').value = state.statuses.join(',');\n  pushHistoryState({type:'colsReset',msg:'Reset columns'});\n  renderAll();\n});\n\n// Selected controls\ndocument.getElementById('saveSel').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return;\n  const id = Array.from(state.selectedIds)[0];\n  const title = document.getElementById('selTitle').value;\n  const desc = document.getElementById('selDesc').value;\n  const points = Number(document.getElementById('selPoints').value) || 1;\n  const priority = Number(document.getElementById('selPriority').value);\n  const assigned = document.getElementById('selAssigned').value || null;\n  const status = document.getElementById('selStatus').value;\n  const blocked = document.getElementById('selBlocked').checked;\n  const deps = document.getElementById('selDeps').value.split(',').map(s=>Number(s.trim())).filter(Boolean);\n  updateTask(id, {title,desc,points,priority,assigned,status,blocked,deps});\n  logEvent(`Saved changes to #${id}`);\n});\ndocument.getElementById('moveLeft').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return;\n  const id = Array.from(state.selectedIds)[0];\n  const t = state.tasks.find(x=>x.id===id);\n  const idx = state.statuses.indexOf(t.status);\n  if(idx>0) moveTaskToStatus(id, state.statuses[idx-1]);\n});\ndocument.getElementById('moveRight').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return;\n  const id = Array.from(state.selectedIds)[0];\n  const t = state.tasks.find(x=>x.id===id);\n  const idx = state.statuses.indexOf(t.status);\n  if(idx<state.statuses.length-1) moveTaskToStatus(id, state.statuses[idx+1]);\n});\ndocument.getElementById('cloneSel').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return;\n  const id = Array.from(state.selectedIds)[0];\n  cloneTask(id);\n});\ndocument.getElementById('deleteSel').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return;\n  if(!confirm('Delete selected item?')) return;\n  const id = Array.from(state.selectedIds)[0];\n  deleteTask(id);\n  state.selectedIds.clear();\n  renderAll();\n});\n\ndocument.getElementById('splitTask').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return alert('Select a task to split');\n  const id = Array.from(state.selectedIds)[0];\n  splitTask(id);\n});\n\ndocument.getElementById('mergeSelected').addEventListener('click', ()=>{\n  if(state.selectedIds.size<2) return alert('Select at least two tasks to merge');\n  const ids = Array.from(state.selectedIds);\n  mergeTasks(ids);\n  state.selectedIds.clear();\n});\n\ndocument.getElementById('markDone').addEventListener('click', ()=>{\n  if(state.selectedIds.size===0) return;\n  const id = Array.from(state.selectedIds)[0];\n  moveTaskToStatus(id, state.statuses[state.statuses.length-1]);\n});\n\n// Auto assign\ndocument.getElementById('autoAssign').addEventListener('click', ()=>{\n  const unassigned = state.tasks.filter(t=>!t.assigned && t.status!==state.statuses[state.statuses.length-1]);\n  if(state.team.length===0) return alert('No team members');\n  unassigned.forEach((t,i)=>{\n    // naive: choose member with most matching skills and least assigned points\n    let best = state.team[0];\n    let bestScore = -1;\n    state.team.forEach(m=>{\n      let score = 0;\n      if(m.skills.includes('dev')) score += 1;\n      if(m.skills.includes('review') && t.review) score += 1;\n      if(m.skills.includes('qa') && t.qa) score += 1;\n      // capacity load\n      const assignedPoints = state.tasks.filter(x=>x.assigned===m.name).reduce((s,x)=>s+x.remaining,0);\n      score -= assignedPoints/50;\n      if(score>bestScore){ bestScore = score; best = m; }\n    });\n    t.assigned = best.name;\n    logEvent(`Auto-assigned #${t.id} to ${best.name}`);\n  });\n  pushHistoryState({type:'autoassign',msg:`Assigned ${unassigned.length} tasks`});\n  renderAll();\n});\n\n// Undo/Redo (basic)\ndocument.getElementById('undo').addEventListener('click', ()=>{\n  const action = state.history.pop();\n  if(!action) return alert('Nothing to undo');\n  // Very simplified undo: reverse common actions\n  if(action.type==='add'){\n    const id = action.id;\n    state.tasks = state.tasks.filter(t=>t.id!==id);\n    logEvent(`Undo: removed task #${id}`);\n  } else if(action.type==='delete'){\n    // cannot recover deleted full data; ignore\n    logEvent(`Undo: cannot restore deleted item #${action.id}`);\n  } else if(action.type==='update'){\n    // cannot revert precise; inform user\n    logEvent('Undo: limited support; state may be inconsistent');\n  } else if(action.type==='autogen'){\n    // remove last n autogenerated by message parsing\n    logEvent('Undo autogen limited; clearing recently added items');\n    // best-effort: remove tasks named 'Auto story'\n    state.tasks = state.tasks.filter(t=>!t.title.startsWith('Auto story'));\n  } else if(action.type==='teamAdd'){\n    state.team = state.team.filter(m=>m.name!==action.name);\n  } else if(action.type==='teamRemove'){\n    // cannot restore\n  } else if(action.type==='cols'){\n    // no-op\n  } else if(action.type==='split'){\n    // cannot easily restore\n  } else if(action.type==='merge'){\n    logEvent('Undo merge is not supported in detail');\n  }\n  state.future.push(action);\n  renderAll();\n  renderHistory();\n});\ndocument.getElementById('redo').addEventListener('click', ()=>{\n  const action = state.future.pop();\n  if(!action) return alert('Nothing to redo');\n  // just re-apply limited actions\n  if(action.type==='add'){\n    // cannot easily restore\n  }\n  state.history.push(action);\n  renderHistory();\n  renderAll();\n});\n\n// Selection & click outside\ndocument.addEventListener('click', (ev)=>{\n  if(!ev.target.closest('.task')) {\n    // clear selection\n    //state.selectedIds.clear();\n    //renderBoard();\n    //renderSelected();\n  }\n});\n\n// Sprint simulation\nfunction calculateDailyCapacity(){\n  // sum of team caps\n  return state.team.reduce((s,m)=>s + m.cap, 0);\n}\n\ndocument.getElementById('startSprint').addEventListener('click', ()=>{\n  if(state.sprint.running) return;\n  const len = Number(document.getElementById('sprintDays').value) || 10;\n  state.sprint.length = len;\n  state.sprint.day = 0;\n  state.sprint.burndown = [];\n  state.config.simSpeed = Number(document.getElementById('simSpeed').value) || 700;\n  state.config.randomEventChance = Number(document.getElementById('randomEvent').value) || 15;\n  // Carryover: move top backlog into To Do until capacity filled by points\n  state.tasks = state.tasks || [];\n  pushHistoryState({type:'sprintStart',msg:`Sprint length ${len}`});\n  logEvent(`Sprint started for ${len} days`);\n  state.sprint.running = true;\n  document.getElementById('sprintStatus').textContent = 'Running';\n  // initialize burndown day 0\n  state.sprint.burndown.push(totalRemainingPoints());\n  renderAll();\n  runSprintLoop();\n});\n\nfunction runSprintLoop(){\n  if(!state.sprint.running) return;\n  state.sprint.timer = setTimeout(()=> {\n    stepSprintDay();\n    if(state.sprint.running) runSprintLoop();\n  }, state.config.simSpeed);\n}\n\nfunction stepSprintDay(){\n  if(!state.sprint.running) return;\n  if(state.sprint.day >= state.sprint.length){\n    endSprint();\n    return;\n  }\n  state.sprint.day++;\n  document.getElementById('sprintDay').textContent = state.sprint.day;\n  // Each day: simulate work flow\n  simulateDay();\n  // Random events\n  if(Math.random()*100 < state.config.randomEventChance){\n    triggerRandomEvent();\n  }\n  // Record burndown\n  state.sprint.burndown.push(totalRemainingPoints());\n  renderAll();\n  // End if last day reached\n  if(state.sprint.day >= state.sprint.length){\n    endSprint();\n  }\n}\n\ndocument.getElementById('stepDay').addEventListener('click', ()=>{\n  stepSprintDay();\n});\n\ndocument.getElementById('pauseSprint').addEventListener('click', ()=>{\n  if(state.sprint.running){\n    clearTimeout(state.sprint.timer);\n    state.sprint.running = false;\n    document.getElementById('sprintStatus').textContent = 'Paused';\n    pushHistoryState({type:'sprintPause',msg:'Paused sprint'});\n    logEvent('Sprint paused');\n  } else {\n    state.sprint.running = true;\n    runSprintLoop();\n    document.getElementById('sprintStatus').textContent = 'Running';\n    logEvent('Sprint resumed');\n  }\n});\n\ndocument.getElementById('endSprint').addEventListener('click', ()=>{\n  if(confirm('End sprint now?')) endSprint();\n});\n\nfunction endSprint(){\n  if(state.sprint.timer) clearTimeout(state.sprint.timer);\n  state.sprint.running = false;\n  document.getElementById('sprintStatus').textContent = 'Ended';\n  logEvent('Sprint ended');\n  // carryover unfinished items to backlog or next sprint To Do\n  const doneStatus = state.statuses[state.statuses.length-1];\n  const unfinished = state.tasks.filter(t=>t.status !== doneStatus);\n  unfinished.forEach(t=>{\n    t.status = state.statuses[1] || state.statuses[0]; // move to To Do if exists else backlog\n  });\n  pushHistoryState({type:'sprintEnd',msg:'Ended sprint'});\n  renderAll();\n}\n\n// Simulate day: assign work to In Progress items, move items along when complete\nfunction simulateDay(){\n  const dailyCap = calculateDailyCapacity();\n  let available = dailyCap;\n  // Prioritize In Progress, then To Do\n  const inProgress = state.tasks.filter(t=>t.status===state.statuses[2] && !t.blocked).sort((a,b)=>a.priority - b.priority);\n  const todo = state.tasks.filter(t=>t.status===state.statuses[1] && !t.blocked).sort((a,b)=>a.priority - b.priority);\n  const workQueue = inProgress.concat(todo);\n  for(const t of workQueue){\n    if(available<=0) break;\n    if(t.remaining<=0) continue;\n    // If dependencies exist and not all done, skip\n    const depUnfinished = t.deps.some(did => {\n      const dep = state.tasks.find(x=>x.id===did);\n      return dep && dep.status !== state.statuses[state.statuses.length-1];\n    });\n    if(depUnfinished) continue;\n    // assign some work\n    const effort = Math.min(available, Math.ceil(Math.min(t.remaining, Math.max(1, t.points/2))));\n    t.remaining -= effort;\n    available -= effort;\n    t.history.push({day:state.sprint.day,worked:effort});\n    logEvent(`Worked ${effort}pt on #${t.id} (${t.remaining} left)`);\n    if(t.remaining<=0){\n      // progress to next step\n      const idx = state.statuses.indexOf(t.status);\n      const nextIdx = Math.min(state.statuses.length-1, idx+1);\n      t.status = state.statuses[nextIdx];\n      logEvent(`#${t.id} moved to ${t.status} (auto)`);\n      // if moved to code review but review not required, skip ahead\n      if(t.status === 'Code Review' && !t.review){\n        const i2 = state.statuses.indexOf(t.status);\n        t.status = state.statuses[Math.min(state.statuses.length-1,i2+1)];\n      }\n    }\n  }\n  // Simulate review rejections probabilistically\n  const inReview = state.tasks.filter(t=>t.status.toLowerCase().includes('review') || t.status==='Code Review');\n  inReview.forEach(t=>{\n    if(Math.random() < 0.2 && t.review){\n      // fail review -> move back to In Progress and add remaining work\n      t.status = state.statuses[Math.max(0,state.statuses.indexOf(t.status)-1)];\n      t.remaining = Math.max(1, Math.ceil(t.points*0.3));\n      t.blocked = false;\n      logEvent(`#${t.id} failed review, moved back to ${t.status}`);\n    } else if(!t.review){\n      // auto approve\n      const idx = state.statuses.indexOf(t.status);\n      if(idx<state.statuses.length-1) t.status = state.statuses[idx+1];\n      logEvent(`#${t.id} auto-approved (no review required)`);\n    }\n  });\n  // QA failures\n  const inQA = state.tasks.filter(t=>t.status.toLowerCase().includes('qa') || t.status==='QA');\n  inQA.forEach(t=>{\n    if(Math.random() < 0.15 && t.qa){\n      t.status = state.statuses[Math.max(0,state.statuses.indexOf(t.status)-2)];\n      t.remaining = Math.max(1, Math.ceil(t.points*0.5));\n      t.blocked = false;\n      logEvent(`#${t.id} failed QA and moved back to ${t.status}`);\n    } else {\n      if(t.qa){\n        // pass occasionally\n        if(Math.random() < 0.6){\n          const idx = state.statuses.indexOf(t.status);\n          if(idx<state.statuses.length-1) t.status = state.statuses[idx+1];\n          logEvent(`#${t.id} passed QA and moved to ${t.status}`);\n        }\n      } else {\n        // no QA required: move to Done\n        const idx = state.statuses.indexOf(t.status);\n        if(idx<state.statuses.length-1) t.status = state.statuses[idx+1];\n        logEvent(`#${t.id} advanced (no QA required)`);\n      }\n    }\n  });\n}\n\nfunction triggerRandomEvent(){\n  const r = Math.random();\n  if(r < 0.4){\n    // blocker on random in-progress task\n    const candidates = state.tasks.filter(t=>t.status===state.statuses[2]);\n    if(candidates.length===0) return;\n    const t = candidates[Math.floor(Math.random()*candidates.length)];\n    t.blocked = true;\n    logEvent(`Random event: Task #${t.id} got blocked due to external dependency`);\n  } else if(r < 0.8){\n    // reduce capacity for a day\n    if(state.team.length===0) return;\n    const who = state.team[Math.floor(Math.random()*state.team.length)];\n    who._origCap = who.cap;\n    who.cap = Math.max(1, Math.floor(who.cap * (0.3 + Math.random()*0.6)));\n    logEvent(`Random event: ${who.name} is partially unavailable today (cap ${who.cap})`);\n    // restore next day via scheduled undo entry in logs (simplified)\n    setTimeout(()=>{ if(who._origCap) { who.cap = who._origCap; delete who._origCap; logEvent(`${who.name} capacity restored`); renderTeam(); } }, state.config.simSpeed * 1.1);\n  } else {\n    // new urgent item added mid-sprint\n    addTask({\n      title: `Urgent ${state.nextId}`,\n      desc: 'Urgent work added mid-sprint',\n      points: [1,2,3,5][Math.floor(Math.random()*4)],\n      priority: 1,\n      review: Math.random()>0.5,\n      qa: Math.random()>0.4,\n      status: state.statuses[1] // To Do\n    }, {silent:true});\n    logEvent('Random event: Urgent task added to To Do');\n  }\n  renderAll();\n}\n\ndocument.getElementById('addBlocker').addEventListener('click', ()=>{ triggerRandomEvent(); });\ndocument.getElementById('fixBlockers').addEventListener('click', ()=>{\n  state.tasks.forEach(t=>t.blocked=false);\n  logEvent('All blockers cleared manually');\n  renderAll();\n});\n\n// Retrospective\ndocument.getElementById('runRetro').addEventListener('click', ()=>{\n  const doneStatus = state.statuses[state.statuses.length-1];\n  const done = state.tasks.filter(t=>t.status===doneStatus);\n  const unfinished = state.tasks.filter(t=>t.status!==doneStatus);\n  const output = [];\n  output.push(`Completed ${done.length} items totaling ${done.reduce((s,t)=>s + t.points,0)} points.`);\n  output.push(`Unfinished ${unfinished.length} items totaling ${unfinished.reduce((s,t)=>s + t.points,0)} points.`);\n  const commonBlocks = {};\n  state.tasks.forEach(t=>{\n    if(t.blocked) commonBlocks[t.id] = (commonBlocks[t.id]||0)+1;\n  });\n  output.push(`Blocked items at sprint end: ${Object.keys(commonBlocks).length}`);\n  output.push('Team capacity: ' + calculateDailyCapacity() + ' points/day');\n  document.getElementById('retroOutput').textContent = output.join('\\n');\n  pushHistoryState({type:'retro',msg:'Ran retrospective'});\n});\n\n// Events: selection helper\nfunction selectTask(id){\n  state.selectedIds.clear();\n  state.selectedIds.add(id);\n  renderSelected();\n}\n\n// Misc small helpers\ndocument.getElementById('addMember').addEventListener('keyup', ()=>{ renderTeam(); });\n\n// initial sample data\n(function init(){\n  state.team = [{name:'Alice',cap:4,skills:['dev','review']},{name:'Bob',cap:3,skills:['dev']},{name:'Cathy',cap:2,skills:['qa']}];\n  addTask({title:'User login',desc:'Allow users to log in',points:5,priority:1,review:true,qa:true,status:state.statuses[0]},{silent:true});\n  addTask({title:'Signup flow',desc:'Signup with email',points:8,priority:2,review:true,qa:true,status:state.statuses[0]},{silent:true});\n  addTask({title:'Search',desc:'Search products',points:3,priority:3,review:false,qa:true,status:state.statuses[1]},{silent:true});\n  addTask({title:'Refactor auth',desc:'Improve token handling',points:5,priority:4,review:true,qa:false,status:state.statuses[2]},{silent:true});\n  addTask({title:'Fix checkout bug',desc:'Failing payment edge case',points:2,priority:1,review:false,qa:true,status:state.statuses[1]},{silent:true});\n  renderAll();\n})();\n\n</script>\n</body>\n</html>"
