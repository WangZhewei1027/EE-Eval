    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Integration Testing | Visual Symphony</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n            --warning: #fdcb6e;\n            --error: #d63031;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            overflow-x: hidden;\n            color: var(--dark);\n            line-height: 1.6;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            margin-bottom: 1rem;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: -0.05em;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .main-visual {\n            position: relative;\n            height: 500px;\n            margin: 4rem 0;\n            perspective: 1000px;\n        }\n\n        .system {\n            position: absolute;\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            font-size: 0.9rem;\n            text-align: center;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            opacity: 0;\n            transform: translateY(30px);\n            animation: systemAppear 0.8s forwards;\n            z-index: 10;\n        }\n\n        .system:nth-child(1) { \n            background: var(--primary); \n            top: 50%; \n            left: 20%; \n            animation-delay: 0.3s;\n        }\n        .system:nth-child(2) { \n            background: var(--accent); \n            top: 20%; \n            left: 50%; \n            transform: translate(-50%, 30px);\n            animation-delay: 0.5s;\n        }\n        .system:nth-child(3) { \n            background: var(--success); \n            top: 50%; \n            right: 20%; \n            animation-delay: 0.7s;\n        }\n        .system:nth-child(4) { \n            background: var(--warning); \n            bottom: 10%; \n            left: 50%; \n            transform: translate(-50%, 30px);\n            animation-delay: 0.9s;\n            color: var(--dark);\n        }\n\n        .connection {\n            position: absolute;\n            background: var(--secondary);\n            height: 4px;\n            border-radius: 2px;\n            transform-origin: left center;\n            z-index: 5;\n            opacity: 0;\n            animation: connectionAppear 0.5s forwards;\n        }\n\n        .connection-1 { \n            width: 160px; \n            top: 80px; \n            left: 180px; \n            transform: rotate(30deg);\n            animation-delay: 1.2s;\n        }\n        .connection-2 { \n            width: 160px; \n            top: 80px; \n            right: 180px; \n            transform: rotate(-30deg);\n            animation-delay: 1.4s;\n        }\n        .connection-3 { \n            width: 100px; \n            top: 240px; \n            left: 50%; \n            transform: translateX(-50%) rotate(90deg);\n            animation-delay: 1.6s;\n        }\n\n        .test-flow {\n            position: absolute;\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n            background: white;\n            box-shadow: 0 0 15px rgba(255, 255, 255, 0.8);\n            z-index: 20;\n            opacity: 0;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: 0.8rem 1.8rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n        }\n\n        button:hover {\n            background: var(--accent);\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n\n        button:disabled {\n            background: #dfe6e9;\n            color: #b2bec3;\n            transform: none;\n            box-shadow: none;\n            cursor: not-allowed;\n        }\n\n        .status {\n            text-align: center;\n            margin-top: 2rem;\n            font-size: 1.1rem;\n            font-weight: 500;\n            height: 1.5rem;\n            color: var(--dark);\n            opacity: 0.8;\n        }\n\n        .test-complete {\n            position: absolute;\n            width: 100%;\n            text-align: center;\n            top: 50%;\n            left: 0;\n            transform: translateY(-50%);\n            font-size: 1.5rem;\n            font-weight: 600;\n            color: var(--success);\n            opacity: 0;\n            z-index: 30;\n        }\n\n        @keyframes systemAppear {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes connectionAppear {\n            to {\n                opacity: 0.6;\n            }\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); opacity: 0.8; }\n            50% { transform: scale(1.05); opacity: 1; }\n            100% { transform: scale(1); opacity: 0.8; }\n        }\n\n        @keyframes flow {\n            0% { transform: translate(0, 0) scale(1); opacity: 0; }\n            10% { opacity: 1; }\n            90% { opacity: 1; }\n            100% { transform: translate(var(--tx), var(--ty)) scale(0.5); opacity: 0; }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            font-size: 0.9rem;\n            color: var(--dark);\n            opacity: 0.6;\n            animation: fadeIn 2s ease-out;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Integration Testing</h1>\n            <p class=\"subtitle\">A visual demonstration of how independent systems communicate and are tested as a unified group, ensuring seamless interaction between components.</p>\n        </header>\n\n        <div class=\"main-visual\">\n            <div class=\"system\">User Interface</div>\n            <div class=\"system\">Authentication</div>\n            <div class=\"system\">Database</div>\n            <div class=\"system\">Payment Gateway</div>\n\n            <div class=\"connection connection-1\"></div>\n            <div class=\"connection connection-2\"></div>\n            <div class=\"connection connection-3\"></div>\n\n            <div class=\"test-complete\">Integration Test Complete ✓</div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"startTest\">Run Integration Test</button>\n            <button id=\"resetTest\" disabled>Reset</button>\n        </div>\n\n        <div class=\"status\" id=\"status\">Ready to test system integration</div>\n\n        <footer>\n            <p>Visualizing the harmony between independent systems</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const startBtn = document.getElementById('startTest');\n            const resetBtn = document.getElementById('resetTest');\n            const statusEl = document.getElementById('status');\n            const testComplete = document.querySelector('.test-complete');\n            const systems = document.querySelectorAll('.system');\n            const connections = document.querySelectorAll('.connection');\n\n            let testRunning = false;\n\n            const runTestSequence = () => {\n                if (testRunning) return;\n                testRunning = true;\n                startBtn.disabled = true;\n                statusEl.textContent = 'Starting integration test...';\n                \n                // Phase 1: Activate connections\n                setTimeout(() => {\n                    connections.forEach(conn => {\n                        conn.style.opacity = '1';\n                        conn.style.background = 'var(--success)';\n                    });\n                    statusEl.textContent = 'Establishing connections between systems...';\n                }, 1000);\n\n                // Phase 2: Highlight systems\n                setTimeout(() => {\n                    systems.forEach(system => {\n                        system.style.transform = 'scale(1.1)';\n                        system.style.boxShadow = '0 20px 40px rgba(0, 0, 0, 0.2)';\n                    });\n                    statusEl.textContent = 'Verifying system interoperability...';\n                }, 2000);\n\n                // Phase 3: Test flow animation\n                setTimeout(() => {\n                    createTestFlow('User Interface', 'Authentication', 1);\n                    setTimeout(() => createTestFlow('Authentication', 'Database', 2), 800);\n                    setTimeout(() => createTestFlow('Database', 'Payment Gateway', 3), 1600);\n                    setTimeout(() => createTestFlow('Payment Gateway', 'User Interface', 4), 2400);\n                    statusEl.textContent = 'Testing data flow between components...';\n                }, 3000);\n\n                // Final phase\n                setTimeout(() => {\n                    systems.forEach(system => {\n                        system.style.animation = 'pulse 1.5s infinite';\n                    });\n                    testComplete.style.opacity = '1';\n                    testComplete.style.animation = 'fadeIn 1.5s ease-out';\n                    statusEl.textContent = 'All systems integrated successfully!';\n                    resetBtn.disabled = false;\n                }, 6000);\n            };\n\n            const createTestFlow = (fromSystem, toSystem, order) => {\n                const fromEl = [...systems].find(s => s.textContent === fromSystem);\n                const toEl = [...systems].find(s => s.textContent === toSystem);\n                \n                if (!fromEl || !toEl) return;\n\n                const fromRect = fromEl.getBoundingClientRect();\n                const toRect = toEl.getBoundingClientRect();\n\n                const flow = document.createElement('div');\n                flow.className = 'test-flow';\n                flow.style.left = `${fromRect.left + fromRect.width/2 - 10}px`;\n                flow.style.top = `${fromRect.top + fromRect.height/2 - 10}px`;\n                \n                // Calculate translation values\n                const tx = toRect.left - fromRect.left;\n                const ty = toRect.top - fromRect.top;\n                flow.style.setProperty('--tx', `${tx}px`);\n                flow.style.setProperty('--ty', `${ty}px`);\n                \n                flow.style.animation = `flow 1s ${order * 0.2}s forwards`;\n                document.querySelector('.main-visual').appendChild(flow);\n\n                setTimeout(() => {\n                    flow.remove();\n                }, 1500 + order * 200);\n            };\n\n            const resetTest = () => {\n                testRunning = false;\n                systems.forEach(system => {\n                    system.style.transform = '';\n                    system.style.boxShadow = '';\n                    system.style.animation = '';\n                });\n                connections.forEach(conn => {\n                    conn.style.opacity = '';\n                    conn.style.background = '';\n                });\n                testComplete.style.opacity = '0';\n                testComplete.style.animation = '';\n                statusEl.textContent = 'Ready to test system integration';\n                startBtn.disabled = false;\n                resetBtn.disabled = true;\n            };\n\n            startBtn.addEventListener('click', runTestSequence);\n            resetBtn.addEventListener('click', resetTest);\n        });\n    </script>\n</body>\n</html>"
