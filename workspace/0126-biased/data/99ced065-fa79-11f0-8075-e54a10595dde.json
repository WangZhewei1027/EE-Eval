    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Search Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Linear Search Demonstration</h1>\n    \n    <label for=\"arrayInput\">Enter numbers (comma-separated):</label>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 1, 2, 3, 4, 5\">\n    \n    <label for=\"targetInput\">Enter target number:</label>\n    <input type=\"number\" id=\"targetInput\" placeholder=\"Target number\">\n    \n    <button id=\"searchButton\">Search</button>\n    \n    <h2>Search Result:</h2>\n    <p id=\"resultOutput\"></p>\n    \n    <h2>Search Steps:</h2>\n    <ul id=\"stepsOutput\"></ul>\n    \n    <script>\n        document.getElementById('searchButton').addEventListener('click', function() {\n            const arrayInput = document.getElementById('arrayInput').value;\n            const target = parseInt(document.getElementById('targetInput').value);\n            const array = arrayInput.split(',').map(num => parseInt(num.trim()));\n            let result = 'Not Found';\n            let steps = [];\n            \n            for (let i = 0; i < array.length; i++) {\n                steps.push(`Checking index ${i}: value ${array[i]}`);\n                if (array[i] === target) {\n                    result = `Found at index ${i}`;\n                    break;\n                }\n            }\n\n            document.getElementById('resultOutput').innerText = result;\n            document.getElementById('stepsOutput').innerHTML = steps.map(step => `<li>${step}</li>`).join('');\n        });\n    </script>\n</body>\n</html>"
