    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>DNS — Visual Journey</title>\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#081021;\n    --accent1:#6EE7B7;\n    --accent2:#60A5FA;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.7);\n    --card-blur: 10px;\n    --soft-shadow: 0 8px 30px rgba(2,6,23,0.6);\n    --glass-border: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(96,165,250,0.08), transparent),\n                radial-gradient(1000px 500px at 90% 80%, rgba(110,231,183,0.05), transparent),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e6eef8;\n    overflow:hidden;\n  }\n\n  /* Subtle animated background particles */\n  .bg-ornaments{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    mix-blend-mode:screen;\n    opacity:0.9;\n  }\n  .orb{\n    position:absolute;\n    width:420px;\n    height:420px;\n    border-radius:50%;\n    filter:blur(60px);\n    transform:translate3d(0,0,0);\n    opacity:0.12;\n    animation: float 8s ease-in-out infinite alternate;\n  }\n  .orb.one{ left:-5%; top:-5%; background:linear-gradient(135deg,var(--accent2), #7c3aed); animation-duration:12s; }\n  .orb.two{ right:-8%; bottom:-6%; background:linear-gradient(135deg,var(--accent1), #34d399); animation-duration:9s; }\n  @keyframes float {\n    0% { transform: translateY(0) translateX(0) scale(1); }\n    100% { transform: translateY(-40px) translateX(30px) scale(1.05); }\n  }\n\n  /* Main layout */\n  .wrap{\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:40px;\n    width:calc(100% - 120px);\n    margin:60px auto;\n    align-items:center;\n    max-width:1300px;\n  }\n\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:36px;\n    box-shadow: var(--soft-shadow);\n    backdrop-filter: blur(var(--card-blur));\n    border: 1px solid rgba(255,255,255,0.04);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Title */\n  header.title{\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:18px;\n  }\n  .logo{\n    width:64px;\n    height:64px;\n    border-radius:14px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background: linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.5), inset 0 -6px 20px rgba(255,255,255,0.02);\n  }\n  .logo svg{ width:44px; height:44px; filter: drop-shadow(0 6px 18px rgba(96,165,250,0.08)); }\n\n  h1{\n    font-size:20px;\n    margin:0;\n    letter-spacing:0.4px;\n    color: #f0f7ff;\n  }\n  p.lead{ margin:6px 0 0 0; color:rgba(230,238,248,0.8); font-size:13px; }\n\n  /* Visualization area */\n  .visual{\n    height:560px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  .map{\n    width:100%;\n    max-width:880px;\n    height:100%;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Node styling */\n  .node{\n    width:120px;\n    height:120px;\n    border-radius:24px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    gap:8px;\n    padding:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n    color:var(--muted);\n    transition: transform 400ms cubic-bezier(.2,.9,.2,1), box-shadow 400ms;\n    transform: translateZ(0);\n    backdrop-filter: blur(6px);\n  }\n  .node .icon{\n    width:46px;\n    height:46px;\n    border-radius:10px;\n    display:grid;\n    place-items:center;\n    background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--accent2);\n  }\n  .node small{ font-size:12px; color:rgba(230,238,248,0.7); }\n\n  /* Layout for nodes on a horizontal \"path\" */\n  .path{\n    position:relative;\n    width:92%;\n    height:280px;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:8px;\n  }\n  .node-wrap{\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:12px;\n    position:relative;\n  }\n  .node.stacked{ transform: translateY(-28px); }\n\n  /* Lines between nodes drawn with SVG overlay */\n  .connections{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n  }\n\n  /* Pulse & active state */\n  .node.active{\n    transform: translateY(-12px) scale(1.03);\n    box-shadow: 0 18px 60px rgba(96,165,250,0.12), 0 6px 30px rgba(2,6,23,0.5);\n    border-image: linear-gradient(90deg,var(--accent2),var(--accent1)) 1;\n  }\n  .node.pulse::after{\n    content:\"\";\n    position:absolute;\n    width:110%;\n    height:110%;\n    border-radius:20px;\n    left: -5%;\n    top:-5%;\n    background: linear-gradient(90deg, rgba(96,165,250,0.12), rgba(110,231,183,0.08));\n    transform:scale(.6);\n    opacity:0;\n    animation: nodePulse 1400ms ease-out forwards;\n    z-index:-1;\n  }\n  @keyframes nodePulse{\n    0%{ transform:scale(0.6); opacity:0.8; }\n    100%{ transform:scale(1.7); opacity:0; }\n  }\n\n  /* Animating stroke on path */\n  .connection-line{\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:2.6;\n    stroke-linecap:round;\n    filter: drop-shadow(0 10px 30px rgba(2,6,23,0.6));\n  }\n  .connection-anim{\n    stroke: url(#gradStroke);\n    stroke-width:3.2;\n    stroke-linecap:round;\n    stroke-dasharray: 600;\n    stroke-dashoffset: 600;\n    animation: dash 1100ms linear forwards;\n    filter: drop-shadow(0 12px 28px rgba(96,165,250,0.12));\n  }\n  @keyframes dash {\n    to { stroke-dashoffset: 0; }\n  }\n\n  /* Caption and controls */\n  .meta{\n    margin-top:18px;\n    display:flex;\n    gap:16px;\n    align-items:center;\n    justify-content:space-between;\n  }\n  .caption{\n    font-size:13px;\n    color:rgba(230,238,248,0.78);\n    flex:1;\n    line-height:1.34;\n    min-height:44px;\n  }\n\n  /* Button */\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 16px;\n    border-radius:12px;\n    font-weight:600;\n    background: linear-gradient(90deg,var(--accent2),var(--accent1));\n    color:#052028;\n    cursor:pointer;\n    box-shadow: 0 10px 30px rgba(96,165,250,0.14);\n    transition: transform 220ms cubic-bezier(.2,.9,.2,1), box-shadow 220ms;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    font-size:14px;\n  }\n  .btn:active{ transform: translateY(2px) scale(.998); }\n  .btn[disabled]{ opacity:0.6; cursor:default; transform:none; box-shadow:none; }\n\n  /* Info side panel */\n  .info{\n    padding:28px;\n    border-radius:16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    height:100%;\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n  }\n  .info h2{ margin:0; font-size:16px; color:#f7fbff; }\n  .info p{ margin-top:8px; color:rgba(230,238,248,0.78); font-size:13px; line-height:1.5; }\n  .legend{\n    margin-top:18px;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n  }\n  .legend .row{ display:flex; align-items:center; gap:12px; color:rgba(230,238,248,0.82); font-size:13px; }\n  .swatch{ width:12px; height:12px; border-radius:4px; background:linear-gradient(90deg,var(--accent2),var(--accent1)); box-shadow:0 6px 18px rgba(96,165,250,0.12); }\n\n  footer.credit{\n    margin-top:18px;\n    font-size:12px;\n    color:rgba(230,238,248,0.6);\n  }\n\n  /* Responsive */\n  @media (max-width:1100px){\n    .wrap{ grid-template-columns: 1fr; gap:22px; width:calc(100% - 56px); margin:28px auto; }\n    .info{ order:2; }\n    .panel{ order:1; }\n    .visual{ height:520px; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"bg-ornaments\" aria-hidden=\"true\">\n    <div class=\"orb one\"></div>\n    <div class=\"orb two\"></div>\n  </div>\n\n  <main class=\"wrap\" role=\"main\">\n    <section class=\"panel\" aria-labelledby=\"title\">\n      <header class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <!-- Stylized DNS logo -->\n          <svg viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"lg\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#60A5FA\"/>\n                <stop offset=\"1\" stop-color=\"#6EE7B7\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"4\" y=\"6\" width=\"40\" height=\"36\" rx=\"7\" fill=\"url(#lg)\" opacity=\"0.12\"/>\n            <path d=\"M12 22h10\" stroke=\"url(#lg)\" stroke-width=\"2.6\" stroke-linecap=\"round\"/>\n            <circle cx=\"34\" cy=\"18\" r=\"2.6\" fill=\"url(#lg)\"/>\n            <path d=\"M26 30h6\" stroke=\"url(#lg)\" stroke-width=\"2.6\" stroke-linecap=\"round\"/>\n            <path d=\"M22 12c2 1.8 4.5 3 7 3.3\" stroke=\"url(#lg)\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n        <div>\n          <h1 id=\"title\">DNS — Visual Journey</h1>\n          <p class=\"lead\">A calm, elegant illustration of how a DNS name resolves across the global hierarchy.</p>\n        </div>\n      </header>\n\n      <div class=\"visual\" aria-hidden=\"false\">\n        <div class=\"map\" id=\"map\">\n          <!-- Nodes arranged visually -->\n          <div class=\"path\" id=\"path\">\n            <div class=\"node-wrap\" style=\"align-items:flex-start;\">\n              <div class=\"node\" id=\"node-client\" title=\"Client\">\n                <div class=\"icon\" aria-hidden=\"true\">\n                  <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\">\n                    <path d=\"M3 13v4a2 2 0 0 0 2 2h4\"/>\n                    <path d=\"M21 11v-3a2 2 0 0 0-2-2h-4\"/>\n                    <path d=\"M8 10a4 4 0 1 1 8 0\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  </svg>\n                </div>\n                <small>Client</small>\n              </div>\n              <div style=\"width:110px;height:6px;border-radius:6px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); margin-top:10px;\"></div>\n            </div>\n\n            <div class=\"node-wrap node stacked\" style=\"align-items:center;\">\n              <div class=\"node\" id=\"node-resolver\" title=\"Recursive Resolver\">\n                <div class=\"icon\" aria-hidden=\"true\" style=\"color:var(--accent1)\">\n                  <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\">\n                    <path d=\"M12 5v14\"/>\n                    <path d=\"M5 12h14\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  </svg>\n                </div>\n                <small>Recursive Resolver</small>\n              </div>\n            </div>\n\n            <div class=\"node-wrap\" style=\"align-items:center;\">\n              <div class=\"node\" id=\"node-root\" title=\"Root Server\">\n                <div class=\"icon\" aria-hidden=\"true\" style=\"color:#FFD166\">\n                  <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\">\n                    <circle cx=\"12\" cy=\"12\" r=\"3\" />\n                    <path d=\"M12 3v2M12 19v2M3 12h2M19 12h2M5 5l1.5 1.5M17.5 17.5 19 19M17.5 6.5 19 5M5 19l1.5-1.5\" stroke-linecap=\"round\"/>\n                  </svg>\n                </div>\n                <small>Root Nameserver</small>\n              </div>\n            </div>\n\n            <div class=\"node-wrap node stacked\" style=\"align-items:center;\">\n              <div class=\"node\" id=\"node-tld\" title=\"TLD Server\">\n                <div class=\"icon\" aria-hidden=\"true\" style=\"color:#C084FC\">\n                  <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\">\n                    <path d=\"M3 7h18M6 21V7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    <path d=\"M11 21v-6h6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  </svg>\n                </div>\n                <small>TLD Nameserver</small>\n              </div>\n            </div>\n\n            <div class=\"node-wrap\" style=\"align-items:flex-end;\">\n              <div class=\"node\" id=\"node-auth\" title=\"Authoritative Server\">\n                <div class=\"icon\" aria-hidden=\"true\" style=\"color:#34D399\">\n                  <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\">\n                    <path d=\"M12 2L2 7l10 5 10-5L12 2z\"/>\n                    <path d=\"M2 17l10 5 10-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                    <path d=\"M7 11v6\" stroke-linecap=\"round\"/>\n                  </svg>\n                </div>\n                <small>Authoritative Server</small>\n              </div>\n              <div style=\"width:110px;height:6px;border-radius:6px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); margin-top:10px;\"></div>\n            </div>\n          </div>\n\n          <!-- SVG overlay for connections and animating lines -->\n          <svg class=\"connections\" viewBox=\"0 0 1200 560\" preserveAspectRatio=\"none\">\n            <defs>\n              <linearGradient id=\"gradStroke\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#60A5FA\"/>\n                <stop offset=\"1\" stop-color=\"#6EE7B7\"/>\n              </linearGradient>\n            </defs>\n\n            <!-- Pre-drawn soft background connectors -->\n            <path id=\"bg-conn\" d=\"M120 260 C 260 240, 360 240, 480 260 S 760 280, 900 260\" class=\"connection-line\" fill=\"none\" opacity=\"0.12\" />\n            <!-- Animating segments (hidden until animated) -->\n            <path id=\"anim1\" d=\"M120 260 C 260 240, 360 240, 480 260\" class=\"connection-anim\" fill=\"none\" style=\"opacity:0;\" />\n            <path id=\"anim2\" d=\"M480 260 C 600 280, 700 280, 860 260\" class=\"connection-anim\" fill=\"none\" style=\"opacity:0;\" />\n            <path id=\"back1\" d=\"M480 260 C 360 240, 260 240, 120 260\" class=\"connection-anim\" fill=\"none\" style=\"opacity:0; stroke-dashoffset:600; animation-duration:900ms; animation-delay:900ms;\"/>\n            <path id=\"back2\" d=\"M860 260 C 700 280, 600 280, 480 260\" class=\"connection-anim\" fill=\"none\" style=\"opacity:0; stroke-dashoffset:600; animation-duration:900ms; animation-delay:1200ms;\"/>\n          </svg>\n        </div>\n      </div>\n\n      <div class=\"meta\" aria-live=\"polite\">\n        <div class=\"caption\" id=\"caption\">Click \"Start DNS Journey\" to watch a single query flow from a client through the recursive resolver, the root and TLD servers, to the authoritative server and back. This animation highlights query and response steps visually — observe the pulses and paths.</div>\n        <div style=\"display:flex;align-items:center;gap:12px;\">\n          <button class=\"btn\" id=\"startBtn\" aria-controls=\"map\" title=\"Start demo\">\n            <!-- simple play icon -->\n            <svg viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" style=\"transform:translateY(1px);\">\n              <path d=\"M5 3v18l15-9L5 3z\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n            Start DNS Journey\n          </button>\n        </div>\n      </div>\n    </section>\n\n    <aside class=\"info panel\" aria-labelledby=\"info-title\">\n      <div>\n        <h2 id=\"info-title\">What is DNS?</h2>\n        <p>DNS (Domain Name System) translates human-friendly names (like example.com) into IP addresses computers use. It's a global, hierarchical system made of recursive resolvers, root servers, TLD servers, and authoritative servers.</p>\n\n        <div class=\"legend\" aria-hidden=\"true\">\n          <div class=\"row\"><span class=\"swatch\"></span> Visualizes query flow and response path</div>\n          <div class=\"row\"><span style=\"width:12px;height:12px;border-radius:4px;background:rgba(255,255,255,0.06)\"></span> Static infrastructure & labels</div>\n        </div>\n      </div>\n\n      <div>\n        <p style=\"font-size:13px;margin-bottom:10px;color:rgba(230,238,248,0.72)\">Animation steps (brief):</p>\n        <ol style=\"padding-left:18px;margin:0 0 10px 0;color:rgba(230,238,248,0.72);font-size:13px;line-height:1.5\">\n          <li>Client asks Recursive Resolver</li>\n          <li>Resolver queries Root</li>\n          <li>Resolver queries TLD</li>\n          <li>Resolver queries Authoritative</li>\n          <li>Authoritative responds & the resolver returns the answer to the client</li>\n        </ol>\n\n        <footer class=\"credit\">Designed as a calm, aesthetic teaching illustration • Minimal interactivity</footer>\n      </div>\n    </aside>\n  </main>\n\n<script>\n  // Minimal interactivity: single button to run the animation sequence.\n  (function(){\n    const btn = document.getElementById('startBtn');\n    const caption = document.getElementById('caption');\n\n    const nodes = {\n      client: document.getElementById('node-client'),\n      resolver: document.getElementById('node-resolver'),\n      root: document.getElementById('node-root'),\n      tld: document.getElementById('node-tld'),\n      auth: document.getElementById('node-auth')\n    };\n\n    const animPaths = {\n      toRoot: document.getElementById('anim1'),\n      toAuth: document.getElementById('anim2'),\n      backToResolver1: document.getElementById('back1'),\n      backToResolver2: document.getElementById('back2')\n    };\n\n    // Utility to trigger a path animation: show, reset dashoffset, then let CSS animate.\n    function triggerPath(pathEl, delay=0, duration=1100){\n      return new Promise(resolve=>{\n        setTimeout(()=>{\n          pathEl.style.opacity = '1';\n          pathEl.style.transition = 'none';\n          // Force reflow to reset animation\n          void pathEl.getBoundingClientRect();\n          // reset dashoffset to full length\n          pathEl.style.strokeDashoffset = pathEl.style.strokeDasharray || 600;\n          // set animation via native CSS transition (we're using keyframes defined in CSS)\n          pathEl.style.animation = `dash ${duration}ms linear forwards`;\n          // end event\n          setTimeout(()=>{\n            resolve();\n          }, duration);\n        }, delay);\n      });\n    }\n\n    function resetPaths(){\n      Object.values(animPaths).forEach(p=>{\n        p.style.opacity = '0';\n        p.style.animation = 'none';\n        p.style.strokeDashoffset = (p.getTotalLength && p.getTotalLength()) ? p.getTotalLength() : 600;\n      });\n    }\n\n    function clearNodeStates(){\n      Object.values(nodes).forEach(n=>{\n        n.classList.remove('active');\n        n.classList.remove('pulse');\n      });\n    }\n\n    // Animation sequence with measured steps and captions\n    async function runSequence(){\n      btn.disabled = true;\n      clearNodeStates();\n      resetPaths();\n      caption.textContent = 'Client creates a DNS query and asks the recursive resolver...';\n      nodes.client.classList.add('pulse','active');\n\n      // small wait\n      await new Promise(r=>setTimeout(r,700));\n\n      // client -> resolver (visual pulse)\n      nodes.client.classList.remove('pulse');\n      nodes.resolver.classList.add('pulse','active');\n      caption.textContent = 'Recursive resolver receives the query and begins the lookup process.';\n      await new Promise(r=>setTimeout(r,900));\n\n      // resolver -> root\n      nodes.resolver.classList.remove('pulse');\n      nodes.root.classList.add('pulse','active');\n      caption.textContent = 'Resolver queries a Root nameserver to find the TLD server for the domain.';\n      await triggerPath(animPaths.toRoot, 80, 1100);\n\n      // small pause then tld\n      await new Promise(r=>setTimeout(r,400));\n      nodes.root.classList.remove('pulse');\n      nodes.tld.classList.add('pulse','active');\n      caption.textContent = 'Root refers the resolver to the appropriate TLD nameserver.';\n      await triggerPath(animPaths.toAuth, 80, 1000);\n\n      await new Promise(r=>setTimeout(r,500));\n      nodes.tld.classList.remove('pulse');\n      nodes.auth.classList.add('pulse','active');\n      caption.textContent = 'Resolver queries the authoritative server for the domain\\'s record.';\n      // short animation to authoritative\n      await new Promise(r=>setTimeout(r,900));\n\n      // authoritative responds back: animate return paths\n      nodes.auth.classList.remove('pulse');\n      nodes.auth.classList.add('active','pulse');\n      caption.textContent = 'Authoritative server responds with the IP address. Response flows back through the resolver to the client.';\n      await triggerPath(animPaths.backToResolver1, 120, 900);\n      await triggerPath(animPaths.backToResolver2, 120, 900);\n\n      // Show resolver then client receiving\n      nodes.resolver.classList.add('pulse','active');\n      await new Promise(r=>setTimeout(r,700));\n      nodes.client.classList.add('pulse','active');\n      caption.textContent = 'Resolver caches the answer and returns it to the client. Name resolved — connection can proceed.';\n      await new Promise(r=>setTimeout(r,1200));\n\n      // finalize visuals\n      clearNodeStates();\n      nodes.client.classList.add('active');\n      caption.textContent = 'Done — example.com → 93.184.216.34 (example response). The resolver cached the result to answer future queries faster.';\n      btn.disabled = false;\n    }\n\n    // Initialize dashoffsets on load (for browsers that can get path length)\n    function init(){\n      Object.values(animPaths).forEach(p=>{\n        try{\n          const len = p.getTotalLength();\n          p.style.strokeDasharray = len;\n          p.style.strokeDashoffset = len;\n        }catch(e){\n          // fallback using CSS default\n          p.style.strokeDasharray = 600;\n          p.style.strokeDashoffset = 600;\n        }\n        p.style.opacity = '0';\n      });\n    }\n\n    init();\n\n    btn.addEventListener('click', function(){\n      runSequence();\n    });\n\n    // Small accessibility: press Enter triggers button\n    btn.addEventListener('keyup', function(ev){\n      if(ev.key === 'Enter' || ev.key === ' '){\n        runSequence();\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
