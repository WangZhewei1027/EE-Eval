    .marker {\n            position: absolute;\n            background-color: #ffcc00;\n            width: 15px;\n            height: 15px;\n            border-radius: 50%;\n            animation: bounce 1s infinite alternate;\n        }\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n                transform: translateY(-20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        @keyframes bounce {\n            from {\n                transform: translateY(0);\n            }\n            to {\n                transform: translateY(-10px);\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Ternary Search Visualization</h1>\n        <p>Observe how Ternary Search efficiently narrows down the search space of a sorted array by dividing it into three parts.</p>\n        <div class=\"visualization\">\n            <div class=\"line\"></div>\n            <div class=\"marker\" id=\"marker1\" style=\"left: 20%;\"></div>\n            <div class=\"marker\" id=\"marker2\" style=\"left: 50%;\"></div>\n            <div class=\"marker\" id=\"marker3\" style=\"left: 80%;\"></div>\n        </div>\n        <button id=\"startButton\">Start Visualization</button>\n    </div>\n    <script>\n        let step = 0;\n        const markers = [\n            {element: document.getElementById('marker1'), position: '20%', label: 'L'},\n            {element: document.getElementById('marker2'), position: '50%', label: 'M'},\n            {element: document.getElementById('marker3'), position: '80%', label: 'R'}\n        ];\n\n        document.getElementById('startButton').addEventListener('click', function () {\n            step = 0;\n            animateSearch();\n        });\n\n        function animateSearch() {\n            if (step >= markers.length) return;\n            markers[step].element.animate([\n                { transform: 'translateY(0)' },\n                { transform: 'translateY(-20px)' },\n                { transform: 'translateY(0)' }\n            ], {\n                duration: 500,\n                easing: 'ease-in-out',\n                fill: 'forwards'\n            });\n            step++;\n            setTimeout(animateSearch, 1000);\n        }\n    </script>\n</body>\n</html>"
