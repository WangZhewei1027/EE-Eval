    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Recursive Beauty</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --bg: #f8f9fa;\n            --text: #2d3436;\n            --light: #ffffff;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: var(--bg);\n            color: var(--text);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--secondary);\n            font-weight: 300;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization-container {\n            position: relative;\n            width: 100%;\n            max-width: 800px;\n            height: 500px;\n            margin: 2rem auto;\n            background: var(--light);\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .recursive-tree {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n        }\n\n        .branch {\n            position: absolute;\n            bottom: 50px;\n            width: 10px;\n            background: linear-gradient(to top, #6c5ce7, #a29bfe);\n            border-radius: 5px;\n            transform-origin: bottom center;\n            box-shadow: 0 0 15px rgba(108, 92, 231, 0.3);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .leaf {\n            position: absolute;\n            width: 20px;\n            height: 20px;\n            background-color: var(--accent);\n            border-radius: 50% 50% 50% 0;\n            transform: rotate(45deg);\n            box-shadow: 0 0 10px rgba(253, 121, 168, 0.5);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        .controls {\n            margin-top: 2rem;\n            display: flex;\n            gap: 1rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 0.5s forwards;\n        }\n\n        button {\n            padding: 0.8rem 1.8rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.6);\n        }\n\n        button:active {\n            transform: translateY(1px);\n        }\n\n        .explanation {\n            max-width: 700px;\n            margin: 3rem auto;\n            padding: 2rem;\n            background: var(--light);\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 1s forwards;\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-weight: 400;\n        }\n\n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n            color: var(--text);\n        }\n\n        .code-snippet {\n            background: #2d3436;\n            color: #f8f9fa;\n            padding: 1rem;\n            border-radius: 8px;\n            font-family: 'Courier New', Courier, monospace;\n            margin: 1rem 0;\n            overflow-x: auto;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes branchGrow {\n            0% { transform: scaleY(0); }\n            100% { transform: scaleY(1); }\n        }\n\n        @keyframes leafAppear {\n            0% { opacity: 0; transform: rotate(45deg) scale(0.5); }\n            100% { opacity: 1; transform: rotate(45deg) scale(1); }\n        }\n\n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--secondary);\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 1.5s forwards;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Recursive Beauty</h1>\n        <p class=\"subtitle\">A visual exploration of recursion through fractal branching patterns and elegant animations</p>\n    </header>\n\n    <div class=\"visualization-container\">\n        <div class=\"recursive-tree\" id=\"tree\"></div>\n    </div>\n\n    <div class=\"controls\">\n        <button id=\"growBtn\">Grow Tree</button>\n        <button id=\"resetBtn\">Reset</button>\n    </div>\n\n    <div class=\"explanation\">\n        <h2>Understanding Recursion</h2>\n        <p>Recursion is a programming technique where a function calls itself in order to solve a problem. Each recursive call works on a smaller piece of the problem until it reaches a base case that can be solved without further recursion.</p>\n        \n        <p>The branching tree visualization demonstrates this concept beautifully. Each branch splits into smaller branches, which in turn split into even smaller ones, until reaching the smallest possible size (the base case).</p>\n        \n        <div class=\"code-snippet\">\n            function drawBranch(depth, maxDepth) {<br>\n            &nbsp;&nbsp;if (depth > maxDepth) return; // Base case<br>\n            &nbsp;&nbsp;<br>\n            &nbsp;&nbsp;// Draw current branch<br>\n            &nbsp;&nbsp;// ...<br>\n            &nbsp;&nbsp;<br>\n            &nbsp;&nbsp;// Recursive calls for left and right branches<br>\n            &nbsp;&nbsp;drawBranch(depth + 1, maxDepth);<br>\n            &nbsp;&nbsp;drawBranch(depth + 1, maxDepth);<br>\n            }\n        </div>\n    </div>\n\n    <footer>\n        <p>An artistic visualization of recursion | Designed with elegance</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const treeContainer = document.getElementById('tree');\n            const growBtn = document.getElementById('growBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let animationId;\n            let currentDepth = 0;\n            const maxDepth = 5;\n            const branchColors = ['#6c5ce7', '#7d6beb', '#8f7bef', '#a18bf3', '#b39bf7', '#c5abfb'];\n            \n            function createBranch(x, y, length, angle, depth, parentWidth) {\n                if (depth > maxDepth) return;\n                \n                const branch = document.createElement('div');\n                branch.className = 'branch';\n                \n                const width = parentWidth * 0.7;\n                const newLength = length * 0.7;\n                \n                branch.style.width = `${width}px`;\n                branch.style.height = `${length}px`;\n                branch.style.left = `${x}px`;\n                branch.style.bottom = `${y}px`;\n                branch.style.transform = `rotate(${angle}deg) scaleY(0)`;\n                \n                treeContainer.appendChild(branch);\n                \n                // Animate the branch growing\n                setTimeout(() => {\n                    branch.style.animation = `branchGrow 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards`;\n                }, depth * 200);\n                \n                // Add leaves at the end of branches\n                if (depth === maxDepth) {\n                    const leaf = document.createElement('div');\n                    leaf.className = 'leaf';\n                    leaf.style.left = `${x - 10}px`;\n                    leaf.style.bottom = `${y + length - 10}px`;\n                    leaf.style.backgroundColor = branchColors[depth];\n                    treeContainer.appendChild(leaf);\n                    \n                    setTimeout(() => {\n                        leaf.style.animation = `leafAppear 0.5s ease-out forwards`;\n                    }, (depth * 200) + 500);\n                }\n                \n                // Calculate new positions for child branches\n                const leftAngle = angle - 30;\n                const rightAngle = angle + 30;\n                \n                const leftX = x + Math.sin(leftAngle * Math.PI / 180) * length * 0.7;\n                const leftY = y + Math.cos(leftAngle * Math.PI / 180) * length * 0.7;\n                \n                const rightX = x + Math.sin(rightAngle * Math.PI / 180) * length * 0.7;\n                const rightY = y + Math.cos(rightAngle * Math.PI / 180) * length * 0.7;\n                \n                // Recursive calls for left and right branches\n                setTimeout(() => {\n                    createBranch(leftX, leftY, newLength, leftAngle, depth + 1, width);\n                    createBranch(rightX, rightY, newLength, rightAngle, depth + 1, width);\n                }, 200);\n            }\n            \n            function growTree() {\n                resetTree();\n                const centerX = treeContainer.offsetWidth / 2 - 5;\n                createBranch(centerX, 50, 120, 0, 0, 10);\n            }\n            \n            function resetTree() {\n                while (treeContainer.firstChild) {\n                    treeContainer.removeChild(treeContainer.firstChild);\n                }\n                currentDepth = 0;\n            }\n            \n            growBtn.addEventListener('click', growTree);\n            resetBtn.addEventListener('click', resetTree);\n            \n            // Initial animation\n            setTimeout(growTree, 1000);\n        });\n    </script>\n</body>\n</html>"
