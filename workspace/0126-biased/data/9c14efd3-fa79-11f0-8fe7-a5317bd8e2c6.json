  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Big-Omega Notation Interactive Lab</title>\n<style>\n/* Minimal visual design: plain black text on white background, basic layout only */\nbody { font-family: monospace; margin: 12px; color: black; background: white; }\nsection { margin-bottom: 12px; }\nlabel { display: inline-block; min-width: 120px; }\ninput[type=\"text\"], input[type=\"number\"], select, textarea { width: 320px; }\ntextarea { height: 80px; }\nbutton { margin: 2px; }\ncanvas { border: 1px solid #000; display: block; margin-top:6px; }\nsmall { color: black; }\n.controls { max-width: 980px; }\n.row { margin:6px 0; }\n.inline { display:inline-block; vertical-align:middle; margin-right:8px; }\n.logbox { width:100%; height:140px; }\n</style>\n</head>\n<body>\n<h1>Big-Omega Notation — Interactive Lab</h1>\n\n<section class=\"controls\">\n  <div class=\"row\">\n    <label>Example functions:</label>\n    <select id=\"exampleSelect\"></select>\n    <button id=\"loadExample\">Load</button>\n    <button id=\"resetExample\">Reset</button>\n  </div>\n\n  <div class=\"row\">\n    <label>f(n) (left side):</label>\n    <input id=\"fexpr\" type=\"text\" value=\"n\" />\n  </div>\n\n  <div class=\"row\">\n    <label>g(n) (right side):</label>\n    <input id=\"gexpr\" type=\"text\" value=\"1\" />\n  </div>\n\n  <div class=\"row\">\n    <label>Domain start n_min:</label>\n    <input id=\"nmin\" type=\"number\" value=\"1\" min=\"0\" />\n    <label style=\"min-width:80px\">n_max (plot/test):</label>\n    <input id=\"nmax\" type=\"number\" value=\"200\" min=\"1\" />\n  </div>\n\n  <div class=\"row\">\n    <label>Comparison type:</label>\n    <select id=\"cmpType\">\n      <option value=\"omega\">Omega (f(n) ∈ Ω(g(n)))</option>\n      <option value=\"omega_strict\">Ω strict (&gt;)</option>\n      <option value=\"theta\">Theta (Θ)</option>\n      <option value=\"not\">Check counterexample (find violation)</option>\n    </select>\n  </div>\n\n  <div class=\"row\">\n    <label>Proposed constant c:</label>\n    <input id=\"c_input\" type=\"number\" value=\"1\" step=\"any\" />\n    <label style=\"min-width:80px\">Proposed n0:</label>\n    <input id=\"n0_input\" type=\"number\" value=\"1\" />\n    <button id=\"applyProposition\">Apply</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Search settings:</label>\n    <input id=\"searchMax\" type=\"number\" value=\"10000\" /> (max n to search for violations)\n    <label style=\"min-width:80px\">Sample points:</label>\n    <input id=\"sampleCount\" type=\"number\" value=\"200\" />\n  </div>\n\n  <div class=\"row\">\n    <label>Heuristic tools:</label>\n    <button id=\"autoFind\">Auto-find c & n0 (heuristic)</button>\n    <button id=\"proveAuto\">Attempt numeric \"proof\" (logs)</button>\n    <button id=\"findCounter\">Find counterexample</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Graph options:</label>\n    <input id=\"showBand\" type=\"checkbox\" checked /> Show c·g(n)\n    <input id=\"logScale\" type=\"checkbox\" /> Log scale Y\n    <input id=\"showRatio\" type=\"checkbox\" /> Show f(n)/g(n)\n  </div>\n\n  <div class=\"row\">\n    <label>Save / Load:</label>\n    <input id=\"saveName\" type=\"text\" placeholder=\"name\" />\n    <button id=\"saveConfig\">Save</button>\n    <select id=\"savedList\"></select>\n    <button id=\"loadSaved\">Load</button>\n    <button id=\"deleteSaved\">Delete</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Undo / Redo:</label>\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <button id=\"clearLog\">Clear Log</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Transcript / Log:</label><br/>\n    <textarea id=\"transcript\" class=\"logbox\" readonly></textarea>\n  </div>\n</section>\n\n<section>\n  <div class=\"row\">\n    <label>Canvas (plot):</label>\n    <canvas id=\"plot\" width=\"720\" height=\"240\"></canvas>\n  </div>\n\n  <div class=\"row\">\n    <label>Detailed numeric table (samples):</label><br/>\n    <textarea id=\"tableOutput\" readonly></textarea>\n  </div>\n\n  <div class=\"row\">\n    <label>Proof assistant output:</label><br/>\n    <textarea id=\"assistant\" readonly></textarea>\n  </div>\n</section>\n\n<section>\n  <div class=\"row\">\n    <label>Workflow controls:</label>\n    <button id=\"step1\">1. Validate expressions</button>\n    <button id=\"step2\">2. Apply proposition</button>\n    <button id=\"step3\">3. Run test</button>\n    <button id=\"step4\">4. Refine / Autosearch</button>\n    <button id=\"resetAll\">Reset Lab</button>\n  </div>\n</section>\n\n<script>\n/*\nInteractive Big-Omega Lab\n- User provides f(n) and g(n) expressions (use n variable; Math.* functions available without prefix)\n- Many interactive controls: propose c & n0, auto-find, find counterexample, plotting\n- Simple state machine with undo/redo and saved configurations\n- Minimal visual design; heavy interactivity and features\n*/\n\n(function(){\n  // Utilities\n  function log(msg){\n    const t = document.getElementById('transcript');\n    const now = new Date().toLocaleTimeString();\n    t.value += '['+now+'] '+msg + '\\\\n';\n    t.scrollTop = t.scrollHeight;\n  }\n\n  function safeEvalFactory(expr){\n    // Very simple sanitizer to prevent DOM or control access\n    const banned = ['window','document','localStorage','sessionStorage','alert','prompt','confirm','fetch','XMLHttpRequest','while','for','=>','function','class','new','constructor','prototype','eval','setInterval','setTimeout'];\n    const low = expr.toLowerCase();\n    for(const b of banned){\n      if(low.indexOf(b) !== -1) throw new Error('Expression contains a forbidden token: ' + b);\n    }\n    if(expr.indexOf(';') !== -1) throw new Error('Semicolons are not allowed in expressions.');\n    // Return a function that evaluates expression with n and Math in scope\n    // Use \"with (Math)\" to allow sin, log, pow etc.\n    try {\n      const fn = new Function('n', 'with(Math){ return (' + expr + ') }');\n      // quick test\n      const test = fn(1);\n      if(typeof test === 'object' && test !== null) {\n        // allow objects? probably not\n      }\n      return fn;\n    } catch(e){\n      throw new Error('Invalid expression: ' + e.message);\n    }\n  }\n\n  // Elements\n  const fexprEl = document.getElementById('fexpr');\n  const gexprEl = document.getElementById('gexpr');\n  const nminEl = document.getElementById('nmin');\n  const nmaxEl = document.getElementById('nmax');\n  const cmpTypeEl = document.getElementById('cmpType');\n  const cInput = document.getElementById('c_input');\n  const n0Input = document.getElementById('n0_input');\n  const sampleCountEl = document.getElementById('sampleCount');\n  const searchMaxEl = document.getElementById('searchMax');\n  const plot = document.getElementById('plot');\n  const ctx = plot.getContext('2d');\n  const showBandEl = document.getElementById('showBand');\n  const logScaleEl = document.getElementById('logScale');\n  const showRatioEl = document.getElementById('showRatio');\n  const tableOutput = document.getElementById('tableOutput');\n  const assistant = document.getElementById('assistant');\n  const transcript = document.getElementById('transcript');\n\n  // Example functions\n  const examples = [\n    {name:'Linear vs Constant', f:'n', g:'1'},\n    {name:'Quadratic vs Linear', f:'n*n', g:'n'},\n    {name:'n log n vs n', f:'n*log(n)', g:'n'},\n    {name:'Logarithm vs Constant', f:'log(n)', g:'1'},\n    {name:'Exponential vs Polynomial', f:'2**n', g:'n**5'},\n    {name:'Polynomial degree difference', f:'n**3 + 5*n', g:'n**2'},\n    {name:'Same order (Theta)', f:'3*n*log(n) + 5', g:'n*log(n)'},\n    {name:'Square root vs Log', f:'sqrt(n)', g:'log(n)'},\n    {name:'Oscillating (not Omega)', f:'sin(n) + 2', g:'1'},\n    {name:'Decreasing to 0', f:'1/n', g:'1'},\n    {name:'Factorial vs Exponential', f:'gamma(n+1)', g:'2**n'} // gamma used to emulate factorial (beware huge numbers)\n  ];\n\n  const exampleSelect = document.getElementById('exampleSelect');\n  examples.forEach((e,i)=> {\n    const opt = document.createElement('option');\n    opt.value = i;\n    opt.textContent = e.name;\n    exampleSelect.appendChild(opt);\n  });\n\n  document.getElementById('loadExample').addEventListener('click', ()=> {\n    const idx = +exampleSelect.value;\n    const ex = examples[idx];\n    fexprEl.value = ex.f;\n    gexprEl.value = ex.g;\n    log('Loaded example: ' + ex.name + ' -> f(n)=' + ex.f + ', g(n)=' + ex.g);\n    pushState();\n    renderAll();\n  });\n\n  document.getElementById('resetExample').addEventListener('click', ()=> {\n    fexprEl.value = 'n';\n    gexprEl.value = '1';\n    nminEl.value = 1;\n    nmaxEl.value = 200;\n    cInput.value = 1;\n    n0Input.value = 1;\n    log('Reset inputs to defaults.');\n    pushState();\n    renderAll();\n  });\n\n  // Saved configs in localStorage\n  function refreshSavedList(){\n    const sel = document.getElementById('savedList');\n    sel.innerHTML = '';\n    for(let i=0;i<localStorage.length;i++){\n      const key = localStorage.key(i);\n      const opt = document.createElement('option');\n      opt.value = key;\n      opt.textContent = key;\n      sel.appendChild(opt);\n    }\n  }\n  document.getElementById('saveConfig').addEventListener('click', ()=> {\n    const name = document.getElementById('saveName').value || ('config_'+Date.now());\n    const data = {\n      f: fexprEl.value, g: gexprEl.value,\n      nmin: nminEl.value, nmax: nmaxEl.value,\n      c: cInput.value, n0: n0Input.value,\n      cmpType: cmpTypeEl.value\n    };\n    try {\n      localStorage.setItem(name, JSON.stringify(data));\n      log('Saved configuration \"'+name+'\".');\n      refreshSavedList();\n    } catch(e){\n      log('Save failed: ' + e.message);\n    }\n  });\n  document.getElementById('loadSaved').addEventListener('click', ()=> {\n    const sel = document.getElementById('savedList');\n    if(!sel.value){ log('No saved config selected.'); return; }\n    const raw = localStorage.getItem(sel.value);\n    if(!raw){ log('Saved item not found.'); refreshSavedList(); return; }\n    const data = JSON.parse(raw);\n    fexprEl.value = data.f; gexprEl.value = data.g;\n    nminEl.value = data.nmin; nmaxEl.value = data.nmax;\n    cInput.value = data.c; n0Input.value = data.n0;\n    cmpTypeEl.value = data.cmpType || 'omega';\n    log('Loaded saved configuration \"'+sel.value+'\".');\n    pushState();\n    renderAll();\n  });\n  document.getElementById('deleteSaved').addEventListener('click', ()=> {\n    const sel = document.getElementById('savedList');\n    if(!sel.value){ log('No saved config selected.'); return; }\n    localStorage.removeItem(sel.value);\n    log('Deleted saved configuration \"'+sel.value+'\".');\n    refreshSavedList();\n  });\n  refreshSavedList();\n\n  // Undo / Redo stack\n  let history = [];\n  let future = [];\n  function pushState(){\n    const state = {\n      f: fexprEl.value, g: gexprEl.value,\n      nmin: nminEl.value, nmax: nmaxEl.value,\n      c: cInput.value, n0: n0Input.value,\n      cmpType: cmpTypeEl.value,\n      showBand: showBandEl.checked, logScale: logScaleEl.checked, showRatio: showRatioEl.checked\n    };\n    history.push(JSON.stringify(state));\n    if(history.length>200) history.shift();\n    future = [];\n    updateUndoRedo();\n  }\n  function restoreState(serialized){\n    const s = JSON.parse(serialized);\n    fexprEl.value = s.f; gexprEl.value = s.g;\n    nminEl.value = s.nmin; nmaxEl.value = s.nmax;\n    cInput.value = s.c; n0Input.value = s.n0;\n    cmpTypeEl.value = s.cmpType;\n    showBandEl.checked = s.showBand; logScaleEl.checked = s.logScale; showRatioEl.checked = s.showRatio;\n    renderAll();\n  }\n  function updateUndoRedo(){\n    document.getElementById('undoBtn').disabled = history.length<=1;\n    document.getElementById('redoBtn').disabled = future.length===0;\n  }\n  document.getElementById('undoBtn').addEventListener('click', ()=> {\n    if(history.length<=1) return;\n    const cur = history.pop();\n    future.push(cur);\n    const prev = history[history.length-1];\n    restoreState(prev);\n    log('Undo applied.');\n    updateUndoRedo();\n  });\n  document.getElementById('redoBtn').addEventListener('click', ()=> {\n    if(future.length===0) return;\n    const s = future.pop();\n    history.push(s);\n    restoreState(s);\n    log('Redo applied.');\n    updateUndoRedo();\n  });\n\n  // Basic machine steps\n  document.getElementById('step1').addEventListener('click', ()=> { stepValidate(); });\n  document.getElementById('step2').addEventListener('click', ()=> { applyProposition(); });\n  document.getElementById('step3').addEventListener('click', ()=> { runTest(); });\n  document.getElementById('step4').addEventListener('click', ()=> { refineAndAuto(); });\n  document.getElementById('resetAll').addEventListener('click', ()=> { resetLab(); });\n\n  // Core numeric sampling\n  function sampleFunctions(fFn, gFn, opts){\n    // opts: nmin, nmax, sampleCount\n    const nmin = +opts.nmin || 1;\n    const nmax = +opts.nmax || 200;\n    const N = Math.max(1, +opts.sampleCount || (nmax-nmin+1));\n    const samples = [];\n    if(N >= (nmax - nmin + 1)){\n      for(let n=nmin;n<=nmax;n++){\n        samples.push(sampleOne(n,fFn,gFn));\n      }\n    } else {\n      // pick N points spaced\n      for(let i=0;i<N;i++){\n        const n = Math.floor(nmin + i*(nmax-nmin)/(N-1 || 1));\n        samples.push(sampleOne(n,fFn,gFn));\n      }\n    }\n    return samples;\n  }\n  function sampleOne(n,fFn,gFn){\n    let f=NaN,g=NaN,ratio=NaN;\n    try { f = +fFn(n); } catch(e){ f = NaN; }\n    try { g = +gFn(n); } catch(e){ g = NaN; }\n    if(isFinite(f) && isFinite(g) && g !== 0) ratio = f/g;\n    if(isFinite(f) && isFinite(g) && g === 0) ratio = (f>0? Infinity : (f<0? -Infinity : NaN));\n    return {n: n, f: f, g: g, ratio: ratio};\n  }\n\n  // Plotting\n  function renderPlot(samples, c, n0){\n    const W = plot.width, H = plot.height;\n    ctx.clearRect(0,0,W,H);\n    // compute ranges\n    let minY = Infinity, maxY = -Infinity;\n    for(const s of samples){\n      if(!isFinite(s.f) || !isFinite(s.g)) continue;\n      minY = Math.min(minY, s.f, s.g * (c!==null? c:1));\n      maxY = Math.max(maxY, s.f, s.g * (c!==null? c:1));\n      if(showRatioEl.checked && isFinite(s.ratio)) { minY = Math.min(minY, s.ratio); maxY = Math.max(maxY, s.ratio); }\n    }\n    if(!isFinite(minY)) { minY = -1; maxY = 1; }\n    if(minY === maxY) { minY -= 1; maxY += 1; }\n    // If log scale selected, transform\n    const logScale = logScaleEl.checked;\n    function transformY(val){\n      if(!isFinite(val)) return null;\n      if(logScale){\n        const v = (val<=0)? Math.log(Math.abs(val)+1) * (val<0 ? -1 : 1) : Math.log(val);\n        return v;\n      }\n      return val;\n    }\n    let tmin = transformY(minY), tmax = transformY(maxY);\n    if(!isFinite(tmin) || !isFinite(tmax)) { tmin = -1; tmax = 1; }\n    const pad = 20;\n    function mapX(i){\n      return pad + i*(W-2*pad)/(samples.length-1 || 1);\n    }\n    function mapY(v){\n      const tv = transformY(v);\n      if(!isFinite(tv)) return NaN;\n      const r = (tv - tmin) / (tmax - tmin || 1);\n      return H - pad - r*(H-2*pad);\n    }\n\n    // Draw axes\n    ctx.strokeStyle = 'black';\n    ctx.beginPath();\n    ctx.moveTo(pad, pad/2);\n    ctx.lineTo(pad, H-pad/2);\n    ctx.stroke();\n    ctx.beginPath();\n    ctx.moveTo(pad, H-pad);\n    ctx.lineTo(W-pad, H-pad);\n    ctx.stroke();\n\n    // Draw f(n)\n    ctx.strokeStyle = 'black';\n    ctx.lineWidth = 1.5;\n    ctx.beginPath();\n    let started=false;\n    for(let i=0;i<samples.length;i++){\n      const s=samples[i];\n      const x = mapX(i);\n      const y = mapY(s.f);\n      if(!isFinite(y)) { started=false; continue; }\n      if(!started){ ctx.moveTo(x,y); started=true; } else ctx.lineTo(x,y);\n    }\n    ctx.stroke();\n\n    // Draw c*g(n) band if requested\n    if(showBandEl.checked && c!==null){\n      ctx.strokeStyle = 'black';\n      ctx.lineWidth = 1;\n      ctx.setLineDash([3,2]);\n      ctx.beginPath();\n      let started2=false;\n      for(let i=0;i<samples.length;i++){\n        const s=samples[i];\n        const x = mapX(i);\n        const y = mapY(s.g * c);\n        if(!isFinite(y)) { started2=false; continue; }\n        if(!started2){ ctx.moveTo(x,y); started2=true; } else ctx.lineTo(x,y);\n      }\n      ctx.stroke();\n      ctx.setLineDash([]);\n    }\n\n    // Draw ratio if requested (scaled down)\n    if(showRatioEl.checked){\n      ctx.strokeStyle = 'black';\n      ctx.lineWidth = 1;\n      ctx.beginPath();\n      let started3=false;\n      for(let i=0;i<samples.length;i++){\n        const s=samples[i];\n        const x = mapX(i);\n        const y = mapY(s.ratio);\n        if(!isFinite(y)) { started3=false; continue; }\n        if(!started3){ ctx.moveTo(x,y); started3=true; } else ctx.lineTo(x,y);\n      }\n      ctx.stroke();\n    }\n\n    // mark n0 vertical line\n    if(n0 !== null){\n      const idx = samples.findIndex(s=> s.n >= n0);\n      if(idx >= 0){\n        const x = mapX(idx);\n        ctx.strokeStyle = 'black';\n        ctx.beginPath();\n        ctx.moveTo(x, pad);\n        ctx.lineTo(x, H-pad);\n        ctx.stroke();\n      }\n    }\n\n    // simple legend\n    ctx.fillStyle = 'black';\n    ctx.fillText('Solid: f(n)  --  Dashed: c·g(n)  --  (vertical line: n0)', 8, 12);\n  }\n\n  // Core checking\n  function checkProposition(fFn, gFn, c, n0, opts){\n    // Check whether for all integers n >= n0 and <= searchMax, inequality holds:\n    // if cmpType is 'omega' => f(n) >= c*g(n)\n    // 'omega_strict' => f(n) > c*g(n)\n    // 'theta' => both Omega and O (we only check Omega here)\n    const searchMax = Math.min(+opts.searchMax || 10000, +opts.globalLimit || 1000000);\n    const cmpType = opts.cmp || 'omega';\n    const res = {violations: [], testedUpTo: null, ok:true};\n    for(let n = Math.max(1, Math.floor(n0)); n<=searchMax; n++){\n      let f,g;\n      try { f = +fFn(n); } catch(e){ f = NaN; }\n      try { g = +gFn(n); } catch(e){ g = NaN; }\n      if(!isFinite(f) || !isFinite(g)){ res.violations.push({n:n, f:f, g:g, reason:'non-finite'}); res.ok=false; break; }\n      const left = f;\n      const right = c * g;\n      const ok = (cmpType === 'omega_strict') ? (left > right + 1e-12) : (left + 1e-12 >= right);\n      if(!ok){\n        res.violations.push({n:n, f:f, g:g, reason:'inequality fails'});\n        res.ok=false;\n        break;\n      }\n      res.testedUpTo = n;\n    }\n    return res;\n  }\n\n  // Auto-find c & n0 heuristics\n  function autoFindConstants(fFn, gFn, opts){\n    // Sample many n, compute ratio r = f/g. We'll attempt to find positive lim inf.\n    const nmin = +opts.nmin || 1;\n    const nmax = +opts.nmax || 2000;\n    const step = Math.max(1, Math.floor((nmax - nmin)/1000) || 1);\n    const ratios = [];\n    for(let n=nmin; n<=nmax; n+=step){\n      let f,g;\n      try { f = +fFn(n); } catch(e){ f = NaN; }\n      try { g = +gFn(n); } catch(e){ g = NaN; }\n      let r = NaN;\n      if(isFinite(f) && isFinite(g)){\n        if(g === 0) r = (f>0? Infinity : (f<0? -Infinity : NaN));\n        else r = f/g;\n      }\n      ratios.push({n:n, r:r});\n    }\n    // compute moving minima of ratios for last half of domain\n    const valid = ratios.filter(x=> isFinite(x.r));\n    if(valid.length === 0) return {found:false, reason:'No valid samples'};\n    // estimate liminf as min of the tail ratios (e.g., last 30% of samples)\n    const tail = valid.slice(Math.floor(valid.length*0.3));\n    const minTail = tail.reduce((a,b)=> Math.min(a, b.r), Infinity);\n    if(!isFinite(minTail) || minTail <= 0) return {found:false, reason:'Estimated lim inf <= 0'};\n    // propose c = 0.9 * minTail\n    const c = Math.max(1e-12, minTail * 0.9);\n    // find n0 as first n after which ratio >= c for all subsequent sampled points\n    let n0 = nmin;\n    for(let i=0;i<ratios.length;i++){\n      const ok = ratios.slice(i).every(x => isFinite(x.r) && x.r >= c - 1e-12);\n      if(ok){ n0 = ratios[i].n; break; }\n    }\n    return {found:true, c:c, n0:n0, minTail:minTail};\n  }\n\n  // find counterexample: attempt to find n >= n0 where inequality fails within searchMax\n  function findCounterexample(fFn,gFn,c,n0,searchMax){\n    for(let n = Math.max(1, Math.floor(n0)); n<=searchMax; n++){\n      let f,g;\n      try { f = +fFn(n); } catch(e){ f = NaN; }\n      try { g = +gFn(n); } catch(e){ g = NaN; }\n      if(!isFinite(f) || !isFinite(g)) return {found:true,n:n,f:f,g:g,reason:'non-finite'};\n      if(!(f + 1e-12 >= c*g)) return {found:true,n:n,f:f,g:g,reason:'inequality fails'};\n    }\n    return {found:false};\n  }\n\n  // UI actions\n  function stepValidate(){\n    assistant.value = '';\n    try {\n      const fFn = safeEvalFactory(fexprEl.value);\n      const gFn = safeEvalFactory(gexprEl.value);\n      log('Expressions parsed OK.');\n      pushState();\n      renderAll();\n    } catch(e){\n      log('Validation error: ' + e.message);\n    }\n  }\n\n  function applyProposition(){\n    assistant.value = '';\n    const c = +cInput.value;\n    const n0 = +n0Input.value;\n    if(!isFinite(c) || !isFinite(n0)){ log('Invalid c or n0.'); return; }\n    log('Applied proposition: f(n) ' + ((cmpTypeEl.value==='omega_strict')? '>' : '≥') + ' ' + c + '·g(n) for all n ≥ ' + n0);\n    pushState();\n    renderAll();\n  }\n\n  function runTest(){\n    assistant.value = '';\n    let fFn, gFn;\n    try {\n      fFn = safeEvalFactory(fexprEl.value);\n      gFn = safeEvalFactory(gexprEl.value);\n    } catch(e){\n      log('Cannot run test: ' + e.message);\n      return;\n    }\n    const c = +cInput.value;\n    const n0 = +n0Input.value;\n    const cmp = cmpTypeEl.value;\n    const searchMax = +searchMaxEl.value;\n    log('Running test up to n=' + searchMax + '...');\n    const res = checkProposition(fFn,gFn,c,n0,{searchMax:searchMax, cmp:cmp});\n    if(res.ok){\n      log('No violation found up to search limit. Candidate holds on tested range (not a formal proof).');\n      assistant.value = 'Numeric test: passed up to n=' + res.testedUpTo + '.\\\\nThis suggests f(n) ∈ ' + (cmp==='omega_strict'? 'Ω_strict(g(n))' : 'Ω(g(n))') + ' with these constants on the tested domain.';\n    } else {\n      log('Violation found at n=' + (res.violations[0].n) + ' (reason: ' + res.violations[0].reason + ').');\n      assistant.value = 'Counterexample: n=' + res.violations[0].n + ', f(n)=' + res.violations[0].f + ', g(n)=' + res.violations[0].g + '.';\n    }\n    pushState();\n    renderAll();\n  }\n\n  document.getElementById('applyProposition').addEventListener('click', applyProposition);\n\n  document.getElementById('autoFind').addEventListener('click', ()=> {\n    assistant.value = '';\n    let fFn,gFn;\n    try{\n      fFn = safeEvalFactory(fexprEl.value);\n      gFn = safeEvalFactory(gexprEl.value);\n    } catch(e){\n      log('Auto-find failed: ' + e.message);\n      return;\n    }\n    const nmin = +nminEl.value || 1;\n    const nmax = +nmaxEl.value || 2000;\n    const r = autoFindConstants(fFn,gFn,{nmin:nmin, nmax:nmax});\n    if(!r.found){\n      log('Auto-find: No suitable positive lim inf found. Reason: ' + r.reason);\n      assistant.value = 'Auto-find failed: ' + r.reason;\n    } else {\n      cInput.value = r.c;\n      n0Input.value = r.n0;\n      log('Auto-find suggests c ≈ ' + r.c.toExponential(6) + ' and n0 = ' + r.n0 + ' (estimated lim inf = ' + r.minTail.toExponential(6) + ').');\n      assistant.value = 'Suggested constants: c=' + r.c + ', n0=' + r.n0 + '\\\\nThis is a numeric heuristic, not a formal proof.';\n      pushState();\n      renderAll();\n    }\n  });\n\n  document.getElementById('proveAuto').addEventListener('click', ()=> {\n    assistant.value = '';\n    let fFn,gFn;\n    try{\n      fFn = safeEvalFactory(fexprEl.value);\n      gFn = safeEvalFactory(gexprEl.value);\n    } catch(e){\n      log('Auto-prove failed: ' + e.message);\n      return;\n    }\n    const auto = autoFindConstants(fFn,gFn,{nmin:+nminEl.value, nmax:+nmaxEl.value});\n    if(!auto.found){\n      log('Auto-prove heuristic: could not find positive lim inf.');\n      assistant.value = 'Auto-prove failed: ' + auto.reason;\n      return;\n    }\n    const c = auto.c, n0 = auto.n0;\n    // verify strictly up to searchMax\n    const verify = checkProposition(fFn,gFn,c,n0,{searchMax:+searchMaxEl.value, cmp:cmpTypeEl.value});\n    if(verify.ok){\n      log('Auto-prove heuristic succeeded numerically: constants validated up to search limit.');\n      assistant.value = 'Numeric \"proof\": Verified f(n) ≥ ' + c + '·g(n) for all n in [' + n0 + ',' + verify.testedUpTo + '].\\\\nInterpretation: strong numeric evidence for Ω.';\n      cInput.value = c; n0Input.value = n0;\n      pushState();\n      renderAll();\n    } else {\n      log('Auto-prove check failed: violation at n=' + (verify.violations[0].n));\n      assistant.value = 'Auto-prove check failed: violation at n=' + verify.violations[0].n;\n    }\n  });\n\n  document.getElementById('findCounter').addEventListener('click', ()=> {\n    assistant.value = '';\n    let fFn,gFn;\n    try{\n      fFn = safeEvalFactory(fexprEl.value);\n      gFn = safeEvalFactory(gexprEl.value);\n    } catch(e){\n      log('Counterexample search failed: ' + e.message);\n      return;\n    }\n    const c = +cInput.value;\n    const n0 = +n0Input.value;\n    const searchMax = Math.min(+searchMaxEl.value, 1000000);\n    const res = findCounterexample(fFn,gFn,c,n0,searchMax);\n    if(res.found){\n      log('Counterexample found: n=' + res.n + ', f=' + res.f + ', g=' + res.g + ' (reason: ' + res.reason + ')');\n      assistant.value = 'Counterexample: n=' + res.n + ', f=' + res.f + ', g=' + res.g;\n      // set highlight in table by adjusting nmax to include it\n      nmaxEl.value = Math.max(+nmaxEl.value, res.n);\n      pushState();\n      renderAll();\n    } else {\n      log('No counterexample found in range up to ' + searchMax + '.');\n      assistant.value = 'No counterexample in inspected range.';\n    }\n  });\n\n  // Rendering everything: sampling, table, plot\n  function renderAll(){\n    // try to parse functions\n    let fFn, gFn;\n    try {\n      fFn = safeEvalFactory(fexprEl.value);\n      gFn = safeEvalFactory(gexprEl.value);\n    } catch(e){\n      tableOutput.value = 'Cannot render: ' + e.message;\n      ctx.clearRect(0,0,plot.width,plot.height);\n      return;\n    }\n    const nmin = Math.max(0, Math.floor(+nminEl.value || 1));\n    const nmax = Math.max(nmin+1, Math.floor(+nmaxEl.value || 200));\n    const sampleCount = Math.max(2, +sampleCountEl.value || Math.min(200, nmax-nmin+1));\n    const samples = sampleFunctions(fFn,gFn,{nmin:nmin, nmax:nmax, sampleCount:sampleCount});\n    // fill table\n    let lines = 'n\\tf(n)\\tg(n)\\tf/g\\n';\n    for(const s of samples){\n      lines += s.n + '\\t' + (isFinite(s.f)? s.f.toExponential(6): String(s.f)) + '\\t' + (isFinite(s.g)? s.g.toExponential(6): String(s.g)) + '\\t' + (isFinite(s.ratio)? s.ratio.toExponential(6): String(s.ratio)) + '\\\\n';\n    }\n    tableOutput.value = lines;\n    // plot\n    const c = (showBandEl.checked? (+cInput.value || 0) : null);\n    const n0 = +n0Input.value || null;\n    renderPlot(samples, c, n0);\n  }\n\n  // refine and auto step\n  function refineAndAuto(){\n    assistant.value = '';\n    let fFn,gFn;\n    try{\n      fFn = safeEvalFactory(fexprEl.value);\n      gFn = safeEvalFactory(gexprEl.value);\n    } catch(e){\n      log('Refine failed: ' + e.message);\n      return;\n    }\n    log('Refining... running auto-find then verify.');\n    const auto = autoFindConstants(fFn,gFn,{nmin:+nminEl.value, nmax:+nmaxEl.value});\n    if(!auto.found){\n      log('Refine: auto-find failed (' + auto.reason + '). Consider manual inspection or larger sampling range.');\n      assistant.value = 'Refine failed: ' + auto.reason;\n      return;\n    }\n    cInput.value = auto.c;\n    n0Input.value = auto.n0;\n    log('Auto-suggested c=' + auto.c + ', n0=' + auto.n0 + '. Verifying...');\n    const verify = checkProposition(fFn,gFn,auto.c,auto.n0,{searchMax:+searchMaxEl.value, cmp:cmpTypeEl.value});\n    if(verify.ok){\n      log('Verification OK up to ' + verify.testedUpTo + '.');\n      assistant.value = 'Refinement successful: numeric verification passed up to n=' + verify.testedUpTo + '.';\n    } else {\n      log('Verification failed. Violation at n=' + verify.violations[0].n);\n      assistant.value = 'Refinement failed: violation at n=' + verify.violations[0].n;\n    }\n    pushState();\n    renderAll();\n  }\n\n  function resetLab(){\n    fexprEl.value='n';\n    gexprEl.value='1';\n    nminEl.value=1;\n    nmaxEl.value=200;\n    cInput.value=1;\n    n0Input.value=1;\n    sampleCountEl.value=200;\n    searchMaxEl.value=10000;\n    cmpTypeEl.value='omega';\n    showBandEl.checked=true;\n    logScaleEl.checked=false;\n    showRatioEl.checked=false;\n    transcript.value='';\n    assistant.value='';\n    tableOutput.value='';\n    history = [];\n    future = [];\n    pushState();\n    renderAll();\n    log('Lab reset.');\n  }\n\n  // event listeners to re-render when fields change\n  ['fexpr','gexpr','nmin','nmax','sampleCount','showBand','logScale','showRatio','c_input','n0_input'].forEach(id=>{\n    const el = document.getElementById(id) || document.getElementById(id.replace('_',''));\n    if(!el) return;\n    el.addEventListener('change', ()=> { pushState(); renderAll(); });\n    el.addEventListener('input', ()=> { /* don't push history on every keystroke */ });\n  });\n\n  // provide gamma function for factorial-like example\n  // simple approximation using Lanczos or using Math.gamma if available; implement basic Lanczos gamma\n  (function(){\n    function gamma(z){\n      // Lanczos approximation\n      const p = [\n        676.5203681218851, -1259.1392167224028,\n        771.32342877765313, -176.61502916214059,\n        12.507343278686905, -0.13857109526572012,\n        9.9843695780195716e-6, 1.5056327351493116e-7\n      ];\n      if(z < 0.5) return Math.PI / (Math.sin(Math.PI*z) * gamma(1-z));\n      z -= 1;\n      let x = 0.99999999999980993;\n      for(let i=0;i<p.length;i++) x += p[i]/(z+1+i);\n      const t = z + p.length - 0.5;\n      return Math.sqrt(2*Math.PI)*Math.pow(t, z+0.5)*Math.exp(-t)*x;\n    }\n    // expose gamma to the global scope for user expressions via \"gamma(n+1)\" as used in example\n    window.gamma = gamma;\n  })();\n\n  // initialization\n  resetLab();\n  log('Interactive Big-Omega Lab ready. Use functions like n, n*n, n**2, log(n), sqrt(n), sin(n), 2**n, gamma(n+1).');\n})();\n</script>\n</body>\n</html>"
