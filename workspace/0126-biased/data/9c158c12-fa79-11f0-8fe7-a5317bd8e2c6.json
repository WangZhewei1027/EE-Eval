  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Indexing Interactive Playground</title>\n<style>\n/* Minimal styling only for spacing and layout; keep visual plain (black text on white, no colors) */\nbody { font-family: Arial, sans-serif; margin: 10px; color: black; background: white; }\nsection { margin-bottom: 16px; padding: 8px; border: 1px solid #00000010; }\nlabel { display: inline-block; margin-right: 8px; }\n.controls-row { margin-bottom: 8px; }\n.small { font-size: 12px; }\n.button { margin-right: 6px; }\ntextarea { width: 100%; height: 80px; }\ntextarea.small { height: 40px; }\n.codebox { white-space: pre-wrap; font-family: monospace; background: #ffffff; border: 1px solid #ccc; padding: 6px; }\n.leftcol { width: 32%; display: inline-block; vertical-align: top; }\n.midcol { width: 32%; display: inline-block; vertical-align: top; margin-left: 1%; }\n.rightcol { width: 34%; display: inline-block; vertical-align: top; margin-left: 1%; }\n.step { border: 1px dashed #00000010; padding: 6px; margin-bottom: 6px; }\n.step-controls { margin-top: 6px; }\n.listbox { max-height: 160px; overflow: auto; border: 1px solid #ccc; padding: 6px; }\n.kv { font-family: monospace; }\n.smallnote { font-size: 12px; color: black; }\ntable { border-collapse: collapse; width: 100%; font-size: 13px; }\nth, td { border: 1px solid #ddd; padding: 4px; text-align: left; }\n.result-snippet { font-family: monospace; font-size: 13px; }\n</style>\n</head>\n<body>\n\n<h2>Indexing Interactive Playground</h2>\n<p class=\"smallnote\">This page demonstrates many interactive index-building controls and workflows. Interface is intentionally plain.</p>\n\n<section>\n  <strong>1. Documents — Manage corpus</strong>\n  <div class=\"leftcol\">\n    <div class=\"controls-row\">\n      <label for=\"docIdInput\">Doc ID:</label>\n      <input id=\"docIdInput\" type=\"text\" placeholder=\"doc1\">\n      <button id=\"addDocBtn\" class=\"button\">Add / Update Doc</button>\n      <button id=\"clearDocsBtn\" class=\"button\">Clear All</button>\n    </div>\n    <div class=\"controls-row\">\n      <textarea id=\"docText\" placeholder=\"Enter document text here\"></textarea>\n    </div>\n    <div class=\"controls-row\">\n      <label>Import samples:</label>\n      <select id=\"sampleSelect\">\n        <option value=\"news\">News mini-corpus</option>\n        <option value=\"recipes\">Recipes mini-corpus</option>\n        <option value=\"short\">Short phrases</option>\n      </select>\n      <button id=\"importSampleBtn\">Import Sample</button>\n      <button id=\"generateRandomBtn\">Generate Random Docs</button>\n    </div>\n    <div class=\"controls-row\">\n      <strong>Documents in corpus</strong>\n      <div id=\"docList\" class=\"listbox\"></div>\n    </div>\n  </div>\n\n  <div class=\"midcol\">\n    <strong>2. Analysis Pipeline — Build and reorder steps</strong>\n    <div class=\"controls-row\">\n      <label for=\"addStepSelect\">Add step:</label>\n      <select id=\"addStepSelect\">\n        <option value=\"lowercase\">Lowercase</option>\n        <option value=\"removePunct\">Remove punctuation</option>\n        <option value=\"removeDiacritics\">Remove diacritics</option>\n        <option value=\"customStop\">Remove stopwords (custom)</option>\n        <option value=\"tokenize\">Tokenize (regex)</option>\n        <option value=\"minLength\">Min token length</option>\n        <option value=\"stemming\">Simple stemming</option>\n        <option value=\"ngram\">Generate n-grams</option>\n      </select>\n      <button id=\"addStepBtn\">Add Step</button>\n      <button id=\"resetPipelineBtn\">Reset Pipeline</button>\n    </div>\n    <div id=\"pipeline\" class=\"listbox\"></div>\n\n    <div class=\"controls-row\">\n      <label for=\"applyPipelineDocs\">Apply pipeline to:</label>\n      <select id=\"applyPipelineDocs\">\n        <option value=\"all\">All documents</option>\n        <option value=\"selected\">Only selected doc</option>\n      </select>\n      <button id=\"applyPipelineBtn\">Apply Pipeline</button>\n      <button id=\"previewTokenBtn\">Preview Tokens (selected)</button>\n    </div>\n    <div id=\"pipelinePreview\" class=\"codebox small\"></div>\n  </div>\n\n  <div class=\"rightcol\">\n    <strong>3. Index Builder & Options</strong>\n    <div class=\"controls-row\">\n      <input id=\"includePositions\" type=\"checkbox\" checked> <label for=\"includePositions\">Include term positions</label><br>\n      <input id=\"buildKGram\" type=\"checkbox\"> <label for=\"buildKGram\">Build k-gram index (for wildcard)</label>\n      <label for=\"kGramK\">k:</label> <input id=\"kGramK\" type=\"number\" value=\"3\" min=\"1\" style=\"width:50px\">\n    </div>\n    <div class=\"controls-row\">\n      <label for=\"minTermFreq\">Min term freq (global):</label>\n      <input id=\"minTermFreq\" type=\"number\" value=\"1\" min=\"1\" style=\"width:60px\">\n      <label for=\"minDocFreq\">Min doc freq:</label>\n      <input id=\"minDocFreq\" type=\"number\" value=\"1\" min=\"1\" style=\"width:60px\">\n    </div>\n    <div class=\"controls-row\">\n      <button id=\"buildIndexBtn\">Build Index</button>\n      <button id=\"snapshotBtn\">Snapshot Index</button>\n      <button id=\"clearIndexBtn\">Clear Index</button>\n    </div>\n    <div class=\"controls-row\">\n      <strong>Snapshots</strong>\n      <div id=\"snapshotsList\" class=\"listbox small\"></div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <strong>4. Index Views & Exploration</strong>\n  <div class=\"controls-row\">\n    <label for=\"termFilter\">Filter terms (regex or prefix):</label>\n    <input id=\"termFilter\" type=\"text\" placeholder=\"e.g., ^the|ing$|pre*\">\n    <button id=\"refreshTermView\">Refresh</button>\n    <label for=\"topNterms\">Top N:</label>\n    <input id=\"topNterms\" type=\"number\" value=\"50\" style=\"width:60px\">\n  </div>\n  <div id=\"termTableContainer\" class=\"listbox\" style=\"max-height:250px; overflow:auto;\"></div>\n  <div class=\"controls-row\">\n    <button id=\"exportIndexBtn\">Export Index JSON</button>\n    <input id=\"importIndexFile\" type=\"file\">\n    <button id=\"importIndexBtn\">Import Index from File</button>\n  </div>\n</section>\n\n<section>\n  <strong>5. Search & Query</strong>\n  <div class=\"controls-row\">\n    <input id=\"queryInput\" type=\"text\" placeholder=\"Enter query (AND, OR, NOT, \\\"phrase\\\", wildcard * , fuzzy ~ )\" style=\"width:60%\">\n    <select id=\"queryMode\">\n      <option value=\"boolean\">Boolean</option>\n      <option value=\"ranked\">Ranked (tf-idf)</option>\n      <option value=\"phrase\">Phrase</option>\n      <option value=\"proximity\">Proximity</option>\n      <option value=\"wildcard\">Wildcard</option>\n    </select>\n    <button id=\"searchBtn\">Search</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label for=\"topK\">Top-K:</label>\n    <input id=\"topK\" type=\"number\" value=\"10\" min=\"1\" style=\"width:60px\">\n    <label><input id=\"useTfIdf\" type=\"checkbox\" checked> Use tf-idf for ranking</label>\n    <label><input id=\"normLength\" type=\"checkbox\" checked> Normalize by doc length</label>\n    <label for=\"fuzzyThreshold\">Fuzzy threshold:</label>\n    <input id=\"fuzzyThreshold\" type=\"number\" value=\"1\" min=\"0\" max=\"5\" style=\"width:50px\">\n  </div>\n\n  <div>\n    <div id=\"searchResults\" class=\"listbox\" style=\"max-height:300px;\"></div>\n  </div>\n</section>\n\n<section>\n  <strong>6. Advanced Tools & Utilities</strong>\n  <div class=\"controls-row\">\n    <button id=\"showTermStatsBtn\">Show overall stats</button>\n    <button id=\"compareSnapshotsBtn\">Compare last two snapshots</button>\n    <button id=\"undoBtn\">Undo last action</button>\n    <button id=\"redoBtn\">Redo</button>\n  </div>\n  <div id=\"advancedOutput\" class=\"codebox small\"></div>\n</section>\n\n<script>\n// Data models\nlet docs = {}; // docId -> {text, tokens (last processed), active:true}\nlet pipeline = []; // list of steps {type, params}\nlet index = null; // built index object\nlet kgramIndex = null;\nlet snapshots = [];\nlet history = [];\nlet redoStack = [];\n\n// Basic stopwords for demo\nconst DEFAULT_STOPWORDS = new Set([\n  \"the\",\"is\",\"at\",\"which\",\"on\",\"and\",\"a\",\"an\",\"in\",\"to\",\"for\",\"of\",\"with\",\"that\",\"this\",\"it\",\"as\"\n]);\n\n// Utilities\nfunction saveHistory(action) {\n  history.push(JSON.stringify({docs, pipeline, index, kgramIndex, snapshots}));\n  if (history.length > 200) history.shift();\n  redoStack = [];\n}\nfunction undo() {\n  if (!history.length) return;\n  redoStack.push(JSON.stringify({docs, pipeline, index, kgramIndex, snapshots}));\n  let s = history.pop();\n  let obj = JSON.parse(s);\n  docs = obj.docs;\n  pipeline = obj.pipeline;\n  index = obj.index;\n  kgramIndex = obj.kgramIndex;\n  snapshots = obj.snapshots;\n  refreshAll();\n}\nfunction redo() {\n  if (!redoStack.length) return;\n  history.push(JSON.stringify({docs, pipeline, index, kgramIndex, snapshots}));\n  let s = redoStack.pop();\n  let obj = JSON.parse(s);\n  docs = obj.docs;\n  pipeline = obj.pipeline;\n  index = obj.index;\n  kgramIndex = obj.kgramIndex;\n  snapshots = obj.snapshots;\n  refreshAll();\n}\n\nfunction refreshAll() {\n  renderDocList();\n  renderPipeline();\n  renderSnapshots();\n  renderTermTable();\n  renderAdvancedOutput(\"Refreshed.\");\n}\n\nfunction simpleStem(word) {\n  // very naive suffix stripper\n  const suffixes = [\"ing\",\"edly\",\"edly\",\"edly\",\"ed\",\"es\",\"s\",\"ly\",\"ment\",\"ness\",\"able\",\"ible\"];\n  for (let suf of suffixes) {\n    if (word.length - suf.length >= 2 && word.endsWith(suf)) {\n      return word.slice(0, -suf.length);\n    }\n  }\n  return word;\n}\n\nfunction removeDiacritics(str) {\n  // basic replacement\n  return str.normalize ? str.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\") : str;\n}\n\nfunction tokenizeWithRegex(text, regexStr) {\n  try {\n    let re = new RegExp(regexStr, \"g\");\n    let matches = [];\n    let m;\n    while ((m = re.exec(text)) !== null) {\n      matches.push({token: m[0], index: m.index});\n      if (re.lastIndex === m.index) re.lastIndex++;\n    }\n    return matches;\n  } catch (e) {\n    // fallback to whitespace\n    let parts = text.split(/\\s+/);\n    let res = [];\n    let idx = 0;\n    for (let p of parts) { if (p) { let i = text.indexOf(p, idx); res.push({token:p, index:i}); idx = i + p.length; } }\n    return res;\n  }\n}\n\nfunction applyPipelineToText(text, docIdForPositions=null) {\n  let state = {text: text, tokens: [{token:text, start:0}]};// initial\n  for (let step of pipeline) {\n    if (step.type === \"lowercase\") {\n      state.text = state.text.toLowerCase();\n      state.tokens = [{token: state.text, start: 0}];\n    } else if (step.type === \"removePunct\") {\n      state.text = state.text.replace(/[^\\w\\s]|_/g, \" \");\n      state.tokens = [{token: state.text, start: 0}];\n    } else if (step.type === \"removeDiacritics\") {\n      state.text = removeDiacritics(state.text);\n      state.tokens = [{token: state.text, start: 0}];\n    } else if (step.type === \"customStop\") {\n      // will remove tokens later in tokenization step\n      // store param in pipeline step\n    } else if (step.type === \"tokenize\") {\n      let regexStr = step.params.regex || \"\\\\w+\";\n      let matches = tokenizeWithRegex(state.text, regexStr);\n      let toks = matches.map(m => ({token: m.token, start: m.index}));\n      state.tokens = toks;\n    } else if (step.type === \"minLength\") {\n      let minL = step.params.min || 1;\n      if (!state.tokens) { state.tokens = [{token: state.text, start:0}]; }\n      state.tokens = state.tokens.filter(t => t.token.length >= minL);\n    } else if (step.type === \"stemming\") {\n      if (!state.tokens) state.tokens = [{token:state.text, start:0}];\n      state.tokens = state.tokens.map(t => ({token: simpleStem(t.token), start: t.start}));\n    } else if (step.type === \"ngram\") {\n      // generate n-grams from tokens\n      let n = step.params.n || 2;\n      let toks = state.tokens || [{token:state.text, start:0}];\n      let words = toks.map(t => t.token);\n      let grams = [];\n      for (let i=0;i+ n <= words.length;i++){\n        let g = words.slice(i,i+n).join(\" \");\n        grams.push({token: g, start: toks[i].start});\n      }\n      state.tokens = state.tokens.concat(grams);\n    }\n  }\n  // Post-process: remove stopwords if any customStop step exists\n  let customStops = new Set();\n  for (let s of pipeline) {\n    if (s.type === \"customStop\") {\n      let list = (s.params.list || \"\").split(/\\s*,\\s*|\\s+/).filter(Boolean);\n      for (let w of list) customStops.add(w.toLowerCase());\n      if (s.params.useDefault) for (let w of DEFAULT_STOPWORDS) customStops.add(w);\n    }\n  }\n  let finalTokens = (state.tokens && state.tokens.length) ? state.tokens.map(t=>t.token) : [state.text];\n  // remove empties\n  let res = [];\n  let pos = 0;\n  for (let t of state.tokens) {\n    if (!t.token) continue;\n    let token = t.token;\n    if (customStops.has(token.toLowerCase())) continue;\n    res.push({token: token, start: t.start});\n  }\n  return res;\n}\n\n// Document management\nfunction addOrUpdateDoc() {\n  let id = document.getElementById(\"docIdInput\").value.trim();\n  let text = document.getElementById(\"docText\").value;\n  if (!id) {\n    alert(\"Provide a document ID.\");\n    return;\n  }\n  saveHistory(\"addDoc\");\n  docs[id] = {text: text, tokens: [], active: true};\n  renderDocList();\n}\n\nfunction renderDocList() {\n  let container = document.getElementById(\"docList\");\n  container.innerHTML = \"\";\n  let keys = Object.keys(docs);\n  if (!keys.length) { container.textContent = \"(no documents)\"; return; }\n  for (let k of keys) {\n    let d = docs[k];\n    let div = document.createElement(\"div\");\n    div.style.marginBottom = \"6px\";\n    let re = document.createElement(\"input\");\n    re.type = \"checkbox\";\n    re.checked = !!d.active;\n    re.onchange = () => { d.active = re.checked; };\n    let title = document.createElement(\"span\");\n    title.textContent = \" \" + k + \" \";\n    let btnEdit = document.createElement(\"button\");\n    btnEdit.textContent = \"Edit\";\n    btnEdit.onclick = () => {\n      document.getElementById(\"docIdInput\").value = k;\n      document.getElementById(\"docText\").value = d.text;\n    };\n    let btnDelete = document.createElement(\"button\");\n    btnDelete.textContent = \"Delete\";\n    btnDelete.onclick = () => {\n      saveHistory(\"delDoc\");\n      delete docs[k];\n      renderDocList();\n    };\n    let btnPreview = document.createElement(\"button\");\n    btnPreview.textContent = \"Preview Tokens\";\n    btnPreview.onclick = () => {\n      let tokens = applyPipelineToText(d.text, k);\n      document.getElementById(\"pipelinePreview\").textContent = JSON.stringify(tokens, null, 2);\n    };\n    div.appendChild(re);\n    div.appendChild(title);\n    div.appendChild(btnEdit);\n    div.appendChild(btnDelete);\n    div.appendChild(btnPreview);\n    container.appendChild(div);\n  }\n}\n\n// Sample import & generation\ndocument.getElementById(\"importSampleBtn\").addEventListener(\"click\", () => {\n  let val = document.getElementById(\"sampleSelect\").value;\n  saveHistory(\"importSample\");\n  if (val === \"news\") {\n    docs[\"doc_news_1\"] = {text: \"The council met to discuss housing and planning issues in the downtown area.\", tokens: [], active:true};\n    docs[\"doc_news_2\"] = {text: \"A new development project includes affordable apartments and community spaces.\", tokens: [], active:true};\n    docs[\"doc_news_3\"] = {text: \"Planning officials emphasized sustainability and long-term investment.\", tokens: [], active:true};\n  } else if (val === \"recipes\") {\n    docs[\"doc_recipe_1\"] = {text: \"Preheat oven to 350 degrees. Mix flour, sugar, and eggs for the cake batter.\", tokens: [], active:true};\n    docs[\"doc_recipe_2\"] = {text: \"Combine olive oil, garlic, and herbs for the marinade. Grill chicken until golden.\", tokens: [], active:true};\n    docs[\"doc_recipe_3\"] = {text: \"Boil pasta until al dente then toss with tomato sauce and basil.\", tokens: [], active:true};\n  } else {\n    docs[\"p1\"] = {text: \"Quick brown fox jumps over the lazy dog.\", tokens: [], active:true};\n    docs[\"p2\"] = {text: \"Lazy dogs prefer quiet afternoons and naps.\", tokens: [], active:true};\n    docs[\"p3\"] = {text: \"Quick recipes save time in the kitchen.\", tokens: [], active:true};\n  }\n  renderDocList();\n});\n\ndocument.getElementById(\"generateRandomBtn\").addEventListener(\"click\", () => {\n  saveHistory(\"genRandom\");\n  const words = [\"alpha\",\"beta\",\"gamma\",\"delta\",\"epsilon\",\"quick\",\"brown\",\"fox\",\"lazy\",\"dog\",\"kitchen\",\"cook\",\"plan\",\"invest\",\"build\"];\n  for (let i=0;i<5;i++){\n    let id = \"rnd_\" + Date.now().toString(36) + \"_\" + i;\n    let len = 8 + Math.floor(Math.random()*20);\n    let s = [];\n    for (let j=0;j<len;j++) s.push(words[Math.floor(Math.random()*words.length)]);\n    docs[id] = {text: s.join(\" \"), tokens: [], active:true};\n  }\n  renderDocList();\n});\n\ndocument.getElementById(\"clearDocsBtn\").addEventListener(\"click\", () => {\n  if (!confirm(\"Clear all documents?\")) return;\n  saveHistory(\"clearDocs\");\n  docs = {};\n  renderDocList();\n});\n\n// Pipeline controls\nfunction renderPipeline() {\n  let container = document.getElementById(\"pipeline\");\n  container.innerHTML = \"\";\n  if (!pipeline.length) container.textContent = \"(no steps)\";\n  pipeline.forEach((step, idx) => {\n    let div = document.createElement(\"div\");\n    div.className = \"step\";\n    let h = document.createElement(\"div\");\n    h.textContent = (idx+1) + \". \" + step.type;\n    div.appendChild(h);\n    let paramsDiv = document.createElement(\"div\");\n    paramsDiv.className = \"step-controls\";\n    if (step.type === \"customStop\") {\n      let ta = document.createElement(\"textarea\");\n      ta.className = \"small\";\n      ta.value = step.params.list || \"\";\n      ta.placeholder = \"comma or whitespace separated stopwords\";\n      ta.onchange = () => { step.params.list = ta.value; };\n      paramsDiv.appendChild(document.createTextNode(\"Stopwords:\"));\n      paramsDiv.appendChild(ta);\n      let cb = document.createElement(\"input\");\n      cb.type = \"checkbox\";\n      cb.checked = !!step.params.useDefault;\n      cb.onchange = () => { step.params.useDefault = cb.checked; };\n      paramsDiv.appendChild(cb);\n      paramsDiv.appendChild(document.createTextNode(\" use default stopwords\"));\n    } else if (step.type === \"tokenize\") {\n      paramsDiv.appendChild(document.createTextNode(\"Regex:\"));\n      let inp = document.createElement(\"input\");\n      inp.type = \"text\";\n      inp.value = step.params.regex || \"\\\\w+\";\n      inp.onchange = () => { step.params.regex = inp.value; };\n      paramsDiv.appendChild(inp);\n    } else if (step.type === \"minLength\") {\n      paramsDiv.appendChild(document.createTextNode(\"Min length: \"));\n      let inp = document.createElement(\"input\");\n      inp.type = \"number\";\n      inp.value = step.params.min || 1;\n      inp.style.width = \"60px\";\n      inp.onchange = () => { step.params.min = Math.max(0, parseInt(inp.value)||0); };\n      paramsDiv.appendChild(inp);\n    } else if (step.type === \"ngram\") {\n      paramsDiv.appendChild(document.createTextNode(\"n: \"));\n      let inp = document.createElement(\"input\");\n      inp.type = \"number\";\n      inp.value = step.params.n || 2;\n      inp.style.width = \"60px\";\n      inp.onchange = () => { step.params.n = Math.max(1, parseInt(inp.value)||1); };\n      paramsDiv.appendChild(inp);\n    } else {\n      paramsDiv.textContent = \"(no params)\";\n    }\n    let btnUp = document.createElement(\"button\");\n    btnUp.textContent = \"Up\";\n    btnUp.onclick = () => { if (idx>0) { saveHistory(\"stepUp\"); [pipeline[idx-1], pipeline[idx]] = [pipeline[idx], pipeline[idx-1]]; renderPipeline(); } };\n    let btnDown = document.createElement(\"button\");\n    btnDown.textContent = \"Down\";\n    btnDown.onclick = () => { if (idx < pipeline.length-1) { saveHistory(\"stepDown\"); [pipeline[idx+1], pipeline[idx]] = [pipeline[idx], pipeline[idx+1]]; renderPipeline(); } };\n    let btnRemove = document.createElement(\"button\");\n    btnRemove.textContent = \"Remove\";\n    btnRemove.onclick = () => { saveHistory(\"stepRemove\"); pipeline.splice(idx,1); renderPipeline(); };\n    paramsDiv.appendChild(document.createElement(\"br\"));\n    paramsDiv.appendChild(btnUp); paramsDiv.appendChild(btnDown); paramsDiv.appendChild(btnRemove);\n    div.appendChild(paramsDiv);\n    container.appendChild(div);\n  });\n}\n\ndocument.getElementById(\"addStepBtn\").addEventListener(\"click\", () => {\n  let sel = document.getElementById(\"addStepSelect\").value;\n  let step = {type: sel, params: {}};\n  if (sel === \"tokenize\") step.params.regex = \"\\\\w+\";\n  if (sel === \"minLength\") step.params.min = 2;\n  if (sel === \"ngram\") step.params.n = 2;\n  if (sel === \"customStop\") step.params = {list: \"\", useDefault: true};\n  saveHistory(\"addStep\");\n  pipeline.push(step);\n  renderPipeline();\n});\n\ndocument.getElementById(\"resetPipelineBtn\").addEventListener(\"click\", () => {\n  if (!confirm(\"Reset pipeline to empty?\")) return;\n  saveHistory(\"resetPipeline\");\n  pipeline = [];\n  renderPipeline();\n});\n\ndocument.getElementById(\"applyPipelineBtn\").addEventListener(\"click\", () => {\n  let mode = document.getElementById(\"applyPipelineDocs\").value;\n  saveHistory(\"applyPipeline\");\n  if (mode === \"all\") {\n    for (let id in docs) {\n      if (!docs[id].active) continue;\n      let toks = applyPipelineToText(docs[id].text, id);\n      docs[id].tokens = toks;\n    }\n    renderAdvancedOutput(\"Applied pipeline to all active documents.\");\n  } else {\n    // selected doc is using docIdInput\n    let id = document.getElementById(\"docIdInput\").value.trim();\n    if (!id || !docs[id]) { alert(\"Select a document ID that exists.\"); return; }\n    docs[id].tokens = applyPipelineToText(docs[id].text, id);\n    renderAdvancedOutput(\"Applied pipeline to document \" + id);\n  }\n  renderDocList();\n});\n\ndocument.getElementById(\"previewTokenBtn\").addEventListener(\"click\", () => {\n  let id = document.getElementById(\"docIdInput\").value.trim();\n  if (!id || !docs[id]) { alert(\"Provide an existing doc ID in the Doc ID field to preview.\"); return; }\n  let toks = applyPipelineToText(docs[id].text, id);\n  document.getElementById(\"pipelinePreview\").textContent = JSON.stringify(toks, null, 2);\n});\n\n// Index building\nfunction buildIndex() {\n  saveHistory(\"buildIndex\");\n  let includePositions = document.getElementById(\"includePositions\").checked;\n  let buildK = document.getElementById(\"buildKGram\").checked;\n  let k = Math.max(1, parseInt(document.getElementById(\"kGramK\").value) || 3);\n  let minTermFreq = Math.max(1, parseInt(document.getElementById(\"minTermFreq\").value) || 1);\n  let minDocFreq = Math.max(1, parseInt(document.getElementById(\"minDocFreq\").value) || 1);\n\n  let inv = {}; // term -> {totalFreq, docFreq, postings: {docId: {tf, positions[]}}}\n  let docLengths = {}; // docId -> total tokens (for normalization)\n  let docCountActive = 0;\n  for (let id in docs) {\n    if (!docs[id].active) continue;\n    docCountActive++;\n    let tokens = docs[id].tokens && docs[id].tokens.length ? docs[id].tokens : applyPipelineToText(docs[id].text, id);\n    docs[id].tokens = tokens.slice(); // store processed tokens\n    docLengths[id] = tokens.length;\n    let pos = 0;\n    for (let t of tokens) {\n      let term = String(t.token);\n      if (!inv[term]) inv[term] = {totalFreq:0, postings: {}};\n      inv[term].totalFreq += 1;\n      if (!inv[term].postings[id]) inv[term].postings[id] = {tf:0, positions: []};\n      inv[term].postings[id].tf += 1;\n      inv[term].postings[id].positions.push(t.start || pos);\n      pos++;\n    }\n  }\n  // compute docFreq and enforce mins\n  for (let term in inv) {\n    inv[term].docFreq = Object.keys(inv[term].postings).length;\n  }\n  // Apply min filters\n  for (let term of Object.keys(inv)) {\n    if (inv[term].totalFreq < minTermFreq || inv[term].docFreq < minDocFreq) {\n      delete inv[term];\n    }\n  }\n  // compute idf and tf-idf vectors\n  let docVectors = {}; // docId -> {term: tfidf}\n  for (let term in inv) {\n    let df = inv[term].docFreq;\n    let idf = Math.log(1 + (docCountActive / (df || 1)));\n    inv[term].idf = idf;\n    for (let docId in inv[term].postings) {\n      let tf = inv[term].postings[docId].tf;\n      let tfw = 1 + Math.log(tf);\n      let tfidf = tfw * idf;\n      if (!docVectors[docId]) docVectors[docId] = {};\n      docVectors[docId][term] = tfidf;\n    }\n  }\n  index = {inverted: inv, docVectors: docVectors, docLengths: docLengths, docCount: docCountActive, builtAt: Date.now()};\n  // k-gram index\n  kgramIndex = null;\n  if (buildK) {\n    kgramIndex = {};\n    for (let term in inv) {\n      let ext = \"^\" + term + \"$\";\n      let padded = \"$\" + term + \"$\";\n      for (let i=0;i<=padded.length - k;i++) {\n        let gram = padded.slice(i,i+k);\n        if (!kgramIndex[gram]) kgramIndex[gram] = new Set();\n        kgramIndex[gram].add(term);\n      }\n    }\n    // convert sets to arrays for portability\n    for (let g in kgramIndex) kgramIndex[g] = Array.from(kgramIndex[g]);\n  }\n  renderAdvancedOutput(\"Index built. Terms: \" + Object.keys(index.inverted).length + \". Docs indexed: \" + (index.docCount || 0));\n  renderTermTable();\n}\n\ndocument.getElementById(\"buildIndexBtn\").addEventListener(\"click\", () => {\n  buildIndex();\n});\n\ndocument.getElementById(\"clearIndexBtn\").addEventListener(\"click\", () => {\n  if (!confirm(\"Clear index?\")) return;\n  saveHistory(\"clearIndex\");\n  index = null;\n  kgramIndex = null;\n  renderTermTable();\n  renderAdvancedOutput(\"Index cleared.\");\n});\n\ndocument.getElementById(\"snapshotBtn\").addEventListener(\"click\", () => {\n  if (!index) { alert(\"Build an index first.\"); return; }\n  saveHistory(\"snapshot\");\n  let snap = {\n    id: \"snap_\" + Date.now().toString(36),\n    index: JSON.parse(JSON.stringify(index)),\n    kgramIndex: kgramIndex ? JSON.parse(JSON.stringify(kgramIndex)) : null,\n    pipeline: JSON.parse(JSON.stringify(pipeline)),\n    docsSummary: Object.keys(docs).length,\n    ts: Date.now()\n  };\n  snapshots.push(snap);\n  renderSnapshots();\n});\n\nfunction renderSnapshots() {\n  let container = document.getElementById(\"snapshotsList\");\n  container.innerHTML = \"\";\n  if (!snapshots.length) { container.textContent = \"(no snapshots)\"; return; }\n  for (let i = snapshots.length-1; i>=0; i--) {\n    let s = snapshots[i];\n    let div = document.createElement(\"div\");\n    div.style.marginBottom = \"6px\";\n    div.textContent = s.id + \" - terms:\" + Object.keys(s.index.inverted).length + \" docs:\" + s.index.docCount;\n    let btnLoad = document.createElement(\"button\");\n    btnLoad.textContent = \"Load\";\n    btnLoad.onclick = () => {\n      saveHistory(\"loadSnapshot\");\n      index = JSON.parse(JSON.stringify(s.index));\n      kgramIndex = s.kgramIndex ? JSON.parse(JSON.stringify(s.kgramIndex)) : null;\n      pipeline = JSON.parse(JSON.stringify(s.pipeline));\n      renderAll();\n    };\n    let btnDel = document.createElement(\"button\");\n    btnDel.textContent = \"Delete\";\n    btnDel.onclick = () => { if (confirm(\"Delete snapshot \" + s.id + \"?\")) { saveHistory(\"delSnap\"); snapshots = snapshots.filter(x=>x!==s); renderSnapshots(); } };\n    div.appendChild(btnLoad);\n    div.appendChild(btnDel);\n    container.appendChild(div);\n  }\n}\n\n// Term / index view\nfunction renderTermTable() {\n  let container = document.getElementById(\"termTableContainer\");\n  container.innerHTML = \"\";\n  if (!index || !index.inverted) { container.textContent = \"(no index built)\"; return; }\n  let filter = document.getElementById(\"termFilter\").value.trim();\n  let topN = Math.max(1, parseInt(document.getElementById(\"topNterms\").value) || 50);\n  let terms = Object.keys(index.inverted);\n  // apply filter heuristics: support prefix* wildcard or regex\n  if (filter) {\n    if (filter.includes(\"*\")) {\n      let pat = \"^\" + filter.replace(/\\*/g, \".*\") + \"$\";\n      let re = new RegExp(pat);\n      terms = terms.filter(t => re.test(t));\n    } else {\n      try {\n        let re = new RegExp(filter);\n        terms = terms.filter(t => re.test(t));\n      } catch (e) {\n        terms = terms.filter(t => t.indexOf(filter) !== -1);\n      }\n    }\n  }\n  terms.sort((a,b) => (index.inverted[b].totalFreq - index.inverted[a].totalFreq));\n  terms = terms.slice(0, topN);\n  let tbl = document.createElement(\"table\");\n  let thead = document.createElement(\"tr\");\n  thead.innerHTML = \"<th>Term</th><th>TotalFreq</th><th>DocFreq</th><th>Postings (preview)</th><th>Actions</th>\";\n  tbl.appendChild(thead);\n  for (let term of terms) {\n    let row = document.createElement(\"tr\");\n    let td1 = document.createElement(\"td\"); td1.textContent = term;\n    let td2 = document.createElement(\"td\"); td2.textContent = index.inverted[term].totalFreq;\n    let td3 = document.createElement(\"td\"); td3.textContent = index.inverted[term].docFreq;\n    let td4 = document.createElement(\"td\");\n    td4.textContent = Object.keys(index.inverted[term].postings).slice(0,5).join(\", \");\n    let td5 = document.createElement(\"td\");\n    let btnShow = document.createElement(\"button\"); btnShow.textContent = \"Show\";\n    btnShow.onclick = () => { showTermDetails(term); };\n    let btnFindDocs = document.createElement(\"button\"); btnFindDocs.textContent = \"Find in docs\";\n    btnFindDocs.onclick = () => { let docsFound = Object.keys(index.inverted[term].postings); if (docsFound.length) highlightDocs(docsFound, term); else alert(\"No docs.\"); };\n    td5.appendChild(btnShow); td5.appendChild(btnFindDocs);\n    row.appendChild(td1); row.appendChild(td2); row.appendChild(td3); row.appendChild(td4); row.appendChild(td5);\n    tbl.appendChild(row);\n  }\n  container.appendChild(tbl);\n}\n\nfunction showTermDetails(term) {\n  if (!index || !index.inverted[term]) { alert(\"Term not found.\"); return; }\n  let obj = index.inverted[term];\n  let out = [];\n  out.push(\"Term: \" + term);\n  out.push(\"Total frequency: \" + obj.totalFreq);\n  out.push(\"Document frequency: \" + obj.docFreq);\n  out.push(\"IDF: \" + (obj.idf || 0));\n  out.push(\"Postings:\");\n  for (let docId in obj.postings) {\n    out.push(\"  \" + docId + \" -> tf=\" + obj.postings[docId].tf + \" positions=\" + JSON.stringify(obj.postings[docId].positions));\n  }\n  renderAdvancedOutput(out.join(\"\\n\"));\n}\n\nfunction highlightDocs(docIds, term) {\n  // show doc contents with highlights in a popup-like area (in advanced output)\n  let out = [];\n  for (let id of docIds) {\n    let text = docs[id].text;\n    let toks = docs[id].tokens && docs[id].tokens.length ? docs[id].tokens : applyPipelineToText(text, id);\n    let snippet = text;\n    // naive highlight: show positions of term tokens\n    let positions = [];\n    for (let t of toks) {\n      if (String(t.token) === term) positions.push(t.start);\n    }\n    out.push(\"Doc: \" + id);\n    if (positions.length) {\n      out.push(\"Positions: \" + positions.join(\", \"));\n      // show small snippet around first position (fallback if start indexes not accurate)\n      let first = positions[0] || 0;\n      let s = Math.max(0, first - 30);\n      let e = Math.min(text.length, first + 60);\n      let raw = text.slice(s,e);\n      // mark token occurrences by surrounding with [* *]\n      let display = raw.split(new RegExp(\"(\" + escapeRegExp(term) + \")\", \"gi\")).map((chunk,i) => {\n        if (i%2===1) return \"[*\"+chunk+\"*]\"; else return chunk;\n      }).join(\"\");\n      out.push(display);\n    } else {\n      out.push(\"No exact token positions after pipeline; showing raw:\");\n      out.push(snippet.slice(0,200));\n    }\n    out.push(\"----\");\n  }\n  renderAdvancedOutput(out.join(\"\\n\"));\n}\n\nfunction escapeRegExp(string) {\n  return string.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\n// Search & query\ndocument.getElementById(\"searchBtn\").addEventListener(\"click\", () => {\n  let q = document.getElementById(\"queryInput\").value.trim();\n  if (!q) { alert(\"Enter a query.\"); return; }\n  if (!index) { alert(\"Build an index first.\"); return; }\n  let mode = document.getElementById(\"queryMode\").value;\n  if (mode === \"boolean\") performBooleanQuery(q);\n  else if (mode === \"ranked\") performRankedQuery(q);\n  else if (mode === \"phrase\") performPhraseQuery(q);\n  else if (mode === \"proximity\") performProximityQuery(q);\n  else if (mode === \"wildcard\") performWildcardQuery(q);\n});\n\nfunction performBooleanQuery(q) {\n  // very simple boolean parser: tokens, AND, OR, NOT, parentheses\n  try {\n    let tokens = tokenizeBoolean(q);\n    let postfix = shuntingYard(tokens);\n    let resultSet = evalPostfix(postfix);\n    showResults(Array.from(resultSet));\n  } catch (e) {\n    renderAdvancedOutput(\"Boolean parse error: \" + e.message);\n  }\n}\n\nfunction tokenizeBoolean(q) {\n  // split into words and operators\n  let parts = [];\n  let i=0;\n  while (i<q.length) {\n    let c = q[i];\n    if (/\\s/.test(c)) { i++; continue; }\n    if (c === '(' || c === ')') { parts.push({type:'paren', val:c}); i++; continue;}\n    if (q.slice(i).toUpperCase().startsWith(\"AND\")) { parts.push({type:'op', val:'AND'}); i+=3; continue; }\n    if (q.slice(i).toUpperCase().startsWith(\"OR\")) { parts.push({type:'op', val:'OR'}); i+=2; continue; }\n    if (q.slice(i).toUpperCase().startsWith(\"NOT\")) { parts.push({type:'op', val:'NOT'}); i+=3; continue; }\n    // phrase\n    if (c === '\"') {\n      let j = q.indexOf('\"', i+1);\n      if (j === -1) j = q.length;\n      let phrase = q.slice(i+1, j);\n      parts.push({type:'term', val:phrase});\n      i = j+1; continue;\n    }\n    // otherwise read a token\n    let m = q.slice(i).match(/^[^\\s()]+/);\n    if (m) {\n      parts.push({type:'term', val:m[0]});\n      i += m[0].length;\n    } else i++;\n  }\n  return parts;\n}\n\nfunction shuntingYard(tokens) {\n  let out = [], ops = [];\n  let prec = { 'NOT':3, 'AND':2, 'OR':1 };\n  for (let t of tokens) {\n    if (t.type === 'term') out.push(t);\n    else if (t.type === 'op') {\n      while (ops.length && ops[ops.length-1].type === 'op' && prec[ops[ops.length-1].val] >= prec[t.val]) {\n        out.push(ops.pop());\n      }\n      ops.push(t);\n    } else if (t.type === 'paren') {\n      if (t.val === '(') ops.push(t);\n      else {\n        while (ops.length && ops[ops.length-1].val !== '(') out.push(ops.pop());\n        ops.pop();\n      }\n    }\n  }\n  while (ops.length) out.push(ops.pop());\n  return out;\n}\n\nfunction evalPostfix(postfix) {\n  let stack = [];\n  for (let token of postfix) {\n    if (token.type === 'term') {\n      // resolve term -> set of docs\n      let term = token.val;\n      let set = new Set();\n      // phrase? if contains space detect phrase search\n      if (term.indexOf(' ') !== -1) {\n        let docsFound = phraseSearchDocs(term);\n        for (let d of docsFound) set.add(d);\n      } else {\n        // exact term or fallback fuzzy\n        if (index.inverted[term]) {\n          for (let d in index.inverted[term].postings) set.add(d);\n        } else {\n          // try lowercase\n          if (index.inverted[term.toLowerCase()]) {\n            for (let d in index.inverted[term.toLowerCase()].postings) set.add(d);\n          }\n        }\n      }\n      stack.push(set);\n    } else if (token.type === 'op') {\n      if (token.val === 'NOT') {\n        let a = stack.pop();\n        let all = new Set(Object.keys(docs).filter(id=>docs[id].active));\n        for (let x of a) all.delete(x);\n        stack.push(all);\n      } else {\n        let b = stack.pop(); let a = stack.pop();\n        if (!a) a = new Set();\n        if (!b) b = new Set();\n        if (token.val === 'AND') {\n          let res = new Set([...a].filter(x=>b.has(x)));\n          stack.push(res);\n        } else if (token.val === 'OR') {\n          let res = new Set([...a, ...b]);\n          stack.push(res);\n        }\n      }\n    }\n  }\n  return stack.pop() || new Set();\n}\n\nfunction phraseSearchDocs(phrase) {\n  // naive phrase search using token lists in docs\n  let parts = phrase.split(/\\s+/);\n  let res = [];\n  for (let id in docs) {\n    if (!docs[id].active) continue;\n    let toks = docs[id].tokens && docs[id].tokens.length ? docs[id].tokens.map(t=>t.token) : applyPipelineToText(docs[id].text, id).map(t=>t.token);\n    for (let i=0;i+parts.length<=toks.length;i++) {\n      let ok = true;\n      for (let j=0;j<parts.length;j++) if (toks[i+j] !== parts[j]) { ok=false; break; }\n      if (ok) { res.push(id); break; }\n    }\n  }\n  return res;\n}\n\nfunction showResults(docIdsArray) {\n  let container = document.getElementById(\"searchResults\");\n  container.innerHTML = \"\";\n  if (!docIdsArray.length) { container.textContent = \"(no results)\"; return; }\n  for (let id of docIdsArray) {\n    let div = document.createElement(\"div\");\n    div.style.marginBottom = \"8px\";\n    let title = document.createElement(\"div\");\n    title.textContent = id;\n    let txt = document.createElement(\"div\");\n    txt.className = \"result-snippet\";\n    let full = docs[id].text;\n    let snippet = full.slice(0,200);\n    txt.textContent = snippet + (full.length > 200 ? \"...\" : \"\");\n    let btnView = document.createElement(\"button\"); btnView.textContent = \"View\";\n    btnView.onclick = () => { renderAdvancedOutput(\"Doc: \" + id + \"\\n\\n\" + full); };\n    div.appendChild(title); div.appendChild(txt); div.appendChild(btnView);\n    container.appendChild(div);\n  }\n}\n\n// Ranked query (tf-idf cosine similarity)\nfunction performRankedQuery(q) {\n  let tokens = tokenizeQueryForRanking(q);\n  let useTfIdf = document.getElementById(\"useTfIdf\").checked;\n  let topK = Math.max(1, parseInt(document.getElementById(\"topK\").value) || 10);\n  // build query vector\n  let qvec = {};\n  for (let t of tokens) {\n    if (!index.inverted[t]) {\n      // attempt fuzzy if not found\n      let matched = findSimilarTerms(t, parseInt(document.getElementById(\"fuzzyThreshold\").value) || 1);\n      if (matched.length) t = matched[0];\n    }\n    let idf = index.inverted[t] ? index.inverted[t].idf : 1;\n    qvec[t] = (qvec[t] || 0) + 1 * idf;\n  }\n  // compute cosine similarity with docVectors\n  let scores = {};\n  let qnorm = Math.sqrt(Object.values(qvec).reduce((a,b)=>a+b*b,0));\n  for (let docId in index.docVectors) {\n    let dv = index.docVectors[docId];\n    let dot = 0;\n    for (let term in qvec) {\n      if (dv[term]) dot += dv[term] * qvec[term];\n    }\n    let dnorm = Math.sqrt(Object.values(dv).reduce((a,b)=>a+b*b,0));\n    let score = 0;\n    if (qnorm && dnorm) score = dot / (qnorm * dnorm);\n    if (document.getElementById(\"normLength\").checked) {\n      let len = index.docLengths[docId] || 1;\n      score = score / Math.sqrt(len);\n    }\n    scores[docId] = score;\n  }\n  // sort\n  let ranked = Object.keys(scores).sort((a,b) => scores[b] - scores[a]).slice(0, topK);\n  // show with scores\n  let container = document.getElementById(\"searchResults\");\n  container.innerHTML = \"\";\n  for (let id of ranked) {\n    if (scores[id] <= 0) continue;\n    let div = document.createElement(\"div\");\n    div.style.marginBottom = \"8px\";\n    div.textContent = id + \" (score: \" + scores[id].toFixed(4) + \")\";\n    let s = docs[id].text.slice(0,200);\n    let snip = document.createElement(\"div\"); snip.className = \"result-snippet\"; snip.textContent = s + (docs[id].text.length>200?\"...\":\"\");\n    let btnView = document.createElement(\"button\"); btnView.textContent = \"View details\";\n    btnView.onclick = () => {\n      renderAdvancedOutput(\"Doc: \" + id + \"\\nScore: \" + scores[id] + \"\\nVector: \" + JSON.stringify(index.docVectors[id], null, 2) + \"\\n\\nText:\\n\" + docs[id].text);\n    };\n    div.appendChild(snip);\n    div.appendChild(btnView);\n    container.appendChild(div);\n  }\n}\n\n// helper to find similar terms (Levenshtein)\nfunction levenshtein(a, b) {\n  a = a || \"\"; b = b || \"\";\n  let dp = Array(a.length+1).fill(null).map(()=>Array(b.length+1).fill(0));\n  for (let i=0;i<=a.length;i++) dp[i][0]=i;\n  for (let j=0;j<=b.length;j++) dp[0][j]=j;\n  for (let i=1;i<=a.length;i++) {\n    for (let j=1;j<=b.length;j++) {\n      dp[i][j] = Math.min(\n        dp[i-1][j] + 1,\n        dp[i][j-1] + 1,\n        dp[i-1][j-1] + (a[i-1]===b[j-1] ? 0 : 1)\n      );\n    }\n  }\n  return dp[a.length][b.length];\n}\n\nfunction findSimilarTerms(term, threshold) {\n  threshold = threshold || 1;\n  let res = [];\n  for (let t in index.inverted) {\n    let d = levenshtein(term, t);\n    if (d <= threshold) res.push({term:t,dist:d});\n  }\n  res.sort((a,b)=>a.dist - b.dist);\n  return res.map(x=>x.term);\n}\n\nfunction tokenizeQueryForRanking(q) {\n  // simple split\n  return q.split(/\\s+/).map(x=>x.replace(/[^A-Za-z0-9_]/g,\"\")).filter(Boolean);\n}\n\n// Phrase search (exact sequence)\nfunction performPhraseQuery(q) {\n  let phrase = q.replace(/^\"|\"$/g, \"\");\n  let docsFound = phraseSearchDocs(phrase);\n  showResults(docsFound);\n}\n\n// Proximity query: user input format: term1 term2~k or \"term1;term2\" and slider (we'll parse simple)\nfunction performProximityQuery(q) {\n  // Accept format: \"word1 word2 / k\" or \"w1 w2~k\"\n  let m = q.match(/(.+)\\s+(.+)~(\\d+)/) || q.match(/(.+)\\s+(.+)\\s*\\/\\s*(\\d+)/);\n  if (!m) { renderAdvancedOutput(\"Proximity query parse failed. Use 'word1 word2~k' or 'word1 word2 / k'\"); return; }\n  let t1 = m[1].trim();\n  let t2 = m[2].trim();\n  let k = parseInt(m[3]);\n  let res = [];\n  for (let id in docs) {\n    if (!docs[id].active) continue;\n    let toks = docs[id].tokens && docs[id].tokens.length ? docs[id].tokens : applyPipelineToText(docs[id].text, id);\n    let pos1 = []; let pos2 = [];\n    for (let i=0;i<toks.length;i++){\n      if (toks[i].token === t1) pos1.push(i);\n      if (toks[i].token === t2) pos2.push(i);\n    }\n    let found = false;\n    for (let p of pos1) for (let qpos of pos2) if (Math.abs(p-qpos) <= k) { found = true; break; }\n    if (found) res.push(id);\n  }\n  showResults(res);\n}\n\n// Wildcard query\nfunction performWildcardQuery(q) {\n  // convert * to regex and match terms in index\n  let pattern = q.replace(/\\*/g, \".*\");\n  let re = new RegExp(\"^\" + pattern + \"$\");\n  let matched = Object.keys(index.inverted).filter(t => re.test(t));\n  if (!matched.length) {\n    renderAdvancedOutput(\"No matching terms in index.\");\n    return;\n  }\n  // gather docs for all matched terms\n  let docsSet = new Set();\n  for (let term of matched) {\n    for (let d in index.inverted[term].postings) docsSet.add(d);\n  }\n  showResults(Array.from(docsSet));\n}\n\n// Export / import index\ndocument.getElementById(\"exportIndexBtn\").addEventListener(\"click\", () => {\n  if (!index) { alert(\"No index to export.\"); return; }\n  let blob = new Blob([JSON.stringify({index: index, kgramIndex: kgramIndex, pipeline: pipeline}, null, 2)], {type: \"application/json\"});\n  let url = URL.createObjectURL(blob);\n  let a = document.createElement(\"a\"); a.href = url; a.download = \"index_export.json\"; a.click();\n  URL.revokeObjectURL(url);\n});\n\ndocument.getElementById(\"importIndexBtn\").addEventListener(\"click\", () => {\n  let f = document.getElementById(\"importIndexFile\").files[0];\n  if (!f) { alert(\"Choose a file input.\"); return; }\n  let r = new FileReader();\n  r.onload = function(e) {\n    try {\n      let obj = JSON.parse(e.target.result);\n      if (obj.index) {\n        saveHistory(\"importIndex\");\n        index = obj.index;\n        kgramIndex = obj.kgramIndex || null;\n        pipeline = obj.pipeline || [];\n        renderAll();\n        renderAdvancedOutput(\"Index imported.\");\n      } else alert(\"File not in expected format.\");\n    } catch (err) { alert(\"Import error: \" + err.message); }\n  };\n  r.readAsText(f);\n});\n\n// Advanced tools\ndocument.getElementById(\"showTermStatsBtn\").addEventListener(\"click\", () => {\n  if (!index) { alert(\"Build index first.\"); return; }\n  let terms = Object.keys(index.inverted);\n  let totalFreq = terms.reduce((a,b)=>a+index.inverted[b].totalFreq, 0);\n  let most = terms.map(t=>({t:t,f:index.inverted[t].totalFreq})).sort((a,b)=>b.f-a.f).slice(0,20);\n  let out = \"Terms: \" + terms.length + \"\\nTotal tokens: \" + totalFreq + \"\\nTop terms:\\n\" + most.map(x=>x.t + \" (\"+x.f+\")\").join(\", \");\n  renderAdvancedOutput(out);\n});\n\ndocument.getElementById(\"compareSnapshotsBtn\").addEventListener(\"click\", () => {\n  if (snapshots.length < 2) { alert(\"Need at least two snapshots.\"); return; }\n  let a = snapshots[snapshots.length-2].index.inverted;\n  let b = snapshots[snapshots.length-1].index.inverted;\n  let added = [], removed = [];\n  for (let t in b) if (!a[t]) added.push(t);\n  for (let t in a) if (!b[t]) removed.push(t);\n  renderAdvancedOutput(\"Added terms since previous snapshot: \" + added.slice(0,50).join(\", \") + \"\\nRemoved: \" + removed.slice(0,50).join(\", \"));\n});\n\ndocument.getElementById(\"undoBtn\").addEventListener(\"click\", () => { undo(); });\ndocument.getElementById(\"redoBtn\").addEventListener(\"click\", () => { redo(); });\n\nfunction renderAdvancedOutput(text) {\n  document.getElementById(\"advancedOutput\").textContent = text;\n}\n\n// Helpers & initial setup\nfunction renderAll() {\n  renderDocList();\n  renderPipeline();\n  renderSnapshots();\n  renderTermTable();\n}\n\n// Term details action\nfunction showTermDetailsInteractive(term) { showTermDetails(term); }\n\n// Initial default pipeline\npipeline = [\n  {type: \"lowercase\", params: {}},\n  {type: \"removePunct\", params: {}},\n  {type: \"tokenize\", params: {regex: \"\\\\w+\"}},\n  {type: \"minLength\", params: {min: 2}}\n];\nrenderAll();\n\n// Misc UI wiring\ndocument.getElementById(\"refreshTermView\").addEventListener(\"click\", renderTermTable);\n\n// Undo stack initial state\nhistory.push(JSON.stringify({docs, pipeline, index, kgramIndex, snapshots}));\n\n// small convenience: allow pressing Enter in query input to search\ndocument.getElementById(\"queryInput\").addEventListener(\"keydown\", function(e){\n  if (e.key === \"Enter\") { e.preventDefault(); document.getElementById(\"searchBtn\").click(); }\n});\n</script>\n\n</body>\n</html>"
