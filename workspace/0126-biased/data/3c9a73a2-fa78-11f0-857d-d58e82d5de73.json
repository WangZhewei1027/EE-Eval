    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Load Balancing – Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  :root {\n    --bg-dark: #0f131a;\n    --bg-gradient-start: #1c2331;\n    --bg-gradient-end: #141a26;\n    --color-primary: #62d2a2;\n    --color-secondary: #4a90e2;\n    --color-accent: #ff8c61;\n    --color-light: #e4f0f6;\n    --color-softblue: #a7c7e7;\n    --shadow-soft: rgba(75, 123, 196, 0.35);\n    --font-primary: 'Poppins', sans-serif;\n    --transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: var(--bg-dark);\n    background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);\n    font-family: var(--font-primary);\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    color: var(--color-light);\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    letter-spacing: 0.05em;\n    margin-bottom: 0.1em;\n    color: var(--color-primary);\n    user-select: none;\n    text-shadow: 0 0 10px var(--color-primary);\n  }\n\n  h2 {\n    font-weight: 300;\n    color: var(--color-softblue);\n    font-size: 1.4rem;\n    font-style: italic;\n    letter-spacing: 0.07em;\n    margin-top: 0;\n    user-select: none;\n  }\n\n  .container {\n    max-width: 1200px;\n    margin: 60px auto 100px;\n    padding: 0 32px;\n    text-align: center;\n  }\n\n  /* Load Balancer Graphical Section */\n  .network-box {\n    position: relative;\n    margin: 5rem auto 3rem;\n    width: 900px;\n    height: 420px;\n    background: linear-gradient(145deg, #29354a, #1d2437);\n    border-radius: 30px;\n    box-shadow:\n      inset 8px 8px 14px #1b263a,\n      inset -8px -8px 14px #344863,\n      0 15px 40px rgba(0,0,0,0.6);\n    user-select: none;\n    overflow: visible;\n  }\n\n  /* Nodes */\n  .node {\n    position: absolute;\n    background: radial-gradient(circle at 40% 40%, var(--color-secondary), #12243c);\n    box-shadow:\n      0 0 15px var(--color-secondary),\n      0 0 30px var(--color-secondary),\n      inset 0 0 8px rgba(255,255,255,0.15);\n    border-radius: 50%;\n    width: 80px;\n    height: 80px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--color-light);\n    font-weight: 600;\n    font-size: 1.15rem;\n    text-shadow: 0 0 8px #316ca5;\n    user-select: none;\n    cursor: default;\n    transition: box-shadow 0.4s ease;\n  }\n\n  .node.lb {\n    width: 110px;\n    height: 110px;\n    font-size: 1.3rem;\n    background: radial-gradient(circle at 40% 40%, var(--color-primary), #1a3c28);\n    box-shadow:\n      0 0 25px var(--color-primary),\n      0 0 50px var(--color-primary),\n      inset 0 0 15px rgba(255,255,255,0.25);\n  }\n\n  .node:after {\n    content: '';\n    position: absolute;\n    inset: -22px;\n    border-radius: 50%;\n    filter: blur(14px);\n    opacity: 0.1;\n    transition: opacity 0.4s ease;\n  }\n\n  .node.lb:after {\n    background: var(--color-primary);\n    opacity: 0.25;\n  }\n\n  /* Positions */\n  /* Load Balancer center-left */\n  .node.lb {\n    top: 50%;\n    left: 10%;\n    transform: translate(0, -50%);\n    z-index: 10;\n  }\n\n  /* Server Nodes top row */\n  .node.server1 {\n    top: 22%;\n    right: 18%;\n  }\n  .node.server2 {\n    top: 22%;\n    right: 43%;\n  }\n  .node.server3 {\n    top: 22%;\n    right: 68%;\n  }\n  /* Server Nodes bottom row */\n  .node.server4 {\n    bottom: 22%;\n    right: 18%;\n  }\n  .node.server5 {\n    bottom: 22%;\n    right: 43%;\n  }\n  .node.server6 {\n    bottom: 22%;\n    right: 68%;\n  }\n\n  /* Clients left-top and left-bottom */\n  .node.client1 {\n    top: 15%;\n    left: 72%;\n    width: 65px;\n    height: 65px;\n    font-size: 1rem;\n    background: radial-gradient(circle at 40% 40%, var(--color-accent), #542d1f);\n    box-shadow:\n      0 0 15px var(--color-accent),\n      inset 0 0 8px rgba(255, 160, 120, 0.4);\n    text-shadow: 0 0 6px #9e4626;\n  }\n  .node.client2 {\n    bottom: 15%;\n    left: 72%;\n    width: 65px;\n    height: 65px;\n    font-size: 1rem;\n    background: radial-gradient(circle at 40% 40%, var(--color-accent), #542d1f);\n    box-shadow:\n      0 0 15px var(--color-accent),\n      inset 0 0 8px rgba(255, 160, 120, 0.4);\n    text-shadow: 0 0 6px #9e4626;\n  }\n\n  /* Connecting lines */\n  svg.connector {\n    position: absolute;\n    pointer-events: none;\n    overflow: visible;\n  }\n\n  /* Animations for flow */\n  .flow-path {\n    stroke: var(--color-primary);\n    stroke-width: 3;\n    fill: none;\n    stroke-dasharray: 150;\n    stroke-dashoffset: 150;\n    animation: flowLine 3s linear infinite;\n    filter: drop-shadow(0 0 3px var(--color-primary));\n    transition: stroke 0.5s ease;\n  }\n\n  .flow-path.accent {\n    stroke: var(--color-accent);\n    filter: drop-shadow(0 0 8px var(--color-accent));\n  }\n\n  @keyframes flowLine {\n    from {\n      stroke-dashoffset: 150;\n    }\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Glow circles on nodes */\n  .glow {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(12px);\n    opacity: 0.5;\n    pointer-events: none;\n  }\n\n  .glow.lb-glow {\n    background: var(--color-primary);\n    width: 150px;\n    height: 150px;\n    top: 50%;\n    left: 10%;\n    transform: translate(-50%, -50%);\n    z-index: 5;\n  }\n\n  .glow.server-glow {\n    background: var(--color-secondary);\n    width: 120px;\n    height: 120px;\n    opacity: 0.3;\n    animation: pulseGlow 4s ease-in-out infinite alternate;\n  }\n\n  .glow.client-glow {\n    background: var(--color-accent);\n    width: 100px;\n    height: 100px;\n    opacity: 0.4;\n    animation: pulseGlow 5s ease-in-out infinite alternate;\n  }\n\n  @keyframes pulseGlow {\n    0% {opacity: 0.3;}\n    50% {opacity: 0.6;}\n    100% {opacity: 0.3;}\n  }\n\n  /* Layout Wrapper for all lines */\n  .lines-wrapper {\n    position: absolute;\n    top: 0; left: 0;\n    width: 100%; height: 100%;\n    pointer-events: none;\n  }\n\n  /* INFO BAR */\n  .info-bar {\n    margin-top: 5rem;\n    color: var(--color-light);\n    font-size: 1.15rem;\n    max-width: 700px;\n    margin-left: auto;\n    margin-right: auto;\n    line-height: 1.5;\n    letter-spacing: 0.025em;\n    user-select: none;\n    opacity: 0.85;\n  }\n\n  strong {\n    color: var(--color-primary);\n  }\n\n  /* BUTTONS */\n  .buttons {\n    margin-top: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 24px;\n  }\n\n  button {\n    background: transparent;\n    border: 2.5px solid var(--color-primary);\n    color: var(--color-primary);\n    padding: 0.8rem 2.2rem;\n    border-radius: 35px;\n    font-weight: 600;\n    font-family: var(--font-primary);\n    letter-spacing: 0.12em;\n    font-size: 1rem;\n    cursor: pointer;\n    user-select: none;\n    box-shadow: 0 0 15px rgba(98,210,162, 0.38);\n    transition:\n      background-color var(--transition),\n      color var(--transition),\n      box-shadow var(--transition);\n  }\n\n  button:hover {\n    background-color: var(--color-primary);\n    color: var(--bg-gradient-end);\n    box-shadow:\n      0 0 25px var(--color-primary),\n      0 0 50px var(--color-primary);\n  }\n\n  /* FOOTER */\n  footer {\n    color: var(--color-softblue);\n    font-size: 0.85rem;\n    text-align: center;\n    margin-bottom: 30px;\n    user-select: none;\n  }\n\n  /* Accessibility: Reduce motion when requested */\n  @media (prefers-reduced-motion: reduce) {\n    .flow-path {\n      animation-play-state: paused !important;\n      stroke-dashoffset: 0 !important;\n    }\n    .glow.server-glow,\n    .glow.client-glow {\n      animation-play-state: paused !important;\n      opacity: 0.4 !important;\n    }\n  }\n\n</style>\n</head>\n<body>\n\n  <div class=\"container\" role=\"main\" aria-label=\"Load Balancing Visualization\">\n\n    <h1>Load Balancing</h1>\n    <h2>Optimizing Traffic Distribution Across Servers</h2>\n\n    <div class=\"network-box\" aria-hidden=\"true\">\n\n      <!-- Glows -->\n      <span class=\"glow lb-glow\" aria-hidden=\"true\"></span>\n\n      <span class=\"glow server-glow\" style=\"top: 22%; right: 18%; position: absolute; transform: translate(50%, -50%);\" aria-hidden=\"true\"></span>\n      <span class=\"glow server-glow\" style=\"top: 22%; right: 43%; position: absolute; transform: translate(50%, -50%);\" aria-hidden=\"true\"></span>\n      <span class=\"glow server-glow\" style=\"top: 22%; right: 68%; position: absolute; transform: translate(50%, -50%);\" aria-hidden=\"true\"></span>\n      <span class=\"glow server-glow\" style=\"bottom: 22%; right: 18%; position: absolute; transform: translate(50%, 50%);\" aria-hidden=\"true\"></span>\n      <span class=\"glow server-glow\" style=\"bottom: 22%; right: 43%; position: absolute; transform: translate(50%, 50%);\" aria-hidden=\"true\"></span>\n      <span class=\"glow server-glow\" style=\"bottom: 22%; right: 68%; position: absolute; transform: translate(50%, 50%);\" aria-hidden=\"true\"></span>\n\n      <span class=\"glow client-glow\" style=\"top: 15%; left: 72%; position: absolute; transform: translate(-50%, -50%);\" aria-hidden=\"true\"></span>\n      <span class=\"glow client-glow\" style=\"bottom: 15%; left: 72%; position: absolute; transform: translate(-50%, 50%);\" aria-hidden=\"true\"></span>\n\n      <!-- Nodes -->\n      <div class=\"node lb\" aria-label=\"Load Balancer\" role=\"img\" tabindex=\"0\">Load Balancer</div>\n\n      <div class=\"node server1\" aria-label=\"Server 1\" role=\"img\" tabindex=\"0\">Server 1</div>\n      <div class=\"node server2\" aria-label=\"Server 2\" role=\"img\" tabindex=\"0\">Server 2</div>\n      <div class=\"node server3\" aria-label=\"Server 3\" role=\"img\" tabindex=\"0\">Server 3</div>\n      <div class=\"node server4\" aria-label=\"Server 4\" role=\"img\" tabindex=\"0\">Server 4</div>\n      <div class=\"node server5\" aria-label=\"Server 5\" role=\"img\" tabindex=\"0\">Server 5</div>\n      <div class=\"node server6\" aria-label=\"Server 6\" role=\"img\" tabindex=\"0\">Server 6</div>\n\n      <div class=\"node client1\" aria-label=\"Client A\" role=\"img\" tabindex=\"0\">Client A</div>\n      <div class=\"node client2\" aria-label=\"Client B\" role=\"img\" tabindex=\"0\">Client B</div>\n\n      <!-- SVG Connectors -->\n      <svg aria-hidden=\"true\" class=\"connector\" width=\"900\" height=\"420\" style=\"position:absolute; top:0; left:0; pointer-events:none;\" preserveAspectRatio=\"xMinYMin meet\" viewBox=\"0 0 900 420\" >\n\n        <!-- Clients to Load Balancer -->\n        <path class=\"flow-path accent\" id=\"client1-to-lb\" d=\"\" />\n        <path class=\"flow-path accent\" id=\"client2-to-lb\" d=\"\" />\n\n        <!-- Load Balancer to Servers -->\n        <path class=\"flow-path\" id=\"lb-to-server1\" d=\"\" />\n        <path class=\"flow-path\" id=\"lb-to-server2\" d=\"\" />\n        <path class=\"flow-path\" id=\"lb-to-server3\" d=\"\" />\n        <path class=\"flow-path\" id=\"lb-to-server4\" d=\"\" />\n        <path class=\"flow-path\" id=\"lb-to-server5\" d=\"\" />\n        <path class=\"flow-path\" id=\"lb-to-server6\" d=\"\" />\n\n      </svg>\n\n    </div>\n\n    <section class=\"info-bar\" aria-label=\"Explanation of Load Balancing Concept\">\n      <p><strong>Load balancing</strong> is a critical process in network and cloud infrastructure that distributes incoming client requests efficiently across multiple servers. It helps optimize resource use, maximize throughput, minimize response time, and prevent overload on any single server.</p>\n      <p>Here, <strong>Clients A and B</strong> send traffic to a central <strong>Load Balancer</strong>, which intelligently routes each request to one of several <strong>Servers</strong>. The goal is to maintain a smooth, reliable user experience even during traffic surges.</p>\n    </section>\n\n    <div class=\"buttons\" role=\"region\" aria-label=\"Load Balancing Simulation Controls\">\n      <button id=\"toggleFlow\" aria-pressed=\"true\" aria-label=\"Toggle flow animation\">Pause Flow</button>\n      <button id=\"toggleHighlight\" aria-pressed=\"false\" aria-label=\"Toggle highlight of server paths\">Highlight Servers</button>\n    </div>\n\n  </div>\n\n  <footer>\n    &copy; 2024 Visual Concepts · Designed by AI\n  </footer>\n\n<script>\n  // Map nodes by their classes for SVG path calculations\n  const nodes = {\n    lb: document.querySelector('.node.lb'),\n    client1: document.querySelector('.node.client1'),\n    client2: document.querySelector('.node.client2'),\n    server1: document.querySelector('.node.server1'),\n    server2: document.querySelector('.node.server2'),\n    server3: document.querySelector('.node.server3'),\n    server4: document.querySelector('.node.server4'),\n    server5: document.querySelector('.node.server5'),\n    server6: document.querySelector('.node.server6'),\n  };\n\n  const svg = document.querySelector('svg.connector');\n\n  // Function to get center coordinates relative to SVG container\n  function getCenterCoords(el) {\n    const rect = el.getBoundingClientRect();\n    const svgRect = svg.getBoundingClientRect();\n\n    // Calculate center coordinates relative to the SVG top-left\n    const cx = rect.left + rect.width / 2 - svgRect.left;\n    const cy = rect.top + rect.height / 2 - svgRect.top;\n    return { cx, cy };\n  }\n\n  // Build smooth Bezier curve path between two points\n  function buildCurvePath(start, end) {\n    // Control points for nice curve\n    // Horizontal curve with control points horizontally aligned and some offset vertically\n    const deltaX = Math.abs(end.cx - start.cx);\n    const controlOffsetX = deltaX / 2;\n\n    // For curve, adjust Y control points to create a smooth S-curve\n    const path = `M ${start.cx} ${start.cy} \n      C ${start.cx + controlOffsetX} ${start.cy}, \n        ${end.cx - controlOffsetX} ${end.cy}, \n        ${end.cx} ${end.cy}`;\n    return path;\n  }\n\n  // Set path 'd' attributes dynamically for all lines\n  function updatePaths() {\n    // Clients to Load Balancer\n    const c1 = getCenterCoords(nodes.client1);\n    const c2 = getCenterCoords(nodes.client2);\n    const lb = getCenterCoords(nodes.lb);\n\n    document.getElementById('client1-to-lb').setAttribute('d', buildCurvePath(c1, lb));\n    document.getElementById('client2-to-lb').setAttribute('d', buildCurvePath(c2, lb));\n\n    // Load Balancer to Servers\n    const servers = ['server1', 'server2', 'server3', 'server4', 'server5', 'server6'];\n    servers.forEach(serverId => {\n      const server = getCenterCoords(nodes[serverId]);\n      const pathEl = document.getElementById(`lb-to-${serverId}`);\n      pathEl.setAttribute('d', buildCurvePath(lb, server));\n    });\n  }\n\n  // Initial call and update on window resize\n  updatePaths();\n  window.addEventListener('resize', () => {\n    updatePaths();\n  });\n\n  // BUTTONS FUNCTIONALITY\n  const toggleFlowBtn = document.getElementById('toggleFlow');\n  const toggleHighlightBtn = document.getElementById('toggleHighlight');\n\n  let flowRunning = true;\n  toggleFlowBtn.addEventListener('click', () => {\n    flowRunning = !flowRunning;\n    const flowPaths = document.querySelectorAll('.flow-path');\n    flowPaths.forEach(path => {\n      if(flowRunning) {\n        path.style.animationPlayState = 'running';\n      } else {\n        path.style.animationPlayState = 'paused';\n        // Reset strokeDashoffset for visible lines when paused\n        path.style.strokeDashoffset = '0';\n      }\n    });\n    toggleFlowBtn.textContent = flowRunning ? 'Pause Flow' : 'Play Flow';\n    toggleFlowBtn.setAttribute('aria-pressed', flowRunning.toString());\n  });\n\n  // Highlight servers toggle – changes stroke color and line thickness\n  let highlight = false;\n  toggleHighlightBtn.addEventListener('click', () => {\n    highlight = !highlight;\n    const serverPaths = [\n      'lb-to-server1', 'lb-to-server2', 'lb-to-server3',\n      'lb-to-server4', 'lb-to-server5', 'lb-to-server6'\n    ];\n    serverPaths.forEach(id => {\n      const path = document.getElementById(id);\n      if(highlight) {\n        path.style.stroke = 'var(--color-accent)';\n        path.style.strokeWidth = '4.5';\n        path.style.filter = 'drop-shadow(0 0 8px var(--color-accent))';\n      } else {\n        path.style.stroke = 'var(--color-primary)';\n        path.style.strokeWidth = '3';\n        path.style.filter = 'drop-shadow(0 0 3px var(--color-primary))';\n      }\n    });\n    toggleHighlightBtn.textContent = highlight ? 'Unhighlight Servers' : 'Highlight Servers';\n    toggleHighlightBtn.setAttribute('aria-pressed', highlight.toString());\n  });\n\n</script>\n\n</body>\n</html>"
