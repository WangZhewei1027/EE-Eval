    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Transaction System</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Transaction System</h1>\n\n    <h2>Input Transaction Details</h2>\n    <label for=\"amount\">Amount:</label>\n    <input type=\"number\" id=\"amount\" value=\"0\"><br><br>\n\n    <label for=\"transactionType\">Transaction Type:</label>\n    <select id=\"transactionType\">\n        <option value=\"debit\">Debit</option>\n        <option value=\"credit\">Credit</option>\n    </select><br><br>\n\n    <button onclick=\"performTransaction()\">Submit Transaction</button>\n    <button onclick=\"resetTransaction()\">Reset</button><br><br>\n\n    <h2>Transaction History</h2>\n    <ul id=\"transactionHistory\"></ul>\n\n    <h2>Calculate Balance</h2>\n    <button onclick=\"calculateBalance()\">Calculate Balance</button>\n    <p id=\"balance\">Current Balance: 0</p>\n\n    <script>\n        let balance = 0;\n        let transactionHistory = [];\n\n        function performTransaction() {\n            const amount = parseFloat(document.getElementById('amount').value);\n            const transactionType = document.getElementById('transactionType').value;\n            if (transactionType === 'debit') {\n                balance -= amount;\n                transactionHistory.push(`Debited: ${amount}`);\n            } else {\n                balance += amount;\n                transactionHistory.push(`Credited: ${amount}`);\n            }\n            updateHistory();\n            document.getElementById('amount').value = 0;\n        }\n\n        function updateHistory() {\n            const historyList = document.getElementById('transactionHistory');\n            historyList.innerHTML = '';\n            transactionHistory.forEach((entry) => {\n                const li = document.createElement('li');\n                li.textContent = entry;\n                historyList.appendChild(li);\n            });\n        }\n\n        function calculateBalance() {\n            document.getElementById('balance').textContent = `Current Balance: ${balance}`;\n        }\n\n        function resetTransaction() {\n            balance = 0;\n            transactionHistory = [];\n            document.getElementById('balance').textContent = 'Current Balance: 0';\n            updateHistory();\n            document.getElementById('amount').value = 0;\n        }\n    </script>\n</body>\n</html>"
