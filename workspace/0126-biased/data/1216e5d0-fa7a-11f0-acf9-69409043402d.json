{
  "id": "1216e5d0-fa7a-11f0-acf9-69409043402d",
  "timestamp": "2026-01-26T05:47:23.479Z",
  "model": "gpt-3.5-turbo",
  "status": "success",
  "question": "Refactoring",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Refactoring Interactive Explorer</title>\n</head>\n<body>\n<h1>Refactoring Interactive Explorer</h1>\n<p>This tool lets you explore different refactoring approaches, steps, and their effects with extensive interactivity.</p>\n\n<!-- Workflow Control Panel -->\n<section>\n  <h2>Workflow Controls</h2>\n  <p><strong>Current Step:</strong> <span id=\"currentStep\">0</span> / <span id=\"totalSteps\">0</span></p>\n  <button id=\"btnPrevStep\" disabled>Previous Step</button>\n  <button id=\"btnNextStep\" disabled>Next Step</button>\n  <button id=\"btnAddStep\">Add Step After Current</button>\n  <button id=\"btnDeleteStep\" disabled>Delete Current Step</button>\n  <button id=\"btnResetWorkflow\">Reset Workflow</button>\n  <p>\n    Go to step: <input type=\"number\" id=\"inputGotoStep\" min=\"1\" style=\"width:50px\" /> <button id=\"btnGotoStep\">Go</button>\n  </p>\n</section>\n\n<hr />\n\n<!-- Step Editing Panel -->\n<section>\n  <h2>Edit Current Step</h2>\n  <label>\n    Step Title: <input type=\"text\" id=\"stepTitle\" style=\"width:300px\" />\n  </label>\n  <br /><br />\n  <label>\n    Step Description:<br />\n    <textarea id=\"stepDescription\" rows=\"4\" cols=\"70\" style=\"resize:none\"></textarea>\n  </label>\n  <br /><br />\n  <label>\n    Step Category:\n    <select id=\"stepCategory\">\n      <option value=\"Analysis\">Analysis</option>\n      <option value=\"CodeChange\">Code Change</option>\n      <option value=\"Testing\">Testing</option>\n      <option value=\"Review\">Review</option>\n      <option value=\"Rollback\">Rollback</option>\n      <option value=\"Documentation\">Documentation</option>\n      <option value=\"Deployment\">Deployment</option>\n    </select>\n  </label>\n  <br /><br />\n  <fieldset style=\"width:400px;\">\n    <legend>Advanced Options</legend>\n    <label><input type=\"checkbox\" id=\"stepHasPreconditions\" /> Has Preconditions</label>\n    <br />\n    <label><input type=\"checkbox\" id=\"stepHasPostconditions\" /> Has Postconditions</label>\n    <br /><br />\n    <label>Estimated Difficulty (1-10): <input type=\"range\" id=\"stepDifficulty\" min=\"1\" max=\"10\" step=\"1\" value=\"5\" /></label>\n    <span id=\"difficultyValue\">5</span>\n    <br /><br />\n    <label>Expected Time (minutes): <input type=\"number\" id=\"stepExpectedTime\" min=\"0\" value=\"10\" style=\"width:60px\" /></label>\n  </fieldset>\n</section>\n\n<hr />\n\n<!-- Preconditions / Postconditions Editing -->\n<section>\n  <h2>Preconditions and Postconditions</h2>\n  <div style=\"display:flex;justify-content:space-between;max-width:800px;\">\n    <div style=\"width:48%;\">\n      <label for=\"preconditionsList\">Preconditions:</label><br />\n      <textarea id=\"preconditionsList\" rows=\"5\" cols=\"40\" style=\"resize:none\" placeholder=\"One precondition per line\"></textarea>\n    </div>\n    <div style=\"width:48%;\">\n      <label for=\"postconditionsList\">Postconditions:</label><br />\n      <textarea id=\"postconditionsList\" rows=\"5\" cols=\"40\" style=\"resize:none\" placeholder=\"One postcondition per line\"></textarea>\n    </div>\n  </div>\n</section>\n\n<hr />\n\n<!-- Refactoring Patterns Selection -->\n<section>\n  <h2>Select Refactoring Pattern</h2>\n  <select id=\"patternSelect\" style=\"width:300px;\">\n    <option value=\"\" disabled selected>Select pattern</option>\n    <option value=\"extractMethod\">Extract Method</option>\n    <option value=\"inlineMethod\">Inline Method</option>\n    <option value=\"renameVariable\">Rename Variable</option>\n    <option value=\"moveMethod\">Move Method</option>\n    <option value=\"replaceTempWithQuery\">Replace Temp With Query</option>\n    <option value=\"introduceParameterObject\">Introduce Parameter Object</option>\n    <option value=\"removeDeadCode\">Remove Dead Code</option>\n    <option value=\"replaceConditionalWithPolymorphism\">Replace Conditional with Polymorphism</option>\n    <option value=\"simplifyMethodCalls\">Simplify Method Calls</option>\n    <option value=\"decomposeConditional\">Decompose Conditional</option>\n  </select>\n  <button id=\"btnLoadPattern\">Load Pattern Into Current Step</button>\n</section>\n\n<hr />\n\n<!-- Current Step Summary & Effects -->\n<section>\n  <h2>Step Summary and Effects</h2>\n  <pre id=\"stepSummary\" style=\"white-space: pre-wrap; max-height: 200px; overflow-y: auto; border: 1px solid black; padding: 5px;\"></pre>\n</section>\n\n<hr />\n\n<!-- Workflow Visualization -->\n<section>\n  <h2>Workflow Visualization (Textual)</h2>\n  <textarea id=\"workflowVisualization\" rows=\"10\" cols=\"90\" style=\"resize:none; white-space: pre; font-family: monospace;\"></textarea>\n</section>\n\n<hr />\n\n<!-- Complex State & Branching Controls -->\n<section>\n  <h2>Advanced Workflow Management</h2>\n  <p>\n    This allows creating branches and merging different step paths to explore complex workflows.\n  </p>\n  <label>\n    Create Branch From Current Step:\n    <input type=\"text\" id=\"branchNameInput\" placeholder=\"Branch name\" style=\"width:150px\" />\n    <button id=\"btnCreateBranch\">Create Branch</button>\n  </label>\n  <br /><br />\n  <label>\n    Switch to Branch:\n    <select id=\"branchSelect\" style=\"width:200px;\">\n      <option value=\"main\">main</option>\n    </select>\n    <button id=\"btnSwitchBranch\">Switch</button>\n  </label>\n  <br /><br />\n  <label>\n    Merge Branch Into Current:\n    <select id=\"mergeBranchSelect\" style=\"width:200px;\">\n      <option value=\"\" disabled selected>Select branch to merge</option>\n    </select>\n    <button id=\"btnMergeBranch\">Merge</button>\n  </label>\n  <p><small><em>Merge combines steps and attempts to integrate branches preserving order.</em></small></p>\n</section>\n\n<script>\n(function(){\n  // Data structures\n  // Workflow consists of named branches, each branch is a list of steps\n  // Each step is an object:\n  //  id, title, description, category, preconditions [], postconditions[], difficulty (1-10), expectedTime (minutes), hasPreconditions, hasPostconditions\n\n  let workflow = {\n    branches: {\n      main: []\n    },\n    currentBranch: 'main'\n  };\n  let currentStepIndex = -1;\n\n  // === DOM references ===\n  const currentStepSpan = document.getElementById('currentStep');\n  const totalStepsSpan = document.getElementById('totalSteps');\n  const btnPrevStep = document.getElementById('btnPrevStep');\n  const btnNextStep = document.getElementById('btnNextStep');\n  const btnAddStep = document.getElementById('btnAddStep');\n  const btnDeleteStep = document.getElementById('btnDeleteStep');\n  const btnResetWorkflow = document.getElementById('btnResetWorkflow');\n  const inputGotoStep = document.getElementById('inputGotoStep');\n  const btnGotoStep = document.getElementById('btnGotoStep');\n\n  const stepTitleInput = document.getElementById('stepTitle');\n  const stepDescriptionInput = document.getElementById('stepDescription');\n  const stepCategorySelect = document.getElementById('stepCategory');\n  const stepHasPreconditionsCheck = document.getElementById('stepHasPreconditions');\n  const stepHasPostconditionsCheck = document.getElementById('stepHasPostconditions');\n  const stepDifficultyRange = document.getElementById('stepDifficulty');\n  const difficultyValueSpan = document.getElementById('difficultyValue');\n  const stepExpectedTimeInput = document.getElementById('stepExpectedTime');\n\n  const preconditionsListTA = document.getElementById('preconditionsList');\n  const postconditionsListTA = document.getElementById('postconditionsList');\n\n  const patternSelect = document.getElementById('patternSelect');\n  const btnLoadPattern = document.getElementById('btnLoadPattern');\n\n  const stepSummaryPre = document.getElementById('stepSummary');\n  const workflowVisualizationTA = document.getElementById('workflowVisualization');\n\n  const branchNameInput = document.getElementById('branchNameInput');\n  const btnCreateBranch = document.getElementById('btnCreateBranch');\n  const branchSelect = document.getElementById('branchSelect');\n  const btnSwitchBranch = document.getElementById('btnSwitchBranch');\n  const mergeBranchSelect = document.getElementById('mergeBranchSelect');\n  const btnMergeBranch = document.getElementById('btnMergeBranch');\n\n  // Utility: generate unique IDs for steps\n  let stepIdCounter = 1;\n  function generateStepId(){\n    return 'step' + (stepIdCounter++);\n  }\n\n  // Initialize with a default workflow after reset\n  function resetWorkflow(){\n    workflow = {\n      branches: {\n        main: [\n          {\n            id: generateStepId(),\n            title: 'Identify Refactoring Opportunity',\n            description: 'Analyze the codebase to find areas that need refactoring.',\n            category: 'Analysis',\n            preconditions: [],\n            postconditions: ['Refactoring candidates identified'],\n            difficulty: 3,\n            expectedTime: 20,\n            hasPreconditions: false,\n            hasPostconditions: true,\n          },\n          {\n            id: generateStepId(),\n            title: 'Write Tests',\n            description: 'Write unit or integration tests covering the code to be refactored.',\n            category: 'Testing',\n            preconditions: ['Refactoring candidates identified'],\n            postconditions: ['Tests written and passing'],\n            difficulty: 5,\n            expectedTime: 30,\n            hasPreconditions: true,\n            hasPostconditions: true,\n          },\n          {\n            id: generateStepId(),\n            title: 'Apply Refactoring',\n            description: 'Perform the actual code changes to improve design without altering behavior.',\n            category: 'CodeChange',\n            preconditions: ['Tests written and passing'],\n            postconditions: ['Code structure improved', 'Tests still passing'],\n            difficulty: 7,\n            expectedTime: 45,\n            hasPreconditions: true,\n            hasPostconditions: true,\n          },\n          {\n            id: generateStepId(),\n            title: 'Run Tests',\n            description: 'Verify that refactoring did not break existing functionality.',\n            category: 'Testing',\n            preconditions: ['Code structure improved', 'Tests still passing'],\n            postconditions: ['All tests pass after refactoring'],\n            difficulty: 4,\n            expectedTime: 15,\n            hasPreconditions: true,\n            hasPostconditions: true,\n          },\n          {\n            id: generateStepId(),\n            title: 'Code Review',\n            description: 'Let peers review the refactored code for maintainability and correctness.',\n            category: 'Review',\n            preconditions: ['All tests pass after refactoring'],\n            postconditions: ['Review feedback addressed'],\n            difficulty: 6,\n            expectedTime: 30,\n            hasPreconditions: true,\n            hasPostconditions: true,\n          }\n        ]\n      },\n      currentBranch: 'main'\n    };\n    currentStepIndex = 0;\n    rebuildBranchSelects();\n    updateUI();\n  }\n\n  function currentBranchSteps(){\n    return workflow.branches[workflow.currentBranch];\n  }\n\n  // === Navigation ===\n  function canGoPrev(){\n    return currentStepIndex > 0;\n  }\n  function canGoNext(){\n    return currentStepIndex >= 0 && currentStepIndex < currentBranchSteps().length - 1;\n  }\n\n  function updateUI(){\n    const steps = currentBranchSteps();\n    const total = steps.length;\n    totalStepsSpan.textContent = total;\n    currentStepSpan.textContent = currentStepIndex >= 0 ? (currentStepIndex+1) : '0';\n\n    btnPrevStep.disabled = !canGoPrev();\n    btnNextStep.disabled = !canGoNext();\n    btnDeleteStep.disabled = !(currentStepIndex >= 0 && total > 0);\n\n    // If no steps, clear editing\n    if(currentStepIndex < 0 || currentStepIndex >= total){\n      clearStepEditing();\n      stepSummaryPre.textContent = 'No current step selected.';\n      workflowVisualizationTA.value = getWorkflowVisualizationText();\n      return;\n    }\n\n    // Load current step data into inputs\n    const step = steps[currentStepIndex];\n    stepTitleInput.value = step.title;\n    stepDescriptionInput.value = step.description;\n    stepCategorySelect.value = step.category || 'Analysis';\n    stepHasPreconditionsCheck.checked = step.hasPreconditions;\n    stepHasPostconditionsCheck.checked = step.hasPostconditions;\n    stepDifficultyRange.value = step.difficulty;\n    difficultyValueSpan.textContent = step.difficulty;\n    stepExpectedTimeInput.value = step.expectedTime;\n\n    preconditionsListTA.value = step.preconditions.join('\\n');\n    postconditionsListTA.value = step.postconditions.join('\\n');\n\n    btnLoadPattern.disabled = false;\n    btnAddStep.disabled = false;\n\n    updateStepSummary();\n\n    workflowVisualizationTA.value = getWorkflowVisualizationText();\n  }\n\n  function clearStepEditing(){\n    stepTitleInput.value = '';\n    stepDescriptionInput.value = '';\n    stepCategorySelect.value = 'Analysis';\n    stepHasPreconditionsCheck.checked = false;\n    stepHasPostconditionsCheck.checked = false;\n    stepDifficultyRange.value = 5;\n    difficultyValueSpan.textContent = 5;\n    stepExpectedTimeInput.value = 10;\n    preconditionsListTA.value = '';\n    postconditionsListTA.value = '';\n  }\n\n  // === Step Editing ===\n  function saveCurrentStep(){\n    if(currentStepIndex < 0 || currentStepIndex >= currentBranchSteps().length) return;\n    const step = currentBranchSteps()[currentStepIndex];\n\n    step.title = stepTitleInput.value.trim() || 'Untitled Step';\n    step.description = stepDescriptionInput.value.trim();\n    step.category = stepCategorySelect.value || 'Analysis';\n    step.hasPreconditions = stepHasPreconditionsCheck.checked;\n    step.hasPostconditions = stepHasPostconditionsCheck.checked;\n    step.difficulty = Number(stepDifficultyRange.value);\n    stepExpectedTimeInput.value = stepExpectedTimeInput.value.trim();\n    let et = parseInt(stepExpectedTimeInput.value, 10);\n    step.expectedTime = isNaN(et) || et < 0 ? 10 : et;\n\n    step.preconditions = preconditionsListTA.value.split('\\n').map(s=>s.trim()).filter(s=>s.length>0);\n    step.postconditions = postconditionsListTA.value.split('\\n').map(s=>s.trim()).filter(s=>s.length>0);\n\n    updateStepSummary();\n    updateUI();\n  }\n\n  function updateStepSummary(){\n    if(currentStepIndex < 0 || currentStepIndex >= currentBranchSteps().length){\n      stepSummaryPre.textContent = '(No step selected)';\n      return;\n    }\n    const step = currentBranchSteps()[currentStepIndex];\n    let summary = '';\n    summary += 'ID: ' + step.id + '\\n';\n    summary += 'Title: ' + step.title + '\\n';\n    summary += 'Category: ' + step.category + '\\n';\n    summary += 'Description:\\n' + step.description + '\\n\\n';\n\n    if(step.hasPreconditions && step.preconditions.length > 0){\n      summary += 'Preconditions:\\n';\n      for(let pre of step.preconditions){\n        summary += ' - ' + pre + '\\n';\n      }\n      summary += '\\n';\n    } else {\n      summary += 'No preconditions.\\n\\n';\n    }\n\n    if(step.hasPostconditions && step.postconditions.length > 0){\n      summary += 'Postconditions:\\n';\n      for(let post of step.postconditions){\n        summary += ' - ' + post + '\\n';\n      }\n      summary += '\\n';\n    } else {\n      summary += 'No postconditions.\\n\\n';\n    }\n    summary += 'Estimated difficulty (1-10): ' + step.difficulty + '\\n';\n    summary += 'Expected time (minutes): ' + step.expectedTime + '\\n';\n\n    stepSummaryPre.textContent = summary;\n  }\n\n  // === Workflow Operations ===\n  btnPrevStep.addEventListener('click', () => {\n    saveCurrentStep();\n    if(canGoPrev()){\n      currentStepIndex--;\n      updateUI();\n    }\n  });\n  btnNextStep.addEventListener('click', () => {\n    saveCurrentStep();\n    if(canGoNext()){\n      currentStepIndex++;\n      updateUI();\n    }\n  });\n  btnAddStep.addEventListener('click', () => {\n    saveCurrentStep();\n    // Insert a new blank step after current\n    const steps = currentBranchSteps();\n    const newStep = {\n      id: generateStepId(),\n      title: 'New Step',\n      description: '',\n      category: 'Analysis',\n      preconditions: [],\n      postconditions: [],\n      difficulty: 5,\n      expectedTime: 10,\n      hasPreconditions: false,\n      hasPostconditions: false,\n    };\n    if(currentStepIndex < 0 || currentStepIndex >= steps.length){\n      steps.push(newStep);\n      currentStepIndex = steps.length - 1;\n    } else {\n      steps.splice(currentStepIndex + 1, 0, newStep);\n      currentStepIndex++;\n    }\n    updateUI();\n  });\n  btnDeleteStep.addEventListener('click', () => {\n    if(currentStepIndex < 0) return;\n    const steps = currentBranchSteps();\n    saveCurrentStep();\n    steps.splice(currentStepIndex, 1);\n    if(currentStepIndex >= steps.length)\n      currentStepIndex = steps.length -1;\n    if(currentStepIndex < 0 && steps.length > 0)\n      currentStepIndex = 0;\n    updateUI();\n  });\n  btnResetWorkflow.addEventListener('click', () => {\n    if(confirm('Are you sure you want to reset the workflow? All unsaved changes will be lost.')){\n      resetWorkflow();\n    }\n  });\n\n  btnGotoStep.addEventListener('click', () => {\n    const val = Number(inputGotoStep.value);\n    if(!isNaN(val)){\n      const steps = currentBranchSteps();\n      if(val >= 1 && val <= steps.length){\n        saveCurrentStep();\n        currentStepIndex = val - 1;\n        updateUI();\n      }\n    }\n  });\n\n  // Update fields on input changes\n  stepTitleInput.addEventListener('input', () => {\n    updateStepSummary();\n  });\n  stepDescriptionInput.addEventListener('input', () => {\n    updateStepSummary();\n  });\n  stepCategorySelect.addEventListener('change', () => {\n    updateStepSummary();\n  });\n  stepHasPreconditionsCheck.addEventListener('change', () => {\n    updateStepSummary();\n  });\n  stepHasPostconditionsCheck.addEventListener('change', () => {\n    updateStepSummary();\n  });\n  stepDifficultyRange.addEventListener('input', () => {\n    difficultyValueSpan.textContent = stepDifficultyRange.value;\n    updateStepSummary();\n  });\n  stepExpectedTimeInput.addEventListener('input', () => {\n    updateStepSummary();\n  });\n  preconditionsListTA.addEventListener('input', () => {\n    updateStepSummary();\n  });\n  postconditionsListTA.addEventListener('input', () => {\n    updateStepSummary();\n  });\n\n  // On page unload, save step edits to data\n  window.addEventListener('beforeunload', (e) => {\n    saveCurrentStep();\n  });\n\n  // === Refactoring Patterns ===\n  const predefinedPatterns = {\n    extractMethod: {\n      title: 'Extract Method',\n      description: 'Create a new method by extracting part of an existing method to improve readability and reuse.',\n      category: 'CodeChange',\n      preconditions: ['Code segment exists that can be extracted without changing behavior'],\n      postconditions: ['New method created', 'Original method calls new method'],\n      difficulty: 6,\n      expectedTime: 40,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    inlineMethod: {\n      title: 'Inline Method',\n      description: 'Replace calls to a method with the method\\'s content to simplify the code when method is trivial.',\n      category: 'CodeChange',\n      preconditions: ['Method is trivial and called only in few places'],\n      postconditions: ['Method calls replaced by code', 'Method removed if unused'],\n      difficulty: 5,\n      expectedTime: 30,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    renameVariable: {\n      title: 'Rename Variable',\n      description: 'Change the name of a variable to clarify its purpose or conform to naming conventions.',\n      category: 'CodeChange',\n      preconditions: [],\n      postconditions: ['Variable renamed consistently'],\n      difficulty: 2,\n      expectedTime: 10,\n      hasPreconditions: false,\n      hasPostconditions: true,\n    },\n    moveMethod: {\n      title: 'Move Method',\n      description: 'Move a method from one class to another where it fits better to improve encapsulation.',\n      category: 'CodeChange',\n      preconditions: ['Target class related and accessible'],\n      postconditions: ['Method moved', 'Clients updated if necessary'],\n      difficulty: 7,\n      expectedTime: 50,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    replaceTempWithQuery: {\n      title: 'Replace Temp With Query',\n      description: 'Replace temporary variable with method calls for clearer expressions.',\n      category: 'CodeChange',\n      preconditions: ['Temporary variable is set once and used in multiple places'],\n      postconditions: ['Temporary variable removed', 'Calls replaced with method calls'],\n      difficulty: 6,\n      expectedTime: 35,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    introduceParameterObject: {\n      title: 'Introduce Parameter Object',\n      description: 'Consolidate multiple parameters into a single object to simplify method signatures.',\n      category: 'CodeChange',\n      preconditions: ['Method has numerous parameters that logically group'],\n      postconditions: ['New parameter object created', 'Method signature updated'],\n      difficulty: 8,\n      expectedTime: 60,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    removeDeadCode: {\n      title: 'Remove Dead Code',\n      description: 'Clean up unused variables, methods, or classes to improve code maintainability.',\n      category: 'CodeChange',\n      preconditions: ['Code identified as unused/unreachable'],\n      postconditions: ['Dead code removed'],\n      difficulty: 4,\n      expectedTime: 25,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    replaceConditionalWithPolymorphism: {\n      title: 'Replace Conditional With Polymorphism',\n      description: 'Use polymorphism to replace conditionals that select behavior based on type.',\n      category: 'CodeChange',\n      preconditions: ['Code uses conditionals to dispatch methods based on type'],\n      postconditions: ['Polymorphism implemented', 'Conditionals removed'],\n      difficulty: 9,\n      expectedTime: 90,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    simplifyMethodCalls: {\n      title: 'Simplify Method Calls',\n      description: 'Hide complex method call sequences behind simpler APIs to reduce coupling.',\n      category: 'CodeChange',\n      preconditions: ['Complex chains of method calls'],\n      postconditions: ['Simplified method signatures', 'Easier to use methods'],\n      difficulty: 7,\n      expectedTime: 40,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n    decomposeConditional: {\n      title: 'Decompose Conditional',\n      description: 'Break down complicated conditionals into separate methods for clarity.',\n      category: 'CodeChange',\n      preconditions: ['Long or nested conditional statements'],\n      postconditions: ['Conditionals simplified', 'New helper methods created'],\n      difficulty: 6,\n      expectedTime: 45,\n      hasPreconditions: true,\n      hasPostconditions: true,\n    },\n  };\n\n  btnLoadPattern.addEventListener('click', () => {\n    if(currentStepIndex < 0) return;\n    const patternKey = patternSelect.value;\n    if(!patternKey) return;\n    const patternData = predefinedPatterns[patternKey];\n    if(!patternData) return;\n\n    saveCurrentStep();\n\n    const step = currentBranchSteps()[currentStepIndex];\n    step.title = patternData.title;\n    step.description = patternData.description;\n    step.category = patternData.category;\n    step.preconditions = patternData.preconditions.slice();\n    step.postconditions = patternData.postconditions.slice();\n    step.difficulty = patternData.difficulty;\n    step.expectedTime = patternData.expectedTime;\n    step.hasPreconditions = patternData.hasPreconditions;\n    step.hasPostconditions = patternData.hasPostconditions;\n\n    updateUI();\n  });\n\n  // === Workflow Visualization (Textual) ===\n  function getWorkflowVisualizationText(){\n    let text = 'Workflow Branch: \"' + workflow.currentBranch + '\"\\n\\n';\n    let steps = currentBranchSteps();\n    if(steps.length === 0){\n      text += '(No steps in this branch)';\n      return text;\n    }\n\n    // Show step index, ID, title, category, and summary of pre/post conditions\n    steps.forEach((step, index) => {\n      const num = (index + 1).toString().padStart(3, ' ');\n      text += num + '. ' + step.title + ' [' + step.category + ']\\n';\n      if(step.hasPreconditions && step.preconditions.length > 0){\n        text += '    Preconditions: ' + step.preconditions.join('; ') + '\\n';\n      }\n      if(step.hasPostconditions && step.postconditions.length > 0){\n        text += '    Postconditions: ' + step.postconditions.join('; ') + '\\n';\n      }\n      text += '    Diff: ' + step.difficulty + '  Expected Time: ' + step.expectedTime + 'min\\n\\n';\n    });\n\n    // Show available branches too\n    const otherBranches = Object.keys(workflow.branches).filter(b => b !== workflow.currentBranch);\n    if(otherBranches.length > 0){\n      text += 'Other branches:\\n';\n      for(let br of otherBranches){\n        text += '  - ' + br + ' (' + workflow.branches[br].length + ' steps)\\n';\n      }\n    }\n    return text;\n  }\n\n  // === Branching and Merging ===\n  // Add a new branch starting from current step\n  btnCreateBranch.addEventListener('click', () => {\n    const newBranchName = (branchNameInput.value || '').trim();\n    if(!newBranchName){\n      alert('Please enter a branch name.');\n      return;\n    }\n    if(workflow.branches[newBranchName]){\n      alert('Branch with this name already exists.');\n      return;\n    }\n    if(currentStepIndex < 0){\n      alert('Select a step to branch from.');\n      return;\n    }\n    const steps = currentBranchSteps().slice(0, currentStepIndex + 1);\n    workflow.branches[newBranchName] = steps.map(s => duplicateStep(s));\n    branchNameInput.value = '';\n    rebuildBranchSelects();\n    alert('Branch \"' + newBranchName + '\" created starting from step ' + (currentStepIndex+1) + '.');\n  });\n\n  // Switch current branch\n  btnSwitchBranch.addEventListener('click', () => {\n    const selectedBranch = branchSelect.value;\n    if(!selectedBranch) return;\n    saveCurrentStep();\n    workflow.currentBranch = selectedBranch;\n    const steps = currentBranchSteps();\n    currentStepIndex = steps.length > 0 ? 0 : -1;\n    updateUI();\n  });\n\n  function rebuildBranchSelects(){\n    // Update branchSelect options\n    const branches = Object.keys(workflow.branches);\n    // Clear selects first\n    [branchSelect, mergeBranchSelect].forEach(sel => {\n      while(sel.firstChild){\n        sel.removeChild(sel.firstChild);\n      }\n    });\n    for(let b of branches){\n      const optSwitch = document.createElement('option');\n      optSwitch.value = b;\n      optSwitch.textContent = b;\n      branchSelect.appendChild(optSwitch);\n\n      if(b !== workflow.currentBranch){\n        const optMerge = document.createElement('option');\n        optMerge.value = b;\n        optMerge.textContent = b;\n        mergeBranchSelect.appendChild(optMerge);\n      }\n    }\n    branchSelect.value = workflow.currentBranch || 'main';\n    mergeBranchSelect.value = '';\n  }\n\n  // Deep duplication of steps array elements\n  function duplicateStep(step){\n    return {\n      id: generateStepId(),\n      title: step.title,\n      description: step.description,\n      category: step.category,\n      preconditions: step.preconditions.slice(),\n      postconditions: step.postconditions.slice(),\n      difficulty: step.difficulty,\n      expectedTime: step.expectedTime,\n      hasPreconditions: step.hasPreconditions,\n      hasPostconditions: step.hasPostconditions,\n    };\n  }\n\n  // Merging two branches - complex logic: append new unique steps,\n  // and if steps with same title exist, merge pre/post conditions when possible.\n  btnMergeBranch.addEventListener('click', () => {\n    const branchToMerge = mergeBranchSelect.value;\n    if(!branchToMerge){\n      alert('Select a branch to merge.');\n      return;\n    }\n    if(branchToMerge === workflow.currentBranch){\n      alert('Cannot merge a branch into itself.');\n      return;\n    }\n    if(currentStepIndex < 0){\n      alert('Select a step in the current branch to merge into.');\n      return;\n    }\n\n    saveCurrentStep();\n\n    const targetBranch = workflow.currentBranch;\n    const targetSteps = workflow.branches[targetBranch];\n    const mergeSteps = workflow.branches[branchToMerge];\n\n    // Find step title index to merge from\n    const mergeStartStep = mergeSteps[0];\n    if(!mergeStartStep){\n      alert('Nothing to merge: source branch has no steps.');\n      return;\n    }\n\n    // Strategy:\n    // Start from currentStepIndex + 1 in target branch.\n    // Append steps from merge branch that are not already in target branch by title.\n    // If title exists in target branch, merge pre/postconditions in place.\n\n    const targetTitles = new Set(targetSteps.map(s => s.title));\n    let addedStepsCount = 0;\n    for(let ms of mergeSteps){\n      if(!targetTitles.has(ms.title)){\n        // Append a duplicated step\n        targetSteps.push(duplicateStep(ms));\n        addedStepsCount++;\n      } else {\n        // Merge pre/postconditions for existing step\n        const existingStep = targetSteps.find(s => s.title === ms.title);\n        // Merge preconditions\n        ms.preconditions.forEach(pre => {\n          if(existingStep.preconditions.indexOf(pre) === -1){\n            existingStep.preconditions.push(pre);\n          }\n        });\n        // Merge postconditions\n        ms.postconditions.forEach(post => {\n          if(existingStep.postconditions.indexOf(post) === -1){\n            existingStep.postconditions.push(post);\n          }\n        });\n      }\n    }\n\n    rebuildBranchSelects();\n    alert('Merge complete: ' + addedStepsCount + ' new steps added, some conditions merged.');\n\n    updateUI();\n  });\n\n  // Initialization\n  resetWorkflow();\n\n})();\n</script>\n</body>\n</html>"
