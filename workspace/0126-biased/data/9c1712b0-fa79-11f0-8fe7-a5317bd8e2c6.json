  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Overfitting Interactive Demo</title>\n<style>\n/* Minimal visual design as requested: plain black text on white background, default form elements */\nbody { font-family: sans-serif; margin: 10px; color: black; background: white; }\nsection { margin-bottom: 12px; }\n.controls { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }\n.controls > * { margin: 2px; }\ncanvas { border: 1px solid #000; cursor: crosshair; }\nsmall { display: block; margin-top: 4px; }\npre { white-space: pre-wrap; word-wrap: break-word; max-height: 200px; overflow: auto; border: 1px solid #000; padding: 4px; }\ntable { border-collapse: collapse; }\ntd, th { border: 1px solid #000; padding: 4px; }\n</style>\n</head>\n<body>\n\n<h2>Overfitting Interactive Demo (Minimal UI)</h2>\n\n<section>\n  <div class=\"controls\">\n    <label>Seed <input type=\"number\" id=\"seed\" value=\"1\" style=\"width:80px;\"></label>\n    <label>Num points <input type=\"range\" id=\"numPoints\" min=\"5\" max=\"200\" value=\"30\"></label>\n    <span id=\"numPointsVal\">30</span>\n    <label>Noise σ <input type=\"range\" id=\"noise\" min=\"0\" max=\"4\" step=\"0.1\" value=\"0.5\"></label>\n    <span id=\"noiseVal\">0.5</span>\n    <label>Train % <input type=\"range\" id=\"trainPct\" min=\"10\" max=\"90\" value=\"70\"></label>\n    <span id=\"trainPctVal\">70%</span>\n    <label>Degree <input type=\"range\" id=\"degree\" min=\"0\" max=\"15\" value=\"3\"></label>\n    <span id=\"degreeVal\">3</span>\n    <label>Lambda (L2) <input type=\"range\" id=\"lambda\" min=\"0\" max=\"100\" step=\"0.1\" value=\"0\"></label>\n    <span id=\"lambdaVal\">0</span>\n    <button id=\"genData\">Generate Data</button>\n    <button id=\"fitModel\">Fit Model</button>\n    <button id=\"fitWithReg\">Fit with L2</button>\n    <button id=\"clearPoints\">Clear Points</button>\n  </div>\n  <small>Use the canvas to drag points to reposition them. Click to add a point when \"Add Point\" mode is ON. Delete nearest point with \"Delete Nearest\".</small>\n</section>\n\n<section>\n  <div class=\"controls\">\n    <label><input type=\"checkbox\" id=\"addPointMode\"> Add Point Mode</label>\n    <button id=\"deleteNearest\">Delete Nearest</button>\n    <button id=\"addOutlier\">Add Random Outlier</button>\n    <button id=\"undo\">Undo</button>\n    <button id=\"redo\">Redo</button>\n    <button id=\"saveState\">Save State (JSON)</button>\n    <button id=\"loadStateBtn\">Load State</button>\n    <button id=\"exportCSV\">Export CSV</button>\n    <button id=\"importCSVBtn\">Import CSV</button>\n  </div>\n  <textarea id=\"stateBox\" placeholder=\"Saved JSON or CSV paste area\" rows=\"4\" style=\"width:100%\"></textarea>\n</section>\n\n<section>\n  <div style=\"display:flex; gap:12px;\">\n    <canvas id=\"plot\" width=\"700\" height=\"300\"></canvas>\n    <div style=\"flex:1;\">\n      <div><strong>Metrics</strong></div>\n      <div id=\"metrics\">\n        Train MSE: - <br>\n        Test MSE: - <br>\n        CV MSE: - <br>\n        Coeffs: - <br>\n      </div>\n      <hr>\n      <div><strong>Cross-Validation & Grid Search</strong></div>\n      <div class=\"controls\">\n        <label>K folds <input type=\"number\" id=\"kfolds\" min=\"2\" max=\"20\" value=\"5\" style=\"width:60px\"></label>\n        <label>Max degree <input type=\"number\" id=\"gridMaxDeg\" min=\"0\" max=\"15\" value=\"10\" style=\"width:60px\"></label>\n        <label>Lambda list (comma) <input type=\"text\" id=\"gridLambdas\" value=\"0,0.1,1,10\" style=\"width:140px\"></label>\n        <button id=\"runGrid\">Run Grid Search (CV)</button>\n        <button id=\"runCV\">Run CV for current model</button>\n      </div>\n      <div id=\"gridResults\" style=\"max-height:220px; overflow:auto\"></div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Bootstrap Bias-Variance Estimate</strong>\n    <div class=\"controls\">\n      <label># Bootstrap <input type=\"number\" id=\"nBoot\" min=\"10\" max=\"2000\" value=\"200\" style=\"width:80px\"></label>\n      <label>Eval points <input type=\"number\" id=\"evalPts\" min=\"10\" max=\"200\" value=\"100\" style=\"width:80px\"></label>\n      <button id=\"runBootstrap\">Run Bootstrap</button>\n    </div>\n    <div id=\"bootstrapResults\"></div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Automated Degree Sweep</strong>\n    <div class=\"controls\">\n      <label>From <input type=\"number\" id=\"sweepFrom\" min=\"0\" max=\"15\" value=\"0\" style=\"width:60px\"></label>\n      <label>To <input type=\"number\" id=\"sweepTo\" min=\"0\" max=\"15\" value=\"12\" style=\"width:60px\"></label>\n      <label>Step <input type=\"number\" id=\"sweepStep\" min=\"1\" max=\"5\" value=\"1\" style=\"width:60px\"></label>\n      <button id=\"runSweep\">Run Sweep</button>\n      <button id=\"stopSweep\">Stop Sweep</button>\n    </div>\n    <div id=\"sweepResults\" style=\"max-height:200px; overflow:auto\"></div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Model Coefficients & Diagnostics</strong>\n    <div id=\"coeffsBox\">No model fitted yet.</div>\n  </div>\n</section>\n\n<script>\n// Minimal but feature-rich interactive demo for Overfitting\n// Random number generator (seeded)\nfunction mulberry32(a) {\n  return function() {\n    var t = a += 0x6D2B79F5;\n    t = Math.imul(t ^ t >>> 15, t | 1);\n    t ^= t + Math.imul(t ^ t >>> 7, t | 61);\n    return ((t ^ t >>> 14) >>> 0) / 4294967296;\n  }\n}\n\n// Linear algebra helpers\nfunction transpose(A) {\n  var m=A.length, n=A[0].length, B=[];\n  for(var j=0;j<n;j++){B[j]=Array(m); for(var i=0;i<m;i++)B[j][i]=A[i][j];}\n  return B;\n}\nfunction matMul(A,B){\n  var m=A.length, p=B[0].length, n=B[0].length?B.length:0;\n  var C=[];\n  for(var i=0;i<m;i++){ C[i]=Array(p); for(var j=0;j<p;j++){ var s=0; for(var k=0;k<n;k++) s+=A[i][k]*B[k][j]; C[i][j]=s; } }\n  return C;\n}\nfunction matVecMul(A,v){\n  var m=A.length,n=A[0].length, r=Array(m);\n  for(var i=0;i<m;i++){ var s=0; for(var j=0;j<n;j++) s+=A[i][j]*v[j]; r[i]=s; }\n  return r;\n}\nfunction identity(n){\n  var I=[]; for(var i=0;i<n;i++){ I[i]=Array(n).fill(0); I[i][i]=1; } return I;\n}\n// Solve linear system A x = b using Gaussian elimination with partial pivoting\nfunction solveLinear(Aorig, borig) {\n  // clone\n  var n=Aorig.length;\n  var A=Array(n); for(var i=0;i<n;i++) A[i]=Aorig[i].slice();\n  var b=borig.slice();\n  for(var i=0;i<n;i++){\n    // pivot\n    var maxRow=i, maxVal=Math.abs(A[i][i]);\n    for(var r=i+1;r<n;r++){ if(Math.abs(A[r][i])>maxVal){ maxVal=Math.abs(A[r][i]); maxRow=r; } }\n    if(maxRow!==i){ var tmp=A[i]; A[i]=A[maxRow]; A[maxRow]=tmp; var tb=b[i]; b[i]=b[maxRow]; b[maxRow]=tb; }\n    var diag=A[i][i];\n    if(Math.abs(diag) < 1e-12) { // singular, fallback\n      diag = (diag === 0) ? 1e-12 : diag;\n    }\n    for(var j=i+1;j<n;j++){\n      var factor=A[j][i]/diag;\n      b[j]-=factor*b[i];\n      for(var k=i;k<n;k++) A[j][k]-=factor*A[i][k];\n    }\n  }\n  var x=Array(n).fill(0);\n  for(var i=n-1;i>=0;i--){\n    var s=b[i];\n    for(var j=i+1;j<n;j++) s-=A[i][j]*x[j];\n    x[i]=s / (A[i][i] || 1e-12);\n  }\n  return x;\n}\n\n// Polynomial basis: scale x to [-1,1] for stability\nfunction scaleX(x, xmin, xmax){\n  if(xmax===xmin) return 0;\n  return (2*(x - xmin)/(xmax - xmin) - 1);\n}\n\nfunction buildVandermonde(xs, degree){\n  var n=xs.length, X=Array(n);\n  var xmin=Math.min.apply(null, xs), xmax=Math.max.apply(null,xs);\n  for(var i=0;i<n;i++){\n    var xx=scaleX(xs[i], xmin, xmax);\n    var row=[];\n    var v=1;\n    for(var d=0;d<=degree;d++){ row.push(v); v*=xx; }\n    X[i]=row;\n  }\n  X._xmin=xmin; X._xmax=xmax;\n  return X;\n}\n\nfunction fitPoly(xs, ys, degree, lambda){\n  if(xs.length===0) return {coeffs:[], xmin:0, xmax:1};\n  var X = buildVandermonde(xs, degree);\n  var Xt = transpose(X);\n  // compute XtX and Xty\n  var XtX = Array(Xt.length);\n  for(var i=0;i<Xt.length;i++){\n    XtX[i]=Array(Xt.length).fill(0);\n    for(var j=0;j<Xt.length;j++){\n      var s=0;\n      for(var k=0;k<X.length;k++) s+=Xt[i][k]*X[k][j];\n      XtX[i][j]=s;\n    }\n  }\n  var Xty = Array(Xt.length).fill(0);\n  for(var i=0;i<Xt.length;i++){\n    var s=0;\n    for(var k=0;k<X.length;k++) s+=Xt[i][k]*ys[k];\n    Xty[i]=s;\n  }\n  // regularization\n  if(lambda && lambda>0){\n    for(var i=1;i<XtX.length;i++){ XtX[i][i] += lambda; }\n  }\n  // solve\n  var coeffs = solveLinear(XtX, Xty);\n  return {coeffs:coeffs, xmin:X._xmin, xmax:X._xmax, degree:degree};\n}\n\nfunction predict(model, x){\n  if(!model || !model.coeffs) return 0;\n  var xmin=model.xmin, xmax=model.xmax;\n  var xx=scaleX(x, xmin, xmax);\n  var v=1, s=0;\n  for(var i=0;i<model.coeffs.length;i++){ s += model.coeffs[i]*v; v*=xx; }\n  return s;\n}\n\nfunction mse(ytrue, ypred){\n  var n=ytrue.length, s=0;\n  for(var i=0;i<n;i++){ var d=ytrue[i]-ypred[i]; s+=d*d; }\n  return s/n;\n}\n\n// UI and state\nvar stateStack = [], redoStack = [];\nvar appState = {\n  points: [], // {x,y,set:'train'/'test'}\n  seed: 1,\n  numPoints: 30,\n  noise: 0.5,\n  trainPct: 70,\n  model: null,\n  lambda: 0,\n  degree: 3\n};\n\nfunction pushState() { stateStack.push(JSON.parse(JSON.stringify(appState))); if(stateStack.length>200) stateStack.shift(); redoStack=[]; }\nfunction undo(){ if(stateStack.length>1){ redoStack.push(stateStack.pop()); appState = JSON.parse(JSON.stringify(stateStack[stateStack.length-1])); renderAll(); } }\nfunction redo(){ if(redoStack.length){ var s=redoStack.pop(); stateStack.push(s); appState = JSON.parse(JSON.stringify(s)); renderAll(); } }\n\nvar plot = document.getElementById('plot');\nvar ctx = plot.getContext('2d');\n\nfunction generateData(){\n  var seedVal = parseInt(document.getElementById('seed').value) || 1;\n  var rng = mulberry32(seedVal);\n  var n = parseInt(document.getElementById('numPoints').value);\n  var noise = parseFloat(document.getElementById('noise').value);\n  var trainPct = parseInt(document.getElementById('trainPct').value);\n  var xs=[], ys=[];\n  // underlying function: mixture of sines and polynomial to be nontrivial\n  for(var i=0;i<n;i++){\n    var x = -3 + 6 * rng(); // range [-3,3]\n    var y = 0.5*Math.sin(1.5*x) + 0.3*x + 0.2*Math.cos(3*x) + 0.1*x*x;\n    y += (rng()*2-1) * noise;\n    xs.push(x); ys.push(y);\n  }\n  // assign train/test\n  var points=[];\n  for(var i=0;i<n;i++){\n    var set = (rng()*100 < trainPct) ? 'train' : 'test';\n    points.push({x: xs[i], y: ys[i], set: set});\n  }\n  appState.points = points;\n  appState.seed = seedVal;\n  appState.numPoints = n;\n  appState.noise = noise;\n  appState.trainPct = trainPct;\n  pushState();\n  renderAll();\n}\n\nfunction clearPoints(){\n  appState.points = [];\n  pushState();\n  renderAll();\n}\n\nfunction addRandomOutlier(){\n  var rng = mulberry32(appState.seed + Math.floor(Math.random()*10000));\n  var x = -3 + 6*rng();\n  var y = -10 + 20*rng();\n  var set = (Math.random()*100 < appState.trainPct) ? 'train' : 'test';\n  appState.points.push({x:x,y:y,set:set});\n  pushState();\n  renderAll();\n}\n\nfunction exportCSV(){\n  var rows = ['x,y,set'];\n  appState.points.forEach(p=>rows.push([p.x,p.y,p.set].join(',')));\n  document.getElementById('stateBox').value = rows.join('\\n');\n}\n\nfunction importCSV(){\n  var txt = document.getElementById('stateBox').value.trim();\n  if(!txt) { alert('Paste CSV into the textarea first.'); return; }\n  var lines = txt.split(/\\r?\\n/);\n  var pts=[];\n  for(var i=1;i<lines.length;i++){\n    if(!lines[i].trim()) continue;\n    var parts = lines[i].split(',');\n    if(parts.length<2) continue;\n    var x=parseFloat(parts[0]), y=parseFloat(parts[1]), set=(parts[2]||'train');\n    pts.push({x:x,y:y,set:set});\n  }\n  appState.points = pts;\n  pushState();\n  renderAll();\n}\n\nfunction saveStateJSON(){\n  var s = JSON.stringify(appState, null, 2);\n  document.getElementById('stateBox').value = s;\n}\n\nfunction loadStateJSON(){\n  var txt = document.getElementById('stateBox').value.trim();\n  if(!txt) { alert('Paste JSON into the textarea first.'); return; }\n  try{\n    var obj = JSON.parse(txt);\n    // basic validation\n    if(!Array.isArray(obj.points)) throw 'Bad state';\n    appState = obj;\n    pushState();\n    renderAll();\n  } catch(e){ alert('Invalid JSON: ' + e); }\n}\n\n// Fitting and evaluation\nfunction splitPoints(){\n  var trainX=[], trainY=[], testX=[], testY=[];\n  appState.points.forEach(p=>{\n    if(p.set==='train'){ trainX.push(p.x); trainY.push(p.y); } else { testX.push(p.x); testY.push(p.y); }\n  });\n  return {trainX, trainY, testX, testY};\n}\n\nfunction fitCurrent(lambdaOverride){\n  var degree = parseInt(document.getElementById('degree').value);\n  var lambda = (typeof lambdaOverride==='number') ? lambdaOverride : parseFloat(document.getElementById('lambda').value) || 0;\n  var sp = splitPoints();\n  var model = fitPoly(sp.trainX, sp.trainY, degree, lambda);\n  appState.model = model;\n  appState.degree = degree;\n  appState.lambda = lambda;\n  // compute metrics\n  var predsTrain = sp.trainX.map(x=>predict(model,x));\n  var predsTest = sp.testX.map(x=>predict(model,x));\n  var trainMSE = sp.trainX.length ? mse(sp.trainY, predsTrain) : NaN;\n  var testMSE = sp.testX.length ? mse(sp.testY, predsTest) : NaN;\n  renderModelMetrics(trainMSE, testMSE, null, model);\n  pushState();\n  renderAll();\n}\n\nfunction renderModelMetrics(trainMSE, testMSE, cvMSE, model){\n  var s = 'Train MSE: ' + (isNaN(trainMSE)? '-' : trainMSE.toFixed(4)) + '<br>';\n  s += 'Test MSE: ' + (isNaN(testMSE)? '-' : testMSE.toFixed(4)) + '<br>';\n  s += 'CV MSE: ' + (cvMSE==null? '-' : (isNaN(cvMSE)? '-' : cvMSE.toFixed(4))) + '<br>';\n  if(model && model.coeffs){\n    s += 'Coefficients (a0..a' + (model.coeffs.length-1) + '): ' + model.coeffs.map(v=>v.toFixed(4)).join(', ') + '<br>';\n  } else s += 'Coeffs: -<br>';\n  document.getElementById('metrics').innerHTML = s;\n  var coeffsBox = document.getElementById('coeffsBox');\n  if(model && model.coeffs){\n    var html = '<table><tr><th>Index</th><th>Coeff</th></tr>';\n    for(var i=0;i<model.coeffs.length;i++){\n      html += '<tr><td>' + i + '</td><td><input data-idx=\"'+i+'\" value=\"'+model.coeffs[i].toFixed(6)+'\" style=\"width:120px\"></td></tr>';\n    }\n    html += '</table>';\n    coeffsBox.innerHTML = html;\n    // enable editing coefficients\n    coeffsBox.querySelectorAll('input').forEach(inp=>{\n      inp.addEventListener('change', function(){\n        var idx = parseInt(this.getAttribute('data-idx'));\n        var val = parseFloat(this.value) || 0;\n        appState.model.coeffs[idx]=val;\n        pushState();\n        renderAll();\n      });\n    });\n  } else coeffsBox.innerHTML = 'No model fitted yet.';\n}\n\n// Cross-validation\nfunction runCV(k){\n  var sp = splitPoints();\n  var X = sp.trainX.slice(), Y = sp.trainY.slice();\n  if(X.length < k) { alert('Not enough training points for that many folds.'); return; }\n  // create folds\n  var idx = Array.from({length:X.length}, (_,i)=>i);\n  // shuffle deterministically based on seed\n  var rng = mulberry32(appState.seed || 1);\n  for(var i=idx.length-1;i>0;i--){ var j=Math.floor(rng()* (i+1)); var t=idx[i]; idx[i]=idx[j]; idx[j]=t; }\n  var folds = [];\n  for(var i=0;i<k;i++) folds[i]=[];\n  for(var i=0;i<idx.length;i++) folds[i%k].push(idx[i]);\n  var degree = parseInt(document.getElementById('degree').value);\n  var lambda = parseFloat(document.getElementById('lambda').value) || 0;\n  var mses=[];\n  for(var f=0;f<k;f++){\n    var trainIdx = []; var valIdx = folds[f];\n    for(var i=0;i<idx.length;i++) if(!valIdx.includes(idx[i])) trainIdx.push(idx[i]);\n    var tX = trainIdx.map(i=>X[i]), tY = trainIdx.map(i=>Y[i]);\n    var vX = valIdx.map(i=>X[i]), vY = valIdx.map(i=>Y[i]);\n    var model = fitPoly(tX, tY, degree, lambda);\n    var preds = vX.map(x=>predict(model,x));\n    mses.push(mse(vY, preds));\n  }\n  var avg = mses.reduce((a,b)=>a+b,0)/mses.length;\n  renderModelMetrics(null,null,avg, appState.model);\n  document.getElementById('gridResults').innerHTML = 'CV MSE (k=' + k + '): ' + avg.toFixed(6);\n  return avg;\n}\n\n// Grid search over degree and lambda using CV on training set\nfunction runGridSearch(){\n  var k = parseInt(document.getElementById('kfolds').value) || 5;\n  var maxDeg = parseInt(document.getElementById('gridMaxDeg').value) || 6;\n  var lambdas = document.getElementById('gridLambdas').value.split(',').map(s=>parseFloat(s.trim())).filter(x=>!isNaN(x));\n  var sp = splitPoints();\n  var X = sp.trainX.slice(), Y = sp.trainY.slice();\n  if(X.length<2){ alert('Not enough training points.'); return; }\n  var results = [];\n  for(var deg=0; deg<=maxDeg; deg++){\n    for(var li=0; li<lambdas.length; li++){\n      var lambda = lambdas[li];\n      // k-fold CV\n      var idx = Array.from({length:X.length}, (_,i)=>i);\n      var rngi = mulberry32(appState.seed || 1);\n      for(var i=idx.length-1;i>0;i--){ var j=Math.floor(rngi()* (i+1)); var t=idx[i]; idx[i]=idx[j]; idx[j]=t; }\n      var folds=[]; for(var i=0;i<k;i++) folds[i]=[];\n      for(var i=0;i<idx.length;i++) folds[i%k].push(idx[i]);\n      var mses=[];\n      for(var f=0; f<k; f++){\n        var valIdx = folds[f];\n        var trainIdx = idx.filter(i=>!valIdx.includes(i));\n        var tX=trainIdx.map(i=>X[i]), tY=trainIdx.map(i=>Y[i]);\n        var vX=valIdx.map(i=>X[i]), vY=valIdx.map(i=>Y[i]);\n        var model = fitPoly(tX,tY,deg,lambda);\n        var preds = vX.map(x=>predict(model,x));\n        mses.push(mse(vY,preds));\n      }\n      var avg = mses.reduce((a,b)=>a+b,0)/mses.length;\n      results.push({deg:deg,lambda:lambda,cv:avg});\n    }\n  }\n  results.sort((a,b)=>a.cv-b.cv);\n  var out = '<table><tr><th>Rank</th><th>Degree</th><th>Lambda</th><th>CV MSE</th></tr>';\n  for(var i=0;i<Math.min(20,results.length);i++){\n    out += '<tr><td>'+(i+1)+'</td><td>'+results[i].deg+'</td><td>'+results[i].lambda+'</td><td>'+results[i].cv.toFixed(6)+'</td></tr>';\n  }\n  out += '</table>';\n  document.getElementById('gridResults').innerHTML = out;\n  // auto-select best\n  var best = results[0];\n  document.getElementById('degree').value = best.deg;\n  document.getElementById('degreeVal').textContent = best.deg;\n  document.getElementById('lambda').value = best.lambda;\n  document.getElementById('lambdaVal').textContent = best.lambda;\n  fitCurrent(best.lambda);\n}\n\n// Sweep degrees, computing train/test MSEs\nvar sweepRunning = false;\nasync function runSweep(){\n  var from = parseInt(document.getElementById('sweepFrom').value) || 0;\n  var to = parseInt(document.getElementById('sweepTo').value) || 10;\n  var step = parseInt(document.getElementById('sweepStep').value) || 1;\n  var sp = splitPoints();\n  var Xtrain = sp.trainX, Ytrain = sp.trainY, Xtest=sp.testX, Ytest=sp.testY;\n  if(Xtrain.length===0){ alert('No training data'); return; }\n  sweepRunning = true;\n  document.getElementById('sweepResults').innerHTML = 'Running sweep...';\n  var lines = [];\n  for(var d=from; d<=to; d+=step){\n    if(!sweepRunning) break;\n    var model = fitPoly(Xtrain, Ytrain, d, parseFloat(document.getElementById('lambda').value)||0);\n    var trainPred = Xtrain.map(x=>predict(model,x));\n    var testPred = Xtest.map(x=>predict(model,x));\n    var tr = Xtrain.length?mse(Ytrain, trainPred):NaN;\n    var te = Xtest.length?mse(Ytest, testPred):NaN;\n    lines.push({deg:d,train:tr,test:te});\n    document.getElementById('sweepResults').innerHTML = JSON.stringify(lines, null, 2);\n    renderSweepPlot(lines);\n    await new Promise(r=>setTimeout(r,50));\n  }\n  sweepRunning = false;\n}\n\n// basic plot of sweep results (textual and mini-plot on main canvas)\nfunction renderSweepPlot(lines){\n  // small plot below metrics using the canvas right side area\n  // we'll draw a small overlay on the left of canvas to visualize the trend\n  // For minimal UI, just update text summary\n  var txt = 'Degree sweep results (deg, trainMSE, testMSE):\\n';\n  lines.forEach(l=> txt += l.deg + ' , ' + (isNaN(l.train)? '-' : l.train.toFixed(4)) + ' , ' + (isNaN(l.test)? '-' : l.test.toFixed(4)) + '\\n');\n  document.getElementById('sweepResults').innerText = txt;\n}\n\n// Bootstrap bias-variance\nfunction runBootstrap(){\n  var nBoot = parseInt(document.getElementById('nBoot').value) || 200;\n  var evalPts = parseInt(document.getElementById('evalPts').value) || 100;\n  var sp = splitPoints();\n  var Xtrain = sp.trainX, Ytrain = sp.trainY, Xtest = sp.testX, Ytest = sp.testY;\n  if(Xtrain.length===0){ alert('No training data'); return; }\n  // choose evaluation points across data range\n  var xmin = Math.min.apply(null, Xtrain.concat(Xtest)), xmax = Math.max.apply(null, Xtrain.concat(Xtest));\n  var evalXs = [];\n  for(var i=0;i<evalPts;i++) evalXs.push(xmin + (xmax-xmin)*(i/(evalPts-1)));\n  var degree = parseInt(document.getElementById('degree').value);\n  var lambda = parseFloat(document.getElementById('lambda').value) || 0;\n  var predsAll = evalXs.map(()=>[]);\n  var rng = mulberry32(appState.seed || 1);\n  for(var b=0;b<nBoot;b++){\n    // sample with replacement from training set\n    var bx=[], by=[];\n    for(var i=0;i<Xtrain.length;i++){ var j = Math.floor(rng()*Xtrain.length); bx.push(Xtrain[j]); by.push(Ytrain[j]); }\n    var model = fitPoly(bx, by, degree, lambda);\n    for(var i=0;i<evalXs.length;i++) predsAll[i].push(predict(model, evalXs[i]));\n  }\n  // compute bias^2 and variance; assume true function unknown: approximate by test true values nearest or use average of actual Ys?\n  // We'll estimate expected squared error = variance + bias^2 + noise (we approximate bias using mean prediction - actual if test exists near point)\n  var variances = [], biasesq = [], means=[];\n  for(var i=0;i<evalXs.length;i++){\n    var arr = predsAll[i];\n    var mean = arr.reduce((a,b)=>a+b,0)/arr.length;\n    means.push(mean);\n    var varr = arr.reduce((a,b)=>a+(b-mean)*(b-mean),0)/arr.length;\n    variances.push(varr);\n    // estimate bias^2 by difference to true underlying function approximated by nearest test point if available, else 0\n    var xi = evalXs[i];\n    var nearestIdx = -1, nd=Infinity;\n    for(var j=0;j<Xtest.length;j++){ var d=Math.abs(Xtest[j]-xi); if(d<nd){ nd=d; nearestIdx=j; } }\n    var bias2 = 0;\n    if(nearestIdx>=0 && nd < (xmax-xmin)/evalPts*2){\n      var truey = Ytest[nearestIdx];\n      bias2 = (mean - truey)*(mean - truey);\n    } else {\n      bias2 = (0); // unknown; we attach 0 as conservative placeholder\n    }\n    biasesq.push(bias2);\n  }\n  var avgVar = variances.reduce((a,b)=>a+b,0)/variances.length;\n  var avgBias2 = biasesq.reduce((a,b)=>a+b,0)/biasesq.length;\n  var out = 'Bootstrap results (approx):\\nAverage Variance: ' + avgVar.toFixed(6) + '\\nAverage Bias^2 (approx): ' + avgBias2.toFixed(6) + '\\nAverage Var+Bias^2: ' + (avgVar+avgBias2).toFixed(6);\n  document.getElementById('bootstrapResults').innerText = out;\n}\n\n// Rendering points and model on canvas\nfunction renderAll(){\n  // update UI values\n  document.getElementById('numPointsVal').textContent = document.getElementById('numPoints').value;\n  document.getElementById('noiseVal').textContent = document.getElementById('noise').value;\n  document.getElementById('trainPctVal').textContent = document.getElementById('trainPct').value + '%';\n  document.getElementById('degreeVal').textContent = document.getElementById('degree').value;\n  document.getElementById('lambdaVal').textContent = document.getElementById('lambda').value;\n  // draw\n  ctx.clearRect(0,0,plot.width,plot.height);\n  // axes\n  ctx.beginPath();\n  ctx.moveTo(40,10); ctx.lineTo(40,plot.height-30); ctx.lineTo(plot.width-10,plot.height-30);\n  ctx.stroke();\n  // compute data bounds\n  var xs = appState.points.map(p=>p.x);\n  var ys = appState.points.map(p=>p.y);\n  var xmin = xs.length?Math.min.apply(null,xs):-3, xmax = xs.length?Math.max.apply(null,xs):3;\n  var ymin = ys.length?Math.min.apply(null,ys):-1, ymax = ys.length?Math.max.apply(null,ys):1;\n  if(xmin===xmax){ xmin-=1; xmax+=1; }\n  if(ymin===ymax){ ymin-=1; ymax+=1; }\n  // padding\n  var left = 40, top = 10, right = plot.width-10, bottom = plot.height-30;\n  function x2px(x){ return left + ( (x-xmin) / (xmax-xmin) ) * (right-left); }\n  function y2px(y){ return bottom - ( (y-ymin)/(ymax-ymin) ) * (bottom-top); }\n  // grid lines ticks minimal\n  for(var t=0;t<=4;t++){\n    var xv = xmin + (xmax-xmin)*(t/4);\n    ctx.fillText(xv.toFixed(2), left + (right-left)*(t/4)-10, bottom+15);\n  }\n  for(var t=0;t<=4;t++){\n    var yv = ymin + (ymax-ymin)*(t/4);\n    ctx.fillText(yv.toFixed(2), 4, bottom - (bottom-top)*(t/4)+4);\n  }\n  // draw predicted curve if model exists\n  if(appState.model && appState.model.coeffs){\n    var model = appState.model;\n    var steps = 400;\n    ctx.beginPath();\n    for(var i=0;i<=steps;i++){\n      var xx = xmin + (xmax-xmin)*(i/steps);\n      var yy = predict(model, xx);\n      var px = x2px(xx), py = y2px(yy);\n      if(i===0) ctx.moveTo(px,py); else ctx.lineTo(px,py);\n    }\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    ctx.lineWidth = 1;\n    // draw residual lines for train points\n    appState.points.forEach(p=>{\n      if(p.set==='train'){\n        var px = x2px(p.x), py = y2px(p.y);\n        var pyPred = y2px(predict(model, p.x));\n        ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(px,pyPred); ctx.stroke();\n      }\n    });\n  }\n  // draw points\n  appState.points.forEach(p=>{\n    var px = x2px(p.x), py = y2px(p.y);\n    ctx.beginPath();\n    ctx.arc(px,py,4,0,Math.PI*2);\n    if(p.set==='train'){\n      ctx.fill(); ctx.stroke();\n    } else {\n      ctx.stroke(); ctx.beginPath(); ctx.arc(px,py,6,0,Math.PI*2); ctx.stroke();\n    }\n  });\n}\n\n// Canvas interactions: dragging, adding, deleting\nvar dragging = null;\nvar dragOffset = {x:0,y:0};\nplot.addEventListener('mousedown', function(e){\n  var rect = plot.getBoundingClientRect();\n  var cx = e.clientX - rect.left, cy = e.clientY - rect.top;\n  var hit = nearestPoint(cx,cy);\n  if(document.getElementById('addPointMode').checked){\n    // add new point\n    var p = canvasToData(cx,cy);\n    var set = (Math.random()*100 < document.getElementById('trainPct').value) ? 'train' : 'test';\n    appState.points.push({x:p.x,y:p.y,set:set});\n    pushState();\n    renderAll();\n    return;\n  }\n  if(hit && hit.dist < 10){\n    dragging = hit.idx;\n    dragOffset.x = hit.px - cx;\n    dragOffset.y = hit.py - cy;\n  }\n});\nplot.addEventListener('mousemove', function(e){\n  if(dragging===null) return;\n  var rect = plot.getBoundingClientRect();\n  var cx = e.clientX - rect.left + dragOffset.x, cy = e.clientY - rect.top + dragOffset.y;\n  var p = canvasToData(cx,cy);\n  if(appState.points[dragging]){\n    appState.points[dragging].x = p.x;\n    appState.points[dragging].y = p.y;\n    renderAll();\n  }\n});\nplot.addEventListener('mouseup', function(e){\n  if(dragging!==null){\n    pushState();\n  }\n  dragging = null;\n});\nplot.addEventListener('mouseleave', function(){ if(dragging!==null){ pushState(); dragging=null; } });\n\nfunction nearestPoint(cx,cy){\n  // find nearest canvas-space point\n  var xs = appState.points.map(p=>p.x);\n  var ys = appState.points.map(p=>p.y);\n  var xmin = xs.length?Math.min.apply(null,xs):-3, xmax = xs.length?Math.max.apply(null,xs):3;\n  var ymin = ys.length?Math.min.apply(null,ys):-1, ymax = ys.length?Math.max.apply(null,ys):1;\n  var left = 40, top = 10, right = plot.width-10, bottom = plot.height-30;\n  function x2px(x){ return left + ( (x-xmin) / (xmax-xmin) ) * (right-left); }\n  function y2px(y){ return bottom - ( (y-ymin)/(ymax-ymin) ) * (bottom-top); }\n  var minD = Infinity, idx=-1, px=0, py=0;\n  for(var i=0;i<appState.points.length;i++){\n    var p = appState.points[i];\n    var px0 = x2px(p.x), py0 = y2px(p.y);\n    var d = Math.hypot(px0-cx, py0-cy);\n    if(d<minD){ minD=d; idx=i; px=px0; py=py0; }\n  }\n  if(idx===-1) return null;\n  return {idx:idx, dist:minD, px:px, py:py};\n}\nfunction canvasToData(cx,cy){\n  var xs = appState.points.map(p=>p.x);\n  var ys = appState.points.map(p=>p.y);\n  var xmin = xs.length?Math.min.apply(null,xs):-3, xmax = xs.length?Math.max.apply(null,xs):3;\n  var ymin = ys.length?Math.min.apply(null,ys):-1, ymax = ys.length?Math.max.apply(null,ys):1;\n  if(xmin===xmax){ xmin -= 1; xmax += 1; }\n  if(ymin===ymax){ ymin -= 1; ymax += 1; }\n  var left = 40, top = 10, right = plot.width-10, bottom = plot.height-30;\n  var x = xmin + ( (cx - left) / (right-left) ) * (xmax-xmin);\n  var y = ymin + ( (bottom - cy) / (bottom-top) ) * (ymax-ymin);\n  return {x:x, y:y};\n}\n\n// delete nearest point to center click\nfunction deleteNearest(){\n  // delete nearest to center of canvas\n  var rect = plot.getBoundingClientRect();\n  var cx = rect.width/2, cy = rect.height/2;\n  // actually use mouse-free: pick nearest to center of axes\n  var hit = nearestPoint(cx,cy);\n  if(!hit) return;\n  appState.points.splice(hit.idx,1);\n  pushState();\n  renderAll();\n}\n\n// UI wiring\ndocument.getElementById('genData').addEventListener('click', generateData);\ndocument.getElementById('fitModel').addEventListener('click', function(){ fitCurrent(0); });\ndocument.getElementById('fitWithReg').addEventListener('click', function(){ fitCurrent(parseFloat(document.getElementById('lambda').value)||0); });\ndocument.getElementById('clearPoints').addEventListener('click', clearPoints);\ndocument.getElementById('addOutlier').addEventListener('click', addRandomOutlier);\ndocument.getElementById('undo').addEventListener('click', undo);\ndocument.getElementById('redo').addEventListener('click', redo);\ndocument.getElementById('saveState').addEventListener('click', saveStateJSON);\ndocument.getElementById('loadStateBtn').addEventListener('click', loadStateJSON);\ndocument.getElementById('exportCSV').addEventListener('click', exportCSV);\ndocument.getElementById('importCSVBtn').addEventListener('click', importCSV);\ndocument.getElementById('deleteNearest').addEventListener('click', function(){\n  // choose point nearest to last mouse position or to center if none\n  // we'll delete the globally nearest point to canvas center\n  var rect = plot.getBoundingClientRect();\n  var cx = rect.width/2, cy = rect.height/2;\n  var hit = nearestPoint(cx,cy);\n  if(hit) { appState.points.splice(hit.idx,1); pushState(); renderAll(); }\n});\n\ndocument.getElementById('numPoints').addEventListener('input', function(){ document.getElementById('numPointsVal').textContent = this.value; });\ndocument.getElementById('noise').addEventListener('input', function(){ document.getElementById('noiseVal').textContent = this.value; });\ndocument.getElementById('trainPct').addEventListener('input', function(){ document.getElementById('trainPctVal').textContent = this.value + '%'; });\ndocument.getElementById('degree').addEventListener('input', function(){ document.getElementById('degreeVal').textContent = this.value; });\ndocument.getElementById('lambda').addEventListener('input', function(){ document.getElementById('lambdaVal').textContent = this.value; });\n\ndocument.getElementById('runCV').addEventListener('click', function(){ runCV(parseInt(document.getElementById('kfolds').value)||5); });\ndocument.getElementById('runGrid').addEventListener('click', runGridSearch);\ndocument.getElementById('runSweep').addEventListener('click', runSweep);\ndocument.getElementById('stopSweep').addEventListener('click', function(){ sweepRunning=false; });\ndocument.getElementById('runBootstrap').addEventListener('click', runBootstrap);\n\ndocument.getElementById('stateBox').addEventListener('change', function(){ /* placeholder */ });\n\ndocument.getElementById('degree').value = appState.degree;\ndocument.getElementById('lambda').value = appState.lambda;\n\n// initial data\npushState();\ngenerateData();\n\n// keyboard shortcuts for power users\ndocument.addEventListener('keydown', function(e){\n  if(e.key==='z' && (e.ctrlKey||e.metaKey)){ undo(); }\n  if(e.key==='y' && (e.ctrlKey||e.metaKey)){ redo(); }\n  if(e.key==='g'){ generateData(); }\n  if(e.key==='f'){ fitCurrent(); }\n});\n\n// allow saving/loading app state via JSON on the textarea using buttons\n// done above\n\n</script>\n\n</body>\n</html>"
