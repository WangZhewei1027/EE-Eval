    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>CPU Scheduling — Visual Demonstration</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #081120;\n    --card: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.03);\n    --accent: linear-gradient(135deg,#7b5cff,#00d4ff);\n    --muted: rgba(255,255,255,0.6);\n    --glass-border: rgba(255,255,255,0.06);\n    --success: #22c55e;\n    --danger: #ff6b6b;\n  }\n\n  /* Page */\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1000px 500px at 10% 10%, rgba(123,92,255,0.08), transparent 6%),\n                radial-gradient(900px 400px at 90% 90%, rgba(0,212,255,0.04), transparent 8%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Layout */\n  .wrap{\n    display:grid;\n    grid-template-columns: 380px 1fr 360px;\n    gap:28px;\n    padding:36px;\n    height:100vh;\n    box-sizing:border-box;\n  }\n\n  /* Left panel (intro & legend) */\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:18px;\n    padding:28px;\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid var(--glass-border);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .brand{\n    display:flex;\n    gap:14px;\n    align-items:center;\n  }\n  .logo{\n    width:64px;height:64px;border-radius:14px;\n    background:linear-gradient(135deg,#7b5cff,#00d4ff);\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 6px 18px rgba(123,92,255,0.16);\n    font-weight:700;font-size:20px;color:white;\n    transform:skewX(-6deg);\n  }\n  h1{\n    margin:0;font-size:20px;letter-spacing:-0.4px;\n  }\n  p.lead{margin:0;color:var(--muted);font-size:13px;line-height:1.4}\n\n  .legend{\n    margin-top:6px;\n    display:flex;flex-direction:column;gap:10px;\n  }\n  .legend-item{\n    display:flex;gap:12px;align-items:center;font-size:13px;color:var(--muted);\n  }\n  .chip{width:44px;height:28px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-weight:700;color:#051024;box-shadow:0 4px 14px rgba(2,6,23,0.45)}\n  .chip-small{width:14px;height:14px;border-radius:4px;box-shadow:0 2px 8px rgba(2,6,23,0.35)}\n  .muted{color:var(--muted);font-size:13px}\n\n  /* Center visualization */\n  .canvas-card{\n    position:relative;\n    border-radius:20px;\n    padding:34px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 20px 60px rgba(2,6,23,0.65), inset 0 1px 0 rgba(255,255,255,0.02);\n    overflow:hidden;\n  }\n\n  .top-row{\n    display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;\n  }\n  .title{\n    display:flex;flex-direction:column;\n  }\n  .title h2{margin:0;font-size:18px}\n  .title p{margin:0;color:var(--muted);font-size:13px}\n\n  .controls{\n    display:flex;gap:10px;align-items:center;\n  }\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    color:white;padding:10px 14px;border-radius:12px;font-weight:600;\n    cursor:pointer;display:inline-flex;gap:10px;align-items:center;backdrop-filter: blur(6px);\n    transition:transform .18s ease, box-shadow .18s ease, opacity .18s;\n  }\n  .btn:hover{transform:translateY(-3px)}\n  .btn:active{transform:translateY(-1px)}\n  .btn.secondary{background:transparent;border:1px dashed rgba(255,255,255,0.03);font-weight:600}\n\n  /* Main visual area */\n  .visual{\n    display:flex;align-items:stretch;height:calc(100% - 96px);\n    gap:20px;\n  }\n\n  .lane{\n    flex:1;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:14px;padding:18px;position:relative;border:1px solid rgba(255,255,255,0.02);\n    display:flex;flex-direction:column;gap:12px;\n  }\n\n  .ready{\n    width:220px;min-width:220px;max-width:260px;\n    display:flex;flex-direction:column;gap:12px;align-items:flex-start;\n  }\n\n  .label{font-size:12px;color:var(--muted);letter-spacing:0.6px}\n  .queue{\n    width:100%;min-height:220px;border-radius:12px;padding:12px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    display:flex;flex-direction:column;gap:10px;align-items:flex-start;justify-content:flex-start;\n    border:1px dashed rgba(255,255,255,0.02);\n  }\n\n  .proc{\n    min-width:120px;padding:10px 12px;border-radius:12px;color:#021025;font-weight:700;\n    display:inline-flex;gap:10px;align-items:center;justify-content:flex-start;\n    box-shadow:0 8px 22px rgba(2,6,23,0.45);\n    transition:transform .6s cubic-bezier(.2,.9,.2,1), opacity .4s ease;\n    transform-origin:left center;\n  }\n  .proc .dot{width:12px;height:12px;border-radius:3px}\n  .proc small{font-weight:600;font-size:12px;color:rgba(0,0,0,0.4)}\n\n  .scheduler{\n    width:160px;height:160px;border-radius:18px;background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.00));\n    display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;\n    border:1px solid rgba(255,255,255,0.02);\n    margin:auto;\n  }\n  .gear{\n    width:88px;height:88px;border-radius:22px;background:linear-gradient(135deg,#0b2235,#122744);\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 2px 0 rgba(255,255,255,0.02);\n    position:relative;overflow:hidden;\n    transition:transform .7s cubic-bezier(.2,.9,.2,1);\n  }\n  .gear svg{filter:drop-shadow(0 6px 18px rgba(0,0,0,0.8));}\n  .gear.spin{animation:gear-spin 8s linear infinite}\n\n  @keyframes gear-spin{\n    from{transform:rotate(0deg)}to{transform:rotate(360deg)}\n  }\n\n  .cpu{\n    flex:1;border-radius:12px;padding:18px;display:flex;flex-direction:column;gap:8px;align-items:center;justify-content:center;\n    position:relative;border:1px dashed rgba(255,255,255,0.02);\n  }\n  .cpu-core{\n    width:220px;height:120px;border-radius:14px;background:linear-gradient(180deg,#021428,#082634);\n    display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:var(--muted);\n    box-shadow: 0 20px 60px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n  }\n  .core-top{display:flex;gap:12px;align-items:center}\n  .core-title{font-weight:700;font-size:16px}\n  .cpu-slot{position:absolute;left:50%;transform:translateX(-50%);bottom:10px;transition:all .6s cubic-bezier(.2,.9,.2,1)}\n\n  .completed{\n    width:100%;min-height:80px;border-radius:12px;padding:12px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    display:flex;align-items:center;gap:8px;flex-wrap:wrap;border-top:1px dashed rgba(255,255,255,0.02);\n  }\n\n  /* Gantt area */\n  .gantt{\n    margin-top:16px;padding:12px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;flex-direction:column;gap:8px;\n  }\n  .gantt-canvas{\n    height:72px;width:100%;background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:8px;position:relative;overflow:hidden;\n  }\n  .timebar{\n    position:absolute;left:0;top:0;height:100%;display:flex;align-items:center;gap:0;\n  }\n  .tlabel{position:absolute;bottom:-20px;font-size:12px;color:var(--muted)}\n  .gantt-legend{display:flex;gap:10px;align-items:center;flex-wrap:wrap;font-size:12px;color:var(--muted)}\n\n  /* Right info panel */\n  .info{\n    padding:28px;border-radius:18px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.55);\n    display:flex;flex-direction:column;gap:16px;\n  }\n\n  .specs{display:flex;flex-direction:column;gap:8px}\n  .spec-pill{display:flex;justify-content:space-between;align-items:center;padding:12px;border-radius:12px;background:rgba(255,255,255,0.02);font-weight:700}\n  .footer{margin-top:auto;font-size:12px;color:var(--muted)}\n\n  /* small */\n  .small{font-size:12px;color:var(--muted)}\n  .muted-2{color:rgba(255,255,255,0.04)}\n  .faded{opacity:0.6}\n\n  /* Responsiveness */\n  @media (max-width:1100px){\n    .wrap{grid-template-columns: 1fr; padding:20px; grid-auto-rows: auto; height:auto;}\n    .canvas-card{height:640px}\n    .visual{flex-direction:column}\n    .ready{width:100%}\n  }\n\n</style>\n</head>\n<body>\n<div class=\"wrap\" role=\"main\" aria-label=\"CPU Scheduling visualization\">\n  <!-- Left panel -->\n  <section class=\"panel\" aria-hidden=\"false\">\n    <div class=\"brand\">\n      <div class=\"logo\">CS</div>\n      <div>\n        <h1>CPU Scheduling</h1>\n        <p class=\"lead\">An elegant, animated demonstration that reveals how processes flow through the scheduler to the CPU — clarity through motion.</p>\n      </div>\n    </div>\n\n    <div class=\"legend\">\n      <div class=\"legend-item\">\n        <div class=\"chip\" style=\"background:linear-gradient(90deg,#ffd166,#ff7b00)\">FCFS</div>\n        <div class=\"muted\">First-Come, First-Served (visualized)</div>\n      </div>\n      <div class=\"legend-item\">\n        <div class=\"chip-small\" style=\"background:#7b5cff\"></div>\n        <div class=\"muted\">Process waiting</div>\n      </div>\n      <div class=\"legend-item\">\n        <div class=\"chip-small\" style=\"background:#00d4ff\"></div>\n        <div class=\"muted\">Running on CPU</div>\n      </div>\n      <div class=\"legend-item\">\n        <div class=\"chip-small\" style=\"background:#9be15d\"></div>\n        <div class=\"muted\">Completed</div>\n      </div>\n    </div>\n\n    <div style=\"flex:1\"></div>\n\n    <div class=\"small\">\n      Tip: This demonstration uses a small FCFS scenario. Use the controls on the right to play, pause, or restart. Observe how arrival times and bursts determine order.\n    </div>\n  </section>\n\n  <!-- Center visualization -->\n  <section class=\"canvas-card\" aria-label=\"Visualization area\">\n    <div class=\"top-row\">\n      <div class=\"title\">\n        <h2>FCFS — Flow of Processes</h2>\n        <p>Watch processes arrive, queue, and execute. The Gantt chart below traces execution over time.</p>\n      </div>\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button id=\"playBtn\" class=\"btn\" title=\"Play / Pause (space)\">\n          <svg id=\"playIcon\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.95\">\n            <path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path>\n          </svg>\n          <span id=\"playLabel\">Play</span>\n        </button>\n        <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset\">\n          <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\">\n            <path d=\"M21 12a9 9 0 1 1-3-6.71\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n            <path d=\"M21 3v6h-6\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n          </svg>\n          Reset\n        </button>\n      </div>\n    </div>\n\n    <div class=\"visual\" aria-hidden=\"false\">\n      <!-- Ready queue -->\n      <div class=\"lane ready\" aria-label=\"Ready queue\">\n        <div class=\"label\">Ready Queue</div>\n        <div class=\"queue\" id=\"queueArea\">\n          <!-- Process tokens inserted here -->\n        </div>\n\n        <div class=\"label\" style=\"margin-top:6px\">Scheduler</div>\n        <div class=\"scheduler\">\n          <div class=\"gear\" id=\"gear\">\n            <svg width=\"64\" height=\"64\" viewBox=\"0 0 24 24\"><path fill=\"#a8d8ff\" opacity=\"0.06\" d=\"M0 0h24v24H0z\"></path>\n              <path d=\"M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z\" fill=\"#00d4ff\" opacity=\"0.88\"></path>\n              <path d=\"M21 12a9 9 0 0 0-.2-2l1.9-1.5-2-3.5-2.2.6A8.9 8.9 0 0 0 12 3.2V1H8v2.2A8.9 8.9 0 0 0 5.5 4.1L3.3 3.5.9 7 2.8 8.5A9 9 0 0 0 3 12c0 .7.1 1.4.2 2L.9 15.5 2.9 19l2.4-.8c.8.5 1.7.9 2.6 1.2V23h4v-2.2c.9-.2 1.8-.6 2.6-1.2l2.4.8 2-3.5-1.9-1.5c.1-.6.2-1.3.2-2z\" fill=\"#07263a\" opacity=\"0.18\"></path>\n            </svg>\n          </div>\n          <div class=\"muted small\">Scheduler active</div>\n        </div>\n      </div>\n\n      <!-- CPU area -->\n      <div class=\"lane cpu\" aria-label=\"CPU\">\n        <div class=\"label\">CPU Cores</div>\n        <div class=\"cpu-core\" id=\"cpuCore\" aria-live=\"polite\">\n          <div class=\"core-top\">\n            <div style=\"width:10px;height:10px;border-radius:4px;background:#9be15d;box-shadow:0 4px 12px rgba(155,225,93,0.15)\"></div>\n            <div class=\"core-title\">Core 0</div>\n          </div>\n          <div class=\"small\">Processing will appear here</div>\n          <div class=\"cpu-slot\" id=\"cpuSlot\">\n            <!-- active process token gets positioned here -->\n          </div>\n        </div>\n\n        <div class=\"label\" style=\"margin-top:8px\">Completed</div>\n        <div class=\"completed\" id=\"doneArea\" aria-live=\"polite\">\n          <!-- completed tokens -->\n        </div>\n      </div>\n\n      <!-- Gantt & info mini -->\n      <div class=\"lane\" style=\"width:360px;min-width:260px;max-width:360px\">\n        <div class=\"label\">Gantt Chart</div>\n        <div class=\"gantt\">\n          <div class=\"gantt-canvas\" id=\"ganttCanvas\">\n            <div id=\"ganttTimebar\" class=\"timebar\"></div>\n            <canvas id=\"ganttDraw\" width=\"640\" height=\"72\" style=\"display:block;\"></canvas>\n          </div>\n          <div class=\"gantt-legend\">\n            <div style=\"display:flex;gap:8px;align-items:center\"><div style=\"width:12px;height:12px;background:#ffd166;border-radius:3px\"></div><div class=\"small\">Execution</div></div>\n            <div style=\"display:flex;gap:8px;align-items:center\"><div style=\"width:12px;height:12px;background:rgba(255,255,255,0.04);border-radius:3px\"></div><div class=\"small\">Idle / Wait</div></div>\n            <div style=\"display:flex;gap:8px;align-items:center\"><div style=\"width:12px;height:12px;background:#9be15d;border-radius:3px\"></div><div class=\"small\">Done</div></div>\n          </div>\n        </div>\n\n        <div style=\"height:18px\"></div>\n\n        <div class=\"label\">Process Summary</div>\n        <div style=\"display:flex;flex-direction:column;gap:8px;margin-top:8px\" id=\"processSummary\">\n          <!-- list -->\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Right info panel -->\n  <aside class=\"info\" aria-hidden=\"false\">\n    <div style=\"display:flex;justify-content:space-between;align-items:center\">\n      <div>\n        <div style=\"font-weight:800;font-size:18px\">Scenario</div>\n        <div class=\"small\">Deterministic FCFS demonstration</div>\n      </div>\n      <div style=\"text-align:right\">\n        <div class=\"small faded\">Total time</div>\n        <div id=\"totalTime\" style=\"font-weight:800;font-size:18px\">—</div>\n      </div>\n    </div>\n\n    <div class=\"specs\">\n      <div class=\"spec-pill\"><div class=\"small\">Processes</div><div id=\"specCount\" style=\"font-weight:800\">—</div></div>\n      <div class=\"spec-pill\"><div class=\"small\">Scheduling</div><div style=\"font-weight:800\">FCFS</div></div>\n      <div class=\"spec-pill\"><div class=\"small\">Speed</div><div style=\"font-weight:800\">1x (animated)</div></div>\n    </div>\n\n    <div class=\"footer\">\n      A minimal interactive demo — only Play/Pause and Reset controls. The visualization focuses on aesthetics: smooth motion, soft shadows, and a clear execution timeline.\n    </div>\n  </aside>\n</div>\n\n<script>\n/*\n  CPU Scheduling — FCFS Visual Demo\n  - Minimal controls: Play/Pause, Reset\n  - Predefined processes with arrival and burst times\n  - Gantt chart drawn on canvas, animated progression\n  - Tokens move from ready queue -> CPU -> completed\n*/\n\n(() => {\n  // Data: processes with arrival and burst (time units)\n  const processes = [\n    { id: 'P1', arrival: 0, burst: 3, color: '#ffd166' },\n    { id: 'P2', arrival: 1, burst: 5, color: '#7b5cff' },\n    { id: 'P3', arrival: 2, burst: 2, color: '#00d4ff' },\n    { id: 'P4', arrival: 4, burst: 4, color: '#ff7b9c' },\n    { id: 'P5', arrival: 6, burst: 1, color: '#9be15d' },\n    { id: 'P6', arrival: 7, burst: 2, color: '#ffa94d' }\n  ];\n\n  // compute FCFS schedule segments\n  function computeFCFS(list) {\n    const sorted = [...list].sort((a,b) => a.arrival - b.arrival);\n    let time = 0;\n    const segments = [];\n    for (const p of sorted) {\n      const start = Math.max(time, p.arrival);\n      const end = start + p.burst;\n      segments.push({ id: p.id, start, end, burst: p.burst, arrival: p.arrival, color: p.color });\n      time = end;\n    }\n    return { segments, total: time };\n  }\n\n  const { segments, total } = computeFCFS(processes);\n\n  // DOM elements\n  const queueArea = document.getElementById('queueArea');\n  const doneArea = document.getElementById('doneArea');\n  const cpuSlot = document.getElementById('cpuSlot');\n  const playBtn = document.getElementById('playBtn');\n  const playLabel = document.getElementById('playLabel');\n  const playIcon = document.getElementById('playIcon');\n  const resetBtn = document.getElementById('resetBtn');\n  const gear = document.getElementById('gear');\n  const totalTimeEl = document.getElementById('totalTime');\n  const specCountEl = document.getElementById('specCount');\n  const processSummary = document.getElementById('processSummary');\n  const ganttCanvas = document.getElementById('ganttDraw');\n  const ganttTimebar = document.getElementById('ganttTimebar');\n\n  // initial state\n  let simTime = 0; // simulation time in units\n  let playing = false;\n  const speed = 0.9; // real seconds per simulation unit (slower for aesthetics)\n  const pxPerUnit = 56; // pixels per simulation unit for Gantt scale\n  const totalPixels = Math.max(480, Math.ceil(total * pxPerUnit));\n  ganttCanvas.width = totalPixels;\n  document.getElementById('ganttCanvas').style.width = Math.min(totalPixels, 640) + 'px';\n\n  totalTimeEl.textContent = `${total} unit${total===1?'':'s'}`;\n  specCountEl.textContent = processes.length;\n\n  // Create tokens in queue\n  processes.forEach((p, i) => {\n    const el = document.createElement('div');\n    el.className = 'proc';\n    el.id = `token-${p.id}`;\n    el.style.background = p.color;\n    el.style.boxShadow = `0 10px 30px ${hexToRgba(p.color,0.12)}`;\n    el.innerHTML = `<div class=\"dot\" style=\"background:rgba(0,0,0,0.12)\"></div><div style=\"display:flex;flex-direction:column\"><div>${p.id}</div><small>arr ${p.arrival} • ${p.burst}u</small></div>`;\n    el.style.opacity = '0';\n    queueArea.appendChild(el);\n    // animate in with delay\n    setTimeout(()=> el.style.opacity = '1', 200 + i*110);\n  });\n\n  // populate summary\n  processes.forEach(p=>{\n    const row = document.createElement('div');\n    row.style.display = 'flex';\n    row.style.justifyContent = 'space-between';\n    row.style.alignItems = 'center';\n    row.style.gap = '12px';\n    row.innerHTML = `<div style=\"display:flex;gap:10px;align-items:center\"><div style=\"width:12px;height:12px;background:${p.color};border-radius:3px\"></div><div class=\"small\">${p.id}</div></div><div class=\"small\">A:${p.arrival} • B:${p.burst}</div>`;\n    processSummary.appendChild(row);\n  });\n\n  // draw static baseline of Gantt (time grid)\n  const ctx = ganttCanvas.getContext('2d');\n  function drawGanttBaseline(){\n    ctx.clearRect(0,0,ganttCanvas.width,ganttCanvas.height);\n    // background stripes\n    ctx.fillStyle = 'rgba(255,255,255,0.02)';\n    ctx.fillRect(0,0,ganttCanvas.width,ganttCanvas.height);\n\n    // vertical unit separators\n    ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n    ctx.lineWidth = 1;\n    for(let t=0;t<=total;t++){\n      const x = Math.round(t * pxPerUnit) + 0.5;\n      ctx.beginPath();\n      ctx.moveTo(x,0);\n      ctx.lineTo(x,ganttCanvas.height);\n      ctx.stroke();\n      // label\n      ctx.fillStyle = 'rgba(255,255,255,0.18)';\n      ctx.font = '10px Inter, system-ui';\n      ctx.fillText(t, x+4, ganttCanvas.height - 6);\n    }\n\n    // initial idle fill as subtle gradient\n    const g = ctx.createLinearGradient(0,0,ganttCanvas.width,0);\n    g.addColorStop(0, 'rgba(255,255,255,0.02)');\n    g.addColorStop(1, 'rgba(255,255,255,0.00)');\n    ctx.fillStyle = g;\n    ctx.fillRect(0,0,ganttCanvas.width,ganttCanvas.height);\n  }\n  drawGanttBaseline();\n\n  // state mapping segments per process\n  const segMap = {};\n  segments.forEach(s => {\n    segMap[s.id] = s;\n  });\n\n  // Create placeholders for gantt passive (we will fill execution progressively)\n  function drawExecutionUpTo(t){\n    // redraw baseline then draw execution rectangles for segments with start < t\n    drawGanttBaseline();\n    for(const seg of segments){\n      const segStart = seg.start;\n      const segEnd = seg.end;\n      if (t <= segStart) continue;\n      const filledEnd = Math.min(t, segEnd);\n      const sx = Math.round(segStart * pxPerUnit);\n      const sw = Math.round((filledEnd - segStart) * pxPerUnit);\n      ctx.fillStyle = hexToRgba(seg.color, 0.96);\n      ctx.fillRect(sx + 6, 12, Math.max(6, sw - 12), 40);\n      // stroke\n      ctx.strokeStyle = 'rgba(0,0,0,0.12)';\n      ctx.lineWidth = 1;\n      ctx.strokeRect(sx + 6, 12, Math.max(6, sw - 12), 40);\n\n      // label inside bar\n      ctx.fillStyle = '#021024';\n      ctx.font = '11px Inter, system-ui';\n      ctx.fillText(seg.id, sx + 14, 36);\n    }\n  }\n\n  // movement helper: move token element to a target (absolute position inside container)\n  function moveTo(el, targetRect, duration=700){\n    const from = el.getBoundingClientRect();\n    const parent = el.offsetParent.getBoundingClientRect();\n    // compute translation relative to current transform\n    const curX = from.left - parent.left;\n    const curY = from.top - parent.top;\n    const toX = targetRect.left - parent.left;\n    const toY = targetRect.top - parent.top;\n    // apply transform\n    el.style.transition = `transform ${duration}ms cubic-bezier(.2,.9,.2,1), opacity 300ms ease`;\n    el.style.transform = `translate(${toX - curX}px, ${toY - curY}px) scale(1.02)`;\n    // ensure reflow\n    setTimeout(()=>{ el.style.transform = `translate(${toX - curX}px, ${toY - curY}px) scale(1)`; }, 20);\n  }\n\n  // we'll use absolute positioning for moving tokens to CPU and done area by appending clones\n  function placeInCPU(tokenEl){\n    // clone and position into cpuSlot\n    const clone = tokenEl.cloneNode(true);\n    clone.id = tokenEl.id + '-active';\n    clone.style.position = 'absolute';\n    clone.style.left = '50%';\n    clone.style.transform = 'translateX(-50%) translateY(0)';\n    clone.style.bottom = '0';\n    clone.style.margin = '0';\n    clone.style.opacity = '0';\n    clone.style.pointerEvents = 'none';\n    clone.style.transition = 'opacity 200ms ease, transform 400ms cubic-bezier(.2,.9,.2,1)';\n    cpuSlot.appendChild(clone);\n    requestAnimationFrame(()=> clone.style.opacity = '1');\n    return clone;\n  }\n\n  function moveToDone(cloneEl){\n    cloneEl.style.transition = 'transform 700ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease';\n    // compute target inside doneArea, append there\n    doneArea.appendChild(cloneEl);\n    cloneEl.style.position = 'relative';\n    cloneEl.style.left = 'auto';\n    cloneEl.style.bottom = 'auto';\n    cloneEl.style.transform = 'translateY(0)';\n    // slight scale-down fading\n    setTimeout(()=> cloneEl.style.opacity = '0.98', 20);\n    cloneEl.style.opacity = '0.98';\n  }\n\n  // Simulation control\n  let lastTimestamp = 0;\n  let animRequest = null;\n\n  // Map to keep which token is active\n  const tokenMap = {};\n  processes.forEach(p=>{\n    tokenMap[p.id] = document.getElementById(`token-${p.id}`);\n  });\n\n  // Keep track of which process is in CPU (active clone reference)\n  let activeClone = null;\n\n  // Play/pause handling\n  playBtn.addEventListener('click', togglePlay);\n  resetBtn.addEventListener('click', resetSim);\n\n  // keyboard support: space toggles play/pause\n  window.addEventListener('keydown', (e) => {\n    if (e.code === 'Space'){ e.preventDefault(); togglePlay(); }\n  });\n\n  function togglePlay(){\n    playing = !playing;\n    if (playing){\n      playLabel.textContent = 'Pause';\n      // change icon to pause\n      playIcon.innerHTML = '<path d=\"M6 19h4V5H6v14zM14 5v14h4V5h-4z\" fill=\"currentColor\"></path>';\n      gear.classList.add('spin');\n      lastTimestamp = performance.now();\n      animRequest = requestAnimationFrame(loop);\n    } else {\n      playLabel.textContent = 'Play';\n      playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path>';\n      gear.classList.remove('spin');\n      if (animRequest) cancelAnimationFrame(animRequest);\n    }\n  }\n\n  function resetSim(){\n    // stop\n    playing = false;\n    playLabel.textContent = 'Play';\n    playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path>';\n    gear.classList.remove('spin');\n    if (animRequest) cancelAnimationFrame(animRequest);\n    // cleanup clones in cpu & done\n    cpuSlot.innerHTML = '';\n    doneArea.innerHTML = '';\n    // reset tokens transforms\n    processes.forEach(p=>{\n      const el = tokenMap[p.id];\n      el.style.transition = 'transform 600ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease';\n      el.style.transform = 'translate(0,0)';\n      el.style.opacity = '1';\n    });\n    simTime = 0;\n    activeClone = null;\n    drawExecutionUpTo(0);\n  }\n\n  // core animation loop\n  function loop(ts){\n    if (!lastTimestamp) lastTimestamp = ts;\n    const dt = ts - lastTimestamp;\n    lastTimestamp = ts;\n    // advance simulation time by dt scaled\n    simTime += dt / (1000 * speed);\n    // cap\n    if (simTime >= total){\n      simTime = total;\n      playing = false;\n      playLabel.textContent = 'Play';\n      playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path>';\n      gear.classList.remove('spin');\n      if (animRequest) cancelAnimationFrame(animRequest);\n    }\n\n    // update gantt drawing\n    drawExecutionUpTo(simTime);\n\n    // manage tokens: when their arrival time passes, ensure they are visible in queue (they already are)\n    // when simTime crosses segment.start for a process, animate it into CPU\n    for (const seg of segments){\n      const id = seg.id;\n      const token = tokenMap[id];\n      const started = seg.start <= simTime && seg.start + 0.0001 <= simTime; // started if simTime >= start\n      const ended = seg.end <= simTime;\n\n      // if started and token still in queue (not moved)\n      if (simTime >= seg.start && !token.dataset.moved){\n        token.dataset.moved = '1';\n        // visually move token to CPU by creating clone\n        // fade original out\n        token.style.opacity = '0.12';\n        token.style.transform = 'scale(0.98) translateX(6px)';\n        // create clone inside CPU\n        activeClone = placeInCPU(token);\n        // set color and inner text\n        activeClone.style.background = seg.color;\n        activeClone.style.boxShadow = `0 10px 30px ${hexToRgba(seg.color,0.12)}`;\n        // show label inside CPU\n        activeClone.innerHTML = `<div style=\"display:flex;gap:10px;align-items:center\"><div style=\"width:12px;height:12px;background:rgba(0,0,0,0.12);border-radius:3px\"></div><div style=\"display:flex;flex-direction:column\"><div style=\"font-weight:800\">${seg.id}</div><small style=\"font-weight:600;color:rgba(0,0,0,0.36)\">${seg.burst}u</small></div></div>`;\n      }\n\n      // when segment ends and we still have active clone, move it to done\n      if (simTime >= seg.end && token.dataset.moved === '1' && token.dataset.completed !== '1'){\n        token.dataset.completed = '1';\n        if (activeClone){\n          // remove from cpu after tiny delay to show completion\n          setTimeout(()=> {\n            // animate to done area: make relative\n            moveToDone(activeClone);\n            // shrink slightly\n            activeClone.style.transform = 'scale(0.96)';\n            activeClone.style.opacity = '0.98';\n            activeClone = null;\n          }, 140);\n        }\n        // fade original in completed area: keep faded\n        token.style.opacity = '0.12';\n      }\n    }\n\n    // update timebar indicator\n    const barX = Math.min(simTime * pxPerUnit, totalPixels);\n    ganttTimebar.style.transform = `translateX(${barX}px)`;\n    // timebar line\n    ganttTimebar.innerHTML = `<div style=\"width:2px;height:100%;background:linear-gradient(180deg,#ffd166,#ff7b00);box-shadow:0 6px 12px rgba(255,150,60,0.12)\"></div>`;\n\n    // stop when finished\n    if (playing) animRequest = requestAnimationFrame(loop);\n    else animRequest = null;\n  }\n\n  // small helper: hex to rgba\n  function hexToRgba(hex, a=1){\n    const h = hex.replace('#','');\n    const bigint = parseInt(h,16);\n    const r = (bigint >> 16) & 255;\n    const g = (bigint >> 8) & 255;\n    const b = bigint & 255;\n    return `rgba(${r},${g},${b},${a})`;\n  }\n\n  // Initial draw\n  drawExecutionUpTo(0);\n\n  // subtle entrance animation for the whole scene\n  setTimeout(()=> {\n    document.querySelectorAll('.panel, .canvas-card, .info').forEach((el,i)=>{\n      el.style.transform = 'translateY(0)';\n      el.style.opacity = '1';\n    });\n  }, 300);\n\n  // small accessibility: announce schedule on load\n  if ('ariaLive' in document){} // noop\n\n})();\n</script>\n</body>\n</html>"
