    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>OSI Model - Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #f0f3f5;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 3rem 1rem 6rem;\n    overflow-x: hidden;\n  }\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    letter-spacing: 0.12em;\n    margin-bottom: 1rem;\n    color: #e0e7ff;\n    text-align: center;\n    text-shadow:\n      0 0 8px #5a7cff88,\n      0 0 20px #4467f7aa,\n      0 0 30px #3346ffcc;\n  }\n  p.subtitle {\n    font-weight: 300;\n    font-size: 1.15rem;\n    opacity: 0.8;\n    margin-bottom: 4rem;\n    max-width: 600px;\n    text-align: center;\n    letter-spacing: 0.06em;\n  }\n\n  /* Container for the OSI model layers */\n  .osi-container {\n    position: relative;\n    width: 380px;\n    max-width: 95vw;\n    /* height will adjust by content */\n    perspective: 1200px;\n    user-select: none;\n  }\n\n  /* Layer pillars - vertical stack with subtle 3D effect */\n  .osi-layer {\n    position: relative;\n    margin: 0 auto;\n    height: 64px;\n    border-radius: 12px;\n    margin-bottom: 22px;\n    padding: 12px 1.8rem 12px 3rem;\n    display: flex;\n    align-items: center;\n    box-shadow:\n      inset 0 0 8px #2e4a86a0,\n      0 2.5px 5px rgba(13, 18, 39, 0.5);\n    cursor: default;\n    transform-style: preserve-3d;\n    transition:\n      background 0.6s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  .osi-layer::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 0;\n    width: 7px;\n    height: 100%;\n    border-radius: 12px 0 0 12px;\n    background: linear-gradient(180deg, #5a7cf7, #1134a6);\n    filter: drop-shadow(0 0 4px #566eff88);\n    transform: translateZ(12px);\n  }\n  .osi-layer:hover {\n    background: linear-gradient(90deg, #3f51b5ff, #607d8bdd);\n    box-shadow:\n      inset 0 0 20px #607d8b,\n      0 6px 35px #304ffeaa;\n  }\n  .osi-label {\n    font-weight: 600;\n    font-size: 1.2rem;\n    letter-spacing: 0.1em;\n    flex: 0 0 160px;\n    color: #c7d0ffdd;\n    transform: translateZ(20px);\n    text-shadow:\n      0 0 2px #94a7ffcc,\n      0 0 6px #8fa4ffbb;\n    user-select: none;\n  }\n  .osi-desc {\n    flex: 1;\n    color: #adb4d1cc;\n    font-weight: 300;\n    font-size: 0.85rem;\n    line-height: 1.35;\n    letter-spacing: 0.02em;\n    padding-right: 1rem;\n    user-select: none;\n    transform: translateZ(10px);\n  }\n\n  /* Color themes for each layer, from bottom (physical) to top (application) */\n  .layer-7 {\n    background: linear-gradient(90deg, #ff8a80, #ffc7c7dd);\n  }\n  .layer-6 {\n    background: linear-gradient(90deg, #ffb74d, #ffe0b2dd);\n  }\n  .layer-5 {\n    background: linear-gradient(90deg, #4db6ac, #b2dfdbdd);\n  }\n  .layer-4 {\n    background: linear-gradient(90deg, #81d4fa, #b3e5fcdd);\n  }\n  .layer-3 {\n    background: linear-gradient(90deg, #9575cd, #d1c4e9dd);\n  }\n  .layer-2 {\n    background: linear-gradient(90deg, #64b5f6, #bbdefbdd);\n  }\n  .layer-1 {\n    background: linear-gradient(90deg, #90caf9, #e3f2fddd);\n    color: #334a9f;\n  }\n  /* Adjust label and desc colors on layer-1 */\n  .layer-1 .osi-label {\n    color: #21325a;\n    text-shadow: none;\n  }\n  .layer-1 .osi-desc {\n    color: #3f51b5aa;\n  }\n\n  /* Glow highlight toggle for animation */\n  .glow {\n    animation: glowPulse 3.6s ease-in-out infinite;\n  }\n  @keyframes glowPulse {\n    0%, 100% {\n      box-shadow:\n        inset 0 0 16px currentColor,\n        0 0 24px currentColor;\n    }\n    50% {\n      box-shadow:\n        inset 0 0 40px currentColor,\n        0 0 65px currentColor;\n    }\n  }\n\n  /* Central graphic behind layers: stylized OSI hex shapes stacked */\n  .osi-graphic {\n    position: absolute;\n    left: 50%;\n    top: 10%;\n    transform: translateX(-50%);\n    z-index: -1;\n    max-width: 400px;\n    width: 90vw;\n    pointer-events: none;\n    -webkit-user-select:none;\n    user-select:none;\n    filter: drop-shadow(0 0 10px #1b3b92cc);\n  }\n\n  /* Hex shape base */\n  .hex {\n    position: relative;\n    width: 140px;\n    height: 80px;\n    background: rgba(255,255,255,0.06);\n    margin: 16px auto;\n    border-radius: 12px;\n    clip-path: polygon(\n      25% 4%, 75% 4%,\n      100% 50%, 75% 96%,\n      25% 96%, 0 50%\n    );\n    box-shadow:\n      inset 0 0 18px #5573c2aa,\n      0 0 10px #334a9f99;\n    transform-style: preserve-3d;\n    filter: blur(1px);\n    transition: filter 0.45s ease;\n  }\n  /* Hex lines inside */\n  .hex > div {\n    position: absolute;\n    width: 80%;\n    height: 8px;\n    background: linear-gradient(90deg, #a3b3ee44 10%, #a3b3ee88 50%, #a3b3ee44 90%);\n    left: 10%;\n    top: 50%;\n    border-radius: 5px;\n    box-shadow: 0 0 8px #4f6aea88;\n    filter: blur(0.25px);\n  }\n\n  /* Small animated network wave behind */\n  .wave-container {\n    position: absolute;\n    top: 120px;\n    width: 100%;\n    left: 0;\n    pointer-events: none;\n    overflow: visible;\n    z-index: -2;\n  }\n  /* simple wave */\n  svg.wave {\n    display: block;\n    width: 100%;\n    max-width: 600px;\n    height: 120px;\n    margin: 0 auto;\n    filter: drop-shadow(0 0 12px #4a6ef7cc);\n  }\n  .wave path {\n    stroke: #7f8cfc88;\n    stroke-width: 3;\n    fill: none;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 12px #6378f9cc);\n    animation: waveAnim 6s linear infinite;\n  }\n  @keyframes waveAnim {\n    0% {\n      stroke-dashoffset: 300;\n    }\n    100% {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Button styling */\n  .btn-container {\n    margin-top: 2rem;\n  }\n  button.toggleBtn {\n    background: none;\n    border: 2px solid #647bffdd;\n    border-radius: 28px;\n    color: #aabbeecc;\n    font-weight: 600;\n    font-size: 1.1rem;\n    padding: 0.62rem 1.6rem;\n    letter-spacing: 0.1em;\n    cursor: pointer;\n    transition:\n      background-color 0.35s ease,\n      color 0.35s ease,\n      border-color 0.35s ease,\n      box-shadow 0.4s ease;\n    user-select: none;\n  }\n  button.toggleBtn:hover {\n    background-color: #4b61ffdd;\n    color: #dde8ff;\n    border-color: #4b61ffdd;\n    box-shadow: 0 0 24px #4b61ffbb;\n  }\n  /* Accessibility focus states */\n  button.toggleBtn:focus-visible {\n    outline: none;\n    box-shadow:\n      0 0 0 3px #7f90ffcc,\n      0 0 15px #647bffcc;\n  }\n\n  /* Footer */\n  footer {\n    margin-top: auto;\n    color: #3a438ecc;\n    font-size: 0.8rem;\n    letter-spacing: 0.12em;\n    text-align: center;\n    margin-bottom: 1rem;\n  }\n\n  /* Responsive */\n  @media (max-width: 400px) {\n    h1 {\n      font-size: 2.4rem;\n    }\n    .osi-container {\n      width: 320px;\n    }\n    .osi-layer {\n      height: 54px;\n      font-size: 0.9rem;\n      padding-left: 2.4rem;\n    }\n    .osi-label {\n      flex-basis: 140px;\n      font-size: 1rem;\n    }\n  }\n</style>\n</head>\n<body>\n<h1>OPEN SYSTEMS INTERCONNECTION <br><span style=\"font-weight:300; font-size:0.8em; letter-spacing:0.16em; color:#8899c900;\">MODEL</span></h1>\n<p class=\"subtitle\">A conceptual framework used to understand and implement standardized communication protocols in seven distinct layers.</p>\n\n<div class=\"osi-container\" aria-label=\"OSI Model Layers Diagram\">\n\n  <!-- Layers 7 to 1 (top to bottom) -->\n  <div class=\"osi-layer layer-7\" style=\"order:7;\">\n    <div class=\"osi-label\">Application</div>\n    <div class=\"osi-desc\">End-user software interacting with the network</div>\n  </div>\n  <div class=\"osi-layer layer-6\" style=\"order:6;\">\n    <div class=\"osi-label\">Presentation</div>\n    <div class=\"osi-desc\">Data translation, encryption, and compression</div>\n  </div>\n  <div class=\"osi-layer layer-5\" style=\"order:5;\">\n    <div class=\"osi-label\">Session</div>\n    <div class=\"osi-desc\">Controls sessions and connections between devices</div>\n  </div>\n  <div class=\"osi-layer layer-4\" style=\"order:4;\">\n    <div class=\"osi-label\">Transport</div>\n    <div class=\"osi-desc\">End-to-end data transfer and reliability</div>\n  </div>\n  <div class=\"osi-layer layer-3\" style=\"order:3;\">\n    <div class=\"osi-label\">Network</div>\n    <div class=\"osi-desc\">Routing, addressing and packet forwarding</div>\n  </div>\n  <div class=\"osi-layer layer-2\" style=\"order:2;\">\n    <div class=\"osi-label\">Data Link</div>\n    <div class=\"osi-desc\">Error detection, framing, and physical addressing</div>\n  </div>\n  <div class=\"osi-layer layer-1\" style=\"order:1;\">\n    <div class=\"osi-label\">Physical</div>\n    <div class=\"osi-desc\">Transmission of raw bitstream over physical medium</div>\n  </div>\n\n  <!-- Stylized hex graphics stacked behind layers -->\n  <div aria-hidden=\"true\" class=\"osi-graphic\" style=\"top: 14%; width: 380px;\">\n    <div class=\"hex\" style=\"margin-top: 0; filter: drop-shadow(0 0 15px #4778ffaa);\">\n      <div></div>\n    </div>\n    <div class=\"hex\" style=\"filter: drop-shadow(0 0 14px #3e69d3cc);\">\n      <div></div>\n    </div>\n    <div class=\"hex\" style=\"filter: drop-shadow(0 0 12px #375daacc);\">\n      <div></div>\n    </div>\n    <div class=\"hex\" style=\"filter: drop-shadow(0 0 10px #305396bb);\">\n      <div></div>\n    </div>\n    <div class=\"hex\" style=\"filter: drop-shadow(0 0 8px #2a4778bb);\">\n      <div></div>\n    </div>\n    <div class=\"hex\" style=\"filter: drop-shadow(0 0 6px #243e6caa);\">\n      <div></div>\n    </div>\n    <div class=\"hex\" style=\"filter: drop-shadow(0 0 4px #1e3653aa); margin-bottom:0;\">\n      <div></div>\n    </div>\n  </div>\n\n  <!-- Wave line animation below -->\n  <div class=\"wave-container\" aria-hidden=\"true\">\n    <svg class=\"wave\" viewBox=\"0 0 600 150\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n      <path stroke-dasharray=\"300\" stroke-dashoffset=\"300\" d=\"M0 80 C150 10 350 140 600 80\" />\n    </svg>\n  </div>\n\n</div>\n\n<div class=\"btn-container\" aria-label=\"Toggle layer highlight button\">\n  <button id=\"highlightBtn\" class=\"toggleBtn\" aria-pressed=\"false\" aria-label=\"Toggle layer highlight animation\">Highlight Layers</button>\n</div>\n\n<footer>\n  <small>© 2024 OSI Model Concept Visual &nbsp;&bull;&nbsp; Designed by AI</small>\n</footer>\n\n<script>\n  (() => {\n    const layers = document.querySelectorAll('.osi-layer');\n    const btn = document.getElementById('highlightBtn');\n    let highlightOn = false;\n\n    btn.addEventListener('click', () => {\n      highlightOn = !highlightOn;\n      btn.setAttribute('aria-pressed', highlightOn);\n\n      if (highlightOn) {\n        // Add glow animation to each layer in sequence\n        layers.forEach((layer, idx) => {\n          setTimeout(() => layer.classList.add('glow'), idx * 220);\n        });\n        btn.textContent = 'Remove Highlight';\n      } else {\n        // Remove glow from all layers\n        layers.forEach(layer => layer.classList.remove('glow'));\n        btn.textContent = 'Highlight Layers';\n      }\n    });\n  })();\n</script>\n\n</body>\n</html>"
