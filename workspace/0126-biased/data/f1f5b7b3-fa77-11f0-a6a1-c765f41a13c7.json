    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Radix Sort • Visualized</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #071421;\n      --bg-2: #081826;\n      --accent: #7ee7ff;\n      --accent-2: #b388ff;\n      --muted: #90a4ae;\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.03);\n      --success: #7ee7c7;\n      --card-h: 62px;\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(120,60,255,0.08), transparent 8%),\n                  radial-gradient(900px 400px at 90% 90%, rgba(126,231,255,0.04), transparent 10%),\n                  linear-gradient(180deg,var(--bg-1) 0%, var(--bg-2) 100%);\n      color:#e6f3fb;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Subtle animated nebula */\n    .nebula {\n      position:fixed;\n      inset:0;\n      z-index:0;\n      pointer-events:none;\n      opacity:0.7;\n      filter: blur(30px) saturate(120%);\n      mix-blend-mode: screen;\n      background:\n        radial-gradient(600px 240px at 15% 25%, rgba(179,136,255,0.06), transparent 15%),\n        radial-gradient(420px 160px at 85% 70%, rgba(126,231,255,0.05), transparent 12%);\n      animation: floatNeb 10s linear infinite alternate;\n    }\n    @keyframes floatNeb {\n      from { transform: translateY(-10px) rotate(-1deg); }\n      to { transform: translateY(10px) rotate(1deg); }\n    }\n\n    .app {\n      position:relative;\n      z-index:5;\n      padding:36px;\n      display:flex;\n      flex-direction:column;\n      gap:28px;\n      height:100%;\n      box-sizing:border-box;\n    }\n\n    .header {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:24px;\n    }\n    .title {\n      display:flex;\n      flex-direction:column;\n      gap:4px;\n    }\n    .title h1 {\n      margin:0;\n      font-family: \"Playfair Display\", serif;\n      font-size:28px;\n      letter-spacing:0.2px;\n      color:linear-gradient(90deg,#fff,#dfefff);\n      text-shadow: 0 6px 30px rgba(120,60,255,0.12);\n    }\n    .title p {\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n      font-weight:600;\n      letter-spacing:0.6px;\n      text-transform:uppercase;\n    }\n\n    .controls {\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn {\n      border:0;\n      outline:0;\n      background:linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));\n      color:var(--accent);\n      padding:10px 14px;\n      border-radius:12px;\n      font-weight:700;\n      letter-spacing:0.6px;\n      cursor:pointer;\n      box-shadow: 0 4px 18px rgba(0,0,0,0.5), inset 0 -1px 0 rgba(255,255,255,0.02);\n      transition: transform .18s cubic-bezier(.2,.9,.2,1), box-shadow .18s;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      font-size:13px;\n    }\n    .btn:active{ transform:translateY(1px) }\n    .btn.secondary{\n      color:#dbeaff;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n    .btn.primary{\n      background:linear-gradient(90deg, rgba(126,231,255,0.12), rgba(179,136,255,0.08));\n      color:#02121a;\n      box-shadow: 0 8px 28px rgba(120,60,255,0.12), 0 2px 6px rgba(0,0,0,0.5);\n    }\n\n    .stage {\n      position:relative;\n      flex:1 1 auto;\n      display:flex;\n      gap:20px;\n      align-items:center;\n      justify-content:center;\n      min-height:480px;\n    }\n\n    /* Main visual card */\n    .panel {\n      width:1100px;\n      max-width:calc(100% - 72px);\n      height:480px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:20px;\n      padding:28px;\n      box-shadow: 0 10px 40px rgba(6,10,15,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      border: 1px solid rgba(255,255,255,0.03);\n      overflow:hidden;\n      position:relative;\n      display:flex;\n      flex-direction:column;\n    }\n\n    .panel-top {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:20px;\n      margin-bottom:10px;\n    }\n    .panel-top .label {\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .badge {\n      height:44px;\n      min-width:150px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;\n      padding:10px 14px;\n      display:flex;\n      align-items:center;\n      gap:12px;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .badge strong { font-weight:800; color:#fff; font-size:16px; letter-spacing:0.6px; }\n    .badge span { color:var(--muted); font-size:13px; font-weight:600; }\n\n    .legend {\n      color:var(--muted);\n      font-size:13px;\n      display:flex;\n      gap:18px;\n      align-items:center;\n    }\n\n    .visual {\n      position:relative;\n      flex:1 1 auto;\n      display:block;\n      margin-top:6px;\n    }\n\n    /* Input row */\n    .input-row {\n      position:absolute;\n      left:48px;\n      right:48px;\n      top:44px;\n      height:var(--card-h);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      gap:12px;\n      pointer-events:none;\n    }\n    .input-track {\n      position:relative;\n      height:var(--card-h);\n      width:calc(100% - 180px);\n      margin:0 auto;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      gap:18px;\n    }\n\n    .card {\n      width:92px;\n      height:var(--card-h);\n      border-radius:14px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:800;\n      font-size:20px;\n      color:#fff;\n      letter-spacing:0.6px;\n      box-shadow: 0 8px 30px rgba(4,10,20,0.6);\n      border:1px solid rgba(255,255,255,0.04);\n      position:relative;\n      transform-origin:center;\n      transition: transform .6s cubic-bezier(.2,.9,.25,1), box-shadow .3s;\n      will-change:transform;\n      pointer-events:auto;\n    }\n    .card .sub {\n      position:absolute;\n      left:10px;\n      top:9px;\n      font-size:11px;\n      color:var(--muted);\n      font-weight:700;\n      letter-spacing:0.6px;\n    }\n    .card .val {\n      z-index:2;\n      text-shadow: 0 6px 26px rgba(50,80,120,0.18);\n    }\n\n    .card.glow {\n      box-shadow: 0 18px 48px rgba(120,60,255,0.14), 0 6px 24px rgba(0,0,0,0.6);\n      transform:translateY(-6px) scale(1.02);\n    }\n\n    /* Buckets arc */\n    .buckets {\n      position:absolute;\n      left:34px;\n      right:34px;\n      bottom:28px;\n      height:260px;\n      pointer-events:none;\n    }\n    .bucket {\n      position:absolute;\n      width:92px;\n      height:140px;\n      border-radius:14px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      display:flex;\n      flex-direction:column;\n      align-items:center;\n      justify-content:flex-start;\n      gap:8px;\n      padding-top:12px;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 8px 30px rgba(0,0,0,0.6);\n      will-change:transform;\n    }\n    .bucket .label {\n      font-weight:800;\n      color:var(--muted);\n      font-size:15px;\n      margin-top:6px;\n    }\n    .bucket .slot {\n      width:86px;\n      height:84px;\n      border-radius:10px;\n      margin-top:6px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      display:flex;\n      align-items:flex-end;\n      justify-content:center;\n      padding:6px;\n      gap:8px;\n      box-sizing:border-box;\n      overflow:visible;\n    }\n\n    /* Pass badge */\n    .pass-indicator {\n      position:absolute;\n      left:48px;\n      top:120px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:10px 14px;\n      border-radius:12px;\n      border:1px solid rgba(255,255,255,0.03);\n      color:var(--muted);\n      font-weight:700;\n      font-size:13px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      box-shadow: 0 6px 18px rgba(0,0,0,0.6);\n    }\n\n    .hint {\n      position:absolute;\n      right:48px;\n      bottom:18px;\n      color:var(--muted);\n      font-size:13px;\n      display:flex;\n      gap:8px;\n      align-items:center;\n    }\n\n    /* Tiny accent sparkles */\n    .spark {\n      position:absolute;\n      width:12px;\n      height:12px;\n      border-radius:50%;\n      background:radial-gradient(circle at 40% 35%, #fff, rgba(255,255,255,0.2) 40%, rgba(255,255,255,0) 60%);\n      filter:blur(6px) drop-shadow(0 2px 6px rgba(120,60,255,0.2));\n      opacity:0.9;\n      transform:translate(-50%,-50%);\n      pointer-events:none;\n      mix-blend-mode: screen;\n      animation: twinkle 3s infinite;\n    }\n    .spark.s1 { left:72px; top:68px; background: radial-gradient(circle at 40% 35%, #b388ff, rgba(179,136,255,0.25) 40%, rgba(179,136,255,0) 60%); animation-delay:0s;}\n    .spark.s2 { left:980px; top:48px; background: radial-gradient(circle at 40% 35%, #7ee7ff, rgba(126,231,255,0.22) 40%, rgba(126,231,255,0) 60%); animation-delay:0.7s;}\n    .spark.s3 { left:540px; top:420px; background: radial-gradient(circle at 40% 35%, #b388ff, rgba(179,136,255,0.12) 40%, rgba(179,136,255,0) 60%); animation-delay:1.2s;}\n    @keyframes twinkle {\n      0% { transform:translate(-50%,-50%) scale(.6); opacity:.7 }\n      50% { transform:translate(-50%,-46%) scale(1.15); opacity:1 }\n      100% { transform:translate(-50%,-50%) scale(.6); opacity:.7 }\n    }\n\n    /* Responsive */\n    @media (max-width:1200px){\n      .panel{ height:420px; }\n      .buckets { height:220px; }\n    }\n    @media (max-width:800px){\n      .panel{ width:100%; padding:18px; }\n      .input-row { left:18px; right:18px; top:36px; }\n      .badge { min-width:120px }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"nebula\"></div>\n  <div class=\"app\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <h1>Radix Sort — LSD Visualized</h1>\n        <p>Elegant, step-by-step animation of Least Significant Digit Radix Sort</p>\n      </div>\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button id=\"shuffleBtn\" class=\"btn secondary\" title=\"Shuffle numbers\">\n          Shuffle\n        </button>\n        <button id=\"startBtn\" class=\"btn primary\" title=\"Start animation\">\n          Start Animation\n        </button>\n      </div>\n    </div>\n\n    <div class=\"stage\">\n      <div class=\"panel\" role=\"main\" aria-live=\"polite\">\n        <div class=\"panel-top\">\n          <div class=\"label\">\n            <div class=\"badge\">\n              <strong>Radix Sort</strong>\n              <span>Least Significant Digit</span>\n            </div>\n            <div style=\"width:16px\"></div>\n            <div class=\"legend\">\n              <div style=\"display:flex;flex-direction:column\">\n                <small style=\"color:var(--muted);font-weight:700\">Elements</small>\n                <strong id=\"countLabel\">8 items</strong>\n              </div>\n              <div style=\"display:flex;flex-direction:column\">\n                <small style=\"color:var(--muted);font-weight:700\">Digits</small>\n                <strong id=\"digitsLabel\">3 passes</strong>\n              </div>\n            </div>\n          </div>\n          <div style=\"display:flex;flex-direction:column;align-items:flex-end;gap:6px\">\n            <small style=\"color:var(--muted);font-weight:700\">Concept</small>\n            <div style=\"font-weight:700;color:var(--muted);font-size:13px\">Distribute by digits → Collect → Repeat</div>\n          </div>\n        </div>\n\n        <div class=\"visual\" id=\"visual\">\n          <div class=\"input-row\" id=\"inputRow\">\n            <div class=\"input-track\" id=\"inputTrack\"></div>\n          </div>\n\n          <div class=\"pass-indicator\" id=\"passIndicator\">Pass: 0 / 0</div>\n\n          <div class=\"buckets\" id=\"buckets\"></div>\n\n          <div class=\"hint\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:.9\"><path d=\"M12 2v6\" stroke=\"#7ee7ff\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M5 9.5L12 2l7 7.5\" stroke=\"#b388ff\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            <div style=\"color:var(--muted)\">Observe the distribution of elements into buckets 0–9 by digit.</div>\n          </div>\n\n          <div class=\"spark s1\"></div>\n          <div class=\"spark s2\"></div>\n          <div class=\"spark s3\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Radix Sort Visualizer (LSD) — minimal controls: Shuffle & Start\n    (function(){\n      const startBtn = document.getElementById('startBtn');\n      const shuffleBtn = document.getElementById('shuffleBtn');\n      const inputTrack = document.getElementById('inputTrack');\n      const bucketsEl = document.getElementById('buckets');\n      const passIndicator = document.getElementById('passIndicator');\n      const countLabel = document.getElementById('countLabel');\n      const digitsLabel = document.getElementById('digitsLabel');\n\n      const STATE = {\n        values: [],\n        cardEls: [],\n        buckets: [],\n        animating: false,\n        maxDigits: 1,\n      };\n\n      const CARD_W = 92;\n      const CARD_H = 62;\n\n      // Initialize UI\n      function init(){\n        generateValues();\n        buildBuckets();\n        placeCards();\n        updateLabels();\n      }\n\n      function generateValues(){\n        // Create 8 values in range 0..999, varied digits\n        const n = 8;\n        const arr = [];\n        for(let i=0;i<n;i++){\n          // ensure variety: some small, some 2-digit, some 3-digit\n          const r = Math.random();\n          let v;\n          if(r < 0.35) v = Math.floor(Math.random()*30); // small\n          else if(r < 0.75) v = Math.floor(Math.random()*200); // medium\n          else v = Math.floor(Math.random()*900)+100; // large\n          arr.push(v);\n        }\n        STATE.values = arr;\n        STATE.maxDigits = Math.max(...arr).toString().length || 1;\n      }\n\n      function buildBuckets(){\n        // create 10 bucket DOMs arranged on an arc\n        bucketsEl.innerHTML = '';\n        STATE.buckets = [];\n        for(let d=0; d<10; d++){\n          const be = document.createElement('div');\n          be.className = 'bucket';\n          be.dataset.digit = d;\n          be.innerHTML = `\n            <div class=\"label\">${d}</div>\n            <div class=\"slot\"></div>\n          `;\n          bucketsEl.appendChild(be);\n          STATE.buckets.push(be);\n        }\n        positionBucketsArc();\n      }\n\n      function positionBucketsArc(){\n        // place 10 buckets along a subtle semicircular arc within bucketsEl\n        const rect = bucketsEl.getBoundingClientRect();\n        const w = rect.width;\n        const h = rect.height;\n        const cx = w / 2;\n        const cy = h * 1.1; // circle center below container to make arc\n        const radius = Math.min(w / 1.8, h * 2); // adjust radius\n        STATE.buckets.forEach((b, i) => {\n          const t = i / 9; // 0..1\n          const angle = (Math.PI * 0.9) * (1 - t) + (Math.PI * 0.05); // left->right along arc\n          const bx = cx + Math.cos(angle) * radius - b.offsetWidth / 2;\n          const by = cy - Math.sin(angle) * radius - b.offsetHeight / 2;\n          b.style.transform = `translate(${bx}px, ${by}px)`;\n          // apply slight color gradient\n          const hue = 180 + (i/9)*80;\n          b.style.background = `linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.008))`;\n        });\n      }\n\n      function placeCards(){\n        // clear existing\n        inputTrack.innerHTML = '';\n        STATE.cardEls = [];\n        const vals = STATE.values;\n        vals.forEach((v, idx) => {\n          const ce = document.createElement('div');\n          ce.className = 'card';\n          ce.dataset.value = v;\n          ce.dataset.index = idx;\n          ce.innerHTML = `<div class=\"sub\">#${idx+1}</div><div class=\"val\">${v}</div>`;\n          inputTrack.appendChild(ce);\n          STATE.cardEls.push(ce);\n        });\n        // ensure initial positions by forcing layout\n        requestAnimationFrame(()=> {\n          // style cards with slight gradient accents\n          STATE.cardEls.forEach((c,i) => {\n            const g1 = i % 2 === 0 ? 'rgba(126,231,255,0.10)' : 'rgba(179,136,255,0.10)';\n            c.style.background = `linear-gradient(180deg, ${g1}, rgba(255,255,255,0.02))`;\n            c.style.border = '1px solid rgba(255,255,255,0.04)';\n            c.style.transition = 'transform .68s cubic-bezier(.2,.9,.25,1), box-shadow .28s';\n            // reset transform\n            c.style.transform = 'translate3d(0,0,0)';\n          });\n        });\n        // Reposition buckets in case of resize\n        setTimeout(()=> positionBucketsArc(), 80);\n      }\n\n      // Utility: get numeric digit at place d (0 = LSD)\n      function digitAt(num, d){\n        return Math.floor(Math.abs(num) / Math.pow(10,d)) % 10;\n      }\n\n      // Animate moving card to target (x,y) (absolute coordinates relative to visual container)\n      function animateMoveTo(cardEl, targetX, targetY, opts = {}){\n        return new Promise(resolve => {\n          const visualRect = document.getElementById('visual').getBoundingClientRect();\n          // compute current center\n          const cr = cardEl.getBoundingClientRect();\n          const curX = cr.left + cr.width/2 - visualRect.left;\n          const curY = cr.top + cr.height/2 - visualRect.top;\n          const dx = targetX - curX;\n          const dy = targetY - curY;\n          // apply transform translate\n          // make transform relative to current by using translate3d\n          cardEl.style.transition = `transform ${opts.duration || 600}ms cubic-bezier(.2,.9,.25,1), box-shadow ${Math.min(opts.duration||600,420)}ms`;\n          cardEl.style.zIndex = 2000;\n          if(opts.glow) cardEl.classList.add('glow');\n          cardEl.style.transform = `translate3d(${dx}px, ${dy}px, 0)`;\n          // optional slight rotate\n          if(opts.rotate) cardEl.style.transform += ` rotate(${opts.rotate}deg)`;\n          setTimeout(()=>{\n            if(opts.glow) cardEl.classList.remove('glow');\n            cardEl.style.zIndex = '';\n            resolve();\n          }, opts.duration || 600);\n        });\n      }\n\n      // Get center of a bucket's slot area\n      function getBucketSlotCenter(bucketEl, stackIndex){\n        const visualRect = document.getElementById('visual').getBoundingClientRect();\n        const br = bucketEl.getBoundingClientRect();\n        const slot = bucketEl.querySelector('.slot').getBoundingClientRect();\n        // stack cards inside slot bottom-up\n        const x = slot.left + slot.width/2 - visualRect.left;\n        // base on slot bottom minus card heights offset\n        const baseY = slot.top + slot.height - visualRect.top;\n        const y = baseY - (CARD_H/2) - (stackIndex * (CARD_H*0.34)); // slight overlap\n        return {x, y};\n      }\n\n      async function animateRadix(){\n        if(STATE.animating) return;\n        STATE.animating = true;\n        startBtn.disabled = true;\n        shuffleBtn.disabled = true;\n\n        const maxDigits = STATE.maxDigits;\n        passIndicator.textContent = `Pass: 0 / ${maxDigits}`;\n        for(let pass = 0; pass < maxDigits; pass++){\n          passIndicator.textContent = `Pass: ${pass+1} / ${maxDigits}`;\n          // create bucket arrays\n          const buckets = Array.from({length:10}, ()=>[]);\n          const bucketStacks = Array.from({length:10}, ()=>0);\n\n          // Distribute: move each card to its bucket based on digit\n          for(let i=0;i<STATE.cardEls.length;i++){\n            const card = STATE.cardEls[i];\n            const value = Number(card.dataset.value);\n            const d = digitAt(value, pass);\n            const bucketEl = STATE.buckets[d];\n            const stackIdx = bucketStacks[d]++;\n            buckets[d].push(card);\n\n            // Compute target center for this stack position\n            const center = getBucketSlotCenter(bucketEl, stackIdx);\n            // small rotation randomly for aesthetic\n            const rotate = (Math.random()*12 - 6);\n            await animateMoveTo(card, center.x, center.y, {duration: 550, glow:true, rotate});\n            // After move, pin card to new location by setting transform relative to parent visual container\n            // We will keep transform as is; mark card as in-bucket\n            card.dataset.location = `bucket-${d}`;\n            // slight pause between elements for cascading effect\n            await wait(80);\n          }\n\n          // Small pause before collection\n          await wait(450);\n\n          // Collect: take cards from buckets 0..9 in order and move them back into input positions\n          // New order: flatten buckets\n          const newOrder = [];\n          for(let b=0;b<10;b++){\n            for(const c of buckets[b]) newOrder.push(c);\n          }\n\n          // Recompute positions where to place cards in inputTrack centerline\n          // We want to animate them to a neat row center\n          const visualRect = document.getElementById('visual').getBoundingClientRect();\n          const trackRect = inputTrack.getBoundingClientRect();\n          const centerX = trackRect.left + trackRect.width/2 - visualRect.left;\n          const y = trackRect.top + trackRect.height/2 - visualRect.top;\n          const total = newOrder.length;\n          const spacing = 110; // space between centers\n          const rowWidth = (total - 1) * spacing;\n          // target centers for each index\n          const targets = newOrder.map((c, idx) => {\n            const tx = centerX - rowWidth/2 + idx * spacing;\n            return {x: tx, y: y};\n          });\n\n          // move each card to its new input position in sequence with stylish easing\n          for(let i=0;i<newOrder.length;i++){\n            const card = newOrder[i];\n            const t = targets[i];\n            await animateMoveTo(card, t.x, t.y, {duration: 520, glow:true, rotate:0});\n            card.dataset.location = `row-${i}`;\n            // After moved, snap to input row styling\n            await wait(70);\n          }\n\n          // Reorder internal cardEls array to match collected order\n          STATE.cardEls = newOrder.slice();\n\n          // brief pause before next pass\n          await wait(540);\n        }\n\n        passIndicator.textContent = `Completed • ${STATE.maxDigits} passes`;\n        // subtle final highlight\n        for(const c of STATE.cardEls){\n          c.classList.add('glow');\n        }\n        await wait(900);\n        for(const c of STATE.cardEls) c.classList.remove('glow');\n\n        STATE.animating = false;\n        startBtn.disabled = false;\n        shuffleBtn.disabled = false;\n      }\n\n      function wait(ms){ return new Promise(r=>setTimeout(r, ms)); }\n\n      // Shuffle handler\n      function shuffle(){\n        if(STATE.animating) return;\n        // Randomize values and re-render\n        generateValues();\n        placeCards();\n        updateLabels();\n        passIndicator.textContent = `Ready • ${STATE.maxDigits} passes`;\n      }\n\n      function updateLabels(){\n        countLabel.textContent = `${STATE.values.length} items`;\n        digitsLabel.textContent = `${STATE.maxDigits} passes`;\n        passIndicator.textContent = `Ready • ${STATE.maxDigits} passes`;\n      }\n\n      // Responsive repositioning\n      window.addEventListener('resize', ()=> {\n        positionBucketsArc();\n        // ensure card transforms remain consistent (quick fix: reset transforms)\n        STATE.cardEls.forEach(c => { c.style.transform = 'translate3d(0,0,0)'; });\n        // reposition cards to row\n        requestAnimationFrame(()=> {\n          const visualRect = document.getElementById('visual').getBoundingClientRect();\n          const trackRect = inputTrack.getBoundingClientRect();\n          const centerX = trackRect.left + trackRect.width/2 - visualRect.left;\n          const y = trackRect.top + trackRect.height/2 - visualRect.top;\n          const total = STATE.cardEls.length;\n          const spacing = 110;\n          const rowWidth = (total - 1) * spacing;\n          STATE.cardEls.forEach((c,i)=>{\n            const tx = centerX - rowWidth/2 + i * spacing;\n            c.style.transform = `translate3d(${tx - (c.getBoundingClientRect().left + c.getBoundingClientRect().width/2 - visualRect.left)}px, ${y - (c.getBoundingClientRect().top + c.getBoundingClientRect().height/2 - visualRect.top)}px, 0)`;\n          });\n        });\n      });\n\n      // Attach handlers\n      startBtn.addEventListener('click', async ()=>{\n        if(STATE.animating) return;\n        // recompute max digits (in case of changes)\n        STATE.maxDigits = Math.max(1, ...STATE.values.map(v => v.toString().length));\n        digitsLabel.textContent = `${STATE.maxDigits} passes`;\n        await animateRadix();\n      }