  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Dynamic Programming Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n  }\n  #output {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 8px;\n    height: 200px;\n    overflow-y: scroll;\n    margin-bottom: 1em;\n  }\n  label, button {\n    display: block;\n    margin-top: 0.5em;\n  }\n  input[type=number] {\n    width: 5em;\n  }\n  select {\n    width: 15em;\n  }\n</style>\n</head>\n<body>\n<h1>Dynamic Programming Interactive Demo</h1>\n\n<div>\n  <label for=\"problem\">Select a DP Problem:</label>\n  <select id=\"problem\">\n    <option value=\"fib\">Fibonacci Sequence</option>\n    <option value=\"knapsack\">0/1 Knapsack Problem</option>\n    <option value=\"lcs\">Longest Common Subsequence</option>\n    <option value=\"coinchange\">Coin Change (Min Coins)</option>\n    <option value=\"editdistance\">Edit Distance</option>\n  </select>\n</div>\n\n<div id=\"inputs-area\"></div>\n\n<button id=\"reset\">Reset Inputs</button>\n<button id=\"run\">Run / Step Execute</button>\n<button id=\"autoRun\">Auto Run Complete</button>\n<button id=\"prevStep\" disabled>Previous Step</button>\n<button id=\"nextStep\" disabled>Next Step</button>\n\n<div>\n  <label>\n    Step Delay (ms) for Auto Run:\n    <input type=\"number\" id=\"stepDelay\" value=\"500\" min=\"50\" max=\"5000\" step=\"50\" />\n  </label>\n</div>\n\n<hr />\n\n<div><b>State / Memo Table:</b></div>\n<div id=\"tableOutput\" style=\"font-family: monospace; white-space: pre;\"></div>\n\n<hr />\n\n<div><b>Trace / Explanation:</b></div>\n<div id=\"output\"></div>\n\n<script>\n(() => {\n  // Core: We'll implement 5 classic DP problems with full state step-by-step interactive solving.\n  // Supported Problems:\n  // fib: Fibonacci sequence (basic 1-d array)\n  // knapsack: 0/1 Knapsack problem\n  // lcs: Longest Common Subsequence\n  // coinchange: Minimum number of coins for change\n  // editdistance: Edit distance between two strings\n\n  // UI Elements\n  const problemSelect = document.getElementById(\"problem\");\n  const inputsArea = document.getElementById(\"inputs-area\");\n  const resetBtn = document.getElementById(\"reset\");\n  const runBtn = document.getElementById(\"run\");\n  const autoRunBtn = document.getElementById(\"autoRun\");\n  const prevStepBtn = document.getElementById(\"prevStep\");\n  const nextStepBtn = document.getElementById(\"nextStep\");\n  const outputDiv = document.getElementById(\"output\");\n  const tableOutput = document.getElementById(\"tableOutput\");\n  const stepDelayInp = document.getElementById(\"stepDelay\");\n\n  // Global state\n  let currentProblem = null;\n  let currentInputs = {};\n  let solver = null;\n  let steps = [];\n  let stepIndex = -1;\n  let autoRunning = false;\n  let autoIntervalID = null;\n\n  // UTILITIES\n  function clearOutput() {\n    outputDiv.textContent = \"\";\n    tableOutput.textContent = \"\";\n  }\n\n  function printOutput(text) {\n    outputDiv.textContent += text + \"\\n\";\n    outputDiv.scrollTop = outputDiv.scrollHeight;\n  }\n\n  function printTable(text) {\n    tableOutput.textContent = text;\n  }\n\n  // Base class for problems\n  class DPProblem {\n    constructor(inputs) {\n      this.inputs = inputs;\n      this.steps = [];\n      this.stepIndex = -1;\n    }\n    // Advance one step forward, returns false if no more steps\n    stepForward() { return false; }\n    // Step backward one step, optional (to support prevStep)\n    stepBackward() { return false; }\n    // Reset state and prepare steps for a fresh start\n    reset() {}\n    // Provide ASCII representation of memo/state table(s)\n    renderTable() { return \"\"; }\n    // Provide explanation / trace for current stepIndex\n    renderExplanation() { return \"\"; }\n  }\n\n\n  // PROBLEM 1: Fibonacci (bottom-up)\n  class FibProblem extends DPProblem {\n    constructor(inputs) {\n      super(inputs);\n      this.n = inputs.n;\n      this.dp = Array(this.n+1).fill(null);\n      this.stepIndex = -1;\n      this.stateHistory = [];\n      this.reset();\n    }\n    reset() {\n      this.dp = Array(this.n+1).fill(null);\n      this.dp[0] = 0;\n      if(this.n>=1) this.dp[1] = 1;\n      this.stepIndex = 1; // starting from i=2\n      this.stateHistory = [{\n        dp: this.dp.slice(),\n        i: 1,\n        explanation: \"Initialized dp[0]=0, dp[1]=1\"\n      }];\n    }\n    stepForward() {\n      if(this.stepIndex >= this.n) return false;\n      let i = this.stepIndex+1;\n      // dp[i] = dp[i-1] + dp[i-2]\n      this.dp[i] = this.dp[i-1] + this.dp[i-2];\n      this.stepIndex++;\n      this.stateHistory.push({\n        dp: this.dp.slice(),\n        i,\n        explanation: `Computed dp[${i}] = dp[${i-1}] + dp[${i-2}] = ${this.dp[i-1]} + ${this.dp[i-2]} = ${this.dp[i]}`\n      });\n      return true;\n    }\n    stepBackward() {\n      if(this.stepIndex <= 1) return false;\n      this.stepIndex--;\n      this.stateHistory.pop();\n      this.dp = this.stateHistory[this.stateHistory.length -1].dp.slice();\n      return true;\n    }\n    renderTable() {\n      let s = \"Index i: \";\n      for(let i=0; i<=this.n; i++) s += i.toString().padStart(4,\" \") + \" \";\n      s += \"\\ndp[i] : \";\n      for(let i=0; i<=this.n; i++) {\n        let val = this.dp[i];\n        s += (val===null?\"  .\":val.toString().padStart(4,\" \")) + \" \";\n      }\n      return s;\n    }\n    renderExplanation() {\n      if(this.stepIndex < 0) return \"\";\n      return `Step ${this.stepIndex}: ` + this.stateHistory[this.stepIndex].explanation + \"\\n\" +\n        `Current dp array state:\\n${this.renderTable()}`;\n    }\n  }\n\n  // PROBLEM 2: 0/1 Knapsack (bottom-up tabulation)\n  class KnapsackProblem extends DPProblem {\n    // inputs: weights[], values[], capacity (integer)\n    constructor(inputs) {\n      super(inputs);\n      this.weights = inputs.weights.slice();\n      this.values = inputs.values.slice();\n      this.capacity = inputs.capacity;\n      this.n = this.weights.length;\n      // dp[i][w] = max value for first i items with max weight w\n      this.dp = [];\n      this.i = 0;\n      this.w = -1;\n      this.history = [];\n      this.reset();\n    }\n    reset() {\n      // initialize dp with zeros\n      this.dp = Array(this.n+1);\n      for(let i=0; i<=this.n; i++) {\n        this.dp[i] = Array(this.capacity+1).fill(0);\n      }\n      this.i = 0;\n      this.w = 0;\n      this.history = [];\n      this.history.push(this._recordState(\"Initialized dp table with zeros\"));\n    }\n    _recordState(note, chosen=null) {\n      // chosen: true/false if item i chosen for current cell\n      return {\n        dp: this.dp.map(row => row.slice()),\n        i: this.i,\n        w: this.w,\n        note,\n        chosen\n      };\n    }\n    stepForward() {\n      // Move through dp[i][w] row-major order (i:1..n, w:0..capacity)\n      if(this.i > this.n) return false;\n      this.w++;\n      if(this.w > this.capacity) {\n        this.i++;\n        this.w = 0;\n      }\n      if(this.i > this.n) return false;\n\n      let i = this.i;\n      let w = this.w;\n      let wi = (i>0 ? this.weights[i-1] : 0);\n      let vi = (i>0 ? this.values[i-1] : 0);\n\n      if(i === 0) {\n        // dp[0][w]=0 always\n        this.dp[i][w] = 0;\n        this.history.push(this._recordState(`dp[0][${w}] set to 0 (no items)`));\n      } else {\n        if(wi > w) {\n          this.dp[i][w] = this.dp[i-1][w];\n          this.history.push(this._recordState(\n            `Weight of item ${i} (${wi}) > current capacity ${w}; dp[${i}][${w}] = dp[${i-1}][${w}] = ${this.dp[i][w]}`,\n            false));\n        } else {\n          // pick max of excluding or including item\n          let exclude = this.dp[i-1][w];\n          let include = this.dp[i-1][w - wi] + vi;\n          if(include > exclude) {\n            this.dp[i][w] = include;\n            this.history.push(this._recordState(\n              `Include item ${i} (weight ${wi}, value ${vi}): dp[${i}][${w}] = max(${exclude}, ${include}) = ${include}`,\n              true));\n          } else {\n            this.dp[i][w] = exclude;\n            this.history.push(this._recordState(\n              `Exclude item ${i}: dp[${i}][${w}] = max(${exclude}, ${include}) = ${exclude}`,\n              false));\n          }\n        }\n      }\n      return true;\n    }\n    stepBackward() {\n      // undo last step if possible\n      if(this.history.length <= 1) return false;\n      this.history.pop();\n      let lastState = this.history[this.history.length -1];\n      this.dp = lastState.dp.map(row => row.slice());\n      this.i = lastState.i;\n      this.w = lastState.w;\n      return true;\n    }\n    renderTable() {\n      // print dp table for i=0..n, w=0..capacity\n      let header = \"w:     \";\n      for(let w=0; w<=this.capacity; w++) header += w.toString().padStart(4,\" \") + \" \";\n      let lines = [header];\n      for(let i=0; i<=this.n; i++) {\n        let row = (i===0 ? \"0(Itm)\" : i.toString().padStart(3,\" \") + `(W=${this.weights[i-1]||\"-\"})`) + \": \";\n        for(let w=0; w<=this.capacity; w++) {\n          row += this.dp[i][w].toString().padStart(4,\" \") + \" \";\n        }\n        lines.push(row);\n      }\n      return lines.join(\"\\n\");\n    }\n    renderExplanation() {\n      let st = this.history[this.history.length-1];\n      if(!st) return \"\";\n      let chosenStr = st.chosen === true ? \"Item chosen\" : (st.chosen === false ? \"Item excluded\" : \"\");\n      return `Step [i=${st.i}, w=${st.w}]:\\n${st.note}\\n${chosenStr}\\n\\nTable snippet:\\n${this.renderTable()}`;\n    }\n  }\n\n  // PROBLEM 3: Longest Common Subsequence (bottom-up)\n  class LCSProblem extends DPProblem {\n    // inputs: string s1, string s2\n    constructor(inputs) {\n      super(inputs);\n      this.s1 = inputs.s1;\n      this.s2 = inputs.s2;\n      this.m = this.s1.length;\n      this.n = this.s2.length;\n      this.dp = [];\n      this.i = 0;\n      this.j = -1;\n      this.history = [];\n      this.reset();\n    }\n    reset() {\n      // dp[i][j] = length of LCS of s1[0..i-1], s2[0..j-1]\n      this.dp = Array(this.m+1);\n      for(let i=0; i<=this.m; i++) {\n        this.dp[i] = Array(this.n+1).fill(0);\n      }\n      this.i = 0;\n      this.j = 0;\n      this.history = [];\n      this.history.push(this._recordState(\"Initialized dp table with zeros\"));\n    }\n    _recordState(note, matched=null) {\n      return {\n        dp: this.dp.map(row => row.slice()),\n        i: this.i,\n        j: this.j,\n        note,\n        matched\n      };\n    }\n    stepForward() {\n      if(this.i > this.m) return false;\n      this.j++;\n      if(this.j > this.n) {\n        this.i++;\n        this.j = 0;\n      }\n      if(this.i > this.m) return false;\n      if(this.i === 0 || this.j === 0) {\n        this.dp[this.i][this.j] = 0;\n        this.history.push(this._recordState(`dp[${this.i}][${this.j}] = 0 (base case)`));\n      } else {\n        if(this.s1[this.i-1] === this.s2[this.j-1]) {\n          this.dp[this.i][this.j] = this.dp[this.i-1][this.j-1] + 1;\n          this.history.push(this._recordState(\n            `s1[${this.i-1}] == s2[${this.j-1}] ('${this.s1[this.i-1]}') --> dp[${this.i}][${this.j}] = dp[${this.i-1}][${this.j-1}] + 1 = ${this.dp[this.i-1][this.j-1]} + 1 = ${this.dp[this.i][this.j]}`, true));\n        } else {\n          this.dp[this.i][this.j] = Math.max(this.dp[this.i-1][this.j], this.dp[this.i][this.j-1]);\n          this.history.push(this._recordState(\n            `s1[${this.i-1}] != s2[${this.j-1}] ('${this.s1[this.i-1]}' vs '${this.s2[this.j-1]}') --> dp[${this.i}][${this.j}] = max(dp[${this.i-1}][${this.j}] = ${this.dp[this.i-1][this.j]}, dp[${this.i}][${this.j-1}] = ${this.dp[this.i][this.j-1]}) = ${this.dp[this.i][this.j]}`, false));\n        }\n      }\n      return true;\n    }\n    stepBackward() {\n      if(this.history.length <= 1) return false;\n      this.history.pop();\n      let st = this.history[this.history.length -1];\n      this.dp = st.dp.map(row => row.slice());\n      this.i = st.i;\n      this.j = st.j;\n      return true;\n    }\n    renderTable() {\n      let header = \"j→  \";\n      for(let j=0; j<=this.n; j++) header += j.toString().padStart(4,\" \") +\" \";\n      let lines = [header];\n      for(let i=0; i<=this.m; i++) {\n        let row = (i===0 ? \"0(i)\" : i.toString().padStart(3,\" \") + \"(i)\") + \": \";\n        for(let j=0; j<=this.n; j++) {\n          row += this.dp[i][j].toString().padStart(4,\" \") + \" \";\n        }\n        lines.push(row);\n      }\n      return lines.join(\"\\n\");\n    }\n    renderExplanation() {\n      let st = this.history[this.history.length-1];\n      if(!st) return \"\";\n      return `Step at dp[${st.i}][${st.j}]:\\n${st.note}\\n\\nTable:\\n${this.renderTable()}`;\n    }\n  }\n\n  // PROBLEM 4: Coin Change (minimum number of coins)\n  class CoinChangeProblem extends DPProblem {\n    // inputs: coins[], amount\n    constructor(inputs) {\n      super(inputs);\n      this.coins = inputs.coins.slice();\n      this.amount = inputs.amount;\n      this.dp = [];\n      this.i = 0;\n      this.j = -1;\n      this.history = [];\n      this.reset();\n    }\n    reset() {\n      this.dp = Array(this.coins.length + 1);\n      for(let i=0; i<=this.coins.length; i++) {\n        this.dp[i] = Array(this.amount+1).fill(Infinity);\n      }\n      // base case dp[0][0]=0, no coins needed to make amount=0\n      for(let i=0; i<=this.coins.length; i++) {\n        this.dp[i][0] = 0;\n      }\n      this.i = 0;\n      this.j = 0;\n      this.history = [];\n      this.history.push(this._recordState(\"Initialized dp table; dp[i][0]=0\"));\n    }\n    _recordState(note, coinUsed=null) {\n      return {\n        dp: this.dp.map(row => row.slice()),\n        i: this.i,\n        j: this.j,\n        note,\n        coinUsed\n      };\n    }\n    stepForward() {\n      if(this.i > this.coins.length) return false;\n      this.j++;\n      if(this.j > this.amount) {\n        this.i++;\n        this.j = 0;\n      }\n      if(this.i > this.coins.length) return false;\n\n      if(this.j === 0) {\n        this.dp[this.i][this.j] = 0;\n        this.history.push(this._recordState(`dp[${this.i}][0] = 0 (amount zero)`));\n      } else if(this.i === 0) {\n        // no coins to use, amount>0 no solution\n        this.dp[this.i][this.j] = Infinity;\n        this.history.push(this._recordState(`dp[0][${this.j}] = ∞ (no coins)`));\n      } else {\n        let coin = this.coins[this.i-1];\n        if(coin > this.j) {\n          this.dp[this.i][this.j] = this.dp[this.i-1][this.j];\n          this.history.push(this._recordState(\n            `Coin (${coin}) > current amount (${this.j}), dp[${this.i}][${this.j}] = dp[${this.i-1}][${this.j}] = ${this.dp[this.i][this.j]}`, false));\n        } else {\n          let exclude = this.dp[this.i-1][this.j];\n          let include = this.dp[this.i][this.j - coin] + 1;\n          if(include < exclude) {\n            this.dp[this.i][this.j] = include;\n            this.history.push(this._recordState(\n              `Include coin ${coin}: dp[${this.i}][${this.j}] = min(${exclude}, ${include}) = ${include}`, true));\n          } else {\n            this.dp[this.i][this.j] = exclude;\n            this.history.push(this._recordState(\n              `Exclude coin ${coin}: dp[${this.i}][${this.j}] = min(${exclude}, ${include}) = ${exclude}`, false));\n          }\n        }\n      }\n      return true;\n    }\n    stepBackward() {\n      if(this.history.length <= 1) return false;\n      this.history.pop();\n      let st = this.history[this.history.length-1];\n      this.dp = st.dp.map(row => row.slice());\n      this.i = st.i;\n      this.j = st.j;\n      return true;\n    }\n    renderTable() {\n      let header = \"amt→  \";\n      for(let a=0; a<=this.amount; a++) {\n        header += a.toString().padStart(4,\" \") + \" \";\n      }\n      let lines = [header];\n      for(let i=0; i<=this.coins.length; i++) {\n        let row = (i===0 ? \"0(coins)\" : i.toString().padStart(3,\" \") + \"(c\" + this.coins[i-1] + \")\") + \": \";\n        for(let a=0; a<=this.amount; a++) {\n          let val = this.dp[i][a];\n          row += (val === Infinity ? \"  ∞\" : val.toString().padStart(4,\" \")) + \" \";\n        }\n        lines.push(row);\n      }\n      return lines.join(\"\\n\");\n    }\n    renderExplanation() {\n      let st = this.history[this.history.length-1];\n      if(!st) return \"\";\n      let coinUsed = st.coinUsed === true ? \"Coin included\" : (st.coinUsed === false ? \"Coin excluded\" : \"\");\n      return `Step [i=${st.i}, amount=${st.j}]:\\n${st.note}\\n${coinUsed}\\n\\nTable snippet:\\n${this.renderTable()}`;\n    }\n  }\n\n  // PROBLEM 5: Edit Distance (Levenshtein distance)\n  class EditDistanceProblem extends DPProblem {\n    // inputs: string s1, string s2\n    constructor(inputs) {\n      super(inputs);\n      this.s1 = inputs.s1;\n      this.s2 = inputs.s2;\n      this.m = this.s1.length;\n      this.n = this.s2.length;\n      this.dp = [];\n      this.i = 0;\n      this.j = -1;\n      this.history = [];\n      this.reset();\n    }\n    reset() {\n      // dp[i][j] = minimal edit operations to convert s1[0..i-1] to s2[0..j-1]\n      this.dp = Array(this.m+1);\n      for(let i=0; i<=this.m; i++) {\n        this.dp[i] = Array(this.n+1).fill(0);\n      }\n      for(let i=0; i<=this.m; i++) this.dp[i][0] = i;\n      for(let j=0; j<=this.n; j++) this.dp[0][j] = j;\n      this.i = 0;\n      this.j = 0;\n      this.history = [];\n      this.history.push(this._recordState(\"Initialized dp table for base cases\"));\n    }\n    _recordState(note, operation=null) {\n      return {\n        dp: this.dp.map(row => row.slice()),\n        i: this.i,\n        j: this.j,\n        note,\n        operation\n      };\n    }\n    stepForward() {\n      if(this.i > this.m) return false;\n      this.j++;\n      if(this.j > this.n) {\n        this.i++;\n        this.j = 0;\n      }\n      if(this.i > this.m) return false;\n\n      if(this.i === 0) {\n        // First row\n        this.dp[this.i][this.j] = this.j;\n        this.history.push(this._recordState(`dp[0][${this.j}] = ${this.j} (base case; insertions)`));\n      } else if(this.j === 0) {\n        this.dp[this.i][0] = this.i;\n        this.history.push(this._recordState(`dp[${this.i}][0] = ${this.i} (base case; deletions)`));\n      } else {\n        if(this.s1[this.i-1] === this.s2[this.j-1]) {\n          this.dp[this.i][this.j] = this.dp[this.i-1][this.j-1];\n          this.history.push(this._recordState(\n            `Chars match (${this.s1[this.i-1]}), dp[${this.i}][${this.j}] = dp[${this.i-1}][${this.j-1}] = ${this.dp[this.i][this.j]}`, \"match\"));\n        } else {\n          let insert = this.dp[this.i][this.j-1] + 1;\n          let remove = this.dp[this.i-1][this.j] + 1;\n          let replace = this.dp[this.i-1][this.j-1] + 1;\n          let minOp = Math.min(insert, remove, replace);\n          this.dp[this.i][this.j] = minOp;\n\n          let opStr = \"\";\n          if(minOp === insert) opStr = \"insert\";\n          else if(minOp === remove) opStr = \"remove\";\n          else opStr = \"replace\";\n\n          this.history.push(this._recordState(\n            `Chars differ (${this.s1[this.i-1]} vs ${this.s2[this.j-1]}), dp[${this.i}][${this.j}] = min(insert=${insert}, remove=${remove}, replace=${replace}) = ${minOp} (${opStr})`,\n            opStr));\n        }\n      }\n      return true;\n    }\n    stepBackward() {\n      if(this.history.length <= 1) return false;\n      this.history.pop();\n      let st = this.history[this.history.length-1];\n      this.dp = st.dp.map(row => row.slice());\n      this.i = st.i;\n      this.j = st.j;\n      return true;\n    }\n    renderTable() {\n      let header = \"j→  \";\n      for(let j=0; j<=this.n; j++) {\n        header += j.toString().padStart(4,\" \") + \" \";\n      }\n      let lines = [header];\n      for(let i=0; i<=this.m; i++) {\n        let row = (i===0 ? \"0(i)\" : i.toString().padStart(3,\" \") + \"(i)\") + \": \";\n        for(let j=0; j<=this.n; j++) {\n          row += this.dp[i][j].toString().padStart(4,\" \") + \" \";\n        }\n        lines.push(row);\n      }\n      return lines.join(\"\\n\");\n    }\n    renderExplanation() {\n      let st = this.history[this.history.length-1];\n      if(!st) return \"\";\n      let op = st.operation ? `Operation: ${st.operation}` : \"\";\n      return `Step [i=${st.i}, j=${st.j}]:\\n${st.note}\\n${op}\\n\\nTable:\\n${this.renderTable()}`;\n    }\n  }\n\n\n  // INPUTS CONTROLS SETUP for each problem\n  function createFibInputs() {\n    return `\n      <label>\n        Enter n (max Fibonacci term index, integer ≥ 2):\n        <input id=\"fib_n\" type=\"number\" min=\"2\" max=\"50\" step=\"1\" value=\"10\" />\n      </label>\n    `;\n  }\n\n  function createKnapsackInputs() {\n    return `\n      <label>\n        Enter weights (comma-separated integers):\n        <input id=\"knapsack_weights\" type=\"text\" value=\"1,3,4,5\" />\n      </label>\n      <label>\n        Enter values (comma-separated integers):\n        <input id=\"knapsack_values\" type=\"text\" value=\"1,4,5,7\" />\n      </label>\n      <label>\n        Enter capacity (integer):\n        <input id=\"knapsack_capacity\" type=\"number\" min=\"1\" max=\"50\" step=\"1\" value=\"7\" />\n      </label>\n    `;\n  }\n\n  function createLCSInputs() {\n    return `\n      <label>\n        Enter string s1 (max length 20):\n        <input id=\"lcs_s1\" type=\"text\" maxlength=\"20\" value=\"ABCBDAB\" />\n      </label>\n      <label>\n        Enter string s2 (max length 20):\n        <input id=\"lcs_s2\" type=\"text\" maxlength=\"20\" value=\"BDCABA\" />\n      </label>\n    `;\n  }\n\n  function createCoinChangeInputs() {\n    return `\n      <label>\n        Enter coin denominations (comma-separated integers):\n        <input id=\"coinchange_coins\" type=\"text\" value=\"1,2,5\" />\n      </label>\n      <label>\n        Enter amount (integer):\n        <input id=\"coinchange_amount\" type=\"number\" min=\"1\" max=\"50\" step=\"1\" value=\"11\" />\n      </label>\n    `;\n  }\n\n  function createEditDistanceInputs() {\n    return `\n      <label>\n        Enter string s1 (max length 20):\n        <input id=\"editdistance_s1\" type=\"text\" maxlength=\"20\" value=\"horse\" />\n      </label>\n      <label>\n        Enter string s2 (max length 20):\n        <input id=\"editdistance_s2\" type=\"text\" maxlength=\"20\" value=\"ros\" />\n      </label>\n    `;\n  }\n\n  // Inputs parser for each problem\n  function parseFibInputs() {\n    let n = parseInt(document.getElementById(\"fib_n\").value, 10);\n    if(isNaN(n) || n < 2 || n > 50) throw new Error(\"n must be integer between 2 and 50\");\n    return { n };\n  }\n\n  function parseKnapsackInputs() {\n    let wsRaw = document.getElementById(\"knapsack_weights\").value.trim();\n    let vsRaw = document.getElementById(\"knapsack_values\").value.trim();\n    let cRaw = document.getElementById(\"knapsack_capacity\").value.trim();\n    if(!wsRaw || !vsRaw || !cRaw) throw new Error(\"All inputs required\");\n    let weights = wsRaw.split(\",\").map(s=>parseInt(s.trim(),10));\n    let values = vsRaw.split(\",\").map(s=>parseInt(s.trim(),10));\n    let capacity = parseInt(cRaw,10);\n    if(weights.length !== values.length) throw new Error(\"Weights and values arrays must be the same length\");\n    if(weights.some(w=>isNaN(w) || w<=0)) throw new Error(\"Weights must be positive integers\");\n    if(values.some(v=>isNaN(v) || v<0)) throw new Error(\"Values must be non-negative integers\");\n    if(isNaN(capacity) || capacity <= 0) throw new Error(\"Capacity must be positive integer\");\n    if(weights.length > 20) throw new Error(\"Too many items (max 20)\");\n    if(capacity > 50) throw new Error(\"Capacity too large (max 50)\");\n    return { weights, values, capacity };\n  }\n\n  function parseLCSInputs() {\n    let s1 = document.getElementById(\"lcs_s1\").value;\n    let s2 = document.getElementById(\"lcs_s2\").value;\n    if(!s1 || !s2) throw new Error(\"Both strings required\");\n    if(s1.length > 20 || s2.length > 20) throw new Error(\"String length max is 20\");\n    return { s1, s2 };\n  }\n\n  function parseCoinChangeInputs() {\n    let coinsRaw = document.getElementById(\"coinchange_coins\").value.trim();\n    let amountRaw = document.getElementById(\"coinchange_amount\").value.trim();\n    if(!coinsRaw || !amountRaw) throw new Error(\"All inputs required\");\n    let coins = coinsRaw.split(\",\").map(s=>parseInt(s.trim(),10));\n    let amount = parseInt(amountRaw,10);\n    if(coins.some(c=>isNaN(c) || c <= 0)) throw new Error(\"Coins must be positive integers\");\n    if(amount <= 0 || isNaN(amount)) throw new Error(\"Amount must be positive integer\");\n    if(coins.length > 20) throw new Error(\"Too many coin types (max 20)\");\n    if(amount > 50) throw new Error(\"Amount too large (max 50)\");\n    return { coins, amount };\n  }\n\n  function parseEditDistanceInputs() {\n    let s1 = document.getElementById(\"editdistance_s1\").value;\n    let s2 = document.getElementById(\"editdistance_s2\").value;\n    if(!s1 || !s2) throw new Error(\"Both strings required\");\n    if(s1.length > 20 || s2.length > 20) throw new Error(\"String length max is 20\");\n    return { s1, s2 };\n  }\n\n\n  // On problem selection change, redraw inputs\n  function updateInputs() {\n    clearOutput();\n    let val = problemSelect.value;\n    let html = \"\";\n    try {\n      switch(val) {\n        case \"fib\": html = createFibInputs(); break;\n        case \"knapsack\": html = createKnapsackInputs(); break;\n        case \"lcs\": html = createLCSInputs(); break;\n        case \"coinchange\": html = createCoinChangeInputs(); break;\n        case \"editdistance\": html = createEditDistanceInputs(); break;\n        default: html = \"\"; break;\n      }\n      inputsArea.innerHTML = html;\n    } catch(e) {\n      inputsArea.innerHTML = \"Error loading inputs.\";\n    }\n  }\n\n  problemSelect.addEventListener(\"change\", () => {\n    updateInputs();\n    solver = null;\n    steps = [];\n    stepIndex = -1;\n    prevStepBtn.disabled = true;\n    nextStepBtn.disabled = true;\n    runBtn.disabled = false;\n    autoRunBtn.disabled = false;\n    clearOutput();\n    printOutput(\"Please enter inputs and click Run / Step Execute.\");\n  });\n\n  resetBtn.addEventListener(\"click\", () => {\n    if(!solver) {\n      printOutput(\"No solver active.\");\n      return;\n    }\n    solver.reset();\n    stepIndex = 0;\n    prevStepBtn.disabled = true;\n    nextStepBtn.disabled = true;\n    autoRunBtn.disabled = false;\n    runBtn.disabled = false;\n    clearOutput();\n    printTable(solver.renderTable());\n    printOutput(\"Reset completed. Use Run / Step buttons to execute.\");\n  });\n\n  runBtn.addEventListener(\"click\", () => {\n    if(autoRunning) return;\n    if(!solver) {\n      try {\n        initSolverFromInputs();\n      } catch(e) {\n        clearOutput();\n        printOutput(\"Error parsing inputs: \" + e.message);\n        return;\n      }\n    }\n    // perform one step forward\n    let res = solver.stepForward();\n    if(!res) {\n      printOutput(\"Reached end of computation.\");\n      runBtn.disabled = true;\n      nextStepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      prevStepBtn.disabled = false;\n    } else {\n      prevStepBtn.disabled = false;\n      nextStepBtn.disabled = false;\n      autoRunBtn.disabled = false;\n      runBtn.disabled = false;\n    }\n    printTable(solver.renderTable());\n    clearOutput();\n    printOutput(solver.renderExplanation());\n  });\n\n  autoRunBtn.addEventListener(\"click\", () => {\n    if(autoRunning) return;\n    if(!solver) {\n      try {\n        initSolverFromInputs();\n      } catch(e) {\n        clearOutput();\n        printOutput(\"Error parsing inputs: \" + e.message);\n        return;\n      }\n    }\n    autoRunning = true;\n    runBtn.disabled = true;\n    autoRunBtn.disabled = true;\n    prevStepBtn.disabled = true;\n    nextStepBtn.disabled = true;\n\n    let delay = parseInt(stepDelayInp.value, 10);\n    if(isNaN(delay) || delay < 50) delay = 500;\n\n    function iterate() {\n      let res = solver.stepForward();\n      printTable(solver.renderTable());\n      clearOutput();\n      printOutput(solver.renderExplanation());\n      if(!res) {\n        autoRunning = false;\n        runBtn.disabled = true;\n        autoRunBtn.disabled = true;\n        prevStepBtn.disabled = false;\n        nextStepBtn.disabled = false;\n        return;\n      }\n      autoIntervalID = setTimeout(iterate, delay);\n    }\n    iterate();\n  });\n\n  prevStepBtn.addEventListener(\"click\", () => {\n    if(autoRunning) return;\n    if(!solver) {\n      printOutput(\"No solver active.\");\n      return;\n    }\n    let res = solver.stepBackward();\n    if(!res) {\n      printOutput(\"Cannot go further back.\");\n      prevStepBtn.disabled = true;\n      return;\n    }\n    runBtn.disabled = false;\n    autoRunBtn.disabled = false;\n    nextStepBtn.disabled = false;\n    prevStepBtn.disabled = solver.history && solver.history.length <= 1;\n    printTable(solver.renderTable());\n    clearOutput();\n    printOutput(solver.renderExplanation());\n  });\n\n  nextStepBtn.addEventListener(\"click\", () => {\n    if(autoRunning) return;\n    if(!solver) {\n      printOutput(\"No solver active.\");\n      return;\n    }\n    let res = solver.stepForward();\n    if(!res) {\n      printOutput(\"Reached end of computation.\");\n      runBtn.disabled = true;\n      nextStepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      return;\n    }\n    prevStepBtn.disabled = false;\n    runBtn.disabled = false;\n    autoRunBtn.disabled = false;\n    printTable(solver.renderTable());\n    clearOutput();\n    printOutput(solver.renderExplanation());\n  });\n\n  // Init solver from current inputs per problem\n  function initSolverFromInputs() {\n    clearOutput();\n    printOutput(\"Initializing solver...\");\n    let val = problemSelect.value;\n    let inputs;\n    switch(val) {\n      case \"fib\":\n        inputs = parseFibInputs();\n        solver = new FibProblem(inputs);\n        break;\n      case \"knapsack\":\n        inputs = parseKnapsackInputs();\n        solver = new KnapsackProblem(inputs);\n        break;\n      case \"lcs\":\n        inputs = parseLCSInputs();\n        solver = new LCSProblem(inputs);\n        break;\n      case \"coinchange\":\n        inputs = parseCoinChangeInputs();\n        solver = new CoinChangeProblem(inputs);\n        break;\n      case \"editdistance\":\n        inputs = parseEditDistanceInputs();\n        solver = new EditDistanceProblem(inputs);\n        break;\n      default:\n        throw new Error(\"Unknown problem\");\n    }\n    solver.reset();\n    printTable(solver.renderTable());\n    printOutput(\"Initialized. Click Run/Step Execute to start stepping.\");\n  }\n\n  // Initial page setup\n  updateInputs();\n  clearOutput();\n  printOutput(\"Select a DP problem, adjust inputs, then run or step through the computation.\");\n})();\n</script>\n</body>\n</html>"
