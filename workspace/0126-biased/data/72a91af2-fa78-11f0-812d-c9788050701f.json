    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Red-Black Tree Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:wght@400;600&display=swap');\n        \n        :root {\n            --primary-bg: #1a1a2e;\n            --secondary-bg: #16213e;\n            --accent-red: #e94560;\n            --accent-black: #0f3460;\n            --text-light: #f1f1f1;\n            --text-muted: #b8b8b8;\n            --transition-speed: 0.5s;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, var(--primary-bg), var(--secondary-bg));\n            color: var(--text-light);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out forwards;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3rem;\n            font-weight: 600;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, #e94560, #f8b195);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--text-muted);\n            font-weight: 300;\n            margin-top: 0;\n        }\n        \n        .tree-container {\n            width: 100%;\n            min-height: 60vh;\n            display: flex;\n            justify-content: center;\n            align-items: flex-start;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n        \n        .tree {\n            position: relative;\n            width: 100%;\n            height: 100%;\n        }\n        \n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: 600;\n            font-size: 1.2rem;\n            color: var(--text-light);\n            transition: all var(--transition-speed) ease-out;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);\n            z-index: 2;\n        }\n        \n        .node.red {\n            background: var(--accent-red);\n        }\n        \n        .node.black {\n            background: var(--accent-black);\n        }\n        \n        .node.highlight {\n            transform: scale(1.1);\n            box-shadow: 0 0 20px rgba(233, 69, 96, 0.7);\n            animation: pulse 2s infinite;\n        }\n        \n        .connector {\n            position: absolute;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.2);\n            transform-origin: left center;\n            z-index: 1;\n            transition: all var(--transition-speed) ease-out;\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 0.5s forwards;\n        }\n        \n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 30px;\n            background: linear-gradient(45deg, var(--accent-red), #f8b195);\n            color: white;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(233, 69, 96, 0.4);\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(233, 69, 96, 0.6);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .legend {\n            display: flex;\n            gap: 2rem;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1s forwards;\n        }\n        \n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n        \n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n        }\n        \n        .legend-color.red {\n            background: var(--accent-red);\n        }\n        \n        .legend-color.black {\n            background: var(--accent-black);\n        }\n        \n        .info-panel {\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            border-radius: 15px;\n            padding: 1.5rem;\n            margin-top: 2rem;\n            max-width: 600px;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n            border-left: 3px solid var(--accent-red);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes pulse {\n            0% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0.7); }\n            70% { box-shadow: 0 0 0 15px rgba(233, 69, 96, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0); }\n        }\n        \n        .particles {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            pointer-events: none;\n        }\n        \n        .particle {\n            position: absolute;\n            width: 2px;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 50%;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Red-Black Tree</h1>\n            <p class=\"subtitle\">A self-balancing binary search tree with elegant properties</p>\n        </header>\n        \n        <div class=\"controls\">\n            <button id=\"insertBtn\">Insert Node</button>\n            <button id=\"resetBtn\">Reset Tree</button>\n        </div>\n        \n        <div class=\"tree-container\">\n            <div class=\"tree\" id=\"tree\"></div>\n        </div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color red\"></div>\n                <span>Red Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color black\"></div>\n                <span>Black Node</span>\n            </div>\n        </div>\n        \n        <div class=\"info-panel\">\n            <h3>Properties of Red-Black Trees</h3>\n            <ul>\n                <li>Every node is either red or black</li>\n                <li>The root is always black</li>\n                <li>Red nodes cannot have red children (no two red nodes in a row)</li>\n                <li>Every path from a node to its descendant NULL nodes has the same number of black nodes</li>\n            </ul>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            createParticles();\n            \n            // Initialize tree\n            const tree = new RedBlackTree();\n            const treeElement = document.getElementById('tree');\n            const insertBtn = document.getElementById('insertBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            // Initial tree values\n            const initialValues = [10, 5, 15, 3, 7, 12, 17];\n            initialValues.forEach(val => {\n                tree.insert(val);\n            });\n            visualizeTree(tree, treeElement);\n            \n            // Insert random node\n            insertBtn.addEventListener('click', function() {\n                const value = Math.floor(Math.random() * 30) + 1;\n                tree.insert(value);\n                visualizeTree(tree, treeElement);\n                \n                // Highlight the new node\n                const newNode = document.querySelector(`[data-value=\"${value}\"]`);\n                newNode.classList.add('highlight');\n                setTimeout(() => newNode.classList.remove('highlight'), 2000);\n            });\n            \n            // Reset tree\n            resetBtn.addEventListener('click', function() {\n                tree.root = null;\n                initialValues.forEach(val => {\n                    tree.insert(val);\n                });\n                visualizeTree(tree, treeElement);\n            });\n        });\n        \n        function createParticles() {\n            const container = document.getElementById('particles');\n            const particleCount = 50;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                // Random position\n                const x = Math.random() * 100;\n                const y = Math.random() * 100;\n                \n                // Random size\n                const size = Math.random() * 3 + 1;\n                \n                // Random opacity\n                const opacity = Math.random() * 0.3 + 0.1;\n                \n                // Random animation\n                const duration = Math.random() * 20 + 10;\n                const delay = Math.random() * -20;\n                \n                particle.style.left = `${x}%`;\n                particle.style.top = `${y}%`;\n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.opacity = opacity;\n                particle.style.animation = `float ${duration}s linear ${delay}s infinite`;\n                \n                container.appendChild(particle);\n            }\n        }\n        \n        // Red-Black Tree implementation\n        class Node {\n            constructor(value, color = 'red') {\n                this.value = value;\n                this.color = color;\n                this.left = null;\n                this.right = null;\n                this.parent = null;\n            }\n        }\n        \n        class RedBlackTree {\n            constructor() {\n                this.root = null;\n            }\n            \n            insert(value) {\n                const newNode = new Node(value);\n                \n                if (!this.root) {\n                    this.root = newNode;\n                    this.root.color = 'black';\n                    return;\n                }\n                \n                let current = this.root;\n                let parent = null;\n                \n                while (current) {\n                    parent = current;\n                    if (value < current.value) {\n                        current = current.left;\n                    } else {\n                        current = current.right;\n                    }\n                }\n                \n                newNode.parent = parent;\n                if (value < parent.value) {\n                    parent.left = newNode;\n                } else {\n                    parent.right = newNode;\n                }\n                \n                this.fixViolations(newNode);\n            }\n            \n            fixViolations(node) {\n                while (node !== this.root && node.color === 'red' && node.parent.color === 'red') {\n                    const parent = node.parent;\n                    const grandParent = parent.parent;\n                    \n                    // Case A: Parent is left child of grandparent\n                    if (parent === grandParent.left) {\n                        const uncle = grandParent.right;\n                        \n                        // Case 1: Uncle is red - only recoloring\n                        if (uncle && uncle.color === 'red') {\n                            grandParent.color = 'red';\n                            parent.color = 'black';\n                            uncle.color = 'black';\n                            node = grandParent;\n                        } else {\n                            // Case 2: Node is right child - left rotation\n                            if (node === parent.right) {\n                                this.rotateLeft(parent);\n                                node = parent;\n                                parent = node.parent;\n                            }\n                            \n                            // Case 3: Node is left child - right rotation\n                            this.rotateRight(grandParent);\n                            [parent.color, grandParent.color] = [grandParent.color, parent.color];\n                            node = parent;\n                        }\n                    } \n                    // Case B: Parent is right child of grandparent\n                    else {\n                        const uncle = grandParent.left;\n                        \n                        // Case 1: Uncle is red - only recoloring\n                        if (uncle && uncle.color === 'red') {\n                            grandParent.color = 'red';\n                            parent.color = 'black';\n                            uncle.color = 'black';\n                            node = grandParent;\n                        } else {\n                            // Case 2: Node is left child - right rotation\n                            if (node === parent.left) {\n                                this.rotateRight(parent);\n                                node = parent;\n                                parent = node.parent;\n                            }\n                            \n                            // Case 3: Node is right child - left rotation\n                            this.rotateLeft(grandParent);\n                            [parent.color, grandParent.color] = [grandParent.color, parent.color];\n                            node = parent;\n                        }\n                    }\n                }\n                \n                this.root.color = 'black';\n            }\n            \n            rotateLeft(node) {\n                const rightChild = node.right;\n                node.right = rightChild.left;\n                \n                if (node.right) {\n                    node.right.parent = node;\n                }\n                \n                rightChild.parent = node.parent;\n                \n                if (!node.parent) {\n                    this.root = rightChild;\n                } else if (node === node.parent.left) {\n                    node.parent.left = rightChild;\n                } else {\n                    node.parent.right = rightChild;\n                }\n                \n                rightChild.left = node;\n                node.parent = rightChild;\n            }\n            \n            rotateRight(node) {\n                const leftChild = node.left;\n                node.left = leftChild.right;\n                \n                if (node.left) {\n                    node.left.parent = node;\n                }\n                \n                leftChild.parent = node.parent;\n                \n                if (!node.parent) {\n                    this.root = leftChild;\n                } else if (node === node.parent.left) {\n                    node.parent.left = leftChild;\n                } else {\n                    node.parent.right = leftChild;\n                }\n                \n                leftChild.right = node;\n                node.parent = leftChild;\n            }\n        }\n        \n        function visualizeTree(tree, container) {\n            container.innerHTML = '';\n            \n            if (!tree.root) return;\n            \n            const treeWidth = container.offsetWidth;\n            const treeHeight = container.offsetHeight;\n            const nodeSize = 60;\n            const levelHeight = 100;\n            \n            const positions = new Map();\n            let maxLevel = 0;\n            \n            // Calculate node positions\n            function calculatePositions(node, level, x, direction) {\n                if (!node) return;\n                \n                maxLevel = Math.max(maxLevel, level);\n                \n                const offset = treeWidth / Math.pow(2, level + 1);\n                const posX = direction === 'left' ? x - offset : x + offset;\n                \n                positions.set(node, { x: posX, y: level * levelHeight + 50 });\n                \n                calculatePositions(node.left, level + 1, posX, 'left');\n                calculatePositions(node.right, level + 1, posX, 'right');\n            }\n            \n            // Start from root at the top center\n            positions.set(tree.root, { x: treeWidth / 2, y: 50 });\n            calculatePositions(tree.root.left, 1, treeWidth / 2, 'left');\n            calculatePositions(tree.root.right, 1, treeWidth / 2, 'right');\n            \n            // Draw connectors first (so nodes appear on top)\n            positions.forEach((pos, node) => {\n                if (node.left && positions.has(node.left)) {\n                    const leftPos = positions.get(node.left);\n                    drawConnector(pos, leftPos, container);\n                }\n                if (node.right && positions.has(node.right)) {\n                    const rightPos = positions.get(node.right);\n                    drawConnector(pos, rightPos, container);\n                }\n            });\n            \n            // Draw nodes\n            positions.forEach((pos, node) => {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = `node ${node.color}`;\n                nodeElement.textContent = node.value;\n                nodeElement.style.left = `${pos.x - nodeSize/2}px`;\n                nodeElement.style.top = `${pos.y - nodeSize/2}px`;\n                nodeElement.setAttribute('data-value', node.value);\n                \n                // Add animation delay based on level\n                nodeElement.style.animationDelay = `${pos.y / 300}s`;\n                \n                container.appendChild(nodeElement);\n            });\n        }\n        \n        function drawConnector(from, to, container) {\n            const length = Math.sqrt(Math.pow(to.x - from.x, 2) + Math.pow(to.y - from.y, 2));\n            const angle = Math.atan2(to.y - from.y, to.x - from.x) * 180 / Math.PI;\n            \n            const connector = document.createElement('div');\n            connector.className = 'connector';\n            connector.style.width = `${length}px`;\n            connector.style.left = `${from.x}px`;\n            connector.style.top = `${from.y}px`;\n            connector.style.transform = `rotate(${angle}deg)`;\n            \n            container.appendChild(connector);\n        }\n    </script>\n</body>\n</html>"
