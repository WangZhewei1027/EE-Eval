    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Dijkstra — Visual Elegance</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071129;\n    --panel: rgba(255,255,255,0.04);\n    --accent: linear-gradient(135deg,#7dd3fc 0%,#60a5fa 40%,#7c3aed 100%);\n    --muted: rgba(255,255,255,0.65);\n    --glass: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --success: #34d399;\n    --danger: #fb7185;\n    --soft: rgba(255,255,255,0.06);\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 15%, rgba(124,58,237,0.12), transparent 8%),\n                radial-gradient(1000px 500px at 90% 85%, rgba(96,165,250,0.06), transparent 10%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  .app{\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n  }\n\n  .card{\n    width:1100px;\n    max-width: calc(100% - 96px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    display:grid;\n    grid-template-columns:410px 1fr;\n    gap:28px;\n    padding:28px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border: 1px solid rgba(255,255,255,0.04);\n    backdrop-filter: blur(8px) saturate(120%);\n    overflow:hidden;\n  }\n\n  /* Left panel */\n  .left{\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    display:flex;\n    flex-direction:column;\n    gap:20px;\n  }\n\n  .brand{\n    display:flex;\n    align-items:center;\n    gap:14px;\n  }\n  .logo{\n    width:56px;\n    height:56px;\n    border-radius:14px;\n    background: linear-gradient(135deg,#60a5fa,#7c3aed);\n    box-shadow: 0 6px 20px rgba(124,58,237,0.18), inset 0 -6px 18px rgba(255,255,255,0.06);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:800;\n    font-family:\"Playfair Display\", serif;\n    color:white;\n    transform:rotate(-10deg);\n  }\n  .title{\n    font-family:\"Playfair Display\", serif;\n    font-size:20px;\n    line-height:1;\n    color: #f8fbff;\n  }\n  .subtitle{\n    font-size:12px;\n    color:var(--muted);\n    margin-top:4px;\n  }\n\n  .desc{\n    margin-top:8px;\n    color: #d9e9ff;\n    opacity:0.95;\n    font-size:13px;\n    line-height:1.5;\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:auto;\n    align-items:center;\n  }\n\n  .btn{\n    appearance:none;\n    border:0;\n    padding:12px 16px;\n    border-radius:12px;\n    cursor:pointer;\n    color:white;\n    font-weight:600;\n    font-size:13px;\n    letter-spacing:0.2px;\n    box-shadow: 0 6px 22px rgba(3,7,18,0.5);\n    transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  .btn:active{ transform:translateY(1px) }\n  .btn:disabled{ opacity:0.5; cursor:not-allowed; transform:none; box-shadow:none }\n\n  .btn-play{\n    background: linear-gradient(90deg,#60a5fa,#7c3aed);\n  }\n  .btn-reset{\n    background: transparent;\n    border: 1px solid rgba(255,255,255,0.06);\n    color: #cfe9ff;\n    backdrop-filter: blur(6px);\n  }\n\n  .meta{\n    display:flex;\n    gap:10px;\n    align-items:center;\n    margin-top:14px;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .badge{\n    font-size:12px;\n    padding:6px 8px;\n    background:rgba(255,255,255,0.02);\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.02);\n    color:var(--muted);\n  }\n\n  .explain{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:12px;\n    padding:14px;\n    margin-top:8px;\n    font-size:13px;\n    color:#d2e8ff;\n    line-height:1.5;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Right: visualization */\n  .right{\n    position:relative;\n    border-radius:14px;\n    overflow:hidden;\n    display:flex;\n    flex-direction:column;\n    padding:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.03);\n  }\n\n  .viz-header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    padding:8px 12px;\n    gap:12px;\n  }\n  .legend{\n    display:flex;\n    gap:10px;\n    font-size:13px;\n    align-items:center;\n  }\n  .legend .item{ display:flex; gap:8px; align-items:center; color:var(--muted) }\n  .swatch{\n    width:12px;height:12px;border-radius:4px;background:linear-gradient(90deg,#60a5fa,#7c3aed);box-shadow:0 4px 14px rgba(124,58,237,0.18);\n  }\n  .panel-bottom{\n    margin-top:8px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  /* SVG container */\n  .canvas-wrap{\n    flex:1;\n    min-height:420px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n  svg{ width:100%; height:100%; display:block; overflow:visible }\n\n  /* Node styles */\n  .node{\n    cursor:default;\n    transition:transform .35s cubic-bezier(.2,.9,.2,1), filter .35s;\n    transform-origin:center;\n    will-change:transform, filter;\n  }\n  .node .core{\n    transition:fill .25s ease, r .25s ease;\n    filter: drop-shadow(0 10px 30px rgba(2,6,23,0.6));\n  }\n  .node .halo{\n    transition:opacity .35s ease, transform .35s ease;\n    transform-origin:center;\n  }\n  .node-label{\n    font-size:12px;\n    fill: #e8f5ff;\n    font-weight:700;\n    text-anchor:middle;\n    dominant-baseline:central;\n    pointer-events:none;\n  }\n  .node-dist{\n    font-size:11px;\n    fill:#bfe6ff;\n    opacity:0.95;\n    text-anchor:middle;\n    dominant-baseline:central;\n    pointer-events:none;\n  }\n\n  /* Edge styles */\n  .edge{\n    stroke:rgba(255,255,255,0.06);\n    stroke-width:3;\n    stroke-linecap:round;\n    transition:stroke .25s ease, stroke-width .25s ease, opacity .25s ease;\n    filter: drop-shadow(0 6px 16px rgba(2,6,23,0.4));\n  }\n  .edge .weight{\n    font-size:12px;\n    fill:#cdeeff;\n    pointer-events:none;\n  }\n\n  /* states */\n  .state-unseen .core{ fill: url(#gNodeBase) }\n  .state-frontier .core{ fill: url(#gNodeAccent); transform:scale(1.04) }\n  .state-visited .core{ fill: linear-gradient(90deg,#4ade80,#16a34a) }\n  .state-final .core{ fill: url(#gNodeFinal); transform:scale(1.08) }\n\n  .node-frontier .halo{ opacity:0.6; transform:scale(1) }\n  .node-visited .halo{ opacity:0.9; transform:scale(1.25) }\n  .node-final .halo{ opacity:1; transform:scale(1.6) }\n\n  /* subtle floating background */\n  .bg-orb{\n    position:absolute;\n    right:-10%;\n    top:-20%;\n    width:420px;\n    height:420px;\n    border-radius:50%;\n    background: radial-gradient(circle at 30% 20%, rgba(96,165,250,0.08), transparent 25%),\n                radial-gradient(circle at 70% 80%, rgba(124,58,237,0.06), transparent 18%);\n    z-index:0;\n    filter: blur(30px);\n    transform: rotate(12deg);\n    pointer-events:none;\n  }\n\n  .info-panel{\n    font-size:13px;\n    margin-top:10px;\n    color:var(--muted);\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  /* small log */\n  .log{\n    margin-top:14px;\n    font-size:12px;\n    color: #cfe9ff;\n    opacity:0.9;\n    line-height:1.5;\n    height:88px;\n    overflow:hidden;\n  }\n\n  /* Hover hints */\n  .hint{\n    color:var(--muted);\n    font-size:12px;\n    margin-top:6px;\n  }\n\n  /* Responsive */\n  @media (max-width:1000px){\n    .card{ grid-template-columns: 1fr; width:calc(100% - 48px) }\n    .left{ order:2 }\n    .right{ order:1 }\n    .canvas-wrap{ min-height:360px }\n  }\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"card\" role=\"main\" aria-label=\"Dijkstra algorithm visualization\">\n    <div class=\"left\">\n      <div class=\"brand\">\n        <div class=\"logo\">Dk</div>\n        <div>\n          <div class=\"title\">Dijkstra — Path to Elegance</div>\n          <div class=\"subtitle\">A refined visualization of shortest path discovery</div>\n        </div>\n      </div>\n\n      <div class=\"desc\">\n        Observe Dijkstra's algorithm as it unfolds. A curated graph breathes with motion: explored nodes glow, frontier nodes shimmer, and the shortest path emerges in a final, luminous reveal. Minimal controls — just play/pause and reset — keep the focus on the story the visualization tells.\n      </div>\n\n      <div class=\"meta\">\n        <div class=\"badge\">Source: Node A</div>\n        <div class=\"badge\">Target: Node H</div>\n        <div class=\"badge\">Weighted, positive edges</div>\n      </div>\n\n      <div class=\"explain\">\n        Dijkstra's algorithm systematically picks the currently closest unexplored node (the frontier), relaxes its outgoing edges to update tentative distances, and eventually finalizes the shortest path to the target. The visual accent here is on clarity and craft — see distances update smoothly and the path materialize.\n      </div>\n\n      <div class=\"controls\">\n        <button id=\"playBtn\" class=\"btn btn-play\" title=\"Play / Pause\">\n          ▶︎ Play\n        </button>\n        <button id=\"resetBtn\" class=\"btn btn-reset\" title=\"Reset visualization\">Reset</button>\n        <div style=\"flex:1\"></div>\n      </div>\n\n      <div class=\"log\" id=\"log\" aria-live=\"polite\">\n        Ready. Press Play to begin the demonstration.\n      </div>\n\n      <div class=\"hint\">Tip: This demo is curated for observation — limited controls keep attention on the animation and design.</div>\n    </div>\n\n    <div class=\"right\">\n      <div class=\"viz-header\">\n        <div style=\"display:flex;flex-direction:column;\">\n          <div style=\"font-weight:700;font-size:15px;color:#f8fbff\">Graph Canvas</div>\n          <div style=\"font-size:12px;color:var(--muted);margin-top:2px\">Animated Dijkstra exploration</div>\n        </div>\n        <div class=\"legend\">\n          <div class=\"item\"><div class=\"swatch\"></div> Current/Frontier</div>\n          <div class=\"item\" style=\"opacity:0.85\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"6\" fill=\"#34d399\" /></svg> Finalized</div>\n        </div>\n      </div>\n\n      <div class=\"canvas-wrap\" aria-hidden=\"false\">\n        <div class=\"bg-orb\"></div>\n        <!-- SVG Graph -->\n        <svg id=\"svg\" viewBox=\"0 0 900 520\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"gNodeBase\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#1f2937\" stop-opacity=\"0.8\"/>\n              <stop offset=\"1\" stop-color=\"#0f1724\" stop-opacity=\"0.9\"/>\n            </linearGradient>\n            <linearGradient id=\"gNodeAccent\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#60a5fa\"/>\n              <stop offset=\"1\" stop-color=\"#7c3aed\"/>\n            </linearGradient>\n            <linearGradient id=\"gNodeFinal\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#10b981\"/>\n              <stop offset=\"1\" stop-color=\"#059669\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-40%\" y=\"-40%\" width=\"180%\" height=\"180%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- Edges group -->\n          <g id=\"edges\"></g>\n          <!-- Edge animated pulses layer -->\n          <g id=\"edge-pulses\"></g>\n\n          <!-- Nodes group -->\n          <g id=\"nodes\"></g>\n\n        </svg>\n      </div>\n\n      <div class=\"panel-bottom\" style=\"margin-top:12px;\">\n        <div class=\"info-panel\">\n          <div style=\"font-weight:700\">Current action:</div>\n          <div id=\"actionText\" style=\"color:var(--muted)\">Idle</div>\n        </div>\n        <div style=\"flex:1\"></div>\n        <div style=\"color:var(--muted);font-size:12px\">Visualization curated • non-interactive graph</div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n(() => {\n  // Predefined graph layout and weighted edges\n  const nodes = [\n    { id: 'A', x: 120, y: 100 },\n    { id: 'B', x: 330, y: 70 },\n    { id: 'C', x: 540, y: 100 },\n    { id: 'D', x: 220, y: 230 },\n    { id: 'E', x: 430, y: 230 },\n    { id: 'F', x: 660, y: 230 },\n    { id: 'G', x: 240, y: 380 },\n    { id: 'H', x: 540, y: 380 },\n  ];\n\n  const edges = [\n    { from:'A', to:'B', w:4 },\n    { from:'A', to:'D', w:2 },\n    { from:'B', to:'C', w:3 },\n    { from:'B', to:'E', w:6 },\n    { from:'C', to:'F', w:2 },\n    { from:'D', to:'E', w:1 },\n    { from:'D', to:'G', w:7 },\n    { from:'E', to:'F', w:1 },\n    { from:'E', to:'H', w:4 },\n    { from:'F', to:'H', w:3 },\n    { from:'G', to:'H', w:2 },\n  ];\n\n  const startId = 'A';\n  const targetId = 'H';\n\n  // Build adjacency\n  const adj = {};\n  nodes.forEach(n => adj[n.id] = []);\n  edges.forEach(e => {\n    adj[e.from].push({to:e.to,w:e.w});\n    adj[e.to].push({to:e.from,w:e.w});\n  });\n\n  // SVG references\n  const svg = document.getElementById('svg');\n  const nodesGroup = document.getElementById('nodes');\n  const edgesGroup = document.getElementById('edges');\n  const pulsesGroup = document.getElementById('edge-pulses');\n  const actionText = document.getElementById('actionText');\n  const logBox = document.getElementById('log');\n\n  // Create map of nodes for rendering\n  const nodeMap = new Map();\n  nodes.forEach(n => nodeMap.set(n.id, n));\n\n  // Draw edges\n  function drawEdges(){\n    edgesGroup.innerHTML = '';\n    pulsesGroup.innerHTML = '';\n    edges.forEach((e,i) => {\n      const a = nodeMap.get(e.from);\n      const b = nodeMap.get(e.to);\n\n      const edgeId = `edge-${e.from}-${e.to}`;\n      const line = document.createElementNS('http://www.w3.org/2000/svg','path');\n      const d = `M ${a.x} ${a.y} L ${b.x} ${b.y}`;\n      line.setAttribute('d', d);\n      line.setAttribute('class','edge');\n      line.setAttribute('id', edgeId);\n      line.setAttribute('stroke-linecap','round');\n      line.setAttribute('fill','none');\n      line.setAttribute('data-w', e.w);\n\n      edgesGroup.appendChild(line);\n\n      // weight label: place at midpoint with slight offset\n      const mx = (a.x + b.x)/2;\n      const my = (a.y + b.y)/2;\n      const weight = document.createElementNS('http://www.w3.org/2000/svg','text');\n      weight.setAttribute('x', mx + (Math.random()*6-3));\n      weight.setAttribute('y', my + (Math.random()*6-3));\n      weight.setAttribute('class', 'weight');\n      weight.setAttribute('style', 'font-size:12px; fill:#cdeeff; pointer-events:none;');\n      weight.textContent = e.w;\n      edgesGroup.appendChild(weight);\n\n      // pulse path for animation (invisible base)\n      const pulse = document.createElementNS('http://www.w3.org/2000/svg','path');\n      pulse.setAttribute('d', d);\n      pulse.setAttribute('fill','none');\n      pulse.setAttribute('stroke','url(#gNodeAccent)');\n      pulse.setAttribute('stroke-width','6');\n      pulse.setAttribute('stroke-linecap','round');\n      pulse.setAttribute('opacity','0.0');\n      pulse.setAttribute('id', 'pulse-'+i);\n      pulse.setAttribute('stroke-dasharray','8 200');\n      pulsesGroup.appendChild(pulse);\n    });\n  }\n\n  // Draw nodes\n  function drawNodes(){\n    nodesGroup.innerHTML = '';\n    nodes.forEach(n => {\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${n.x},${n.y})`);\n      g.setAttribute('class', 'node state-unseen');\n      g.setAttribute('data-id', n.id);\n\n      // halo\n      const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      halo.setAttribute('r', 30);\n      halo.setAttribute('class','halo');\n      halo.setAttribute('fill','url(#gNodeBase)');\n      halo.setAttribute('opacity','0.08');\n      halo.setAttribute('filter','url(#glow)');\n      g.appendChild(halo);\n\n      // core\n      const core = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      core.setAttribute('r', 16);\n      core.setAttribute('class','core');\n      core.setAttribute('fill','url(#gNodeBase)');\n      g.appendChild(core);\n\n      // label\n      const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n      label.setAttribute('class','node-label');\n      label.setAttribute('y',-2);\n      label.textContent = n.id;\n      g.appendChild(label);\n\n      // distance\n      const dist = document.createElementNS('http://www.w3.org/2000/svg','text');\n      dist.setAttribute('class','node-dist');\n      dist.setAttribute('y',24);\n      dist.textContent = '∞';\n      dist.setAttribute('data-dist','inf');\n      g.appendChild(dist);\n\n      nodesGroup.appendChild(g);\n    });\n  }\n\n  drawEdges();\n  drawNodes();\n\n  // Utility: set node state classes\n  function setNodeState(id, state){\n    const g = nodesGroup.querySelector(`[data-id=\"${id}\"]`);\n    if(!g) return;\n    g.classList.remove('state-unseen','state-frontier','state-visited','state-final');\n    g.classList.remove('node-frontier','node-visited','node-final');\n    if(state === 'unseen'){ g.classList.add('state-unseen'); g.querySelector('.halo').setAttribute('opacity','0.06'); }\n    if(state === 'frontier'){ g.classList.add('state-frontier'); g.querySelector('.halo').setAttribute('opacity','0.5'); }\n    if(state === 'visited'){ g.classList.add('state-visited'); g.querySelector('.halo').setAttribute('opacity','0.9'); }\n    if(state === 'final'){ g.classList.add('state-final'); g.querySelector('.halo').setAttribute('opacity','1'); }\n  }\n\n  // Utility: update distance label\n  function updateDistLabel(id, val){\n    const g = nodesGroup.querySelector(`[data-id=\"${id}\"]`);\n    if(!g) return;\n    const dist = g.querySelector('.node-dist');\n    dist.textContent = (val===Infinity)? '∞' : String(val);\n    dist.setAttribute('data-dist', String(val));\n    // animate a subtle pulse\n    const core = g.querySelector('.core');\n    core.animate([\n      { transform: 'scale(1)' },\n      { transform: 'scale(1.06)' },\n      { transform: 'scale(1)' }\n    ], { duration: 360, easing: 'cubic-bezier(.2,.9,.2,1)' });\n  }\n\n  // Animate pulse along edge\n  function animateEdgePulse(edgeIndex, color='#7c3aed', duration=700){\n    const pulse = pulsesGroup.children[edgeIndex];\n    if(!pulse) return;\n    pulse.setAttribute('opacity','1');\n    pulse.style.transition = `opacity ${duration}ms ease`;\n    pulse.setAttribute('stroke', color);\n\n    // animate dashoffset\n    pulse.animate([\n      { strokeDashoffset: '0' },\n      { strokeDashoffset: '-220' }\n    ], { duration: duration, easing: 'linear' });\n\n    setTimeout(()=> {\n      pulse.setAttribute('opacity','0');\n    }, duration-80);\n  }\n\n  // Simple priority queue (min-heap)\n  class MinHeap {\n    constructor(){ this.data = [] }\n    push(item){ this.data.push(item); this._siftUp() }\n    pop(){\n      if(this.data.length===0) return null;\n      if(this.data.length===1) return this.data.pop();\n      const top = this.data[0];\n      this.data[0] = this.data.pop();\n      this._siftDown();\n      return top;\n    }\n    _siftUp(){\n      let i = this.data.length-1;\n      while(i>0){\n        const p = Math.floor((i-1)/2);\n        if(this.data[p].dist <= this.data[i].dist) break;\n        [this.data[p], this.data[i]] = [this.data[i], this.data[p]];\n        i = p;\n      }\n    }\n    _siftDown(){\n      let i=0;\n      while(true){\n        const l = 2*i+1, r = 2*i+2;\n        let smallest = i;\n        if(l < this.data.length && this.data[l].dist < this.data[smallest].dist) smallest = l;\n        if(r < this.data.length && this.data[r].dist < this.data[smallest].dist) smallest = r;\n        if(smallest === i) break;\n        [this.data[i], this.data[smallest]] = [this.data[smallest], this.data[i]];\n        i = smallest;\n      }\n    }\n    isEmpty(){ return this.data.length===0 }\n  }\n\n  // Compute Dijkstra steps (non-animated): we'll produce events to animate\n  function computeDijkstraSteps(start, target){\n    // Initialize\n    const dist = {};\n    const prev = {};\n    nodes.forEach(n => { dist[n.id] = Infinity; prev[n.id] = null; });\n    dist[start] = 0;\n    const visited = new Set();\n    const heap = new MinHeap();\n    heap.push({ id: start, dist: 0 });\n\n    const steps = []; // each step: {type:'visit'|'consider'|'relax'|'finalize', data:...}\n\n    // initial frontier\n    steps.push({ type:'init', dist: {...dist} });\n\n    while(!heap.isEmpty()){\n      const cur = heap.pop();\n      const id = cur.id;\n      if(visited.has(id)) continue;\n      visited.add(id);\n      steps.push({ type:'visit', id, dist: {...dist} });\n\n      if(id === target){\n        steps.push({ type:'targetReached', id, dist: {...dist} });\n        break;\n      }\n\n      for(const edge of adj[id]){\n        const to = edge.to;\n        const weight = edge.w;\n        // consider edge\n        steps.push({ type:'consider', from:id, to, weight, dist: {...dist} });\n\n        if(visited.has(to)) continue;\n        if(dist[id] + weight < dist[to]){\n          const old = dist[to];\n          dist[to] = dist[id] + weight;\n          prev[to] = id;\n          heap.push({ id: to, dist: dist[to] });\n          steps.push({ type:'relax', from:id, to, weight, oldDist:old, newDist:dist[to], dist: {...dist} });\n        }\n      }\n      steps.push({ type:'finalize', id, dist: {...dist} });\n    }\n\n    // reconstruct path\n    const path = [];\n    let cur = target;\n    while(cur){\n      path.push(cur);\n      cur = prev[cur];\n    }\n    path.reverse();\n    steps.push({ type:'path', path, dist:{...dist} });\n\n    return steps;\n  }\n\n  const steps = computeDijkstraSteps(startId, targetId);\n\n  // Animation controller\n  let idx = 0;\n  let running = false;\n  let timer = null;\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  function log(msg){\n    logBox.textContent = msg;\n  }\n\n  function resetVisual(){\n    if(timer) { clearTimeout(timer); timer = null; }\n    idx = 0;\n    running = false;\n    playBtn.textContent = '▶︎ Play';\n    actionText.textContent = 'Idle';\n    // reset nodes\n    nodes.forEach(n => {\n      setNodeState(n.id, 'unseen');\n      updateDistLabel(n.id, Infinity);\n      const g = nodesGroup.querySelector(`[data-id=\"${n.id}\"]`);\n      // subtle transform reset\n      if(g) g.setAttribute('transform', `translate(${n.x},${n.y})`);\n    });\n    // reset edges\n    Array.from(edgesGroup.querySelectorAll('.edge')).forEach(e=>{\n      e.setAttribute('opacity','1');\n      e.setAttribute('stroke','rgba(255,255,255,0.06)');\n      e.setAttribute('stroke-width','3');\n    });\n    // set start dist\n    updateDistLabel(startId, 0);\n    setNodeState(startId, 'frontier');\n    log('Ready. Press Play to begin the demonstration.');\n  }\n\n  resetVisual();\n\n  function stepForward(){\n    if(idx >= steps.length){\n      finishVisual();\n      return;\n    }\n    const s = steps[idx++];\n    // handle types\n    if(s.type === 'init'){\n      actionText.textContent = 'Preparing…';\n      setTimeout(()=>{}, 120);\n    } else if(s.type === 'visit'){\n      actionText.textContent = `Visiting node ${s.id}`;\n      setNodeState(s.id, 'visited');\n      // subtle pop\n      const g = nodesGroup.querySelector(`[data-id=\"${s.id}\"]`);\n      if(g){\n        g.animate([\n          { transform: 'translate('+nodeMap.get(s.id).x+'px,'+nodeMap.get(s.id).y+'px) scale(1)' },\n          { transform: 'translate('+nodeMap.get(s.id).x+'px,'+nodeMap.get(s.id).y+'px) scale(1.03)' },\n          { transform: 'translate('+nodeMap.get(s.id).x+'px,'+nodeMap.get(s.id).y+'px) scale(1)' }\n        ], { duration: 420, easing: 'cubic-bezier(.2,.9,.2,1)' });\n      }\n      log(`Visited ${s.id}. Tentative distances updated previously.`);\n    } else if(s.type === 'consider'){\n      actionText.textContent = `Considering edge ${s.from} → ${s.to} (w=${s.weight})`;\n      // find edge index\n      const edgeIndex = edges.findIndex(ed => (ed.from===s.from && ed.to===s.to) || (ed.from===s.to && ed.to===s.from));\n      if(edgeIndex>=0) animateEdgePulse(edgeIndex, '#60a5fa', 680);\n      // highlight the to node as frontier candidate\n      setNodeState(s.to, 'frontier');\n      // temporary emphasize edge\n      const a = edgesGroup.querySelectorAll('.edge')[edgeIndex];\n      if(a){\n        a.setAttribute('stroke','rgba(124,58,237,0.9)');\n        a.setAttribute('stroke-width','5');\n        setTimeout(()=> { a.setAttribute('stroke','rgba(255,255,255,0.06)'); a.setAttribute('stroke-width','3'); }, 600);\n      }\n      log(`Considering ${s.from} → ${s.to} (w=${s.weight})`);\n    } else if(s.type === 'relax'){\n      actionText.textContent = `Relax: ${s.from} → ${s.to} → dist ${s.oldDist} → ${s.newDist}`;\n      updateDistLabel(s.to, s.newDist);\n      // animate node brightness\n      const g = nodesGroup.querySelector(`[data-id=\"${s.to}\"]`);\n      if(g){\n        const core = g.querySelector('.core');\n        core.animate([\n          { filter: 'brightness(0.9)' },\n          { filter: 'brightness(1.2)' },\n          { filter: 'brightness(1)' }\n        ], { duration: 420, easing: 'ease-out' });\n      }\n      log(`Updated distance to ${s.to}: ${s.newDist}`);\n    } else if(s.type === 'finalize'){\n      actionText.textContent = `Finalized ${s.id}`;\n      setNodeState(s.id, 'final');\n      // brighten connected edges\n      edges.forEach((ed,ei) => {\n        if(ed.from===s.id || ed.to===s.id){\n          const eelm = edgesGroup.querySelectorAll('.edge')[ei];\n          if(eelm){\n            eelm.setAttribute('stroke','rgba(96,165,250,0.14)');\n            eelm.setAttribute('stroke-width','4');\n            setTimeout(()=> { if(eelm) { eelm.setAttribute('stroke','rgba(255,255,255,0.06)'); eelm.setAttribute('stroke-width','3'); } }, 700);\n          }\n        }\n      });\n      log(`Node ${s.id} finalized.`);\n    } else if(s.type === 'targetReached'){\n      actionText.textContent = `Target ${s.id} reached — reconstructing path`;\n      log(`Target ${s.id} reached. Shortest path will be highlighted.`);\n    } else if(s.type === 'path'){\n      actionText.textContent = `Shortest path discovered`;\n      // highlight path\n      const p = s.path;\n      // highlight nodes on path\n      p.forEach((nid, idxP) => {\n        setTimeout(()=> {\n          setNodeState(nid, 'final');\n          updateDistLabel(nid, s.dist[nid]);\n        }, idxP*120);\n      });\n      // highlight edges along path\n      setTimeout(()=> {\n        for(let i=0;i<p.length-1;i++){\n          const a = p[i], b = p[i+1];\n          const edgeIndex = edges.findIndex(ed => (ed.from===a && ed.to===b) || (ed.from===b && ed.to===a));\n          const eelm = edgesGroup.querySelectorAll('.edge')[edgeIndex];\n          if(eelm){\n            eelm.setAttribute('stroke','url(#gNodeAccent)');\n            eelm.setAttribute('stroke-width','6');\n            eelm.setAttribute('opacity','1');\n            // animate a bright pulse\n            animateEdgePulse(edgeIndex, '#34d399', 900);\n          }\n        }\n        log(`Shortest path: ${p.join(' → ')} (distance: ${s.dist[targetId]})`);\n      }, 240);\n      // mark finished after some time\n      setTimeout(()=> { actionText.textContent = 'Complete'; }, 1000);\n    }\n  }\n\n  function run(){\n    if(running) return;\n    running = true;\n    playBtn.textContent = '❚❚ Pause';\n    log('Running demonstration...');\n    const tick = () => {\n      if(!running) return;\n      stepForward();\n      if(idx < steps.length){\n        timer = setTimeout(tick, 720);\n      } else {\n        running = false;\n        playBtn.textContent = '▶︎ Play';\n      }\n    };\n    tick();\n  }\n\n  function pause(){\n    running = false;\n    playBtn.textContent = '▶︎ Play';\n    if(timer){ clearTimeout(timer); timer = null; }\n    log('Paused');\n  }\n\n  playBtn.addEventListener('click', ()=>{\n    if(!running){\n      // If at end, reset first\n      if(idx >= steps.length) { resetVisual(); }\n      run();\n    } else {\n      pause();\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    pause();\n    resetVisual();\n  });\n\n  // auto-play once after slight delay for presentation\n  setTimeout(()=> {\n    playBtn.click();\n  }, 900);\n\n})();\n</script>\n</body>\n</html>"
