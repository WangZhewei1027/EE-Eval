    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deque Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Deque Interactive Demo</h1>\n    <div>\n        <input type=\"number\" id=\"valueInput\" placeholder=\"Enter a number\" />\n        <button onclick=\"addFront()\">Add to Front</button>\n        <button onclick=\"addBack()\">Add to Back</button>\n        <button onclick=\"removeFront()\">Remove from Front</button>\n        <button onclick=\"removeBack()\">Remove from Back</button>\n        <button onclick=\"clearDeque()\">Clear Deque</button>\n    </div>\n    <div>\n        <strong>Current Deque:</strong>\n        <div id=\"output\">[]</div>\n    </div>\n\n    <script>\n        class Deque {\n            constructor() {\n                this.items = [];\n            }\n\n            addFront(element) {\n                this.items.unshift(element);\n            }\n\n            addBack(element) {\n                this.items.push(element);\n            }\n\n            removeFront() {\n                return this.items.shift();\n            }\n\n            removeBack() {\n                return this.items.pop();\n            }\n\n            size() {\n                return this.items.length;\n            }\n\n            clear() {\n                this.items = [];\n            }\n\n            toString() {\n                return JSON.stringify(this.items);\n            }\n        }\n\n        const deque = new Deque();\n\n        function updateOutput() {\n            document.getElementById(\"output\").innerText = deque.toString();\n        }\n\n        function addFront() {\n            const value = document.getElementById(\"valueInput\").value;\n            if (value) {\n                deque.addFront(value);\n                updateOutput();\n                document.getElementById(\"valueInput\").value = '';\n            }\n        }\n\n        function addBack() {\n            const value = document.getElementById(\"valueInput\").value;\n            if (value) {\n                deque.addBack(value);\n                updateOutput();\n                document.getElementById(\"valueInput\").value = '';\n            }\n        }\n\n        function removeFront() {\n            if (deque.size() > 0) {\n                deque.removeFront();\n                updateOutput();\n            }\n        }\n\n        function removeBack() {\n            if (deque.size() > 0) {\n                deque.removeBack();\n                updateOutput();\n            }\n        }\n\n        function clearDeque() {\n            deque.clear();\n            updateOutput();\n        }\n    </script>\n</body>\n</html>"
