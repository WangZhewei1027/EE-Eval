    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Context Switching Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        .hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Context Switching Interactive Demo</h1>\n\n<div>\n    <h2>Control Area</h2>\n    <button id=\"view1Btn\">View 1</button>\n    <button id=\"view2Btn\">View 2</button>\n    <button id=\"view3Btn\">View 3</button>\n</div>\n\n<div id=\"view1\" class=\"view hidden\">\n    <h2>View 1</h2>\n    <input type=\"text\" id=\"input1\" placeholder=\"Type something...\">\n    <button id=\"submit1\">Submit</button>\n    <div id=\"output1\"></div>\n</div>\n\n<div id=\"view2\" class=\"view hidden\">\n    <h2>View 2</h2>\n    <input type=\"range\" id=\"slider1\" min=\"0\" max=\"100\" value=\"50\">\n    <button id=\"submit2\">Submit Slider</button>\n    <div id=\"output2\"></div>\n</div>\n\n<div id=\"view3\" class=\"view hidden\">\n    <h2>View 3</h2>\n    <input type=\"text\" id=\"input2\" placeholder=\"Another input...\">\n    <label for=\"select1\">Choose an option:</label>\n    <select id=\"select1\">\n        <option value=\"Option 1\">Option 1</option>\n        <option value=\"Option 2\">Option 2</option>\n        <option value=\"Option 3\">Option 3</option>\n    </select>\n    <button id=\"submit3\">Submit</button>\n    <div id=\"output3\"></div>\n</div>\n\n<script>\n    document.getElementById('view1Btn').onclick = function() {\n        switchView('view1');\n    };\n    document.getElementById('view2Btn').onclick = function() {\n        switchView('view2');\n    };\n    document.getElementById('view3Btn').onclick = function() {\n        switchView('view3');\n    };\n\n    function switchView(viewId) {\n        const views = document.querySelectorAll('.view');\n        views.forEach(view => {\n            if (view.id === viewId) {\n                view.classList.remove('hidden');\n            } else {\n                view.classList.add('hidden');\n            }\n        });\n    }\n\n    document.getElementById('submit1').onclick = function() {\n        const input = document.getElementById('input1').value;\n        document.getElementById('output1').innerText = 'You entered: ' + input;\n    };\n    \n    document.getElementById('submit2').onclick = function() {\n        const sliderValue = document.getElementById('slider1').value;\n        document.getElementById('output2').innerText = 'Slider value: ' + sliderValue;\n    };\n\n    document.getElementById('submit3').onclick = function() {\n        const input = document.getElementById('input2').value;\n        const selectedOption = document.getElementById('select1').value;\n        document.getElementById('output3').innerText = 'Input: ' + input + ', Selected: ' + selectedOption;\n    };\n</script>\n\n</body>\n</html>"
