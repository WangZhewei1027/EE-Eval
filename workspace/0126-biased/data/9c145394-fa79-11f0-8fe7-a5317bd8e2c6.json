    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Floyd-Warshall Interactive Demonstration</title>\n<style>\n  /* Extremely minimal styling: keep plain black text on white background and basic layout */\n  body { margin: 12px; font-family: monospace; color: black; background: white; }\n  input, button, select, textarea { font-family: monospace; }\n  table { border-collapse: collapse; }\n  td, th { padding: 2px 4px; vertical-align: middle; }\n  .matrix-input { width: 64px; }\n  .small { width: 40px; }\n  .tight { padding: 1px 3px; }\n  .section { margin-bottom: 12px; }\n  textarea { width: 100%; height: 80px; }\n</style>\n</head>\n<body>\n\n<h3>Floyd-Warshall Algorithm — Interactive Demonstration</h3>\n\n<div class=\"section\">\n  Controls (very plain):\n  <div>\n    Nodes:\n    <input id=\"nodeCount\" type=\"range\" min=\"2\" max=\"10\" value=\"5\"> <input id=\"nodeCountNum\" class=\"small\" type=\"number\" min=\"2\" max=\"10\" value=\"5\">\n    Directed:\n    <input id=\"directed\" type=\"checkbox\" checked>\n    Make symmetric (undirected helper):\n    <button id=\"symmetrize\">Symmetrize (copy i→j to j→i)</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    Initialize:\n    <button id=\"initDefault\">Default (0, INF diag)</button>\n    <button id=\"randomize\">Randomize</button>\n    Edge probability:\n    <input id=\"edgeProb\" type=\"range\" min=\"0\" max=\"100\" value=\"50\"> <input id=\"edgeProbNum\" class=\"small\" type=\"number\" min=\"0\" max=\"100\" value=\"50\"> \n    Weight range:\n    <input id=\"minWeight\" class=\"small\" type=\"number\" value=\"-5\"> to <input id=\"maxWeight\" class=\"small\" type=\"number\" value=\"10\">\n    Random integer weights.\n    <button id=\"clearAll\">Clear (all INF)</button>\n    <button id=\"completePos\">Complete non-negative</button>\n    <button id=\"presetNegCycle\">Preset: Negative Cycle</button>\n  </div>\n\n</div>\n\n<div class=\"section\">\n  Adjacency matrix (edit weights or \"INF\" or leave blank):\n  <div id=\"adjContainer\"></div>\n  <div style=\"margin-top:6px;\">\n    Auto-update matrices from adjacency: <button id=\"applyAdj\">Apply Adjacency</button>\n    Read matrices into adjacency (overwrite): <button id=\"captureAsAdj\">Capture Current Matrices to Adjacency</button>\n    Auto-symmetric on edit:\n    <input id=\"autoSym\" type=\"checkbox\">\n  </div>\n</div>\n\n<div class=\"section\">\n  Floyd-Warshall controls:\n  <div>\n    Step controls:\n    <button id=\"toStart\">|&lt; Start</button>\n    <button id=\"stepBack\">&lt; Step</button>\n    <button id=\"stepForward\">Step &gt;</button>\n    <button id=\"toEnd\">End &gt;|</button>\n    Play:\n    <button id=\"playPause\">Play</button>\n    Speed (ms per step):\n    <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\"> <input id=\"speedNum\" class=\"small\" type=\"number\" min=\"50\" max=\"2000\" value=\"400\">\n    Run full (compute all states):\n    <button id=\"runFull\">Run Full</button>\n    Run until negative cycle:\n    <button id=\"runUntilNeg\">Run Until Negative Cycle</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    Manual triple application: k (0-based)\n    <input id=\"manualK\" class=\"small\" type=\"number\" min=\"0\" value=\"0\">\n    i:\n    <input id=\"manualI\" class=\"small\" type=\"number\" min=\"0\" value=\"0\">\n    j:\n    <input id=\"manualJ\" class=\"small\" type=\"number\" min=\"0\" value=\"0\">\n    <button id=\"applyTriple\">Apply single (i,j,k)</button>\n    Commit current matrices as new base snapshot:\n    <button id=\"commitSnapshot\">Commit Snapshot</button>\n    Undo/Redo:\n    <button id=\"undo\">Undo</button> <button id=\"redo\">Redo</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    Show changes only:\n    <input id=\"showChangesOnly\" type=\"checkbox\">\n    Show predecessor/next:\n    <input id=\"showNext\" type=\"checkbox\" checked>\n    Show log verbose:\n    <input id=\"verboseLog\" type=\"checkbox\">\n  </div>\n</div>\n\n<div class=\"section\">\n  Matrices / State display:\n  <div id=\"stateInfo\"></div>\n  <div style=\"display:flex; gap:12px;\">\n    <div>\n      Distance matrix (current):\n      <div id=\"distContainer\"></div>\n    </div>\n    <div>\n      Next matrix (for reconstructing paths):\n      <div id=\"nextContainer\"></div>\n    </div>\n  </div>\n  <div style=\"margin-top:8px;\">\n    Reconstruct path:\n    From <input id=\"pathFrom\" class=\"small\" type=\"number\" min=\"0\" value=\"0\"> To <input id=\"pathTo\" class=\"small\" type=\"number\" min=\"0\" value=\"1\">\n    <button id=\"reconstructPath\">Show Path</button>\n    <div id=\"pathResult\"></div>\n  </div>\n</div>\n\n<div class=\"section\">\n  Logs and history:\n  <div>Step index: <span id=\"stepIndex\">0</span> / <span id=\"stepCount\">0</span></div>\n  <div style=\"height:150px; overflow:auto; border:1px solid #000; padding:6px;\">\n    <pre id=\"logArea\" style=\"margin:0; white-space:pre-wrap;\"></pre>\n  </div>\n  <div style=\"margin-top:6px;\">\n    Save/Load state:\n    <button id=\"exportJson\">Export JSON</button>\n    <button id=\"importJsonBtn\">Import JSON (overwrite)</button>\n    <textarea id=\"jsonArea\" placeholder=\"State JSON appears here when exporting or paste JSON here to import\"></textarea>\n  </div>\n</div>\n\n<div class=\"section\">\n  Misc tools:\n  <button id=\"dijkstraCompare\">Compare with Dijkstra (single-source)</button>\n  Source:\n  <input id=\"dijSrc\" class=\"small\" type=\"number\" min=\"0\" value=\"0\">\n  <div id=\"dijkstraResult\"></div>\n</div>\n\n<script>\n(function(){\n  const INF = 1e12;\n  let n = 5;\n  let directed = true;\n  let history = []; // snapshots\n  let histIndex = -1; // current index\n  let playing = false;\n  let playTimer = null;\n\n  // Each snapshot: {dist:[][], next:[][], meta:{k,i,j,comp,updated,old,new,via}, description}\n  // Initial snapshot at histIndex = 0 is the initial state (k = -1)\n  const adjContainer = document.getElementById('adjContainer');\n  const distContainer = document.getElementById('distContainer');\n  const nextContainer = document.getElementById('nextContainer');\n  const nodeCount = document.getElementById('nodeCount');\n  const nodeCountNum = document.getElementById('nodeCountNum');\n  const directedChk = document.getElementById('directed');\n  const autoSymChk = document.getElementById('autoSym');\n  const edgeProb = document.getElementById('edgeProb');\n  const edgeProbNum = document.getElementById('edgeProbNum');\n  const speed = document.getElementById('speed');\n  const speedNum = document.getElementById('speedNum');\n\n  function label(i){ return String.fromCharCode(65 + i); }\n\n  function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }\n\n  function makeEmptyMatrices(size){\n    const dist = Array.from({length:size}, (_,i)=> Array.from({length:size}, (_,j)=> i===j?0:INF));\n    const next = Array.from({length:size}, ()=> Array.from({length:size}, ()=> null));\n    return {dist,next};\n  }\n\n  function copyMatrix(m){\n    return m.map(row => row.slice());\n  }\n\n  // Build adjacency editable table\n  function buildAdjTable(){\n    adjContainer.innerHTML = '';\n    const table = document.createElement('table');\n    const header = document.createElement('tr');\n    header.appendChild(document.createElement('th'));\n    for(let j=0;j<n;j++){\n      const th = document.createElement('th');\n      th.textContent = label(j);\n      header.appendChild(th);\n    }\n    table.appendChild(header);\n    for(let i=0;i<n;i++){\n      const tr = document.createElement('tr');\n      const th = document.createElement('th');\n      th.textContent = label(i);\n      tr.appendChild(th);\n      for(let j=0;j<n;j++){\n        const td = document.createElement('td');\n        const input = document.createElement('input');\n        input.className = 'matrix-input';\n        input.dataset.i = i;\n        input.dataset.j = j;\n        input.value = (i===j)? '0' : '';\n        input.addEventListener('change', onAdjChanged);\n        td.appendChild(input);\n        tr.appendChild(td);\n      }\n      table.appendChild(tr);\n    }\n    adjContainer.appendChild(table);\n  }\n\n  function onAdjChanged(e){\n    if(autoSymChk.checked){\n      const i = parseInt(e.target.dataset.i,10);\n      const j = parseInt(e.target.dataset.j,10);\n      if(i!==j){\n        // copy to symmetric cell\n        const inputs = adjContainer.querySelectorAll('input');\n        for(const inp of inputs){\n          if(parseInt(inp.dataset.i,10)===j && parseInt(inp.dataset.j,10)===i){\n            inp.value = e.target.value;\n            break;\n          }\n        }\n      }\n    }\n  }\n\n  function readAdjacency(){\n    const inputs = adjContainer.querySelectorAll('input');\n    const mat = Array.from({length:n}, ()=> Array.from({length:n}, ()=> INF));\n    for(const inp of inputs){\n      const i = parseInt(inp.dataset.i,10);\n      const j = parseInt(inp.dataset.j,10);\n      let v = inp.value.trim();\n      if(v === '' || v.toUpperCase()==='INF') {\n        mat[i][j] = INF;\n      } else {\n        const num = Number(v);\n        if(Number.isFinite(num)) mat[i][j] = num;\n        else mat[i][j] = INF;\n      }\n    }\n    for(let i=0;i<n;i++) mat[i][i]=0;\n    return mat;\n  }\n\n  function writeAdjacencyFromMatrices(dist){\n    const inputs = adjContainer.querySelectorAll('input');\n    for(const inp of inputs){\n      const i = parseInt(inp.dataset.i,10);\n      const j = parseInt(inp.dataset.j,10);\n      let v = dist[i][j];\n      if(i===j) inp.value = '0';\n      else inp.value = (Math.abs(v) > INF/2)? 'INF' : String(Number.isFinite(v)? v : 'INF');\n    }\n  }\n\n  function initFromAdj(){\n    const mat = readAdjacency();\n    const next = Array.from({length:n}, ()=> Array.from({length:n}, ()=> null));\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i!==j && Math.abs(mat[i][j]) < INF/2){\n          next[i][j] = j;\n        } else if(i===j){\n          next[i][j] = i;\n        } else {\n          next[i][j] = null;\n        }\n      }\n    }\n    const snap = {dist: mat, next: next, meta:{k:-1}, description:'Initial from adjacency'};\n    history = [serializeSnapshot(snap)];\n    histIndex = 0;\n    rebuildStateUI();\n  }\n\n  function initDefault(){\n    const {dist,next} = makeEmptyMatrices(n);\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i!==j) dist[i][j] = INF;\n        next[i][j] = (i===j)? i : null;\n      }\n    }\n    const snap = {dist, next, meta:{k:-1}, description:'Default empty (no edges)'};\n    history = [serializeSnapshot(snap)];\n    histIndex = 0;\n    writeAdjacencyFromMatrices(dist);\n    rebuildStateUI();\n  }\n\n  function randomizeGraph(){\n    const prob = Number(edgeProbNum.value)/100;\n    const minW = Number(document.getElementById('minWeight').value);\n    const maxW = Number(document.getElementById('maxWeight').value);\n    const dist = Array.from({length:n}, (_,i)=> Array.from({length:n}, (_,j)=> i===j?0:INF));\n    const next = Array.from({length:n}, ()=> Array.from({length:n}, ()=> null));\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i===j) continue;\n        if(Math.random() < prob){\n          const w = Math.floor(Math.random()*(maxW - minW +1)) + minW;\n          dist[i][j] = w;\n          next[i][j] = j;\n        } else {\n          dist[i][j] = INF;\n          next[i][j] = null;\n        }\n      }\n    }\n    if(!directed){\n      for(let i=0;i<n;i++){\n        for(let j=i+1;j<n;j++){\n          if(Math.random() < prob){\n            const w = Math.floor(Math.random()*(maxW - minW +1)) + minW;\n            dist[i][j] = w; dist[j][i] = w;\n            next[i][j] = j; next[j][i] = i;\n          }\n        }\n      }\n    }\n    const snap = {dist, next, meta:{k:-1}, description:'Randomized graph'};\n    history = [serializeSnapshot(snap)];\n    histIndex = 0;\n    writeAdjacencyFromMatrices(dist);\n    rebuildStateUI();\n  }\n\n  function presetNegativeCycle(){\n    // small 4-node graph with negative cycle\n    n = 4;\n    nodeCount.value = n; nodeCountNum.value = n;\n    buildAdjTable();\n    const dist = [\n      [0, 1, INF, INF],\n      [INF, 0, -2, INF],\n      [INF, INF, 0, -2],\n      [-1, INF, INF, 0]\n    ];\n    const next = Array.from({length:n}, ()=> Array.from({length:n}, ()=> null));\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i===j){ next[i][j]=i; continue;}\n        if(Math.abs(dist[i][j])<INF/2) next[i][j]=j;\n      }\n    }\n    history = [serializeSnapshot({dist,next,meta:{k:-1}, description:'Preset negative cycle'})];\n    histIndex = 0;\n    writeAdjacencyFromMatrices(dist);\n    rebuildStateUI();\n  }\n\n  function completeNonNegative(){\n    const dist = Array.from({length:n}, (_,i)=> Array.from({length:n}, (_,j)=> i===j?0: Math.floor(Math.random()*10+1)));\n    const next = Array.from({length:n}, ()=> Array.from({length:n}, ()=> null));\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i!==j) next[i][j]=j;\n        else next[i][j]=i;\n      }\n    }\n    history = [serializeSnapshot({dist,next,meta:{k:-1}, description:'Complete non-negative'})];\n    histIndex = 0;\n    writeAdjacencyFromMatrices(dist);\n    rebuildStateUI();\n  }\n\n  function clearAll(){\n    const {dist,next} = makeEmptyMatrices(n);\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i===j) next[i][j] = i;\n        else next[i][j] = null;\n      }\n    }\n    history = [serializeSnapshot({dist,next,meta:{k:-1}, description:'Cleared'})];\n    histIndex = 0;\n    writeAdjacencyFromMatrices(dist);\n    rebuildStateUI();\n  }\n\n  function serializeSnapshot(snap){\n    // ensure deep copy of arrays\n    const dist = copyMatrix(snap.dist);\n    const next = copyMatrix(snap.next);\n    return {dist,next,meta:Object.assign({}, snap.meta), description: snap.description || ''};\n  }\n\n  function pushSnapshot(snap){\n    // push snapshot, truncate any redo branch\n    history = history.slice(0, histIndex+1);\n    history.push(serializeSnapshot(snap));\n    histIndex = history.length - 1;\n  }\n\n  function rebuildStateUI(){\n    // Update info, matrices, logs (log area should reflect from meta)\n    const stateInfo = document.getElementById('stateInfo');\n    stateInfo.innerHTML = 'Nodes: ' + n + ' | Directed: ' + (directed ? 'Yes' : 'No') + '<br>' +\n      'Current: ' + (histIndex+1) + ' / ' + history.length + ' | Description: ' + (history[histIndex]?.description || '');\n    document.getElementById('stepIndex').textContent = String(histIndex);\n    document.getElementById('stepCount').textContent = String(history.length-1);\n    renderDistNext();\n    renderLog();\n  }\n\n  function renderDistNext(){\n    const snap = history[histIndex];\n    if(!snap) return;\n    const dist = snap.dist;\n    const next = snap.next;\n    // Distance matrix\n    distContainer.innerHTML = '';\n    const table = document.createElement('table');\n    const header = document.createElement('tr');\n    header.appendChild(document.createElement('th'));\n    for(let j=0;j<n;j++){ const th=document.createElement('th'); th.textContent=label(j); header.appendChild(th); }\n    table.appendChild(header);\n    for(let i=0;i<n;i++){\n      const tr=document.createElement('tr');\n      const th=document.createElement('th'); th.textContent = label(i);\n      tr.appendChild(th);\n      for(let j=0;j<n;j++){\n        const td=document.createElement('td');\n        const val = dist[i][j];\n        const txt = (Math.abs(val) > INF/2 || !Number.isFinite(val)) ? 'INF' : String(val);\n        const span = document.createElement('span');\n        span.textContent = txt;\n        td.appendChild(span);\n        tr.appendChild(td);\n      }\n      table.appendChild(tr);\n    }\n    distContainer.appendChild(table);\n\n    // Next matrix\n    nextContainer.innerHTML = '';\n    if(document.getElementById('showNext').checked){\n      const t2 = document.createElement('table');\n      const h2 = document.createElement('tr');\n      h2.appendChild(document.createElement('th'));\n      for(let j=0;j<n;j++){ const th=document.createElement('th'); th.textContent=label(j); h2.appendChild(th); }\n      t2.appendChild(h2);\n      for(let i=0;i<n;i++){\n        const tr = document.createElement('tr');\n        const th = document.createElement('th'); th.textContent=label(i);\n        tr.appendChild(th);\n        for(let j=0;j<n;j++){\n          const td = document.createElement('td');\n          const v = next[i][j];\n          td.textContent = (v===null || v===undefined) ? '-' : label(v);\n          tr.appendChild(td);\n        }\n        t2.appendChild(tr);\n      }\n      nextContainer.appendChild(t2);\n    } else {\n      nextContainer.textContent = '(hidden)';\n    }\n  }\n\n  function renderLog(){\n    const logArea = document.getElementById('logArea');\n    const snap = history[histIndex];\n    if(!snap){ logArea.textContent=''; return; }\n    // Build a log by scanning history entries up to current index, optionally verbose\n    const verbose = document.getElementById('verboseLog').checked;\n    let lines = [];\n    for(let idx=0; idx<=histIndex; idx++){\n      const s = history[idx];\n      const m = s.meta || {};\n      if(m.k === -1 || m.k === undefined){\n        lines.push((idx) + ': Initial state. ' + (s.description || ''));\n      } else {\n        const changed = m.updated ? 'UPDATED' : 'checked';\n        const detail = `k=${m.k}, i=${label(m.i)}, j=${label(m.j)} => ${changed}`;\n        if(m.updated){\n          lines.push(idx + ': ' + detail + (verbose ? ` | old=${formatVal(m.old)} new=${formatVal(m.new)} via=${label(m.via)}` : ''));\n        } else {\n          lines.push(idx + ': ' + detail);\n        }\n      }\n    }\n    logArea.textContent = lines.join('\\n');\n  }\n\n  function formatVal(v){\n    return (Math.abs(v) > INF/2 || !Number.isFinite(v)) ? 'INF' : String(v);\n  }\n\n  function computeFullHistory(){\n    // Run the Floyd-Warshall algorithm starting from current base snapshot (histIndex)\n    // We'll produce snapshots for every comparison (k,i,j) and any updates.\n    const base = history[histIndex];\n    const dist = copyMatrix(base.dist);\n    const next = copyMatrix(base.next);\n    const newHistory = [];\n    // initial snapshot copy\n    newHistory.push(serializeSnapshot({dist: copyMatrix(dist), next: copyMatrix(next), meta:{k:-1}, description: 'Start of run'}));\n    for(let k=0;k<n;k++){\n      for(let i=0;i<n;i++){\n        for(let j=0;j<n;j++){\n          const oldVal = dist[i][j];\n          const viaVal = (Math.abs(dist[i][k]) < INF/2 && Math.abs(dist[k][j]) < INF/2) ? dist[i][k] + dist[k][j] : INF;\n          let updated = false;\n          if(viaVal + 0 < oldVal){\n            dist[i][j] = viaVal;\n            next[i][j] = next[i][k];\n            updated = true;\n          }\n          const meta = {k,k,i:i,j:j,updated:updated, old:oldVal, new:dist[i][j], via:k};\n          newHistory.push(serializeSnapshot({dist: copyMatrix(dist), next: copyMatrix(next), meta, description: `After k=${k}, i=${i}, j=${j}`}));\n        }\n      }\n    }\n    // Replace history branch after current index with newHistory appended to base\n    // We will keep snapshots up to histIndex then append newHistory (excluding initial base duplicate)\n    history = history.slice(0, histIndex+1).concat(newHistory.slice(1)); // remove duplicate starting snapshot\n    histIndex = history.length - 1;\n    rebuildStateUI();\n  }\n\n  function runUntilNegativeCycle(){\n    const base = history[histIndex];\n    const dist = copyMatrix(base.dist);\n    const next = copyMatrix(base.next);\n    const newHistory = [];\n    newHistory.push(serializeSnapshot({dist: copyMatrix(dist), next: copyMatrix(next), meta:{k:-1}, description:'Start runUntilNeg'}));\n    let foundNeg = false;\n    for(let k=0;k<n && !foundNeg;k++){\n      for(let i=0;i<n && !foundNeg;i++){\n        for(let j=0;j<n;j++){\n          const oldVal = dist[i][j];\n          const viaVal = (Math.abs(dist[i][k])<INF/2 && Math.abs(dist[k][j])<INF/2) ? dist[i][k] + dist[k][j] : INF;\n          let updated = false;\n          if(viaVal + 0 < oldVal){\n            dist[i][j] = viaVal;\n            next[i][j] = next[i][k];\n            updated = true;\n          }\n          const meta = {k,k,i:i,j:j,updated:updated,old:oldVal,new:dist[i][j],via:k};\n          newHistory.push(serializeSnapshot({dist: copyMatrix(dist), next: copyMatrix(next), meta, description:`k=${k},i=${i},j=${j}`}));\n          // check negative cycle\n          for(let x=0;x<n;x++){\n            if(dist[x][x] < 0){\n              foundNeg = true;\n              newHistory.push(serializeSnapshot({dist: copyMatrix(dist), next: copyMatrix(next), meta:{k:k, note:'negcycle'}, description:'Negative cycle detected'}));\n              break;\n            }\n          }\n          if(foundNeg) break;\n        }\n      }\n    }\n    history = history.slice(0, histIndex+1).concat(newHistory.slice(1));\n    histIndex = history.length - 1;\n    rebuildStateUI();\n    if(foundNeg) alert('Negative cycle detected in the run (check dist[x][x] < 0).');\n  }\n\n  function stepForward(){\n    if(histIndex < history.length - 1){\n      histIndex++;\n      rebuildStateUI();\n    } else {\n      // nothing to step, optionally compute full\n    }\n  }\n\n  function stepBack(){\n    if(histIndex > 0){\n      histIndex--;\n      rebuildStateUI();\n    }\n  }\n\n  function toStart(){\n    histIndex = 0;\n    rebuildStateUI();\n  }\n\n  function toEnd(){\n    histIndex = history.length - 1;\n    rebuildStateUI();\n  }\n\n  function playPause(){\n    if(playing){\n      playing = false;\n      clearInterval(playTimer);\n      playTimer = null;\n      document.getElementById('playPause').textContent = 'Play';\n    } else {\n      playing = true;\n      document.getElementById('playPause').textContent = 'Pause';\n      const interval = Number(speed.value);\n      playTimer = setInterval(()=> {\n        if(histIndex < history.length - 1) stepForward();\n        else { playPause(); }\n      }, interval);\n    }\n  }\n\n  function applySingleTriple(k,i,j){\n    const base = history[histIndex];\n    const dist = copyMatrix(base.dist);\n    const next = copyMatrix(base.next);\n    if(k < 0 || k >= n || i<0 || i>=n || j<0 || j>=n) { alert('Indices out of range'); return; }\n    const oldVal = dist[i][j];\n    const viaVal = (Math.abs(dist[i][k])<INF/2 && Math.abs(dist[k][j])<INF/2) ? dist[i][k] + dist[k][j] : INF;\n    let updated = false;\n    if(viaVal + 0 < oldVal){\n      dist[i][j] = viaVal;\n      next[i][j] = next[i][k];\n      updated = true;\n    }\n    const meta = {k:k,i:i,j:j,updated:updated,old:oldVal,new:dist[i][j],via:k};\n    pushSnapshot({dist: copyMatrix(dist), next: copyMatrix(next), meta, description:`Manual triple k=${k},i=${i},j=${j}`});\n    rebuildStateUI();\n  }\n\n  function commitSnapshot(){\n    // commit current snapshot as new base and truncate history leaving only this state\n    const snap = serializeSnapshot(history[histIndex]);\n    history = [snap];\n    histIndex = 0;\n    rebuildStateUI();\n  }\n\n  function reconstructPath(u,v){\n    const snap = history[histIndex];\n    const next = snap.next;\n    const dist = snap.dist;\n    if(Math.abs(dist[u][v])>INF/2) return {path:null, distance: Infinity};\n    if(next[u][v] === null) return {path:null, distance: Infinity};\n    const path = [u];\n    let cur = u;\n    while(cur !== v){\n      cur = next[cur][v];\n      if(cur === null || path.length > n+5) { return {path:null,distance:Infinity}; }\n      path.push(cur);\n    }\n    return {path, distance: Math.abs(dist[u][v])>INF/2? Infinity: dist[u][v]};\n  }\n\n  function reconstructPathText(){\n    const from = Number(document.getElementById('pathFrom').value);\n    const to = Number(document.getElementById('pathTo').value);\n    if(isNaN(from) || isNaN(to) || from <0 || to <0 || from>=n || to>=n){ alert('Out of range'); return; }\n    const res = reconstructPath(from,to);\n    const out = document.getElementById('pathResult');\n    if(!res.path) out.textContent = 'No path (distance INF)';\n    else out.textContent = 'Path: ' + res.path.map(label).join(' -> ') + ' | Distance: ' + res.distance;\n  }\n\n  function applyAdjToMatrices(){\n    const mat = readAdjacency();\n    const next = Array.from({length:n}, ()=> Array.from({length:n}, ()=> null));\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i===j) next[i][j]=i;\n        else if(Math.abs(mat[i][j]) < INF/2) next[i][j]=j;\n        else next[i][j]=null;\n      }\n    }\n    pushSnapshot({dist: mat, next, meta:{k:-1}, description:'Applied adjacency inputs'});\n    rebuildStateUI();\n  }\n\n  function captureMatricesToAdj(){\n    const snap = history[histIndex];\n    writeAdjacencyFromMatrices(snap.dist);\n  }\n\n  function symmetrizeAdj(){\n    const inputs = adjContainer.querySelectorAll('input');\n    const map = {};\n    for(const inp of inputs){\n      const key = inp.dataset.i + ',' + inp.dataset.j;\n      map[key] = inp;\n    }\n    for(const key in map){\n      const [i,j] = key.split(',').map(Number);\n      if(i<j){\n        map[j+','+i].value = map[key].value;\n      }\n    }\n  }\n\n  function exportJson(){\n    const data = {\n      n: n,\n      directed: directed,\n      history: history.map(snap => ({\n        dist: snap.dist.map(row => row.map(v => (Math.abs(v)>INF/2 || !Number.isFinite(v))? 'INF' : v)),\n        next: snap.next.map(row => row.map(v => (v===null || v===undefined)? null : v)),\n        meta: snap.meta,\n        description: snap.description\n      })),\n      histIndex: histIndex\n    };\n    document.getElementById('jsonArea').value = JSON.stringify(data, null, 2);\n  }\n\n  function importJson(){\n    try {\n      const txt = document.getElementById('jsonArea').value;\n      if(!txt) { alert('Paste JSON into textarea first'); return; }\n      const data = JSON.parse(txt);\n      if(!data || !data.n) { alert('Invalid JSON'); return; }\n      n = data.n;\n      nodeCount.value = n; nodeCountNum.value = n;\n      directed = data.directed;\n      directedChk.checked = directed;\n      buildAdjTable();\n      history = data.history.map(snap => {\n        const dist = snap.dist.map(row => row.map(v => (v==='INF' || v===null)? INF : Number(v)));\n        const next = snap.next.map(row => row.map(v => (v===null)? null : v));\n        return {dist,next,meta:snap.meta, description: snap.description};\n      });\n      histIndex = clamp(Number(data.histIndex)||0, 0, history.length-1);\n      writeAdjacencyFromMatrices(history[histIndex].dist);\n      rebuildStateUI();\n    } catch(e){\n      alert('Failed to import JSON: ' + e.message);\n    }\n  }\n\n  function undo(){\n    // go to previous snapshot if available\n    if(histIndex > 0){\n      histIndex--;\n      rebuildStateUI();\n    }\n  }\n\n  function redo(){\n    if(histIndex < history.length - 1){\n      histIndex++;\n      rebuildStateUI();\n    }\n  }\n\n  function dijkstraCompare(){\n    const src = Number(document.getElementById('dijSrc').value);\n    if(isNaN(src) || src<0 || src>=n){ alert('Invalid source'); return; }\n    // We only run if no negative weights present (Dijkstra requires nonnegative edges)\n    const snap = history[histIndex];\n    const dist = snap.dist;\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i!==j && Math.abs(dist[i][j])<INF/2 && dist[i][j] < 0){\n          alert('Negative edge present; Dijkstra is not valid');\n          return;\n        }\n      }\n    }\n    // Build adjacency list\n    const adj = Array.from({length:n}, ()=> []);\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(Math.abs(dist[i][j])<INF/2){\n          adj[i].push({to:j, w: dist[i][j]});\n        }\n      }\n    }\n    // run Dijkstra\n    const d = Array(n).fill(Infinity);\n    const prev = Array(n).fill(null);\n    d[src] = 0;\n    const visited = Array(n).fill(false);\n    for(let t=0;t<n;t++){\n      let u=-1; let best=Infinity;\n      for(let i=0;i<n;i++) if(!visited[i] && d[i]<best){ best=d[i]; u=i; }\n      if(u===-1) break;\n      visited[u]=true;\n      for(const e of adj[u]){\n        if(d[e.to] > d[u] + e.w){\n          d[e.to] = d[u] + e.w;\n          prev[e.to] = u;\n        }\n      }\n    }\n    // compare with Floyd-Warshall result for same source\n    const fw = snap.dist[src];\n    let lines = [];\n    for(let i=0;i<n;i++){\n      const fwv = fw[i];\n      const dv = d[i];\n      lines.push(label(i) + ': Dijkstra=' + (dv===Infinity? 'INF' : dv) + ' | Floyd=' + ((Math.abs(fwv)>INF/2) ? 'INF' : fwv) + ((Math.abs(fwv - dv) > 1e-6) ? ' <-- mismatch' : ''));\n    }\n    document.getElementById('dijkstraResult').textContent = lines.join('\\n');\n  }\n\n  // Utility to build compute-full and then step through via play; but we already have computeFullHistory()\n\n  // Setup event listeners\n  nodeCount.addEventListener('input', ()=> {\n    n = Number(nodeCount.value);\n    nodeCountNum.value = n;\n    buildAdjTable();\n    initDefault();\n  });\n  nodeCountNum.addEventListener('change', ()=> {\n    let v = clamp(Number(nodeCountNum.value) || 2, 2, 10);\n    n = v;\n    nodeCount.value = v;\n    nodeCountNum.value = v;\n    buildAdjTable();\n    initDefault();\n  });\n  directedChk.addEventListener('change', ()=> {\n    directed = directedChk.checked;\n  });\n  edgeProb.addEventListener('input', ()=> { edgeProbNum.value = edgeProb.value; });\n  edgeProbNum.addEventListener('change', ()=> { const v = clamp(Number(edgeProbNum.value)||0,0,100); edgeProb.value = v; edgeProbNum.value = v; });\n\n  speed.addEventListener('input', ()=> { speedNum.value = speed.value; if(playing){ playPause(); playPause(); }});\n  speedNum.addEventListener('change', ()=> { const v = clamp(Number(speedNum.value)||400, 50, 2000); speed.value = v; speedNum.value = v; if(playing){ playPause(); playPause(); }});\n\n  document.getElementById('initDefault').addEventListener('click', initDefault);\n  document.getElementById('randomize').addEventListener('click', randomizeGraph);\n  document.getElementById('applyAdj').addEventListener('click', applyAdjToMatrices);\n  document.getElementById('captureAsAdj').addEventListener('click', captureMatricesToAdj);\n  document.getElementById('symmetrize').addEventListener('click', symmetrizeAdj);\n  document.getElementById('clearAll').addEventListener('click', clearAll);\n  document.getElementById('completePos').addEventListener('click', completeNonNegative);\n  document.getElementById('presetNegCycle').addEventListener('click', presetNegativeCycle);\n\n  document.getElementById('toStart').addEventListener('click', toStart);\n  document.getElementById('toEnd').addEventListener('click', toEnd);\n  document.getElementById('stepForward').addEventListener('click', ()=> { stepForward(); });\n  document.getElementById('stepBack').addEventListener('click', ()=> { stepBack(); });\n  document.getElementById('playPause').addEventListener('click', playPause);\n  document.getElementById('runFull').addEventListener('click', computeFullHistory);\n  document.getElementById('runUntilNeg').addEventListener('click', runUntilNegativeCycle);\n\n  document.getElementById('applyTriple').addEventListener('click', ()=> {\n    const k = Number(document.getElementById('manualK').value);\n    const i = Number(document.getElementById('manualI').value);\n    const j = Number(document.getElementById('manualJ').value);\n    applySingleTriple(k,i,j);\n  });\n\n  document.getElementById('commitSnapshot').addEventListener('click', commitSnapshot);\n  document.getElementById('undo').addEventListener('click', undo);\n  document.getElementById('redo').addEventListener('click', redo);\n\n  document.getElementById('reconstructPath').addEventListener('click', reconstructPathText);\n\n  document.getElementById('exportJson').addEventListener('click', exportJson);\n  document.getElementById('importJsonBtn').addEventListener('click', importJson);\n\n  document.getElementById('applyAdj').addEventListener('dblclick', ()=> { alert('Double-click detected: quick tip: edit adjacency entries and click Apply Adjacency to load into algorithm.'); });\n\n  document.getElementById('dijkstraCompare').addEventListener('click', dijkstraCompare);\n\n  // Keyboard stepping\n  window.addEventListener('keydown', (e)=>{\n    if(e.key === 'ArrowRight') stepForward();\n    if(e.key === 'ArrowLeft') stepBack();\n    if(e.key === ' ') { e.preventDefault(); playPause(); }\n  });\n\n  // Initialize UI\n  buildAdjTable();\n  initDefault();\n\n  // Extra: allow user to change adjacency element types by clicking to cycle INF/<number> - left minimal behavior\n  adjContainer.addEventListener('dblclick', (e)=>{\n    const t = e.target;\n    if(t.tagName === 'INPUT'){\n      if(t.value.trim()==='') t.value = 'INF';\n      else if(t.value.trim().toUpperCase()==='INF') t.value = '1';\n      else t.value = '';\n      onAdjChanged({target:t});\n    }\n  });\n\n  // Expose some state to window for debugging in console (allowed minimal)\n  window.fwState = {\n    getHistory: ()=> history,\n    getIndex: ()=> histIndex,\n    stepForward,\n    stepBack,\n    computeFullHistory,\n    reconstructPath: reconstructPath\n  };\n\n})();\n</script>\n\n</body>\n</html>"
