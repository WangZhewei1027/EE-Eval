    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Software Development Life Cycle</title>\n    <style>\n        body {\n            background-color: #000;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"text\"], select, textarea {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n        button {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #333;\n            color: #fff;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #444;\n        }\n    </style>\n</head>\n<body>\n    <h1>Software Development Life Cycle</h1>\n    <p>Phase 1: Requirements Gathering</p>\n    <div class=\"phase\">\n        <h2>Requirements Gathering</h2>\n        <form>\n            <label for=\"name\">Name:</label>\n            <input type=\"text\" id=\"name\" name=\"name\"><br><br>\n            <label for=\"email\">Email:</label>\n            <input type=\"email\" id=\"email\" name=\"email\"><br><br>\n            <label for=\"message\">Message:</label>\n            <textarea id=\"message\" name=\"message\"></textarea><br><br>\n            <input type=\"submit\" value=\"Submit\">\n        </form>\n    </div>\n    <p>Phase 2: Design</p>\n    <div class=\"phase\">\n        <h2>Design</h2>\n        <form>\n            <label for=\"color\">Color:</label>\n            <select id=\"color\" name=\"color\">\n                <option value=\"red\">Red</option>\n                <option value=\"green\">Green</option>\n                <option value=\"blue\">Blue</option>\n            </select><br><br>\n            <label for=\"shape\">Shape:</label>\n            <select id=\"shape\" name=\"shape\">\n                <option value=\"circle\">Circle</option>\n                <option value=\"square\">Square</option>\n                <option value=\"triangle\">Triangle</option>\n            </select><br><br>\n            <label for=\"size\">Size:</label>\n            <input type=\"number\" id=\"size\" name=\"size\"><br><br>\n            <input type=\"submit\" value=\"Submit\">\n        </form>\n    </div>\n    <p>Phase 3: Implementation</p>\n    <div class=\"phase\">\n        <h2>Implementation</h2>\n        <form>\n            <label for=\"language\">Language:</label>\n            <select id=\"language\" name=\"language\">\n                <option value=\"python\">Python</option>\n                <option value=\"java\">Java</option>\n                <option value=\"javascript\">JavaScript</option>\n            </select><br><br>\n            <label for=\"framework\">Framework:</label>\n            <select id=\"framework\" name=\"framework\">\n                <option value=\"django\">Django</option>\n                <option value=\"flask\">Flask</option>\n                <option value=\"angular\">Angular</option>\n            </select><br><br>\n            <label for=\"database\">Database:</label>\n            <select id=\"database\" name=\"database\">\n                <option value=\"mysql\">MySQL</option>\n                <option value=\"postgres\">Postgres</option>\n                <option value=\"mongodb\">MongoDB</option>\n            </select><br><br>\n            <input type=\"submit\" value=\"Submit\">\n        </form>\n    </div>\n    <p>Phase 4: Testing</p>\n    <div class=\"phase\">\n        <h2>Testing</h2>\n        <form>\n            <label for=\"test_type\">Test Type:</label>\n            <select id=\"test_type\" name=\"test_type\">\n                <option value=\"unit\">Unit</option>\n                <option value=\"integration\">Integration</option>\n                <option value=\"system\">System</option>\n            </select><br><br>\n            <label for=\"test_case\">Test Case:</label>\n            <input type=\"text\" id=\"test_case\" name=\"test_case\"><br><br>\n            <label for=\"expected_result\">Expected Result:</label>\n            <input type=\"text\" id=\"expected_result\" name=\"expected_result\"><br><br>\n            <input type=\"submit\" value=\"Submit\">\n        </form>\n    </div>\n    <p>Phase 5: Deployment</p>\n    <div class=\"phase\">\n        <h2>Deployment</h2>\n        <form>\n            <label for=\"deployment_type\">Deployment Type:</label>\n            <select id=\"deployment_type\" name=\"deployment_type\">\n                <option value=\"web\">Web</option>\n                <option value=\"mobile\">Mobile</option>\n                <option value=\"desktop\">Desktop</option>\n            </select><br><br>\n            <label for=\"deployment_method\">Deployment Method:</label>\n            <select id=\"deployment_method\" name=\"deployment_method\">\n                <option value=\"git\">Git</option>\n                <option value=\"svn\">SVN</option>\n                <option value=\"mercurial\">Mercurial</option>\n            </select><br><br>\n            <input type=\"submit\" value=\"Submit\">\n        </form>\n    </div>\n    <p>Phase 6: Maintenance</p>\n    <div class=\"phase\">\n        <h2>Maintenance</h2>\n        <form>\n            <label for=\"bug_report\">Bug Report:</label>\n            <textarea id=\"bug_report\" name=\"bug_report\"></textarea><br><br>\n            <label for=\"solution\">Solution:</label>\n            <textarea id=\"solution\" name=\"solution\"></textarea><br><br>\n            <input type=\"submit\" value=\"Submit\">\n        </form>\n    </div>\n    <button onclick=\"generatePage()\">Generate Page</button>\n    <script>\n        function generatePage() {\n            var phase = document.querySelector('.phase');\n            phase.innerHTML = '';\n            phase.className = 'phase';\n\n            var name = document.querySelector('#name');\n            var email = document.querySelector('#email');\n            var message = document.querySelector('#message');\n            var color = document.querySelector('#color');\n            var shape = document.querySelector('#shape');\n            var size = document.querySelector('#size');\n            var language = document.querySelector('#language');\n            var framework = document.querySelector('#framework');\n            var database = document.querySelector('#database');\n            var test_type = document.querySelector('#test_type');\n            var test_case = document.querySelector('#test_case');\n            var expected_result = document.querySelector('#expected_result');\n            var deployment_type = document.querySelector('#deployment_type');\n            var deployment_method = document.querySelector('#deployment_method');\n            var bug_report = document.querySelector('#bug_report');\n            var solution = document.querySelector('#solution');\n\n            name.value = 'John Doe';\n            email.value = 'john.doe@example.com';\n            message.value = 'This is a sample message.';\n            color.value = 'red';\n            shape.value = 'circle';\n            size.value = 10;\n            language.value = 'python';\n            framework.value = 'django';\n            database.value = 'mysql';\n            test_type.value = 'unit';\n            test_case.value = 'test1';\n            expected_result.value = 'This is an expected result.';\n            deployment_type.value = 'web';\n            deployment_method.value = 'git';\n            bug_report.value = 'This is a bug report.';\n            solution.value = 'This is a solution.';\n        }\n    </script>\n</body>\n</html>"
