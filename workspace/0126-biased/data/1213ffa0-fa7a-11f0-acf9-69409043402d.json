    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Tim Sort Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n    margin: 1em;\n  }\n  button, input[type=number], input[type=text], select {\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  label {\n    margin-right: 0.5em;\n  }\n  .section {\n    margin-bottom: 1.2em;\n  }\n  #log {\n    border: 1px solid #000;\n    height: 180px;\n    overflow-y: auto;\n    padding: 4px;\n    white-space: pre-wrap;\n  }\n  #arrayContainer {\n    font-family: monospace, monospace;\n    line-height: 1.3em;\n  }\n  input[type=checkbox] {\n    vertical-align: middle;\n    margin-right: 0.3em;\n  }\n  select {\n    vertical-align: middle;\n  }\n</style>\n</head>\n<body>\n<h1>Tim Sort Interactive Explorer</h1>\n\n<div class=\"section\" id=\"inputSection\">\n  <label for=\"arrayInputText\">Input Array (comma or space separated integers):</label><br />\n  <textarea id=\"arrayInputText\" rows=\"3\" cols=\"60\" placeholder=\"e.g. 5, 3, 1, 4, 2\"></textarea><br />\n\n  <label for=\"runLengthInput\">Manual Min Run Length (optional):</label>\n  <input type=\"number\" id=\"runLengthInput\" min=\"1\" step=\"1\" placeholder=\"let auto-calc if blank\" size=\"5\" />\n  <button id=\"setMinRunBtn\">Set/Apply Min Run Length</button><br />\n\n  <label>\n    <input type=\"checkbox\" id=\"useNaturalRuns\" />\n    Use natural runs detection (pre-sorted runs)\n  </label><br />\n\n  <label for=\"sortOrderSelect\">Sort Order:</label>\n  <select id=\"sortOrderSelect\">\n    <option value=\"asc\" selected>Ascending</option>\n    <option value=\"desc\">Descending</option>\n  </select><br />\n</div>\n\n<div class=\"section\" id=\"commandsSection\">\n  <button id=\"parseArrayBtn\">Parse & Prepare Array</button>\n  <button id=\"autoMinRunBtn\" disabled>Auto-calc Min Run Length</button>\n  <button id=\"detectRunsBtn\" disabled>Detect Runs</button>\n  <button id=\"pushNextRunBtn\" disabled>Push Next Run onto Stack</button>\n  <button id=\"tryCollapseBtn\" disabled>Try Collapse Stack (Run merges)</button>\n  <button id=\"mergeTopRunsBtn\" disabled>Manually Merge Top Runs</button>\n  <button id=\"runSortBtn\" disabled>Sort Current Run (if unsorted)</button>\n  <button id=\"fullSortBtn\" disabled>Run Full TimSort Automatically</button>\n  <button id=\"resetBtn\">Reset All</button>\n</div>\n\n<div class=\"section\" id=\"settingsSection\">\n  <label for=\"runSortMethodSelect\">Run Sort Method:</label>\n  <select id=\"runSortMethodSelect\">\n    <option value=\"insertion\">Insertion Sort (default for small runs)</option>\n    <option value=\"binary\">Binary Insertion Sort</option>\n    <option value=\"builtin\">Built-in Array.sort()</option>\n  </select>\n</div>\n\n<div class=\"section\" id=\"statusSection\">\n  <h3>Current Status:</h3>\n  <div><b>Array:</b></div>\n  <div id=\"arrayContainer\"></div>\n  <div><b>Min Run Length:</b> <span id=\"minRunLengthDisplay\">N/A</span></div>\n  <div><b>Runs Detected:</b> <span id=\"runsDetectedCount\">0</span></div>\n  <div><b>Run Stack (top at right):</b> <span id=\"runStackDisplay\">[]</span></div>\n</div>\n\n<div class=\"section\" id=\"logsSection\">\n  <h3>Logs & Step Info:</h3>\n  <div id=\"log\" tabindex=\"0\"></div>\n</div>\n\n<script>\n(() => {\n  // Data and states\n  let array = [];\n  let minRunLength = 0;\n  let runs = []; // array of {start, length, sorted:bool}\n  let runStack = []; // indexes into runs, stack holding the runs to be merged\n  let sortedOrder = 'asc';\n\n  let naturalRunsEnabled = false;\n  let runSortMethod = 'insertion';\n\n  // DOM Elements\n  const arrayInputText = document.getElementById('arrayInputText');\n  const runLengthInput = document.getElementById('runLengthInput');\n  const setMinRunBtn = document.getElementById('setMinRunBtn');\n  const useNaturalRunsCheckbox = document.getElementById('useNaturalRuns');\n  const sortOrderSelect = document.getElementById('sortOrderSelect');\n\n  const parseArrayBtn = document.getElementById('parseArrayBtn');\n  const autoMinRunBtn = document.getElementById('autoMinRunBtn');\n  const detectRunsBtn = document.getElementById('detectRunsBtn');\n  const pushNextRunBtn = document.getElementById('pushNextRunBtn');\n  const tryCollapseBtn = document.getElementById('tryCollapseBtn');\n  const mergeTopRunsBtn = document.getElementById('mergeTopRunsBtn');\n  const runSortBtn = document.getElementById('runSortBtn');\n  const fullSortBtn = document.getElementById('fullSortBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  const runSortMethodSelect = document.getElementById('runSortMethodSelect');\n\n  const arrayContainer = document.getElementById('arrayContainer');\n  const minRunLengthDisplay = document.getElementById('minRunLengthDisplay');\n  const runsDetectedCount = document.getElementById('runsDetectedCount');\n  const runStackDisplay = document.getElementById('runStackDisplay');\n\n  const logDiv = document.getElementById('log');\n\n  // Helper functions for logging and state display\n  function log(msg) {\n    const timeStr = new Date().toLocaleTimeString();\n    logDiv.textContent += `[${timeStr}] ${msg}\\n`;\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  function arraysEqual(a, b) {\n    if (a.length !== b.length) return false;\n    for (let i=0;i<a.length;i++) {\n      if (a[i] !== b[i]) return false;\n    }\n    return true;\n  }\n\n  function updateDisplays() {\n    // Show array with runs highlighted (by underlining runs)\n    if (array.length === 0) {\n      arrayContainer.textContent = '[Empty Array]';\n      minRunLengthDisplay.textContent = 'N/A';\n      runsDetectedCount.textContent = '0';\n      runStackDisplay.textContent = '[]';\n      return;\n    }\n    // Compose a text representation, runs underlined by _ or | marks\n    // For minimal: Just show the array with brackets and runs counts\n    // More info: show array elements and runs as [run0],[run1],...\n    let parts = [];\n    if (runs.length === 0) {\n      parts.push(`[${array.join(', ')}]`);\n    } else {\n      // Show runs as separate segments\n      for (let i = 0; i < runs.length; i++) {\n        let r = runs[i];\n        let runElements = array.slice(r.start, r.start + r.length);\n        let runText = runElements.join(', ');\n        let sortedMark = r.sorted ? '(sorted)' : '(unsorted)';\n        parts.push(`[${runText}]${sortedMark}`);\n      }\n    }\n    arrayContainer.textContent = parts.join('  ');\n\n    minRunLengthDisplay.textContent = minRunLength > 0 ? minRunLength : 'N/A';\n    runsDetectedCount.textContent = runs.length.toString();\n\n    // Show run stack as something like: [RunIdx:length] for each run in runStack top at right\n    let stackText = runStack.map(i => {\n      let r = runs[i];\n      if (!r) return '?';\n      return `[Idx:${i} Start:${r.start} Len:${r.length} ${r.sorted ? 'S' : 'U'}]`;\n    }).join(' ← ');\n    runStackDisplay.textContent = stackText || '[]';\n  }\n\n  // Core: TimSort helper methods\n\n  // Calculate min run length according to python timsort logic (minimum run length between 32 and 64)\n  function calcMinRunLength(n) {\n    let r = 0;\n    while (n >= 64) {\n      r |= (n & 1);\n      n >>= 1;\n    }\n    return n + r;\n  }\n\n  // Detect natural runs in the array based on ascending or descending order\n  // Returns array of runs {start, length, sorted}\n  function detectNaturalRuns(arr, orderAsc) {\n    let runsDetected = [];\n    let n = arr.length;\n    if (n === 0) return runsDetected;\n    let i = 0;\n    while (i < n) {\n      let runStart = i;\n      i++;\n      if (i === n) {\n        runsDetected.push({start: runStart, length: 1, sorted: true});\n        break;\n      }\n      // Determine if ascending or descending run\n      let runAsc = undefined;\n      if (arr[i-1] === arr[i]) {\n        runAsc = true; // treat equal as ascending by default\n      } else {\n        runAsc = orderAsc ? true : false; // fallback default\n        // We try to detect actual order of run\n        runAsc = (arr[i-1] < arr[i]);\n      }\n      // Extend the run while order matches\n      while (i < n) {\n        if (runAsc) {\n          if (arr[i-1] <= arr[i]) {\n            i++;\n          } else break;\n        } else {\n          if (arr[i-1] >= arr[i]) {\n            i++;\n          } else break;\n        }\n      }\n      let runLength = i - runStart;\n      let sorted = true;\n      if (!runAsc) {\n        // Reverse descending runs for TimSort usage ascending anyway - timsort reverses descending runs\n        sorted = false; // mark unsorted so user can manually reverse or sort if desired\n      }\n      runsDetected.push({start: runStart, length: runLength, sorted: sorted, descending: !runAsc});\n    }\n    return runsDetected;\n  }\n\n  // Push runs of length minRunLength from remaining array part as unsorted runs if natural runs disabled\n  // or push detected runs from natural runs one by one.\n  // Returns the run object pushed or null if no runs left.\n  let pushIndex = 0;\n  function pushNextRun() {\n    if (runs.length === 0) {\n      log('No runs detected to push onto runStack.');\n      return null;\n    }\n    if (pushIndex >= runs.length) {\n      log('All runs have been pushed onto the run stack.');\n      return null;\n    }\n    let r = runs[pushIndex];\n    runStack.push(pushIndex);\n    log(`Pushed run #${pushIndex} (start: ${r.start}, length: ${r.length}, sorted: ${r.sorted}) onto the run stack.`);\n    pushIndex++;\n    updateDisplays();\n    return r;\n  }\n\n  // Merge two runs indexed by indices in runs: runStack top two\n  // Returns true if a merge was done, false otherwise\n  function tryMergeCollapse() {\n    while (true) {\n      let n = runStack.length;\n      if (n < 2) return false;\n      let i = runStack[n-2]; // second from top\n      let j = runStack[n-1]; // top\n      let runX = runs[i];\n      let runY = runs[j];\n      // TimSort invariants for merging runs:\n      // From Tim Peters' paper:\n      // Let X, Y, Z be the lengths of the last three runs on the stack\n      // (Run A on top has length Z, below it Run B length Y, below that Run C length X)\n      // Merge occurs when these conditions meet:\n      // 1) X > Y + Z and Y > Z is false - merge the smaller runs\n      // Implementing simplified version: merge top two runs whenever run before last length <= run last length\n      // For demo, let's just try to merge top two runs if possible\n      // ... since no third run info needed here, we merge top two runs if their sum <= minRunLength * 2 or top run smaller\n      // We'll allow manual merge or full auto to be precise\n\n      // We leave decision to user or separate function\n      return false; // this function only tries collapse in full auto or manual merge triggered externally\n    }\n  }\n\n  // Manually merge top two runs on stack\n  // Merge runs[i] and runs[j] where i=runStack[n-2], j=runStack[n-1]\n  // The runs must be consecutive in array, left run starts before right run\n  // Returns true on success, false if runs are not mergeable\n  function mergeTopRuns() {\n    if (runStack.length < 2) {\n      log('Need at least two runs on stack to merge.');\n      return false;\n    }\n    let n = runStack.length;\n    let i = runStack[n-2], j = runStack[n-1];\n    let run1 = runs[i];\n    let run2 = runs[j];\n\n    if (run1.start + run1.length !== run2.start) {\n      log('Runs are not contiguous and cannot be merged.');\n      return false;\n    }\n\n    log(`Merging runs #${i} (start: ${run1.start}, len: ${run1.length}) and #${j} (start: ${run2.start}, len: ${run2.length})`);\n\n    // Merge arrays slices with respect to sortedOrder\n    const mergedArray = mergeArrays(\n      array.slice(run1.start, run1.start + run1.length),\n      array.slice(run2.start, run2.start + run2.length),\n      sortedOrder\n    );\n\n    // Replace in the array\n    array.splice(run1.start, run1.length + run2.length, ...mergedArray);\n\n    // Update runs array\n    runs[i] = {start: run1.start, length: mergedArray.length, sorted: true};\n    runs.splice(j, 1); // remove run2 from runs array\n\n    // Update runStack, remove top run index\n    runStack.pop();\n\n    // Adjust runStack indices after removing run at j\n    for (let k = 0; k < runStack.length; k++) {\n      if (runStack[k] > j) runStack[k]--;\n    }\n\n    // Adjust pushIndex because runs array reduced by 1\n    if (pushIndex > j) pushIndex--;\n\n    log(`Runs merged. New run #${i} length: ${mergedArray.length}.`);\n\n    updateDisplays();\n    return true;\n  }\n\n  // Merge two sorted arrays into one sorted array given order ('asc' or 'desc')\n  function mergeArrays(left, right, order) {\n    let result = [];\n    let i = 0, j = 0;\n    while (i < left.length && j < right.length) {\n      if ((order === 'asc' && left[i] <= right[j]) || (order === 'desc' && left[i] >= right[j])) {\n        result.push(left[i++]);\n      } else {\n        result.push(right[j++]);\n      }\n    }\n    while (i < left.length) result.push(left[i++]);\n    while (j < right.length) result.push(right[j++]);\n    return result;\n  }\n\n  // Perform insertion sort on array slice [start, start+length), ascending or descending\n  function insertionSort(arr, start, length, order) {\n    let comp = (a,b) => order === 'asc' ? a > b : a < b;\n    let end = start + length;\n    for (let i = start + 1; i < end; i++) {\n      let temp = arr[i];\n      let j = i - 1;\n      while (j >= start && comp(arr[j], temp)) {\n        arr[j+1] = arr[j];\n        j--;\n      }\n      arr[j+1] = temp;\n    }\n  }\n\n  // Perform binary insertion sort on array slice [start, start+length)\n  function binaryInsertionSort(arr, start, length, order) {\n    let comp = (a,b) => order === 'asc' ? a > b : a < b;\n    let end = start + length;\n    for (let i = start + 1; i < end; i++) {\n      let key = arr[i];\n      // Find location to insert with binary search\n      let left = start, right = i - 1;\n      while (left <= right) {\n        let mid = Math.floor((left + right) / 2);\n        if (comp(arr[mid], key)) left = mid + 1;\n        else right = mid - 1;\n      }\n      // Shift all elements right from left to i-1\n      for (let j = i - 1; j >= left; j--) {\n        arr[j + 1] = arr[j];\n      }\n      arr[left] = key;\n    }\n  }\n\n  // Sort a run if unsorted by chosen method\n  function sortRun(runIndex) {\n    if (runIndex < 0 || runIndex >= runs.length) {\n      log('Invalid run index for sorting.');\n      return;\n    }\n    let r = runs[runIndex];\n    if (r.sorted) {\n      log(`Run #${runIndex} is already sorted.`);\n      return;\n    }\n\n    log(`Sorting run #${runIndex} (start: ${r.start}, length: ${r.length}) using ${runSortMethod} method.`);\n\n    // If run is descending, reverse first (simulate timsort behavior)\n    if (r.descending) {\n      // Reverse array slice\n      for (let i = 0; i < Math.floor(r.length / 2); i++) {\n        let leftIdx = r.start + i;\n        let rightIdx = r.start + r.length - 1 - i;\n        let tmp = array[leftIdx];\n        array[leftIdx] = array[rightIdx];\n        array[rightIdx] = tmp;\n      }\n      r.descending = false;\n      log(`Run #${runIndex} was descending and reversed.`);\n    }\n\n    // Choose method\n    if (runSortMethod === 'insertion') {\n      insertionSort(array, r.start, r.length, sortedOrder);\n    } else if (runSortMethod === 'binary') {\n      binaryInsertionSort(array, r.start, r.length, sortedOrder);\n    } else {\n      // builtin\n      let slice = array.slice(r.start, r.start + r.length);\n      slice.sort((a,b) => {\n        if (sortedOrder === 'asc') return a - b;\n        else return b - a;\n      });\n      for(let i = 0; i < r.length; i++) {\n        array[r.start+i] = slice[i];\n      }\n    }\n    r.sorted = true;\n    log(`Run #${runIndex} sorted.`);\n    updateDisplays();\n  }\n\n  // Full automatic timsort simulation: 1) detect runs, 2) push runs, 3) sort if needed, 4) merge to one run\n  // We allow a blocking loop with manual yield by intervals to remain responsive\n  async function fullTimSortAuto() {\n    if (array.length === 0) {\n      log('No array to sort.');\n      return;\n    }\n    log('Starting full automatic TimSort simulation...');\n\n    // Step 1: detect runs if natural runs enabled, else create runs of minRunLength\n    if (naturalRunsEnabled) {\n      log('Detecting natural runs...');\n      runs = detectNaturalRuns(array, sortedOrder === 'asc');\n    } else {\n      // Create fixed length runs of minRunLength\n      runs = [];\n      let n = array.length;\n      let idx = 0;\n      while (idx < n) {\n        let runLen = Math.min(minRunLength, n - idx);\n        runs.push({start: idx, length: runLen, sorted: false, descending: false});\n        idx += runLen;\n      }\n    }\n    minRunLengthDisplay.textContent = minRunLength.toString();\n    runsDetectedCount.textContent = runs.length.toString();\n    runStack = [];\n    pushIndex = 0;\n    updateDisplays();\n\n    // Step 2: push runs and sort if needed\n    while(pushIndex < runs.length) {\n      pushNextRun();\n      let runIdx = runStack[runStack.length - 1];\n      if (!runs[runIdx].sorted) {\n        sortRun(runIdx);\n        await pause(100);\n      }\n      // Check collapse rules: simplified merge runs at top if length criteria met (simulate)\n      await collapseRunsAuto();\n      await pause(100);\n    }\n\n    // Step 3: final merges until one run remains\n    while (runStack.length > 1) {\n      mergeTopRuns();\n      await pause(200);\n    }\n    log('Full TimSort automatic simulation complete.');\n    updateDisplays();\n  }\n\n  // Automated collapsing of runs based on basic TimSort merging invariant:\n  // Merge when run length conditions are met according to TimSort rules:\n  // For simplicity, we implement the merging invariants from Tim Peters' algorithm:\n  // Let stack runs length from bottom: A, B, C (C top)\n  // While (|A| > |B| + |C| == false OR |B| > |C|)\n  // Merge runs accordingly\n  async function collapseRunsAuto() {\n    while (true) {\n      let n = runStack.length;\n      if (n < 2) return;\n      let X = n >= 3 ? runs[runStack[n-3]].length : Infinity;\n      let Y = runs[runStack[n-2]].length;\n      let Z = runs[runStack[n-1]].length;\n\n      if (n >= 3 && X <= Y + Z) {\n        if (X < Z) {\n          mergeAt(n - 3);\n        } else {\n          mergeAt(n - 2);\n        }\n        await pause(100);\n      } else if (Y <= Z) {\n        mergeAt(n - 2);\n        await pause(100);\n      } else break;\n    }\n  }\n\n  // Merge runs at position i and i+1 on runStack\n  function mergeAt(iOnStack) {\n    if (iOnStack < 0 || iOnStack + 1 >= runStack.length) {\n      log('mergeAt: invalid indices on runStack.');\n      return;\n    }\n    let a = runStack[iOnStack];\n    let b = runStack[iOnStack + 1];\n    let runA = runs[a];\n    let runB = runs[b];\n\n    if (runA.start + runA.length !== runB.start) {\n      log(`mergeAt: runs #${a} and #${b} are not adjacent, cannot merge.`);\n      return;\n    }\n    log(`mergeAt: Merging runs #${a} and #${b}.`);\n    const mergedArray = mergeArrays(\n      array.slice(runA.start, runA.start + runA.length),\n      array.slice(runB.start, runB.start + runB.length),\n      sortedOrder\n    );\n\n    array.splice(runA.start, runA.length + runB.length, ...mergedArray);\n\n    runs[a] = {start: runA.start, length: mergedArray.length, sorted: true};\n    runs.splice(b, 1);\n\n    runStack.splice(iOnStack + 1, 1);\n\n    // Update indices in the runStack above removed index\n    for (let k = iOnStack + 1; k < runStack.length; k++) {\n      if (runStack[k] > b) runStack[k]--;\n    }\n\n    // Adjust pushIndex\n    if (pushIndex > b) pushIndex--;\n\n    updateDisplays();\n  }\n\n  function pause(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Parsing input array from textarea\n  function parseInputArray() {\n    const text = arrayInputText.value.trim();\n    if (!text) {\n      log('Input array is empty.');\n      return false;\n    }\n    // Split by comma or whitespace\n    let parts = text.split(/[\\s,]+/);\n    let nums = [];\n    for (let p of parts) {\n      let n = Number(p);\n      if (Number.isNaN(n)) {\n        log(`Invalid number detected: \"${p}\"`);\n        return false;\n      }\n      nums.push(n);\n    }\n    if (nums.length === 0) {\n      log('No valid numbers found in input.');\n      return false;\n    }\n    array = nums;\n    log(`Parsed array with ${array.length} elements.`);\n    updateDisplays();\n    return true;\n  }\n\n  // Reset all state\n  function resetAll() {\n    array = [];\n    minRunLength = 0;\n    runs = [];\n    runStack = [];\n    pushIndex = 0;\n    sortedOrder = 'asc';\n    naturalRunsEnabled = false;\n    runSortMethod = 'insertion';\n    arrayInputText.value = '';\n    runLengthInput.value = '';\n    useNaturalRunsCheckbox.checked = false;\n    runSortMethodSelect.value = 'insertion';\n    sortOrderSelect.value = 'asc';\n    minRunLengthDisplay.textContent = 'N/A';\n    runsDetectedCount.textContent = '0';\n    runStackDisplay.textContent = '[]';\n    arrayContainer.textContent = '[Empty Array]';\n    logDiv.textContent = '';\n    log('Reset all states and inputs.');\n    // Disable all except initial controls\n    disableButtonsOnReset();\n  }\n\n  function disableButtonsOnReset() {\n    autoMinRunBtn.disabled = true;\n    detectRunsBtn.disabled = true;\n    pushNextRunBtn.disabled = true;\n    tryCollapseBtn.disabled = true;\n    mergeTopRunsBtn.disabled = true;\n    runSortBtn.disabled = true;\n    fullSortBtn.disabled = true;\n  }\n\n  // Enable buttons after parse\n  function enableButtonsAfterParse() {\n    autoMinRunBtn.disabled = false;\n    detectRunsBtn.disabled = false;\n    pushNextRunBtn.disabled = false;\n    tryCollapseBtn.disabled = false;\n    mergeTopRunsBtn.disabled = false;\n    runSortBtn.disabled = false;\n    fullSortBtn.disabled = false;\n  }\n\n  // Button event handlers\n\n  parseArrayBtn.addEventListener('click', () => {\n    if (parseInputArray()) {\n      sortedOrder = sortOrderSelect.value;\n      naturalRunsEnabled = useNaturalRunsCheckbox.checked;\n      runSortMethod = runSortMethodSelect.value;\n\n      // Auto-calc min run length when user did not set manually\n      if (runLengthInput.value && Number(runLengthInput.value) > 0) {\n        minRunLength = Number(runLengthInput.value);\n        log(`Using user-set min run length: ${minRunLength}`);\n      } else {\n        minRunLength = calcMinRunLength(array.length);\n        log(`Auto-calculated min run length: ${minRunLength}`);\n      }\n\n      // Reset runs, stack indices\n      runs = [];\n      runStack = [];\n      pushIndex = 0;\n      updateDisplays();\n\n      enableButtonsAfterParse();\n    }\n  });\n\n  autoMinRunBtn.addEventListener('click', () => {\n    minRunLength = calcMinRunLength(array.length);\n    runLengthInput.value = minRunLength.toString();\n    minRunLengthDisplay.textContent = minRunLength.toString();\n    log(`Auto-calculated min run length: ${minRunLength}`);\n  });\n\n  detectRunsBtn.addEventListener('click', () => {\n    if (array.length === 0) {\n      log('Array empty. Parse array first.');\n      return;\n    }\n    if (naturalRunsEnabled) {\n      runs = detectNaturalRuns(array, sortedOrder === 'asc');\n      log(`Detected ${runs.length} natural run(s).`);\n    } else {\n      // Create fixed-length runs based on minRunLength (except last run)\n      runs = [];\n      let n = array.length;\n      let idx = 0;\n      while (idx < n) {\n        let len = Math.min(minRunLength, n - idx);\n        runs.push({start: idx, length: len, sorted: false, descending:false});\n        idx += len;\n      }\n      log(`Created fixed runs (length ${minRunLength}), total runs: ${runs.length}.`);\n    }\n    runStack = [];\n    pushIndex = 0;\n    updateDisplays();\n  });\n\n  pushNextRunBtn.addEventListener('click', () => {\n    if (runs.length === 0) {\n      log('No runs available. Detect runs first.');\n      return;\n    }\n    if (pushIndex >= runs.length) {\n      log('All runs have been pushed onto the stack.');\n      return;\n    }\n    pushNextRun();\n    // Enable runSortBtn only if top run unsorted\n    const runIdx = runStack[runStack.length - 1];\n    runSortBtn.disabled = runs[runIdx].sorted;\n  });\n\n  tryCollapseBtn.addEventListener('click', async () => {\n    log('Attempting automated collapse according to TimSort run merging rules...');\n    await collapseRunsAuto();\n    updateDisplays();\n  });\n\n  mergeTopRunsBtn.addEventListener('click', () => {\n    if (!mergeTopRuns()) {\n      log('Manual merge unable to proceed.');\n    }\n  });\n\n  runSortBtn.addEventListener('click', () => {\n    if (runStack.length === 0) {\n      log('No runs on stack to sort.');\n      return;\n    }\n    const runIdx = runStack[runStack.length - 1];\n    sortRun(runIdx);\n    runSortBtn.disabled = true;\n  });\n\n  fullSortBtn.addEventListener('click', async () => {\n    await fullTimSortAuto();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    resetAll();\n  });\n\n  runSortMethodSelect.addEventListener('change', () => {\n    runSortMethod = runSortMethodSelect.value;\n    log(`Run sort method changed to \"${runSortMethod}\".`);\n  });\n\n  useNaturalRunsCheckbox.addEventListener('change', () => {\n    naturalRunsEnabled = useNaturalRunsCheckbox.checked;\n    log(`Natural runs detection ${naturalRunsEnabled ? 'enabled' : 'disabled'}.`);\n  });\n\n  sortOrderSelect.addEventListener('change', () => {\n    sortedOrder = sortOrderSelect.value;\n    log(`Sort order changed to \"${sortedOrder}\".`);\n  });\n\n  setMinRunBtn.addEventListener('click', () => {\n    let val = Number(runLengthInput.value);\n    if (Number.isInteger(val) && val > 0) {\n      minRunLength = val;\n      minRunLengthDisplay.textContent = minRunLength.toString();\n      log(`Min run length manually set to ${minRunLength}.`);\n    } else {\n      log('Invalid min run length input.');\n    }\n  });\n\n  // Initialize page state\n  resetAll();\n\n})();\n</script>\n</body>\n</html>"
