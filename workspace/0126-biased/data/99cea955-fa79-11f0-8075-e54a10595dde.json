    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Quick Sort</title>\n    <style>\n        body { font-family: monospace; margin: 20px; }\n        #arrayDisplay { margin-bottom: 10px; }\n    </style>\n</head>\n<body>\n    <h1>Interactive Quick Sort</h1>\n    <label for=\"arrayInput\">Enter comma-separated integers:</label>\n    <input type=\"text\" id=\"arrayInput\" value=\"3,6,8,10,1,2,1\">\n    <button id=\"sortButton\">Sort</button>\n    <button id=\"resetButton\">Reset</button>\n    \n    <h3>Manual Controls</h3>\n    <label for=\"lowIndex\">Low Index:</label>\n    <input type=\"number\" id=\"lowIndex\" value=\"0\">\n    <label for=\"highIndex\">High Index:</label>\n    <input type=\"number\" id=\"highIndex\" value=\"0\">\n    <button id=\"stepButton\">Step</button>\n    \n    <div id=\"arrayDisplay\"></div>\n    <div id=\"statusDisplay\"></div>\n\n    <script>\n        let array = [];\n        let lowIndex = 0;\n        let highIndex = 0;\n        let steps = [];\n        let currentStep = 0;\n\n        document.getElementById('sortButton').onclick = function() {\n            const input = document.getElementById('arrayInput').value;\n            array = input.split(\",\").map(Number);\n            highIndex = array.length - 1;\n            steps = [];\n            currentStep = 0;\n\n            quickSort(array, 0, highIndex);\n            displayArray();\n        };\n\n        document.getElementById('stepButton').onclick = function() {\n            if (currentStep < steps.length) {\n                lowIndex = steps[currentStep][0];\n                highIndex = steps[currentStep][1];\n                partition(array, lowIndex, highIndex);\n            } else {\n                document.getElementById('statusDisplay').innerText = \"Sort Complete!\";\n            }\n        };\n\n        document.getElementById('resetButton').onclick = function() {\n            array = [];\n            lowIndex = 0;\n            highIndex = 0;\n            steps = [];\n            currentStep = 0;\n            displayArray();\n            document.getElementById('statusDisplay').innerText = '';\n        };\n\n        function quickSort(arr, low, high) {\n            if (low < high) {\n                const pi = partition(arr, low, high);\n                quickSort(arr, low, pi - 1);\n                quickSort(arr, pi + 1, high);\n                steps.push([low, high]);\n            }\n        }\n\n        function partition(arr, low, high) {\n            let pivot = arr[high];\n            let i = (low - 1);\n\n            for (let j = low; j <= high - 1; j++) {\n                if (arr[j] < pivot) {\n                    i++;\n                    [arr[i], arr[j]] = [arr[j], arr[i]];\n                }\n            }\n            [arr[i + 1], arr[high]] = [arr[high], arr[i + 1]];\n            displayArray();\n            return i + 1;\n        }\n\n        function displayArray() {\n            document.getElementById('arrayDisplay').innerText = \"Array: \" + array.join(\", \");\n        }\n    </script>\n</body>\n</html>"
