    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visualizing Hash Functions</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-20px); }\n        }\n\n        @keyframes pulse {\n            0%, 100% { opacity: 1; }\n            50% { opacity: 0.6; }\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 5rem;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: -0.05em;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.1);\n            padding: 3rem;\n            margin-bottom: 4rem;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .visualization::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n        }\n\n        .input-output {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 3rem;\n        }\n\n        .input-box, .output-box {\n            width: 48%;\n            position: relative;\n        }\n\n        .box-label {\n            font-size: 0.9rem;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-weight: 600;\n            display: block;\n        }\n\n        .text-input {\n            width: 100%;\n            padding: 1.5rem;\n            border: 2px solid #e0e0e0;\n            border-radius: 12px;\n            font-size: 1.1rem;\n            transition: all 0.3s ease;\n            outline: none;\n            resize: none;\n            min-height: 150px;\n        }\n\n        .text-input:focus {\n            border-color: var(--primary);\n            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.2);\n        }\n\n        .hash-display {\n            width: 100%;\n            padding: 1.5rem;\n            background: var(--light);\n            border-radius: 12px;\n            font-family: 'Courier New', monospace;\n            font-size: 1rem;\n            min-height: 150px;\n            word-break: break-all;\n            color: var(--dark);\n            border: 2px solid transparent;\n        }\n\n        .hash-display.highlight {\n            animation: pulse 1.5s infinite;\n            border-color: var(--success);\n        }\n\n        .hash-button {\n            display: block;\n            margin: 0 auto 3rem;\n            padding: 1rem 2rem;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n            color: white;\n            border: none;\n            border-radius: 50px;\n            font-size: 1.1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 10px 20px -10px var(--primary);\n        }\n\n        .hash-button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 15px 25px -10px var(--primary);\n        }\n\n        .hash-button:active {\n            transform: translateY(0);\n        }\n\n        .hash-visual {\n            display: flex;\n            justify-content: center;\n            margin: 3rem 0;\n        }\n\n        .hash-bits {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 8px;\n            max-width: 800px;\n        }\n\n        .bit {\n            width: 30px;\n            height: 30px;\n            border-radius: 6px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 0.7rem;\n            font-weight: 600;\n            transition: all 0.5s ease;\n            background: var(--secondary);\n            color: white;\n        }\n\n        .bit.on {\n            background: var(--primary);\n            transform: scale(1.1);\n        }\n\n        .info-section {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            margin-top: 4rem;\n        }\n\n        .info-card {\n            background: white;\n            border-radius: 16px;\n            padding: 2rem;\n            box-shadow: 0 15px 30px -10px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n        }\n\n        .info-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);\n        }\n\n        .info-card h3 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.3rem;\n        }\n\n        .info-card p {\n            color: var(--dark);\n            opacity: 0.8;\n            line-height: 1.6;\n        }\n\n        .floating-shapes {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .shape {\n            position: absolute;\n            border-radius: 50%;\n            opacity: 0.1;\n            animation: float 6s ease-in-out infinite;\n        }\n\n        .shape-1 {\n            width: 300px;\n            height: 300px;\n            background: var(--primary);\n            top: -100px;\n            right: -100px;\n            animation-delay: 0s;\n        }\n\n        .shape-2 {\n            width: 200px;\n            height: 200px;\n            background: var(--accent);\n            bottom: -50px;\n            left: -50px;\n            animation-delay: 1s;\n        }\n\n        .shape-3 {\n            width: 150px;\n            height: 150px;\n            background: var(--success);\n            top: 40%;\n            left: 20%;\n            animation-delay: 2s;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n\n        @media (max-width: 768px) {\n            .input-output {\n                flex-direction: column;\n            }\n\n            .input-box, .output-box {\n                width: 100%;\n                margin-bottom: 2rem;\n            }\n\n            h1 {\n                font-size: 2.5rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"floating-shapes\">\n        <div class=\"shape shape-1\"></div>\n        <div class=\"shape shape-2\"></div>\n        <div class=\"shape shape-3\"></div>\n    </div>\n\n    <div class=\"container\">\n        <header>\n            <h1>Hash Functions</h1>\n            <p class=\"subtitle\">A cryptographic hash function is a mathematical algorithm that maps data of arbitrary size to a bit array of a fixed size. It's a one-way function, meaning it's practically infeasible to invert or reverse the computation.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"input-output\">\n                <div class=\"input-box\">\n                    <span class=\"box-label\">Input (Any Data)</span>\n                    <textarea id=\"inputText\" class=\"text-input\" placeholder=\"Enter any text here to see it hashed...\"></textarea>\n                </div>\n                <div class=\"output-box\">\n                    <span class=\"box-label\">Output (SHA-256 Hash)</span>\n                    <div id=\"outputHash\" class=\"hash-display\">Hash will appear here...</div>\n                </div>\n            </div>\n\n            <button id=\"hashButton\" class=\"hash-button\">Generate Hash</button>\n\n            <div class=\"hash-visual\">\n                <div id=\"hashBits\" class=\"hash-bits\"></div>\n            </div>\n        </div>\n\n        <div class=\"info-section\">\n            <div class=\"info-card\">\n                <h3>Deterministic</h3>\n                <p>The same input will always produce the same output hash. Change even one bit of the input, and the output hash changes completely.</p>\n            </div>\n            <div class=\"info-card\">\n                <h3>Fixed Size</h3>\n                <p>No matter the size of the input data, the output hash will always be the same length. SHA-256 always produces a 256-bit (32-byte) hash.</p>\n            </div>\n            <div class=\"info-card\">\n                <h3>One-Way Function</h3>\n                <p>It's computationally infeasible to reconstruct the input data from its hash output. This property is crucial for security applications.</p>\n            </div>\n        </div>\n    </div>\n\n    <footer>\n        <p>A visual demonstration of cryptographic hash functions</p>\n    </footer>\n\n    <script>\n        // Simple SHA-256 implementation (for demonstration purposes)\n        async function sha256(message) {\n            // Encode the message as UTF-8\n            const msgBuffer = new TextEncoder().encode(message);\n            \n            // Hash the message\n            const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);\n            \n            // Convert to hexadecimal string\n            const hashArray = Array.from(new Uint8Array(hashBuffer));\n            const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');\n            \n            return hashHex;\n        }\n\n        function createBitVisualization(hash) {\n            const bitsContainer = document.getElementById('hashBits');\n            bitsContainer.innerHTML = '';\n            \n            // Convert hex to binary\n            let binaryString = '';\n            for (let i = 0; i < hash.length; i++) {\n                const hexByte = parseInt(hash[i], 16);\n                binaryString += hexByte.toString(2).padStart(4, '0');\n            }\n            \n            // Create bit elements\n            for (let i = 0; i < binaryString.length; i++) {\n                const bit = document.createElement('div');\n                bit.className = 'bit';\n                bit.textContent = binaryString[i];\n                \n                if (binaryString[i] === '1') {\n                    setTimeout(() => {\n                        bit.classList.add('on');\n                    }, i * 10);\n                }\n                \n                bitsContainer.appendChild(bit);\n            }\n        }\n\n        document.getElementById('hashButton').addEventListener('click', async function() {\n            const input = document.getElementById('inputText').value;\n            const outputElement = document.getElementById('outputHash');\n            \n            if (input.trim() === '') {\n                outputElement.textContent = 'Please enter some text to hash';\n                return;\n            }\n            \n            outputElement.classList.add('highlight');\n            outputElement.textContent = 'Calculating...';\n            \n            try {\n                const hash = await sha256(input);\n                outputElement.textContent = hash;\n                createBitVisualization(hash);\n                \n                setTimeout(() => {\n                    outputElement.classList.remove('highlight');\n                }, 1500);\n            } catch (error) {\n                outputElement.textContent = 'Error generating hash';\n                console.error(error);\n            }\n        });\n\n        // Initialize with a sample hash\n        window.addEventListener('DOMContentLoaded', () => {\n            sha256('Hash Functions').then(hash => {\n                document.getElementById('outputHash').textContent = hash;\n                createBitVisualization(hash);\n            });\n        });\n    </script>\n</body>\n</html>"
