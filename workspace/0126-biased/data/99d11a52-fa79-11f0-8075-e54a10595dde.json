    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Decision Tree</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .question { margin: 10px 0; }\n        .result { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive Decision Tree</h1>\n\n<div id=\"decision-tree\">\n    <div class=\"question\" id=\"question\">Is it a fruit or vegetable?</div>\n    <button onclick=\"nextStep('fruit')\">Fruit</button>\n    <button onclick=\"nextStep('vegetable')\">Vegetable</button>\n</div>\n\n<div class=\"result\" id=\"result\"></div>\n\n<script>\n    const tree = {\n        question: \"Is it a fruit or vegetable?\",\n        fruit: {\n            question: \"Is it citrus?\",\n            yes: {\n                question: \"Is it small?\",\n                yes: \"You selected Orange\",\n                no: \"You selected Watermelon\"\n            },\n            no: {\n                question: \"Is it a berry?\",\n                yes: \"You selected Strawberry\",\n                no: \"You selected Mango\"\n            }\n        },\n        vegetable: {\n            question: \"Is it green?\",\n            yes: {\n                question: \"Is it leafy?\",\n                yes: \"You selected Spinach\",\n                no: \"You selected Broccoli\"\n            },\n            no: {\n                question: \"Is it root?\",\n                yes: \"You selected Carrot\",\n                no: \"You selected Cucumber\"\n            }\n        }\n    };\n\n    let currentNode = tree;\n\n    function nextStep(selection) {\n        if (typeof currentNode[selection] === 'object') {\n            currentNode = currentNode[selection];\n            updateQuestion();\n        } else {\n            displayResult(currentNode[selection]);\n            reset();\n        }\n    }\n\n    function updateQuestion() {\n        document.getElementById('question').innerText = currentNode.question;\n    }\n\n    function displayResult(result) {\n        document.getElementById('result').innerText = result;\n    }\n\n    function reset() {\n        currentNode = tree;\n        setTimeout(() => {\n            document.getElementById('question').innerText = currentNode.question;\n            document.getElementById('result').innerText = '';\n        }, 2000);\n    }\n</script>\n\n</body>\n</html>"
