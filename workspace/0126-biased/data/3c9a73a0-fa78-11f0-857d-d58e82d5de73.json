    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Routing – A Visual Journey</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Root & base */\n  :root {\n    --primary: #2a9d8f;\n    --secondary: #264653;\n    --accent: #e76f51;\n    --background: #f0f4f8;\n    --shadow-light: rgba(255, 255, 255, 0.7);\n    --shadow-dark: rgba(0, 0, 0, 0.15);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Poppins', sans-serif;\n    background: var(--background);\n    color: var(--secondary);\n    overflow-x: hidden;\n  }\n\n  /* Container */\n  .container {\n    max-width: 900px;\n    margin: 3rem auto 4rem;\n    padding: 0 1.5rem;\n    user-select: none;\n  }\n\n  /* Title */\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    text-align: center;\n    color: var(--secondary);\n    margin-bottom: 0.2em;\n    letter-spacing: 0.08em;\n    position: relative;\n    text-transform: uppercase;\n  }\n  h1::after {\n    content: 'Conceptual Routing';\n    position: absolute;\n    left: 50%;\n    top: 120%;\n    transform: translateX(-50%);\n    font-weight: 300;\n    font-size: 1.15rem;\n    letter-spacing: 0.12em;\n    color: var(--primary);\n    opacity: 0.7;\n  }\n\n  /* Subtitle */\n  p.subtitle {\n    text-align: center;\n    margin-top: 0.4em;\n    font-weight: 300;\n    font-size: 1.15rem;\n    letter-spacing: 0.06em;\n    color: var(--accent);\n    filter: drop-shadow(0 0 3px var(--accent));\n  }\n\n  /* Visual routing container */\n  .routing-visual {\n    margin-top: 4rem;\n    position: relative;\n    background: white;\n    border-radius: 1.5rem;\n    box-shadow:\n      10px 10px 30px var(--shadow-dark),\n      inset 0 0 15px var(--shadow-light);\n    padding: 2rem 2.5rem;\n    overflow: visible;\n  }\n\n  /* Nodes container */\n  .nodes {\n    display: flex;\n    justify-content: space-between;\n    position: relative;\n    z-index: 10;\n  }\n\n  /* Node basics */\n  .node {\n    background: #eaf4f3;\n    border-radius: 2.2rem;\n    width: 5.5rem;\n    height: 5.5rem;\n    box-shadow:\n      inset 5px 5px 12px #c1d6d4,\n      7px 7px 15px #a7c0bd;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--secondary);\n    font-weight: 600;\n    font-size: 1.85rem;\n    letter-spacing: 0.1em;\n    user-select: none;\n    position: relative;\n    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);\n  }\n  .node[data-active=\"true\"] {\n    background: var(--primary);\n    color: white;\n    box-shadow:\n      0 0 16px var(--primary),\n      inset 0 0 20px #46bdb3;\n    transform: scale(1.15);\n    z-index: 20;\n  }\n  .node.subtitle {\n    font-weight: 300;\n    font-size: 0.9rem;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    color: var(--accent);\n    user-select: none;\n    margin-top: 0.5rem;\n  }\n\n  /* Connecting paths */\n  .connection {\n    position: absolute;\n    top: 2.75rem;\n    height: 6px;\n    background: linear-gradient(90deg, var(--primary), var(--accent));\n    border-radius: 3px;\n    filter: drop-shadow(0 1px 1px rgba(0,0,0,0.08));\n    transition: background 0.8s ease;\n    will-change: background;\n    z-index: 5;\n  }\n  .connection.active {\n    background: linear-gradient(90deg, #f4a261, #e76f51);\n    box-shadow:\n      0 0 15px #e76f51cc;\n  }\n  .connection.inactive {\n    background: linear-gradient(90deg, #a8c5c2, #9ab2ad);\n  }\n\n  /* Curved SVG routes for style */\n  svg.routes {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 9rem;\n    overflow: visible;\n    pointer-events: none;\n    filter: drop-shadow(0 3px 5px rgba(0,0,0,0.1));\n    z-index: 1;\n  }\n\n  /* Route paths */\n  path.route-path {\n    fill: none;\n    stroke: url(#grad);\n    stroke-width: 6;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 6px var(--primary));\n    transition: stroke 1s ease;\n  }\n  path.route-highlight {\n    stroke: url(#grad-accent);\n    stroke-width: 8;\n    filter: drop-shadow(0 0 20px #e76f5188);\n  }\n\n  /* Buttons */\n  .controls {\n    margin-top: 3rem;\n    text-align: center;\n  }\n\n  button {\n    background: var(--primary);\n    color: white;\n    border: none;\n    outline: none;\n    padding: 0.65rem 1.8rem;\n    margin: 0 0.6rem;\n    border-radius: 1.2rem;\n    font-weight: 600;\n    font-size: 1rem;\n    cursor: pointer;\n    box-shadow:\n      0 3px 10px #2a9d8faa,\n      inset 0 -3px 8px #207467;\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.2s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: var(--accent);\n    box-shadow:\n      0 7px 18px #e76f5188,\n      inset 0 -4px 12px #bb4c34;\n    transform: scale(1.07);\n  }\n  button:active {\n    transform: scale(0.96);\n  }\n\n  /* Footer small print */\n  footer {\n    text-align: center;\n    font-size: 0.85rem;\n    color: var(--secondary);\n    letter-spacing: 0.07em;\n    opacity: 0.5;\n    margin-top: 5rem;\n    font-weight: 300;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width: 600px) {\n    h1 {\n      font-size: 2.8rem;\n    }\n    .node {\n      width: 4.5rem;\n      height: 4.5rem;\n      font-size: 1.4rem;\n    }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Routing</h1>\n  <p class=\"subtitle\">Visualizing the Elegant Flow of Paths and Decisions</p>\n\n  <div class=\"routing-visual\" aria-label=\"Routing concept visualization\" role=\"img\">\n    <!-- Nodes and connections container -->\n    <div class=\"nodes\" aria-hidden=\"true\">\n      <!-- Nodes: Representing route segments -->\n      <div class=\"node\" data-id=\"0\" data-active=\"true\" aria-label=\"Home route node\">Home</div>\n      <div class=\"node\" data-id=\"1\" data-active=\"false\" aria-label=\"About route node\">About</div>\n      <div class=\"node\" data-id=\"2\" data-active=\"false\" aria-label=\"Services route node\">Srvcs</div>\n      <div class=\"node\" data-id=\"3\" data-active=\"false\" aria-label=\"Portfolio route node\">Port</div>\n      <div class=\"node\" data-id=\"4\" data-active=\"false\" aria-label=\"Contact route node\">Cont</div>\n    </div>\n    <!-- Connections between nodes -->\n    <div class=\"connection connection-0 active\" style=\"left:70px; width:140px;\"></div>\n    <div class=\"connection connection-1 inactive\" style=\"left:240px; width:140px;\"></div>\n    <div class=\"connection connection-2 inactive\" style=\"left:410px; width:140px;\"></div>\n    <div class=\"connection connection-3 inactive\" style=\"left:580px; width:140px;\"></div>\n\n    <!-- SVG Curved routing lines behind nodes -->\n    <svg class=\"routes\" aria-hidden=\"true\" viewBox=\"0 0 700 90\" preserveAspectRatio=\"none\" >\n      <defs>\n        <linearGradient id=\"grad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n          <stop offset=\"0%\" style=\"stop-color:#2a9d8f;stop-opacity:1\" />\n          <stop offset=\"100%\" style=\"stop-color:#e76f51;stop-opacity:1\" />\n        </linearGradient>\n        <linearGradient id=\"grad-accent\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n          <stop offset=\"0%\" style=\"stop-color:#f4a261;stop-opacity:1\" />\n          <stop offset=\"100%\" style=\"stop-color:#e76f51;stop-opacity:1\" />\n        </linearGradient>\n      </defs>\n      <path id=\"route-0\" class=\"route-path route-highlight\" d=\"M45 70 C130 5, 190 5, 275 70\" />\n      <path id=\"route-1\" class=\"route-path\" d=\"M215 70 C300 5, 360 5, 445 70\" />\n      <path id=\"route-2\" class=\"route-path\" d=\"M385 70 C470 5, 530 5, 615 70\" />\n      <path id=\"route-3\" class=\"route-path\" d=\"M555 70 C640 5, 700 5, 785 70\" />\n    </svg>\n  </div>\n\n  <div class=\"controls\" role=\"region\" aria-label=\"Routing navigation controls\">\n    <button id=\"prevBtn\" aria-label=\"Active route previous\">Previous</button>\n    <button id=\"nextBtn\" aria-label=\"Active route next\">Next</button>\n  </div>\n</div>\n<footer>\n  &copy; 2024 &nbsp;|&nbsp; <em>Routing Concept &mdash; Aesthetic Visualization</em>\n</footer>\n\n<script>\n  (() => {\n    const nodes = [...document.querySelectorAll('.node')];\n    const connections = [...document.querySelectorAll('.connection')];\n    const routes = [...document.querySelectorAll('path.route-path')];\n    let activeIndex = 0;\n\n    const setActive = (idx) => {\n      // Clamp the index\n      if (idx < 0) idx = nodes.length - 1;\n      else if (idx >= nodes.length) idx = 0;\n      activeIndex = idx;\n\n      // Update nodes\n      nodes.forEach((node, i) => {\n        node.dataset.active = (i === activeIndex).toString();\n        node.setAttribute('aria-current', i === activeIndex ? 'page' : 'false');\n      });\n\n      // Update connections\n      connections.forEach((conn, i) => {\n        if (i === activeIndex - 1) {\n          conn.classList.add('active');\n          conn.classList.remove('inactive');\n        } else {\n          conn.classList.add('inactive');\n          conn.classList.remove('active');\n        }\n      });\n\n      // Update SVG routes highlight\n      routes.forEach((path, i) => {\n        if (i === activeIndex - 1) {\n          path.classList.add('route-highlight');\n        } else {\n          path.classList.remove('route-highlight');\n        }\n      });\n    };\n\n    // Buttons\n    document.getElementById('prevBtn').addEventListener('click', () => {\n      setActive(activeIndex - 1);\n    });\n    document.getElementById('nextBtn').addEventListener('click', () => {\n      setActive(activeIndex + 1);\n    });\n\n    // Initialize states\n    setActive(0);\n  })();\n</script>\n</body>\n</html>"
