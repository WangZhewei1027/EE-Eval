    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Topological Sort Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .hidden { display: none; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Topological Sort Interactive Demo</h1>\n    <p>Define your directed graph below:</p>\n    <textarea id=\"graph-input\" rows=\"10\" cols=\"30\" placeholder=\"Enter edges as 'A B' for A -> B, one per line\"></textarea><br>\n    <button id=\"submit-graph\">Set Graph</button>\n    <button id=\"perform-sort\" class=\"hidden\">Perform Topological Sort</button>\n    <div id=\"output\"></div>\n\n    <script>\n        let graph = {};\n        const outputDiv = document.getElementById('output');\n\n        document.getElementById('submit-graph').addEventListener('click', function() {\n            const input = document.getElementById('graph-input').value.trim();\n            const edges = input.split('\\n');\n            graph = {};\n            edges.forEach(edge => {\n                const [from, to] = edge.split(' ');\n                if (!graph[from]) graph[from] = [];\n                graph[from].push(to);\n                if (!graph[to]) graph[to] = []; // ensures all nodes are initialized\n            });\n            document.getElementById('perform-sort').classList.remove('hidden');\n            outputDiv.innerHTML = 'Graph set. Ready to perform topological sort.';\n        });\n\n        document.getElementById('perform-sort').addEventListener('click', function() {\n            const sorted = topologicalSort(graph);\n            outputDiv.innerHTML = sorted.length ? 'Topological Sort Order: ' + sorted.join(', ') : 'Graph has cycles or is invalid.';\n        });\n\n        function topologicalSort(graph) {\n            const inDegree = {};\n            Object.keys(graph).forEach(node => {\n                inDegree[node] = 0;\n            });\n            Object.keys(graph).forEach(node => {\n                graph[node].forEach(neighbor => {\n                    inDegree[neighbor]++;\n                });\n            });\n\n            const queue = Object.keys(inDegree).filter(node => inDegree[node] === 0);\n            const sortedOrder = [];\n  \n            while (queue.length) {\n                const currentNode = queue.shift();\n                sortedOrder.push(currentNode);\n\n                graph[currentNode].forEach(neighbor => {\n                    inDegree[neighbor]--;\n                    if (inDegree[neighbor] === 0) {\n                        queue.push(neighbor);\n                    }\n                });\n            }\n\n            return sortedOrder.length === Object.keys(graph).length ? sortedOrder : [];\n        }\n    </script>\n</body>\n</html>"
