    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Counting Sort Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #output {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Counting Sort Interactive Demo</h1>\n    <label for=\"arrayInput\">Enter numbers (comma-separated):</label><br>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g., 4, 2, 2, 8, 3, 3, 1\"><br>\n    \n    <label for=\"maxValue\">Enter maximum value:</label><br>\n    <input type=\"number\" id=\"maxValue\" placeholder=\"Enter maximum value of numbers\"><br>\n    \n    <button id=\"sortButton\">Sort</button>\n    <button id=\"resetButton\">Reset</button>\n    \n    <div id=\"output\"></div>\n    \n    <script>\n        document.getElementById('sortButton').addEventListener('click', function() {\n            const userInput = document.getElementById('arrayInput').value;\n            const maxInput = parseInt(document.getElementById('maxValue').value);\n            const array = userInput.split(',').map(Number);\n            \n            if(!validateInput(array, maxInput)) {\n                alert(\"Please enter valid numbers.\");\n                return;\n            }\n            \n            const sortedArray = countingSort(array, maxInput);\n            document.getElementById('output').innerText = 'Sorted Array: ' + sortedArray.join(', ');\n        });\n\n        document.getElementById('resetButton').addEventListener('click', function() {\n            document.getElementById('arrayInput').value = '';\n            document.getElementById('maxValue').value = '';\n            document.getElementById('output').innerText = '';\n        });\n\n        function countingSort(arr, max) {\n            let count = new Array(max + 1).fill(0);\n            let output = new Array(arr.length);\n            \n            // Count occurrences\n            for (let i = 0; i < arr.length; i++) {\n                count[arr[i]]++;\n            }\n            \n            // Update the count array\n            for (let i = 1; i <= max; i++) {\n                count[i] += count[i - 1];\n            }\n            \n            // Build the output array\n            for (let i = arr.length - 1; i >= 0; i--) {\n                output[count[arr[i]] - 1] = arr[i];\n                count[arr[i]]--;\n            }\n            \n            return output;\n        }\n\n        function validateInput(array, max) {\n            return array.every(num => !isNaN(num) && num >= 0 && num <= max) && max > 0;\n        }\n    </script>\n</body>\n</html>"
