    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Thread Symphony</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap');\n        \n        :root {\n            --primary: #4a2545;\n            --secondary: #d1b3c4;\n            --accent: #b392ac;\n            --light: #f8f4f7;\n            --dark: #1e0e1b;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--light);\n            color: var(--dark);\n            overflow-x: hidden;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n        }\n        \n        .header {\n            padding: 2rem;\n            text-align: center;\n            background: linear-gradient(135deg, var(--primary) 0%, var(--dark) 100%);\n            color: var(--light);\n            position: relative;\n            overflow: hidden;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            margin-bottom: 0.5rem;\n            position: relative;\n            z-index: 2;\n            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);\n        }\n        \n        .subtitle {\n            font-weight: 300;\n            font-size: 1.2rem;\n            opacity: 0.9;\n            position: relative;\n            z-index: 2;\n        }\n        \n        .content {\n            flex: 1;\n            padding: 2rem;\n            max-width: 1200px;\n            margin: 0 auto;\n            width: 100%;\n        }\n        \n        .thread-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            position: relative;\n            height: 600px;\n        }\n        \n        .thread {\n            position: absolute;\n            top: 0;\n            width: 4px;\n            background: linear-gradient(to bottom, var(--accent), var(--secondary));\n            border-radius: 2px;\n            height: 100%;\n            transform-origin: top center;\n            box-shadow: 0 0 20px rgba(179, 146, 172, 0.4);\n            transition: all 0.8s cubic-bezier(0.19, 1, 0.22, 1);\n        }\n        \n        .thread-node {\n            position: absolute;\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            background: radial-gradient(circle, var(--light) 30%, var(--accent) 100%);\n            border: 3px solid var(--primary);\n            z-index: 2;\n            box-shadow: 0 0 15px rgba(179, 146, 172, 0.6);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            color: var(--primary);\n            transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        \n        .thread-node:hover {\n            transform: scale(1.2);\n            box-shadow: 0 0 25px rgba(179, 146, 172, 0.8);\n        }\n        \n        .thread-info {\n            position: absolute;\n            left: 50px;\n            background-color: var(--light);\n            border-radius: 8px;\n            padding: 1.5rem;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n            max-width: 300px;\n            opacity: 0;\n            transform: translateX(-20px);\n            transition: all 0.4s ease;\n            border-left: 4px solid var(--accent);\n        }\n        \n        .thread-node.active + .thread-info {\n            opacity: 1;\n            transform: translateX(0);\n        }\n        \n        .thread-info h3 {\n            font-family: 'Playfair Display', serif;\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            background: linear-gradient(135deg, var(--primary) 0%, var(--dark) 100%);\n            color: var(--light);\n            border: none;\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.1);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(0,0,0,0.15);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .floating-threads {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: 1;\n            overflow: hidden;\n        }\n        \n        .floating-thread {\n            position: absolute;\n            background: linear-gradient(to right, transparent, var(--secondary), transparent);\n            width: 1px;\n            height: 100px;\n            opacity: 0.3;\n            animation: float 15s linear infinite;\n        }\n        \n        @keyframes float {\n            0% {\n                transform: translateY(100vh) rotate(0deg);\n            }\n            100% {\n                transform: translateY(-100px) rotate(360deg);\n            }\n        }\n        \n        footer {\n            text-align: center;\n            padding: 1.5rem;\n            background-color: var(--primary);\n            color: var(--light);\n            font-weight: 300;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Thread Symphony</h1>\n        <p class=\"subtitle\">A visual exploration of interconnected processes</p>\n        <div class=\"floating-threads\">\n            <div class=\"floating-thread\" style=\"left: 10%; animation-delay: 0s;\"></div>\n            <div class=\"floating-thread\" style=\"left: 30%; animation-delay: 2s;\"></div>\n            <div class=\"floating-thread\" style=\"left: 70%; animation-delay: 5s;\"></div>\n            <div class=\"floating-thread\" style=\"left: 90%; animation-delay: 3s;\"></div>\n            <div class=\"floating-thread\" style=\"left: 50%; animation-delay: 7s;\"></div>\n        </div>\n    </div>\n    \n    <div class=\"content\">\n        <div class=\"thread-container\">\n            <div class=\"thread\"></div>\n            \n            <div class=\"thread-node\" style=\"top: 10%; left: 50%;\" data-info=\"main-thread\">M</div>\n            <div class=\"thread-info\">\n                <h3>Main Thread</h3>\n                <p>The primary execution thread that handles user interface and application flow.</p>\n            </div>\n            \n            <div class=\"thread-node\" style=\"top: 30%; left: 30%;\" data-info=\"worker-1\">1</div>\n            <div class=\"thread-info\">\n                <h3>Worker Thread #1</h3>\n                <p>Handles background computations without blocking the main thread.</p>\n            </div>\n            \n            <div class=\"thread-node\" style=\"top: 30%; left: 70%;\" data-info=\"worker-2\">2</div>\n            <div class=\"thread-info\">\n                <h3>Worker Thread #2</h3>\n                <p>Processes I/O operations and network requests asynchronously.</p>\n            </div>\n            \n            <div class=\"thread-node\" style=\"top: 50%; left: 50%;\" data-info=\"render\">R</div>\n            <div class=\"thread-info\">\n                <h3>Render Thread</h3>\n                <p>Manages UI updates and visual rendering in coordination with the main thread.</p>\n            </div>\n            \n            <div class=\"thread-node\" style=\"top: 70%; left: 30%;\" data-info=\"db\">D</div>\n            <div class=\"thread-info\">\n                <h3>Database Thread</h3>\n                <p>Handles all data persistence operations in a non-blocking manner.</p>\n            </div>\n            \n            <div class=\"thread-node\" style=\"top: 70%; left: 70%;\" data-info=\"net\">N</div>\n            <div class=\"thread-info\">\n                <h3>Network Thread</h3>\n                <p>Manages all external communications and API interactions.</p>\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"animate-btn\">Animate</button>\n            <button id=\"reset-btn\">Reset</button>\n        </div>\n    </div>\n    \n    <footer>\n        Thread Symphony &copy; 2023 | A visual representation of concurrent execution\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const threadNodes = document.querySelectorAll('.thread-node');\n            const animateBtn = document.getElementById('animate-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            const thread = document.querySelector('.thread');\n            \n            // Floating thread elements\n            function createFloatingThreads() {\n                const container = document.querySelector('.floating-threads');\n                for (let i = 0; i < 10; i++) {\n                    const thread = document.createElement('div');\n                    thread.classList.add('floating-thread');\n                    thread.style.left = `${Math.random() * 100}%`;\n                    thread.style.animationDelay = `${Math.random() * 10}s`;\n                    thread.style.height = `${100 + Math.random() * 100}px`;\n                    thread.style.transform = `rotate(${Math.random() * 360}deg)`;\n                    container.appendChild(thread);\n                }\n            }\n            \n            createFloatingThreads();\n            \n            // Node hover effects\n            threadNodes.forEach(node => {\n                node.addEventListener('mouseenter', function() {\n                    // Remove active class from all nodes\n                    threadNodes.forEach(n => n.classList.remove('active'));\n                    // Add active class to current node\n                    this.classList.add('active');\n                });\n            });\n            \n            // Animate button\n            animateBtn.addEventListener('click', function() {\n                thread.style.transform = 'scaleY(1.1)';\n                thread.style.background = 'linear-gradient(to bottom, #b392ac, #d1b3c4, #e7d5e0)';\n                \n                threadNodes.forEach((node, index) => {\n                    setTimeout(() => {\n                        node.style.transform = 'scale(1.3)';\n                        node.style.boxShadow = '0 0 30px rgba(179, 146, 172, 0.8)';\n                        \n                        setTimeout(() => {\n                            node.style.transform = 'scale(1)';\n                            node.style.boxShadow = '0 0 15px rgba(179, 146, 172, 0.6)';\n                        }, 500);\n                    }, index * 200);\n                });\n                \n                setTimeout(() => {\n                    thread.style.transform = 'scaleY(1)';\n                    thread.style.background = 'linear-gradient(to bottom, var(--accent), var(--secondary))';\n                }, 1500);\n            });\n            \n            // Reset button\n            resetBtn.addEventListener('click', function() {\n                thread.style.transform = 'scaleY(1)';\n                thread.style.background = 'linear-gradient(to bottom, var(--accent), var(--secondary))';\n                \n                threadNodes.forEach(node => {\n                    node.style.transform = 'scale(1)';\n                    node.style.boxShadow = '0 0 15px rgba(179, 146, 172, 0.6)';\n                    node.classList.remove('active');\n                });\n            });\n            \n            // Initial animation\n            setTimeout(() => {\n                animateBtn.click();\n            }, 1000);\n        });\n    </script>\n</body>\n</html>"
