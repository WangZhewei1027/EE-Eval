    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Software Development Life Cycle</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Roboto+Slab:wght@700&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #e8eaf6;\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1.5rem 4rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Roboto Slab', serif;\n    font-size: 3.25rem;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    margin-bottom: 0.5rem;\n    text-align: center;\n    text-transform: uppercase;\n    color: #ffdd57;\n    text-shadow:\n      0 0 10px #ffdd57aa,\n      0 0 30px #ffdd57cc,\n      0 0 50px #ffdd57ee;\n  }\n\n  h2 {\n    font-weight: 600;\n    font-size: 1.25rem;\n    letter-spacing: 0.06em;\n    margin-top: 1rem;\n    margin-bottom: 0.25rem;\n    color: #e8eaf6cc;\n  }\n\n  main {\n    max-width: 1000px;\n    width: 100%;\n    margin-top: 2rem;\n    position: relative;\n  }\n\n  /* The cycle container */\n  .cycle-wrapper {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    max-width: 900px;\n    margin: 0 auto 3rem;\n  }\n\n  /* Circular path */\n  svg#cycle-svg {\n    width: 100%;\n    height: 100%;\n    display: block;\n  }\n\n  /* Step circles */\n  .step-circle {\n    cursor: default;\n    filter: drop-shadow(0 0 5px rgba(255 221 87 / 0.7));\n    transition: transform 0.35s cubic-bezier(.4,0,.2,1), filter 0.35s ease;\n  }\n\n  .step-circle:hover {\n    transform: scale(1.15);\n    filter: drop-shadow(0 0 15px rgba(255 221 87 / 1));\n  }\n\n  .step-label {\n    user-select: none;\n    fill: #ffdd57;\n    font-weight: 600;\n    font-size: 1.15rem;\n    letter-spacing: 0.03em;\n    filter: drop-shadow(0 0 3px #111a27bb);\n    pointer-events: none;\n  }\n\n  /* Connecting arrows */\n  .arrow-path {\n    fill: none;\n    stroke: #ffdd57cc;\n    stroke-width: 4;\n    filter: drop-shadow(0 0 5px #ffdd57aa);\n    marker-end: url(#arrowhead);\n    transform-origin: center;\n    transition: stroke 0.3s ease;\n  }\n\n  /* Step info box */\n  .info-box {\n    background: linear-gradient(145deg, #203a43, #2c5364);\n    border-radius: 1rem;\n    color: #f0f4ff;\n    padding: 1.5rem 2rem;\n    box-shadow:\n      0 0 20px #ffdd5711,\n      inset 0 0 15px #121f2a88;\n    max-width: 480px;\n    text-align: center;\n    margin: 0 auto;\n    font-size: 1rem;\n    line-height: 1.45;\n    font-weight: 400;\n    letter-spacing: 0.02em;\n    user-select: text;\n    min-height: 140px;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    transition: background 0.4s ease;\n  }\n\n  /* Highlight the step title in info */\n  .info-box strong {\n    color: #ffdd57;\n    font-weight: 700;\n    font-size: 1.15rem;\n    margin-bottom: 0.4rem;\n    letter-spacing: 0.04em;\n  }\n\n  /* Footer with button */\n  footer {\n    margin-top: auto;\n    user-select: none;\n  }\n\n  button#nextButton {\n    background: #ffdd57;\n    border: none;\n    border-radius: 30px;\n    padding: 0.7rem 2.4rem;\n    font-weight: 600;\n    font-size: 1.15rem;\n    color: #121212;\n    cursor: pointer;\n    box-shadow:\n      0 6px 15px #ffdd5788,\n      inset 0 -2px 6px #efa918;\n    transition: background-color 0.35s ease, box-shadow 0.35s ease, transform 0.2s ease;\n    user-select: none;\n  }\n\n  button#nextButton:hover {\n    background: #ffea85;\n    box-shadow:\n      0 9px 20px #ffea8588,\n      inset 0 -4px 10px #f1c935;\n    transform: translateY(-2px);\n  }\n\n  /* Responsive text scaling */\n  @media (max-width: 580px) {\n    h1 {\n      font-size: 2.1rem;\n    }\n    .step-label {\n      font-size: 0.9rem;\n    }\n    .info-box {\n      max-width: 90vw;\n      font-size: 0.9rem;\n      min-height: 120px;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>Software Development Life Cycle</h1>\n  <main>\n    <div class=\"cycle-wrapper\" aria-label=\"Software Development Life Cycle diagram\" role=\"img\">\n      <svg id=\"cycle-svg\" viewBox=\"0 0 900 900\" aria-hidden=\"true\" focusable=\"false\" >\n        <defs>\n          <marker id=\"arrowhead\" markerWidth=\"12\" markerHeight=\"10\" refX=\"9\" refY=\"5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n            <path d=\"M0,0 L10,5 L0,10 z\" fill=\"#ffdd57cc\"/>\n          </marker>\n        </defs>\n        <!-- Circular path -->\n        <circle cx=\"450\" cy=\"450\" r=\"330\" stroke=\"rgba(255, 221, 87, 0.25)\" stroke-width=\"5\" fill=\"none\" />\n\n        <!-- Arrows between steps -->\n        <path class=\"arrow-path\" id=\"arrow1\" d=\"M675 240 A330 330 0 0 1 706 450\" />\n        <path class=\"arrow-path\" id=\"arrow2\" d=\"M706 450 A330 330 0 0 1 573 662\" />\n        <path class=\"arrow-path\" id=\"arrow3\" d=\"M573 662 A330 330 0 0 1 285 706\" />\n        <path class=\"arrow-path\" id=\"arrow4\" d=\"M285 706 A330 330 0 0 1 100 450\" />\n        <path class=\"arrow-path\" id=\"arrow5\" d=\"M100 450 A330 330 0 0 1 210 244\" />\n        <path class=\"arrow-path\" id=\"arrow6\" d=\"M210 244 A330 330 0 0 1 378 197\" />\n        <path class=\"arrow-path\" id=\"arrow7\" d=\"M378 197 A330 330 0 0 1 675 240\" />\n\n        <!-- Steps circles -->\n        <circle class=\"step-circle\" id=\"step0\" cx=\"675\" cy=\"240\" r=\"48\" fill=\"#ffdd57\" />\n        <circle class=\"step-circle\" id=\"step1\" cx=\"706\" cy=\"450\" r=\"48\" fill=\"#ffdd57\" />\n        <circle class=\"step-circle\" id=\"step2\" cx=\"573\" cy=\"662\" r=\"48\" fill=\"#ffdd57\" />\n        <circle class=\"step-circle\" id=\"step3\" cx=\"285\" cy=\"706\" r=\"48\" fill=\"#ffdd57\" />\n        <circle class=\"step-circle\" id=\"step4\" cx=\"100\" cy=\"450\" r=\"48\" fill=\"#ffdd57\" />\n        <circle class=\"step-circle\" id=\"step5\" cx=\"210\" cy=\"244\" r=\"48\" fill=\"#ffdd57\" />\n        <circle class=\"step-circle\" id=\"step6\" cx=\"378\" cy=\"197\" r=\"48\" fill=\"#ffdd57\" />\n\n        <!-- Step labels -->\n        <text class=\"step-label\" x=\"675\" y=\"248\" text-anchor=\"middle\" dominant-baseline=\"middle\">Planning</text>\n        <text class=\"step-label\" x=\"706\" y=\"458\" text-anchor=\"middle\" dominant-baseline=\"middle\">Analysis</text>\n        <text class=\"step-label\" x=\"573\" y=\"670\" text-anchor=\"middle\" dominant-baseline=\"middle\">Design</text>\n        <text class=\"step-label\" x=\"285\" y=\"714\" text-anchor=\"middle\" dominant-baseline=\"middle\">Implementation</text>\n        <text class=\"step-label\" x=\"100\" y=\"458\" text-anchor=\"middle\" dominant-baseline=\"middle\">Testing</text>\n        <text class=\"step-label\" x=\"210\" y=\"252\" text-anchor=\"middle\" dominant-baseline=\"middle\">Deployment</text>\n        <text class=\"step-label\" x=\"378\" y=\"205\" text-anchor=\"middle\" dominant-baseline=\"middle\">Maintenance</text>\n      </svg>\n    </div>\n\n    <section class=\"info-box\" aria-live=\"polite\" aria-atomic=\"true\" id=\"infoBox\">\n      <strong>Planning</strong>\n      <p>Defining the project objectives, scope, and feasibility to set a clear roadmap for the software development.</p>\n    </section>\n  </main>\n\n  <footer>\n    <button id=\"nextButton\" aria-label=\"Show next Software Development Life Cycle phase\">Next Phase &rarr;</button>\n  </footer>\n\n<script>\n  (() => {\n    const phases = [\n      {\n        title: 'Planning',\n        info: 'Defining the project objectives, scope, and feasibility to set a clear roadmap for the software development.'\n      },\n      {\n        title: 'Analysis',\n        info: 'Gathering and analyzing requirements from stakeholders to understand what the software must achieve.'\n      },\n      {\n        title: 'Design',\n        info: 'Creating architecture, user interfaces, and detailed plans to guide the development process effectively.'\n      },\n      {\n        title: 'Implementation',\n        info: 'Writing clean, efficient code and integrating components to build the functional software system.'\n      },\n      {\n        title: 'Testing',\n        info: 'Verifying and validating the software to identify and fix bugs ensuring quality and reliability.'\n      },\n      {\n        title: 'Deployment',\n        info: 'Releasing the software to the production environment making it available to end users.'\n      },\n      {\n        title: 'Maintenance',\n        info: 'Ongoing updates and improvements post-deployment to adapt the software to evolving needs.'\n      }\n    ];\n\n    const infoBox = document.getElementById('infoBox');\n    const nextBtn = document.getElementById('nextButton');\n    const stepCircles = Array.from(document.querySelectorAll('.step-circle'));\n    const stepLabels = Array.from(document.querySelectorAll('.step-label'));\n\n    let currentIndex = 0;\n\n    // Highlight function\n    function highlightStep(index) {\n      stepCircles.forEach((circle, i) => {\n        if (i === index) {\n          circle.setAttribute('fill', '#fff176');\n          circle.style.filter = 'drop-shadow(0 0 20px #fff176cc)';\n          circle.style.transform = 'scale(1.25)';\n        } else {\n          circle.setAttribute('fill', '#ffdd57');\n          circle.style.filter = 'drop-shadow(0 0 5px rgba(255 221 87 / 0.7))';\n          circle.style.transform = 'scale(1)';\n        }\n      });\n      stepLabels.forEach((label, i) => {\n        label.setAttribute('fill', i === index ? '#fff8e1' : '#ffdd57');\n        label.style.filter = i === index ? 'drop-shadow(0 0 7px #fff8e1dd)' : 'drop-shadow(0 0 3px #111a27bb)';\n      });\n      infoBox.querySelector('strong').textContent = phases[index].title;\n      infoBox.querySelector('p').textContent = phases[index].info;\n\n      // Animate info box background briefly on change\n      infoBox.animate([\n        { backgroundColor: 'rgba(255, 221, 87, 0.2)' },\n        { backgroundColor: 'linear-gradient(145deg, #203a43, #2c5364)' }\n      ], {\n        duration: 700,\n        easing: 'ease-out'\n      });\n    }\n\n    nextBtn.addEventListener('click', () => {\n      currentIndex = (currentIndex + 1) % phases.length;\n      highlightStep(currentIndex);\n    });\n\n    // Initialize highlight on load\n    highlightStep(currentIndex);\n  })();\n</script>\n</body>\n</html>"
