    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Runtime Environment — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&family=Space+Grotesk:wght@400;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #071229;\n    --bg-2: #0d1b2a;\n    --accent-a: #00e5ff;\n    --accent-b: #ff66c4;\n    --muted: rgba(255,255,255,0.06);\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --text: rgba(255,255,255,0.95);\n    --sub: rgba(255,255,255,0.7);\n    --radius: 14px;\n  }\n\n  /* Reset */\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{height:100%}\n  body{\n    font-family: \"Poppins\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, #081226 0%, rgba(2,10,23,0.6) 20%, rgba(6,12,20,0.4) 40%, rgba(8,10,16,1) 100%), linear-gradient(120deg,var(--bg-1),var(--bg-2));\n    color:var(--text);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:36px;\n  }\n\n  /* Subtle animated background orbs */\n  .ambient{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    overflow:hidden;\n  }\n  .orb{\n    position:absolute;\n    filter: blur(38px) saturate(140%);\n    opacity:0.65;\n    mix-blend-mode:screen;\n    transform:translate3d(0,0,0);\n    transition:transform 1s ease;\n  }\n  .orb.a{width:520px;height:520px;background:radial-gradient(circle at 30% 30%, rgba(0,229,255,0.24), rgba(0,229,255,0.06) 28%, transparent 60%); left:-6%; top:-10%;}\n  .orb.b{width:420px;height:420px;background:radial-gradient(circle at 70% 70%, rgba(255,102,196,0.22), rgba(255,102,196,0.04) 40%, transparent 70%); right:-8%; bottom:-12%;}\n  .orb.c{width:280px;height:280px;background:radial-gradient(circle at 40% 60%, rgba(0,180,255,0.09), rgba(255,102,196,0.06) 40%, transparent 68%); left:20%; bottom:10%;}\n\n  /* Container */\n  .stage{\n    position:relative;\n    z-index:2;\n    width:min(1100px,95%);\n    max-width:1200px;\n    height:min(720px,86vh);\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:28px;\n    align-items:stretch;\n    transform:translateZ(0);\n  }\n\n  /* Left: Visual canvas */\n  .panel{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:var(--radius);\n    padding:26px;\n    box-shadow: 0 10px 40px rgba(2,6,12,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:hidden;\n    min-height:520px;\n  }\n\n  /* Header */\n  .header{\n    display:flex;\n    gap:18px;\n    align-items:center;\n    margin-bottom:14px;\n  }\n  .title{\n    display:flex;\n    flex-direction:column;\n  }\n  .title h1{\n    font-family:\"Space Grotesk\", \"Poppins\", sans-serif;\n    font-size:20px;\n    letter-spacing:0.2px;\n    margin-bottom:2px;\n    color:var(--text);\n    font-weight:600;\n  }\n  .title p{\n    font-size:13px;\n    color:var(--sub);\n  }\n\n  /* Control */\n  .controls{\n    margin-left:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.06);\n    color:var(--text);\n    padding:10px 14px;\n    border-radius:12px;\n    cursor:pointer;\n    font-weight:600;\n    font-size:13px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition:all .28s cubic-bezier(.2,.9,.3,1);\n    box-shadow: 0 6px 18px rgba(2,6,20,0.45);\n    user-select:none;\n  }\n  .btn:hover{transform:translateY(-2px) scale(1.01)}\n  .btn:active{transform:translateY(0)}\n  .btn .dot{\n    width:10px;height:10px;border-radius:50%;\n    box-shadow: 0 0 12px rgba(0,229,255,0.5);\n    background:linear-gradient(180deg,var(--accent-a),#7afcff);\n  }\n  .btn.paused .dot{\n    background:linear-gradient(180deg,var(--accent-b),#ffa1dd);\n    box-shadow: 0 0 12px rgba(255,102,196,0.32);\n  }\n  .status{\n    font-size:12px;color:var(--sub);\n    display:flex;flex-direction:column;align-items:flex-end;\n  }\n  .status .state{font-weight:600;color:var(--text);font-size:13px}\n  .status .hint{font-size:11px;color:rgba(255,255,255,0.45)}\n\n  /* Canvas area */\n  .canvas{\n    position:relative;\n    height:100%;\n    border-radius:10px;\n    overflow:visible;\n    margin-top:6px;\n    padding:10px;\n  }\n\n  /* Right: Info card */\n  .info{\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:var(--radius);\n    padding:22px;\n    box-shadow: 0 10px 40px rgba(2,6,12,0.5), inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n    min-height:520px;\n  }\n  .inf-head{\n    display:flex;align-items:center;gap:12px;margin-bottom:18px;\n  }\n  .chip{\n    width:48px;height:48px;border-radius:12px;\n    background:linear-gradient(135deg, rgba(0,229,255,0.12), rgba(255,102,196,0.08));\n    border:1px solid rgba(255,255,255,0.04);\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 6px 20px rgba(0,0,0,0.5);\n    font-weight:700;color:var(--text);\n    font-family:\"Space Grotesk\", \"Poppins\";\n    font-size:18px;\n  }\n  .inf-title{font-weight:700;font-size:16px;color:var(--text)}\n  .inf-sub{font-size:13px;color:var(--sub);margin-top:6px}\n\n  .info .grid{\n    margin-top:18px;\n    display:grid;\n    grid-template-columns:1fr 1fr;\n    gap:12px;\n  }\n  .card{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border-radius:12px;padding:12px;border:1px solid rgba(255,255,255,0.03);\n    min-height:96px;\n    display:flex;flex-direction:column;justify-content:center;\n  }\n  .card h3{font-size:13px;margin-bottom:6px;color:var(--sub);font-weight:600}\n  .card p{font-size:14px;color:var(--text);font-weight:700}\n\n  .legend{\n    margin-top:18px;padding:12px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));border:1px solid rgba(255,255,255,0.02);\n    color:var(--sub);font-size:13px;\n  }\n\n  /* Nodes style */\n  .node{\n    fill:transparent;\n    stroke-width:0;\n  }\n  .node-rect{\n    rx:12;ry:12;\n    filter: drop-shadow(0 8px 30px rgba(0,0,0,0.6));\n    stroke:rgba(255,255,255,0.03);\n  }\n  .node-title{font-size:12px;font-weight:700;fill:rgba(255,255,255,0.95);font-family:\"Space Grotesk\", \"Poppins\";}\n  .node-sub{font-size:11px;fill:rgba(255,255,255,0.6);font-family:\"Poppins\"}\n\n  /* Path glow */\n  .path{\n    fill:none;stroke:rgba(255,255,255,0.02);stroke-width:2;\n  }\n  .path-glow{\n    fill:none;stroke:rgba(0,229,255,0.12);stroke-width:8;stroke-linecap:round;\n    filter:blur(6px);\n    mix-blend-mode:screen;\n  }\n\n  /* Orb style */\n  .orb-dot{\n    transition:opacity .5s linear, transform .5s linear;\n    transform-origin:center;\n    filter:drop-shadow(0 6px 18px rgba(0,0,0,0.65));\n  }\n\n  /* Runtime ring */\n  .ring{\n    width:84px;height:84px;border-radius:50%;\n    display:flex;align-items:center;justify-content:center;margin-left:auto;\n    background:conic-gradient(from 180deg at 50% 50%, rgba(0,229,255,0.28) 0%, rgba(255,102,196,0.22) 45%, rgba(255,255,255,0.02) 45%);\n    box-shadow:inset 0 2px 12px rgba(255,255,255,0.02), 0 10px 30px rgba(3,8,16,0.6);\n    border:1px solid rgba(255,255,255,0.04);\n  }\n  .ring .inner{\n    width:66px;height:66px;border-radius:50%;background:linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.02));\n    display:flex;align-items:center;justify-content:center;flex-direction:column;\n    color:var(--text);\n  }\n  .ring .p{font-size:10px;color:var(--sub)}\n  .ring .v{font-weight:700;font-size:18px}\n\n  /* paused state */\n  .paused .panel, .paused .info{\n    opacity:0.92;\n    transform:scale(0.996);\n  }\n\n  /* Tiny labels */\n  .muted{font-size:12px;color:var(--sub);}\n\n  /* footer thin */\n  .footer-note{\n    position:absolute;left:26px;bottom:18px;font-size:12px;color:rgba(255,255,255,0.06);\n  }\n\n  /* subtle animations */\n  @keyframes driftA { 0%{transform:translateY(0) translateX(0)} 50%{transform:translateY(-18px) translateX(8px)} 100%{transform:translateY(0) translateX(0)}}\n  @keyframes driftB { 0%{transform:translateY(0) translateX(0)} 50%{transform:translateY(12px) translateX:-8px} 100%{transform:translateY(0) translateX(0)}}\n\n  .orb.a{animation:driftA 16s ease-in-out infinite}\n  .orb.b{animation:driftB 18s ease-in-out infinite}\n  .orb.c{animation:driftA 20s ease-in-out infinite}\n\n  /* Responsive */\n  @media (max-width:980px){\n    .stage{grid-template-columns:1fr;grid-auto-rows:min-content;gap:18px;height:auto}\n    .info{order:2}\n  }\n</style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <div class=\"orb a\"></div>\n    <div class=\"orb b\"></div>\n    <div class=\"orb c\"></div>\n  </div>\n\n  <div class=\"stage\" id=\"stage\">\n    <div class=\"panel panel-left\" id=\"panel\">\n      <div class=\"header\">\n        <div class=\"title\" aria-hidden=\"true\">\n          <h1>Runtime Environment</h1>\n          <p>Dynamic visualization of processes, scheduling, memory, and I/O—flowing in real time.</p>\n        </div>\n\n        <div class=\"controls\">\n          <div class=\"status\" aria-hidden=\"true\">\n            <div class=\"state\" id=\"stateLabel\">Running</div>\n            <div class=\"hint\">Toggle to pause visual flow</div>\n          </div>\n          <button class=\"btn\" id=\"toggleBtn\" title=\"Toggle runtime\">\n            <span class=\"dot\" id=\"dot\"></span>\n            <span id=\"btnText\">Pause</span>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"canvas\" id=\"canvasArea\" aria-hidden=\"true\">\n        <!-- SVG visual -->\n        <svg id=\"viz\" viewBox=\"0 0 1000 640\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"gA\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#00e5ff\" stop-opacity=\"0.85\"/>\n              <stop offset=\"1\" stop-color=\"#7afcff\" stop-opacity=\"0.35\"/>\n            </linearGradient>\n            <linearGradient id=\"gB\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ff66c4\" stop-opacity=\"0.85\"/>\n              <stop offset=\"1\" stop-color=\"#ffb3e0\" stop-opacity=\"0.35\"/>\n            </linearGradient>\n            <filter id=\"softGlow\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n            <filter id=\"tinyBlur\">\n              <feGaussianBlur stdDeviation=\"3\" />\n            </filter>\n          </defs>\n\n          <!-- Background subtle grid -->\n          <g opacity=\"0.06\">\n            <rect x=\"0\" y=\"0\" width=\"1000\" height=\"640\" fill=\"none\" stroke=\"#ffffff\" stroke-opacity=\"0.02\" />\n            <!-- few diagonal lines -->\n            <path d=\"M0 560 L1000 240\" stroke=\"#ffffff\" stroke-opacity=\"0.02\" stroke-width=\"1\"/>\n            <path d=\"M0 480 L1000 160\" stroke=\"#ffffff\" stroke-opacity=\"0.02\" stroke-width=\"1\"/>\n          </g>\n\n          <!-- Paths between nodes -->\n          <!-- Central kernel -->\n          <g id=\"nodes\">\n            <!-- Kernel center -->\n            <g id=\"kernel\" transform=\"translate(500,310)\">\n              <rect x=\"-96\" y=\"-66\" width=\"192\" height=\"132\" class=\"node-rect\" fill=\"url(#gA)\" opacity=\"0.12\" />\n              <rect x=\"-96\" y=\"-66\" width=\"192\" height=\"132\" rx=\"12\" ry=\"12\" stroke=\"rgba(255,255,255,0.03)\" fill=\"transparent\"/>\n              <text x=\"0\" y=\"-6\" text-anchor=\"middle\" class=\"node-title\">KERNEL</text>\n              <text x=\"0\" y=\"18\" text-anchor=\"middle\" class=\"node-sub\">scheduling · syscall · memory</text>\n            </g>\n\n            <!-- Process pool - left top -->\n            <g id=\"proc\" transform=\"translate(200,150)\">\n              <rect x=\"-64\" y=\"-44\" width=\"128\" height=\"88\" class=\"node-rect\" fill=\"url(#gB)\" opacity=\"0.10\"/>\n              <rect x=\"-64\" y=\"-44\" width=\"128\" height=\"88\" rx=\"12\" ry=\"12\" stroke=\"rgba(255,255,255,0.03)\" fill=\"transparent\"/>\n              <text x=\"0\" y=\"-4\" text-anchor=\"middle\" class=\"node-title\">Processes</text>\n              <text x=\"0\" y=\"18\" text-anchor=\"middle\" class=\"node-sub\">threads · runtime</text>\n            </g>\n\n            <!-- Memory - left bottom -->\n            <g id=\"mem\" transform=\"translate(200,420)\">\n              <rect x=\"-80\" y=\"-44\" width=\"160\" height=\"88\" class=\"node-rect\" fill=\"url(#gA)\" opacity=\"0.08\"/>\n              <rect x=\"-80\" y=\"-44\" width=\"160\" height=\"88\" rx=\"12\" ry=\"12\" stroke=\"rgba(255,255,255,0.03)\" fill=\"transparent\"/>\n              <text x=\"0\" y=\"-4\" text-anchor=\"middle\" class=\"node-title\">Memory</text>\n              <text x=\"0\" y=\"18\" text-anchor=\"middle\" class=\"node-sub\">heap · stack · cache</text>\n            </g>\n\n            <!-- Scheduler - top right -->\n            <g id=\"sched\" transform=\"translate(770,120)\">\n              <rect x=\"-70\" y=\"-40\" width=\"140\" height=\"80\" class=\"node-rect\" fill=\"url(#gB)\" opacity=\"0.09\"/>\n              <rect x=\"-70\" y=\"-40\" width=\"140\" height=\"80\" rx=\"12\" ry=\"12\" stroke=\"rgba(255,255,255,0.03)\" fill=\"transparent\"/>\n              <text x=\"0\" y=\"-4\" text-anchor=\"middle\" class=\"node-title\">Scheduler</text>\n              <text x=\"0\" y=\"18\" text-anchor=\"middle\" class=\"node-sub\">queues · priorities</text>\n            </g>\n\n            <!-- I/O - right center -->\n            <g id=\"io\" transform=\"translate(770,330)\">\n              <rect x=\"-64\" y=\"-44\" width=\"128\" height=\"88\" class=\"node-rect\" fill=\"url(#gA)\" opacity=\"0.08\"/>\n              <rect x=\"-64\" y=\"-44\" width=\"128\" height=\"88\" rx=\"12\" ry=\"12\" stroke=\"rgba(255,255,255,0.03)\" fill=\"transparent\"/>\n              <text x=\"0\" y=\"-4\" text-anchor=\"middle\" class=\"node-title\">I/O</text>\n              <text x=\"0\" y=\"18\" text-anchor=\"middle\" class=\"node-sub\">disk · devices</text>\n            </g>\n\n            <!-- Network - right bottom -->\n            <g id=\"net\" transform=\"translate(580,520)\">\n              <rect x=\"-72\" y=\"-36\" width=\"144\" height=\"72\" class=\"node-rect\" fill=\"url(#gB)\" opacity=\"0.09\"/>\n              <rect x=\"-72\" y=\"-36\" width=\"144\" height=\"72\" rx=\"12\" ry=\"12\" stroke=\"rgba(255,255,255,0.03)\" fill=\"transparent\"/>\n              <text x=\"0\" y=\"-2\" text-anchor=\"middle\" class=\"node-title\">Network</text>\n              <text x=\"0\" y=\"16\" text-anchor=\"middle\" class=\"node-sub\">sockets · streams</text>\n            </g>\n\n          </g>\n\n          <!-- Paths -->\n          <g id=\"links\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path id=\"p1\" class=\"path-glow\" d=\"M404 250 C 420 260, 450 290, 500 290\" opacity=\"0.7\"/>\n            <path id=\"p1b\" class=\"path\" d=\"M404 250 C 420 260, 450 290, 500 290\" />\n\n            <path id=\"p2\" class=\"path-glow\" d=\"M404 420 C 450 400, 480 370, 500 375\" opacity=\"0.6\"/>\n            <path id=\"p2b\" class=\"path\" d=\"M404 420 C 450 400, 480 370, 500 375\" />\n\n            <path id=\"p3\" class=\"path-glow\" d=\"M580 330 C 650 330, 700 330, 730 330\" opacity=\"0.6\"/>\n            <path id=\"p3b\" class=\"path\" d=\"M580 330 C 650 330, 700 330, 730 330\" />\n\n            <path id=\"p4\" class=\"path-glow\" d=\"M552 380 C 620 420, 700 470, 770 520\" opacity=\"0.5\"/>\n            <path id=\"p4b\" class=\"path\" d=\"M552 380 C 620 420, 700 470, 770 520\" />\n\n            <path id=\"p5\" class=\"path-glow\" d=\"M280 160 C 350 180, 420 230, 480 280\" opacity=\"0.55\"/>\n            <path id=\"p5b\" class=\"path\" d=\"M280 160 C 350 180, 420 230, 480 280\" />\n\n            <path id=\"p6\" class=\"path-glow\" d=\"M280 420 C 330 420, 420 380, 490 360\" opacity=\"0.55\"/>\n            <path id=\"p6b\" class=\"path\" d=\"M280 420 C 330 420, 420 380, 490 360\" />\n\n            <path id=\"p7\" class=\"path-glow\" d=\"M520 240 C 600 200, 700 160, 770 120\" opacity=\"0.5\"/>\n            <path id=\"p7b\" class=\"path\" d=\"M520 240 C 600 200, 700 160, 770 120\" />\n          </g>\n\n          <!-- Moving orbs (will be positioned by JS) -->\n          <g id=\"orbs\" filter=\"url(#softGlow)\">\n            <!-- Circles injected from JS -->\n          </g>\n\n          <!-- Small overlay micro lines to add depth -->\n          <g opacity=\"0.08\">\n            <path d=\"M350 120 Q 480 200, 600 150\" stroke=\"#ffffff\" stroke-width=\"1\" fill=\"none\"/>\n            <path d=\"M120 540 Q 300 430, 480 380\" stroke=\"#ffffff\" stroke-width=\"1\" fill=\"none\"/>\n          </g>\n\n        </svg>\n      </div>\n\n      <div class=\"footer-note\">This visualization is aesthetic-first — elements are symbolic representations of runtime components.</div>\n    </div>\n\n    <aside class=\"info\" id=\"infoCard\">\n      <div class=\"inf-head\">\n        <div class=\"chip\">RE</div>\n        <div>\n          <div class=\"inf-title\">Runtime Environment — Overview</div>\n          <div class=\"inf-sub\">Ecosystem of kernel, processes, memory, scheduler and I/O — portrayed as dynamic flow.</div>\n        </div>\n        <div class=\"ring\" aria-hidden=\"true\">\n          <div class=\"inner\">\n            <div class=\"p\">Latency</div>\n            <div class=\"v\" id=\"latencyVal\">12ms</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"grid\">\n        <div class=\"card\">\n          <h3>Scheduler</h3>\n          <p id=\"schedVal\">Round-robin · active</p>\n        </div>\n        <div class=\"card\">\n          <h3>Processes</h3>\n          <p id=\"procVal\">42 running</p>\n        </div>\n        <div class=\"card\">\n          <h3>Memory</h3>\n          <p id=\"memVal\">3.2 GB used</p>\n        </div>\n        <div class=\"card\">\n          <h3>I/O Throughput</h3>\n          <p id=\"ioVal\">120 MB/s</p>\n        </div>\n      </div>\n\n      <div class=\"legend\">\n        Colors and flow represent activity levels. Bright cyan flow indicates scheduling and kernel-driven traffic; magenta accents indicate I/O or network bursts.\n      </div>\n    </aside>\n  </div>\n\n<script>\n  (function(){\n    // Minimal interactivity: one toggle button to pause/resume the animation\n    const toggleBtn = document.getElementById('toggleBtn');\n    const btnText = document.getElementById('btnText');\n    const dot = document.getElementById('dot');\n    const stateLabel = document.getElementById('stateLabel');\n    const stage = document.getElementById('stage');\n    let running = true;\n\n    toggleBtn.addEventListener('click', () => {\n      running = !running;\n      if(!running){\n        btnText.textContent = 'Run';\n        stage.classList.add('paused');\n        dot.parentElement.classList.add('paused');\n        stateLabel.textContent = 'Paused';\n      } else {\n        btnText.textContent = 'Pause';\n        stage.classList.remove('paused');\n        dot.parentElement.classList.remove('paused');\n        stateLabel.textContent = 'Running';\n      }\n      // adjust orb speeds in the runtime loop by flag\n    });\n\n    // Setup SVG orb motion along paths\n    const svg = document.getElementById('viz');\n    const orbsGroup = document.getElementById('orbs');\n\n    // register paths to flow along (IDs)\n    const linkIds = ['p1','p2','p3','p4','p5','p6','p7'];\n    const colors = ['#00e5ff','#00e5ff','#ff66c4','#00e5ff','#ff66c4','#00e5ff','#ff66c4'];\n    const sizes = [8,7,9,6,7,6,8];\n    const speedsBase = [0.0009,0.0007,0.0011,0.0006,0.0008,0.0007,0.0009]; // per ms\n\n    const flows = [];\n\n    // Create orbs for each path, some paths have multiple orbs\n    linkIds.forEach((id,i) => {\n      const path = svg.getElementById(id);\n      if(!path) return;\n      const length = path.getTotalLength();\n      // create 2 orbs on longer paths\n      const orbCount = length > 250 ? 2 : 1;\n      for(let j=0;j<orbCount;j++){\n        const circle = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n        circle.setAttribute('r', sizes[i]);\n        circle.setAttribute('fill', colors[i]);\n        circle.setAttribute('class','orb-dot');\n        circle.setAttribute('opacity', 0.95);\n        orbsGroup.appendChild(circle);\n\n        flows.push({\n          path,\n          el: circle,\n          length,\n          pos: Math.random()*length,\n          speed: speedsBase[i] * (0.6 + Math.random()*1.2), // add variation\n          size: sizes[i]\n        });\n      }\n    });\n\n    // Add small orbs that loop between kernel and processes to indicate scheduling\n    (function addKernelBurst(){\n      const kernelBurstPath = svg.createSVGPathSegCurvetoCubicAbs ? null : null;\n      // We'll create a custom small path from kernel to processes (p5)\n      const p5 = svg.getElementById('p5');\n      if(p5){\n        const l = p5.getTotalLength();\n        for(let i=0;i<3;i++){\n          const c = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n          c.setAttribute('r', 5);\n          c.setAttribute('fill', '#7afcff');\n          c.setAttribute('opacity', 0.9 - i*0.15);\n          c.setAttribute('class','orb-dot');\n          orbsGroup.appendChild(c);\n          flows.push({\n            path: p5,\n            el: c,\n            length: l,\n            pos: (i/3)*l,\n            speed: 0.0015*(0.6 + Math.random()*0.8),\n            size: 5\n          });\n        }\n      }\n    })();\n\n    // Animation loop\n    let last = performance.now();\n    function step(now){\n      const dt = now - last;\n      last = now;\n      // Slight ambient changes when paused vs running\n      const globalSpeedMult = running ? 1 : 0.04;\n      orbsGroup.style.opacity = running ? 1 : 0.55;\n\n      flows.forEach(flow => {\n        flow.pos += flow.speed * dt * globalSpeedMult * 1.0;\n        // wrap\n        while(flow.pos > flow.length) flow.pos -= flow.length;\n        // compute point\n        const pt = flow.path.getPointAtLength(flow.pos);\n        flow.el.setAttribute('cx', pt.x);\n        flow.el.setAttribute('cy', pt.y);\n        // subtle size/opacity breathing\n        const b = 1 + Math.sin(now*0.002 + flow.pos*0.02)*0.08;\n        const size = Math.max(2, flow.size * b * (running ? 1.0 : 0.8));\n        flow.el.setAttribute('r', size);\n        flow.el.style.opacity = running ? (0.85 + Math.sin(now*0.003 + flow.pos*0.05)*0.08) : 0.45;\n        // little trail blur when faster\n        flow.el.style.filter = running ? 'blur(0.6px)' : 'blur(1.8px)';\n      });\n\n      // Update right-panel metrics gently\n      updateMetrics(dt);\n\n      requestAnimationFrame(step);\n    }\n    requestAnimationFrame(step);\n\n    // Simple metrics drift (purely aesthetic)\n    const schedVal = document.getElementById('schedVal');\n    const procVal = document.getElementById('procVal');\n    const memVal = document.getElementById('memVal');\n    const ioVal = document.getElementById('ioVal');\n    const latencyVal = document.getElementById('latencyVal');\n\n    let metricState = {\n      proc: 42,\n      mem: 3.2, // GB\n      io: 120, // MB/s\n      lat: 12 // ms\n    };\n    let metricTimer = 0;\n    function updateMetrics(dt){\n      metricTimer += dt;\n      if(metricTimer > 800){\n        metricTimer = 0;\n        // small fluctuations\n        if(running){\n          metricState.proc = clamp(metricState.proc + (Math.random()*4-2), 30, 70);\n          metricState.mem = clamp(metricState.mem + (Math.random()*0.2-0.1), 1.8, 8.0);\n          metricState.io = clamp(metricState.io + (Math.random()*20-10), 40, 420);\n          metricState.lat = clamp(metricState.lat + (Math.random()*6-3), 3, 120);\n        } else {\n          // decay to stable lower activity\n          metricState.proc = Math.round(lerp(metricState.proc, 18 + Math.random()*10, 0.08));\n          metricState.mem = lerp(metricState.mem, 2.0, 0.06);\n          metricState.io = Math.round(lerp(metricState.io, 20 + Math.random()*40, 0.06));\n          metricState.lat = Math.round(lerp(metricState.lat, 18 + Math.random()*6, 0.06));\n        }\n        // display nicely\n        procVal.textContent = Math.round(metricState.proc) + ' running';\n        memVal.textContent = metricState.mem.toFixed(1) + ' GB used';\n        ioVal.textContent = Math.round(metricState.io) + ' MB/s';\n        latencyVal.textContent = Math.round(metricState.lat) + 'ms';\n      }\n    }\n\n    function clamp(v,a,b){return Math.max(a,Math.min(b,v))}\n    function lerp(a,b,t){return a + (b-a)*t}\n\n    // initial tiny entrance animations for nodes\n    window.addEventListener('load', () => {\n      const nodes = svg.querySelectorAll('#nodes g');\n      nodes.forEach((n,i) => {\n        n.style.opacity = 0;\n        n.style.transformOrigin = 'center center';\n        n.animate([\n          { transform: 'translateY(18px) scale(0.98)', opacity: 0 },\n          { transform: 'translateY(0px) scale(1)', opacity: 1 }\n        ], {\n          duration: 900,\n          delay: i*80,\n          easing: 'cubic-bezier(.2,.9,.3,1)',\n          fill: 'forwards'\n        });\n      });\n\n      // subtle glow on links\n      const glows = svg.querySelectorAll('.path-glow');\n      glows.forEach((g,i) => {\n        const d = [0.2 + Math.random()*0.8, 0.2 + Math.random()*0.8, 0.4 + Math.random()*0.6];\n        g.animate([\n          { opacity: d[0] },\n          { opacity: d[1] },\n          { opacity: d[2] },\n          { opacity: d[0] }\n        ], { duration: 4000 + Math.random()*2800, iterations: Infinity });\n      });\n    });\n\n    // Accessibility: keyboard toggle (Space/Enter)\n    toggleBtn.addEventListener('keydown', (e) => {\n      if(e.key === ' ' || e.key === 'Enter'){\n        e.preventDefault(); toggleBtn.click();\n      }\n    });\n\n    // Reduce motion respect (simple)\n    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');\n    if(mq.matches){\n      // stop heavy animations\n      flows.forEach(f => { f.speed *= 0.2; });\n      document.querySelectorAll('.orb.a,.orb.b,.orb.c').forEach(o => { o.style.animation = 'none'; });\n    }\n\n  })();\n</script>\n</body>\n</html>"
  },
