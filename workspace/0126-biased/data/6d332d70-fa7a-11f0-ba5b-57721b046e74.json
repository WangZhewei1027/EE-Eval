  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>K-Nearest Neighbors Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        canvas {\n            border: 1px solid #000;\n            margin: 10px 0;\n        }\n        .control-panel {\n            margin: 20px 0;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        .control-group {\n            margin: 10px 0;\n        }\n        button, select, input {\n            margin: 5px;\n        }\n        .data-table {\n            border-collapse: collapse;\n            margin: 10px 0;\n        }\n        .data-table td, .data-table th {\n            border: 1px solid #000;\n            padding: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>K-Nearest Neighbors Interactive Demo</h1>\n    \n    <div class=\"control-panel\">\n        <h2>Controls</h2>\n        \n        <div class=\"control-group\">\n            <label for=\"kValue\">K value: </label>\n            <input type=\"range\" id=\"kValue\" min=\"1\" max=\"15\" value=\"3\" oninput=\"updateKValue()\">\n            <span id=\"kValueDisplay\">3</span>\n        </div>\n        \n        <div class=\"control-group\">\n            <label for=\"distanceMetric\">Distance Metric: </label>\n            <select id=\"distanceMetric\" onchange=\"updateDistanceMetric()\">\n                <option value=\"euclidean\">Euclidean</option>\n                <option value=\"manhattan\">Manhattan</option>\n                <option value=\"chebyshev\">Chebyshev</option>\n            </select>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Dataset: </label>\n            <button onclick=\"generateRandomData()\">Generate Random Data</button>\n            <button onclick=\"clearData()\">Clear Data</button>\n            <button onclick=\"loadSampleData()\">Load Sample Data</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Class to add: </label>\n            <select id=\"classToAdd\">\n                <option value=\"0\">Class 0</option>\n                <option value=\"1\">Class 1</option>\n                <option value=\"2\">Class 2</option>\n            </select>\n            <button onclick=\"addRandomPoint()\">Add Random Point</button>\n            <button onclick=\"enableManualPlacement()\">Add Point Manually</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Test Point: </label>\n            <input type=\"number\" id=\"testX\" placeholder=\"X\" step=\"0.1\" value=\"0.5\">\n            <input type=\"number\" id=\"testY\" placeholder=\"Y\" step=\"0.1\" value=\"0.5\">\n            <button onclick=\"classifyPoint()\">Classify</button>\n            <button onclick=\"addTestPointToData()\">Add to Dataset</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Visualization: </label>\n            <button onclick=\"toggleDecisionBoundary()\">Toggle Decision Boundary</button>\n            <button onclick=\"toggleNeighbors()\">Toggle Neighbors</button>\n        </div>\n    </div>\n    \n    <div>\n        <h2>Visualization</h2>\n        <canvas id=\"canvas\" width=\"600\" height=\"400\" onclick=\"handleCanvasClick(event)\"></canvas>\n    </div>\n    \n    <div>\n        <h2>Dataset</h2>\n        <table class=\"data-table\" id=\"dataTable\">\n            <thead>\n                <tr>\n                    <th>ID</th>\n                    <th>X</th>\n                    <th>Y</th>\n                    <th>Class</th>\n                    <th>Distance</th>\n                    <th>Actions</th>\n                </tr>\n            </thead>\n            <tbody id=\"dataTableBody\">\n            </tbody>\n        </table>\n    </div>\n    \n    <div>\n        <h2>Classification Results</h2>\n        <div id=\"results\"></div>\n    </div>\n    \n    <script>\n        // Global variables\n        let dataPoints = [];\n        let testPoint = {x: 0.5, y: 0.5, class: null};\n        let k = 3;\n        let distanceMetric = 'euclidean';\n        let showDecisionBoundary = false;\n        let showNeighbors = false;\n        let manualPlacementMode = false;\n        let nextId = 1;\n        \n        // Canvas setup\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n        const width = canvas.width;\n        const height = canvas.height;\n        \n        // Color mapping for classes\n        const classColors = ['#FF0000', '#00FF00', '#0000FF'];\n        \n        // Initialize\n        function init() {\n            drawCanvas();\n            updateDataTable();\n        }\n        \n        // Drawing functions\n        function drawCanvas() {\n            ctx.clearRect(0, 0, width, height);\n            \n            // Draw grid\n            ctx.strokeStyle = '#DDD';\n            for (let x = 0; x <= width; x += width / 10) {\n                ctx.beginPath();\n                ctx.moveTo(x, 0);\n                ctx.lineTo(x, height);\n                ctx.stroke();\n            }\n            for (let y = 0; y <= height; y += height / 10) {\n                ctx.beginPath();\n                ctx.moveTo(0, y);\n                ctx.lineTo(width, y);\n                ctx.stroke();\n            }\n            \n            // Draw decision boundary if enabled\n            if (showDecisionBoundary) {\n                drawDecisionBoundary();\n            }\n            \n            // Draw data points\n            dataPoints.forEach(point => {\n                drawPoint(point.x, point.y, point.class, false);\n            });\n            \n            // Draw test point\n            if (testPoint) {\n                drawPoint(testPoint.x, testPoint.y, testPoint.class, true);\n            }\n            \n            // Highlight neighbors if enabled\n            if (showNeighbors && testPoint) {\n                highlightNeighbors();\n            }\n        }\n        \n        function drawPoint(x, y, pointClass, isTestPoint) {\n            const canvasX = x * width;\n            const canvasY = y * height;\n            const radius = isTestPoint ? 8 : 6;\n            const borderWidth = isTestPoint ? 2 : 1;\n            \n            ctx.beginPath();\n            ctx.arc(canvasX, canvasY, radius, 0, Math.PI * 2);\n            ctx.fillStyle = pointClass !== null ? classColors[pointClass] : '#FFFFFF';\n            ctx.fill();\n            ctx.lineWidth = borderWidth;\n            ctx.strokeStyle = '#000000';\n            ctx.stroke();\n        }\n        \n        function drawDecisionBoundary() {\n            const resolution = 20;\n            const cellWidth = width / resolution;\n            const cellHeight = height / resolution;\n            \n            for (let i = 0; i < resolution; i++) {\n                for (let j = 0; j < resolution; j++) {\n                    const x = (i + 0.5) / resolution;\n                    const y = (j + 0.5) / resolution;\n                    \n                    const neighbors = findNearestNeighbors(x, y, k);\n                    const predictedClass = predictClass(neighbors);\n                    \n                    ctx.fillStyle = classColors[predictedClass] + '40'; // Add transparency\n                    ctx.fillRect(i * cellWidth, j * cellHeight, cellWidth, cellHeight);\n                }\n            }\n        }\n        \n        function highlightNeighbors() {\n            const neighbors = findNearestNeighbors(testPoint.x, testPoint.y, k);\n            \n            neighbors.forEach(neighbor => {\n                const point = dataPoints[neighbor.index];\n                const canvasX = point.x * width;\n                const canvasY = point.y * height;\n                \n                ctx.beginPath();\n                ctx.arc(canvasX, canvasY, 10, 0, Math.PI * 2);\n                ctx.strokeStyle = '#FF00FF';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n                \n                // Draw line to test point\n                ctx.beginPath();\n                ctx.moveTo(canvasX, canvasY);\n                ctx.lineTo(testPoint.x * width, testPoint.y * height);\n                ctx.strokeStyle = '#FF00FF';\n                ctx.lineWidth = 1;\n                ctx.stroke();\n            });\n        }\n        \n        // KNN functions\n        function calculateDistance(x1, y1, x2, y2) {\n            switch (distanceMetric) {\n                case 'euclidean':\n                    return Math.sqrt(Math.pow(x1 - x2, 2) + Math.pow(y1 - y2, 2));\n                case 'manhattan':\n                    return Math.abs(x1 - x2) + Math.abs(y1 - y2);\n                case 'chebyshev':\n                    return Math.max(Math.abs(x1 - x2), Math.abs(y1 - y2));\n                default:\n                    return 0;\n            }\n        }\n        \n        function findNearestNeighbors(x, y, k) {\n            const distances = dataPoints.map((point, index) => ({\n                index,\n                distance: calculateDistance(x, y, point.x, point.y),\n                class: point.class\n            }));\n            \n            distances.sort((a, b) => a.distance - b.distance);\n            return distances.slice(0, k);\n        }\n        \n        function predictClass(neighbors) {\n            const classCounts = {};\n            \n            neighbors.forEach(neighbor => {\n                const cls = neighbor.class;\n                classCounts[cls] = (classCounts[cls] || 0) + 1;\n            });\n            \n            let maxCount = 0;\n            let predictedClass = 0;\n            \n            for (const cls in classCounts) {\n                if (classCounts[cls] > maxCount) {\n                    maxCount = classCounts[cls];\n                    predictedClass = parseInt(cls);\n                }\n            }\n            \n            return predictedClass;\n        }\n        \n        // Data management\n        function addPoint(x, y, cls) {\n            dataPoints.push({\n                id: nextId++,\n                x: x,\n                y: y,\n                class: cls\n            });\n            updateDataTable();\n            drawCanvas();\n        }\n        \n        function addRandomPoint() {\n            const cls = parseInt(document.getElementById('classToAdd').value);\n            const x = Math.random();\n            const y = Math.random();\n            addPoint(x, y, cls);\n        }\n        \n        function generateRandomData() {\n            clearData();\n            const classCount = 3;\n            const pointsPerClass = 10;\n            \n            for (let c = 0; c < classCount; c++) {\n                for (let i = 0; i < pointsPerClass; i++) {\n                    // Cluster points around different centers\n                    const centerX = 0.2 + c * 0.3;\n                    const centerY = 0.2 + c * 0.3;\n                    \n                    const x = Math.max(0, Math.min(1, centerX + (Math.random() - 0.5) * 0.3));\n                    const y = Math.max(0, Math.min(1, centerY + (Math.random() - 0.5) * 0.3));\n                    \n                    addPoint(x, y, c);\n                }\n            }\n        }\n        \n        function loadSampleData() {\n            clearData();\n            // Linearly separable data\n            addPoint(0.1, 0.1, 0);\n            addPoint(0.2, 0.1, 0);\n            addPoint(0.1, 0.2, 0);\n            addPoint(0.2, 0.2, 0);\n            addPoint(0.3, 0.3, 0);\n            \n            addPoint(0.7, 0.7, 1);\n            addPoint(0.8, 0.7, 1);\n            addPoint(0.7, 0.8, 1);\n            addPoint(0.8, 0.8, 1);\n            addPoint(0.9, 0.9, 1);\n            \n            // Some overlapping points\n            addPoint(0.4, 0.4, 2);\n            addPoint(0.5, 0.5, 2);\n            addPoint(0.6, 0.6, 2);\n            addPoint(0.4, 0.6, 2);\n            addPoint(0.6, 0.4, 2);\n        }\n        \n        function clearData() {\n            dataPoints = [];\n            nextId = 1;\n            updateDataTable();\n            drawCanvas();\n        }\n        \n        function removePoint(id) {\n            dataPoints = dataPoints.filter(point => point.id !== id);\n            updateDataTable();\n            drawCanvas();\n        }\n        \n        // UI functions\n        function updateKValue() {\n            k = parseInt(document.getElementById('kValue').value);\n            document.getElementById('kValueDisplay').textContent = k;\n            drawCanvas();\n        }\n        \n        function updateDistanceMetric() {\n            distanceMetric = document.getElementById('distanceMetric').value;\n            drawCanvas();\n        }\n        \n        function toggleDecisionBoundary() {\n            showDecisionBoundary = !showDecisionBoundary;\n            drawCanvas();\n        }\n        \n        function toggleNeighbors() {\n            showNeighbors = !showNeighbors;\n            drawCanvas();\n        }\n        \n        function enableManualPlacement() {\n            manualPlacementMode = true;\n            alert('Click on the canvas to place a point. Current class: ' + \n                  document.getElementById('classToAdd').options[document.getElementById('classToAdd').selectedIndex].text);\n        }\n        \n        function classifyPoint() {\n            testPoint.x = parseFloat(document.getElementById('testX').value);\n            testPoint.y = parseFloat(document.getElementById('testY').value);\n            \n            if (dataPoints.length === 0) {\n                document.getElementById('results').innerHTML = 'No data points available';\n                return;\n            }\n            \n            const neighbors = findNearestNeighbors(testPoint.x, testPoint.y, k);\n            const predictedClass = predictClass(neighbors);\n            testPoint.class = predictedClass;\n            \n            let resultHTML = `<p>Predicted class: <strong>Class ${predictedClass}</strong></p>`;\n            resultHTML += '<p>Nearest neighbors:</p><ul>';\n            \n            neighbors.forEach(neighbor => {\n                const point = dataPoints[neighbor.index];\n                resultHTML += `<li>Point ${neighbor.index + 1}: Class ${point.class}, Distance: ${neighbor.distance.toFixed(3)}</li>`;\n            });\n            \n            resultHTML += '</ul>';\n            document.getElementById('results').innerHTML = resultHTML;\n            \n            drawCanvas();\n        }\n        \n        function addTestPointToData() {\n            if (testPoint.class === null) {\n                alert('Please classify the point first');\n                return;\n            }\n            \n            addPoint(testPoint.x, testPoint.y, testPoint.class);\n            testPoint = {x: 0.5, y: 0.5, class: null};\n            document.getElementById('testX').value = 0.5;\n            document.getElementById('testY').value = 0.5;\n            document.getElementById('results').innerHTML = '';\n        }\n        \n        function updateDataTable() {\n            const tableBody = document.getElementById('dataTableBody');\n            tableBody.innerHTML = '';\n            \n            dataPoints.forEach(point => {\n                const row = document.createElement('tr');\n                \n                row.innerHTML = `\n                    <td>${point.id}</td>\n                    <td>${point.x.toFixed(3)}</td>\n                    <td>${point.y.toFixed(3)}</td>\n                    <td>Class ${point.class}</td>\n                    <td>${testPoint ? calculateDistance(point.x, point.y, testPoint.x, testPoint.y).toFixed(3) : '-'}</td>\n                    <td><button onclick=\"removePoint(${point.id})\">Remove</button></td>\n                `;\n                \n                tableBody.appendChild(row);\n            });\n        }\n        \n        function handleCanvasClick(event) {\n            if (!manualPlacementMode) return;\n            \n            const rect = canvas.getBoundingClientRect();\n            const x = (event.clientX - rect.left) / width;\n            const y = (event.clientY - rect.top) / height;\n            const cls = parseInt(document.getElementById('classToAdd').value);\n            \n            addPoint(x, y, cls);\n            manualPlacementMode = false;\n        }\n        \n        // Initialize the app\n        init();\n    </script>\n</body>\n</html>"
  },
