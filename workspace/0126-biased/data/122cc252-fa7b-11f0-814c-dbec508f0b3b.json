    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Context Switching</title>\n    <style>\n        body {\n            background-color: #fff;\n            font-family: monospace;\n        }\n        #context {\n            width: 50%;\n            height: 50vh;\n            border: 1px solid black;\n            padding: 20px;\n            margin: 20px auto;\n        }\n        #context input, #context textarea {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n        #context button {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        #context button:hover {\n            background-color: #3e8e41;\n        }\n        #context textarea {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"context\"></div>\n    <script>\n        const context = document.getElementById('context');\n        const input = document.createElement('input');\n        const textarea = document.createElement('textarea');\n        const button = document.createElement('button');\n        const output = document.createElement('div');\n        context.appendChild(input);\n        context.appendChild(textarea);\n        context.appendChild(button);\n        context.appendChild(output);\n\n        input.value = 'Hello World!';\n        textarea.value = 'This is a test textarea.';\n        button.textContent = 'Click me!';\n        button.addEventListener('click', () => {\n            context.innerHTML = '';\n            context.appendChild(input);\n            context.appendChild(textarea);\n            context.appendChild(button);\n            context.appendChild(output);\n            input.value = 'Hello again!';\n            textarea.value = 'This is another test textarea.';\n            button.textContent = 'Click me again!';\n        });\n\n        function updateOutput() {\n            output.textContent = input.value + '\\n' + textarea.value;\n        }\n\n        setInterval(updateOutput, 1000);\n    </script>\n</body>\n</html>"
