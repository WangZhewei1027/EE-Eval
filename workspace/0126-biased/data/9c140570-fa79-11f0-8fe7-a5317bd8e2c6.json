  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Counting Sort — Interactive Demonstration</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  /* Extremely minimal styling - plain black text on white background, basic layout */\n  html,body { margin:10px; padding:0; font-family: Arial, sans-serif; color: #000; background: #fff; }\n  h1 { font-size:16px; margin:6px 0; }\n  .row { display:flex; gap:12px; align-items:flex-start; }\n  .col { display:flex; flex-direction:column; gap:8px; }\n  .controls { width:320px; }\n  .vis { flex:1; }\n  label { font-size:12px; }\n  input[type=\"text\"], input[type=\"number\"], select, textarea { font-size:12px; padding:4px; }\n  button { font-size:12px; padding:6px 8px; }\n  .box-row { display:flex; gap:4px; flex-wrap:wrap; }\n  .box { display:flex; flex-direction:column; align-items:center; justify-content:center; border:1px solid #000; padding:6px; min-width:36px; min-height:30px; font-size:12px; }\n  .small { font-size:11px; padding:4px; min-width:28px; min-height:24px; }\n  .highlight { outline:2px solid #000; }\n  .log { white-space:pre-wrap; font-size:12px; border:1px solid #000; padding:6px; height:160px; overflow:auto; }\n  .controls-section { border:1px solid #000; padding:8px; }\n  .inline { display:inline-block; margin-right:6px; }\n  .very-small { font-size:11px; }\n  .slider { width:100%; }\n  .muted { font-size:12px; }\n  .compact { padding:4px; margin:2px 0; }\n  .array-edit { display:flex; gap:6px; align-items:center; }\n  .index { font-size:10px; color:#000; }\n  input[type=range] { width:100%; }\n  .footer { margin-top:8px; font-size:12px; }\n  /* minimal responsive */\n  @media (max-width:700px) { .row { flex-direction:column; } .controls { width:100%; } }\n</style>\n</head>\n<body>\n<h1>Counting Sort — Interactive Demonstration</h1>\n\n<div class=\"row\">\n  <div class=\"controls col\">\n    <div class=\"controls-section\">\n      <div><strong>Input Array Controls</strong></div>\n      <div class=\"compact\">\n        <label>Length:\n          <input id=\"lenInput\" type=\"number\" min=\"1\" max=\"200\" value=\"10\" style=\"width:60px\" />\n        </label>\n        <label>Min value:\n          <input id=\"minInput\" type=\"number\" value=\"0\" style=\"width:60px\" />\n        </label>\n        <label>Max value:\n          <input id=\"maxInput\" type=\"number\" value=\"9\" style=\"width:60px\" />\n        </label>\n      </div>\n      <div class=\"compact\">\n        <button id=\"randomBtn\">Randomize</button>\n        <button id=\"patternsBtn\">Patterns…</button>\n        <button id=\"loadTextBtn\">Load from Text</button>\n        <button id=\"applyTextBtn\">Apply Text</button>\n      </div>\n      <div class=\"compact\">\n        <textarea id=\"arrayText\" rows=\"2\" style=\"width:100%\" placeholder=\"Comma-separated values, e.g. 3,1,4,1,5\"></textarea>\n      </div>\n      <div class=\"compact\">\n        <button id=\"addElemBtn\">Add Element</button>\n        <button id=\"removeElemBtn\">Remove Last</button>\n        <button id=\"resetBtn\">Reset All</button>\n      </div>\n    </div>\n\n    <div class=\"controls-section\">\n      <div><strong>Algorithm Options</strong></div>\n      <div class=\"compact\">\n        <label>Stable Placement:\n          <select id=\"stableMode\">\n            <option value=\"right\">Right-to-left (stable)</option>\n            <option value=\"left\">Left-to-right (unstable)</option>\n          </select>\n        </label>\n      </div>\n      <div class=\"compact\">\n        <label>Final Order:\n          <select id=\"finalOrder\">\n            <option value=\"asc\">Ascending</option>\n            <option value=\"desc\">Descending (reverse final)</option>\n          </select>\n        </label>\n      </div>\n      <div class=\"compact\">\n        <label><input id=\"autoRange\" type=\"checkbox\" /> Auto adjust range from input</label>\n      </div>\n    </div>\n\n    <div class=\"controls-section\">\n      <div><strong>Execution Controls</strong></div>\n      <div class=\"compact\">\n        <button id=\"stepBackBtn\">Step Back</button>\n        <button id=\"stepForwardBtn\">Step Forward</button>\n        <button id=\"runPauseBtn\">Run</button>\n        <button id=\"fastForwardBtn\">Fast Forward</button>\n      </div>\n      <div class=\"compact\">\n        <label>Speed:\n          <input id=\"speedRange\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\" />\n        </label>\n        <div class=\"muted very-small\">Lower = faster (ms per step)</div>\n      </div>\n      <div class=\"compact\">\n        <label>Jump to step:\n          <input id=\"jumpStep\" type=\"number\" min=\"0\" value=\"0\" style=\"width:80px\" />\n        </label>\n        <button id=\"jumpBtn\">Go</button>\n      </div>\n      <div class=\"compact\">\n        <button id=\"regenStepsBtn\">Recompute Steps</button>\n        <button id=\"exportBtn\">Export Config</button>\n        <button id=\"importBtn\">Import Config</button>\n      </div>\n    </div>\n\n    <div class=\"controls-section\">\n      <div><strong>Display Options</strong></div>\n      <div class=\"compact\">\n        <label><input id=\"showCounts\" type=\"checkbox\" checked /> Show Counts Array</label>\n        <label><input id=\"showCum\" type=\"checkbox\" checked /> Show Cumulative</label>\n        <label><input id=\"showLogs\" type=\"checkbox\" checked /> Show Logs</label>\n      </div>\n      <div class=\"compact\">\n        <label><input id=\"showIds\" type=\"checkbox\" checked /> Show Original IDs (stability)</label>\n      </div>\n    </div>\n\n    <div class=\"controls-section\">\n      <div><strong>Utility</strong></div>\n      <div class=\"compact\">\n        <button id=\"verifyBtn\">Verify Sorted</button>\n        <button id=\"checkStableBtn\">Check Stability</button>\n        <button id=\"clearLogsBtn\">Clear Logs</button>\n      </div>\n      <div class=\"compact\">\n        <textarea id=\"logs\" class=\"log\" readonly></textarea>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      Minimal UI. Use controls above to explore many interaction paths and workflows. Edit array values by clicking their boxes in the visualization.\n    </div>\n\n  </div>\n\n  <div class=\"vis col\">\n    <div>\n      <div><strong>Visualization</strong></div>\n      <div class=\"compact\">\n        <div><span class=\"inline\">Step: </span><span id=\"stepIndicator\">0 / 0</span></div>\n        <div style=\"margin-top:6px;\">\n          <div><strong>Input Array</strong></div>\n          <div id=\"inputArray\" class=\"box-row\" title=\"Click a cell to edit\"></div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <div><strong>Counts Array</strong></div>\n          <div id=\"countsArray\" class=\"box-row\"></div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <div><strong>Cumulative Counts</strong></div>\n          <div id=\"cumArray\" class=\"box-row\"></div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <div><strong>Output Array</strong></div>\n          <div id=\"outputArray\" class=\"box-row\"></div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <div><strong>Current Operation</strong></div>\n          <div id=\"currentOp\" class=\"compact\">Idle</div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <div><strong>Step Timeline</strong></div>\n          <div id=\"timeline\" class=\"log\" style=\"height:120px; overflow:auto;\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  Counting Sort Interactive Demo\n  - Many interactive controls\n  - Precomputes a sequence of snapshots (atomic steps)\n  - Allows stepping forward/back, auto-run, editing input\n  - Minimal visual styling as requested\n*/\n\n// Utility\nfunction $(id){ return document.getElementById(id); }\nfunction clamp(v, a, b){ return Math.max(a, Math.min(b, v)); }\nfunction deepCopy(obj){ return JSON.parse(JSON.stringify(obj)); }\n\n// App state\nlet state = {\n  input: [], // array of {val, id}\n  minVal: 0,\n  maxVal: 9,\n  autoRange: true,\n  stableMode: 'right', // 'right' = stable (right-to-left placement), 'left' = unstable\n  finalOrder: 'asc',\n  showCounts: true,\n  showCum: true,\n  showLogs: true,\n  showIds: true\n};\n\nlet snapshots = []; // array of snapshot objects describing each atomic step\nlet currentStep = 0;\nlet running = false;\nlet runTimer = null;\n\n// DOM references\nconst inputArrayDiv = $('inputArray');\nconst countsArrayDiv = $('countsArray');\nconst cumArrayDiv = $('cumArray');\nconst outputArrayDiv = $('outputArray');\nconst currentOpDiv = $('currentOp');\nconst timelineDiv = $('timeline');\nconst logsArea = $('logs');\nconst stepIndicator = $('stepIndicator');\n\n// Setup initial UI values\n$('lenInput').value = 10;\n$('minInput').value = 0;\n$('maxInput').value = 9;\n$('autoRange').checked = true;\n\n// Initialize with random array\nfunction initRandom() {\n  const len = parseInt($('lenInput').value) || 10;\n  const min = parseInt($('minInput').value) || 0;\n  const max = parseInt($('maxInput').value);\n  if (isNaN(max)) { state.maxVal = min + 9; $('maxInput').value = state.maxVal; }\n  generateRandomArray(len, parseInt($('minInput').value), parseInt($('maxInput').value));\n}\nfunction generateRandomArray(len, min, max) {\n  if (min > max) { [min, max] = [max, min]; $('minInput').value = min; $('maxInput').value = max; }\n  state.minVal = min; state.maxVal = max;\n  state.input = [];\n  for (let i = 0; i < len; i++) {\n    const v = Math.floor(Math.random() * (max - min + 1)) + min;\n    state.input.push({ val: v, id: i+1 });\n  }\n  recomputeAndRender();\n}\n\n// Recompute ranges from input if autoRange\nfunction adjustRangeAuto() {\n  if (!$('autoRange').checked) return;\n  if (state.input.length === 0) return;\n  let min = state.input[0].val, max = state.input[0].val;\n  state.input.forEach(it => { if (it.val < min) min = it.val; if (it.val > max) max = it.val; });\n  state.minVal = min; state.maxVal = max;\n  $('minInput').value = state.minVal;\n  $('maxInput').value = state.maxVal;\n}\n\n// Create snapshots (steps) for current input and options\nfunction buildSnapshots() {\n  snapshots = [];\n  currentOpDiv.textContent = 'Building steps...';\n\n  adjustRangeAuto();\n\n  let input = state.input.map((it, idx) => ({ val: it.val, id: it.id }));\n  const n = input.length;\n  const minVal = parseInt($('minInput').value);\n  const maxVal = parseInt($('maxInput').value);\n  const min = Math.min(minVal, maxVal);\n  const max = Math.max(minVal, maxVal);\n  // ensure min/max reflect inputs if autoRange on\n  state.minVal = min; state.maxVal = max;\n  $('minInput').value = min; $('maxInput').value = max;\n\n  const K = max - min + 1;\n  let counts = new Array(K).fill(0);\n  let cum = new Array(K).fill(0);\n  let output = new Array(n).fill(null);\n\n  // Helper to push snapshot\n  function pushSnapshot(desc, options = {}) {\n    const snap = {\n      desc: desc,\n      input: deepCopy(input),\n      counts: counts.slice(),\n      cum: cum.slice(),\n      output: deepCopy(output),\n      highlight: options.highlight || {},\n      meta: { min, max, K, n }\n    };\n    snapshots.push(snap);\n  }\n\n  // Initial state snapshot\n  pushSnapshot('Initial state');\n\n  // Phase 1: Counting each input element\n  for (let i = 0; i < n; i++) {\n    const v = input[i].val;\n    pushSnapshot('Read input[' + i + '] = ' + v, { highlight: { readIndex: i } });\n    counts[v - min]++;\n    pushSnapshot('Increment counts[' + (v - min) + '] for value ' + v, { highlight: { updatedCountIndex: v - min, readIndex: i } });\n  }\n\n  // Show counts before prefix\n  pushSnapshot('Counts computed', { highlight: { countsSnapshot: true } });\n\n  // Phase 2: Compute cumulative counts (prefix sums)\n  for (let k = 0; k < K; k++) {\n    if (k === 0) cum[k] = counts[k];\n    else cum[k] = cum[k-1] + counts[k];\n    pushSnapshot('Compute cum[' + k + '] = ' + cum[k], { highlight: { prefixIndex: k } });\n  }\n\n  pushSnapshot('Cumulative counts computed', { highlight: { cumSnapshot: true } });\n\n  // Phase 3: Distribution into output\n  // Standard stable counting sort places elements from right-to-left using cum counts\n  const stableMode = $('stableMode').value; // 'right' or 'left'\n  if (stableMode === 'right') {\n    // iterate from n-1 downto 0\n    for (let i = n - 1; i >= 0; i--) {\n      const elem = input[i];\n      const v = elem.val;\n      const idx = v - min;\n      pushSnapshot('Place element (read input[' + i + ']) value ' + v + ' (id ' + elem.id + ')', { highlight: { readIndex: i, placeIndexForValue: idx } });\n      const pos = cum[idx] - 1;\n      output[pos] = { val: elem.val, id: elem.id, fromIndex: i };\n      cum[idx]--;\n      pushSnapshot('Placed at output[' + pos + '], decrement cum[' + idx + '] to ' + cum[idx], { highlight: { outputIndex: pos, updatedCumIndex: idx } });\n    }\n  } else {\n    // left-to-right placement (unstable)\n    // We'll place elements from left-to-right using a running pointer based on cumulative counts built as prefix of counts (we need a separate pointer array)\n    // Convert cum (which currently is prefix sums) to startPositions array (first position for each value)\n    const startPos = new Array(K).fill(0);\n    startPos[0] = 0;\n    for (let k = 1; k < K; k++) startPos[k] = startPos[k-1] + counts[k-1];\n    pushSnapshot('Start positions computed for left-to-right placement', { highlight: { startPosSnapshot: true } });\n    // place left-to-right\n    for (let i = 0; i < n; i++) {\n      const elem = input[i];\n      const idx = elem.val - min;\n      pushSnapshot('Place element (read input[' + i + ']) value ' + elem.val + ' (id ' + elem.id + ')', { highlight: { readIndex: i, placeIndexForValue: idx } });\n      const pos = startPos[idx];\n      output[pos] = { val: elem.val, id: elem.id, fromIndex: i };\n      startPos[idx]++;\n      pushSnapshot('Placed at output[' + pos + '], increment startPos[' + idx + '] to ' + startPos[idx], { highlight: { outputIndex: pos, updatedStartIndex: idx } });\n    }\n  }\n\n  // Optional final reversal for descending\n  if ($('finalOrder').value === 'desc') {\n    pushSnapshot('Final reversal for descending order (will reverse output array)', { highlight: { reversing: true } });\n    output.reverse();\n    pushSnapshot('Output reversed (descending final)', { highlight: { reversed: true } });\n  } else {\n    pushSnapshot('Final output (ascending)', { highlight: { final: true } });\n  }\n\n  // Completed\n  pushSnapshot('Algorithm completed');\n\n  // Update metadata and UI indicators\n  currentStep = 0;\n  renderFromSnapshot(0);\n  updateStepIndicator();\n  log('Recomputed ' + snapshots.length + ' steps.');\n}\n\n// Rendering functions\nfunction renderFromSnapshot(index) {\n  if (snapshots.length === 0) { clearVisuals(); return; }\n  index = clamp(index, 0, snapshots.length - 1);\n  const snap = snapshots[index];\n  // Input\n  renderInputArray(snap.input, snap.highlight);\n  // Counts\n  if ($('showCounts').checked) renderCounts(snap.counts, snap.meta.min, snap.meta);\n  else countsArrayDiv.innerHTML = '(hidden)';\n  // Cum\n  if ($('showCum').checked) renderCum(snap.cum);\n  else cumArrayDiv.innerHTML = '(hidden)';\n  // Output\n  renderOutput(snap.output, snap.highlight);\n  // Current operation and timeline\n  currentOpDiv.textContent = snap.desc || '';\n  renderTimeline(index);\n  if ($('showLogs').checked) {\n    // Append snapshot desc to logs area on each render step when stepping forward; but we won't auto-append to avoid duplicates\n  }\n  updateStepIndicator();\n}\n\nfunction clearVisuals() {\n  inputArrayDiv.innerHTML = '';\n  countsArrayDiv.innerHTML = '';\n  cumArrayDiv.innerHTML = '';\n  outputArrayDiv.innerHTML = '';\n  currentOpDiv.textContent = 'Idle';\n  timelineDiv.textContent = '';\n}\n\nfunction renderInputArray(arr, highlight = {}) {\n  inputArrayDiv.innerHTML = '';\n  arr.forEach((it, idx) => {\n    const box = document.createElement('div');\n    box.className = 'box';\n    box.dataset.index = idx;\n    const valSpan = document.createElement('div');\n    valSpan.textContent = String(it.val);\n    valSpan.contentEditable = true;\n    valSpan.style.minWidth = '18px';\n    valSpan.addEventListener('blur', (e) => {\n      const newVal = parseInt(e.target.textContent);\n      if (!isNaN(newVal)) {\n        it.val = newVal;\n        // assign back to state.input (matching by id)\n        const inputIndex = state.input.findIndex(x => x.id === it.id);\n        if (inputIndex >= 0) state.input[inputIndex].val = newVal;\n        // if autoRange, adjust min/max\n        if ($('autoRange').checked) adjustRangeAuto();\n        // rebuild steps\n        buildSnapshots();\n      } else {\n        e.target.textContent = String(it.val);\n      }\n    });\n    const idSpan = document.createElement('div');\n    idSpan.className = 'small';\n    if ($('showIds').checked) idSpan.textContent = 'id:' + it.id;\n    else idSpan.textContent = '';\n    const idxSpan = document.createElement('div');\n    idxSpan.className = 'index';\n    idxSpan.textContent = idx;\n    box.appendChild(valSpan);\n    box.appendChild(idSpan);\n    box.appendChild(idxSpan);\n    // highlight readIndex\n    if (highlight && typeof highlight.readIndex !== 'undefined' && highlight.readIndex === idx) {\n      box.classList.add('highlight');\n    }\n    box.addEventListener('click', () => {\n      // focus the contentEditable to edit\n      valSpan.focus();\n      // place cursor at end\n      document.execCommand('selectAll', false, null);\n      document.getSelection().collapseToEnd();\n    });\n    inputArrayDiv.appendChild(box);\n  });\n}\n\nfunction renderCounts(counts, min, meta) {\n  countsArrayDiv.innerHTML = '';\n  counts.forEach((c, idx) => {\n    const box = document.createElement('div');\n    box.className = 'box small';\n    const label = document.createElement('div');\n    label.textContent = (min + idx);\n    label.className = 'very-small';\n    const val = document.createElement('div');\n    val.textContent = String(c);\n    box.appendChild(label);\n    box.appendChild(val);\n    countsArrayDiv.appendChild(box);\n  });\n}\n\nfunction renderCum(cum) {\n  cumArrayDiv.innerHTML = '';\n  cum.forEach((c, idx) => {\n    const box = document.createElement('div');\n    box.className = 'box small';\n    const idxSpan = document.createElement('div');\n    idxSpan.textContent = idx;\n    idxSpan.className = 'very-small';\n    const val = document.createElement('div');\n    val.textContent = String(c);\n    box.appendChild(idxSpan);\n    box.appendChild(val);\n    cumArrayDiv.appendChild(box);\n  });\n}\n\nfunction renderOutput(output, highlight = {}) {\n  outputArrayDiv.innerHTML = '';\n  output.forEach((it, idx) => {\n    const box = document.createElement('div');\n    box.className = 'box';\n    if (it === null) {\n      box.textContent = '';\n      const idxSpan = document.createElement('div');\n      idxSpan.className = 'index';\n      idxSpan.textContent = idx;\n      box.appendChild(idxSpan);\n    } else {\n      const valSpan = document.createElement('div');\n      valSpan.textContent = String(it.val);\n      const idSpan = document.createElement('div');\n      idSpan.className = 'small';\n      if ($('showIds').checked) idSpan.textContent = 'id:' + it.id;\n      const from = document.createElement('div');\n      from.className = 'index';\n      from.textContent = 'from:' + (it.fromIndex);\n      box.appendChild(valSpan);\n      box.appendChild(idSpan);\n      box.appendChild(from);\n    }\n    if (highlight && highlight.outputIndex === idx) {\n      box.classList.add('highlight');\n    }\n    outputArrayDiv.appendChild(box);\n  });\n}\n\nfunction renderTimeline(activeIndex) {\n  timelineDiv.innerHTML = '';\n  // We'll show up to 200 recent steps for performance\n  let start = Math.max(0, activeIndex - 200);\n  for (let i = start; i < snapshots.length; i++) {\n    const div = document.createElement('div');\n    div.textContent = i + ': ' + snapshots[i].desc;\n    div.style.cursor = 'pointer';\n    if (i === activeIndex) div.style.fontWeight = 'bold';\n    div.addEventListener('click', () => {\n      currentStep = i;\n      renderFromSnapshot(currentStep);\n      updateStepIndicator();\n    });\n    timelineDiv.appendChild(div);\n  }\n}\n\n// Step controls\nfunction stepForward() {\n  if (snapshots.length === 0) return;\n  if (currentStep < snapshots.length - 1) {\n    currentStep++;\n    renderFromSnapshot(currentStep);\n    if ($('showLogs').checked) appendLog('Step ' + currentStep + ': ' + snapshots[currentStep].desc);\n  }\n  updateStepIndicator();\n  if (currentStep >= snapshots.length - 1) stopRunning();\n}\n\nfunction stepBack() {\n  if (snapshots.length === 0) return;\n  if (currentStep > 0) {\n    currentStep--;\n    renderFromSnapshot(currentStep);\n    updateStepIndicator();\n  }\n}\n\nfunction jumpToStep(i) {\n  const idx = clamp(i, 0, snapshots.length - 1);\n  currentStep = idx;\n  renderFromSnapshot(currentStep);\n  if ($('showLogs').checked) appendLog('Jump to step ' + currentStep + ': ' + snapshots[currentStep].desc);\n}\n\nfunction runToggle() {\n  if (running) stopRunning();\n  else startRunning();\n}\nfunction startRunning() {\n  if (snapshots.length === 0) return;\n  running = true;\n  $('runPauseBtn').textContent = 'Pause';\n  scheduleNext();\n}\nfunction stopRunning() {\n  running = false;\n  $('runPauseBtn').textContent = 'Run';\n  if (runTimer) { clearTimeout(runTimer); runTimer = null; }\n}\nfunction scheduleNext() {\n  if (!running) return;\n  if (currentStep >= snapshots.length - 1) {\n    stopRunning();\n    return;\n  }\n  const delay = parseInt($('speedRange').value) || 400;\n  runTimer = setTimeout(() => {\n    stepForward();\n    scheduleNext();\n  }, delay);\n}\nfunction fastForward() {\n  if (snapshots.length === 0) return;\n  // Run to end quickly (no logs)\n  for (let i = currentStep + 1; i < snapshots.length; i++) {\n    currentStep = i;\n  }\n  renderFromSnapshot(currentStep);\n  stopRunning();\n}\n\n// Logging\nfunction log(msg) {\n  const time = new Date().toLocaleTimeString();\n  logsArea.value = time + ' - ' + msg + '\\n' + logsArea.value;\n}\nfunction appendLog(msg) {\n  logsArea.value = msg + '\\n' + logsArea.value;\n}\nfunction clearLogs() {\n  logsArea.value = '';\n}\n\n// UI bindings\n$('randomBtn').addEventListener('click', () => { initRandom(); });\n$('patternsBtn').addEventListener('click', () => {\n  // Simple modal pattern selector using prompt (minimal)\n  const p = prompt('Enter pattern: increasing, decreasing, few-unique, two-values', 'increasing');\n  if (!p) return;\n  const len = parseInt($('lenInput').value) || 10;\n  let arr = [];\n  if (p === 'increasing') {\n    const min = parseInt($('minInput').value);\n    for (let i = 0; i < len; i++) arr.push(min + (i % (parseInt($('maxInput').value) - min + 1)));\n  } else if (p === 'decreasing') {\n    const max = parseInt($('maxInput').value);\n    for (let i = 0; i < len; i++) arr.push(max - (i % (max - parseInt($('minInput').value) + 1)));\n  } else if (p === 'few-unique') {\n    const min = parseInt($('minInput').value);\n    const max = parseInt($('maxInput').value);\n    const choices = [];\n    for (let v = min; v <= max; v++) if (Math.random() < 0.3) choices.push(v);\n    if (choices.length === 0) for (let v = min; v <= max; v++) choices.push(v);\n    for (let i = 0; i < len; i++) arr.push(choices[Math.floor(Math.random()*choices.length)]);\n  } else if (p === 'two-values') {\n    const min = parseInt($('minInput').value);\n    const max = parseInt($('maxInput').value);\n    const a = min; const b = max;\n    for (let i = 0; i < len; i++) arr.push(Math.random() < 0.5 ? a : b);\n  } else {\n    alert('Unknown pattern');\n    return;\n  }\n  state.input = arr.map((v,i)=>({val:v,id:i+1}));\n  recomputeAndRender();\n});\n$('loadTextBtn').addEventListener('click', () => {\n  const txt = $('arrayText').value.trim();\n  if (!txt) { alert('Enter comma-separated values in the text area.'); return; }\n  const parts = txt.split(',').map(s => s.trim()).filter(s=>s.length>0);\n  const arr = parts.map((p, i) => ({ val: parseInt(p) || 0, id: i+1 }));\n  state.input = arr;\n  recomputeAndRender();\n});\n$('applyTextBtn').addEventListener('click', () => {\n  $('loadTextBtn').click();\n});\n$('addElemBtn').addEventListener('click', () => {\n  const nextId = state.input.length ? (Math.max(...state.input.map(x=>x.id))+1) : 1;\n  state.input.push({ val: state.minVal, id: nextId });\n  $('lenInput').value = state.input.length;\n  recomputeAndRender();\n});\n$('removeElemBtn').addEventListener('click', () => {\n  if (state.input.length>0) state.input.pop();\n  $('lenInput').value = state.input.length;\n  recomputeAndRender();\n});\n$('resetBtn').addEventListener('click', () => {\n  if (!confirm('Reset to default example?')) return;\n  state.input = [];\n  for (let i=0;i<10;i++) state.input.push({ val: i % 10, id: i+1 });\n  $('lenInput').value = state.input.length;\n  $('minInput').value = 0;\n  $('maxInput').value = 9;\n  $('autoRange').checked = true;\n  recomputeAndRender();\n});\n\n$('lenInput').addEventListener('change', () => {\n  const newLen = clamp(parseInt($('lenInput').value) || 1, 1, 200);\n  $('lenInput').value = newLen;\n  const cur = state.input.length;\n  if (newLen > cur) {\n    const nextId = cur ? Math.max(...state.input.map(x=>x.id))+1 : 1;\n    for (let i=0;i<newLen-cur;i++) state.input.push({ val: state.minVal, id: nextId + i });\n  } else if (newLen < cur) {\n    state.input.length = newLen;\n  }\n  recomputeAndRender();\n});\n$('minInput').addEventListener('change', () => {\n  const min = parseInt($('minInput').value);\n  const max = parseInt($('maxInput').value);\n  if (min > max) $('maxInput').value = min;\n  recomputeAndRender();\n});\n$('maxInput').addEventListener('change', () => {\n  const min = parseInt($('minInput').value);\n  const max = parseInt($('maxInput').value);\n  if (max < min) $('minInput').value = max;\n  recomputeAndRender();\n});\n\n$('stableMode').addEventListener('change', () => { recomputeAndRender(); });\n$('finalOrder').addEventListener('change', () => { recomputeAndRender(); });\n$('autoRange').addEventListener('change', () => { recomputeAndRender(); });\n\n$('showCounts').addEventListener('change', () => renderFromSnapshot(currentStep));\n$('showCum').addEventListener('change', () => renderFromSnapshot(currentStep));\n$('showLogs').addEventListener('change', () => { if (!$('showLogs').checked) clearLogs(); });\n$('showIds').addEventListener('change', () => renderFromSnapshot(currentStep));\n\n$('stepForwardBtn').addEventListener('click', () => stepForward());\n$('stepBackBtn').addEventListener('click', () => stepBack());\n$('runPauseBtn').addEventListener('click', () => runToggle());\n$('fastForwardBtn').addEventListener('click', () => { fastForward(); });\n\n$('jumpBtn').addEventListener('click', () => {\n  const v = parseInt($('jumpStep').value);\n  if (isNaN(v)) return;\n  jumpToStep(v);\n});\n\n$('regenStepsBtn').addEventListener('click', () => buildSnapshots());\n\n$('exportBtn').addEventListener('click', () => {\n  const cfg = {\n    input: state.input,\n    min: parseInt($('minInput').value),\n    max: parseInt($('maxInput').value),\n    stableMode: $('stableMode').value,\n    finalOrder: $('finalOrder').value\n  };\n  const json = JSON.stringify(cfg);\n  prompt('Config JSON (copy):', json);\n});\n$('importBtn').addEventListener('click', () => {\n  const s = prompt('Paste config JSON:');\n  if (!s) return;\n  try {\n    const cfg = JSON.parse(s);\n    if (Array.isArray(cfg.input)) state.input = cfg.input.map((it, i) => ({ val: it.val, id: it.id || i+1 }));\n    if (typeof cfg.min !== 'undefined') $('minInput').value = cfg.min;\n    if (typeof cfg.max !== 'undefined') $('maxInput').value = cfg.max;\n    if (cfg.stableMode) $('stableMode').value = cfg.stableMode;\n    if (cfg.finalOrder) $('finalOrder').value = cfg.finalOrder;\n    recomputeAndRender();\n  } catch (e) {\n    alert('Invalid JSON');\n  }\n});\n\n$('verifyBtn').addEventListener('click', () => {\n  // Verify that final output (last snapshot) is sorted according to final order\n  if (snapshots.length === 0) { alert('No snapshots built yet.'); return; }\n  const final = snapshots[snapshots.length - 1].output.filter(x => x !== null).map(x => x.val);\n  let ok = true;\n  for (let i = 1; i < final.length; i++) {\n    if ($('finalOrder').value === 'asc') {\n      if (final[i-1] > final[i]) { ok = false; break; }\n    } else {\n      if (final[i-1] < final[i]) { ok = false; break; }\n    }\n  }\n  alert(ok ? 'Output is sorted according to selected final order.' : 'Output is NOT sorted.');\n});\n\n$('checkStableBtn').addEventListener('click', () => {\n  // If original had duplicate values, verify that relative order was preserved for stable mode\n  if (snapshots.length === 0) { alert('No snapshots built yet.'); return; }\n  const initial = snapshots[0].input;\n  const final = snapshots[snapshots.length - 1].output.filter(x => x !== null);\n  const map = {};\n  initial.forEach((it, idx) => {\n    if (!map[it.val]) map[it.val] = [];\n    map[it.val].push(it.id);\n  });\n  let stable = true;\n  // For each value, final order of IDs should match initial order\n  for (const v in map) {\n    const expected = map[v];\n    const actual = final.filter(x => x.val == v).map(x => x.id);\n    // Compare sequences\n    for (let i=0;i<Math.min(expected.length, actual.length); i++) {\n      if (expected[i] !== actual[i]) { stable = false; break; }\n    }\n    if (!stable) break;\n  }\n  alert(stable ? 'Stable ordering preserved.' : 'Stability violated for at least one duplicate value.');\n});\n\n$('clearLogsBtn').addEventListener('click', () => clearLogs());\n\n// Helper to recompute steps and render\nfunction recomputeAndRender() {\n  stopRunning();\n  buildSnapshots();\n  renderFromSnapshot(currentStep);\n}\n\nfunction updateStepIndicator() {\n  stepIndicator.textContent = currentStep + ' / ' + (snapshots.length - 1);\n  $('jumpStep').value = currentStep;\n}\n\n// Start with default data\n(function bootstrap(){\n  // default input\n  state.input = [];\n  for (let i=0;i<10;i++) state.input.push({ val: Math.floor(Math.random()*10), id: i+1 });\n  recomputeAndRender();\n})();\n\n</script>\n</body>\n</html>"
