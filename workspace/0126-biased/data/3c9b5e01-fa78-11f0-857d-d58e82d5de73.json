    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Type System – Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:wght@700&family=Inter&display=swap');\n\n  :root {\n    --primary-color: #6a5acd;\n    --accent-color: #f0a500;\n    --background-dark: #0f0f1a;\n    --background-light: #1a1a2e;\n    --text-light: #e6e6fa;\n    --text-muted: #b0b0d8;\n    --shadow-glow: rgba(106, 90, 205, 0.6);\n    --shadow-accent: rgba(240, 165, 0, 0.7);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    height: 100vh;\n    background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 100%);\n    color: var(--text-light);\n    font-family: 'Inter', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    user-select: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  h1 {\n    font-family: 'Fraunces', serif;\n    font-weight: 900;\n    font-size: 3.5rem;\n    margin: 0 0 0.2em 0;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--accent-color);\n    text-shadow: 0 0 10px var(--shadow-accent), 0 0 20px var(--shadow-accent);\n    user-select: none;\n  }\n\n  h2 {\n    font-weight: 700;\n    font-size: 1.2rem;\n    color: var(--text-muted);\n    letter-spacing: 0.15em;\n    margin-bottom: 3rem;\n  }\n\n  main {\n    width: 90vw;\n    max-width: 1100px;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 2.7rem 3rem;\n    padding: 0 1rem 6rem 1rem;\n  }\n\n  /* Type Cards */\n  .type-card {\n    background: linear-gradient(145deg, #222240, #16162f);\n    border-radius: 1rem;\n    box-shadow:\n      0 4px 15px rgba(106, 90, 205, 0.3),\n      inset 0 0 12px #4b4293,\n      0 0 15px var(--shadow-glow);\n    padding: 2rem 1.8rem 3rem 1.8rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    transition: transform 0.35s ease, box-shadow 0.35s ease;\n    cursor: default;\n    position: relative;\n  }\n  .type-card:hover {\n    transform: translateY(-12px) scale(1.08);\n    box-shadow:\n      0 10px 40px var(--shadow-glow),\n      inset 0 0 25px #6a5acd,\n      0 0 35px var(--shadow-glow);\n  }\n  \n  .type-name {\n    font-family: 'Fraunces', serif;\n    font-weight: 900;\n    font-size: 2.3rem;\n    color: var(--accent-color);\n    margin-bottom: 0.5em;\n    text-shadow: 0 0 7px var(--shadow-accent);\n  }\n\n  .type-category {\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: var(--text-muted);\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n    margin-bottom: 1.7rem;\n  }\n\n  /* Circular diagram container */\n  .diagram {\n    position: relative;\n    width: 150px;\n    height: 150px;\n    border-radius: 50%;\n    background: radial-gradient(circle at center, #2e2d45 30%, #16162f 90%);\n    box-shadow: inset 0 0 15px #4b4293;\n    margin-bottom: 1.5rem;\n  }\n\n  /* Nodes in diagram */\n  .node {\n    position: absolute;\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background: var(--primary-color);\n    box-shadow:\n      0 0 12px var(--shadow-glow),\n      inset 0 0 10px #857fd1;\n    transition: background-color 0.4s ease;\n  }\n\n  .node.base {\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    background: var(--accent-color);\n    box-shadow:\n      0 0 18px var(--shadow-accent),\n      inset 0 0 14px #f0a500;\n  }\n\n  /* Position nodes around circle */\n  .node-primitive { top: 20%; left: 50%; transform: translate(-50%, -50%); }\n  .node-composite { top: 50%; left: 85%; transform: translate(-50%, -50%); }\n  .node-polymorphic { top: 80%; left: 50%; transform: translate(-50%, -50%); }\n  .node-dependent { top: 50%; left: 15%; transform: translate(-50%, -50%); }\n\n  /* Node labels */\n  .node-label {\n    position: absolute;\n    font-weight: 600;\n    color: var(--text-light);\n    font-size: 0.75rem;\n    white-space: nowrap;\n    opacity: 0.9;\n    user-select: none;\n  }\n\n  .node-label-primitive {\n    top: 10%;\n    left: 50%;\n    transform: translateX(-50%);\n  }\n  .node-label-composite {\n    top: 50%;\n    right: 0;\n    transform: translateY(-50%);\n  }\n  .node-label-polymorphic {\n    bottom: 10%;\n    left: 50%;\n    transform: translateX(-50%);\n  }\n  .node-label-dependent {\n    top: 50%;\n    left: 0;\n    transform: translateY(-50%);\n  }\n  .node-label-base {\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    font-family: 'Fraunces', serif;\n    color: var(--accent-color);\n    font-weight: 900;\n    font-size: 1rem;\n    pointer-events: none;\n    text-shadow: 0 0 5px var(--shadow-accent);\n  }\n\n  /* Description text */\n  .type-desc {\n    font-weight: 400;\n    font-size: 0.9rem;\n    color: var(--text-muted);\n    flex-grow: 1;\n    line-height: 1.45;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Container for the explanation section */\n  #explanation {\n    position: fixed;\n    bottom: 2rem;\n    width: 90vw;\n    max-width: 700px;\n    background: linear-gradient(145deg, #222240, #1c1c35);\n    border-radius: 1.4rem;\n    box-shadow:\n      0 6px 35px rgba(106, 90, 205, 0.45),\n      inset 0 0 20px #4b4293;\n    padding: 1.6rem 2rem 1.6rem 2rem;\n    font-size: 1rem;\n    color: var(--text-light);\n    font-weight: 600;\n    user-select: none;\n    line-height: 1.5;\n    pointer-events: none;\n    text-align: center;\n  }\n\n  /* Buttons in a minimal fixed top bar */\n  header {\n    position: fixed;\n    top: 1.6rem;\n    right: 2rem;\n    display: flex;\n    gap: 1.3rem;\n    z-index: 10;\n  }\n\n  button {\n    border: none;\n    outline: none;\n    background: linear-gradient(145deg, #2e2d45, #16162f);\n    color: var(--accent-color);\n    font-family: 'Fraunces', serif;\n    font-weight: 700;\n    padding: 0.55rem 1.3rem;\n    border-radius: 0.75rem;\n    box-shadow:\n      3px 3px 10px #16162f,\n      -3px -3px 8px #3b3980;\n    cursor: pointer;\n    font-size: 1rem;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n    user-select: none;\n    transition: background-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #3b3a65, #26254e);\n    box-shadow:\n      0 0 25px var(--shadow-accent),\n      inset 0 0 20px #857fd1;\n    transform: scale(1.05);\n  }\n  button:active {\n    transform: scale(0.97);\n  }\n\n  /* Fade-in animation for main content on load */\n  main, h1, h2, #explanation {\n    opacity: 0;\n    transform: translateY(15px);\n    animation-fill-mode: forwards;\n    animation-timing-function: cubic-bezier(0.23, 1, 0.32, 1);\n  }\n  h1 {\n    animation-name: fadeInUp;\n    animation-duration: 1.0s;\n    animation-delay: 0.2s;\n  }\n  h2 {\n    animation-name: fadeInUp;\n    animation-duration: 1.1s;\n    animation-delay: 0.45s;\n  }\n  main {\n    animation-name: fadeInUp;\n    animation-duration: 1.3s;\n    animation-delay: 0.7s;\n  }\n  #explanation {\n    animation-name: fadeInUp;\n    animation-duration: 0.9s;\n    animation-delay: 1.6s;\n  }\n\n  @keyframes fadeInUp {\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  /* Scrollbar hidden and smooth scroll */\n  ::-webkit-scrollbar {\n    width: 9px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #16162f;\n    border-radius: 12px;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #4b4293;\n    border-radius: 12px;\n    border: 2px solid #16162f;\n  }\n  body {\n    scroll-behavior: smooth;\n  }\n\n  /* Responsive */\n  @media (max-width: 920px) {\n    main {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 2.5rem 2rem;\n    }\n  }\n  @media (max-width: 480px) {\n    main {\n      grid-template-columns: 1fr;\n      padding-bottom: 8rem;\n    }\n    header {\n      top: 1rem;\n      right: 1rem;\n    }\n    button {\n      font-size: 0.9rem;\n      padding: 0.5rem 1rem;\n    }\n    h1 {\n      font-size: 2.6rem;\n    }\n    h2 {\n      font-size: 1rem;\n      margin-bottom: 2rem;\n    }\n    #explanation {\n      font-size: 0.93rem;\n      padding: 1rem 1.3rem;\n      bottom: 1rem;\n      max-width: 90vw;\n    }\n  }\n</style>\n</head>\n<body>\n<header aria-label=\"Control Buttons\">\n  <button id=\"btnToggleDesc\" aria-pressed=\"true\" title=\"Toggle Explanation Text\">Hide Explanation</button>\n  <button id=\"btnNextTheme\" title=\"Change Color Theme\">Theme</button>\n</header>\n<h1>Type System</h1>\n<h2>Foundations of Programming Languages</h2>\n<main role=\"list\" aria-label=\"Visual representation of Type System concepts\">\n\n  <article class=\"type-card\" role=\"listitem\" aria-labelledby=\"title-primitive\" tabindex=\"0\" aria-describedby=\"desc-primitive\">\n    <div class=\"diagram\" aria-hidden=\"true\">\n      <div class=\"node node-base\"></div>\n      <div class=\"node node-primitive\"></div>\n      <div class=\"node-label node-label-base\">Type</div>\n      <div class=\"node-label node-label-primitive\">Primitive</div>\n    </div>\n    <div class=\"type-name\" id=\"title-primitive\">Primitive Types</div>\n    <div class=\"type-category\">Basic Building Blocks</div>\n    <p class=\"type-desc\" id=\"desc-primitive\">\n      Immutable, built-in types such as <em>int</em>, <em>bool</em>, and <em>char</em> that form the foundation of data representation.\n    </p>\n  </article>\n\n  <article class=\"type-card\" role=\"listitem\" aria-labelledby=\"title-composite\" tabindex=\"0\" aria-describedby=\"desc-composite\">\n    <div class=\"diagram\" aria-hidden=\"true\">\n      <div class=\"node node-base\"></div>\n      <div class=\"node node-composite\"></div>\n      <div class=\"node-label node-label-base\">Type</div>\n      <div class=\"node-label node-label-composite\">Composite</div>\n    </div>\n    <div class=\"type-name\" id=\"title-composite\">Composite Types</div>\n    <div class=\"type-category\">Structured Aggregates</div>\n    <p class=\"type-desc\" id=\"desc-composite\">\n      Types constructed from primitives or other types, like <em>arrays</em>, <em>records</em>, and <em>tuples</em>, organizing data hierarchically.\n    </p>\n  </article>\n\n  <article class=\"type-card\" role=\"listitem\" aria-labelledby=\"title-polymorphic\" tabindex=\"0\" aria-describedby=\"desc-polymorphic\">\n    <div class=\"diagram\" aria-hidden=\"true\">\n      <div class=\"node node-base\"></div>\n      <div class=\"node node-polymorphic\"></div>\n      <div class=\"node-label node-label-base\">Type</div>\n      <div class=\"node-label node-label-polymorphic\">Polymorphic</div>\n    </div>\n    <div class=\"type-name\" id=\"title-polymorphic\">Polymorphic Types</div>\n    <div class=\"type-category\">Generalized Abstraction</div>\n    <p class=\"type-desc\" id=\"desc-polymorphic\">\n      Types parameterized by other types, enabling generic programming and code reuse, such as <em>generics</em> or <em>templates</em>.\n    </p>\n  </article>\n\n  <article class=\"type-card\" role=\"listitem\" aria-labelledby=\"title-dependent\" tabindex=\"0\" aria-describedby=\"desc-dependent\">\n    <div class=\"diagram\" aria-hidden=\"true\">\n      <div class=\"node node-base\"></div>\n      <div class=\"node node-dependent\"></div>\n      <div class=\"node-label node-label-base\">Type</div>\n      <div class=\"node-label node-label-dependent\">Dependent</div>\n    </div>\n    <div class=\"type-name\" id=\"title-dependent\">Dependent Types</div>\n    <div class=\"type-category\">Value-Indexed Types</div>\n    <p class=\"type-desc\" id=\"desc-dependent\">\n      Types that depend on values, allowing for more expressive and precise type information, often used in theorem proving and advanced type systems.\n    </p>\n  </article>\n\n</main>\n\n<div id=\"explanation\" role=\"note\" aria-live=\"polite\">\n  A <strong>Type System</strong> is a set of rules that assigns a property called a <em>type</em> to the various constructs in a computer program, such as variables, expressions, functions, or modules. Types classify data and help prevent errors by constraining operations to valid combinations. From <em>primitive</em> to <em>dependent</em> types, the system provides a framework for both safety and expressiveness in programming languages.\n</div>\n\n<script>\n(function(){\n  const btnToggleDesc = document.getElementById('btnToggleDesc');\n  const explanation = document.getElementById('explanation');\n  const btnNextTheme = document.getElementById('btnNextTheme');\n\n  // Simple toggle explanation visibility with fade\n  btnToggleDesc.addEventListener('click', () => {\n    if (explanation.style.opacity === '0' || explanation.style.display === 'none') {\n      explanation.style.display = 'block';\n      setTimeout(() => explanation.style.opacity = '1', 10);\n      btnToggleDesc.textContent = 'Hide Explanation';\n      btnToggleDesc.setAttribute('aria-pressed', 'true');\n    } else {\n      explanation.style.opacity = '0';\n      explanation.addEventListener('transitionend', () => {\n        if (explanation.style.opacity === '0') explanation.style.display = 'none';\n      }, { once: true });\n      btnToggleDesc.textContent = 'Show Explanation';\n      btnToggleDesc.setAttribute('aria-pressed', 'false');\n    }\n  });\n\n  // Define a few color themes to cycle through\n  const themes = [\n    {\n      '--primary-color': '#6a5acd',\n      '--accent-color': '#f0a500',\n      '--background-dark': '#0f0f1a',\n      '--background-light': '#1a1a2e',\n      '--text-light': '#e6e6fa',\n      '--text-muted': '#b0b0d8',\n      '--shadow-glow': 'rgba(106, 90, 205, 0.6)',\n      '--shadow-accent': 'rgba(240, 165, 0, 0.7)'\n    },\n    {\n      '--primary-color': '#57c7d4',\n      '--accent-color': '#f95759',\n      '--background-dark': '#081c24',\n      '--background-light': '#11303d',\n      '--text-light': '#e0f7fa',\n      '--text-muted': '#a0bfc9',\n      '--shadow-glow': 'rgba(87, 199, 212, 0.6)',\n      '--shadow-accent': 'rgba(249, 87, 89, 0.7)'\n    },\n    {\n      '--primary-color': '#f72585',\n      '--accent-color': '#720026',\n      '--background-dark': '#2c003e',\n      '--background-light': '#3e004f',\n      '--text-light': '#fce7f3',\n      '--text-muted': '#d5b0c7',\n      '--shadow-glow': 'rgba(247, 37, 133, 0.6)',\n      '--shadow-accent': 'rgba(114, 0, 38, 0.7)'\n    }\n  ];\n\n  let currentTheme = 0;\n\n  // Smooth theme change by updating CSS variables\n  btnNextTheme.addEventListener('click', () => {\n    currentTheme = (currentTheme + 1) % themes.length;\n    const theme = themes[currentTheme];\n    const root = document.documentElement;\n\n    // Animate color variable changes for subtle transitions\n    // We'll update in small steps with requestAnimationFrame\n    const duration = 600;\n    const fps = 60;\n    let frame = 0;\n\n    const getColorChannels = (c) => {\n      if (c.startsWith('rgba')) {\n        const m = c.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+),?\\s*([\\d\\.]+)?\\)/);\n        return m ? [parseInt(m[1]), parseInt(m[2]), parseInt(m[3]), parseFloat(m[4]||1)] : null;\n      }\n      if (c.startsWith('#')) {\n        let r=0,g=0,b=0,a=1;\n        if(c.length===7){\n          r = parseInt(c.slice(1,3),16);\n          g = parseInt(c.slice(3,5),16);\n          b = parseInt(c.slice(5,7),16);\n        }\n        return [r,g,b,a];\n      }\n      return null;\n    };\n    const lerp = (a,b,t) => a+(b - a)*t;\n\n    // Read current colors\n    const currentColors = {};\n    for (const key in theme) {\n      const v = getComputedStyle(root).getPropertyValue(key).trim();\n      currentColors[key] = getColorChannels(v) || [0,0,0,1];\n    }\n    const targetColors = {};\n    for (const key in theme) {\n      targetColors[key] = getColorChannels(theme[key]) || [0,0,0,1];\n    }\n\n    function animate() {\n      frame++;\n      const t = Math.min(frame / (duration/(1000/fps)), 1);\n      for (const key in theme) {\n        const c0 = currentColors[key];\n        const c1 = targetColors[key];\n        if(!c0 || !c1) continue;\n        const r = Math.round(lerp(c0[0], c1[0], t));\n        const g = Math.round(lerp(c0[1], c1[1], t));\n        const b = Math.round(lerp(c0[2], c1[2], t));\n        const a = lerp(c0[3], c1[3], t).toFixed(3);\n        if (a < 1) {\n          root.style.setProperty(key, `rgba(${r},${g},${b},${a})`);\n        } else {\n          root.style.setProperty(key, `rgb(${r},${g},${b})`);\n        }\n      }\n      if (t < 1) {\n        requestAnimationFrame(animate);\n      }\n    }\n    animate();\n  });\n\n\n  // On load: ensure explanation visible\n  window.addEventListener('load', () => {\n    explanation.style.display = 'block';\n    explanation.style.opacity = '1';\n  });\n})();\n</script>\n</body>\n</html>"
  },
