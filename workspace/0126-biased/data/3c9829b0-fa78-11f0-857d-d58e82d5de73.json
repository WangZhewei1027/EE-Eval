    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>A* Search Visualization — Elegant Demo</title>\n<style>\n  /* Fonts & base */\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display&display=swap');\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body, html {\n    margin: 0; padding: 0; height: 100%;\n    background: linear-gradient(135deg, #0a1128 0%, #001f54 60%, #003566 100%);\n    color: #e0e6f0;\n    font-family: 'Montserrat', sans-serif;\n    overflow: hidden;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 2.8rem;\n    text-align: center;\n    margin: 1.5rem 0 0.25rem 0;\n    letter-spacing: 0.12em;\n    color: #f0f5ff;\n    user-select: none;\n    text-shadow: 0 0 12px #97caffbb;\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.3rem;\n    color: #bfcde7dd;\n    text-align: center;\n    margin: 0 0 1.8rem 0;\n    letter-spacing: 0.1em;\n  }\n\n  #container {\n    width: 540px;\n    max-width: 90vw;\n    margin: 0 auto 3rem auto;\n    padding: 0;\n    border-radius: 20px;\n    background: rgba(20,35,72,0.6);\n    box-shadow:\n      inset 0 0 20px #0b2a57,\n      0 14px 30px rgba(1, 54, 105, 0.9);\n  }\n\n  /* Grid container */\n  #grid {\n    display: grid;\n    grid-template-columns: repeat(18, 28px);\n    grid-template-rows: repeat(12, 28px);\n    gap: 5px;\n    padding: 18px 18px 24px 18px;\n    border-radius: 0 0 20px 20px;\n    background: #07182c88;\n  }\n\n  /* Cell base */\n  .cell {\n    width: 28px; height: 28px;\n    border-radius: 6px;\n    position: relative;\n    user-select: none;\n    cursor: default;\n    box-shadow:\n      inset 0 0 8px #0f3a82,\n      inset 0 -2px 6px #1b5cc6aa,\n      0 3px 5px #0d1f3b90;\n    transition:\n      background-color 0.3s cubic-bezier(.4,0,.2,1),\n      box-shadow 0.5s cubic-bezier(.4,0,.2,1),\n      transform 0.35s ease,\n      filter 0.4s ease;\n  }\n\n  /* Terrain types */\n  .cell.empty {\n    background-color: #09203f;\n  }\n\n  .cell.wall {\n    background: #0c1729;\n    box-shadow:\n      inset 0 0 7px #2c2347,\n      0 2px 10px #482465aa;\n  }\n\n  .cell.start {\n    background: linear-gradient(145deg, #08f7fe 0%, #00f2fe 100%);\n    box-shadow:\n      0 0 18px 4px #00f2fe,\n      inset 0 0 10px 3px #08f7fe;\n    position: relative;\n    overflow: visible;\n    transform-origin: center;\n    animation: pulseStart 2.5s ease-in-out infinite;\n  }\n\n  .cell.end {\n    background: linear-gradient(45deg, #ff416c 0%, #ff4b2b 100%);\n    box-shadow:\n      0 0 18px 4px #ff4b2b,\n      inset 0 0 15px 5px #ff416c;\n    position: relative;\n    overflow: visible;\n    transform-origin: center;\n    animation: pulseEnd 2.5s ease-in-out infinite;\n  }\n\n  /* Visited */\n  .cell.visited {\n    background-color: #16407b;\n    box-shadow: inset 0 0 10px #235393aa;\n    filter: brightness(1.15);\n    transform: scale(1.05);\n  }\n\n  /* Frontier cells (open set) */\n  .cell.frontier {\n    background: linear-gradient(135deg, #3877d6cc 25%, #82aaffdd 100%);\n    box-shadow:\n      0 0 10px 3px #2c68d437,\n      inset 0 0 12px 3px #5c8edeaa;\n    transform: scale(1.1);\n  }\n\n  /* Path cells */\n  .cell.path {\n    background: linear-gradient(135deg, #ff6519cc 30%, #ffd16cca 90%);\n    box-shadow:\n      0 0 14px 5px #ff8a1c88,\n      inset 0 0 18px 5px #ffa33cbb;\n    transform: scale(1.15);\n    filter: drop-shadow(0 0 6px #ffa33daa);\n  }\n\n  /* Text inside cells - smooth transparent style */\n  .cell span {\n    position: absolute;\n    width: 100%; height: 100%;\n    top: 0; left: 0;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    font-size: 12px;\n    font-weight: 600;\n    text-shadow:\n      0 0 4px #000000bb;\n    color: #e3e9fccc;\n    user-select: none;\n    pointer-events: none;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  /* Button panel */\n  #buttons {\n    display: flex;\n    justify-content: center;\n    gap: 18px;\n    margin: 0 0 1.8rem 0;\n  }\n  button {\n    background: linear-gradient(145deg, #2c88ff, #004bbb);\n    border: none;\n    outline: none;\n    color: white;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1rem;\n    padding: 0.85rem 2rem;\n    border-radius: 14px;\n    cursor: pointer;\n    box-shadow:\n      0 6px 12px rgba(0,75,187,0.8),\n      inset 0 -4px 6px #00256f;\n    transition: background-color 0.3s ease, box-shadow 0.3s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #3f9dff, #1d5fce);\n    box-shadow:\n      0 10px 20px rgba(0,118,255,0.7),\n      inset 0 -5px 8px #004fbd;\n  }\n  button:active {\n    background: #004bbb;\n    box-shadow:\n      inset 0 3px 5px #00368a;\n    transform: translateY(2px);\n  }\n\n  /* Animations */\n\n  @keyframes pulseStart {\n    0%, 100% {\n      transform: scale(1);\n      box-shadow:\n        0 0 18px 4px #00f2fe,\n        inset 0 0 10px 3px #08f7fe;\n    }\n    50% {\n      transform: scale(1.1);\n      box-shadow:\n        0 0 26px 8px #00f2fecc,\n        inset 0 0 15px 5px #08f7fecc;\n    }\n  }\n\n  @keyframes pulseEnd {\n    0%, 100% {\n      transform: scale(1);\n      box-shadow:\n        0 0 18px 4px #ff4b2b,\n        inset 0 0 15px 5px #ff416c;\n    }\n    50% {\n      transform: scale(1.12);\n      box-shadow:\n        0 0 28px 9px #ff4b2bcc,\n        inset 0 0 20px 8px #ff416ccc;\n    }\n  }\n\n  /* Footer - small note */\n  #footer {\n    font-size: 0.8rem;\n    text-align: center;\n    color: #6b85b9bb;\n    font-style: italic;\n    letter-spacing: 0.12em;\n    margin-bottom: 2rem;\n    user-select: none;\n  }\n\n</style>\n</head>\n<body>\n  <h1>A* SEARCH</h1>\n  <h2>Tracing the shortest path with heuristic guidance</h2>\n\n  <section id=\"container\" aria-label=\"A star search grid visualization\">\n    <div id=\"grid\" aria-live=\"polite\" aria-relevant=\"additions removals\">\n      <!-- grid cells generated by JS -->\n    </div>\n  </section>\n\n  <div id=\"buttons\" role=\"region\" aria-label=\"Control buttons\">\n    <button id=\"runBtn\" aria-label=\"Run A star search animation\">Run Search</button>\n    <button id=\"resetBtn\" aria-label=\"Reset grid to initial state\">Reset</button>\n  </div>\n\n  <div id=\"footer\">Visualization by GPT &mdash; Elegant A* Search Demo</div>\n\n<script>\n(() => {\n\n  // Configuration of grid size\n  const COLS = 18;\n  const ROWS = 12;\n\n  // Node types\n  const TYPE_EMPTY = 'empty';\n  const TYPE_WALL = 'wall';\n  const TYPE_START = 'start';\n  const TYPE_END = 'end';\n\n  // Reference to container\n  const gridEl = document.getElementById('grid');\n  const runBtn = document.getElementById('runBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Grid data: each node has { x, y, f, g, h, type, neighbors, previous }\n  // We'll build this structure on start.\n  let grid = [];\n\n  // Start and end nodes\n  let startNode = null;\n  let endNode = null;\n\n  // Animation variables\n  let animationQueue = [];\n  let animationFrameId = null;\n  let animationCancelled = false;\n\n  // Heuristic function (Manhattan)\n  function heuristic(a, b) {\n    return Math.abs(a.x - b.x) + Math.abs(a.y - b.y);\n  }\n\n  // Initialize grid data and DOM\n  function initGrid() {\n    grid = [];\n    gridEl.innerHTML = '';\n\n    // Create nodes with base properties\n    for(let y=0; y<ROWS; y++) {\n      for(let x=0; x<COLS; x++) {\n        let node = {\n          x, y,\n          f: 0,\n          g: 0,\n          h: 0,\n          type: TYPE_EMPTY,\n          neighbors: [],\n          previous: null,\n          el: null,\n        };\n        grid.push(node);\n      }\n    }\n\n    // Assign neighbors (only 4 directions)\n    grid.forEach(n => {\n      const neighbors = [];\n      const {x, y} = n;\n      if (y > 0) neighbors.push(getNode(x, y-1));\n      if (y < ROWS-1) neighbors.push(getNode(x, y+1));\n      if (x > 0) neighbors.push(getNode(x-1, y));\n      if (x < COLS-1) neighbors.push(getNode(x+1, y));\n      n.neighbors = neighbors;\n    });\n\n    // Walls generation: some aesthetic pattern for elegance\n    // Pattern: vertical stripes + random dots with glow effect\n    const wallPositions = new Set();\n\n    // Vertical stripes (cool blue shadows)\n    for(let x=3; x<COLS; x+=5) {\n      for(let y=1; y<ROWS-1; y++) {\n        wallPositions.add(`${x},${y}`);\n      }\n    }\n    // Random \"floating\" walls with soft glow, about a dozen\n    for(let i=0; i<14; i++) {\n      let wx = 2 + Math.floor(Math.random()*(COLS-4));\n      let wy = 1 + Math.floor(Math.random()*(ROWS-2));\n      wallPositions.add(`${wx},${wy}`);\n    }\n\n    // Assign walls\n    grid.forEach(n => {\n      if (wallPositions.has(`${n.x},${n.y}`)) n.type = TYPE_WALL;\n    });\n\n    // Define fixed start and end - symmetric and elegant positions\n    startNode = getNode(1, Math.floor(ROWS/2));\n    endNode = getNode(COLS-2, Math.floor(ROWS/2));\n\n    startNode.type = TYPE_START;\n    endNode.type = TYPE_END;\n\n    // Create DOM elements for each node, with data attributes for reference and accessibility\n    grid.forEach(node => {\n      const cell = document.createElement('div');\n      cell.className = `cell ${node.type}`;\n      cell.setAttribute('data-x', node.x);\n      cell.setAttribute('data-y', node.y);\n      cell.setAttribute('aria-label', node.type === TYPE_START ? \"Start node\" :\n                                       node.type === TYPE_END ? \"End node\" :\n                                       node.type === TYPE_WALL ? \"Wall\" :\n                                       \"Empty node\");\n      if(node.type === TYPE_START) cell.setAttribute('aria-current', 'step');\n      node.el = cell;\n\n      // Optional: show coordinates unobtrusively on hover\n      // (Commented out for cleaner UI)\n      // let coordSpan = document.createElement('span');\n      // coordSpan.textContent = `${node.x},${node.y}`;\n      // cell.appendChild(coordSpan);\n\n      gridEl.appendChild(cell);\n    });\n  }\n\n  // Get node by x,y coordinates\n  function getNode(x, y) {\n    if (x < 0 || y < 0 || x >= COLS || y >= ROWS) return null;\n    return grid[y*COLS + x];\n  }\n\n  // Core A* Search algorithm implementation\n  // Returns an animation queue of steps:\n  // Each step: { type: 'visit' | 'frontier' | 'path', node }\n  function aStar() {\n    const openSet = [];\n    const closedSet = new Set();\n\n    openSet.push(startNode);\n\n    // Initialize costs\n    grid.forEach(n => {\n      n.f = Infinity;\n      n.g = Infinity;\n      n.h = 0;\n      n.previous = null;\n    });\n    startNode.g = 0;\n    startNode.h = heuristic(startNode, endNode);\n    startNode.f = startNode.h;\n\n    const animationSteps = [];\n\n    while (openSet.length > 0) {\n      // Sort openSet by f value (lowest first)\n      openSet.sort((a,b) => a.f - b.f);\n      let current = openSet.shift();\n\n      // Add current to closedSet\n      closedSet.add(current);\n\n      // Mark node as visited\n      if(current !== startNode && current !== endNode) animationSteps.push({type:'visited',node:current});\n\n      // Found the end\n      if(current === endNode) {\n        // Trace path backward\n        let pathNode = current;\n        const pathNodes = [];\n        while(pathNode.previous && pathNode !== startNode) {\n          pathNodes.push(pathNode);\n          pathNode = pathNode.previous;\n        }\n        pathNodes.reverse();\n\n        for(const pn of pathNodes) {\n          animationSteps.push({type:'path',node:pn});\n        }\n        return animationSteps;\n      }\n\n      // Check neighbors\n      for(const neighbor of current.neighbors) {\n        if (neighbor.type === TYPE_WALL || closedSet.has(neighbor)) continue;\n        let tentative_g = current.g + 1; // cost between nodes is 1\n\n        if (tentative_g < neighbor.g) {\n          neighbor.previous = current;\n          neighbor.g = tentative_g;\n          neighbor.h = heuristic(neighbor, endNode);\n          neighbor.f = neighbor.g + neighbor.h;\n          if(!openSet.includes(neighbor)) {\n            openSet.push(neighbor);\n            if(neighbor !== endNode && neighbor !== startNode) animationSteps.push({type:'frontier',node:neighbor});\n          }\n        }\n      }\n    }\n    // No path found - return empty path but still return steps as visited as much as explored\n    return animationSteps;\n  }\n\n  // Animate the algorithm steps\n  function animate(steps) {\n    let i = 0;\n\n    animationCancelled = false;\n\n    function nextStep() {\n      if(animationCancelled) return;\n\n      if(i >= steps.length) {\n        runBtn.disabled = false;\n        resetBtn.disabled = false;\n        runBtn.textContent = \"Run Search\";\n        return;\n      }\n\n      const {type, node} = steps[i];\n      i++;\n\n      switch(type) {\n        case 'visited':\n          node.el.classList.add('visited');\n          node.el.classList.remove('frontier');\n          break;\n        case 'frontier':\n          node.el.classList.add('frontier');\n          break;\n        case 'path':\n          node.el.classList.add('path');\n          break;\n      }\n      // Animate next step after delay\n      animationFrameId = setTimeout(nextStep, 65);\n    }\n\n    nextStep();\n  }\n\n  // Reset visual states except walls/start/end\n  function resetVisuals() {\n    animationCancelled = true;\n    if(animationFrameId) window.clearTimeout(animationFrameId);\n\n    grid.forEach(node => {\n      node.el.classList.remove('visited','frontier','path');\n      // Reset walls, start, end remain with respective classes\n      if(node.type === TYPE_WALL) {\n        node.el.className = 'cell wall';\n      } else if(node === startNode) {\n        node.el.className = 'cell start';\n      } else if(node === endNode) {\n        node.el.className = 'cell end';\n      } else {\n        node.el.className = 'cell empty';\n      }\n      node.previous = null;\n      node.f = Infinity;\n      node.g = Infinity;\n      node.h = 0;\n    });\n  }\n\n  // Handle Run Search button click\n  runBtn.addEventListener('click', () => {\n    runBtn.disabled = true;\n    resetBtn.disabled = true;\n    runBtn.textContent = \"Searching...\";\n    resetVisuals();\n\n    // Small delay to let UI update before calculation\n    setTimeout(() => {\n      const steps = aStar();\n      animate(steps);\n    }, 300);\n  });\n\n  // Handle Reset button click\n  resetBtn.addEventListener('click', () => {\n    resetVisuals();\n  });\n\n  // Initialization on load\n  initGrid();\n\n})();\n</script>\n</body>\n</html>"
  },
