  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Exponential Search Interactive Playground</title>\n  <style>\n    /* Intentionally minimal/empty — interface should remain plain and basic */\n  </style>\n</head>\n<body>\n  <h1>Exponential Search - Interactive Playground</h1>\n\n  <p>Plain interface for deep, interactive exploration of Exponential Search. Use the controls below to create arrays, tune execution, step through the algorithm, set breakpoints, and explore alternative behaviors. Everything is textual and minimal.</p>\n\n  <!-- Array controls -->\n  <fieldset>\n    <legend>Array Management</legend>\n    <label>Array (comma-separated integers):</label><br>\n    <input id=\"arrayInput\" type=\"text\" size=\"80\" value=\"1,2,4,8,16,32,64,128,256,512\"><br>\n    <button id=\"applyArrayBtn\">Apply Array</button>\n    <button id=\"randomSortedBtn\">Generate Random Sorted</button>\n    <label>Size: <input id=\"sizeSlider\" type=\"range\" min=\"1\" max=\"200\" value=\"10\"></label>\n    <span id=\"sizeLabel\">10</span>\n    <label>Max value: <input id=\"maxVal\" type=\"number\" value=\"1000\" style=\"width:80px\"></label>\n    <button id=\"uniqueBtn\">Ensure Unique & Sort</button>\n    <button id=\"shuffleBtn\">Shuffle (makes unsorted)</button>\n    <button id=\"sortBtn\">Sort</button>\n    <button id=\"clearArrayBtn\">Clear</button>\n    <p>\n      <label><input type=\"checkbox\" id=\"allowUnsorted\"> Allow unsorted array (Exponential Search will auto-sort before running by default)</label>\n    </p>\n  </fieldset>\n\n  <!-- Target controls -->\n  <fieldset>\n    <legend>Target & Comparator</legend>\n    <label>Target value: <input id=\"targetInput\" type=\"text\" value=\"32\" style=\"width:120px\"></label>\n    <button id=\"chooseExisting\">Choose from Array</button>\n    <select id=\"existingValues\"></select>\n    <button id=\"randomTargetBtn\">Random Target</button>\n    <p>\n      <label>Comparator (JS expression, use a and b):</label><br>\n      <input id=\"comparatorExpr\" type=\"text\" size=\"80\" value=\"(a - b)\">\n      <button id=\"applyComparatorBtn\">Apply Comparator</button>\n      <span id=\"comparatorStatus\"></span>\n    </p>\n  </fieldset>\n\n  <!-- Execution controls -->\n  <fieldset>\n    <legend>Execution Controls</legend>\n    <button id=\"initBtn\">Initialize</button>\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"stepBackBtn\">Step Back</button>\n    <button id=\"runBtn\">Run</button>\n    <button id=\"pauseBtn\">Pause</button>\n    <button id=\"runToEndBtn\">Run to End</button>\n    <button id=\"resetBtn\">Reset</button>\n    <p>\n      <label>Speed (ms per step): <input id=\"speedRange\" type=\"range\" min=\"0\" max=\"2000\" value=\"300\"></label>\n      <span id=\"speedLabel\">300 ms</span>\n    </p>\n    <p>\n      <label><input id=\"autoExplain\" type=\"checkbox\"> Auto-explain each step</label>\n      <label><input id=\"detailedSteps\" type=\"checkbox\" checked> Detailed step granularity</label>\n    </p>\n    <p>\n      <label>Breakpoint - comparisons >= </label><input id=\"breakpointComp\" type=\"number\" value=\"\" style=\"width:80px\">\n      <button id=\"setBreakComp\">Set</button>\n      <label>Breakpoint - index hit: </label><input id=\"breakpointIndex\" type=\"number\" value=\"\" style=\"width:80px\">\n      <button id=\"setBreakIndex\">Set</button>\n      <button id=\"clearBreakpoints\">Clear Breakpoints</button>\n    </p>\n    <p>\n      <label>Step granularity:\n        <select id=\"granularitySelect\">\n          <option value=\"comparison\">Comparison-level (each comparison)</option>\n          <option value=\"probe\">Probe-level (each probe/doubling step)</option>\n        </select>\n      </label>\n    </p>\n    <p>\n      <button id=\"stepIntoBinaryBtn\">Step Into Binary Phase</button>\n      <button id=\"autoBinaryBtn\">Auto-choose binary bounds</button>\n    </p>\n  </fieldset>\n\n  <!-- Visualization / display -->\n  <fieldset>\n    <legend>Live State & Visualization (textual)</legend>\n    <div>\n      <button id=\"toggleArrayView\">Toggle compact/annotated view</button>\n      <button id=\"jumpIndexBtn\">Jump to index</button>\n      <input id=\"jumpIndexInput\" type=\"number\" style=\"width:80px\">\n    </div>\n    <pre id=\"arrayView\" style=\"white-space:pre-wrap;\"></pre>\n\n    <p>Current Phase: <span id=\"phase\">-</span></p>\n    <p>Pointers & Indices: <span id=\"pointers\">-</span></p>\n    <p>Metrics: Comparisons: <span id=\"comparisons\">0</span>,\n       Accesses: <span id=\"accesses\">0</span>,\n       Steps: <span id=\"stepsCount\">0</span>\n    </p>\n    <p>Found Index: <span id=\"foundIndex\">-</span></p>\n    <p>Hints: <span id=\"hints\">-</span></p>\n  </fieldset>\n\n  <!-- Pseudocode and explanation -->\n  <fieldset>\n    <legend>Pseudocode / Explanation</legend>\n    <pre id=\"pseudocode\" style=\"white-space:pre-wrap;\">\n1. If array[0] == target return 0\n2. i = 1\n3. while i < n and array[i] < target:\n4.   i = i * 2\n5. left = i/2, right = min(i, n-1)\n6. perform binary search on array[left..right]\n    </pre>\n    <button id=\"showCodeBtn\">Show JS Implementation</button>\n    <pre id=\"codeView\" style=\"white-space:pre-wrap; display:none;\"></pre>\n    <p><button id=\"explainStepBtn\">Explain Current Step</button></p>\n    <pre id=\"explanation\" style=\"white-space:pre-wrap;\"></pre>\n  </fieldset>\n\n  <!-- History/tracing -->\n  <fieldset>\n    <legend>History / Trace</legend>\n    <p>\n      <button id=\"exportSessionBtn\">Export Session (JSON)</button>\n      <button id=\"importSessionBtn\">Import Session</button>\n      <input id=\"importSessionArea\" type=\"text\" size=\"80\" placeholder=\"Paste session JSON here\">\n    </p>\n    <div>\n      <button id=\"prevHistoryBtn\">Prev</button>\n      <button id=\"nextHistoryBtn\">Next</button>\n      Current Snapshot: <span id=\"historyIndex\">0</span> / <span id=\"historyLen\">0</span>\n    </div>\n    <pre id=\"traceLog\" style=\"white-space:pre-wrap; max-height:200px; overflow:auto;\"></pre>\n    <p>\n      <button id=\"clearTraceBtn\">Clear Trace</button>\n    </p>\n  </fieldset>\n\n  <!-- Comparison with Linear Search -->\n  <fieldset>\n    <legend>Comparison: Linear Search</legend>\n    <p>\n      <label><input id=\"runLinearNow\" type=\"checkbox\"> Run linear search concurrently (instant)</label>\n      <button id=\"runLinearBtn\">Run Linear Search Now</button>\n    </p>\n    <pre id=\"linearResult\" style=\"white-space:pre-wrap;\"></pre>\n  </fieldset>\n\n  <hr>\n\n  <p>\n    Note: Interface is intentionally plain. Controls allow deep exploration paths: generating different arrays, editing comparator, inserting breakpoints, stepping granularly, rewinding history, exporting sessions, comparing linear vs exponential search, and more.\n  </p>\n\n  <script>\n    // Minimal global styles logic omitted - textual UI only.\n\n    // State and configuration\n    let state = {\n      array: [],\n      n: 0,\n      target: null,\n      comparator: (a,b)=>a-b,\n      snapshots: [], // history of states\n      snapIndex: -1,\n      running: false,\n      runTimer: null,\n      speed: 300,\n      phase: 'idle', // idle, init, doubling, binary, done\n      // doubling phase fields\n      i: 1,\n      prev: 0,\n      left: 0,\n      right: 0,\n      mid: null,\n      foundIndex: -1,\n      comparisons: 0,\n      accesses: 0,\n      steps: 0,\n      // breakpoints\n      breakComp: null,\n      breakIndex: null,\n      // config\n      granularity: 'comparison',\n      detailed: true,\n      allowUnsorted: false,\n      compactView: false\n    };\n\n    // DOM elements\n    const arrayInput = document.getElementById('arrayInput');\n    const applyArrayBtn = document.getElementById('applyArrayBtn');\n    const randomSortedBtn = document.getElementById('randomSortedBtn');\n    const sizeSlider = document.getElementById('sizeSlider');\n    const sizeLabel = document.getElementById('sizeLabel');\n    const maxVal = document.getElementById('maxVal');\n    const uniqueBtn = document.getElementById('uniqueBtn');\n    const shuffleBtn = document.getElementById('shuffleBtn');\n    const sortBtn = document.getElementById('sortBtn');\n    const clearArrayBtn = document.getElementById('clearArrayBtn');\n    const allowUnsorted = document.getElementById('allowUnsorted');\n\n    const targetInput = document.getElementById('targetInput');\n    const chooseExisting = document.getElementById('chooseExisting');\n    const existingValues = document.getElementById('existingValues');\n    const randomTargetBtn = document.getElementById('randomTargetBtn');\n    const comparatorExpr = document.getElementById('comparatorExpr');\n    const applyComparatorBtn = document.getElementById('applyComparatorBtn');\n    const comparatorStatus = document.getElementById('comparatorStatus');\n\n    const initBtn = document.getElementById('initBtn');\n    const stepBtn = document.getElementById('stepBtn');\n    const stepBackBtn = document.getElementById('stepBackBtn');\n    const runBtn = document.getElementById('runBtn');\n    const pauseBtn = document.getElementById('pauseBtn');\n    const runToEndBtn = document.getElementById('runToEndBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const speedRange = document.getElementById('speedRange');\n    const speedLabel = document.getElementById('speedLabel');\n    const autoExplain = document.getElementById('autoExplain');\n    const detailedSteps = document.getElementById('detailedSteps');\n    const breakpointComp = document.getElementById('breakpointComp');\n    const setBreakComp = document.getElementById('setBreakComp');\n    const breakpointIndex = document.getElementById('breakpointIndex');\n    const setBreakIndex = document.getElementById('setBreakIndex');\n    const clearBreakpoints = document.getElementById('clearBreakpoints');\n    const granularitySelect = document.getElementById('granularitySelect');\n    const stepIntoBinaryBtn = document.getElementById('stepIntoBinaryBtn');\n    const autoBinaryBtn = document.getElementById('autoBinaryBtn');\n\n    const toggleArrayView = document.getElementById('toggleArrayView');\n    const jumpIndexBtn = document.getElementById('jumpIndexBtn');\n    const jumpIndexInput = document.getElementById('jumpIndexInput');\n    const arrayView = document.getElementById('arrayView');\n    const phaseSpan = document.getElementById('phase');\n    const pointersSpan = document.getElementById('pointers');\n    const comparisonsSpan = document.getElementById('comparisons');\n    const accessesSpan = document.getElementById('accesses');\n    const stepsCountSpan = document.getElementById('stepsCount');\n    const foundIndexSpan = document.getElementById('foundIndex');\n    const hintsSpan = document.getElementById('hints');\n\n    const pseudocode = document.getElementById('pseudocode');\n    const showCodeBtn = document.getElementById('showCodeBtn');\n    const codeView = document.getElementById('codeView');\n    const explainStepBtn = document.getElementById('explainStepBtn');\n    const explanation = document.getElementById('explanation');\n\n    const exportSessionBtn = document.getElementById('exportSessionBtn');\n    const importSessionBtn = document.getElementById('importSessionBtn');\n    const importSessionArea = document.getElementById('importSessionArea');\n    const prevHistoryBtn = document.getElementById('prevHistoryBtn');\n    const nextHistoryBtn = document.getElementById('nextHistoryBtn');\n    const historyIndex = document.getElementById('historyIndex');\n    const historyLen = document.getElementById('historyLen');\n    const traceLog = document.getElementById('traceLog');\n    const clearTraceBtn = document.getElementById('clearTraceBtn');\n\n    const runLinearNow = document.getElementById('runLinearNow');\n    const runLinearBtn = document.getElementById('runLinearBtn');\n    const linearResult = document.getElementById('linearResult');\n\n    // Utility functions\n    function parseArrayFromInput() {\n      const raw = arrayInput.value.trim();\n      if (!raw) return [];\n      try {\n        // support numeric arrays and spaces\n        const parts = raw.split(',').map(s=>s.trim()).filter(s=>s.length>0);\n        const arr = parts.map(s=>{\n          if (/^\\d+$/.test(s)) return Number(s);\n          const v = Number(s);\n          if (!isNaN(v)) return v;\n          return s; // allow strings (but comparator must handle)\n        });\n        return arr;\n      } catch (e) {\n        return [];\n      }\n    }\n\n    function updateExistingValuesDropdown() {\n      existingValues.innerHTML = '';\n      state.array.forEach(v=>{\n        const opt = document.createElement('option');\n        opt.value = String(v);\n        opt.text = String(v);\n        existingValues.appendChild(opt);\n      });\n    }\n\n    function setArray(arr) {\n      state.array = arr.slice();\n      state.n = state.array.length;\n      arrayInput.value = state.array.join(',');\n      updateExistingValuesDropdown();\n      resetState();\n      render();\n    }\n\n    function ensureSortedIfNeeded() {\n      if (!state.allowUnsorted) {\n        // try to sort using comparator\n        try {\n          state.array.sort((a,b)=>state.comparator(a,b));\n          updateExistingValuesDropdown();\n        } catch (e) {\n          // ignore\n        }\n      }\n    }\n\n    function randInt(max) {\n      return Math.floor(Math.random()*max);\n    }\n\n    // Initialize default array from input at load\n    setArray(parseArrayFromInput());\n\n    // Initialize comparator from input\n    function compileComparator(expr) {\n      try {\n        const fn = new Function('a','b','return ' + expr + ';');\n        // test\n        const test = fn(1,2);\n        state.comparator = (a,b)=> {\n          try { return fn(a,b); } catch(e){ return a-b; }\n        };\n        comparatorStatus.textContent = \"OK\";\n      } catch (e) {\n        comparatorStatus.textContent = \"Error: invalid expression\";\n      }\n    }\n    compileComparator(comparatorExpr.value);\n\n    // Core Exponential Search logic with step capability\n    function snapshot(note) {\n      const snap = {\n        array: state.array.slice(),\n        n: state.n,\n        target: state.target,\n        phase: state.phase,\n        i: state.i,\n        prev: state.prev,\n        left: state.left,\n        right: state.right,\n        mid: state.mid,\n        foundIndex: state.foundIndex,\n        comparisons: state.comparisons,\n        accesses: state.accesses,\n        steps: state.steps,\n        note: note || ''\n      };\n      state.snapshots = state.snapshots.slice(0, state.snapIndex+1);\n      state.snapshots.push(snap);\n      state.snapIndex = state.snapshots.length-1;\n      updateHistoryView();\n      logTrace(`Snapshot ${state.snapIndex}: ${note||'state saved'}`);\n    }\n\n    function restoreSnapshot(index) {\n      if (index < 0 || index >= state.snapshots.length) return;\n      const s = state.snapshots[index];\n      state.array = s.array.slice();\n      state.n = s.n;\n      state.target = s.target;\n      state.phase = s.phase;\n      state.i = s.i;\n      state.prev = s.prev;\n      state.left = s.left;\n      state.right = s.right;\n      state.mid = s.mid;\n      state.foundIndex = s.foundIndex;\n      state.comparisons = s.comparisons;\n      state.accesses = s.accesses;\n      state.steps = s.steps;\n      state.snapIndex = index;\n      render();\n    }\n\n    function updateHistoryView() {\n      historyIndex.textContent = String(Math.max(0,state.snapIndex));\n      historyLen.textContent = String(state.snapshots.length);\n    }\n\n    function logTrace(msg) {\n      const time = new Date().toLocaleTimeString();\n      traceLog.textContent = `[${time}] ${msg}\\n` + traceLog.textContent;\n    }\n\n    function resetState() {\n      stopRunning();\n      state.phase = 'idle';\n      state.i = 1;\n      state.prev = 0;\n      state.left = 0;\n      state.right = state.n-1;\n      state.mid = null;\n      state.foundIndex = -1;\n      state.comparisons = 0;\n      state.accesses = 0;\n      state.steps = 0;\n      state.snapshots = [];\n      state.snapIndex = -1;\n      state.breakComp = null;\n      state.breakIndex = null;\n      render();\n      logTrace('State reset');\n    }\n\n    function initAlgorithm() {\n      stopRunning();\n      if (!Array.isArray(state.array)) {\n        state.array = [];\n      }\n      if (!state.allowUnsorted) {\n        ensureSortedIfNeeded();\n      }\n      state.target = parseTargetInput();\n      state.phase = 'init';\n      state.i = 1;\n      state.prev = 0;\n      state.left = 0;\n      state.right = state.n - 1;\n      state.mid = null;\n      state.foundIndex = -1;\n      state.comparisons = 0;\n      state.accesses = 0;\n      state.steps = 0;\n      snapshot('Initialized algorithm');\n      logTrace('Algorithm initialized');\n      render();\n    }\n\n    function parseTargetInput() {\n      const t = targetInput.value.trim();\n      if (t === '') return null;\n      // try number\n      if (!isNaN(Number(t))) return Number(t);\n      return t;\n    }\n\n    // Accessing array with comparator counting\n    function cmpAt(index, target) {\n      state.accesses++;\n      state.comparisons++;\n      try {\n        const a = state.array[index];\n        const c = state.comparator(a, target);\n        return c;\n      } catch (e) {\n        return state.array[index] - target;\n      }\n    }\n\n    // Step execution: performs one micro-step depending on phase and granularity\n    function stepExecution() {\n      if (state.phase === 'idle') {\n        explanation.textContent = 'Algorithm not initialized. Press Initialize.';\n        return;\n      }\n      if (state.phase === 'done') {\n        explanation.textContent = 'Search already completed.';\n        return;\n      }\n\n      // Check breakpoints before executing step\n      if (state.breakComp !== null && state.comparisons >= state.breakComp) {\n        stopRunning();\n        logTrace(`Paused: comparisons >= breakpoint (${state.breakComp})`);\n        return;\n      }\n      if (state.breakIndex !== null && (state.i === state.breakIndex || state.left === state.breakIndex || state.right === state.breakIndex)) {\n        stopRunning();\n        logTrace(`Paused: index breakpoint hit (${state.breakIndex})`);\n        return;\n      }\n\n      if (state.phase === 'init') {\n        // Special initial check: compare array[0] with target\n        if (state.n === 0) {\n          state.phase = 'done';\n          state.foundIndex = -1;\n          snapshot('Empty array -> done');\n          render();\n          return;\n        }\n        state.steps++;\n        state.i = 1;\n        // Compare index 0\n        const c0 = cmpAt(0, state.target);\n        logTrace(`Compared array[0] (${state.array[0]}) with target -> comparator=${c0}`);\n        if (c0 === 0) {\n          state.foundIndex = 0;\n          state.phase = 'done';\n          snapshot('Found at index 0');\n          render();\n          return;\n        } else {\n          state.phase = 'doubling';\n          snapshot('Went to doubling phase');\n          render();\n          return;\n        }\n      }\n\n      if (state.phase === 'doubling') {\n        // Doubling phase: probe at i until i>=n or array[i] >= target\n        // Granularity: if probe-level and not detailed, we jump doubling without intermediate comparisons? We'll still do comparison but mark as one step.\n        if (state.i >= state.n) {\n          state.prev = Math.floor(state.i / 2);\n          state.left = state.prev;\n          state.right = state.n - 1;\n          state.phase = 'binary';\n          snapshot('Doubling ended due to i >= n -> binary bounds set');\n          render();\n          return;\n        }\n        state.steps++;\n        const idx = Math.min(state.i, state.n-1);\n        const c = cmpAt(idx, state.target);\n        logTrace(`Probe at index ${idx}: value=${state.array[idx]} comparator=${c}`);\n        if (c === 0) {\n          state.foundIndex = idx;\n          state.phase = 'done';\n          snapshot(`Found at index ${idx} during doubling`);\n          render();\n          return;\n        }\n        if (c < 0) {\n          // element < target, need to double\n          state.prev = state.i;\n          state.i = state.i * 2;\n          if (state.granularity === 'probe') {\n            snapshot(`Doubled i to ${state.i}`);\n            render();\n            return;\n          } else {\n            // comparison-level: we might continue, but take snapshot after doubling anyway\n            snapshot(`Doubled i to ${state.i}`);\n            render();\n            return;\n          }\n        } else {\n          // element > target: we've found upper bound\n          state.left = Math.floor(state.i/2);\n          state.right = idx;\n          state.phase = 'binary';\n          snapshot(`Upper bound found at index ${idx} -> binary bounds [${state.left}, ${state.right}]`);\n          render();\n          return;\n        }\n      }\n\n      if (state.phase === 'binary') {\n        // standard binary search between left and right inclusive\n        if (state.left > state.right) {\n          state.foundIndex = -1;\n          state.phase = 'done';\n          snapshot('Binary finished -> not found');\n          render();\n          return;\n        }\n        state.steps++;\n        state.mid = Math.floor((state.left + state.right)/2);\n        const c = cmpAt(state.mid, state.target);\n        logTrace(`Binary compare at mid=${state.mid}, val=${state.array[state.mid]}, comparator=${c}`);\n        if (c === 0) {\n          state.foundIndex = state.mid;\n          state.phase = 'done';\n          snapshot(`Found at index ${state.mid} in binary search`);\n          render();\n          return;\n        } else if (c < 0) {\n          state.left = state.mid + 1;\n          snapshot(`Binary moved left->${state.left}`);\n          render();\n          return;\n        } else {\n          state.right = state.mid - 1;\n          snapshot(`Binary moved right->${state.right}`);\n          render();\n          return;\n        }\n      }\n\n      render();\n    }\n\n    function runLoop() {\n      if (state.running) return;\n      state.running = true;\n      state.runTimer = setInterval(()=>{\n        // Check if done\n        if (state.phase === 'done') {\n          stopRunning();\n          return;\n        }\n        stepExecution();\n        if (autoExplain.checked) {\n          explainCurrentStep();\n        }\n        if (state.snapshots[state.snapIndex] && state.snapshots[state.snapIndex].note) {\n          // continue\n        }\n        // breakpoints check handled in stepExecution\n      }, state.speed);\n    }\n\n    function stopRunning() {\n      state.running = false;\n      if (state.runTimer) {\n        clearInterval(state.runTimer);\n        state.runTimer = null;\n      }\n    }\n\n    // Expose a full run to end\n    function runToEnd() {\n      stopRunning();\n      while(state.phase !== 'done') {\n        // check breakpoints to avoid infinite loop\n        if (state.breakComp !== null && state.comparisons >= state.breakComp) {\n          logTrace('Run-to-end paused by comparison breakpoint');\n          return;\n        }\n        stepExecution();\n      }\n      logTrace('Run to end completed');\n      render();\n    }\n\n    // Rendering\n    function render() {\n      // array view: show index:value pairs and annotate pointers\n      const arr = state.array;\n      const parts = [];\n      for (let idx=0; idx<arr.length; idx++) {\n        let s = `${idx}:${String(arr[idx])}`;\n        const markers = [];\n        if (idx === state.i) markers.push('i');\n        if (idx === state.prev) markers.push('prev');\n        if (idx === state.left) markers.push('L');\n        if (idx === state.right) markers.push('R');\n        if (idx === state.mid) markers.push('mid');\n        if (idx === state.foundIndex) markers.push('FOUND');\n        if (markers.length) s += `<${markers.join('|')}>`;\n        parts.push(s);\n      }\n      // Show compact or annotated view (compact removes index markers)\n      if (state.compactView) {\n        arrayView.textContent = arr.map(v=>String(v)).join(' ');\n      } else {\n        // Render as preformatted annotated text; no styling, so we use textual markers like <...>\n        arrayView.innerText = parts.join('    ');\n      }\n\n      phaseSpan.textContent = state.phase;\n      pointersSpan.textContent = `i=${state.i}, prev=${state.prev}, left=${state.left}, right=${state.right}, mid=${state.mid}`;\n      comparisonsSpan.textContent = String(state.comparisons);\n      accessesSpan.textContent = String(state.accesses);\n      stepsCountSpan.textContent = String(state.steps);\n      foundIndexSpan.textContent = String(state.foundIndex);\n      hintsSpan.textContent = generateHint();\n      updateHistoryView();\n    }\n\n    function generateHint() {\n      if (state.phase === 'init') return 'Initial check of index 0 next.';\n      if (state.phase === 'doubling') return 'Doubling: probe at i and compare to target.';\n      if (state.phase === 'binary') return 'Binary search between left and right.';\n      if (state.phase === 'done') {\n        return state.foundIndex>=0 ? `Found at ${state.foundIndex}.` : 'Not found.';\n      }\n      return '-';\n    }\n\n    // Explanations\n    function explainCurrentStep() {\n      const s = [];\n      s.push(`Phase: ${state.phase}`);\n      s.push(`Steps: ${state.steps}, Comparisons: ${state.comparisons}, Accesses: ${state.accesses}`);\n      if (state.phase === 'init') {\n        s.push('We check index 0 to quickly detect if the target is at the start.');\n      } else if (state.phase === 'doubling') {\n        s.push(`Doubling probe at i=${state.i}. Prev doubling bound is ${state.prev}.`);\n        s.push('If array[i] < target, double i. If >= target, we set binary search bounds.');\n      } else if (state.phase === 'binary') {\n        s.push(`Binary search in [${state.left}, ${state.right}]. Mid is ${state.mid}.`);\n      } else if (state.phase === 'done') {\n        s.push(state.foundIndex>=0 ? `Target found at index ${state.foundIndex}.` : 'Target not found.');\n      }\n      explanation.textContent = s.join('\\\\n');\n    }\n\n    // Expose JS implementation for user view\n    showCodeBtn.addEventListener('click', ()=>{\n      if (codeView.style.display === 'none') {\n        codeView.style.display = 'block';\n        codeView.textContent = [\n`function exponentialSearch(arr, target, comparator) {\n  if (arr.length === 0) return -1;\n  if (comparator(arr[0], target) === 0) return 0;\n  let i = 1;\n  while (i < arr.length && comparator(arr[i], target) < 0) {\n    i *= 2;\n  }\n  const left = Math.floor(i/2);\n  const right = Math.min(i, arr.length-1);\n  // binary search between left and right\n  let l = left, r = right;\n  while (l <= r) {\n    const mid = Math.floor((l + r) / 2);\n    const c = comparator(arr[mid], target);\n    if (c === 0) return mid;\n    if (c < 0) l = mid + 1;\n    else r = mid - 1;\n  }\n  return -1;\n}`\n        ].join('\\\\n');\n      } else {\n        codeView.style.display = 'none';\n      }\n    });\n\n    // Explain button\n    explainStepBtn.addEventListener('click', ()=>{\n      explainCurrentStep();\n    });\n\n    // History navigation\n    prevHistoryBtn.addEventListener('click', ()=>{\n      if (state.snapIndex > 0) {\n        restoreSnapshot(state.snapIndex - 1);\n      }\n    });\n    nextHistoryBtn.addEventListener('click', ()=>{\n      if (state.snapIndex < state.snapshots.length-1) {\n        restoreSnapshot(state.snapIndex + 1);\n      }\n    });\n\n    exportSessionBtn.addEventListener('click', ()=>{\n      const exportObj = {\n        array: state.array,\n        target: state.target,\n        snapshots: state.snapshots,\n        comparatorExpr: comparatorExpr.value\n      };\n      const json = JSON.stringify(exportObj);\n      const w = window.open('', '_blank');\n      w.document.write('<pre>'+json.replace(/</g,'&lt;')+'</pre>');\n    });\n\n    importSessionBtn.addEventListener('click', ()=>{\n      const txt = importSessionArea.value.trim();\n      if (!txt) {\n        alert('Paste session JSON into the field first.');\n        return;\n      }\n      try {\n        const obj = JSON.parse(txt);\n        if (Array.isArray(obj.array)) {\n          setArray(obj.array);\n        }\n        if (obj.comparatorExpr) {\n          comparatorExpr.value = obj.comparatorExpr;\n          compileComparator(obj.comparatorExpr);\n        }\n        if (Array.isArray(obj.snapshots)) {\n          state.snapshots = obj.snapshots;\n          state.snapIndex = state.snapshots.length-1;\n          if (state.snapIndex >= 0) {\n            restoreSnapshot(state.snapIndex);\n          }\n          updateHistoryView();\n        }\n        logTrace('Session imported');\n      } catch (e) {\n        alert('Invalid JSON');\n      }\n    });\n\n    clearTraceBtn.addEventListener('click', ()=>{\n      traceLog.textContent = '';\n    });\n\n    // Linear search\n    runLinearBtn.addEventListener('click', ()=>{\n      runLinearSearch();\n    });\n\n    function runLinearSearch() {\n      const arr = state.array;\n      const t = parseTargetInput();\n      let comps = 0;\n      let acc = 0;\n      let found = -1;\n      for (let i=0;i<arr.length;i++) {\n        comps++;\n        acc++;\n        try {\n          if (state.comparator(arr[i], t) === 0) { found = i; break; }\n        } catch (e) {\n          if (arr[i] === t) { found = i; break; }\n        }\n      }\n      linearResult.textContent = `Linear search -> foundIndex: ${found}, comparisons: ${comps}, accesses: ${acc}`;\n    }\n\n    // Buttons and events wiring\n    applyArrayBtn.addEventListener('click', ()=>{\n      setArray(parseArrayFromInput());\n      logTrace('Array applied from input');\n    });\n\n    randomSortedBtn.addEventListener('click', ()=>{\n      const size = Number(sizeSlider.value);\n      const maxv = Number(maxVal.value) || 1000;\n      const arr = [];\n      let cur = 0;\n      for (let i=0;i<size;i++) {\n        cur += Math.max(1, Math.floor(Math.random()*Math.max(1,Math.floor(maxv/size+1))));\n        arr.push(cur);\n      }\n      setArray(arr);\n      logTrace('Random sorted array generated');\n    });\n\n    sizeSlider.addEventListener('input', ()=>{\n      sizeLabel.textContent = sizeSlider.value;\n    });\n\n    uniqueBtn.addEventListener('click', ()=>{\n      // remove duplicates and sort\n      const uniq = Array.from(new Set(state.array.map(x=>x)));\n      uniq.sort((a,b)=>state.comparator(a,b));\n      setArray(uniq);\n      logTrace('Array deduplicated and sorted');\n    });\n\n    shuffleBtn.addEventListener('click', ()=>{\n      const arr = state.array.slice();\n      for (let i=arr.length-1;i>0;i--) {\n        const j = Math.floor(Math.random()*(i+1));\n        [arr[i],arr[j]] = [arr[j],arr[i]];\n      }\n      setArray(arr);\n      logTrace('Array shuffled (unsorted)');\n    });\n\n    sortBtn.addEventListener('click', ()=>{\n      setArray(state.array.slice().sort((a,b)=>state.comparator(a,b)));\n      logTrace('Array sorted using comparator');\n    });\n\n    clearArrayBtn.addEventListener('click', ()=>{\n      setArray([]);\n      logTrace('Array cleared');\n    });\n\n    allowUnsorted.addEventListener('change', ()=>{\n      state.allowUnsorted = allowUnsorted.checked;\n    });\n\n    chooseExisting.addEventListener('click', ()=>{\n      const val = existingValues.value;\n      if (val !== undefined) {\n        targetInput.value = val;\n      }\n    });\n\n    randomTargetBtn.addEventListener('click', ()=>{\n      if (state.array.length === 0) return;\n      const pickExisting = Math.random() < 0.5;\n      if (pickExisting) {\n        const idx = randInt(state.array.length);\n        targetInput.value = String(state.array[idx]);\n      } else {\n        // random outside range\n        const maxv = Number(maxVal.value) || 1000;\n        targetInput.value = String(Math.floor(Math.random()*(maxv+1)));\n      }\n    });\n\n    applyComparatorBtn.addEventListener('click', ()=>{\n      const expr = comparatorExpr.value;\n      try {\n        const fn = new Function('a','b','return ' + expr + ';');\n        const test = fn(1,2);\n        state.comparator = (a,b)=> {\n          try { return fn(a,b); } catch(e){ return a-b; }\n        };\n        comparatorStatus.textContent = 'OK';\n        logTrace('Comparator applied');\n      } catch (e) {\n        comparatorStatus.textContent = 'Error';\n        alert('Invalid comparator expression. Use \"a\" and \"b\" in expression, e.g. (a-b) or (String(a).localeCompare(String(b)))');\n      }\n    });\n\n    initBtn.addEventListener('click', ()=>{ initAlgorithm(); });\n    stepBtn.addEventListener('click', ()=>{ stepExecution(); if (autoExplain.checked) explainCurrentStep(); });\n    stepBackBtn.addEventListener('click', ()=>{\n      if (state.snapIndex > 0) {\n        restoreSnapshot(state.snapIndex - 1);\n      } else {\n        alert('No earlier snapshot.');\n      }\n    });\n    runBtn.addEventListener('click', ()=>{ state.speed = Number(speedRange.value); runLoop(); });\n    pauseBtn.addEventListener('click', ()=>{ stopRunning(); logTrace('Paused'); });\n    runToEndBtn.addEventListener('click', ()=>{ runToEnd(); });\n    resetBtn.addEventListener('click', ()=>{ resetState(); });\n\n    speedRange.addEventListener('input', ()=>{\n      speedLabel.textContent = speedRange.value + ' ms';\n      state.speed = Number(speedRange.value);\n      if (state.running) {\n        stopRunning();\n        runLoop();\n      }\n    });\n\n    detailedSteps.addEventListener('change', ()=>{\n      state.detailed = detailedSteps.checked;\n    });\n\n    granularitySelect.addEventListener('change', ()=>{\n      state.granularity = granularitySelect.value;\n    });\n\n    setBreakComp.addEventListener('click', ()=>{\n      const v = breakpointComp.value.trim();\n      if (v==='') { state.breakComp = null; logTrace('Comparison breakpoint cleared'); return; }\n      state.breakComp = Number(v);\n      logTrace(`Set comparison breakpoint >= ${state.breakComp}`);\n    });\n\n    setBreakIndex.addEventListener('click', ()=>{\n      const v = breakpointIndex.value.trim();\n      if (v==='') { state.breakIndex = null; logTrace('Index breakpoint cleared'); return; }\n      state.breakIndex = Number(v);\n      logTrace(`Set index breakpoint at ${state.breakIndex}`);\n    });\n\n    clearBreakpoints.addEventListener('click', ()=>{\n      state.breakComp = null;\n      state.breakIndex = null;\n      breakpointComp.value = '';\n      breakpointIndex.value = '';\n      logTrace('All breakpoints cleared');\n    });\n\n    stepIntoBinaryBtn.addEventListener('click', ()=>{\n      if (state.phase === 'doubling') {\n        // force binary with current i\n        state.left = Math.floor(state.i/2);\n        state.right = Math.min(state.i, state.n-1);\n        state.phase = 'binary';\n        snapshot('Manually stepped into binary phase');\n        render();\n      } else {\n        alert('Not in doubling phase.');\n      }\n    });\n\n    autoBinaryBtn.addEventListener('click', ()=>{\n      // calculate appropriate bounds based on comparisons done (approx)\n      if (state.phase === 'doubling') {\n        state.left = Math.floor(state.i/2);\n        state.right = Math.min(state.i, state.n-1);\n        state.phase = 'binary';\n        snapshot('Auto-chosen binary bounds');\n        render();\n      } else {\n        alert('Auto bounds are settable only during doubling phase.');\n      }\n    });\n\n    toggleArrayView.addEventListener('click', ()=>{\n      state.compactView = !state.compactView;\n      render();\n    });\n\n    jumpIndexBtn.addEventListener('click', ()=>{\n      const idx = Number(jumpIndexInput.value);\n      if (!isFinite(idx) || idx < 0 || idx >= state.n) {\n        alert('Invalid index');\n        return;\n      }\n      // create snapshot showing jump marker by setting i to that index (non-destructive)\n      const oldi = state.i;\n      state.i = idx;\n      snapshot(`Jumped view to index ${idx}`);\n      state.i = oldi;\n      render();\n    });\n\n    // Initialize UI with listeners applied\n    updateExistingValuesDropdown();\n    render();\n\n    // Auto-run linear search if checkbox set\n    runLinearNow.addEventListener('change', ()=>{\n      if (runLinearNow.checked) runLinearSearch();\n    });\n\n    // keyboard shortcuts for stepping and running\n    document.addEventListener('keydown', (e)=>{\n      if (e.key === ' ') {\n        e.preventDefault();\n        if (state.running) pauseBtn.click(); else runBtn.click();\n      }\n      if (e.key === 'ArrowRight') stepBtn.click();\n      if (e.key === 'ArrowLeft') stepBackBtn.click();\n    });\n\n    // warn if editing array while running\n    arrayInput.addEventListener('input', ()=>{\n      if (state.running) {\n        // do not auto-apply, but warn\n        hintsSpan.textContent = 'Editing array while running. Press Apply Array to commit; this will reset algorithm.';\n      } else {\n        hintsSpan.textContent = '';\n      }\n    });\n\n    // When user applies array, ensure a reset\n    applyArrayBtn.addEventListener('click', ()=>{\n      if (state.running) {\n        if (!confirm('Applying the array will stop the running execution. Continue?')) return;\n        stopRunning();\n      }\n      setArray(parseArrayFromInput());\n      resetState();\n      logTrace('Array applied and state reset after apply');\n    });\n\n    // Safety: if user modifies comparator, we warn and reset\n    comparatorExpr.addEventListener('input', ()=>{\n      comparatorStatus.textContent = 'Edited';\n    });\n\n    comparatorExpr.addEventListener('blur', ()=>{\n      // auto compile but do not reset state; just apply comparator\n      try {\n        compileComparator(comparatorExpr.value);\n        logTrace('Comparator compiled on blur');\n      } catch (e) {}\n    });\n\n    // small initial snapshot\n    snapshot('Initial snapshot');\n    render();\n  </script>\n</body>\n</html>"
