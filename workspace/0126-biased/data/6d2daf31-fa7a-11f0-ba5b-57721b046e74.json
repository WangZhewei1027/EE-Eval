  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Selection Sort Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n            max-width: 800px;\n            margin: 0 auto;\n        }\n        .array-container {\n            display: flex;\n            height: 200px;\n            align-items: flex-end;\n            border-bottom: 1px solid #000;\n            padding-bottom: 10px;\n            margin-bottom: 10px;\n        }\n        .array-bar {\n            flex: 1;\n            background-color: #ddd;\n            margin: 0 2px;\n            position: relative;\n            text-align: center;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            display: flex;\n            flex-direction: column;\n            gap: 5px;\n            margin-right: 20px;\n        }\n        .status {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #000;\n            min-height: 50px;\n        }\n        .highlight {\n            background-color: #aaa;\n        }\n        .min {\n            background-color: #888;\n        }\n        .sorted {\n            background-color: #666;\n        }\n        .comparison {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Selection Sort Visualization</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <label for=\"arraySize\">Array Size:</label>\n                <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"30\" value=\"10\">\n                <span id=\"arraySizeValue\">10</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"speed\">Animation Speed:</label>\n                <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\" step=\"100\">\n                <span id=\"speedValue\">500ms</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <button id=\"generateBtn\">Generate New Array</button>\n                <button id=\"startBtn\">Start Sorting</button>\n                <button id=\"pauseBtn\" disabled>Pause</button>\n                <button id=\"stepBtn\" disabled>Step</button>\n                <button id=\"resetBtn\">Reset</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"dataType\">Data Type:</label>\n                <select id=\"dataType\">\n                    <option value=\"random\">Random</option>\n                    <option value=\"nearlySorted\">Nearly Sorted</option>\n                    <option value=\"reversed\">Reversed</option>\n                    <option value=\"fewUnique\">Few Unique</option>\n                </select>\n            </div>\n        </div>\n        \n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n        \n        <div class=\"status\" id=\"status\">\n            Ready to begin. Click \"Generate New Array\" or \"Start Sorting\".\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Algorithm Explanation</h3>\n            <p>\n                Selection Sort works by repeatedly finding the minimum element from the unsorted part of the array\n                and putting it at the beginning. The algorithm maintains two subarrays: sorted and unsorted.\n            </p>\n            <p>\n                <strong>Current step:</strong> <span id=\"currentStep\"></span>\n            </p>\n        </div>\n    </div>\n\n    <script>\n        let array = [];\n        let animationSpeed = 500;\n        let isSorting = false;\n        let isPaused = false;\n        let animationId = null;\n        let currentStep = 0;\n        let sortingState = {};\n        \n        // DOM elements\n        const arrayContainer = document.getElementById('arrayContainer');\n        const arraySizeInput = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const speedInput = document.getElementById('speed');\n        const speedValue = document.getElementById('speedValue');\n        const generateBtn = document.getElementById('generateBtn');\n        const startBtn = document.getElementById('startBtn');\n        const pauseBtn = document.getElementById('pauseBtn');\n        const stepBtn = document.getElementById('stepBtn');\n        const resetBtn = document.getElementById('resetBtn');\n        const dataTypeSelect = document.getElementById('dataType');\n        const statusElement = document.getElementById('status');\n        const currentStepElement = document.getElementById('currentStep');\n        \n        // Event listeners\n        arraySizeInput.addEventListener('input', updateArraySize);\n        speedInput.addEventListener('input', updateSpeed);\n        generateBtn.addEventListener('click', generateNewArray);\n        startBtn.addEventListener('click', startSorting);\n        pauseBtn.addEventListener('click', togglePause);\n        stepBtn.addEventListener('click', performStep);\n        resetBtn.addEventListener('click', reset);\n        dataTypeSelect.addEventListener('change', generateNewArray);\n        \n        // Initialize\n        generateNewArray();\n        \n        function updateArraySize() {\n            const size = arraySizeInput.value;\n            arraySizeValue.textContent = size;\n            generateNewArray();\n        }\n        \n        function updateSpeed() {\n            animationSpeed = speedInput.value;\n            speedValue.textContent = animationSpeed + 'ms';\n        }\n        \n        function generateNewArray() {\n            if (isSorting) return;\n            \n            const size = parseInt(arraySizeInput.value);\n            const dataType = dataTypeSelect.value;\n            array = [];\n            \n            switch(dataType) {\n                case 'random':\n                    for (let i = 0; i < size; i++) {\n                        array.push(Math.floor(Math.random() * 100) + 1);\n                    }\n                    break;\n                case 'nearlySorted':\n                    for (let i = 0; i < size; i++) {\n                        array.push(i * 5 + Math.floor(Math.random() * 10));\n                    }\n                    break;\n                case 'reversed':\n                    for (let i = size; i > 0; i--) {\n                        array.push(i * 5 + Math.floor(Math.random() * 3));\n                    }\n                    break;\n                case 'fewUnique':\n                    const uniqueValues = [10, 30, 50, 70, 90];\n                    for (let i = 0; i < size; i++) {\n                        array.push(uniqueValues[Math.floor(Math.random() * uniqueValues.length)]);\n                    }\n                    break;\n            }\n            \n            renderArray();\n            statusElement.textContent = 'New array generated. Ready to sort.';\n            currentStepElement.textContent = '';\n            currentStep = 0;\n        }\n        \n        function renderArray(state = {}) {\n            arrayContainer.innerHTML = '';\n            const maxValue = Math.max(...array, 1);\n            \n            array.forEach((value, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'array-bar';\n                bar.style.height = `${(value / maxValue) * 100}%`;\n                \n                if (state.sortedIndices && state.sortedIndices.includes(index)) {\n                    bar.classList.add('sorted');\n                }\n                \n                if (state.currentMinIndex === index) {\n                    bar.classList.add('min');\n                }\n                \n                if (state.comparingIndices && state.comparingIndices.includes(index)) {\n                    bar.classList.add('comparison');\n                }\n                \n                const label = document.createElement('div');\n                label.textContent = value;\n                bar.appendChild(label);\n                \n                arrayContainer.appendChild(bar);\n            });\n        }\n        \n        function startSorting() {\n            if (isSorting) return;\n            \n            isSorting = true;\n            isPaused = false;\n            startBtn.disabled = true;\n            generateBtn.disabled = true;\n            pauseBtn.disabled = false;\n            stepBtn.disabled = false;\n            \n            currentStep = 0;\n            sortingState = {\n                i: 0,\n                j: 0,\n                minIndex: 0,\n                sortedIndices: [],\n                comparingIndices: []\n            };\n            \n            statusElement.textContent = 'Sorting in progress...';\n            performSortStep();\n        }\n        \n        function performSortStep() {\n            if (isPaused) return;\n            \n            if (sortingState.i >= array.length - 1) {\n                finishSorting();\n                return;\n            }\n            \n            currentStep++;\n            currentStepElement.textContent = `Step ${currentStep}: `;\n            \n            if (sortingState.j === 0) {\n                sortingState.minIndex = sortingState.i;\n                currentStepElement.textContent += `Initializing minimum at position ${sortingState.i}`;\n            }\n            \n            if (sortingState.j < array.length) {\n                sortingState.comparingIndices = [sortingState.j, sortingState.minIndex];\n                \n                if (array[sortingState.j] < array[sortingState.minIndex]) {\n                    sortingState.minIndex = sortingState.j;\n                    currentStepElement.textContent += `Found new minimum ${array[sortingState.minIndex]} at position ${sortingState.minIndex}`;\n                } else {\n                    currentStepElement.textContent += `Comparing ${array[sortingState.j]} with current minimum ${array[sortingState.minIndex]}`;\n                }\n                \n                renderArray(sortingState);\n                sortingState.j++;\n                \n                animationId = setTimeout(performSortStep, animationSpeed);\n            } else {\n                if (sortingState.minIndex !== sortingState.i) {\n                    // Swap elements\n                    [array[sortingState.i], array[sortingState.minIndex]] = \n                        [array[sortingState.minIndex], array[sortingState.i]];\n                    currentStepElement.textContent += `Swapping ${array[sortingState.i]} to position ${sortingState.i}`;\n                }\n                \n                sortingState.sortedIndices.push(sortingState.i);\n                sortingState.i++;\n                sortingState.j = sortingState.i;\n                sortingState.comparingIndices = [];\n                \n                renderArray(sortingState);\n                animationId = setTimeout(performSortStep, animationSpeed);\n            }\n        }\n        \n        function togglePause() {\n            isPaused = !isPaused;\n            pauseBtn.textContent = isPaused ? 'Resume' : 'Pause';\n            \n            if (!isPaused) {\n                performSortStep();\n            } else {\n                clearTimeout(animationId);\n            }\n        }\n        \n        function performStep() {\n            if (!isSorting) return;\n            \n            isPaused = true;\n            pauseBtn.textContent = 'Resume';\n            clearTimeout(animationId);\n            performSortStep();\n        }\n        \n        function finishSorting() {\n            isSorting = false;\n            startBtn.disabled = false;\n            generateBtn.disabled = false;\n            pauseBtn.disabled = true;\n            stepBtn.disabled = true;\n            \n            sortingState.sortedIndices = Array.from({length: array.length}, (_, i) => i);\n            renderArray(sortingState);\n            \n            statusElement.textContent = 'Sorting completed!';\n            currentStepElement.textContent += 'Sorting completed!';\n        }\n        \n        function reset() {\n            clearTimeout(animationId);\n            isSorting = false;\n            isPaused = false;\n            currentStep = 0;\n            \n            startBtn.disabled = false;\n            generateBtn.disabled = false;\n            pauseBtn.disabled = true;\n            stepBtn.disabled = true;\n            pauseBtn.textContent = 'Pause';\n            \n            statusElement.textContent = 'Ready to begin. Click \"Generate New Array\" or \"Start Sorting\".';\n            currentStepElement.textContent = '';\n            \n            renderArray();\n        }\n    </script>\n</body>\n</html>"
  },
