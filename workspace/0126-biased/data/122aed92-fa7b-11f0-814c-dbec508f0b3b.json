    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Multiset</title>\n    <style>\n        body {\n            background-color: #000;\n        }\n        #multiset {\n            width: 800px;\n            height: 600px;\n            margin: 40px auto;\n            border: 1px solid #000;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);\n        }\n        #multiset h1 {\n            color: #fff;\n            margin-bottom: 20px;\n        }\n        #multiset p {\n            margin-bottom: 10px;\n        }\n        #multiset input, #multiset textarea {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #000;\n            border-radius: 5px;\n            box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);\n        }\n        #multiset button {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #000;\n            color: #fff;\n            cursor: pointer;\n        }\n        #multiset button:hover {\n            background-color: #444;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"multiset\">\n        <h1>Multiset</h1>\n        <p>Example usage of a multiset data structure.</p>\n        <p>This is a text field for user input.</p>\n        <input type=\"text\" id=\"input\" placeholder=\"Enter a word\">\n        <button id=\"add-word-btn\">Add Word</button>\n        <button id=\"remove-word-btn\">Remove Word</button>\n        <button id=\"clear-btn\">Clear Multiset</button>\n        <p id=\"multiset-words\"></p>\n    </div>\n\n    <script>\n        let words = new Set();\n        let currentWord = '';\n\n        function addWord() {\n            const word = document.getElementById('input').value;\n            if (word) {\n                words.add(word);\n                document.getElementById('multiset-words').innerHTML += `<p>${word}</p>`;\n                document.getElementById('input').value = '';\n            }\n        }\n\n        function removeWord() {\n            const word = document.getElementById('input').value;\n            if (word) {\n                words.delete(word);\n                document.getElementById('multiset-words').innerHTML = words.size;\n            }\n        }\n\n        function clearMultiset() {\n            words.clear();\n            document.getElementById('multiset-words').innerHTML = '';\n        }\n\n        document.getElementById('add-word-btn').addEventListener('click', addWord);\n        document.getElementById('remove-word-btn').addEventListener('click', removeWord);\n        document.getElementById('clear-btn').addEventListener('click', clearMultiset);\n\n        document.getElementById('input').addEventListener('input', () => {\n            currentWord = document.getElementById('input').value;\n        });\n    </script>\n</body>\n</html>"
