    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Interactive Trie Playground</title>\n<style>\n/* Extremely minimal styling: plain black text on white background */\nbody { background: white; color: black; font-family: monospace; margin: 12px; }\nbutton, input, textarea, select { margin: 2px 4px; }\nsection { margin-bottom: 12px; }\nlabel { margin-right: 6px; }\n.small { font-size: 12px; }\n.log { white-space: pre-wrap; border: 1px solid #000; padding: 6px; height: 160px; overflow: auto; background: white; }\n.tree, .adj, .words, .jsonout { border: 1px solid #000; padding: 6px; margin-top: 6px; height: 220px; overflow: auto; background: white; }\n.controls-row { margin-bottom: 6px; }\n.inline { display: inline-block; vertical-align: top; margin-right: 12px; }\nkbd { background: #eee; border: 1px solid #000; padding: 1px 4px; }\n</style>\n</head>\n<body>\n\n<h1>Trie Interactive Playground</h1>\n\n<section>\n  <strong>Basic Controls</strong>\n  <div class=\"controls-row\">\n    <label>Word:</label>\n    <input id=\"wordInput\" type=\"text\" placeholder=\"type word\" />\n    <button id=\"insertBtn\">Insert</button>\n    <button id=\"deleteBtn\">Delete</button>\n    <button id=\"searchBtn\">Search</button>\n    <button id=\"highlightBtn\">Highlight Path</button>\n  </div>\n  <div class=\"controls-row\">\n    <label>Prefix:</label>\n    <input id=\"prefixInput\" type=\"text\" placeholder=\"prefix\" />\n    <button id=\"prefixSearchBtn\">Prefix Search</button>\n    <label>k:</label>\n    <input id=\"kInput\" type=\"number\" value=\"10\" min=\"1\" style=\"width:60px\" />\n    <button id=\"autoCompleteBtn\">Autocomplete</button>\n    <button id=\"countPrefixBtn\">Count Prefix</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Batch (one per line):</label><br/>\n    <textarea id=\"batchInput\" rows=\"4\" cols=\"60\" placeholder=\"one word per line\"></textarea><br/>\n    <button id=\"insertBatchBtn\">Insert Batch</button>\n    <button id=\"deleteBatchBtn\">Delete Batch</button>\n    <button id=\"randomBtn\">Add Random Words</button>\n    <label>n:</label><input id=\"randN\" type=\"number\" value=\"20\" style=\"width:60px\" />\n    <label>len min:</label><input id=\"randMin\" type=\"number\" value=\"3\" style=\"width:50px\" />\n    <label>max:</label><input id=\"randMax\" type=\"number\" value=\"8\" style=\"width:50px\" />\n  </div>\n\n  <div class=\"controls-row\">\n    <button id=\"clearBtn\">Clear Trie</button>\n    <button id=\"exportBtn\">Export JSON</button>\n    <button id=\"importBtn\">Import JSON</button>\n    <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n    <button id=\"loadSnapshotBtn\">Load Snapshot</button>\n    <select id=\"snapshotSelect\"></select>\n  </div>\n\n  <div class=\"controls-row\">\n    <label><input id=\"caseSensitive\" type=\"checkbox\" /> Case Sensitive</label>\n    <label><input id=\"allowSymbols\" type=\"checkbox\" /> Allow Symbols (non-letter)</label>\n    <label><input id=\"recordSteps\" type=\"checkbox\" checked /> Record Steps</label>\n    <label><input id=\"showCounts\" type=\"checkbox\" checked /> Show Counts</label>\n    <label><input id=\"compressedView\" type=\"checkbox\" /> Compressed View</label>\n    <button id=\"compressBtn\">Compress</button>\n    <button id=\"decompressBtn\">Decompress</button>\n  </div>\n</section>\n\n<section>\n  <strong>Step Controls / Playback</strong>\n  <div class=\"controls-row\">\n    <button id=\"stepPrev\">Step ◀</button>\n    <button id=\"stepNext\">Step ▶</button>\n    <button id=\"playPause\">Play</button>\n    <label>Speed:</label>\n    <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\" />\n    <span id=\"speedVal\">400ms</span>\n    <button id=\"resetSteps\">Reset Steps</button>\n    <button id=\"replayLastOp\">Replay Last Operation</button>\n  </div>\n  <div>\n    <label>Operation Log (click entry to replay):</label>\n    <div id=\"operationLog\" class=\"log\"></div>\n  </div>\n</section>\n\n<section>\n  <strong>Advanced Actions</strong>\n  <div class=\"controls-row\">\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <button id=\"listWordsBtn\">List All Words</button>\n    <button id=\"longestPrefixBtn\">Longest Common Prefix</button>\n    <button id=\"compressCountBtn\">Compress Chains Count</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Max results:</label><input id=\"maxResults\" type=\"number\" value=\"200\" style=\"width:80px\" />\n    <button id=\"truncateBtn\">Truncate Trie (limit nodes)</button>\n    <input id=\"nodeLimit\" type=\"number\" value=\"500\" style=\"width:80px\" />\n  </div>\n</section>\n\n<section>\n  <div class=\"inline\" style=\"width:48%\">\n    <strong>Trie Structure</strong>\n    <div id=\"tree\" class=\"tree\"></div>\n  </div>\n  <div class=\"inline\" style=\"width:48%\">\n    <strong>Adjacency / Metadata</strong>\n    <div id=\"adj\" class=\"adj\"></div>\n  </div>\n</section>\n\n<section>\n  <div class=\"inline\" style=\"width:48%\">\n    <strong>Words / Results</strong>\n    <div id=\"words\" class=\"words\"></div>\n  </div>\n  <div class=\"inline\" style=\"width:48%\">\n    <strong>JSON Export / Import</strong>\n    <div><textarea id=\"jsonArea\" class=\"jsonout\" placeholder=\"Exported JSON appears here\"></textarea></div>\n  </div>\n</section>\n\n<script>\n// Extremely feature-rich trie playground with minimal visuals.\n\n// Data structures and utilities\n(function(){\n  // Unique id generator for nodes\n  let nodeIdCounter = 1;\n  function nextId(){ return nodeIdCounter++; }\n  function resetIdCounter(){ nodeIdCounter = 1; }\n\n  // Trie Node (normal)\n  function TrieNode(char){\n    this.char = char === undefined ? '' : char;\n    this.children = Object.create(null); // simple object map char -> node\n    this.isEnd = false;\n    this.count = 0; // how many words pass through or end here\n    this.id = nextId();\n  }\n\n  // Compressed node (used only when compressed)\n  function CompressedNode(label){\n    this.label = label === undefined ? '' : label;\n    this.children = Object.create(null); // label -> node\n    this.isEnd = false;\n    this.count = 0;\n    this.id = nextId();\n  }\n\n  // Trie main\n  function Trie(){\n    this.root = new TrieNode('');\n    this.countWords = 0;\n    this.isCompressed = false;\n    this.steps = []; // recorded step snapshots for playback\n    this.lastOperationLog = []; // human-readable log lines for last op\n  }\n\n  // Config from UI\n  const config = {\n    caseSensitive: false,\n    allowSymbols: false,\n    recordSteps: true,\n    showCounts: true,\n  };\n\n  // Utility functions\n  function normalizeWord(w){\n    if(typeof w !== 'string') return '';\n    if(!config.caseSensitive) w = w.toLowerCase();\n    if(!config.allowSymbols) w = w.replace(/[^a-zA-Z]/g,'');\n    return w;\n  }\n\n  // Traverse helpers produce snapshots\n  Trie.prototype._recordStep = function(info){\n    if(!config.recordSteps) return;\n    // Snapshot: we snapshot a minimal serializable version of trie and meta info\n    try {\n      const snap = {\n        time: Date.now(),\n        info: info,\n        trie: exportTrie(this), // serializable\n      };\n      // store steps\n      this.steps.push(snap);\n    } catch(e){\n      console.error(\"snapshot failed\", e);\n    }\n  };\n\n  Trie.prototype.insert = function(word){\n    if(!word) return false;\n    if(this.isCompressed){\n      // perform naive decompress, insert on normal trie, re-compress optional later\n      decompressTrie(this);\n    }\n    const w = normalizeWord(word);\n    this.lastOperationLog = [];\n    this.steps = [];\n    this._recordStep(\"Start insert '\" + word + \"'\");\n    let node = this.root;\n    node.count++;\n    this._recordStep(\"Root count++\");\n    for(let i=0;i<w.length;i++){\n      const ch = w[i];\n      this._recordStep(\"Processing char '\" + ch + \"' (index \" + i + \")\");\n      if(!node.children[ch]){\n        const newNode = new TrieNode(ch);\n        node.children[ch] = newNode;\n        this._recordStep(\"Created node for '\" + ch + \"' id=\" + newNode.id);\n      } else {\n        this._recordStep(\"Moved to existing node '\" + ch + \"' id=\" + node.children[ch].id);\n      }\n      node = node.children[ch];\n      node.count++;\n      this._recordStep(\"Incremented count at node id=\" + node.id + \" -> \" + node.count);\n    }\n    if(!node.isEnd){\n      node.isEnd = true;\n      this.countWords++;\n      this._recordStep(\"Marked end of word at id=\" + node.id);\n      this.lastOperationLog.push(\"Inserted: \" + word);\n      this._recordStep(\"Insert complete: '\" + word + \"'\");\n      return true;\n    } else {\n      this._recordStep(\"Word already existed\");\n      this.lastOperationLog.push(\"Insert (already existed): \" + word);\n      return false;\n    }\n  };\n\n  // Delete with decrement and cleanup\n  Trie.prototype.delete = function(word){\n    if(!word) return false;\n    if(this.isCompressed){\n      decompressTrie(this);\n    }\n    const w = normalizeWord(word);\n    this.lastOperationLog = [];\n    this.steps = [];\n    this._recordStep(\"Start delete '\" + word + \"'\");\n    let node = this.root;\n    const stack = []; // to keep nodes path\n    stack.push(node);\n    for(let i=0;i<w.length;i++){\n      const ch = w[i];\n      this._recordStep(\"Traversing char '\" + ch + \"'\");\n      if(!node.children[ch]){\n        this._recordStep(\"Char not found; abort delete\");\n        this.lastOperationLog.push(\"Delete failed (not found): \" + word);\n        return false;\n      }\n      node = node.children[ch];\n      stack.push(node);\n    }\n    if(!node.isEnd){\n      this._recordStep(\"Target node not marked end; abort delete\");\n      this.lastOperationLog.push(\"Delete failed (not a word): \" + word);\n      return false;\n    }\n    // decrement counts backwards and remove nodes with count==1 (will become 0)\n    node.isEnd = false;\n    this.countWords--;\n    this._recordStep(\"Unmarked end of word at id=\" + node.id);\n    for(let i = w.length; i >= 0; i--){\n      const cur = stack[i];\n      cur.count--;\n      this._recordStep(\"Decremented count at id=\" + cur.id + \" -> \" + cur.count);\n      if(i>0){\n        const parent = stack[i-1];\n        const ch = w[i-1];\n        if(cur.count <= 0){\n          // delete reference\n          delete parent.children[ch];\n          this._recordStep(\"Removed node for '\" + ch + \"' id=\" + cur.id);\n        } else {\n          this._recordStep(\"Stop removal at id=\" + cur.id + \" (count>0)\");\n          break;\n        }\n      }\n    }\n    this.lastOperationLog.push(\"Deleted: \" + word);\n    this._recordStep(\"Delete complete: '\" + word + \"'\");\n    return true;\n  };\n\n  Trie.prototype.search = function(word){\n    if(!word) return false;\n    const w = normalizeWord(word);\n    if(this.isCompressed){\n      // we can search compressed\n      return searchCompressed(this, w);\n    }\n    let node = this.root;\n    this.steps = [];\n    this.lastOperationLog = [];\n    this._recordStep(\"Start search '\" + word + \"'\");\n    for(let i=0;i<w.length;i++){\n      const ch = w[i];\n      this._recordStep(\"Looking for '\" + ch + \"'\");\n      if(!node.children[ch]){\n        this._recordStep(\"Not found at char '\" + ch + \"'\");\n        this.lastOperationLog.push(\"Search: not found \" + word);\n        return false;\n      }\n      node = node.children[ch];\n      this._recordStep(\"Moved to id=\" + node.id);\n    }\n    this._recordStep(\"Ended at id=\" + node.id + \" isEnd=\" + node.isEnd);\n    this.lastOperationLog.push(\"Search: \" + (node.isEnd? \"found \":\"not found \") + word);\n    return node.isEnd;\n  };\n\n  Trie.prototype._collectFromNode = function(node, prefix, results, limit){\n    if(!node) return;\n    if(node.isEnd) results.push(prefix);\n    if(limit && results.length >= limit) return;\n    const keys = Object.keys(node.children).sort();\n    for(let i=0;i<keys.length;i++){\n      const ch = keys[i];\n      if(limit && results.length >= limit) break;\n      this._collectFromNode(node.children[ch], prefix + ch, results, limit);\n    }\n  };\n\n  Trie.prototype.startsWith = function(prefix, limit){\n    if(this.isCompressed){\n      return startsWithCompressed(this, normalizeWord(prefix), limit);\n    }\n    const p = normalizeWord(prefix || '');\n    let node = this.root;\n    for(let i=0;i<p.length;i++){\n      const ch = p[i];\n      if(!node.children[ch]) return [];\n      node = node.children[ch];\n    }\n    const results = [];\n    this._collectFromNode(node, p, results, limit);\n    return results;\n  };\n\n  Trie.prototype.listAllWords = function(limit){\n    return this.startsWith('', limit);\n  };\n\n  Trie.prototype.countPrefix = function(prefix){\n    const p = normalizeWord(prefix || '');\n    if(this.isCompressed){\n      // decompress for count or implement compressed approach; decompress for correctness\n      decompressTrie(this);\n    }\n    let node = this.root;\n    for(let i=0;i<p.length;i++){\n      const ch = p[i];\n      if(!node.children[ch]) return 0;\n      node = node.children[ch];\n    }\n    return node.count || 0;\n  };\n\n  Trie.prototype.longestCommonPrefix = function(){\n    if(this.countWords === 0) return '';\n    if(this.isCompressed){\n      // decompress to compute simple\n      decompressTrie(this);\n    }\n    let node = this.root;\n    let prefix = '';\n    while(true){\n      const keys = Object.keys(node.children);\n      if(keys.length !== 1) break;\n      const ch = keys[0];\n      const child = node.children[ch];\n      if(child.isEnd) break;\n      prefix += ch;\n      node = child;\n    }\n    return prefix;\n  };\n\n  // Serialization / export helpers\n  function exportTrie(trie){\n    // produce object {isCompressed, countWords, root: recursive}\n    if(trie.isCompressed){\n      // compressed serialize\n      function serC(node){\n        const obj = {id: node.id, label: node.label, isEnd: !!node.isEnd, count: node.count, children: {}};\n        for(const k in node.children){\n          obj.children[k] = serC(node.children[k]);\n        }\n        return obj;\n      }\n      return {isCompressed: true, countWords: trie.countWords, root: serC(trie.root)};\n    } else {\n      function ser(node){\n        const obj = {id: node.id, char: node.char, isEnd: !!node.isEnd, count: node.count, children: {}};\n        for(const k in node.children){\n          obj.children[k] = ser(node.children[k]);\n        }\n        return obj;\n      }\n      return {isCompressed: false, countWords: trie.countWords, root: ser(trie.root)};\n    }\n  }\n\n  function importTrie(obj, trie){\n    resetIdCounter();\n    // reconstruct into provided trie object\n    if(!obj || typeof obj !== 'object') return false;\n    if(obj.isCompressed){\n      trie.isCompressed = true;\n      function revC(o){\n        const n = new CompressedNode(o.label);\n        n.id = o.id || nextId();\n        n.isEnd = !!o.isEnd;\n        n.count = o.count || 0;\n        n.children = Object.create(null);\n        for(const k in o.children){\n          n.children[k] = revC(o.children[k]);\n        }\n        return n;\n      }\n      trie.root = revC(obj.root);\n      trie.countWords = obj.countWords || 0;\n    } else {\n      trie.isCompressed = false;\n      function rev(o){\n        const n = new TrieNode(o.char);\n        n.id = o.id || nextId();\n        n.isEnd = !!o.isEnd;\n        n.count = o.count || 0;\n        n.children = Object.create(null);\n        for(const k in o.children){\n          n.children[k] = rev(o.children[k]);\n        }\n        return n;\n      }\n      trie.root = rev(obj.root);\n      trie.countWords = obj.countWords || 0;\n    }\n    return true;\n  }\n\n  // Decompress compressed trie into normal trie (destructive)\n  function decompressTrie(trie){\n    if(!trie.isCompressed) return trie;\n    const newTrie = new Trie();\n    newTrie.countWords = trie.countWords;\n    newTrie.isCompressed = false;\n    newTrie.root = new TrieNode('');\n    newTrie.root.count = trie.root.count || 0;\n    const stack = [{cnode: trie.root, prefix: ''}];\n    while(stack.length){\n      const {cnode, prefix} = stack.pop();\n      if(cnode.isEnd){\n        newTrie.insert(prefix + cnode.label);\n      } else {\n        // if label may represent a sequence, we need to create path nodes\n        if(cnode.label){\n          // Create chain for label (but do not mark end unless isEnd)\n          // We'll use insert to handle counts properly\n          // But we must preserve counts exactly, so we will insert multiple times?\n          // Simpler approach: insert the word.\n          // This will set counts correctly in newTrie.\n          // Danger: if counts encoded differently, but acceptable for interactive demo.\n          // Insert prefix+label as word if node.isEnd, but we already added above.\n        }\n      }\n      for(const k in cnode.children){\n        const chNode = cnode.children[k];\n        stack.push({cnode: chNode, prefix: prefix + cnode.label});\n      }\n    }\n    // However above approach missed establishing nodes in many cases; simpler: collect words then insert them.\n    // Let's collect words from compressed trie first, then rebuild new trie.\n    const words = collectFromCompressed(trie);\n    // rebuild\n    newTrie.root = new TrieNode('');\n    newTrie.countWords = 0;\n    newTrie.steps = [];\n    for(const w of words){\n      newTrie.insert(w);\n    }\n    // replace\n    trie.root = newTrie.root;\n    trie.countWords = newTrie.countWords;\n    trie.isCompressed = false;\n    trie.steps = newTrie.steps;\n    return trie;\n  }\n\n  function collectFromCompressed(trie){\n    const out = [];\n    function dfs(node, prefix){\n      const cur = prefix + (node.label || '');\n      if(node.isEnd) out.push(cur);\n      for(const k in node.children){\n        dfs(node.children[k], cur);\n      }\n    }\n    dfs(trie.root, '');\n    return out;\n  }\n\n  // Simple compression: merge chains of single-child nodes where parent isn't end and child isn't branching\n  function compressTrie(trie){\n    if(trie.isCompressed) return trie;\n    // collect words then build compressed trie by inserting sequences greedily\n    const words = trie.listAllWords(1000000);\n    const cTrie = new Trie();\n    cTrie.isCompressed = true;\n    resetIdCounter();\n    cTrie.root = new CompressedNode('');\n    cTrie.root.count = trie.root.count || 0;\n    cTrie.countWords = words.length;\n    for(const w of words){\n      // Insert into compressed structure: insert as path of labels; if can merge with existing child by prefix\n      let node = cTrie.root;\n      let remaining = w;\n      while(remaining.length){\n        // try to find a child whose label shares prefix\n        let matchedChildKey = null;\n        let matchedChild = null;\n        for(const k in node.children){\n          const child = node.children[k];\n          const common = commonPrefix(remaining, child.label);\n          if(common.length > 0){\n            matchedChild = child;\n            matchedChildKey = k;\n            break;\n          }\n        }\n        if(!matchedChild){\n          // create new child with the entire remaining as label\n          const newNode = new CompressedNode(remaining);\n          newNode.count = 1;\n          newNode.isEnd = true;\n          node.children[newNode.label] = newNode;\n          break;\n        } else {\n          const child = matchedChild;\n          const common = commonPrefix(remaining, child.label);\n          if(common === child.label){\n            // remaining has child.label as prefix -> descend\n            child.count++;\n            remaining = remaining.slice(child.label.length);\n            node = child;\n            if(remaining === ''){\n              child.isEnd = true;\n            }\n            continue;\n          } else if(common === remaining){\n            // need to split child: remaining is prefix of child.label\n            const oldLabel = child.label;\n            const suffix = oldLabel.slice(common.length);\n            const splitNode = new CompressedNode(suffix);\n            splitNode.children = child.children;\n            splitNode.isEnd = child.isEnd;\n            splitNode.count = child.count;\n            splitNode.id = child.id;\n            // adjust child to be common prefix node\n            child.label = common;\n            child.children = {};\n            child.children[splitNode.label] = splitNode;\n            child.isEnd = true;\n            child.count++;\n            break;\n          } else {\n            // partial match but neither is prefix: split both\n            const oldLabel = child.label;\n            const suffixChild = oldLabel.slice(common.length);\n            const suffixRemaining = remaining.slice(common.length);\n            const newSplit = new CompressedNode(suffixChild);\n            newSplit.children = child.children;\n            newSplit.isEnd = child.isEnd;\n            newSplit.count = child.count;\n            newSplit.id = child.id;\n            // update existing child to be common\n            child.label = common;\n            child.children = {};\n            child.children[newSplit.label] = newSplit;\n            child.isEnd = false;\n            // now attach new node for remaining suffix\n            const remNode = new CompressedNode(suffixRemaining);\n            remNode.isEnd = true;\n            remNode.count = 1;\n            child.children[remNode.label] = remNode;\n            child.count += 1;\n            break;\n          }\n        }\n      }\n    }\n    // update counts for all nodes roughly by traversing\n    function setCounts(node){\n      let c = node.isEnd ? 1 : 0;\n      for(const k in node.children){\n        c += setCounts(node.children[k]);\n      }\n      node.count = c;\n      return c;\n    }\n    setCounts(cTrie.root);\n    // assign ids properly\n    function assignIds(node){\n      node.id = nextId();\n      for(const k in node.children) assignIds(node.children[k]);\n    }\n    assignIds(cTrie.root);\n    // replace original trie content\n    trie.root = cTrie.root;\n    trie.isCompressed = true;\n    trie.countWords = cTrie.countWords;\n    return trie;\n  }\n\n  function commonPrefix(a,b){\n    let i=0;\n    while(i<a.length && i<b.length && a[i]===b[i]) i++;\n    return a.slice(0,i);\n  }\n\n  // Search compressed by walking labels\n  function searchCompressed(trie, w){\n    let node = trie.root;\n    let pos = 0;\n    while(pos < w.length){\n      const foundKey = Object.keys(node.children).find(k => w.startsWith(node.children[k].label, pos));\n      if(!foundKey) return false;\n      const child = node.children[foundKey];\n      pos += child.label.length;\n      node = child;\n    }\n    return !!node.isEnd;\n  }\n\n  // startsWith compressed\n  function startsWithCompressed(trie, prefix, limit){\n    // collect all words starting with prefix by DFS with matching labels\n    const results = [];\n    function dfs(node, current){\n      if(results.length >= (limit || Infinity)) return;\n      const cur = current + (node.label || '');\n      if(cur.startsWith(prefix) || prefix.startsWith(cur)){\n        if(node.isEnd && cur.startsWith(prefix)) results.push(cur);\n        // traverse deeper\n        for(const k in node.children){\n          dfs(node.children[k], cur);\n          if(results.length >= (limit || Infinity)) return;\n        }\n      } else {\n        // no match\n        // if prefix starts with cur, it's okay to explore children\n        if(prefix.startsWith(cur)){\n          for(const k in node.children){\n            dfs(node.children[k], cur);\n            if(results.length >= (limit || Infinity)) return;\n          }\n        }\n      }\n    }\n    dfs(trie.root, '');\n    return results.slice(0, limit || results.length);\n  }\n\n  // Collect all words from normal trie\n  Trie.prototype._collectAll = function(){\n    const results = [];\n    this._collectFromNode(this.root, '', results);\n    return results;\n  };\n\n  // Utilities for app UI rendering\n  function renderNormalTree(node, depth, activeIds){\n    depth = depth || 0;\n    activeIds = activeIds || {};\n    let out = '';\n    const indent = ' '.repeat(depth*2);\n    const marker = node === null ? '' : (node.isEnd ? '[*]' : '');\n    const displayChar = node.char === '' ? '<root>' : node.char;\n    const countPart = config.showCounts ? (' count=' + (node.count||0)) : '';\n    const highlight = activeIds[node.id] ? '>> ' : '';\n    out += indent + highlight + displayChar + marker + countPart + ' (id=' + node.id + ')\\n';\n    const keys = Object.keys(node.children).sort();\n    for(const k of keys){\n      out += renderNormalTree(node.children[k], depth+1, activeIds);\n    }\n    return out;\n  }\n\n  function renderCompressedTree(node, depth, activeIds){\n    depth = depth || 0;\n    activeIds = activeIds || {};\n    let out = '';\n    const indent = ' '.repeat(depth*2);\n    const marker = node === null ? '' : (node.isEnd ? '[*]' : '');\n    const displayLabel = node.label === '' ? '<root>' : node.label;\n    const countPart = config.showCounts ? (' count=' + (node.count||0)) : '';\n    const highlight = activeIds[node.id] ? '>> ' : '';\n    out += indent + highlight + displayLabel + marker + countPart + ' (id=' + node.id + ')\\n';\n    const keys = Object.keys(node.children).sort();\n    for(const k of keys){\n      out += renderCompressedTree(node.children[k], depth+1, activeIds);\n    }\n    return out;\n  }\n\n  function renderAdjacency(trie){\n    let out = '';\n    if(trie.isCompressed){\n      function dfs(node){\n        out += 'id=' + node.id + ' label=\"' + node.label + '\" isEnd=' + !!node.isEnd + ' count=' + node.count + '\\n';\n        for(const k in node.children){\n          out += '  -> ' + node.children[k].id + ' (\"' + node.children[k].label + '\")\\n';\n        }\n        for(const k in node.children) dfs(node.children[k]);\n      }\n      dfs(trie.root);\n    } else {\n      function dfs(node){\n        out += 'id=' + node.id + ' char=\"' + node.char + '\" isEnd=' + !!node.isEnd + ' count=' + node.count + '\\n';\n        for(const k in node.children){\n          out += '  -> ' + node.children[k].id + ' (\"' + node.children[k].char + '\")\\n';\n        }\n        for(const k in node.children) dfs(node.children[k]);\n      }\n      dfs(trie.root);\n    }\n    return out;\n  }\n\n  // Expose to global\n  window.Trie = Trie;\n  window.TrieNode = TrieNode;\n  window.CompressedNode = CompressedNode;\n  window.exportTrie = exportTrie;\n  window.importTrie = importTrie;\n  window.compressTrie = compressTrie;\n  window.decompressTrie = decompressTrie;\n  window.collectFromCompressed = collectFromCompressed;\n  window.searchCompressed = searchCompressed;\n})();\n\n// UI wiring and complex interactions\n\n(function(){\n  const trie = new Trie();\n\n  // history stack for undo/redo\n  const history = [];\n  let historyPos = -1;\n  function pushHistory(desc){\n    const obj = exportTrie(trie);\n    history.splice(historyPos+1); // drop redo entries\n    history.push({state: obj, desc: desc || ('op@' + Date.now())});\n    historyPos = history.length - 1;\n    refreshSnapshotSelect();\n  }\n  function canUndo(){ return historyPos > 0; }\n  function canRedo(){ return historyPos < history.length-1; }\n  function doUndo(){\n    if(!canUndo()) return;\n    historyPos--;\n    importTrie(history[historyPos].state, trie);\n    renderAll();\n  }\n  function doRedo(){\n    if(!canRedo()) return;\n    historyPos++;\n    importTrie(history[historyPos].state, trie);\n    renderAll();\n  }\n\n  // initial state\n  pushHistory('initial empty');\n\n  // UI elements\n  const wordInput = document.getElementById('wordInput');\n  const insertBtn = document.getElementById('insertBtn');\n  const deleteBtn = document.getElementById('deleteBtn');\n  const searchBtn = document.getElementById('searchBtn');\n  const highlightBtn = document.getElementById('highlightBtn');\n  const prefixInput = document.getElementById('prefixInput');\n  const prefixSearchBtn = document.getElementById('prefixSearchBtn');\n  const autoCompleteBtn = document.getElementById('autoCompleteBtn');\n  const kInput = document.getElementById('kInput');\n  const countPrefixBtn = document.getElementById('countPrefixBtn');\n  const batchInput = document.getElementById('batchInput');\n  const insertBatchBtn = document.getElementById('insertBatchBtn');\n  const deleteBatchBtn = document.getElementById('deleteBatchBtn');\n  const randomBtn = document.getElementById('randomBtn');\n  const randN = document.getElementById('randN');\n  const randMin = document.getElementById('randMin');\n  const randMax = document.getElementById('randMax');\n  const clearBtn = document.getElementById('clearBtn');\n  const exportBtn = document.getElementById('exportBtn');\n  const importBtn = document.getElementById('importBtn');\n  const jsonArea = document.getElementById('jsonArea');\n  const saveSnapshotBtn = document.getElementById('saveSnapshotBtn');\n  const loadSnapshotBtn = document.getElementById('loadSnapshotBtn');\n  const snapshotSelect = document.getElementById('snapshotSelect');\n  const caseSensitive = document.getElementById('caseSensitive');\n  const allowSymbols = document.getElementById('allowSymbols');\n  const recordSteps = document.getElementById('recordSteps');\n  const showCounts = document.getElementById('showCounts');\n  const compressedView = document.getElementById('compressedView');\n  const compressBtn = document.getElementById('compressBtn');\n  const decompressBtn = document.getElementById('decompressBtn');\n\n  const stepPrev = document.getElementById('stepPrev');\n  const stepNext = document.getElementById('stepNext');\n  const playPause = document.getElementById('playPause');\n  const speed = document.getElementById('speed');\n  const speedVal = document.getElementById('speedVal');\n  const resetSteps = document.getElementById('resetSteps');\n  const replayLastOp = document.getElementById('replayLastOp');\n  const operationLog = document.getElementById('operationLog');\n\n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n  const listWordsBtn = document.getElementById('listWordsBtn');\n  const longestPrefixBtn = document.getElementById('longestPrefixBtn');\n  const compressCountBtn = document.getElementById('compressCountBtn');\n  const maxResults = document.getElementById('maxResults');\n  const truncateBtn = document.getElementById('truncateBtn');\n  const nodeLimit = document.getElementById('nodeLimit');\n\n  const treeDiv = document.getElementById('tree');\n  const adjDiv = document.getElementById('adj');\n  const wordsDiv = document.getElementById('words');\n\n  // Step playback state\n  let playTimer = null;\n  let playIndex = 0;\n\n  function refreshSnapshotSelect(){\n    snapshotSelect.innerHTML = '';\n    for(let i=0;i<history.length;i++){\n      const opt = document.createElement('option');\n      opt.value = i;\n      opt.text = i + ': ' + (history[i].desc || 'snapshot');\n      snapshotSelect.appendChild(opt);\n    }\n  }\n\n  refreshSnapshotSelect();\n\n  // Render entire UI views\n  function renderAll(activeIds){\n    activeIds = activeIds || {};\n    // tree\n    if(trie.isCompressed || compressedView.checked){\n      compressedView.checked = true;\n      const text = renderCompressedTree(trie.root, 0, activeIds);\n      treeDiv.textContent = text;\n    } else {\n      compressedView.checked = false;\n      const text = renderNormalTree(trie.root, 0, activeIds);\n      treeDiv.textContent = text;\n    }\n    // adj\n    adjDiv.textContent = renderAdjacency(trie);\n\n    // words\n    const words = trie.listAllWords(Number(maxResults.value) || 200);\n    wordsDiv.textContent = words.join('\\n');\n\n    // json area is left for explicit export\n    operationLog.textContent = (trie.lastOperationLog || []).join('\\n') + '\\n\\nSteps recorded: ' + (trie.steps ? trie.steps.length : 0);\n    undoBtn.disabled = !canUndo();\n    redoBtn.disabled = !canRedo();\n  }\n\n  // Helpers to render tree strings via global functions\n  function renderNormalTree(node, depth, activeIds){\n    return window.renderNormalTree ? window.renderNormalTree(node, depth, activeIds) : '';\n  }\n  function renderCompressedTree(node, depth, activeIds){\n    return window.renderCompressedTree ? window.renderCompressedTree(node, depth, activeIds) : '';\n  }\n  function renderAdjacency(tr){\n    return window.renderAdjacency ? window.renderAdjacency(tr) : '';\n  }\n\n  // But these functions are not globally exposed; write local simple versions using existing ones:\n  function localRenderNormal(node, depth, activeIds){\n    depth = depth || 0;\n    activeIds = activeIds || {};\n    let out = '';\n    const indent = ' '.repeat(depth*2);\n    const marker = node === null ? '' : (node.isEnd ? '[*]' : '');\n    const displayChar = node.char === '' ? '<root>' : node.char;\n    const countPart = config.showCounts ? (' count=' + (node.count||0)) : '';\n    const highlight = activeIds[node.id] ? '>> ' : '';\n    out += indent + highlight + displayChar + marker + countPart + ' (id=' + node.id + ')\\n';\n    const keys = Object.keys(node.children).sort();\n    for(const k of keys){\n      out += localRenderNormal(node.children[k], depth+1, activeIds);\n    }\n    return out;\n  }\n  function localRenderCompressed(node, depth, activeIds){\n    depth = depth || 0;\n    activeIds = activeIds || {};\n    let out = '';\n    const indent = ' '.repeat(depth*2);\n    const marker = node === null ? '' : (node.isEnd ? '[*]' : '');\n    const displayLabel = node.label === '' ? '<root>' : node.label;\n    const countPart = config.showCounts ? (' count=' + (node.count||0)) : '';\n    const highlight = activeIds[node.id] ? '>> ' : '';\n    out += indent + highlight + displayLabel + marker + countPart + ' (id=' + node.id + ')\\n';\n    const keys = Object.keys(node.children).sort();\n    for(const k of keys){\n      out += localRenderCompressed(node.children[k], depth+1, activeIds);\n    }\n    return out;\n  }\n  function localRenderAdj(tr){\n    let out = '';\n    if(tr.isCompressed){\n      function dfs(node){\n        out += 'id=' + node.id + ' label=\"' + node.label + '\" isEnd=' + !!node.isEnd + ' count=' + node.count + '\\n';\n        for(const k in node.children){\n          out += '  -> ' + node.children[k].id + ' (\"' + node.children[k].label + '\")\\n';\n        }\n        for(const k in node.children) dfs(node.children[k]);\n      }\n      dfs(tr.root);\n    } else {\n      function dfs(node){\n        out += 'id=' + node.id + ' char=\"' + node.char + '\" isEnd=' + !!node.isEnd + ' count=' + node.count + '\\n';\n        for(const k in node.children){\n          out += '  -> ' + node.children[k].id + ' (\"' + node.children[k].char + '\")\\n';\n        }\n        for(const k in node.children) dfs(node.children[k]);\n      }\n      dfs(tr.root);\n    }\n    return out;\n  }\n\n  // override render functions used above\n  window.renderNormalTree = localRenderNormal;\n  window.renderCompressedTree = localRenderCompressed;\n  window.renderAdjacency = localRenderAdj;\n\n  // Wire config toggles\n  caseSensitive.addEventListener('change', () => config.caseSensitive = caseSensitive.checked);\n  allowSymbols.addEventListener('change', () => config.allowSymbols = allowSymbols.checked);\n  recordSteps.addEventListener('change', () => config.recordSteps = recordSteps.checked);\n  showCounts.addEventListener('change', () => { config.showCounts = showCounts.checked; renderAll(); });\n  compressedView.addEventListener('change', () => { renderAll(); });\n\n  // Speed display\n  speed.addEventListener('input', () => speedVal.textContent = speed.value + 'ms');\n\n  // Insert\n  insertBtn.addEventListener('click', () => {\n    const w = wordInput.value.trim();\n    if(!w) { alert('Enter a word'); return; }\n    const ok = trie.insert(w);\n    pushHistory('insert ' + w);\n    renderAll();\n  });\n\n  // Delete\n  deleteBtn.addEventListener('click', () => {\n    const w = wordInput.value.trim();\n    if(!w){ alert('Enter word'); return; }\n    const ok = trie.delete(w);\n    pushHistory('delete ' + w);\n    renderAll();\n  });\n\n  // Search\n  searchBtn.addEventListener('click', () => {\n    const w = wordInput.value.trim();\n    if(!w){ alert('Enter word'); return; }\n    const found = trie.search(w);\n    alert('Search: ' + w + ' -> ' + (found ? 'found' : 'not found'));\n    renderAll();\n  });\n\n  // Highlight path (uses last recorded steps to highlight nodes)\n  highlightBtn.addEventListener('click', () => {\n    const w = wordInput.value.trim();\n    if(!w){ alert('Enter word'); return; }\n    // find path and collect node ids\n    const activeIds = {};\n    if(trie.isCompressed){\n      // follow labels\n      let node = trie.root;\n      let pos = 0;\n      activeIds[node.id] = true;\n      while(pos < normalizeWord(w).length){\n        let matched = false;\n        for(const k in node.children){\n          const child = node.children[k];\n          const lab = child.label || '';\n          const rem = normalizeWord(w).slice(pos);\n          if(rem.startsWith(lab)){\n            activeIds[child.id] = true;\n            pos += lab.length;\n            node = child;\n            matched = true;\n            break;\n          }\n        }\n        if(!matched) break;\n      }\n    } else {\n      let node = trie.root;\n      activeIds[node.id] = true;\n      const s = normalizeWord(w);\n      for(let i=0;i<s.length;i++){\n        const ch = s[i];\n        if(!node.children[ch]) break;\n        node = node.children[ch];\n        activeIds[node.id] = true;\n      }\n    }\n    renderAll(activeIds);\n  });\n\n  // Prefix search\n  prefixSearchBtn.addEventListener('click', () => {\n    const p = prefixInput.value.trim();\n    const limit = Number(kInput.value) || 50;\n    const results = trie.startsWith(p, limit);\n    alert('Prefix results (' + results.length + '):\\n' + results.slice(0,200).join('\\n'));\n    renderAll();\n  });\n\n  // Autocomplete\n  autoCompleteBtn.addEventListener('click', () => {\n    const p = prefixInput.value.trim();\n    const k = Number(kInput.value) || 10;\n    const results = trie.startsWith(p, k);\n    alert('Autocomplete top ' + k + ':\\n' + results.join('\\n'));\n    renderAll();\n  });\n\n  // Count prefix\n  countPrefixBtn.addEventListener('click', () => {\n    const p = prefixInput.value.trim();\n    const c = trie.countPrefix(p);\n    alert('Prefix count for \"' + p + '\": ' + c);\n    renderAll();\n  });\n\n  // Batch insert\n  insertBatchBtn.addEventListener('click', () => {\n    const lines = batchInput.value.split('\\n').map(s => s.trim()).filter(Boolean);\n    if(lines.length === 0){ alert('No words to insert'); return; }\n    trie.lastOperationLog = [];\n    trie.steps = [];\n    for(const w of lines){\n      trie.insert(w);\n    }\n    pushHistory('insert batch ' + lines.length + ' words');\n    renderAll();\n  });\n\n  // Batch delete\n  deleteBatchBtn.addEventListener('click', () => {\n    const lines = batchInput.value.split('\\n').map(s => s.trim()).filter(Boolean);\n    if(lines.length === 0){ alert('No words to delete'); return; }\n    trie.lastOperationLog = [];\n    trie.steps = [];\n    for(const w of lines){\n      trie.delete(w);\n    }\n    pushHistory('delete batch ' + lines.length + ' words');\n    renderAll();\n  });\n\n  // Random generator\n  randomBtn.addEventListener('click', () => {\n    const n = Number(randN.value) || 10;\n    const mn = Number(randMin.value) || 3;\n    const mx = Number(randMax.value) || 8;\n    const chars = 'abcdefghijklmnopqrstuvwxyz';\n    const words = [];\n    for(let i=0;i<n;i++){\n      const L = Math.floor(Math.random()*(mx-mn+1)) + mn;\n      let s = '';\n      for(let j=0;j<L;j++) s += chars[Math.floor(Math.random()*chars.length)];\n      words.push(s);\n      trie.insert(s);\n    }\n    pushHistory('random add ' + n);\n    alert('Added random words:\\n' + words.join('\\n'));\n    renderAll();\n  });\n\n  // Clear trie\n  clearBtn.addEventListener('click', () => {\n    if(!confirm('Clear the entire trie?')) return;\n    // Reset by importing fresh\n    importTrie({isCompressed:false, countWords:0, root:{id:1,char:'',isEnd:false,count:0,children:{}}}, trie);\n    pushHistory('clear');\n    renderAll();\n  });\n\n  // Export JSON\n  exportBtn.addEventListener('click', () => {\n    const obj = exportTrie(trie);\n    jsonArea.value = JSON.stringify(obj, null, 2);\n  });\n\n  // Import JSON\n  importBtn.addEventListener('click', () => {\n    try{\n      const obj = JSON.parse(jsonArea.value);\n      importTrie(obj, trie);\n      pushHistory('import json');\n      renderAll();\n    } catch(e){\n      alert('Invalid JSON: ' + e.message);\n    }\n  });\n\n  // Save snapshot\n  saveSnapshotBtn.addEventListener('click', () => {\n    const name = prompt('Enter snapshot description (optional):','snapshot');\n    pushHistory(name || 'snapshot');\n    alert('Snapshot saved.');\n  });\n\n  // Load snapshot\n  loadSnapshotBtn.addEventListener('click', () => {\n    const idx = Number(snapshotSelect.value);\n    if(isNaN(idx)) { alert('Select snapshot'); return; }\n    if(!history[idx]) { alert('Invalid snapshot'); return; }\n    importTrie(history[idx].state, trie);\n    historyPos = idx;\n    renderAll();\n  });\n\n  // Steps playback handlers\n  stepPrev.addEventListener('click', () => {\n    if(trie.steps.length === 0){ alert('No recorded steps'); return; }\n    playIndex = Math.max(0, playIndex-1);\n    renderStep(playIndex);\n  });\n  stepNext.addEventListener('click', () => {\n    if(trie.steps.length === 0){ alert('No recorded steps'); return; }\n    playIndex = Math.min(trie.steps.length-1, playIndex+1);\n    renderStep(playIndex);\n  });\n\n  playPause.addEventListener('click', () => {\n    if(playTimer){\n      clearInterval(playTimer);\n      playTimer = null;\n      playPause.textContent = 'Play';\n    } else {\n      if(trie.steps.length === 0){ alert('No recorded steps'); return; }\n      playPause.textContent = 'Pause';\n      playTimer = setInterval(() => {\n        renderStep(playIndex);\n        playIndex++;\n        if(playIndex >= trie.steps.length){\n          clearInterval(playTimer);\n          playTimer = null;\n          playPause.textContent = 'Play';\n          playIndex = trie.steps.length-1;\n        }\n      }, Number(speed.value) || 400);\n    }\n  });\n\n  resetSteps.addEventListener('click', () => {\n    trie.steps = [];\n    playIndex = 0;\n    renderAll();\n  });\n\n  // render a recorded step snapshot\n  function renderStep(i){\n    if(!trie.steps || trie.steps.length === 0) return;\n    i = Math.max(0, Math.min(trie.steps.length-1, i));\n    const snap = trie.steps[i];\n    if(!snap) return;\n    // import trie snapshot temporarily for rendering\n    const tmp = new Trie();\n    importTrie(snap.trie, tmp);\n    // use activeIds to highlight nodes mentioned in snapshot.info text if possible (match ids)\n    const info = snap.info || '';\n    const activeIds = {};\n    // find numbers in info that look like id=123\n    const re = /id=(\\d+)/g;\n    let m;\n    while((m = re.exec(info)) !== null){\n      activeIds[Number(m[1])] = true;\n    }\n    // show info in operationLog area as highlight\n    operationLog.textContent = \"Step \" + i + \"/\" + (trie.steps.length-1) + \": \" + info + \"\\n\\n\" + JSON.stringify(snap.trie, null, 2);\n    // render tmp tri\n    if(tmp.isCompressed){\n      treeDiv.textContent = localRenderCompressed(tmp.root, 0, activeIds);\n      adjDiv.textContent = localRenderAdj(tmp);\n    } else {\n      treeDiv.textContent = localRenderNormal(tmp.root, 0, activeIds);\n      adjDiv.textContent = localRenderAdj(tmp);\n    }\n    wordsDiv.textContent = tmp.listAllWords(200).join('\\n');\n  }\n\n  // Replay last operation\n  replayLastOp.addEventListener('click', () => {\n    // if last operation left recorded steps, we can replay\n    if(trie.steps && trie.steps.length > 0){\n      playIndex = 0;\n      if(playTimer) { clearInterval(playTimer); playTimer = null; playPause.textContent = 'Play'; }\n      playPause.click(); // start playing\n    } else {\n      alert('No steps recorded to replay. Try performing operations with \"Record Steps\" enabled.');\n    }\n  });\n\n  // Undo/Redo\n  undoBtn.addEventListener('click', () => { doUndo(); });\n  redoBtn.addEventListener('click', () => { doRedo(); });\n\n  // List words\n  listWordsBtn.addEventListener('click', () => {\n    const words = trie.listAllWords(Number(maxResults.value) || 200);\n    alert('Words (' + words.length + '):\\n' + words.join('\\n'));\n  });\n\n  // Longest common prefix\n  longestPrefixBtn.addEventListener('click', () => {\n    const lcp = trie.longestCommonPrefix();\n    alert('Longest common prefix: \"' + lcp + '\"');\n  });\n\n  // Compress chains count\n  compressCountBtn.addEventListener('click', () => {\n    const beforeNodes = countNodes(trie);\n    compressTrie(trie);\n    const afterNodes = countNodes(trie);\n    pushHistory('compress');\n    alert('Compressed. Nodes before: ' + beforeNodes + ', after: ' + afterNodes);\n    renderAll();\n  });\n\n  // Compress / Decompress buttons\n  compressBtn.addEventListener('click', () => {\n    compressTrie(trie);\n    pushHistory('compress');\n    renderAll();\n  });\n  decompressBtn.addEventListener('click', () => {\n    decompressTrie(trie);\n    pushHistory('decompress');\n    renderAll();\n  });\n\n  // Truncate trie by limiting nodes (naive BFS prune)\n  truncateBtn.addEventListener('click', () => {\n    const limit = Number(nodeLimit.value) || 500;\n    const nodes = [];\n    // BFS collect nodes\n    const q = [trie.root];\n    while(q.length && nodes.length < limit){\n      const n = q.shift();\n      nodes.push(n);\n      for(const k in n.children) q.push(n.children[k]);\n    }\n    // rebuild a pruned trie by exporting words only that are fully within nodes\n    const words = trie.listAllWords(1000000).slice(0, Number(maxResults.value) || 10000);\n    // naive approach: keep the first N words up to node limit\n    const t2 = new Trie();\n    for(const w of words){\n      t2.insert(w);\n      if(countNodes(t2) >= limit) break;\n    }\n    importTrie(exportTrie(t2), trie);\n    pushHistory('truncate to ' + limit + ' nodes');\n    renderAll();\n  });\n\n  function countNodes(tr){\n    let cnt = 0;\n    function dfs(n){\n      cnt++;\n      if(tr.isCompressed){\n        for(const k in n.children) dfs(n.children[k]);\n      } else {\n        for(const k in n.children) dfs(n.children[k]);\n      }\n    }\n    dfs(tr.root);\n    return cnt;\n  }\n\n  // Clickable operation log: clicking lines will attempt to replay that operation (if in history)\n  operationLog.addEventListener('click', (e) => {\n    const text = operationLog.textContent;\n    const lines = text.split('\\n').filter(Boolean);\n    if(lines.length === 0) return;\n    // attempt to parse an index like \"Step i/j: info\"\n    const sel = window.getSelection().toString().trim();\n    if(sel){\n      // if selection is a word present in trie, highlight it\n      if(sel.length < 200){\n        wordInput.value = sel;\n        highlightBtn.click();\n      }\n    }\n  });\n\n  // On any manual modifications, push history\n  function attachPushAfterOperation(fn){\n    return function(){\n      const res = fn.apply(this, arguments);\n      pushHistory(fn.name || 'op');\n      renderAll();\n      return res;\n    };\n  }\n\n  // Preload some words for exploration\n  const starters = ['apple','app','apricot','banana','band','bandana','bandit','can','candy','cape','car','card','care','dog','dove','doom','cute','cut','cutter'];\n  for(const 