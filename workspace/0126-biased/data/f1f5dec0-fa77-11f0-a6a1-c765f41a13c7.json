    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Bucket Sort — Visual Demonstration</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071024;\n    --card: rgba(255,255,255,0.06);\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --accent: linear-gradient(135deg,#7bffea 0%, #6ec1ff 50%, #9b8bff 100%);\n    --accent-2: linear-gradient(135deg,#ffbf69 0%, #ff7aa2 70%);\n    --glass-blur: 18px;\n    --font-sans: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  /* Page */\n  html,body{\n    height:100%;\n    margin:0;\n    font-family:var(--font-sans);\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(110,193,255,0.08), transparent),\n                radial-gradient(1000px 500px at 90% 90%, rgba(155,139,255,0.06), transparent),\n                linear-gradient(180deg,var(--bg1) 0%, var(--bg2) 100%);\n    color: #e9f0ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  .wrap{\n    max-width:1100px;\n    margin:40px auto;\n    padding:34px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 10px 30px rgba(3,10,30,0.6);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Decorative blurred shapes */\n  .wrap::before, .wrap::after{\n    content:\"\";\n    position:absolute;\n    width:420px;height:420px;border-radius:50%;\n    filter: blur(60px); opacity:0.22;\n    z-index:0;\n    transform:translate(-10%,-30%);\n    pointer-events:none;\n  }\n  .wrap::before{\n    background: radial-gradient(circle at 30% 30%, #6ec1ff 0%, transparent 40%);\n    left:-160px; top:-120px;\n  }\n  .wrap::after{\n    background: radial-gradient(circle at 70% 70%, #9b8bff 0%, transparent 40%);\n    right:-180px; bottom:-120px;\n  }\n\n  header{\n    display:flex;\n    align-items:center;\n    gap:18px;\n    position:relative;\n    z-index:2;\n  }\n  .logo{\n    width:68px;height:68px;border-radius:14px;\n    display:grid;place-items:center;\n    background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 6px 18px rgba(14,28,57,0.6), inset 0 -6px 24px rgba(0,0,0,0.2);\n    font-weight:700;\n    color:transparent;\n    position:relative;\n  }\n  .logo svg{filter:drop-shadow(0 6px 14px rgba(76,137,255,0.15));}\n  h1{\n    font-size:22px;margin:0;\n    letter-spacing:0.2px;\n  }\n  p.lead{\n    margin:6px 0 0 0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Main visual panel */\n  .visual{\n    margin-top:24px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:16px;\n    padding:26px;\n    position:relative;\n    z-index:2;\n    border:1px solid rgba(255,255,255,0.03);\n    overflow:visible;\n  }\n\n  .playground{\n    height:420px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    position:relative;\n    user-select:none;\n  }\n\n  /* Top row: unsorted / sorted array */\n  .array-row{\n    height:96px;\n    display:flex;\n    align-items:center;\n    gap:14px;\n    padding:10px 18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:12px;\n    border:1px dashed rgba(255,255,255,0.03);\n  }\n  .array-row .label{\n    width:120px;\n    font-size:13px;color:var(--muted);\n    padding-left:6px;\n  }\n  .array-canvas{\n    flex:1;\n    position:relative;\n    height:72px;\n    display:flex;\n    align-items:center;\n    gap:12px;\n    padding:6px;\n    overflow:visible;\n  }\n\n  /* Bucket area */\n  .buckets{\n    flex:1;\n    position:relative;\n    display:flex;\n    gap:14px;\n    align-items:stretch;\n    padding:16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border-radius:12px;\n    border:1px solid rgba(255,255,255,0.02);\n    overflow:hidden;\n  }\n  .bucket{\n    flex:1;\n    position:relative;\n    min-width:60px;\n    border-radius:10px;\n    padding:12px 10px;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    box-shadow: inset 0 -6px 18px rgba(0,0,0,0.18);\n    transition:transform .4s ease;\n  }\n  .bucket .range{\n    font-size:12px;color:var(--muted);\n    background: rgba(255,255,255,0.02);\n    padding:6px 8px;border-radius:8px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .bucket .lane{\n    flex:1;\n    width:100%;\n    position:relative;\n    display:flex;\n    align-items:flex-end;\n    justify-content:center;\n    gap:8px;\n    padding-bottom:6px;\n    overflow:visible;\n  }\n  .bucket .count{\n    font-size:11px;color:var(--muted);\n  }\n\n  /* Number token */\n  .token{\n    width:64px;height:64px;\n    border-radius:14px;\n    display:grid;place-items:center;\n    font-weight:700;\n    font-size:18px;\n    color:white;\n    position:absolute;\n    will-change:transform, left, top;\n    transition: transform 800ms cubic-bezier(.2,.9,.25,1), opacity 300ms ease;\n    box-shadow: 0 10px 30px rgba(2,8,23,0.55), 0 2px 8px rgba(0,0,0,0.25);\n    border: 1px solid rgba(255,255,255,0.06);\n    text-shadow: 0 2px 8px rgba(0,0,0,0.45);\n    transform-origin:center;\n    cursor:default;\n  }\n  .token .sub{\n    position:absolute;right:8px;bottom:6px;font-size:10px;opacity:0.85;color:rgba(255,255,255,0.85);\n  }\n\n  /* Gradients for tokens based on bucket */\n  .g0{background: linear-gradient(135deg,#ffd6a5,#fdcb6e);}\n  .g1{background: linear-gradient(135deg,#ffd6a5,#ff9fa3);}\n  .g2{background: linear-gradient(135deg,#bde0fe,#6ec1ff);}\n  .g3{background: linear-gradient(135deg,#d4a5ff,#9b8bff);}\n  .g4{background: linear-gradient(135deg,#b7f0d2,#7bffea);}\n  .g5{background: linear-gradient(135deg,#ffa8a8,#ff9fb2);}\n  .g6{background: linear-gradient(135deg,#ffd6a5,#ffbf69);}\n  .g7{background: linear-gradient(135deg,#c4b5fd,#9b8bff);}\n  .g8{background: linear-gradient(135deg,#9be7ff,#6ec1ff);}\n  .g9{background: linear-gradient(135deg,#ffd7e2,#ff9fb2);}\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:18px;\n    align-items:center;\n    z-index:3;\n  }\n  button{\n    border:0;outline:0;\n    background: linear-gradient(90deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    color:#eaf6ff;\n    padding:10px 16px;border-radius:12px;\n    box-shadow: 0 6px 20px rgba(10,20,40,0.45);\n    cursor:pointer;\n    transition: transform .18s ease, box-shadow .18s ease, opacity .18s;\n    font-weight:600;\n  }\n  button:active{transform:translateY(1px) scale(.997);}\n  .btn-primary{\n    background: linear-gradient(90deg,#7bffea 0%, #6ec1ff 50%, #9b8bff 100%);\n    color:#052033;\n  }\n  .btn-ghost{\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.05);\n    color:var(--muted);\n  }\n  button[disabled]{opacity:0.5; cursor:not-allowed;}\n\n  /* Step caption */\n  .status{\n    margin-left:auto;\n    text-align:right;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* footer / legend */\n  .legend{\n    margin-top:18px;\n    color:var(--muted);\n    font-size:13px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  /* Responsive */\n  @media (max-width:880px){\n    .wrap{margin:20px;padding:18px;}\n    .buckets{gap:10px;padding:12px;}\n    .token{width:56px;height:56px}\n    .array-row{height:84px}\n  }\n\n</style>\n</head>\n<body>\n<div class=\"wrap\" role=\"main\" aria-label=\"Bucket Sort Visual Demonstration\">\n  <header>\n    <div class=\"logo\" aria-hidden=\"true\">\n      <svg width=\"44\" height=\"44\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"lg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7bffea\"/>\n            <stop offset=\"1\" stop-color=\"#9b8bff\"/>\n          </linearGradient>\n        </defs>\n        <rect x=\"4\" y=\"4\" width=\"40\" height=\"40\" rx=\"10\" fill=\"url(#lg)\" opacity=\"0.18\"/>\n        <g transform=\"translate(6 6)\" fill=\"none\" stroke=\"url(#lg)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M4 28 L12 8 L18 28\"></path>\n          <path d=\"M22 28 L30 8 L36 28\"></path>\n        </g>\n      </svg>\n    </div>\n    <div>\n      <h1>Bucket Sort — Elegant Visualization</h1>\n      <p class=\"lead\">Observe how values are distributed into buckets, sorted locally, then merged back into a sorted list.</p>\n    </div>\n  </header>\n\n  <section class=\"visual\" aria-hidden=\"false\">\n    <div class=\"playground\">\n      <div class=\"array-row\" aria-hidden=\"true\">\n        <div class=\"label\">Array</div>\n        <div class=\"array-canvas\" id=\"arrayCanvas\"></div>\n      </div>\n\n      <div class=\"buckets\" id=\"bucketsContainer\" aria-hidden=\"true\"></div>\n\n      <div class=\"controls\">\n        <button id=\"startBtn\" class=\"btn-primary\">Start Animation</button>\n        <button id=\"randBtn\" class=\"btn-ghost\">Randomize</button>\n        <div class=\"status\" id=\"status\">Ready — press Start to run the demonstration.</div>\n      </div>\n\n      <div class=\"legend\" aria-hidden=\"true\">\n        <div style=\"opacity:0.9\">Buckets: 10 ranges (0–9 … 90–99)</div>\n        <div style=\"margin-left:auto;color:var(--muted)\">Minimal controls — visual-first experience</div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<script>\n/*\n  Bucket Sort Visual Demonstration\n  - Extremely limited interactivity: Start and Randomize\n  - Beautiful, staggered, smooth animations\n*/\n\n(function(){\n  const BUCKET_COUNT = 10;\n  const ITEM_COUNT = 12;\n  const MAX_VALUE = 100;\n  const arrayCanvas = document.getElementById('arrayCanvas');\n  const bucketsContainer = document.getElementById('bucketsContainer');\n  const startBtn = document.getElementById('startBtn');\n  const randBtn = document.getElementById('randBtn');\n  const status = document.getElementById('status');\n\n  let tokens = []; // {value, el, id}\n  let buckets = []; // array of arrays of token ids\n  let running = false;\n  let seedId = 0;\n\n  // Utilities\n  function randInt(n){ return Math.floor(Math.random()*n); }\n  function clamp(v,a,b){return Math.max(a,Math.min(b,v));}\n  function bucketIndex(value){\n    return clamp(Math.floor(value / (MAX_VALUE/BUCKET_COUNT)), 0, BUCKET_COUNT-1);\n  }\n\n  // Build bucket UI\n  function createBucketsUI(){\n    bucketsContainer.innerHTML = '';\n    buckets = Array.from({length:BUCKET_COUNT}, ()=>[]);\n    for(let i=0;i<BUCKET_COUNT;i++){\n      const low = i*(MAX_VALUE/BUCKET_COUNT)|0;\n      const high = Math.min(MAX_VALUE-1, (i+1)*(MAX_VALUE/BUCKET_COUNT)-1)|0;\n      const b = document.createElement('div');\n      b.className='bucket';\n      b.dataset.idx = i;\n      b.innerHTML = `\n        <div class=\"range\">${low} – ${high}</div>\n        <div class=\"lane\" id=\"lane-${i}\"></div>\n        <div class=\"count\">0</div>\n      `;\n      bucketsContainer.appendChild(b);\n    }\n  }\n\n  // Generate random array tokens and render them\n  function generateArray(){\n    // clear\n    tokens.forEach(t=>t.el.remove());\n    tokens = [];\n    seedId++;\n    const values = [];\n    for(let i=0;i<ITEM_COUNT;i++){\n      values.push(randInt(MAX_VALUE));\n    }\n    // Create token elements placed horizontally in arrayCanvas (absolute positioning)\n    arrayCanvas.innerHTML = '';\n    const canvasRect = arrayCanvas.getBoundingClientRect();\n    const spacing = 12;\n    const tokenW = 64;\n    const totalW = ITEM_COUNT*tokenW + (ITEM_COUNT-1)*spacing;\n    const startX = Math.max(6, (canvasRect.width - totalW)/2);\n    for(let i=0;i<values.length;i++){\n      const v = values[i];\n      const el = document.createElement('div');\n      el.className = `token g${bucketIndex(v)}`;\n      const id = `t-${seedId}-${i}`;\n      el.dataset.id = id;\n      el.innerHTML = `<div>${v}</div><div class=\"sub\">${v}</div>`;\n      // initial absolute position\n      el.style.position = 'absolute';\n      const x = startX + i*(tokenW+spacing);\n      const y = 6;\n      el.style.left = x + 'px';\n      el.style.top = y + 'px';\n      // subtle entrance\n      el.style.transform = 'translateY(-18px) scale(.98)';\n      el.style.opacity = '0';\n      arrayCanvas.appendChild(el);\n      tokens.push({id, value:v, el});\n      // animate in\n      requestAnimationFrame(()=> {\n        el.style.transition = 'transform 600ms cubic-bezier(.2,.9,.25,1), opacity 420ms ease';\n        el.style.transform = 'translateY(0px) scale(1)';\n        el.style.opacity = '1';\n      });\n    }\n    updateCounts();\n    status.textContent = 'New array generated — ready.';\n  }\n\n  // Update bucket counts UI\n  function updateCounts(){\n    for(let i=0;i<BUCKET_COUNT;i++){\n      const bEl = bucketsContainer.children[i];\n      bEl.querySelector('.count').textContent = buckets[i].length;\n    }\n  }\n\n  // Move a token element to a target absolute position relative to the root container\n  function moveTo(el, targetX, targetY, delay=0, dur=800){\n    return new Promise(resolve=>{\n      el.style.transition = `transform ${dur}ms cubic-bezier(.2,.9,.25,1) ${delay}ms, opacity 200ms ease ${delay}ms`;\n      // compute current position\n      const parentRect = el.parentElement.getBoundingClientRect();\n      const curLeft = parseFloat(el.style.left || el.getBoundingClientPropertyValue('left') || el.offsetLeft);\n      const curTop = parseFloat(el.style.top || el.getBoundingClientPropertyValue('top') || el.offsetTop);\n      // We'll use transform translate to animate from current to target\n      const dx = targetX - curLeft;\n      const dy = targetY - curTop;\n      // set transform\n      el.style.transform = `translate(${dx}px, ${dy}px)`;\n      // Wait for transition end\n      const onEnd = (ev)=>{\n        if(ev && ev.target !== el) return;\n        el.removeEventListener('transitionend', onEnd);\n        // Snap: update left/top to target and reset transform for smooth further moves\n        el.style.transition = 'none';\n        el.style.left = targetX + 'px';\n        el.style.top = targetY + 'px';\n        el.style.transform = 'none';\n        // allow a tick then resolve\n        requestAnimationFrame(()=>requestAnimationFrame(resolve));\n      };\n      el.addEventListener('transitionend', onEnd);\n      // Fallback timeout\n      setTimeout(()=>{ onEnd(); }, dur + delay + 60);\n    });\n  }\n\n  // Animate distribution into buckets\n  async function distribute(){\n    status.textContent = 'Distributing values into buckets...';\n    // Clear buckets arrays\n    buckets = Array.from({length:BUCKET_COUNT}, ()=>[]);\n    updateCounts();\n    // For positioning compute coordinates relative to layout\n    const wrapRect = document.querySelector('.wrap').getBoundingClientRect();\n    const arrayRect = arrayCanvas.getBoundingClientRect();\n    const tokenW = 64;\n    const laneDepth = 140; // approximate vertical stack space within bucket\n    for(let i=0;i<tokens.length;i++){\n      const t = tokens[i];\n      const bIdx = bucketIndex(t.value);\n      const lane = document.getElementById(`lane-${bIdx}`);\n      // Move element from arrayCanvas into bucketsContainer (re-parent) to keep coordinates stable\n      // compute global target position:\n      const bucketEl = bucketsContainer.children[bIdx];\n      const laneRect = lane.getBoundingClientRect();\n      // compute stacked position offset in lane (bottom-up)\n      const stackIndex = buckets[bIdx].length;\n      const spacing = 10;\n      const targetX = (laneRect.left - arrayRect.left) + (laneRect.width - tokenW)/2 + arrayRect.left - wrapRect.left;\n      // for consistent coordinates, we'll place tokens relative to arrayCanvas container by converting absolute to arrayCanvas coordinates\n      // Actually simpler: append token into wrap and position absolute in wrap\n      // We'll ensure tokens are direct children of wrap for animation steps\n      // Move token to wrap\n      const wrap = document.querySelector('.wrap');\n      const currentRect = t.el.getBoundingClientRect();\n      // prepare: place in wrap with same visual location\n      t.el.style.left = (currentRect.left - wrapRect.left) + 'px';\n      t.el.style.top = (currentRect.top - wrapRect.top) + 'px';\n      wrap.appendChild(t.el);\n\n      // Determine final target inside the bucket lane (stack from bottom)\n      const bucketInnerRect = lane.getBoundingClientRect();\n      const targetCenterX = bucketInnerRect.left + (bucketInnerRect.width - tokenW)/2;\n      const bottomY = bucketInnerRect.bottom - tokenW - 8; // some padding\n      const targetY = bottomY - stackIndex*(tokenW + spacing);\n\n      // Animate drop with dramatic easing\n      await moveTo(t.el, targetCenterX - wrapRect.left, targetY - wrapRect.top, i*90, 700);\n\n      // After move, append to lane container DOM at correct absolute coords within wrap (keeps visual)\n      buckets[bIdx].push(t);\n      updateCounts();\n      // tiny bounce\n      t.el.style.transition = 'transform 260ms cubic-bezier(.2,1.3,.4,1)';\n      t.el.style.transform = 'translateY(-6px) scale(1.02)';\n      setTimeout(()=>{ t.el.style.transform='none'; }, 260);\n    }\n    status.textContent = 'All values distributed into buckets.';\n  }\n\n  // Sort each bucket locally and animate internal rearrangement\n  async function sortBuckets(){\n    status.textContent = 'Sorting each bucket locally...';\n    const wrapRect = document.querySelector('.wrap').getBoundingClientRect();\n    const tokenW = 64;\n    const spacing = 10;\n\n    for(let b=0;b<BUCKET_COUNT;b++){\n      if(buckets[b].length <= 1) {\n        await new Promise(r=>setTimeout(r, 120));\n        continue;\n      }\n      // perform a stable sort of bucket by value\n      const bucketArr = buckets[b];\n      // compute lane geometry\n      const lane = document.getElementById(`lane-${b}`);\n      const laneRect = lane.getBoundingClientRect();\n      // compute bottom baseline\n      const bottomY = laneRect.bottom - tokenW - 8;\n      // sort by value\n      bucketArr.sort((a,bk)=> a.value - bk.value);\n      // animate tokens to their new stacked positions\n      for(let i=0;i<bucketArr.length;i++){\n        const t = bucketArr[i];\n        const targetX = laneRect.left + (laneRect.width - tokenW)/2 - wrapRect.left;\n        const targetY = bottomY - i*(tokenW + spacing) - wrapRect.top;\n        // small stagger per bucket\n        await moveTo(t.el, targetX, targetY, i*80, 430);\n      }\n      // slight pause per bucket\n      await new Promise(r=>setTimeout(r, 160));\n      // update stored order\n      buckets[b] = bucketArr;\n    }\n    status.textContent = 'Buckets sorted. Preparing to merge...';\n  }\n\n  // Collect buckets into sorted array displayed in top area\n  async function collect(){\n    status.textContent = 'Collecting buckets: merging back into sorted array...';\n    const wrapRect = document.querySelector('.wrap').getBoundingClientRect();\n    const topRow = arrayCanvas.getBoundingClientRect();\n    const tokenW = 64;\n    // Build sorted sequence\n    const sorted = [];\n    for(let b=0;b<BUCKET_COUNT;b++){\n      for(const t of buckets[b]) sorted.push(t);\n    }\n    // compute target positions in top row\n    const spacing = 12;\n    const totalW = sorted.length*tokenW + (sorted.length-1)*spacing;\n    const startX = Math.max(6, (topRow.width - totalW)/2);\n    // re-parent tokens to wrap have them already in wrap; animate to top positions\n    for(let i=0;i<sorted.length;i++){\n      const t = sorted[i];\n      const targetAbsX = topRow.left + startX + i*(tokenW+spacing) - wrapRect.left;\n      const targetAbsY = topRow.top + 6 - wrapRect.top;\n      // small staggered delay for elegance\n      await moveTo(t.el, targetAbsX, targetAbsY, i*70, 520);\n      // update token color to neutral sorted style\n      t.el.style.boxShadow = '0 12px 28px rgba(6,18,42,0.6)';\n      t.el.style.border = '1px solid rgba(255,255,255,0.06)';\n    }\n    status.textContent = 'Sorted — operation complete.';\n  }\n\n  // Main run\n  async function runDemo(){\n    if(running) return;\n    running = true;\n    startBtn.disabled = true;\n    randBtn.disabled = true;\n    status.textContent = 'Starting animation...';\n    // Step 1: distribute\n    await distribute();\n    await new Promise(r=>setTimeout(r, 420));\n    // Step 2: sort buckets\n    await sortBuckets();\n    await new Promise(r=>setTimeout(r, 420));\n    // Step 3: collect\n    await collect();\n    // finalize\n    running = false;\n    startBtn.disabled = false;\n    randBtn.disabled = false;\n    status.textContent = 'Finished — press Randomize for a new example or Start to replay.';\n  }\n\n  // Reset layout on randomize\n  function reset(){\n    // remove tokens from wrap\n    const wrap = document.querySelector('.wrap');\n    tokens.forEach(t=>{\n      if(t.el.parentElement) t.el.remove();\n    });\n    createBucketsUI();\n    generateArray();\n  }\n\n  // Initial setup\n  createBucketsUI();\n  generateArray();\n\n  // Event handlers\n  startBtn.addEventListener('click', ()=>{\n    runDemo();\n  });\n  randBtn.addEventListener('click', ()=>{\n    if(running) return;\n    reset();\n  });\n\n  // Defensive: reposition tokens on resize (simple snap)\n  window.addEventListener('resize', ()=>{\n    if(running) return;\n    // Recreate, to keep layout consistent\n    createBucketsUI();\n    generateArray();\n  });\n\n  // Accessibility small animation when hovered\n  document.querySelectorAll('button').forEach(b=>{\n    b.addEventListener('mouseenter', ()=> b.style.transform='translateY(-2px)');\n    b.addEventListener('mouseleave', ()=> b.style.transform='none');\n  });\n\n})();\n</script>\n</body>\n</html>"
