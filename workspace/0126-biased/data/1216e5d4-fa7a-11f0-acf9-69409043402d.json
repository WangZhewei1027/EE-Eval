  "question": "Garbage Collection",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Garbage Collection Interactive Simulator</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n    font-family: monospace, monospace;\n  }\n  select, input, button {\n    font-family: monospace, monospace;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n  pre {\n    background: #eee;\n    padding: 0.5em;\n    white-space: pre-wrap;\n    max-height: 15em;\n    overflow-y: auto;\n  }\n  .inline {\n    display: inline-block;\n    margin-right: 1em;\n  }\n</style>\n</head>\n<body>\n<h1>Garbage Collection Interactive Simulator</h1>\n\n<p>\nThis simulator models a heap with objects, references, and roots. You can create objects,\nlink references, set roots, and trigger different garbage collection algorithms to see\nwhat objects get collected or preserved.\n</p>\n\n<div>\n  <fieldset>\n    <legend>Heap Objects Management</legend>\n    <label>\n      New Object ID (integer ≥1):\n      <input type=\"number\" id=\"newObjId\" min=\"1\" step=\"1\" value=\"1\" />\n      <button id=\"createObjBtn\">Create Object</button>\n    </label>\n    <label>\n      Existing Objects: \n      <select id=\"existingObjs\" size=\"5\" style=\"width:8em;\"></select>\n    </label>\n    <div id=\"objDetails\" style=\"white-space: pre-wrap; font-size: 0.9em;\"></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>References Management</legend>\n    <label>\n      From Object:\n      <select id=\"refFrom\"></select>\n    </label>\n    <label>\n      To Object:\n      <select id=\"refTo\"></select>\n    </label>\n    <button id=\"addRefBtn\">Add Reference</button>\n    <button id=\"removeRefBtn\">Remove Reference</button>\n    <label>\n      References of <span id=\"currentRefObj\">-</span>:\n      <select id=\"refsList\" size=\"5\" style=\"width:8em;\"></select>\n    </label>\n  </fieldset>\n\n  <fieldset>\n    <legend>Roots Management</legend>\n    <label>\n      <input type=\"checkbox\" class=\"rootCheckbox\" id=\"rootObjCheckbox\" />\n      Mark selected object as root\n    </label>\n    <div>Roots: <span id=\"rootsList\"></span></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Garbage Collection Controls</legend>\n    <label>\n      Select GC Algorithm:\n      <select id=\"gcAlgorithm\">\n        <option value=\"markSweep\">Mark & Sweep</option>\n        <option value=\"referenceCounting\">Reference Counting</option>\n        <option value=\"copying\">Copying Collector (semi-space)</option>\n        <option value=\"generational\">Generational (2 generations)</option>\n      </select>\n    </label>\n    <button id=\"runGcBtn\">Run Garbage Collection</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Heap View & Logs</legend>\n    <button id=\"refreshHeapViewBtn\">Refresh Heap View</button>\n    <pre id=\"heapView\" style=\"height: 18em; overflow-y: scroll;\"></pre>\n    <button id=\"clearLogBtn\">Clear Logs</button>\n    <pre id=\"logOutput\" style=\"height: 10em; overflow-y: scroll;\"></pre>\n  </fieldset>\n\n  <fieldset>\n    <legend>Script Simulation</legend>\n    <p>Write a sequence of commands (one per line) to automate object creation, linking, rooting, and garbage collection.</p>\n    <textarea id=\"scriptInput\" placeholder=\"Example commands:\nCREATE 1\nCREATE 2\nLINK 1 2\nROOT 1\nGC markSweep\n\"></textarea><br/>\n    <button id=\"runScriptBtn\">Run Script</button>\n    <button id=\"clearScriptBtn\">Clear Script</button>\n  </fieldset>\n</div>\n\n<script>\n(function(){\n  // Model of the heap and GC simulation\n\n  // Heap stores objects:\n  // object = { id: number, references: Set<number>, refCount: number, generation: 0 or 1 (for generational), marked: boolean }\n  // roots = Set of object ids\n\n  let heap = new Map();\n  let roots = new Set();\n\n  let logs = [];\n\n  // Utilities\n  function log(msg){\n    logs.push(msg);\n    let out = document.getElementById(\"logOutput\");\n    out.textContent = logs.join(\"\\\\n\");\n    out.scrollTop = out.scrollHeight;\n  }\n  function clearLog(){\n    logs = [];\n    document.getElementById(\"logOutput\").textContent = \"\";\n  }\n  function refreshHeapView(){\n    let out = document.getElementById(\"heapView\");\n    let lines = [];\n    lines.push(\"HEAP OBJECTS:\");\n    if(heap.size === 0){\n      lines.push(\"  (no objects)\");\n    } else {\n      for(let [id,obj] of [...heap.entries()].sort((a,b)=>a[0]-b[0])){\n        let refs = [...obj.references].sort((a,b)=>a-b).join(\", \") || \"(none)\";\n        let rootMark = roots.has(id) ? \"[ROOT]\" : \"\";\n        let genMark = (obj.generation === 0) ? \"Gen0\" : \"Gen1\";\n        let refCountDisplay = \"RC=\" + obj.refCount;\n        let marked = (obj.marked) ? \"[marked]\" : \"\";\n        lines.push(`  Object ${id} ${rootMark} ${marked} (${genMark}, Ref to: ${refs}, ${refCountDisplay})`);\n      }\n    }\n    out.textContent = lines.join(\"\\\\n\");\n    out.scrollTop = 0;\n  }\n\n  // Update the object selects in the UI\n  function updateObjectSelects(){\n    const selects = [document.getElementById(\"existingObjs\"),\n                     document.getElementById(\"refFrom\"),\n                     document.getElementById(\"refTo\")];\n    for(let sel of selects){\n      let oldValue = sel.value;\n      sel.innerHTML = \"\";\n      for(let id of [...heap.keys()].sort((a,b) => a-b)){\n        let opt = document.createElement(\"option\");\n        opt.value = id;\n        opt.textContent = id;\n        sel.appendChild(opt);\n      }\n      // try to keep old selection\n      if(oldValue && sel.querySelector(`option[value='${oldValue}']`)){\n        sel.value = oldValue;\n      } else if(sel.options.length > 0){\n        sel.selectedIndex = 0;\n      }\n    }\n    updateReferencesList();\n    updateRootsUI();\n    updateObjectDetails();\n    refreshHeapView();\n  }\n\n  // Update references of selected object\n  function updateReferencesList(){\n    let refList = document.getElementById(\"refsList\");\n    refList.innerHTML = \"\";\n    let fromSel = document.getElementById(\"refFrom\");\n    let objId = Number(fromSel.value);\n    if(!heap.has(objId)){\n      document.getElementById(\"currentRefObj\").textContent = \"-\";\n      return;\n    }\n    document.getElementById(\"currentRefObj\").textContent = objId;\n    let obj = heap.get(objId);\n    for(let refId of [...obj.references].sort((a,b)=>a-b)){\n      let opt = document.createElement(\"option\");\n      opt.value = refId;\n      opt.textContent = refId;\n      refList.appendChild(opt);\n    }\n  }\n\n  // Update roots checkbox for selected object\n  function updateRootsUI(){\n    let existsObjs = document.getElementById(\"existingObjs\");\n    let id = Number(existsObjs.value);\n    let cb = document.getElementById(\"rootObjCheckbox\");\n    if(heap.has(id)){\n      cb.disabled = false;\n      cb.checked = roots.has(id);\n    } else {\n      cb.disabled = true;\n      cb.checked = false;\n    }\n  }\n\n  // Show details for selected object\n  function updateObjectDetails(){\n    let existsObjs = document.getElementById(\"existingObjs\");\n    let id = Number(existsObjs.value);\n    let det = document.getElementById(\"objDetails\");\n    if(!heap.has(id)){\n      det.textContent = \"\";\n      return;\n    }\n    let obj = heap.get(id);\n    let lines = [];\n    lines.push(`Object ID: ${id}`);\n    lines.push(`References to: ${[...obj.references].sort((a,b)=>a-b).join(\", \") || \"(none)\"}`);\n    lines.push(`Reference count: ${obj.refCount}`);\n    lines.push(`Generation: ${obj.generation === 0 ? \"0 (young)\" : \"1 (old)\"}`);\n    lines.push(`Rooted: ${roots.has(id) ? \"Yes\" : \"No\"}`);\n    lines.push(`Marked (last GC): ${obj.marked ? \"Yes\" : \"No\"}`);\n    det.textContent = lines.join(\"\\\\n\");\n  }\n\n  // Modifiers\n  function createObject(id){\n    if(heap.has(id)){\n      log(`Failed to create object ${id}: already exists.`);\n      return false;\n    }\n    heap.set(id, { id:id, references: new Set(), refCount:0, generation: 0, marked:false });\n    log(`Created object ${id}`);\n    updateObjectSelects();\n    return true;\n  }\n\n  function addReference(fromId, toId){\n    if(!heap.has(fromId) || !heap.has(toId)){\n      log(`Cannot add reference from ${fromId} to ${toId}: one or both objects do not exist.`);\n      return false;\n    }\n    let fromObj = heap.get(fromId);\n    if(fromObj.references.has(toId)){\n      log(`Reference from ${fromId} to ${toId} already exists.`);\n      return false;\n    }\n    fromObj.references.add(toId);\n    // Increase refCount of toId\n    let toObj = heap.get(toId);\n    toObj.refCount++;\n    log(`Added reference from ${fromId} to ${toId}`);\n    updateObjectSelects();\n    return true;\n  }\n\n  function removeReference(fromId, toId){\n    if(!heap.has(fromId) || !heap.has(toId)){\n      log(`Cannot remove reference from ${fromId} to ${toId}: one or both objects do not exist.`);\n      return false;\n    }\n    let fromObj = heap.get(fromId);\n    if(!fromObj.references.has(toId)){\n      log(`Reference from ${fromId} to ${toId} does not exist.`);\n      return false;\n    }\n    fromObj.references.delete(toId);\n    // Decrement refCount of toId\n    let toObj = heap.get(toId);\n    toObj.refCount = Math.max(0, toObj.refCount - 1);\n    log(`Removed reference from ${fromId} to ${toId}`);\n    updateObjectSelects();\n    return true;\n  }\n\n  function setRoot(id, isRoot){\n    if(!heap.has(id)){\n      log(`Cannot modify root: object ${id} does not exist.`);\n      return false;\n    }\n    if(isRoot){\n      if(!roots.has(id)){\n        roots.add(id);\n        heap.get(id).refCount++;\n        log(`Object ${id} set as root (refCount incremented)`);\n      } else {\n        log(`Object ${id} is already root.`);\n      }\n    } else {\n      if(roots.has(id)){\n        roots.delete(id);\n        let obj = heap.get(id);\n        obj.refCount = Math.max(0, obj.refCount - 1);\n        log(`Object ${id} removed from roots (refCount decremented)`);\n      } else {\n        log(`Object ${id} was not a root.`);\n      }\n    }\n    updateObjectSelects();\n    return true;\n  }\n\n  // Garbage Collection Algorithms\n\n  // 1. Mark & Sweep\n  function gcMarkSweep(){\n    log(\"Starting Mark & Sweep GC\");\n    // Clear marks\n    for(let obj of heap.values()){\n      obj.marked = false;\n    }\n    // Mark phase\n    function mark(obj){\n      if(obj.marked) return;\n      obj.marked = true;\n      log(`Marked object ${obj.id}`);\n      for(let refId of obj.references){\n        if(heap.has(refId)){\n          mark(heap.get(refId));\n        }\n      }\n    }\n    for(let rootId of roots){\n      if(heap.has(rootId)){\n        mark(heap.get(rootId));\n      }\n    }\n    // Sweep phase: collect unmarked\n    let collected = [];\n    for(let [id, obj] of heap.entries()){\n      if(!obj.marked){\n        collected.push(id);\n      }\n    }\n    for(let id of collected){\n      heap.delete(id);\n      // Remove roots if any (should not occur)\n      roots.delete(id);\n      log(`Collected unreachable object ${id}`);\n    }\n    log(`Mark & Sweep GC collected ${collected.length} objects.`);\n  }\n\n  // 2. Reference Counting\n  // In this simulation, reference counts updated on references added/removed and roots set/unset.\n  // We also simulate cleanup here by repeatedly removing objects with ref count 0,\n  // cascading because their references' refCounts should decrease.\n  // We'll implement a simple process for that.\n  function gcReferenceCounting(){\n    log(\"Starting Reference Counting GC\");\n    let toCollect = [];\n    // Find all objects with refCount==0\n    for(let [id,obj] of heap.entries()){\n      if(obj.refCount === 0){\n        toCollect.push(id);\n      }\n    }\n    let collectedCount = 0;\n    while(toCollect.length > 0){\n      let id = toCollect.pop();\n      if(!heap.has(id)) continue;\n      let obj = heap.get(id);\n      // Remove the object\n      heap.delete(id);\n      roots.delete(id);\n      collectedCount++;\n      log(`Collected object ${id} due to zero refCount`);\n      // Decrement refCount of all objects it referenced\n      for(let refId of obj.references){\n        if(heap.has(refId)){\n          let refObj = heap.get(refId);\n          refObj.refCount = Math.max(0, refObj.refCount - 1);\n          if(refObj.refCount === 0){\n            toCollect.push(refId);\n          }\n        }\n      }\n    }\n    log(`Reference Counting GC collected ${collectedCount} objects.`);\n  }\n\n  // 3. Copying Collector (Semi-Space)\n  // We simulate two spaces: fromSpace and toSpace, store objects in one.\n  // We move all objects reachable from roots to toSpace.\n  // Unreachable are discarded.\n  // Swap spaces after collection.\n  // This simulates compaction.\n  let semiSpace = { fromSpace: new Map(), toSpace: new Map(), usingFromSpace:true };\n  // Copy all objects from heap to fromSpace initially\n  function resetSemiSpaceFromHeap(){\n    semiSpace.fromSpace = new Map();\n    semiSpace.toSpace = new Map();\n    semiSpace.usingFromSpace = true;\n    for(let [id,obj] of heap){\n      // Make shallow copy but references are IDs only\n      semiSpace.fromSpace.set(id, {\n        id:id,\n        references: new Set(obj.references),\n        generation: obj.generation,\n        marked: false,\n        refCount: obj.refCount\n      });\n    }\n  }\n  function gcCopying(){\n    log(\"Starting Copying Collector GC\");\n    resetSemiSpaceFromHeap();\n    let fromSpace = semiSpace.fromSpace;\n    let toSpace = new Map();\n    let worklist = [];\n\n    function copyObject(id){\n      if(toSpace.has(id)) return; // already copied\n      if(!fromSpace.has(id)) return;\n      let fromObj = fromSpace.get(id);\n      // Copy object shallowly\n      toSpace.set(id, {\n        id: id,\n        references: new Set(),\n        generation: fromObj.generation,\n        marked: false,\n        refCount:0\n      });\n      worklist.push(id);\n      log(`Copied object ${id} to toSpace`);\n    }\n\n    // Start by copying roots\n    for(let rid of roots){\n      copyObject(rid);\n    }\n\n    // Traverse references\n    while(worklist.length > 0){\n      let oid = worklist.pop();\n      let obj = toSpace.get(oid);\n      let fromObj = fromSpace.get(oid);\n      for(let refId of fromObj.references){\n        // Copy referenced object\n        copyObject(refId);\n        obj.references.add(refId);\n      }\n    }\n\n    // Recalculate refCounts (simulate)\n    for(let obj of toSpace.values()){\n      obj.refCount = 0;\n    }\n    for(let obj of toSpace.values()){\n      for(let refId of obj.references){\n        if(toSpace.has(refId)){\n          toSpace.get(refId).refCount++;\n        }\n      }\n    }\n    for(let rid of roots){\n      if(toSpace.has(rid)){\n        toSpace.get(rid).refCount++;\n      }\n    }\n\n    semiSpace.fromSpace = toSpace;\n    semiSpace.toSpace = new Map();\n    semiSpace.usingFromSpace = true;\n\n    // Update main heap to toSpace cloned objects\n    heap.clear();\n    for(let [id, obj] of toSpace){\n      heap.set(id, {\n        id:id,\n        references: new Set(obj.references),\n        refCount: obj.refCount,\n        generation: obj.generation,\n        marked: false\n      });\n    }\n    log(`Copying Collector GC completed. Heap compacted. Collected objects: ${[...fromSpace.keys()].filter(k => !heap.has(k)).length}`);\n  }\n\n  // 4. Generational GC (2 generations: Gen0 young, Gen1 old)\n  // Young gen: collected frequently with mark-sweep\n  // Old gen: collected less frequently (only by Reference Counting simulation here)\n  // Objects survive a number of GC cycles in young generation and get promoted.\n  // We'll keep an \"age\" counter per object in young gen.\n\n  // Extend each object with obj.age (integer)\n  // Objects created start age 0 in generation 0\n  // Define parameters:\n  const PROMOTION_AGE = 2; // survive 2 young GCs to promote to old\n\n  let genCycleCount = 0; // count how many generational GC cycles done\n\n  // On each GC:\n  // 1) Mark & Sweep young gen objects\n  // 2) Increase age of survivor young gen objects\n  // 3) Promote if age >= PROMOTION_AGE\n  // 4) Old gen collected by RC algorithm (simulate)\n\n  // Implement generational GC\n  function gcGenerational(){\n    log(\"Starting Generational GC\");\n    genCycleCount++;\n    // Step 1: mark & sweep young gen (generation 0)\n    // Clear marks\n    for(let obj of heap.values()){\n      obj.marked = false;\n    }\n    // mark all roots and follow references, but only mark young gen objects here\n\n    // Mark function that marks young gen objects only and recursively visits their refs regardless gen\n    function markGen0(obj){\n      if(obj.generation === 0){\n        if(obj.marked) return;\n        obj.marked = true;\n      }\n      for(let rid of obj.references){\n        if(heap.has(rid)){\n          markGen0(heap.get(rid));\n        }\n      }\n    }\n    for(let rid of roots){\n      if(heap.has(rid)){\n        markGen0(heap.get(rid));\n      }\n    }\n    // Sweep young gen\n    let collectedYoung = [];\n    for(let [id, obj] of heap.entries()){\n      if(obj.generation === 0 && !obj.marked){\n        collectedYoung.push(id);\n        heap.delete(id);\n        roots.delete(id);\n        log(`Collected young generation unreachable object ${id} (Mark & Sweep)`);\n      }\n    }\n    // Step 2: Increase age of surviving young gen objects (marked ones)\n    for(let id of heap.keys()){\n      let obj = heap.get(id);\n      if(obj.generation === 0 && obj.marked){\n        obj.age = (obj.age||0) + 1;\n        log(`Increased age of object ${id} to ${obj.age}`);\n      }\n    }\n    // Step 3: Promote if aged enough\n    for(let id of heap.keys()){\n      let obj = heap.get(id);\n      if(obj.generation === 0 && (obj.age||0) >= PROMOTION_AGE){\n        obj.generation = 1;\n        delete obj.age;\n        log(`Promoted object ${id} to old generation`);\n      }\n    }\n    // Step 4: Collect old generation using Reference Counting\n    // Remove old gen objects with zero refCount\n    let oldGenObjects = [...heap.entries()].filter(([id,obj]) => obj.generation === 1);\n    // Recalculate refCount for old gen as no update from young links\n    // We recount reference counts of old gen objects only from other old gen and roots\n    // For simplicity assume roots count for both generations\n    for(let [id,obj] of oldGenObjects){\n      obj.refCount = 0;\n    }\n    for(let [id,obj] of oldGenObjects){\n      for(let rid of obj.references){\n        if(heap.has(rid)){\n          let refObj = heap.get(rid);\n          if(refObj.generation === 1){\n            refObj.refCount++;\n          }\n        }\n      }\n    }\n    for(let rid of roots){\n      if(heap.has(rid)){\n        let rObj = heap.get(rid);\n        if(rObj.generation === 1){\n          rObj.refCount++;\n        }\n      }\n    }\n    // Collect old gen objects with refCount 0\n    let collectedOld = [];\n    for(let [id,obj] of oldGenObjects){\n      if(obj.refCount === 0){\n        heap.delete(id);\n        roots.delete(id);\n        collectedOld.push(id);\n        log(`Collected old generation unreferenced object ${id} (Reference Counting)`);\n      }\n    }\n    log(`Generational GC summary: collected young: ${collectedYoung.length}, old: ${collectedOld.length}`);\n  }\n\n  // Run selected GC algorithm\n  function runGCSelected(){\n    let algo = document.getElementById(\"gcAlgorithm\").value;\n    switch(algo){\n      case \"markSweep\": gcMarkSweep(); break;\n      case \"referenceCounting\": gcReferenceCounting(); break;\n      case \"copying\": gcCopying(); break;\n      case \"generational\": gcGenerational(); break;\n      default: log(\"Unknown GC algorithm selected.\"); break;\n    }\n    updateObjectSelects();\n    refreshHeapView();\n  }\n\n  // UI Event Handlers\n  document.getElementById(\"createObjBtn\").addEventListener(\"click\", function(){\n    let id = Number(document.getElementById(\"newObjId\").value);\n    if(!Number.isInteger(id)||id < 1){\n      alert(\"Object ID must be an integer ≥ 1.\");\n      return;\n    }\n    createObject(id);\n  });\n\n  document.getElementById(\"existingObjs\").addEventListener(\"change\", function(){\n    let id = Number(this.value);\n    updateObjectDetails();\n    updateRootsUI();\n  });\n  document.getElementById(\"refFrom\").addEventListener(\"change\", updateReferencesList);\n\n  document.getElementById(\"addRefBtn\").addEventListener(\"click\", function(){\n    let fromId = Number(document.getElementById(\"refFrom\").value);\n    let toId = Number(document.getElementById(\"refTo\").value);\n    if(fromId === toId){\n      alert(\"An object cannot reference itself.\");\n      return;\n    }\n    addReference(fromId, toId);\n  });\n  document.getElementById(\"removeRefBtn\").addEventListener(\"click\", function(){\n    let fromId = Number(document.getElementById(\"refFrom\").value);\n    let refsList = document.getElementById(\"refsList\");\n    if(refsList.selectedIndex < 0){\n      alert(\"Select a reference to remove.\");\n      return;\n    }\n    let toId = Number(refsList.value);\n    removeReference(fromId, toId);\n  });\n\n  document.getElementById(\"rootObjCheckbox\").addEventListener(\"change\", function(){\n    let existsObjs = document.getElementById(\"existingObjs\");\n    let id = Number(existsObjs.value);\n    setRoot(id, this.checked);\n  });\n\n  document.getElementById(\"runGcBtn\").addEventListener(\"click\", function(){\n    runGCSelected();\n  });\n\n  document.getElementById(\"refreshHeapViewBtn\").addEventListener(\"click\", function(){\n    refreshHeapView();\n  });\n  document.getElementById(\"clearLogBtn\").addEventListener(\"click\", clearLog);\n\n  // Script processing\n  // Commands:\n  // CREATE <id>\n  // LINK <fromId> <toId>\n  // UNLINK <fromId> <toId>\n  // ROOT <id>\n  // UNROOT <id>\n  // GC <algorithm>  (markSweep, referenceCounting, copying, generational)\n  // CLEARLOG\n  // REFRESHHEAP\n  // Comments start with # or //\n  // Blank lines ignored\n\n  function runScript(scriptText){\n    clearLog();\n    log(\"Running Script...\");\n    let lines = scriptText.split(\"\\\\n\");\n    let lineNum = 0;\n    for(let l of lines){\n      lineNum++;\n      let line = l.trim();\n      if(line === \"\" || line.startsWith(\"#\") || line.startsWith(\"//\")) continue;\n      let parts = line.split(/\\s+/);\n      let cmd = parts[0].toUpperCase();\n      try{\n        switch(cmd){\n          case \"CREATE\":\n            if(parts.length < 2) throw \"CREATE command needs an object ID\";\n            let id = Number(parts[1]);\n            if(!Number.isInteger(id) || id < 1) throw \"Invalid object ID\";\n            createObject(id);\n            break;\n          case \"LINK\":\n            if(parts.length < 3) throw \"LINK command needs from and to IDs\";\n            let f1 = Number(parts[1]), t1 = Number(parts[2]);\n            if(f1 === t1) throw \"Cannot LINK object to itself\";\n            addReference(f1, t1);\n            break;\n          case \"UNLINK\":\n            if(parts.length < 3) throw \"UNLINK command needs from and to IDs\";\n            let f2 = Number(parts[1]), t2 = Number(parts[2]);\n            removeReference(f2, t2);\n            break;\n          case \"ROOT\":\n            if(parts.length < 2) throw \"ROOT command needs object ID\";\n            let rID = Number(parts[1]);\n            setRoot(rID, true);\n            break;\n          case \"UNROOT\":\n            if(parts.length < 2) throw \"UNROOT command needs object ID\";\n            let urID = Number(parts[1]);\n            setRoot(urID, false);\n            break;\n          case \"GC\":\n            if(parts.length < 2) throw \"GC command needs algorithm name\";\n            let algo = parts[1];\n            if(![\"markSweep\",\"referenceCounting\",\"copying\",\"generational\"].includes(algo)){\n              throw \"Unsupported GC algorithm: \"+algo;\n            }\n            document.getElementById(\"gcAlgorithm\").value = algo;\n            runGCSelected();\n            break;\n          case \"CLEARLOG\":\n            clearLog();\n            break;\n          case \"REFRESHHEAP\":\n            refreshHeapView();\n            updateObjectSelects();\n            break;\n          default:\n            throw \"Unknown command: \"+cmd;\n        }\n      } catch(e){\n        log(`Error at line ${lineNum}: ${e}`);\n      }\n    }\n    log(\"Script completed.\");\n    refreshHeapView();\n    updateObjectSelects();\n  }\n\n  document.getElementById(\"runScriptBtn\").addEventListener(\"click\", function(){\n    let script = document.getElementById(\"scriptInput\").value;\n    runScript(script);\n  });\n  document.getElementById(\"clearScriptBtn\").addEventListener(\"click\", function(){\n    document.getElementById(\"scriptInput\").value = \"\";\n  });\n\n  // Initialize interface with empty heap\n  updateObjectSelects();\n  refreshHeapView();\n  clearLog();\n\n})();\n</script>\n</body>\n</html>"
  },
  "messages": [
