    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Backtracking Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .visualization {\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 300px;\n            font-family: monospace;\n            white-space: pre;\n            overflow: auto;\n        }\n        .state-info {\n            margin-top: 20px;\n            border-top: 1px solid #000;\n            padding-top: 10px;\n        }\n        button, select, input {\n            padding: 5px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Backtracking Algorithm Explorer</h1>\n        \n        <div class=\"controls\">\n            <div>\n                <h3>Problem Type</h3>\n                <select id=\"problemType\">\n                    <option value=\"nqueens\">N-Queens</option>\n                    <option value=\"sudoku\">Sudoku</option>\n                    <option value=\"maze\">Maze Solver</option>\n                    <option value=\"subset\">Subset Sum</option>\n                </select>\n            </div>\n            \n            <div>\n                <h3>Problem Size</h3>\n                <input type=\"range\" id=\"problemSize\" min=\"3\" max=\"10\" value=\"4\">\n                <span id=\"sizeValue\">4</span>\n            </div>\n            \n            <div>\n                <h3>Speed</h3>\n                <input type=\"range\" id=\"speed\" min=\"50\" max=\"2000\" value=\"500\">\n                <span id=\"speedValue\">500ms</span>\n            </div>\n            \n            <div>\n                <h3>Algorithm Control</h3>\n                <button id=\"startBtn\">Start</button>\n                <button id=\"stepBtn\">Step</button>\n                <button id=\"resetBtn\">Reset</button>\n            </div>\n            \n            <div>\n                <h3>Visualization Mode</h3>\n                <select id=\"visualMode\">\n                    <option value=\"full\">Full State</option>\n                    <option value=\"current\">Current Path</option>\n                    <option value=\"compact\">Compact</option>\n                </select>\n            </div>\n            \n            <div>\n                <h3>Heuristics</h3>\n                <select id=\"heuristic\">\n                    <option value=\"none\">None</option>\n                    <option value=\"mrv\">Minimum Remaining Values</option>\n                    <option value=\"degree\">Degree Heuristic</option>\n                </select>\n            </div>\n        </div>\n        \n        <div class=\"visualization\" id=\"visualization\"></div>\n        \n        <div class=\"state-info\">\n            <h3>Current State Information</h3>\n            <div id=\"stateDetails\"></div>\n            <div id=\"backtrackCount\">Backtracks: 0</div>\n            <div id=\"stepsCount\">Steps: 0</div>\n        </div>\n    </div>\n\n    <script>\n        // Global state\n        let currentProblem = 'nqueens';\n        let problemSize = 4;\n        let speed = 500;\n        let running = false;\n        let intervalId = null;\n        let steps = 0;\n        let backtracks = 0;\n        let currentState = [];\n        let solution = [];\n        let history = [];\n        let currentIndex = 0;\n        \n        // DOM elements\n        const problemTypeSelect = document.getElementById('problemType');\n        const problemSizeInput = document.getElementById('problemSize');\n        const sizeValueSpan = document.getElementById('sizeValue');\n        const speedInput = document.getElementById('speed');\n        const speedValueSpan = document.getElementById('speedValue');\n        const startBtn = document.getElementById('startBtn');\n        const stepBtn = document.getElementById('stepBtn');\n        const resetBtn = document.getElementById('resetBtn');\n        const visualModeSelect = document.getElementById('visualMode');\n        const heuristicSelect = document.getElementById('heuristic');\n        const visualizationDiv = document.getElementById('visualization');\n        const stateDetailsDiv = document.getElementById('stateDetails');\n        const backtrackCountDiv = document.getElementById('backtrackCount');\n        const stepsCountDiv = document.getElementById('stepsCount');\n        \n        // Event listeners\n        problemTypeSelect.addEventListener('change', (e) => {\n            currentProblem = e.target.value;\n            resetProblem();\n        });\n        \n        problemSizeInput.addEventListener('input', (e) => {\n            problemSize = parseInt(e.target.value);\n            sizeValueSpan.textContent = problemSize;\n            resetProblem();\n        });\n        \n        speedInput.addEventListener('input', (e) => {\n            speed = parseInt(e.target.value);\n            speedValueSpan.textContent = speed + 'ms';\n            if (running) {\n                clearInterval(intervalId);\n                startAlgorithm();\n            }\n        });\n        \n        startBtn.addEventListener('click', () => {\n            if (running) {\n                stopAlgorithm();\n                startBtn.textContent = 'Start';\n            } else {\n                startAlgorithm();\n                startBtn.textContent = 'Stop';\n            }\n        });\n        \n        stepBtn.addEventListener('click', () => {\n            if (!running) {\n                performStep();\n            }\n        });\n        \n        resetBtn.addEventListener('click', () => {\n            resetProblem();\n        });\n        \n        visualModeSelect.addEventListener('change', () => {\n            updateVisualization();\n        });\n        \n        // Initialize\n        resetProblem();\n        \n        // Problem-specific functions\n        function initializeProblem() {\n            steps = 0;\n            backtracks = 0;\n            currentIndex = 0;\n            history = [];\n            \n            switch(currentProblem) {\n                case 'nqueens':\n                    currentState = Array(problemSize).fill(-1);\n                    break;\n                case 'sudoku':\n                    currentState = Array(problemSize*problemSize).fill(0);\n                    // Add some fixed numbers for Sudoku\n                    for (let i = 0; i < Math.floor(problemSize/2); i++) {\n                        const pos = Math.floor(Math.random() * problemSize*problemSize);\n                        const num = Math.floor(Math.random() * problemSize) + 1;\n                        currentState[pos] = num;\n                    }\n                    break;\n                case 'maze':\n                    currentState = Array(problemSize*problemSize).fill(0);\n                    // Create walls\n                    for (let i = 0; i < problemSize*2; i++) {\n                        const pos = Math.floor(Math.random() * problemSize*problemSize);\n                        currentState[pos] = 1; // 1 represents a wall\n                    }\n                    // Set start and end\n                    currentState[0] = 2; // Start\n                    currentState[problemSize*problemSize-1] = 3; // End\n                    break;\n                case 'subset':\n                    currentState = Array(problemSize).fill(0).map((_, i) => i+1);\n                    solution = [];\n                    break;\n            }\n            \n            updateVisualization();\n            updateStateDetails();\n        }\n        \n        function performStep() {\n            if (isSolutionFound()) {\n                stopAlgorithm();\n                return;\n            }\n            \n            steps++;\n            stepsCountDiv.textContent = `Steps: ${steps}`;\n            \n            switch(currentProblem) {\n                case 'nqueens':\n                    stepNQueens();\n                    break;\n                case 'sudoku':\n                    stepSudoku();\n                    break;\n                case 'maze':\n                    stepMaze();\n                    break;\n                case 'subset':\n                    stepSubsetSum();\n                    break;\n            }\n            \n            updateVisualization();\n            updateStateDetails();\n        }\n        \n        function stepNQueens() {\n            let row = currentState.indexOf(-1);\n            if (row === -1) return;\n            \n            for (let col = 0; col < problemSize; col++) {\n                if (isQueenSafe(row, col)) {\n                    // Save current state to history\n                    history.push([...currentState]);\n                    currentIndex = history.length;\n                    \n                    currentState[row] = col;\n                    return;\n                }\n            }\n            \n            // No valid position found, need to previous state\n            backtracks();\n        }\n        \n        function isQueenSafe(row, col) {\n            for (let i = 0; i < row; i++) {\n                // Check column\n                if (currentState[i] === col) return false;\n                \n                // Check diagonals\n                if (Math.abs(currentState[i] - col) === Math.abs(i - row)) return false;\n            }\n            return true;\n        }\n        \n        function stepSudoku() {\n            const emptyCell = currentState.indexOf(0);\n            if (emptyCell === -1) return;\n            \n            const row = Math.floor(emptyCell / problemSize);\n            const col = emptyCell % problemSize;\n            \n            for (let num = 1; num <= problemSize; num++) {\n                if (isSudokuValid(row, col, num)) {\n                    history.push([...currentState]);\n                    currentIndex = history.length;\n                    \n                    currentState[emptyCell] = num;\n                    return;\n                }\n            }\n            \n            // No valid number found, backtrack\n            backtracks();\n        }\n        \n        function isSudokuValid(row, col, num) {\n            // Check row\n            for (let i = 0; i < problemSize; i++) {\n                if (currentState[row * problemSize + i] === num) return false;\n            }\n            \n            // Check column\n            for (let i = 0; i < problemSize; i++) {\n                if (currentState[i * problemSize + col] === num) return false;\n            }\n            \n            // Check subgrid (for simplicity, assuming perfect square size)\n            const subSize = Math.sqrt(problemSize);\n            const startRow = row - row % subSize;\n            const startCol = col - col % subSize;\n            \n            for (let i = 0; i < subSize; i++) {\n                for (let j = 0; j < subSize; j++) {\n                    if (currentState[(startRow + i) * problemSize + (startCol + j)] === num) return false;\n                }\n            }\n            \n            return true;\n        }\n        \n        function stepMaze() {\n            // Simplified maze solver - just finds a path\n            const pos = currentState.indexOf(2); // Start position\n            const nextPos = findNextMove(pos);\n            \n            if (nextPos === -1) {\n                backtracks();\n            } else {\n                history.push([...currentState]);\n                currentIndex = history.length;\n                \n                currentState[pos] = 4; // Mark as visited\n                currentState[nextPos] = 2; // Move to new position\n            }\n        }\n        \n        function findNextMove(pos) {\n            const row = Math.floor(pos / problemSize);\n            const col = pos % problemSize;\n            const directions = [\n                {dr: -1, dc: 0}, // up\n                {dr: 1, dc: 0},  // down\n                {dr: 0, dc: -1}, // left\n                {dr: 0, dc: 1}   // right\n            ];\n            \n            for (const dir of directions) {\n                const newRow = row + dir.dr;\n                const newCol = col + dir.dc;\n                if (newRow >= 0 && newRow < problemSize && newCol >= 0 && newCol < problemSize) {\n                    const newPos = newRow * problemSize + newCol;\n                    if (currentState[newPos] === 3) return newPos; // Found exit\n                    if (currentState[newPos] === 0) return newPos; // Empty cell\n                }\n            }\n            \n            return -1;\n        }\n        \n        function stepSubsetSum() {\n            // Target sum is half of total sum (partition problem)\n            const totalSum = currentState.reduce((a, b) => a + b, 0);\n            const target = Math.floor(totalSum / 2);\n            \n            if (solution.reduce((a, b) => a + b, 0) === target) {\n                return; // Solution found\n            }\n            \n            if (solution.length >= currentState.length) {\n                backtracks();\n                return;\n            }\n            \n            // Try adding next number\n            const nextNum = currentState[solution.length];\n            history.push([...solution]);\n            currentIndex = history.length;\n            \n            solution.push(nextNum);\n        }\n        \n        function backtracks() {\n            backtracks++;\n            backtrackCountDiv.textContent = `Backtracks: ${backtracks}`;\n            \n            if (history.length === 0) {\n                // No more backtracking possible\n                stopAlgorithm();\n                return;\n            }\n            \n            // Revert to previous state\n            currentIndex--;\n            if (currentIndex < 0) currentIndex = 0;\n            \n            switch(currentProblem) {\n                case 'nqueens':\n                case 'sudoku':\n                case 'maze':\n                    currentState = [...history[currentIndex]];\n                    break;\n                case 'subset':\n                    solution = [...history[currentIndex]];\n                    break;\n            }\n            \n            // Remove future history\n            history = history.slice(0, currentIndex);\n        }\n        \n        function isSolutionFound() {\n            switch(currentProblem) {\n                case 'nqueens':\n                    return currentState.includes(-1) === false;\n                case 'sudoku':\n                    return currentState.includes(0) === false;\n                case 'maze':\n                    const pos = currentState.indexOf(2); // Current position\n                    const endPos = currentState.indexOf(3); // End position\n                    return pos === endPos;\n                case 'subset':\n                    const totalSum = currentState.reduce((a, b) => a + b, 0);\n                    const target = Math.floor(totalSum / 2);\n                    return solution.reduce((a, b) => a + b, 0) === target;\n            }\n            return false;\n        }\n        \n        function updateVisualization() {\n            let visualization = '';\n            const visualMode = visualModeSelect.value;\n            \n            switch(currentProblem) {\n                case 'nqueens':\n                    if (visualMode === 'compact') {\n                        visualization = currentState.map((col, row) => \n                            `Row ${row}: ${col === -1 ? 'Empty' : 'Queen at column ' + col}`\n                        ).join('\\n');\n                    } else {\n                        for (let row = 0; row < problemSize; row++) {\n                            for (let col = 0; col < problemSize; col++) {\n                                visualization += currentState[row] === col ? 'Q ' : '. ';\n                            }\n                            visualization += '\\n';\n                        }\n                    }\n                    break;\n                    \n                case 'sudoku':\n                    for (let row = 0; row < problemSize; row++) {\n                        for (let col = 0; col < problemSize; col++) {\n                            const val = currentState[row * problemSize + col];\n                            visualization += (val === 0 ? '.' : val) + ' ';\n                            if ((col + 1) % Math.sqrt(problemSize) === 0 && col !== problemSize - 1) {\n                                visualization += '| ';\n                            }\n                        }\n                        visualization += '\\n';\n                        if ((row + 1) % Math.sqrt(problemSize) === 0 && row !== problemSize - 1) {\n                            visualization += '-'.repeat(problemSize * 2 + Math.sqrt(problemSize) * 2 - 3) + '\\n';\n                        }\n                    }\n                    break;\n                    \n                case 'maze':\n                    for (let row = 0; row < problemSize; row++) {\n                        for (let col = 0; col < problemSize; col++) {\n                            const val = currentState[row * problemSize + col];\n                            visualization += \n                                val === 0 ? '. ' : \n                                val === 1 ? '# ' : \n                                val === 2 ? 'S ' : \n                                val === 3 ? 'E ' : 'V ';\n                        }\n                        visualization += '\\n';\n                    }\n                    break;\n                    \n                case 'subset':\n                    visualization = `Set: [${currentState.join(', ')}]\\n`;\n                    visualization += `Current subset: [${solution.join(', ')}]\\n`;\n                    visualization += `Sum: ${solution.reduce((a, b) => a + b, 0)}`;\n                    visualization += ` (Target: ${Math.floor(currentState.reduce((a, b) => a + b, 0) / 2)})`;\n                    break;\n            }\n            \n            visualizationDiv.textContent = visualization;\n        }\n        \n        function updateStateDetails() {\n            let details = '';\n            \n            switch(currentProblem) {\n                case 'nqueens':\n                    const placedQueens = currentState.filter(x => x !== -1).length;\n                    details = `Placed queens: ${placedQueens}/${problemSize}`;\n                    break;\n                    \n                case 'sudoku':\n                    const emptyCells = currentState.filter(x => x === 0).length;\n                    details = `Empty cells: ${emptyCells}`;\n                    break;\n                    \n                case 'maze':\n                    const pos = currentState.indexOf(2);\n                    details = `Current position: (${Math.floor(pos / problemSize)}, ${pos % problemSize})`;\n                    break;\n                    \n                case 'subset':\n                    details = `Subset size: ${solution.length}/${currentState.length}`;\n                    break;\n            }\n            \n            if (isSolutionFound()) {\n                details += '\\nSOLUTION FOUND!';\n            }\n            \n            stateDetailsDiv.textContent = details;\n        }\n        \n        function startAlgorithm() {\n            running = true;\n            intervalId = setInterval(performStep, speed);\n        }\n        \n        function stopAlgorithm() {\n            running = false;\n            clearInterval(intervalId);\n            startBtn.textContent = 'Start';\n        }\n        \n        function resetProblem() {\n            stopAlgorithm();\n            initializeProblem();\n        }\n    </script>\n</body>\n</html>"
  },
