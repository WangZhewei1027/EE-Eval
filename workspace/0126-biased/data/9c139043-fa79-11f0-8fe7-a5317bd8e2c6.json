    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Priority Queue — Interactive Demo</title>\n<style>\n  /* Extremely minimal styling: plain black text on white background, simple layout */\n  body { font-family: sans-serif; margin: 12px; color: #000; background: #fff; }\n  h1 { font-size: 18px; margin: 6px 0; }\n  .row { margin: 6px 0; }\n  label { margin-right: 6px; }\n  input[type=\"text\"], input[type=\"number\"], select, button, textarea { font: inherit; }\n  textarea { width: 100%; height: 120px; }\n  .panel { border: 1px solid #000; padding: 8px; margin: 6px 0; }\n  pre { font-family: monospace; white-space: pre-wrap; word-wrap: break-word; }\n  .small { font-size: 12px; }\n  button { margin-right: 6px; margin-bottom: 6px; }\n  .controls { display:block; }\n</style>\n</head>\n<body>\n  <h1>Priority Queue — Interactive Demo</h1>\n\n  <div class=\"panel\">\n    <div class=\"row\">\n      <label for=\"impl\">Implementation:</label>\n      <select id=\"impl\">\n        <option value=\"binary\">Binary Heap</option>\n        <option value=\"sorted\">Sorted Array</option>\n        <option value=\"unsorted\">Unsorted Array</option>\n      </select>\n\n      <label for=\"mode\">Mode:</label>\n      <select id=\"mode\">\n        <option value=\"max\">MAX (largest priority first)</option>\n        <option value=\"min\">MIN (smallest priority first)</option>\n      </select>\n\n      <label><input type=\"checkbox\" id=\"stable\" checked> Stable (tie-break by insertion)</label>\n    </div>\n\n    <div class=\"row\">\n      <label for=\"valueInput\">Value:</label>\n      <input id=\"valueInput\" type=\"text\" value=\"item\">\n\n      <label for=\"priorityInput\">Priority:</label>\n      <input id=\"priorityInput\" type=\"number\" value=\"10\" step=\"1\">\n\n      <button id=\"enqueueBtn\">Enqueue</button>\n      <button id=\"peekBtn\">Peek</button>\n      <button id=\"dequeueBtn\">Dequeue</button>\n      <button id=\"clearBtn\">Clear</button>\n    </div>\n\n    <div class=\"row\">\n      <label for=\"generateCount\">Random count:</label>\n      <input id=\"generateCount\" type=\"range\" min=\"1\" max=\"200\" value=\"10\">\n      <span id=\"generateCountLabel\">10</span>\n\n      <label for=\"randomSeed\">Seed (optional):</label>\n      <input id=\"randomSeed\" type=\"text\" placeholder=\"seed\">\n\n      <button id=\"randomBtn\">Generate Random</button>\n\n      <select id=\"randomPreset\">\n        <option value=\"random\">Random priorities</option>\n        <option value=\"ascending\">Ascending priorities</option>\n        <option value=\"descending\">Descending priorities</option>\n        <option value=\"duplicates\">Many duplicates</option>\n      </select>\n    </div>\n\n    <div class=\"row\">\n      <label for=\"bulkInput\">Bulk import (CSV value:priority or JSON array):</label>\n      <input id=\"bulkInput\" type=\"text\" style=\"width:60%\" placeholder=\"a:5,b:3,c:7 or [{...}]\">\n      <button id=\"bulkBtn\">Bulk Enqueue</button>\n    </div>\n\n    <div class=\"row\">\n      <label for=\"targetIndex\">Index/ID (for change/remove):</label>\n      <input id=\"targetIndex\" type=\"text\" placeholder=\"id or index\">\n\n      <label for=\"newPriority\">New priority:</label>\n      <input id=\"newPriority\" type=\"number\" value=\"0\">\n\n      <button id=\"changePriorityBtn\">Change Priority</button>\n      <button id=\"removeBtn\">Remove Item</button>\n    </div>\n\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"row\">\n      <button id=\"stepModeBtn\">Enter Step Mode for Next Operation</button>\n      <button id=\"autoRunBtn\">Auto-run Steps</button>\n      <button id=\"stopAutoBtn\">Stop Auto</button>\n\n      <button id=\"stepPrevBtn\">Step Prev</button>\n      <button id=\"stepNextBtn\">Step Next</button>\n      <span class=\"small\"> (use prev/next to navigate recorded internal steps)</span>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"cloneBtn\">Clone Queue</button>\n      <button id=\"mergeBtn\">Merge with Clone</button>\n      <button id=\"benchmarkBtn\">Run Benchmark</button>\n      <button id=\"exportBtn\">Export JSON</button>\n      <button id=\"importBtn\">Import JSON</button>\n      <input id=\"importArea\" type=\"text\" placeholder='Paste JSON here' style=\"width:45%\">\n    </div>\n\n    <div class=\"row\">\n      <label for=\"logLimit\">Log limit:</label>\n      <input id=\"logLimit\" type=\"number\" value=\"200\" style=\"width:60px\">\n      <button id=\"clearLogBtn\">Clear Log</button>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h2>Queue State</h2>\n    <div class=\"row\">\n      <label>Size:</label> <span id=\"size\">0</span>\n      <label style=\"margin-left:10px\">Implementation:</label> <span id=\"implLabel\">binary</span>\n    </div>\n\n    <div class=\"row\">\n      <label>Internal Array (id|value|priority|order):</label>\n      <pre id=\"arrayView\">[]</pre>\n    </div>\n\n    <div class=\"row\">\n      <label>Binary Tree View (if heap):</label>\n      <pre id=\"treeView\"></pre>\n    </div>\n\n    <div class=\"row\">\n      <label>Instrumentation (comparisons / swaps / moves / reads / writes):</label>\n      <pre id=\"instr\">comparisons:0 swaps:0 moves:0 reads:0 writes:0</pre>\n    </div>\n\n    <div class=\"row\">\n      <label>History (undo / redo):</label>\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n      <span id=\"historyInfo\" class=\"small\"></span>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h2>Step Simulation</h2>\n    <div class=\"row\">\n      <label>Last operation steps (human-readable):</label>\n      <pre id=\"stepsView\">No steps recorded.</pre>\n    </div>\n\n    <div class=\"row\">\n      <label>Simulation Array:</label>\n      <pre id=\"simArrayView\">[]</pre>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h2>Log</h2>\n    <textarea id=\"logArea\" readonly></textarea>\n  </div>\n\n<script>\n(function(){\n\n/*\n  Priority Queue Interactive Demo\n  - Multiple implementations: binary heap, sorted array, unsorted array\n  - Modes: MAX / MIN\n  - Stable option for tie-breaking\n  - Rich controls: enqueue, dequeue, peek, change priority, remove, bulk import, random generation\n  - Step mode: record internal steps (compares, swaps, moves) and step through them\n  - Instrumentation counters\n  - History snapshots for undo/redo, clone/merge, benchmarks, import/export\n  - Extremely minimal visual design (plain text, no colors)\n*/\n\n/* Utilities */\nfunction log(msg){\n  const area = document.getElementById('logArea');\n  const limit = parseInt(document.getElementById('logLimit').value || '200', 10);\n  area.value = ((area.value || '') + msg + '\\n').split('\\n').slice(-limit).join('\\n');\n  area.scrollTop = area.scrollHeight;\n}\n\nfunction now(){ return Date.now(); }\n\nlet globalId = 1;\n\n/* Instrumentation */\nfunction createInstr(){\n  return { comparisons:0, swaps:0, moves:0, reads:0, writes:0 };\n}\n\n/* Step recording */\nfunction createStepRecorder(){\n  const steps = [];\n  return {\n    steps,\n    recordCompare(a,b,info){ steps.push({type:'compare', a, b, info}); },\n    recordSwap(i,j,info){ steps.push({type:'swap', i, j, info}); },\n    recordSet(i,value,info){ steps.push({type:'set', i, value, info}); },\n    recordPush(value,info){ steps.push({type:'push', value, info}); },\n    recordPop(value,info){ steps.push({type:'pop', value, info}); },\n    recordNote(text){ steps.push({type:'note', text}); },\n    get(){ return steps; }\n  };\n}\n\n/* Queue Item */\nfunction makeItem(value, priority, order){\n  return { id: (globalId++), value: String(value), priority: Number(priority), order: order || 0 };\n}\n\n/* Cloning utility */\nfunction deepCloneQueueArray(arr){\n  return arr.map(x => ({ id:x.id, value:x.value, priority:x.priority, order:x.order }));\n}\n\n/* Implementations with instrumentation & step recording\n   Each implementation exposes:\n    - init(array, instr, recorder, comparator)\n    - enqueue(item)\n    - dequeue()\n    - peek()\n    - changePriority(predicate or id/index, newPriority)\n    - remove(predicate or id/index)\n    - snapshot() returns array\n*/\nfunction makeComparator(mode, stable){\n  // returns compare(a,b): positive if a > b in priority (depending on mode)\n  const sign = mode === 'max' ? 1 : -1;\n  return function(a,b){\n    if (a.priority === b.priority){\n      if (!stable) return 0;\n      // stable: compare insertion order: lower order earlier\n      if (a.order === b.order) return 0;\n      return (a.order < b.order) ? -1 : 1;\n    }\n    return (a.priority < b.priority) ? -1 * sign : 1 * sign;\n  };\n}\n\n/* Binary Heap implementation (array-based 0-indexed)\n   We'll implement typical siftUp/siftDown for max-heap; comparator defines ordering.\n*/\nfunction BinaryHeap(arr, instr, recorder, comparator){\n  let heap = deepCloneQueueArray(arr || []);\n  function swap(i,j){\n    instr.swaps++;\n    recorder.recordSwap(i,j);\n    const t = heap[i]; heap[i] = heap[j]; heap[j] = t;\n  }\n  function compareIndex(i,j){\n    instr.comparisons++;\n    recorder.recordCompare(i,j);\n    return comparator(heap[i], heap[j]);\n  }\n  function siftUp(i){\n    while (i > 0){\n      const p = Math.floor((i-1)/2);\n      if (compareIndex(i,p) <= 0) break;\n      swap(i,p);\n      i = p;\n    }\n  }\n  function siftDown(i){\n    const n = heap.length;\n    while (true){\n      const l = 2*i+1, r = 2*i+2;\n      let largest = i;\n      if (l < n && compareIndex(l, largest) > 0) largest = l;\n      if (r < n && compareIndex(r, largest) > 0) largest = r;\n      if (largest === i) break;\n      swap(i, largest);\n      i = largest;\n    }\n  }\n\n  return {\n    enqueue(item){\n      recorder.recordPush(item);\n      instr.writes++;\n      heap.push(item);\n      siftUp(heap.length - 1);\n    },\n    dequeue(){\n      if (heap.length === 0) return null;\n      recorder.recordNote('dequeue root');\n      instr.reads += 2;\n      const root = heap[0];\n      instr.writes++;\n      const last = heap.pop();\n      recorder.recordPop(last);\n      if (heap.length > 0){\n        heap[0] = last;\n        instr.writes++;\n        siftDown(0);\n      }\n      return root;\n    },\n    peek(){ return heap[0] || null; },\n    changePriority(idOrIndex, newPriority){\n      // find by id or numeric index\n      let idx = -1;\n      if (typeof idOrIndex === 'number') idx = idOrIndex;\n      else idx = heap.findIndex(x => String(x.id) === String(idOrIndex) || String(x.value) === String(idOrIndex));\n      if (idx < 0) return null;\n      recorder.recordNote('change priority at index ' + idx);\n      instr.reads++;\n      heap[idx].priority = newPriority;\n      instr.writes++;\n      // reheapify: try siftUp then siftDown\n      siftUp(idx);\n      siftDown(idx);\n      return heap[idx];\n    },\n    remove(idOrIndex){\n      let idx = -1;\n      if (typeof idOrIndex === 'number') idx = idOrIndex;\n      else idx = heap.findIndex(x => String(x.id) === String(idOrIndex) || String(x.value) === String(idOrIndex));\n      if (idx < 0) return null;\n      const removed = heap[idx];\n      recorder.recordNote('remove at index ' + idx);\n      instr.reads++;\n      const last = heap.pop();\n      recorder.recordPop(last);\n      if (idx < heap.length){\n        heap[idx] = last;\n        instr.writes++;\n        // restore heap\n        siftUp(idx);\n        siftDown(idx);\n      }\n      return removed;\n    },\n    snapshot(){ return deepCloneQueueArray(heap); },\n    internalArray(){ return heap; }\n  };\n}\n\n/* Sorted Array implementation\n   Maintains sorted order according to comparator, highest priority at index 0\n   Insert uses binary search to find insertion position with recording\n*/\nfunction SortedArray(arr, instr, recorder, comparator){\n  let list = deepCloneQueueArray(arr || []);\n  function cmp(a,b){\n    instr.comparisons++;\n    recorder.recordCompare(a,b);\n    return comparator(a,b);\n  }\n  // ensure sorted\n  list.sort((A,B)=>cmp(A,B) ? -cmp(A,B) : 0);\n\n  function binarySearchPos(item){\n    let lo = 0, hi = list.length;\n    while (lo < hi){\n      const mid = Math.floor((lo+hi)/2);\n      recorder.recordNote('bs compare with index ' + mid);\n      instr.comparisons++;\n      const c = comparator(item, list[mid]);\n      if (c > 0) hi = mid;\n      else lo = mid + 1;\n    }\n    return lo;\n  }\n\n  return {\n    enqueue(item){\n      recorder.recordPush(item);\n      instr.writes++;\n      const pos = binarySearchPos(item);\n      // insert at pos\n      list.splice(pos, 0, item);\n      instr.moves += 1;\n      recorder.recordNote('insert at pos ' + pos);\n    },\n    dequeue(){\n      if (list.length === 0) return null;\n      recorder.recordNote('dequeue from head');\n      instr.reads++;\n      const it = list.shift();\n      recorder.recordPop(it);\n      instr.moves++;\n      return it;\n    },\n    peek(){ return list[0] || null; },\n    changePriority(idOrIndex, newPriority){\n      let idx = -1;\n      if (typeof idOrIndex === 'number') idx = idOrIndex;\n      else idx = list.findIndex(x => String(x.id) === String(idOrIndex) || String(x.value) === String(idOrIndex));\n      if (idx < 0) return null;\n      const it = list[idx];\n      recorder.recordNote('change at index ' + idx);\n      it.priority = newPriority; instr.writes++;\n      // remove and reinsert\n      list.splice(idx,1);\n      instr.moves++;\n      const pos = binarySearchPos(it);\n      list.splice(pos,0,it);\n      instr.moves++;\n      return it;\n    },\n    remove(idOrIndex){\n      let idx = -1;\n      if (typeof idOrIndex === 'number') idx = idOrIndex;\n      else idx = list.findIndex(x => String(x.id) === String(idOrIndex) || String(x.value) === String(idOrIndex));\n      if (idx < 0) return null;\n      recorder.recordNote('remove at ' + idx);\n      const it = list.splice(idx,1)[0];\n      instr.moves++;\n      return it;\n    },\n    snapshot(){ return deepCloneQueueArray(list); },\n    internalArray(){ return list; }\n  };\n}\n\n/* Unsorted Array implementation\n   Enqueue pushes; dequeue scans for best element\n*/\nfunction UnsortedArray(arr, instr, recorder, comparator){\n  let list = deepCloneQueueArray(arr || []);\n  function cmpIndex(i,j){\n    instr.comparisons++;\n    recorder.recordCompare(i,j);\n    return comparator(list[i], list[j]);\n  }\n  return {\n    enqueue(item){\n      recorder.recordPush(item);\n      instr.writes++;\n      list.push(item);\n    },\n    dequeue(){\n      if (list.length === 0) return null;\n      recorder.recordNote('scan for best');\n      let best = 0;\n      for (let i=1;i<list.length;i++){\n        const c = cmpIndex(i,best);\n        if (c > 0) best = i;\n      }\n      const it = list.splice(best,1)[0];\n      recorder.recordPop(it);\n      instr.moves++;\n      return it;\n    },\n    peek(){\n      if (list.length === 0) return null;\n      let best = 0;\n      for (let i=1;i<list.length;i++){\n        instr.comparisons++;\n        recorder.recordCompare(i,best);\n        if (comparator(list[i], list[best]) > 0) best = i;\n      }\n      return list[best];\n    },\n    changePriority(idOrIndex, newPriority){\n      let idx = -1;\n      if (typeof idOrIndex === 'number') idx = idOrIndex;\n      else idx = list.findIndex(x => String(x.id) === String(idOrIndex) || String(x.value) === String(idOrIndex));\n      if (idx < 0) return null;\n      recorder.recordNote('change at ' + idx);\n      list[idx].priority = newPriority; instr.writes++;\n      return list[idx];\n    },\n    remove(idOrIndex){\n      let idx = -1;\n      if (typeof idOrIndex === 'number') idx = idOrIndex;\n      else idx = list.findIndex(x => String(x.id) === String(idOrIndex) || String(x.value) === String(idOrIndex));\n      if (idx < 0) return null;\n      const it = list.splice(idx,1)[0];\n      recorder.recordNote('removed ' + idx);\n      instr.moves++;\n      return it;\n    },\n    snapshot(){ return deepCloneQueueArray(list); },\n    internalArray(){ return list; }\n  };\n}\n\n/* Controller for the demo state */\nconst state = {\n  impl: 'binary',\n  mode: 'max',\n  stable: true,\n  orderCounter: 0,\n  queueArr: [], // underlying storage items\n  instr: createInstr(),\n  recorder: createStepRecorder(),\n  implInstance: null,\n  history: [],\n  historyIndex: -1,\n  lastSteps: [],\n  stepSimIndex: -1,\n  stepSimArray: [],\n  autoStep: false,\n  cloneQueueArr: null,\n};\n\nfunction resetInstr(){\n  state.instr = createInstr();\n  updateInstrView();\n}\n\nfunction recreateImpl(recordSteps){\n  // build a new implementation instance from state.queueArr\n  state.recorder = createStepRecorder();\n  if (recordSteps) state.recorder.recordNote('init');\n  const cmp = makeComparator(state.mode, state.stable);\n  if (state.impl === 'binary'){\n    state.implInstance = BinaryHeap(state.queueArr, state.instr, state.recorder, cmp);\n  } else if (state.impl === 'sorted'){\n    state.implInstance = SortedArray(state.queueArr, state.instr, state.recorder, cmp);\n  } else {\n    state.implInstance = UnsortedArray(state.queueArr, state.instr, state.recorder, cmp);\n  }\n  updateViews();\n}\n\n/* Snapshot history management */\nfunction pushHistorySnapshot(reason){\n  const snap = deepCloneQueueArray(state.queueArr);\n  // discard future history if we undid\n  if (state.historyIndex < state.history.length - 1){\n    state.history.splice(state.historyIndex+1);\n  }\n  state.history.push({ snap, reason, time: now() });\n  state.historyIndex = state.history.length - 1;\n  updateHistoryInfo();\n}\n\nfunction undo(){\n  if (state.historyIndex <= 0) return;\n  state.historyIndex--;\n  const s = state.history[state.historyIndex].snap;\n  state.queueArr = deepCloneQueueArray(s);\n  recreateImpl(false);\n  log('Undo: restored history index ' + state.historyIndex);\n  updateViews();\n  updateHistoryInfo();\n}\nfunction redo(){\n  if (state.historyIndex >= state.history.length - 1) return;\n  state.historyIndex++;\n  const s = state.history[state.historyIndex].snap;\n  state.queueArr = deepCloneQueueArray(s);\n  recreateImpl(false);\n  log('Redo: restored history index ' + state.historyIndex);\n  updateViews();\n  updateHistoryInfo();\n}\n\n/* UI wiring */\nconst ui = {\n  implSelect: document.getElementById('impl'),\n  modeSelect: document.getElementById('mode'),\n  stableCheckbox: document.getElementById('stable'),\n  valueInput: document.getElementById('valueInput'),\n  priorityInput: document.getElementById('priorityInput'),\n  enqueueBtn: document.getElementById('enqueueBtn'),\n  dequeueBtn: document.getElementById('dequeueBtn'),\n  peekBtn: document.getElementById('peekBtn'),\n  clearBtn: document.getElementById('clearBtn'),\n  generateCount: document.getElementById('generateCount'),\n  generateCountLabel: document.getElementById('generateCountLabel'),\n  randomBtn: document.getElementById('randomBtn'),\n  randomPreset: document.getElementById('randomPreset'),\n  randomSeed: document.getElementById('randomSeed'),\n  bulkInput: document.getElementById('bulkInput'),\n  bulkBtn: document.getElementById('bulkBtn'),\n  changePriorityBtn: document.getElementById('changePriorityBtn'),\n  removeBtn: document.getElementById('removeBtn'),\n  targetIndex: document.getElementById('targetIndex'),\n  newPriority: document.getElementById('newPriority'),\n  stepModeBtn: document.getElementById('stepModeBtn'),\n  stepPrevBtn: document.getElementById('stepPrevBtn'),\n  stepNextBtn: document.getElementById('stepNextBtn'),\n  autoRunBtn: document.getElementById('autoRunBtn'),\n  stopAutoBtn: document.getElementById('stopAutoBtn'),\n  cloneBtn: document.getElementById('cloneBtn'),\n  mergeBtn: document.getElementById('mergeBtn'),\n  benchmarkBtn: document.getElementById('benchmarkBtn'),\n  exportBtn: document.getElementById('exportBtn'),\n  importBtn: document.getElementById('importBtn'),\n  importArea: document.getElementById('importArea'),\n  arrayView: document.getElementById('arrayView'),\n  treeView: document.getElementById('treeView'),\n  instrView: document.getElementById('instr'),\n  stepsView: document.getElementById('stepsView'),\n  simArrayView: document.getElementById('simArrayView'),\n  sizeLabel: document.getElementById('size'),\n  implLabel: document.getElementById('implLabel'),\n  undoBtn: document.getElementById('undoBtn'),\n  redoBtn: document.getElementById('redoBtn'),\n  logArea: document.getElementById('logArea'),\n  stepModeFlag: false,\n  clearLogBtn: document.getElementById('clearLogBtn'),\n  logLimit: document.getElementById('logLimit')\n};\n\nui.generateCount.addEventListener('input', function(){ ui.generateCountLabel.textContent = ui.generateCount.value; });\n\nui.implSelect.addEventListener('change', function(){\n  state.impl = ui.implSelect.value;\n  recreateImpl(false);\n  pushHistorySnapshot('impl change');\n  log('Implementation changed to ' + state.impl);\n});\nui.modeSelect.addEventListener('change', function(){\n  state.mode = ui.modeSelect.value;\n  recreateImpl(false);\n  pushHistorySnapshot('mode change');\n  log('Mode changed to ' + state.mode);\n});\nui.stableCheckbox.addEventListener('change', function(){\n  state.stable = ui.stableCheckbox.checked;\n  recreateImpl(false);\n  pushHistorySnapshot('stable change');\n  log('Stable set to ' + state.stable);\n});\n\n/* Operation helpers */\nfunction applyOperationWithSteps(opFunc, description){\n  // reset instr and recorder\n  resetInstr();\n  state.recorder = createStepRecorder();\n  // create a fresh impl instance that will record steps into state.recorder\n  const cmp = makeComparator(state.mode, state.stable);\n  if (state.impl === 'binary') state.implInstance = BinaryHeap(state.queueArr, state.instr, state.recorder, cmp);\n  else if (state.impl === 'sorted') state.implInstance = SortedArray(state.queueArr, state.instr, state.recorder, cmp);\n  else state.implInstance = UnsortedArray(state.queueArr, state.instr, state.recorder, cmp);\n\n  // capture pre-state for simulation\n  const preState = deepCloneQueueArray(state.queueArr);\n\n  // perform operation using implInstance; it will update internal array (but not state.queueArr directly)\n  const result = opFunc(state.implInstance);\n\n  // capture steps and final internal array from implInstance\n  const steps = state.recorder.get().slice();\n  state.lastSteps = steps;\n  state.stepSimIndex = -1;\n  // final array snapshot:\n  const finalSnap = state.implInstance.snapshot();\n  // commit final result to state.queueArr and history\n  state.queueArr = finalSnap;\n  pushHistorySnapshot(description);\n  recreateImpl(false); // rebuild current impl (no need to record)\n  updateViews();\n  // prepare simulation state (start from preState)\n  state.stepSimArray = deepCloneQueueArray(preState);\n  updateStepsView();\n  log(description + ' => ' + (result && result.value ? result.value : JSON.stringify(result)));\n}\n\nui.enqueueBtn.addEventListener('click', function(){\n  const v = ui.valueInput.value || 'item';\n  const p = Number(ui.priorityInput.value || 0);\n  const item = makeItem(v,p, ++state.orderCounter);\n  const desc = 'Enqueue ' + item.value + ':' + item.priority;\n  if (ui.stepModeFlag){\n    applyOperationWithSteps(function(impl){ impl.enqueue(item); return item; }, desc);\n  } else {\n    // direct enqueue without step recording\n    state.implInstance.enqueue(item);\n    state.queueArr = state.implInstance.snapshot();\n    resetInstr();\n    state.lastSteps = [];\n    pushHistorySnapshot(desc);\n    updateViews();\n    log(desc);\n  }\n});\n\nui.peekBtn.addEventListener('click', function(){\n  // peek using current implementation\n  resetInstr();\n  state.recorder = createStepRecorder();\n  const cmp = makeComparator(state.mode, state.stable);\n  if (state.impl === 'binary') state.implInstance = BinaryHeap(state.queueArr, state.instr, state.recorder, cmp);\n  else if (state.impl === 'sorted') state.implInstance = SortedArray(state.queueArr, state.instr, state.recorder, cmp);\n  else state.implInstance = UnsortedArray(state.queueArr, state.instr, state.recorder, cmp);\n  const top = state.implInstance.peek();\n  updateViews();\n  updateStepsView();\n  log('Peek => ' + (top ? (top.value + ':' + top.priority + ' (id:' + top.id + ')') : 'null'));\n});\n\nui.dequeueBtn.addEventListener('click', function(){\n  const desc = 'Dequeue';\n  if (ui.stepModeFlag){\n    applyOperationWithSteps(function(impl){ return impl.dequeue(); }, desc);\n  } else {\n    const item = state.implInstance.dequeue();\n    state.queueArr = state.implInstance.snapshot();\n    pushHistorySnapshot(desc);\n    resetInstr();\n    updateViews();\n    state.lastSteps = [];\n    log('Dequeue => ' + (item ? item.value + ':' + item.priority : 'null'));\n  }\n});\n\nui.clearBtn.addEventListener('click', function(){\n  state.queueArr = [];\n  state.implInstance = null;\n  resetInstr();\n  pushHistorySnapshot('Clear');\n  recreateImpl(false);\n  updateViews();\n  log('Cleared queue.');\n});\n\nui.randomBtn.addEventListener('click', function(){\n  const count = Number(ui.generateCount.value) || 10;\n  const preset = ui.randomPreset.value;\n  const seed = ui.randomSeed.value || null;\n  // simple RNG\n  let rng = Math.random;\n  if (seed){\n    let s = 0;\n    for (let i=0;i<seed.length;i++) s = (s * 31 + seed.charCodeAt(i)) >>> 0;\n    rng = function(){ s = (s * 1664525 + 1013904223) >>> 0; return s / 4294967296; };\n  }\n  const newItems = [];\n  for (let i=0;i<count;i++){\n    let p;\n    if (preset === 'random') p = Math.floor(rng()*100);\n    else if (preset === 'ascending') p = i;\n    else if (preset === 'descending') p = count - i;\n    else if (preset === 'duplicates') p = Math.floor(rng()*6);\n    newItems.push(makeItem('v'+i, p, ++state.orderCounter));\n  }\n  // bulk enqueue\n  newItems.forEach(it => state.implInstance.enqueue(it));\n  state.queueArr = state.implInstance.snapshot();\n  resetInstr();\n  pushHistorySnapshot('Random generate ' + count);\n  recreateImpl(false);\n  updateViews();\n  log('Generated ' + count + ' items (' + preset + ').');\n});\n\nui.bulkBtn.addEventListener('click', function(){\n  const text = ui.bulkInput.value.trim();\n  if (!text) return;\n  let parsed = [];\n  // try JSON\n  try {\n    parsed = JSON.parse(text);\n    if (Array.isArray(parsed)){\n      // normalize: accept objects or [value,priority]\n      parsed = parsed.map(x => {\n        if (Array.isArray(x)) return makeItem(x[0], x[1], ++state.orderCounter);\n        if (x && typeof x === 'object') return makeItem(x.value ?? x.v ?? x.id ?? 'v', x.priority ?? x.p ?? 0, ++state.orderCounter);\n        return makeItem(x, 0, ++state.orderCounter);\n      });\n    } else {\n      throw new Error('not array JSON');\n    }\n  } catch(e){\n    // try CSV style value:priority,value2:priority2\n    const pairs = text.split(/[;,]+/).map(x=>x.trim()).filter(x=>x);\n    parsed = pairs.map(p=>{\n      const m = p.split(':');\n      return makeItem(m[0]||'v', Number(m[1]||0), ++state.orderCounter);\n    });\n  }\n  parsed.forEach(it => state.implInstance.enqueue(it));\n  state.queueArr = state.implInstance.snapshot();\n  resetInstr();\n  pushHistorySnapshot('Bulk enqueue ' + parsed.length);\n  recreateImpl(false);\n  updateViews();\n  log('Bulk enqueued ' + parsed.length + ' items.');\n});\n\nui.changePriorityBtn.addEventListener('click', function(){\n  const target = ui.targetIndex.value.trim();\n  if (!target) return;\n  const newP = Number(ui.newPriority.value);\n  const desc = 'Change priority of ' + target + ' => ' + newP;\n  if (ui.stepModeFlag){\n    applyOperationWithSteps(function(impl){ return impl.changePriority(target, newP); }, desc);\n  } else {\n    const res = state.implInstance.changePriority(target, newP);\n    state.queueArr = state.implInstance.snapshot();\n    resetInstr();\n    pushHistorySnapshot(desc);\n    recreateImpl(false);\n    updateViews();\n    log(desc + ' => ' + (res ? 'ok' : 'not found'));\n  }\n});\n\nui.removeBtn.addEventListener('click', function(){\n  const target = ui.targetIndex.value.trim();\n  if (!target) return;\n  const desc = 'Remove ' + target;\n  if (ui.stepModeFlag){\n    applyOperationWithSteps(function(impl){ return impl.remove(target); }, desc);\n  } else {\n    const res = state.implInstance.remove(target);\n    state.queueArr = state.implInstance.snapshot();\n    resetInstr();\n    pushHistorySnapshot(desc);\n    recreateImpl(false);\n    updateViews();\n    log(desc + ' => ' + (res ? 'removed' : 'not found'));\n  }\n});\n\nui.stepModeBtn.addEventListener('click', function(){\n  ui.stepModeFlag = !ui.stepModeFlag;\n  ui.stepModeBtn.textContent = ui.stepModeFlag ? 'Step Mode: ON (for next op)' : 'Step Mode: Enter Step Mode for Next Operation';\n  log('Step mode ' + (ui.stepModeFlag ? 'enabled' : 'disabled'));\n});\n\nui.stepPrevBtn.addEventListener('click', function(){\n  if (!state.lastSteps || state.lastSteps.length === 0){ log('No steps to navigate'); return; }\n  // move back one simulated step (rebuild from initial)\n  state.stepSimIndex = Math.max(-1, state.stepSimIndex - 1);\n  applySimulatedSteps(state.stepSimIndex);\n});\n\nui.stepNextBtn.addEventListener('click', function(){\n  if (!state.lastSteps || state.lastSteps.length === 0){ log('No steps to navigate'); return; }\n  state.stepSimIndex = Math.min(state.lastSteps.length - 1, state.stepSimIndex + 1);\n  applySimulatedSteps(state.stepSimIndex);\n});\n\nui.autoRunBtn.addEventListener('click', function(){\n  if (!state.lastSteps || state.lastSteps.length === 0){ log('No steps recorded'); return; }\n  state.autoStep = true;\n  runAutoSteps();\n});\n\nui.stopAutoBtn.addEventListener('click', function(){\n  state.autoStep = false;\n});\n\nfunction runAutoSteps(){\n  if (!state.autoStep) return;\n  if (state.stepSimIndex < state.lastSteps.length - 1){\n    state.stepSimIndex++;\n    applySimulatedSteps(state.stepSimIndex);\n    setTimeout(runAutoSteps, 200);\n  } else {\n    state.autoStep = false;\n  }\n}\n\nui.cloneBtn.addEventListener('click', function(){\n  state.cloneQueueArr = deepCloneQueueArray(state.queueArr);\n  log('Cloned current queue snapshot.');\n});\n\nui.mergeBtn.addEventListener('click', function(){\n  if (!state.cloneQueueArr) { log('No clone exists. Use Clone Queue first.'); return; }\n  const desc = 'Merge clone';\n  // merge by enqueuing all items from clone into current implInstance\n  state.cloneQueueArr.forEach(it => state.implInstance.enqueue(makeItem(it.value, it.priority, ++state.orderCounter)));\n  state.queueArr = state.implInstance.snapshot();\n  resetInstr();\n  pushHistorySnapshot(desc);\n  recreateImpl(false);\n  updateViews();\n  log('Merged clone into current queue.');\n});\n\nui.benchmarkBtn.addEventListener('click', function(){\n  // run simple benchmark: enqueue N, dequeue N, measure instr counts\n  const N = Math.max(100, Number(ui.generateCount.value) || 100);\n  const seed = Date.now();\n  const rng = function(){ seed = (seed * 1664525 + 1013904223) >>> 0; return seed / 4294967296; };\n  const items = [];\n  for (let i=0;i<N;i++) items.push(makeItem('b'+i, Math.floor(Math.random()*1000), ++state.orderCounter));\n  // benchmark on current implementation type\n  resetInstr();\n  state.recorder = createStepRecorder();\n  const cmp = makeComparator(state.mode, state.stable);\n  let impl;\n  if (state.impl === 'binary') impl = BinaryHeap([], state.instr, state.recorder, cmp);\n  else if (state.impl === 'sorted') impl = SortedArray([], state.instr, state.recorder, cmp);\n  else impl = UnsortedArray([], state.instr, state.recorder, cmp);\n  const t0 = performance.now();\n  items.forEach(it => impl.enqueue(it));\n  const t1 = performance.now();\n  for (let i=0;i<N;i++) impl.dequeue();\n  const t2 = performance.now();\n  const msEnq = t1 - t0, msDeq = t2 - t1;\n  updateInstrView();\n  log('Benchmark: N=' + N + ' enq=' + msEnq.toFixed(2) + 'ms deq=' + msDeq.toFixed(2) + 'ms instr=' + JSON.stringify(state.instr));\n});\n\nui.exportBtn.addEventListener('click', function(){\n  const exportObj = { arr: state.queueArr, impl: state.impl, mode: state.mode, stable: state.stable, history: state.history.map(h=>({time:h.time, reason:h.reason})) };\n  const s = JSON.stringify(exportObj, null, 2);\n  ui.importArea.value = s;\n  log('Exported current queue into text area.');\n});\n\nui.importBtn.addEventListener('click', function(){\n  const text = ui.importArea.value.trim();\n  if (!text) return;\n  try{\n    const obj = JSON.parse(text);\n    if (Array.isArray(obj.arr)){\n      state.queueArr = obj.arr.map(x => ({ id: x.id || (globalId++), value: x.value, priority: Number(x.priority), order: ++state.orderCounter }));\n      state.impl = obj.impl || state.impl;\n      state.mode = obj.mode || state.mode;\n      state.stable = !!obj.stable;\n      ui.implSelect.value = state.impl;\n      ui.modeSelect.value = state.mode;\n      ui.stableCheckbox.checked = state.stable;\n      resetInstr();\n      pushHistorySnapshot('Import');\n      recreateImpl(false);\n      updateViews();\n      log('Imported queue from JSON.');\n    } else {\n      log('Import JSON format invalid: no arr');\n    }\n  } catch(e){\n    log('Import failed: ' + e.message);\n  }\n});\n\nui.undoBtn.addEventListener('click', undo);\nui.redoBtn.addEventListener('click', redo);\nui.clearLogBtn.addEventListener('click', function(){ ui.logArea.value = ''; });\n\n/* Simulation of recorded steps */\nfunction updateStepsView(){\n  const steps = state.lastSteps || [];\n  if (!steps || steps.length === 0){\n    ui.stepsView.textContent = 'No steps recorded.';\n    ui.simArrayView.textContent = '[]';\n    return;\n  }\n  // show human-readable steps\n  const lines = steps.map((s,i) => {\n    if (s.type === 'compare') return '['+i+'] COMPARE ' + JSON.stringify(s.a) + ' vs ' + JSON.stringify(s.b) + (s.info ? (' // '+s.info) : '');\n    if (s.type === 'swap') return '['+i+'] SWAP index ' + s.i + ' <-> ' + s.j + (s.info ? (' // '+s.info) : '');\n    if (s.type === 'set') return '['+i+'] SET index ' + s.i + ' = ' + JSON.stringify(s.value);\n    if (s.type === 'push') return '['+i+'] PUSH ' + JSON.stringify(s.value);\n    if (s.type === 'pop') return '['+i+'] POP ' + JSON.stringify(s.value);\n    if (s.type === 'note') return '['+i+'] NOTE: ' + s.text;\n    return '['+i+'] ' + JSON.stringify(s);\n  });\n  ui.stepsView.textContent = lines.join('\\n');\n  // initialize sim array view at start\n  if (state.stepSimIndex < 0) ui.simArrayView.textContent = JSON.stringify(state.stepSimArray, null, 2);\n  else {\n    // apply up to state.stepSimIndex\n    applySimulatedSteps(state.stepSimIndex);\n  }\n}\n\nfunction applySimulatedSteps(targetIndex){\n  // Start from pre-operation state (assumed stored)\n  const initial = state.stepSimArray ? deepCloneQueueArray(state.stepSimArray) : [];\n  if (!state.lastSteps) { ui.simArrayView.textContent = JSON.stringify(initial, null, 2); return; }\n  const arr = deepCloneQueueArray(initial);\n  // We'll interpret steps and modify arr accordingly in simple ways.\n  for (let sIndex = 0; sIndex <= targetIndex; sIndex++){\n    const s = state.lastSteps[sIndex];\n    if (!s) break;\n    if (s.type === 'push'){\n      arr.push(s.value);\n    } else if (s.type === 'pop'){\n      // remove last matching by id if exists, otherwise pop\n      if (s.value && s.value.id){\n        const idx = arr.findIndex(x=>x.id === s.value.id);\n        if (idx >= 0) arr.splice(idx,1);\n        else arr.pop();\n      } else {\n        arr.pop();\n      }\n    } else if (s.type === 'swap'){\n      const i = s.i, j = s.j;\n      if (i >= 0 && j >= 0 && i < arr.length && j < arr.length){\n        const t = arr[i]; arr[i] = arr[j]; arr[j] = t;\n      }\n    } else if (s.type === 'set'){\n      const i = s.i;\n      if (i >= 0 && i < arr.length) arr[i] = s.value;\n      else if (i === arr.length) arr.push(s.value);\n    } else if (s.type === 'note'){\n      // ignore for simulation\n    } else if (s.type === 'compare'){\n      // no mutation\n    }\n  }\n  ui.simArrayView.textContent = JSON.stringify(arr, null, 2);\n  // also highlight which step index\n  ui.stepsView.textContent = (state.lastSteps || []).map((s,i)=>{\n    const prefix = (i === targetIndex ? '>> ' : '   ');\n    if (s.type === 'compare') return prefix+'['+i+'] COMPARE ' + JSON.stringify(s.a) + ' vs ' + JSON.stringify(s.b);\n    if (s.type === 'swap') return prefix+'['+i+'] SWAP index ' + s.i + ' <-> ' + s.j;\n    if (s.type === 'set') return prefix+'['+i+'] SET index ' + s.i + ' = ' + JSON.stringify(s.value);\n    if (s.type === 'push') return prefix+'['+i+'] PUSH ' + JSON.stringify(s.value);\n    if (s.type === 'pop') return prefix+'['+i+'] POP ' + JSON.stringify(s.value);\n    if (s.type === 'note') return prefix+'['+i+'] NOTE: ' + s.text;\n    return prefix+'['+i+'] ' + JSON.stringify(s);\n  }).join('\\n');\n}\n\n/* Views update */\nfunction updateViews(){\n  ui.arrayView.textContent = JSON.stringify(state.queueArr, null, 2);\n  ui.sizeLabel.textContent = state.queueArr.length;\n  ui.implLabel.textContent = state.impl + ' / ' + state.mode + (state.stable ? ' (stable)' : '');\n  updateTreeView();\n  updateInstrView();\n  updateHistoryInfo();\n  updateStepsView();\n}\n\nfunction updateTreeView(){\n  // For heap implementations show a simple level-order tree (ASCII)\n  if (state.impl !== 'binary'){ ui.treeView.textContent = '(tree view only for binary heap)'; return; }\n  const arr = (state.implInstance && state.implInstance.internalArray) ? state.implInstance.internalArray() : state.queueArr;\n  const lines = [];\n  let level = 0;\n  let i = 0;\n  while (i < arr.length){\n    const levelCount = Math.pow(2, level);\n    const slice = arr.slice(i, i + levelCount);\n    lines.push(slice.map((n,idx)=>('[' + (i+idx) + '] ' + (n ? (n.value + ':' + n.priority + '(id:'+n.id+')') : 'null'))).join(' | '));\n    i += levelCount; level++;\n  }\n  ui.treeView.textContent = lines.join('\\n');\n}\n\nfunction updateInstrView(){\n  ui.instrView.textContent = 'comparisons:' + state.instr.comparisons + ' swaps:' + state.instr.swaps + ' moves:' + state.instr.moves + ' reads:' + state.instr.reads + ' writes:' + state.instr.writes;\n}\n\nfunction updateHistoryInfo(){\n  ui.historyInfo.textContent = 'history ' + (state.historyIndex+1) + '/' + state.history.length;\n}\n\n/* Initialize default impl and history */\nfunction init(){\n  state.queueArr = [];\n  recreateImpl(false);\n  pushHistorySnapshot('initial');\n  updateViews();\n  log('Initialized priority queue demo.');\n}\ninit();\n\n})();\n</script>\n</body>\n</html>"
