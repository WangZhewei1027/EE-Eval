    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Thread Concept Interactive Exploration</title>\n<style>\n  body {\n    margin: 1em;\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  textarea, input, button, select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin: 0.2em 0;\n  }\n  .section {\n    border-top: 1px solid #000;\n    margin-top: 1em;\n    padding-top: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 0.3em;\n  }\n  #log {\n    width: 100%;\n    height: 200px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Interactive Thread Concept Demonstration</h1>\n\n<p>\nThis tool models a simplified <strong>Thread</strong> system for concurrent/execution flow concepts.\nYou can create threads, control their states, manage scheduling, communication, and simulate some real thread behaviors.\n</p>\n\n<div class=\"section\">\n  <h2>Thread Creation and Management</h2>\n  <label for=\"threadName\">Thread Name:</label>\n  <input type=\"text\" id=\"threadName\" placeholder=\"Thread1\" />\n\n  <label for=\"threadPriority\">Priority (1 lowest - 10 highest):</label>\n  <input type=\"number\" id=\"threadPriority\" min=\"1\" max=\"10\" value=\"5\" />\n\n  <button id=\"createThreadBtn\">Create Thread</button>\n\n  <h3>Existing Threads</h3>\n  <select id=\"threadList\" size=\"5\" style=\"width: 100%;\"></select>\n  <button id=\"deleteThreadBtn\">Delete Selected Thread</button>\n</div>\n\n<div class=\"section\">\n  <h2>Thread Controls</h2>\n  <label for=\"currentThread\">Select Thread to Control:</label>\n  <select id=\"currentThread\" style=\"width: 100%;\"></select>\n\n  <fieldset>\n    <legend>Thread State Controls</legend>\n    <button id=\"startThread\">Start</button>\n    <button id=\"pauseThread\">Pause</button>\n    <button id=\"resumeThread\">Resume</button>\n    <button id=\"stopThread\">Stop</button>\n    <button id=\"restartThread\">Restart</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Thread Attributes</legend>\n    <label for=\"changePriority\">Change Priority:</label>\n    <input type=\"number\" id=\"changePriority\" min=\"1\" max=\"10\" />\n    <button id=\"applyPriority\">Apply</button>\n\n    <label for=\"changeName\">Change Thread Name:</label>\n    <input type=\"text\" id=\"changeName\" />\n    <button id=\"applyName\">Apply</button>\n  </fieldset>\n</div>\n\n<div class=\"section\">\n  <h2>Simulated Thread Actions and Communication</h2>\n\n  <label for=\"sendFromThread\">Send Message From:</label>\n  <select id=\"sendFromThread\" style=\"width: 100%;\"></select>\n\n  <label for=\"sendToThread\">Send Message To:</label>\n  <select id=\"sendToThread\" style=\"width: 100%;\"></select>\n\n  <label for=\"messageContent\">Message Content:</label>\n  <input type=\"text\" id=\"messageContent\" placeholder=\"Hello, thread!\" />\n  <button id=\"sendMessageBtn\">Send Message</button>\n\n  <button id=\"stepSimulation\">Step Simulation (advance running threads)</button>\n</div>\n\n<div class=\"section\">\n  <h2>Thread States and Messages Log</h2>\n  <textarea id=\"log\" readonly></textarea>\n  <button id=\"clearLogBtn\">Clear Log</button>\n</div>\n\n<script>\n(() => {\n  // Thread States Constants\n  const STATES = {\n    NEW: 'NEW',\n    RUNNING: 'RUNNING',\n    PAUSED: 'PAUSED',\n    STOPPED: 'STOPPED',\n    TERMINATED: 'TERMINATED',\n  };\n\n  // Simulated Thread Object Constructor\n  function Thread(id, name, priority) {\n    this.id = id;\n    this.name = name || `Thread${id}`;\n    this.priority = priority || 5;\n    this.state = STATES.NEW;\n    this.messageQueue = [];\n    this.executionCounter = 0; // tracks how many steps executed\n  }\n\n  Thread.prototype.start = function() {\n    if (this.state === STATES.NEW || this.state === STATES.STOPPED) {\n      this.state = STATES.RUNNING;\n      log(`Thread \"${this.name}\" started.`);\n    } else {\n      log(`Thread \"${this.name}\" cannot start from state ${this.state}.`);\n    }\n  };\n\n  Thread.prototype.pause = function() {\n    if(this.state === STATES.RUNNING) {\n      this.state = STATES.PAUSED;\n      log(`Thread \"${this.name}\" paused.`);\n    } else {\n      log(`Thread \"${this.name}\" can only be paused if running.`);\n    }\n  };\n\n  Thread.prototype.resume = function() {\n    if(this.state === STATES.PAUSED) {\n      this.state = STATES.RUNNING;\n      log(`Thread \"${this.name}\" resumed.`);\n    } else {\n      log(`Thread \"${this.name}\" can only be resumed if paused.`);\n    }\n  };\n\n  Thread.prototype.stop = function() {\n    if(this.state !== STATES.TERMINATED && this.state !== STATES.STOPPED) {\n      this.state = STATES.STOPPED;\n      log(`Thread \"${this.name}\" stopped.`);\n    } else {\n      log(`Thread \"${this.name}\" cannot stop from state ${this.state}.`);\n    }\n  };\n\n  Thread.prototype.restart = function() {\n    if(this.state === STATES.STOPPED) {\n      this.executionCounter = 0;\n      this.state = STATES.RUNNING;\n      this.messageQueue = [];\n      log(`Thread \"${this.name}\" restarted and is now running.`);\n    } else {\n      log(`Thread \"${this.name}\" can only restart if stopped.`);\n    }\n  };\n\n  Thread.prototype.terminate = function() {\n    this.state = STATES.TERMINATED;\n    log(`Thread \"${this.name}\" terminated.`);\n  };\n\n  Thread.prototype.enqueueMessage = function(msg) {\n    this.messageQueue.push(msg);\n  };\n\n  Thread.prototype.processStep = function() {\n    if(this.state !== STATES.RUNNING) return;\n\n    // Process one message if present\n    if(this.messageQueue.length > 0) {\n      const msg = this.messageQueue.shift();\n      log(`Thread \"${this.name}\" processed message: \"${msg.content}\" from \"${msg.from.name}\"`);\n    } else {\n      // Simulate some work\n      this.executionCounter++;\n      log(`Thread \"${this.name}\" executed step ${this.executionCounter}.`);\n    }\n\n    // For demonstration, stop thread automatically after 10 steps\n    if(this.executionCounter >= 10) {\n      this.stop();\n      log(`Thread \"${this.name}\" reached 10 execution steps and stopped automatically.`);\n    }\n  };\n\n  function log(text) {\n    const logArea = document.getElementById('log');\n    logArea.value += text + '\\n';\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  // All threads stored here by id\n  const threads = new Map();\n  let threadIdCounter = 1;\n\n  // Helper to update all thread dropdowns and lists\n  function updateThreadSelections() {\n    const list = document.getElementById('threadList');\n    const currentThread = document.getElementById('currentThread');\n    const sendFrom = document.getElementById('sendFromThread');\n    const sendTo = document.getElementById('sendToThread');\n\n    // Build options sorted by priority desc then id asc\n    const sortedThreads = Array.from(threads.values()).sort((a,b) => b.priority - a.priority || a.id - b.id);\n\n    function fillSelect(select, includeTerminated = false) {\n      const prevVal = select.value;\n      select.innerHTML = '';\n      sortedThreads.forEach(t => {\n        if(includeTerminated || t.state !== STATES.TERMINATED) {\n          const option = document.createElement('option');\n          option.value = t.id;\n          option.textContent = `${t.name} [${t.state}] (Pri: ${t.priority})`;\n          select.appendChild(option);\n        }\n      });\n      if (select.options.length > 0) {\n        // Retain previous selection if possible\n        let found = false;\n        for(let i = 0; i < select.options.length; i++) {\n          if(select.options[i].value === prevVal) {\n            select.selectedIndex = i;\n            found = true;\n            break;\n          }\n        }\n        if(!found) select.selectedIndex = 0;\n      }\n    }\n\n    fillSelect(list, true);\n    fillSelect(currentThread);\n    fillSelect(sendFrom);\n    fillSelect(sendTo);\n  }\n\n  // Create a new thread\n  function createThread() {\n    const nameInput = document.getElementById('threadName');\n    const priorityInput = document.getElementById('threadPriority');\n\n    let name = nameInput.value.trim();\n    let priority = parseInt(priorityInput.value, 10);\n\n    if(!name) name = `Thread${threadIdCounter}`;\n    if(isNaN(priority) || priority < 1) priority = 1;\n    if(priority > 10) priority = 10;\n\n    const newThread = new Thread(threadIdCounter++, name, priority);\n    threads.set(newThread.id, newThread);\n    log(`Created thread \"${newThread.name}\" with priority ${newThread.priority}.`);\n    updateThreadSelections();\n\n    nameInput.value = '';\n    priorityInput.value = 5;\n  }\n\n  // Delete thread (only terminated or stopped threads allowed for deletion for safety)\n  function deleteThread() {\n    const list = document.getElementById('threadList');\n    if(list.selectedIndex === -1) {\n      alert('No thread selected for deletion.');\n      return;\n    }\n    const id = parseInt(list.value, 10);\n    const thread = threads.get(id);\n    if(!thread) {\n      alert('Selected thread not found.');\n      return;\n    }\n    if(thread.state !== STATES.TERMINATED && thread.state !== STATES.STOPPED) {\n      if(!confirm(`Thread \"${thread.name}\" is not stopped or terminated. Are you sure you want to delete?`)) return;\n    }\n    threads.delete(id);\n    log(`Deleted thread \"${thread.name}\".`);\n    updateThreadSelections();\n  }\n\n  // Get thread object by currentThread selection safely\n  function getSelectedControlledThread() {\n    const select = document.getElementById('currentThread');\n    if(select.selectedIndex === -1) {\n      alert('No thread selected to control.');\n      return null;\n    }\n    const id = parseInt(select.value, 10);\n    return threads.get(id) || null;\n  }\n\n  // Change thread priority from controls\n  function applyPriorityChange() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    const input = document.getElementById('changePriority');\n    let val = parseInt(input.value, 10);\n    if(isNaN(val) || val < 1 || val > 10) {\n      alert('Priority must be a number between 1 and 10.');\n      return;\n    }\n    const old = thread.priority;\n    thread.priority = val;\n    log(`Changed priority of \"${thread.name}\" from ${old} to ${val}.`);\n    updateThreadSelections();\n  }\n\n  // Change thread name from controls\n  function applyNameChange() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    const input = document.getElementById('changeName');\n    const val = input.value.trim();\n    if(!val) {\n      alert('Name cannot be empty.');\n      return;\n    }\n    const old = thread.name;\n    thread.name = val;\n    log(`Changed thread name from \"${old}\" to \"${val}\".`);\n    updateThreadSelections();\n  }\n\n  // Thread state transitions controls\n  function startThread() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    thread.start();\n    updateThreadSelections();\n  }\n  function pauseThread() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    thread.pause();\n    updateThreadSelections();\n  }\n  function resumeThread() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    thread.resume();\n    updateThreadSelections();\n  }\n  function stopThread() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    thread.stop();\n    updateThreadSelections();\n  }\n  function restartThread() {\n    const thread = getSelectedControlledThread();\n    if(!thread) return;\n    thread.restart();\n    updateThreadSelections();\n  }\n\n  // Send message between threads\n  function sendMessage() {\n    const fromSel = document.getElementById('sendFromThread');\n    const toSel = document.getElementById('sendToThread');\n    const msgInput = document.getElementById('messageContent');\n\n    if(fromSel.selectedIndex === -1 || toSel.selectedIndex === -1) {\n      alert('Select both sender and receiver threads.');\n      return;\n    }\n    const fromId = parseInt(fromSel.value, 10);\n    const toId = parseInt(toSel.value, 10);\n\n    if(fromId === toId) {\n      alert('Cannot send message to the same thread.');\n      return;\n    }\n\n    const fromThread = threads.get(fromId);\n    const toThread = threads.get(toId);\n\n    if(!fromThread || !toThread) {\n      alert('Sender or receiver thread does not exist.');\n      return;\n    }\n\n    if(toThread.state === STATES.TERMINATED) {\n      alert('Cannot send message to terminated thread.');\n      return;\n    }\n\n    const content = msgInput.value.trim();\n    if(!content) {\n      alert('Message content cannot be empty.');\n      return;\n    }\n\n    // Enqueue message to receiver\n    toThread.enqueueMessage({from: fromThread, content});\n    log(`Message sent from \"${fromThread.name}\" to \"${toThread.name}\": \"${content}\"`);\n    msgInput.value = '';\n  }\n\n  // Simulation step: advance all running threads by processing one step\n  function stepSimulation() {\n    if(threads.size === 0) {\n      log('No threads exist to simulate.');\n      return;\n    }\n    // Order threads by priority then id\n    const runnableThreads = Array.from(threads.values())\n      .filter(t => t.state === STATES.RUNNING)\n      .sort((a,b) => b.priority - a.priority || a.id - b.id);\n\n    if(runnableThreads.length === 0) {\n      log('No running threads to advance.');\n      return;\n    }\n\n    // Simulate round-robin stepping by priority order\n    runnableThreads.forEach(thread => thread.processStep());\n    updateThreadSelections();\n  }\n\n  // Clear log button\n  function clearLog() {\n    document.getElementById('log').value = '';\n  }\n\n  // Hook up event listeners\n  document.getElementById('createThreadBtn').addEventListener('click', createThread);\n  document.getElementById('deleteThreadBtn').addEventListener('click', deleteThread);\n\n  document.getElementById('applyPriority').addEventListener('click', applyPriorityChange);\n  document.getElementById('applyName').addEventListener('click', applyNameChange);\n\n  document.getElementById('startThread').addEventListener('click', startThread);\n  document.getElementById('pauseThread').addEventListener('click', pauseThread);\n  document.getElementById('resumeThread').addEventListener('click', resumeThread);\n  document.getElementById('stopThread').addEventListener('click', stopThread);\n  document.getElementById('restartThread').addEventListener('click', restartThread);\n\n  document.getElementById('sendMessageBtn').addEventListener('click', sendMessage);\n\n  document.getElementById('stepSimulation').addEventListener('click', stepSimulation);\n\n  document.getElementById('clearLogBtn').addEventListener('click', clearLog);\n\n  // When currentThread selection changes set inputs for priority and name accordingly\n  document.getElementById('currentThread').addEventListener('change', () => {\n    const thread = getSelectedControlledThread();\n    if(thread) {\n      document.getElementById('changePriority').value = thread.priority;\n      document.getElementById('changeName').value = thread.name;\n    } else {\n      document.getElementById('changePriority').value = '';\n      document.getElementById('changeName').value = '';\n    }\n  });\n\n  // Initialize with a few sample threads for easier exploration\n  function createSampleThreads() {\n    const defaultThreads = [\n      {name: 'Main', priority: 8},\n      {name: 'WorkerA', priority: 5},\n      {name: 'WorkerB', priority: 6},\n      {name: 'Helper', priority: 3},\n    ];\n    defaultThreads.forEach(t => {\n      const thr = new Thread(threadIdCounter++, t.name, t.priority);\n      threads.set(thr.id, thr);\n    });\n    updateThreadSelections();\n    log('Sample threads created: Main, WorkerA, WorkerB, Helper.');\n  }\n\n  createSampleThreads();\n\n})();\n</script>\n\n</body>\n</html>"
