    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Min Heap Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n  }\n  label {\n    display: inline-block;\n    width: 140px;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n  }\n  textarea {\n    width: 100%;\n    height: 120px;\n    font-family: monospace, monospace;\n    margin-top: 10px;\n  }\n  #heapDisplay {\n    white-space: pre;\n    font-family: monospace, monospace;\n  }\n  button {\n    margin: 2px 5px 8px 0;\n  }\n  .section {\n    margin-bottom: 15px;\n  }\n</style>\n</head>\n<body>\n<h2>Interactive Min Heap (Binary) Explorer</h2>\n\n<div class=\"section\" id=\"buildSection\">\n  <label for=\"inputValues\">Build Heap from Array:</label>\n  <input type=\"text\" id=\"inputValues\" placeholder=\"e.g., 5,3,8,1,2\" />\n  <button id=\"btnBuild\">Build Heap</button>\n  <br />\n  <small>Allowed: Integers, separated by commas or spaces.</small>\n</div>\n\n<div class=\"section\" id=\"insertSection\">\n  <label for=\"insertValue\">Insert Value:</label>\n  <input type=\"number\" id=\"insertValue\" />\n  <button id=\"btnInsert\">Insert</button>\n</div>\n\n<div class=\"section\" id=\"extractMinSection\">\n  <button id=\"btnExtractMin\">Extract Min (Pop)</button> \n  <span id=\"extractedMinDisplay\"></span>\n</div>\n\n<div class=\"section\" id=\"peekSection\">\n  <button id=\"btnPeekMin\">Peek Min (Top)</button>\n  <span id=\"peekMinDisplay\"></span>\n</div>\n\n<div class=\"section\" id=\"clearSection\">\n  <button id=\"btnClearHeap\">Clear Heap</button>\n</div>\n\n<div class=\"section\" id=\"bulkOperationsSection\">\n  <label for=\"bulkCount\">Bulk Insert Count:</label>\n  <input type=\"number\" id=\"bulkCount\" min=\"1\" max=\"1000\" value=\"10\" />\n  <button id=\"btnBulkRandomInsert\">Insert Random Values</button>\n</div>\n\n<div class=\"section\" id=\"stateSection\">\n  <button id=\"btnSerialize\">Serialize Heap</button>\n  <button id=\"btnDeserialize\">Deserialize Heap</button><br />\n  <textarea id=\"heapSerialization\" placeholder=\"Serialized heap array here\"></textarea>\n</div>\n\n<div class=\"section\" id=\"heapVisualSection\">\n  <h3>Heap Array (Level order):</h3>\n  <div id=\"heapDisplay\"></div>\n</div>\n\n<div class=\"section\" id=\"stepSection\">\n  <h3>Step-by-Step Heapify (Min-Heapify) Visualization</h3>\n  <label for=\"stepIndex\">Index to Heapify:</label>\n  <input type=\"number\" id=\"stepIndex\" min=\"0\" value=\"0\" />\n  <button id=\"btnStepDownHeapify\">Heapify One Step Down</button>\n  <button id=\"btnStepUpHeapify\">Heapify One Step Up</button>\n  <button id=\"btnResetStep\">Reset Heap to Original State</button>\n  <div><small>Use this to visualize how heapify operations bubble values up or down.</small></div>\n  <div id=\"stepHeapDisplay\" style=\"white-space: pre; font-family: monospace; margin-top: 8px;\"></div>\n</div>\n\n<div class=\"section\" id=\"explanationSection\">\n  <details>\n    <summary><strong>About Min Heap and Controls</strong></summary>\n    <p>\n      This interactive demo lets you explore a <em>min binary heap</em>.\n      The heap invariant is that each parent node is less than or equal to its children.\n    </p>\n    <ul>\n      <li><b>Build Heap</b>: Inputs an array, turns it into a valid min heap.</li>\n      <li><b>Insert</b>: Adds a new value maintaining the heap property.</li>\n      <li><b>Extract Min</b>: Removes and returns the smallest element (the root).</li>\n      <li><b>Peek Min</b>: Shows the smallest value without removing it.</li>\n      <li><b>Bulk Insert</b>: Insert many random values quickly.</li>\n      <li><b>Serialize/Deserialize</b>: Save/load heap state as a JSON array.</li>\n      <li><b>Step-by-Step Heapify</b>: Visualize heapify operations from a specific node. You can step \"down\" or \"up\".</li>\n    </ul>\n  </details>\n</div>\n\n<script>\n(function() {\n  // MinHeap data structure implemented as an array\n  function MinHeap() {\n    this.data = [];\n  }\n\n  MinHeap.prototype._parent = function(i) {\n    return Math.floor((i - 1) / 2);\n  };\n  MinHeap.prototype._left = function(i) {\n    return 2 * i + 1;\n  };\n  MinHeap.prototype._right = function(i) {\n    return 2 * i + 2;\n  };\n\n  // Sift up to restore min heap upwards\n  MinHeap.prototype._heapifyUp = function(index) {\n    if (index <= 0) return false;\n    var parent = this._parent(index);\n    if (this.data[parent] > this.data[index]) {\n      this._swap(parent, index);\n      return parent; // New position after swap\n    }\n    return false;\n  };\n\n  // Sift down to restore min heap downwards\n  MinHeap.prototype._heapifyDown = function(index) {\n    var left = this._left(index);\n    var right = this._right(index);\n    var smallest = index;\n    if (left < this.data.length && this.data[left] < this.data[smallest]) {\n      smallest = left;\n    }\n    if (right < this.data.length && this.data[right] < this.data[smallest]) {\n      smallest = right;\n    }\n    if (smallest !== index) {\n      this._swap(index, smallest);\n      return smallest; // New position after swap\n    }\n    return false;\n  };\n\n  MinHeap.prototype._swap = function(i, j) {\n    var tmp = this.data[i];\n    this.data[i] = this.data[j];\n    this.data[j] = tmp;\n  };\n\n  // Insert a value and restore heap\n  MinHeap.prototype.insert = function(val) {\n    this.data.push(val);\n    // bubble up\n    var i = this.data.length - 1;\n    while(true) {\n      var p = this._parent(i);\n      if (p < 0 || this.data[p] <= this.data[i]) break;\n      this._swap(i, p);\n      i = p;\n    }\n  };\n\n  // Extract min root and restore heap\n  MinHeap.prototype.extractMin = function() {\n    if (this.data.length === 0) return null;\n    if (this.data.length === 1) return this.data.pop();\n    var root = this.data[0];\n    this.data[0] = this.data.pop();\n    this._heapify(0);\n    return root;\n  };\n\n  // Peek min value\n  MinHeap.prototype.peekMin = function() {\n    return this.data.length ? this.data[0] : null;\n  };\n\n  // Heapify whole array from bottom up\n  MinHeap.prototype.buildHeap = function(arr) {\n    this.data = arr.slice();\n    var start = this._parent(this.data.length - 1);\n    for (var i = start; i >= 0; i--) {\n      this._heapify(i);\n    }\n  };\n\n  // Heapify down from index until stable\n  MinHeap.prototype._heapify = function(index) {\n    var pos = index;\n    while(true) {\n      var nextPos = this._heapifyDown(pos);\n      if (nextPos === false) break;\n      pos = nextPos;\n    }\n  };\n\n  // Heapify up from index until stable\n  MinHeap.prototype._heapifyUpFull = function(index) {\n    var pos = index;\n    while (pos > 0) {\n      var nextPos = this._heapifyUp(pos);\n      if (nextPos === false) break;\n      pos = nextPos;\n    }\n  };\n\n  // ----------------------\n  // State to enable step by step heapify visualization\n\n  var heap = new MinHeap();\n  var originalHeapData = []; // To reset step visualization\n\n  // We keep working copies for the step visualizer (copy of current heap data)\n  var stepHeap = null; // new MinHeap()\n  var stepOriginalData = null;\n\n  var inputValuesEl = document.getElementById('inputValues');\n  var btnBuild = document.getElementById('btnBuild');\n  var btnInsert = document.getElementById('btnInsert');\n  var insertValueEl = document.getElementById('insertValue');\n  var btnExtractMin = document.getElementById('btnExtractMin');\n  var extractedMinDisplay = document.getElementById('extractedMinDisplay');\n  var btnPeekMin = document.getElementById('btnPeekMin');\n  var peekMinDisplay = document.getElementById('peekMinDisplay');\n  var btnClearHeap = document.getElementById('btnClearHeap');\n  var heapDisplay = document.getElementById('heapDisplay');\n  var btnSerialize = document.getElementById('btnSerialize');\n  var btnDeserialize = document.getElementById('btnDeserialize');\n  var heapSerialization = document.getElementById('heapSerialization');\n  var bulkCountEl = document.getElementById('bulkCount');\n  var btnBulkRandomInsert = document.getElementById('btnBulkRandomInsert');\n\n  var stepIndexEl = document.getElementById('stepIndex');\n  var btnStepDownHeapify = document.getElementById('btnStepDownHeapify');\n  var btnStepUpHeapify = document.getElementById('btnStepUpHeapify');\n  var btnResetStep = document.getElementById('btnResetStep');\n  var stepHeapDisplay = document.getElementById('stepHeapDisplay');\n\n  // Utility: parses input to array of integers or returns null on invalid\n  function parseInputArray(str) {\n    var parts = str.split(/[\\s,]+/);\n    var res = [];\n    for (var i=0; i<parts.length; i++) {\n      if (parts[i].trim() === '') continue;\n      var n = Number(parts[i]);\n      if (!Number.isInteger(n)) return null;\n      res.push(n);\n    }\n    return res;\n  }\n\n  // Utility: display array in tree-ish format (basic inset for heap levels)\n  // Example:\n  // Index:  Value\n  // Level 0: 2\n  // Level 1: 3, 4\n  // Level 2: 10,11,8\n  function displayHeapArray(arr) {\n    if (arr.length === 0) return \"(empty heap)\";\n    var lines = [];\n    var level = 0;\n    var levelCount = 1;\n    var index = 0;\n    while(index < arr.length) {\n      var lineVals = [];\n      for(var i=0; i<levelCount && index < arr.length; i++, index++) {\n        lineVals.push(arr[index]);\n      }\n      lines.push(\"Level \" + level + \": \" + lineVals.join(\", \"));\n      level++;\n      levelCount *= 2;\n    }\n    return lines.join(\"\\n\");\n  }\n\n  function updateHeapDisplay() {\n    heapDisplay.textContent = displayHeapArray(heap.data);\n  }\n\n  function updateStepHeapDisplay() {\n    if (!stepHeap) {\n      stepHeapDisplay.textContent = \"(No heap loaded for step-by-step)\";\n      return;\n    }\n    stepHeapDisplay.textContent = displayHeapArray(stepHeap.data);\n  }\n\n  function resetStepHeap() {\n    if (!originalHeapData || originalHeapData.length == 0) {\n      stepHeap = null;\n      stepOriginalData = null;\n      updateStepHeapDisplay();\n      return;\n    }\n    stepOriginalData = originalHeapData.slice();\n    stepHeap = new MinHeap();\n    stepHeap.data = stepOriginalData.slice();\n    updateStepHeapDisplay();\n  }\n\n  // Initialize/reset all displays and states\n  function resetAll() {\n    extractedMinDisplay.textContent = \"\";\n    peekMinDisplay.textContent = \"\";\n    heapSerialization.value = \"\";\n    updateHeapDisplay();\n    resetStepHeap();\n  }\n\n  // INTERACTIONS -----------------------------------\n\n  // Build heap from input array\n  btnBuild.addEventListener('click', function() {\n    var arr = parseInputArray(inputValuesEl.value);\n    if (arr === null) {\n      alert(\"Invalid input. Please enter integers separated by commas or spaces.\");\n      return;\n    }\n    if (arr.length === 0) {\n      alert(\"Input is empty.\");\n      return;\n    }\n    heap.buildHeap(arr);\n    originalHeapData = heap.data.slice();\n    resetAll();\n  });\n\n  // Insert single value\n  btnInsert.addEventListener('click', function() {\n    var val = Number(insertValueEl.value);\n    if (!Number.isInteger(val)) {\n      alert(\"Please enter a valid integer to insert.\");\n      return;\n    }\n    heap.insert(val);\n    originalHeapData = heap.data.slice();\n    resetAll();\n  });\n\n  // Extract min\n  btnExtractMin.addEventListener('click', function() {\n    if (heap.data.length === 0) {\n      extractedMinDisplay.textContent = \"Heap is empty.\";\n      return;\n    }\n    var minVal = heap.extractMin();\n    extractedMinDisplay.textContent = \"Extracted Min: \" + minVal;\n    originalHeapData = heap.data.slice();\n    resetAll();\n  });\n\n  // Peek min\n  btnPeekMin.addEventListener('click', function() {\n    var minVal = heap.peekMin();\n    if (minVal === null) {\n      peekMinDisplay.textContent = \"Heap is empty.\";\n    } else {\n      peekMinDisplay.textContent = \"Min: \" + minVal;\n    }\n  });\n\n  // Clear heap\n  btnClearHeap.addEventListener('click', function() {\n    heap.data = [];\n    originalHeapData = [];\n    resetAll();\n  });\n\n  // Bulk random insertions\n  btnBulkRandomInsert.addEventListener('click', function() {\n    var count = Number(bulkCountEl.value);\n    if (!Number.isInteger(count) || count <= 0 || count > 1000) {\n      alert(\"Enter a positive integer (1 to 1000) for bulk insert count.\");\n      return;\n    }\n    for (var i=0; i<count; i++) {\n      var val = Math.floor(Math.random()*1000);\n      heap.insert(val);\n    }\n    originalHeapData = heap.data.slice();\n    resetAll();\n  });\n\n  // Serialization\n  btnSerialize.addEventListener('click', function() {\n    heapSerialization.value = JSON.stringify(heap.data);\n  });\n\n  // Deserialization\n  btnDeserialize.addEventListener('click', function() {\n    var text = heapSerialization.value.trim();\n    if (!text) {\n      alert(\"Paste a serialized heap array here.\");\n      return;\n    }\n    try {\n      var arr = JSON.parse(text);\n      if (!Array.isArray(arr)) throw \"Not an array\";\n      // Validate array contains only integers\n      for (var i=0; i<arr.length; i++) {\n        if (!Number.isInteger(arr[i])) throw \"Array has non-integer value\";\n      }\n      heap.buildHeap(arr);\n      originalHeapData = heap.data.slice();\n      resetAll();\n    } catch(e) {\n      alert(\"Invalid serialized data: \" + e);\n    }\n  });\n\n  // Step by step Heapify visualization\n\n  // Heapify one step down from index\n  btnStepDownHeapify.addEventListener('click', function() {\n    if (!stepHeap) {\n      alert(\"No heap loaded for step-by-step heapify. Build or load a heap first.\");\n      return;\n    }\n    var idx = Number(stepIndexEl.value);\n    if (!Number.isInteger(idx) || idx < 0 || idx >= stepHeap.data.length) {\n      alert(\"Index must be an integer within heap indices (0-\"+(stepHeap.data.length-1)+\").\");\n      return;\n    }\n    var newPos = stepHeap._heapifyDown(idx);\n    if (newPos === false) {\n      alert(\"Heapify down: Node is already in correct position.\");\n    } else {\n      stepIndexEl.value = newPos;\n      updateStepHeapDisplay();\n    }\n  });\n\n  // Heapify one step up from index\n  btnStepUpHeapify.addEventListener('click', function() {\n    if (!stepHeap) {\n      alert(\"No heap loaded for step-by-step heapify. Build or load a heap first.\");\n      return;\n    }\n    var idx = Number(stepIndexEl.value);\n    if (!Number.isInteger(idx) || idx < 0 || idx >= stepHeap.data.length) {\n      alert(\"Index must be an integer within heap indices (0-\"+(stepHeap.data.length-1)+\").\");\n      return;\n    }\n    var newPos = stepHeap._heapifyUp(idx);\n    if (newPos === false) {\n      alert(\"Heapify up: Node is already in correct position.\");\n    } else {\n      stepIndexEl.value = newPos;\n      updateStepHeapDisplay();\n    }\n  });\n\n  // Reset step heap to original copied data\n  btnResetStep.addEventListener('click', function() {\n    resetStepHeap();\n  });\n\n  // On load, initialize minimal state\n  resetAll();\n})();\n</script>\n</body>\n</html>"
  },
