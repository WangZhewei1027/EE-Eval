  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Queue Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  input[type=\"text\"], input[type=\"number\"] {\n    width: 8em;\n  }\n  button {\n    margin: 0.2em 0.1em 0.2em 0;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n  }\n  label {\n    user-select:none;\n  }\n  #queue-visual {\n    white-space: nowrap;\n    overflow-x: auto;\n    margin: 1em 0;\n    padding: 0.5em 0;\n    border-top: 1px solid black;\n    border-bottom: 1px solid black;\n  }\n  #queue-visual > span {\n    border: 1px solid black;\n    padding: 0.3em 0.6em;\n    margin-right: 0.3em;\n    display: inline-block;\n    min-width: 2em;\n    text-align: center;\n  }\n  #log {\n    white-space: pre-wrap;\n    height: 12em;\n    overflow-y: scroll;\n    border: 1px solid black;\n    padding: 0.3em;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.6em;\n  }\n</style>\n</head>\n<body>\n<h2>Interactive Queue Explorer</h2>\n\n<div>\n  <label for=\"input-enqueue\">Element to enqueue:</label>\n  <input type=\"text\" id=\"input-enqueue\" aria-label=\"Element to enqueue\" />\n  <button id=\"btn-enqueue\">Enqueue</button>\n</div>\n\n<div>\n  <button id=\"btn-dequeue\">Dequeue</button>\n  <button id=\"btn-peek\">Peek Front</button>\n  <button id=\"btn-clear\">Clear Queue</button>\n</div>\n\n<div>\n  <label for=\"input-bulk-enqueue\">Bulk enqueue (comma or newline separated):</label><br />\n  <textarea id=\"input-bulk-enqueue\" aria-label=\"Bulk enqueue input\"></textarea><br />\n  <button id=\"btn-bulk-enqueue\">Bulk Enqueue</button>\n</div>\n\n<div>\n  <label for=\"input-enqueue-position\">Enqueue at position:</label>\n  <input type=\"number\" id=\"input-enqueue-position\" min=\"0\" />\n  <input type=\"text\" id=\"input-enqueue-pos-value\" aria-label=\"Value to enqueue at position\" />\n  <button id=\"btn-enqueue-at\">Enqueue at Position</button>\n</div>\n\n<div>\n  <label for=\"input-remove-position\">Remove from position:</label>\n  <input type=\"number\" id=\"input-remove-position\" min=\"0\" />\n  <button id=\"btn-remove-at\">Remove at Position</button>\n</div>\n\n<div>\n  <label for=\"input-find-value\">Find all indexes of value:</label>\n  <input type=\"text\" id=\"input-find-value\" />\n  <button id=\"btn-find\">Find</button>\n</div>\n\n<div>\n  <label for=\"input-rotate-count\">Rotate queue by positions (positive = right, negative = left):</label>\n  <input type=\"number\" id=\"input-rotate-count\" />\n  <button id=\"btn-rotate\">Rotate</button>\n</div>\n\n<div>\n  <label for=\"input-reverse-length\">Reverse first N elements (0 = all):</label>\n  <input type=\"number\" id=\"input-reverse-length\" min=\"0\" />\n  <button id=\"btn-reverse\">Reverse</button>\n</div>\n\n<div id=\"queue-visual\" aria-live=\"polite\" aria-label=\"Queue content\" tabindex=\"0\">\n  <!-- Queue elements appear here -->\n</div>\n\n<fieldset>\n<legend>Queue State & Controls</legend>\n<div><b>Current Size:</b> <span id=\"queue-size\">0</span></div>\n<div><b>Front Element:</b> <span id=\"queue-front\">N/A</span></div>\n<div><b>Back Element:</b> <span id=\"queue-back\">N/A</span></div>\n<div><b>Is Empty:</b> <span id=\"queue-empty\">True</span></div>\n\n<label for=\"input-max-size\">Set max queue size (0 = unlimited):</label>\n<input type=\"number\" id=\"input-max-size\" min=\"0\" value=\"0\" />\n<button id=\"btn-set-max-size\">Set Max Size</button>\n<div><small>Enqueue operations respect max size limit.</small></div>\n</fieldset>\n\n<fieldset>\n<legend>Advanced Queue Operations</legend>\n\n<div>\n  <label for=\"input-compare-value\">Count elements equal to value:</label>\n  <input type=\"text\" id=\"input-compare-value\" />\n  <button id=\"btn-count-equal\">Count Equal</button>\n</div>\n\n<div>\n  <label for=\"input-filter-condition\">Filter elements (JavaScript condition, \"x\" is element):</label><br />\n  <input type=\"text\" id=\"input-filter-condition\" style=\"width: 100%;\" placeholder=\"e.g. x.length > 3 or x.startsWith('a')\" />\n  <button id=\"btn-filter\">Filter Queue</button>\n  <button id=\"btn-reset-filter\">Reset Filter</button>\n  <div><small><b>Warning:</b> this evaluates JavaScript expressions on elements.</small></div>\n</div>\n\n<div>\n  <label for=\"input-map-function\">Map elements (JavaScript expression, \"x\" is element):</label><br />\n  <input type=\"text\" id=\"input-map-function\" style=\"width: 100%;\" placeholder=\"e.g. x.toUpperCase() or x.length\" />\n  <button id=\"btn-map\">Map Queue</button>\n  <button id=\"btn-reset-map\">Reset Map</button>\n  <div><small><b>Warning:</b> this evaluates JavaScript expressions on elements.</small></div>\n</div>\n\n<div>\n  <button id=\"btn-history-back\">Undo (Back)</button>\n  <button id=\"btn-history-forward\">Redo (Forward)</button>\n  <span><small><i>Undo/Redo queue state changes</i></small></span>\n</div>\n</fieldset>\n\n<fieldset>\n<legend>Operation Log (latest at bottom)</legend>\n<div id=\"log\" aria-live=\"polite\" tabindex=\"0\"></div>\n</fieldset>\n\n<script>\n(function(){\n  // The queue is internally an array\n  let queue = [];\n  let maxSize = 0; // 0 means unlimited\n\n  // For undo/redo functionality: history of queue states\n  const history = [];\n  let historyPos = -1; // Points to current state in history\n\n  // For filter/map layers (transformations)\n  // We keep original queue and show filtered/mapped views\n  // Filtered is an array of indices of elements from original queue kept\n  let filterActive = false;\n  let filterIndices = []; \n  let filterCondition = '';\n  // Map function string (JS expr) and parsed function\n  let mapActive = false;\n  let mapFunctionStr = '';\n  let mapFunction = null;\n\n  // For preserving original queue when filtering/mapping changes\n  // queue always holds original data\n  // Display uses filtered/mapped data\n\n  // Cached dom elements\n  const elEnqueue = document.getElementById('input-enqueue');\n  const btnEnqueue = document.getElementById('btn-enqueue');\n  const btnDequeue = document.getElementById('btn-dequeue');\n  const btnPeek = document.getElementById('btn-peek');\n  const btnClear = document.getElementById('btn-clear');\n\n  const elBulk = document.getElementById('input-bulk-enqueue');\n  const btnBulk = document.getElementById('btn-bulk-enqueue');\n\n  const elEnqPos = document.getElementById('input-enqueue-position');\n  const elEnqPosVal = document.getElementById('input-enqueue-pos-value');\n  const btnEnqAt = document.getElementById('btn-enqueue-at');\n\n  const elRemPos = document.getElementById('input-remove-position');\n  const btnRemAt = document.getElementById('btn-remove-at');\n\n  const elFindVal = document.getElementById('input-find-value');\n  const btnFind = document.getElementById('btn-find');\n\n  const elRotateCount = document.getElementById('input-rotate-count');\n  const btnRotate = document.getElementById('btn-rotate');\n\n  const elReverseLen = document.getElementById('input-reverse-length');\n  const btnReverse = document.getElementById('btn-reverse');\n\n  const elQueueVisual = document.getElementById('queue-visual');\n\n  const elSize = document.getElementById('queue-size');\n  const elFront = document.getElementById('queue-front');\n  const elBack = document.getElementById('queue-back');\n  const elEmpty = document.getElementById('queue-empty');\n\n  const elMaxSize = document.getElementById('input-max-size');\n  const btnSetMax = document.getElementById('btn-set-max-size');\n\n  const elCountEqualVal = document.getElementById('input-compare-value');\n  const btnCountEqual = document.getElementById('btn-count-equal');\n\n  const elFilterCond = document.getElementById('input-filter-condition');\n  const btnFilter = document.getElementById('btn-filter');\n  const btnResetFilter = document.getElementById('btn-reset-filter');\n\n  const elMapFunc = document.getElementById('input-map-function');\n  const btnMap = document.getElementById('btn-map');\n  const btnResetMap = document.getElementById('btn-reset-map');\n\n  const btnHistBack = document.getElementById('btn-history-back');\n  const btnHistFwd = document.getElementById('btn-history-forward');\n\n  const elLog = document.getElementById('log');\n\n  // Utility: Log event with timestamp\n  function logEvent(msg) {\n    const dt = new Date().toLocaleTimeString();\n    elLog.textContent += `[${dt}] ${msg}\\n`;\n    elLog.scrollTop = elLog.scrollHeight;\n  }\n\n  function saveHistory() {\n    // Truncate future if needed\n    if (historyPos < history.length -1) {\n      history.splice(historyPos+1);\n    }\n    // Save current queue copy (shallow copy is enough since elements are strings)\n    history.push(queue.slice());\n    historyPos = history.length -1;\n    updateHistoryButtons();\n  }\n\n  function undo() {\n    if(historyPos > 0) {\n      historyPos--;\n      queue = history[historyPos].slice();\n      resetFiltersAndMaps();\n      logEvent(\"Undo: Reverted to previous queue state\");\n      updateUI();\n      updateHistoryButtons();\n    } else {\n      logEvent(\"Undo: No earlier state to revert to\");\n    }\n  }\n\n  function redo() {\n    if(historyPos < history.length-1){\n      historyPos++;\n      queue = history[historyPos].slice();\n      resetFiltersAndMaps();\n      logEvent(\"Redo: Reapplied next queue state\");\n      updateUI();\n      updateHistoryButtons();\n    } else {\n      logEvent(\"Redo: No further state to apply\");\n    }\n  }\n\n  function updateHistoryButtons() {\n    btnHistBack.disabled = historyPos <= 0;\n    btnHistFwd.disabled = historyPos >= history.length -1;\n  }\n\n  function applyFilter() {\n    if (!filterActive) return null;\n    // filterIndices stores indexes in queue to keep\n    return filterIndices.map(i => queue[i]);\n  }\n\n  function applyMap(arr){\n    if (!mapActive || !mapFunction) return arr;\n    try {\n      return arr.map(mapFunction);\n    } catch(e){\n      logEvent(\"Error during map application: \" + e);\n      return arr;\n    }\n  }\n\n  // Compose final view data after filter and map\n  function getViewQueue() {\n    let data;\n    if(filterActive) {\n      data = applyFilter();\n    } else {\n      data = queue.slice();\n    }\n    data = applyMap(data);\n    return data;\n  }\n\n  // Reset filter and mapping\n  function resetFiltersAndMaps(){\n    filterActive = false;\n    filterIndices = [];\n    filterCondition = '';\n    elFilterCond.value = '';\n    mapActive = false;\n    mapFunctionStr = '';\n    mapFunction = null;\n    elMapFunc.value = '';\n  }\n\n  function updateUI() {\n    // Update size/empty\n    elSize.textContent = queue.length;\n    elEmpty.textContent = queue.length === 0 ? \"True\" : \"False\";\n    elFront.textContent = queue.length > 0 ? queue[0] : \"N/A\";\n    elBack.textContent = queue.length > 0 ? queue[queue.length-1] : \"N/A\";\n\n    // Update queue visual with applied filter and map\n    const view = getViewQueue();\n\n    elQueueVisual.textContent = '';\n    if(view.length === 0){\n      elQueueVisual.textContent = \"(empty)\";\n    } else {\n      for(let i=0; i<view.length; i++){\n        const span = document.createElement('span');\n        span.textContent = view[i];\n        span.setAttribute('data-index', i);\n        elQueueVisual.appendChild(span);\n      }\n    }\n    updateHistoryButtons();\n  }\n\n  // Enqueue an element if allowed\n  function enqueue(value) {\n    if (value === '' || value === null || value === undefined) {\n      logEvent(\"Enqueue: Cannot enqueue empty value\");\n      return false;\n    }\n    if(maxSize > 0 && queue.length >= maxSize){\n      logEvent(`Enqueue: Max size ${maxSize} reached, cannot enqueue \"${value}\"`);\n      return false;\n    }\n    queue.push(String(value));\n    saveHistory();\n    logEvent(`Enqueue: \"${value}\" added to back`);\n    updateUI();\n    return true;\n  }\n\n  // Enqueue multiple elements\n  function enqueueMultiple(values) {\n    let succeeded = 0;\n    for(let v of values){\n      v = v.trim();\n      if(v === '') continue;\n      if(enqueue(v)){\n        succeeded++;\n      } else {\n        break; // stop if max size reached\n      }\n    }\n    if(succeeded>0){\n      logEvent(`Bulk Enqueue: Added ${succeeded} elements`);\n    }\n    updateUI();\n  }\n\n  // Dequeue element\n  function dequeue() {\n    if(queue.length === 0){\n      logEvent(\"Dequeue: Queue is empty\");\n      return null;\n    }\n    const val = queue.shift();\n    saveHistory();\n    logEvent(`Dequeue: Removed front element \"${val}\"`);\n    updateUI();\n    return val;\n  }\n\n  // Peek front element\n  function peek() {\n    if(queue.length === 0){\n      logEvent(\"Peek: Queue is empty\");\n      return null;\n    }\n    const val = queue[0];\n    logEvent(`Peek: Front element is \"${val}\"`);\n    return val;\n  }\n\n  // Clear queue\n  function clearQueue() {\n    if(queue.length === 0){\n      logEvent(\"Clear: Queue already empty\");\n      return;\n    }\n    queue = [];\n    saveHistory();\n    resetFiltersAndMaps();\n    logEvent(\"Clear: Queue emptied\");\n    updateUI();\n  }\n\n  // Enqueue at arbitrary position\n  // position >= 0. If > length, treated as length (back)\n  function enqueueAtPosition(position, value){\n    if(value === '' || value === null) {\n      logEvent(\"Enqueue at Position: Value is empty\");\n      return false;\n    }\n\n    position = Math.floor(position);\n    if(isNaN(position) || position < 0) {\n      logEvent(\"Enqueue at Position: Invalid position\");\n      return false;\n    }\n\n    if(maxSize > 0 && queue.length >= maxSize){\n      logEvent(`Enqueue at Position: Max size ${maxSize} reached, cannot enqueue \"${value}\"`);\n      return false;\n    }\n    \n    if(queue.length >= maxSize && maxSize > 0){\n      logEvent(`Enqueue at Position: Max size reached, operation aborted`);\n      return false;\n    }\n\n    if(position > queue.length) position = queue.length;\n    queue.splice(position, 0, String(value));\n    saveHistory();\n    logEvent(`Enqueue at Position: Added \"${value}\" at index ${position}`);\n    updateUI();\n    return true;\n  }\n\n  // Remove at arbitrary position\n  function removeAtPosition(position){\n    position = Math.floor(position);\n    if(isNaN(position) || position < 0 || position >= queue.length){\n      logEvent(\"Remove at Position: Invalid position\");\n      return false;\n    }\n    const removed = queue.splice(position, 1)[0];\n    saveHistory();\n    logEvent(`Remove at Position: Removed element \"${removed}\" at index ${position}`);\n    updateUI();\n    return true;\n  }\n\n  // Find all indexes of a value in queue (before filter/map)\n  // Strict equality of strings here (after trimming)\n  function findAllIndexes(value){\n    value = String(value);\n    const indexes = [];\n    for(let i=0; i<queue.length; i++){\n      if(queue[i] === value){\n        indexes.push(i);\n      }\n    }\n    if(indexes.length === 0){\n      logEvent(`Find: Value \"${value}\" not found in queue`);\n    } else {\n      logEvent(`Find: Value \"${value}\" found at index(es): ${indexes.join(\", \")}`);\n    }\n    return indexes;\n  }\n\n  // Rotate queue by n positions (positive right, negative left)\n  function rotateQueue(n){\n    if(queue.length === 0){\n      logEvent(\"Rotate: Queue is empty\");\n      return false;\n    }\n    n = Math.trunc(n);\n    if(n === 0){\n      logEvent(\"Rotate: Rotation count is zero\");\n      return false;\n    }\n    const len = queue.length;\n    // Normalize n in range -len to len\n    n = ((n % len) + len) % len; \n    if(n === 0){\n      logEvent(\"Rotate: Effective rotation is zero\");\n      return false;\n    }\n    const part1 = queue.slice(-n);\n    const part2 = queue.slice(0, len-n);\n    queue = part1.concat(part2);\n    saveHistory();\n    logEvent(`Rotate: Queue rotated right by ${n} positions`);\n    updateUI();\n    return true;\n  }\n\n  // Reverse first N elements, if N=0 reverse entire queue\n  function reverseFirstN(n){\n    if(queue.length === 0){\n      logEvent(\"Reverse: Queue is empty\");\n      return false;\n    }\n    n = Math.trunc(n);\n    if(n < 0){\n      logEvent(\"Reverse: N cannot be negative\");\n      return false;\n    }\n    if(n === 0 || n > queue.length){\n      n = queue.length;\n    }\n    // Reverse in place first n elements\n    const firstN = queue.slice(0,n).reverse();\n    queue = firstN.concat(queue.slice(n));\n    saveHistory();\n    logEvent(`Reverse: First ${n} elements reversed`);\n    updateUI();\n    return true;\n  }\n\n  // Count elements strictly equal to a value in original queue\n  function countEqualTo(value){\n    value = String(value);\n    let count = 0;\n    for(let el of queue){\n      if(el === value){\n        count++;\n      }\n    }\n    logEvent(`Count Equal: Found ${count} element(s) strictly equal to \"${value}\"`);\n    return count;\n  }\n\n  // Filter Queue by JS condition on elements (\"x\" variable)\n  // Returns array of indices kept in filterIndices, else empty array disables filter\n  function filterQueue(conditionStr){\n    if(conditionStr.trim()===''){\n      logEvent(\"Filter: Empty condition, filter cleared\");\n      filterActive = false;\n      filterIndices = [];\n      filterCondition = '';\n      updateUI();\n      return;\n    }\n    try{\n      // Create function dynamically with 'x' as parameter\n      const f = new Function('x', 'return ' + conditionStr);\n      // Find indices where condition is true\n      const newFilter = [];\n      for(let i=0; i<queue.length; i++){\n        // run condition on the element (strings only)\n        let res = f(queue[i]);\n        if(res) newFilter.push(i);\n      }\n      filterActive = true;\n      filterIndices = newFilter;\n      filterCondition = conditionStr;\n      logEvent(`Filter: Condition applied, ${newFilter.length} elements kept`);\n    } catch(e) {\n      logEvent(`Filter: Error in condition: ${e.message}`);\n      return;\n    }\n    updateUI();\n  }\n  \n  function resetFilter() {\n    if(filterActive){\n      filterActive = false;\n      filterIndices = [];\n      filterCondition = '';\n      logEvent(\"Filter: Filter reset to show all elements\");\n      updateUI();\n    } else {\n      logEvent(\"Filter: No active filter to reset\");\n    }\n  }\n\n  // Map queue elements (transform) by JS expression on each element x\n  function mapQueue(exprStr){\n    if(exprStr.trim() === ''){\n      logEvent(\"Map: Empty expression, map cleared\");\n      mapActive = false;\n      mapFunction = null;\n      mapFunctionStr = '';\n      updateUI();\n      return;\n    }\n    try{\n      // Create function of x returning expression\n      const f = new Function('x', 'return ' + exprStr);\n      // Test once to catch possible error\n      for(let x of queue){\n        f(x);\n      }\n      mapActive = true;\n      mapFunctionStr = exprStr;\n      mapFunction = f;\n      logEvent(\"Map: Mapping function applied to queue\");\n    } catch(e){\n      logEvent(\"Map: Error in map expression: \" + e.message);\n      return;\n    }\n    updateUI();\n  }\n\n  function resetMap() {\n    if(mapActive){\n      mapActive = false;\n      mapFunction = null;\n      mapFunctionStr = '';\n      logEvent(\"Map: Mapping reset to identity\");\n      updateUI();\n    } else {\n      logEvent(\"Map: No active map to reset\");\n    }\n  }\n\n  // Event listeners\n  btnEnqueue.addEventListener('click', () => {\n    const val = elEnqueue.value.trim();\n    if(enqueue(val)){\n      elEnqueue.value = '';\n    }\n  });\n\n  btnDequeue.addEventListener('click', () => {\n    dequeue();\n  });\n\n  btnPeek.addEventListener('click', () => {\n    peek();\n  });\n\n  btnClear.addEventListener('click', () => {\n    if(confirm(\"Are you sure you want to clear the queue?\")){\n      clearQueue();\n    }\n  });\n\n  btnBulk.addEventListener('click', () => {\n    const text = elBulk.value;\n    // Split by comma or newline\n    const parts = text.split(/[\\n,]+/);\n    enqueueMultiple(parts);\n    elBulk.value = '';\n  });\n\n  btnEnqAt.addEventListener('click', () => {\n    const pos = Number(elEnqPos.value);\n    const val = elEnqPosVal.value.trim();\n    if(enqueueAtPosition(pos, val)){\n      elEnqPos.value = '';\n      elEnqPosVal.value = '';\n    }\n  });\n\n  btnRemAt.addEventListener('click', () => {\n    const pos = Number(elRemPos.value);\n    if(removeAtPosition(pos)){\n      elRemPos.value = '';\n    }\n  });\n\n  btnFind.addEventListener('click', () => {\n    const val = elFindVal.value.trim();\n    if(val === ''){\n      logEvent(\"Find: No value provided\");\n      return;\n    }\n    findAllIndexes(val);\n  });\n\n  btnRotate.addEventListener('click', () => {\n    const n = Number(elRotateCount.value);\n    rotateQueue(n);\n    elRotateCount.value = '';\n  });\n\n  btnReverse.addEventListener('click', () => {\n    let n = Number(elReverseLen.value);\n    if(isNaN(n)) n = 0;\n    reverseFirstN(n);\n    elReverseLen.value = '';\n  });\n\n  btnSetMax.addEventListener('click', () => {\n    let n = Number(elMaxSize.value);\n    if(isNaN(n) || n < 0){\n      logEvent(\"Max Size: Invalid max size\");\n      return;\n    }\n    maxSize = n;\n    logEvent(`Max Size: Queue max size set to ${maxSize === 0 ? \"unlimited\" : maxSize}`);\n  });\n\n  btnCountEqual.addEventListener('click', () => {\n    const val = elCountEqualVal.value.trim();\n    if(val === ''){\n      logEvent(\"Count Equal: No value provided\");\n      return;\n    }\n    countEqualTo(val);\n  });\n\n  btnFilter.addEventListener('click', () => {\n    const cond = elFilterCond.value.trim();\n    filterQueue(cond);\n  });\n\n  btnResetFilter.addEventListener('click', () => {\n    resetFilter();\n  });\n\n  btnMap.addEventListener('click', () => {\n    const expr = elMapFunc.value.trim();\n    mapQueue(expr);\n  });\n\n  btnResetMap.addEventListener('click', () => {\n    resetMap();\n  });\n\n  btnHistBack.addEventListener('click', () => {\n    undo();\n  });\n\n  btnHistFwd.addEventListener('click', () => {\n    redo();\n  });\n\n  // Initialization\n  // save empty queue state\n  saveHistory();\n  updateUI();\n  logEvent(\"Queue Explorer loaded\");\n\n  // Extra: Allow Enter key press on single element enqueue to enqueue immediately\n  elEnqueue.addEventListener('keypress', e => {\n    if(e.key === 'Enter'){\n      e.preventDefault();\n      btnEnqueue.click();\n    }\n  });\n  // Same for enqueue at position value input (on Enter enqueue there)\n  elEnqPosVal.addEventListener('keypress', e => {\n    if(e.key === 'Enter'){\n      e.preventDefault();\n      btnEnqAt.click();\n    }\n  });\n\n})();\n</script>\n\n</body>\n</html>"
  },
