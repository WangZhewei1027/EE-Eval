    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Mutex Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        button, input {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Mutex Simulation</h1>\n    \n    <h2>Controls</h2>\n    <button id=\"lockBtn\">Lock</button>\n    <button id=\"unlockBtn\">Unlock</button>\n    \n    <h2>Thread Simulation</h2>\n    <div>\n        <button id=\"startThread1\">Start Thread 1</button>\n        <button id=\"startThread2\">Start Thread 2</button>\n        <button id=\"stopThread1\">Stop Thread 1</button>\n        <button id=\"stopThread2\">Stop Thread 2</button>\n    </div>\n    \n    <h2>Thread States</h2>\n    <div>\n        <span id=\"thread1State\">Thread 1 State: Idle</span><br>\n        <span id=\"thread2State\">Thread 2 State: Idle</span>\n    </div>\n    \n    <h2>Mutex State</h2>\n    <span id=\"mutexState\">Mutex is Unlocked</span><br>\n    \n    <script>\n        let mutex = false;\n        let thread1Active = false;\n        let thread2Active = false;\n\n        const lockBtn = document.getElementById('lockBtn');\n        const unlockBtn = document.getElementById('unlockBtn');\n        const startThread1 = document.getElementById('startThread1');\n        const startThread2 = document.getElementById('startThread2');\n        const stopThread1 = document.getElementById('stopThread1');\n        const stopThread2 = document.getElementById('stopThread2');\n        const thread1State = document.getElementById('thread1State');\n        const thread2State = document.getElementById('thread2State');\n        const mutexState = document.getElementById('mutexState');\n\n        function updateMutexState() {\n            mutexState.textContent = mutex ? \"Mutex is Locked\" : \"Mutex is Unlocked\";\n        }\n\n        function updateThreadState() {\n            thread1State.textContent = `Thread 1 State: ${thread1Active ? 'Running' : 'Idle'}`;\n            thread2State.textContent = `Thread 2 State: ${thread2Active ? 'Running' : 'Idle'}`;\n        }\n\n        lockBtn.addEventListener('click', () => {\n            if (!mutex) {\n                mutex = true;\n                updateMutexState();\n            } else {\n                alert(\"Mutex is already locked!\");\n            }\n        });\n\n        unlockBtn.addEventListener('click', () => {\n            if (mutex) {\n                mutex = false;\n                updateMutexState();\n            } else {\n                alert(\"Mutex is already unlocked!\");\n            }\n        });\n\n        startThread1.addEventListener('click', () => {\n            if (!mutex) {\n                thread1Active = true;\n                updateThreadState();\n            } else {\n                alert(\"Cannot start Thread 1, Mutex is locked!\");\n            }\n        });\n\n        startThread2.addEventListener('click', () => {\n            if (!mutex) {\n                thread2Active = true;\n                updateThreadState();\n            } else {\n                alert(\"Cannot start Thread 2, Mutex is locked!\");\n            }\n        });\n\n        stopThread1.addEventListener('click', () => {\n            thread1Active = false;\n            updateThreadState();\n        });\n\n        stopThread2.addEventListener('click', () => {\n            thread2Active = false;\n            updateThreadState();\n        });\n    </script>\n</body>\n</html>"
