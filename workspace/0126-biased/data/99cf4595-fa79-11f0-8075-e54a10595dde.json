    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Programming Visualizer</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        h1, h2 { margin: 0; }\n        .container { margin: 20px; }\n        .output { margin-top: 20px; }\n        .controls { margin-bottom: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Dynamic Programming Visualizer</h1>\n        \n        <div class=\"controls\">\n            <label for=\"arrayInput\">Enter rice amounts (comma separated):</label>\n            <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 1,2,3,4,5\" />\n            <button id=\"submitBtn\">Submit</button>\n        </div>\n        \n        <div class=\"controls\">\n            <label for=\"targetInput\">Enter target amount:</label>\n            <input type=\"number\" id=\"targetInput\" placeholder=\"e.g. 7\" />\n            <button id=\"calculateBtn\">Calculate</button>\n        </div>\n\n        <button id=\"resetBtn\">Reset</button>\n\n        <div class=\"output\">\n            <h2>Results</h2>\n            <pre id=\"resultsOutput\"></pre>\n        </div>\n    </div>\n\n    <script>\n        let amounts = [];\n        let target = 0;\n\n        document.getElementById('submitBtn').onclick = function() {\n            const input = document.getElementById('arrayInput').value;\n            amounts = input.split(',').map(Number).filter(n => !isNaN(n));\n            document.getElementById('resultsOutput').textContent = \"Amounts set. \" + JSON.stringify(amounts);\n        };\n\n        document.getElementById('calculateBtn').onclick = function() {\n            target = parseInt(document.getElementById('targetInput').value);\n            if (isNaN(target)) {\n                document.getElementById('resultsOutput').textContent = \"Please enter a valid target amount.\";\n                return;\n            }\n\n            const result = dynamicProgrammingMax(amounts, target);\n            document.getElementById('resultsOutput').textContent = \"Result for target \" + target + \": \" + JSON.stringify(result);\n        };\n\n        document.getElementById('resetBtn').onclick = function() {\n            amounts = [];\n            target = 0;\n            document.getElementById('arrayInput').value = '';\n            document.getElementById('targetInput').value = '';\n            document.getElementById('resultsOutput').textContent = '';\n        };\n\n        function dynamicProgrammingMax(nums, target) {\n            const dp = new Array(target + 1).fill(0);\n            for (let i = 1; i <= target; i++) {\n                for (let num of nums) {\n                    if (i >= num) {\n                        dp[i] = Math.max(dp[i], dp[i - num] + num);\n                    }\n                }\n            }\n            return dp[target];\n        }\n    </script>\n</body>\n</html>"
