    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deque - Elegant Visual Exploration</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display&family=Space+Grotesk:wght@400;700&display=swap');\n\n  /* Root and Reset */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n  html, body {\n    height: 100%;\n    background: linear-gradient(135deg, #1f2937, #3b82f6);\n    font-family: 'Space Grotesk', sans-serif;\n    color: #e0e7ff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  /* Container */\n  .container {\n    width: 900px;\n    max-width: 90vw;\n    background: linear-gradient(145deg, #0f1624, #192736);\n    border-radius: 35px;\n    box-shadow:\n      0 0 40px rgba(59,130,246,0.4),\n      inset 0 0 30px #2563eb;\n    padding: 3rem 4rem;\n    overflow: hidden;\n  }\n\n  /* Heading */\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.8rem;\n    color: #60a5fa;\n    text-align: center;\n    margin-bottom: 1rem;\n    letter-spacing: 0.15em;\n    user-select: none;\n    text-shadow:\n      0 0 8px #3b82f6cc,\n      0 0 12px #2563ebcc;\n  }\n\n  /* Subtitle */\n  .subtitle {\n    font-weight: 600;\n    font-size: 1.25rem;\n    color: #93c5fd;\n    text-align: center;\n    margin-bottom: 3.5rem;\n    font-style: italic;\n    user-select: none;\n    text-shadow: 0 0 6px #60a5faaa;\n  }\n\n  /* Deque Visual */\n  .deque {\n    display: flex;\n    justify-content: center;\n    gap: 1.5rem;\n    perspective: 1500px;\n  }\n\n  /* Node Style */\n  .node {\n    position: relative;\n    background: linear-gradient(145deg, #2563eb, #3b82f6);\n    border-radius: 15px;\n    width: 85px;\n    height: 85px;\n    box-shadow:\n      0 10px 15px -3px rgba(14, 165, 233, 0.6),\n      0 4px 6px -2px rgba(14, 165, 233, 0.4);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    color: #ecfeff;\n    font-weight: 700;\n    font-size: 1.12rem;\n    letter-spacing: 0.1em;\n    user-select: none;\n    text-transform: uppercase;\n    transition: transform 0.6s ease;\n    box-reflect: below 0\n      linear-gradient(transparent, transparent 30%, rgba(96,165,250,0.3));\n  }\n  .node::before {\n    content: \"\";\n    position: absolute;\n    top: -8px; left: -8px; right: -8px; bottom: -8px;\n    border-radius: 22px;\n    pointer-events: none;\n    background:\n      radial-gradient(circle at 50% 50%, #60a5fa88 15%, transparent 70%),\n      conic-gradient(from 90deg, #2563eb44, #3b82f6aa);\n    filter: blur(3.8px);\n    opacity: 0.35;\n    z-index: -1;\n  }\n  .node span.value {\n    line-height: 1.15;\n    font-family: 'Playfair Display', serif;\n    font-size: 1.6rem;\n  }\n  .node span.label {\n    font-weight: 500;\n    font-size: 0.75rem;\n    margin-top: 5px;\n    color: #bae6fdcc;\n  }\n\n  /* Arrows between nodes */\n  .arrow {\n    width: 40px;\n    height: 24px;\n    margin: auto 0;\n    position: relative;\n  }\n  .arrow svg {\n    width: 100%; height: 100%;\n    filter: drop-shadow(0 0 2px #60a5fa88);\n  }\n  /* Pulsate animation for arrow */\n  .arrow svg path {\n    stroke: #93c5fddd;\n    stroke-width: 3;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    animation: pulseArrow 2.8s linear infinite;\n  }\n  @keyframes pulseArrow {\n    0%, 100% { stroke-dashoffset: 0; stroke-opacity: 1; }\n    50% { stroke-dashoffset: 14; stroke-opacity: 0.5; }\n  }\n\n  /* Controls at bottom */\n  .controls {\n    margin-top: 4rem;\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n  }\n  .button {\n    background: #2563eb;\n    border: none;\n    border-radius: 12px;\n    padding: 0.65rem 1.75rem;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 700;\n    font-size: 1rem;\n    color: #ecfeff;\n    cursor: pointer;\n    box-shadow:\n      0 6px 12px rgba(37, 99, 235, 0.7);\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.25s ease;\n    user-select: none;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n  }\n  .button:hover {\n    background: #3b82f6;\n    box-shadow:\n      0 10px 18px rgba(59, 130, 246, 0.9);\n    transform: translateY(-3px);\n  }\n  .button:active {\n    transform: translateY(0);\n    box-shadow:\n      0 5px 10px rgba(37, 99, 235, 0.7);\n  }\n\n  /* Concept Description */\n  .description {\n    max-width: 760px;\n    margin: 2rem auto 0 auto;\n    font-size: 1.05rem;\n    line-height: 1.5;\n    color: #93c5fdcc;\n    font-style: italic;\n    text-align: center;\n    user-select:none;\n    pointer-events:none;\n  }\n\n  /* Glow highlight for active node */\n  .node.active {\n    animation: glowPulse 2.5s infinite ease-in-out;\n    box-shadow:\n      0 0 12px 3px #60a5fa,\n      0 0 20px 8px #3b82f6aa;\n  }\n\n  @keyframes glowPulse {\n    0%, 100% {\n      box-shadow:\n        0 0 12px 3px #60a5fa,\n        0 0 20px 8px #3b82f6aa;\n      filter: brightness(1);\n    }\n    50% {\n      box-shadow:\n        0 0 24px 5px #93c5fd,\n        0 0 36px 14px #60a5faee;\n      filter: brightness(1.1);\n    }\n  }\n\n  /* Subtle background shapes - faint, layered */\n  .bg-shapes {\n    position: absolute;\n    top: 0; left: 50%; transform: translateX(-50%);\n    width: 120vw;\n    height: 115vh;\n    pointer-events: none;\n    z-index: 0;\n  }\n  .bg-shapes svg {\n    position: absolute;\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  .bg-shape1 {\n    top: 12vh;\n    left: 10vw;\n    width: 260px; height: 260px;\n    stroke: #2563eb33;\n    filter: drop-shadow(0 0 30px #2563eb50);\n    transform-origin: center;\n    animation: rotateSlow 120s linear infinite;\n  }\n  .bg-shape2 {\n    bottom: 15vh;\n    right: 15vw;\n    width: 320px; height: 320px;\n    stroke: #3b82f633;\n    filter: drop-shadow(0 0 40px #3b82f650);\n    transform-origin: center;\n    animation: rotateSlowReverse 85s linear infinite;\n  }\n  @keyframes rotateSlow {\n    0% { transform: rotate(0deg);}\n    100% { transform: rotate(360deg);}\n  }\n  @keyframes rotateSlowReverse {\n    0% { transform: rotate(360deg);}\n    100% { transform: rotate(0deg);}\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\" aria-label=\"Deque visualization\">\n    <h1>DEQUE</h1>\n    <div class=\"subtitle\">Double-Ended Queue Data Structure Visualized</div>\n    <div class=\"deque\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <!-- Nodes inserted dynamically -->\n    </div>\n    <div class=\"controls\" role=\"region\" aria-label=\"Deque controls\">\n      <button class=\"button\" id=\"pushFront\" aria-describedby=\"descPushFront\">Push Front</button>\n      <button class=\"button\" id=\"popBack\" aria-describedby=\"descPopBack\">Pop Back</button>\n    </div>\n    <p class=\"description\" id=\"descPushFront\">Add a new element to the front of the deque.</p>\n    <p class=\"description\" id=\"descPopBack\">Remove an element from the back of the deque.</p>\n  </div>\n  <div class=\"bg-shapes\" aria-hidden=\"true\">\n    <svg viewBox=\"0 0 100 100\" class=\"bg-shape1\" >\n      <circle cx=\"50\" cy=\"50\" r=\"48\" stroke-dasharray=\"15 7\" />\n    </svg>\n    <svg viewBox=\"0 0 100 100\" class=\"bg-shape2\" >\n      <rect x=\"12\" y=\"12\" width=\"76\" height=\"76\" rx=\"24\" ry=\"24\" stroke-dasharray=\"18 5 8\" />\n    </svg>\n  </div>\n\n<script>\n  (() => {\n    const dequeEl = document.querySelector('.deque');\n    const pushFrontBtn = document.getElementById('pushFront');\n    const popBackBtn = document.getElementById('popBack');\n\n    // Initial data in deque\n    let deque = [18, 7, 35, 22];\n\n    // Animate arrows - a smooth pulsating dash offset handled by CSS;\n\n    // Render deque nodes with arrows\n    function renderDeque() {\n      dequeEl.innerHTML = '';\n      for(let i=0; i<deque.length; i++) {\n        const node = document.createElement('div');\n        node.classList.add('node');\n        // Mark active center-ish node for glow if length>2, else first\n        if(deque.length >= 3 && i === Math.floor(deque.length/2)) {\n          node.classList.add('active');\n        } else if(deque.length < 3 && i === 0) {\n          node.classList.add('active');\n        }\n\n        // Node content: large value and label\n        node.innerHTML = `<span class=\"value\">${deque[i]}</span><span class=\"label\">Node</span>`;\n        dequeEl.appendChild(node);\n\n        // If not last node, add arrow between\n        if(i < deque.length -1) {\n          const arrow = document.createElement('div');\n          arrow.classList.add('arrow');\n          arrow.setAttribute('aria-hidden', 'true');\n          arrow.innerHTML = `\n            <svg viewBox=\"0 0 40 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" >\n              <path d=\"M2 12h36M30 6l8 6-8 6\"/>\n            </svg>\n          `;\n          dequeEl.appendChild(arrow);\n        }\n      }\n    }\n\n    // Utility: Generate random integer 10-99\n    function randomValue() {\n      return Math.floor(Math.random()*90)+10;\n    }\n\n    // Limit deque size visually & logically\n    const MAX_SIZE = 7;\n\n    // Push Front with subtle animation highlight\n    pushFrontBtn.addEventListener('click', () => {\n      if(deque.length >= MAX_SIZE) {\n        // brief shake animation on container to indicate full\n        dequeEl.classList.add('shake');\n        setTimeout(() => dequeEl.classList.remove('shake'), 440);\n        return;\n      }\n      const newVal = randomValue();\n      deque.unshift(newVal);\n      renderDeque();\n      // small animation on new front node\n      const firstNode = dequeEl.querySelector('.node');\n      firstNode.style.transform = 'scale(1.25)';\n      setTimeout(() => {\n        firstNode.style.transition = 'transform 0.5s ease';\n        firstNode.style.transform = 'scale(1)';\n      },1);\n      setTimeout(() => firstNode.style.transition = '', 520);\n    });\n\n    // Pop Back with highlight fade out\n    popBackBtn.addEventListener('click', () => {\n      if(deque.length === 0) {\n        dequeEl.classList.add('shake');\n        setTimeout(() => dequeEl.classList.remove('shake'), 440);\n        return;\n      }\n      const lastNodeIndex = deque.length -1;\n      // Animate fade of last node, then pop and rerender\n      const nodes = dequeEl.querySelectorAll('.node');\n      if(nodes[lastNodeIndex]) {\n        nodes[lastNodeIndex].style.transition = 'transform 0.45s ease, opacity 0.45s ease';\n        nodes[lastNodeIndex].style.transform = 'scale(0.65)';\n        nodes[lastNodeIndex].style.opacity = '0';\n        setTimeout(() => {\n          deque.pop();\n          renderDeque();\n        },460);\n      } else {\n        // fallback\n        deque.pop();\n        renderDeque();\n      }\n    });\n\n    // Initial render\n    renderDeque();\n\n    // Add subtle shake keyframes\n    const style = document.createElement('style');\n    style.textContent = `\n      @keyframes shakeX {\n        0%, 100% { transform: translateX(0) }\n        25% { transform: translateX(-6px) }\n        50% { transform: translateX(6px) }\n        75% { transform: translateX(-4px) }\n      }\n      .shake {\n        animation: shakeX 0.44s cubic-bezier(.36,.07,.19,.97);\n      }\n    `;\n    document.head.appendChild(style);\n  })();\n</script>\n</body>\n</html>"
