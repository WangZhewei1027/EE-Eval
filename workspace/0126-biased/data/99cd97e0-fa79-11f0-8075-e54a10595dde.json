    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Array Demonstration</title>\n    <script>\n        let array = [];\n\n        function updateDisplay() {\n            const display = document.getElementById('arrayDisplay');\n            display.innerText = `Array: [${array.join(', ')}]`;\n        }\n\n        function addElement() {\n            const value = document.getElementById('addElementInput').value;\n            if (value) {\n                array.push(value);\n                updateDisplay();\n                document.getElementById('addElementInput').value = '';\n            }\n        }\n\n        function removeElement() {\n            const value = document.getElementById('removeElementInput').value;\n            const index = array.indexOf(value);\n            if (index !== -1) {\n                array.splice(index, 1);\n                updateDisplay();\n                document.getElementById('removeElementInput').value = '';\n            }\n        }\n\n        function clearArray() {\n            array = [];\n            updateDisplay();\n        }\n\n        function sortArray() {\n            array.sort();\n            updateDisplay();\n        }\n\n        function reverseArray() {\n            array.reverse();\n            updateDisplay();\n        }\n\n        function setArrayLength() {\n            const length = parseInt(document.getElementById('lengthInput').value);\n            if (length >= 0) {\n                array.length = length;\n                updateDisplay();\n            }\n        }\n\n        function addRange() {\n            const start = parseInt(document.getElementById('rangeStartInput').value);\n            const end = parseInt(document.getElementById('rangeEndInput').value);\n            if (!isNaN(start) && !isNaN(end) && start < end) {\n                for (let i = start; i <= end; i++) {\n                    array.push(i);\n                }\n                updateDisplay();\n            }\n        }\n    </script>\n</head>\n<body>\n    <h1>Interactive Array</h1>\n    <div>\n        <h2>Array Operations</h2>\n        <div>\n            <h3>Add Element</h3>\n            <input type=\"text\" id=\"addElementInput\" placeholder=\"Value to add\">\n            <button onclick=\"addElement()\">Add</button>\n        </div>\n        <div>\n            <h3>Remove Element</h3>\n            <input type=\"text\" id=\"removeElementInput\" placeholder=\"Value to remove\">\n            <button onclick=\"removeElement()\">Remove</button>\n        </div>\n        <div>\n            <h3>Clear Array</h3>\n            <button onclick=\"clearArray()\">Clear</button>\n        </div>\n        <div>\n            <h3>Sort Array</h3>\n            <button onclick=\"sortArray()\">Sort</button>\n        </div>\n        <div>\n            <h3>Reverse Array</h3>\n            <button onclick=\"reverseArray()\">Reverse</button>\n        </div>\n        <div>\n            <h3>Set Length</h3>\n            <input type=\"number\" id=\"lengthInput\" placeholder=\"New Length\">\n            <button onclick=\"setArrayLength()\">Set Length</button>\n        </div>\n        <div>\n            <h3>Add Range</h3>\n            <input type=\"number\" id=\"rangeStartInput\" placeholder=\"Start\">\n            <input type=\"number\" id=\"rangeEndInput\" placeholder=\"End\">\n            <button onclick=\"addRange()\">Add Range</button>\n        </div>\n    </div>\n    <div>\n        <h3>Current Array</h3>\n        <div id=\"arrayDisplay\">Array: []</div>\n    </div>\n</body>\n</html>"
