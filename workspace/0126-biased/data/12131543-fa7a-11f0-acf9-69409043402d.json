  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Interactive B-Tree Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n  }\n  textarea, input[type=number] {\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  #output {\n    white-space: pre;\n    font-family: monospace, monospace;\n    border: 1px solid black;\n    padding: 5px;\n    max-height: 300px;\n    overflow: auto;\n  }\n  .section {\n    margin-bottom: 15px;\n  }\n  .inline {\n    display: inline-block;\n    margin-right: 10px;\n  }\n  label {\n    user-select:none;\n  }\n</style>\n</head>\n<body>\n\n<h1>B-Tree Interactive Explorer</h1>\n\n<div class=\"section\">\n  <label for=\"degreeInput\">Set B-Tree Minimum Degree (t): </label>\n  <input type=\"number\" id=\"degreeInput\" value=\"2\" min=\"2\" max=\"20\" step=\"1\" /> \n  <button id=\"resetTree\">Create New Empty Tree</button>\n  <br>\n  <small>Minimum degree t ≥ 2 defines: every node except root has at least t-1 keys and max 2t-1 keys.</small>\n</div>\n\n<div class=\"section\" id=\"insertSection\">\n  <label for=\"insertValue\">Insert Key(s) (comma separated integers): </label>\n  <input type=\"text\" id=\"insertValue\" size=\"30\" />\n  <button id=\"insertBtn\">Insert</button>\n</div>\n\n<div class=\"section\" id=\"deleteSection\">\n  <label for=\"deleteValue\">Delete Key(s) (comma separated integers): </label>\n  <input type=\"text\" id=\"deleteValue\" size=\"30\" />\n  <button id=\"deleteBtn\">Delete</button>\n</div>\n\n<div class=\"section\" id=\"searchSection\">\n  <label for=\"searchValue\">Search Key: </label>\n  <input type=\"number\" id=\"searchValue\" />\n  <button id=\"searchBtn\">Search</button>\n</div>\n\n<div class=\"section\">\n  <button id=\"printInorder\">Print In-Order Traversal</button>\n  <button id=\"printLevelOrder\">Print Level-Order Traversal</button>\n</div>\n\n<div class=\"section\">\n  <label for=\"stepByStepCheckbox\"><input type=\"checkbox\" id=\"stepByStepCheckbox\" /> Enable Step-by-Step Visualization Mode (For Insert/Delete/Search)</label>\n</div>\n\n<div class=\"section\" id=\"visualizationSection\" style=\"display:none;\">\n  <div><b>Step-by-Step Visualization</b></div>\n  <div id=\"stepInfo\" style=\"white-space: pre; font-family: monospace;\"></div>\n  <button id=\"stepBackBtn\" disabled>Step Back</button>\n  <button id=\"stepNextBtn\" disabled>Step Next</button>\n  <button id=\"stepEndBtn\" disabled>Run to End</button>\n</div>\n\n<div class=\"section\">\n  <label><input type=\"checkbox\" id=\"showNodesInfo\" /> Show Node Details</label><br>\n  <label><input type=\"checkbox\" id=\"showKeysCount\" /> Show Key Counts per Node</label><br>\n  <label><input type=\"checkbox\" id=\"showChildrenCount\" /> Show Children Counts per Node</label><br>\n</div>\n\n<hr />\n\n<h2>Current B-Tree Structure</h2>\n<div id=\"output\"></div>\n\n<hr />\n<h2>Logs & Messages</h2>\n<div id=\"log\" style=\"white-space: pre; font-family: monospace; border:1px solid black; padding:5px; max-height: 200px; overflow:auto;\"></div>\n\n<script>\n// B-Tree Implementation with step-by-step visualization\n\nclass BTreeNode {\n  constructor(t, leaf) {\n    this.t = t; // Minimum degree\n    this.leaf = leaf; // Is leaf node\n    this.keys = [];  // keys array\n    this.children = []; // children array\n  }\n\n  // A utility function that returns the index of the first key that is greater or equal to k\n  findKey(k) {\n    let idx = 0;\n    while (idx < this.keys.length && this.keys[idx] < k) {\n      idx++;\n    }\n    return idx;\n  }\n\n  // Step function wrappers will call internal functions with visualization callbacks\n\n  // Insert a key in this node (non-full node)\n  insertNonFull(k, viz) {\n    let i = this.keys.length - 1;\n\n    if (this.leaf) {\n      // Insert key into this leaf node in the correct position\n      while (i >= 0 && this.keys[i] > k) {\n        i--;\n      }\n      this.keys.splice(i + 1, 0, k);\n\n      if (viz) viz.logStep(`Inserted key ${k} at position ${i+1} in leaf node with keys: [${this.keys.join(\", \")}]`);\n      return;\n    } else {\n      // Find the child which is going to have the new key\n      while (i >= 0 && this.keys[i] > k) {\n        i--;\n      }\n      i++;\n      if (viz) viz.logStep(`Descending to child index ${i} with keys: [${this.children[i].keys.join(\", \")}]`);\n\n      // If the found child is full, split it\n      if (this.children[i].keys.length === 2 * this.t - 1) {\n        if (viz) viz.logStep(`Child ${i} full, splitting...`);\n        this.splitChild(i, viz);\n\n        // After split, the middle key moves up and child's keys split\n        if (this.keys[i] < k) {\n          i++;\n        }\n        if (viz) viz.logStep(`After split, descending to child index ${i}`);\n      }\n      this.children[i].insertNonFull(k, viz);\n    }\n  }\n\n  // Split child y of this node. i is index of y in children array\n  splitChild(i, viz) {\n    let y = this.children[i];\n    let z = new BTreeNode(y.t, y.leaf);\n    let t = y.t;\n\n    // Copy last (t-1) keys of y to z\n    for (let j = 0; j < t - 1; j++) {\n      z.keys[j] = y.keys[j + t];\n    }\n\n    // If y is not leaf, copy last t children to z\n    if (!y.leaf) {\n      for (let j = 0; j < t; j++) {\n        z.children[j] = y.children[j + t];\n      }\n    }\n\n    // Reduce size of y\n    y.keys.length = t - 1;\n    y.children.length = y.leaf ? 0 : t;\n\n    // Insert z as child after y\n    this.children.splice(i + 1, 0, z);\n\n    // Move middle key of y up to this node\n    this.keys.splice(i, 0, y.keys[t - 1]);\n    y.keys.splice(t - 1, 1);\n\n    if (viz) {\n      viz.logStep(`Split child node at index ${i}:`);\n      viz.logStep(` - Left node keys after split: [${y.keys.join(\", \")}]`);\n      viz.logStep(` - Right node keys after split: [${z.keys.join(\", \")}]`);\n      viz.logStep(` - Moved up key: ${this.keys[i]}`);\n    }\n  }\n\n  // Delete key k from subtree rooted with this node\n  delete(k, viz) {\n    // Find the key location or child for deletion\n    let idx = this.findKey(k);\n\n    if (idx < this.keys.length && this.keys[idx] === k) {\n      if (this.leaf) {\n        // Case 1: key is in leaf node\n        this.keys.splice(idx,1);\n        if (viz) viz.logStep(`Deleted key ${k} from leaf node: [${this.keys.join(\", \")}]`);\n      } else {\n        // Case 2: key is in internal node\n        if (viz) viz.logStep(`Deleting key ${k} from internal node...`);\n        this.deleteFromNonLeaf(idx, viz);\n      }\n    } else {\n      if (this.leaf) {\n        // Key not found in tree\n        if (viz) viz.logStep(`Key ${k} not found in leaf node.`);\n        return;\n      }\n\n      // Flag to indicate if the key is present in subtree rooted with last child\n      let flag = (idx === this.keys.length);\n\n      if (this.children[idx].keys.length < this.t) {\n        if (viz) viz.logStep(`Child ${idx} has less than t keys, filling...`);\n        this.fill(idx, viz);\n      }\n      // After fill, if last child has been merged, recurse on (idx-1)th child\n      if (flag && idx > this.keys.length) {\n        this.children[idx - 1].delete(k, viz);\n      } else {\n        this.children[idx].delete(k, viz);\n      }\n    }\n  }\n\n  deleteFromNonLeaf(idx, viz) {\n    let k = this.keys[idx];\n    if (this.children[idx].keys.length >= this.t) {\n      // Case 2a: predecessor key\n      let pred = this.getPredecessor(idx);\n      if (viz) viz.logStep(`Replace key ${k} with predecessor ${pred}`);\n      this.keys[idx] = pred;\n      this.children[idx].delete(pred, viz);\n    } else if (this.children[idx+1].keys.length >= this.t) {\n      // Case 2b: successor key\n      let succ = this.getSuccessor(idx);\n      if (viz) viz.logStep(`Replace key ${k} with successor ${succ}`);\n      this.keys[idx] = succ;\n      this.children[idx+1].delete(succ, viz);\n    } else {\n      // Case 2c: merge children[idx] and children[idx+1] and delete k from merged node\n      if (viz) viz.logStep(`Merging children at index ${idx} and ${idx+1}...`);\n      this.merge(idx, viz);\n      this.children[idx].delete(k, viz);\n    }\n  }\n\n  getPredecessor(idx) {\n    let cur = this.children[idx];\n    while (!cur.leaf) {\n      cur = cur.children[cur.keys.length];\n    }\n    return cur.keys[cur.keys.length - 1];\n  }\n\n  getSuccessor(idx) {\n    let cur = this.children[idx + 1];\n    while (!cur.leaf) {\n      cur = cur.children[0];\n    }\n    return cur.keys[0];\n  }\n\n  fill(idx, viz) {\n    if (idx !== 0 && this.children[idx-1].keys.length >= this.t) {\n      if (viz) viz.logStep(`Borrowing from previous sibling at index ${idx-1}`);\n      this.borrowFromPrev(idx, viz);\n    } else if (idx !== this.keys.length && this.children[idx+1].keys.length >= this.t) {\n      if (viz) viz.logStep(`Borrowing from next sibling at index ${idx+1}`);\n      this.borrowFromNext(idx, viz);\n    } else {\n      if (idx !== this.keys.length) {\n        if (viz) viz.logStep(`Merging child at index ${idx} with next sibling at index ${idx+1}`);\n        this.merge(idx, viz);\n      } else {\n        if (viz) viz.logStep(`Merging child at index ${idx-1} with current child at index ${idx}`);\n        this.merge(idx - 1, viz);\n      }\n    }\n  }\n\n  borrowFromPrev(idx, viz) {\n    let child = this.children[idx];\n    let sibling = this.children[idx-1];\n\n    child.keys.unshift(this.keys[idx-1]);\n\n    if (!child.leaf) {\n      child.children.unshift(sibling.children.pop());\n    }\n\n    this.keys[idx-1] = sibling.keys.pop();\n\n    if (viz) {\n      viz.logStep(`Borrowed key from previous sibling.`);\n      viz.logStep(` - Updated child keys: [${child.keys.join(\", \")}]`);\n      viz.logStep(` - Updated sibling keys: [${sibling.keys.join(\", \")}]`);\n      viz.logStep(` - Parent keys: [${this.keys.join(\", \")}]`);\n    }\n  }\n\n  borrowFromNext(idx, viz) {\n    let child = this.children[idx];\n    let sibling = this.children[idx+1];\n\n    child.keys.push(this.keys[idx]);\n\n    if (!child.leaf) {\n      child.children.push(sibling.children.shift());\n    }\n\n    this.keys[idx] = sibling.keys.shift();\n\n    if (viz) {\n      viz.logStep(`Borrowed key from next sibling.`);\n      viz.logStep(` - Updated child keys: [${child.keys.join(\", \")}]`);\n      viz.logStep(` - Updated sibling keys: [${sibling.keys.join(\", \")}]`);\n      viz.logStep(` - Parent keys: [${this.keys.join(\", \")}]`);\n    }\n  }\n\n  merge(idx, viz) {\n    let child = this.children[idx];\n    let sibling = this.children[idx+1];\n\n    child.keys.push(this.keys[idx]);\n\n    for (let i=0;i<sibling.keys.length;i++) {\n      child.keys.push(sibling.keys[i]);\n    }\n\n    if (!child.leaf) {\n      for (let i=0;i<=sibling.keys.length;i++) {\n        child.children.push(sibling.children[i]);\n      }\n    }\n\n    this.keys.splice(idx,1);\n    this.children.splice(idx+1,1);\n\n    if (viz) {\n      viz.logStep(`Merged child at index ${idx} and sibling at index ${idx+1}`);\n      viz.logStep(` - New child keys: [${child.keys.join(\", \")}]`);\n      viz.logStep(` - Parent keys after merge: [${this.keys.join(\", \")}]`);\n    }\n  }\n\n  // Search key k starting from this node, return { node, index } or null\n  search(k, viz) {\n    let i = 0;\n    while (i < this.keys.length && k > this.keys[i]) {\n      i++;\n    }\n    if (viz) viz.logStep(`At node with keys [${this.keys.join(\", \")}], searching for key ${k}, next child index: ${i}`);\n\n    if (i < this.keys.length && this.keys[i] === k) {\n      if (viz) viz.logStep(`Found key ${k} at index ${i} of node.`);\n      return {node: this, index: i};\n    }\n    if (this.leaf) {\n      if (viz) viz.logStep(`Reached leaf node, key ${k} not found.`);\n      return null;\n    }\n    return this.children[i].search(k, viz);\n  }\n\n  // Traverse the tree in order and return keys as array\n  traverse() {\n    let result = [];\n    let i;\n    for (i=0;i<this.keys.length;i++) {\n      if (!this.leaf) {\n        result = result.concat(this.children[i].traverse());\n      }\n      result.push(this.keys[i]);\n    }\n    if (!this.leaf) {\n      result = result.concat(this.children[i].traverse());\n    }\n    return result;\n  }\n\n  // Traverse the tree in level order (BFS) and return array of arrays of keys per level\n  levelOrder() {\n    let result = [];\n    let queue = [{node:this, level:0}];\n    while(queue.length > 0) {\n      let {node, level} = queue.shift();\n      if (!result[level]) result[level] = [];\n      result[level].push(node);\n      if (!node.leaf) {\n        for(let child of node.children) {\n          queue.push({node:child, level:level+1});\n        }\n      }\n    }\n    return result;\n  }\n}\n\nclass BTree {\n  constructor(t) {\n    this.t = t;\n    this.root = new BTreeNode(t, true);\n  }\n\n  insert(k, viz) {\n    if (this.root.keys.length === 2 * this.t - 1) {\n      if (viz) viz.logStep(`Root node full, need to split root.`);\n      let s = new BTreeNode(this.t, false);\n      s.children[0] = this.root;\n      this.root = s;\n      s.splitChild(0, viz);\n      s.insertNonFull(k, viz);\n    } else {\n      this.root.insertNonFull(k, viz);\n    }\n  }\n\n  search(k, viz) {\n    return this.root.search(k, viz);\n  }\n\n  delete(k, viz) {\n    if (!this.root) {\n      if (viz) viz.logStep(`Tree is empty.`);\n      return;\n    }\n    this.root.delete(k, viz);\n    if (this.root.keys.length === 0) {\n      if (!this.root.leaf) {\n        this.root = this.root.children[0];\n      } else {\n        // Tree is empty now\n        this.root = new BTreeNode(this.t, true);\n      }\n      if (viz) viz.logStep(`Updated root after deletion.`);\n    }\n  }\n\n  traverse() {\n    return this.root ? this.root.traverse() : [];\n  }\n\n  levelOrder() {\n    return this.root ? this.root.levelOrder() : [];\n  }\n}\n\n// Visualization State Machine to enable step-by-step interaction\n\nclass VisualizationController {\n  constructor(btree) {\n    this.btree = btree;\n    this.steps = [];\n    this.current = -1;\n    this.activeOperation = null;\n  }\n\n  clear() {\n    this.steps = [];\n    this.current = -1;\n    this.activeOperation = null;\n  }\n\n  // Append a step message\n  logStep(message) {\n    this.steps.push(message);\n  }\n\n  // Add wrapper: Will execute given function and collect logs\n  runInsert(keys, onComplete) {\n    this.clear();\n    this.activeOperation = 'insert';\n    for(let k of keys) {\n      this.logStep(`--- Insert key ${k} ---`);\n      this.btree.insert(k, this);\n    }\n    this.logStep(`Insertion completed.`);\n    if (onComplete) onComplete();\n  }\n\n  runDelete(keys, onComplete) {\n    this.clear();\n    this.activeOperation = 'delete';\n    for(let k of keys) {\n      this.logStep(`--- Delete key ${k} ---`);\n      this.btree.delete(k, this);\n    }\n    this.logStep(`Deletion completed.`);\n    if (onComplete) onComplete();\n  }\n\n  runSearch(key, onComplete) {\n    this.clear();\n    this.activeOperation = 'search';\n    this.logStep(`--- Search for key ${key} ---`);\n    let res = this.btree.search(key, this);\n    if (res) {\n      this.logStep(`Result: Key ${key} FOUND at node keys [${res.node.keys.join(\", \")}] index ${res.index}`);\n    } else {\n      this.logStep(`Result: Key ${key} NOT found in tree.`);\n    }\n    this.logStep(`Search completed.`);\n    if (onComplete) onComplete();\n  }\n\n  canStepNext() {\n    return this.current + 1 < this.steps.length;\n  }\n\n  canStepBack() {\n    return this.current - 1 >= 0;\n  }\n\n  stepNext() {\n    if (this.canStepNext()) this.current++;\n    return this.getCurrentStep();\n  }\n\n  stepBack() {\n    if (this.canStepBack()) this.current--;\n    return this.getCurrentStep();\n  }\n\n  stepEnd() {\n    this.current = this.steps.length - 1;\n    return this.getCurrentStep();\n  }\n\n  getCurrentStep() {\n    if (this.current < 0 || this.current >= this.steps.length) return \"\";\n    return this.steps[this.current];\n  }\n}\n\n// UI and interaction\n(function() {\n  let btree = new BTree(2);\n  let viz = new VisualizationController(btree);\n\n  // DOM refs\n  const degreeInput = document.getElementById(\"degreeInput\");\n  const resetTree = document.getElementById(\"resetTree\");\n  const insertValue = document.getElementById(\"insertValue\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const deleteValue = document.getElementById(\"deleteValue\");\n  const deleteBtn = document.getElementById(\"deleteBtn\");\n  const searchValue = document.getElementById(\"searchValue\");\n  const searchBtn = document.getElementById(\"searchBtn\");\n  const output = document.getElementById(\"output\");\n  const log = document.getElementById(\"log\");\n\n  const printInorderBtn = document.getElementById(\"printInorder\");\n  const printLevelOrderBtn = document.getElementById(\"printLevelOrder\");\n\n  const stepByStepCheckbox = document.getElementById(\"stepByStepCheckbox\");\n  const visualizationSection = document.getElementById(\"visualizationSection\");\n  const stepInfo = document.getElementById(\"stepInfo\");\n  const stepBackBtn = document.getElementById(\"stepBackBtn\");\n  const stepNextBtn = document.getElementById(\"stepNextBtn\");\n  const stepEndBtn = document.getElementById(\"stepEndBtn\");\n\n  const showNodesInfo = document.getElementById(\"showNodesInfo\");\n  const showKeysCount = document.getElementById(\"showKeysCount\");\n  const showChildrenCount = document.getElementById(\"showChildrenCount\");\n\n  // Helpers\n  function logMessage(msg, append=true) {\n    if (append) {\n      log.textContent += msg + \"\\n\";\n      log.scrollTop = log.scrollHeight;\n    } else {\n      log.textContent = msg + \"\\n\";\n      log.scrollTop = log.scrollHeight;\n    }\n  }\n\n  function clearLog() {\n    log.textContent = \"\";\n  }\n\n  // Parse input keys separated by commas\n  function parseKeys(str) {\n    if (!str.trim()) return [];\n    let arr = str.split(\",\").map(s => s.trim()).filter(s=>s!==\"\");\n    let output = [];\n    for(let a of arr) {\n      if (/^-?\\d+$/.test(a)) {\n        output.push(parseInt(a));\n      }\n    }\n    return output;\n  }\n\n  function renderNodeDetails(node) {\n    let parts = [];\n    parts.push(\"[\");\n    for (let i=0; i<node.keys.length; i++) {\n      parts.push(node.keys[i]);\n      if (showKeysCount.checked) {\n        parts.push(`(keys:${node.keys.length})`);\n      }\n      if (showChildrenCount.checked) {\n        parts.push(`(children:${node.children.length})`);\n      }\n      if (i < node.keys.length-1) parts.push(\", \");\n    }\n    parts.push(\"]\");\n    if (showNodesInfo.checked) {\n      parts.push(node.leaf ? \" (leaf)\" : \" (internal)\");\n    }\n    return parts.join(\"\");\n  }\n\n  // Render the tree textually with options\n  function renderTree() {\n    if (!btree.root) {\n      output.textContent = \"(empty tree)\";\n      return;\n    }\n    let lines = [];\n\n    // Level order printing with node details optionally\n    let levels = btree.levelOrder();\n    for (let l=0;l<levels.length;l++) {\n      let lineParts = [];\n      for (let node of levels[l]) {\n        lineParts.push(renderNodeDetails(node));\n      }\n      lines.push(`Level ${l}: ${lineParts.join(\"   \")}`);\n    }\n    output.textContent = lines.join(\"\\n\");\n  }\n\n  // UI State updates for step controls\n  function updateStepControls() {\n    stepBackBtn.disabled = !viz.canStepBack();\n    stepNextBtn.disabled = !viz.canStepNext();\n    stepEndBtn.disabled = !viz.canStepNext();\n  }\n\n  // Run step visualization for insert\n  function runInsertVisualization(keys) {\n    clearLog();\n    viz.runInsert(keys, () => {\n      if (viz.steps.length === 0) {\n        stepInfo.textContent = \"No steps recorded.\";\n      } else {\n        viz.current = -1;\n        stepInfo.textContent = \"\";\n        stepNextBtn.disabled = false;\n        stepBackBtn.disabled = true;\n        stepEndBtn.disabled = false;\n      }\n      renderTree();\n      updateStepControls();\n    });\n  }\n\n  // Run step visualization for delete\n  function runDeleteVisualization(keys) {\n    clearLog();\n    viz.runDelete(keys, () => {\n      if (viz.steps.length === 0) {\n        stepInfo.textContent = \"No steps recorded.\";\n      } else {\n        viz.current = -1;\n        stepInfo.textContent = \"\";\n        stepNextBtn.disabled = false;\n        stepBackBtn.disabled = true;\n        stepEndBtn.disabled = false;\n      }\n      renderTree();\n      updateStepControls();\n    });\n  }\n\n  // Run step visualization for search\n  function runSearchVisualization(key) {\n    clearLog();\n    viz.runSearch(key, () => {\n      if (viz.steps.length === 0) {\n        stepInfo.textContent = \"No steps recorded.\";\n      } else {\n        viz.current = -1;\n        stepInfo.textContent = \"\";\n        stepNextBtn.disabled = false;\n        stepBackBtn.disabled = true;\n        stepEndBtn.disabled = false;\n      }\n      renderTree();\n      updateStepControls();\n    });\n  }\n\n  // Handlers for buttons\n  resetTree.addEventListener(\"click\", function() {\n    let t = parseInt(degreeInput.value);\n    if (isNaN(t) || t < 2) {\n      alert(\"Please enter a valid minimum degree (t ≥ 2).\");\n      return;\n    }\n    btree = new BTree(t);\n    viz = new VisualizationController(btree);\n    clearLog();\n    stepInfo.textContent = \"\";\n    renderTree();\n    if (stepByStepCheckbox.checked) {\n      visualizationSection.style.display = \"block\";\n      stepBackBtn.disabled = true;\n      stepNextBtn.disabled = true;\n      stepEndBtn.disabled = true;\n    } else {\n      visualizationSection.style.display = \"none\";\n    }\n  });\n\n  insertBtn.addEventListener(\"click\", function() {\n    let keys = parseKeys(insertValue.value);\n    if (keys.length === 0) {\n      alert(\"Please enter at least one valid integer key to insert.\");\n      return;\n    }\n    if (stepByStepCheckbox.checked) {\n      runInsertVisualization(keys);\n    } else {\n      clearLog();\n      for (let k of keys) {\n        btree.insert(k);\n        logMessage(`Inserted key ${k}`);\n      }\n      renderTree();\n    }\n  });\n\n  deleteBtn.addEventListener(\"click\", function() {\n    let keys = parseKeys(deleteValue.value);\n    if (keys.length === 0) {\n      alert(\"Please enter at least one valid integer key to delete.\");\n      return;\n    }\n    if (stepByStepCheckbox.checked) {\n      runDeleteVisualization(keys);\n    } else {\n      clearLog();\n      for(let k of keys) {\n        btree.delete(k);\n        logMessage(`Deleted key ${k}`);\n      }\n      renderTree();\n    }\n  });\n\n  searchBtn.addEventListener(\"click\", function() {\n    let k = parseInt(searchValue.value);\n    if (isNaN(k)) {\n      alert(\"Please enter a valid integer key to search.\");\n      return;\n    }\n    if (stepByStepCheckbox.checked) {\n      runSearchVisualization(k);\n    } else {\n      clearLog();\n      let res = btree.search(k);\n      if (res) {\n        logMessage(`Key ${k} found in node with keys [${res.node.keys.join(\", \")}] at index ${res.index}`);\n      } else {\n        logMessage(`Key ${k} not found in B-Tree.`);\n      }\n      renderTree();\n    }\n  });\n\n  printInorderBtn.addEventListener(\"click\", function() {\n    clearLog();\n    let keys = btree.traverse();\n    logMessage(\"In-order traversal:\");\n    logMessage(keys.join(\", \"));\n  });\n\n  printLevelOrderBtn.addEventListener(\"click\", function() {\n    clearLog();\n    let levels = btree.levelOrder();\n    logMessage(\"Level-order traversal:\");\n    for(let i=0;i<levels.length;i++) {\n      let line = \"Level \"+i+\": \";\n      let nodes = levels[i].map(n => `[${n.keys.join(\", \")}]`);\n      logMessage(line + nodes.join(\"  \"));\n    }\n  });\n\n  stepByStepCheckbox.addEventListener(\"change\", function() {\n    if (stepByStepCheckbox.checked) {\n      visualizationSection.style.display = \"block\";\n    } else {\n      visualizationSection.style.display = \"none\";\n      viz.clear();\n      stepInfo.textContent = \"\";\n      stepBackBtn.disabled = true;\n      stepNextBtn.disabled = true;\n      stepEndBtn.disabled = true;\n    }\n  });\n\n  stepNextBtn.addEventListener(\"click\", function() {\n    let msg = viz.stepNext();\n    if (msg !== null) {\n      stepInfo.textContent = msg;\n      logMessage(msg);\n    }\n    updateStepControls();\n    if (!viz.canStepNext()) renderTree();\n  });\n\n  stepBackBtn.addEventListener(\"click\", function() {\n    let msg = viz.stepBack();\n    if (msg !== null) {\n      stepInfo.textContent = msg;\n      // On step back remove last log line if equals step, else do not append again\n      let loglines = log.textContent.trim().split(\"\\n\");\n      if (loglines.length>0 && loglines[loglines.length-1]===msg) {\n        loglines.pop();\n        log.textContent = loglines.join(\"\\n\") + \"\\n\";\n      }\n    }\n    updateStepControls();\n  });\n\n  stepEndBtn.addEventListener(\"click\", function() {\n    let msg = viz.stepEnd();\n    if (msg !== null) {\n      stepInfo.textContent = msg;\n      for(let i = viz.current+1; i<viz.steps.length; i++) {\n        logMessage(viz.steps[i]);\n      }\n    }\n    updateStepControls();\n    renderTree();\n  });\n\n  showNodesInfo.addEventListener(\"change\", renderTree);\n  showKeysCount.addEventListener(\"change\", renderTree);\n  showChildrenCount.addEventListener(\"change\", renderTree);\n\n  // Initialize tree and render\n  renderTree();\n\n})();\n\n</script>\n\n</body>\n</html>"
