    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Ternary Search Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n\n  /* Root colors */\n  :root {\n    --clr-bg: #0f172a;\n    --clr-primary: #4ade80;\n    --clr-secondary: #60a5fa;\n    --clr-accent: #f97316;\n    --clr-neutral-light: #e0e7ff;\n    --clr-neutral-dark: #64748b;\n    --clr-error: #ef4444;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(120deg, #0f172a 0%, #1e293b 100%);\n    color: var(--clr-neutral-light);\n    font-family: 'Poppins', sans-serif;\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n    overflow: hidden;\n  }\n\n  header {\n    padding: 2rem 3rem;\n    text-align: center;\n    user-select: none;\n  }\n\n  header h1 {\n    font-weight: 600;\n    font-size: 3rem;\n    letter-spacing: 0.06em;\n    margin: 0;\n    color: var(--clr-primary);\n    text-shadow:\n      0 0 6px var(--clr-primary),\n      0 0 12px var(--clr-primary);\n  }\n\n  header p {\n    max-width: 520px;\n    margin: 0.5rem auto 0;\n    font-weight: 400;\n    font-size: 1.15rem;\n    color: var(--clr-neutral-light);\n    opacity: 0.75;\n    line-height: 1.5;\n  }\n\n  main {\n    flex-grow: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 1rem 1.5rem 3rem;\n  }\n\n  /* Container holding the ternary search visualization */\n  #visualizer {\n    position: relative;\n    width: 920px;\n    max-width: 95vw;\n    height: 240px;\n    background: #1e293b;\n    border-radius: 20px;\n    box-shadow:\n      inset 0 0 25px #2563eb88,\n      0 10px 30px #2563eb55;\n    overflow: visible;\n    user-select: none;\n    padding: 40px 30px 70px;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n  }\n\n  /* Array container */\n  #array {\n    display: flex;\n    justify-content: space-between;\n    user-select: none;\n  }\n\n  /* Individual array element box */\n  .array-el {\n    position: relative;\n    width: 50px;\n    height: 72px;\n    background: #334155;\n    border-radius: 12px;\n    box-shadow:\n      inset 0 0 12px #64748b55,\n      0 4px 8px #1e293bcc;\n    transition:\n      background-color 0.48s cubic-bezier(0.4,0,0.2,1),\n      box-shadow 0.48s cubic-bezier(0.4,0,0.2,1),\n      transform 0.36s cubic-bezier(0.4,0,0.2,1);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    cursor: default;\n  }\n\n  .array-el span {\n    font-weight: 600;\n    font-size: 1.45rem;\n    color: var(--clr-neutral-light);\n    user-select: text;\n    letter-spacing: 0.02em;\n    text-shadow: 0 0 2px #00000088;\n  }\n\n  /* Selected marker labels (mid1, mid2) */\n  .marker-label {\n    position: absolute;\n    top: -48px;\n    font-weight: 600;\n    font-size: 0.88rem;\n    color: var(--clr-accent);\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    user-select: none;\n    white-space: nowrap;\n    text-shadow:\n      0 0 5px var(--clr-accent),\n      0 0 8px var(--clr-accent);\n  }\n\n  /* Indicator arrow below marker label */\n  .arrow-down {\n    position: absolute;\n    top: -12px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 0; \n    height: 0; \n    border-left: 8px solid transparent;\n    border-right: 8px solid transparent;\n    border-top: 12px solid var(--clr-accent);\n    filter: drop-shadow(0 0 1.2px var(--clr-accent));\n    animation: bounceArrow 1.8s ease-in-out infinite;\n  }\n\n  @keyframes bounceArrow {\n    0%, 100% {\n      transform: translateX(-50%) translateY(0);\n      opacity: 1;\n    }\n    50% {\n      transform: translateX(-50%) translateY(6px);\n      opacity: 0.72;\n    }\n  }\n\n  /* Highlight colors */\n  .highlight-left {\n    background: linear-gradient(135deg, #2563ebbb 10%, #3b82f6cc 90%);\n    box-shadow: 0 0 18px #3b82f6dd;\n    color: #dbeafe;\n  }\n\n  .highlight-mid1 {\n    background: linear-gradient(135deg, #d97706dd 20%, #fbbf24ee 90%);\n    box-shadow: 0 0 20px #fbbf2411, 0 0 16px #eab308cc;\n    color: #fff7cc;\n  }\n\n  .highlight-mid2 {\n    background: linear-gradient(135deg, #ea580cdd 20%, #f9731611 90%);\n    box-shadow: 0 0 22px #fb923cdd, 0 0 18px #f8717111;\n    color: #fff9e6;\n  }\n\n  .highlight-right {\n    background: linear-gradient(135deg, #10b981cc 10%, #34d399dd 90%);\n    box-shadow: 0 0 16px #22c55eaa;\n    color: #e6fff9;\n  }\n\n  .highlight-found {\n    background: linear-gradient(135deg,#facc15dd,#fde68add);\n    box-shadow: 0 0 24px #facc15cc;\n    color: #222200;\n  }\n\n  /* Range separators below array */\n  #range-indicators {\n    position: absolute;\n    bottom: 25px;\n    left: 30px;\n    right: 30px;\n    display: flex;\n    justify-content: space-between;\n    font-weight: 600;\n    color: var(--clr-neutral-dark);\n    text-shadow: 0 0 3px #00000055;\n    pointer-events: none;\n    user-select: none;\n  }\n\n  /* Explanation box */\n  #explanation {\n    max-width: 920px;\n    margin: 0 auto 24px;\n    background: #1e293bdd;\n    padding: 18px 28px;\n    border-radius: 14px;\n    box-shadow: 0 0 30px #4ade8080 inset;\n    font-weight: 500;\n    font-size: 1.2rem;\n    color: var(--clr-neutral-light);\n    line-height: 1.4;\n    min-height: 60px;\n    user-select: none;\n    text-align: center;\n  }\n\n  /* Controls container */\n  #controls {\n    max-width: 920px;\n    margin: 0 auto 2rem;\n    display: flex;\n    justify-content: center;\n    gap: 18px;\n  }\n\n  button {\n    background: linear-gradient(145deg, #2563eb, #1e40af);\n    border: none;\n    border-radius: 12px;\n    padding: 14px 28px;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: var(--clr-neutral-light);\n    cursor: pointer;\n    box-shadow:\n      0 2px 8px #2563ebcc,\n      inset 0 -2px 6px #1e40afcc;\n    user-select: none;\n    transition:\n      background 0.36s ease,\n      box-shadow 0.36s ease,\n      color 0.36s ease;\n  }\n\n  button:hover,\n  button:focus-visible {\n    background: linear-gradient(145deg, #3b82f6, #2563eb);\n    box-shadow:\n      0 4px 18px #3b82f6ff,\n      inset 0 -3px 8px #1e40afcc;\n    outline-offset: 4px;\n    outline: 3px solid #60a5faaa;\n  }\n\n  /* Footer credit */\n  footer {\n    text-align: center;\n    padding: 1rem 1rem 1.5rem;\n    color: var(--clr-neutral-dark);\n    font-size: 0.9rem;\n    user-select: none;\n    font-style: italic;\n    letter-spacing: 0.04em;\n  }\n\n  /* Scrollbar hidden for aesthetic */\n  ::-webkit-scrollbar {\n    width: 0px;\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: transparent;\n  }\n\n  /* Tooltip styling for explanations (if needed) */\n  [data-tooltip] {\n    position: relative;\n    cursor: default;\n  }\n\n  [data-tooltip]:hover::after {\n    content: attr(data-tooltip);\n    position: absolute;\n    bottom: 120%;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #2563ebcc;\n    color: var(--clr-neutral-light);\n    padding: 6px 12px;\n    border-radius: 10px;\n    white-space: normal;\n    font-weight: 500;\n    font-size: 0.88rem;\n    box-shadow: 0 0 16px #2563ebdd;\n    pointer-events: none;\n    opacity: 1;\n    transition: opacity 0.3s ease;\n    z-index: 110;\n  }\n\n  [data-tooltip]::after {\n    opacity: 0;\n    pointer-events: none;\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Ternary Search Visualization</h1>\n  <p>Aesthetic & elegant display of the ternary search algorithm progressively narrowing down a sorted array.</p>\n</header>\n<main>\n  <section id=\"visualizer\" aria-label=\"Ternary Search Visualization\">\n    <div id=\"array\" role=\"list\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n    <div id=\"range-indicators\" aria-hidden=\"true\"></div>\n  </section>\n</main>\n\n<div id=\"explanation\" aria-live=\"polite\" aria-atomic=\"true\" aria-label=\"Step explanation\">\n  Press <strong>Start</strong> to begin the beautiful ternary search animation.\n</div>\n\n<div id=\"controls\">\n  <button id=\"startBtn\" aria-label=\"Start ternary search animation\">Start</button>\n  <button id=\"resetBtn\" aria-label=\"Reset visualization\" disabled>Reset</button>\n</div>\n\n<footer>© 2024 Visualized by AI | Designed for Exceptional Aesthetic Experience</footer>\n\n<script>\n(() => {\n  'use strict';\n\n  const arrayEl = document.getElementById('array');\n  const explanationEl = document.getElementById('explanation');\n  const rangeIndicatorsEl = document.getElementById('range-indicators');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Sorted array to search in\n  // Beautiful incremental values for smooth visual and easier demonstration\n  const arr = [3, 7, 11, 18, 24, 29, 37, 44, 52, 59, 66, 73, 79, 85, 91, 98];\n\n  // Target value to find — exist in array\n  // Let's pick a mid/high element for aesthetic balance\n  const target = 66;\n\n  let left = 0;\n  let right = arr.length - 1;\n  let running = false;\n  let timeoutId = null;\n\n  // Step duration in ms\n  const stepDuration = 2200;\n\n  // Clear the container and display array elements initially\n  function renderArray(selectedIndices = {}, foundIndex = -1) {\n    // selectedIndices keys: left, mid1, mid2, right — each stores index or -1\n    arrayEl.innerHTML = '';\n\n    for (let i = 0; i < arr.length; i++) {\n      const val = arr[i];\n      const el = document.createElement('div');\n      el.classList.add('array-el');\n      el.setAttribute('role', 'listitem');\n      el.setAttribute('aria-label', `Index ${i}, value ${val}`);\n\n      const span = document.createElement('span');\n      span.textContent = val;\n      el.appendChild(span);\n\n      // Add highlights\n      if (foundIndex === i) {\n        el.classList.add('highlight-found');\n      } else {\n        if (i < selectedIndices.left) {\n          // Left of search range - dim\n          el.style.opacity = '0.25';\n          el.style.transform = 'scale(0.85)';\n        } else if (i > selectedIndices.right) {\n          // Right of search range - dim\n          el.style.opacity = '0.25';\n          el.style.transform = 'scale(0.85)';\n        } else {\n          el.style.opacity = '';\n          el.style.transform = '';\n        }\n\n        if (i === selectedIndices.left) el.classList.add('highlight-left');\n        if (i === selectedIndices.mid1) el.classList.add('highlight-mid1');\n        if (i === selectedIndices.mid2) el.classList.add('highlight-mid2');\n        if (i === selectedIndices.right) el.classList.add('highlight-right');\n      }\n\n      // Add marker labels for mid1 and mid2 if present\n      if (i === selectedIndices.mid1 || i === selectedIndices.mid2) {\n        const label = document.createElement('div');\n        label.className = 'marker-label';\n        label.style.left = '50%';\n        label.textContent = i === selectedIndices.mid1 ? 'MID 1' : 'MID 2';\n\n        // We'll position label on top center\n        label.style.transform = 'translateX(-50%)';\n        el.appendChild(label);\n\n        const arrow = document.createElement('div');\n        arrow.className = 'arrow-down';\n        label.appendChild(arrow);\n      }\n\n      arrayEl.appendChild(el);\n    }\n\n    // Show left and right range indicators as array indices below the array\n    rangeIndicatorsEl.innerHTML = `\n      <div>Left: ${selectedIndices.left}</div>\n      <div>Right: ${selectedIndices.right}</div>\n    `;\n  }\n\n  // Explanation text for each step state\n  function explainStep(left, mid1, mid2, right, found, action) {\n    if(found !== -1) {\n      explanationEl.innerHTML = `Value <strong>${target}</strong> found at index <strong>${found}</strong>. Search complete.`;\n      return;\n    }\n    switch(action) {\n      case 'init':\n        explanationEl.innerHTML = `Search for <strong>${target}</strong> begins between indices <strong>${left}</strong> and <strong>${right}</strong>.`;\n        break;\n      case 'compare_mid1_lt':\n        explanationEl.innerHTML = `Target <strong>${target}</strong> is less than middle 1 value <strong>${arr[mid1]}</strong> at index <strong>${mid1}</strong>.<br> Narrowing search to left part.`;\n        break;\n      case 'compare_mid1_eq':\n        explanationEl.innerHTML = `Target <strong>${target}</strong> equals value at middle 1 index <strong>${mid1}</strong>! Found.`;\n        break;\n      case 'compare_mid2_lt':\n        explanationEl.innerHTML = `Target <strong>${target}</strong> is greater than middle 1 <strong>${arr[mid1]}</strong> but less than middle 2 <strong>${arr[mid2]}</strong>. Narrowing search to middle segment.`;\n        break;\n      case 'compare_mid2_eq':\n        explanationEl.innerHTML = `Target <strong>${target}</strong> equals value at middle 2 index <strong>${mid2}</strong>! Found.`;\n        break;\n      case 'compare_mid2_gt':\n        explanationEl.innerHTML = `Target <strong>${target}</strong> is greater than middle 2 value <strong>${arr[mid2]}</strong>.<br> Narrowing search to right part.`;\n        break;\n      default:\n        explanationEl.innerHTML = `Searching indices <strong>${left}</strong> through <strong>${right}</strong>.`;\n    }\n  }\n\n  // Compute middles for ternary search in current range\n  function getMids(l, r) {\n    const third = Math.floor((r - l) / 3);\n    const mid1 = l + third;\n    const mid2 = r - third;\n    return [mid1, mid2];\n  }\n\n  // Animation frame of the ternary search algorithm\n  async function ternarySearchAnim() {\n    running = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    left = 0;\n    right = arr.length - 1;\n    let found = -1;\n\n    // Initial render\n    const [mid1_init, mid2_init] = getMids(left, right);\n    renderArray({ left, mid1: mid1_init, mid2: mid2_init, right });\n    explainStep(left, mid1_init, mid2_init, right, -1, 'init');\n\n    await wait(stepDuration);\n\n    while (left <= right && found === -1) {\n      const [mid1, mid2] = getMids(left, right);\n\n      renderArray({ left, mid1, mid2, right });\n      explainStep(left, mid1, mid2, right, -1, 'default');\n      await wait(stepDuration / 2);\n\n      if (target === arr[mid1]) {\n        found = mid1;\n        renderArray({ left, mid1, mid2, right }, found);\n        explainStep(left, mid1, mid2, right, found, 'compare_mid1_eq');\n        break;\n      }\n\n      if (target < arr[mid1]) {\n        explainStep(left, mid1, mid2, right, -1, 'compare_mid1_lt');\n        right = mid1 - 1;\n        renderArray({ left, mid1, mid2, right });\n        await wait(stepDuration);\n        continue;\n      }\n\n      if (target === arr[mid2]) {\n        found = mid2;\n        renderArray({ left, mid1, mid2, right }, found);\n        explainStep(left, mid1, mid2, right, found, 'compare_mid2_eq');\n        break;\n      }\n\n      if (target < arr[mid2]) {\n        explainStep(left, mid1, mid2, right, -1, 'compare_mid2_lt');\n        left = mid1 + 1;\n        right = mid2 - 1;\n        renderArray({ left, mid1, mid2, right });\n        await wait(stepDuration);\n        continue;\n      }\n\n      explainStep(left, mid1, mid2, right, -1, 'compare_mid2_gt');\n      left = mid2 + 1;\n      renderArray({ left, mid1, mid2, right });\n      await wait(stepDuration);\n    }\n\n    if(found === -1) {\n      explanationEl.innerHTML = `Value <strong>${target}</strong> not found in the array.`;\n      renderArray({ left, mid1: -1, mid2: -1, right }, -1);\n    }\n\n    running = false;\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Utility wait function returning Promise for delays\n  function wait(ms) {\n    return new Promise(r => {\n      timeoutId = setTimeout(r, ms);\n    });\n  }\n\n  // Initialize array display with no highlight at load or reset\n  function initializeDisplay() {\n    renderArray({ left: 0, mid1: -1, mid2: -1, right: arr.length - 1 });\n    explanationEl.innerHTML = `Press <strong>Start</strong> to begin the beautiful ternary search animation.`;\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Reset current animation and visuals\n  function reset() {\n    clearTimeout(timeoutId);\n    running = false;\n    initializeDisplay();\n  }\n\n  startBtn.addEventListener('click', () => {\n    if(running) return;\n    ternarySearchAnim();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n\n  // On initial page load\n  initializeDisplay();\n\n  // Accessibility: prevent focus outline except keyboard navigation\n  let hadKeyboardEvent = false;\n  function handleFirstTab(e) {\n    if (e.key === 'Tab') {\n      hadKeyboardEvent = true;\n      document.body.classList.add('user-is-tabbing');\n      window.removeEventListener('keydown', handleFirstTab);\n    }\n  }\n  window.addEventListener('keydown', handleFirstTab);\n\n})();\n\n</script>\n</body>\n</html>"
  },
