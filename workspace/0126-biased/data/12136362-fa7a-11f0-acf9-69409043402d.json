  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Trie Explorer</title>\n<style>\n  /* Minimal styling for layout: no colors, no fonts, no animations */\n  body { margin: 1em; font-family: monospace, monospace; }\n  button, input, select, label { margin: 0.1em 0.3em 0.1em 0; }\n  textarea { width: 100%; height: 6em; font-family: monospace; font-size: 1em; margin-top: 0.5em; }\n  fieldset { margin-top: 1em; padding: 0.5em; }\n  legend { font-weight: bold; }\n  .output { margin-top: 1em; white-space: pre-wrap; }\n  .inline-block { display: inline-block; vertical-align: middle; }\n  .controls-row { margin-bottom: 0.7em; }\n  hr { margin: 1em 0; }\n</style>\n</head>\n<body>\n\n<h1>Interactive Trie Explorer</h1>\n\n<div class=\"controls-row\">\n  <label for=\"inputWord\">Word/Input:</label>\n  <input id=\"inputWord\" type=\"text\" size=\"20\" aria-label=\"Word or string input\" />\n  <button id=\"btnInsert\">Insert Word</button>\n  <button id=\"btnDelete\">Delete Word</button>\n  <button id=\"btnSearch\">Search Word</button>\n</div>\n\n<div class=\"controls-row\">\n  <label for=\"autoCompletePrefix\">Autocomplete prefix:</label>\n  <input id=\"autoCompletePrefix\" type=\"text\" size=\"15\" aria-label=\"Autocomplete prefix input\" />\n  <button id=\"btnAutocompleteUpto10\">Autocomplete up to 10 results</button>\n  <button id=\"btnAutocompleteAll\">Autocomplete all results</button>\n</div>\n\n<div class=\"controls-row\">\n  <label for=\"prefixCountInput\">Prefix count:</label>\n  <input id=\"prefixCountInput\" type=\"text\" size=\"12\" aria-label=\"Prefix count input\" />\n  <button id=\"btnCountPrefix\">Count Words With Prefix</button>\n</div>\n\n<div class=\"controls-row\">\n  <label for=\"deletePrefixInput\">Delete all with prefix:</label>\n  <input id=\"deletePrefixInput\" type=\"text\" size=\"12\" aria-label=\"Prefix to delete input\" />\n  <button id=\"btnDeletePrefix\">Delete Words With Prefix</button>\n</div>\n\n<hr />\n\n<fieldset>\n  <legend>Bulk Operations</legend>\n  <label for=\"bulkWords\">Paste words (one per line):</label><br />\n  <textarea id=\"bulkWords\" aria-label=\"Bulk words input area\"></textarea><br />\n  <button id=\"btnBulkInsert\">Bulk Insert Words</button>\n  <button id=\"btnBulkDelete\">Bulk Delete Words</button>\n  <button id=\"btnResetTrie\">Reset Trie (clear all)</button>\n</fieldset>\n\n<hr />\n\n<fieldset>\n  <legend>Trie Exploration and Visualization Controls</legend>\n  <div>\n    <label>Traverse From Root to Node:</label>\n    <input id=\"traversePathInput\" type=\"text\" size=\"20\" placeholder=\"e.g. cat\" aria-label=\"Traverse path input\" />\n    <button id=\"btnTraverseNode\">Traverse to Node</button>\n    <button id=\"btnShowAllWordsUnderNode\">List Words Under Node</button>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <label for=\"depthLimitRange\">Traversal Depth Limit:</label>\n    <input type=\"range\" id=\"depthLimitRange\" min=\"1\" max=\"20\" value=\"10\" />\n    <span id=\"depthLimitValue\">10</span>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <button id=\"btnShowTrieStructure\">Show Trie Structure (textual)</button>\n  </div>\n</fieldset>\n\n<hr />\n\n<fieldset>\n  <legend>Advanced Query</legend>\n  <label for=\"fuzzySearchInput\">Fuzzy Search (max edit distance):</label>\n  <input id=\"fuzzySearchInput\" type=\"text\" size=\"15\" aria-label=\"Fuzzy search input\" />\n  <label for=\"fuzzyDistanceInput\">Distance (0-3):</label>\n  <select id=\"fuzzyDistanceInput\" aria-label=\"Select max edit distance\">\n    <option value=\"0\">0</option>\n    <option value=\"1\" selected>1</option>\n    <option value=\"2\">2</option>\n    <option value=\"3\">3</option>\n  </select>\n  <button id=\"btnFuzzySearch\">Run Fuzzy Search</button>\n</fieldset>\n\n<hr />\n\n<div>\n  <h2>Output</h2>\n  <pre id=\"outputArea\" class=\"output\" aria-live=\"polite\" aria-atomic=\"true\"></pre>\n</div>\n\n<script>\n// ******************** TRIE DATA STRUCTURE ********************\n\nclass TrieNode {\n  constructor() {\n    this.children = new Map(); // char -> TrieNode\n    this.endOfWord = false;\n    this.countSubtreeWords = 0; // number of complete words in subtree rooted here\n  }\n}\n\nclass Trie {\n  constructor() {\n    this.root = new TrieNode();\n  }\n\n  insert(word) {\n    if (typeof word !== 'string' || word.length === 0) return false;\n    let node = this.root;\n    let createdNew = false;\n    for (const c of word) {\n      if (!node.children.has(c)) {\n        node.children.set(c, new TrieNode());\n        createdNew = true;\n      }\n      node = node.children.get(c);\n    }\n    if (!node.endOfWord) {\n      node.endOfWord = true;\n      createdNew = true;\n      // Update countSubtreeWords on insert path\n      this._updateCounts(word, 1);\n    }\n    return createdNew;\n  }\n\n  _updateCounts(word, delta) {\n    // delta = +1 for insert, -1 for deletion\n    let node = this.root;\n    node.countSubtreeWords += delta;\n    for (const c of word) {\n      node = node.children.get(c);\n      node.countSubtreeWords += delta;\n    }\n  }\n\n  search(word) {\n    if (typeof word !== 'string' || word.length === 0) return false;\n    let node = this.root;\n    for (const c of word) {\n      if (!node.children.has(c)) return false;\n      node = node.children.get(c);\n    }\n    return node.endOfWord === true;\n  }\n\n  delete(word) {\n    if (!this.search(word)) return false;\n    this._delete(this.root, word, 0);\n    return true;\n  }\n\n  _delete(node, word, index) {\n    if (index === word.length) {\n      if (!node.endOfWord) return false;\n      node.endOfWord = false;\n      this._updateCounts(word, -1);\n      return node.children.size === 0;\n    }\n    const c = word[index];\n    const childNode = node.children.get(c);\n    if (!childNode) return false;\n    const shouldDelete = this._delete(childNode, word, index + 1);\n    if (shouldDelete) {\n      node.children.delete(c);\n      return !node.endOfWord && node.children.size === 0;\n    }\n    return false;\n  }\n\n  startsWith(prefix) {\n    if (typeof prefix !== 'string') return false;\n    let node = this.root;\n    for (const c of prefix) {\n      if (!node.children.has(c)) return null;\n      node = node.children.get(c);\n    }\n    return node;\n  }\n\n  countWordsWithPrefix(prefix) {\n    const node = this.startsWith(prefix);\n    if (!node) return 0;\n    return node.countSubtreeWords;\n  }\n\n  listWords(prefix=\"\", limit=Infinity) {\n    // returns up to limit words lexicographically under prefix\n    const node = this.startsWith(prefix);\n    if (!node) return [];\n    const results = [];\n    function dfs(currentNode, path) {\n      if (results.length >= limit) return;\n      if (currentNode.endOfWord) results.push(prefix + path.join(''));\n      for (const [char, nextNode] of [...currentNode.children.entries()].sort((a,b)=>a[0].localeCompare(b[0]))) {\n        path.push(char);\n        dfs(nextNode, path);\n        path.pop();\n        if (results.length >= limit) return;\n      }\n    }\n    dfs(node, []);\n    return results;\n  }\n\n  deleteWordsWithPrefix(prefix) {\n    // Deletes all words with the prefix and updates counts accordingly\n    const node = this.startsWith(prefix);\n    if (!node) return 0;\n    const count = node.countSubtreeWords;\n    if (count === 0) return 0;\n    // To delete words, we need to remove the subtree for prefix from root\n    // But partial nodes may need preservation\n    // Strategy:\n    // We will walk down to prefix node, then remove subtree reference from parent\n    // and update counts upward\n    if (prefix.length === 0) { // delete all trie content\n      this.root = new TrieNode();\n      return count;\n    }\n    let pathNodes = [this.root];\n    let nodeCurrent = this.root;\n    for (const c of prefix) {\n      nodeCurrent = nodeCurrent.children.get(c);\n      pathNodes.push(nodeCurrent);\n    }\n    // remove subtree at prefix node from parent\n    let parent = pathNodes[pathNodes.length - 2];\n    parent.children.delete(prefix[prefix.length - 1]);\n    // update counts backwards\n    for(let i = pathNodes.length - 2; i >= 0; i--) {\n      pathNodes[i].countSubtreeWords -= count;\n    }\n    return count;\n  }\n\n  // Traverse to node by path and return node or null\n  traverse(path) {\n    if(typeof path !== 'string') return null;\n    let node = this.root;\n    for(const c of path) {\n      if(!node.children.has(c)) return null;\n      node = node.children.get(c);\n    }\n    return node;\n  }\n\n  // Show textual structure from node:\n  // Represented with indentation, maxDepth limits recursion depth\n  // format: c [* if endOfWord] (countSubtreeWords)\n  textualStructure(node=this.root, indent=\"\", maxDepth=10) {\n    if(maxDepth <0) return '';\n    let lines = [];\n    for (const [char, childNode] of [...node.children.entries()].sort((a,b)=>a[0].localeCompare(b[0]))) {\n      const wordEndMark = childNode.endOfWord ? \"*\" : \"\";\n      lines.push(`${indent}${char}${wordEndMark} (${childNode.countSubtreeWords})`);\n      if(maxDepth>0) {\n        lines = lines.concat(this.textualStructure(childNode, indent+\"  \", maxDepth-1));\n      }\n    }\n    return lines.join(\"\\n\");\n  }\n\n  // List all words under node with depth limit\n  listWordsUnderNode(node, prefix, limit, maxDepth) {\n    const results = [];\n    function dfs(currentNode, path, depth){\n      if(results.length>=limit)return;\n      if(depth<0)return;\n      if(currentNode.endOfWord)results.push(prefix + path.join(''));\n      for(const [char, nextNode] of [...currentNode.children.entries()].sort((a,b)=>a[0].localeCompare(b[0]))){\n        path.push(char);\n        dfs(nextNode, path, depth-1);\n        path.pop();\n        if(results.length>=limit)return;\n      }\n    }\n    dfs(node, [], maxDepth);\n    return results;\n  }\n\n  // Fuzzy search with max edit distance (using a simple DP approach)\n  // Returns words with edit distance <= maxDistance\n  fuzzySearch(word, maxDistance=1, maxResults=1000) {\n    const results = [];\n    const root = this.root;\n    const wlen = word.length;\n\n    // Using a standard algorithm (trie + edit distance DP)\n    function recursiveSearch(node, prefix, previousRow) {\n      if(results.length >= maxResults) return;\n      const columns = wlen + 1;\n      for (const [char, childNode] of node.children.entries()) {\n        const currentRow = [previousRow[0] + 1];\n        for(let i=1; i<columns; i++) {\n          const insertCost = currentRow[i - 1] + 1;\n          const deleteCost = previousRow[i] + 1;\n          const replaceCost = word[i - 1] === char ? previousRow[i - 1] : previousRow[i - 1] + 1;\n          currentRow.push(Math.min(insertCost, deleteCost, replaceCost));\n        }\n        if(currentRow[currentRow.length - 1] <= maxDistance && childNode.endOfWord) {\n          results.push(prefix + char);\n          if(results.length >= maxResults) return;\n        }\n        if(Math.min(...currentRow) <= maxDistance) {\n          recursiveSearch(childNode, prefix + char, currentRow);\n          if(results.length >= maxResults) return;\n        }\n      }\n    }\n\n    recursiveSearch(root, \"\", Array.from({length:wlen+1}, (_,i)=>i));\n    return results;\n  }\n}\n\n\n// ******************** UI AND LOGIC ********************\n\nconst trie = new Trie();\n\nconst outputArea = document.getElementById(\"outputArea\");\n\nfunction log(msg) {\n  outputArea.textContent = msg;\n}\n\nfunction appendLog(msg) {\n  outputArea.textContent += msg + \"\\n\";\n}\n\n// Buttons and inputs\nconst inputWord = document.getElementById(\"inputWord\");\nconst btnInsert = document.getElementById(\"btnInsert\");\nconst btnDelete = document.getElementById(\"btnDelete\");\nconst btnSearch = document.getElementById(\"btnSearch\");\n\nconst autoCompletePrefix = document.getElementById(\"autoCompletePrefix\");\nconst btnAutocompleteUpto10 = document.getElementById(\"btnAutocompleteUpto10\");\nconst btnAutocompleteAll = document.getElementById(\"btnAutocompleteAll\");\n\nconst prefixCountInput = document.getElementById(\"prefixCountInput\");\nconst btnCountPrefix = document.getElementById(\"btnCountPrefix\");\n\nconst deletePrefixInput = document.getElementById(\"deletePrefixInput\");\nconst btnDeletePrefix = document.getElementById(\"btnDeletePrefix\");\n\nconst bulkWords = document.getElementById(\"bulkWords\");\nconst btnBulkInsert = document.getElementById(\"btnBulkInsert\");\nconst btnBulkDelete = document.getElementById(\"btnBulkDelete\");\nconst btnResetTrie = document.getElementById(\"btnResetTrie\");\n\nconst traversePathInput = document.getElementById(\"traversePathInput\");\nconst btnTraverseNode = document.getElementById(\"btnTraverseNode\");\nconst btnShowAllWordsUnderNode = document.getElementById(\"btnShowAllWordsUnderNode\");\n\nconst depthLimitRange = document.getElementById(\"depthLimitRange\");\nconst depthLimitValue = document.getElementById(\"depthLimitValue\");\n\nconst btnShowTrieStructure = document.getElementById(\"btnShowTrieStructure\");\n\nconst fuzzySearchInput = document.getElementById(\"fuzzySearchInput\");\nconst fuzzyDistanceInput = document.getElementById(\"fuzzyDistanceInput\");\nconst btnFuzzySearch = document.getElementById(\"btnFuzzySearch\");\n\n\nfunction sanitizeWord(w) {\n  if(typeof w !== 'string') return '';\n  return w.trim().toLowerCase();\n}\n\n// >>> Insert Word\nbtnInsert.addEventListener('click', () => {\n  const w = sanitizeWord(inputWord.value);\n  if (w.length === 0) {\n    log(\"Please enter a non-empty word to insert.\");\n    return;\n  }\n  if(trie.insert(w))\n    log(`Inserted word: \"${w}\"`);\n  else\n    log(`Word \"${w}\" already in trie.`);\n  inputWord.value = \"\";\n});\n\n// >>> Delete Word\nbtnDelete.addEventListener('click', () => {\n  const w = sanitizeWord(inputWord.value);\n  if (w.length === 0) {\n    log(\"Please enter a non-empty word to delete.\");\n    return;\n  }\n  if(trie.delete(w))\n    log(`Deleted word: \"${w}\"`);\n  else\n    log(`Word \"${w}\" not found in trie.`);\n  inputWord.value = \"\";\n});\n\n// >>> Search Word\nbtnSearch.addEventListener('click', () => {\n  const w = sanitizeWord(inputWord.value);\n  if (w.length === 0) {\n    log(\"Please enter a non-empty word to search.\");\n    return;\n  }\n  if(trie.search(w))\n    log(`Word \"${w}\" FOUND in trie.`);\n  else\n    log(`Word \"${w}\" NOT found in trie.`);\n});\n\n// >>> Autocomplete up to 10\nbtnAutocompleteUpto10.addEventListener('click', () => {\n  const prefix = sanitizeWord(autoCompletePrefix.value);\n  if (prefix.length === 0) {\n    log(\"Please enter a prefix to autocomplete.\");\n    return;\n  }\n  const matches = trie.listWords(prefix, 10);\n  if (matches.length === 0) {\n    log(`No autocomplete results for prefix \"${prefix}\".`);\n  } else {\n    log(`Autocomplete up to 10 for prefix \"${prefix}\":\\n` + matches.join(\"\\n\"));\n  }\n});\n\n// >>> Autocomplete all\nbtnAutocompleteAll.addEventListener('click', () => {\n  const prefix = sanitizeWord(autoCompletePrefix.value);\n  if (prefix.length === 0) {\n    log(\"Please enter a prefix to autocomplete.\");\n    return;\n  }\n  const matches = trie.listWords(prefix, 10000);\n  if (matches.length === 0) {\n    log(`No autocomplete results for prefix \"${prefix}\".`);\n  } else {\n    log(`Autocomplete all results for prefix \"${prefix}\":\\n` + matches.join(\"\\n\"));\n  }\n});\n\n// >>> Count words with prefix\nbtnCountPrefix.addEventListener('click', () => {\n  const prefix = sanitizeWord(prefixCountInput.value);\n  if(prefix.length === 0) {\n    log(\"Please enter a prefix to count words.\");\n    return;\n  }\n  const count = trie.countWordsWithPrefix(prefix);\n  log(`Number of words with prefix \"${prefix}\": ${count}`);\n});\n\n// >>> Delete words with prefix\nbtnDeletePrefix.addEventListener('click', () => {\n  const prefix = sanitizeWord(deletePrefixInput.value);\n  if(prefix.length === 0) {\n    log(\"Please enter a prefix to delete words.\");\n    return;\n  }\n  const count = trie.deleteWordsWithPrefix(prefix);\n  if(count === 0) {\n    log(`No words found with prefix \"${prefix}\" to delete.`);\n  } else {\n    log(`Deleted ${count} word(s) with prefix \"${prefix}\".`);\n  }\n});\n\n// >>> Bulk insert words\nbtnBulkInsert.addEventListener('click', () => {\n  const text = bulkWords.value;\n  if(text.trim().length === 0) {\n    log(\"Please paste words (one per line) to bulk insert.\");\n    return;\n  }\n  const words = text.split(/\\r?\\n/).map(w=>sanitizeWord(w)).filter(w=>w.length>0);\n  let insertedCount = 0;\n  for(const w of words) {\n    if(trie.insert(w)) insertedCount++;\n  }\n  log(`Bulk Insert: ${insertedCount} new word(s) inserted out of ${words.length} lines.`);\n  bulkWords.value = \"\";\n});\n\n// >>> Bulk delete words\nbtnBulkDelete.addEventListener('click', () => {\n  const text = bulkWords.value;\n  if(text.trim().length === 0) {\n    log(\"Please paste words (one per line) to bulk delete.\");\n    return;\n  }\n  const words = text.split(/\\r?\\n/).map(w=>sanitizeWord(w)).filter(w=>w.length>0);\n  let deletedCount = 0;\n  for(const w of words) {\n    if(trie.delete(w)) deletedCount++;\n  }\n  log(`Bulk Delete: ${deletedCount} word(s) deleted out of ${words.length} lines.`);\n  bulkWords.value = \"\";\n});\n\n// >>> Reset Trie\nbtnResetTrie.addEventListener('click', () => {\n  if(confirm(\"Are you sure you want to reset the trie and erase all words?\")) {\n    trie.root = new TrieNode();\n    log(\"Trie has been reset.\");\n  } else {\n    log(\"Reset cancelled.\");\n  }\n});\n\n// >>> Traverse to node by path\nbtnTraverseNode.addEventListener('click', () => {\n  const path = sanitizeWord(traversePathInput.value);\n  if(path.length === 0) {\n    log(\"Please enter a path to traverse.\");\n    return;\n  }\n  const node = trie.traverse(path);\n  if(node === null) {\n    log(`Path \"${path}\" does NOT exist in the trie.`);\n    return;\n  }\n  log(`Traversed to node \"${path}\".\\nEnd Of Word: ${node.endOfWord}\\nWords in Subtree: ${node.countSubtreeWords}`);\n});\n\n// >>> Show all words under node\nbtnShowAllWordsUnderNode.addEventListener('click', () => {\n  const path = sanitizeWord(traversePathInput.value);\n  if(path.length === 0) {\n    log(\"Please enter a path to show words under the node.\");\n    return;\n  }\n  const node = trie.traverse(path);\n  if(node === null) {\n    log(`Node \"${path}\" does NOT exist in the trie.`);\n    return;\n  }\n  const maxDepth = parseInt(depthLimitRange.value, 10);\n  const limit = 1000; // safety limit to avoid huge dumps\n  const words = trie.listWordsUnderNode(node, path, limit, maxDepth);\n  if(words.length === 0) {\n    log(`No words under node \"${path}\" up to depth ${maxDepth}.`);\n  } else {\n    log(`Words under node \"${path}\" (depth limit ${maxDepth}, max ${limit}):\\n${words.join('\\n')}`);\n  }\n});\n\n// >>> Depth limit slider sync\ndepthLimitRange.addEventListener('input', () => {\n  depthLimitValue.textContent = depthLimitRange.value;\n});\n\n// >>> Show whole Trie structure textual\nbtnShowTrieStructure.addEventListener('click', () => {\n  const maxDepth = parseInt(depthLimitRange.value, 10);\n  const structureText = trie.textualStructure(trie.root, \"\", maxDepth);\n  if(structureText === \"\") {\n    log(\"(The trie is empty.)\");\n  } else {\n    log(\"Trie structure (max depth \"+maxDepth+\"):\\n\" + structureText);\n  }\n});\n\n// >>> Fuzzy search\nbtnFuzzySearch.addEventListener('click', () => {\n  const pattern = sanitizeWord(fuzzySearchInput.value);\n  if(pattern.length === 0) {\n    log(\"Please enter a word/pattern for fuzzy search.\");\n    return;\n  }\n  const maxDist = parseInt(fuzzyDistanceInput.value, 10);\n  const maxResults = 1000; // limit results\n  log(`Running fuzzy search for \"${pattern}\" with max distance ${maxDist}... Please wait.`);\n  setTimeout(() => {\n    const results = trie.fuzzySearch(pattern, maxDist, maxResults);\n    if(results.length === 0) {\n      log(`No words found within edit distance ${maxDist} of \"${pattern}\".`);\n    } else {\n      log(`Fuzzy search results for \"${pattern}\" (max distance ${maxDist}, up to ${maxResults} results):\\n` + results.join(\"\\n\"));\n    }\n  }, 10);\n});\n\n\n// >>> Keyboard shortcuts: Enter triggers Insert for inputWord if focused\ninputWord.addEventListener('keydown', e => {\n  if(e.key === 'Enter') {\n    e.preventDefault();\n    btnInsert.click();\n  }\n});\n\nautoCompletePrefix.addEventListener('keydown', e => {\n  if(e.key==='Enter'){\n    e.preventDefault();\n    btnAutocompleteUpto10.click();\n  }\n});\n\nprefixCountInput.addEventListener('keydown', e => {\n  if(e.key === 'Enter') {\n    e.preventDefault();\n    btnCountPrefix.click();\n  }\n});\n\ndeletePrefixInput.addEventListener('keydown', e => {\n  if(e.key === 'Enter') {\n    e.preventDefault();\n    btnDeletePrefix.click();\n  }\n});\n\ntraversePathInput.addEventListener('keydown', e => {\n  if(e.key==='Enter'){\n    e.preventDefault();\n    btnTraverseNode.click();\n  }\n});\n\nfuzzySearchInput.addEventListener('keydown', e => {\n  if(e.key === 'Enter') {\n    e.preventDefault();\n    btnFuzzySearch.click();\n  }\n});\n\n// On load show instructions\nlog(\n  \"Trie Interactive Explorer Ready.\\n\"+\n  \"Available operations:\\n\"+\n  \"- Insert/Search/Delete words\\n\"+\n  \"- Autocomplete with prefix\\n\"+\n  \"- Count/Delete words with prefix\\n\"+\n  \"- Bulk insert/delete and reset\\n\"+\n  \"- Traverse nodes and list words under nodes with depth limit\\n\"+\n  \"- Show textual trie structure\\n\"+\n  \"- Fuzzy search (edit distance 0-3)\\n\\n\"+\n  \"Try inserting words then exploring the trie!\"\n);\n\n</script>\n\n</body>\n</html>"
  },
