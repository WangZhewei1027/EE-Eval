    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Max Heap Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n        }\n        \n        h1 {\n            font-size: 2.8rem;\n            font-weight: 700;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 0.5rem;\n            letter-spacing: -0.5px;\n        }\n        \n        .subtitle {\n            font-size: 1.1rem;\n            color: var(--dark);\n            opacity: 0.7;\n            font-weight: 300;\n            max-width: 600px;\n            line-height: 1.6;\n        }\n        \n        .visualization-container {\n            position: relative;\n            width: 100%;\n            max-width: 900px;\n            min-height: 500px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);\n            padding: 2rem;\n            margin-bottom: 2rem;\n            overflow: hidden;\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n        \n        button {\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.8rem;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 25px rgba(108, 92, 231, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .heap-container {\n            width: 100%;\n            height: 400px;\n            position: relative;\n            display: flex;\n            justify-content: center;\n        }\n        \n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: 700;\n            font-size: 1.2rem;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);\n            z-index: 2;\n        }\n        \n        .edge {\n            position: absolute;\n            background: var(--secondary);\n            height: 2px;\n            transform-origin: 0 0;\n            z-index: 1;\n            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);\n        }\n        \n        .extract-animation {\n            animation: extract 1s ease-out forwards;\n        }\n        \n        @keyframes extract {\n            0% {\n                transform: scale(1);\n                opacity: 1;\n            }\n            50% {\n                transform: scale(1.2);\n                opacity: 0.8;\n            }\n            100% {\n                transform: scale(0);\n                opacity: 0;\n            }\n        }\n        \n        .insert-animation {\n            animation: insert 1s ease-out forwards;\n        }\n        \n        @keyframes insert {\n            0% {\n                transform: scale(0);\n                opacity: 0;\n            }\n            70% {\n                transform: scale(1.1);\n                opacity: 0.8;\n            }\n            100% {\n                transform: scale(1);\n                opacity: 1;\n            }\n        }\n        \n        .highlight {\n            animation: highlight 1.5s ease-in-out infinite;\n        }\n        \n        @keyframes highlight {\n            0%, 100% {\n                box-shadow: 0 0 0 0 rgba(253, 121, 168, 0.7);\n            }\n            50% {\n                box-shadow: 0 0 0 15px rgba(253, 121, 168, 0);\n            }\n        }\n        \n        .status {\n            position: absolute;\n            bottom: 2rem;\n            left: 2rem;\n            right: 2rem;\n            background: rgba(255, 255, 255, 0.9);\n            padding: 1rem;\n            border-radius: 10px;\n            font-size: 0.9rem;\n            text-align: center;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n        }\n        \n        .decorative-element {\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, rgba(108, 92, 231, 0.1) 0%, rgba(253, 121, 168, 0.1) 100%);\n            z-index: -1;\n        }\n        \n        .decorative-element:nth-child(1) {\n            top: -100px;\n            right: -100px;\n        }\n        \n        .decorative-element:nth-child(2) {\n            bottom: -50px;\n            left: -100px;\n            width: 200px;\n            height: 200px;\n        }\n        \n        footer {\n            margin-top: 2rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"visualization-container\">\n        <div class=\"decorative-element\"></div>\n        <div class=\"decorative-element\"></div>\n        \n        <header>\n            <h1>Max Heap Visualization</h1>\n            <p class=\"subtitle\">A complete binary tree where each node is greater than or equal to its children. The largest element is always at the root.</p>\n        </header>\n        \n        <div class=\"controls\">\n            <button id=\"insert-btn\">Insert Random Value</button>\n            <button id=\"extract-btn\">Extract Max</button>\n        </div>\n        \n        <div class=\"heap-container\" id=\"heap-container\"></div>\n        \n        <div class=\"status\" id=\"status\">Heap is empty. Click \"Insert Random Value\" to add elements.</div>\n    </div>\n    \n    <footer>An elegant visualization of the Max Heap data structure</footer>\n    \n    <script>\n        class MaxHeap {\n            constructor() {\n                this.heap = [];\n                this.maxSize = 15; // Limit for visualization purposes\n            }\n            \n            parent(index) {\n                return Math.floor((index - 1) / 2);\n            }\n            \n            leftChild(index) {\n                return 2 * index + 1;\n            }\n            \n            rightChild(index) {\n                return 2 * index + 2;\n            }\n            \n            insert(value) {\n                if (this.heap.length >= this.maxSize) {\n                    document.getElementById('status').textContent = 'Heap is full (maximum size reached for visualization)';\n                    return false;\n                }\n                \n                this.heap.push(value);\n                this.heapifyUp(this.heap.length - 1);\n                return true;\n            }\n            \n            extractMax() {\n                if (this.heap.length === 0) return null;\n                \n                const max = this.heap[0];\n                const last = this.heap.pop();\n                \n                if (this.heap.length > 0) {\n                    this.heap[0] = last;\n                    this.heapifyDown(0);\n                }\n                \n                return max;\n            }\n            \n            heapifyUp(index) {\n                while (index > 0 && this.heap[this.parent(index)] < this.heap[index]) {\n                    [this.heap[this.parent(index)], this.heap[index]] = [this.heap[index], this.heap[this.parent(index)]];\n                    index = this.parent(index);\n                }\n            }\n            \n            heapifyDown(index) {\n                let maxIndex = index;\n                const left = this.leftChild(index);\n                const right = this.rightChild(index);\n                \n                if (left < this.heap.length && this.heap[left] > this.heap[maxIndex]) {\n                    maxIndex = left;\n                }\n                \n                if (right < this.heap.length && this.heap[right] > this.heap[maxIndex]) {\n                    maxIndex = right;\n                }\n                \n                if (index !== maxIndex) {\n                    [this.heap[index], this.heap[maxIndex]] = [this.heap[maxIndex], this.heap[index]];\n                    this.heapifyDown(maxIndex);\n                }\n            }\n            \n            size() {\n                return this.heap.length;\n            }\n            \n            isEmpty() {\n                return this.heap.length === 0;\n            }\n        }\n        \n        const heap = new MaxHeap();\n        const heapContainer = document.getElementById('heap-container');\n        const statusElement = document.getElementById('status');\n        const insertBtn = document.getElementById('insert-btn');\n        const extractBtn = document.getElementById('extract-btn');\n        \n        function renderHeap() {\n            // Clear previous rendering\n            heapContainer.innerHTML = '';\n            \n            if (heap.isEmpty()) {\n                statusElement.textContent = 'Heap is empty. Click \"Insert Random Value\" to add elements.';\n                return;\n            }\n            \n            statusElement.textContent = `Current heap size: ${heap.size()}. Root value: ${heap.heap[0]}`;\n            \n            // Calculate tree dimensions\n            const height = Math.floor(Math.log2(heap.size())) + 1;\n            const maxWidth = Math.pow(2, height - 1);\n            \n            // Calculate node positions\n            const nodeWidth = 60;\n            const nodeHeight = 60;\n            const horizontalSpacing = 100;\n            const verticalSpacing = 100;\n            \n            const startX = heapContainer.offsetWidth / 2;\n            const startY = 40;\n            \n            // Create nodes and edges\n            for (let i = 0; i < heap.size(); i++) {\n                const level = Math.floor(Math.log2(i + 1));\n                const levelWidth = Math.pow(2, level);\n                const levelStartIndex = Math.pow(2, level) - 1;\n                const positionInLevel = i - levelStartIndex;\n                \n                const x = startX + (positionInLevel - (levelWidth - 1) / 2) * (nodeWidth + horizontalSpacing);\n                const y = startY + level * (nodeHeight + verticalSpacing);\n                \n                // Draw edges to children if they exist\n                const leftChild = heap.leftChild(i);\n                const rightChild = heap.rightChild(i);\n                \n                if (leftChild < heap.size()) {\n                    const leftChildLevel = Math.floor(Math.log2(leftChild + 1));\n                    const leftChildLevelStartIndex = Math.pow(2, leftChildLevel) - 1;\n                    const leftChildPositionInLevel = leftChild - leftChildLevelStartIndex;\n                    \n                    const leftChildX = startX + (leftChildPositionInLevel - (Math.pow(2, leftChildLevel) - 1) / 2) * (nodeWidth + horizontalSpacing);\n                    const leftChildY = startY + leftChildLevel * (nodeHeight + verticalSpacing);\n                    \n                    drawEdge(x, y, leftChildX, leftChildY);\n                }\n                \n                if (rightChild < heap.size()) {\n                    const rightChildLevel = Math.floor(Math.log2(rightChild + 1));\n                    const rightChildLevelStartIndex = Math.pow(2, rightChildLevel) - 1;\n                    const rightChildPositionInLevel = rightChild - rightChildLevelStartIndex;\n                    \n                    const rightChildX = startX + (rightChildPositionInLevel - (Math.pow(2, rightChildLevel) - 1) / 2) * (nodeWidth + horizontalSpacing);\n                    const rightChildY = startY + rightChildLevel * (nodeHeight + verticalSpacing);\n                    \n                    drawEdge(x, y, rightChildX, rightChildY);\n                }\n                \n                // Create node\n                const node = document.createElement('div');\n                node.className = 'node';\n                node.style.left = `${x - nodeWidth/2}px`;\n                node.style.top = `${y - nodeHeight/2}px`;\n                node.textContent = heap.heap[i];\n                \n                if (i === 0) {\n                    node.classList.add('highlight');\n                }\n                \n                heapContainer.appendChild(node);\n            }\n        }\n        \n        function drawEdge(x1, y1, x2, y2) {\n            const length = Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2));\n            const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;\n            \n            const edge = document.createElement('div');\n            edge.className = 'edge';\n            edge.style.width = `${length}px`;\n            edge.style.left = `${x1}px`;\n            edge.style.top = `${y1}px`;\n            edge.style.transform = `rotate(${angle}deg)`;\n            \n            heapContainer.appendChild(edge);\n        }\n        \n        function insertRandomValue() {\n            const value = Math.floor(Math.random() * 100) + 1;\n            if (heap.insert(value)) {\n                renderHeap();\n                \n                // Animate the new node (last one added)\n                const nodes = document.querySelectorAll('.node');\n                if (nodes.length > 0) {\n                    const newNode = nodes[nodes.length - 1];\n                    newNode.classList.add('insert-animation');\n                    \n                    setTimeout(() => {\n                        newNode.classList.remove('insert-animation');\n                        if (nodes.length === 1) {\n                            newNode.classList.add('highlight');\n                        }\n                    }, 1000);\n                }\n                \n                statusElement.textContent = `Inserted value: ${value}. Current heap size: ${heap.size()}. Root value: ${heap.heap[0]}`;\n            }\n        }\n        \n        function extractMaxValue() {\n            const max = heap.extractMax();\n            if (max !== null) {\n                // Animate the root node before removing\n                const rootNode = document.querySelector('.node');\n                if (rootNode) {\n                    rootNode.classList.add('extract-animation');\n                    \n                    setTimeout(() => {\n                        renderHeap();\n                        statusElement.textContent = `Extracted max value: ${max}. Current heap size: ${heap.size()}. ${heap.size() > 0 ? `New root value: ${heap.heap[0]}` : 'Heap is now empty.'}`;\n                    }, 1000);\n                }\n            } else {\n                statusElement.textContent = 'Heap is empty. Nothing to extract.';\n            }\n        }\n        \n        // Insert initial elements\n        for (let i = 0; i < 5; i++) {\n            heap.insert(Math.floor(Math.random() * 100) + 1);\n        }\n        renderHeap();\n        \n        // Event listeners\n        insertBtn.addEventListener('click', insertRandomValue);\n        extractBtn.addEventListener('click', extractMaxValue);\n        \n        // Initial animation\n        setTimeout(() => {\n            const nodes = document.querySelectorAll('.node');\n            if (nodes.length > 0) {\n                nodes.forEach((node, index) => {\n                    node.style.transitionDelay = `${index * 0.1}s`;\n                });\n            }\n        }, 500);\n    </script>\n</body>\n</html>"
