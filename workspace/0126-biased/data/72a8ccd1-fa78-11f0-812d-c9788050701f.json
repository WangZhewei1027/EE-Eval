    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visual Hash Map</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1s ease-out;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n        \n        .container {\n            width: 100%;\n            max-width: 1200px;\n            position: relative;\n        }\n        \n        .hash-map-visual {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 2rem;\n            margin-bottom: 3rem;\n        }\n        \n        .hash-function {\n            background: white;\n            padding: 1.5rem 2rem;\n            border-radius: 12px;\n            box-shadow: 0 15px 30px rgba(0,0,0,0.1);\n            width: fit-content;\n            text-align: center;\n            position: relative;\n            z-index: 2;\n            transition: all 0.3s ease;\n            animation: float 4s ease-in-out infinite;\n        }\n        \n        .hash-function:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 20px 40px rgba(0,0,0,0.15);\n        }\n        \n        .hash-function h3 {\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n        }\n        \n        .hash-function p {\n            font-family: monospace;\n            font-size: 1.2rem;\n            color: var(--dark);\n        }\n        \n        .buckets-container {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n            gap: 1.5rem;\n            width: 100%;\n            position: relative;\n        }\n        \n        .bucket {\n            background: white;\n            border-radius: 10px;\n            width: 120px;\n            min-height: 180px;\n            box-shadow: 0 10px 20px rgba(0,0,0,0.1);\n            overflow: hidden;\n            transition: all 0.3s ease;\n            position: relative;\n            animation: fadeInUp 0.8s ease-out forwards;\n            animation-delay: calc(var(--order) * 0.1s);\n            opacity: 0;\n        }\n        \n        .bucket-header {\n            background: var(--primary);\n            color: white;\n            padding: 0.5rem;\n            text-align: center;\n            font-weight: 600;\n        }\n        \n        .bucket-items {\n            padding: 0.5rem;\n            display: flex;\n            flex-direction: column;\n            gap: 0.5rem;\n        }\n        \n        .key-value-pair {\n            background: var(--light);\n            border-radius: 6px;\n            padding: 0.5rem;\n            font-size: 0.9rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            transition: all 0.3s ease;\n            transform-origin: top;\n        }\n        \n        .key {\n            font-weight: 600;\n            color: var(--primary);\n        }\n        \n        .value {\n            color: var(--dark);\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n            justify-content: center;\n        }\n        \n        button {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n        }\n        \n        button:hover {\n            background: var(--accent);\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(253, 121, 168, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n        \n        .particle {\n            position: absolute;\n            background: var(--secondary);\n            border-radius: 50%;\n            opacity: 0.3;\n            animation: float 6s infinite ease-in-out;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(-20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes float {\n            0% { transform: translateY(0px); }\n            50% { transform: translateY(-10px); }\n            100% { transform: translateY(0px); }\n        }\n        \n        @keyframes highlight {\n            0% { background: white; }\n            50% { background: rgba(162, 155, 254, 0.3); }\n            100% { background: white; }\n        }\n        \n        .highlight {\n            animation: highlight 1.5s ease-out;\n        }\n        \n        .decoration {\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            border-radius: 50%;\n            background: radial-gradient(circle, rgba(162, 155, 254, 0.2) 0%, rgba(255,255,255,0) 70%);\n            z-index: -1;\n        }\n        \n        .decoration-1 {\n            top: -100px;\n            left: -100px;\n        }\n        \n        .decoration-2 {\n            bottom: -100px;\n            right: -100px;\n        }\n        \n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"decoration decoration-1\"></div>\n    <div class=\"decoration decoration-2\"></div>\n    \n    <header>\n        <h1>Visual Hash Map</h1>\n        <p class=\"subtitle\">A beautifully designed visualization of key-value pair storage using hash functions</p>\n    </header>\n    \n    <div class=\"container\">\n        <div class=\"hash-map-visual\">\n            <div class=\"hash-function\">\n                <h3>Hash Function</h3>\n                <p>hash(key) = key.length % 7</p>\n            </div>\n            \n            <div class=\"buckets-container\" id=\"buckets\">\n                <!-- Buckets will be generated by JavaScript -->\n            </div>\n            \n            <div class=\"controls\">\n                <button id=\"addBtn\">Add Random Item</button>\n                <button id=\"highlightBtn\">Show Hashing</button>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <footer>\n        <p>© 2023 Visual Data Structures | Designed for aesthetic appreciation</p>\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            const particlesContainer = document.getElementById('particles');\n            for (let i = 0; i < 20; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                particle.style.width = `${Math.random() * 10 + 5}px`;\n                particle.style.height = particle.style.width;\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.animationDelay = `${Math.random() * 5}s`;\n                particle.style.animationDuration = `${Math.random() * 5 + 3}s`;\n                particlesContainer.appendChild(particle);\n            }\n            \n            // Sample data\n            const sampleData = [\n                { key: \"apple\", value: \"red fruit\" },\n                { key: \"banana\", value: \"yellow fruit\" },\n                { key: \"cherry\", value: \"small red fruit\" },\n                { key: \"date\", value: \"sweet fruit\" },\n                { key: \"elderberry\", value: \"dark berry\" },\n                { key: \"fig\", value: \"soft fruit\" },\n                { key: \"grape\", value: \"small fruit\" },\n                { key: \"honeydew\", value: \"melon\" },\n                { key: \"kiwi\", value: \"fuzzy fruit\" },\n                { key: \"lemon\", value: \"citrus fruit\" }\n            ];\n            \n            // Initialize hash map with 7 buckets\n            const bucketCount = 7;\n            const bucketsContainer = document.getElementById('buckets');\n            \n            // Create buckets\n            for (let i = 0; i < bucketCount; i++) {\n                const bucket = document.createElement('div');\n                bucket.classList.add('bucket');\n                bucket.style.setProperty('--order', i);\n                \n                const header = document.createElement('div');\n                header.classList.add('bucket-header');\n                header.textContent = `Bucket ${i}`;\n                \n                const items = document.createElement('div');\n                items.classList.add('bucket-items');\n                items.id = `bucket-${i}`;\n                \n                bucket.appendChild(header);\n                bucket.appendChild(items);\n                bucketsContainer.appendChild(bucket);\n            }\n            \n            // Hash function\n            function hash(key) {\n                return key.length % bucketCount;\n            }\n            \n            // Add item to hash map\n            function addItem(key, value) {\n                const bucketIndex = hash(key);\n                const bucket = document.getElementById(`bucket-${bucketIndex}`);\n                \n                const pair = document.createElement('div');\n                pair.classList.add('key-value-pair');\n                \n                const keyEl = document.createElement('span');\n                keyEl.classList.add('key');\n                keyEl.textContent = key;\n                \n                const valueEl = document.createElement('span');\n                valueEl.classList.add('value');\n                valueEl.textContent = value;\n                \n                pair.appendChild(keyEl);\n                pair.appendChild(valueEl);\n                bucket.appendChild(pair);\n                \n                return bucketIndex;\n            }\n            \n            // Add some initial items\n            sampleData.slice(0, 5).forEach(item => {\n                addItem(item.key, item.value);\n            });\n            \n            // Add random item button\n            document.getElementById('addBtn').addEventListener('click', function() {\n                const randomIndex = Math.floor(Math.random() * sampleData.length);\n                const item = sampleData[randomIndex];\n                const bucketIndex = addItem(item.key, item.value);\n                \n                // Highlight the bucket that was modified\n                const bucket = document.getElementById(`bucket-${bucketIndex}`);\n                bucket.parentElement.classList.add('highlight');\n                setTimeout(() => {\n                    bucket.parentElement.classList.remove('highlight');\n                }, 1500);\n            });\n            \n            // Highlight hashing process button\n            document.getElementById('highlightBtn').addEventListener('click', function() {\n                const randomIndex = Math.floor(Math.random() * sampleData.length);\n                const item = sampleData[randomIndex];\n                \n                // Highlight the hash function\n                const hashFunc = document.querySelector('.hash-function');\n                hashFunc.classList.add('highlight');\n                \n                setTimeout(() => {\n                    hashFunc.classList.remove('highlight');\n                    \n                    // Show the bucket it would go to\n                    const bucketIndex = hash(item.key);\n                    const bucket = document.getElementById(`bucket-${bucketIndex}`);\n                    bucket.parentElement.classList.add('highlight');\n                    \n                    setTimeout(() => {\n                        bucket.parentElement.classList.remove('highlight');\n                    }, 1500);\n                }, 1000);\n            });\n        });\n    </script>\n</body>\n</html>"
