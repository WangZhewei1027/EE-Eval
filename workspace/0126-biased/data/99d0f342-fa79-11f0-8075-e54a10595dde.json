    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Static Typing Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        input, button, select {\n            margin: 5px 0;\n            padding: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Static Typing Demonstration</h1>\n    \n    <h2>Variable Declaration</h2>\n    <input type=\"text\" id=\"varName\" placeholder=\"Enter variable name\">\n    <select id=\"varType\">\n        <option value=\"number\">Number</option>\n        <option value=\"string\">String</option>\n        <option value=\"boolean\">Boolean</option>\n    </select>\n    <input type=\"text\" id=\"varValue\" placeholder=\"Enter variable value\">\n    <button id=\"declareVar\">Declare Variable</button>\n\n    <h2>Current Variables</h2>\n    <div id=\"variablesList\"></div>\n\n    <h2>Variable Type Check</h2>\n    <input type=\"text\" id=\"checkVarName\" placeholder=\"Enter variable name to check type\">\n    <button id=\"checkType\">Check Type</button>\n    <div id=\"typeResult\"></div>\n\n    <h2>Type Conversion</h2>\n    <input type=\"text\" id=\"convertValue\" placeholder=\"Enter value to convert\">\n    <select id=\"convertToType\">\n        <option value=\"number\">Number</option>\n        <option value=\"string\">String</option>\n        <option value=\"boolean\">Boolean</option>\n    </select>\n    <button id=\"convertValueBtn\">Convert Value</button>\n    <div id=\"conversionResult\"></div>\n\n    <h2>Error Handling</h2>\n    <input type=\"text\" id=\"errorVarName\" placeholder=\"Enter variable name for error\">\n    <button id=\"simulateError\">Simulate Error</button>\n    <div id=\"errorResult\"></div>\n\n    <script>\n        const variables = {};\n\n        document.getElementById('declareVar').addEventListener('click', () => {\n            const name = document.getElementById('varName').value;\n            const type = document.getElementById('varType').value;\n            const value = document.getElementById('varValue').value;\n\n            try {\n                if (type === 'number') {\n                    variables[name] = parseFloat(value);\n                } else if (type === 'boolean') {\n                    variables[name] = (value.toLowerCase() === 'true');\n                } else {\n                    variables[name] = value;\n                }\n                updateVariablesList();\n                alert(`Variable ${name} of type ${type} declared successfully.`);\n            } catch (error) {\n                alert('Error declaring variable: ' + error.message);\n            }\n        });\n\n        function updateVariablesList() {\n            const list = document.getElementById('variablesList');\n            list.innerHTML = '';\n            for (const [name, value] of Object.entries(variables)) {\n                list.innerHTML += `<div>${name}: ${value} (${typeof value})</div>`;\n            }\n        }\n\n        document.getElementById('checkType').addEventListener('click', () => {\n            const name = document.getElementById('checkVarName').value;\n            const type = typeof variables[name];\n            document.getElementById('typeResult').innerText = type ? \n                `Type of ${name} is ${type}` : \n                `Variable ${name} not found.`;\n        });\n\n        document.getElementById('convertValueBtn').addEventListener('click', () => {\n            const value = document.getElementById('convertValue').value;\n            const toType = document.getElementById('convertToType').value;\n            let result;\n\n            try {\n                if (toType === 'number') {\n                    result = parseFloat(value);\n                } else if (toType === 'boolean') {\n                    result = (value.toLowerCase() === 'true');\n                } else {\n                    result = value.toString();\n                }\n                document.getElementById('conversionResult').innerText = `Converted value: ${result}`;\n            } catch (error) {\n                document.getElementById('conversionResult').innerText = 'Error converting value: ' + error.message;\n            }\n        });\n\n        document.getElementById('simulateError').addEventListener('click', () => {\n            const name = document.getElementById('errorVarName').value;\n            try {\n                if (!variables[name]) {\n                    throw new Error(`Variable ${name} does not exist.`);\n                }\n                document.getElementById('errorResult').innerText = `Variable ${name} exists with value: ${variables[name]}`;\n            } catch (error) {\n                document.getElementById('errorResult').innerText = 'Error: ' + error.message;\n            }\n        });\n    </script>\n</body>\n</html>"
