    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Space Complexity — Visual Exploration</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #081225;\n    --accent: #7de4d9;\n    --accent-2: #8a7dff;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --card: rgba(255,255,255,0.03);\n    --glass-border: rgba(255,255,255,0.06);\n    --shadow: rgba(2,6,23,0.6);\n    --glass-highlight: rgba(255,255,255,0.02);\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, \"Segoe UI\", Roboto, -apple-system, system-ui, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(122,85,255,0.12), transparent 6%),\n                radial-gradient(800px 500px at 90% 80%, rgba(125,228,217,0.07), transparent 6%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2) 60%);\n    color:#fff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Subtle animated noise layer */\n  .noise {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    background:\n      radial-gradient(circle at 10% 20%, rgba(255,255,255,0.02), transparent 15%),\n      radial-gradient(circle at 90% 80%, rgba(255,255,255,0.01), transparent 12%);\n    mix-blend-mode:overlay;\n    opacity:0.9;\n    animation: drift 15s linear infinite;\n  }\n  @keyframes drift{\n    0%{transform:translateY(0) translateX(0)}\n    50%{transform:translateY(-8px) translateX(6px)}\n    100%{transform:translateY(0) translateX(0)}\n  }\n\n  .wrap{\n    display:grid;\n    grid-template-columns: 460px 1fr;\n    gap:36px;\n    max-width:1200px;\n    margin:48px auto;\n    padding:36px;\n    align-items:start;\n  }\n\n  .left {\n    position:relative;\n  }\n\n  .panel {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 10px 40px var(--shadow), inset 0 1px 0 var(--glass-highlight);\n    border-radius:16px;\n    padding:28px;\n    backdrop-filter: blur(6px) saturate(120%);\n    overflow:hidden;\n  }\n\n  .title {\n    display:flex;\n    gap:16px;\n    align-items:center;\n  }\n  .badge{\n    width:68px;\n    height:68px;\n    flex:0 0 68px;\n    border-radius:14px;\n    display:grid;\n    place-items:center;\n    background:linear-gradient(135deg,var(--accent-2),var(--accent));\n    box-shadow: 0 6px 24px rgba(124,95,255,0.28), 0 1px 0 rgba(255,255,255,0.06) inset;\n    transform:translateZ(0);\n  }\n  .badge svg{filter:drop-shadow(0 4px 20px rgba(0,0,0,0.4))}\n\n  h1{\n    margin:0;\n    font-size:26px;\n    letter-spacing:-0.02em;\n    line-height:1.02;\n    font-weight:700;\n  }\n  p.lead{\n    margin:12px 0 18px 0;\n    color:var(--muted);\n    font-size:14.5px;\n    line-height:1.45;\n    max-width:360px;\n  }\n\n  .stat-row{\n    display:flex;\n    gap:12px;\n    margin-top:18px;\n    align-items:center;\n  }\n  .stat{\n    background:linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    padding:10px 12px;\n    border-radius:12px;\n    min-width:120px;\n    text-align:center;\n  }\n  .stat .num{\n    font-weight:700;\n    font-size:16px;\n    color:#fff;\n  }\n  .stat .label{\n    font-size:12px;\n    color:var(--muted);\n    margin-top:4px;\n  }\n\n  .explain{\n    margin-top:20px;\n    color:var(--muted);\n    font-size:13.6px;\n    line-height:1.6;\n  }\n\n  .notes{\n    display:flex;\n    gap:12px;\n    margin-top:18px;\n  }\n  .note{\n    flex:1;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.03);\n    padding:12px;\n    border-radius:10px;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* Right visualization pane */\n  .visual {\n    width:100%;\n    min-height:520px;\n    position:relative;\n    perspective:1000px;\n  }\n  .vis-card{\n    height:100%;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.008));\n    border-radius:18px;\n    border:1px solid rgba(255,255,255,0.035);\n    padding:28px;\n    box-shadow: 0 20px 60px rgba(3,7,20,0.6);\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n    overflow:hidden;\n    transform-style:preserve-3d;\n  }\n\n  .vis-header{\n    display:flex;\n    justify-content:space-between;\n    gap:20px;\n    align-items:center;\n  }\n  .vis-title{\n    display:flex;\n    flex-direction:column;\n  }\n  .vis-title h2{\n    margin:0;\n    font-size:18px;\n    letter-spacing:-0.02em;\n  }\n  .vis-title small{\n    color:var(--muted);\n    font-size:12.4px;\n    margin-top:6px;\n  }\n\n  .vis-canvas {\n    margin-top:18px;\n    height:380px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform-origin:center;\n    perspective:1000px;\n  }\n\n  /* Memory pane styling */\n  .memory {\n    width:84%;\n    max-width:760px;\n    height:300px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:14px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 10px 40px rgba(3,7,20,0.5), inset 0 2px 0 rgba(255,255,255,0.02);\n    position:relative;\n    padding:22px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform:translateZ(40px) rotateX(6deg);\n  }\n\n  .mem-grid{\n    width:100%;\n    height:100%;\n    display:grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-auto-rows: 1fr;\n    gap:8px;\n    align-items:center;\n    justify-items:center;\n    padding:12px;\n    box-sizing:border-box;\n  }\n\n  .block {\n    width:100%;\n    height:100%;\n    border-radius:8px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-size:12px;\n    color:var(--muted);\n    transform-origin:center;\n    transition: transform 600ms cubic-bezier(.2,.9,.25,1), opacity 300ms ease, box-shadow 350ms ease, background 400ms ease;\n    opacity:0.35;\n    box-shadow: 0 4px 18px rgba(3,7,20,0.45);\n    position:relative;\n    overflow:hidden;\n  }\n\n  .block::after{\n    content:'';\n    position:absolute;\n    inset:0;\n    border-radius:8px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n    pointer-events:none;\n  }\n\n  .block.active {\n    background: linear-gradient(180deg, rgba(125,228,217,0.12), rgba(138,125,255,0.12));\n    color:#fff;\n    opacity:1;\n    transform: translateY(-6px) scale(1.06);\n    box-shadow: 0 18px 36px rgba(55,35,110,0.45);\n    border:1px solid rgba(255,255,255,0.08);\n  }\n\n  .block.small{\n    font-size:11px;\n    color:rgba(255,255,255,0.85);\n  }\n\n  .legend {\n    display:flex;\n    gap:10px;\n    align-items:center;\n    margin-top:14px;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .legend .key{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n  }\n  .swatch{\n    width:12px;height:12px;border-radius:3px;background:linear-gradient(135deg,var(--accent-2),var(--accent));\n    box-shadow: 0 6px 14px rgba(120,95,255,0.18), inset 0 1px 0 rgba(255,255,255,0.06);\n  }\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:flex-end;\n    margin-top:18px;\n  }\n\n  .btn{\n    background:transparent;\n    color:var(--accent);\n    border:1px solid rgba(125,228,217,0.12);\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    cursor:pointer;\n    transition: all 220ms cubic-bezier(.2,.9,.25,1);\n    backdrop-filter: blur(4px);\n    box-shadow: 0 6px 22px rgba(10,20,40,0.35);\n  }\n  .btn:active{transform:translateY(1px) scale(0.998)}\n  .btn.ghost{\n    color:var(--muted);\n    border:1px dashed rgba(255,255,255,0.03);\n    box-shadow:none;\n  }\n\n  .pulse {\n    display:inline-block;\n    width:10px;height:10px;border-radius:99px;background:linear-gradient(90deg,#6df4e6,#8a7dff);\n    box-shadow:0 6px 18px rgba(138,125,255,0.16);\n    margin-right:8px;\n    transform-origin:center;\n    animation:blink 2.2s infinite;\n  }\n  @keyframes blink{\n    0%{transform:scale(1);opacity:1}\n    50%{transform:scale(1.5);opacity:0.6}\n    100%{transform:scale(1);opacity:1}\n  }\n\n  /* Footer/annotations */\n  .annotation{\n    margin-top:10px;\n    color:var(--muted);\n    font-size:13px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .wrap{grid-template-columns:1fr; padding:20px; gap:20px}\n    .vis-canvas{height:360px}\n    .memory{width:94%}\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"noise\" aria-hidden=\"true\"></div>\n\n  <main class=\"wrap\" role=\"main\" aria-labelledby=\"main-title\">\n    <section class=\"left\">\n      <div class=\"panel\" aria-labelledby=\"main-title\">\n        <div class=\"title\">\n          <div class=\"badge\" aria-hidden=\"true\">\n            <svg width=\"38\" height=\"38\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <rect x=\"2\" y=\"3\" width=\"20\" height=\"18\" rx=\"4\" fill=\"white\" fill-opacity=\"0.06\"/>\n              <path d=\"M7 9.5H17\" stroke=\"white\" stroke-opacity=\"0.9\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n              <path d=\"M7 13.5H13\" stroke=\"white\" stroke-opacity=\"0.9\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n            </svg>\n          </div>\n          <div>\n            <h1 id=\"main-title\">Space Complexity</h1>\n            <p class=\"lead\">A refined visual guide to understanding how algorithms consume memory — from constant space to polynomial growth. Observe elegant memory allocation patterns and their Big-O relationships.</p>\n          </div>\n        </div>\n\n        <div class=\"stat-row\" role=\"list\" aria-hidden=\"true\">\n          <div class=\"stat\">\n            <div class=\"num\">O(1)</div>\n            <div class=\"label\">Constant Space</div>\n          </div>\n          <div class=\"stat\">\n            <div class=\"num\">O(n)</div>\n            <div class=\"label\">Linear Space</div>\n          </div>\n          <div class=\"stat\">\n            <div class=\"num\">O(n²)</div>\n            <div class=\"label\">Quadratic Space</div>\n          </div>\n        </div>\n\n        <div class=\"explain\" id=\"explain\">\n          Space complexity measures the extra memory an algorithm requires relative to input size. It excludes the input itself and highlights working memory, auxiliary structures, and recursion stacks.\n          <div style=\"margin-top:12px;\"></div>\n          Watch the right panel to see memory blocks appear for different Big-O classes. The animation cycles through scenarios automatically — click \"Pause\" to freeze.\n        </div>\n\n        <div class=\"notes\">\n          <div class=\"note\"><strong>Insight:</strong> O(1) uses a fixed amount of memory regardless of n — think a few variables or pointers.</div>\n          <div class=\"note\"><strong>Practical:</strong> Be mindful of additional buffers, copies, and recursion depth; they often drive up space complexity.</div>\n        </div>\n\n        <div style=\"display:flex; justify-content:space-between; align-items:center; margin-top:18px;\">\n          <div class=\"annotation\"><span class=\"pulse\" aria-hidden=\"true\"></span><div>Auto-demo cycling: O(1) → O(n) → O(n²)</div></div>\n          <div style=\"color:var(--muted); font-size:12px;\">© Complexity Studio</div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"visual\" aria-label=\"Visualization\">\n      <div class=\"vis-card\" role=\"region\" aria-describedby=\"explain\">\n        <div class=\"vis-header\">\n          <div class=\"vis-title\">\n            <h2>Memory Allocation Playground</h2>\n            <small>Visualizing used memory blocks for different space complexities</small>\n          </div>\n          <div style=\"display:flex; align-items:center; gap:14px;\">\n            <div class=\"legend\" aria-hidden=\"true\">\n              <div class=\"key\"><div class=\"swatch\" aria-hidden=\"true\"></div><div>Allocated</div></div>\n              <div class=\"key\" style=\"opacity:0.5\"><div style=\"width:12px;height:12px;border-radius:3px;background:transparent;border:1px solid rgba(255,255,255,0.04)\"></div><div>Free</div></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"vis-canvas\" role=\"img\" aria-label=\"Animated memory blocks representing different space complexity classes\">\n          <div class=\"memory\" id=\"memory\" aria-hidden=\"false\">\n            <div class=\"mem-grid\" id=\"memGrid\" role=\"list\" aria-label=\"memory grid\">\n              <!-- blocks inserted by JS -->\n            </div>\n          </div>\n        </div>\n\n        <div style=\"display:flex; align-items:center; justify-content:space-between;\">\n          <div style=\"color:var(--muted); font-size:13px;\">\n            <strong id=\"scenarioLabel\">Scenario: O(1) — Constant</strong>\n          </div>\n\n          <div class=\"controls\">\n            <button class=\"btn ghost\" id=\"resetBtn\" title=\"Reset animation\" aria-label=\"Reset animation\">Reset</button>\n            <button class=\"btn\" id=\"toggleBtn\" aria-pressed=\"false\" title=\"Pause or play the automatic demonstration\">Pause</button>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n<script>\n/*\n  Space Complexity Visual Demo\n  - Single Play/Pause button for minimal interactivity\n  - Cycles through scenarios: O(1), O(n), O(n^2)\n  - Smooth transitions, subtle delays, and elegant easing\n*/\n\n(function(){\n  const SCENARIOS = [\n    { id: 'O(1)', label: 'O(1) — Constant', type:'constant' },\n    { id: 'O(n)', label: 'O(n) — Linear', type:'linear' },\n    { id: 'O(n²)', label: 'O(n²) — Quadratic', type:'quadratic' }\n  ];\n\n  const grid = document.getElementById('memGrid');\n  const memory = document.getElementById('memory');\n  const scenarioLabel = document.getElementById('scenarioLabel');\n  const toggleBtn = document.getElementById('toggleBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Responsive grid columns (12) and rows set by JS for flexibility\n  const COLS = 12;\n  const MAX_ROWS = 4; // for quadratic visual density (12x4 = 48 blocks)\n  const TOTAL_SLOTS = COLS * MAX_ROWS;\n\n  // Build grid slots\n  const slots = [];\n  for(let i=0;i<TOTAL_SLOTS;i++){\n    const b = document.createElement('div');\n    b.className = 'block';\n    b.dataset.index = i;\n    b.innerHTML = '<span class=\"small\">slot</span>';\n    grid.appendChild(b);\n    slots.push(b);\n  }\n\n  // Animation control\n  let running = true;\n  let scenarioIndex = 0;\n  let cycleTimer = null;\n  let stepTimer = null;\n  let currentStep = 0;\n\n  // Utility easing for visually pleasing delays\n  function easeOutCubic(t){ return (--t)*t*t+1; }\n\n  function clearAll(){\n    slots.forEach(s => {\n      s.classList.remove('active');\n      s.style.transitionDelay = '';\n      s.style.opacity = '';\n      s.style.transform = '';\n      s.innerHTML = '<span class=\"small\">slot</span>';\n    });\n  }\n\n  function activateIndexes(indexes, highlightText){\n    // subtle stagger based on index ordering\n    indexes.forEach((idx,i) => {\n      const el = slots[idx];\n      if(!el) return;\n      const d = Math.min(0.6, (easeOutCubic(i / indexes.length) * 0.45));\n      el.style.transitionDelay = `${d}s`;\n      el.classList.add('active');\n      el.innerHTML = `<div style=\"pointer-events:none;font-size:12px;font-weight:600;\">${highlightText}</div>`;\n    });\n  }\n\n  function scenarioConstant(){\n    scenarioLabel.textContent = 'Scenario: O(1) — Constant';\n    clearAll();\n    // pick a few fixed slots to highlight\n    const fixed = [5, 6]; // small constant memory usage\n    activateIndexes(fixed, 'var');\n  }\n\n  function scenarioLinear(){\n    scenarioLabel.textContent = 'Scenario: O(n) — Linear';\n    clearAll();\n    // We'll animate filling from left to right on first row\n    const rowStart = 0;\n    const rowLen = COLS;\n    const activeCount = Math.min(COLS, 12); // up to 12\n    const indexes = Array.from({length:activeCount}, (_,i)=> rowStart + i);\n    // stagger activation\n    stepTimer && clearTimeout(stepTimer);\n    let i = 0;\n    function step(){\n      if(!running) return;\n      if(i >= indexes.length) return;\n      slots[indexes[i]].classList.add('active');\n      slots[indexes[i]].innerHTML = `<div style=\"font-size:12px;font-weight:600;\">a[${i}]</div>`;\n      slots[indexes[i]].style.transitionDelay = '0s';\n      i++;\n      stepTimer = setTimeout(step, 210);\n    }\n    step();\n  }\n\n  function scenarioQuadratic(){\n    scenarioLabel.textContent = 'Scenario: O(n²) — Quadratic';\n    clearAll();\n    // fill a 6x4 block (or dynamic) to suggest quadratic growth\n    const rowsToFill = 4;\n    const colsToFill = 8; // produce 32 active blocks for demo\n    const indexes = [];\n    for(let r=0;r<rowsToFill;r++){\n      for(let c=0;c<colsToFill;c++){\n        const idx = r * COLS + c;\n        indexes.push(idx);\n      }\n    }\n    // apply staggered ripple from center\n    const center = [(rowsToFill*COLS)/2, (colsToFill)/2];\n    const lens = indexes.map((idx,i)=>{\n      const r = Math.floor(idx/COLS);\n      const c = idx % COLS;\n      const d = Math.hypot(r - (rowsToFill/2), c - (colsToFill/2));\n      return {idx, d};\n    }).sort((a,b)=>a.d-b.d).map(v=>v.idx);\n\n    activateIndexes(lens, 'buf');\n  }\n\n  // Soft crossfade transitions between scenarios\n  function showScenario(index){\n    clearTimeout(cycleTimer);\n    clearTimeout(stepTimer);\n    currentStep = 0;\n    const sc = SCENARIOS[index];\n    // gentle transform\n    memory.style.transform = 'translateZ(32px) rotateX(6deg) scale(0.995)';\n    setTimeout(()=> memory.style.transform = 'translateZ(40px) rotateX(6deg)';, 260);\n\n    // Decide scenario\n    if(sc.type === 'constant'){\n      scenarioConstant();\n    } else if(sc.type === 'linear'){\n      scenarioLinear();\n    } else if(sc.type === 'quadratic'){\n      scenarioQuadratic();\n    }\n\n    // schedule next transition\n    if(running){\n      cycleTimer = setTimeout(() => {\n        scenarioIndex = (scenarioIndex + 1) % SCENARIOS.length;\n        showScenario(scenarioIndex);\n      }, 4200); // each scenario shown for ~4.2s\n    }\n  }\n\n  // initial reveal animation\n  function intro(){\n    clearAll();\n    // tiny entrance: light up a few decorative slots\n    const introIdx = [10,11,12,13,14,15];\n    introIdx.forEach((i,k)=>{\n      const el = slots[i];\n      el.style.transition = 'transform 600ms cubic-bezier(.2,.9,.25,1), opacity 400ms ease';\n      el.style.transitionDelay = `${k*0.06}s`;\n      setTimeout(()=> {\n        el.classList.add('active');\n        el.innerHTML = `<div style=\"font-size:12px;font-weight:600;\">init</div>`;\n      }, 60 + k*60);\n    });\n    setTimeout(()=> {\n      introIdx.forEach(i=>{\n        const el = slots[i];\n        el.classList.remove('active');\n        el.innerHTML = '<span class=\"small\">slot</span>';\n      });\n      showScenario(scenarioIndex);\n    }, 900);\n  }\n\n  // Toggle Running\n  function setRunning(val){\n    running = val;\n    toggleBtn.textContent = running ? 'Pause' : 'Play';\n    toggleBtn.setAttribute('aria-pressed', String(!running));\n    if(running){\n      // resume\n      showScenario(scenarioIndex);\n    } else {\n      clearTimeout(cycleTimer);\n      clearTimeout(stepTimer);\n    }\n  }\n\n  // Reset\n  function reset(){\n    clearTimeout(cycleTimer);\n    clearTimeout(stepTimer);\n    scenarioIndex = 0;\n    clearAll();\n    showScenario(scenarioIndex);\n  }\n\n  // Hook up controls\n  toggleBtn.addEventListener('click', () => setRunning(!running));\n  resetBtn.addEventListener('click', () => {\n    reset();\n    toggleBtn.focus();\n  });\n\n  // Keyboard accessibility: Space toggles play/pause when focusing button\n  toggleBtn.addEventListener('keydown', (e)=>{\n    if(e.key === ' ' || e.key === 'Enter'){ e.preventDefault(); toggleBtn.click(); }\n  });\n\n  // Initialize\n  intro();\n\n  // Subtle floating transform for memory pane to maintain aesthetic motion\n  let t = 0;\n  function subtleMotion(){\n    t += 0.006;\n    const x = Math.sin(t)*4;\n    const y = Math.cos(t/1.4)*2;\n    memory.style.transform = `translateZ(40px) rotateX(6deg) translate(${x}px, ${y}px)`;\n    requestAnimationFrame(subtleMotion);\n  }\n  subtleMotion();\n\n})();\n</script>\n</body>\n</html>"
  },
