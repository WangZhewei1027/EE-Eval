    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Set Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; padding: 20px; }\n        input, button, select { margin: 5px; }\n        .output { margin-top: 15px; }\n    </style>\n</head>\n<body>\n    <h1>Interactive Set Demonstration</h1>\n    \n    <h2>Create a Set</h2>\n    <input type=\"text\" id=\"setInput\" placeholder=\"Enter a value\" />\n    <button onclick=\"addValue()\">Add Value</button>\n    <button onclick=\"clearSet()\">Clear Set</button>\n\n    <h2>Set Operations</h2>\n    <button onclick=\"performUnion()\">Union with Another Set</button>\n    <button onclick=\"performIntersection()\">Intersection with Another Set</button>\n    <button onclick=\"performDifference()\">Difference with Another Set</button>\n\n    <h2>Explore the Set</h2>\n    <button onclick=\"showValues()\">Show Values</button>\n    <button onclick=\"checkValue()\">Check Existence of Value</button>\n    <input type=\"text\" id=\"checkInput\" placeholder=\"Enter a value to check\" />\n\n    <h2>Manage Set</h2>\n    <input type=\"text\" id=\"removeInput\" placeholder=\"Remove a value\" />\n    <button onclick=\"removeValue()\">Remove Value</button>\n\n    <div class=\"output\">\n        <h3>Current Set:</h3>\n        <div id=\"outputSet\"></div>\n        <h3>Result:</h3>\n        <div id=\"outputResult\"></div>\n    </div>\n\n    <script>\n        let currentSet = new Set();\n\n        function addValue() {\n            const value = document.getElementById(\"setInput\").value;\n            if (value) {\n                currentSet.add(value);\n                document.getElementById(\"setInput\").value = '';\n                updateOutput();\n            }\n        }\n\n        function clearSet() {\n            currentSet.clear();\n            updateOutput();\n        }\n\n        function performUnion() {\n            const newSetInput = prompt(\"Enter values for the new set, separated by commas:\");\n            if (newSetInput) {\n                const newSet = new Set(newSetInput.split(',').map(v => v.trim()));\n                const unionSet = new Set([...currentSet, ...newSet]);\n                displayResult(unionSet);\n            }\n        }\n\n        function performIntersection() {\n            const newSetInput = prompt(\"Enter values for the new set, separated by commas:\");\n            if (newSetInput) {\n                const newSet = new Set(newSetInput.split(',').map(v => v.trim()));\n                const intersectionSet = new Set([...currentSet].filter(x => newSet.has(x)));\n                displayResult(intersectionSet);\n            }\n        }\n\n        function performDifference() {\n            const newSetInput = prompt(\"Enter values for the new set, separated by commas:\");\n            if (newSetInput) {\n                const newSet = new Set(newSetInput.split(',').map(v => v.trim()));\n                const differenceSet = new Set([...currentSet].filter(x => !newSet.has(x)));\n                displayResult(differenceSet);\n            }\n        }\n\n        function showValues() {\n            const values = Array.from(currentSet).join(', ');\n            document.getElementById(\"outputResult\").innerText = values || 'Set is empty';\n        }\n\n        function checkValue() {\n            const value = document.getElementById(\"checkInput\").value;\n            const exists = currentSet.has(value) ? \"exists\" : \"does not exist\";\n            document.getElementById(\"outputResult\").innerText = `The value \"${value}\" ${exists} in the set.`;\n        }\n\n        function removeValue() {\n            const value = document.getElementById(\"removeInput\").value;\n            if (currentSet.delete(value)) {\n                document.getElementById(\"removeInput\").value = '';\n                updateOutput();\n            } else {\n                document.getElementById(\"outputResult\").innerText = `Value \"${value}\" not found in the set.`;\n            }\n        }\n\n        function updateOutput() {\n            document.getElementById(\"outputSet\").innerText = Array.from(currentSet).join(', ') || 'Set is empty';\n            document.getElementById(\"outputResult\").innerText = '';\n        }\n\n        function displayResult(resultSet) {\n            document.getElementById(\"outputResult\").innerText = Array.from(resultSet).join(', ') || 'Result set is empty';\n        }\n    </script>\n</body>\n</html>"
