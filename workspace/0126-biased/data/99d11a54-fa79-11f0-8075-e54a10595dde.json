    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Support Vector Machine Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #dataDisplay {\n            margin: 20px 0;\n        }\n        #controls {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Support Vector Machine Interactive Demo</h1>\n\n<div id=\"controls\">\n    <label for=\"pointX\">Point X:</label>\n    <input type=\"number\" id=\"pointX\" value=\"0\" step=\"0.1\">\n    <label for=\"pointY\">Point Y:</label>\n    <input type=\"number\" id=\"pointY\" value=\"0\" step=\"0.1\">\n    <button id=\"addPoint\">Add Point</button>\n    <button id=\"trainSVM\">Train SVM</button>\n    <button id=\"clearPoints\">Clear Points</button>\n</div>\n\n<div id=\"dataDisplay\">\n    <h3>Points:</h3>\n    <ul id=\"pointsList\"></ul>\n</div>\n\n<div id=\"modelStatus\">\n    <h3>Model Status</h3>\n    <p id=\"modelOutput\">No model trained yet.</p>\n</div>\n\n<script>\n    const points = [];\n    const pointsList = document.getElementById('pointsList');\n    const modelOutput = document.getElementById('modelOutput');\n\n    document.getElementById('addPoint').addEventListener('click', function() {\n        const x = parseFloat(document.getElementById('pointX').value);\n        const y = parseFloat(document.getElementById('pointY').value);\n        points.push({x, y});\n        updatePointsList();\n    });\n\n    document.getElementById('trainSVM').addEventListener('click', function() {\n        if (points.length < 2) {\n            modelOutput.innerText = \"At least 2 points are required to train the SVM.\";\n            return;\n        }\n\n        // Simulate training by calculating boundary (just a toy example)\n        const boundary = calculateBoundary(points);\n        \n        modelOutput.innerText = `Model trained. Boundary: y = ${boundary.m}x + ${boundary.b}`;\n    });\n\n    document.getElementById('clearPoints').addEventListener('click', function() {\n        points.length = 0;\n        updatePointsList();\n        modelOutput.innerText = \"No model trained yet.\";\n    });\n\n    function updatePointsList() {\n        pointsList.innerHTML = \"\";\n        points.forEach(point => {\n            const li = document.createElement('li');\n            li.innerText = `(${point.x}, ${point.y})`;\n            pointsList.appendChild(li);\n        });\n    }\n\n    function calculateBoundary(points) {\n        // A mock function to simulate calculating an SVM boundary\n        const xAvg = points.reduce((sum, p) => sum + p.x, 0) / points.length;\n        const yAvg = points.reduce((sum, p) => sum + p.y, 0) / points.length;\n        const slope = (yAvg - xAvg) / (points.length > 1 ? points.length - 1 : 1);\n        const intercept = yAvg - slope * xAvg;\n        return {m: slope, b: intercept};\n    }\n</script>\n\n</body>\n</html>"
