    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Semaphore Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #2c3e50;\n            color: white;\n            overflow: hidden;\n            transition: background-color 0.5s ease;\n        }\n        h1 {\n            font-size: 3rem;\n            text-align: center;\n            margin-bottom: 40px;\n            animation: fadeIn 1s;\n        }\n        .semaphore {\n            position: relative;\n            width: 100px;\n            height: 300px;\n            margin: 0 auto;\n            border-radius: 10px;\n            border: 5px solid #ecf0f1;\n            background-color: #34495e;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);\n        }\n        .light {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            background-color: #e74c3c;\n            border-radius: 50%;\n            top: 20px;\n            left: 10px;\n            transition: background-color 0.5s ease;\n            animation: blink 1.5s infinite alternate;\n        }\n        .light.yellow {\n            background-color: #f1c40f;\n        }\n        .light.green {\n            background-color: #2ecc71;\n        }\n        @keyframes blink {\n            0% {\n                opacity: 1;\n            }\n            100% {\n                opacity: 0.3;\n            }\n        }\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n            }\n            to {\n                opacity: 1;\n            }\n        }\n        .controls {\n            position: absolute;\n            bottom: 50px;\n            display: flex;\n            justify-content: space-between;\n            width: 200px;\n        }\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #2980b9;\n            color: white;\n            font-size: 1.2rem;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n        .button:hover {\n            background-color: #3498db;\n        }\n    </style>\n</head>\n<body>\n    <h1>Pulsating Semaphore Visualization</h1>\n    <div class=\"semaphore\">\n        <div class=\"light\"></div>\n        <div class=\"light yellow\" style=\"top: 110px;\"></div>\n        <div class=\"light green\" style=\"top: 200px;\"></div>\n    </div>\n    <div class=\"controls\">\n        <button class=\"button\" onclick=\"changeLight('red')\">Red</button>\n        <button class=\"button\" onclick=\"changeLight('green')\">Green</button>\n    </div>\n    \n    <script>\n        const lights = document.querySelectorAll('.light');\n\n        function changeLight(color) {\n            lights.forEach(light => {\n                light.style.opacity = '0.2'; // dim all lights\n            });\n\n            if (color === 'red') {\n                lights[0].style.opacity = '1'; // make red light bright\n            } else if (color === 'green') {\n                lights[2].style.opacity = '1'; // make green light bright\n            }\n        }\n    </script>\n</body>\n</html>"
