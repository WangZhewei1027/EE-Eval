    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Floyd-Warshall Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        #floyd-warshall {\n            width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #floyd-warshall h1 {\n            margin-bottom: 10px;\n        }\n        #floyd-warshall button {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"floyd-warshall\">\n        <h1>Floyd-Warshall Algorithm</h1>\n        <button id=\"reset-btn\">Reset</button>\n        <button id=\"solve-btn\">Solve</button>\n        <button id=\"view-btn\">View</button>\n        <input id=\"n-btn\" type=\"number\" placeholder=\"Enter number of vertices\">\n        <input id=\"d-btn\" type=\"number\" placeholder=\"Enter maximum distance\">\n        <input id=\"epsilon-btn\" type=\"number\" placeholder=\"Enter epsilon value\">\n        <textarea id=\"f-w-btn\" rows=\"10\" cols=\"50\" placeholder=\"Enter Floyd-Warshall matrix values\"></textarea>\n        <textarea id=\"w-btn\" rows=\"10\" cols=\"50\" placeholder=\"Enter weight matrix values\"></textarea>\n        <textarea id=\"w2-btn\" rows=\"10\" cols=\"50\" placeholder=\"Enter weight matrix values\"></textarea>\n        <textarea id=\"w3-btn\" rows=\"10\" cols=\"50\" placeholder=\"Enter weight matrix values\"></textarea>\n        <textarea id=\"w4-btn\" rows=\"10\" cols=\"50\" placeholder=\"Enter weight matrix values\"></textarea>\n    </div>\n\n    <script>\n        let n = 0;\n        let d = 0;\n        let epsilon = 0;\n        let fW = [];\n        let w = [];\n        let w2 = [];\n        let w3 = [];\n        let w4 = [];\n\n        function initialize() {\n            n = parseInt(document.getElementById('n-btn').value);\n            d = parseInt(document.getElementById('d-btn').value);\n            epsilon = parseInt(document.getElementById('epsilon-btn').value);\n            fW = [];\n            w = [];\n            w2 = [];\n            w3 = [];\n            w4 = [];\n\n            for (let i = 0; i < n; i++) {\n                fW[i] = [];\n                w[i] = [];\n                w2[i] = [];\n                w3[i] = [];\n                w4[i] = [];\n            }\n\n            document.getElementById('f-w-btn').value = '';\n            document.getElementById('w-btn').value = '';\n            document.getElementById('w2-btn').value = '';\n            document.getElementById('w3-btn').value = '';\n            document.getElementById('w4-btn').value = '';\n        }\n\n        function displayMatrix(matrix) {\n            document.getElementById('f-w-btn').value = matrix.toString();\n        }\n\n        function displayWeightMatrix(matrix) {\n            document.getElementById('w-btn').value = matrix.toString();\n        }\n\n        function displayWeightMatrix2(matrix) {\n            document.getElementById('w2-btn').value = matrix.toString();\n        }\n\n        function displayWeightMatrix3(matrix) {\n            document.getElementById('w3-btn').value = matrix.toString();\n        }\n\n        function displayWeightMatrix4(matrix) {\n            document.getElementById('w4-btn').value = matrix.toString();\n        }\n\n        function updateMatrix(matrix, weight) {\n            fW[matrix[0][0]][matrix[0][1]] = weight;\n            fW[matrix[0][1]][matrix[0][0]] = weight;\n            fW[matrix[1][0]][matrix[1][1]] = weight;\n            fW[matrix[1][1]][matrix[1][0]] = weight;\n        }\n\n        function calculateDijkstra() {\n            let distance = new Array(n).fill(0).map(() => new Array(n).fill(0));\n            for (let i = 0; i < n; i++) {\n                distance[i][i] = 0;\n            }\n            for (let k = 0; k < n; k++) {\n                for (let i = 0; i < n; i++) {\n                    for (let j = 0; j < n; j++) {\n                        if (distance[i][k] + distance[k][j] < distance[i][j]) {\n                            distance[i][j] = distance[i][k] + distance[k][j];\n                        }\n                    }\n                }\n            }\n            return distance;\n        }\n\n        function updateMatrix2(matrix, weight) {\n            w[matrix[0][0]][matrix[0][1]] = weight;\n            w[matrix[0][1]][matrix[0][0]] = weight;\n            w[matrix[1][0]][matrix[1][1]] = weight;\n            w[matrix[1][1]][matrix[1][0]] = weight;\n        }\n\n        function calculateDijkstra2() {\n            let distance = new Array(n).fill(0).map(() => new Array(n).fill(0));\n            for (let i = 0; i < n; i++) {\n                distance[i][i] = 0;\n            }\n            for (let k = 0; k < n; k++) {\n                for (let i = 0; i < n; i++) {\n                    for (let j = 0; j < n; j++) {\n                        if (distance[i][k] + distance[k][j] < distance[i][j]) {\n                            distance[i][j] = distance[i][k] + distance[k][j];\n                        }\n                    }\n                }\n            }\n            return distance;\n        }\n\n        function updateMatrix3(matrix, weight) {\n            w2[matrix[0][0]][matrix[0][1]] = weight;\n            w2[matrix[0][1]][matrix[0][0]] = weight;\n            w2[matrix[1][0]][matrix[1][1]] = weight;\n            w2[matrix[1][1]][matrix[1][0]] = weight;\n        }\n\n        function calculateDijkstra3() {\n            let distance = new Array(n).fill(0).map(() => new Array(n).fill(0));\n            for (let i = 0; i < n; i++) {\n                distance[i][i] = 0;\n            }\n            for (let k = 0; k < n; k++) {\n                for (let i = 0; i < n; i++) {\n                    for (let j = 0; j < n; j++) {\n                        if (distance[i][k] + distance[k][j] < distance[i][j]) {\n                            distance[i][j] = distance[i][k] + distance[k][j];\n                        }\n                    }\n                }\n            }\n            return distance;\n        }\n\n        function updateMatrix4(matrix, weight) {\n            w3[matrix[0][0]][matrix[0][1]] = weight;\n            w3[matrix[0][1]][matrix[0][0]] = weight;\n            w3[matrix[1][0]][matrix[1][1]] = weight;\n            w3[matrix[1][1]][matrix[1][0]] = weight;\n        }\n\n        function calculateDijkstra4() {\n            let distance = new Array(n).fill(0).map(() => new Array(n).fill(0));\n            for (let i = 0; i < n; i++) {\n                distance[i][i] = 0;\n            }\n            for (let k = 0; k < n; k++) {\n                for (let i = 0; i < n; i++) {\n                    for (let j = 0; j < n; j++) {\n                        if (distance[i][k] + distance[k][j] < distance[i][j]) {\n                            distance[i][j] = distance[i][k] + distance[k][j];\n                        }\n                    }\n                }\n            }\n            return distance;\n        }\n\n        function solve() {\n            let distance = calculateDijkstra();\n            let matrix = new Array(n).fill(0).map(() => new Array(n).fill(0));\n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    matrix[i][j] = distance[i][j];\n                }\n            }\n            let result = [];\n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    result.push(matrix[i][j]);\n                }\n            }\n            displayMatrix(result);\n        }\n\n        function view() {\n            let matrix = new Array(n).fill(0).map(() => new Array(n).fill(0));\n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j