ion() {\n            displayWeightMatrix2(document.getElementById('w2-btn').value);\n        });\n        document.getElementById('w3-btn').addEventListener('change', function() {\n            displayWeightMatrix3(document.getElementById('w3-btn').value);\n        });\n        document.getElementById('w4-btn').addEventListener('change', function() {\n            displayWeightMatrix4(document.getElementById('w4-btn').value);\n        });\n    </script>\n</body>\n</html>"
