    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort Visualization</title>\n    <style>\n        body {\n            background-color: #282c34;\n            color: #ffffff;\n            font-family: 'Arial', sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n            margin: 0;\n        }\n        #container {\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n            height: 60%;\n            width: 80%;\n            border: 2px solid #61dafb;\n            position: relative;\n        }\n        .bar {\n            width: 40px;\n            margin: 0 2px;\n            background-color: #61dafb;\n            transition: height 0.4s ease, background-color 0.4s ease;\n        }\n        button {\n            background-color: #61dafb;\n            color: #282c34;\n            border: none;\n            padding: 10px 20px;\n            font-size: 16px;\n            border-radius: 5px;\n            cursor: pointer;\n            margin-top: 20px;\n            transition: background-color 0.3s;\n        }\n        button:hover {\n            background-color: #21a1f1;\n        }\n        .highlight {\n            background-color: #ff6347 !important;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\"></div>\n    <button id=\"startSortBtn\">Start Bubble Sort</button>\n\n    <script>\n        const container = document.getElementById('container');\n        const startSortBtn = document.getElementById('startSortBtn');\n\n        let array = generateRandomArray(10);\n        renderArray(array);\n\n        async function bubbleSort(arr) {\n            const len = arr.length;\n            for (let i = 0; i < len; i++) {\n                for (let j = 0; j < len - 1 - i; j++) {\n                    highlightBars(j, j + 1);\n                    await new Promise(resolve => setTimeout(resolve, 400));\n                    if (arr[j] > arr[j + 1]) {\n                        [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];\n                    }\n                    renderArray(arr);\n                    await new Promise(resolve => setTimeout(resolve, 400));\n                    resetHighlightBars(j, j + 1);\n                }\n            }\n            resetHighlightBars(-1, -1); // Reset highlights at the end\n        }\n\n        function highlightBars(index1, index2) {\n            if (index1 >= 0) container.children[index1].classList.add('highlight');\n            if (index2 >= 0) container.children[index2].classList.add('highlight');\n        }\n\n        function resetHighlightBars(index1, index2) {\n            if (index1 >= 0) container.children[index1].classList.remove('highlight');\n            if (index2 >= 0) container.children[index2].classList.remove('highlight');\n        }\n\n        function renderArray(arr) {\n            container.innerHTML = '';\n            arr.forEach(value => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = `${value * 30}px`; // Height scaled for better visibility\n                container.appendChild(bar);\n            });\n        }\n\n        function generateRandomArray(size) {\n            const arr = [];\n            for (let i = 0; i < size; i++) {\n                arr.push(Math.floor(Math.random() * 10) + 1);\n            }\n            return arr;\n        }\n\n        startSortBtn.addEventListener('click', () => {\n            bubbleSort(array);\n        });\n    </script>\n</body>\n</html>"
