  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Support Vector Machine Explorer</title>\n<style>\n/* Extremely minimal styling: keep default look, only layout tweaks */\nhtml,body { height:100%; margin:0; padding:0; font-family: sans-serif; color: black; background: white; }\n.container { display: flex; height: 100vh; }\n.controls { width: 360px; overflow: auto; padding: 8px; box-sizing: border-box; border-right: 1px solid #00000010; }\n.canvasArea { flex: 1; display: flex; flex-direction: column; align-items: stretch; padding: 8px; box-sizing: border-box; }\ncanvas { border: 1px solid #00000020; background: white; width: 100%; height: 100%; }\nfieldset { margin-bottom: 10px; }\nlabel { display: inline-block; margin-right: 6px; }\n.small { font-size: 12px; }\n.log { height: 120px; overflow:auto; white-space:pre-wrap; border:1px solid #00000010; padding:4px; }\ninput[type=range] { width: 140px; vertical-align: middle; }\nselect, input[type=number], input[type=text] { width: 120px; }\nbutton { margin: 2px 2px 6px 0; }\n.pointsList { width: 100%; height: 100px; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <div class=\"controls\">\n    <h3>Support Vector Machine Explorer</h3>\n    <p class=\"small\">Plain interface to experiment with SVM concepts. Add points, choose algorithm and kernel, train and inspect margins, support vectors and decision boundaries.</p>\n\n    <fieldset>\n      <legend>Point Editing & Input</legend>\n      <div>\n        Class: \n        <label><input type=\"radio\" name=\"addClass\" value=\"1\" checked> +1</label>\n        <label><input type=\"radio\" name=\"addClass\" value=\"-1\"> -1</label>\n      </div>\n      <div>\n        Weight: <input id=\"pointWeight\" type=\"range\" min=\"0.1\" max=\"5\" step=\"0.1\" value=\"1\"> <span id=\"pwVal\">1.0</span>\n      </div>\n      <div>\n        Mode:\n        <label><input type=\"radio\" name=\"mode\" value=\"add\" checked> Add by click</label>\n        <label><input type=\"radio\" name=\"mode\" value=\"remove\"> Remove nearest</label>\n        <label><input type=\"radio\" name=\"mode\" value=\"move\"> Move (drag)</label>\n      </div>\n      <div>\n        <button id=\"clearPoints\">Clear Points</button>\n        <button id=\"clearModel\">Reset Model</button>\n      </div>\n      <div>\n        Points: <select id=\"pointsList\" class=\"pointsList\" multiple></select>\n      </div>\n      <div>\n        Edit selected: x <input id=\"editX\" type=\"number\" step=\"0.01\" style=\"width:70px\"> y <input id=\"editY\" type=\"number\" step=\"0.01\" style=\"width:70px\">\n        label <select id=\"editLabel\"><option value=\"1\">+1</option><option value=\"-1\">-1</option></select>\n        weight <input id=\"editWeight\" type=\"number\" step=\"0.1\" value=\"1\" style=\"width:60px\">\n        <button id=\"applyEdit\">Apply</button>\n        <button id=\"removeSelected\">Remove</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Dataset Generator</legend>\n      <div>\n        Type:\n        <select id=\"genType\">\n          <option value=\"gaussian\">Gaussian clusters</option>\n          <option value=\"twoMoons\">Two moons</option>\n          <option value=\"concentric\">Concentric circles</option>\n          <option value=\"random\">Random uniform</option>\n        </select>\n      </div>\n      <div>\n        n class +: <input id=\"nPos\" type=\"number\" value=\"40\" style=\"width:60px\"> \n        n class -: <input id=\"nNeg\" type=\"number\" value=\"40\" style=\"width:60px\">\n      </div>\n      <div>\n        Separation: <input id=\"separation\" type=\"range\" min=\"0\" max=\"3\" step=\"0.1\" value=\"1.0\"> <span id=\"sepVal\">1.0</span>\n      </div>\n      <div>\n        Noise: <input id=\"noise\" type=\"range\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0.1\"> <span id=\"noiseVal\">0.10</span>\n      </div>\n      <div>\n        <button id=\"generate\">Generate</button>\n        <button id=\"perturb\">Add noise to points</button>\n        <button id=\"shuffle\">Shuffle labels</button>\n        <button id=\"standardize\">Standardize features</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Algorithm & Kernel</legend>\n      <div>\n        Algorithm:\n        <select id=\"algoSelect\">\n          <option value=\"primal\">Primal (SGD / PEGASOS)</option>\n          <option value=\"kernel\">Kernelized (Kernel Ridge approx)</option>\n        </select>\n      </div>\n      <div>\n        Kernel:\n        <select id=\"kernelSelect\">\n          <option value=\"linear\">linear</option>\n          <option value=\"poly\">polynomial</option>\n          <option value=\"rbf\">rbf (Gaussian)</option>\n        </select>\n      </div>\n      <div>\n        C (regularization): <input id=\"Cvalue\" type=\"number\" value=\"1\" step=\"0.1\" style=\"width:80px\">\n      </div>\n      <div id=\"kernelParams\">\n        degree: <input id=\"degree\" type=\"number\" value=\"3\" style=\"width:60px\">\n        gamma: <input id=\"gamma\" type=\"number\" value=\"1\" step=\"0.1\" style=\"width:80px\">\n        coef0: <input id=\"coef0\" type=\"number\" value=\"1\" step=\"0.1\" style=\"width:80px\">\n      </div>\n      <div>\n        Learning rate (SGD): <input id=\"lr\" type=\"number\" value=\"0.1\" step=\"0.01\" style=\"width:80px\">\n        Epochs: <input id=\"epochs\" type=\"number\" value=\"20\" style=\"width:60px\">\n        Batch size: <input id=\"batch\" type=\"number\" value=\"10\" style=\"width:60px\">\n      </div>\n      <div>\n        <button id=\"trainStep\">Train step (1 epoch)</button>\n        <button id=\"trainMore\">Train more (n epochs)</button>\n        <input id=\"trainN\" type=\"number\" value=\"10\" style=\"width:60px\">\n        <button id=\"trainUntil\">Train until convergence</button>\n      </div>\n      <div>\n        <label><input id=\"liveToggle\" type=\"checkbox\"> Live training</label>\n        Interval ms: <input id=\"liveInterval\" type=\"number\" value=\"200\" style=\"width:80px\">\n      </div>\n      <div>\n        <button id=\"crossVal\">Grid Search CV</button>\n        fold: <input id=\"cvfolds\" type=\"number\" value=\"3\" style=\"width:50px\">\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Visualization</legend>\n      <div>\n        Resolution: <input id=\"resolution\" type=\"range\" min=\"20\" max=\"200\" value=\"80\"> <span id=\"resVal\">80</span>\n      </div>\n      <div>\n        <label><input id=\"showBoundary\" type=\"checkbox\" checked> show decision boundary</label><br>\n        <label><input id=\"showMargins\" type=\"checkbox\" checked> show margins (±1)</label><br>\n        <label><input id=\"showSV\" type=\"checkbox\" checked> highlight support vectors</label><br>\n        <label><input id=\"showValues\" type=\"checkbox\"> show decision values</label>\n      </div>\n      <div>\n        Draw domain bounds: x,y min/max:\n        <input id=\"xmin\" type=\"number\" value=\"-3\" style=\"width:60px\"> \n        <input id=\"xmax\" type=\"number\" value=\"3\" style=\"width:60px\">\n        <input id=\"ymin\" type=\"number\" value=\"-3\" style=\"width:60px\">\n        <input id=\"ymax\" type=\"number\" value=\"3\" style=\"width:60px\">\n        <button id=\"applyDomain\">Apply</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Model & Analysis</legend>\n      <div>\n        <button id=\"saveModel\">Save Model (JSON)</button>\n        <button id=\"loadModel\">Load Model (paste)</button>\n      </div>\n      <div>\n        <button id=\"evalTrain\">Evaluate Training</button>\n        <button id=\"showMarginWidth\">Compute margin width (linear)</button>\n      </div>\n      <div>\n        Support vectors threshold: <input id=\"svThresh\" type=\"number\" value=\"0.001\" step=\"0.0001\" style=\"width:80px\">\n      </div>\n      <div>\n        <button id=\"explain\">Explain decision</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Logs & Info</legend>\n      <div class=\"log\" id=\"log\"></div>\n    </fieldset>\n\n  </div>\n\n  <div class=\"canvasArea\">\n    <div style=\"flex:1; margin-bottom:8px;\">\n      <canvas id=\"plot\" width=\"800\" height=\"600\"></canvas>\n    </div>\n    <div style=\"display:flex; gap:8px;\">\n      <div>\n        <button id=\"downloadPNG\">Download PNG</button>\n      </div>\n      <div style=\"flex:1;\">\n        <div id=\"modelInfo\" class=\"small\"></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n// Minimal and functional SVM explorer with many interactive controls.\n// Everything in this single embedded script.\n\n(function(){\n  // Utilities\n  function log(...args){ const d=document.getElementById('log'); d.textContent = args.join(' ') + '\\n' + d.textContent;}\n  function randn() {\n    // Box-Muller\n    let u=0,v=0; while(u===0) u=Math.random(); while(v===0) v=Math.random();\n    return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);\n  }\n\n  // State\n  let points = []; // {x,y,label,weight,id}\n  let nextId = 1;\n  let model = { type: null, data: null }; // hold weights or alphas\n  let liveTrainingTimer = null;\n  let dragging = null;\n  let canvas = document.getElementById('plot');\n  let ctx = canvas.getContext('2d');\n\n  // Domain\n  let domain = {xmin:-3,xmax:3,ymin:-3,ymax:3};\n\n  // DOM references\n  const pw = document.getElementById('pointWeight');\n  const pwVal = document.getElementById('pwVal');\n  pw.addEventListener('input', ()=> pwVal.textContent = parseFloat(pw.value).toFixed(1));\n\n  // Map between canvas pixels and domain coords\n  function pixelToDomain(px, py){\n    const rect = canvas.getBoundingClientRect();\n    const cw = canvas.width, ch = canvas.height;\n    // use canvas coordinate system (0..width)\n    const x = domain.xmin + (px / cw) * (domain.xmax - domain.xmin);\n    const y = domain.ymax - (py / ch) * (domain.ymax - domain.ymin);\n    return {x,y};\n  }\n  function domainToPixel(x,y){\n    const cw = canvas.width, ch = canvas.height;\n    const px = ((x - domain.xmin) / (domain.xmax - domain.xmin)) * cw;\n    const py = ((domain.ymax - y) / (domain.ymax - domain.ymin)) * ch;\n    return {px,py};\n  }\n\n  // Redraw\n  function draw(){\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n    // draw grid of decision values if requested\n    const res = parseInt(document.getElementById('resolution').value,10);\n    const showBoundary = document.getElementById('showBoundary').checked;\n    const showMargins = document.getElementById('showMargins').checked;\n    const showValues = document.getElementById('showValues').checked;\n    // compute grid\n    const nx = res, ny = Math.floor(res * canvas.height / canvas.width);\n    let grid = null;\n    if(showBoundary || showMargins || showValues){\n      grid = [];\n      for(let i=0;i<nx;i++){\n        grid[i]=[];\n        for(let j=0;j<ny;j++){\n          const x = domain.xmin + (i + 0.5)/nx * (domain.xmax-domain.xmin);\n          const y = domain.ymax - (j + 0.5)/ny * (domain.ymax-domain.ymin);\n          const val = decisionValue({x,y});\n          grid[i][j]=val;\n        }\n      }\n      // draw simple contour: draw pixels as light gray according to value magnitude to help see decision surface\n      // We keep only black strokes so we draw faint filled rectangles with globalAlpha\n      ctx.save();\n      for(let i=0;i<nx;i++){\n        for(let j=0;j<ny;j++){\n          const v = grid[i][j];\n          if(v===null) continue;\n          const intensity = Math.tanh(Math.abs(v)) * 0.6; // 0..0.6\n          ctx.fillStyle = 'rgba(0,0,0,'+ (0.02*intensity) + ')';\n          const xpix = i * canvas.width / nx;\n          const ypix = j * canvas.height / ny;\n          ctx.fillRect(xpix, ypix, canvas.width/nx+1, canvas.height/ny+1);\n        }\n      }\n      ctx.restore();\n    }\n\n    // Draw contour lines: find zero-crossings and f=±1 lines\n    function drawContour(level, lineWidth){\n      const nx2 = nx, ny2 = ny;\n      ctx.beginPath();\n      for(let i=0;i<nx2-1;i++){\n        for(let j=0;j<ny2-1;j++){\n          const v00 = grid[i][j], v10 = grid[i+1][j], v01 = grid[i][j+1], v11 = grid[i+1][j+1];\n          if([v00,v10,v01,v11].some(v=>v===null)) continue;\n          // check if the level crosses any edge, approximate drawing small segments along edges\n          const corners = [\n            {x:i,y:j,v:v00},\n            {x:i+1,y:j,v:v10},\n            {x:i+1,y:j+1,v:v11},\n            {x:i,y:j+1,v:v01}\n          ];\n          // marching squares: draw segment if sign change around square\n          let mask = 0;\n          for(let k=0;k<4;k++) if(corners[k].v > level) mask |= (1<<k);\n          // simplistic: for edges where sign changes, compute linear interpolation and draw tiny segment between midpoints\n          const segs = [];\n          function interp(a,b){\n            const t = (level - a.v)/(b.v - a.v);\n            const x = a.x + t*(b.x-a.x);\n            const y = a.y + t*(b.y-a.y);\n            return {x,y};\n          }\n          // edges: 0-1,1-2,2-3,3-0\n          if((corners[0].v - level)*(corners[1].v - level) < 0) segs.push(interp(corners[0], corners[1]));\n          if((corners[1].v - level)*(corners[2].v - level) < 0) segs.push(interp(corners[1], corners[2]));\n          if((corners[2].v - level)*(corners[3].v - level) < 0) segs.push(interp(corners[2], corners[3]));\n          if((corners[3].v - level)*(corners[0].v - level) < 0) segs.push(interp(corners[3], corners[0]));\n          if(segs.length>=2){\n            const p1 = segs[0], p2 = segs[1];\n            const x1 = (p1.x / nx2) * canvas.width;\n            const y1 = (p1.y / ny2) * canvas.height;\n            const x2 = (p2.x / nx2) * canvas.width;\n            const y2 = (p2.y / ny2) * canvas.height;\n            ctx.moveTo(x1,y1);\n            ctx.lineTo(x2,y2);\n          }\n        }\n      }\n      ctx.lineWidth = lineWidth;\n      ctx.strokeStyle = '#000';\n      ctx.stroke();\n    }\n\n    if(grid && showBoundary){\n      ctx.save();\n      ctx.beginPath();\n      drawContour(0,1.2);\n      ctx.restore();\n    }\n    if(grid && showMargins){\n      ctx.save();\n      ctx.beginPath();\n      drawContour(1,0.7);\n      ctx.stroke();\n      ctx.beginPath();\n      drawContour(-1,0.7);\n      ctx.stroke();\n      ctx.restore();\n    }\n\n    // Draw points\n    const svThresh = parseFloat(document.getElementById('svThresh').value);\n    const showSV = document.getElementById('showSV').checked;\n    for(const p of points){\n      const pix = domainToPixel(p.x,p.y);\n      ctx.beginPath();\n      const r = 6 + Math.min(10, Math.abs(p.weight));\n      ctx.arc(pix.px, pix.py, r, 0, Math.PI*2);\n      ctx.fillStyle = p.label>0 ? '#000' : '#000';\n      ctx.fill();\n      // inner white mark to show label difference (we keep black-only; so add small circle)\n      ctx.beginPath();\n      ctx.arc(pix.px, pix.py, r*0.6, 0, Math.PI*2);\n      ctx.fillStyle = '#fff';\n      ctx.fill();\n      // draw label text lightly if requested\n      if(document.getElementById('showValues').checked){\n        const val = decisionValue(p);\n        ctx.fillStyle = '#000';\n        ctx.font = '12px monospace';\n        ctx.fillText((val===null?'-':val.toFixed(2)), pix.px + r + 2, pix.py + 4);\n      }\n      // highlight support vector\n      if(showSV){\n        if(isSupportVector(p, svThresh)){\n          ctx.beginPath();\n          ctx.arc(pix.px, pix.py, r+4, 0, Math.PI*2);\n          ctx.lineWidth = 1.2;\n          ctx.strokeStyle = '#000';\n          ctx.stroke();\n        }\n      }\n    }\n\n    // show model info text\n    updateModelInfo();\n  }\n\n  // Decision function\n  function decisionValue(pt){\n    if(points.length===0) return null;\n    if(model.type === 'primal' && model.data && model.data.w){\n      const w = model.data.w;\n      const b = model.data.b || 0;\n      return w[0]*pt.x + w[1]*pt.y + b;\n    } else if(model.type === 'kernel' && model.data && model.data.alpha){\n      const K = kernelFunctionOpts();\n      let sum = 0;\n      const alphas = model.data.alpha;\n      const Ys = model.data.Y;\n      for(let i=0;i<points.length;i++){\n        const k = K({x:points[i].x,y:points[i].y}, pt);\n        sum += alphas[i] * Ys[i] * k;\n      }\n      return sum;\n    } else {\n      return 0;\n    }\n  }\n\n  // Model helpers\n  function isSupportVector(p, thresh){\n    if(model.type === 'kernel' && model.data && model.data.alpha){\n      const idx = points.indexOf(p);\n      if(idx<0) return false;\n      return Math.abs(model.data.alpha[idx]) > thresh;\n    } else if(model.type === 'primal' && model.data && model.data.w){\n      // For primal, use hinge slack to find near-boundary points\n      const val = decisionValue(p);\n      if(val===null) return false;\n      const slack = Math.max(0, 1 - p.label*val);\n      return slack > 1e-3; // those within margin or misclassified\n    }\n    return false;\n  }\n\n  // Kernel functions\n  function kernelFunctionOpts(){\n    const ktype = document.getElementById('kernelSelect').value;\n    const gamma = parseFloat(document.getElementById('gamma').value);\n    const degree = parseInt(document.getElementById('degree').value,10);\n    const coef0 = parseFloat(document.getElementById('coef0').value);\n    if(ktype === 'linear') return (a,b)=> (a.x*b.x + a.y*b.y);\n    if(ktype === 'poly') return (a,b)=> Math.pow(gamma*(a.x*b.x + a.y*b.y) + coef0, degree);\n    if(ktype === 'rbf') return (a,b)=> Math.exp(-gamma*((a.x-b.x)*(a.x-b.x) + (a.y-b.y)*(a.y-b.y)));\n    return (a,b)=> (a.x*b.x + a.y*b.y);\n  }\n\n  // Training algorithms\n  // Primal SVM via PEGASOS-like SGD (hinge loss)\n  function trainPrimalEpoch(){\n    if(points.length===0) { log('No points to train.'); return; }\n    const lr = parseFloat(document.getElementById('lr').value);\n    const batch = Math.min(parseInt(document.getElementById('batch').value,10), points.length);\n    const C = parseFloat(document.getElementById('Cvalue').value);\n    // initialize\n    if(!model || model.type !== 'primal' || !model.data || !model.data.w){\n      model.type = 'primal';\n      model.data = { w: [0,0], b:0 };\n    }\n    const w = model.data.w;\n    let b = model.data.b;\n\n    // shuffle\n    const idxs = [...Array(points.length).keys()];\n    for(let i=idxs.length-1;i>0;i--){\n      const j = Math.floor(Math.random()*(i+1));\n      [idxs[i], idxs[j]] = [idxs[j], idxs[i]];\n    }\n    // do one epoch (go through all in mini-batches)\n    for(let start=0; start<idxs.length; start += batch){\n      const batchIdx = idxs.slice(start, start+batch);\n      // gradient of regularizer\n      let gw = [w[0], w[1]];\n      gw[0] *= 1; gw[1] *= 1;\n      let gb = 0;\n      // hinge loss gradients\n      for(const ii of batchIdx){\n        const p = points[ii];\n        const y = p.label * p.weight;\n        const f = w[0]*p.x + w[1]*p.y + b;\n        if(y * f < 1){\n          gw[0] -= C * y * p.x;\n          gw[1] -= C * y * p.y;\n          gb -= C * y;\n        }\n      }\n      // update\n      w[0] -= lr * gw[0];\n      w[1] -= lr * gw[1];\n      b -= lr * gb;\n    }\n    model.data.b = b;\n  }\n\n  // Kernelized using kernel ridge approximation:\n  // alpha = (K + lambda I)^{-1} y, where lambda = 1/C\n  function trainKernelRidge(){\n    if(points.length===0) { log('No points to train.'); return; }\n    const C = parseFloat(document.getElementById('Cvalue').value);\n    const lambda = 1 / Math.max(1e-12, C);\n    const n = points.length;\n    const Kfun = kernelFunctionOpts();\n    // build K\n    const K = new Array(n);\n    for(let i=0;i<n;i++){\n      K[i] = new Array(n);\n      for(let j=0;j<n;j++){\n        K[i][j] = Kfun(points[i], points[j]) * 1.0;\n      }\n    }\n    // add lambda to diagonal\n    for(let i=0;i<n;i++) K[i][i] += lambda;\n    // build y vector\n    const y = points.map(p=>p.label * p.weight);\n    // solve linear system K * alpha = y\n    try{\n      const alpha = solveLinearSystem(K, y);\n      model.type = 'kernel';\n      model.data = { alpha: alpha, Y: points.map(p=>p.label) };\n    } catch(e){\n      log('Matrix solve failed: '+e);\n    }\n  }\n\n  // Linear algebra: solve Ax=b using Gaussian elimination with partial pivoting\n  function solveLinearSystem(Aorig, borig){\n    const n = Aorig.length;\n    // deep copy\n    const A = new Array(n);\n    for(let i=0;i<n;i++) A[i] = Aorig[i].slice();\n    const b = borig.slice();\n    for(let i=0;i<n;i++){\n      // pivot\n      let piv = i;\n      for(let r=i+1;r<n;r++){\n        if(Math.abs(A[r][i]) > Math.abs(A[piv][i])) piv = r;\n      }\n      if(Math.abs(A[piv][i]) < 1e-12) throw 'Singular matrix';\n      if(piv !== i){\n        [A[piv], A[i]] = [A[i], A[piv]];\n        [b[piv], b[i]] = [b[i], b[piv]];\n      }\n      // normalize row i\n      const diag = A[i][i];\n      for(let c=i;c<n;c++) A[i][c] /= diag;\n      b[i] /= diag;\n      // eliminate others\n      for(let r=0;r<n;r++){\n        if(r===i) continue;\n        const factor = A[r][i];\n        if(Math.abs(factor) < 1e-18) continue;\n        for(let c=i;c<n;c++) A[r][c] -= factor * A[i][c];\n        b[r] -= factor * b[i];\n      }\n    }\n    return b;\n  }\n\n  // Training orchestrator\n  function trainOneEpochBasedOnAlgo(){\n    const algo = document.getElementById('algoSelect').value;\n    if(algo === 'primal'){\n      trainPrimalEpoch();\n    } else if(algo === 'kernel'){\n      trainKernelRidge();\n    }\n    draw();\n  }\n\n  // Event bindings\n  document.getElementById('trainStep').addEventListener('click', ()=>{\n    trainOneEpochBasedOnAlgo();\n    log('Trained one epoch / solved kernel ridge.');\n  });\n  document.getElementById('trainMore').addEventListener('click', ()=>{\n    const n = parseInt(document.getElementById('trainN').value,10);\n    for(let i=0;i<n;i++) trainOneEpochBasedOnAlgo();\n    log('Trained ' + n + ' epochs / solved kernel ridge repeatedly.');\n  });\n  document.getElementById('trainUntil').addEventListener('click', ()=>{\n    // simple heuristic: iterate until change in weights small or max iter\n    const maxI = 200;\n    let prev = JSON.stringify(model);\n    for(let i=0;i<maxI;i++){\n      trainOneEpochBasedOnAlgo();\n      const cur = JSON.stringify(model);\n      if(cur === prev){\n        log('Converged after '+ (i+1) +' iterations.');\n        break;\n      }\n      prev = cur;\n    }\n    draw();\n  });\n\n  // live training toggle\n  document.getElementById('liveToggle').addEventListener('change', (e)=>{\n    if(e.target.checked){\n      const interval = Math.max(20, parseInt(document.getElementById('liveInterval').value,10));\n      liveTrainingTimer = setInterval(()=>{\n        trainOneEpochBasedOnAlgo();\n      }, interval);\n      log('Live training started.');\n    } else {\n      if(liveTrainingTimer) clearInterval(liveTrainingTimer);\n      liveTrainingTimer = null;\n      log('Live training stopped.');\n    }\n  });\n\n  // Cross-validation (grid search)\n  document.getElementById('crossVal').addEventListener('click', async ()=>{\n    if(points.length < 2){ log('Not enough points for CV'); return; }\n    const folds = Math.max(2, parseInt(document.getElementById('cvfolds').value,10));\n    const Cs = [0.01,0.1,1,10,100];\n    const gammas = [0.1,0.5,1,2,5];\n    const algo = document.getElementById('algoSelect').value;\n    const kernel = document.getElementById('kernelSelect').value;\n    log('Starting grid search CV: algo='+algo+' kernel='+kernel);\n    let best = {score:-Infinity, C:null, gamma:null, model:null};\n    for(const C of Cs){\n      for(const gamma of gammas){\n        document.getElementById('Cvalue').value = C;\n        document.getElementById('gamma').value = gamma;\n        // do simple K-fold CV\n        const idxs = [...Array(points.length).keys()];\n        // shuffle\n        for(let i=idxs.length-1;i>0;i--){\n          const j = Math.floor(Math.random()*(i+1));\n          [idxs[i], idxs[j]] = [idxs[j], idxs[i]];\n        }\n        const foldSize = Math.ceil(points.length / folds);\n        let scoreSum = 0;\n        for(let f=0; f<folds; f++){\n          const testIdx = idxs.slice(f*foldSize, (f+1)*foldSize);\n          const trainIdx = idxs.filter(i => !testIdx.includes(i));\n          // build train subset\n          const saved = points.slice();\n          const trainPts = trainIdx.map(i => ({...points[i]}));\n          // temporarily replace points with trainPts and train\n          const globalPts = points;\n          points = trainPts;\n          // train model (kernel ridge simple)\n          if(algo === 'kernel'){\n            trainKernelRidge();\n          } else {\n            // for primal, run a few epochs\n            for(let e=0;e<15;e++) trainPrimalEpoch();\n          }\n          // evaluate on test set\n          points = saved;\n          let correct = 0;\n          for(const i of testIdx){\n            const p = globalPts[i];\n            const val = decisionValue(p);\n            const pred = val>=0?1:-1;\n            if(pred === p.label) correct++;\n          }\n          scoreSum += (correct / Math.max(1,testIdx.length));\n        }\n        const avgScore = scoreSum / folds;\n        log('C='+C+' gamma='+gamma+' score='+avgScore.toFixed(3));\n        if(avgScore > best.score){\n          best = {score:avgScore, C, gamma};\n        }\n        await new Promise(r=>setTimeout(r,1));\n      }\n    }\n    if(best.C!==null){\n      document.getElementById('Cvalue').value = best.C;\n      document.getElementById('gamma').value = best.gamma;\n      log('Best found C='+best.C+' gamma='+best.gamma+' score='+best.score.toFixed(3));\n    } else {\n      log('Grid search failed.');\n    }\n  });\n\n  // Add and edit points\n  function refreshPointsList(){\n    const sel = document.getElementById('pointsList');\n    sel.innerHTML = '';\n    for(const p of points){\n      const opt = document.createElement('option');\n      opt.value = p.id;\n      opt.textContent = '['+p.id+'] ('+p.x.toFixed(2)+','+p.y.toFixed(2)+') l='+p.label+' w='+p.weight;\n      sel.appendChild(opt);\n    }\n  }\n  canvas.addEventListener('mousedown', (ev)=>{\n    const rect = canvas.getBoundingClientRect();\n    const px = ev.clientX - rect.left;\n    const py = ev.clientY - rect.top;\n    const pos = pixelToDomain(px,py);\n    const mode = document.querySelector('input[name=mode]:checked').value;\n    if(mode === 'add'){\n      const label = parseInt(document.querySelector('input[name=addClass]:checked').value,10);\n      const weight = parseFloat(document.getElementById('pointWeight').value);\n      points.push({x:pos.x, y:pos.y, label, weight, id: nextId++});\n      refreshPointsList();\n      draw();\n      log('Added point', points[points.length-1]);\n    } else if(mode === 'remove'){\n      if(points.length===0) return;\n      // find nearest\n      let minD = Infinity, minIdx = -1;\n      for(let i=0;i<points.length;i++){\n        const dx = points[i].x - pos.x;\n        const dy = points[i].y - pos.y;\n        const d = dx*dx + dy*dy;\n        if(d < minD){ minD = d; minIdx = i; }\n      }\n      if(minIdx>=0){\n        const removed = points.splice(minIdx,1)[0];\n        refreshPointsList();\n        draw();\n        log('Removed point', removed.id);\n      }\n    } else if(mode === 'move'){\n      // select nearest to drag\n      let minD = Infinity, minIdx = -1;\n      for(let i=0;i<points.length;i++){\n        const dx = points[i].x - pos.x;\n        const dy = points[i].y - pos.y;\n        const d = dx*dx + dy*dy;\n        if(d < minD){ minD = d; minIdx = i; }\n      }\n      if(minIdx>=0){\n        dragging = {idx:minIdx, offsetX: points[minIdx].x - pos.x, offsetY: points[minIdx].y - pos.y};\n      }\n    }\n  });\n  canvas.addEventListener('mousemove', (ev)=>{\n    if(!dragging) return;\n    const rect = canvas.getBoundingClientRect();\n    const px = ev.clientX - rect.left;\n    const py = ev.clientY - rect.top;\n    const pos = pixelToDomain(px,py);\n    const p = points[dragging.idx];\n    p.x = pos.x + dragging.offsetX;\n    p.y = pos.y + dragging.offsetY;\n    refreshPointsList();\n    draw();\n  });\n  canvas.addEventListener('mouseup', (ev)=>{\n    dragging = null;\n  });\n  canvas.addEventListener('mouseleave', ()=> dragging = null);\n\n  document.getElementById('clearPoints').addEventListener('click', ()=>{\n    points = [];\n    nextId = 1;\n    model = {type:null, data:null};\n    refreshPointsList();\n    draw();\n    log('Cleared points and model.');\n  });\n  document.getElementById('clearModel').addEventListener('click', ()=>{\n    model = {type:null, data:null};\n    draw();\n    log('Model reset.');\n  });\n\n  document.getElementById('pointsList').addEventListener('change', ()=>{\n    const sel = document.getElementById('pointsList');\n    if(sel.selectedOptions.length===0) return;\n    const id = parseInt(sel.selectedOptions[0].value,10);\n    const p = points.find(pp=>pp.id===id);\n    if(p){\n      document.getElementById('editX').value = p.x.toFixed(3);\n      document.getElementById('editY').value = p.y.toFixed(3);\n      document.getElementById('editLabel').value = p.label;\n      document.getElementById('editWeight').value = p.weight;\n    }\n  });\n\n  document.getElementById('applyEdit').addEventListener('click', ()=>{\n    const sel = document.getElementById('pointsList');\n    if(sel.selectedOptions.length===0) return;\n    for(const opt of sel.selectedOptions){\n      const id = parseInt(opt.value,10);\n      const p = points.find(pp=>pp.id===id);\n      if(p){\n        p.x = parseFloat(document.getElementById('editX').value);\n        p.y = parseFloat(document.getElementById('editY').value);\n        p.label = parseInt(document.getElementById('editLabel').value,10);\n        p.weight = parseFloat(document.getElementById('editWeight').value);\n      }\n    }\n    refreshPointsList();\n    draw();\n    log('Applied edits.');\n  });\n\n  document.getElementById('removeSelected').addEventListener('click', ()=>{\n    const sel = document.getElementById('pointsList');\n    const ids = Array.from(sel.selectedOptions).map(o=>parseInt(o.value,10));\n    points = points.filter(p=>!ids.includes(p.id));\n    refreshPointsList();\n    draw();\n    log('Removed selected points.');\n  });\n\n  // Generation functions\n  document.getElementById('generate').addEventListener('click', ()=>{\n    const type = document.getElementById('genType').value;\n    const npos = parseInt(document.getElementById('nPos').value,10);\n    const nneg = parseInt(document.getElementById('nNeg').value,10);\n    const sep = parseFloat(document.getElementById('separation').value);\n    const noise = parseFloat(document.getElementById('noise').value);\n    if(type === 'gaussian'){\n      points = [];\n      // center pos at (-sep,0), neg at (+sep,0)\n      for(let i=0;i<npos;i++){\n        const x = -sep + randn()*noise;\n        const y = randn()*noise;\n        points.push({x,y,label:1,weight:1,id: nextId++});\n      }\n      for(let i=0;i<nneg;i++){\n        const x = sep + randn()*noise;\n        const y = randn()*noise;\n        points.push({x,y,label:-1,weight:1,id: nextId++});\n      }\n    } else if(type === 'twoMoons'){\n      points = [];\n      for(let i=0;i<npos;i++){\n        const t = Math.PI * (Math.random()*0.8 + 0.1);\n        const x = Math.cos(t) + 0.03*randn();\n        const y = Math.sin(t) + 0.03*randn();\n        points.push({x: x - sep*0.5, y: y, label:1, weight:1, id: nextId++});\n      }\n      for(let i=0;i<nneg;i++){\n        const t = Math.PI * (Math.random()*0.8 + 0.1);\n        const x = 1 - Math.cos(t) + 0.03*randn();\n        const y = -Math.sin(t) - 0.03*randn();\n        points.push({x: x + sep*0.5, y: y, label:-1, weight:1, id: nextId++});\n      }\n    } else if(type === 'concentric'){\n      points = [];\n      for(let i=0;i<npos;i++){\n        const r = 0.2 + Math.random()*0.4;\n        const a = Math.random()*Math.PI*2;\n        const x = r*Math.cos(a) + randn()*noise;\n        const y = r*Math.sin(a) + randn()*noise;\n        points.push({x,y,label:1,weight:1,id: nextId++});\n      }\n      for(let i=0;i<nneg;i++){\n        const r = 0.8 + Math.random()*0.6;\n        const a = Math.random()*Math.PI*2;\n        const x = r*Math.cos(a) + randn()*noise;\n        const y = r*Math.sin(a) + randn()*noise;\n        points.push({x,y,label:-1,weight:1,id: nextId++});\n      }\n    } else {\n      points = [];\n      for(let i=0;i<npos;i++){\n        points.push({x: domain.xmin + Math.random()*(domain.xmax-domain.xmin), y: domain.ymin + Math.random()*(domain.ymax-domain.ymin), label:1,weight:1,id: nextId++});\n      }\n      for(let i=0;i<nneg;i++){\n        points.push({x: domain.xmin + Math.random()*(domain.xmax-domain.xmin), y: domain.ymin + Math.random()*(domain.ymax-domain.ymin), label:-1,weight:1,id: nextId++});\n      }\n    }\n    refreshPointsList();\n    draw();\n    log('Generated dataset: ' + type);\n  });\n\n  document.getElementById('perturb').addEventListener('click', ()=>{\n    const noise = parseFloat(document.getElementById('noise').value);\n    for(const p of points){\n      p.x += randn()*noise;\n      p.y += randn()*noise;\n    }\n    draw();\n    log('Perturbed points.');\n  });\n  document.getElementById('shuffle').addEventListener('click', ()=>{\n    for(const p of points) if(Math.random()<0.5) p.label *= -1;\n    draw();\n    log('Shuffled some labels.');\n  });\n  document.getElementById('standardize').addEventListener('click', ()=>{\n    if(points.length===0) return;\n    const meanX = points.reduce((s,p)=>s+p.x,0)/points.length;\n    const meanY = points.reduce((s,p)=>s+p.y,0)/points.length;\n    const stdX = Math.sqrt(points.reduce((s,p)=>s+(p.x-meanX)*(p.x-meanX),0)/points.length) || 1;\n    const stdY = Math.sqrt(points.reduce((s,p)=>s+(p.y-meanY)*(p.y-meanY),0)/points.length) || 1;\n    for(const p of points){\n      p.x = (p.x-meanX)/stdX;\n      p.y = (p.y-meanY)/stdY;\n    }\n    draw();\n    log('Standardized features.');\n  });\n\n  // Domain apply\n  document.getElementById('applyDomain').addEventListener('click', ()=>{\n    domain.xmin = parseFloat(document.getElementById('xmin').value);\n    domain.xmax = parseFloat(document.getElementById('xmax').value);\n    domain.ymin = parseFloat(document.getElementById('ymin').value);\n    domain.ymax = parseFloat(document.getElementById('ymax').value);\n    draw();\n    log('Applied domain bounds.');\n  });\n\n  // Show resolution update\n  document.getElementById('resolution').addEventListener('input', ()=>{\n    document.getElementById('resVal').textContent = document.getElementById('resolution').value;\n    draw();\n  });\n  document.getElementById('separation').addEventListener('input', ()=> document.getElementById('sepVal').textContent = parseFloat(document.getElementById('separation').value).toFixed(2));\n  document.getElementById('noise').addEventListener('input', ()=> document.getElementById('noiseVal').textContent = parseFloat(document.getElementById('noise').value).toFixed(2));\n  document.getElementById('resolution').dispatchEvent(new Event('input'));\n\n  // Save/load model\n  document.getElementById('saveModel').addEventListener('click', ()=>{\n    const out = { model, domain, points };\n    const txt = JSON.stringify(out, null, 2);\n    prompt('Copy model JSON:', txt);\n  });\n  document.getElementById('loadModel').addEventListener('click', ()=>{\n    const txt = prompt('Paste model JSON:');\n    if(!txt) return;\n    try{\n      const obj = JSON.parse(txt);\n      if(obj.points) points = obj.points;\n      if(obj.model) model = obj.model;\n      if(obj.domain) domain = obj.domain;\n      refreshPointsList();\n      draw();\n      log('Loaded model/points.');\n    }catch(e){\n      log('Failed to load JSON: '+e);\n    }\n  });\n\n  // Evaluate training\n  document.getElementById('evalTrain').addEventListener('click', ()=>{\n    if(points.length===0){ log('No data.'); return; }\n    let tp=0, tn=0, fp=0, fn=0;\n    for(const p of points){\n      const val = decisionValue(p);\n      const pred = (val>=0)?1:-1;\n      if(pred===1 && p.label===1) tp++;\n      if(pred===1 && p.label===-1) fp++;\n      if(pred===-1 && p.label===-1) tn++;\n      if(pred===-1 && p.label===1) fn++;\n    }\n    const acc = (tp+tn)/Math.max(1, points.length);\n    log('Evaluation: acc=' + acc.toFixed(3) + ' TP='+tp+' TN='+tn+' FP='+fp+' FN='+fn);\n  });\n\n  // Compute margin width (for linear model)\n  document.getElementById('showMarginWidth').addEventListener('click', ()=>{\n    if(model.type !== 'primal' || !model.data || !model.data.w) { log('Margin width: only available for primal linear model.'); return; }\n    const w = model.data.w;\n    const norm = Math.sqrt(w[0]*w[0] + w[1]*w[1]);\n    if(norm < 1e-12){ log('Weight vector nearly zero.'); return; }\n    const marginWidth = 2 / norm;\n    log('Margin width (approx): ' + marginWidth.toFixed(4));\n  });\n\n  // Explain decision at mouse click\n  document.getElementById('explain').addEventListener('click', ()=>{\n    alert('Click on canvas to explain decision at that point.\\n\\nExplanation will show weight contributions or kernel support contributions.');\n    const handler = function(ev){\n      const rect = canvas.getBoundingClientRect();\n      const px = ev.clientX - rect.left;\n      const py = ev.clientY - rect.top;\n      const pos = pixelToDomain(px,py);\n      if(model.type === 'primal' && model.data && model.data.w){\n        const w = model.data.w;\n        const b = model.data.b || 0;\n        const contribX = w[0]*pos.x;\n        const contribY = w[1]*pos.y;\n        const total = contribX + contribY + b;\n        alert('Decision value at ('+pos.x.toFixed(2)+','+pos.y.toFixed(2)+') = '+total.toFixed(4) + '\\nContributions:\\n w1*x = '+contribX.toFixed(4)+'\\n w2*y = '+contribY.toFixed(4)+'\\n bias = '+b.toFixed(4));\n      } else if(model.type === 'kernel' && model.data && model.data.alpha){\n        const K = kernelFunctionOpts();\n        let contributions = [];\n        for(let i=0;i<points.length;i++){\n          const k = K(points[i], pos);\n          const val = model.data.alpha[i] * model.data.Y[i] * k;\n          if(Math.abs(val) > 1e-6) contributions.push({id: points[i].id, val: val.toFixed(4)});\n        }\n        contributions.sort((a,b)=>Math.abs(b.val)-Math.abs(a.val));\n        alert('Kernel contributions (top few):\\n' + contributions.slice(0,10).map(c=>'#'+c.id+': '+c.val).join('\\n'));\n      } else {\n        alert('No model available to explain.');\n      }\n      canvas.removeEventListener('click', handler);\n    };\n    canvas.addEventListener('click', handler);\n  });\n\n  // Download PNG\n  document.getElementById('downloadPNG').addEventListener('click', ()=>{\n    const data = canvas.toDataURL('image/png');\n    const a = document.createElement('a');\n    a.href = data;\n    a.download = 'svm_plot.png';\n    a.click();\n  });\n\n  // Utility to update model info\n  function updateModelInfo(){\n    const el = document.getElementById('modelInfo');\n    if(model.type === 'primal' && model.data && model.data.w){\n      const w = model.data.w;\n      const b = model.data.b || 0;\n      el.textContent = 'Model: primal linear | w=['+w[0].toFixed(3)+','+w[1].toFixed(3)+'] b='+b.toFixed(3);\n    } else if(model.type === 'kernel' && model.data && model.data.alpha){\n      const nnz = model.data.alpha.filter(a=>Math.abs(a)>1e-6).length;\n      el.textContent = 'Model: kernel | nonzero alphas='+nnz+' total='+model.data.alpha.length;\n    } else {\n      el.textContent = 'Model: none';\n    }\n  }\n\n  // Initialize\n  refreshPointsList();\n  draw();\n\n  // Keep a timer to update UI occasionally (e.g., model changes)\n  setInterval(()=>{ draw(); }, 1000);\n\n  // Simple convenience: if kernel selection changes, re-train kernel if model is kernel\n  document.getElementById('kernelSelect').addEventListener('change', ()=>{\n    if(model.type === 'kernel') trainKernelRidge();\n    draw();\n  });\n  document.getElementById('algoSelect').addEventListener('change', ()=>{\n    draw();\n  });\n\n  // initial logging\n  log('SVM Explorer ready. Add points by selecting class and clicking on canvas. Use controls to train and analyze models.');\n\n})();\n</script>\n</body>\n</html>"
