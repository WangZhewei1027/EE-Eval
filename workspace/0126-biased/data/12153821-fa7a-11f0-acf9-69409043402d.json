  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Time Complexity Interactive Explorer</title>\n<style>\n  /* Extremely minimal styling: black text on white background, no colors or fancy fonts */\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  button, input, select, label {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin: 0.2em 0;\n    padding: 0.2em 0.4em;\n  }\n  label {\n    user-select: none;\n  }\n  .horizontal {\n    display: inline-block;\n    margin-right: 1em;\n  }\n  textarea {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    width: 100%;\n    height: 150px;\n  }\n  #output {\n    white-space: pre-wrap;\n    font-family: monospace, monospace;\n    font-size: 1em;\n    border: 1px solid black;\n    padding: 0.5em;\n    margin-top: 0.5em;\n    max-height: 300px;\n    overflow-y: auto;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n  .hidden {\n    display: none;\n  }\n</style>\n</head>\n<body>\n<h1>Time Complexity Interactive Explorer</h1>\n\n<p>This tool lets you build and explore algorithms, examine their time complexity with step-by-step analysis, run them with different input sizes, and compare asymptotic complexities interactively.</p>\n\n<!-- Control Panel -->\n<fieldset>\n<legend>1. Algorithm Construction and Source Code</legend>\n<label for=\"algoSelect\" class=\"horizontal\">Select or create algorithm: </label>\n<select id=\"algoSelect\" class=\"horizontal\" aria-label=\"Algorithm select\">\n  <option value=\"linearSearch\">Linear Search</option>\n  <option value=\"binarySearch\">Binary Search (Sorted Array)</option>\n  <option value=\"bubbleSort\">Bubble Sort</option>\n  <option value=\"insertionSort\">Insertion Sort</option>\n  <option value=\"custom\">Custom (edit code below)</option>\n</select>\n<button id=\"loadAlgoBtn\" class=\"horizontal\">Load Algorithm</button>\n</fieldset>\n\n<fieldset>\n<legend>2. Algorithm Source Code (JavaScript function to analyze)</legend>\n<textarea id=\"algoCode\" aria-label=\"Algorithm source code editor\"></textarea>\n<button id=\"runStepBtn\">Run Step-by-Step</button>\n<button id=\"runFullBtn\">Run Full Algorithm</button>\n<button id=\"resetRunBtn\">Reset</button>\n</fieldset>\n\n<fieldset>\n<legend>3. Input Controls</legend>\n<label for=\"inputSize\" class=\"horizontal\">Input size (n):</label>\n<input type=\"number\" id=\"inputSize\" min=\"1\" max=\"10000\" value=\"10\" step=\"1\" class=\"horizontal\" aria-label=\"Input size number\" />\n<br />\n<label for=\"inputArray\" style=\"vertical-align:top;\">Input array (comma separated numbers):</label><br />\n<textarea id=\"inputArray\" rows=\"3\" aria-label=\"Input array\"></textarea>\n</fieldset>\n\n<fieldset>\n<legend>4. Complexity Controls and Comparison</legend>\n<div>\n  <label for=\"asymptoticSelect\" class=\"horizontal\">Select asymptotic function:</label>\n  <select id=\"asymptoticSelect\" class=\"horizontal\" aria-label=\"Asymptotic function selector\">\n    <option value=\"O(1)\">O(1)</option>\n    <option value=\"O(log n)\">O(log n)</option>\n    <option value=\"O(n)\">O(n)</option>\n    <option value=\"O(n log n)\">O(n log n)</option>\n    <option value=\"O(n^2)\">O(n²)</option>\n    <option value=\"O(n^3)\">O(n³)</option>\n    <option value=\"O(2^n)\">O(2^n)</option>\n    <option value=\"O(n!)\">O(n!)</option>\n  </select>\n  <label for=\"compareN\" class=\"horizontal\" style=\"margin-left: 1em;\">Compare at n=</label>\n  <input type=\"number\" min=\"1\" max=\"10000\" step=\"1\" id=\"compareN\" value=\"10\" size=\"5\" class=\"horizontal\" aria-label=\"Comparison input size\"/>\n  <button id=\"compareBtn\" class=\"horizontal\">Compare</button>\n</div>\n<div id=\"compareOutput\" aria-live=\"polite\" style=\"margin-top:0.5em;\"></div>\n</fieldset>\n\n<fieldset>\n<legend>5. Step-by-step Execution and Analysis</legend>\n<div>\n  <button id=\"prevStepBtn\">Previous Step</button>\n  <button id=\"nextStepBtn\">Next Step</button>\n  <button id=\"autoRunBtn\">Auto Run</button>\n</div>\n<div id=\"stepOutput\" aria-live=\"polite\" style=\"white-space:pre-wrap; margin-top:0.5em; border:1px solid black; padding:0.5em; max-height: 250px; overflow-y: auto;\"></div>\n</fieldset>\n\n<fieldset>\n<legend>6. Internal Time Complexity Estimator / Analyzer (Static Analysis)</legend>\n<button id=\"analyzeBtn\">Analyze Code (Count Operations)</button>\n<div id=\"analyzeOutput\" style=\"white-space:pre-wrap; margin-top:0.5em; border:1px solid black; padding:0.5em; max-height: 300px; overflow-y: auto;\"></div>\n</fieldset>\n\n<script>\n(function(){\n  // Initial algorithms: Each defined as JS function source string, takes in input array and returns output\n  const algorithmSources = {\n    linearSearch:\n`function linearSearch(arr, target) {\n  for (let i = 0; i < arr.length; i++) {\n    if (arr[i] === target) return i;\n  }\n  return -1;\n}`,\n    binarySearch:\n`function binarySearch(arr, target) {\n  let left = 0, right = arr.length -1;\n  while (left <= right) {\n    let mid = Math.floor((left+right)/2);\n    if (arr[mid] === target) return mid;\n    else if (arr[mid] < target) left = mid + 1;\n    else right = mid - 1;\n  }\n  return -1;\n}`,\n    bubbleSort:\n`function bubbleSort(arr) {\n  let n = arr.length;\n  for (let i=0; i<n-1; i++) {\n    for (let j=0; j<n - i -1; j++) {\n      if (arr[j] > arr[j+1]) {\n        let temp= arr[j];\n        arr[j] = arr[j+1];\n        arr[j+1] = temp;\n      }\n    }\n  }\n  return arr;\n}`,\n    insertionSort:\n`function insertionSort(arr) {\n  for(let i=1; i<arr.length; i++) {\n    let key = arr[i];\n    let j = i-1;\n    while (j >=0 && arr[j] > key) {\n      arr[j+1] = arr[j];\n      j--;\n    }\n    arr[j+1] = key;\n  }\n  return arr;\n}`\n  };\n  \n  /**\n   * User workflow state objects and controls\n   */\n  const algoSelect = document.getElementById('algoSelect');\n  const loadAlgoBtn = document.getElementById('loadAlgoBtn');\n  const algoCode = document.getElementById('algoCode');\n  const inputSizeElem = document.getElementById('inputSize');\n  const inputArrayElem = document.getElementById('inputArray');\n  const runStepBtn = document.getElementById('runStepBtn');\n  const runFullBtn = document.getElementById('runFullBtn');\n  const resetRunBtn = document.getElementById('resetRunBtn');\n  const stepOutput = document.getElementById('stepOutput');\n  \n  const prevStepBtn = document.getElementById('prevStepBtn');\n  const nextStepBtn = document.getElementById('nextStepBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const autoRunIntervalMs = 700;\n  \n  const analyzeBtn = document.getElementById('analyzeBtn');\n  const analyzeOutput = document.getElementById('analyzeOutput');\n  \n  const asymptoticSelect = document.getElementById('asymptoticSelect');\n  const compareN = document.getElementById('compareN');\n  const compareBtn = document.getElementById('compareBtn');\n  const compareOutput = document.getElementById('compareOutput');\n  \n  let autoRunTimer = null;\n\n  // Current algorithm function (parsed dynamically)\n  let currentFunc = null;\n  // Parsed algorithm function source as string (may be edited)\n  let currentSourceCode = '';\n  // Current target for search algorithms or other input (default will be null)\n  let currentTarget = null;\n  \n  // Step execution state: array of step info (string)\n  let steps = [];\n  // Current step index\n  let currentStepIndex = -1;\n\n  // Proxy-based instrumentation for step tracing through function execution\n  // Approach: We will run the algorithm with instrumented data structures and Proxy wrappers  \n  // to collect detailed operation logs step by step.\n\n  /**\n   * Parse input array string into numeric array\n   * @param {string} input\n   */\n  function parseInputArray(input) {\n    const parts = input.split(',').map(s => s.trim()).filter(s=>s.length>0);\n    const arr = [];\n    for(let p of parts) {\n      let n = Number(p);\n      if (isNaN(n)) return null;\n      arr.push(n);\n    }\n    return arr;\n  }\n  \n  /**\n   * Generate random array of size n with values 0..99\n   * @param {number} n \n   */\n  function generateRandomArray(n) {\n    const arr = new Array(n);\n    for(let i=0; i<n; i++) arr[i] = Math.floor(Math.random()*100);\n    return arr;\n  }\n  \n  // Load algorithm source into textarea depending on selection\n  function loadAlgorithmSource(name) {\n    if (name === 'custom') {\n      algoCode.value = '// Enter your algorithm function here\\nfunction myAlgorithm(arr) {\\n  // Your code\\n  return arr;\\n}';\n      currentSourceCode = algoCode.value;\n      currentFunc = null;\n      currentTarget = null;\n      clearStepState();\n      outputMessage('Custom mode: edit code and press Run or Analyze.');\n      return;\n    }\n    if (algorithmSources[name]) {\n      algoCode.value = algorithmSources[name];\n      currentSourceCode = algorithmSources[name];\n      currentFunc = null;\n      currentTarget = null;\n      clearStepState();\n      outputMessage('Loaded \"'+name+'\" algorithm source.');\n    }\n  }\n  \n  // Output a message to stepOutput\n  function outputMessage(msg) {\n    stepOutput.textContent = msg;\n  }\n  \n  // Evaluate currentSourceCode into currentFunc\n  function evalCurrentFunction() {\n    try {\n      // Wrap code to isolate\n      // We expect the code defines a function named <funcName>, but as name unknown, detect the first function declaration name and return it.\n      // Simple heuristic:\n      const funcMatch = currentSourceCode.match(/function\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*\\(/);\n      if (!funcMatch) throw new Error('No function declaration found.');\n      const funcName = funcMatch[1];\n      // Evaluate the entire code and extract the declared function\n      const codeToRun = currentSourceCode + `\\nreturn ${funcName};`;\n      const f = new Function(codeToRun)();\n      if (typeof f !== 'function') throw new Error('Parsed code is not a function.');\n      currentFunc = f;\n      return f;\n    } catch(e) {\n      outputMessage('Error parsing algorithm function:\\n' + e.message);\n      currentFunc = null;\n      return null;\n    }\n  }\n  \n  // Autofill input array when input size changed or loaded\n  function autofillInputArrayFromSize() {\n    const n = parseInt(inputSizeElem.value, 10);\n    if (isNaN(n) || n < 1) return;\n    const arr = generateRandomArray(n);\n    inputArrayElem.value = arr.join(', ');\n  }\n  \n  // Clear step execution state\n  function clearStepState() {\n    steps = [];\n    currentStepIndex = -1;\n    stepOutput.textContent = '';\n    stopAutoRun();\n  }\n  \n  // ----------------- Instrumentation Helpers -----------------\n  // We'll implement a Proxy wrapper for the input array and also a stepLogger object\n  // The stepLogger will record significant operations\n  \n  /**\n   * Step Logger Object\n   * Records step-by-step events as strings for user to browse interactively.\n   */\n  class StepLogger {\n    constructor() {\n      this.logs = [];\n    }\n    log(str) {\n      this.logs.push(str);\n    }\n    clear() {\n      this.logs.length = 0;\n    }\n    get length() {\n      return this.logs.length;\n    }\n  }\n  \n  // We want to systematically instrument arrays accessed by the function to log reads/writes and iterations.\n  // We'll proxy the input array and add a counter of basic operations.\n  \n  /**\n   * Wrap an array with Proxy that logs reads and writes to StepLogger with operation count\n   * @param {Array} arr \n   * @param {StepLogger} logger \n   * @param {StateCounter} counter\n   */\n  function instrumentArray(arr, logger, counter) {\n    return new Proxy(arr, {\n      get(target, prop, receiver) {\n        if (typeof prop === 'string' && /^[0-9]+$/.test(prop)) {\n          const index = Number(prop);\n          const val = Reflect.get(target, prop, receiver);\n          logger.log(`[Access] arr[${index}] read = ${val}`);\n          counter.increment();\n          return val;\n        }\n        if (prop === 'length') {\n          const len = Reflect.get(target, prop, receiver);\n          logger.log(`[Access] arr.length read = ${len}`);\n          counter.increment();\n          return len;\n        }\n        // method calls (like push, sort) considered opaque, just proxy normally\n        return Reflect.get(target, prop, receiver);\n      },\n      set(target, prop, value, receiver) {\n        if (typeof prop === 'string' && /^[0-9]+$/.test(prop)) {\n          const index = Number(prop);\n          logger.log(`[Modify] arr[${index}] = ${value}`);\n          counter.increment();\n          return Reflect.set(target, prop, value, receiver);\n        }\n        if (prop === 'length') {\n          logger.log(`[Modify] arr.length = ${value}`);\n          counter.increment();\n          return Reflect.set(target, prop, value, receiver);\n        }\n        return Reflect.set(target, prop, value, receiver);\n      }\n    });\n  }\n  \n  /**\n   * Simple step counter object\n   */\n  class StateCounter {\n    constructor() {\n      this.count = 0;\n    }\n    increment() {\n      this.count++;\n    }\n    reset() {\n      this.count = 0;\n    }\n  }\n  \n  /**\n   * Run algorithm with instrumentation to generate step-by-step trace.\n   * We must handle that algorithms may have different signatures.\n   *\n   * Heuristic:\n   * - If algorithm name contains \"search\", second param is a target (from user input).\n   * - Otherwise just run with input array.\n   */\n  function runAlgorithmStepByStep(func, arr, target) {\n    const logger = new StepLogger();\n    const counter = new StateCounter();\n\n    // Wrap input array for instrumentation\n    let arrProxy = instrumentArray(arr.slice(), logger, counter); // clone array to prevent mutation outside\n    \n    // To capture line-by-line or statement-level tracing would require code instrumentation\n    // Since that's very complicated here, we log array access and modifications only\n    // and count \"steps\" as logged operations for user to browse.\n    \n    // Try running function and catch output\n    let result;\n    logger.clear();\n    counter.reset();\n\n    try {\n      // Detect function length to decide how to call\n      let callResult;\n      if (func.length === 2 && target !== null && target !== undefined) {\n        // likely search type function(arr, target)\n        logger.log('[Execution] Starting algorithm with target parameter.');\n        callResult = func(arrProxy, target);\n      } else {\n        logger.log('[Execution] Starting algorithm.');\n        callResult = func(arrProxy);\n      }\n      logger.log('[Execution] Algorithm finished.');\n      result = callResult;\n    } catch (e) {\n      logger.log(`[Error] Exception during execution: ${e.message}`);\n      result = null;\n    }\n    return {\n      logs: logger.logs,\n      output: result,\n      stepsCount: counter.count\n    };\n  }\n  \n  // ----------------- Step-by-step interactive control ----------------\n\n  /**\n   * Initialize step execution with algorithm + input + target\n   */\n  function initStepExecution() {\n    clearStepState();\n    if (!currentFunc) {\n      outputMessage('No valid algorithm function loaded or parsed.');\n      return;\n    }\n    // Parse input array text\n    const inputArr = parseInputArray(inputArrayElem.value);\n    if (!inputArr) {\n      outputMessage('Invalid input array. Please enter comma-separated numbers only.');\n      return;\n    }\n    let t = null;\n    // If search algorithm or has length === 2, attempt to prompt for target number via prompt box\n    if (currentFunc.length === 2) {\n      // Use last number in array as default target for example\n      t = prompt('Enter target value (number) for search algorithm:', '42');\n      if (t === null) {\n        outputMessage('Target value input canceled.');\n        return;\n      }\n      t = Number(t);\n      if (isNaN(t)) {\n        outputMessage('Invalid target number.');\n        return;\n      }\n    }\n    currentTarget = t;\n    // Run step-by-step instrumentation to get logs\n    const result = runAlgorithmStepByStep(currentFunc, inputArr, t);\n    steps = result.logs;\n    currentStepIndex = -1;\n    outputMessage('Algorithm prepared. Total recorded steps: ' + steps.length);\n  }\n  \n  /**\n   * Show current step value in the output\n   */\n  function showCurrentStep() {\n    if (steps.length === 0) {\n      stepOutput.textContent = 'No steps available.';\n      return;\n    }\n    if (currentStepIndex < 0) {\n      stepOutput.textContent = 'Start of steps. Press Next Step.';\n      return;\n    }\n    if (currentStepIndex >= steps.length) {\n      stepOutput.textContent = 'End of steps reached.';\n      return;\n    }\n    stepOutput.textContent = 'Step ' + (currentStepIndex + 1) + ' / ' + steps.length + ':\\n' + steps[currentStepIndex];\n  }\n  \n  /**\n   * Move to next step if possible\n   */\n  function nextStep() {\n    if (currentStepIndex + 1 < steps.length) {\n      currentStepIndex++;\n      showCurrentStep();\n    } else {\n      stepOutput.textContent = 'Already at last step.';\n    }\n  }\n  \n  /**\n   * Move to previous step if possible\n   */\n  function prevStep() {\n    if (currentStepIndex > 0) {\n      currentStepIndex--;\n      showCurrentStep();\n    } else if(currentStepIndex === 0) {\n      currentStepIndex--;\n      showCurrentStep();\n    } else {\n      stepOutput.textContent = 'Already at first step.';\n    }\n  }\n  \n  /**\n   * Auto-run through steps with set interval\n   */\n  function autoRunSteps() {\n    if (autoRunTimer !== null) {\n      stopAutoRun();\n      return;\n    }\n    if (steps.length === 0) {\n      stepOutput.textContent = 'No steps to auto-run. Run step-by-step first.';\n      return;\n    }\n    autoRunBtn.textContent = 'Stop Auto Run';\n    autoRunTimer = setInterval(() => {\n      if (currentStepIndex + 1 < steps.length) {\n        currentStepIndex++;\n        showCurrentStep();\n      } else {\n        stopAutoRun();\n        stepOutput.textContent += '\\nAuto run complete.';\n      }\n    }, autoRunIntervalMs);\n  }\n  \n  function stopAutoRun() {\n    if (autoRunTimer !== null) {\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n      autoRunBtn.textContent = 'Auto Run';\n    }\n  }\n  \n  // ------------------- Full algorithm run with output ----------------------\n  function runFullAlgorithm() {\n    clearStepState();\n    if (!currentFunc) {\n      outputMessage('No valid algorithm function loaded or parsed.');\n      return;\n    }\n    const inputArr = parseInputArray(inputArrayElem.value);\n    if (!inputArr) {\n      outputMessage('Invalid input array. Please enter comma-separated numbers only.');\n      return;\n    }\n    let t = null;\n    if (currentFunc.length === 2) {\n      t = prompt('Enter target value (number) for search algorithm:', '42');\n      if (t === null) {\n        outputMessage('Target value input canceled.');\n        return;\n      }\n      t = Number(t);\n      if (isNaN(t)) {\n        outputMessage('Invalid target number.');\n        return;\n      }\n    }\n    try {\n      let result;\n      if (t !== null) {\n        result = currentFunc(inputArr.slice(), t);\n      } else {\n        result = currentFunc(inputArr.slice());\n      }\n      stepOutput.textContent = 'Algorithm output:\\n' + JSON.stringify(result, null, 2);\n    } catch (e) {\n      stepOutput.textContent = 'Error during run:\\n' + e.message;\n    }\n  }\n  \n  // ---------------- Complexity Comparison ----------------\n  // For given n, evaluate asymptotic selected function and algorithm steps count (estimated)\n  // We'll produce comparative values for some standard functions at same n\n  \n  // Since we cannot automatically determine exact complexity from arbitrary code,\n  // We let user select an asymptotic function which we can evaluate at n,\n  // and we will compare the step count observed during sample run vs the selected asymptotic curve.\n  \n  function asymptoticValue(asymptoticName, n) {\n    n = Number(n);\n    if (isNaN(n) || n <= 0) return NaN;\n    switch (asymptoticName) {\n      case 'O(1)': return 1;\n      case 'O(log n)': return Math.log2(n);\n      case 'O(n)': return n;\n      case 'O(n log n)': return n * Math.log2(n);\n      case 'O(n^2)': return n*n;\n      case 'O(n^3)': return n*n*n;\n      case 'O(2^n)': return Math.pow(2,n);\n      case 'O(n!)': return factorialApprox(n);\n      default: return NaN;\n    }\n  }\n  \n  // Approximate factorial with Stirling's approximation for big n (rounded)\n  //  n! ~ sqrt(2*pi*n)*(n/e)^n\n  function factorialApprox(n) {\n    if (n > 170) return Infinity; // beyond JS safe max number\n    if (n === 0 || n === 1) return 1;\n    const pi = Math.PI;\n    return Math.round(Math.sqrt(2*pi*n)*Math.pow(n/Math.E,n));\n  }\n  \n  function compareComplexities() {\n    const nVal = Number(compareN.value);\n    if (isNaN(nVal) || nVal < 1) {\n      compareOutput.textContent = 'Invalid input size for comparison.';\n      return;\n    }\n    if (!currentFunc) {\n      compareOutput.textContent = 'No algorithm loaded.';\n      return;\n    }\n    // Run algorithm once with input size = nVal (limited to max 5000 to avoid freeze)\n    if (nVal > 5000) {\n      compareOutput.textContent = 'Input size too large for live run (>5000). Choose smaller n.';\n      return;\n    }\n    const testArr = generateRandomArray(nVal);\n    let t = null;\n    if (currentFunc.length === 2) {\n      // search type, select middle element as target arbitrarily\n      t = testArr[Math.floor(testArr.length/2)];\n    }\n    const runResult = runAlgorithmStepByStep(currentFunc, testArr, t);\n    const stepsCount = runResult.stepsCount;\n    const asymName = asymptoticSelect.value;\n    const asymVal = asymptoticValue(asymName, nVal);\n\n    if (!isFinite(asymVal) || isNaN(asymVal)) {\n      compareOutput.textContent = `Selected asymptotic function value at n=${nVal} is too large or undefined.`;\n      return;\n    }\n\n    // Show raw results and ratio\n    let ratio = stepsCount / asymVal;\n\n    let outputLines = [];\n    outputLines.push(`At input size n = ${nVal}:`);\n    outputLines.push(` - Algorithm estimated step count: ${stepsCount}`);\n    outputLines.push(` - Selected asymptotic function ${asymName} value: ${asymVal.toExponential(3)}`);\n    outputLines.push(` - Step count / asymptotic value ratio: ${ratio.toFixed(3)}`);\n    outputLines.push('');\n    outputLines.push('Note: Step count counts array accesses/modifications (proxy intercepted).');\n    outputLines.push('This rough comparison illustrates scaling, not exact runtime.');\n    \n    compareOutput.textContent = outputLines.join('\\n');\n  }\n  \n  // -------------- Simplistic Static Code \"Complexity\" Estimation --------------\n  // Rough counting of loops and nested loops to guess time complexity\n  \n  /*\n   Basic static analysis logic:\n   - Count for/while loops and their nesting depth\n   - Recognize loops over n (arr.length)\n   - Check for nested loops for quadratic, cubic etc.\n   - Count recursive calls by detecting function calls matching its own name.\n  */\n  function analyzeCodeComplexity() {\n    const code = algoCode.value;\n    analyzeOutput.textContent = 'Analyzing...';\n    // Simple lexical scan for loops and nesting\n    \n    // Tokenize code lines for simple detection\n    const lines = code.split('\\n').map(l=>l.trim());\n    let maxLoopDepth = 0;\n    let currentLoopDepth = 0;\n    let functionName = null;\n    let recursiveCalls = 0;\n    let hasWhile = false;\n    let hasFor = false;\n    \n    // Find function name\n    const fnMatch = code.match(/function\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*\\(/);\n    if (fnMatch) functionName = fnMatch[1];\n    \n    // Stack to track loops opening/closing by braces for depth count estimation\n    // We approximate because this is very rough parsing\n    \n    // For simplicity, count 'for' and 'while' keywords:\n    // Track nesting with counting open/close { }, resetting on those lines\n    \n    let braceStack = [];\n    \n    function countLoops(line) {\n      let loops = 0;\n      if (/\\bfor\\b/.test(line)) loops++;\n      if (/\\bwhile\\b/.test(line)) loops++;\n      return loops;\n    }\n    \n    // We'll track depth of loops by manual brace counting and keywords found\n    for (let line of lines) {\n      // Count opening and closing braces in line\n      let openCount = (line.match(/{/g) || []).length;\n      let closeCount = (line.match(/}/g) || []).length;\n      \n      // Adjust depth based on braces\n      for(let i=0; i<closeCount; i++) {\n        if (braceStack.length > 0) {\n          const top = braceStack.pop();\n          if (top === 'loop') currentLoopDepth--;\n        }\n      }\n      \n      // Check if line starts loop\n      const loopsInLine = countLoops(line);\n      if (loopsInLine > 0) {\n        currentLoopDepth += loopsInLine;\n        for(let i=0; i<loopsInLine; i++) braceStack.push('loop');\n        hasFor = hasFor || /\\bfor\\b/.test(line);\n        hasWhile = hasWhile || /\\bwhile\\b/.test(line);\n      }\n      \n      // Max depth update\n      if (currentLoopDepth > maxLoopDepth) maxLoopDepth = currentLoopDepth;\n      \n      // Count recursion by function calling itself\n      if (functionName && line.includes(functionName + '(')) {\n        // avoid counting call inside comment - simple heuristic\n        if (!line.startsWith('//') && !line.includes('function ' + functionName)) {\n          recursiveCalls++;\n        }\n      }\n    }\n\n    // Guess complexity from detected data\n    let guessedComplexity = 'O(1)';\n    if (recursiveCalls > 0) {\n      guessedComplexity = 'Recursive (unknown complexity)';\n    } else if (maxLoopDepth === 1) {\n      if (hasWhile) guessedComplexity = 'O(n) or O(log n) (depends on while condition)';\n      else guessedComplexity = 'O(n)';\n    } else if (maxLoopDepth === 2) {\n      guessedComplexity = 'O(n²)';\n    } else if (maxLoopDepth >= 3) {\n      guessedComplexity = 'O(n^' + maxLoopDepth + ')';\n    }\n\n    analyzeOutput.textContent = [\n      'Static Complexity Analysis:',\n      ` - Function name: ${functionName || 'unknown'}`,\n      ` - Maximum nest loop depth: ${maxLoopDepth}`,\n      ` - For loops detected: ${hasFor ? 'Yes' : 'No'}`,\n      ` - While loops detected: ${hasWhile ? 'Yes' : 'No'}`,\n      ` - Recursive calls detected: ${recursiveCalls}`,\n      '',\n      `Guessed Time Complexity: ${guessedComplexity}`,\n      '',\n      'Note: This is a very rough guess based on lexical analysis only.'\n    ].join('\\n');\n  }\n  \n  // -------------------- Event listeners ---------------------\n  \n  loadAlgoBtn.addEventListener('click', ()=>{\n    loadAlgorithmSource(algoSelect.value);\n  });\n  \n  inputSizeElem.addEventListener('change', () => {\n    let n = parseInt(inputSizeElem.value,10);\n    if (isNaN(n) || n < 1) {\n      inputSizeElem.value = 10;\n      n = 10;\n    }\n    autofillInputArrayFromSize();\n  });\n  \n  runStepBtn.addEventListener('click', () => {\n    currentSourceCode = algoCode.value;\n    evalCurrentFunction();\n    initStepExecution();\n    currentStepIndex = -1;\n    showCurrentStep();\n  });\n  runFullBtn.addEventListener('click', () => {\n    currentSourceCode = algoCode.value;\n    evalCurrentFunction();\n    runFullAlgorithm();\n  });\n  resetRunBtn.addEventListener('click', () => {\n    clearStepState();\n    stepOutput.textContent = 'Execution state reset.';\n  });\n  \n  prevStepBtn.addEventListener('click', () => {\n    prevStep();\n  });\n  \n  nextStepBtn.addEventListener('click', () => {\n    nextStep();\n  });\n  \n  autoRunBtn.addEventListener('click', () => {\n    autoRunSteps();\n  });\n  \n  analyzeBtn.addEventListener('click', () => {\n    analyzeCodeComplexity();\n  });\n  \n  compareBtn.addEventListener('click', () => {\n    compareComplexities();\n  });\n  \n  // Load default algorithm on start\n  loadAlgorithmSource(algoSelect.value);\n  autofillInputArrayFromSize();\n  \n})();\n</script>\n\n</body>\n</html>"
