    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Max Heap — Visualized</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#081022;\n    --glass: rgba(255,255,255,0.06);\n    --accent:#7C5CFF;\n    --accent-2:#00D4FF;\n    --muted: rgba(255,255,255,0.65);\n    --card-shadow: 0 10px 30px rgba(2,6,23,0.75);\n    --glass-2: rgba(255,255,255,0.03);\n    --success: #6EE7B7;\n    --danger: #FF7A7A;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    background:\n      radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.12), transparent 8%),\n      radial-gradient(900px 500px at 90% 90%, rgba(0,212,255,0.06), transparent 8%),\n      linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e8eef9;\n    padding:40px;\n    overflow:hidden;\n  }\n\n  /* Decorative floating shapes */\n  .orb {\n    position:absolute;\n    filter: blur(30px) saturate(120%);\n    opacity:0.25;\n    mix-blend-mode:screen;\n    pointer-events:none;\n  }\n  .orb.a{width:520px;height:520px;background:radial-gradient(circle at 30% 30%, #7C5CFF, transparent 30%);left:-140px;top:-100px}\n  .orb.b{width:420px;height:420px;background:radial-gradient(circle at 70% 70%, #00D4FF, transparent 30%);right:-120px;bottom:-140px}\n\n  .container{\n    max-width:1100px;\n    margin:40px auto;\n    position:relative;\n  }\n\n  .card{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    border-radius:20px;\n    padding:34px;\n    box-shadow:var(--card-shadow);\n    display:flex;\n    gap:30px;\n    align-items:stretch;\n    backdrop-filter: blur(8px) saturate(120%);\n    overflow:hidden;\n  }\n\n  .left {\n    width:360px;\n    display:flex;\n    flex-direction:column;\n    gap:22px;\n  }\n\n  h1{\n    font-family: \"Playfair Display\", serif;\n    font-weight:600;\n    font-size:26px;\n    margin:0;\n    letter-spacing:-0.6px;\n  }\n  .subtitle{\n    color:var(--muted);\n    font-size:13px;\n    margin-top:4px;\n  }\n\n  .array-panel{\n    margin-top:8px;\n    padding:18px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 6px 18px rgba(4,8,20,0.5) inset;\n  }\n\n  .array-row{\n    display:flex;\n    gap:12px;\n    justify-content:center;\n    padding:8px 6px;\n  }\n\n  .arr-box{\n    width:48px;\n    height:48px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border-radius:10px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    font-weight:600;\n    color:#dfe9ff;\n    box-shadow: 0 6px 16px rgba(2,6,23,0.5);\n    border: 1px solid rgba(255,255,255,0.04);\n    transition: transform 300ms cubic-bezier(.2,.9,.25,1), box-shadow 200ms;\n    user-select:none;\n  }\n\n  .arr-box .idx{\n    position:absolute;\n    font-size:10px;\n    top:6px;\n    right:6px;\n    color:rgba(255,255,255,0.32);\n    font-weight:500;\n  }\n\n  .arr-box.highlight{\n    transform: translateY(-6px) scale(1.05);\n    box-shadow: 0 18px 50px rgba(124,92,255,0.18), 0 6px 20px rgba(0,212,255,0.06);\n    border-color: rgba(124,92,255,0.9);\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:8px;\n    align-items:center;\n  }\n\n  .btn{\n    appearance:none;\n    border:0;\n    background: linear-gradient(90deg,var(--accent),var(--accent-2));\n    color:white;\n    padding:10px 16px;\n    border-radius:12px;\n    font-weight:600;\n    cursor:pointer;\n    box-shadow: 0 8px 30px rgba(124,92,255,0.18);\n    transition: transform 160ms ease, box-shadow 160ms;\n  }\n  .btn:active{transform:translateY(1px) scale(0.996)}\n  .btn.ghost{\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    box-shadow:none;\n  }\n\n  .meta{\n    color:var(--muted);\n    font-size:13px;\n    margin-top: 6px;\n  }\n\n  /* Right area: tree visual */\n  .right{\n    flex:1;\n    min-height:420px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .stage {\n    width:100%;\n    height:420px;\n    position:relative;\n    overflow:visible;\n  }\n\n  /* placeholder nodes positions (invisible) */\n  .placeholder{\n    position:absolute;\n    width:64px;\n    height:64px;\n    border-radius:50%;\n    left:0; top:0;\n    transform: translate(-50%,-50%);\n    pointer-events:none;\n    opacity:0;\n  }\n\n  .token {\n    position:absolute;\n    width:64px;\n    height:64px;\n    border-radius:50%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    color:white;\n    font-size:18px;\n    cursor:default;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6);\n    transition: left 850ms cubic-bezier(.2,.9,.25,1), top 850ms cubic-bezier(.2,.9,.25,1), transform 350ms ease;\n    user-select:none;\n    z-index:6;\n    background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    border: 1px solid rgba(255,255,255,0.06);\n  }\n\n  .token .glow{\n    position:absolute;\n    inset:0;\n    border-radius:50%;\n    filter:blur(18px);\n    opacity:0.65;\n    z-index:-1;\n    pointer-events:none;\n  }\n\n  .token .num{\n    position:relative;\n    z-index:2;\n  }\n\n  .token.highlight{\n    transform: translateY(-10px) scale(1.06);\n    box-shadow: 0 30px 80px rgba(124,92,255,0.18);\n  }\n\n  /* connecting lines */\n  svg.lines{\n    position:absolute;\n    inset:0;\n    width:100%;\n    height:100%;\n    z-index:2;\n    overflow:visible;\n    pointer-events:none;\n  }\n\n  /* footer description */\n  .explain{\n    margin-top:18px;\n    color:rgba(255,255,255,0.72);\n    font-size:13px;\n    line-height:1.45;\n  }\n\n  .badge{\n    display:inline-block;\n    padding:6px 10px;\n    border-radius:999px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n    font-size:12px;\n    color:var(--muted);\n    margin-right:8px;\n    vertical-align:middle;\n  }\n\n  .footer-hint{\n    margin-top:12px;\n    color:rgba(255,255,255,0.42);\n    font-size:12px;\n  }\n\n  /* tiny confetti/finish sparkle */\n  .spark{\n    position:absolute;\n    width:12px;height:12px;border-radius:3px;\n    transform:rotate(45deg);\n    opacity:0;\n    pointer-events:none;\n  }\n\n  @media (max-width:920px){\n    .card{flex-direction:column;padding:20px}\n    .left{width:100%}\n    .right{width:100%}\n    .stage{height:360px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"orb a\"></div>\n  <div class=\"orb b\"></div>\n\n  <div class=\"container\">\n    <div class=\"card\" role=\"main\" aria-label=\"Max Heap Visualization\">\n      <div class=\"left\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n          <div>\n            <h1>Max Heap</h1>\n            <div class=\"subtitle\">A priority tree that keeps the largest element at the root</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div class=\"badge\">Heap Type: Max</div>\n            <div style=\"font-size:12px;color:var(--muted);margin-top:6px\">Array Indexing: 0-based (visual)</div>\n          </div>\n        </div>\n\n        <div class=\"array-panel\" aria-hidden=\"true\">\n          <div style=\"display:flex;justify-content:center;align-items:center;\">\n            <div style=\"text-align:center\">\n              <div style=\"font-size:13px;color:var(--muted);margin-bottom:8px\">Underlying Array</div>\n              <div class=\"array-row\" id=\"arrayRow\" aria-live=\"polite\"></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"controls\" aria-hidden=\"false\">\n          <button id=\"playBtn\" class=\"btn\" title=\"Play or pause the animation\">Play</button>\n          <button id=\"resetBtn\" class=\"btn ghost\" title=\"Reset to initial array\">Reset</button>\n          <div style=\"flex:1\"></div>\n        </div>\n\n        <div class=\"meta\">Animation: Building a max heap with bottom-up heapify. Swaps are animated; observe how larger elements rise to the top.</div>\n\n        <div class=\"explain\">\n          <div style=\"font-weight:600;margin-bottom:6px\">How it works</div>\n          Starting from the last non-leaf node, sift down elements to ensure each parent is greater than its children. The sequence below animates the swaps that transform the array into a valid max heap.\n          <div class=\"footer-hint\">Tip: Use the Play and Reset buttons. The visualization is primarily for observation.</div>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div class=\"stage\" id=\"stage\" aria-hidden=\"true\">\n          <svg class=\"lines\" id=\"lines\"></svg>\n          <!-- placeholders and tokens will be injected here -->\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // Configuration & Aesthetics\n  const initialArray = [7, 3, 19, 1, 8, 9, 12, 20, 10]; // 0-based indexing\n  const tokenColors = [\n    ['#7C5CFF', '#BDA5FF'],\n    ['#00D4FF', '#7EEBFF'],\n    ['#FF7AB6', '#FFB3DA'],\n    ['#FFD36B', '#FFE6A8'],\n    ['#86FFB8', '#BFFFD8'],\n    ['#FF9E6F', '#FFC7A8'],\n    ['#6EE7B7','#CFFFEA'],\n    ['#9DA3FF','#C9CFFF'],\n    ['#7ED6FF','#CFF7FF']\n  ];\n\n  // DOM elements\n  const arrayRow = document.getElementById('arrayRow');\n  const stage = document.getElementById('stage');\n  const linesSvg = document.getElementById('lines');\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  let values = initialArray.slice();\n  let actions = []; // list of swap actions {i,j}\n  let isPlaying = false;\n  let currentStep = 0;\n  let tokens = []; // token elements with current index mapping\n  let mapping = {}; // index -> tokenId\n  let placeholders = {}; // index -> {x,y}\n  let animationTimer = null;\n  let finished = false;\n\n  // aesthetics: generate token DOM and array boxes\n  function setupInterface(){\n    arrayRow.innerHTML = '';\n    for(let i=0;i<values.length;i++){\n      const box = document.createElement('div');\n      box.className = 'arr-box';\n      box.dataset.index = i;\n      box.innerHTML = `<div class=\"idx\">${i}</div><div class=\"val\">${values[i]}</div>`;\n      arrayRow.appendChild(box);\n    }\n\n    // clear stage\n    stage.querySelectorAll('.placeholder,.token,.spark').forEach(n=>n.remove());\n    const stageRect = stage.getBoundingClientRect();\n    const width = stageRect.width;\n    const height = stageRect.height;\n\n    // compute tree positions (0-based)\n    const n = values.length;\n    const levels = Math.floor(Math.log2(n))+1;\n    const levelHeight = height / (levels + 1);\n    placeholders = {};\n    for(let i=0;i<n;i++){\n      const level = Math.floor(Math.log2(i+1));\n      const levelStart = Math.pow(2, level)-1;\n      const posInLevel = i - levelStart;\n      const nodesInLevel = Math.pow(2, level);\n      const x = (width) * ( (posInLevel + 0.5) / nodesInLevel );\n      const y = (level+1) * levelHeight - 10;\n      const ph = document.createElement('div');\n      ph.className = 'placeholder';\n      ph.style.left = (x)+'px';\n      ph.style.top = (y)+'px';\n      stage.appendChild(ph);\n      placeholders[i] = {x,y};\n    }\n\n    // draw lines between parent and children\n    linesSvg.innerHTML = '';\n    for(let i=0;i<n;i++){\n      const left = placeholders[i].x;\n      const top = placeholders[i].y;\n      const leftChild = 2*i+1;\n      const rightChild = 2*i+2;\n      if(leftChild < n){\n        const x2 = placeholders[leftChild].x;\n        const y2 = placeholders[leftChild].y;\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        const d = `M ${left} ${top+20} Q ${(left+x2)/2} ${(top+y2)/2 - 24} ${x2} ${y2-20}`;\n        path.setAttribute('d',d);\n        path.setAttribute('stroke','rgba(255,255,255,0.06)');\n        path.setAttribute('stroke-width','2');\n        path.setAttribute('fill','none');\n        path.setAttribute('stroke-linecap','round');\n        linesSvg.appendChild(path);\n      }\n      if(rightChild < n){\n        const x2 = placeholders[rightChild].x;\n        const y2 = placeholders[rightChild].y;\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        const d = `M ${left} ${top+20} Q ${(left+x2)/2} ${(top+y2)/2 - 24} ${x2} ${y2-20}`;\n        path.setAttribute('d',d);\n        path.setAttribute('stroke','rgba(255,255,255,0.06)');\n        path.setAttribute('stroke-width','2');\n        path.setAttribute('fill','none');\n        path.setAttribute('stroke-linecap','round');\n        linesSvg.appendChild(path);\n      }\n    }\n\n    // create tokens representing values (they move)\n    tokens = [];\n    mapping = {};\n    for(let i=0;i<values.length;i++){\n      const t = document.createElement('div');\n      t.className = 'token';\n      t.dataset.id = 'tok'+i;\n      stage.appendChild(t);\n\n      const glow = document.createElement('div');\n      glow.className='glow';\n      glow.style.background = `linear-gradient(135deg, ${tokenColors[i%tokenColors.length][0]}, ${tokenColors[i%tokenColors.length][1]})`;\n      glow.style.opacity = '0.7';\n      t.appendChild(glow);\n\n      const num = document.createElement('div');\n      num.className='num';\n      num.textContent = values[i];\n      t.appendChild(num);\n\n      // initial placement at placeholders[i]\n      const px = placeholders[i].x;\n      const py = placeholders[i].y;\n      t.style.left = (px - 32) + 'px';\n      t.style.top = (py - 32) + 'px';\n\n      tokens.push({el:t, value:values[i], index:i});\n      mapping[i] = i;\n    }\n  }\n\n  // Build actions using bottom-up heapify, record swaps\n  function computeActions(){\n    actions = [];\n    let arr = values.slice();\n    const n = arr.length;\n    function siftDown(i,heapSize){\n      while(true){\n        let largest = i;\n        const l = 2*i+1;\n        const r = 2*i+2;\n        if(l < heapSize && arr[l] > arr[largest]) largest = l;\n        if(r < heapSize && arr[r] > arr[largest]) largest = r;\n        if(largest !== i){\n          // record swap\n          actions.push({i:i,j:largest});\n          const tmp = arr[i]; arr[i] = arr[largest]; arr[largest] = tmp;\n          i = largest;\n        } else break;\n      }\n    }\n    for(let i=Math.floor(n/2)-1;i>=0;i--){\n      siftDown(i,n);\n    }\n    // actions complete\n  }\n\n  // Highlight utility\n  function highlightArrayIndices(i,j, duration=900){\n    const boxes = arrayRow.querySelectorAll('.arr-box');\n    boxes.forEach(b=>b.classList.remove('highlight'));\n    const a = arrayRow.querySelector('.arr-box[data-index=\"'+i+'\"]');\n    const b = arrayRow.querySelector('.arr-box[data-index=\"'+j+'\"]');\n    if(a) a.classList.add('highlight');\n    if(b) b.classList.add('highlight');\n    setTimeout(()=>{ if(a) a.classList.remove('highlight'); if(b) b.classList.remove('highlight'); }, duration+80);\n  }\n\n  // Perform one swap animation between indices i and j (0-based)\n  function animateSwap(i,j){\n    return new Promise(resolve=>{\n      // tokens at mapping positions\n      const tokAId = mapping[i];\n      const tokBId = mapping[j];\n      const tokenA = tokens.find(t=>t.datasetId === undefined ? t : null); // not used this way\n      // We stored tokens array with objects {el,value,index}, but mapping maps index->token array position\n      const idxA = mapping[i];\n      const idxB = mapping[j];\n      const tA = tokens[idxA];\n      const tB = tokens[idxB];\n\n      // highlight array boxes\n      highlightArrayIndices(i,j, 900);\n\n      // Add highlight class to tokens\n      tA.el.classList.add('highlight');\n      tB.el.classList.add('highlight');\n\n      // compute target coords\n      const pa = placeholders[i];\n      const pb = placeholders[j];\n\n      // animate by swapping positions\n      // swap their indices after animation\n      // note: tA currently at placeholders[i], tB at placeholders[j] presumably, but tokens might have been swapped earlier\n      // We will animate to each other's placeholders\n      const aLeft = (pb.x - 32) + 'px';\n      const aTop  = (pb.y - 32) + 'px';\n      const bLeft = (pa.x - 32) + 'px';\n      const bTop  = (pa.y - 32) + 'px';\n\n      // Force reflow to ensure transition\n      tA.el.style.willChange = 'left,top,transform';\n      tB.el.style.willChange = 'left,top,transform';\n\n      // Start animations\n      requestAnimationFrame(()=>{\n        tA.el.style.left = aLeft;\n        tA.el.style.top  = aTop;\n        tB.el.style.left = bLeft;\n        tB.el.style.top  = bTop;\n      });\n\n      // after transition, swap mapping and update internal indexes and array boxes\n      const duration = 900;\n      setTimeout(()=>{\n        // swap mapping content indices\n        const tmpIndex = tA.index;\n        tA.index = tB.index;\n        tB.index = tmpIndex;\n\n        // update tokens array ordering to keep mapping simple: swap tokens positions in tokens[] at idxA, idxB\n        const tempTok = tokens[idxA];\n        tokens[idxA] = tokens[idxB];\n        tokens[idxB] = tempTok;\n\n        // now update mapping to reflect new token positions: mapping[index] -> token array index\n        // we need to map based on tA.index and tB.index\n        mapping[i] = idxB;\n        mapping[j] = idxA;\n\n        // swap displayed numbers in array boxes to reflect array mutation\n        const boxA = arrayRow.querySelector('.arr-box[data-index=\"'+i+'\"] .val');\n        const boxB = arrayRow.querySelector('.arr-box[data-index=\"'+j+'\"] .val');\n        const tmp = boxA.textContent;\n        boxA.textContent = boxB.textContent;\n        boxB.textContent = tmp;\n\n        // remove highlight classes\n        tA.el.classList.remove('highlight');\n        tB.el.classList.remove('highlight');\n\n        resolve();\n      }, duration + 60);\n    });\n  }\n\n  // Simpler animateSwap implementation improved for robust mapping\n  function animateSwap2(i,j){\n    return new Promise(resolve=>{\n      // find token elements currently located at placeholders matching indices i,j\n      // We'll find tokens by checking which token's left/top is closest to placeholder coords\n      const findTokenAtIndex = (index) => {\n        for(let k=0;k<tokens.length;k++){\n          if(tokens[k].index === index) return tokens[k];\n        }\n        // fallback: pick tokens mapping\n        return tokens[mapping[index]];\n      };\n      const tA = findTokenAtIndex(i);\n      const tB = findTokenAtIndex(j);\n\n      // highlight UI\n      highlightArrayIndices(i,j, 900);\n      tA.el.classList.add('highlight');\n      tB.el.classList.add('highlight');\n\n      const pa = placeholders[i];\n      const pb = placeholders[j];\n\n      // animate to each other's positions\n      tA.el.style.left = (pb.x - 32) + 'px';\n      tA.el.style.top  = (pb.y - 32) + 'px';\n      tB.el.style.left = (pa.x - 32) + 'px';\n      tB.el.style.top  = (pa.y - 32) + 'px';\n\n      // after transition duration\n      const duration = 900;\n      setTimeout(()=>{\n        // swap their .index fields\n        const tmpIdx = tA.index;\n        tA.index = tB.index;\n        tB.index = tmpIdx;\n\n        // update mapping: mapping[index] = token (we'll map to token array index)\n        tokens.forEach((tk,u)=>{ mapping[tk.index] = u; });\n\n        // swap array boxes values\n        const boxA = arrayRow.querySelector('.arr-box[data-index=\"'+i+'\"] .val');\n        const boxB = arrayRow.querySelector('.arr-box[data-index=\"'+j+'\"] .val');\n        const tmp = boxA.textContent;\n        boxA.textContent = boxB.textContent;\n        boxB.textContent = tmp;\n\n        tA.el.classList.remove('highlight');\n        tB.el.classList.remove('highlight');\n\n        resolve();\n      }, duration + 30);\n    });\n  }\n\n  // Build actions and run the animation sequence\n  function runAnimation(){\n    if(currentStep >= actions.length){\n      isPlaying = false;\n      playBtn.textContent = 'Play';\n      finished = true;\n      celebration();\n      return;\n    }\n    if(!isPlaying) return;\n\n    const act = actions[currentStep];\n    currentStep++;\n    animateSwap2(act.i, act.j).then(()=>{\n      // small pause between actions\n      setTimeout(()=>{\n        if(isPlaying) runAnimation();\n      },140);\n    });\n  }\n\n  function start(){\n    if(finished) return;\n    if(isPlaying) return;\n    isPlaying = true;\n    playBtn.textContent = 'Pause';\n    runAnimation();\n  }\n\n  function pause(){\n    isPlaying = false;\n    playBtn.textContent = 'Play';\n  }\n\n  function togglePlay(){\n    if(isPlaying) pause();\n    else start();\n  }\n\n  function reset(){\n    pause();\n    currentStep = 0;\n    finished = false;\n    // reset values and interface\n    values = initialArray.slice();\n    setupInterface();\n    computeActions();\n    playBtn.textContent = 'Play';\n    // tiny pulse on reset\n    arrayRow.querySelectorAll('.arr-box').forEach((b,i)=>{\n      b.style.transform = 'translateY(-6px) scale(1.02)';\n      setTimeout(()=>b.style.transform = '', 220);\n    });\n    // remove sparks\n    stage.querySelectorAll('.spark').forEach(s=>s.remove());\n  }\n\n  function celebration(){\n    // create small sparkles near root\n    for(let i=0;i<14;i++){\n      const s = document.createElement('div');\n      s.className = 'spark';\n      s.style.width = (6 + Math.random()*10)+'px';\n      s.style.height = s.style.width;\n      s.style.left = (placeholders[0].x + (Math.random()*120-60)) + 'px';\n      s.style.top = (placeholders[0].y + (Math.random()*60-40)) + 'px';\n      s.style.background = i%2 ? 'linear-gradient(45deg,#7C5CFF,#00D4FF)' : 'linear-gradient(45deg,#FFD36B,#FF7AB6)';\n      s.style.opacity = '0';\n      s.style.transform = 'rotate(45deg) translateY(0px)';\n      stage.appendChild(s);\n      (function(el,delay){\n        setTimeout(()=>{\n          el.animate([\n            {opacity:0, transform:'rotate(45deg) translateY(0px) scale(0.6)'},\n            {opacity:1, transform:'rotate(45deg) translateY(-40px) scale(1.1)'},\n            {opacity:0, transform:'rotate(45deg) translateY(-90px) scale(0.6)'}\n          ], {duration:1000 + Math.random()*700, easing:'cubic-bezier(.2,.9,.25,1)', delay: delay});\n          setTimeout(()=>el.remove(), 1800 + delay);\n        },10);\n      })(s, i*40);\n    }\n\n    // highlight root token\n    const rootTok = tokens.find(t=>t.index===0);\n    if(rootTok){\n      rootTok.el.classList.add('highlight');\n      setTimeout(()=>rootTok.el.classList.remove('highlight'),1500);\n    }\n  }\n\n  // Initial setup\n  setupInterface();\n  computeActions();\n\n  // Event bindings\n  playBtn.addEventListener('click',()=>{\n    togglePlay();\n  });\n  resetBtn.addEventListener('click',()=>{\n    reset();\n  });\n\n  // small resize handling to reposition placeholders/tokens\n  let resizeTimer;\n  window.addEventListener('resize', ()=>{\n    clearTimeout(resizeTimer);\n    resizeTimer = setTimeout(()=>{\n      // rebuild visual layout but keep current token indices and values\n      const tokenState = tokens.map(t=>({value:t.value, index:t.index, inner: t.el.querySelector('.num') ? t.el.querySelector('.num').textContent : t.value}));\n      setupInterface();\n      // now reposition tokens to their tokenState indices\n      tokenState.forEach((st, u)=>{\n        const tok = tokens.find(t=>t.value===st.value && t.index===st.index) || tokens[u];\n        tok.el.querySelector('.num').textContent = st.inner;\n        tok.index = st.index;\n        tok.el.style.left = (placeholders[st.index].x - 32) + 'px';\n        tok.el.style.top  = (placeholders[st.index].y - 32) + 'px';\n      });\n      tokens.forEach((t,idx)=> mapping[t.index] = idx);\n    },150);\n  });\n\n  // tiny polished initial animation: gentle entrance\n  window.requestAnimationFrame(()=> {\n    document.querySelectorAll('.arr-box').forEach((b,i)=>{\n      b.style.transform = 'translateY(10px) scale(0.98)';\n      b.style.opacity = '0';\n      setTimeout(()=>{ b.style.transition = 'transform 600ms cubic-bezier(.2,.9,.25,1), opacity 500ms'; b.style.transform = ''; b.style.opacity = '1'; }, 80 + i*30);\n    });\n    tokens.forEach((t,i)=>{\n      t.el.style.opacity = '0';\n      t.el.style.transform = 'translateY(10px) scale(0.98)';\n      setTimeout(()=>{ t.el.style.transition = 'left 850ms cubic-bezier(.2,.9,.25,1), top 850ms cubic-bezier(.2,.9,.25,1), transform 420ms, opacity 420ms'; t.el.style.opacity = '1'; t.el.style.transform = ''; }, 150 + i*40);\n    });\n  });\n\n  // Expose functions to debug (not necessary)\n  window.__heapViz = {reset, start, pause, actions};\n})();\n</script>\n</body>\n</html>"
