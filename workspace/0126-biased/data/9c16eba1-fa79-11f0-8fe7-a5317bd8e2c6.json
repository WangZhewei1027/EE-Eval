  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>K-Means Clustering Interactive Demo</title>\n  <style>\n    /* Intentionally minimal visual design. No colors, no fancy styling. */\n    body { font-family: sans-serif; margin: 8px; }\n    #controls { display: block; max-width: 100%; }\n    canvas { border: 1px solid black; }\n    .section { margin: 6px 0; padding: 4px 0; }\n    label { display: inline-block; min-width: 120px; }\n    input[type=\"number\"] { width: 70px; }\n    textarea { width: 100%; height: 80px; }\n    .row { margin: 4px 0; }\n    .small { font-size: 12px; }\n  </style>\n</head>\n<body>\n  <h2>K-Means Clustering — Interactive Demo</h2>\n\n  <div id=\"controls\">\n\n    <div class=\"section\">\n      <strong>Data generation and editing</strong>\n      <div class=\"row\">\n        <label for=\"datasetType\">Generate:</label>\n        <select id=\"datasetType\">\n          <option value=\"blobs\">Blobs (k Gaussians)</option>\n          <option value=\"moons\">Moons (2 semicircles)</option>\n          <option value=\"rings\">Rings</option>\n          <option value=\"anisotropic\">Anisotropic Gaussian</option>\n          <option value=\"uniform\">Uniform</option>\n        </select>\n        <label for=\"nPoints\">N:</label>\n        <input type=\"number\" id=\"nPoints\" value=\"200\" min=\"1\">\n        <label for=\"trueK\">true k:</label>\n        <input type=\"number\" id=\"trueK\" value=\"3\" min=\"1\" max=\"20\">\n        <label for=\"seed\">seed:</label>\n        <input type=\"number\" id=\"seed\" value=\"42\" min=\"0\">\n        <button id=\"generateBtn\">Generate</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Canvas actions:</label>\n        <button id=\"modeAdd\">Add point (click)</button>\n        <button id=\"modeMove\">Move points (drag)</button>\n        <button id=\"modeDelete\">Delete (click)</button>\n        <button id=\"modeNone\">Navigate (no edit)</button>\n        <span class=\"small\">Click canvas to interact based on selected mode.</span>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <strong>K-Means control</strong>\n      <div class=\"row\">\n        <label for=\"kInput\">K (clusters):</label>\n        <input type=\"number\" id=\"kInput\" value=\"3\" min=\"1\" max=\"20\">\n        <label for=\"initMethod\">init:</label>\n        <select id=\"initMethod\">\n          <option value=\"random\">Random</option>\n          <option value=\"kmeans++\">kmeans++</option>\n          <option value=\"manual\">Manual (click to place)</option>\n        </select>\n        <label for=\"distanceMetric\">distance:</label>\n        <select id=\"distanceMetric\">\n          <option value=\"euclidean\">Euclidean</option>\n          <option value=\"manhattan\">Manhattan</option>\n          <option value=\"cosine\">Cosine</option>\n        </select>\n      </div>\n\n      <div class=\"row\">\n        <label for=\"normalize\">Normalize:</label>\n        <select id=\"normalize\">\n          <option value=\"none\">None</option>\n          <option value=\"zscore\">Z-score</option>\n          <option value=\"minmax\">Min-Max</option>\n        </select>\n        <label for=\"modeUpdate\">update:</label>\n        <select id=\"modeUpdate\">\n          <option value=\"batch\">Batch (standard)</option>\n          <option value=\"online\">Online (per-point)</option>\n        </select>\n        <label for=\"learningRate\">lr (online):</label>\n        <input type=\"number\" id=\"learningRate\" value=\"0.2\" step=\"0.01\" min=\"0.001\" max=\"1\">\n      </div>\n\n      <div class=\"row\">\n        <label for=\"maxIter\">max iter:</label>\n        <input type=\"number\" id=\"maxIter\" value=\"100\" min=\"1\">\n        <label for=\"tol\">tol (SSE change):</label>\n        <input type=\"number\" id=\"tol\" value=\"1e-4\" step=\"1e-4\">\n        <label for=\"iterSpeed\">iter/sec:</label>\n        <input type=\"number\" id=\"iterSpeed\" value=\"5\" min=\"1\">\n      </div>\n\n      <div class=\"row\">\n        <button id=\"initBtn\">Initialize Centers</button>\n        <button id=\"stepBtn\">Single Step</button>\n        <button id=\"runBtn\">Run</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <button id=\"resetCentersBtn\">Reset Centers</button>\n        <button id=\"reassignBtn\">Reassign Only</button>\n      </div>\n\n      <div class=\"row\">\n        <label for=\"changeKAction\">Change K mid-run:</label>\n        <select id=\"changeKAction\">\n          <option value=\"randomNew\">Add new random</option>\n          <option value=\"splitLargest\">Split largest</option>\n          <option value=\"mergeClosest\">Merge closest</option>\n        </select>\n        <button id=\"applyKChange\">Apply</button>\n      </div>\n\n    </div>\n\n    <div class=\"section\">\n      <strong>Analysis & history</strong>\n      <div class=\"row\">\n        <label>Iter:</label> <span id=\"iterCount\">0</span>\n        <label> SSE:</label> <span id=\"sseVal\">-</span>\n        <label> Inertia:</label> <span id=\"inertiaVal\">-</span>\n        <label> Assigned counts:</label> <span id=\"countsVal\">-</span>\n      </div>\n\n      <div class=\"row\">\n        <label>History (SSE over iterations):</label>\n        <canvas id=\"sseCanvas\" width=\"600\" height=\"120\"></canvas>\n      </div>\n\n      <div class=\"row\">\n        <label>Save/Load Config:</label>\n        <button id=\"exportBtn\">Export JSON</button>\n        <button id=\"importBtn\">Import JSON</button>\n      </div>\n      <div class=\"row\">\n        <textarea id=\"jsonArea\" placeholder=\"Exported JSON appears here...\"></textarea>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <strong>Point inspector</strong>\n      <div class=\"row\">\n        <label>Selected point:</label> <span id=\"selectedInfo\">None</span>\n        <button id=\"deletePointBtn\">Delete</button>\n        <button id=\"toggleWeight\">Toggle weight 1/5</button>\n      </div>\n      <div class=\"row\">\n        <label>Explain assignment for point:</label>\n        <input type=\"number\" id=\"explainIdx\" value=\"0\" min=\"0\">\n        <button id=\"explainBtn\">Explain</button>\n        <div id=\"explainOut\" class=\"small\"></div>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"section\">\n    <strong>Canvas (click to interact)</strong><br>\n    <canvas id=\"plot\" width=\"700\" height=\"500\"></canvas>\n    <div class=\"small\">Left-click to add/move/delete depending on mode. Right-click to place a center when init method is manual.</div>\n  </div>\n\n<script>\n/* K-Means Interactive Demo\n   - Minimal visual style by requirement\n   - Many controls and exploration options\n*/\n\n// Utilities\nfunction clamp(v,a,b){return v<a?a:(v>b?b:v);}\nfunction rndSeed(seed){\n  // mulberry32\n  let t = seed >>> 0;\n  return function(){\n    t += 0x6D2B79F5;\n    let r = Math.imul(t ^ t >>> 15, 1 | t);\n    r ^= r + Math.imul(r ^ r >>> 7, 61 | r);\n    return ((r ^ r >>> 14) >>> 0) / 4294967296;\n  }\n}\n\nfunction distSquared(a,b){\n  let dx=a.x-b.x, dy=a.y-b.y; return dx*dx+dy*dy;\n}\n\n// Global state\nconst state = {\n  points: [], // {x,y,weight,assigned}\n  centers: [], // {x,y,history: []}\n  assignedCounts: [],\n  iter: 0,\n  sseHistory: [],\n  running: false,\n  runTimer: null,\n  rng: rndSeed(42),\n  mode: 'none', // add, move, delete, none\n  selectedPoint: null,\n  manualCenterMode: false,\n  paused: false\n};\n\n// DOM elements\nconst canvas = document.getElementById('plot');\nconst ctx = canvas.getContext('2d');\nconst sseCanvas = document.getElementById('sseCanvas');\nconst sseCtx = sseCanvas.getContext('2d');\n\nconst nPointsInput = document.getElementById('nPoints');\nconst trueKInput = document.getElementById('trueK');\nconst datasetType = document.getElementById('datasetType');\nconst generateBtn = document.getElementById('generateBtn');\nconst seedInput = document.getElementById('seed');\n\nconst modeAddBtn = document.getElementById('modeAdd');\nconst modeMoveBtn = document.getElementById('modeMove');\nconst modeDeleteBtn = document.getElementById('modeDelete');\nconst modeNoneBtn = document.getElementById('modeNone');\n\nconst kInput = document.getElementById('kInput');\nconst initMethod = document.getElementById('initMethod');\nconst initBtn = document.getElementById('initBtn');\nconst resetCentersBtn = document.getElementById('resetCentersBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst runBtn = document.getElementById('runBtn');\nconst pauseBtn = document.getElementById('pauseBtn');\nconst reassignBtn = document.getElementById('reassignBtn');\n\nconst distanceMetric = document.getElementById('distanceMetric');\nconst normalizeSelect = document.getElementById('normalize');\nconst modeUpdate = document.getElementById('modeUpdate');\nconst learningRate = document.getElementById('learningRate');\n\nconst maxIterInput = document.getElementById('maxIter');\nconst tolInput = document.getElementById('tol');\nconst iterSpeedInput = document.getElementById('iterSpeed');\n\nconst changeKAction = document.getElementById('changeKAction');\nconst applyKChangeBtn = document.getElementById('applyKChange');\n\nconst iterCountSpan = document.getElementById('iterCount');\nconst sseValSpan = document.getElementById('sseVal');\nconst inertiaValSpan = document.getElementById('inertiaVal');\nconst countsValSpan = document.getElementById('countsVal');\n\nconst exportBtn = document.getElementById('exportBtn');\nconst importBtn = document.getElementById('importBtn');\nconst jsonArea = document.getElementById('jsonArea');\n\nconst modeWeightToggle = document.getElementById('toggleWeight');\nconst deletePointBtn = document.getElementById('deletePointBtn');\nconst selectedInfoSpan = document.getElementById('selectedInfo');\n\nconst explainIdx = document.getElementById('explainIdx');\nconst explainBtn = document.getElementById('explainBtn');\nconst explainOut = document.getElementById('explainOut');\n\n\n// Canvas coordinate helpers\nfunction canvasToData(px,py){\n  // map canvas (0..width,0..height) to data coords [-1.2..1.2] square scaled by padding\n  const pad = 20;\n  const w = canvas.width - pad*2;\n  const h = canvas.height - pad*2;\n  const x = ((px - pad) / w) * 2.4 - 1.2;\n  const y = -(((py - pad) / h) * 2.4 - 1.2);\n  return {x,y};\n}\nfunction dataToCanvas(x,y){\n  const pad = 20;\n  const w = canvas.width - pad*2;\n  const h = canvas.height - pad*2;\n  const px = pad + ((x + 1.2) / 2.4) * w;\n  const py = pad + ((-y + 1.2) / 2.4) * h;\n  return {px,py};\n}\n\n// Data generation functions\nfunction generateData(type, n, trueK) {\n  const rng = rndSeed(parseInt(seedInput.value||0));\n  const pts = [];\n  if (type === 'blobs') {\n    // trueK Gaussians randomly located\n    const centers = [];\n    for (let i=0;i<trueK;i++){\n      centers.push({x: (rng()*2-1)*0.8, y:(rng()*2-1)*0.8});\n    }\n    for (let i=0;i<n;i++){\n      const c = centers[Math.floor(rng()*centers.length)];\n      const r = 0.05 + rng()*0.08;\n      const angle = rng()*Math.PI*2;\n      const x = c.x + Math.cos(angle)*r + (rng()-0.5)*0.02;\n      const y = c.y + Math.sin(angle)*r + (rng()-0.5)*0.02;\n      pts.push({x,y,weight:1,assigned:-1});\n    }\n  } else if (type === 'moons') {\n    // two semicircles\n    for (let i=0;i<n;i++){\n      const t = rng()*Math.PI;\n      const r = 0.8 + (rng()-0.5)*0.06;\n      if (i % 2 === 0){\n        pts.push({x: Math.cos(t)*0.6 + 0.3 + (rng()-0.5)*0.05, y: Math.sin(t)*0.4 + (rng()-0.5)*0.05, weight:1, assigned:-1});\n      } else {\n        pts.push({x: Math.cos(t)*0.6 - 0.3 + (rng()-0.5)*0.05, y: -Math.sin(t)*0.4 + 0.2 + (rng()-0.5)*0.05, weight:1, assigned:-1});\n      }\n    }\n  } else if (type === 'rings') {\n    for (let i=0;i<n;i++){\n      const ring = Math.floor(rng()*3)+1;\n      const rad = 0.15 * ring + (rng()-0.5)*0.04;\n      const angle = rng()*Math.PI*2;\n      pts.push({x: Math.cos(angle)*rad + (rng()-0.5)*0.02, y: Math.sin(angle)*rad + (rng()-0.5)*0.02, weight:1, assigned:-1});\n    }\n  } else if (type === 'anisotropic') {\n    // sample gaussian then affine transform\n    const A = [[1.5,0.6],[0.2,0.7]];\n    for (let i=0;i<n;i++){\n      const x0 = (rng()*2-1)*0.5;\n      const y0 = (rng()*2-1)*0.5;\n      const x = A[0][0]*x0 + A[0][1]*y0 + (rng()-0.5)*0.03;\n      const y = A[1][0]*x0 + A[1][1]*y0 + (rng()-0.5)*0.03;\n      pts.push({x,y,weight:1,assigned:-1});\n    }\n  } else { // uniform\n    for (let i=0;i<n;i++){\n      pts.push({x:(rng()*2-1)*1.1, y:(rng()*2-1)*1.1, weight:1, assigned:-1});\n    }\n  }\n  return pts;\n}\n\n// Normalization helpers\nfunction computeNormalization(points){\n  // compute min/max and mean/std\n  if (points.length === 0) return null;\n  let minX=Infinity,minY=Infinity,maxX=-Infinity,maxY=-Infinity, sumX=0,sumY=0;\n  for (const p of points){\n    minX = Math.min(minX,p.x); minY = Math.min(minY,p.y);\n    maxX = Math.max(maxX,p.x); maxY = Math.max(maxY,p.y);\n    sumX += p.x; sumY += p.y;\n  }\n  const meanX = sumX/points.length, meanY = sumY/points.length;\n  let varX=0,varY=0;\n  for (const p of points){\n    varX += (p.x-meanX)*(p.x-meanX);\n    varY += (p.y-meanY)*(p.y-meanY);\n  }\n  varX = Math.sqrt(varX/points.length); varY = Math.sqrt(varY/points.length);\n  return {minX,minY,maxX,maxY,meanX,meanY,stdX:varX||1,stdY:varY||1};\n}\n\nfunction applyNormalization(points, centers){\n  const method = normalizeSelect.value;\n  if (method === 'none') return;\n  const norm = computeNormalization(points);\n  if (!norm) return;\n  for (const p of points){\n    if (method === 'zscore'){\n      p.x = (p.x - norm.meanX) / norm.stdX;\n      p.y = (p.y - norm.meanY) / norm.stdY;\n    } else if (method === 'minmax'){\n      p.x = (p.x - norm.minX) / (norm.maxX - norm.minX || 1) * 2 - 1;\n      p.y = (p.y - norm.minY) / (norm.maxY - norm.minY || 1) * 2 - 1;\n    }\n  }\n  if (centers){\n    for (const c of centers){\n      if (method === 'zscore'){\n        c.x = (c.x - norm.meanX) / norm.stdX;\n        c.y = (c.y - norm.meanY) / norm.stdY;\n      } else {\n        c.x = (c.x - norm.minX) / (norm.maxX - norm.minX || 1) * 2 - 1;\n        c.y = (c.y - norm.minY) / (norm.maxY - norm.minY || 1) * 2 - 1;\n      }\n    }\n  }\n}\n\n// Distance metric\nfunction distance(p,c){\n  const m = distanceMetric.value;\n  if (m === 'euclidean'){\n    const dx = p.x - c.x, dy = p.y - c.y;\n    return Math.sqrt(dx*dx+dy*dy);\n  } else if (m === 'manhattan'){\n    return Math.abs(p.x-c.x) + Math.abs(p.y-c.y);\n  } else if (m === 'cosine'){\n    const dot = p.x*c.x + p.y*c.y;\n    const magP = Math.sqrt(p.x*p.x + p.y*p.y) || 1e-9;\n    const magC = Math.sqrt(c.x*c.x + c.y*c.y) || 1e-9;\n    return 1 - (dot/(magP*magC));\n  }\n  return 0;\n}\n\n// KMeans core steps\nfunction initializeCenters(method, k){\n  const rng = state.rng;\n  state.centers = [];\n  if (method === 'random'){\n    for (let i=0;i<k;i++){\n      // choose a random point or random in bounds\n      if (state.points.length>0 && Math.random()>0.5){\n        // copy position of random point (rng)\n        const p = state.points[Math.floor(rng()*state.points.length)];\n        state.centers.push({x:p.x + (rng()-0.5)*0.01, y:p.y + (rng()-0.5)*0.01, history:[]});\n      } else {\n        // random in viewing window\n        state.centers.push({x:(rng()*2-1)*1.0, y:(rng()*2-1)*1.0, history:[]});\n      }\n    }\n  } else if (method === 'kmeans++'){\n    if (state.points.length === 0){\n      // fallback to random\n      initializeCenters('random',k);\n      return;\n    }\n    // pick first at random\n    const first = state.points[Math.floor(rng()*state.points.length)];\n    state.centers.push({x:first.x, y:first.y, history:[]});\n    while (state.centers.length < k){\n      // compute squared distances to nearest center\n      const distances = state.points.map(p=>{\n        let best = Infinity;\n        for (const c of state.centers){\n          const d = distSquared(p,c);\n          if (d < best) best = d;\n        }\n        return best;\n      });\n      const sum = distances.reduce((a,b)=>a+b,0);\n      if (sum === 0) {\n        // all identical points\n        state.centers.push({x:(rng()*2-1)*1.0, y:(rng()*2-1)*1.0, history:[]});\n        continue;\n      }\n      let r = rng()*sum;\n      let idx = 0;\n      while (idx < distances.length && r > 0){\n        r -= distances[idx++];\n      }\n      const chosen = state.points[Math.max(0,idx-1)];\n      state.centers.push({x:chosen.x, y:chosen.y, history:[]});\n    }\n  } else if (method === 'manual'){\n    // manual: user will place centers with right-click; for now create none\n    state.centers = [];\n    state.manualCenterMode = true;\n    alert('Manual init: right-click on the canvas to place centers. Press Initialize Centers again when done and choose a non-manual method or keep manual centers.');\n  }\n  // clear history\n  for (const c of state.centers) c.history = [{x:c.x,y:c.y}];\n  state.iter = 0;\n  state.sseHistory = [];\n  drawAll();\n}\n\nfunction assignPoints(){\n  const centers = state.centers;\n  if (centers.length === 0) return;\n  for (const p of state.points){\n    let best = Infinity;\n    let bestIdx = -1;\n    for (let i=0;i<centers.length;i++){\n      const c = centers[i];\n      const d = distance(p,c);\n      if (d < best){\n        best = d; bestIdx = i;\n      }\n    }\n    p.assigned = bestIdx;\n  }\n}\n\nfunction updateCentersBatch(){\n  const k = state.centers.length;\n  const sums = Array.from({length:k}, ()=>({x:0,y:0,w:0}));\n  for (const p of state.points){\n    const i = Math.max(0, p.assigned);\n    if (i >= 0 && i < k){\n      sums[i].x += p.x * p.weight;\n      sums[i].y += p.y * p.weight;\n      sums[i].w += p.weight;\n    }\n  }\n  for (let i=0;i<k;i++){\n    const s = sums[i];\n    const c = state.centers[i];\n    if (s.w > 0){\n      const nx = s.x / s.w;\n      const ny = s.y / s.w;\n      c.history.push({x:c.x,y:c.y});\n      c.x = nx; c.y = ny;\n    } else {\n      // empty cluster: jitter or reassign\n      const rng = state.rng;\n      c.history.push({x:c.x,y:c.y});\n      c.x += (rng()-0.5)*0.2;\n      c.y += (rng()-0.5)*0.2;\n    }\n  }\n}\n\nfunction updateCentersOnline(){\n  const lr = parseFloat(learningRate.value);\n  // iterate points in random order\n  const idxs = state.points.map((_,i)=>i);\n  for (let i=idxs.length-1;i>0;i--){\n    const j = Math.floor(state.rng()* (i+1));\n    [idxs[i], idxs[j]] = [idxs[j], idxs[i]];\n  }\n  for (const idx of idxs){\n    const p = state.points[idx];\n    const c = state.centers[p.assigned];\n    if (!c) continue;\n    c.history.push({x:c.x,y:c.y});\n    // weighted update\n    c.x = c.x + lr * (p.x - c.x);\n    c.y = c.y + lr * (p.y - c.y);\n  }\n}\n\nfunction computeSSE(){\n  let sse = 0;\n  const counts = Array.from({length: state.centers.length}, ()=>0);\n  for (const p of state.points){\n    const i = p.assigned;\n    if (i >= 0 && i < state.centers.length){\n      const c = state.centers[i];\n      const dx = p.x - c.x, dy = p.y - c.y;\n      const d = dx*dx + dy*dy;\n      sse += d * p.weight;\n      counts[i] += 1;\n    } else {\n      // unassigned\n      sse += 0;\n    }\n  }\n  state.assignedCounts = counts;\n  return sse;\n}\n\nfunction oneIteration(){\n  if (state.centers.length === 0) { alert('No centers. Initialize first.'); return; }\n  assignPoints();\n  const prevSSE = state.sseHistory.length?state.sseHistory[state.sseHistory.length-1]:Infinity;\n  if (modeUpdate.value === 'batch'){\n    updateCentersBatch();\n  } else {\n    updateCentersOnline();\n  }\n  assignPoints();\n  const sse = computeSSE();\n  state.sseHistory.push(sse);\n  state.iter += 1;\n  iterCountSpan.textContent = state.iter;\n  sseValSpan.textContent = sse.toFixed(6);\n  inertiaValSpan.textContent = sse.toFixed(6);\n  countsValSpan.textContent = state.assignedCounts.join(',');\n  drawAll();\n  drawSSE();\n  // check tolerance\n  const maxIter = parseInt(maxIterInput.value);\n  const tol = parseFloat(tolInput.value) || 0;\n  if (state.iter >= maxIter || Math.abs(prevSSE - sse) <= tol){\n    // stop if running\n    if (state.running){\n      stopRunning();\n    }\n  }\n}\n\n// Running loop\nfunction runIterations(){\n  if (state.running) return;\n  state.running = true;\n  state.paused = false;\n  const speed = Math.max(1, parseInt(iterSpeedInput.value));\n  const delay = 1000 / speed;\n  function step(){\n    if (!state.running) return;\n    oneIteration();\n    if (state.running){\n      setTimeout(step, delay);\n    }\n  }\n  step();\n}\n\nfunction stopRunning(){\n  state.running = false;\n  state.paused = true;\n}\n\n// Drawing functions\nfunction drawAll(){\n  // clear\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  // draw grid lines (light; but we must keep minimal, use lines)\n  // axes\n  ctx.beginPath();\n  const center = dataToCanvas(0,0);\n  ctx.moveTo(center.px, 0);\n  ctx.lineTo(center.px, canvas.height);\n  ctx.moveTo(0, center.py);\n  ctx.lineTo(canvas.width, center.py);\n  ctx.strokeStyle = 'black';\n  ctx.lineWidth = 0.5;\n  ctx.stroke();\n\n  // draw points\n  for (let i=0;i<state.points.length;i++){\n    const p = state.points[i];\n    const pos = dataToCanvas(p.x,p.y);\n    // circle\n    ctx.beginPath();\n    ctx.arc(pos.px, pos.py, Math.max(2, 3*Math.sqrt(p.weight)), 0, Math.PI*2);\n    ctx.strokeStyle = 'black';\n    ctx.lineWidth = 0.8;\n    ctx.stroke();\n    // draw assignment id text\n    const text = (p.assigned>=0?('C'+p.assigned):'-');\n    ctx.fillStyle = 'black';\n    ctx.font = '10px sans-serif';\n    ctx.fillText(text, pos.px + 6, pos.py - 6);\n    // optional highlight selected\n    if (state.selectedPoint === i){\n      ctx.beginPath();\n      ctx.rect(pos.px-6, pos.py-6, 12, 12);\n      ctx.stroke();\n    }\n  }\n  // draw center histories and centers\n  for (let i=0;i<state.centers.length;i++){\n    const c = state.centers[i];\n    // draw history lines\n    if (c.history && c.history.length>0){\n      ctx.beginPath();\n      for (let j=0;j<c.history.length;j++){\n        const h = dataToCanvas(c.history[j].x, c.history[j].y);\n        if (j===0) ctx.moveTo(h.px, h.py);\n        else ctx.lineTo(h.px, h.py);\n      }\n      ctx.stroke();\n    }\n    // draw cross for center\n    const cp = dataToCanvas(c.x,c.y);\n    ctx.beginPath();\n    ctx.moveTo(cp.px-8, cp.py-8); ctx.lineTo(cp.px+8, cp.py+8);\n    ctx.moveTo(cp.px-8, cp.py+8); ctx.lineTo(cp.px+8, cp.py-8);\n    ctx.stroke();\n    ctx.fillText('C'+i, cp.px + 8, cp.py + 8);\n  }\n}\n\nfunction drawSSE(){\n  // clear\n  sseCtx.clearRect(0,0,sseCanvas.width,sseCanvas.height);\n  const data = state.sseHistory;\n  if (data.length === 0) return;\n  const w = sseCanvas.width, h = sseCanvas.height;\n  const max = Math.max(...data);\n  const min = Math.min(...data);\n  sseCtx.beginPath();\n  for (let i=0;i<data.length;i++){\n    const x = i/(data.length-1 || 1) * (w-20) + 10;\n    const y = h - 10 - ((data[i]-min)/(max-min || 1)) * (h-20);\n    if (i===0) sseCtx.moveTo(x,y); else sseCtx.lineTo(x,y);\n  }\n  sseCtx.strokeStyle = 'black';\n  sseCtx.stroke();\n  // draw axis\n  sseCtx.fillStyle = 'black';\n  sseCtx.font = '10px sans-serif';\n  sseCtx.fillText('Iter: '+state.iter, 6, 10);\n  sseCtx.fillText('SSE: '+data[data.length-1].toFixed(4), 80, 10);\n}\n\n// Interaction handlers\ncanvas.addEventListener('contextmenu', (e)=>{\n  e.preventDefault();\n  if (initMethod.value === 'manual'){\n    // place center\n    const rect = canvas.getBoundingClientRect();\n    const p = canvasToData(e.clientX - rect.left, e.clientY - rect.top);\n    state.centers.push({x:p.x, y:p.y, history:[{x:p.x,y:p.y}]});\n    drawAll();\n  }\n});\n\nlet dragging = false;\nlet dragIndex = null;\n\ncanvas.addEventListener('mousedown',(e)=>{\n  const rect = canvas.getBoundingClientRect();\n  const p = canvasToData(e.clientX - rect.left, e.clientY - rect.top);\n  if (e.button === 0){\n    if (state.mode === 'add'){\n      state.points.push({x:p.x,y:p.y,weight:1,assigned:-1});\n      drawAll();\n    } else if (state.mode === 'delete'){\n      // find nearest point within threshold\n      let best = Infinity, idx=-1;\n      for (let i=0;i<state.points.length;i++){\n        const d = distSquared(state.points[i], p);\n        if (d < best){ best=d; idx=i; }\n      }\n      if (idx>=0 && best < 0.0012){ // small threshold\n        state.points.splice(idx,1);\n        drawAll();\n      }\n    } else if (state.mode === 'move'){\n      // find nearest point and start dragging\n      let best = Infinity, idx=-1;\n      for (let i=0;i<state.points.length;i++){\n        const d = distSquared(state.points[i], p);\n        if (d < best){ best=d; idx=i; }\n      }\n      if (idx>=0 && best < 0.02){\n        dragging = true; dragIndex = idx;\n        state.selectedPoint = idx;\n        selectedInfoSpan.textContent = `#${idx} x=${state.points[idx].x.toFixed(3)}, y=${state.points[idx].y.toFixed(3)}, w=${state.points[idx].weight}`;\n        drawAll();\n      } else {\n        state.selectedPoint = null;\n        selectedInfoSpan.textContent = 'None';\n      }\n    } else {\n      // select nearest\n      let best = Infinity, idx=-1;\n      for (let i=0;i<state.points.length;i++){\n        const d = distSquared(state.points[i], p);\n        if (d < best){ best=d; idx=i; }\n      }\n      if (idx>=0 && best < 0.02){\n        state.selectedPoint = idx;\n        selectedInfoSpan.textContent = `#${idx} x=${state.points[idx].x.toFixed(3)}, y=${state.points[idx].y.toFixed(3)}, w=${state.points[idx].weight}`;\n        drawAll();\n      } else {\n        state.selectedPoint = null;\n        selectedInfoSpan.textContent = 'None';\n        drawAll();\n      }\n    }\n  }\n});\n\ncanvas.addEventListener('mousemove',(e)=>{\n  if (dragging && dragIndex != null){\n    const rect = canvas.getBoundingClientRect();\n    const p = canvasToData(e.clientX - rect.left, e.clientY - rect.top);\n    state.points[dragIndex].x = clamp(p.x, -2, 2);\n    state.points[dragIndex].y = clamp(p.y, -2, 2);\n    selectedInfoSpan.textContent = `#${dragIndex} x=${state.points[dragIndex].x.toFixed(3)}, y=${state.points[dragIndex].y.toFixed(3)}, w=${state.points[dragIndex].weight}`;\n    drawAll();\n  }\n});\n\ncanvas.addEventListener('mouseup',(e)=>{\n  dragging = false; dragIndex = null;\n});\n\n// Buttons and UI wiring\ngenerateBtn.addEventListener('click', ()=>{\n  const n = parseInt(nPointsInput.value) || 100;\n  const tK = parseInt(trueKInput.value) || 3;\n  state.rng = rndSeed(parseInt(seedInput.value)||0);\n  state.points = generateData(datasetType.value, n, tK);\n  state.centers = [];\n  state.iter = 0;\n  state.sseHistory = [];\n  state.selectedPoint = null;\n  selectedInfoSpan.textContent = 'None';\n  drawAll();\n  drawSSE();\n});\n\nmodeAddBtn.addEventListener('click', ()=>{ state.mode='add'; alert('Add mode: left click to add points.')});\nmodeMoveBtn.addEventListener('click', ()=>{ state.mode='move'; alert('Move mode: drag to move points.')});\nmodeDeleteBtn.addEventListener('click', ()=>{ state.mode='delete'; alert('Delete mode: left click on a point to delete.')});\nmodeNoneBtn.addEventListener('click', ()=>{ state.mode='none'; alert('Navigate mode: click to select points.')});\n\ninitBtn.addEventListener('click', ()=>{\n  const k = parseInt(kInput.value) || 1;\n  state.rng = rndSeed(parseInt(seedInput.value)||0);\n  initializeCenters(initMethod.value, k);\n  // apply normalization to centers if needed? Only apply to data if chosen before generating\n  drawAll();\n});\n\nresetCentersBtn.addEventListener('click', ()=>{\n  state.centers = [];\n  state.iter = 0;\n  state.sseHistory = [];\n  drawAll();\n  drawSSE();\n});\n\nstepBtn.addEventListener('click', ()=>{\n  oneIteration();\n});\n\nrunBtn.addEventListener('click', ()=>{\n  if (state.running) return;\n  runIterations();\n});\n\npauseBtn.addEventListener('click', ()=>{\n  stopRunning();\n});\n\nreassignBtn.addEventListener('click', ()=>{\n  assignPoints();\n  const sse = computeSSE();\n  state.sseHistory.push(sse);\n  drawAll(); drawSSE();\n});\n\n// K change mid-run\napplyKChangeBtn.addEventListener('click', ()=>{\n  const action = changeKAction.value;\n  if (action === 'randomNew'){\n    const kNew = state.centers.length + 1;\n    const rng = state.rng;\n    state.centers.push({x:(rng()*2-1)*1.0, y:(rng()*2-1)*1.0, history:[]});\n  } else if (action === 'splitLargest'){\n    // find largest cluster, split its center slightly\n    const counts = state.assignedCounts || [];\n    if (counts.length === 0){ alert('No assignment info. Run at least one iteration.'); return; }\n    let maxIdx = 0;\n    for (let i=1;i<counts.length;i++) if (counts[i] > counts[maxIdx]) maxIdx=i;\n    const base = state.centers[maxIdx];\n    const rng = state.rng;\n    const c1 = {x:base.x + 0.03, y:base.y + 0.02, history:[]};\n    const c2 = {x:base.x - 0.03, y:base.y - 0.02, history:[]};\n    // replace base with c1, push c2\n    state.centers[maxIdx] = c1;\n    state.centers.push(c2);\n  } else if (action === 'mergeClosest'){\n    if (state.centers.length < 2) return;\n    let best = Infinity, pair=[0,1];\n    for (let i=0;i<state.centers.length;i++){\n      for (let j=i+1;j<state.centers.length;j++){\n        const d = distSquared(state.centers[i], state.centers[j]);\n        if (d < best){ best=d; pair=[i,j]; }\n      }\n    }\n    const i = pair[0], j = pair[1];\n    const ci = state.centers[i], cj = state.centers[j];\n    const merged = {x:(ci.x + cj.x)/2, y:(ci.y + cj.y)/2, history:[]};\n    // replace i with merged, remove j\n    state.centers[i] = merged;\n    state.centers.splice(j,1);\n  }\n  drawAll();\n});\n\n// Export/Import\nexportBtn.addEventListener('click', ()=>{\n  const data = {\n    points: state.points,\n    centers: state.centers,\n    iter: state.iter,\n    sseHistory: state.sseHistory\n  };\n  jsonArea.value = JSON.stringify(data, null, 2);\n});\nimportBtn.addEventListener('click', ()=>{\n  try{\n    const data = JSON.parse(jsonArea.value);\n    state.points = data.points || [];\n    state.centers = data.centers || [];\n    state.iter = data.iter || 0;\n    state.sseHistory = data.sseHistory || [];\n    drawAll(); drawSSE();\n  } catch(e){\n    alert('Invalid JSON');\n  }\n});\n\n// Point inspector controls\ndeletePointBtn.addEventListener('click', ()=>{\n  if (state.selectedPoint == null) { alert('No selected point'); return; }\n  state.points.splice(state.selectedPoint,1);\n  state.selectedPoint = null;\n  selectedInfoSpan.textContent = 'None';\n  drawAll();\n});\nmodeWeightToggle.addEventListener('click', ()=>{\n  if (state.selectedPoint == null) { alert('No selected point'); return; }\n  const p = state.points[state.selectedPoint];\n  p.weight = (p.weight===1?5:1);\n  selectedInfoSpan.textContent = `#${state.selectedPoint} x=${p.x.toFixed(3)}, y=${p.y.toFixed(3)}, w=${p.weight}`;\n  drawAll();\n});\n\n// Explain assignment\nexplainBtn.addEventListener('click', ()=>{\n  const idx = parseInt(explainIdx.value) || 0;\n  if (idx < 0 || idx >= state.points.length){ explainOut.textContent = 'Index out of range.'; return; }\n  const p = state.points[idx];\n  const lines = [];\n  for (let i=0;i<state.centers.length;i++){\n    const c = state.centers[i];\n    if (!c) continue;\n    const d = distance(p,c);\n    lines.push(`C${i}: d=${d.toFixed(6)} at (${c.x.toFixed(3)},${c.y.toFixed(3)})`);\n  }\n  lines.sort();\n  explainOut.textContent = `Point #${idx} (${p.x.toFixed(3)},${p.y.toFixed(3)}) assignments:\\n` + lines.join('\\n');\n});\n\n// Misc helpers\nfunction resetState(){\n  state.points = [];\n  state.centers = [];\n  state.iter = 0;\n  state.sseHistory = [];\n  state.running = false;\n  state.selectedPoint = null;\n  drawAll();\n  drawSSE();\n}\n\n// Initial small dataset\nstate.points = generateData('blobs', 150, 3);\ndrawAll();\n\n// Allow resizing canvas with window to maintain simple but functional UI\nwindow.addEventListener('resize', ()=>{ drawAll(); drawSSE(); });\n\n</script>\n</body>\n</html>"
