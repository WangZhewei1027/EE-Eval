    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<title>Circular Linked List — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071029;\n    --accent: #6EE7B7;\n    --accent-2: #7DD3FC;\n    --glass: rgba(255,255,255,0.04);\n    --soft: rgba(255,255,255,0.03);\n    --muted: rgba(255,255,255,0.6);\n    --node-size: 68px;\n    --circle-radius: 210px;\n    --duration: 8s;\n  }\n\n  *{box-sizing: border-box}\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(9,30,46,0.35), transparent 12%),\n                radial-gradient(900px 400px at 90% 90%, rgba(99,102,241,0.06), transparent 12%),\n                linear-gradient(180deg,var(--bg1), var(--bg2));\n    color:#e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated backdrop particles */\n  .backdrop{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    opacity:0.9;\n    mix-blend-mode: screen;\n  }\n  .backdrop svg{width:100%;height:100%;display:block}\n\n  .stage{\n    display:grid;\n    grid-template-columns: 560px 1fr;\n    gap:36px;\n    align-items:center;\n    height:100vh;\n    padding:64px;\n  }\n\n  .card{\n    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border-radius:20px;\n    padding:34px;\n    box-shadow:\n      0 10px 30px rgba(2,6,23,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  .header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n  }\n  .title{\n    display:flex;flex-direction:column;\n  }\n  .title h1{\n    margin:0;font-family:\"Playfair Display\",serif;\n    font-weight:400;\n    letter-spacing:-0.02em;\n    color: #f6fbff;\n    font-size:28px;\n    line-height:1;\n  }\n  .title p{\n    margin:6px 0 0 0;\n    font-size:13px;\n    color:var(--muted);\n    max-width:360px;\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    cursor:pointer;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    transition: all .28s cubic-bezier(.2,.9,.2,1);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n    backdrop-filter: blur(6px);\n  }\n  .btn:hover{\n    transform:translateY(-3px);\n    color: #e6fdf4;\n    border-color: rgba(125,211,252,0.18);\n  }\n  .btn.primary{\n    background: linear-gradient(90deg, rgba(124,58,237,0.14), rgba(59,130,246,0.06));\n    color: #e6f5ff;\n    border-color: rgba(125,211,252,0.14);\n  }\n\n  .panel{\n    margin-top:22px;\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .chip{\n    font-size:13px;\n    color:var(--muted);\n    background:linear-gradient(180deg, rgba(255,255,255,0.015), transparent);\n    border-radius:100px;\n    padding:8px 12px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Visual area */\n  .visual{\n    position:relative;\n    height:540px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    margin-top:18px;\n  }\n\n  .visual-stage{\n    width:520px;height:520px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .ring{\n    position:absolute;\n    width:520px;height:520px;\n    border-radius:50%;\n    background:\n      conic-gradient(from 180deg at 50% 50%, rgba(124,58,237,0.12), rgba(96,165,250,0.09), rgba(16,185,129,0.06), rgba(124,58,237,0.12));\n    filter: blur(30px);\n    opacity:0.16;\n    transform: scale(0.98);\n    pointer-events:none;\n  }\n\n  /* SVG full-size */\n  svg.diagram{\n    width:520px;height:520px;\n    overflow:visible;\n    display:block;\n  }\n\n  /* Node style */\n  .node{\n    position:absolute;\n    width:var(--node-size);\n    height:var(--node-size);\n    border-radius:50%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform-origin:center;\n    color:#042028;\n    font-weight:700;\n    font-size:20px;\n    box-shadow:\n      0 8px 26px rgba(9,12,24,0.6),\n      inset 0 -6px 18px rgba(255,255,255,0.03);\n    transition: transform .5s cubic-bezier(.2,.9,.2,1), box-shadow .28s;\n    user-select:none;\n  }\n\n  .node .label{\n    transform: translateY(-2px);\n    font-weight:800;\n    font-family:\"Inter\",sans-serif;\n    color:white;\n    text-shadow: 0 3px 20px rgba(0,0,0,0.45);\n  }\n\n  .node .sub{\n    position:absolute;\n    bottom:-18px;\n    left:50%;\n    transform:translateX(-50%);\n    font-size:11px;\n    color:rgba(255,255,255,0.6);\n    letter-spacing:0.02em;\n  }\n\n  /* Nodes look and glow */\n  .node[data-idx=\"0\"]{ background: linear-gradient(180deg,#7CE6C4,#3BD6B0); }\n  .node[data-idx=\"1\"]{ background: linear-gradient(180deg,#7DD3FC,#60A5FA); }\n  .node[data-idx=\"2\"]{ background: linear-gradient(180deg,#C7B6FF,#8B5CF6); }\n  .node[data-idx=\"3\"]{ background: linear-gradient(180deg,#FFC9A3,#FF7A59); }\n  .node[data-idx=\"4\"]{ background: linear-gradient(180deg,#FDE68A,#F59E0B); }\n  .node[data-idx=\"5\"]{ background: linear-gradient(180deg,#86EFAC,#22C55E); }\n  .node[data-idx=\"6\"]{ background: linear-gradient(180deg,#93C5FD,#6366F1); }\n  .node[data-idx=\"7\"]{ background: linear-gradient(180deg,#FBCFE8,#F472B6); }\n\n  /* Glow pulses */\n  .node::after{\n    content:\"\";\n    position:absolute;\n    inset:-6px;\n    border-radius:inherit;\n    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.06), transparent 20%);\n    opacity:1;\n    transition: opacity .28s;\n    pointer-events:none;\n  }\n\n  /* Emphasized pulsing when visited */\n  .node.pulse{\n    transform: scale(1.08);\n    box-shadow: 0 18px 40px rgba(56,102,255,0.12), 0 6px 30px rgba(2,6,23,0.6);\n  }\n\n  /* Central hub */\n  .hub{\n    position:absolute;\n    width:120px;height:120px;border-radius:50%;\n    display:flex;align-items:center;justify-content:center;\n    background: radial-gradient(60% 60% at 30% 30%, rgba(255,255,255,0.06), rgba(255,255,255,0.01)),\n                linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 12px 40px rgba(4,7,29,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    z-index:3;\n    pointer-events:none;\n  }\n  .hub .t{\n    font-family:\"Playfair Display\", serif;\n    font-weight:700;\n    color: #dffcf3;\n    font-size:16px;\n    text-align:center;\n    line-height:1;\n  }\n  .hub .s{\n    display:block;font-size:11px;color:var(--muted);font-weight:600;margin-top:6px;\n  }\n\n  /* orbiting token */\n  .orbit{\n    position:absolute;\n    width:520px;height:520px;left:0;top:0;\n    display:block;\n    z-index:6;\n    pointer-events:none;\n  }\n\n  .token{\n    position:absolute;\n    width:14px;height:14px;border-radius:50%;\n    background:linear-gradient(180deg,#fff,#e6f6ff);\n    box-shadow:0 8px 20px rgba(36,60,90,0.55), 0 0 22px rgba(109,213,255,0.14);\n    transform:translate(-50%,-50%);\n    mix-blend-mode: screen;\n    filter: drop-shadow(0 4px 12px rgba(99,102,241,0.12));\n    z-index:8;\n  }\n\n  /* spin animation */\n  .spin{\n    animation: rotate var(--duration) linear infinite;\n    transform-origin: 260px 260px; /* center of SVG 520/2 */\n  }\n  .paused .spin{ animation-play-state: paused; }\n\n  @keyframes rotate{\n    from{ transform: rotate(0deg); }\n    to{ transform: rotate(360deg); }\n  }\n\n  /* Arrows and links */\n  .links path{\n    stroke: linear-gradient(90deg,#7CE6C4,#7DD3FC);\n    stroke-width:2.8;\n    fill:none;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    opacity:0.9;\n    filter: drop-shadow(0 6px 18px rgba(0,0,0,0.45));\n  }\n  .links path.stroke-anim{\n    stroke: url(#grad);\n    stroke-dasharray: 12 6;\n    stroke-linecap:round;\n    animation: dash 2.6s linear infinite;\n  }\n  @keyframes dash{\n    to{ stroke-dashoffset: -40; }\n  }\n\n  /* Explanatory panel */\n  .explain{\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.55);\n    font-size:14px;color:var(--muted);\n    line-height:1.6;\n    max-width:640px;\n  }\n  .explain h3{\n    font-family:\"Playfair Display\",serif;\n    margin:0 0 8px 0;\n    color:#f9ffff;\n    font-weight:400;\n  }\n  .explain p{ margin:0 0 12px 0;}\n  .note{\n    margin-top:12px;\n    font-size:13px;color:rgba(255,255,255,0.55);\n  }\n\n  /* footer small */\n  .footer{\n    margin-top:18px;font-size:12px;color:rgba(255,255,255,0.45);\n  }\n\n  /* Responsive */\n  @media (max-width:1100px){\n    .stage{ grid-template-columns: 1fr; padding:36px; gap:22px; align-items:start; }\n    .visual{ order: -1; }\n    .visual-stage{ margin:0 auto; }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"backdrop\" aria-hidden=\"true\">\n    <!-- Decorative animated gradient shapes -->\n    <svg preserveAspectRatio=\"none\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\" >\n      <defs>\n        <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#7DD3FC\" stop-opacity=\"0.12\"/>\n          <stop offset=\"1\" stop-color=\"#7CE6C4\" stop-opacity=\"0.06\"/>\n        </linearGradient>\n        <linearGradient id=\"g2\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#C7B6FF\" stop-opacity=\"0.09\"/>\n          <stop offset=\"1\" stop-color=\"#FBCFE8\" stop-opacity=\"0.03\"/>\n        </linearGradient>\n      </defs>\n      <g transform=\"translate(8,12) rotate(-12)\">\n        <ellipse cx=\"10\" cy=\"85\" rx=\"24\" ry=\"8\" fill=\"url(#g1)\">\n          <animate attributeName=\"cx\" dur=\"24s\" values=\"10;28;5;18;10\" repeatCount=\"indefinite\"/>\n        </ellipse>\n      </g>\n      <g transform=\"translate(60,6) rotate(6)\">\n        <ellipse cx=\"10\" cy=\"85\" rx=\"30\" ry=\"10\" fill=\"url(#g2)\">\n          <animate attributeName=\"cy\" dur=\"28s\" values=\"85;65;95;85\" repeatCount=\"indefinite\"/>\n        </ellipse>\n      </g>\n    </svg>\n  </div>\n\n  <div class=\"stage\">\n    <div class=\"card\" style=\"width:580px\">\n      <div class=\"header\">\n        <div class=\"title\">\n          <h1>Circular Linked List</h1>\n          <p>A refined, visual metaphor for a linked list where the final node loops back to the first — creating a circular structure. Observe the flow; interaction is intentionally minimal.</p>\n        </div>\n        <div class=\"controls\" role=\"group\" aria-label=\"controls\">\n          <button id=\"toggleBtn\" class=\"btn primary\" title=\"Play / Pause animation\">Pause</button>\n          <button id=\"shuffleBtn\" class=\"btn\" title=\"Shuffle node values\">Shuffle</button>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <div class=\"chip\">Nodes: <strong id=\"nodeCount\" style=\"margin-left:8px\">8</strong></div>\n        <div class=\"chip\">Speed: <strong style=\"margin-left:8px\">1×</strong></div>\n      </div>\n\n      <div class=\"visual\">\n        <div class=\"visual-stage\">\n          <div class=\"ring\"></div>\n\n          <svg class=\"diagram\" viewBox=\"0 0 520 520\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"grad\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#6EE7B7\"/>\n                <stop offset=\"1\" stop-color=\"#7DD3FC\"/>\n              </linearGradient>\n              <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"8\" refX=\"8\" refY=\"4\" orient=\"auto\" markerUnits=\"strokeWidth\">\n                <path d=\"M0,0 L8,4 L0,8 z\" fill=\"#dffcf3\" opacity=\"0.95\"/>\n              </marker>\n            </defs>\n\n            <g class=\"links\" id=\"links\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.6\"></g>\n\n            <!-- overlay group used for rotating token (spin) -->\n            <g class=\"spin\" id=\"spinGroup\">\n              <!-- central hub and nodes are not in SVG; token will be placed in HTML to overlay -->\n            </g>\n\n          </svg>\n\n          <div class=\"hub\" aria-hidden=\"true\">\n            <div>\n              <div class=\"t\">HEAD</div>\n              <span class=\"s\">Circular reference</span>\n            </div>\n          </div>\n\n          <!-- Nodes placed absolutely -->\n          <div id=\"nodesContainer\" style=\"position:absolute; width:520px; height:520px; left:0; top:0;\">\n            <!-- 8 nodes -->\n            <div class=\"node\" data-idx=\"0\"><span class=\"label\">A</span><span class=\"sub\">0x1a</span></div>\n            <div class=\"node\" data-idx=\"1\"><span class=\"label\">B</span><span class=\"sub\">0x2b</span></div>\n            <div class=\"node\" data-idx=\"2\"><span class=\"label\">C</span><span class=\"sub\">0x3c</span></div>\n            <div class=\"node\" data-idx=\"3\"><span class=\"label\">D</span><span class=\"sub\">0x4d</span></div>\n            <div class=\"node\" data-idx=\"4\"><span class=\"label\">E</span><span class=\"sub\">0x5e</span></div>\n            <div class=\"node\" data-idx=\"5\"><span class=\"label\">F</span><span class=\"sub\">0x6f</span></div>\n            <div class=\"node\" data-idx=\"6\"><span class=\"label\">G</span><span class=\"sub\">0x7g</span></div>\n            <div class=\"node\" data-idx=\"7\"><span class=\"label\">H</span><span class=\"sub\">0x8h</span></div>\n          </div>\n\n          <!-- rotating token element -->\n          <div class=\"orbit spin\" aria-hidden=\"true\">\n            <div class=\"token\" id=\"token\" style=\"left:260px; top:40px;\"></div>\n          </div>\n\n        </div>\n      </div>\n\n      <div class=\"footer\" style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <div>Minimal controls • Observation-focused</div>\n        <div style=\"font-size:12px;color:rgba(255,255,255,0.45)\">Concept visualization • Aesthetic UX</div>\n      </div>\n    </div>\n\n    <div class=\"explain card\">\n      <h3>How to read this illustration</h3>\n      <p>The nodes arranged around the ring represent elements of a linked list. Each link (arrow) points to the next node; the last connection loops back to the first — forming a continuous circle. The glowing token orbits the ring to show traversal flow over time. Nodes lightly pulse as the token passes, visually representing visitation.</p>\n\n      <p class=\"note\"><strong>Key ideas:</strong> Single-direction links, a head pointer, and a cyclical end-to-start connection. Unlike a linear list, a circular linked list has no null terminator — traversal can continue indefinitely.</p>\n    </div>\n\n  </div>\n\n<script>\n(function(){\n  const N = 8;\n  const container = document.getElementById('nodesContainer');\n  const nodes = Array.from(container.querySelectorAll('.node'));\n  const linksGroup = document.getElementById('links');\n  const token = document.getElementById('token');\n  const spinGroup = document.getElementById('spinGroup');\n  const root = document.documentElement;\n  const stageSize = 520;\n  const center = { x: stageSize/2, y: stageSize/2 };\n  const radius = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--circle-radius')) || 210;\n  const duration = 8000; // ms\n  const pauseClass = 'paused';\n\n  // Place nodes around a circle\n  function placeNodes() {\n    nodes.forEach((el, i) => {\n      const angle = (i / N) * Math.PI * 2 - Math.PI/2; // start at top\n      const x = center.x + Math.cos(angle) * radius;\n      const y = center.y + Math.sin(angle) * radius;\n      el.style.left = (x - el.offsetWidth/2) + 'px';\n      el.style.top = (y - el.offsetHeight/2) + 'px';\n      el.dataset.angle = angle;\n    });\n  }\n\n  // Build curved links between nodes\n  function buildLinks() {\n    linksGroup.innerHTML = '';\n    for (let i=0;i<N;i++){\n      const a = nodes[i];\n      const b = nodes[(i+1)%N];\n      const aRect = a.getBoundingClientRect();\n      const bRect = b.getBoundingClientRect();\n      // coordinates relative to SVG (0..520)\n      const ax = a.offsetLeft + a.offsetWidth/2;\n      const ay = a.offsetTop + a.offsetHeight/2;\n      const bx = b.offsetLeft + b.offsetWidth/2;\n      const by = b.offsetTop + b.offsetHeight/2;\n      // mid point and outward control\n      const mx = (ax + bx)/2;\n      const my = (ay + by)/2;\n      // compute outward normal to create a gentle arc\n      const dx = bx - ax;\n      const dy = by - ay;\n      const len = Math.sqrt(dx*dx+dy*dy) || 1;\n      const nx = -dy/len;\n      const ny = dx/len;\n      const curveFactor = 42; // how pronounced the arc is\n      const cx = mx + nx * curveFactor;\n      const cy = my + ny * curveFactor;\n      // shrink endpoints a bit so arrows don't overlap node circles\n      const shrink = 26;\n      const ax2 = ax + (dx/len)*shrink;\n      const ay2 = ay + (dy/len)*shrink;\n      const bx2 = bx - (dx/len)*shrink;\n      const by2 = by - (dy/len)*shrink;\n\n      const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n      path.setAttribute('d', `M ${ax2.toFixed(2)} ${ay2.toFixed(2)} Q ${cx.toFixed(2)} ${cy.toFixed(2)} ${bx2.toFixed(2)} ${by2.toFixed(2)}`);\n      path.setAttribute('stroke','url(#grad)');\n      path.setAttribute('marker-end','url(#arrowhead)');\n      path.classList.add('stroke-anim');\n      linksGroup.appendChild(path);\n    }\n  }\n\n  // Token animation around a perfect circle centered at center\n  let animRef = null;\n  let startTime = null;\n  let playing = true;\n\n  function animateToken(ts) {\n    if (!startTime) startTime = ts;\n    const elapsed = (ts - startTime) % duration;\n    const t = elapsed / duration; // 0..1\n    const angle = t * Math.PI * 2 - Math.PI/2;\n    const tx = center.x + Math.cos(angle) * radius;\n    const ty = center.y + Math.sin(angle) * radius;\n    token.style.left = tx + 'px';\n    token.style.top = ty + 'px';\n\n    // Determine which node is nearest to the token and pulse it briefly\n    const idx = Math.round(((angle + Math.PI/2) / (Math.PI*2)) * N) % N;\n    const index = (idx + N) % N;\n    pulseNode(index);\n\n    animRef = requestAnimationFrame(animateToken);\n  }\n\n  // Gentle pulsing: uses CSS class toggled briefly\n  let lastPulsed = -1;\n  function pulseNode(i){\n    if (lastPulsed === i) return;\n    lastPulsed = i;\n    const el = nodes[i];\n    el.classList.add('pulse');\n    setTimeout(()=> {\n      el.classList.remove('pulse');\n      lastPulsed = -1;\n    }, 480);\n  }\n\n  // Toggle play/pause by toggling a class on document.body\n  const toggleBtn = document.getElementById('toggleBtn');\n  toggleBtn.addEventListener('click', ()=>{\n    playing = !playing;\n    if (!playing){\n      document.body.classList.add(pauseClass);\n      toggleBtn.textContent = 'Play';\n      cancelAnimationFrame(animRef);\n      animRef = null;\n    } else {\n      document.body.classList.remove(pauseClass);\n      toggleBtn.textContent = 'Pause';\n      startTime = null;\n      animRef = requestAnimationFrame(animateToken);\n    }\n  });\n\n  // Shuffle node labels (simple quick visual change)\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const labels = [\"α\",\"β\",\"γ\",\"δ\",\"ε\",\"ζ\",\"η\",\"θ\",\"A\",\"B\",\"C\",\"D\",\"E\",\"F\",\"G\",\"H\",\"₁\",\"₂\",\"₃\",\"₄\"];\n  function shuffleValues(){\n    const used = [];\n    nodes.forEach((el,i)=>{\n      // pick random label and random addr-like hex suffix\n      const lab = labels[Math.floor(Math.random()*labels.length)];\n      const hex = (Math.floor(Math.random()*256)).toString(16).padStart(2,'0');\n      el.querySelector('.label').textContent = lab;\n      el.querySelector('.sub').textContent = '0x' + hex;\n      // animate a small pop\n      el.style.transform = 'scale(1.12)';\n      setTimeout(()=> el.style.transform = '', 340);\n    });\n  }\n  shuffleBtn.addEventListener('click', shuffleValues);\n\n  // initial setup\n  function init(){\n    placeNodes();\n    buildLinks();\n    // start token animation\n    animRef = requestAnimationFrame(animateToken);\n\n    // reposition hub center\n    const hub = document.querySelector('.hub');\n    hub.style.left = (center.x - hub.offsetWidth/2) + 'px';\n    hub.style.top = (center.y - hub.offsetHeight/2) + 'px';\n\n    // small stagger micro-animations for nodes (visual flourish)\n    nodes.forEach((el,i)=>{\n      el.style.transitionDelay = (i * 40) + 'ms';\n    });\n\n    // set node count display\n    document.getElementById('nodeCount').textContent = N;\n  }\n\n  // Rebuild on resize for correctness\n  window.addEventListener('resize', ()=> {\n    placeNodes();\n    buildLinks();\n    const hub = document.querySelector('.hub');\n    hub.style.left = (center.x - hub.offsetWidth/2) + 'px';\n    hub.style.top = (center.y - hub.offsetHeight/2) + 'px';\n  });\n\n  // Kick off\n  init();\n\n  // Gentle attention: pause animations when not visible\n  document.addEventListener('visibilitychange', ()=>{\n    if (document.hidden){\n      if (!document.body.classList.contains(pauseClass)){\n        toggleBtn.dataset._wasPlaying = '1';\n        toggleBtn.click();\n      }\n    } else {\n      if (toggleBtn.dataset._wasPlaying === '1'){\n        toggleBtn.dataset._wasPlaying = '';\n        toggleBtn.click();\n      }\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
