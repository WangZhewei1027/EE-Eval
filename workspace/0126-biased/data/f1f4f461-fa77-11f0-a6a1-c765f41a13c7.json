  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Binary Search Tree — A Visual Elegance</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #081028;\n    --card: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --accent-1: #7ee7c7;\n    --accent-2: #7a7bff;\n    --accent-3: #ff9bb3;\n    --glass: rgba(255,255,255,0.02);\n    --glass-2: rgba(255,255,255,0.03);\n  }\n\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(122,123,255,0.12), transparent),\n                radial-gradient(900px 500px at 90% 90%, rgba(255,155,179,0.06), transparent),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color:#e9eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:36px;\n    overflow:hidden;\n  }\n\n  .stage{\n    width:min(1200px,98vw);\n    height:min(760px,90vh);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:grid;\n    grid-template-columns: 1fr 380px;\n    gap:28px;\n    padding:28px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* left canvas area */\n  .canvas-wrap{\n    position:relative;\n    border-radius:16px;\n    overflow:hidden;\n    padding:22px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006)),\n      radial-gradient(600px 200px at 10% 10%, rgba(122,123,255,0.06), transparent);\n    box-shadow: inset 0 0 40px rgba(7,9,20,0.25);\n  }\n\n  /* right panel */\n  .panel{\n    padding:20px 22px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:stretch;\n  }\n\n  h1{\n    margin:0;\n    font-weight:700;\n    letter-spacing:-0.02em;\n    font-size:20px;\n    color: #f7fbff;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  .title-accent{\n    display:inline-flex;\n    width:44px;\n    height:44px;\n    border-radius:10px;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    font-size:14px;\n    color:var(--bg-1);\n    background: linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    box-shadow: 0 6px 20px rgba(122,123,255,0.12), 0 2px 6px rgba(0,0,0,0.4);\n  }\n\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.35;\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:6px;\n  }\n\n  button.btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:10px;\n    font-weight:600;\n    cursor:pointer;\n    font-size:13px;\n    color:var(--bg-1);\n    transition:transform .18s ease, box-shadow .18s ease;\n    box-shadow: 0 6px 18px rgba(6,8,23,0.5);\n  }\n  button.btn:active{transform:translateY(1px)}\n  .btn-primary{\n    background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n  }\n  .btn-ghost{\n    background: transparent;\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    box-shadow:none;\n  }\n\n  .sequence{\n    display:flex;\n    gap:8px;\n    flex-wrap:wrap;\n    padding:10px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .chip{\n    padding:8px 10px;\n    border-radius:999px;\n    font-weight:700;\n    font-size:13px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.02);\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    min-width:36px;\n    text-align:center;\n  }\n\n  .meta{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .legend{\n    margin-top:auto;\n    display:flex;\n    gap:10px;\n    align-items:center;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* SVG styles */\n  svg { width:100%; height:100%; display:block; overflow:visible }\n\n  .edge{\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:3;\n    stroke-linecap:round;\n    filter: drop-shadow(0 6px 18px rgba(122,123,255,0.06));\n  }\n\n  .edge-ink{\n    stroke: url(#grad-edge);\n    stroke-width:3.4;\n    stroke-linecap:round;\n    fill:none;\n  }\n\n  .node{\n    cursor:default;\n    transform-origin:center;\n    transition: transform 260ms cubic-bezier(.22,.9,.33,1), filter 300ms;\n  }\n  .node circle{\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1.5px;\n  }\n  .node .label{\n    font-weight:700;\n    font-size:13px;\n    fill:#061226;\n    paint-order:stroke;\n    stroke: rgba(255,255,255,0.02);\n    stroke-width:2px;\n  }\n\n  .pulse{\n    fill:none;\n    stroke:rgba(126,231,199,0.9);\n    stroke-width:6;\n    opacity:0;\n    transform-origin:center;\n  }\n\n  .comp-highlight{\n    animation: compPulse 700ms ease-out 1;\n  }\n  @keyframes compPulse{\n    0%{opacity:0; transform:scale(0.9)}\n    30%{opacity:0.9; transform:scale(1.25)}\n    100%{opacity:0}\n  }\n\n  .spawn-glow{\n    position:absolute;\n    top:20px;\n    left:50%;\n    transform:translateX(-50%);\n    width:360px;\n    height:140px;\n    background: radial-gradient(closest-side, rgba(122,123,255,0.08), transparent 50%),\n                conic-gradient(from 200deg at 50% 50%, rgba(126,231,199,0.04), transparent 40%);\n    filter: blur(40px);\n    pointer-events:none;\n    mix-blend-mode:screen;\n  }\n\n  .footer-note{\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  /* Node visual */\n  .node-bg{\n    fill: url(#grad-node);\n    filter: drop-shadow(0 6px 18px rgba(0,0,0,0.5));\n  }\n  .node-gloss{\n    fill: url(#gloss);\n    opacity:0.35;\n    pointer-events:none;\n  }\n\n  /* responsive small screens */\n  @media (max-width:980px){\n    .stage{grid-template-columns: 1fr}\n    .panel{order:2}\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"stage\" role=\"main\" aria-label=\"Binary Search Tree visualization\">\n    <div class=\"canvas-wrap\">\n      <div class=\"spawn-glow\" aria-hidden=\"true\"></div>\n      <!-- SVG tree area -->\n      <svg id=\"treeSvg\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n          <linearGradient id=\"grad-edge\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#7ee7c7\"/>\n            <stop offset=\"100%\" stop-color=\"#7a7bff\"/>\n          </linearGradient>\n          <linearGradient id=\"grad-node\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.95\"/>\n            <stop offset=\"24%\" stop-color=\"#dbefff\" stop-opacity=\"0.8\"/>\n            <stop offset=\"100%\" stop-color=\"#7a7bff\" stop-opacity=\"0.12\"/>\n          </linearGradient>\n          <radialGradient id=\"gloss\" cx=\"30%\" cy=\"22%\">\n            <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.85\"/>\n            <stop offset=\"50%\" stop-color=\"#ffffff\" stop-opacity=\"0.2\"/>\n            <stop offset=\"100%\" stop-color=\"#ffffff\" stop-opacity=\"0.0\"/>\n          </radialGradient>\n\n          <filter id=\"softShadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feDropShadow dx=\"0\" dy=\"6\" stdDeviation=\"20\" flood-color=\"#00000033\"/>\n          </filter>\n        </defs>\n\n        <!-- edges will be appended here -->\n        <g id=\"edgesLayer\"></g>\n        <!-- nodes -->\n        <g id=\"nodesLayer\"></g>\n\n        <!-- subtle grid / decorative -->\n        <g opacity=\"0.03\" id=\"decor\">\n          <rect x=\"0\" y=\"0\" width=\"1000\" height=\"640\" fill=\"none\"></rect>\n        </g>\n      </svg>\n    </div>\n\n    <aside class=\"panel\" aria-hidden=\"false\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;\">\n        <h1><span class=\"title-accent\">BST</span>Binary Search Tree</h1>\n      </div>\n\n      <p class=\"lead\">Observe a curated animation that builds a Binary Search Tree from a fixed sequence of values. Each insertion highlights the decision path and the new node gracefully finding its place within a balanced visual layout. Aesthetic focus with minimal controls.</p>\n\n      <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n        <button id=\"btnAnimate\" class=\"btn btn-primary\" title=\"Animate the BST build\">Animate Build</button>\n        <button id=\"btnReset\" class=\"btn btn-ghost\" title=\"Reset to initial state\">Reset</button>\n      </div>\n\n      <div>\n        <div style=\"font-size:13px;color:var(--muted);margin-bottom:8px;\">Insertion sequence</div>\n        <div class=\"sequence\" id=\"sequenceList\"></div>\n      </div>\n\n      <div class=\"meta\">\n        <div class=\"footer-note\">Conceptual demo • Order and structure determined by BST insertion rules.</div>\n      </div>\n\n      <div class=\"legend\">\n        <div style=\"display:flex;gap:8px;align-items:center\"><svg width=\"12\" height=\"12\"><rect width=\"12\" height=\"12\" rx=\"3\" fill=\"#7ee7c7\"/></svg> comparison</div>\n        <div style=\"display:flex;gap:8px;align-items:center\"><svg width=\"12\" height=\"12\"><rect width=\"12\" height=\"12\" rx=\"3\" fill=\"#7a7bff\"/></svg> new node</div>\n      </div>\n    </aside>\n  </div>\n\n<script>\n(function(){\n  // Sequence to visualize (fixed, curated)\n  const sequence = [50, 30, 70, 20, 40, 60, 80, 10, 25, 35, 45];\n\n  // DOM refs\n  const svg = document.getElementById('treeSvg');\n  const edgesLayer = document.getElementById('edgesLayer');\n  const nodesLayer = document.getElementById('nodesLayer');\n  const seqList = document.getElementById('sequenceList');\n  const btnAnimate = document.getElementById('btnAnimate');\n  const btnReset = document.getElementById('btnReset');\n\n  // Present the sequence as chips\n  sequence.forEach(v=>{\n    const chip = document.createElement('div');\n    chip.className = 'chip';\n    chip.textContent = String(v);\n    seqList.appendChild(chip);\n  });\n\n  // Build final BST structure (so we know final positions)\n  class TNode {\n    constructor(v){\n      this.v = v; this.left = null; this.right = null; this.parent = null;\n    }\n  }\n\n  function buildFinalTree(arr){\n    let root = null;\n    const map = new Map();\n    const nodes = [];\n    arr.forEach(v=>{\n      const node = new TNode(v);\n      map.set(v,node);\n      nodes.push(node);\n      if(!root){ root = node; return; }\n      let cur = root;\n      while(true){\n        if(v < cur.v){\n          if(cur.left === null){ cur.left = node; node.parent = cur; break;}\n          cur = cur.left;\n        } else {\n          if(cur.right === null){ cur.right = node; node.parent = cur; break;}\n          cur = cur.right;\n        }\n      }\n    });\n    return {root, map, nodes};\n  }\n\n  const final = buildFinalTree(sequence);\n\n  // Compute layout via inorder x positions and depth-based y\n  function computeLayout(root){\n    let idx = 0;\n    const positions = new Map();\n    let maxDepth = 0;\n    function inorder(n, depth){\n      if(!n) return;\n      inorder(n.left, depth+1);\n      const xIndex = idx++;\n      positions.set(n.v, {index:xIndex, depth});\n      maxDepth = Math.max(maxDepth, depth);\n      inorder(n.right, depth+1);\n    }\n    inorder(root, 0);\n\n    const horizontalSpacing = 88;\n    const verticalSpacing = 86;\n    const marginX = 60;\n    positions.forEach((v,k)=>{\n      const px = marginX + v.index * horizontalSpacing;\n      const py = 48 + v.depth * verticalSpacing;\n      positions.set(k, {...v, x: px, y: py});\n    });\n    return {positions, width: Math.max(700, marginX*2 + (idx-1)*horizontalSpacing + 120), height: 48 + (maxDepth+1)*verticalSpacing + 40 };\n  }\n\n  const layout = computeLayout(final.root);\n  // adjust svg viewBox to layout\n  function setViewBox(){\n    const vbW = layout.width;\n    const vbH = layout.height;\n    svg.setAttribute('viewBox', `0 0 ${vbW} ${vbH}`);\n  }\n  setViewBox();\n\n  // Map parent relationships and pos\n  const nodeInfo = {}; // v -> {x,y,parent}\n  final.map.forEach((node, v)=>{\n    const pos = layout.positions.get(v);\n    const parent = node.parent ? node.parent.v : null;\n    nodeInfo[v] = {x: pos.x, y: pos.y, depth: pos.depth, parent};\n  });\n\n  // Reset scene\n  function clearScene(){\n    edgesLayer.innerHTML = '';\n    nodesLayer.innerHTML = '';\n  }\n\n  clearScene();\n\n  // Utility: create node SVG group\n  function createNodeElement(value){\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.classList.add('node');\n    g.setAttribute('data-value', value);\n    // group content: pulse ring, main circle, gloss, text\n    const pulse = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    pulse.setAttribute('r', 26);\n    pulse.setAttribute('class','pulse');\n    pulse.setAttribute('cx',0);\n    pulse.setAttribute('cy',0);\n    g.appendChild(pulse);\n\n    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circle.setAttribute('r', 22);\n    circle.setAttribute('cx',0);\n    circle.setAttribute('cy',0);\n    circle.setAttribute('class','node-bg');\n    g.appendChild(circle);\n\n    const gloss = document.createElementNS('http://www.w3.org/2000/svg','path');\n    gloss.setAttribute('d','M-18 -14 C -8 -22, 8 -22, 18 -14 L 18 -6 C 8 -14, -8 -14, -18 -6 Z');\n    gloss.setAttribute('class','node-gloss');\n    g.appendChild(gloss);\n\n    const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n    label.setAttribute('class','label');\n    label.setAttribute('text-anchor','middle');\n    label.setAttribute('dy','5');\n    label.textContent = String(value);\n    g.appendChild(label);\n\n    // initial transform near top center spawn\n    g.setAttribute('transform', `translate(${layout.width/2} ${20})`);\n    return g;\n  }\n\n  // Create edge path between parent and child (invisible initially)\n  function createEdgeElement(parentVal, childVal){\n    const p = nodeInfo[parentVal];\n    const c = nodeInfo[childVal];\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    path.setAttribute('class','edge-ink');\n    // draw a smooth curve: cubic bezier\n    const dx = Math.abs(c.x - p.x);\n    const cpOffset = Math.min(60, dx * 0.4) + 20;\n    const dir = c.y > p.y ? 1 : -1;\n    const d = `M ${p.x} ${p.y+22} C ${p.x} ${p.y+22 + cpOffset} ${c.x} ${c.y-22 - cpOffset} ${c.x} ${c.y-22}`;\n    path.setAttribute('d', d);\n    path.setAttribute('fill','none');\n    path.style.strokeDasharray = '1 2000';\n    path.style.strokeDashoffset = '2000';\n    path.style.opacity = '0.95';\n    return path;\n  }\n\n  // Highlight a node (pulse)\n  function highlightNode(val, duration=450){\n    return new Promise(res=>{\n      const g = nodesLayer.querySelector(`g.node[data-value='${val}']`);\n      if(!g){ res(); return; }\n      const pulse = g.querySelector('.pulse');\n      pulse.classList.add('comp-highlight');\n      pulse.style.opacity = '0.9';\n      setTimeout(()=>{\n        pulse.classList.remove('comp-highlight');\n        pulse.style.opacity = '0';\n        res();\n      }, duration);\n    });\n  }\n\n  // Animate movement of a node element to target x,y with easing\n  function animateMoveTo(g, from, to, duration=900){\n    return new Promise(resolve=>{\n      const start = performance.now();\n      function ease(t){ return (--t)*t*t+1 } // cubic out approximate\n      function frame(now){\n        const t = Math.min(1, (now - start)/duration);\n        const e = ease(t);\n        const cx = from.x + (to.x - from.x) * e;\n        const cy = from.y + (to.y - from.y) * e;\n        g.setAttribute('transform', `translate(${cx} ${cy})`);\n        // subtle scale effect while moving\n        const scale = 0.96 + 0.08 * e;\n        g.style.transform = `scale(${scale})`;\n        if(t < 1) requestAnimationFrame(frame);\n        else {\n          // settle\n          g.style.transform = 'scale(1)';\n          resolve();\n        }\n      }\n      requestAnimationFrame(frame);\n    });\n  }\n\n  // Animate stroke drawing\n  function animateStroke(pathEl, duration=700){\n    return new Promise(res=>{\n      const len = pathEl.getTotalLength();\n      pathEl.style.strokeDasharray = String(len) + ' ' + String(len);\n      pathEl.style.strokeDashoffset = String(len);\n      pathEl.getBoundingClientRect(); // force repaint\n      const start = performance.now();\n      function frame(now){\n        const t = Math.min(1, (now - start)/duration);\n        const e = 1 - Math.pow(1 - t, 3); // ease out cubic\n        pathEl.style.strokeDashoffset = String(Math.round(len * (1 - e)));\n        if(t < 1) requestAnimationFrame(frame);\n        else { pathEl.style.strokeDashoffset = '0'; res(); }\n      }\n      requestAnimationFrame(frame);\n    });\n  }\n\n  // Insert edges permanently: after drawing, we keep a subtle static edge behind\n  function createStaticEdge(parentVal, childVal){\n    const p = nodeInfo[parentVal];\n    const c = nodeInfo[childVal];\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    path.setAttribute('class','edge');\n    const dx = Math.abs(c.x - p.x);\n    const cpOffset = Math.min(60, dx * 0.4) + 20;\n    const d = `M ${p.x} ${p.y+22} C ${p.x} ${p.y+22 + cpOffset} ${c.x} ${c.y-22 - cpOffset} ${c.x} ${c.y-22}`;\n    path.setAttribute('d', d);\n    return path;\n  }\n\n  // Sequence: animate insertions one by one\n  let running = false;\n  async function animateSequence(){\n    if(running) return;\n    running = true;\n    btnAnimate.disabled = true;\n    btnReset.disabled = true;\n    clearScene();\n\n    const insertedSet = new Set();\n\n    // helper to find path of comparisons for value based on insertedSet\n    function findPathForInsert(v){\n      const path = [];\n      if(insertedSet.size === 0) return path;\n      let cur = final.root;\n      while(cur){\n        path.push(cur.v);\n        if(v < cur.v){\n          if(cur.left && insertedSet.has(cur.left.v)) cur = cur.left;\n          else break;\n        } else {\n          if(cur.right && insertedSet.has(cur.right.v)) cur = cur.right;\n          else break;\n        }\n      }\n      return path;\n    }\n\n    for(let i=0;i<sequence.length;i++){\n      const val = sequence[i];\n      // create visual node element at spawn\n      const g = createNodeElement(val);\n      nodesLayer.appendChild(g);\n\n      // if this is root insertion (no prior nodes) - just pop into place\n      if(insertedSet.size === 0){\n        // small intro pulse\n        await new Promise(r=> setTimeout(r,140));\n        const target = {x: nodeInfo[val].x, y: nodeInfo[val].y};\n        await animateMoveTo(g, {x: layout.width/2, y:20}, target, 800);\n        // finalize node appearance\n        g.style.transition = 'transform 280ms cubic-bezier(.22,.9,.33,1)';\n        g.setAttribute('transform', `translate(${target.x} ${target.y})`);\n        insertedSet.add(val);\n        // slight scale / glow\n        g.style.filter = 'drop-shadow(0 10px 28px rgba(122,123,255,0.12))';\n        await new Promise(r=> setTimeout(r,120));\n        continue;\n      }\n\n      // else: compute comparison path\n      const path = findPathForInsert(val);\n\n      // Sequentially highlight nodes on path\n      for(const pv of path){\n        // Put a short delay and highlight\n        await highlightNode(pv, 420);\n        await new Promise(r=> setTimeout(r, 80));\n      }\n\n      // find parent (last node on path)\n      const parentVal = path.length ? path[path.length-1] : null;\n      const parentPos = parentVal !== null ? nodeInfo[parentVal] : null;\n      const finalPos = nodeInfo[val];\n\n      // create a transient edge element (ink) for animation\n      const transientEdge = createEdgeElement(parentVal, val);\n      edgesLayer.appendChild(transientEdge);\n\n      // Animate edge and node movement in parallel\n      const from = {x: layout.width/2, y:20};\n      const to = {x: finalPos.x, y: finalPos.y};\n      // animate both\n      await Promise.all([\n        animateMoveTo(g, from, to, 920),\n        animateStroke(transientEdge, 820)\n      ]);\n\n      // after animation, convert edge to permanent subtle edge, and remove transient\n      const staticEdge = createStaticEdge(parentVal, val);\n      edgesLayer.appendChild(staticEdge);\n      transientEdge.remove();\n\n      // finalize node: firmly set transform and add subtle shadow\n      g.setAttribute('transform', `translate(${to.x} ${to.y})`);\n      g.style.filter = 'drop-shadow(0 8px 26px rgba(7,9,20,0.65))';\n      g.style.transition = 'transform 260ms cubic-bezier(.22,.9,.33,1)';\n      // small pop\n      g.style.transform = 'scale(1.06)';\n      await new Promise(r=> setTimeout(r, 140));\n      g.style.transform = 'scale(1)';\n\n      insertedSet.add(val);\n      // little pause before next insertion\n      await new Promise(r=> setTimeout(r, 180));\n    }\n\n    // final ambient flourish: gently pulse root and fade in tiny labels\n    const nodes = nodesLayer.querySelectorAll('g.node');\n    nodes.forEach((n,i)=>{\n      n.style.transition = `transform 600ms cubic-bezier(.22,.9,.33,1) ${i*18}ms`;\n      n.style.transformOrigin = 'center';\n      n.style.transform = 'scale(1)';\n    });\n\n    await new Promise(r=> setTimeout(r, 360));\n    running = false;\n    btnReset.disabled = false;\n  }\n\n  // Reset button\n  btnReset.addEventListener('click', ()=>{\n    running = false;\n    btnAnimate.disabled = false;\n    btnReset.disabled = true;\n    clearScene();\n  });\n\n  // Animate button\n  btnAnimate.addEventListener('click', async ()=>{\n    btnAnimate.disabled = true;\n    btnReset.disabled = true;\n    await animateSequence();\n    btnAnimate.disabled = false;\n    btnReset.disabled = false;\n  });\n\n  // Initially disable reset (clean state)\n  btnReset.disabled = true;\n\n  // Small accessibility: pressing space on Animate triggers\n  btnAnimate.addEventListener('keyup', (e)=>{ if(e.key === 'Enter' || e.key === ' ') btnAnimate.click(); });\n  btnReset.addEventListener('keyup', (e)=>{ if(e.key === 'Enter' || e.key === ' ') btnReset.click(); });\n\n  // Add an initial decorative faint layout skeleton (final positions faint dots)\n  (function drawGuides(){\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('opacity','0.06');\n    final.map.forEach((node, v)=>{\n      const pos = nodeInfo[v];\n      const d = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      d.setAttribute('cx', pos.x);\n      d.setAttribute('cy', pos.y);\n      d.setAttribute('r', 2.5);\n      d.setAttribute('fill','#fff');\n      g.appendChild(d);\n    });\n    svg.appendChild(g);\n  })();\n\n})();\n</script>\n</body>\n</html>"
  },
  "messages": [
