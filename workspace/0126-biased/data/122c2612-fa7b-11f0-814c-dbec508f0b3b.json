    "content": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <title>PageRank</title>\n    <style>\n        body {\n            font-family: monospace;\n            font-size: 12px;\n            text-align: center;\n            margin: 0;\n            padding: 0;\n            background-color: #f0f0f0;\n        }\n        #input-container {\n            width: 50%;\n            margin: 0 auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #input-container input {\n            padding: 10px;\n            width: 100%;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n        #button-container {\n            margin-top: 20px;\n        }\n        #button-container button {\n            padding: 10px 20px;\n            width: 100%;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        #button-container button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"input-container\">\n        <input type=\"text\" id=\"source-url\" placeholder=\"Enter URL\">\n        <input type=\"number\" id=\"max-iterations\" placeholder=\"Max iterations\">\n        <input type=\"number\" id=\" damping-factor\" placeholder=\"Damping factor\">\n        <input type=\"number\" id=\"initial-link-count\" placeholder=\"Initial link count\">\n        <button id=\"calculate-btn\">Calculate PageRank</button>\n        <button id=\"reset-btn\">Reset</button>\n    </div>\n    <div id=\"button-container\">\n        <button id=\"previous-btn\">Previous</button>\n        <button id=\"next-btn\">Next</button>\n        <button id=\"clear-btn\">Clear</button>\n    </div>\n\n    <script>\n        let sourceUrl = document.getElementById('source-url').value;\n        let maxIterations = parseInt(document.getElementById('max-iterations').value);\n        let dampingFactor = parseFloat(document.getElementById('damping-factor').value);\n        let initialLinkCount = parseInt(document.getElementById('initial-link-count').value);\n\n        let pageRank = new PageRank(maxIterations, dampingFactor, initialLinkCount);\n        let iterations = 0;\n\n        document.getElementById('calculate-btn').addEventListener('click', function() {\n            pageRank.calculate(sourceUrl, maxIterations, dampingFactor, initialLinkCount);\n            iterations++;\n            document.getElementById('iterations').innerHTML = `Iterations: ${iterations}`;\n        });\n\n        document.getElementById('reset-btn').addEventListener('click', function() {\n            sourceUrl = '';\n            maxIterations = 0;\n            dampingFactor = 0.5;\n            initialLinkCount = 0;\n            document.getElementById('iterations').innerHTML = `Iterations: 0`;\n            pageRank = new PageRank(maxIterations, dampingFactor, initialLinkCount);\n        });\n\n        document.getElementById('previous-btn').addEventListener('click', function() {\n            if (iterations > 0) {\n                iterations--;\n                document.getElementById('iterations').innerHTML = `Iterations: ${iterations}`;\n            }\n        });\n\n        document.getElementById('next-btn').addEventListener('click', function() {\n            if (iterations < maxIterations) {\n                iterations++;\n                document.getElementById('iterations').innerHTML = `Iterations: ${iterations}`;\n            }\n        });\n\n        document.getElementById('clear-btn').addEventListener('click', function() {\n            sourceUrl = '';\n            maxIterations = 0;\n            dampingFactor = 0.5;\n            initialLinkCount = 0;\n            iterations = 0;\n            document.getElementById('iterations').innerHTML = `Iterations: 0`;\n            pageRank = new PageRank(maxIterations, dampingFactor, initialLinkCount);\n        });\n\n        function PageRank(maxIterations, dampingFactor, initialLinkCount) {\n            let links = {};\n            for (let i = 0; i < initialLinkCount; i++) {\n                links[i] = sourceUrl;\n            }\n\n            let ranks = new Array(initialLinkCount).fill(0);\n\n            for (let iteration = 0; iteration < maxIterations; iteration++) {\n                let newRanks = new Array(initialLinkCount).fill(0);\n\n                for (let i = 0; i < initialLinkCount; i++) {\n                    let currentRank = ranks[i];\n                    let currentLink = links[i];\n\n                    let newLinkCount = 0;\n                    for (let j = 0; j < initialLinkCount; j++) {\n                        if (links[j] === currentLink) {\n                            newLinkCount++;\n                        }\n                    }\n\n                    let newLinkProb = 1 / newLinkCount;\n                    for (let j = 0; j < initialLinkCount; j++) {\n                        if (links[j] === currentLink) {\n                            newLinkProb *= newRanks[j];\n                        }\n                    }\n\n                    newRanks[i] = currentRank + dampingFactor * newLinkProb;\n                }\n\n                ranks = newRanks;\n            }\n\n            return ranks;\n        }\n    </script>\n</body>\n</html>"
