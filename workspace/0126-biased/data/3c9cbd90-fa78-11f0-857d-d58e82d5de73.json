    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Authentication Concept — Elegant Visual Demo</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n    margin: 0; padding: 0;\n  }\n  html, body {\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f0;\n    overflow: hidden;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n  }\n\n  /* Container */\n  .auth-container {\n    perspective: 1400px;\n    width: 440px;\n    max-width: 90vw;\n  }\n\n  /* Card */\n  .auth-card {\n    position: relative;\n    width: 100%;\n    min-height: 530px;\n    background: linear-gradient(145deg, #1c2940, #263850);\n    border-radius: 24px;\n    box-shadow:\n      0 15px 35px rgba(0,0,0,0.7),\n      inset 0 0 30px rgba(255,255,255,0.08);\n    overflow: hidden;\n    transform-style: preserve-3d;\n    animation: cardFloat 6s ease-in-out infinite;\n  }\n\n  @keyframes cardFloat {\n    0%, 100% { transform: translateY(0) rotateX(2deg) rotateY(-5deg);}\n    50% { transform: translateY(-15px) rotateX(-2deg) rotateY(5deg);}\n  }\n\n  /* Header - Logo & Title */\n  .auth-header {\n    padding: 36px 36px 12px;\n    text-align: center;\n    position: relative;\n  }\n\n  .logo-circle {\n    width: 74px;\n    height: 74px;\n    margin: 0 auto 16px auto;\n    background: radial-gradient(circle at center, #62dafb, #0a7abf);\n    border-radius: 50%;\n    box-shadow:\n      0 4px 12px rgba(98, 218, 251, 0.6),\n      0 0 18px rgba(10, 122, 191, 0.7);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    animation: pulseGlow 3s infinite ease-in-out alternate;\n  }\n\n  @keyframes pulseGlow {\n    0% {\n      box-shadow:\n        0 4px 12px rgba(98, 218, 251, 0.6),\n        0 0 18px rgba(10, 122, 191, 0.7);\n      transform: scale(1);\n    }\n    100% {\n      box-shadow:\n        0 8px 20px rgba(98, 218, 251, 0.9),\n        0 0 36px rgba(10, 122, 191, 1);\n      transform: scale(1.07);\n    }\n  }\n\n  .logo-icon {\n    width: 36px;\n    height: 36px;\n    fill: #e0e6f0;\n    filter: drop-shadow(0 0 1.5px rgba(98, 218, 251, 0.9));\n  }\n\n  .auth-header h1 {\n    font-weight: 600;\n    font-size: 2.4rem;\n    letter-spacing: 0.14em;\n    color: #62dafb;\n    text-shadow:\n      0 0 6px #62dafb90,\n      0 0 14px #62dafb70;\n    user-select: none;\n  }\n\n  /* Subheading */\n  .auth-subheading {\n    margin-top: 6px;\n    font-weight: 300;\n    font-size: 1rem;\n    color: #aabbcc;\n    letter-spacing: 0.08em;\n    user-select: none;\n    text-transform: uppercase;\n  }\n\n  /* Form mockup container */\n  .auth-body {\n    padding: 28px 48px 48px;\n    display: flex;\n    flex-direction: column;\n    gap: 22px;\n    filter: drop-shadow(0 2px 9px #1a2a3dbb);\n    perspective: 800px;\n  }\n\n  /* Input line mockups */\n  .input-line {\n    position: relative;\n    height: 46px;\n    border-radius: 12px;\n    background:\n      linear-gradient(90deg, #062b54, #084171);\n    box-shadow:\n      inset 0 0 6px #0d4e99,\n      0 1px 10px #0a5ecf60;\n    overflow: hidden;\n  }\n  .input-line::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    margin: 3px;\n    border-radius: 8px;\n    background:\n      linear-gradient(90deg, #0157bc 0%, #3dd9fe 45%, #0157bc 100%);\n    filter: blur(10px);\n    opacity: 0.3;\n    animation: pulseBorder 5s linear infinite;\n  }\n  .input-line .label-text {\n    position: absolute;\n    top: 9px;\n    left: 20px;\n    font-weight: 300;\n    font-size: 1.1rem;\n    color: #a0c2e8cc;\n    font-style: italic;\n    user-select: none;\n    text-transform: capitalize;\n    pointer-events: none;\n  }\n  .input-line .input-fake {\n    position: absolute;\n    bottom: 8px;\n    left: 20px;\n    font-weight: 600;\n    font-size: 1.25rem;\n    color: #e1edf9;\n    letter-spacing: 0.04em;\n    user-select: none;\n    filter: drop-shadow(0 0 3px #3dd9febb);\n  }\n\n  @keyframes pulseBorder {\n    0%, 100% {\n      background-position: 0% 50%;\n    }\n    50% {\n      background-position: 100% 50%;\n    }\n  }\n\n  /* Button container */\n  .auth-footer {\n    display: flex;\n    justify-content: center;\n    margin-top: 12px;\n  }\n\n  /* Button styling */\n  button.btn-auth {\n    background: linear-gradient(135deg, #52a3ff, #0a65d0);\n    border: none;\n    border-radius: 48px;\n    padding: 14px 64px;\n    font-weight: 600;\n    font-size: 1.2rem;\n    color: #e0e6f0;\n    letter-spacing: 0.12em;\n    cursor: pointer;\n    box-shadow:\n      0 0 24px #0a65d0cc,\n      inset 0 -3px 6px #2a69db;\n    transition:\n      background 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button.btn-auth:hover {\n    background: linear-gradient(135deg, #75bbff, #1090ff);\n    box-shadow:\n      0 0 36px #1090ffcc,\n      inset 0 -4px 8px #428eff;\n    transform: scale(1.05);\n  }\n  button.btn-auth:active {\n    transform: scale(0.98);\n    box-shadow:\n      0 0 18px #0a65d0cc,\n      inset 0 -2px 4px #2a69db;\n  }\n\n  /* Glow ellipse behind card */\n  .bg-glow-ellipse {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 650px;\n    height: 650px;\n    background:\n      radial-gradient(ellipse at center, #4fc3ff45 0%, transparent 80%);\n    transform: translate(-50%, -50%);\n    filter: blur(70px);\n    pointer-events: none;\n    animation: glowPulse 8s ease-in-out infinite alternate;\n    z-index: -1;\n  }\n  @keyframes glowPulse {\n    0% {\n      filter: blur(65px) brightness(1.05);\n      opacity: 0.48;\n    }\n    50% {\n      filter: blur(80px) brightness(1.25);\n      opacity: 0.75;\n    }\n    100% {\n      filter: blur(65px) brightness(1.05);\n      opacity: 0.48;\n    }\n  }\n\n  /* Abstract top-right shapes */\n  .top-right-graphics {\n    position: absolute;\n    top: 36px;\n    right: 36px;\n    width: 140px;\n    height: 140px;\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  .abstract-shape {\n    position: absolute;\n    border-radius: 42% 58% 65% 35% / 70% 36% 64% 30%;\n    background: linear-gradient(225deg, #31a8ff, #0a4297);\n    opacity: 0.24;\n    filter: drop-shadow(0 0 2px #3bc6ff90);\n    animation: floatShape 6s ease-in-out infinite;\n  }\n  .abstract-shape.one {\n    width: 80px; height: 80px;\n    top: 0; right: 0;\n    animation-delay: 0s;\n  }\n  .abstract-shape.two {\n    width: 52px; height: 52px;\n    top: 56px; right: 46px;\n    animation-delay: 2.3s;\n  }\n  .abstract-shape.three {\n    width: 64px; height: 64px;\n    top: 110px; right: 18px;\n    animation-delay: 4.6s;\n  }\n  @keyframes floatShape {\n    0%, 100% {\n      transform: translateY(0) rotate(0deg);\n      opacity: 0.24;\n      filter: drop-shadow(0 0 2px #3bc6ff90);\n    }\n    50% {\n      transform: translateY(-8px) rotate(7deg);\n      opacity: 0.38;\n      filter: drop-shadow(0 0 9px #3bc6ffc3);\n    }\n  }\n\n  /* Info Tooltip */\n  .tooltip {\n    position: absolute;\n    left: 24px;\n    bottom: 26px;\n    font-size: 0.7rem;\n    color: #62dafb88;\n    letter-spacing: 0.12em;\n    font-weight: 300;\n    user-select: none;\n    font-style: italic;\n    pointer-events: none;\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"auth-container\" aria-label=\"Authentication visual concept demonstration\">\n    <div class=\"auth-card\" role=\"region\" aria-labelledby=\"authTitle\">\n      <div class=\"bg-glow-ellipse\" aria-hidden=\"true\"></div>\n\n      <div class=\"top-right-graphics\" aria-hidden=\"true\">\n        <div class=\"abstract-shape one\"></div>\n        <div class=\"abstract-shape two\"></div>\n        <div class=\"abstract-shape three\"></div>\n      </div>\n\n      <header class=\"auth-header\">\n        <div class=\"logo-circle\" aria-hidden=\"true\">\n          <svg class=\"logo-icon\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\" >\n            <path d=\"M32 6c14.36 0 26 11.64 26 26S46.36 58 32 58 6 46.36 6 32 17.64 6 32 6zm0 4C20.745 10 12 18.745 12 30s8.745 20 20 20 20-8.745 20-20S43.255 10 32 10zm6 8-8 15-8-15h16z\" />\n          </svg>\n        </div>\n        <h1 id=\"authTitle\">AUTHENTICATION</h1>\n        <p class=\"auth-subheading\">SECURE • PROFESSIONAL • TRUSTED</p>\n      </header>\n\n      <main class=\"auth-body\" aria-label=\"Authentication form mockup\">\n        <div class=\"input-line\" aria-hidden=\"true\">\n          <span class=\"label-text\">Username</span>\n          <span class=\"input-fake\">jane.doe</span>\n        </div>\n        <div class=\"input-line\" aria-hidden=\"true\">\n          <span class=\"label-text\">Password</span>\n          <span class=\"input-fake\">•••••••••</span>\n        </div>\n      </main>\n\n      <footer class=\"auth-footer\">\n        <button class=\"btn-auth\" id=\"btnLogin\" type=\"button\" aria-label=\"Simulate login button\">LOGIN</button>\n      </footer>\n\n      <span class=\"tooltip\" aria-hidden=\"true\">Authentication by design, not by chance</span>\n    </div>\n  </div>\n\n<script>\n  // Minimal interactivity: button triggers a subtle glow animation on the card\n  const btnLogin = document.getElementById('btnLogin');\n  const card = document.querySelector('.auth-card');\n  btnLogin.addEventListener('click', () => {\n    if(card.classList.contains('card-glow')) return;\n    card.classList.add('card-glow');\n    setTimeout(() => {\n      card.classList.remove('card-glow');\n    }, 1800);\n  });\n</script>\n\n<style>\n  /* Glow effect on card triggered by the button */\n  .card-glow {\n    animation: cardGlowPulse 1.8s ease forwards;\n  }\n  @keyframes cardGlowPulse {\n    0% {\n      box-shadow:\n        0 15px 35px rgba(0,0,0,0.7),\n        inset 0 0 30px rgba(255,255,255,0.08);\n      transform: translateY(0) rotateX(2deg) rotateY(-5deg);\n      filter: drop-shadow(0 0 0 #3dd9fe);\n    }\n    50% {\n      box-shadow:\n        0 20px 55px #3dd9fecc,\n        inset 0 0 55px #62dafb;\n      transform: translateY(-12px) rotateX(3deg) rotateY(6deg);\n      filter: drop-shadow(0 0 18px #3dd9fecc);\n    }\n    100% {\n      box-shadow:\n        0 15px 35px rgba(0,0,0,0.7),\n        inset 0 0 30px rgba(255,255,255,0.08);\n      transform: translateY(0) rotateX(2deg) rotateY(-5deg);\n      filter: drop-shadow(0 0 0 #3dd9fe);\n    }\n  }\n</style>\n</body>\n</html>"
