    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Suffix Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n            margin: 0;\n            padding: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n        }\n\n        .container {\n            width: 800px;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .suffix-tree {\n            width: 80%;\n            margin: 0 auto;\n        }\n\n        .suffix-tree .node {\n            background-color: #fff;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n\n        .suffix-tree .node h2 {\n            margin: 0;\n        }\n\n        .suffix-tree .node p {\n            margin: 0;\n        }\n\n        .suffix-tree .node button {\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .suffix-tree .node button:hover {\n            background-color: #3e8e41;\n        }\n\n        .suffix-tree .node button:active {\n            background-color: #2e6da4;\n        }\n\n        .suffix-tree .node button:hover .icon {\n            color: #fff;\n        }\n\n        .suffix-tree .icon {\n            margin: 5px;\n        }\n\n        .suffix-tree .node button:active .icon {\n            color: #fff;\n            margin: 0;\n        }\n\n        .suffix-tree .node button:active .icon svg {\n            fill: #fff;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"suffix-tree\">\n            <h2>Suffix Tree</h2>\n            <p>This is a basic implementation of a suffix tree.</p>\n            <p>Click the button to toggle the tree.</p>\n        </div>\n    </div>\n\n    <script>\n        let suffixTree = {\n            nodes: [],\n            root: null\n        };\n\n        function createNode(text) {\n            let node = {\n                text,\n                children: []\n            };\n            suffixTree.nodes.push(node);\n            return node;\n        }\n\n        function addTextToNode(node, text) {\n            if (node.text === '') {\n                node.text = text;\n                return;\n            }\n            for (let child of node.children) {\n                addTextToNode(child, text);\n            }\n        }\n\n        function buildSuffixTree(text) {\n            let node = createNode(text);\n            addTextToNode(node, text);\n            suffixTree.root = node;\n            return node;\n        }\n\n        function toggleTree() {\n            if (suffixTree.root) {\n                suffixTree.root.children = suffixTree.root.children.filter(child => child !== suffixTree.root);\n                suffixTree.root = suffixTree.root.children[0];\n            }\n        }\n\n        let text = 'banana';\n        let node = buildSuffixTree(text);\n        toggleTree();\n    </script>\n</body>\n</html>"
