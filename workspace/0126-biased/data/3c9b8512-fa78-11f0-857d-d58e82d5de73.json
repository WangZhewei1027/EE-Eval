    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linear Regression — Aesthetic Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Playfair+Display:ital,wght@1,700&display=swap');\n\n  /* Root Colors */\n  :root {\n    --deep-indigo: #2c3e50;\n    --slate-gray: #4f5d75;\n    --soft-cyan: #00bcd4;\n    --warm-peach: #ff6f61;\n    --light-gray: #f3f4f6;\n    --dark-bg: #1a202c;\n    --accent-gradient: linear-gradient(135deg, #00bcd4 0%, #ff6f61 100%);\n    --point-color: #ff6f61;\n    --line-color: #00bcd4;\n  }\n\n  /* Reset & base */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n\n  body {\n    background: var(--dark-bg);\n    color: var(--light-gray);\n    font-family: 'Poppins', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    min-height: 100vh;\n    overflow-x: hidden;\n    padding: 3rem 2rem 4rem;\n  }\n\n  header {\n    text-align: center;\n    margin-bottom: 2rem;\n    user-select: none;\n  }\n\n  header h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.8rem;\n    background: var(--accent-gradient);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: -0.04em;\n    text-shadow:\n      0 2px 5px rgba(0,0,0,0.3),\n      0 4px 15px rgba(255,111,97,0.4);\n    margin-bottom: 0.2rem;\n    line-height: 1;\n    transition: color 0.6s ease;\n  }\n\n  header p {\n    font-size: 1.15rem;\n    font-weight: 600;\n    color: var(--slate-gray);\n    letter-spacing: 0.02em;\n  }\n\n  main {\n    background: linear-gradient(135deg, #141a29 0%, #263247 100%);\n    max-width: 900px;\n    width: 100%;\n    border-radius: 2rem;\n    padding: 3rem 3.5rem 4rem;\n    box-shadow:\n      0 8px 24px rgba(0,188,212,0.25),\n      inset 0 0 50px rgba(255,111,97,0.15);\n    position: relative;\n    user-select: none;\n  }\n\n  /* Canvas and border frame */\n  #regressionCanvas {\n    width: 100%;\n    height: 420px;\n    border-radius: 1.5rem;\n    background: #121a2c;\n    box-shadow:\n      inset 0 0 20px rgba(0,188,212,0.3),\n      inset 0 0 50px rgba(255,111,97,0.25),\n      0 12px 36px rgba(0,188,212,0.15);\n    display: block;\n    margin: 0 auto 3rem;\n    transition: box-shadow 0.6s ease;\n  }\n\n  /* Subtitle under canvas */\n  .caption {\n    font-size: 1rem;\n    font-weight: 500;\n    color: var(--soft-cyan);\n    text-align: center;\n    letter-spacing: 0.04em;\n    user-select: none;\n    margin-bottom: 2.5rem;\n    text-shadow:\n      0 0 8px rgba(0,188,212,0.55);\n  }\n\n  /* Control button styles */\n  .controls {\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n  }\n\n  button {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    padding: 0.75rem 2.4rem;\n    font-size: 1rem;\n    border-radius: 1.25rem;\n    border: 2.5px solid var(--soft-cyan);\n    color: var(--soft-cyan);\n    background: transparent;\n    cursor: pointer;\n    position: relative;\n    overflow: hidden;\n    transition:\n      color 0.4s ease,\n      background 0.5s ease,\n      box-shadow 0.4s ease;\n    box-shadow:\n      0 0 12px rgba(0,188,212,0.5);\n  }\n\n  button::before {\n    content: '';\n    position: absolute;\n    width: 120%;\n    height: 0;\n    top: 50%;\n    left: -10%;\n    background: var(--soft-cyan);\n    opacity: 0.2;\n    filter: blur(24px);\n    transform: translateY(-50%);\n    border-radius: 50%;\n    transition: height 0.4s ease;\n    z-index: 0;\n  }\n\n  button:hover {\n    background: var(--soft-cyan);\n    color: var(--dark-bg);\n    box-shadow:\n      0 0 18px 3px rgba(0,188,212,0.8);\n  }\n  button:hover::before {\n    height: 300%;\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 4rem;\n    font-size: 0.95rem;\n    color: var(--slate-gray);\n    user-select: none;\n    opacity: 0.65;\n  }\n\n  /* Responsive text scaling */\n  @media screen and (max-width: 600px) {\n    header h1 {\n      font-size: 3rem;\n    }\n    main {\n      padding: 2rem 2.5rem 3rem;\n    }\n    #regressionCanvas {\n      height: 340px;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Linear Regression</h1>\n  <p>The Art and Geometry of Best-Fit Lines</p>\n</header>\n<main>\n  <canvas id=\"regressionCanvas\" width=\"860\" height=\"420\" aria-label=\"Linear regression visualization\"></canvas>\n  <div class=\"caption\">Observe the elegant fit of a line minimizing squared errors</div>\n  <div class=\"controls\">\n    <button id=\"animateBtn\" aria-pressed=\"false\" aria-label=\"Toggle animation of regression fit\">Animate</button>\n  </div>\n</main>\n<footer>\n  &copy; 2024 &bull; Crafted with 🌟 aesthetics in mind\n</footer>\n\n<script>\n(() => {\n\n  const canvas = document.getElementById('regressionCanvas');\n  const ctx = canvas.getContext('2d');\n  const W = canvas.width;\n  const H = canvas.height;\n\n  // Data points (x, y) with some noise, visually aesthetic placement\n  let points = [\n    {x: 70, y: 320},\n    {x: 130, y: 280},\n    {x: 190, y: 250},\n    {x: 255, y: 230},\n    {x: 310, y: 215},\n    {x: 370, y: 195},\n    {x: 430, y: 175},\n    {x: 480, y: 150},\n    {x: 530, y: 140},\n    {x: 595, y: 125},\n    {x: 645, y: 115},\n    {x: 700, y: 95},\n    {x: 750, y: 85},\n    {x: 810, y: 70},\n  ];\n\n  // Normalize & transform for coordinate system\n  // Canvas origin top-left; y grows downward\n  // We keep our points as is for direct drawing.\n\n  // Regression utilities\n  function linearRegression(data) {\n    const n = data.length;\n    let sumX=0, sumY=0, sumXY=0, sumXX=0;\n    for(let i=0; i<n; i++) {\n      sumX += data[i].x;\n      sumY += data[i].y;\n      sumXY += data[i].x * data[i].y;\n      sumXX += data[i].x * data[i].x;\n    }\n    const denominator = n*sumXX - sumX*sumX;\n    if (denominator === 0) return {m:0,b:0};\n    const m = (n*sumXY - sumX*sumY) / denominator;\n    const b = (sumY - m*sumX)/n;\n    return {m,b};\n  }\n\n  // Colors for elements\n  const COLOR_BG = 'rgba(18, 26, 44, 1)';\n  const COLOR_GRID = 'rgba(72, 90, 124, 0.15)';\n  const COLOR_AXES = 'rgba(0,188,212,0.5)';\n  const COLOR_LINE = 'rgba(0,188,212,0.9)';\n  const COLOR_POINT = 'rgba(255,111,97,1)';\n  const COLOR_POINT_SHADOW = 'rgba(255,111,97,0.28)';\n\n  // Drawing grid with subtle glowing lines\n  function drawGrid() {\n    ctx.save();\n    ctx.lineWidth = 1;\n    ctx.strokeStyle = COLOR_GRID;\n    ctx.shadowColor = 'rgba(0,188,212,0.11)';\n    ctx.shadowBlur = 4;\n\n    const stepX = 60;\n    const stepY = 40;\n\n    for(let x=0; x<=W; x+=stepX){\n      ctx.beginPath();\n      ctx.moveTo(x, 0);\n      ctx.lineTo(x, H);\n      ctx.stroke();\n    }\n    for(let y=0; y<=H; y+=stepY){\n      ctx.beginPath();\n      ctx.moveTo(0, y);\n      ctx.lineTo(W, y);\n      ctx.stroke();\n    }\n    ctx.restore();\n  }\n\n  // Draw axes with labels\n  function drawAxes() {\n    ctx.save();\n\n    ctx.lineWidth = 2;\n    ctx.strokeStyle = COLOR_AXES;\n    ctx.shadowColor = COLOR_AXES;\n    ctx.shadowBlur = 6;\n    ctx.lineCap = 'round';\n\n    // X axis bottom\n    ctx.beginPath();\n    ctx.moveTo(50, H-50);\n    ctx.lineTo(W-20, H-50);\n    ctx.stroke();\n\n    // Y axis left\n    ctx.beginPath();\n    ctx.moveTo(50, H-50);\n    ctx.lineTo(50, 20);\n    ctx.stroke();\n\n    // Arrows\n    // X arrow\n    ctx.beginPath();\n    ctx.moveTo(W-25,H-55);\n    ctx.lineTo(W-20,H-50);\n    ctx.lineTo(W-25,H-45);\n    ctx.fillStyle = COLOR_AXES;\n    ctx.fill();\n\n    // Y arrow\n    ctx.beginPath();\n    ctx.moveTo(45, 25);\n    ctx.lineTo(50, 20);\n    ctx.lineTo(55, 25);\n    ctx.fill();\n\n    // Labels\n    ctx.font = \"600 15px Poppins, sans-serif\";\n    ctx.fillStyle = COLOR_AXES;\n    ctx.textAlign = \"center\";\n    ctx.textBaseline = \"top\";\n    ctx.shadowBlur = 12;\n    ctx.shadowColor = 'rgba(0,188,212,0.4)';\n\n    ctx.fillText(\"X\", W-40, H-45);\n    ctx.textAlign = \"right\";\n    ctx.textBaseline = \"middle\";\n    ctx.fillText(\"Y\", 40, 30);\n\n    ctx.restore();\n  }\n\n  // Draw points with halo glow\n  function drawPoints(points) {\n    points.forEach(({x,y}) => {\n      // Shadow glow\n      ctx.save();\n      ctx.shadowColor = COLOR_POINT_SHADOW;\n      ctx.shadowBlur = 14;\n      ctx.fillStyle = COLOR_POINT;\n      ctx.beginPath();\n      ctx.arc(x, y, 8, 0, Math.PI*2);\n      ctx.fill();\n      ctx.restore();\n\n      // Inner point\n      ctx.fillStyle = 'white';\n      ctx.beginPath();\n      ctx.arc(x, y, 3.8, 0, Math.PI*2);\n      ctx.fill();\n    });\n  }\n\n  // Draw the regression line with gradient glow\n  function drawRegressionLine(m, b, glowAlpha=1) {\n    ctx.save();\n    ctx.lineCap = 'round';\n    ctx.lineWidth = 3.5;\n\n    // Gradient line glow\n    let grad = ctx.createLinearGradient(50, 0, W-20, 0);\n    grad.addColorStop(0, `rgba(0,188,212,${0.2*glowAlpha})`);\n    grad.addColorStop(0.4, `rgba(255,111,97,${0.7*glowAlpha})`);\n    grad.addColorStop(0.7, `rgba(255,111,97,${0.9*glowAlpha})`);\n    grad.addColorStop(1, `rgba(0,188,212,${0.3*glowAlpha})`);\n\n    ctx.strokeStyle = grad;\n    ctx.shadowColor = `rgba(255,111,97,${0.25*glowAlpha})`;\n    ctx.shadowBlur = 16;\n\n    // Calculate endpoints limited to canvas\n    // y = mx + b\n    const x1 = 50;\n    const y1 = m*x1 + b;\n    const x2 = W - 20;\n    const y2 = m*x2 + b;\n\n    // Draw main line\n    ctx.beginPath();\n    ctx.moveTo(x1, y1);\n    ctx.lineTo(x2, y2);\n    ctx.stroke();\n\n    // Outer soft halo\n    ctx.lineWidth = 14;\n    ctx.strokeStyle = `rgba(255,111,97,${0.1*glowAlpha})`;\n    ctx.shadowBlur = 28;\n    ctx.beginPath();\n    ctx.moveTo(x1, y1);\n    ctx.lineTo(x2, y2);\n    ctx.stroke();\n\n    ctx.restore();\n  }\n\n  // Draw vertical residual lines from point to regression line\n  function drawResiduals(points, m, b, alpha=0.15) {\n    ctx.save();\n    ctx.strokeStyle = `rgba(255,111,97,${alpha})`;\n    ctx.lineWidth = 1.6;\n    ctx.setLineDash([6, 10]);\n    ctx.shadowColor = `rgba(255,111,97,${alpha*0.3})`;\n    ctx.shadowBlur = 6;\n    points.forEach(({x,y}) => {\n      const yOnLine = m*x + b;\n      ctx.beginPath();\n      ctx.moveTo(x, y);\n      ctx.lineTo(x, yOnLine);\n      ctx.stroke();\n    });\n    ctx.restore();\n  }\n\n  // Animate regression line progressively from initial to fit line\n  let animating = false;\n  let animationProgress = 0;\n  let animId;\n\n  let initialM = 0.07;  // starting slope\n  let initialB = 360;   // starting y-offset\n\n  let finalReg = linearRegression(points);\n  if (finalReg.m > 0) finalReg.m *= -1; // flip slope for visual aesthetics\n  if (finalReg.b < 100) finalReg.b += 100; // slight offset mod\n\n  function lerp(a, b, t) {\n    return a + (b - a) * t;\n  }\n\n  function animate() {\n    ctx.clearRect(0, 0, W, H);\n    drawGrid();\n    drawAxes();\n    drawPoints(points);\n\n    let m = lerp(initialM, finalReg.m, animationProgress);\n    let b = lerp(initialB, finalReg.b, animationProgress);\n\n    drawResiduals(points, m, b, lerp(0,0.2,animationProgress));\n    drawRegressionLine(m, b, animationProgress);\n\n    animationProgress += 0.013;\n    if (animationProgress > 1) {\n      animationProgress = 1;\n      animating = false;\n      document.getElementById('animateBtn').textContent=\"Animate\";\n      document.getElementById('animateBtn').setAttribute('aria-pressed', 'false');\n      cancelAnimationFrame(animId);\n    } else {\n      animId = requestAnimationFrame(animate);\n    }\n  }\n\n  // Final static draw for initial view\n  function drawStaticView() {\n    ctx.clearRect(0, 0, W, H);\n    drawGrid();\n    drawAxes();\n    drawPoints(points);\n    drawResiduals(points, finalReg.m, finalReg.b, 0.2);\n    drawRegressionLine(finalReg.m, finalReg.b, 1);\n  }\n\n  // Initial draw\n  drawStaticView();\n\n  // Button toggle animation\n  const btn = document.getElementById('animateBtn');\n  btn.addEventListener('click', () => {\n    if (animating) return;\n    animating = true;\n    animationProgress = 0;\n    btn.textContent = 'Animating…';\n    btn.setAttribute('aria-pressed', 'true');\n    animate();\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
