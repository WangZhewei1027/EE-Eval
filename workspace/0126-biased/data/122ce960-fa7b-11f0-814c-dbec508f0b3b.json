put.value = value;\n            }\n\n            function updateButtonValue(value) {\n                buttons.forEach(button => button.textContent = value);\n            }\n\n            function handleSliderChange() {\n                let value = document.getElementById('slider').value;\n                updateOutput(value);\n                updateButtonValue(value);\n            }\n\n            function handleInputChange() {\n                let value = inputs[0].value;\n                updateOutput(value);\n                updateButtonValue(value);\n            }\n\n            function handleInput2Change() {\n                let value = inputs[1].value;\n                updateOutput(value);\n                updateButtonValue(value);\n            }\n\n            function handleInput3Change() {\n                let value = inputs[2].value;\n                updateOutput(value);\n                updateButtonValue(value);\n            }\n\n            buttons.forEach(button => button.addEventListener('click', () => {\n                if (button.id === 'button1') {\n                    handleSliderChange();\n                } else if (button.id === 'button2') {\n                    handleInputChange();\n                } else if (button.id === 'button3') {\n                    handleInput2Change();\n                } else if (button.id === 'input2') {\n                    handleInput2Change();\n                } else if (button.id === 'input3') {\n                    handleInput3Change();\n                }\n            }));\n\n            let slider = document.getElementById('slider');\n            slider.addEventListener('input', handleSliderChange);\n            inputs.forEach(input => input.addEventListener('input', handleInputChange));\n            inputs.forEach(input => input.addEventListener('input', handleInput2Change));\n            inputs.forEach(input => input.addEventListener('input', handleInput3Change));\n        </script>\n    </div>\n</body>\n</html>