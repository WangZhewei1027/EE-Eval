    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Heap (Max)</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        #heap {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        #heap h1 {\n            margin-bottom: 10px;\n        }\n        #controls {\n            margin-bottom: 20px;\n        }\n        #controls button {\n            margin-right: 10px;\n        }\n        #controls input[type=\"number\"] {\n            width: 50px;\n        }\n        #controls input[type=\"text\"] {\n            width: 100px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Heap (Max)</h1>\n    <div id=\"heap\"></div>\n    <div id=\"controls\">\n        <button id=\"add-heap-btn\">Add Heap</button>\n        <input type=\"number\" id=\"heap-size\" value=\"10\">\n        <input type=\"number\" id=\"heap-size-max\" value=\"100\">\n        <button id=\"clear-heap-btn\">Clear Heap</button>\n        <input type=\"text\" id=\"heap-input\" value=\"[]\">\n    </div>\n\n    <script>\n        let heap = null;\n        let input = null;\n\n        function createHeap() {\n            const heapElement = document.getElementById(\"heap\");\n            heap = new Heap();\n            heapElement.innerHTML = \"\";\n            heapElement.appendChild(createHeapElement(heap));\n        }\n\n        function createHeapElement(heap) {\n            const element = document.createElement(\"div\");\n            element.className = \"heap-element\";\n            element.style.width = \"100px\";\n            element.style.height = \"50px\";\n            element.style.backgroundColor = \"black\";\n            element.style.border = \"1px solid black\";\n            element.style.padding = \"10px\";\n            element.style.margin = \"10px\";\n            element.style.borderRadius = \"10px\";\n            element.style.boxShadow = \"0 0 10px rgba(0,0,0,0.1)\";\n            element.appendChild(createHeapButton(heap));\n            element.appendChild(createInputField(heap));\n            return element;\n        }\n\n        function createHeapButton(heap) {\n            const button = document.createElement(\"button\");\n            button.textContent = \"Add\";\n            button.style.width = \"100px\";\n            button.style.height = \"30px\";\n            button.style.backgroundColor = \"black\";\n            button.style.border = \"none\";\n            button.style.padding = \"10px\";\n            button.style.margin = \"10px\";\n            button.style.borderRadius = \"10px\";\n            button.style.boxShadow = \"0 0 10px rgba(0,0,0,0.1)\";\n            button.onclick = () => {\n                heap.add();\n            };\n            return button;\n        }\n\n        function createInputField(heap) {\n            const input = document.createElement(\"input\");\n            input.type = \"number\";\n            input.id = \"heap-input\";\n            input.value = \"\";\n            return input;\n        }\n\n        function add() {\n            const heapSize = parseInt(document.getElementById(\"heap-size\").value);\n            const maxHeapSize = parseInt(document.getElementById(\"heap-size-max\").value);\n            if (heapSize > maxHeapSize) {\n                alert(\"Heap size cannot be greater than max heap size\");\n                return;\n            }\n            heap.add(heapSize);\n            updateHeap();\n        }\n\n        function clearHeap() {\n            heap.clear();\n            updateHeap();\n        }\n\n        function updateHeap() {\n            const heapElement = document.getElementById(\"heap\");\n            heapElement.innerHTML = \"\";\n            for (let i = 0; i < heap.heap.length; i++) {\n                const element = createHeapElement(heap.heap[i]);\n                heapElement.appendChild(element);\n            }\n        }\n\n        createHeap();\n        document.getElementById(\"add-heap-btn\").addEventListener(\"click\", add);\n        document.getElementById(\"clear-heap-btn\").addEventListener(\"click\", clearHeap);\n        document.getElementById(\"heap-input\").addEventListener(\"input\", updateHeap);\n    </script>\n</body>\n</html>"
