arseInt(document.getElementById('minSamplesLeaf').value);\n        \n        let message = `Training Random Forest with ${numTrees} trees, max depth of ${maxDepth}, ` +\n                      `min samples split of ${minSamplesSplit}, and min samples leaf of ${minSamplesLeaf}.`;\n        \n        document.getElementById('output').innerText = message;\n        document.getElementById('output').classList.remove('hidden');\n        \n        document.getElementById('predictButton').classList.remove('hidden');\n    });\n\n    document.getElementById('predictButton').addEventListener('click', function() {\n        const testInput = document.getElementById('testInputs').value.split(',').map(Number);\n        \n        if (testInput.length === 0) {\n            document.getElementById('predictionResult').innerText = \"Please provide valid input.\";\n            document.getElementById('predictionResult').classList.remove('hidden');\n            return;\n        }\n\n        const prediction = simulatePrediction(testInput);\n        \n        document.getElementById('predictionResult').innerText = `Predicted Class: ${prediction}`;\n        document.getElementById('predictionResult').classList.remove('hidden');\n    });\n\n    function simulatePrediction(input) {\n        // For demonstration, this function randomly predicts a class (0 or 1)\n        return Math.random() < 0.5 ? 0 : 1;\n    }\n</script>\n\n</body>\n</html>"
