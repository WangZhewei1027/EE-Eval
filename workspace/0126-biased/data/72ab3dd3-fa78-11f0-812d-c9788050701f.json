    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Space Complexity Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #0f172a;\n            --secondary: #1e293b;\n            --accent: #7c3aed;\n            --text: #e2e8f0;\n            --highlight: #a78bfa;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: var(--primary);\n            color: var(--text);\n            min-height: 100vh;\n            overflow-x: hidden;\n            position: relative;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            position: relative;\n            z-index: 2;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 5rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out forwards 0.3s;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, var(--highlight), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        h2 {\n            font-size: 1.5rem;\n            font-weight: 400;\n            color: var(--text);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization-container {\n            display: flex;\n            flex-direction: column;\n            gap: 3rem;\n            margin-top: 4rem;\n        }\n        \n        .complexity-card {\n            background: rgba(30, 41, 59, 0.5);\n            backdrop-filter: blur(10px);\n            border-radius: 1rem;\n            padding: 2.5rem;\n            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n            transition: all 0.3s ease;\n            opacity: 0;\n            transform: translateY(20px);\n        }\n        \n        .complexity-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);\n        }\n        \n        .card-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 2rem;\n        }\n        \n        .card-title {\n            font-size: 1.75rem;\n            font-weight: 600;\n            color: var(--highlight);\n            font-family: 'Space Mono', monospace;\n        }\n        \n        .card-description {\n            font-size: 1.1rem;\n            line-height: 1.7;\n            color: rgba(226, 232, 240, 0.8);\n            margin-bottom: 2rem;\n        }\n        \n        .space-visualization {\n            height: 200px;\n            position: relative;\n            margin-top: 2rem;\n            overflow: hidden;\n            border-radius: 0.5rem;\n            background: rgba(15, 23, 42, 0.7);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n        \n        .memory-block {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            background: linear-gradient(to top, var(--accent), var(--highlight));\n            transition: height 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;\n            opacity: 0.9;\n            border-top-left-radius: 0.5rem;\n            border-top-right-radius: 0.5rem;\n            box-shadow: 0 -10px 15px -3px rgba(124, 58, 237, 0.3);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 3rem;\n        }\n        \n        button {\n            background: linear-gradient(135deg, var(--accent), var(--highlight));\n            color: white;\n            border: none;\n            padding: 0.75rem 1.5rem;\n            font-size: 1rem;\n            font-weight: 500;\n            border-radius: 0.5rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px -1px rgba(124, 58, 237, 0.3), 0 2px 4px -1px rgba(124, 58, 237, 0.1);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 15px -3px rgba(124, 58, 237, 0.3), 0 4px 6px -2px rgba(124, 58, 237, 0.1);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .stars {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 1;\n            pointer-events: none;\n        }\n        \n        .star {\n            position: absolute;\n            background-color: white;\n            border-radius: 50%;\n            animation: twinkle var(--duration) ease-in-out infinite;\n            opacity: 0;\n        }\n        \n        @keyframes twinkle {\n            0%, 100% { opacity: 0; }\n            50% { opacity: var(--opacity); }\n        }\n        \n        @keyframes fadeIn {\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        .code-snippet {\n            background: var(--secondary);\n            padding: 1.5rem;\n            border-radius: 0.5rem;\n            font-family: 'Space Mono', monospace;\n            font-size: 0.9rem;\n            line-height: 1.7;\n            color: rgba(226, 232, 240, 0.9);\n            margin: 1.5rem 0;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .code-snippet::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 3px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--accent), var(--highlight));\n        }\n        \n        .code-keyword {\n            color: #f472b6;\n        }\n        \n        .code-function {\n            color: #7dd3fc;\n        }\n        \n        .code-var {\n            color: var(--highlight);\n        }\n        \n        .code-comment {\n            color: #64748b;\n            font-style: italic;\n        }\n        \n        .animate-in {\n            animation: fadeIn 1s ease-out forwards;\n        }\n        \n        .animate-delay-1 { animation-delay: 0.3s; }\n        .animate-delay-2 { animation-delay: 0.6s; }\n        .animate-delay-3 { animation-delay: 0.9s; }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .container {\n                padding: 2rem 1rem;\n            }\n            \n            .complexity-card {\n                padding: 1.5rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"stars\" id=\"stars\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Space Complexity</h1>\n            <h2>Understanding how algorithms utilize memory resources</h2>\n        </header>\n        \n        <div class=\"visualization-container\">\n            <div class=\"complexity-card animate-in animate-delay-1\">\n                <div class=\"card-header\">\n                    <h3 class=\"card-title\">O(1) - Constant Space</h3>\n                </div>\n                <p class=\"card-description\">\n                    The algorithm uses a fixed amount of memory regardless of input size.\n                    Memory usage remains flat and predictable.\n                </p>\n                <div class=\"code-snippet\">\n                    <span class=\"code-keyword\">function</span> <span class=\"code-function\">sum</span>(a, b) {<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">const</span> <span class=\"code-var\">result</span> = a + b;<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">return</span> <span class=\"code-var\">result</span>;<br>\n                    }<br>\n                    <span class=\"code-comment\">// Only uses memory for variables a, b, and result</span>\n                </div>\n                <div class=\"space-visualization\" id=\"constant-space\">\n                    <div class=\"memory-block\" style=\"height: 30%;\"></div>\n                </div>\n            </div>\n            \n            <div class=\"complexity-card animate-in animate-delay-2\">\n                <div class=\"card-header\">\n                    <h3 class=\"card-title\">O(n) - Linear Space</h3>\n                </div>\n                <p class=\"card-description\">\n                    Memory usage grows proportionally with input size.\n                    Common when storing each input element in a data structure.\n                </p>\n                <div class=\"code-snippet\">\n                    <span class=\"code-keyword\">function</span> <span class=\"code-function\">duplicateArray</span>(arr) {<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">const</span> <span class=\"code-var\">newArray</span> = [];<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">for</span> (<span class=\"code-keyword\">let</span> i = 0; i < arr.length; i++) {<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;<span class=\"code-var\">newArray</span>.push(arr[i]);<br>\n                    &nbsp;&nbsp;}<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">return</span> <span class=\"code-var\">newArray</span>;<br>\n                    }<br>\n                    <span class=\"code-comment\">// Memory usage grows with input array size</span>\n                </div>\n                <div class=\"space-visualization\" id=\"linear-space\">\n                    <div class=\"memory-block\" style=\"height: 60%;\"></div>\n                </div>\n            </div>\n            \n            <div class=\"complexity-card animate-in animate-delay-3\">\n                <div class=\"card-header\">\n                    <h3 class=\"card-title\">O(n²) - Quadratic Space</h3>\n                </div>\n                <p class=\"card-description\">\n                    Memory usage grows with the square of input size.\n                    Often seen with nested data structures or recursive algorithms.\n                </p>\n                <div class=\"code-snippet\">\n                    <span class=\"code-keyword\">function</span> <span class=\"code-function\">generateMatrix</span>(n) {<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">const</span> <span class=\"code-var\">matrix</span> = [];<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">for</span> (<span class=\"code-keyword\">let</span> i = 0; i < n; i++) {<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;<span class=\"code-var\">matrix</span>[i] = [];<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;<span class=\"code-keyword\">for</span> (<span class=\"code-keyword\">let</span> j = 0; j < n; j++) {<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class=\"code-var\">matrix</span>[i][j] = i * j;<br>\n                    &nbsp;&nbsp;&nbsp;&nbsp;}<br>\n                    &nbsp;&nbsp;}<br>\n                    &nbsp;&nbsp;<span class=\"code-keyword\">return</span> <span class=\"code-var\">matrix</span>;<br>\n                    }<br>\n                    <span class=\"code-comment\">// Memory grows exponentially with input size</span>\n                </div>\n                <div class=\"space-visualization\" id=\"quadratic-space\">\n                    <div class=\"memory-block\" style=\"height: 90%;\"></div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"animate-btn\">Visualize Growth</button>\n        </div>\n    </div>\n\n    <script>\n        // Create twinkling stars\n        function createStars() {\n            const starsContainer = document.getElementById('stars');\n            const starCount = 100;\n            \n            for (let i = 0; i < starCount; i++) {\n                const star = document.createElement('div');\n                star.classList.add('star');\n                \n                // Random properties\n                const size = Math.random() * 2;\n                const x = Math.random() * 100;\n                const y = Math.random() * 100;\n                const opacity = Math.random() * 0.8 + 0.2;\n                const duration = Math.random() * 5 + 3;\n                \n                star.style.width = `${size}px`;\n                star.style.height = `${size}px`;\n                star.style.left = `${x}%`;\n                star.style.top = `${y}%`;\n                star.style.setProperty('--opacity', opacity);\n                star.style.setProperty('--duration', `${duration}s`);\n                \n                starsContainer.appendChild(star);\n            }\n        }\n        \n        // Animate memory blocks\n        function animateMemoryGrowth() {\n            const btn = document.getElementById('animate-btn');\n            btn.disabled = true;\n            btn.textContent = 'Animating...';\n            \n            const constantBlock = document.querySelector('#constant-space .memory-block');\n            const linearBlock = document.querySelector('#linear-space .memory-block');\n            const quadraticBlock = document.querySelector('#quadratic-space .memory-block');\n            \n            // Reset heights\n            constantBlock.style.height = '5%';\n            linearBlock.style.height = '5%';\n            quadraticBlock.style.height = '5%';\n            \n            // Animate to show growth patterns\n            setTimeout(() => {\n                constantBlock.style.height = '30%';\n                linearBlock.style.height = '60%';\n                quadraticBlock.style.height = '90%';\n                \n                setTimeout(() => {\n                    btn.disabled = false;\n                    btn.textContent = 'Visualize Growth';\n                }, 1000);\n            }, 100);\n        }\n        \n        // Initialize\n        document.addEventListener('DOMContentLoaded', () => {\n            createStars();\n            \n            // Set up animations\n            const cards = document.querySelectorAll('.complexity-card');\n            cards.forEach((card, index) => {\n                setTimeout(() => {\n                    card.style.opacity = '1';\n                    card.style.transform = 'translateY(0)';\n                }, 300 + (index * 200));\n            });\n            \n            // Button event\n            document.getElementById('animate-btn').addEventListener('click', animateMemoryGrowth);\n        });\n    </script>\n</body>\n</html>"
