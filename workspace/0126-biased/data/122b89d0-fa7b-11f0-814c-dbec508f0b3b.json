    "content": "<html>\n<head>\n    <title>Merge Sort</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        #result {\n            font-size: 12pt;\n            font-style: italic;\n        }\n    </style>\n</head>\n<body>\n    <h1>Merge Sort</h1>\n    <div id=\"result\"></div>\n    <div>\n        <label for=\"n\">Input size:</label>\n        <input type=\"number\" id=\"n\" value=\"10\" min=\"2\">\n        <button id=\"sort-btn\">Sort</button>\n    </div>\n    <div id=\"controls\">\n        <label for=\"sort-type\">Sort type:</label>\n        <select id=\"sort-type\" value=\"ascending\">\n            <option value=\"ascending\">Ascending</option>\n            <option value=\"descending\">Descending</option>\n        </select>\n        <label for=\"reverse\">Reverse:</label>\n        <input type=\"checkbox\" id=\"reverse\" value=\"true\">\n        <label for=\"reverse\">Reverse</label>\n        <label for=\"step\">Step:</label>\n        <input type=\"number\" id=\"step\" value=\"2\" min=\"1\">\n    </div>\n    <div id=\"input-container\">\n        <button id=\"clear-btn\">Clear</button>\n        <input type=\"number\" id=\"input-field\" value=\"1\" min=\"1\">\n        <button id=\"add-btn\">Add</button>\n        <button id=\"sort-btn\">Sort</button>\n    </div>\n\n    <script>\n        let input = document.getElementById('input-field');\n        let result = document.getElementById('result');\n        let sortBtn = document.getElementById('sort-btn');\n        let controls = document.getElementById('controls');\n        let clearBtn = document.getElementById('clear-btn');\n        let addBtn = document.getElementById('add-btn');\n        let n = document.getElementById('n');\n        let sortType = document.getElementById('sort-type');\n        let reverse = document.getElementById('reverse');\n        let step = document.getElementById('step');\n        let inputContainer = document.getElementById('input-container');\n        let inputField = document.getElementById('input-field');\n\n        let mergeSort = function(arr) {\n            if (arr.length <= 1) {\n                return arr;\n            }\n            let mid = Math.floor(arr.length / 2);\n            let left = arr.slice(0, mid);\n            let right = arr.slice(mid);\n            return merge(mergeSort(left), mergeSort(right));\n        }\n\n        function merge(left, right) {\n            let result = [];\n            while (left.length > 0 && right.length > 0) {\n                if (left[0] <= right[0]) {\n                    result.push(left.shift());\n                } else {\n                    result.push(right.shift());\n                }\n            }\n            result.push(...left);\n            result.push(...right);\n            return result;\n        }\n\n        function sort(arr) {\n            let sortedArr = mergeSort(arr);\n            let sortedHtml = '';\n            for (let i = 0; i < sortedArr.length; i++) {\n                sortedHtml += sortedArr[i] + ' ';\n            }\n            result.innerHTML = '<h1>Merge Sort Result:</h1><p>' + sortedHtml + '</p>';\n        }\n\n        function reverseSort(arr) {\n            let sortedArr = mergeSort(arr);\n            let sortedHtml = '';\n            for (let i = sortedArr.length - 1; i >= 0; i--) {\n                sortedHtml += sortedArr[i] + ' ';\n            }\n            result.innerHTML = '<h1>Merge Sort Result:</h1><p>' + sortedHtml + '</p>';\n        }\n\n        function addToList() {\n            let arr = [];\n            while (inputField.value > 0) {\n                arr.push(parseInt(inputField.value));\n                inputField.value = 0;\n            }\n            sort(arr);\n        }\n\n        function clearList() {\n            result.innerHTML = '';\n        }\n\n        addBtn.addEventListener('click', addToList);\n        clearBtn.addEventListener('click', clearList);\n        inputField.addEventListener('input', function() {\n            inputField.value = 0;\n        });\n        sortBtn.addEventListener('click', sort);\n        sortType.addEventListener('change', function() {\n            if (sortType.value === 'ascending') {\n                sortBtn.textContent = 'Reverse Sort';\n                reverseSort = function(arr) {\n                    let sortedArr = mergeSort(arr);\n                    let sortedHtml = '';\n                    for (let i = 0; i < sortedArr.length; i++) {\n                        sortedHtml += sortedArr[i] + ' ';\n                    }\n                    result.innerHTML = '<h1>Merge Sort Result:</h1><p>' + sortedHtml + '</p>';\n                    return sortedHtml;\n                }\n                reverseSort = function(arr) {\n                    let sortedArr = mergeSort(arr);\n                    let sortedHtml = '';\n                    for (let i = sortedArr.length - 1; i >= 0; i--) {\n                        sortedHtml += sortedArr[i] + ' ';\n                    }\n                    result.innerHTML = '<h1>Merge Sort Result:</h1><p>' + sortedHtml + '</p>';\n                    return sortedHtml;\n                }\n            } else {\n                sortBtn.textContent = 'Reverse Sort';\n                reverseSort = function(arr) {\n                    let sortedArr = mergeSort(arr);\n                    let sortedHtml = '';\n                    for (let i = 0; i < sortedArr.length; i++) {\n                        sortedHtml += sortedArr[i] + ' ';\n                    }\n                    result.innerHTML = '<h1>Merge Sort Result:</h1><p>' + sortedHtml + '</p>';\n                    return sortedHtml;\n                }\n                reverseSort = function(arr) {\n                    let sortedArr = mergeSort(arr);\n                    let sortedHtml = '';\n                    for (let i = sortedArr.length - 1; i >= 0; i--) {\n                        sortedHtml += sortedArr[i] + ' ';\n                    }\n                    result.innerHTML = '<h1>Merge Sort Result:</h1><p>' + sortedHtml + '</p>';\n                    return sortedHtml;\n                }\n            }\n        });\n    </script>\n</body>\n</html>"
