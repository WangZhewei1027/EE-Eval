    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Bucket Sort</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { margin: 10px 0; }\n    </style>\n</head>\n<body>\n    <h1>Bucket Sort Visualization</h1>\n    <label for=\"numbers\">Enter numbers (comma separated): </label>\n    <input type=\"text\" id=\"numbers\" placeholder=\"e.g. 3,5,1,6,2\">\n    <button onclick=\"prepareSort()\">Prepare for Sort</button>\n    <div id=\"output\"></div>\n    <h3>Control Bucket Count</h3>\n    <label for=\"bucketCount\">Number of Buckets: </label>\n    <input type=\"number\" id=\"bucketCount\" min=\"1\" value=\"5\">\n    <button onclick=\"sort()\">Sort with Buckets</button>\n    <h3>Sort Status</h3>\n    <ul id=\"statusList\"></ul>\n    <script>\n        function prepareSort() {\n            const numbersInput = document.getElementById('numbers').value;\n            const numbers = numbersInput.split(',').map(Number).filter(n => !isNaN(n));\n            const bucketCountInput = document.getElementById('bucketCount').value;\n            const bucketCount = Math.max(1, Math.floor(bucketCountInput));\n\n            if (numbers.length === 0) {\n                alert('Please enter valid numbers.');\n                return;\n            }\n\n            // Clear previous output\n            document.getElementById('output').innerText = `Input Numbers: [${numbers}] | Buckets: ${bucketCount}`;\n            document.getElementById('statusList').innerHTML = '';\n            localStorage.setItem('inputNumbers', JSON.stringify(numbers));\n            localStorage.setItem('bucketCount', bucketCount);\n        }\n\n        function sort() {\n            const numbers = JSON.parse(localStorage.getItem('inputNumbers'));\n            const bucketCount = localStorage.getItem('bucketCount');\n\n            if (!numbers || bucketCount === null) {\n                alert('Please prepare numbers before sorting!');\n                return;\n            }\n\n            const maxValue = Math.max(...numbers);\n            const minValue = Math.min(...numbers);\n            const bucketSize = (maxValue - minValue) / bucketCount;\n\n            const buckets = Array.from({length: bucketCount}, () => []);\n            numbers.forEach(num => {\n                const index = Math.floor((num - minValue) / bucketSize);\n                if (index >= bucketCount) {\n                    buckets[bucketCount - 1].push(num);\n                } else {\n                    buckets[index].push(num);\n                }\n            });\n\n            let sortedArray = [];\n            buckets.forEach((bucket, i) => {\n                if (bucket.length > 0) {\n                    bucket.sort((a, b) => a - b);\n                    sortedArray = sortedArray.concat(bucket);\n                    const listItem = document.createElement('li');\n                    listItem.innerText = `Bucket ${i + 1}: [${bucket}] sorted.`;\n                    document.getElementById('statusList').appendChild(listItem);\n                } else {\n                    const listItem = document.createElement('li');\n                    listItem.innerText = `Bucket ${i + 1}: empty.`;\n                    document.getElementById('statusList').appendChild(listItem);\n                }\n            });\n\n            document.getElementById('output').innerText += ` | Sorted Numbers: [${sortedArray}]`;\n        }\n    </script>\n</body>\n</html>"
