    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Random Forest — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #081226;\n      --bg-2: #0b1a2b;\n      --glass: rgba(255,255,255,0.06);\n      --accent-1: #7ee1d0;\n      --accent-2: #ff7aad;\n      --muted: rgba(255,255,255,0.65);\n      --glass-2: rgba(255,255,255,0.04);\n      --card: rgba(255,255,255,0.03);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(124,58,237,0.12), transparent 6%),\n                  radial-gradient(900px 500px at 90% 90%, rgba(255,125,172,0.06), transparent 8%),\n                  linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n      color: #eaf3ff;\n      overflow:hidden;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:36px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    .frame{\n      width:1100px;\n      max-width:calc(100% - 72px);\n      height:640px;\n      border-radius:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.012));\n      box-shadow: 0 10px 30px rgba(7,10,25,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      overflow:hidden;\n      position:relative;\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap:24px;\n      padding:28px;\n    }\n\n    /* Left visual area */\n    .visual {\n      position:relative;\n      border-radius:14px;\n      overflow:hidden;\n      background:\n        linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n      padding:22px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      min-height:584px;\n    }\n\n    .visual .stage {\n      position:relative;\n      width:100%;\n      height:100%;\n      border-radius:12px;\n      overflow:hidden;\n      background:\n        radial-gradient(circle at 20% 10%, rgba(126,225,208,0.04), transparent 6%),\n        radial-gradient(circle at 85% 85%, rgba(255,122,173,0.035), transparent 8%),\n        linear-gradient(180deg, rgba(5,9,19,0.25), rgba(7,11,20,0.35));\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n\n    /* particle overlay */\n    .particles{\n      position:absolute;\n      inset:0;\n      pointer-events:none;\n      mix-blend-mode:screen;\n      opacity:0.8;\n    }\n    .particles svg{width:100%;height:100%}\n\n    /* canvas layers */\n    .layer{\n      position:absolute;\n      left:0;top:0;\n      width:100%;\n      height:100%;\n      display:block;\n      image-rendering: pixelated;\n    }\n\n    /* scatter overlay controls */\n    .overlayTop {\n      position:absolute;\n      left:28px;\n      top:22px;\n      display:flex;\n      align-items:center;\n      gap:14px;\n      z-index:9;\n    }\n\n    .title {\n      font-family:'Playfair Display', serif;\n      font-weight:700;\n      font-size:28px;\n      letter-spacing:-0.02em;\n      color: #f3f9ff;\n      text-shadow: 0 6px 18px rgba(126,225,208,0.06);\n    }\n    .subtitle {\n      font-size:12px;\n      color:var(--muted);\n      margin-top:-2px;\n    }\n\n    .controls {\n      position:absolute;\n      right:18px;\n      top:18px;\n      display:flex;\n      gap:10px;\n      z-index:10;\n    }\n    .btn {\n      -webkit-tap-highlight-color: transparent;\n      border: none;\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      backdrop-filter: blur(6px);\n      color:#fff;\n      padding:10px 14px;\n      border-radius:999px;\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n      cursor:pointer;\n      box-shadow: 0 6px 16px rgba(2,6,23,0.45), inset 0 1px 0 rgba(255,255,255,0.02);\n      transition: transform 220ms cubic-bezier(.2,.9,.3,1), box-shadow 220ms;\n      font-weight:600;\n      font-size:13px;\n    }\n    .btn:active{transform:translateY(1px)}\n    .btn.secondary{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:var(--muted);\n      font-weight:600;\n    }\n    .badge {\n      min-width:46px;\n      padding:6px 10px;\n      border-radius:999px;\n      background: linear-gradient(90deg, rgba(126,225,208,0.12), rgba(255,122,173,0.06));\n      color:#e8fbf5;\n      font-weight:700;\n      text-align:center;\n      font-size:12px;\n    }\n\n    /* Right info panel */\n    .panel {\n      padding:26px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.01);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-items:flex-start;\n    }\n\n    .panel h3{\n      margin:0;\n      font-family:'Playfair Display', serif;\n      font-weight:700;\n      font-size:20px;\n      color:#f6fbff;\n    }\n    .panel p{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n    }\n\n    .legend{\n      width:100%;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:6px;\n    }\n\n    .legend .swatch{\n      width:54px;\n      height:54px;\n      border-radius:10px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color:#fff;\n      font-weight:700;\n      font-size:12px;\n      box-shadow: 0 6px 20px rgba(2,6,23,0.5);\n    }\n\n    .swatch.gradient{\n      background: linear-gradient(135deg,#7ee1d0 0%, #ff7aad 100%);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n\n    .tiny{\n      font-size:12px;\n      color:var(--muted);\n    }\n\n    .panel .metrics{\n      display:flex;\n      gap:12px;\n      margin-top:6px;\n      width:100%;\n    }\n    .metric{\n      flex:1;\n      padding:12px;\n      border-radius:10px;\n      background:var(--glass-2);\n      text-align:center;\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .metric .num{\n      font-size:20px;\n      font-weight:700;\n      color:#fff;\n    }\n    .metric .lbl{\n      font-size:12px;\n      color:var(--muted);\n      margin-top:4px;\n    }\n\n    .explain {\n      margin-top:auto;\n      color:var(--muted);\n      font-size:12px;\n      line-height:1.45;\n    }\n\n    /* small footer */\n    .footer {\n      position:absolute;\n      left:28px;\n      bottom:20px;\n      color:rgba(255,255,255,0.06);\n      font-size:11px;\n      z-index:8;\n    }\n\n    /* subtle entry animations */\n    .fadeIn{\n      animation: fadeIn 800ms ease both;\n    }\n    @keyframes fadeIn{\n      from{opacity:0; transform:translateY(6px)}\n      to{opacity:1; transform:none}\n    }\n\n    /* responsive */\n    @media (max-width:1150px){\n      .frame{grid-template-columns: 1fr 360px}\n    }\n    @media (max-width:860px){\n      .frame{grid-template-columns: 1fr; height:auto; padding:20px}\n      .visual{order:2;height:520px}\n      .panel{order:1}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"frame fadeIn\" role=\"main\" aria-label=\"Random Forest visualization\">\n    <div class=\"visual\" aria-hidden=\"false\">\n      <div class=\"overlayTop\">\n        <div>\n          <div class=\"title\">Random Forest</div>\n          <div class=\"subtitle\">An ensemble of decision trees — vote to consensus</div>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"playBtn\" class=\"btn\" title=\"Play / Pause\">\n          <svg id=\"playIcon\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"filter:drop-shadow(0 4px 10px rgba(0,0,0,0.45));\">\n            <path d=\"M5 3v18l15-9L5 3z\" fill=\"url(#g1)\"></path>\n            <defs><linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7ee1d0\"/><stop offset=\"1\" stop-color=\"#ff7aad\"/></linearGradient></defs>\n          </svg>\n          <span id=\"playText\">Play</span>\n        </button>\n        <button id=\"randBtn\" class=\"btn secondary\" title=\"Randomize data\">\n          Randomize\n        </button>\n        <div class=\"badge\" id=\"treeCount\">0</div>\n      </div>\n\n      <div class=\"stage\" id=\"stage\">\n        <!-- layered canvases -->\n        <canvas id=\"heatmap\" class=\"layer\"></canvas>\n        <canvas id=\"overlay\" class=\"layer\"></canvas>\n        <canvas id=\"glow\" class=\"layer\"></canvas>\n\n        <!-- particles SVG for subtle magic -->\n        <div class=\"particles\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 800 520\" preserveAspectRatio=\"none\">\n            <defs>\n              <radialGradient id=\"p1\" cx=\"0.2\" cy=\"0.1\">\n                <stop offset=\"0\" stop-color=\"#7ee1d0\" stop-opacity=\"0.06\" />\n                <stop offset=\"1\" stop-color=\"transparent\" stop-opacity=\"0\" />\n              </radialGradient>\n              <radialGradient id=\"p2\" cx=\"0.9\" cy=\"0.9\">\n                <stop offset=\"0\" stop-color=\"#ff7aad\" stop-opacity=\"0.04\" />\n                <stop offset=\"1\" stop-color=\"transparent\" stop-opacity=\"0\" />\n              </radialGradient>\n            </defs>\n            <rect x=\"0\" y=\"0\" width=\"800\" height=\"520\" fill=\"url(#p1)\"></rect>\n            <rect x=\"0\" y=\"0\" width=\"800\" height=\"520\" fill=\"url(#p2)\"></rect>\n\n            <!-- drifting particles -->\n            <g opacity=\"0.55\" fill=\"#fff\">\n              <circle cx=\"120\" cy=\"60\" r=\"2.2\" fill=\"#ffffff\" />\n              <circle cx=\"80\" cy=\"210\" r=\"1.6\" fill=\"#ffffff\" />\n              <circle cx=\"680\" cy=\"120\" r=\"1.8\" fill=\"#ffffff\" />\n              <circle cx=\"520\" cy=\"420\" r=\"1.4\" fill=\"#ffffff\" />\n              <circle cx=\"720\" cy=\"80\" r=\"2.0\" fill=\"#ffffff\" />\n              <circle cx=\"260\" cy=\"360\" r=\"1.7\" fill=\"#ffffff\" />\n            </g>\n            <g opacity=\"0.16\" fill=\"#fff\">\n              <circle cx=\"420\" cy=\"80\" r=\"6\" />\n              <circle cx=\"360\" cy=\"260\" r=\"4\" />\n              <circle cx=\"700\" cy=\"400\" r=\"5\" />\n            </g>\n          </svg>\n        </div>\n\n        <div class=\"footer\">Visual metaphor: many trees vote to produce a smooth, confident decision surface</div>\n      </div>\n    </div>\n\n    <div class=\"panel fadeIn\" style=\"animation-delay:160ms\">\n      <h3>Random Forest — Ensemble Intuition</h3>\n      <p>Random Forests combine many decision trees, each built with randomization (data and features). Individually the trees are rough and jagged; together they average out variance to form a stable, accurate decision surface.</p>\n\n      <div class=\"legend\">\n        <div class=\"swatch gradient\">Ensemble</div>\n        <div style=\"flex:1\">\n          <div class=\"tiny\">Left: per-tree influence accumulates visually into a smooth heatmap. Right: data points (blue / pink) are used to build many randomized trees.</div>\n        </div>\n      </div>\n\n      <div class=\"metrics\">\n        <div class=\"metric\">\n          <div class=\"num\" id=\"metricTrees\">0</div>\n          <div class=\"lbl\">Trees in ensemble</div>\n        </div>\n        <div class=\"metric\">\n          <div class=\"num\" id=\"metricDepth\">4</div>\n          <div class=\"lbl\">Tree depth (per tree)</div>\n        </div>\n      </div>\n\n      <div class=\"explain\">\n        Minimal controls: Play to watch trees join the forest; Randomize to generate a new dataset. Observe how many jagged classifiers merge into a cohesive, pastel decision field — the essence of bagging and ensemble averaging.\n      </div>\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Canvas and sizing\n  const stage = document.getElementById('stage');\n  const heatmapCanvas = document.getElementById('heatmap');\n  const overlayCanvas = document.getElementById('overlay');\n  const glowCanvas = document.getElementById('glow');\n\n  // Controls\n  const playBtn = document.getElementById('playBtn');\n  const playText = document.getElementById('playText');\n  const randBtn = document.getElementById('randBtn');\n  const treeCountBadge = document.getElementById('treeCount');\n  const metricTrees = document.getElementById('metricTrees');\n  const metricDepth = document.getElementById('metricDepth');\n\n  // Visualization parameters\n  const GRID_W = 300;\n  const GRID_H = 220;\n  const SCALE = 1; // will scale by CSS to fit, but we use pixel ratio for crispness\n  const MAX_TREES = 80;\n  const DEPTH = 4;\n\n  metricDepth.textContent = DEPTH;\n\n  // Device pixel ratio handling\n  function setCanvasSize() {\n    const rect = stage.getBoundingClientRect();\n    // We'll size canvases to rect in pixels but our grid is fixed; we'll scale via CSS transform\n    heatmapCanvas.width = GRID_W;\n    heatmapCanvas.height = GRID_H;\n    overlayCanvas.width = GRID_W;\n    overlayCanvas.height = GRID_H;\n    glowCanvas.width = GRID_W;\n    glowCanvas.height = GRID_H;\n\n    // Scale canvases to fit the container while keeping aspect ratio\n    const fitW = rect.width - 44; // some padding\n    const fitH = rect.height - 44;\n    const scale = Math.min(fitW / GRID_W, fitH / GRID_H);\n    [heatmapCanvas, overlayCanvas, glowCanvas].forEach(c => {\n      c.style.width = Math.round(GRID_W * scale) + 'px';\n      c.style.height = Math.round(GRID_H * scale) + 'px';\n      c.style.left = Math.round((rect.width - GRID_W * scale) / 2) + 'px';\n      c.style.top = Math.round((rect.height - GRID_H * scale) / 2) + 'px';\n    });\n  }\n\n  setCanvasSize();\n  window.addEventListener('resize', () => {\n    setCanvasSize();\n    drawOverlay(); // redraw scatter for new scale\n  });\n\n  const heatCtx = heatmapCanvas.getContext('2d', {alpha:false});\n  const ovCtx = overlayCanvas.getContext('2d', {alpha:true});\n  const glowCtx = glowCanvas.getContext('2d', {alpha:true});\n\n  // Data generation\n  let points = []; // {x: 0-1, y:0-1, label:0/1}\n  function generateData() {\n    points = [];\n    // two Gaussian blobs\n    function sampleGaussian(cx, cy, sx, sy, n, label) {\n      for (let i = 0; i < n; i++) {\n        const u1 = Math.random();\n        const u2 = Math.random();\n        const r = Math.sqrt(-2*Math.log(u1));\n        const theta = 2*Math.PI*u2;\n        const gx = r*Math.cos(theta);\n        const gy = r*Math.sin(theta);\n        const x = Math.min(0.98, Math.max(0.02, cx + gx * sx));\n        const y = Math.min(0.98, Math.max(0.02, cy + gy * sy));\n        points.push({x,y,label});\n      }\n    }\n    // vary centers a bit\n    const cx1 = 0.32 + (Math.random()-0.5)*0.08;\n    const cy1 = 0.45 + (Math.random()-0.5)*0.08;\n    const cx2 = 0.68 + (Math.random()-0.5)*0.08;\n    const cy2 = 0.55 + (Math.random()-0.5)*0.08;\n\n    sampleGaussian(cx1, cy1, 0.08, 0.09, 70, 0);\n    sampleGaussian(cx2, cy2, 0.09, 0.08, 70, 1);\n\n    // small noise points\n    for (let i=0;i<12;i++){\n      points.push({x:Math.random()*0.92+0.04, y:Math.random()*0.92+0.04, label: Math.random()>.5?1:0});\n    }\n  }\n\n  // Simple randomized decision tree builder (axis-aligned splits only)\n  function buildTree(data, depth, featureSubset=false) {\n    function nodeFrom(points, depthLeft) {\n      // leaf if depth 0 or few points\n      const counts = [0,0];\n      for (const p of points) counts[p.label]++;\n      const majority = counts[0] >= counts[1] ? 0 : 1;\n      if (depthLeft === 0 || points.length < 6) {\n        return {leaf:true, prediction: majority};\n      }\n      // choose feature randomly (0=x,1=y)\n      const feat = (Math.random() < 0.5) ? 'x' : 'y';\n      // choose threshold between min and max of that feature among points\n      let min = Infinity, max = -Infinity;\n      for (const p of points) {\n        if (p[feat] < min) min = p[feat];\n        if (p[feat] > max) max = p[feat];\n      }\n      if (max - min < 1e-6) {\n        return {leaf:true, prediction: majority};\n      }\n      // random threshold within range\n      const thresh = min + Math.random() * (max - min);\n      const left = [], right = [];\n      for (const p of points) {\n        if (p[feat] <= thresh) left.push(p); else right.push(p);\n      }\n      // avoid degenerate split\n      if (left.length === 0 || right.length === 0) {\n        return {leaf:true, prediction: majority};\n      }\n      return {\n        leaf:false,\n        feature:feat,\n        thresh,\n        left: nodeFrom(left, depthLeft-1),\n        right: nodeFrom(right, depthLeft-1)\n      };\n    }\n    return nodeFrom(data, depth);\n  }\n\n  // Evaluate tree at a point (x,y)\n  function evalTree(tree, x, y) {\n    let node = tree;\n    while (!node.leaf) {\n      if ((node.feature === 'x' ? x : y) <= node.thresh) node = node.left;\n      else node = node.right;\n    }\n    return node.prediction;\n  }\n\n  // Build many trees and precompute their predictions on the grid\n  let trees = [];\n  let treePreds = []; // array of Uint8Array of length GRID_W*GRID_H, 0/1\n  function buildForest(maxTrees=MAX_TREES) {\n    trees = [];\n    treePreds = [];\n    // build a copy of dataset (bootstrap sampling per tree)\n    for (let t=0;t<maxTrees;t++){\n      // bootstrap sample\n      const sample = [];\n      for (let i=0;i<points.length;i++){\n        sample.push(points[Math.floor(Math.random()*points.length)]);\n      }\n      const tree = buildTree(sample, DEPTH);\n      trees.push(tree);\n\n      // compute predictions on grid\n      const arr = new Uint8Array(GRID_W * GRID_H);\n      let idx = 0;\n      for (let j=0;j<GRID_H;j++){\n        const y = (j + 0.5) / GRID_H;\n        for (let i=0;i<GRID_W;i++){\n          const x = (i + 0.5) / GRID_W;\n          arr[idx++] = evalTree(tree, x, y);\n        }\n      }\n      treePreds.push(arr);\n    }\n  }\n\n  // Visualization state\n  let aggregated = new Float32Array(GRID_W * GRID_H);\n  let currentTrees = 0;\n  let playing = false;\n  let interval = null;\n\n  function resetAggregation(){\n    aggregated = new Float32Array(GRID_W * GRID_H);\n    currentTrees = 0;\n    updateBadges();\n  }\n\n  function updateBadges(){\n    treeCountBadge.textContent = currentTrees;\n    metricTrees.textContent = currentTrees;\n  }\n\n  // Color mapping (soft pastel blend between teal and pink)\n  function colorForValue(v) {\n    // v: 0..1 proportion for class 1\n    // map to a pastel gradient: teal (class0) -> light purple -> pink (class1)\n    const r = Math.round( (1-v) * 126 + v * 255 ); // base mix\n    const g = Math.round( (1-v) * 225 + v * 122 );\n    const b = Math.round( (1-v) * 208 + v * 173 );\n    const alpha = 220;\n    return [r,g,b,alpha];\n  }\n\n  // Render heatmap to heatCtx via ImageData\n  function renderHeatmap(proportions) {\n    const w = GRID_W, h = GRID_H;\n    const img = heatCtx.createImageData(w, h);\n    const data = img.data;\n    let idx = 0;\n    for (let k=0;k<w*h;k++){\n      const v = proportions[k]; // proportion where class=1\n      const [r,g,b,a] = colorForValue(v);\n      data[idx++] = r;\n      data[idx++] = g;\n      data[idx++] = b;\n      // alpha scaled with confidence away from 0.5\n      const confidence = Math.abs(v - 0.5) * 2; // 0..1\n      data[idx++] = Math.round(a * (0.25 + 0.75*confidence));\n    }\n    heatCtx.putImageData(img, 0, 0);\n\n    // add a subtle gaussian-ish glow layer for softness\n    glowCtx.clearRect(0,0,w,h);\n    glowCtx.globalAlpha = 0.6;\n    glowCtx.drawImage(heatmapCanvas, 0, 0);\n    glowCtx.globalAlpha = 1;\n    // apply a small blur by scaling down/up (cheap blur)\n    const tmp = document.createElement('canvas');\n    tmp.width = Math.round(w*0.25);\n    tmp.height = Math.round(h*0.25);\n    const tmpCtx = tmp.getContext('2d');\n    tmpCtx.drawImage(glowCanvas, 0, 0, tmp.width, tmp.height);\n    glowCtx.clearRect(0,0,w,h);\n    glowCtx.globalAlpha = 0.14;\n    glowCtx.drawImage(tmp, 0, 0, w, h);\n    glowCtx.globalAlpha = 1.0;\n    // overlay heatmap again for crisp edges\n  }\n\n  // Draw scatter and visual tree outlines (stylized)\n  function drawOverlay(highlight=false) {\n    const w = GRID_W, h = GRID_H;\n    ovCtx.clearRect(0,0,w,h);\n\n    // draw soft radial vignette\n    const grad = ovCtx.createLinearGradient(0,0,w,h);\n    grad.addColorStop(0, \"rgba(255,255,255,0.02)\");\n    grad.addColorStop(1, \"rgba(0,0,0,0.04)\");\n    ovCtx.fillStyle = grad;\n    ovCtx.fillRect(0,0,w,h);\n\n    // draw stylized tree silhouettes to emphasize \"forest\" (non-intrusive)\n    ovCtx.save();\n    ovCtx.globalAlpha = 0.06;\n    for (let k=0;k<12;k++){\n      // random position from different zones\n      const tx = (k%4)/4 + ((k%3)/24);\n      const ty = (Math.floor(k/4)/3) * 0.9 + 0.05;\n      const px = Math.floor(tx * w + Math.sin(k*11.3)*8);\n      const py = Math.floor(ty * h + Math.cos(k*7.1)*6);\n      const scale = 20 + (k%4)*10;\n      drawTreeSilhouette(px,py, scale, k*7);\n    }\n    ovCtx.restore();\n\n    // scatter points\n    for (const p of points) {\n      const x = Math.floor(p.x * w);\n      const y = Math.floor(p.y * h);\n      ovCtx.beginPath();\n      ovCtx.arc(x, y, 2.6, 0, Math.PI*2);\n      if (p.label === 0) {\n        ovCtx.fillStyle = 'rgba(126,225,208,0.95)';\n        ovCtx.shadowColor = 'rgba(126,225,208,0.14)';\n        ovCtx.shadowBlur = 10;\n      } else {\n        ovCtx.fillStyle = 'rgba(255,122,173,0.95)';\n        ovCtx.shadowColor = 'rgba(255,122,173,0.14)';\n        ovCtx.shadowBlur = 10;\n      }\n      ovCtx.fill();\n      ovCtx.shadowBlur = 0;\n    }\n\n    // subtle grid lines to suggest partitions (for aesthetics)\n    ovCtx.globalAlpha = 0.06;\n    ovCtx.strokeStyle = 'rgba(255,255,255,0.08)';\n    ovCtx.lineWidth = 1;\n    for (let i=1;i<6;i++){\n      const xx = Math.round(i*w/6);\n      ovCtx.beginPath();\n      ovCtx.moveTo(xx,0);\n      ovCtx.lineTo(xx,h);\n      ovCtx.stroke();\n    }\n    for (let j=1;j<5;j++){\n      const yy = Math.round(j*h/5);\n      ovCtx.beginPath();\n      ovCtx.moveTo(0,yy);\n      ovCtx.lineTo(w,yy);\n      ovCtx.stroke();\n    }\n  }\n\n  function drawTreeSilhouette(cx,cy, size, seed){\n    // trunk\n    ovCtx.save();\n    ovCtx.translate(cx,cy);\n    ovCtx.rotate((seed%37 - 18) * Math.PI/180);\n    ovCtx.beginPath();\n    ovCtx.fillStyle = 'rgba(255,255,255,0.02)';\n    ovCtx.moveTo(-size*0.06, size*0.28);\n    ovCtx.quadraticCurveTo(0, size*0.18, size*0.08, size*0.28);\n    ovCtx.lineTo(size*0.08, size*0.5);\n    ovCtx.lineTo(-size*0.06, size*0.5);\n    ovCtx.closePath();\n    ovCtx.fill();\n\n    // canopy layers\n    for (let i=0;i<3;i++){\n      const r = size*0.28 - i*8;\n      ovCtx.beginPath();\n      const t = i / 3;\n      ovCtx.fillStyle = `rgba(126,225,208,${0.04 - i*0.01})`;\n      ovCtx.ellipse(0, -12 + i*6, r, r*0.6, 0, 0, Math.PI*2);\n      ovCtx.fill();\n    }\n    ovCtx.restore();\n  }\n\n  // Animation loop: progressively add trees and update visualization\n  function stepAddTree() {\n    if (currentTrees >= treePreds.length) {\n      playing = false;\n      clearInterval(interval);\n      interval = null;\n      playText.textContent = 'Play';\n      playBtn.classList.remove('playing');\n      return;\n    }\n    // add the next tree predictions\n    const next = treePreds[currentTrees];\n    for (let k=0;k<aggregated.length;k++){\n      aggregated[k] += next[k];\n    }\n    currentTrees++;\n    updateBadges();\n\n    // compute proportions\n    const proportions = new Float32Array(aggregated.length);\n    for (let k=0;k<aggregated.length;k++){\n      proportions[k] = aggregated[k] / currentTrees;\n    }\n\n    renderHeatmap(proportions);\n    // overlay clear and draw scatter etc\n    drawOverlay();\n  }\n\n  // Initialize\n  function initialize() {\n    generateData();\n    buildForest(MAX_TREES);\n    resetAggregation();\n    // initial render: empty soft background\n    const empty = new Float32Array(GRID_W*GRID_H);\n    renderHeatmap(empty);\n    drawOverlay();\n  }\n\n  // Controls behavior\n  playBtn.addEventListener('click', () => {\n    if (!playing) {\n      // start playing\n      playing = true;\n      playText.textContent = 'Pause';\n      playBtn.classList.add('playing');\n      // if finished, allow replay resets\n      if (currentTrees >= treePreds.length) {\n        resetAggregation();\n      }\n      interval = setInterval(() => {\n        stepAddTree();\n      }, 90);\n    } else {\n      // pause\n      playing = false;\n      playText.textContent = 'Play';\n      playBtn.classList.remove('playing');\n      if (interval) {\n        clearInterval(interval);\n        interval = null;\n      }\n    }\n  });\n\n  randBtn.addEventListener('click', () => {\n    // stop animation\n    playing = false;\n    playText.textContent = 'Play';\n    if (interval) { clearInterval(interval); interval = null; }\n    // regenerate dataset and rebuild forest\n    generateData();\n    buildForest(MAX_TREES);\n    resetAggregation();\n    renderHeatmap(new Float32Array(GRID_W*GRID_H));\n    drawOverlay();\n  });\n\n  // Initial call\n  initialize();\n\n  // small entrance animation for the heatmap to make it luscious\n  (function entrancePulse(){\n    let t = 0;\n    const steps = 18;\n    const id = setInterval(()=>{\n      t++;\n      const alpha = t/steps;\n      heatCtx.globalAlpha = alpha * 0.9 + 0.1;\n      // re-render with current aggregated (initially empty)\n      const proportions = new Float32Array(aggregated.length);\n      if (currentTrees>0) {\n        for (let k=0;k<aggregated.length;k++) proportions[k] = aggregated[k]/currentTrees;\n      }\n      renderHeatmap(proportions);\n      drawOverlay();\n      if (t>=steps) clearInterval(id);\n    }, 24);\n  })();\n\n  // subtle idle animation: slowly wiggle particle SVG for life\n  (function animateParticles(){\n    const svg = stage.querySelector('.particles svg');\n    let s=0;\n    function tick(){\n      s += 0.002;\n      svg.style.transform = `translateY(${Math.sin(s*2)*4}px) rotate(${Math.sin(s)*0.2}deg)`;\n      requestAnimationFrame(tick);\n    }\n    tick();\n  })();\n\n  // Accessibility: keyboard shortcut for play/pause (space)\n  window.addEventListener('keydown', (e)=>{\n    if (e.code === 'Space') {\n      e.preventDefault();\n      playBtn.click();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
