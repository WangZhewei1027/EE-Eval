    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Neural Beauty: The Art of Backpropagation</title>\n    <style>\n        :root {\n            --primary: #6a11cb;\n            --secondary: #2575fc;\n            --accent: #ff4e50;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --shadow: 0 4px 30px rgba(0, 0, 0, 0.1);\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            padding: 2rem;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            background: rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(10px);\n            border-radius: 20px;\n            box-shadow: var(--shadow);\n            border: 1px solid rgba(255, 255, 255, 0.2);\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--light), #f3f4f6);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            position: relative;\n            height: 500px;\n            margin: 3rem 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .neural-network {\n            position: relative;\n            width: 100%;\n            height: 100%;\n        }\n\n        .layer {\n            position: absolute;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-around;\n            align-items: center;\n        }\n\n        .layer-1 { left: 10%; }\n        .layer-2 { left: 40%; }\n        .layer-3 { left: 70%; }\n\n        .neuron {\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background: rgba(255, 255, 255, 0.9);\n            box-shadow: 0 0 20px rgba(255, 255, 255, 0.3);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: bold;\n            color: var(--dark);\n            position: relative;\n            transition: all 0.3s ease;\n            z-index: 2;\n        }\n\n        .connection {\n            position: absolute;\n            background: linear-gradient(to right, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.1));\n            height: 2px;\n            transform-origin: left center;\n            z-index: 1;\n            transition: all 0.5s ease;\n        }\n\n        .error-path {\n            position: absolute;\n            background: var(--accent);\n            height: 3px;\n            transform-origin: left center;\n            z-index: 3;\n            opacity: 0;\n            box-shadow: 0 0 10px var(--accent);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            background: rgba(255, 255, 255, 0.2);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n            color: white;\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(5px);\n        }\n\n        button:hover {\n            background: rgba(255, 255, 255, 0.3);\n            transform: translateY(-2px);\n        }\n\n        .explanation {\n            margin-top: 4rem;\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n            background: rgba(0, 0, 0, 0.2);\n            padding: 2rem;\n            border-radius: 15px;\n            line-height: 1.7;\n        }\n\n        .explanation h2 {\n            margin-bottom: 1rem;\n            font-weight: 300;\n            font-size: 1.8rem;\n        }\n\n        .explanation p {\n            margin-bottom: 1rem;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.1); }\n            100% { transform: scale(1); }\n        }\n\n        @keyframes highlight {\n            0% { box-shadow: 0 0 0 0 rgba(255, 78, 80, 0.4); }\n            70% { box-shadow: 0 0 0 15px rgba(255, 78, 80, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(255, 78, 80, 0); }\n        }\n\n        .highlight {\n            animation: highlight 1.5s ease-out;\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>The Beauty of Backpropagation</h1>\n            <p class=\"subtitle\">Witness the elegant dance of error correction through a neural network, where gradients flow backward to refine the model's understanding.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"neural-network\">\n                <!-- Input Layer -->\n                <div class=\"layer layer-1\">\n                    <div class=\"neuron\" id=\"input-1\">x₁</div>\n                    <div class=\"neuron\" id=\"input-2\">x₂</div>\n                    <div class=\"neuron\" id=\"input-3\">x₃</div>\n                </div>\n\n                <!-- Hidden Layer -->\n                <div class=\"layer layer-2\">\n                    <div class=\"neuron\" id=\"hidden-1\">h₁</div>\n                    <div class=\"neuron\" id=\"hidden-2\">h₂</div>\n                    <div class=\"neuron\" id=\"hidden-3\">h₃</div>\n                </div>\n\n                <!-- Output Layer -->\n                <div class=\"layer layer-3\">\n                    <div class=\"neuron\" id=\"output-1\">ŷ</div>\n                </div>\n\n                <!-- Connections will be added by JavaScript -->\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"forward-btn\">Run Forward Pass</button>\n            <button id=\"backprop-btn\">Run Backpropagation</button>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>The Art Behind the Algorithm</h2>\n            <p>Backpropagation is the cornerstone of modern neural networks, allowing them to learn from their mistakes. This elegant algorithm calculates the gradient of the loss function with respect to each weight by applying the chain rule, propagating errors backward through the network.</p>\n            <p>As you watch the visualization, notice how the error signal flows from the output back to the input layer, adjusting connection weights along the way. This process, repeated across thousands of iterations, gradually sculpts the network into a powerful predictor.</p>\n            <p>The beauty lies in its simplicity and universality - the same fundamental process powers everything from image recognition to natural language understanding.</p>\n        </div>\n\n        <footer>\n            <p>© 2023 Neural Beauty | Aesthetic Machine Learning Visualizations</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create connections between neurons\n            const network = document.querySelector('.neural-network');\n            \n            // Input to Hidden connections\n            const inputNeurons = document.querySelectorAll('.layer-1 .neuron');\n            const hiddenNeurons = document.querySelectorAll('.layer-2 .neuron');\n            \n            inputNeurons.forEach(input => {\n                hiddenNeurons.forEach(hidden => {\n                    createConnection(input, hidden, false);\n                });\n            });\n            \n            // Hidden to Output connections\n            const outputNeurons = document.querySelectorAll('.layer-3 .neuron');\n            \n            hiddenNeurons.forEach(hidden => {\n                outputNeurons.forEach(output => {\n                    createConnection(hidden, output, false);\n                });\n            });\n            \n            // Create error paths (initially hidden)\n            const errorPaths = [];\n            \n            outputNeurons.forEach(output => {\n                hiddenNeurons.forEach(hidden => {\n                    const path = createConnection(hidden, output, true);\n                    errorPaths.push(path);\n                });\n                \n                hiddenNeurons.forEach(hidden => {\n                    inputNeurons.forEach(input => {\n                        const path = createConnection(input, hidden, true);\n                        errorPaths.push(path);\n                    });\n                });\n            });\n            \n            // Button event listeners\n            document.getElementById('forward-btn').addEventListener('click', runForwardPass);\n            document.getElementById('backprop-btn').addEventListener('click', runBackpropagation);\n            \n            // Helper function to create connections\n            function createConnection(start, end, isErrorPath) {\n                const startRect = start.getBoundingClientRect();\n                const endRect = end.getBoundingClientRect();\n                \n                const startX = startRect.left + startRect.width / 2;\n                const startY = startRect.top + startRect.height / 2;\n                const endX = endRect.left + endRect.width / 2;\n                const endY = endRect.top + endRect.height / 2;\n                \n                const length = Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2));\n                const angle = Math.atan2(endY - startY, endX - startX) * 180 / Math.PI;\n                \n                const connection = document.createElement('div');\n                connection.className = isErrorPath ? 'error-path' : 'connection';\n                \n                connection.style.width = `${length}px`;\n                connection.style.left = `${startX}px`;\n                connection.style.top = `${startY}px`;\n                connection.style.transform = `rotate(${angle}deg)`;\n                \n                if (isErrorPath) {\n                    connection.style.opacity = '0';\n                }\n                \n                document.body.appendChild(connection);\n                return connection;\n            }\n            \n            // Forward pass animation\n            function runForwardPass() {\n                // Reset all animations\n                document.querySelectorAll('.neuron').forEach(neuron => {\n                    neuron.classList.remove('highlight', 'pulse');\n                });\n                \n                document.querySelectorAll('.error-path').forEach(path => {\n                    path.style.opacity = '0';\n                });\n                \n                // Animate input layer\n                inputNeurons.forEach((neuron, i) => {\n                    setTimeout(() => {\n                        neuron.classList.add('highlight');\n                    }, i * 300);\n                });\n                \n                // Animate hidden layer\n                hiddenNeurons.forEach((neuron, i) => {\n                    setTimeout(() => {\n                        neuron.classList.add('highlight');\n                    }, inputNeurons.length * 300 + i * 200);\n                });\n                \n                // Animate output layer\n                outputNeurons.forEach((neuron, i) => {\n                    setTimeout(() => {\n                        neuron.classList.add('highlight', 'pulse');\n                    }, inputNeurons.length * 300 + hiddenNeurons.length * 200 + i * 300);\n                });\n            }\n            \n            // Backpropagation animation\n            function runBackpropagation() {\n                // First run forward pass to set context\n                runForwardPass();\n                \n                // Then show error propagation\n                setTimeout(() => {\n                    // Highlight output error\n                    outputNeurons.forEach(neuron => {\n                        neuron.style.backgroundColor = 'rgba(255, 78, 80, 0.8)';\n                    });\n                    \n                    // Show error paths from output to hidden\n                    const hiddenToOutputPaths = Array.from(document.querySelectorAll('.error-path'))\n                        .filter(path => {\n                            const angle = parseFloat(path.style.transform.replace('rotate(', '').replace('deg)', ''));\n                            return angle > -90 && angle < 90; // Approximate rightward paths\n                        });\n                    \n                    hiddenToOutputPaths.forEach((path, i) => {\n                        setTimeout(() => {\n                            path.style.opacity = '1';\n                            path.style.width = '0';\n                            path.style.transition = 'width 1s ease-out, opacity 0.5s ease-in';\n                            setTimeout(() => {\n                                path.style.width = path.getAttribute('data-length') || '100px';\n                            }, 50);\n                        }, i * 200);\n                    });\n                    \n                    // Highlight hidden layer neurons\n                    setTimeout(() => {\n                        hiddenNeurons.forEach((neuron, i) => {\n                            setTimeout(() => {\n                                neuron.style.backgroundColor = 'rgba(255, 78, 80, 0.6)';\n                                neuron.classList.add('pulse');\n                            }, i * 300);\n                        });\n                    }, hiddenToOutputPaths.length * 200);\n                    \n                    // Show error paths from hidden to input\n                    const inputToHiddenPaths = Array.from(document.querySelectorAll('.error-path'))\n                        .filter(path => {\n                            const angle = parseFloat(path.style.transform.replace('rotate(', '').replace('deg)', ''));\n                            return angle < -90 || angle > 90; // Approximate leftward paths\n                        });\n                    \n                    setTimeout(() => {\n                        inputToHiddenPaths.forEach((path, i) => {\n                            setTimeout(() => {\n                                path.style.opacity = '1';\n                                path.style.width = '0';\n                                path.style.transition = 'width 1s ease-out, opacity 0.5s ease-in';\n                                setTimeout(() => {\n                                    path.style.width = path.getAttribute('data-length') || '100px';\n                                }, 50);\n                            }, i * 200);\n                        });\n                    }, hiddenToOutputPaths.length * 200 + hiddenNeurons.length * 300);\n                    \n                    // Highlight input layer neurons\n                    setTimeout(() => {\n                        inputNeurons.forEach((neuron, i) => {\n                            setTimeout(() => {\n                                neuron.style.backgroundColor = 'rgba(255, 78, 80, 0.4)';\n                                neuron.classList.add('pulse');\n                            }, i * 300);\n                        });\n                    }, hiddenToOutputPaths.length * 200 + hiddenNeurons.length * 300 + inputToHiddenPaths.length * 200);\n                    \n                    // Reset colors after animation\n                    setTimeout(() => {\n                        document.querySelectorAll('.neuron').forEach(neuron => {\n                            neuron.style.backgroundColor = 'rgba(255, 255, 255, 0.9)';\n                            neuron.classList.remove('pulse');\n                        });\n                    }, hiddenToOutputPaths.length * 200 + hiddenNeurons.length * 300 + inputToHiddenPaths.length * 200 + inputNeurons.length * 300 + 1000);\n                    \n                }, inputNeurons.length * 300 + hiddenNeurons.length * 200 + outputNeurons.length * 300 + 500);\n            }\n        });\n    </script>\n</body>\n</html>"
