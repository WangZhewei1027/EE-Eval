  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Merge Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 1000px;\n            margin: 0 auto;\n        }\n        .array-container {\n            display: flex;\n            margin: 20px 0;\n            height: 200px;\n            align-items: flex-end;\n        }\n        .array-bar {\n            flex: 1;\n            background-color: #ddd;\n            margin: 0 1px;\n            position: relative;\n        }\n        .array-bar {\n            background-color: #555;\n            width: 100%;\n        }\n        .controls {\n            margin: 20px 0;\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-bottom: 10px;\n        }\n        button {\n            padding: 5px 10px;\n            margin: 2px;\n        }\n        input[type=\"range\"] {\n            width: 200px;\n        }\n        .explanation {\n            margin: 20px 0;\n            padding: 10px;\n            border: 1px solid #eee;\n        }\n        .highlight {\n            background-color: yellow;\n        }\n        .merge-highlight {\n            background-color: lightblue;\n        }\n        .sorted {\n            background-color: lightgreen;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Merge Sort</h1>\n        \n        <div class=\"control-group\">\n            <h3>Array Configuration</h3>\n            <div>\n                <label for=\"arraySize\">Array Size:</label>\n                <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"30\" value=\"15\">\n                <span id=\"arraySizeValue\">15</span>\n            </div>\n            <div>\n                <label for=\"arrayType\">Array Type:</label>\n                <select id=\"arrayType\">\n                    <option value=\"random\">Random</option>\n                    <option value=\"sorted\">Sorted</option>\n                    <option value=\"reverse\">Reverse Sorted</option>\n                    <option value=\"fewUnique\">Few Unique</option>\n                </select>\n            </div>\n            <button id=\"generateArray\">Generate New Array</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Sorting Controls</h3>\n            <button id=\"startSort\">Start Merge Sort</button>\n            <button id=\"pauseSort\" disabled>Pause</button>\n            <button id=\"stepSort\" disabled>Step</button>\n            <button id=\"resetSort\">Reset</button>\n            \n            <div>\n                <label for=\"speedControl\">Animation Speed:</label>\n                <input type=\"range\" id=\"speedControl\" min=\"1\" max=\"10\" value=\"5\">\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Visualization Options</h3>\n            <div>\n                <input type=\"checkbox\" id=\"showRecursion\" checked>\n                <label for=\"showRecursion\">Show Recursion Depth</label>\n            </div>\n            <div>\n                <input type=\"checkbox\" id=\"showMerge\" checked>\n                <label for=\"showMerge\">Highlight Merge Operations</label>\n            </div>\n        </div>\n        \n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n        \n        <div class=\"explanation\" id=\"explanation\">\n            <h3>Algorithm Explanation</h3>\n            <p>Click \"Start Merge Sort\" to begin the visualization.</p>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Detailed View</h3>\n            <div id=\"callStack\"></div>\n            <div id=\"currentStep\"></div>\n            <div id=\"comparisons\">Comparisons: 0</div>\n            <div id=\"merges\">Merges: 0</div>\n            <div id=\"recursionDepth\">Recursion Depth: 0</div>\n        </div>\n    </div>\n\n    <script>\n        // Global variables\n        let array = [];\n        let animationQueue = [];\n        let isSorting = false;\n        let isPaused = false;\n        let animationSpeed = 5;\n        let comparisons = 0;\n        let merges = 0;\n        let maxRecursionDepth = 0;\n        let currentRecursionDepth = 0;\n        \n        // DOM elements\n        const arrayContainer = document.getElementById('arrayContainer');\n        const arraySizeInput = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const arrayTypeSelect = document.getElementById('arrayType');\n        const generateArrayBtn = document.getElementById('generateArray');\n        const startSortBtn = document.getElementById('startSort');\n        const pauseSortBtn = document.getElementById('pauseSort');\n        const stepSortBtn = document.getElementById('stepSort');\n        const resetSortBtn = document.getElementById('resetSort');\n        const speedControl = document.getElementById('speedControl');\n        const showRecursionCheckbox = document.getElementById('showRecursion');\n        const showMergeCheckbox = document.getElementById('showMerge');\n        const explanationDiv = document.getElementById('explanation');\n        const callStackDiv = document.getElementById('callStack');\n        const currentStepDiv = document.getElementById('currentStep');\n        const comparisonsDiv = document.getElementById('comparisons');\n        const mergesDiv = document.getElementById('merges');\n        const recursionDepthDiv = document.getElementById('recursionDepth');\n        \n        // Initialize\n        document.addEventListener('DOMContentLoaded', () => {\n            generateNewArray();\n            setupEventListeners();\n        });\n        \n        function setupEventListeners() {\n            arraySizeInput.addEventListener('input', updateArraySize);\n            generateArrayBtn.addEventListener('click', generateNewArray);\n            startSortBtn.addEventListener('click', startMergeSort);\n            pauseSortBtn.addEventListener('click', togglePause);\n            stepSortBtn.addEventListener('click', processNextStep);\n            resetSortBtn.addEventListener('click', resetVisualization);\n            speedControl.addEventListener('input', updateSpeed);\n        }\n        \n        function updateArraySize() {\n            const size = arraySizeInput.value;\n            arraySizeValue.textContent = size;\n        }\n        \n        function updateSpeed() {\n            animationSpeed = 11 - speedControl.value; // Invert so higher = faster\n        }\n        \n        function generateNewArray() {\n            if (isSorting) return;\n            \n            const size = parseInt(arraySizeInput.value);\n            const type = arrayTypeSelect.value;\n            \n            array = [];\n            \n            switch(type) {\n                case 'random':\n                    for (let i = 0; i < size; i++) {\n                        array.push(Math.floor(Math.random() * 100) + 1);\n                    }\n                    break;\n                case 'sorted':\n                    for (let i = 0; i < size; i++) {\n                        array.push(Math.floor((i + 1) * (100 / size)));\n                    }\n                    break;\n                case 'reverse':\n                    for (let i = 0; i < size; i++) {\n                        array.push(Math.floor((size - i) * (100 / size)));\n                    }\n                    break;\n                case 'fewUnique':\n                    const uniqueValues = [10, 30, 50, 70, 90];\n                    for (let i = 0; i < size; i++) {\n                        array.push(uniqueValues[Math.floor(Math.random() * uniqueValues.length)]);\n                    }\n                    break;\n            }\n            \n            renderArray();\n            resetStats();\n        }\n        \n        function renderArray(highlights = [], mergeHighlights = [], sortedIndices = []) {\n            arrayContainer.innerHTML = '';\n            const maxValue = Math.max(...array, 1);\n            \n            array.forEach((value, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'array-bar';\n                \n                const barHeight = (value / maxValue) * 100;\n                const barInner = document.createElement('div');\n                barInner.className = 'array-bar';\n                barInner.style.height = `${barHeight}%`;\n                \n                if (highlights.includes(index)) {\n                    barInner.classList.add('highlight');\n                }\n                \n                if (mergeHighlights.includes(index)) {\n                    barInner.classList.add('merge-highlight');\n                }\n                \n                if (sortedIndices.includes(index)) {\n                    barInner.classList.add('sorted');\n                }\n                \n                if (showRecursionCheckbox.checked) {\n                    barInner.style.backgroundColor = `hsl(${currentRecursionDepth * 30}, 70%, 60%)`;\n                }\n                \n                const label = document.createElement('div');\n                label.textContent = value;\n                label.style.textAlign = 'center';\n                label.style.fontSize = '10px';\n                \n                bar.appendChild(barInner);\n                bar.appendChild(label);\n                arrayContainer.appendChild(bar);\n            });\n        }\n        \n        function resetStats() {\n            comparisons = 0;\n            merges = 0;\n            maxRecursionDepth = 0;\n            currentRecursionDepth = 0;\n            updateStats();\n        }\n        \n        function updateStats() {\n            comparisonsDiv.textContent = `Comparisons: ${comparisons}`;\n            mergesDiv.textContent = `Merges: ${merges}`;\n            recursionDepthDiv.textContent = `Recursion Depth: ${currentRecursionDepth} (Max: ${maxRecursionDepth})`;\n        }\n        \n        function startMergeSort() {\n            if (isSorting) return;\n            \n            resetStats();\n            animationQueue = [];\n            isSorting = true;\n            isPaused = false;\n            \n            startSortBtn.disabled = true;\n            pauseSortBtn.disabled = false;\n            stepSortBtn.disabled = false;\n            generateArrayBtn.disabled = true;\n            \n            // Generate the animation queue\n            const arrayCopy = [...array];\n            mergeSort(arrayCopy, 0, array.length - 1);\n            \n            // Process the animation queue\n            processAnimationQueue();\n        }\n        \n        function mergeSort(arr, left, right) {\n            currentRecursionDepth++;\n            maxRecursionDepth = Math.max(maxRecursionDepth, currentRecursionDepth);\n            \n            // Add to call stack visualization\n            const callId = `${left}-${right}`;\n            addToCallStack(`mergeSort(${left}, ${right})`, callId);\n            \n            // Highlight current segment\n            animationQueue.push({\n                type: 'highlight',\n                indices: Array.from({length: right - left + 1}, (_, i) => left + i),\n                recursionDepth: currentRecursionDepth,\n                callId\n            });\n            \n            if (left < right) {\n                const mid = Math.floor((left + right) / 2);\n                \n                // Explanation\n                animationQueue.push({\n                    type: 'explanation',\n                    text: `Dividing array from index ${left} to ${right} at midpoint ${mid}`\n                });\n                \n                // Recursively sort left and right halves\n                mergeSort(arr, left, mid);\n                mergeSort(arr, mid + 1, right);\n                \n                // Merge the sorted halves\n                merge(arr, left, mid, right);\n            } else {\n                // Base case - single element is already sorted\n                animationQueue.push({\n                    type: 'sorted',\n                    indices: [left],\n                    callId\n                });\n                \n                animationQueue.push({\n                    type: 'explanation',\n                    text: `Base case reached - single element at index ${left} is already sorted`\n                });\n            }\n            \n            // Remove from call stack visualization\n            animationQueue.push({\n                type: 'removeFromCallStack',\n                callId\n            });\n            \n            currentRecursionDepth--;\n        }\n        \n        function merge(arr, left, mid, right) {\n            merges++;\n            \n            // Explanation\n            animationQueue.push({\n                type: 'explanation',\n                text: `Merging sorted subarrays from ${left}-${mid} and ${mid+1}-${right}`\n            });\n            \n            const n1 = mid - left + 1;\n            const n2 = right - mid;\n            \n            // Create temp arrays\n            const L = new Array(n1);\n            const R = new Array(n2);\n            \n            // Copy data to temp arrays\n            for (let i = 0; i < n1; i++) {\n                L[i] = arr[left + i];\n            }\n            for (let j = 0; j < n2; j++) {\n                R[j] = arr[mid + 1 + j];\n            }\n            \n            // Merge the temp arrays back into arr[left..right]\n            let i = 0, j = 0, k = left;\n            \n            while (i < n1 && j < n2) {\n                comparisons++;\n                \n                // Highlight the elements being compared\n                animationQueue.push({\n                    type: 'compare',\n                    indices: [left + i, mid + 1 + j],\n                    comparison: `${L[i]} <= ${R[j]}`\n                });\n                \n                if (L[i] <= R[j]) {\n                    animationQueue.push({\n                        type: 'overwrite',\n                        index: k,\n                        value: L[i],\n                        from: left + i,\n                        mergeHighlight: true\n                    });\n                    arr[k] = L[i];\n                    i++;\n                } else {\n                    animationQueue.push({\n                        type: 'overwrite',\n                        index: k,\n                        value: R[j],\n                        from: mid + 1 + j,\n                        mergeHighlight: true\n                    });\n                    arr[k] = R[j];\n                    j++;\n                }\n                k++;\n            }\n            \n            // Copy remaining elements of L[] if any\n            while (i < n1) {\n                animationQueue.push({\n                    type: 'overwrite',\n                    index: k,\n                    value: L[i],\n                    from: left + i,\n                    mergeHighlight: true\n                });\n                arr[k] = L[i];\n                i++;\n                k++;\n            }\n            \n            // Copy remaining elements of R[] if any\n            while (j < n2) {\n                animationQueue.push({\n                    type: 'overwrite',\n                    index: k,\n                    value: R[j],\n                    from: mid + 1 + j,\n                    mergeHighlight: true\n                });\n                arr[k] = R[j];\n                j++;\n                k++;\n            }\n            \n            // Mark the merged segment as sorted\n            animationQueue.push({\n                type: 'sorted',\n                indices: Array.from({length: right - left + 1}, (_, i) => left + i)\n            });\n        }\n        \n        function processAnimationQueue() {\n            if (isPaused || animationQueue.length === 0) {\n                if (animationQueue.length === 0) {\n                    sortingComplete();\n                }\n                return;\n            }\n            \n            const animation = animationQueue.shift();\n            processAnimation(animation);\n            \n            if (animation.type === 'explanation') {\n                explanationDiv.innerHTML = `<h3>Algorithm Explanation</h3><p>${animation.text}</p>`;\n            } else if (animation.type === 'compare') {\n                currentStepDiv.textContent = `Comparing elements at indices ${animation.indices[0]} (${array[animation.indices[0]]}) and ${animation.indices[1]} (${array[animation.indices[1]]}): ${animation.comparison}`;\n            } else if (animation.type === 'overwrite') {\n                currentStepDiv.textContent = `Moving value ${animation.value} from index ${animation.from} to index ${animation.index}`;\n            }\n            \n            updateStats();\n            \n            if (animationQueue.length > 0) {\n                setTimeout(processAnimationQueue, 1000 / animationSpeed);\n            } else {\n                sortingComplete();\n            }\n        }\n        \n        function processNextStep() {\n            if (animationQueue.length === 0) {\n                sortingComplete();\n                return;\n            }\n            \n            const animation = animationQueue.shift();\n            processAnimation(animation);\n            \n            if (animation.type === 'explanation') {\n                explanationDiv.innerHTML = `<h3>Algorithm Explanation</h3><p>${animation.text}</p>`;\n            } else if (animation.type === 'compare') {\n                currentStepDiv.textContent = `Comparing elements at indices ${animation.indices[0]} (${array[animation.indices[0]]}) and ${animation.indices[1]} (${array[animation.indices[1]]}): ${animation.comparison}`;\n            } else if (animation.type === 'overwrite') {\n                currentStepDiv.textContent = `Moving value ${animation.value} from index ${animation.from} to index ${animation.index}`;\n            }\n            \n            updateStats();\n        }\n        \n        function processAnimation(animation) {\n            switch(animation.type) {\n                case 'highlight':\n                    currentRecursionDepth = animation.recursionDepth;\n                    renderArray(animation.indices, [], []);\n                    break;\n                    \n                case 'compare':\n                    renderArray(animation.indices, [], []);\n                    break;\n                    \n                case 'overwrite':\n                    array[animation.index] = animation.value;\n                    const mergeHighlights = showMergeCheckbox.checked ? [animation.index, animation.from] : [];\n                    renderArray([], mergeHighlights, []);\n                    break;\n                    \n                case 'sorted':\n                    renderArray([], [], animation.indices);\n                    break;\n                    \n                case 'addToCallStack':\n                    addToCallStack(animation.text, animation.callId);\n                    break;\n                    \n                case 'removeFromCallStack':\n                    removeFromCallStack(animation.callId);\n                    break;\n            }\n        }\n        \n        function addToCallStack(text, callId) {\n            const callElement = document.createElement('div');\n            callElement.textContent = text;\n            callElement.id = callId;\n            callElement.style.marginLeft = `${currentRecursionDepth * 20}px`;\n            callStackDiv.appendChild(callElement);\n        }\n        \n        function removeFromCallStack(callId) {\n            const element = document.getElementById(callId);\n            if (element) {\n                element.remove();\n            }\n        }\n        \n        function togglePause() {\n            isPaused = !isPaused;\n            pauseSortBtn.textContent = isPaused ? 'Resume' : 'Pause';\n            \n            if (!isPaused) {\n                processAnimationQueue();\n            }\n        }\n        \n        function sortingComplete() {\n            isSorting = false;\n            isPaused = false;\n            \n            startSortBtn.disabled = false;\n            pauseSortBtn.disabled = true;\n            stepSortBtn.disabled = true;\n            generateArrayBtn.disabled = false;\n            \n            explanationDiv.innerHTML = '<h3>Algorithm Explanation</h3><p>Merge Sort completed! The algorithm works by recursively dividing the array into halves until single elements are reached, then merging them back together in sorted order.</p>';\n            currentStepDiv.textContent = 'Sorting completed!';\n            \n            // Highlight entire array as sorted\n            renderArray([], [], Array.from({length: array.length}, (_, i) => i));\n        }\n        \n        function resetVisualization() {\n            isSorting = false;\n            isPaused = false;\n            \n            startSortBtn.disabled = false;\n            pauseSortBtn.disabled = true;\n            stepSortBtn.disabled = true;\n            generateArrayBtn.disabled = false;\n            \n            animationQueue = [];\n            callStackDiv.innerHTML = '';\n            currentStepDiv.textContent = '';\n            explanationDiv.innerHTML = '<h3>Algorithm Explanation</h3><p>Click \"Start Merge Sort\" to begin the visualization.</p>';\n            \n            renderArray();\n            resetStats();\n        }\n    </script>\n</body>\n</html>"
  },
