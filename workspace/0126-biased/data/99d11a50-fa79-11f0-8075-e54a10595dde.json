    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Regression Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #dataPoints {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Linear Regression Interactive Demo</h1>\n\n    <div id=\"dataPoints\">\n        <h2>Data Points</h2>\n        <label for=\"numPoints\">Number of Points:</label>\n        <input type=\"number\" id=\"numPoints\" value=\"5\" min=\"2\" max=\"20\"><br><br>\n        <button id=\"generatePoints\">Generate Points</button>\n        <button id=\"clearPoints\">Clear Points</button>\n    </div>\n\n    <div id=\"pointControls\">\n        <h2>Point Controls</h2>\n        <label for=\"xValue\">X Value:</label>\n        <input type=\"number\" id=\"xValue\"><br>\n        <label for=\"yValue\">Y Value:</label>\n        <input type=\"number\" id=\"yValue\"><br>\n        <button id=\"addPoint\">Add Point</button>\n        <button id=\"removePoint\">Remove Last Point</button>\n    </div>\n\n    <div id=\"regressionControls\">\n        <h2>Regression Controls</h2>\n        <button id=\"calculateRegression\">Calculate Regression</button>\n        <button id=\"resetRegression\">Reset Regression</button>\n    </div>\n\n    <div id=\"output\">\n        <h2>Output</h2>\n        <p id=\"outputPoints\"></p>\n        <p id=\"outputRegression\"></p>\n    </div>\n\n    <script>\n        let points = [];\n\n        document.getElementById('generatePoints').addEventListener('click', () => {\n            const numPoints = parseInt(document.getElementById('numPoints').value);\n            points = Array.from({length: numPoints}, (_, i) => {\n                return { x: Math.random() * 10, y: Math.random() * 10 };\n            });\n            updateOutput();\n        });\n\n        document.getElementById('addPoint').addEventListener('click', () => {\n            const x = parseFloat(document.getElementById('xValue').value);\n            const y = parseFloat(document.getElementById('yValue').value);\n            if (!isNaN(x) && !isNaN(y)) {\n                points.push({ x, y });\n                updateOutput();\n            }\n        });\n\n        document.getElementById('removePoint').addEventListener('click', () => {\n            if (points.length > 0) {\n                points.pop();\n                updateOutput();\n            }\n        });\n\n        document.getElementById('calculateRegression').addEventListener('click', () => {\n            const n = points.length;\n            const sumX = points.reduce((sum, point) => sum + point.x, 0);\n            const sumY = points.reduce((sum, point) => sum + point.y, 0);\n            const sumXY = points.reduce((sum, point) => sum + point.x * point.y, 0);\n            const sumXX = points.reduce((sum, point) => sum + point.x * point.x, 0);\n\n            const slope = (n * sumXY - sumX * sumY) / (n * sumXX - sumX * sumX);\n            const intercept = (sumY - slope * sumX) / n;\n\n            const regressionLine = `y = ${slope.toFixed(2)}x + ${intercept.toFixed(2)}`;\n            document.getElementById('outputRegression').innerText = regressionLine;\n        });\n\n        document.getElementById('clearPoints').addEventListener('click', () => {\n            points = [];\n            updateOutput();\n        });\n\n        document.getElementById('resetRegression').addEventListener('click', () => {\n            document.getElementById('outputRegression').innerText = '';\n        });\n\n        function updateOutput() {\n            const pointsList = points.map(point => `(${point.x.toFixed(2)}, ${point.y.toFixed(2)})`).join(', ');\n            document.getElementById('outputPoints').innerText = `Points: ${pointsList}`;\n        }\n    </script>\n</body>\n</html>"
