  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Monitor Concept Interactive</title>\n<style>\n  /* Minimal styling */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  button, input, select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  label {\n    margin-right: 0.3em;\n  }\n  pre {\n    border: 1px solid black;\n    padding: 0.5em;\n    white-space: pre-wrap;\n    max-height: 300px;\n    overflow-y: auto;\n  }\n  .section {\n    margin-bottom: 1em;\n  }\n</style>\n</head>\n<body>\n<h1>Monitor Concept Interactive Demo</h1>\n<p>\nThis interactive demo simulates a <strong>Monitor</strong> system that watches states, handles input events, manages complex state transitions, and visualizes internal metrics.\nUsers can create monitors, configure thresholds, send inputs/events, explore states, and control behaviors.\n</p>\n\n<div class=\"section\" id=\"monitor-creation-section\">\n  <h2>1. Create a New Monitor</h2>\n  <label for=\"monitor-name-input\">Monitor Name:</label>\n  <input type=\"text\" id=\"monitor-name-input\" placeholder=\"Enter monitor name\" />\n  <button id=\"create-monitor-btn\">Create Monitor</button>\n  <div id=\"create-monitor-msg\"></div>\n</div>\n\n<div class=\"section\" id=\"monitor-control-section\" style=\"display:none;\">\n  <h2>2. Monitor Controls and Configuration</h2>\n  <div>\n    <label for=\"current-monitor-select\">Select Monitor:</label>\n    <select id=\"current-monitor-select\"></select>\n    <button id=\"delete-monitor-btn\">Delete Monitor</button>\n  </div>\n  <div id=\"config-area\" style=\"margin-top:0.5em;\">\n    <label for=\"state-threshold-slider\">State Threshold (0 - 100):</label>\n    <input type=\"range\" id=\"state-threshold-slider\" min=\"0\" max=\"100\" value=\"50\" />\n    <input type=\"number\" id=\"state-threshold-number\" min=\"0\" max=\"100\" value=\"50\" style=\"width:4em;\" />\n  </div>\n  <div id=\"alert-thresholds-area\" style=\"margin-top:0.5em;\">\n    <label for=\"alert-threshold-input\">Alert Thresholds (comma separated numbers):</label><br />\n    <input type=\"text\" id=\"alert-threshold-input\" placeholder=\"e.g. 20,50,80\" style=\"width: 20em;\"/>\n    <button id=\"set-alert-thresholds-btn\">Set Alert Thresholds</button>\n  </div>\n  <div id=\"alert-thresholds-list\" style=\"margin-top:0.3em; font-size: 0.9em;\"></div>\n</div>\n\n<div class=\"section\" id=\"input-event-section\" style=\"display:none;\">\n  <h2>3. Input Events to Monitor</h2>\n  <label for=\"input-event-type\">Event Type:</label>\n  <select id=\"input-event-type\">\n    <option value=\"increase\">Increase Value</option>\n    <option value=\"decrease\">Decrease Value</option>\n    <option value=\"reset\">Reset Value</option>\n    <option value=\"custom\">Custom Numeric Input</option>\n  </select>\n  <label for=\"input-event-value\" id=\"input-event-value-label\" style=\"display:none;\">Value:</label>\n  <input type=\"number\" id=\"input-event-value\" style=\"width:5em; display:none;\" />\n  <button id=\"send-event-btn\">Send Event</button>\n  <div id=\"input-event-msg\" style=\"margin-top:0.3em;\"></div>\n</div>\n\n<div class=\"section\" id=\"monitor-state-section\" style=\"display:none;\">\n  <h2>4. Monitor State and Exploration</h2>\n  <div><strong>Current State Value:</strong> <span id=\"current-state-value\">-</span></div>\n  <div><strong>Current State Status:</strong> <span id=\"current-state-status\">-</span></div>\n  \n  <h3>Explore Past States</h3>\n  <label for=\"past-states-select\">Select Past State Index:</label>\n  <select id=\"past-states-select\"></select>\n  <button id=\"view-state-btn\">View State Details</button>\n  <button id=\"rollback-state-btn\">Roll Back To This State</button>\n  <pre id=\"state-details-pre\" aria-live=\"polite\"></pre>\n</div>\n\n<div class=\"section\" id=\"complex-workflow-section\" style=\"display:none;\">\n  <h2>5. Complex Workflow Simulation</h2>\n  <p>\n    This monitor supports complex workflows including alarms that must be acknowledged,\n    multi-stage state changes, and user confirmations. Use the controls below to interact.\n  </p>\n  <div>\n    <button id=\"trigger-alarm-btn\">Trigger Alarm</button>\n    <button id=\"acknowledge-alarm-btn\" disabled>Acknowledge Alarm</button>\n    <button id=\"clear-alarm-btn\" disabled>Clear Alarm</button>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <label for=\"workflow-step-input\">Set Workflow Step (1-5):</label>\n    <input type=\"number\" id=\"workflow-step-input\" min=\"1\" max=\"5\" value=\"1\" style=\"width:3em\" />\n    <button id=\"set-workflow-step-btn\">Set Step</button>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <label for=\"auto-advance-toggle\">\n      <input type=\"checkbox\" id=\"auto-advance-toggle\" /> Enable Auto-Advance Steps\n    </label>\n  </div>\n  <div id=\"workflow-status\" style=\"margin-top:0.7em; white-space: pre-wrap; max-height: 150px; overflow-y: auto; border:1px solid black; padding:0.3em;\"></div>\n</div>\n\n<script>\n(() => {\n  // Internal Monitor class & logic\n  class Monitor {\n    constructor(name) {\n      this.name = name;\n      this.stateValue = 0;  // numeric state\n      this.stateHistory = [];\n      this.stateThreshold = 50;\n      this.alertThresholds = [20, 50, 80];\n      this.status = 'Normal'; // Normal, Warning, Critical, Alarm\n      this.alarmTriggered = false;\n      this.alarmAcknowledged = false;\n      this.workflowStep = 1;\n      this.workflowAutoAdvance = false;\n      this.workflowLog = [];\n      this.pushStateHistory('Initial state');\n    }\n\n    pushStateHistory(note) {\n      const timestamp = new Date().toISOString();\n      this.stateHistory.push({\n        value: this.stateValue,\n        status: this.status,\n        alarmTriggered: this.alarmTriggered,\n        alarmAcknowledged: this.alarmAcknowledged,\n        workflowStep: this.workflowStep,\n        workflowAutoAdvance: this.workflowAutoAdvance,\n        note,\n        timestamp\n      });\n      if (this.stateHistory.length > 1000) {\n        this.stateHistory.shift();\n      }\n    }\n\n    updateStatus() {\n      if (this.alarmTriggered) {\n        this.status = this.alarmAcknowledged ? 'Alarm Acknowledged' : 'Alarm';\n        return;\n      }\n      if (this.stateValue >= this.alertThresholds[2]) {\n        this.status = 'Critical';\n      } else if (this.stateValue >= this.alertThresholds[1]) {\n        this.status = 'Warning';\n      } else {\n        this.status = 'Normal';\n      }\n    }\n\n    processEvent(eventType, value = null) {\n      let oldValue = this.stateValue;\n      switch(eventType) {\n        case 'increase':\n          this.stateValue += 1;\n          this.pushStateHistory(`Increased from ${oldValue} to ${this.stateValue}`);\n          break;\n        case 'decrease':\n          this.stateValue -= 1;\n          this.pushStateHistory(`Decreased from ${oldValue} to ${this.stateValue}`);\n          break;\n        case 'reset':\n          this.stateValue = 0;\n          this.pushStateHistory(`Reset from ${oldValue} to 0`);\n          break;\n        case 'custom':\n          if (typeof value === 'number' && !isNaN(value)) {\n            this.stateValue = value;\n            this.pushStateHistory(`Custom set from ${oldValue} to ${this.stateValue}`);\n          }\n          break;\n        default:\n          break;\n      }\n      // Clamp stateValue 0-1000 for sanity\n      this.stateValue = Math.max(0, Math.min(1000, this.stateValue));\n      this.updateStatus();\n    }\n\n    setThreshold(val) {\n      if (typeof val === 'number' && val >= 0 && val <= 100)\n      {\n        this.stateThreshold = val;\n        this.pushStateHistory(`State threshold set to ${val}`);\n        this.updateStatus();\n      }\n    }\n\n    setAlertThresholds(thresholdArray) {\n      // Validate array, must be ascending numbers 0-100\n      if (!Array.isArray(thresholdArray)) return false;\n      if (thresholdArray.some(v => typeof v !== 'number' || v < 0 || v > 100)) return false;\n      for(let i=1; i<thresholdArray.length; i++){\n        if(thresholdArray[i] < thresholdArray[i-1]) return false;\n      }\n      this.alertThresholds = thresholdArray;\n      this.pushStateHistory(`Alert thresholds updated to [${thresholdArray.join(', ')}]`);\n      this.updateStatus();\n      return true;\n    }\n\n    triggerAlarm() {\n      if (!this.alarmTriggered) {\n        this.alarmTriggered = true;\n        this.alarmAcknowledged = false;\n        this.pushStateHistory('Alarm triggered');\n        this.updateStatus();\n        this.logWorkflow('Alarm triggered');\n      }\n    }\n\n    acknowledgeAlarm() {\n      if (this.alarmTriggered && !this.alarmAcknowledged) {\n        this.alarmAcknowledged = true;\n        this.pushStateHistory('Alarm acknowledged');\n        this.updateStatus();\n        this.logWorkflow('Alarm acknowledged');\n      }\n    }\n\n    clearAlarm() {\n      if (this.alarmTriggered) {\n        this.alarmTriggered = false;\n        this.alarmAcknowledged = false;\n        this.pushStateHistory('Alarm cleared');\n        this.updateStatus();\n        this.logWorkflow('Alarm cleared');\n      }\n    }\n\n    setWorkflowStep(step) {\n      if (typeof step === 'number' && step >= 1 && step <= 5) {\n        this.workflowStep = step;\n        this.pushStateHistory(`Workflow step set to ${step}`);\n        this.logWorkflow(`Workflow step set to ${step}`);\n      }\n    }\n\n    setAutoAdvance(enabled) {\n      this.workflowAutoAdvance = enabled;\n      this.pushStateHistory(`Workflow auto-advance set to ${enabled}`);\n      this.logWorkflow(`Workflow auto-advance set to ${enabled}`);\n      if (enabled) {\n        this.startAutoAdvance();\n      } else {\n        this.stopAutoAdvance();\n      }\n    }\n\n    logWorkflow(msg) {\n      const ts = new Date().toISOString();\n      this.workflowLog.push(`[${ts}] ${msg}`);\n      if (this.workflowLog.length > 1000) {\n        this.workflowLog.shift();\n      }\n    }\n\n    startAutoAdvance() {\n      if (this.autoAdvanceTimer) return;\n      this.autoAdvanceTimer = setInterval(() => {\n        this.workflowStep += 1;\n        if (this.workflowStep > 5) this.workflowStep = 1;\n        this.pushStateHistory(`Workflow auto-advanced to step ${this.workflowStep}`);\n        this.logWorkflow(`Workflow auto-advanced to step ${this.workflowStep}`);\n        updateDisplay();\n      }, 3000);\n    }\n\n    stopAutoAdvance() {\n      if (this.autoAdvanceTimer) {\n        clearInterval(this.autoAdvanceTimer);\n        this.autoAdvanceTimer = null;\n      }\n    }\n\n    rollbackToState(index) {\n      if (index<0 || index>=this.stateHistory.length) return false;\n      const stateSnap = this.stateHistory[index];\n      this.stateValue = stateSnap.value;\n      this.status = stateSnap.status;\n      this.alarmTriggered = stateSnap.alarmTriggered;\n      this.alarmAcknowledged = stateSnap.alarmAcknowledged;\n      this.workflowStep = stateSnap.workflowStep;\n      this.workflowAutoAdvance = stateSnap.workflowAutoAdvance;\n      // Remove all future states after rollback point\n      this.stateHistory = this.stateHistory.slice(0, index+1);\n      this.pushStateHistory(`Rolled back to state index ${index} from ${stateSnap.timestamp}`);\n      this.updateStatus();\n      this.logWorkflow(`Rolled back to state index ${index}`);\n      return true;\n    }\n\n    getStateAt(index) {\n      if (index < 0 || index >= this.stateHistory.length) return null;\n      return this.stateHistory[index];\n    }\n  }\n\n  // Globals:\n  const monitors = new Map();\n  let currentMonitor = null;\n\n  // UI Elements:\n  const monitorNameInput = document.getElementById('monitor-name-input');\n  const createMonitorBtn = document.getElementById('create-monitor-btn');\n  const createMonitorMsg = document.getElementById('create-monitor-msg');\n\n  const monitorControlSection = document.getElementById('monitor-control-section');\n  const currentMonitorSelect = document.getElementById('current-monitor-select');\n  const deleteMonitorBtn = document.getElementById('delete-monitor-btn');\n  const stateThresholdSlider = document.getElementById('state-threshold-slider');\n  const stateThresholdNumber = document.getElementById('state-threshold-number');\n  const alertThresholdInput = document.getElementById('alert-threshold-input');\n  const setAlertThresholdsBtn = document.getElementById('set-alert-thresholds-btn');\n  const alertThresholdsList = document.getElementById('alert-thresholds-list');\n\n  const inputEventSection = document.getElementById('input-event-section');\n  const inputEventType = document.getElementById('input-event-type');\n  const inputEventValueLabel = document.getElementById('input-event-value-label');\n  const inputEventValue = document.getElementById('input-event-value');\n  const sendEventBtn = document.getElementById('send-event-btn');\n  const inputEventMsg = document.getElementById('input-event-msg');\n\n  const monitorStateSection = document.getElementById('monitor-state-section');\n  const currentStateValueSpan = document.getElementById('current-state-value');\n  const currentStateStatusSpan = document.getElementById('current-state-status');\n  const pastStatesSelect = document.getElementById('past-states-select');\n  const viewStateBtn = document.getElementById('view-state-btn');\n  const rollbackStateBtn = document.getElementById('rollback-state-btn');\n  const stateDetailsPre = document.getElementById('state-details-pre');\n\n  const complexWorkflowSection = document.getElementById('complex-workflow-section');\n  const triggerAlarmBtn = document.getElementById('trigger-alarm-btn');\n  const acknowledgeAlarmBtn = document.getElementById('acknowledge-alarm-btn');\n  const clearAlarmBtn = document.getElementById('clear-alarm-btn');\n  const workflowStepInput = document.getElementById('workflow-step-input');\n  const setWorkflowStepBtn = document.getElementById('set-workflow-step-btn');\n  const autoAdvanceToggle = document.getElementById('auto-advance-toggle');\n  const workflowStatusDiv = document.getElementById('workflow-status');\n\n  // Functions to update UI\n  function updateMonitorSelectOptions() {\n    currentMonitorSelect.innerHTML = '';\n    for (const name of monitors.keys()) {\n      const opt = document.createElement('option');\n      opt.value = name;\n      opt.textContent = name;\n      currentMonitorSelect.appendChild(opt);\n    }\n  }\n\n  function loadMonitorToUI(monitor) {\n    if (!monitor) return;\n    stateThresholdSlider.value = monitor.stateThreshold;\n    stateThresholdNumber.value = monitor.stateThreshold;\n    alertThresholdInput.value = monitor.alertThresholds.join(',');\n    updateAlertThresholdsList(monitor.alertThresholds);\n    inputEventMsg.textContent = '';\n    stateDetailsPre.textContent = '';\n    workflowStatusDiv.textContent = monitor.workflowLog.slice(-20).join('\\n');\n\n    // Workflow controls update\n    acknowledgeAlarmBtn.disabled = !monitor.alarmTriggered || monitor.alarmAcknowledged;\n    clearAlarmBtn.disabled = !monitor.alarmTriggered;\n\n    workflowStepInput.value = monitor.workflowStep;\n    autoAdvanceToggle.checked = monitor.workflowAutoAdvance;\n\n    updatePastStatesSelect(monitor);\n    updateMonitorStateDisplay(monitor);\n  }\n\n  function updateAlertThresholdsList(arr) {\n    alertThresholdsList.textContent = 'Current Alert Thresholds: ' + arr.join(', ');\n  }\n\n  function updatePastStatesSelect(monitor) {\n    pastStatesSelect.innerHTML = '';\n    monitor.stateHistory.forEach((state, i) => {\n      const opt = document.createElement('option');\n      opt.value = i;\n      opt.textContent = `[${i}] ${state.timestamp} - val:${state.value} status:${state.status}`;\n      pastStatesSelect.appendChild(opt);\n    });\n  }\n\n  function updateMonitorStateDisplay(monitor) {\n    currentStateValueSpan.textContent = monitor.stateValue.toFixed(2);\n    currentStateStatusSpan.textContent = monitor.status;\n  }\n\n  function updateDisplay() {\n    if (!currentMonitor) return;\n    loadMonitorToUI(currentMonitor);\n  }\n\n  // Event Listeners\n\n  createMonitorBtn.addEventListener('click', () => {\n    const name = monitorNameInput.value.trim();\n    createMonitorMsg.textContent = '';\n    if (!name) {\n      createMonitorMsg.textContent = 'Enter a valid monitor name.';\n      return;\n    }\n    if (monitors.has(name)) {\n      createMonitorMsg.textContent = 'Monitor name already exists.';\n      return;\n    }\n    const monitor = new Monitor(name);\n    monitors.set(name, monitor);\n    currentMonitor = monitor;\n    updateMonitorSelectOptions();\n    currentMonitorSelect.value = name;\n    createMonitorMsg.textContent = `Monitor \"${name}\" created.`;\n    monitorControlSection.style.display = 'block';\n    inputEventSection.style.display = 'block';\n    monitorStateSection.style.display = 'block';\n    complexWorkflowSection.style.display = 'block';\n\n    updateDisplay();\n  });\n\n  currentMonitorSelect.addEventListener('change', () => {\n    const selectedName = currentMonitorSelect.value;\n    currentMonitor = monitors.get(selectedName);\n    updateDisplay();\n  });\n\n  deleteMonitorBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    const toDelete = currentMonitor.name;\n    monitors.delete(toDelete);\n    if (monitors.size === 0) {\n      currentMonitor = null;\n      monitorControlSection.style.display = 'none';\n      inputEventSection.style.display = 'none';\n      monitorStateSection.style.display = 'none';\n      complexWorkflowSection.style.display = 'none';\n    } else {\n      const firstKey = monitors.keys().next().value;\n      currentMonitor = monitors.get(firstKey);\n      currentMonitorSelect.value = firstKey;\n      updateDisplay();\n    }\n    updateMonitorSelectOptions();\n  });\n\n  // Sync slider and number input\n  stateThresholdSlider.addEventListener('input', () => {\n    const val = Number(stateThresholdSlider.value);\n    stateThresholdNumber.value = val;\n    if (currentMonitor) {\n      currentMonitor.setThreshold(val);\n      updateDisplay();\n    }\n  });\n\n  stateThresholdNumber.addEventListener('change', () => {\n    let val = Number(stateThresholdNumber.value);\n    if (isNaN(val) || val<0) val = 0;\n    if (val>100) val=100;\n    stateThresholdNumber.value = val;\n    stateThresholdSlider.value = val;\n    if (currentMonitor) {\n      currentMonitor.setThreshold(val);\n      updateDisplay();\n    }\n  });\n\n  setAlertThresholdsBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    let valStr = alertThresholdInput.value.trim();\n    if (!valStr) {\n      inputEventMsg.textContent = 'Alert thresholds cannot be empty.';\n      return;\n    }\n    let valArr = valStr.split(',').map(v => Number(v.trim())).filter(v => !isNaN(v));\n    if (valArr.length === 0) {\n      inputEventMsg.textContent = 'No valid numbers found.';\n      return;\n    }\n    // Sort ascending and unique\n    valArr = [...new Set(valArr)].sort((a,b)=>a-b);\n    const success = currentMonitor.setAlertThresholds(valArr);\n    if (!success) {\n      inputEventMsg.textContent = 'Invalid alert thresholds. Must be numbers 0-100 ascending.';\n    } else {\n      inputEventMsg.textContent = 'Alert thresholds updated.';\n      updateAlertThresholdsList(valArr);\n      updateDisplay();\n    }\n  });\n\n  inputEventType.addEventListener('change', () => {\n    if (inputEventType.value === 'custom') {\n      inputEventValue.style.display = 'inline';\n      inputEventValueLabel.style.display = 'inline';\n    } else {\n      inputEventValue.style.display = 'none';\n      inputEventValueLabel.style.display = 'none';\n      inputEventValue.value = '';\n    }\n  });\n\n  sendEventBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    inputEventMsg.textContent = '';\n    const type = inputEventType.value;\n    if (type === 'custom') {\n      const val = Number(inputEventValue.value);\n      if (isNaN(val)) {\n        inputEventMsg.textContent = 'Enter a valid numeric value for custom input.';\n        return;\n      }\n      currentMonitor.processEvent(type, val);\n    } else {\n      currentMonitor.processEvent(type);\n    }\n    updateDisplay();\n  });\n\n  viewStateBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    const idx = Number(pastStatesSelect.value);\n    if (isNaN(idx)) return;\n    const state = currentMonitor.getStateAt(idx);\n    if (!state) {\n      stateDetailsPre.textContent = 'Invalid state index.';\n      return;\n    }\n    let txt = `State at index ${idx}:\\n`;\n    txt += ` Timestamp: ${state.timestamp}\\n`;\n    txt += ` Value: ${state.value}\\n`;\n    txt += ` Status: ${state.status}\\n`;\n    txt += ` Alarm Triggered: ${state.alarmTriggered}\\n`;\n    txt += ` Alarm Acknowledged: ${state.alarmAcknowledged}\\n`;\n    txt += ` Workflow Step: ${state.workflowStep}\\n`;\n    txt += ` Workflow Auto-Advance: ${state.workflowAutoAdvance}\\n`;\n    txt += ` Note: ${state.note}\\n`;\n    stateDetailsPre.textContent = txt;\n  });\n\n  rollbackStateBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    const idx = Number(pastStatesSelect.value);\n    if (isNaN(idx)) return;\n    const success = currentMonitor.rollbackToState(idx);\n    if (success) {\n      updateDisplay();\n      stateDetailsPre.textContent = 'Rolled back to selected state.';\n    } else {\n      stateDetailsPre.textContent = 'Rollback failed.';\n    }\n  });\n\n  triggerAlarmBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    currentMonitor.triggerAlarm();\n    updateDisplay();\n  });\n\n  acknowledgeAlarmBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    currentMonitor.acknowledgeAlarm();\n    updateDisplay();\n  });\n\n  clearAlarmBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    currentMonitor.clearAlarm();\n    updateDisplay();\n  });\n\n  setWorkflowStepBtn.addEventListener('click', () => {\n    if (!currentMonitor) return;\n    let step = Number(workflowStepInput.value);\n    if (isNaN(step) || step <1) step =1;\n    if (step >5) step =5;\n    workflowStepInput.value = step;\n    currentMonitor.setWorkflowStep(step);\n    updateDisplay();\n  });\n\n  autoAdvanceToggle.addEventListener('change', () => {\n    if (!currentMonitor) return;\n    currentMonitor.setAutoAdvance(autoAdvanceToggle.checked);\n    updateDisplay();\n  });\n\n  // Periodical UI updater to keep things in sync:\n  setInterval(() => {\n    updateDisplay();\n  }, 1000);\n\n  // On load, disable parts that need monitor\n  monitorControlSection.style.display = 'none';\n  inputEventSection.style.display = 'none';\n  monitorStateSection.style.display = 'none';\n  complexWorkflowSection.style.display = 'none';\n\n})();\n</script>\n</body>\n</html>"
