    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Unit Testing — Excellence in Code Quality</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n\n  /*\n  Color Palette:\n  - Primary: #005f73 (Deep Cyan)\n  - Secondary: #0a9396 (Tealish)\n  - Accent: #94d2bd (Light Mint)\n  - Neutral Dark: #001219\n  - Neutral Light: #e9d8a6 (Warm Sand)\n  - Error Red: #ca3e47\n  */\n\n  :root {\n    --clr-primary: #005f73;\n    --clr-secondary: #0a9396;\n    --clr-accent: #94d2bd;\n    --clr-neutral-dark: #001219;\n    --clr-neutral-light: #e9d8a6;\n    --clr-error-red: #ca3e47;\n    --font-family: 'Inter', system-ui, sans-serif;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, var(--clr-neutral-dark) 0%, #002f4b 70%);\n    font-family: var(--font-family);\n    color: var(--clr-neutral-light);\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 2rem 1rem 5rem;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    color: var(--clr-accent);\n    text-align: center;\n    margin-bottom: 0.1em;\n    text-shadow:\n      0 0 8px var(--clr-accent),\n      0 0 20px var(--clr-accent);\n  }\n\n  h2 {\n    font-weight: 600;\n    color: var(--clr-secondary);\n    font-size: 1.6rem;\n    margin-bottom: 0.5rem;\n    letter-spacing: 0.03em;\n  }\n\n  .subtitle {\n    font-weight: 400;\n    font-size: 1.1rem;\n    color: #a9bdc0;\n    text-align: center;\n    margin-bottom: 3rem;\n    max-width: 480px;\n    line-height: 1.5;\n  }\n\n  /* Container for main visual */\n  .container {\n    max-width: 900px;\n    width: 100%;\n    background: linear-gradient(145deg, #072f44 0%, #0f475e 100%);\n    border-radius: 2rem;\n    box-shadow:\n      0 8px 20px rgba(0, 0, 0, 0.6),\n      inset 0 0 20px #0a9396aa;\n    padding: 2rem 3rem 3rem;\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Stylized box representing code/unit tests */\n  .code-wrapper {\n    background: #001a25;\n    border-radius: 1.3rem;\n    padding: 2rem 2.5rem;\n    box-shadow:\n      0 12px 18px rgba(9, 45, 61, 0.6),\n      inset 0 0 40px #0a9396cc;\n    font-family: 'Fira Mono', monospace;\n    font-size: 1.1rem;\n    line-height: 1.5;\n    color: var(--clr-accent);\n    letter-spacing: 0.04em;\n    max-height: 280px;\n    overflow: auto;\n    user-select: none;\n    /* subtle glowing border animation */\n    border: 2.5px solid transparent;\n    background-origin: border-box;\n    background-clip: padding-box, border-box;\n    background-image: \n      linear-gradient(#001a25, #001a25),\n      linear-gradient(270deg, var(--clr-primary), var(--clr-secondary), var(--clr-primary));\n    animation: borderGlow 6s linear infinite;\n  }\n\n  /* Scrollbar styled for aesthetic */\n  .code-wrapper::-webkit-scrollbar {\n    height: 8px;\n  }\n  .code-wrapper::-webkit-scrollbar-track {\n    background: #072f44;\n    border-radius: 40px;\n  }\n  .code-wrapper::-webkit-scrollbar-thumb {\n    background: var(--clr-secondary);\n    border-radius: 40px;\n    box-shadow: inset 0 0 4px #94d2bd;\n  }\n\n  @keyframes borderGlow {\n    0% {\n      background-position: 0% 50%, 0% 50%;\n    }\n    100% {\n      background-position: 200% 50%, 0% 50%;\n    }\n  }\n\n  /* Code line highlight animations */\n  .code-line {\n    position: relative;\n    padding-left: 1.3rem;\n  }\n\n  .code-line::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 0.6em;\n    width: 0.7em;\n    height: 0.7em;\n    border-radius: 50%;\n    opacity: 0.8;\n  }\n\n  .pass::before {\n    background: var(--clr-accent);\n    box-shadow:\n      0 0 6px var(--clr-accent),\n      0 0 10px var(--clr-primary);\n  }\n\n  .fail::before {\n    background: var(--clr-error-red);\n    box-shadow:\n      0 0 8px var(--clr-error-red),\n      0 0 15px #ff4d4d;\n  }\n\n  /* Result bar container */\n  .result-bar {\n    margin-top: 3rem;\n    display: flex;\n    height: 32px;\n    width: 100%;\n    border-radius: 60px;\n    box-shadow:\n      0 4px 10px rgba(0,0,0,0.4),\n      inset 0 0 12px rgb(4 109 113 / 0.8);\n    overflow: hidden;\n    user-select: none;\n  }\n\n  .result-pass {\n    flex-grow: 1;\n    background: var(--clr-primary);\n    background-image: linear-gradient(135deg, #008080 0%, #00b5ad 100%);\n    box-shadow: inset 0 0 13px #86e7d8;\n    transition: flex-grow 1.4s ease-in-out;\n  }\n  .result-fail {\n    background: var(--clr-error-red);\n    background-image: linear-gradient(135deg, #d7383a 0%, #ff3f45 90%);\n    box-shadow: inset 0 0 14px #ff6b6b;\n    transition: flex-grow 1.4s ease-in-out;\n  }\n\n  /* Summary text over result bar */\n  .result-text {\n    position: absolute;\n    left: 50%;\n    top: 100%;\n    transform: translateX(-50%);\n    margin-top: 0.8rem;\n    font-weight: 600;\n    font-size: 1.3rem;\n    color: var(--clr-neutral-light);\n    letter-spacing: 0.04em;\n    text-shadow:\n      0 0 7px var(--clr-primary);\n    user-select: none;\n  }\n\n  /* Button style */\n  .btn-refresh {\n    display: inline-flex;\n    margin: 2rem auto 0;\n    background: var(--clr-secondary);\n    color: var(--clr-neutral-light);\n    border: none;\n    outline: none;\n    padding: 0.75rem 2rem;\n    font-size: 1.05rem;\n    font-weight: 600;\n    border-radius: 9999px;\n    cursor: pointer;\n    box-shadow:\n      0 4px 12px #0a9396cc,\n      inset 0 -3px 6px #077a7bcc;\n    transition: background 0.25s ease, box-shadow 0.25s ease;\n    user-select: none;\n  }\n\n  .btn-refresh:hover {\n    background: var(--clr-primary);\n    box-shadow:\n      0 7px 20px #056d71cc,\n      inset 0 -4px 8px #034d52cc;\n  }\n\n  /* Caption text inside code box */\n  .caption {\n    text-align: center;\n    margin-top: 3rem;\n    color: #94d2bdcc;\n    font-size: 1rem;\n    font-style: italic;\n    letter-spacing: 0.02em;\n  }\n\n  /* SVG bubble cluster decorations */\n  .decor-svg {\n    position: absolute;\n    pointer-events: none;\n    opacity: 0.13;\n    filter: drop-shadow(0 0 5px var(--clr-accent));\n    will-change: transform, opacity;\n  }\n\n  .decor-top-left {\n    top: -50px;\n    left: -50px;\n    width: 200px;\n    height: 200px;\n    animation: slowFloat 12s ease-in-out infinite alternate;\n  }\n\n  .decor-bottom-right {\n    bottom: -60px;\n    right: -60px;\n    width: 260px;\n    height: 260px;\n    animation: slowFloat 9s ease-in-out infinite alternate-reverse;\n  }\n\n  @keyframes slowFloat {\n    0% {\n      transform: translateY(0) translateX(0) scale(1);\n      opacity: 0.13;\n    }\n    100% {\n      transform: translateY(-12px) translateX(6px) scale(1.04);\n      opacity: 0.15;\n    }\n  }\n\n  /* Tooltip style */\n  .tooltip {\n    position: relative;\n  }\n  .tooltip:hover::after {\n    content: attr(data-tip);\n    position: absolute;\n    bottom: 100%;\n    left: 50%;\n    transform: translateX(-50%) translateY(-0.25rem);\n    background: var(--clr-primary);\n    color: var(--clr-neutral-light);\n    font-size: 0.8rem;\n    font-weight: 600;\n    padding: 0.35rem 0.65rem;\n    border-radius: 0.6rem;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.7);\n    white-space: nowrap;\n    opacity: 0.95;\n    pointer-events: none;\n    user-select: none;\n    z-index: 999;\n  }\n</style>\n</head>\n<body>\n\n<h1>Unit Testing</h1>\n<div class=\"subtitle\" aria-label=\"Definition and purpose of unit testing\">\n  <em>Ensuring every snippet of code works flawlessly — Crafting bulletproof software one test at a time.</em>\n</div>\n\n<div class=\"container\" aria-label=\"Illustration and results for unit testing concept\">\n  <!-- Decorative bubble clusters -->\n  <svg class=\"decor-svg decor-top-left\" aria-hidden=\"true\" viewBox=\"0 0 200 200\" >\n    <circle cx=\"40\" cy=\"30\" r=\"12\" fill=\"url(#grad1)\" />\n    <circle cx=\"90\" cy=\"70\" r=\"24\" fill=\"url(#grad2)\" />\n    <circle cx=\"150\" cy=\"40\" r=\"36\" fill=\"url(#grad1)\" />\n    <circle cx=\"120\" cy=\"120\" r=\"18\" fill=\"url(#grad2)\" />\n    <defs>\n      <radialGradient id=\"grad1\" cx=\"0.4\" cy=\"0.4\" r=\"0.8\">\n        <stop offset=\"0%\" stop-color=\"var(--clr-accent)\" stop-opacity=\"0.8\" />\n        <stop offset=\"100%\" stop-color=\"var(--clr-primary)\" stop-opacity=\"0\"/>\n      </radialGradient>\n      <radialGradient id=\"grad2\" cx=\"0.5\" cy=\"0.5\" r=\"0.7\">\n        <stop offset=\"0%\" stop-color=\"var(--clr-secondary)\" stop-opacity=\"0.9\" />\n        <stop offset=\"100%\" stop-color=\"var(--clr-accent)\" stop-opacity=\"0\"/>\n      </radialGradient>\n    </defs>\n  </svg>\n\n  <svg class=\"decor-svg decor-bottom-right\" aria-hidden=\"true\" viewBox=\"0 0 260 260\">\n    <circle cx=\"60\" cy=\"200\" r=\"36\" fill=\"url(#grad3)\" />\n    <circle cx=\"140\" cy=\"140\" r=\"54\" fill=\"url(#grad4)\" />\n    <circle cx=\"200\" cy=\"210\" r=\"24\" fill=\"url(#grad3)\" />\n    <circle cx=\"190\" cy=\"90\" r=\"18\" fill=\"url(#grad4)\" />\n    <defs>\n      <radialGradient id=\"grad3\" cx=\"0.6\" cy=\"0.6\" r=\"0.9\">\n        <stop offset=\"10%\" stop-color=\"var(--clr-primary)\" stop-opacity=\"0.85\"/>\n        <stop offset=\"100%\" stop-color=\"var(--clr-secondary)\" stop-opacity=\"0\"/>\n      </radialGradient>\n      <radialGradient id=\"grad4\" cx=\"0.5\" cy=\"0.5\" r=\"1\">\n        <stop offset=\"0\" stop-color=\"var(--clr-accent)\" stop-opacity=\"0.6\"/>\n        <stop offset=\"100%\" stop-color=\"var(--clr-primary)\" stop-opacity=\"0\"/>\n      </radialGradient>\n    </defs>\n  </svg>\n\n  <pre class=\"code-wrapper\" aria-label=\"Example unit tests code snippet\">\n<span class=\"code-line pass tooltip\" data-tip=\"Test passed successfully\">✓ should return true when input is valid</span>\n<span class=\"code-line pass tooltip\" data-tip=\"Test passed successfully\">✓ processes user input correctly</span>\n<span class=\"code-line fail tooltip\" data-tip=\"Test failed: Expected 42 but got 21\">✗ computes sum with edge cases</span>\n<span class=\"code-line pass tooltip\" data-tip=\"Test passed successfully\">✓ throws error on invalid argument</span>\n<span class=\"code-line fail tooltip\" data-tip=\"Test failed: Timeout after 3000ms\">✗ async operation completes timely</span>\n<span class=\"code-line pass tooltip\" data-tip=\"Test passed successfully\">✓ formats date strings properly</span>\n<span class=\"code-line pass tooltip\" data-tip=\"Test passed successfully\">✓ normalizes user data</span>\n<span class=\"code-line pass tooltip\" data-tip=\"Test passed successfully\">✓ returns null when data is missing</span>\n  </pre>\n\n  <div style=\"position: relative; margin-top: 2.8rem;\">\n    <div class=\"result-bar\" aria-label=\"Test results summary bar\">\n      <div class=\"result-pass\" style=\"flex-grow: 7;\"></div>\n      <div class=\"result-fail\" style=\"flex-grow: 2;\"></div>\n    </div>\n    <div class=\"result-text\" aria-live=\"polite\" aria-atomic=\"true\">\n      7 Passed &nbsp;&middot;&nbsp; 2 Failed\n    </div>\n  </div>\n\n  <button class=\"btn-refresh\" aria-label=\"Refresh test results\">Run Tests Again</button>\n  <div class=\"caption\" aria-hidden=\"true\">Unit testing validates isolated code units to guarantee faultless execution.</div>\n</div>\n\n<script>\n  // We keep interactivity limited, only a simple simulated re-run of tests with subtle animation\n\n  const btn = document.querySelector('.btn-refresh');\n  const codeLines = document.querySelectorAll('.code-wrapper .code-line');\n  const passBar = document.querySelector('.result-pass');\n  const failBar = document.querySelector('.result-fail');\n  const resultText = document.querySelector('.result-text');\n\n  // Predefined test outcomes (simulate shuffle)\n  const testScenarios = [\n    [true,true,false,true,false,true,true,true], // current\n    [true,true,true,true,true,true,true,false],\n    [true,false,false,true,true,true,true,true],\n    [true,true,true,true,true,false,true,true],\n    [true,true,true,true,true,true,true,true],\n    [true,false,true,true,false,true,true,false],\n    [true,true,true,true,true,true,false,true]\n  ];\n\n  function getRandomScenario() {\n    return testScenarios[Math.floor(Math.random() * testScenarios.length)];\n  }\n\n  function updateTests(results) {\n    let passCount = 0;\n    let failCount = 0;\n    codeLines.forEach((line, idx) => {\n      const pass = results[idx];\n      line.classList.remove('pass', 'fail');\n      if (pass) {\n        line.classList.add('pass');\n        passCount++;\n      } else {\n        line.classList.add('fail');\n        failCount++;\n      }\n    });\n    // Update result bar flex grow based on counts with smooth transition\n    const total = passCount + failCount || 1;\n    const fracPass = passCount / total;\n    const fracFail = failCount / total;\n    // clamp minimum width for fail or pass for aesthetics\n    passBar.style.flexGrow = (fracPass * 9 + 1).toFixed(2);\n    failBar.style.flexGrow = (fracFail * 9 + 1).toFixed(2);\n\n    // Update text\n    resultText.textContent = `${passCount} Passed  ·  ${failCount} Failed`;\n  }\n\n  btn.addEventListener('click', () => {\n    btn.disabled = true;\n    btn.textContent = 'Running...';\n\n    // subtle flash animation of code lines & result bar on refresh\n    document.querySelector('.container').style.filter = 'brightness(1.15)';\n    setTimeout(() => {\n      document.querySelector('.container').style.filter = 'brightness(1)';\n    }, 350);\n\n    setTimeout(() => {\n      const scenario = getRandomScenario();\n      updateTests(scenario);\n      btn.textContent = 'Run Tests Again';\n      btn.disabled = false;\n    }, 1400);\n  });\n\n  // Initialize with current scenario styling\n  updateTests([true,true,false,true,false,true,true,true]);\n</script>\n</body>\n</html>"
