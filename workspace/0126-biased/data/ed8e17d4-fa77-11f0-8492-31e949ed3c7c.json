    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Branch and Bound Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #f3f4f6, #e0e7ff);\n            color: #333;\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n        }\n\n        #container {\n            position: relative;\n            width: 80%;\n            height: 80%;\n            border-radius: 15px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n        }\n\n        .node {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background-color: #4a90e2;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: bold;\n            transition: transform 0.5s ease;\n        }\n\n        .active {\n            background-color: #e94e77;\n            transform: scale(1.1);\n        }\n\n        h1 {\n            position: absolute;\n            top: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 2.5rem;\n            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.2);\n        }\n\n        button {\n            position: absolute;\n            top: 90%;\n            left: 50%;\n            transform: translateX(-50%);\n            padding: 10px 20px;\n            font-size: 1.2rem;\n            border: none;\n            border-radius: 10px;\n            background-color: #4a90e2;\n            color: white;\n            cursor: pointer;\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n            transition: background-color 0.3s ease;\n        }\n\n        button:hover {\n            background-color: #3a7bbf;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <h1>Branch and Bound Visualization</h1>\n        <button id=\"startButton\">Start Visualization</button>\n        <div id=\"nodes\"></div>\n    </div>\n\n    <script>\n        const container = document.getElementById(\"nodes\");\n        const startButton = document.getElementById(\"startButton\");\n        const nodeCount = 10;\n        let nodes = [];\n\n        function createNodes() {\n            for (let i = 0; i < nodeCount; i++) {\n                const node = document.createElement(\"div\");\n                node.classList.add(\"node\");\n                node.innerText = i + 1;\n                node.style.left = Math.random() * 90 + \"%\";\n                node.style.top = Math.random() * 90 + \"%\";\n                container.appendChild(node);\n                nodes.push(node);\n            }\n        }\n\n        function activateNodes() {\n            nodes.forEach((node, index) => {\n                setTimeout(() => {\n                    node.classList.add(\"active\");\n                    if (index > 0) {\n                        nodes[index - 1].classList.remove(\"active\");\n                    }\n                }, index * 1000);\n            });\n        }\n\n        startButton.addEventListener(\"click\", () => {\n            createNodes();\n            activateNodes();\n            startButton.style.display = 'none'; // Hide button after start\n        });\n    </script>\n</body>\n</html>"
