    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Amortized Analysis — Visual Demonstration</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #071024;\n    --bg2: #0b1a2b;\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.65);\n    --accent: #6ce5c5;\n    --accent2: #ffb86b;\n    --accent3: #8db6ff;\n    --danger: #ff6b6b;\n    --glass2: rgba(255,255,255,0.03);\n    --card: rgba(255,255,255,0.03);\n    --shadow: 0 8px 30px rgba(2,6,23,0.6);\n    font-family: 'Inter', system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(108,229,197,0.06), transparent 10%),\n                radial-gradient(900px 500px at 90% 80%, rgba(141,182,255,0.04), transparent 10%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e8f0ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  .wrap{\n    max-width:1100px;\n    margin:40px auto;\n    padding:36px;\n    border-radius:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    display:grid;\n    grid-template-columns: 1fr 380px;\n    gap:28px;\n    align-items:start;\n    backdrop-filter: blur(8px) saturate(1.1);\n  }\n\n  header{\n    grid-column: 1 / -1;\n    display:flex;\n    align-items: center;\n    gap:18px;\n  }\n  .logo{\n    width:68px;\n    height:68px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(108,229,197,0.16), rgba(141,182,255,0.12));\n    border: 1px solid rgba(255,255,255,0.04);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 6px 30px rgba(14,40,60,0.35), inset 0 -6px 18px rgba(255,255,255,0.02);\n  }\n  .logo svg{filter: drop-shadow(0 6px 16px rgba(12,30,60,0.5));}\n  h1{\n    margin:0;\n    font-weight:700;\n    letter-spacing:-0.02em;\n    font-size:20px;\n    color: #f6fbff;\n  }\n  p.lead{\n    margin:0;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* Left panel (visualization) */\n  .visual{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n    border-radius:14px;\n    padding:22px;\n    min-height:520px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:hidden;\n  }\n\n  .subtitle{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n  .desc{\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .desc .title{\n    font-size:15px;\n    font-weight:600;\n    color:#f8fcff;\n  }\n  .desc .meta{\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  .controls{\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn{\n    padding:9px 14px;\n    border-radius:10px;\n    font-weight:600;\n    font-size:13px;\n    cursor:pointer;\n    border: 1px solid rgba(255,255,255,0.04);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color: #e9fbf4;\n    transition: transform .18s ease, box-shadow .18s ease, opacity .12s ease;\n    box-shadow: 0 8px 20px rgba(3,8,18,0.45);\n  }\n  .btn:active{ transform: translateY(1px) scale(.997); }\n  .btn.ghost{\n    background: transparent;\n    border:1px dashed rgba(255,255,255,0.03);\n    color: var(--muted);\n    font-weight:600;\n  }\n\n  .stage{\n    flex:1;\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    padding:18px 6px;\n  }\n\n  /* array visualization */\n  .array-wrap{\n    width:100%;\n    display:flex;\n    justify-content:center;\n    align-items:center;\n    gap:18px;\n    transition: all 420ms cubic-bezier(.2,.95,.1,1);\n    perspective:900px;\n  }\n  .array{\n    min-width:300px;\n    max-width:720px;\n    width:66%;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    border: 1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 14px 40px rgba(4,10,18,0.55);\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    transform: translateZ(0);\n  }\n  .array-top{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:10px;\n  }\n  .capsule{\n    background: linear-gradient(90deg, rgba(108,229,197,0.09), rgba(141,182,255,0.06));\n    padding:8px 12px;\n    border-radius:999px;\n    font-weight:600;\n    color: #dffbf0;\n    font-size:13px;\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .capsule .pill{\n    background: rgba(255,255,255,0.04);\n    padding:6px 10px;\n    border-radius:999px;\n    font-weight:700;\n    color:#f6fbff;\n    font-size:12px;\n  }\n\n  .cells{\n    display:flex;\n    gap:8px;\n    align-items:center;\n    justify-content:flex-start;\n    min-height:84px;\n  }\n\n  .cell{\n    --w:56px;\n    width:var(--w);\n    height:56px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:#bfeee1;\n    font-weight:700;\n    font-size:15px;\n    position:relative;\n    transition: transform 420ms cubic-bezier(.2,.95,.1,1), box-shadow 280ms ease, opacity 300ms ease;\n    box-shadow: 0 8px 26px rgba(4,10,18,0.45);\n  }\n  .cell.index{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    color:rgba(255,255,255,0.38);\n    font-weight:600;\n    font-size:12px;\n  }\n  .cell.filled{\n    background: linear-gradient(180deg, rgba(108,229,197,0.16), rgba(141,182,255,0.06));\n    color: #02131b;\n    box-shadow: 0 12px 30px rgba(30,90,110,0.12), inset 0 -6px 24px rgba(255,255,255,0.03);\n  }\n\n  .resizing{\n    position:absolute;\n    top:28%;\n    left:50%;\n    transform:translate(-50%,-50%);\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:16px 18px;\n    border-radius:10px;\n    border: 1px solid rgba(255,255,255,0.04);\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    box-shadow: 0 18px 50px rgba(2,8,20,0.55);\n    opacity:0;\n    pointer-events:none;\n    transform-origin:center;\n    transition: all 360ms cubic-bezier(.2,.95,.1,1);\n  }\n  .resizing.show{\n    opacity:1;\n    transform:translate(-50%,-50%) scale(1.02);\n  }\n\n  /* Right panel (stats) */\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:18px;\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n    min-height:520px;\n  }\n  .stat{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .stat .k{\n    font-weight:800;\n    font-size:28px;\n    color:#fff;\n  }\n  .stat .label{\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  .chart{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border-radius:10px;\n    padding:12px;\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:8px;\n    height:250px;\n  }\n  .chart .info{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    color:var(--muted);\n    font-size:12px;\n  }\n  .bars{\n    flex:1;\n    display:flex;\n    align-items:flex-end;\n    gap:6px;\n    padding:8px;\n    overflow:hidden;\n    position:relative;\n  }\n  .bar{\n    width:14px;\n    border-radius:6px 6px 4px 4px;\n    background: linear-gradient(180deg, rgba(108,229,197,0.9), rgba(141,182,255,0.6));\n    box-shadow: 0 8px 20px rgba(12,18,34,0.5);\n    transform-origin:bottom center;\n    transition: height 420ms cubic-bezier(.2,.95,.1,1), opacity 360ms ease, background 240ms ease;\n  }\n  .bar.spike{\n    background: linear-gradient(180deg, rgba(255,184,107,0.95), rgba(255,107,107,0.75));\n    box-shadow: 0 16px 34px rgba(255,129,80,0.12);\n  }\n\n  .avg{\n    position:absolute;\n    right:8px;\n    top:8px;\n    background: rgba(255,255,255,0.03);\n    padding:6px 10px;\n    border-radius:999px;\n    font-weight:700;\n    color:#f4fff7;\n    font-size:13px;\n    border: 1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(6px);\n  }\n\n  .theory{\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.3;\n    padding-top:6px;\n  }\n\n  footer{\n    grid-column: 1 / -1;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    color:var(--muted);\n    font-size:12px;\n    margin-top:6px;\n    padding-top:6px;\n    border-top: 1px dashed rgba(255,255,255,0.02);\n  }\n\n  /* subtle animations */\n  .pulse{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    background:\n      radial-gradient(600px 200px at 12% 18%, rgba(108,229,197,0.02), transparent 10%),\n      radial-gradient(500px 160px at 88% 86%, rgba(141,182,255,0.02), transparent 10%);\n    mix-blend-mode: screen;\n    opacity:0.9;\n    filter: blur(12px);\n  }\n\n  /* responsive */\n  @media (max-width:980px){\n    .wrap{ grid-template-columns: 1fr; padding:18px; gap:18px; margin:18px; }\n    .array{ width:100%; }\n    .array-wrap{ gap:8px; }\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\" role=\"main\" aria-label=\"Amortized Analysis visualization\">\n  <header>\n    <div class=\"logo\" aria-hidden=\"true\">\n      <svg width=\"46\" height=\"46\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#6CE5C5\"/>\n            <stop offset=\"1\" stop-color=\"#8DB6FF\"/>\n          </linearGradient>\n        </defs>\n        <rect x=\"2\" y=\"2\" width=\"44\" height=\"44\" rx=\"10\" fill=\"url(#g1)\" opacity=\"0.14\"/>\n        <path d=\"M14 28c2-6 9-11 17-7\" stroke=\"url(#g1)\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        <circle cx=\"28\" cy=\"18\" r=\"2.3\" fill=\"url(#g1)\"/>\n      </svg>\n    </div>\n    <div style=\"flex:1;\">\n      <h1>Amortized Analysis — Dynamic Array (Doubling)</h1>\n      <p class=\"lead\">Observe occasional expensive resizes versus many cheap insertions. Watch the average cost stabilize.</p>\n    </div>\n    <div style=\"display:flex; gap:10px; align-items:center;\">\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"playBtn\" class=\"btn\" title=\"Play or pause animation\">Pause</button>\n        <button id=\"resetBtn\" class=\"btn ghost\" title=\"Reset demonstration\">Reset</button>\n      </div>\n    </div>\n  </header>\n\n  <section class=\"visual\" aria-hidden=\"false\">\n    <div class=\"subtitle\">\n      <div class=\"desc\">\n        <div class=\"title\">Dynamic array — push operations</div>\n        <div class=\"meta\">Capacity doubles when full. Resizes produce spikes in cost (copying elements).</div>\n      </div>\n      <div class=\"capsule\" aria-hidden=\"true\">\n        <div class=\"pill\" id=\"capPill\">Cap: 4</div>\n        <div class=\"pill\" id=\"sizePill\">Size: 0</div>\n      </div>\n    </div>\n\n    <div class=\"stage\">\n      <div class=\"array-wrap\">\n        <div class=\"array\" id=\"arrayCard\" role=\"img\" aria-label=\"Array visualization\">\n          <div class=\"array-top\">\n            <div style=\"font-weight:700; color:#ecfbf8;\">Array Storage</div>\n            <div style=\"font-size:12px; color:var(--muted);\">Doubling strategy • Resizes cost = number of copied elements + insertion</div>\n          </div>\n          <div class=\"cells\" id=\"cells\"></div>\n        </div>\n      </div>\n\n      <div class=\"resizing\" id=\"resizingBox\" aria-live=\"polite\">\n        <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" style=\"opacity:0.9; transform:translateY(2px);\">\n          <path d=\"M12 2v6M12 16v6M4 12h6M14 12h6\" stroke=\"url(#g2)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\" stroke=\"#eafff6\"/>\n        </svg>\n        <div style=\"display:flex;flex-direction:column\">\n          <div style=\"font-weight:700; color:#f3fff9; font-size:14px;\">Resizing…</div>\n          <div style=\"font-size:12px; color:var(--muted);\">Copying elements into new buffer</div>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"height:6px;\"></div>\n\n    <div style=\"display:flex; gap:12px; align-items:center; justify-content:center;\">\n      <div style=\"background:linear-gradient(90deg, rgba(108,229,197,0.06), rgba(141,182,255,0.04)); padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.02);\">\n        <div style=\"font-size:12px; color:var(--muted);\">Last operation cost</div>\n        <div id=\"lastCost\" style=\"font-weight:800; font-size:22px; color:#fff;\">0</div>\n      </div>\n\n      <div style=\"background:linear-gradient(90deg, rgba(255,184,107,0.04), rgba(141,182,255,0.02)); padding:10px 14px; border-radius:10px; border:1px solid rgba(255,255,255,0.02);\">\n        <div style=\"font-size:12px; color:var(--muted);\">Cumulative cost</div>\n        <div id=\"cumCost\" style=\"font-weight:800; font-size:22px; color:#fff;\">0</div>\n      </div>\n    </div>\n\n    <div class=\"pulse\" aria-hidden=\"true\"></div>\n  </section>\n\n  <aside class=\"panel\" aria-hidden=\"false\">\n    <div class=\"stat\">\n      <div style=\"flex:1;\">\n        <div class=\"k\" id=\"opsCounter\">0</div>\n        <div class=\"label\">Total insert operations</div>\n      </div>\n    </div>\n\n    <div class=\"chart\" aria-hidden=\"true\">\n      <div class=\"info\">\n        <div style=\"font-weight:700; color:#f7fff8;\">Operation costs (recent)</div>\n        <div style=\"font-size:12px; color:var(--muted);\">spikes represent resizes</div>\n      </div>\n      <div class=\"bars\" id=\"bars\"></div>\n      <div class=\"avg\" id=\"avgBadge\">Avg: 0.00</div>\n    </div>\n\n    <div style=\"padding-top:6px;\">\n      <div style=\"font-weight:700; color:#fff; margin-bottom:6px;\">Amortized cost (observed)</div>\n      <div style=\"font-size:14px; font-weight:700; color:#dffbf0;\" id=\"amortizedDisplay\">0.00 per operation</div>\n      <div class=\"theory\" style=\"margin-top:8px;\">\n        Theory: For doubling arrays the amortized cost per push is O(1). A classic bound shows amortized cost ≤ 3. Observe that long-term average stabilizes near a small constant.\n      </div>\n    </div>\n\n    <div style=\"flex:1\"></div>\n\n    <div style=\"display:flex; gap:8px; align-items:center; justify-content:space-between;\">\n      <div style=\"font-size:12px; color:var(--muted);\">Visualization auto-runs. Pause to inspect. Reset clears state.</div>\n      <div style=\"font-size:12px; color:var(--muted);\">© Amortized Demo</div>\n    </div>\n  </aside>\n\n  <footer>\n    <div>Elegant, minimal interaction — observe the process</div>\n    <div style=\"display:flex; gap:12px; align-items:center;\">\n      <div style=\"color:var(--muted);\">Cap doubling example • Resizing cost shown</div>\n    </div>\n  </footer>\n</div>\n\n<script>\n/*\n  Amortized Analysis Visualization (single-file)\n  - Simple controls: Play/Pause and Reset\n  - Animates pushes into a dynamic array with doubling capacity\n  - Visual spikes when a resize (copying) happens\n  - Shows cumulative and average (amortized) cost\n*/\n\n(function(){\n  // DOM elements\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const cellsEl = document.getElementById('cells');\n  const capPill = document.getElementById('capPill');\n  const sizePill = document.getElementById('sizePill');\n  const lastCostEl = document.getElementById('lastCost');\n  const cumCostEl = document.getElementById('cumCost');\n  const opsCounter = document.getElementById('opsCounter');\n  const barsEl = document.getElementById('bars');\n  const avgBadge = document.getElementById('avgBadge');\n  const amortizedDisplay = document.getElementById('amortizedDisplay');\n  const resizingBox = document.getElementById('resizingBox');\n  const arrayCard = document.getElementById('arrayCard');\n\n  // state\n  let capacity = 4;\n  let size = 0;\n  let ops = 0;\n  let cumCost = 0;\n  let running = true;\n  let interval = null;\n  const recent = []; // recent operation costs\n  const MAX_BARS = 30;\n\n  // styles & sizes\n  const baseCellWidth = 56;\n  const gap = 8;\n\n  // initialize visualization\n  function init(){\n    capacity = 4;\n    size = 0;\n    ops = 0;\n    cumCost = 0;\n    recent.length = 0;\n    renderCells();\n    updatePills();\n    updateStats();\n    clearBars();\n    hideResizing();\n  }\n\n  function renderCells(){\n    // render capacity cells with indices; mark filled ones\n    cellsEl.innerHTML = '';\n    for(let i=0;i<capacity;i++){\n      const cell = document.createElement('div');\n      cell.className = 'cell' + (i < size ? ' filled' : ' index');\n      cell.style.setProperty('--w', baseCellWidth + 'px');\n      cell.style.opacity = '0';\n      // content\n      if(i < size){\n        cell.textContent = i+1;\n      } else {\n        cell.innerHTML = '<span style=\"font-size:11px;color:rgba(255,255,255,0.18)\">·</span>';\n      }\n      cellsEl.appendChild(cell);\n      // staggered entrance\n      setTimeout(()=> cell.style.opacity = '1', 60 + i*18);\n    }\n  }\n\n  function updatePills(){\n    capPill.textContent = 'Cap: ' + capacity;\n    sizePill.textContent = 'Size: ' + size;\n  }\n\n  function updateStats(){\n    lastCostEl.textContent = String(recent.length ? recent[recent.length-1] : 0);\n    cumCostEl.textContent = String(cumCost);\n    opsCounter.textContent = String(ops);\n    const avg = ops ? (cumCost / ops) : 0;\n    avgBadge.textContent = 'Avg: ' + avg.toFixed(2);\n    amortizedDisplay.textContent = avg.toFixed(2) + ' per operation';\n  }\n\n  function pushOperation(){\n    // Determine if resize occurs BEFORE insertion (when size == capacity)\n    let cost = 1;\n    let didResize = false;\n    if(size === capacity){\n      // resizing: copy size elements (existing) + insertion\n      cost = size + 1;\n      didResize = true;\n      performResizeAnimation(capacity * 2);\n    } else {\n      // simple push\n      animateSimplePush();\n    }\n\n    // apply state changes (after a short delay to sync with animation)\n    ops += 1;\n    cumCost += cost;\n    recent.push(cost);\n    if(recent.length > MAX_BARS) recent.shift();\n\n    if(didResize){\n      // apply resize logic: double capacity, then add element\n      capacity = capacity * 2;\n      size = size + 1;\n      // render after resize finishes; schedule a render after animation\n      setTimeout(() => {\n        renderCells();\n        updatePills();\n        updateStats();\n        renderBars();\n      }, 680);\n    } else {\n      size = size + 1;\n      // just update cell visuals for the new filled cell\n      setTimeout(()=> {\n        renderCells();\n        updatePills();\n        updateStats();\n        renderBars();\n      }, 140);\n    }\n\n    // immediate small updates\n    updateStats();\n  }\n\n  // Visual behaviors\n  function animateSimplePush(){\n    // small pulse on the next empty cell\n    const idx = size;\n    const target = cellsEl.children[idx];\n    if(!target) return;\n    target.classList.add('filled');\n    target.style.transform = 'translateY(-8px) scale(1.02)';\n    target.style.boxShadow = '0 14px 30px rgba(20,90,110,0.12)';\n    setTimeout(()=> {\n      target.style.transform = '';\n      target.style.boxShadow = '';\n    }, 380);\n  }\n\n  function performResizeAnimation(newCap){\n    showResizing();\n    // animate array card scale slightly for dramatic effect\n    arrayCard.style.transform = 'scale3d(1.02,1.02,1.02) translateZ(0)';\n    setTimeout(() => arrayCard.style.transform = '', 720);\n\n    // animate copy motion: clone current filled cells and animate them moving\n    const currentFilled = Math.max(0, size);\n    const clones = [];\n    for(let i=0;i<currentFilled;i++){\n      const orig = cellsEl.children[i];\n      if(!orig) continue;\n      const rect = orig.getBoundingClientRect();\n      const clone = orig.cloneNode(true);\n      clone.style.position = 'fixed';\n      clone.style.left = rect.left + 'px';\n      clone.style.top = rect.top + 'px';\n      clone.style.margin = '0';\n      clone.style.transition = 'transform 640ms cubic-bezier(.2,.95,.1,1), opacity 420ms ease';\n      clone.style.zIndex = 1200;\n      document.body.appendChild(clone);\n      clones.push(clone);\n    }\n\n    // compute target positions: simulate expansion to new width\n    // we place target positions slightly to the right to illustrate copying\n    setTimeout(() => {\n      for(let i=0;i<clones.length;i++){\n        const c = clones[i];\n        c.style.transform = `translateX(${40 + (i*10)}px) translateY(-12px) scale(0.98)`;\n        c.style.opacity = '0.9';\n      }\n    }, 60);\n\n    // fade out clones (they represent copying into new buffer)\n    setTimeout(()=> {\n      for(const c of clones){\n        c.style.opacity = '0';\n        c.style.transform += ' translateY(-4px) scale(0.92)';\n      }\n    }, 520);\n\n    // remove clones after animation\n    setTimeout(()=> {\n      for(const c of clones){\n        if(c && c.parentNode) c.parentNode.removeChild(c);\n      }\n      hideResizing();\n    }, 820);\n  }\n\n  function showResizing(){\n    resizingBox.classList.add('show');\n  }\n  function hideResizing(){\n    resizingBox.classList.remove('show');\n  }\n\n  // Bars for recent costs\n  function clearBars(){\n    barsEl.innerHTML = '';\n    for(let i=0;i<MAX_BARS;i++){\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      bar.style.height = '6px';\n      bar.style.opacity = '0.18';\n      barsEl.appendChild(bar);\n    }\n  }\n\n  function renderBars(){\n    // ensure bars count equals MAX_BARS\n    while(barsEl.children.length < MAX_BARS){\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      bar.style.height = '6px';\n      barsEl.insertBefore(bar, barsEl.firstChild);\n    }\n    const bars = Array.from(barsEl.children);\n    // map recent costs to last N bars aligned to right\n    // compute scaling: find max recent cost to scale bars, but clamp for visibility\n    const maxCost = Math.max(3, ...recent, 6);\n    // left pad\n    const pad = Math.max(0, MAX_BARS - recent.length);\n    for(let i=0;i<pad;i++){\n      const b = bars[i];\n      b.style.height = '6px';\n      b.style.opacity = '0.12';\n      b.classList.remove('spike');\n    }\n    // fill from pad..end with recent\n    for(let i=0;i<recent.length;i++){\n      const cost = recent[i];\n      const idx = pad + i;\n      const b = bars[idx];\n      const h = Math.max(6, Math.min(180, Math.round((cost / maxCost) * 160) + 6));\n      b.style.height = h + 'px';\n      b.style.opacity = '1';\n      if(cost > 3){\n        b.classList.add('spike');\n      } else {\n        b.classList.remove('spike');\n      }\n    }\n    // update lastCost etc\n    updateStats();\n  }\n\n  // loop control\n  function startLoop(){\n    if(interval) clearInterval(interval);\n    interval = setInterval(()=> {\n      if(running) pushOperation();\n    }, 900);\n    playBtn.textContent = 'Pause';\n  }\n  function stopLoop(){\n    if(interval) clearInterval(interval);\n    interval = null;\n    playBtn.textContent = 'Play';\n  }\n\n  // events\n  playBtn.addEventListener('click', ()=>{\n    running = !running;\n    if(running){\n      startLoop();\n    } else {\n      stopLoop();\n    }\n    playBtn.classList.toggle('active', running);\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    running = false;\n    stopLoop();\n    init();\n    // small visual bounce\n    arrayCard.style.transform = 'translateY(6px) scale(0.998)';\n    setTimeout(()=> arrayCard.style.transform = '', 260);\n    // resume after brief pause for observation\n    setTimeout(()=> {\n      running = true;\n      startLoop();\n    }, 780);\n  });\n\n  // initialize once\n  init();\n  renderBars();\n  startLoop();\n\n  // small adaptive behavior: keep the visualization lively even if hidden\n  document.addEventListener('visibilitychange', () => {\n    if(document.hidden){\n      // slow down\n      if(interval) clearInterval(interval);\n      interval = setInterval(()=> {\n        if(running) pushOperation();\n      }, 2200);\n    } else {\n      if(interval) clearInterval(interval);\n      interval = setInterval(()=> {\n        if(running) pushOperation();\n      }, 900);\n    }\n  });\n\n  // For graceful resizing adapt cell widths\n  function adaptCellSizes(){\n    const cardWidth = arrayCard.getBoundingClientRect().width - 36; // padding\n    // compute allowed cell width from capacity\n    const totalGaps = (capacity - 1) * 8;\n    const w = Math.max(36, Math.floor((cardWidth - totalGaps) / Math.max(4, capacity)));\n    const cells = document.querySelectorAll('.cell');\n    cells.forEach(c => c.style.setProperty('--w', (w) + 'px'));\n  }\n  window.addEventListener('resize', () => {\n    adaptCellSizes();\n  });\n  // adapt on every renderCells call\n  const originalRenderCells = renderCells;\n  renderCells = function(){\n    originalRenderCells();\n    adaptCellSizes();\n  };\n})();\n</script>\n</body>\n</html>"
