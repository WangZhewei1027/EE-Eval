    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Big-Omega Notation — Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Playfair+Display&display=swap');\n\n  /* Reset and base */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n  body, html {\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);\n    font-family: 'Poppins', sans-serif;\n    color: #f0f3f7;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    overflow: hidden;\n    user-select: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  /* Container */\n  main {\n    width: 90vw;\n    max-width: 900px;\n    background: rgba(255 255 255 / 0.08);\n    border-radius: 24px;\n    box-shadow:\n      0 0 40px 4px rgba(0, 255, 185, 0.15),\n      inset 0 0 40px 6px rgba(255 255 255 / 0.15);\n    padding: 3rem 4rem 4rem 4rem;\n    backdrop-filter: blur(12px);\n    position: relative;\n  }\n\n  /* Heading */\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 600;\n    font-size: 3.7rem;\n    text-align: center;\n    background: linear-gradient(90deg, #00FFD1, #00A3FF, #0096FF);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 0.08em;\n    margin-bottom: 0.3em;\n    user-select:none;\n  }\n\n  /* Subtitle */\n  h2 {\n    font-weight: 300;\n    font-size: 1.3rem;\n    text-align: center;\n    color: #ade8f4cc;\n    margin-bottom: 2rem;\n    user-select:none;\n  }\n\n  /* Visual container */\n  .visual {\n    position: relative;\n    width: 100%;\n    height: 320px;\n    border-radius: 20px;\n    background:\n      radial-gradient(circle at center, rgba(0,255,185,0.12), transparent 80%),\n      linear-gradient(130deg, #00ffd1a1, #0096ff55);\n    box-shadow:\n      inset 0 0 32px 2px rgba(0,255,185,0.3),\n      0 16px 48px rgba(0, 163, 255, 0.4);\n    overflow: visible;\n    user-select:none;\n  }\n\n  /* Big-Omega symbol container */\n  .omega-symbol {\n    position: absolute;\n    top: 12%;\n    left: 50%;\n    transform: translateX(-50%);\n    font-family: 'Playfair Display', serif;\n    font-size: 5.2rem;\n    font-weight: 700;\n    color: #00ffd1;\n    filter:\n      drop-shadow(0 0 6px #00ffd1cc)\n      drop-shadow(0 0 20px #00ffd1aa);\n    user-select:none;\n    pointer-events:none;\n    letter-spacing: 0.1em;\n  }\n\n  /* Text annotation block */\n  .annotation {\n    position: absolute;\n    top: 56%;\n    left: 50%;\n    transform: translateX(-50%);\n    color: #d1eefaee;\n    font-weight: 600;\n    text-align: center;\n    font-size: 1.15rem;\n    max-width: 80%;\n    user-select:none;\n    line-height: 1.4;\n    text-shadow:\n      0 0 6px #00ffd1aa;\n  }\n\n  /* Graph container */\n  .graph {\n    position: relative;\n    width: 100%;\n    height: 260px;\n    margin-top: 20px;\n    overflow: visible;\n  }\n\n  /* Axis lines */\n  .axis-line {\n    stroke: #00ffd1aa;\n    stroke-width: 1.8;\n    shape-rendering: crispEdges;\n  }\n\n  .axis-label {\n    font-family: 'Poppins', sans-serif;\n    fill: #00ffd1bb;\n    font-weight: 600;\n    font-size: 0.9rem;\n    user-select:none;\n  }\n\n  /* Curves styling */\n  path.curve {\n    fill: none;\n    stroke-width: 3.2;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 6px);\n  }\n\n  path.omega-bound {\n    stroke: #00ffd1;\n    filter: drop-shadow(0 0 16px #00ffd1);\n    transition: stroke-dashoffset 1.6s ease-in-out;\n  }\n\n  path.t-function {\n    stroke: #0096ff;\n    filter: drop-shadow(0 0 14px #0078ff);\n  }\n\n  /* Labels on curves */\n  text.curve-label {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 700;\n    font-size: 1.1rem;\n    fill: #00ffd1dd;\n    filter: drop-shadow(0 0 6px #00ffd1cc);\n    user-select:none;\n  }\n\n  text.t-label {\n    fill: #0096ffcc;\n    filter: drop-shadow(0 0 6px #0057ddcc);\n  }\n\n  /* Buttons container */\n  .controls {\n    margin-top: 2.5rem;\n    display: flex;\n    justify-content: center;\n    gap: 24px;\n    user-select:none;\n  }\n  button {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    letter-spacing: 0.05em;\n    background: linear-gradient(135deg, #00ffd1, #0096ff);\n    color: #0e2233;\n    border: none;\n    border-radius: 28px;\n    padding: 16px 38px;\n    cursor: pointer;\n    box-shadow:\n      0 0 12px 0 rgba(0,255,209,0.5);\n    transition:\n      background 0.25s ease,\n      box-shadow 0.35s ease,\n      transform 0.22s ease;\n  }\n  button:hover,\n  button:focus {\n    outline: none;\n    background: linear-gradient(135deg, #00a6f7, #0079ff);\n    box-shadow:\n      0 0 18px 4px #00a6f7bd;\n    transform: translateY(-4.5px);\n  }\n  button:active {\n    transform: translateY(-1.5px);\n    box-shadow:\n      0 0 8px 1px #0082ffbb;\n  }\n\n  /* Animations for the curves drawing */\n  path {\n    stroke-dasharray: 1100;\n    stroke-dashoffset: 1100;\n    animation-fill-mode: forwards;\n  }\n  path.draw-omega {\n    animation: drawOmega 1.8s ease-out forwards;\n  }\n  path.draw-t {\n    animation: drawT 2.2s ease-out forwards;\n  }\n\n  /* Animation keyframes */\n  @keyframes drawOmega {\n    0% { stroke-dashoffset: 1100; }\n    100% { stroke-dashoffset: 0; }\n  }\n  @keyframes drawT {\n    0% { stroke-dashoffset: 1100; }\n    100% { stroke-dashoffset: 0; }\n  }\n\n  /* Detailed text block beneath graph */\n  .description {\n    margin-top: 3rem;\n    color: #b2d9f7bb;\n    font-weight: 300;\n    line-height: 1.6;\n    font-size: 1rem;\n    max-width: 860px;\n    text-align: center;\n    user-select:none;\n    text-shadow: 0 0 8px #00ffd1aa;\n  }\n\n  /* Glowing subtle background circle */\n  .glow-circle {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 400px;\n    height: 400px;\n    transform: translate(-50%, -50%);\n    background: radial-gradient(circle at center, #00ffd1bb 0%, transparent 70%);\n    filter: blur(100px);\n    z-index: 0;\n    pointer-events:none;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width: 640px) {\n    main {\n      padding: 2rem 2.5rem 3rem 2.5rem;\n    }\n    h1 {\n      font-size: 2.8rem;\n    }\n    h2 {\n      font-size: 1.1rem;\n    }\n    .omega-symbol {\n      font-size: 4rem;\n      top: 15%;\n    }\n    .visual {\n      height: 250px;\n    }\n  }\n</style>\n</head>\n<body>\n  <main role=\"main\" aria-label=\"Big Omega Notation Visual Explanation\">\n    <div class=\"glow-circle\" aria-hidden=\"true\"></div>\n    <h1>Big−Ω Notation</h1>\n    <h2><em>Asymptotic Lower Bound of Complexity</em></h2>\n\n    <section class=\"visual\" aria-describedby=\"annotation-text\" aria-label=\"Graph visualization of Big Omega notation\">\n      <div class=\"omega-symbol\" aria-hidden=\"true\">Ω</div>\n      <div class=\"annotation\" id=\"annotation-text\">\n        <p>\n          <strong>Big Omega (Ω)</strong> describes a function's growth lower bound. For large <em>n</em>, the function grows <em>at least as fast</em> as Ω(<em>g</em>(<em>n</em>)).\n        </p>\n      </div>\n      <svg\n        class=\"graph\"\n        viewBox=\"0 0 600 260\"\n        role=\"img\"\n        aria-label=\"Graph showing Big Omega lower bound relation between functions\"\n        xmlns=\"http://www.w3.org/2000/svg\"\n        aria-live=\"polite\"\n        tabindex=\"0\"\n      >\n        <!-- Axis -->\n        <line x1=\"40\" y1=\"230\" x2=\"40\" y2=\"20\" class=\"axis-line\" />\n        <line x1=\"40\" y1=\"230\" x2=\"590\" y2=\"230\" class=\"axis-line\" />\n\n        <!-- Axis labels -->\n        <text x=\"20\" y=\"32\" class=\"axis-label\" aria-hidden=\"true\" font-weight=\"700\">T(n)</text>\n        <text x=\"580\" y=\"252\" class=\"axis-label\" aria-hidden=\"true\">n →</text>\n\n        <!-- Omega bound curve -->\n        <path\n          class=\"curve omega-bound draw-omega\"\n          d=\"M40 210 \n             C110 180, 190 140, 270 120 \n             C350 110, 430 90, 510 80 \n             L510 230 L40 230 Z\"\n          aria-label=\"Big Omega lower bound curve\"\n        ></path>\n\n        <!-- Function t(n) curve -->\n        <path\n          class=\"curve t-function draw-t\"\n          d=\"M40 200 \n             C130 170, 230 140, 290 120 \n             C360 90, 470 60, 540 55\"\n          aria-label=\"Function T(n) curve\"\n        ></path>\n\n        <!-- Labels on curves -->\n        <text x=\"420\" y=\"70\" class=\"curve-label\" aria-hidden=\"true\">Ω(g(n))</text>\n        <text x=\"480\" y=\"45\" class=\"curve-label t-label\" aria-hidden=\"true\">T(n)</text>\n      </svg>\n    </section>\n\n    <p class=\"description\" id=\"desc\">\n      By ensuring <strong>T(n) &ge; c·g(n)</strong> for sufficiently large <em>n</em>, Big Omega notation provides a guaranteed *minimum* growth rate of an algorithm’s time or space complexity. It's fundamental for understanding the performance floor beneath an algorithm's behavior.\n    </p>\n\n    <nav class=\"controls\" aria-label=\"Controls to replay animations and toggle theme\">\n      <button id=\"replayBtn\" type=\"button\" aria-describedby=\"desc\">Replay Animation</button>\n      <button id=\"themeBtn\" type=\"button\" aria-pressed=\"false\" aria-label=\"Toggle light and dark theme\">Toggle Theme</button>\n    </nav>\n  </main>\n\n<script>\n  (() => {\n    const replayBtn = document.getElementById('replayBtn');\n    const themeBtn = document.getElementById('themeBtn');\n    const omegaPath = document.querySelector('path.omega-bound');\n    const tPath = document.querySelector('path.t-function');\n    const body = document.body;\n\n    replayBtn.addEventListener('click', () => {\n      // Restart CSS animations by cloning nodes\n      const newOmega = omegaPath.cloneNode(true);\n      omegaPath.parentNode.replaceChild(newOmega, omegaPath);\n\n      const newT = tPath.cloneNode(true);\n      tPath.parentNode.replaceChild(newT, tPath);\n\n      // Reassign for next replay\n      omegaPath = newOmega;\n      tPath = newT;\n    });\n\n    themeBtn.addEventListener('click', () => {\n      const isDark = body.classList.toggle('light-theme');\n      themeBtn.setAttribute('aria-pressed', isDark ? 'true' : 'false');\n\n      if (isDark) {\n        document.body.style.background = 'linear-gradient(135deg, #f0f4f8, #d9e2ec, #bcccdc)';\n        document.body.style.color = '#204060';\n        document.querySelector('main').style.background = 'rgba(10 35 65 / 0.05)';\n        // Switch heading gradient to a darker blue\n        document.querySelector('h1').style.background = 'linear-gradient(90deg, #004e8a, #0072ce, #004273)';\n        // Adjust glow\n        document.querySelector('.glow-circle').style.background = 'radial-gradient(circle at center, #0072cebb 0%, transparent 70%)';\n      } else {\n        // Reset to dark theme\n        document.body.style.background = 'linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%)';\n        document.body.style.color = '#f0f3f7';\n        document.querySelector('main').style.background = 'rgba(255 255 255 / 0.08)';\n        document.querySelector('h1').style.background = 'linear-gradient(90deg, #00FFD1, #00A3FF, #0096FF)';\n        document.querySelector('.glow-circle').style.background = 'radial-gradient(circle at center, #00ffd1bb 0%, transparent 70%)';\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
