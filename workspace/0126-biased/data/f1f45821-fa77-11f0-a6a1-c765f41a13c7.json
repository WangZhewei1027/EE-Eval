    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Doubly Linked List — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --accent: #7c5cff;\n    --accent-2: #30d5c8;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --node-bg: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    --node-border: rgba(255,255,255,0.08);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(123,63,255,0.12), transparent 8%),\n                radial-gradient(800px 400px at 90% 85%, rgba(48,213,200,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg1), #071026 60%);\n    color: #e9eefb;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n  }\n\n  /* Center Card */\n  .board{\n    width: min(1100px, 96%);\n    border-radius:20px;\n    padding:28px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    display:block;\n    overflow:hidden;\n    position:relative;\n  }\n\n  /* Decorative corner */\n  .board::before{\n    content:\"\";\n    position:absolute;\n    left:-120px;\n    top:-120px;\n    width:400px;height:400px;\n    background: radial-gradient(circle at 30% 30%, rgba(124,92,255,0.12), transparent 30%),\n                linear-gradient(60deg, rgba(48,213,200,0.06), transparent 30%);\n    transform: rotate(-18deg);\n    filter: blur(28px);\n    opacity:0.95;\n    pointer-events:none;\n  }\n\n  header{\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:18px;\n  }\n  .logo{\n    width:72px;height:72px;border-radius:14px;\n    background:linear-gradient(135deg,var(--accent),var(--accent-2));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow:0 6px 30px rgba(124,92,255,0.28), inset 0 1px 0 rgba(255,255,255,0.18);\n    transform:translateZ(0);\n    flex-shrink:0;\n  }\n  .logo svg{filter:drop-shadow(0 6px 18px rgba(48,213,200,0.12));}\n  h1{\n    margin:0;\n    font-family:\"Playfair Display\", serif;\n    font-weight:700;\n    letter-spacing:-0.6px;\n    font-size:20px;\n    color: #ffffff;\n  }\n  p.lead{\n    margin:2px 0 0 0;\n    font-size:13px;color:var(--muted);\n  }\n\n  /* Content area */\n  .visual{\n    margin-top:18px;\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:18px;\n    position:relative;\n  }\n\n  /* Node Row */\n  .nodes-wrap{\n    width:100%;\n    display:flex;\n    justify-content:center;\n    align-items:center;\n    gap:18px;\n    padding:34px 20px;\n    position:relative;\n  }\n\n  /* Each node */\n  .node{\n    width:120px;\n    height:120px;\n    border-radius:18px;\n    background:var(--node-bg);\n    border:1px solid var(--node-border);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.45), inset 0 -6px 30px rgba(255,255,255,0.01);\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    transition: transform 450ms cubic-bezier(.2,.9,.3,1), box-shadow 300ms;\n    transform-origin:center;\n    cursor:default;\n  }\n  .node .idx{\n    font-size:12px;color:var(--muted);position:absolute;top:10px;left:12px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), transparent);\n    padding:6px 8px;border-radius:10px;border:1px solid rgba(255,255,255,0.02);\n    backdrop-filter: blur(6px);\n  }\n  .node .val{\n    font-size:22px;font-weight:700;color:#fff;letter-spacing:0.6px;\n    font-family:Inter, sans-serif;\n  }\n  .node .ptr{\n    font-size:11px;color:var(--muted);position:absolute;bottom:10px;right:12px;\n    display:flex;gap:6px;align-items:center;\n  }\n  .node .dot{\n    width:8px;height:8px;border-radius:50%;\n    background:linear-gradient(180deg,var(--accent),var(--accent-2));\n    box-shadow:0 4px 10px rgba(124,92,255,0.22);\n  }\n\n  /* Current highlight */\n  .node.current{\n    transform: translateY(-12px) scale(1.03);\n    box-shadow: 0 22px 60px rgba(124,92,255,0.22), 0 2px 12px rgba(48,213,200,0.08);\n  }\n  .node .halo{\n    position:absolute;inset:-14px;border-radius:26px;\n    background: radial-gradient(ellipse at center, rgba(124,92,255,0.06), transparent 30%);\n    filter: blur(14px);opacity:0.95;z-index:-1;\n  }\n\n  /* Arrow SVG overlay */\n  .arrows{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    display:block;\n  }\n\n  /* Controls area */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border: 1px solid rgba(255,255,255,0.04);\n    color:#fff;padding:10px 14px;border-radius:12px;font-weight:600;font-size:13px;\n    display:inline-flex;gap:10px;align-items:center;cursor:pointer;\n    transition: transform 160ms ease, box-shadow 160ms ease, opacity 140ms;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n  }\n  .btn:active{transform: translateY(1px)}\n  .btn.secondary{\n    color:var(--muted);\n    background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.008));\n  }\n  .btn .dot{\n    width:10px;height:10px;border-radius:50%;background:var(--accent);\n    box-shadow: 0 6px 14px rgba(124,92,255,0.26);\n  }\n  .btn.pause .dot{background: #ff7a7a; box-shadow: 0 6px 14px rgba(255,122,122,0.16)}\n  .status{\n    margin-left:auto;color:var(--muted);font-size:13px;\n  }\n\n  /* Footer caption */\n  .meta{\n    margin-top:14px;color:var(--muted);font-size:13px;display:flex;align-items:center;justify-content:space-between;\n  }\n  .meta .explain{max-width:70%}\n  .chips{display:flex;gap:8px;align-items:center}\n\n  /* small screens */\n  @media (max-width:820px){\n    .nodes-wrap{overflow:auto;padding:24px 6px}\n    .node{width:96px;height:96px;border-radius:14px}\n    .node .val{font-size:18px}\n    .logo{width:56px;height:56px}\n  }\n\n  /* Subtle animated shimmer on title */\n  .brandPulse{\n    display:inline-block;\n    background: linear-gradient(90deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02) 40%, rgba(255,255,255,0.12));\n    background-size:200% 100%;\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    animation: pulse 6s linear infinite;\n  }\n  @keyframes pulse{0%{background-position:0%}50%{background-position:100%}100%{background-position:0%}}\n\n  /* Arrow animations */\n  .arrow-path{stroke:#9fbff6; stroke-width:2.2; fill:none; opacity:0.65; stroke-linecap:round; transition:opacity 220ms}\n  .arrow-path.reverse{stroke:#7ce6d8; opacity:0.5}\n  .arrow-dot{fill:var(--accent); opacity:0.0; transition:opacity 200ms}\n  .arrow-active{opacity:1; filter:drop-shadow(0 8px 20px rgba(124,92,255,0.22));}\n  /* dash drawing */\n  .dash-animate{ stroke-dasharray: 1000; stroke-dashoffset: 1000; animation: draw 600ms forwards cubic-bezier(.2,.9,.3,1) }\n  @keyframes draw{ to{stroke-dashoffset: 0} }\n\n  /* small meta circles */\n  .tag{font-size:12px;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.02)}\n</style>\n</head>\n<body>\n<div class=\"board\" role=\"main\" aria-label=\"Doubly Linked List Visualization\">\n  <header>\n    <div class=\"logo\" aria-hidden=\"true\">\n      <svg width=\"42\" height=\"42\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ffffff\" stop-opacity=\"0.9\"/>\n            <stop offset=\"1\" stop-color=\"#ffffff\" stop-opacity=\"0.2\"/>\n          </linearGradient>\n        </defs>\n        <rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" fill=\"url(#g1)\" opacity=\"0.06\"></rect>\n        <path d=\"M7 12h6M11 8v8\" stroke=\"#fff\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.95\"/>\n        <circle cx=\"18\" cy=\"6\" r=\"2.2\" fill=\"#fff\" opacity=\"0.9\"/>\n      </svg>\n    </div>\n    <div>\n      <h1><span class=\"brandPulse\">Doubly Linked List</span></h1>\n      <p class=\"lead\">A refined, animated concept showcasing nodes with next and previous pointers — observe the bidirectional traversal.</p>\n    </div>\n  </header>\n\n  <div class=\"visual\">\n    <div class=\"nodes-wrap\" id=\"canvas\">\n      <!-- Nodes will be rendered here -->\n      <div class=\"node\" data-idx=\"0\" id=\"node-0\">\n        <div class=\"idx\">0x01</div>\n        <div class=\"val\">A</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <div class=\"node\" data-idx=\"1\" id=\"node-1\">\n        <div class=\"idx\">0x02</div>\n        <div class=\"val\">B</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <div class=\"node\" data-idx=\"2\" id=\"node-2\">\n        <div class=\"idx\">0x03</div>\n        <div class=\"val\">C</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <div class=\"node\" data-idx=\"3\" id=\"node-3\">\n        <div class=\"idx\">0x04</div>\n        <div class=\"val\">D</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <div class=\"node\" data-idx=\"4\" id=\"node-4\">\n        <div class=\"idx\">0x05</div>\n        <div class=\"val\">E</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <div class=\"node\" data-idx=\"5\" id=\"node-5\">\n        <div class=\"idx\">0x06</div>\n        <div class=\"val\">F</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <div class=\"node\" data-idx=\"6\" id=\"node-6\">\n        <div class=\"idx\">0x07</div>\n        <div class=\"val\">G</div>\n        <div class=\"ptr\"><span class=\"dot\"></span><span style=\"opacity:.9\">prev • next</span></div>\n      </div>\n\n      <!-- SVG overlay for arrows -->\n      <svg class=\"arrows\" id=\"arrows-svg\" xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"none\">\n        <!-- Paths will be generated dynamically -->\n      </svg>\n    </div>\n\n    <div style=\"width:100%;display:flex;align-items:center;\">\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button class=\"btn\" id=\"playBtn\" title=\"Play / Pause traversal\" aria-pressed=\"false\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path id=\"playIcon\" d=\"M5 3v18l15-9L5 3z\" fill=\"#fff\"></path></svg>\n          <span id=\"playLabel\">Pause</span>\n        </button>\n\n        <button class=\"btn secondary\" id=\"dirBtn\" title=\"Toggle direction\" aria-pressed=\"false\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 17l5-5-5-5\" stroke=\"#9fbff6\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          <span id=\"dirLabel\">Direction: Forward</span>\n        </button>\n\n      </div>\n\n      <div class=\"status\" id=\"status\">Traversing → &nbsp;&bull;&nbsp; Index: <strong id=\"idxLabel\">0</strong></div>\n    </div>\n\n    <div class=\"meta\">\n      <div class=\"explain\">\n        <span class=\"tag\">Concept</span>\n        <span style=\"margin-left:10px\">Nodes are connected both ways — each pointer links to previous and next. Watch the active node and arrows animate to illustrate bidirectional traversal.</span>\n      </div>\n      <div class=\"chips\">\n        <div class=\"tag\">Doubly Linked List</div>\n        <div class=\"tag\">Nodes: 7</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function(){\n    const nodes = Array.from(document.querySelectorAll('.node'));\n    const svg = document.getElementById('arrows-svg');\n    const playBtn = document.getElementById('playBtn');\n    const playLabel = document.getElementById('playLabel');\n    const dirBtn = document.getElementById('dirBtn');\n    const dirLabel = document.getElementById('dirLabel');\n    const idxLabel = document.getElementById('idxLabel');\n    const status = document.getElementById('status');\n\n    let current = 0;\n    let playing = true;\n    let forward = true;\n    let timer = null;\n    const spacing = 18;\n\n    // Setup initial sizes and svg size\n    function resizeSvg(){\n      const wrap = document.getElementById('canvas');\n      const rect = wrap.getBoundingClientRect();\n      svg.setAttribute('width', rect.width);\n      svg.setAttribute('height', rect.height);\n      svg.style.left = '0';\n      svg.style.top = '0';\n    }\n\n    // compute center positions of nodes relative to canvas\n    function centers(){\n      const wrap = document.getElementById('canvas');\n      const wrect = wrap.getBoundingClientRect();\n      return nodes.map(n=>{\n        const r = n.getBoundingClientRect();\n        return {\n          cx: r.left - wrect.left + r.width/2,\n          cy: r.top - wrect.top + r.height/2,\n          el: n,\n          rect: r\n        };\n      });\n    }\n\n    // clear svg arrows\n    function clearArrows(){ svg.innerHTML = ''; }\n\n    // create arrow path between node a -> b (curved slightly)\n    function createArrow(a,b,cls='forward'){\n      const dx = b.cx - a.cx;\n      const dy = b.cy - a.cy;\n      const dist = Math.hypot(dx,dy);\n      const curve = Math.min(90, dist/3);\n      const sweep = (dx>0)?1:0;\n      const midx = (a.cx + b.cx)/2;\n      const midy = (a.cy + b.cy)/2;\n      // simple quadratic bezier\n      const cx = midx - (dy>0 ? -curve : curve);\n      const cy = midy - (dx>0 ? curve : -curve);\n      const pathD = `M ${a.cx} ${a.cy} Q ${cx} ${cy} ${b.cx} ${b.cy}`;\n      const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n      path.setAttribute('d', pathD);\n      path.setAttribute('class','arrow-path' + (cls==='reverse' ? ' reverse' : ''));\n      path.setAttribute('data-from', nodes.indexOf(a.el).toString());\n      path.setAttribute('data-to', nodes.indexOf(b.el).toString());\n      path.style.opacity = 0.28;\n      svg.appendChild(path);\n      // small dot at end\n      const dot = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      dot.setAttribute('cx', b.cx);\n      dot.setAttribute('cy', b.cy);\n      dot.setAttribute('r', 4);\n      dot.setAttribute('class','arrow-dot');\n      svg.appendChild(dot);\n      return {path,dot};\n    }\n\n    // render all bidirectional arrows\n    function renderArrows(){\n      clearArrows();\n      const c = centers();\n      for(let i=0;i<c.length-1;i++){\n        // forward arrow i -> i+1\n        createArrow(c[i], c[i+1], 'forward');\n        // reverse arrow i+1 -> i (slightly different style)\n        createArrow(c[i+1], c[i], 'reverse');\n      }\n    }\n\n    // highlight a node and animate arrow(s)\n    function highlight(idx, animate=true){\n      nodes.forEach((n,i)=> n.classList.toggle('current', i===idx));\n      idxLabel.textContent = idx;\n      status.innerHTML = (forward ? 'Traversing →' : 'Traversing ←') + ` &nbsp;&bull;&nbsp; Index: <strong>${idx}</strong>`;\n\n      // animate arrow between previous/current depending on direction\n      // find SVG path that goes from prev->curr or curr->prev and animate\n      const from = forward ? idx-1 : idx+1;\n      const to = idx;\n      // reset all arrow styles\n      const paths = svg.querySelectorAll('path.arrow-path');\n      const dots = svg.querySelectorAll('circle.arrow-dot');\n      paths.forEach(p=>{ p.classList.remove('dash-animate','arrow-active'); p.style.opacity = 0.28; });\n      dots.forEach(d=> d.style.opacity = 0);\n\n      if(from>=0 && from<nodes.length && to>=0 && to<nodes.length){\n        // find path with matching data-from & data-to\n        for(const p of paths){\n          if(p.getAttribute('data-from')==from && p.getAttribute('data-to')==to){\n            // trigger dash animation\n            if(animate){\n              // ensure recent redraw\n              void p.getBoundingClientRect();\n              p.classList.add('dash-animate','arrow-active');\n            } else {\n              p.classList.add('arrow-active');\n            }\n          }\n        }\n        for(const d of dots){\n          // dots follow the 'to' index positions: we can match by xml order: path count = 2*(n-1). We created forward then reverse for each adjacent pair, and appended dot after each path. So to find dot that matches path, easier to compute index: each adjacent creates path then dot, path then dot -> pattern path,dot,path,dot...\n          // Simpler approach: make a small proximity search to find dot near the target node center\n          const bbox = d.getBoundingClientRect ? d.getBoundingClientRect() : {x:0,y:0};\n          // We'll just set the appropriate dot (closest to target center)\n        }\n        // make the dot nearest to the 'to' node visible\n        const c = centers();\n        let best=null, bestD=Infinity;\n        dots.forEach(d=>{\n          const dx = parseFloat(d.getAttribute('cx')) - c[to].cx;\n          const dy = parseFloat(d.getAttribute('cy')) - c[to].cy;\n          const dist = Math.hypot(dx,dy);\n          if(dist < bestD){ bestD=dist; best=d; }\n        });\n        if(best) best.style.opacity = 1;\n      }\n    }\n\n    // traversal loop\n    function step(){\n      // advance current index\n      if(forward){\n        current++;\n        if(current >= nodes.length) current = 0;\n      } else {\n        current--;\n        if(current < 0) current = nodes.length - 1;\n      }\n      highlight(current,true);\n    }\n\n    function start(){\n      if(timer) clearInterval(timer);\n      timer = setInterval(step, 1300);\n      playing = true;\n      playBtn.setAttribute('aria-pressed','false');\n      playLabel.textContent = 'Pause';\n      // swap play icon to pause shape\n      playBtn.querySelector('#playIcon').setAttribute('d','M6 5h4v14H6zM14 5h4v14h-4z');\n    }\n    function stop(){\n      if(timer) clearInterval(timer);\n      timer = null;\n      playing = false;\n      playBtn.setAttribute('aria-pressed','true');\n      playLabel.textContent = 'Play';\n      playBtn.querySelector('#playIcon').setAttribute('d','M5 3v18l15-9L5 3z');\n    }\n\n    // toggle direction\n    function toggleDir(){\n      forward = !forward;\n      dirBtn.setAttribute('aria-pressed', String(!forward));\n      dirLabel.textContent = 'Direction: ' + (forward ? 'Forward' : 'Reverse');\n      // animate a subtle rotation on direction button\n      dirBtn.animate([{transform:'rotate(0deg)'},{transform:'rotate(' + (forward ? 8 : -8) + 'deg)'},{transform:'rotate(0deg)'}],{duration:380, easing:'cubic-bezier(.2,.9,.3,1)'});\n    }\n\n    // initialize\n    function init(){\n      resizeSvg();\n      renderArrows();\n      highlight(current,false);\n      start();\n    }\n\n    // events\n    window.addEventListener('resize', ()=>{\n      resizeSvg();\n      renderArrows();\n      highlight(current,false);\n    });\n\n    playBtn.addEventListener('click', ()=>{\n      if(playing) stop(); else start();\n      // subtle feedback\n      playBtn.animate([{transform:'scale(1)'},{transform:'scale(0.98)'},{transform:'scale(1)'}],{duration:220});\n    });\n\n    dirBtn.addEventListener('click', ()=>{\n      toggleDir();\n    });\n\n    // allow hover sparkle but keep interactions limited (no clicking nodes)\n    nodes.forEach(n=>{\n      n.addEventListener('mouseenter', ()=>{\n        n.animate([{transform:'translateY(0px)'},{transform:'translateY(-6px)'}],{duration:260,fill:'forwards', easing:'cubic-bezier(.2,.9,.3,1)'});\n      });\n      n.addEventListener('mouseleave', ()=>{\n        n.animate([{transform:'translateY(-6px)'},{transform:'translateY(0px)'}],{duration:260,fill:'forwards', easing:'cubic-bezier(.2,.9,.3,1)'});\n      });\n    });\n\n    // small auto-synchronization in case fonts load late\n    window.addEventListener('load', ()=> setTimeout(()=>{ resizeSvg(); renderArrows(); highlight(current,false); }, 120) );\n\n    // prepare for initial layout (defer to let layout settle)\n    setTimeout(init, 160);\n  })();\n</script>\n</body>\n</html>"
  },
