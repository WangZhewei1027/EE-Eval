  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Socket Programming Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  label, button, input, select {\n    margin: 2px 0;\n    display: block;\n  }\n  fieldset {\n    margin: 8px 0;\n    padding: 6px;\n  }\n  textarea {\n    width: 100%;\n    height: 150px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Socket Programming Interactive Simulator</h1>\n\n<div>\n  <fieldset>\n    <legend>Socket Configuration</legend>\n    <label for=\"ipAddress\">Remote IP Address:</label>\n    <input type=\"text\" id=\"ipAddress\" placeholder=\"e.g. 192.168.1.10\" value=\"127.0.0.1\"/>\n    \n    <label for=\"portNumber\">Port Number:</label>\n    <input type=\"number\" id=\"portNumber\" min=\"1\" max=\"65535\" value=\"8080\" />\n    \n    <label for=\"protocolSelect\">Protocol:</label>\n    <select id=\"protocolSelect\">\n      <option value=\"TCP\">TCP</option>\n      <option value=\"UDP\">UDP</option>\n    </select>\n    \n    <label for=\"socketTypeSelect\">Socket Type:</label>\n    <select id=\"socketTypeSelect\">\n      <option value=\"client\">Client</option>\n      <option value=\"server\">Server</option>\n    </select>\n    \n    <button id=\"createSocketBtn\">Create Socket</button>\n    <button id=\"closeSocketBtn\" disabled>Close Socket</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Socket State</legend>\n    <div id=\"socketState\">Socket not created</div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Server Controls (only for server sockets)</legend>\n    <button id=\"listenBtn\" disabled>Start Listening</button>\n    <button id=\"stopListenBtn\" disabled>Stop Listening</button>\n    <label for=\"backlogSlider\">Backlog (connection queue size): <span id=\"backlogValue\">5</span></label>\n    <input type=\"range\" id=\"backlogSlider\" min=\"1\" max=\"20\" value=\"5\" disabled />\n  </fieldset>\n\n  <fieldset>\n    <legend>Connection Controls (only for client sockets or accepted server sockets)</legend>\n    <button id=\"connectBtn\" disabled>Connect to Server</button>\n    <button id=\"disconnectBtn\" disabled>Disconnect</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Message Exchange</legend>\n    <label for=\"messageInput\">Message to send:</label>\n    <input type=\"text\" id=\"messageInput\" disabled />\n    <button id=\"sendMsgBtn\" disabled>Send Message</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Received Messages (Simulated)</legend>\n    <textarea id=\"receivedMessages\" readonly></textarea>\n  </fieldset>\n\n  <fieldset>\n    <legend>Simulated Network Conditions</legend>\n    <label for=\"latencySlider\">Latency (ms): <span id=\"latencyValue\">0</span></label>\n    <input type=\"range\" id=\"latencySlider\" min=\"0\" max=\"3000\" value=\"0\" />\n    <label for=\"packetLossSlider\">Packet Loss (%): <span id=\"packetLossValue\">0</span></label>\n    <input type=\"range\" id=\"packetLossSlider\" min=\"0\" max=\"100\" value=\"0\" />\n  </fieldset>\n\n  <fieldset>\n    <legend>Logs</legend>\n    <textarea id=\"logs\" readonly></textarea>\n  </fieldset>\n</div>\n\n<script>\n(() => {\n  // States possible for socket:\n  // Not created -> Created (closed) -> Server: Listening/Not Listening\n  // Client: Connected/Disconnected\n  // Server: On accept can create new connection sockets with Connected/Disconnected states\n  // We will simulate socket connections & data transfers in JS only - no real networking\n\n  const ipAddressInput = document.getElementById('ipAddress');\n  const portNumberInput = document.getElementById('portNumber');\n  const protocolSelect = document.getElementById('protocolSelect');\n  const socketTypeSelect = document.getElementById('socketTypeSelect');\n  const createSocketBtn = document.getElementById('createSocketBtn');\n  const closeSocketBtn = document.getElementById('closeSocketBtn');\n\n  const socketStateDiv = document.getElementById('socketState');\n\n  const listenBtn = document.getElementById('listenBtn');\n  const stopListenBtn = document.getElementById('stopListenBtn');\n  const backlogSlider = document.getElementById('backlogSlider');\n  const backlogValue = document.getElementById('backlogValue');\n\n  const connectBtn = document.getElementById('connectBtn');\n  const disconnectBtn = document.getElementById('disconnectBtn');\n\n  const messageInput = document.getElementById('messageInput');\n  const sendMsgBtn = document.getElementById('sendMsgBtn');\n\n  const receivedMessages = document.getElementById('receivedMessages');\n\n  const latencySlider = document.getElementById('latencySlider');\n  const latencyValue = document.getElementById('latencyValue');\n  const packetLossSlider = document.getElementById('packetLossSlider');\n  const packetLossValue = document.getElementById('packetLossValue');\n\n  const logs = document.getElementById('logs');\n\n  // The main simulated socket object\n  class SimSocket {\n    constructor(type, protocol, ip, port) {\n      this.type = type; // 'client' or 'server'\n      this.protocol = protocol; // 'TCP' or 'UDP'\n      this.ip = ip;\n      this.port = port;\n      this.state = 'created'; // 'created', 'listening', 'connected', 'disconnected', 'closed'\n      this.serverBacklog = 5;\n      this.listeningQueue = [];\n      this.acceptedConnections = [];\n      this.onAccept = null;\n      this.onReceive = null;\n      this.isClosed = false;\n      this.log(`Socket created: ${this.type} ${this.protocol} ${this.ip}:${this.port}`);\n    }\n    log(txt) {\n      appendLog(`[Socket ${this.type} ${this.protocol}]: ${txt}`);\n    }\n    close() {\n      this.state = 'closed';\n      this.isClosed = true;\n      this.log('Socket closed.');\n    }\n    listen(backlog) {\n      if(this.type !== 'server') {\n        this.log('Listen called on non-server socket.');\n        return false;\n      }\n      if(this.state !== 'created' && this.state !== 'disconnected') {\n        this.log(`Cannot listen while state is ${this.state}`);\n        return false;\n      }\n      this.state = 'listening';\n      this.serverBacklog = backlog;\n      this.listeningQueue = [];\n      this.log(`Now listening with backlog ${backlog}`);\n      return true;\n    }\n    stopListen() {\n      if(this.state !== 'listening') {\n        this.log('Not currently listening.');\n        return false;\n      }\n      this.state = 'created';\n      this.listeningQueue = [];\n      this.log('Stopped listening.');\n      return true;\n    }\n    accept() {\n      // Accept next connection in queue if any\n      if(this.state !== 'listening') {\n        this.log('Cannot accept if not listening.');\n        return null;\n      }\n      if(this.listeningQueue.length === 0) {\n        this.log('No pending connections to accept.');\n        return null;\n      }\n      const conn = this.listeningQueue.shift();\n      conn.state = 'connected';\n      this.acceptedConnections.push(conn);\n      this.log(`Accepted connection from ${conn.ip}:${conn.port}`);\n      return conn;\n    }\n    queueConnection(conn) {\n      if(this.state !== 'listening') {\n        this.log('Server not listening, cannot queue connection.');\n        return false;\n      }\n      if(this.listeningQueue.length >= this.serverBacklog) {\n        this.log(`Backlog full (${this.serverBacklog}), rejecting connection from ${conn.ip}:${conn.port}`);\n        return false; // Reject due to full backlog\n      }\n      this.listeningQueue.push(conn);\n      this.log(`Queued new connection from ${conn.ip}:${conn.port} (queue size: ${this.listeningQueue.length}/${this.serverBacklog})`);\n      return true;\n    }\n    connect() {\n      if(this.type !== 'client') {\n        this.log('Connect called on non-client socket.');\n        return false;\n      }\n      if(this.state === 'connected') {\n        this.log('Already connected.');\n        return false;\n      }\n      this.state = 'connecting';\n      this.log(`Connecting to ${this.ip}:${this.port}...`);\n      return true;\n    }\n    acceptConnectionOnServer(serverSocket) {\n      // For client socket trying to connect, try to place into server backlog or connect immediately?\n      if(serverSocket.state !== 'listening') return false;\n      return serverSocket.queueConnection(this);\n    }\n    disconnect() {\n      if(this.state !== 'connected' && this.state !== 'connecting') {\n        this.log('Socket not connected.');\n        return false;\n      }\n      this.state = 'disconnected';\n      this.log('Socket disconnected.');\n      return true;\n    }\n    sendMessage(msg, networkSimulator) {\n      if(this.state !== 'connected') {\n        this.log('Cannot send message, socket not connected.');\n        return false;\n      }\n      this.log(`Sending message: ${msg}`);\n      if(this.onReceive) {\n        // Simulate network conditions using networkSimulator\n        networkSimulator.sendWithConditions(this, msg, this.onReceive);\n      }\n      return true;\n    }\n  }\n\n  // Network Simulator manages latency, packet loss, and simulates message delivery between sockets.\n  class NetworkSimulator {\n    constructor() {\n      this.latency = 0;\n      this.packetLossPercent = 0;\n      this.connections = new Set(); // all sockets connected\n    }\n    setLatency(ms) {\n      this.latency = ms;\n    }\n    setPacketLoss(percent) {\n      this.packetLossPercent = percent;\n    }\n    // Simulate sending msg from socket, msg passed to recvCallback after latency if not lost\n    sendWithConditions(sock, msg, recvCallback) {\n      if(Math.random()*100 < this.packetLossPercent) {\n        appendLog(`[Network] Packet lost: \"${msg}\"`);\n        // packet lost silently\n        return;\n      }\n      setTimeout(() => {\n        recvCallback(msg, sock);\n      }, this.latency);\n      appendLog(`[Network] Message scheduled with latency ${this.latency}ms: \"${msg}\"`);\n    }\n  }\n\n  // Global Network Simulator Instance\n  const netSim = new NetworkSimulator();\n\n  // Logging helpers\n  function appendLog(text) {\n    logs.value += text + '\\n';\n    logs.scrollTop = logs.scrollHeight;\n  }\n  function appendReceived(text) {\n    receivedMessages.value += text + '\\n';\n    receivedMessages.scrollTop = receivedMessages.scrollHeight;\n  }\n\n  // UI and socket state\n  let currentSocket = null; // main socket (client or server)\n  let activeAcceptedSockets = []; // for accepted connections on server\n  let connectedClientSocket = null; // for client sockets or accepted connections\n\n  // UI update functions\n  function setSocketState(stateText) {\n    socketStateDiv.textContent = stateText;\n  }\n\n  function enableControlsForState() {\n    // Disable or enable controls based on state & socket type:\n\n    if(!currentSocket || currentSocket.isClosed) {\n      // no socket\n      listenBtn.disabled = true;\n      stopListenBtn.disabled = true;\n      backlogSlider.disabled = true;\n      connectBtn.disabled = true;\n      disconnectBtn.disabled = true;\n      messageInput.disabled = true;\n      sendMsgBtn.disabled = true;\n      closeSocketBtn.disabled = true;\n      createSocketBtn.disabled = false;\n      return;\n    }\n\n    createSocketBtn.disabled = true;\n    closeSocketBtn.disabled = false;\n\n    if(currentSocket.type === 'server') {\n      connectBtn.disabled = true;\n      disconnectBtn.disabled = true;\n      messageInput.disabled = true;\n      sendMsgBtn.disabled = true;\n\n      backlogSlider.disabled = false;\n      backlogSlider.value = currentSocket.serverBacklog;\n      backlogValue.textContent = backlogSlider.value;\n\n      if(currentSocket.state === 'created' || currentSocket.state === 'disconnected') {\n        listenBtn.disabled = false;\n        stopListenBtn.disabled = true;\n      } else if(currentSocket.state === 'listening') {\n        listenBtn.disabled = true;\n        stopListenBtn.disabled = false;\n      } else {\n        listenBtn.disabled = true;\n        stopListenBtn.disabled = true;\n      }\n\n    } else if(currentSocket.type === 'client') {\n      backlogSlider.disabled = true;\n      listenBtn.disabled = true;\n      stopListenBtn.disabled = true;\n\n      if(currentSocket.state === 'created' || currentSocket.state === 'disconnected') {\n        connectBtn.disabled = false;\n        disconnectBtn.disabled = true;\n        messageInput.disabled = true;\n        sendMsgBtn.disabled = true;\n      } else if(currentSocket.state === 'connecting') {\n        connectBtn.disabled = true;\n        disconnectBtn.disabled = false;\n        messageInput.disabled = true;\n        sendMsgBtn.disabled = true;\n      } else if(currentSocket.state === 'connected') {\n        connectBtn.disabled = true;\n        disconnectBtn.disabled = false;\n        messageInput.disabled = false;\n        sendMsgBtn.disabled = false;\n      } else {\n        connectBtn.disabled = true;\n        disconnectBtn.disabled = true;\n        messageInput.disabled = true;\n        sendMsgBtn.disabled = true;\n      }\n    }\n  }\n\n  function updateStateText() {\n    if(!currentSocket) {\n      setSocketState('Socket not created');\n      return;\n    }\n    let s = `Socket (${currentSocket.type} | ${currentSocket.protocol}) at ${currentSocket.ip}:${currentSocket.port} - State: ${currentSocket.state}`;\n    if(currentSocket.type === 'server' && currentSocket.state === 'listening') {\n      s+= ` (Backlog: ${currentSocket.serverBacklog}, queued: ${currentSocket.listeningQueue.length})`;\n    }\n    setSocketState(s);\n  }\n\n  // Event Handlers\n\n  createSocketBtn.addEventListener('click', () => {\n    const ip = ipAddressInput.value.trim();\n    const port = parseInt(portNumberInput.value, 10);\n    const protocol = protocolSelect.value;\n    const type = socketTypeSelect.value;\n\n    if(!ip) {\n      alert('Enter valid IP address.');\n      return;\n    }\n    if(isNaN(port) || port < 1 || port > 65535) {\n      alert('Enter valid port number (1-65535).');\n      return;\n    }\n\n    if(currentSocket && !currentSocket.isClosed) {\n      alert('Close existing socket before creating a new one.');\n      return;\n    }\n\n    currentSocket = new SimSocket(type, protocol, ip, port);\n    receivedMessages.value = '';\n    logs.value = '';\n    appendLog(`Created new ${type.toUpperCase()} socket (${protocol})`);\n    updateStateText();\n    enableControlsForState();\n  });\n\n  closeSocketBtn.addEventListener('click', () => {\n    if(currentSocket) {\n      currentSocket.close();\n      currentSocket = null;\n      activeAcceptedSockets = [];\n      connectedClientSocket = null;\n      updateStateText();\n      enableControlsForState();\n      appendLog('Socket closed and cleared.');\n    }\n  });\n\n  backlogSlider.addEventListener('input', () => {\n    backlogValue.textContent = backlogSlider.value;\n    if(currentSocket && currentSocket.type === 'server') {\n      currentSocket.serverBacklog = parseInt(backlogSlider.value, 10);\n      appendLog(`Backlog changed to ${currentSocket.serverBacklog}`);\n      updateStateText();\n      enableControlsForState();\n    }\n  });\n\n  listenBtn.addEventListener('click', () => {\n    if(!currentSocket) return;\n\n    const backlog = parseInt(backlogSlider.value, 10) || 5;\n    if(currentSocket.listen(backlog)) {\n      appendLog('Server started listening');\n    }\n    updateStateText();\n    enableControlsForState();\n  });\n  stopListenBtn.addEventListener('click', () => {\n    if(!currentSocket) return;\n    if(currentSocket.stopListen()) {\n      appendLog('Server stopped listening');\n    }\n    updateStateText();\n    enableControlsForState();\n  });\n\n  connectBtn.addEventListener('click', () => {\n    if(!currentSocket) return;\n    if(currentSocket.state === 'connected') {\n      appendLog('Already connected.');\n      return;\n    }\n    if(currentSocket.connect()) {\n      appendLog('Client initiating connection...');\n      updateStateText();\n      enableControlsForState();\n\n      // Simulate server presence and connection behavior\n      // Find server socket listening at ip and port on this page if any:\n      // Since this demo simulates one socket only, we simulate connection success/failure depending on current socket type & state.\n\n      // To allow richer exploration: allow user to create a server socket in a separate \"virtual\" space that client can connect to.\n      // But since there's only one main socket, we simulate server presence internally:\n      // We simulate success or failure with latency.\n\n      // Simulate connection attempt with arbitrary delay & success/failure based on \"fake\" server presence for demo purposes:\n      const simulatedServerSocket = window._simulatedServerSocket;\n\n      function finalizeClientConnect(success) {\n        if(success) {\n          currentSocket.state = 'connected';\n          appendLog('Client connected successfully.');\n          messageInput.disabled = false;\n          sendMsgBtn.disabled = false;\n        } else {\n          currentSocket.state = 'disconnected';\n          appendLog('Connection failed or refused.');\n          messageInput.disabled = true;\n          sendMsgBtn.disabled = true;\n        }\n        updateStateText();\n        enableControlsForState();\n      }\n\n      if(simulatedServerSocket && simulatedServerSocket.state === 'listening' &&\n         simulatedServerSocket.ip === currentSocket.ip &&\n         simulatedServerSocket.port === currentSocket.port) {\n        // Try to queue connection on server\n        let accepted = simulatedServerSocket.queueConnection(currentSocket);\n        if(!accepted){\n          setTimeout(() => {\n            finalizeClientConnect(false);\n          }, 1000 + Math.random()*1000);\n          return;\n        }\n        // Accepted connection queued, simulate delay then promote to connected:\n        setTimeout(() => {\n          // server accepts the connection:\n          simulatedServerSocket.accept();\n\n          // client connected\n          finalizeClientConnect(true);\n        }, 500 + Math.random()*1500);\n      } else {\n        // No server found or not listening: fail connection\n        setTimeout(() => {\n          finalizeClientConnect(false);\n        }, 1000 + Math.random()*2000);\n      }\n    }\n  });\n  disconnectBtn.addEventListener('click', () => {\n    if(!currentSocket) return;\n    if(currentSocket.disconnect()) {\n      appendLog('Disconnected.');\n      messageInput.disabled = true;\n      sendMsgBtn.disabled = true;\n      updateStateText();\n      enableControlsForState();\n    }\n  });\n\n  sendMsgBtn.addEventListener('click', () => {\n    if(!currentSocket) return;\n    const msg = messageInput.value.trim();\n    if(!msg) return;\n    // Send message from user current socket through network simulator to the peer\n    // Since this is simulation, we echo message and simulate reply or forward based on type\n\n    if(currentSocket.state !== 'connected') {\n      appendLog('Cannot send message: socket not connected.');\n      return;\n    }\n\n    appendLog(`Sending message: \"${msg}\"`);\n    messageInput.value = '';\n\n    // Message receive handler: when this socket receives message\n    currentSocket.onReceive = (incomingMsg, fromSocket) => {\n      // Show incoming message from peer\n      appendReceived(`From ${fromSocket.type}: ${incomingMsg}`);\n      appendLog(`Received message: \"${incomingMsg}\" from ${fromSocket.type}`);\n    };\n\n    // Simulate message transmission with network conditions:\n    // We simulate a peer socket to receive message and respond\n\n    // Setup simulated peer sockets for the demo:\n\n    if(currentSocket.type === 'client') {\n      // Client sends message to server\n      // The server is the simulatedServerSocket\n      const serverSock = window._simulatedServerSocket;\n\n      if(serverSock && serverSock.state === 'listening' || serverSock.state === 'connected') {\n        // Server will receive message and respond after delay\n        serverSock.onReceive = (msgRecv, fromSock) => {\n          appendLog(`Server received message: \"${msgRecv}\" from client`);\n          // Echo back + append info\n          const response = `Echo from server: \"${msgRecv}\"`;\n          netSim.sendWithConditions(serverSock, response, currentSocket.onReceive);\n        };\n        // Send the message to server socket:\n        netSim.sendWithConditions(currentSocket, msg, serverSock.onReceive);\n      } else {\n        appendLog('No server connected to receive message.');\n      }\n\n    } else if(currentSocket.type === 'server') {\n      // Server message sending: send to all connected clients if any\n      if(currentSocket.acceptedConnections.length === 0) {\n        appendLog('No connected clients to send message to.');\n        return;\n      }\n      currentSocket.acceptedConnections.forEach(clientSock => {\n        if(clientSock.state === 'connected') {\n          clientSock.onReceive = (msgRecv, fromSock) => {\n            appendReceived(`From server: ${msgRecv}`);\n            appendLog(`Client received message: \"${msgRecv}\"`);\n          };\n          netSim.sendWithConditions(currentSocket, msg, clientSock.onReceive);\n        }\n      });\n    }\n  });\n\n  // Simulate a global server socket for interaction with client:\n  // This adds complexity to explore interaction between a server & client on same page.\n  window._simulatedServerSocket = null;\n\n  // When a server socket is created, keep a reference as simulatedServerSocket if type=server\n  // When a client socket created, it attempts connection only if simulatedServerSocket available.\n\n  // Patch createSocketBtn to track server socket globally:\n  createSocketBtn.addEventListener('click', () => {\n    setTimeout(() => {\n      if(currentSocket && currentSocket.type === 'server') {\n        window._simulatedServerSocket = currentSocket;\n        appendLog('Simulated server socket registered globally for client connections.');\n      } else if(currentSocket && currentSocket.type === 'client') {\n        appendLog('Client socket ready to connect to simulated server socket if available.');\n      }\n    }, 1);\n  });\n\n  // Latency and packet loss control handlers\n  latencySlider.addEventListener('input', () => {\n    latencyValue.textContent = latencySlider.value;\n    netSim.setLatency(parseInt(latencySlider.value, 10));\n    appendLog(`Network latency set to ${latencySlider.value} ms`);\n  });\n  packetLossSlider.addEventListener('input', () => {\n    packetLossValue.textContent = packetLossSlider.value;\n    netSim.setPacketLoss(parseInt(packetLossSlider.value, 10));\n    appendLog(`Packet loss set to ${packetLossSlider.value}%`);\n  });\n\n  // Initial UI updates\n  updateStateText();\n  enableControlsForState();\n  latencyValue.textContent = latencySlider.value;\n  packetLossValue.textContent = packetLossSlider.value;\n\n  // Extra explorative capabilities: allow user to accept connections manually on server\n  // New Buttons and controls:\n\n  // Add new UI controls dynamically since problem said single file only:\n\n  const extraControlsDiv = document.createElement('div');\n  extraControlsDiv.style.marginTop = '10px';\n  extraControlsDiv.textContent = 'Server Accepted Connections and Control:';\n\n  // Accept connection button\n  const acceptConBtn = document.createElement('button');\n  acceptConBtn.textContent = 'Accept Next Connection';\n  acceptConBtn.disabled = true;\n  extraControlsDiv.appendChild(acceptConBtn);\n\n  // Connection list select\n  const connectionsSelect = document.createElement('select');\n  connectionsSelect.size = 4;\n  connectionsSelect.style.width = '100%';\n  extraControlsDiv.appendChild(connectionsSelect);\n\n  // Controls to send message and disconnect accepted connection\n  const sendToConnInput = document.createElement('input');\n  sendToConnInput.placeholder = 'Message to selected connection';\n  sendToConnInput.disabled = true;\n  extraControlsDiv.appendChild(sendToConnInput);\n\n  const sendToConnBtn = document.createElement('button');\n  sendToConnBtn.textContent = 'Send to Selected Connection';\n  sendToConnBtn.disabled = true;\n  extraControlsDiv.appendChild(sendToConnBtn);\n\n  const disconnectConnBtn = document.createElement('button');\n  disconnectConnBtn.textContent = 'Disconnect Selected Connection';\n  disconnectConnBtn.disabled = true;\n  extraControlsDiv.appendChild(disconnectConnBtn);\n\n  // Add extra controls after logs fieldset\n  const logsFieldset = logs.parentNode;\n  logsFieldset.parentNode.insertBefore(extraControlsDiv, logsFieldset.nextSibling);\n\n  // Update UI function for accepted connections\n  function refreshAcceptedConnectionsList() {\n    connectionsSelect.innerHTML = '';\n    if(!currentSocket || currentSocket.type !== 'server') {\n      acceptConBtn.disabled = true;\n      sendToConnInput.disabled = true;\n      sendToConnBtn.disabled = true;\n      disconnectConnBtn.disabled = true;\n      return;\n    }\n    acceptConBtn.disabled = (currentSocket.state !== 'listening' || currentSocket.listeningQueue.length === 0);\n\n    currentSocket.acceptedConnections.forEach((conn, idx) => {\n      const option = document.createElement('option');\n      option.value = idx;\n      option.textContent = `[${conn.protocol}] Client ${conn.ip}:${conn.port} - State: ${conn.state}`;\n      connectionsSelect.appendChild(option);\n    });\n\n    const selectedIndex = connectionsSelect.selectedIndex;\n    if(selectedIndex >= 0 && currentSocket.acceptedConnections[selectedIndex]) {\n      const selConn = currentSocket.acceptedConnections[selectedIndex];\n      sendToConnInput.disabled = (selConn.state !== 'connected');\n      sendToConnBtn.disabled = (selConn.state !== 'connected');\n      disconnectConnBtn.disabled = (selConn.state !== 'connected' && selConn.state !== 'connecting');\n    } else {\n      sendToConnInput.disabled = true;\n      sendToConnBtn.disabled = true;\n      disconnectConnBtn.disabled = true;\n    }\n  }\n\n  acceptConBtn.addEventListener('click', () => {\n    if(!currentSocket || currentSocket.type !== 'server') return;\n    const accepted = currentSocket.accept();\n    if(accepted) {\n      appendLog(`Accepted new connection from ${accepted.ip}:${accepted.port}`);\n      // Setup onReceive for accepted connection (simulate client response)\n      accepted.onReceive = (msg, fromSock) => {\n        appendReceived(`From client ${accepted.ip}:${accepted.port}: ${msg}`);\n        appendLog(`Server connection received message from client ${accepted.ip}:${accepted.port}: \"${msg}\"`);\n        // Server echoes back message after delay\n        netSim.sendWithConditions(accepted, `Server echo: \"${msg}\"`, accepted.onReceive);\n      };\n    } else {\n      appendLog('No connections to accept.');\n    }\n    refreshAcceptedConnectionsList();\n  });\n\n  connectionsSelect.addEventListener('change', () => {\n    refreshAcceptedConnectionsList();\n  });\n\n  sendToConnBtn.addEventListener('click', () => {\n    if(!currentSocket || currentSocket.type !== 'server') return;\n    const idx = connectionsSelect.selectedIndex;\n    if(idx < 0) return;\n    const conn = currentSocket.acceptedConnections[idx];\n    if(!conn || conn.state !== 'connected') return;\n    const msg = sendToConnInput.value.trim();\n    if(!msg) return;\n\n    appendLog(`Server sending to client ${conn.ip}:${conn.port}: \"${msg}\"`);\n\n    // Send msg to client connection\n    conn.onReceive = (incomingMsg, fromSock) => {\n      appendLog(`Client ${conn.ip}:${conn.port} received message: \"${incomingMsg}\"`);\n      appendReceived(`To client ${conn.ip}:${conn.port}: ${incomingMsg}`);\n    };\n    netSim.sendWithConditions(currentSocket, msg, conn.onReceive);\n    sendToConnInput.value = '';\n  });\n\n  disconnectConnBtn.addEventListener('click', () => {\n    if(!currentSocket || currentSocket.type !== 'server') return;\n    const idx = connectionsSelect.selectedIndex;\n    if(idx < 0) return;\n    const conn = currentSocket.acceptedConnections[idx];\n    if(!conn) return;\n    conn.state = 'disconnected';\n    appendLog(`Client connection ${conn.ip}:${conn.port} disconnected.`);\n    // Remove from acceptedConnections\n    currentSocket.acceptedConnections.splice(idx,1);\n    refreshAcceptedConnectionsList();\n  });\n\n  // Refresh accepted connection list frequently (for state changes)\n  setInterval(() => {\n    refreshAcceptedConnectionsList();\n  }, 1000);\n\n})();\n</script>\n\n</body>\n</html>"
  },
