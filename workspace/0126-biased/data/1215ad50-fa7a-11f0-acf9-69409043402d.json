  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Semaphore - Interactive Exploration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n    font-family: monospace, monospace;\n  }\n  input[type=number] {\n    width: 4em;\n  }\n  fieldset {\n    margin-top: 1em;\n  }\n  label {\n    display: inline-block;\n    margin-right: 0.5em;\n  }\n  button {\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  #log {\n    width: 100%;\n    height: 12em;\n    overflow-y: auto;\n    white-space: pre-wrap;\n    border: 1px solid #000;\n    margin-top: 1em;\n    padding: 0.25em 0.5em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Semaphore - Interactive Exploration</h1>\n\n<p><strong>Concept:</strong> A semaphore is a synchronization tool used in concurrent programming to control access to a shared resource by multiple processes/threads. It maintains a count representing available \"permits\". Processes wait to acquire permits before proceeding and release permits when done.</p>\n\n<hr/>\n\n<fieldset>\n  <legend>Configure Semaphore</legend>\n  <label>Initial Count (permits): <input type=\"number\" id=\"initialCount\" min=\"0\" max=\"10\" value=\"3\" /></label>\n  <button id=\"createSemaphore\">Create Semaphore</button>\n  <p id=\"semaphoreStatus\">Semaphore not created yet.</p>\n</fieldset>\n\n<fieldset id=\"processControls\" disabled>\n  <legend>Processes Management</legend>\n  <label>Process Name: <input type=\"text\" id=\"procName\" maxlength=\"20\" /></label>\n  <button id=\"createProcess\">Create Process</button>\n  <p><strong>Processes:</strong> <span id=\"processList\">(none)</span></p>\n\n  <label for=\"procSelect\">Select Process:</label>\n  <select id=\"procSelect\" size=\"6\" style=\"width: 20em;\"></select>\n  <br/>\n\n  <button id=\"procWait\">Wait (P)</button>\n  <button id=\"procSignal\">Signal (V)</button>\n  <button id=\"procBlock\">Block Process</button>\n  <button id=\"procUnblock\">Unblock Process</button>\n  <button id=\"procKill\">Kill Process</button>\n</fieldset>\n\n<fieldset id=\"advancedControls\" disabled>\n  <legend>Advanced & Exploration Controls</legend>\n  <button id=\"stepLog\">Step Log (Show last steps)</button>\n  <button id=\"resetAll\">Reset All</button>\n  <label><input type=\"checkbox\" id=\"autoUnblock\" /> Auto-unblock waiting processes when permits released</label>\n  <br/>\n  <label>Throttle (ms delay per operation): <input type=\"number\" id=\"throttle\" min=\"0\" max=\"5000\" step=\"100\" value=\"0\" /></label>\n</fieldset>\n\n<fieldset>\n  <legend>Semaphore State</legend>\n  <p>Current Permits Available: <span id=\"permitsAvailable\">-</span></p>\n  <p>Queue (Waiting Processes): <span id=\"waitingQueue\">empty</span></p>\n</fieldset>\n\n<fieldset>\n  <legend>Log / Trace</legend>\n  <textarea id=\"log\" readonly></textarea>\n</fieldset>\n\n<script>\n(function(){\n  // STATE\n  let semaphore = null;\n  let processes = new Map(); // key: procID, value: process object\n  let processCounter = 0;\n  let stepLog = [];\n  let throttle = 0;\n  let autoUnblock = false;\n\n  // Process states: 'ready', 'waiting', 'blocked', 'terminated'\n  class Process {\n    constructor(name,id){\n      this.name = name;\n      this.id = id;\n      this.state = 'ready';\n      this.waitSemaphoreTime = null;\n    }\n    toString() {\n      return `${this.name} [${this.state}]`;\n    }\n  }\n\n  class Semaphore {\n    constructor(initial){\n      this.count = initial;\n      this.waitingQueue = [];\n    }\n    async wait(proc){\n      if(proc.state === 'terminated') throw new Error(\"Process terminated cannot wait.\");\n      if(proc.state === 'blocked') throw new Error(\"Blocked process cannot wait.\");\n\n      if(this.count > 0){\n        this.count--;\n        log(`Process \"${proc.name}\" acquired a permit. Permits left: ${this.count}`);\n        proc.state = 'ready';\n        return true;\n      } else {\n        proc.state = 'waiting';\n        this.waitingQueue.push(proc);\n        proc.waitSemaphoreTime = Date.now();\n        log(`Process \"${proc.name}\" is waiting (blocked) for a permit. Queue length: ${this.waitingQueue.length}`);\n        updateUI();\n        // Return Promise that resolves when process is unblocked (signal)\n        return new Promise((resolve,reject) => {\n          proc._resolveWait = resolve;\n          proc._rejectWait = reject;\n        });\n      }\n    }\n    signal(proc){\n      if(proc.state === 'terminated') {\n        log(`Process \"${proc.name}\" is terminated, cannot signal.`);\n        return;\n      }\n      if(proc.state === 'waiting'){\n        log(`Process \"${proc.name}\" is waiting and cannot signal until it acquires a permit.`);\n        return;\n      }\n      this.count++;\n      log(`Process \"${proc.name}\" released a permit. Permits available: ${this.count}`);\n      // Unblock waiting process if any\n      if(autoUnblock && this.waitingQueue.length > 0){\n        let nextProc = this.waitingQueue.shift();\n        if(nextProc.state === 'waiting'){\n          nextProc.state = 'ready';\n          log(`Auto-unblocking waiting process \"${nextProc.name}\".`);\n          this.count--;\n          if(nextProc._resolveWait) {\n            nextProc._resolveWait(true);\n            delete nextProc._resolveWait;\n            delete nextProc._rejectWait;\n          }\n          updateUI();\n        }\n      }\n    }\n    unblockProcess(proc){\n      // called to manually unblock a waiting process. Remove from queue and resolve.\n      let idx = this.waitingQueue.indexOf(proc);\n      if(idx !== -1){\n        this.waitingQueue.splice(idx,1);\n        proc.state = 'ready';\n        log(`Process \"${proc.name}\" manually unblocked.`);\n        this.count--;\n        if(proc._resolveWait) {\n          proc._resolveWait(true);\n          delete proc._resolveWait;\n          delete proc._rejectWait;\n        }\n        updateUI();\n        return true;\n      }\n      return false;\n    }\n    removeProcess(proc){\n      // Remove from waiting queue if present\n      let idx = this.waitingQueue.indexOf(proc);\n      if(idx !== -1){\n        this.waitingQueue.splice(idx,1);\n      }\n      // If process was holding a permit before terminating, do not change count here (since we don't track permit ownership)\n      proc.state = 'terminated';\n      // Clear any blocked promises\n      if(proc._resolveWait) {\n        proc._rejectWait && proc._rejectWait(new Error(\"Process terminated during wait.\"));\n        delete proc._resolveWait;\n        delete proc._rejectWait;\n      }\n    }\n  }\n\n  // UI References\n  const initialCountInput = document.getElementById('initialCount');\n  const createSemaphoreBtn = document.getElementById('createSemaphore');\n  const semaphoreStatusP = document.getElementById('semaphoreStatus');\n\n  const processControls = document.getElementById('processControls');\n  const procNameInput = document.getElementById('procName');\n  const createProcessBtn = document.getElementById('createProcess');\n  const processListSpan = document.getElementById('processList');\n  const procSelect = document.getElementById('procSelect');\n  const procWaitBtn = document.getElementById('procWait');\n  const procSignalBtn = document.getElementById('procSignal');\n  const procBlockBtn = document.getElementById('procBlock');\n  const procUnblockBtn = document.getElementById('procUnblock');\n  const procKillBtn = document.getElementById('procKill');\n\n  const permitsAvailableSpan = document.getElementById('permitsAvailable');\n  const waitingQueueSpan = document.getElementById('waitingQueue');\n\n  const logArea = document.getElementById('log');\n  const stepLogBtn = document.getElementById('stepLog');\n  const resetAllBtn = document.getElementById('resetAll');\n  const autoUnblockCb = document.getElementById('autoUnblock');\n  const throttleInput = document.getElementById('throttle');\n\n  // FUNCTIONS\n\n  function log(msg){\n    let time = new Date().toLocaleTimeString();\n    const line = `[${time}] ${msg}`;\n    stepLog.push(line);\n    while(stepLog.length > 1000) stepLog.shift();\n    logArea.value += line + '\\n';\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  function updateSemaphoreStatus(){\n    if(semaphore) {\n      semaphoreStatusP.textContent = `Semaphore created with ${semaphore.count} permit(s) available.`;\n      permitsAvailableSpan.textContent = semaphore.count;\n      let qnames = semaphore.waitingQueue.map(p => p.name).join(', ');\n      waitingQueueSpan.textContent = qnames || 'empty';\n    } else {\n      semaphoreStatusP.textContent = 'Semaphore not created yet.';\n      permitsAvailableSpan.textContent = '-';\n      waitingQueueSpan.textContent = 'empty';\n    }\n  }\n\n  function updateProcessList(){\n    if(processes.size===0){\n      processListSpan.textContent = '(none)';\n      procSelect.innerHTML = '';\n      disableProcessButtons(true);\n      return;\n    }\n    processListSpan.textContent = [...processes.values()].map(p=>`${p.name}[${p.state}]`).join(', ');\n    // Update process select options\n    let oldSelectedId = procSelect.value;\n    procSelect.innerHTML = '';\n    for(let p of processes.values()){\n      let option = document.createElement('option');\n      option.value = p.id;\n      option.textContent = `${p.name} [${p.state}]`;\n      procSelect.appendChild(option);\n    }\n    if([...procSelect.options].some(o=>o.value===oldSelectedId)){\n      procSelect.value = oldSelectedId;\n    }\n    updateProcessButtonsDisabledState();\n  }\n  function disableProcessButtons(disabled){\n    procWaitBtn.disabled = disabled;\n    procSignalBtn.disabled = disabled;\n    procBlockBtn.disabled = disabled;\n    procUnblockBtn.disabled = disabled;\n    procKillBtn.disabled = disabled;\n  }\n\n  function updateProcessButtonsDisabledState(){\n    let proc = getSelectedProcess();\n    if(!proc){\n      disableProcessButtons(true);\n      return;\n    }\n    disableProcessButtons(false);\n    // Disable wait if process terminated or blocked\n    if(proc.state === 'terminated' || proc.state === 'blocked'){\n      procWaitBtn.disabled = true;\n      procSignalBtn.disabled = true;\n    } else if(proc.state === 'waiting') {\n      procWaitBtn.disabled = true;\n      procSignalBtn.disabled = false;\n    } else if(proc.state === 'ready'){\n      procWaitBtn.disabled = false;\n      procSignalBtn.disabled = false;\n    }\n    // Disable block if terminated or waiting\n    procBlockBtn.disabled = (proc.state === 'terminated' || proc.state === 'waiting' || proc.state === 'blocked');\n    // Disable unblock if not blocked\n    procUnblockBtn.disabled = proc.state !== 'blocked';\n    // Disable kill if terminated\n    procKillBtn.disabled = proc.state === 'terminated';\n  }\n\n  function getSelectedProcess(){\n    let val = procSelect.value;\n    if(!val) return null;\n    return processes.get(val) || null;\n  }\n\n  function delay(ms){\n    return new Promise(res=>setTimeout(res, ms));\n  }\n\n  async function doWait(proc){\n    if(!semaphore) {\n      log(`Semaphore not created. Cannot wait.`);\n      return;\n    }\n    if(proc.state === 'terminated') {\n      log(`Process \"${proc.name}\" already terminated - cannot wait.`);\n      return;\n    }\n    if(proc.state === 'blocked') {\n      log(`Process \"${proc.name}\" is blocked - cannot wait.`);\n      return;\n    }\n    log(`Process \"${proc.name}\" attempts WAIT (P) operation...`);\n    if (throttle > 0) await delay(throttle);\n\n    try {\n      let res = await semaphore.wait(proc);\n      if(res === true){\n        log(`Process \"${proc.name}\" successfully acquired a permit.`);\n      }\n    } catch(e) {\n      log(`Process \"${proc.name}\" wait error: ${e.message}`);\n    }\n    updateUI();\n  }\n\n  function doSignal(proc){\n    if(!semaphore) {\n      log(`Semaphore not created. Cannot signal.`);\n      return;\n    }\n    if(proc.state === 'terminated'){\n      log(`Process \"${proc.name}\" already terminated - cannot signal.`);\n      return;\n    }\n    if(throttle > 0) {\n      delay(throttle).then(() => {\n        semaphore.signal(proc);\n        updateUI();\n      });\n    } else {\n      semaphore.signal(proc);\n      updateUI();\n    }\n  }\n\n  function doBlockProcess(proc){\n    if(proc.state === 'terminated'){\n      log(`Process \"${proc.name}\" is terminated, cannot block.`);\n      return;\n    }\n    if(proc.state === 'waiting'){\n      log(`Process \"${proc.name}\" is currently waiting on semaphore - cannot block.`);\n      return;\n    }\n    if(proc.state === 'blocked'){\n      log(`Process \"${proc.name}\" is already blocked.`);\n      return;\n    }\n    proc.state = 'blocked';\n    log(`Process \"${proc.name}\" has been BLOCKED.`);\n    updateUI();\n  }\n\n  function doUnblockProcess(proc){\n    if(proc.state !== 'blocked'){\n      log(`Process \"${proc.name}\" is not blocked - cannot unblock.`);\n      return;\n    }\n    proc.state = 'ready';\n    log(`Process \"${proc.name}\" has been UNBLOCKED.`);\n    updateUI();\n  }\n\n  function doKillProcess(proc){\n    if(proc.state === 'terminated'){\n      log(`Process \"${proc.name}\" is already terminated.`);\n      return;\n    }\n    semaphore && semaphore.removeProcess(proc);\n    processes.delete(proc.id);\n    log(`Process \"${proc.name}\" has been KILLED (terminated).`);\n    updateUI();\n  }\n\n  function updateUI(){\n    updateSemaphoreStatus();\n    updateProcessList();\n  }\n\n  // EVENT LISTENERS\n  createSemaphoreBtn.addEventListener('click', ()=>{\n    const val = Number(initialCountInput.value);\n    if(isNaN(val) || val <0 || val >10){\n      alert('Initial count must be between 0 and 10');\n      return;\n    }\n    semaphore = new Semaphore(val);\n    log(`Semaphore created with initial count ${val}.`);\n    processControls.disabled = false;\n    advancedControls.disabled = false;\n    updateUI();\n  });\n\n  createProcessBtn.addEventListener('click', ()=>{\n    if(!semaphore){\n      alert('Create a semaphore first.');\n      return;\n    }\n    const name = procNameInput.value.trim();\n    if(name.length === 0){\n      alert('Process name cannot be empty.');\n      return;\n    }\n    // Prevent duplicate process names:\n    for(let p of processes.values()){\n      if(p.name === name && p.state !== 'terminated'){\n        alert('Process with this name already exists.');\n        return;\n      }\n    }\n    processCounter++;\n    let p = new Process(name, 'proc' + processCounter);\n    processes.set(p.id, p);\n    log(`Created process \"${p.name}\".`);\n    updateUI();\n    procNameInput.value = '';\n  });\n\n  procWaitBtn.addEventListener('click', ()=>{\n    let proc = getSelectedProcess();\n    if(!proc) {\n      alert('Select a process first.');\n      return;\n    }\n    doWait(proc);\n  });\n\n  procSignalBtn.addEventListener('click', ()=>{\n    let proc = getSelectedProcess();\n    if(!proc) {\n      alert('Select a process first.');\n      return;\n    }\n    doSignal(proc);\n  });\n\n  procBlockBtn.addEventListener('click', ()=>{\n    let proc = getSelectedProcess();\n    if(!proc){\n      alert('Select a process first.');\n      return;\n    }\n    doBlockProcess(proc);\n  });\n\n  procUnblockBtn.addEventListener('click', ()=>{\n    let proc = getSelectedProcess();\n    if(!proc){\n      alert('Select a process first.');\n      return;\n    }\n    doUnblockProcess(proc);\n  });\n\n  procKillBtn.addEventListener('click', ()=>{\n    let proc = getSelectedProcess();\n    if(!proc){\n      alert('Select a process first.');\n      return;\n    }\n    if(!confirm(`Are you sure you want to kill process \"${proc.name}\"? This cannot be undone.`)){\n      return;\n    }\n    doKillProcess(proc);\n  });\n\n  procSelect.addEventListener('change', ()=>{\n    updateProcessButtonsDisabledState();\n  });\n\n  stepLogBtn.addEventListener('click', ()=>{\n    alert(stepLog.slice(-20).join('\\n'));\n  });\n\n  resetAllBtn.addEventListener('click', ()=>{\n    if(!confirm('Reset everything including semaphore and all processes?')){\n      return;\n    }\n    semaphore = null;\n    processes.clear();\n    processCounter = 0;\n    stepLog.length=0;\n    logArea.value = '';\n    processControls.disabled = true;\n    advancedControls.disabled = true;\n    updateUI();\n  });\n\n  autoUnblockCb.addEventListener('change', ()=>{\n    autoUnblock = autoUnblockCb.checked;\n    log(`Auto-unblock waiting processes when permits released: ${autoUnblock ? 'Enabled' : 'Disabled'}`);\n  });\n\n  throttleInput.addEventListener('change', ()=>{\n    throttle = Number(throttleInput.value);\n    if(isNaN(throttle) || throttle < 0) throttle = 0;\n    log(`Throttle delay per operation set to ${throttle} ms.`);\n  });\n\n  // Initialize UI as disabled\n  processControls.disabled = true;\n  const advancedControls = document.getElementById('advancedControls');\n  advancedControls.disabled = true;\n  updateUI();\n\n  // Insert initial instructions log\n  log('Welcome! Configure semaphore and create processes to explore the WAIT (P) and SIGNAL (V) operations. You can also block/unblock processes and kill them. Use auto-unblock feature to see automatic permit granting to waiting processes.');\n})();\n</script>\n\n</body>\n</html>"
  },
