  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Dynamic Array Explorer</title>\n<style>\n/* Minimal visual design: plain black text on white background, very basic layout */\nbody { font-family: monospace; color: black; background: white; margin: 12px; }\nbutton,input,select,textarea { font-family: monospace; margin: 2px; }\nfieldset { margin: 6px 0; padding: 6px; }\nlabel { margin-right: 6px; }\n.array-row { white-space: pre; font-family: monospace; }\n.small { font-size: 12px; }\n.controls { display: block; }\n.step-controls { margin-top: 6px; }\n.log { white-space: pre-wrap; max-height: 240px; overflow: auto; border: 1px solid #ddd; padding: 6px; }\n.slot { display: inline-block; min-width: 36px; text-align: center; padding: 2px; border: 1px solid #eee; margin-right: 2px; }\n.slot-index { display: inline-block; min-width: 36px; text-align: center; padding: 0 2px; margin-right: 2px; }\n.simple-list { list-style: none; padding-left: 0; margin: 0; font-size: 13px; }\n.note { font-size: 12px; margin-top: 6px; }\n</style>\n</head>\n<body>\n<h1>Dynamic Array Explorer</h1>\n<p class=\"small\">Interactive demonstration of a dynamic array (resizable array). Use the controls below to perform operations, step through internal changes (reallocations, copies, shifts) and explore behavior. The interface is intentionally minimal.</p>\n\n<fieldset>\n  <legend>Configuration / Create</legend>\n  <label>Initial capacity: <input id=\"initCapacity\" type=\"number\" value=\"4\" min=\"0\" style=\"width:60px\"></label>\n  <label>Growth factor: \n    <select id=\"growthFactor\">\n      <option value=\"2\">2</option>\n      <option value=\"1.5\">1.5</option>\n      <option value=\"1.25\">1.25</option>\n      <option value=\"1\">1 (no auto-grow)</option>\n    </select>\n  </label>\n  <button id=\"btnCreate\">Create new DynamicArray</button>\n  <label class=\"small\">Mode:\n    <select id=\"mode\">\n      <option value=\"normal\">Normal (auto-ensure capacity)</option>\n      <option value=\"manual\">Manual capacity (only change by reserve/resize)</option>\n    </select>\n  </label>\n  <div class=\"note\">After create you may reserve capacity, change growth factor, or operate on the array.</div>\n</fieldset>\n\n<fieldset>\n  <legend>Current Array State</legend>\n  <div>Length: <span id=\"displayLength\">0</span> &nbsp; Capacity: <span id=\"displayCapacity\">0</span> &nbsp; Growth: <span id=\"displayGrowth\">2</span></div>\n  <div id=\"arrayView\" class=\"array-row\"></div>\n  <div id=\"bufferView\" class=\"array-row\"></div>\n  <div class=\"note\">Slots show index and value. Empty slots shown as _ . Highlight markers like [&gt;value&lt;] indicate the active index for current step.</div>\n</fieldset>\n\n<fieldset>\n  <legend>Basic Operations</legend>\n  <label>Value: <input id=\"valueInput\" type=\"text\" value=\"X\" style=\"width:80px\"></label>\n  <label>Index: <input id=\"indexInput\" type=\"number\" value=\"0\" style=\"width:60px\"></label>\n  <label>Count: <input id=\"countInput\" type=\"number\" value=\"1\" style=\"width:60px\"></label>\n  <br>\n  <button id=\"btnPush\">push(value)</button>\n  <button id=\"btnPop\">pop()</button>\n  <button id=\"btnInsert\">insertAt(index, value)</button>\n  <button id=\"btnRemove\">removeAt(index)</button>\n  <button id=\"btnSet\">set(index, value)</button>\n  <button id=\"btnGet\">get(index)</button>\n  <button id=\"btnUnshift\">unshift(value)</button>\n  <button id=\"btnShift\">shift()</button>\n  <button id=\"btnPushMany\">pushMany(count, random?)</button>\n  <button id=\"btnClear\">clear()</button>\n</fieldset>\n\n<fieldset>\n  <legend>Capacity & Resizing</legend>\n  <label>Reserve capacity: <input id=\"reserveInput\" type=\"number\" value=\"8\" style=\"width:80px\"></label>\n  <button id=\"btnReserve\">reserve()</button>\n  <label>Shrink to fit: <button id=\"btnShrink\">shrink_to_fit()</button></label>\n  <label>Resize length to: <input id=\"resizeInput\" type=\"number\" value=\"0\" style=\"width:80px\"></label>\n  <button id=\"btnResize\">resize()</button>\n  <label>Manual set capacity: <input id=\"manualCapacity\" type=\"number\" value=\"0\" style=\"width:80px\"></label>\n  <button id=\"btnSetCapacity\">set capacity (danger)</button>\n</fieldset>\n\n<fieldset>\n  <legend>Higher-level Operations (map/filter/slice/splice/sort)</legend>\n  <div>\n    <label>Expression (use x,i,arr): <input id=\"exprInput\" type=\"text\" value=\"x\" style=\"width:360px\"></label>\n    <button id=\"btnMap\">map(expr)</button>\n    <button id=\"btnFilter\">filter(predicate)</button>\n  </div>\n  <div style=\"margin-top:4px\">\n    <label>Slice start: <input id=\"sliceStart\" type=\"number\" value=\"0\" style=\"width:60px\"></label>\n    <label>end: <input id=\"sliceEnd\" type=\"number\" value=\"0\" style=\"width:60px\"></label>\n    <button id=\"btnSlice\">slice(start,end)</button>\n  </div>\n  <div style=\"margin-top:4px\">\n    <label>Splice index: <input id=\"spliceIndex\" type=\"number\" value=\"0\" style=\"width:60px\"></label>\n    <label>deleteCount: <input id=\"spliceDel\" type=\"number\" value=\"1\" style=\"width:60px\"></label>\n    <label>items (comma): <input id=\"spliceItems\" type=\"text\" value=\"\" style=\"width:200px\"></label>\n    <button id=\"btnSplice\">splice()</button>\n  </div>\n  <div style=\"margin-top:4px\">\n    <button id=\"btnReverse\">reverse()</button>\n    <button id=\"btnSort\">sort()</button>\n    <label>Sort method:\n      <select id=\"sortMethod\">\n        <option value=\"native\">native</option>\n        <option value=\"bubble\">bubble (step-by-step)</option>\n      </select>\n    </label>\n    <label>Compare expr (a,b): <input id=\"compareExpr\" type=\"text\" value=\"(a>b?1:(a<b?-1:0))\" style=\"width:260px\"></label>\n  </div>\n  <div style=\"margin-top:4px\">\n    <label>Rotate by (steps, + right): <input id=\"rotateCount\" type=\"number\" value=\"1\" style=\"width:60px\"></label>\n    <button id=\"btnRotate\">rotate()</button>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Step-through Visualization</legend>\n  <div class=\"step-controls\">\n    <button id=\"btnPrev\">Prev Step</button>\n    <button id=\"btnNext\">Next Step</button>\n    <button id=\"btnPlay\">Play</button>\n    <button id=\"btnPause\">Pause</button>\n    Speed(ms): <input id=\"playSpeed\" type=\"number\" value=\"500\" style=\"width:80px\"> (ms per step)\n  </div>\n  <div>Current step: <span id=\"stepIndex\">0</span> / <span id=\"stepTotal\">0</span></div>\n  <div class=\"note\">Each operation generates an ordered list of internal states. Use Prev/Next to inspect individual internal steps (allocations, copies, moves).</div>\n</fieldset>\n\n<fieldset>\n  <legend>History / Snapshots / Undo</legend>\n  <div>\n    <button id=\"btnSnapshot\">Save Snapshot</button>\n    <button id=\"btnListSnapshots\">List Snapshots</button>\n    <button id=\"btnUndo\">Undo</button>\n    <button id=\"btnRedo\">Redo</button>\n    <button id=\"btnResetHistory\">Clear History</button>\n  </div>\n  <div id=\"snapshotList\" class=\"small\"></div>\n  <div id=\"historyList\" class=\"small\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>Bench / Randomized Tests</legend>\n  <label>Ops: <input id=\"benchOps\" type=\"number\" value=\"10000\" style=\"width:80px\"></label>\n  <label>Max value text: <input id=\"benchMaxVal\" type=\"text\" value=\"VAL\" style=\"width:80px\"></label>\n  <button id=\"btnBench\">Run benchmark (random ops)</button>\n  <div id=\"benchResult\" class=\"small\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>Logs & Step Details</legend>\n  <div id=\"log\" class=\"log\"></div>\n</fieldset>\n\n<script>\n/*\nDynamic Array Explorer\n- Core model: DynamicArray that stores internal buffer, capacity and length\n- All operations generate an array of \"steps\" (snapshots) describing intermediate states for step-through visualization.\n- Steps are minimal representations: { buffer: [...], length, capacity, message, highlight }\n- No fancy styling; highlights shown textually with markers.\n*/\n\n(function(){\n  // Utilities\n  function cloneBuffer(buf) { return buf.slice(); }\n  function pad(s, n) { return (''+s).padEnd(n,' '); }\n\n  // Step structure: {buffer, length, capacity, message, highlight}\n  function makeStep(buffer, length, capacity, message, highlight) {\n    return { buffer: cloneBuffer(buffer), length: length, capacity: capacity, message: message || '', highlight: highlight || null };\n  }\n\n  // DynamicArray class with step-producing operations\n  function DynamicArray(initCapacity, growthFactor, mode) {\n    this.capacity = Math.max(0, Math.floor(initCapacity) || 0);\n    if (this.capacity === 0) this.capacity = 0;\n    this.buffer = new Array(this.capacity);\n    this.length = 0;\n    this.growthFactor = Number(growthFactor) || 2;\n    this.mode = mode || 'normal'; // 'normal' or 'manual'\n  }\n\n  DynamicArray.prototype.stateSnapshot = function(message, highlight) {\n    return makeStep(this.buffer, this.length, this.capacity, message, highlight);\n  };\n\n  DynamicArray.prototype._allocate = function(newCap) {\n    var steps = [];\n    if (newCap <= this.capacity) return steps;\n    var newBuff = new Array(newCap);\n    steps.push(makeStep(this.buffer, this.length, this.capacity, 'allocate new buffer of capacity ' + newCap, {type:'allocate', newCapacity:newCap}));\n    // copy elements one by one\n    for (var i=0;i<this.length;i++){\n      newBuff[i] = this.buffer[i];\n      steps.push(makeStep(mergeCopy(newBuff, newCap), this.length, newCap,\n        'copy element at index '+i+' ('+String(this.buffer[i])+') to new buffer index '+i,\n        {type:'copy', from:i, to:i, value:this.buffer[i]}));\n    }\n    // replace buffer\n    this.buffer = newBuff;\n    this.capacity = newCap;\n    steps.push(this.stateSnapshot('replace internal buffer; capacity now '+this.capacity));\n    return steps;\n  };\n\n  // Helpers to build a buffer snapshot for steps during allocation (without altering this.buffer until finish)\n  function mergeCopy(tempBuff, cap) {\n    var arr = new Array(cap);\n    for (var j=0;j<cap;j++) arr[j] = tempBuff[j];\n    return arr;\n  }\n\n  DynamicArray.prototype.ensureCapacitySteps = function(minNeeded) {\n    var steps = [];\n    if (this.mode === 'manual') {\n      if (minNeeded > this.capacity) {\n        steps.push(this.stateSnapshot('manual mode: capacity too small; operation will throw or be truncated'));\n        return steps;\n      }\n      return steps;\n    }\n    if (minNeeded <= this.capacity) return steps;\n    // compute new capacity using growthFactor until >= minNeeded\n    var newCap = Math.max(1, this.capacity || 1);\n    while (newCap < minNeeded) {\n      newCap = Math.floor(newCap * this.growthFactor) || (newCap+1);\n      if (newCap <= this.capacity) newCap = this.capacity + 1; // ensure progress\n    }\n    // allocate and copy producing steps\n    steps = steps.concat(this._allocate(newCap));\n    return steps;\n  };\n\n  DynamicArray.prototype.pushSteps = function(value) {\n    var steps = [];\n    steps.push(this.stateSnapshot('push: prepare to push '+String(value)));\n    var need = this.length + 1;\n    steps = steps.concat(this.ensureCapacitySteps(need));\n    // set value\n    this.buffer[this.length] = value;\n    steps.push(this.stateSnapshot('set index '+this.length+' = '+String(value), {type:'set', index:this.length, value:value}));\n    this.length++;\n    steps.push(this.stateSnapshot('length incremented to '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.popSteps = function() {\n    var steps = [];\n    if (this.length === 0) {\n      steps.push(this.stateSnapshot('pop: array empty -> undefined'));\n      return steps;\n    }\n    var idx = this.length-1;\n    var val = this.buffer[idx];\n    this.buffer[idx] = undefined;\n    steps.push(this.stateSnapshot('pop: removed value at index '+idx+' ('+String(val)+')', {type:'remove', index:idx, value:val}));\n    this.length--;\n    steps.push(this.stateSnapshot('length decremented to '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.insertAtSteps = function(index, value) {\n    var steps = [];\n    index = Math.max(0, Math.min(index, this.length));\n    steps.push(this.stateSnapshot('insertAt: prepare to insert '+String(value)+' at index '+index));\n    steps = steps.concat(this.ensureCapacitySteps(this.length+1));\n    // shift elements to the right one by one from end to index\n    for (var i=this.length; i>index; i--) {\n      this.buffer[i] = this.buffer[i-1];\n      steps.push(this.stateSnapshot('shift element from '+(i-1)+' -> '+i, {type:'move', from:i-1, to:i, value:this.buffer[i]}));\n    }\n    this.buffer[index] = value;\n    steps.push(this.stateSnapshot('set index '+index+' = '+String(value), {type:'set', index:index, value:value}));\n    this.length++;\n    steps.push(this.stateSnapshot('length incremented to '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.removeAtSteps = function(index) {\n    var steps = [];\n    if (this.length === 0) {\n      steps.push(this.stateSnapshot('removeAt: empty array'));\n      return steps;\n    }\n    index = Math.max(0, Math.min(index, this.length-1));\n    var val = this.buffer[index];\n    steps.push(this.stateSnapshot('removeAt: remove value at index '+index+' ('+String(val)+')', {type:'remove', index:index, value:val}));\n    // shift left\n    for (var i=index;i<this.length-1;i++){\n      this.buffer[i] = this.buffer[i+1];\n      steps.push(this.stateSnapshot('shift element from '+(i+1)+' -> '+i, {type:'move', from:i+1, to:i, value:this.buffer[i]}));\n    }\n    this.buffer[this.length-1] = undefined;\n    this.length--;\n    steps.push(this.stateSnapshot('length decremented to '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.setAtSteps = function(index, value) {\n    var steps = [];\n    index = Math.max(0, index);\n    if (index >= this.length) {\n      // if setting beyond length, either extend with undefined or error depending on mode; we'll extend if normal\n      if (this.mode === 'manual') {\n        steps.push(this.stateSnapshot('manual mode: cannot set beyond length without resize'));\n        return steps;\n      }\n      // need to grow length up to index+1\n      steps.push(this.stateSnapshot('set: need to extend length to index '+index));\n      steps = steps.concat(this.ensureCapacitySteps(index+1));\n      for (var j=this.length;j<index;j++){\n        this.buffer[j] = undefined;\n        steps.push(this.stateSnapshot('initialize index '+j+' = undefined', {type:'init', index:j}));\n      }\n      this.length = index+1;\n    }\n    this.buffer[index] = value;\n    steps.push(this.stateSnapshot('set index '+index+' = '+String(value), {type:'set', index:index, value:value}));\n    return steps;\n  };\n\n  DynamicArray.prototype.unshiftSteps = function(value) {\n    var steps = [];\n    steps.push(this.stateSnapshot('unshift: insert at start value '+String(value)));\n    steps = steps.concat(this.ensureCapacitySteps(this.length+1));\n    for (var i=this.length;i>0;i--){\n      this.buffer[i] = this.buffer[i-1];\n      steps.push(this.stateSnapshot('shift element '+(i-1)+' -> '+i, {type:'move', from:i-1, to:i, value:this.buffer[i]}));\n    }\n    this.buffer[0] = value;\n    steps.push(this.stateSnapshot('set index 0 = '+String(value), {type:'set', index:0, value:value}));\n    this.length++;\n    steps.push(this.stateSnapshot('length incremented to '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.shiftSteps = function() {\n    var steps = [];\n    if (this.length===0) {\n      steps.push(this.stateSnapshot('shift: empty array'));\n      return steps;\n    }\n    var val = this.buffer[0];\n    steps.push(this.stateSnapshot('shift: remove index 0 ('+String(val)+')', {type:'remove', index:0, value:val}));\n    for (var i=0;i<this.length-1;i++){\n      this.buffer[i] = this.buffer[i+1];\n      steps.push(this.stateSnapshot('shift element '+(i+1)+' -> '+i, {type:'move', from:i+1, to:i, value:this.buffer[i]}));\n    }\n    this.buffer[this.length-1] = undefined;\n    this.length--;\n    steps.push(this.stateSnapshot('length decremented to '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.clearSteps = function() {\n    var steps = [];\n    for (var i=0;i<this.length;i++){\n      this.buffer[i] = undefined;\n      steps.push(this.stateSnapshot('clear index '+i, {type:'clear', index:i}));\n    }\n    this.length = 0;\n    steps.push(this.stateSnapshot('clear done; length=0'));\n    return steps;\n  };\n\n  DynamicArray.prototype.reserveSteps = function(newCap) {\n    var steps = [];\n    newCap = Math.max(0, Math.floor(newCap));\n    if (newCap <= this.capacity) {\n      steps.push(this.stateSnapshot('reserve: current capacity '+this.capacity+' >= '+newCap+' -> no-op'));\n      return steps;\n    }\n    steps = steps.concat(this._allocate(newCap));\n    return steps;\n  };\n\n  DynamicArray.prototype.shrinkToFitSteps = function() {\n    var steps = [];\n    if (this.length >= this.capacity) {\n      steps.push(this.stateSnapshot('shrink_to_fit: no-op; capacity == length'));\n      return steps;\n    }\n    var newCap = this.length;\n    var newBuff = new Array(newCap);\n    steps.push(makeStep(this.buffer, this.length, this.capacity, 'shrink_to_fit: allocate new buffer of capacity '+newCap, {type:'allocate', newCapacity:newCap}));\n    for (var i=0;i<this.length;i++){\n      newBuff[i] = this.buffer[i];\n      steps.push(makeStep(mergeCopy(newBuff,newCap), this.length, newCap, 'copy element '+i+' ('+String(this.buffer[i])+')', {type:'copy', from:i, to:i, value:this.buffer[i]}));\n    }\n    this.buffer = newBuff;\n    this.capacity = newCap;\n    steps.push(this.stateSnapshot('shrink_to_fit done; capacity now '+this.capacity));\n    return steps;\n  };\n\n  DynamicArray.prototype.resizeSteps = function(newLen) {\n    var steps = [];\n    newLen = Math.max(0, Math.floor(newLen));\n    steps.push(this.stateSnapshot('resize: request new length '+newLen));\n    if (newLen > this.length) {\n      steps = steps.concat(this.ensureCapacitySteps(newLen));\n      for (var i=this.length;i<newLen;i++){\n        this.buffer[i] = undefined;\n        steps.push(this.stateSnapshot('initialize index '+i+' = undefined', {type:'init', index:i}));\n      }\n    } else {\n      for (var j=newLen;j<this.length;j++){\n        this.buffer[j] = undefined;\n        steps.push(this.stateSnapshot('clear index '+j, {type:'clear', index:j}));\n      }\n    }\n    this.length = newLen;\n    steps.push(this.stateSnapshot('resize done; length now '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.setCapacitySteps = function(newCap) {\n    var steps = [];\n    newCap = Math.max(0, Math.floor(newCap));\n    if (newCap === this.capacity) {\n      steps.push(this.stateSnapshot('set capacity: no change'));\n      return steps;\n    }\n    if (newCap < this.length) {\n      steps.push(this.stateSnapshot('set capacity: new capacity '+newCap+' less than length '+this.length+' -> truncate'));\n      for (var i=newCap;i<this.length;i++){\n        this.buffer[i] = undefined;\n        steps.push(this.stateSnapshot('truncate clear index '+i, {type:'clear', index:i}));\n      }\n      this.length = newCap;\n    }\n    var newBuff = new Array(newCap);\n    steps.push(makeStep(this.buffer, this.length, this.capacity, 'set capacity: allocate new buffer of size '+newCap, {type:'allocate', newCapacity:newCap}));\n    for (var k=0;k<Math.min(this.length,newCap);k++){\n      newBuff[k] = this.buffer[k];\n      steps.push(makeStep(mergeCopy(newBuff,newCap), this.length, newCap, 'copy element '+k+' ('+String(this.buffer[k])+')', {type:'copy', from:k, to:k}));\n    }\n    this.buffer = newBuff;\n    this.capacity = newCap;\n    steps.push(this.stateSnapshot('set capacity done; capacity now '+this.capacity));\n    return steps;\n  };\n\n  DynamicArray.prototype.mapSteps = function(expr) {\n    var steps = [];\n    steps.push(this.stateSnapshot('map: creating mapped array using expression: '+expr));\n    var fn;\n    try {\n      fn = new Function('x','i','arr','return ('+expr+')');\n    } catch (e) {\n      steps.push(this.stateSnapshot('map: invalid expression -> abort'));\n      return steps;\n    }\n    var newArr = new DynamicArray(this.length, this.growthFactor, this.mode);\n    for (var i=0;i<this.length;i++){\n      var out;\n      try { out = fn(this.buffer[i], i, this.buffer); } catch(e) { out = undefined; }\n      var s = newArr.pushSteps(out);\n      steps = steps.concat(s);\n      steps.push(makeStep(newArr.buffer, newArr.length, newArr.capacity, 'map: produced element '+i+' = '+String(out), {type:'set', index:i, value:out}));\n    }\n    steps.push(makeStep(newArr.buffer, newArr.length, newArr.capacity, 'map: finished; new array created (not replacing original)'));\n    return steps;\n  };\n\n  DynamicArray.prototype.filterSteps = function(expr) {\n    var steps = [];\n    steps.push(this.stateSnapshot('filter: predicate = '+expr));\n    var fn;\n    try {\n      fn = new Function('x','i','arr','return ('+expr+')');\n    } catch (e) {\n      steps.push(this.stateSnapshot('filter: invalid predicate -> abort'));\n      return steps;\n    }\n    var outArr = new DynamicArray(this.length, this.growthFactor, this.mode);\n    for (var i=0;i<this.length;i++){\n      var keep = false;\n      try { keep = !!fn(this.buffer[i], i, this.buffer); } catch(e) { keep = false; }\n      steps.push(this.stateSnapshot('predicate for index '+i+' value '+String(this.buffer[i])+' -> '+keep, {type:'compare', index:i}));\n      if (keep) {\n        steps = steps.concat(outArr.pushSteps(this.buffer[i]));\n      }\n    }\n    steps.push(makeStep(outArr.buffer, outArr.length, outArr.capacity, 'filter: finished; result array created'));\n    return steps;\n  };\n\n  DynamicArray.prototype.sliceSteps = function(start, end) {\n    var steps = [];\n    start = start || 0;\n    if (start < 0) start = Math.max(0, this.length + start);\n    if (typeof end === 'undefined') end = this.length;\n    if (end < 0) end = Math.max(0, this.length + end);\n    start = Math.min(this.length, Math.max(0, start));\n    end = Math.min(this.length, Math.max(0, end));\n    steps.push(this.stateSnapshot('slice: start='+start+' end='+end));\n    var out = new DynamicArray(end-start, this.growthFactor, this.mode);\n    for (var i=start;i<end;i++){\n      steps = steps.concat(out.pushSteps(this.buffer[i]));\n    }\n    steps.push(makeStep(out.buffer, out.length, out.capacity, 'slice done; new array created'));\n    return steps;\n  };\n\n  DynamicArray.prototype.spliceSteps = function(index, deleteCount, items) {\n    var steps = [];\n    index = Math.max(0, Math.min(this.length, index));\n    deleteCount = Math.max(0, Math.min(this.length-index, deleteCount || 0));\n    steps.push(this.stateSnapshot('splice: index '+index+' deleteCount '+deleteCount+' insert '+JSON.stringify(items)));\n    // remove deleteCount items\n    var removed = [];\n    for (var i=0;i<deleteCount;i++){\n      removed.push(this.buffer[index+i]);\n    }\n    // copy items after deleted area into temporary\n    var tail = [];\n    for (var j=index+deleteCount;j<this.length;j++) tail.push(this.buffer[j]);\n    // write inserted items starting at index\n    var need = this.length - deleteCount + items.length;\n    steps = steps.concat(this.ensureCapacitySteps(need));\n    // put items\n    for (var k=0;k<items.length;k++){\n      this.buffer[index+k] = items[k];\n      steps.push(this.stateSnapshot('insert item at '+(index+k)+' = '+String(items[k]), {type:'set', index:index+k, value:items[k]}));\n    }\n    // put tail after inserted\n    for (var t=0;t<tail.length;t++){\n      this.buffer[index+items.length+t] = tail[t];\n      steps.push(this.stateSnapshot('move tail element to '+(index+items.length+t), {type:'move', from:index+deleteCount+t, to:index+items.length+t, value:tail[t]}));\n    }\n    // clear leftover if any\n    var newLen = index + items.length + tail.length;\n    for (var c=newLen;c<this.length;c++){\n      this.buffer[c] = undefined;\n      steps.push(this.stateSnapshot('clear index '+c, {type:'clear', index:c}));\n    }\n    var oldLen = this.length;\n    this.length = newLen;\n    steps.push(this.stateSnapshot('splice done; removed '+removed.length+' items, length from '+oldLen+' -> '+this.length));\n    return steps;\n  };\n\n  DynamicArray.prototype.reverseSteps = function() {\n    var steps = [];\n    steps.push(this.stateSnapshot('reverse: start'));\n    var i=0, j=this.length-1;\n    while (i<j) {\n      var tmp = this.buffer[i];\n      this.buffer[i] = this.buffer[j];\n      this.buffer[j] = tmp;\n      steps.push(this.stateSnapshot('swap '+i+' <-> '+j, {type:'swap', a:i, b:j}));\n      i++; j--;\n    }\n    steps.push(this.stateSnapshot('reverse done'));\n    return steps;\n  };\n\n  DynamicArray.prototype.rotateSteps = function(stepsCount) {\n    var steps = [];\n    if (this.length === 0) {\n      steps.push(this.stateSnapshot('rotate: empty array'));\n      return steps;\n    }\n    var n = this.length;\n    var k = ((stepsCount % n) + n) % n;\n    steps.push(this.stateSnapshot('rotate: rotate by '+stepsCount+' -> effective '+k));\n    if (k === 0) return steps;\n    // simple rotate via temp copy for clarity and step tracking\n    var temp = new Array(this.length);\n    for (var i=0;i<this.length;i++){\n      temp[(i+k)%n] = this.buffer[i];\n      steps.push(this.stateSnapshot('compute new position for index '+i+' -> '+((i+k)%n), {type:'move', from:i, to:(i+k)%n, value:this.buffer[i]}));\n    }\n    for (var j=0;j<n;j++){\n      this.buffer[j] = temp[j];\n      steps.push(this.stateSnapshot('write rotated value to index '+j+' = '+String(this.buffer[j]), {type:'set', index:j, value:this.buffer[j]}));\n    }\n    steps.push(this.stateSnapshot('rotate done'));\n    return steps;\n  };\n\n  DynamicArray.prototype.sortSteps = function(method, compareExpr) {\n    var steps = [];\n    steps.push(this.stateSnapshot('sort: method='+method+' compareExpr='+compareExpr));\n    if (this.length <= 1) {\n      steps.push(this.stateSnapshot('sort: trivial (length<=1)'));\n      return steps;\n    }\n    if (method === 'native') {\n      // create compare function\n      var cmp;\n      try {\n        cmp = new Function('a','b','return ('+compareExpr+')');\n      } catch(e) {\n        steps.push(this.stateSnapshot('sort: invalid compare expression -> fallback to default'));\n        cmp = function(a,b){ if (a>b) return 1; if (a<b) return -1; return 0; };\n      }\n      // We'll run native sort on a shallow copy and then apply changes by swapping to reach sorted order (for step visualization).\n      var arr = this.buffer.slice(0, this.length).slice();\n      arr.sort(cmp);\n      // Now transform original into arr by successive swaps (naive)\n      for (var i=0;i<this.length;i++){\n        if (this.buffer[i] === arr[i]) continue;\n        // find index j>i where buffer[j] === arr[i]\n        var j = i+1;\n        while (j<this.length && this.buffer[j] !== arr[i]) j++;\n        if (j===this.length) {\n          // fallback: set directly\n          this.buffer[i] = arr[i];\n          steps.push(this.stateSnapshot('set index '+i+' = '+String(arr[i]), {type:'set', index:i, value:arr[i]}));\n        } else {\n          // swap downwards\n          while (j>i) {\n            var tmp = this.buffer[j-1];\n            this.buffer[j-1] = this.buffer[j];\n            this.buffer[j] = tmp;\n            steps.push(this.stateSnapshot('swap '+(j-1)+' <-> '+j, {type:'swap', a:j-1, b:j}));\n            j--;\n          }\n        }\n      }\n      steps.push(this.stateSnapshot('sort finished (native)'));\n      return steps;\n    } else if (method === 'bubble') {\n      // bubble sort with detailed steps\n      var cmp;\n      try {\n        cmp = new Function('a','b','return ('+compareExpr+')');\n      } catch(e) {\n        cmp = function(a,b){ if (a>b) return 1; if (a<b) return -1; return 0; };\n      }\n      var swapped=true;\n      for (var pass=0; pass<this.length-1 && swapped; pass++){\n        swapped=false;\n        for (var i=0;i<this.length-1-pass;i++){\n          steps.push(this.stateSnapshot('compare index '+i+' ('+String(this.buffer[i])+') and '+(i+1)+' ('+String(this.buffer[i+1])+')', {type:'compare', a:i, b:i+1}));\n          var c;\n          try { c = cmp(this.buffer[i], this.buffer[i+1]); } catch(e){ c=0; }\n          if (c>0) {\n            var tmp=this.buffer[i];\n            this.buffer[i]=this.buffer[i+1];\n            this.buffer[i+1]=tmp;\n            swapped=true;\n            steps.push(this.stateSnapshot('swap because compare>0: swap '+i+' <-> '+(i+1), {type:'swap', a:i, b:i+1}));\n          }\n        }\n      }\n      steps.push(this.stateSnapshot('bubble sort finished'));\n      return steps;\n    } else {\n      steps.push(this.stateSnapshot('sort: unknown method'));\n      return steps;\n    }\n  };\n\n  // Simple bench: perform random push/pop/insert/remove to show performance\n  DynamicArray.prototype.randomOpSteps = function(count, maxValue) {\n    var steps = [];\n    for (var k=0;k<count;k++) {\n      var op = Math.floor(Math.random()*4);\n      if (op===0) { // push\n        steps = steps.concat(this.pushSteps(randomVal(maxValue)));\n      } else if (op===1) { // pop\n        steps = steps.concat(this.popSteps());\n      } else if (op===2) { // insert random index\n        var idx = Math.floor(Math.random()*(this.length+1));\n        steps = steps.concat(this.insertAtSteps(idx, randomVal(maxValue)));\n      } else { // remove at\n        if (this.length>0) {\n          var idx2 = Math.floor(Math.random()*this.length);\n          steps = steps.concat(this.removeAtSteps(idx2));\n        } else {\n          steps = steps.concat(this.pushSteps(randomVal(maxValue)));\n        }\n      }\n    }\n    return steps;\n  };\n\n  function randomVal(maxVal) {\n    return String(maxVal) + '_' + Math.floor(Math.random()*100000);\n  }\n\n  // UI Controller\n  var arr = new DynamicArray(4, 2, 'normal');\n  var currentSteps = [ arr.stateSnapshot('initial') ];\n  var stepPointer = 0;\n  var autoPlayTimer = null;\n\n  var history = []; // sequence of final-state snapshots and descriptions\n  var historyIndex = -1;\n  var snapshots = [];\n\n  // DOM elements\n  var displayLength = document.getElementById('displayLength');\n  var displayCapacity = document.getElementById('displayCapacity');\n  var displayGrowth = document.getElementById('displayGrowth');\n  var arrayView = document.getElementById('arrayView');\n  var bufferView = document.getElementById('bufferView');\n  var logEl = document.getElementById('log');\n  var stepIndexEl = document.getElementById('stepIndex');\n  var stepTotalEl = document.getElementById('stepTotal');\n  var playSpeedEl = document.getElementById('playSpeed');\n  var snapshotListEl = document.getElementById('snapshotList');\n  var historyListEl = document.getElementById('historyList');\n\n  // Render functions\n  function renderStep(step) {\n    // show length/capacity and buffer view\n    displayLength.textContent = step.length;\n    displayCapacity.textContent = step.capacity;\n    displayGrowth.textContent = arr.growthFactor;\n    // buffer indices\n    var idxs = '';\n    for (var i=0;i<step.capacity;i++){\n      var label = '['+i+']';\n      idxs += pad(label, 7);\n    }\n    // values row - show slots up to capacity\n    var vals = '';\n    for (var j=0;j<step.capacity;j++){\n      var v = typeof step.buffer[j] === 'undefined' ? '_' : String(step.buffer[j]);\n      // if highlighted\n      var markerLeft = ' ';\n      var markerRight = ' ';\n      if (step.highlight) {\n        var h = step.highlight;\n        if (h.type==='set' && h.index===j) { markerLeft='[>'; markerRight='<]'; }\n        if (h.type==='remove' && h.index===j) { markerLeft='[-'; markerRight='-]'; }\n        if (h.type==='move' && (h.from===j || h.to===j)) { markerLeft='(>'; markerRight='<)'; }\n        if (h.type==='swap' && (h.a===j || h.b===j)) { markerLeft='{/'; markerRight='/}'; }\n        if (h.type==='copy' && h.to===j) { markerLeft='<<'; markerRight='>>'; }\n        if (h.type==='compare' && h.index===j) { markerLeft='<?'; markerRight='?>'; }\n        if (h.type==='init' && h.index===j) { markerLeft='(i'; markerRight='i)'; }\n      }\n      var cell = markerLeft + v + markerRight;\n      // pad to width\n      vals += pad(cell, 7);\n    }\n    arrayView.textContent = idxs;\n    bufferView.textContent = vals;\n    // log area: show message of the step\n    stepIndexEl.textContent = stepPointer;\n    stepTotalEl.textContent = currentSteps.length-1;\n    // append the step message to the log area as current focused step message only (not full history)\n    logEl.textContent = \"STEP \"+stepPointer+\" / \"+(currentSteps.length-1)+\"\\n\" + step.message + \"\\n\\nFull buffer preview:\\nIndices:\\n\" + idxs + \"\\nValues:\\n\" + vals + \"\\n\";\n  }\n\n  // Apply stepPointer to render\n  function refreshUI() {\n    var st = currentSteps[stepPointer] || arr.stateSnapshot('empty');\n    renderStep(st);\n  }\n\n  // Set the current steps and pointer to final step; push to history\n  function commitOperation(steps, opDesc) {\n    if (!steps || steps.length===0) {\n      // ensure at least snapshot\n      steps = [arr.stateSnapshot(opDesc || 'noop')];\n    }\n    currentSteps = steps;\n    stepPointer = steps.length - 1;\n    refreshUI();\n    // push to history (final snapshot)\n    var final = steps[steps.length-1];\n    history = history.slice(0, historyIndex+1); // truncate redo chain\n    history.push({snapshot: cloneState(final), desc: opDesc || final.message});\n    historyIndex = history.length-1;\n    updateHistoryList();\n  }\n\n  function cloneState(step) {\n    return { buffer: cloneBuffer(step.buffer), length: step.length, capacity: step.capacity, message: step.message };\n  }\n\n  function updateHistoryList() {\n    var html = '';\n    for (var i=0;i<history.length;i++){\n      var h = history[i];\n      html += (i===historyIndex ? '-> ' : '   ') + i + ': ' + h.desc + ' (len='+h.snapshot.length+' cap='+h.snapshot.capacity+')\\n';\n    }\n    historyListEl.textContent = html;\n  }\n\n  function listSnapshots() {\n    var html = '';\n    for (var i=0;i<snapshots.length;i++){\n      var s = snapshots[i];\n      html += i+': ' + (s.name||'snapshot') + ' (len='+s.length+' cap='+s.capacity+')\\n';\n    }\n    snapshotListEl.textContent = html || 'no snapshots';\n  }\n\n  // Button handlers and wiring\n  document.getElementById('btnCreate').addEventListener('click', function(){\n    var cap = parseInt(document.getElementById('initCapacity').value,10) || 0;\n    var gf = parseFloat(document.getElementById('growthFactor').value) || 2;\n    var mode = document.getElementById('mode').value;\n    arr = new DynamicArray(cap, gf, mode);\n    currentSteps = [arr.stateSnapshot('created new array cap='+cap+' growth='+gf+' mode='+mode)];\n    stepPointer = 0;\n    commitOperation(currentSteps, 'create');\n  });\n\n  document.getElementById('btnPush').addEventListener('click', function(){\n    var v = document.getElementById('valueInput').value;\n    var steps = arr.pushSteps(v);\n    commitOperation(steps, 'push('+v+')');\n  });\n\n  document.getElementById('btnPop').addEventListener('click', function(){\n    var steps = arr.popSteps();\n    commitOperation(steps, 'pop()');\n  });\n\n  document.getElementById('btnInsert').addEventListener('click', function(){\n    var v = document.getElementById('valueInput').value;\n    var idx = parseInt(document.getElementById('indexInput').value,10) || 0;\n    var steps = arr.insertAtSteps(idx, v);\n    commitOperation(steps, 'insertAt('+idx+','+v+')');\n  });\n\n  document.getElementById('btnRemove').addEventListener('click', function(){\n    var idx = parseInt(document.getElementById('indexInput').value,10) || 0;\n    var steps = arr.removeAtSteps(idx);\n    commitOperation(steps, 'removeAt('+idx+')');\n  });\n\n  document.getElementById('btnSet').addEventListener('click', function(){\n    var v = document.getElementById('valueInput').value;\n    var idx = parseInt(document.getElementById('indexInput').value,10) || 0;\n    var steps = arr.setAtSteps(idx, v);\n    commitOperation(steps, 'set('+idx+','+v+')');\n  });\n\n  document.getElementById('btnGet').addEventListener('click', function(){\n    var idx = parseInt(document.getElementById('indexInput').value,10) || 0;\n    var steps = [];\n    if (idx < 0 || idx >= arr.length) {\n      steps.push(arr.stateSnapshot('get('+idx+') -> undefined'));\n    } else {\n      steps.push(arr.stateSnapshot('get('+idx+') -> '+String(arr.buffer[idx]), {type:'compare', index:idx}));\n    }\n    commitOperation(steps, 'get('+idx+')');\n  });\n\n  document.getElementById('btnUnshift').addEventListener('click', function(){\n    var v = document.getElementById('valueInput').value;\n    var steps = arr.unshiftSteps(v);\n    commitOperation(steps, 'unshift('+v+')');\n  });\n\n  document.getElementById('btnShift').addEventListener('click', function(){\n    var steps = arr.shiftSteps();\n    commitOperation(steps, 'shift()');\n  });\n\n  document.getElementById('btnPushMany').addEventListener('click', function(){\n    var count = parseInt(document.getElementById('countInput').value,10) || 1;\n    count = Math.max(0, Math.min(10000, count));\n    var steps = [];\n    for (var i=0;i<count;i++){\n      steps = steps.concat(arr.pushSteps(document.getElementById('valueInput').value + '_' + i));\n    }\n    commitOperation(steps, 'pushMany('+count+')');\n  });\n\n  document.getElementById('btnClear').addEventListener('click', function(){\n    var steps = arr.clearSteps();\n    commitOperation(steps, 'clear()');\n  });\n\n  document.getElementById('btnReserve').addEventListener('click', function(){\n    var cap = parseInt(document.getElementById('reserveInput').value,10) || 0;\n    var steps = arr.reserveSteps(cap);\n    commitOperation(steps, 'reserve('+cap+')');\n  });\n\n  document.getElementById('btnShrink').addEventListener('click', function(){\n    var steps = arr.shrinkToFitSteps();\n    commitOperation(steps, 'shrink_to_fit()');\n  });\n\n  document.getElementById('btnResize').addEventListener('click', function(){\n    var nl = parseInt(document.getElementById('resizeInput').value,10);\n    var steps = arr.resizeSteps(nl);\n    commitOperation(steps, 'resize('+nl+')');\n  });\n\n  document.getElementById('btnSetCapacity').addEventListener('click', function(){\n    var nc = parseInt(document.getElementById('manualCapacity').value,10) || 0;\n    var steps = arr.setCapacitySteps(nc);\n    commitOperation(steps, 'set_capacity('+nc+')');\n  });\n\n  document.getElementById('btnMap').addEventListener('click', function(){\n    var expr = document.getElementById('exprInput').value;\n    var steps = arr.mapSteps(expr);\n    commitOperation(steps, 'map('+expr+')');\n  });\n\n  document.getElementById('btnFilter').addEventListener('click', function(){\n    var expr = document.getElementById('exprInput').value;\n    var steps = arr.filterSteps(expr);\n    commitOperation(steps, 'filter('+expr+')');\n  });\n\n  document.getElementById('btnSlice').addEventListener('click', function(){\n    var s = parseInt(document.getElementById('sliceStart').value,10) || 0;\n    var e = parseInt(document.getElementById('sliceEnd').value,10);\n    var steps = arr.sliceSteps(s, isNaN(e) ? undefined : e);\n    commitOperation(steps, 'slice('+s+','+e+')');\n  });\n\n  document.getElementById('btnSplice').addEventListener('click', function(){\n    var idx = parseInt(document.getElementById('spliceIndex').value,10) || 0;\n    var del = parseInt(document.getElementById('spliceDel').value,10) || 0;\n    var itemsStr = document.getElementById('spliceItems').value;\n    var items = itemsStr === '' ? [] : itemsStr.split(',').map(function(s){return s.trim();});\n    var steps = arr.spliceSteps(idx, del, items);\n    commitOperation(steps, 'splice('+idx+','+del+','+JSON.stringify(items)+')');\n  });\n\n  document.getElementById('btnReverse').addEventListener('click', function(){\n    var steps = arr.reverseSteps();\n    commitOperation(steps, 'reverse()');\n  });\n\n  document.getElementById('btnRotate').addEventListener('click', function(){\n    var k = parseInt(document.getElementById('rotateCount').value,10) || 0;\n    var steps = arr.rotateSteps(k);\n    commitOperation(steps, 'rotate('+k+')');\n  });\n\n  document.getElementById('btnSort').addEventListener('click', function(){\n    var method = document.getElementById('sortMethod').value;\n    var expr = document.getElementById('compareExpr').value;\n    var steps = arr.sortSteps(method, expr);\n    commitOperation(steps, 'sort('+method+')');\n  });\n\n  document.getElementById('btnPrev').addEventListener('click', function(){\n    stepPointer = Math.max(0, stepPointer-1);\n    refreshUI();\n  });\n\n  document.getElementById('btnNext').addEventListener('click', function(){\n    stepPointer = Math.min(currentSteps.length-1, stepPointer+1);\n    refreshUI();\n  });\n\n  document.getElementById('btnPlay').addEventListener('click', function(){\n    var speed = Math.max(10, parseInt(playSpeedEl.value,10) || 500);\n    if (autoPlayTimer) clearInterval(autoPlayTimer);\n    autoPlayTimer = setInterval(function(){\n      if (stepPointer < currentSteps.length-1) {\n        stepPointer++;\n        refreshUI();\n      } else {\n        clearInterval(autoPlayTimer);\n        autoPlayTimer = null;\n      }\n    }, speed);\n  });\n\n  document.getElementById('btnPause').addEventListener('click', function(){\n    if (autoPlayTimer) { clearInterval(autoPlayTimer); autoPlayTimer = null; }\n  });\n\n  document.getElementById('btnSnapshot').addEventListener('click', function(){\n    var name = prompt('Snapshot name (optional):','snapshot_'+snapshots.length);\n    var final = arr.stateSnapshot('snapshot');\n    snapshots.push({ name: name || ('snapshot_'+snapshots.length), buffer: cloneBuffer(final.buffer), length: final.length, capacity: final.capacity });\n    listSnapshots();\n  });\n\n  document.getElementById('btnListSnapshots').addEventListener('click', function(){\n    listSnapshots();\n    var idx = prompt('Enter snapshot index to restore (or Cancel):','');\n    if (idx === null || idx === '') return;\n    idx = parseInt(idx,10);\n    if (isNaN(idx) || idx < 0 || idx >= snapshots.length) {\n      alert('invalid index');\n      return;\n    }\n    var s = snapshots[idx];\n    arr.buffer = cloneBuffer(s.buffer);\n    arr.length = s.length;\n    arr.capacity = s.capacity;\n    var steps = [ arr.stateSnapshot('restored snapshot '+s.name) ];\n    commitOperation(steps, 'restore snapshot '+s.name);\n  });\n\n  document.getElementById('btnUndo').addEventListener('click', function(){\n    if (historyIndex <= 0) {\n      alert('no undo available');\n      return;\n    }\n    historyIndex--;\n    var state = history[historyIndex].snapshot;\n    arr.buffer = cloneBuffer(state.buffer);\n    arr.length = state.length;\n    arr.capacity = state.capacity;\n    commitOperation([arr.stateSnapshot('undo -> history index '+historyIndex)], 'undo');\n  });\n\n  document.getElementById('btnRedo').addEventListener('click', function(){\n    if (historyIndex >= history.length-1) {\n      alert('no redo available');\n      return;\n    }\n    historyIndex++;\n    var state = history[historyIndex].snapshot;\n    arr.buffer = cloneBuffer(state.buffer);\n    arr.length = state.length;\n    arr.capacity = state.capacity;\n    commitOperation([arr.stateSnapshot('redo -> history index '+historyIndex)], 'redo');\n  });\n\n  document.getElementById('btnResetHistory').addEventListener('click', function(){\n    history = [];\n    historyIndex = -1;\n    updateHistoryList();\n  });\n\n  document.getElementById('btnBench').addEventListener('click', function(){\n    var ops = parseInt(document.getElementById('benchOps').value,10) || 10000;\n    var val = document.getElementById('benchMaxVal').value || 'V';\n    // run random ops but do not create massive steps (we will only time and then produce a final snapshot)\n    var t0 = performance.now();\n    // lightweight simulation: directly operate without step tracking for speed\n    var lightweight = new DynamicArray(arr.capacity || 4, arr.growthFactor, arr.mode);\n    for (var k=0;k<ops;k++){\n      var op = Math.floor(Math.random()*4);\n      if (op===0) {\n        // push\n        if (lightweight.mode !== 'manual') {\n          if (lightweight.length+1 > lightweight.capacity) {\n            var newCap = Math.max(1, Math.floor((lightweight.capacity||1) * lightweight.growthFactor));\n            if (newCap <= lightweight.capacity) newCap = lightweight.capacity+1;\n            var newBuff = new Array(newCap);\n            for (var c=0;c<lightweight.length;c++) newBuff[c] = lightweight.buffer[c];\n            lightweight.buffer = newBuff;\n            lightweight.capacity = newCap;\n          }\n        } else {\n          if (lightweight.length+1 > lightweight.capacity) {\n            // ignore push\n            continue;\n          }\n        }\n        lightweight.buffer[lightweight.length] = val + '_' + k;\n        lightweight.length++;\n      } else if (op===1) {\n        if (lightweight.length>0) {\n          lightweight.buffer[lightweight.length-1] = undefined;\n          lightweight.length--;\n        }\n      } else if (op===2) {\n        var idx = Math.floor(Math.random()*(lightweight.length+1));\n        if (lightweight.mode !== 'manual') {\n          if (lightweight.length+1 > lightweight.capacity) {\n            var newCap2 = Math.max(1, Math.floor((lightweight.capacity||1) * lightweight.growthFactor));\n            if (newCap2 <= lightweight.capacity) newCap2 = lightweight.capacity+1;\n            var nb = new Array(newCap2);