  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>CPU Scheduling Interactive Simulator</title>\n<style>\n/* Extremely minimal styling only for basic readability */\nbody { font-family: Arial, Helvetica, sans-serif; color: black; background: white; margin: 12px; }\ninput, select, button, textarea { font: inherit; }\npre { background: transparent; padding: 0; margin: 0; white-space: pre-wrap; word-wrap: break-word; }\n.section { margin-bottom: 16px; }\n.small { font-size: 90%; }\n.grid { display: block; }\n.table { border-collapse: collapse; }\n.table td, .table th { padding: 2px 6px; vertical-align: top; }\n.note { font-size: 90%; color: black; }\n</style>\n</head>\n<body>\n\n<h2>CPU Scheduling Interactive Simulator (Minimal UI)</h2>\n\n<div class=\"section\">\n  <strong>Simulation Controls</strong><br>\n  Algorithm:\n  <select id=\"algo\">\n    <option value=\"FCFS\">FCFS (First-Come First-Served)</option>\n    <option value=\"SJF\">SJF (Shortest Job First - non-preemptive)</option>\n    <option value=\"SRTF\">SRTF (Shortest Remaining Time First - preemptive)</option>\n    <option value=\"Priority\">Priority (select preemptive toggle)</option>\n    <option value=\"RR\">Round Robin</option>\n    <option value=\"Manual\">Manual Scheduler (user chooses next)</option>\n  </select>\n  Preemptive (for Priority):\n  <input type=\"checkbox\" id=\"priorityPreempt\" />\n  Quantum (RR):\n  <input type=\"range\" id=\"quantum\" min=\"1\" max=\"10\" value=\"3\" />\n  <span id=\"quantumVal\">3</span>\n  Context switch cost:\n  <input type=\"number\" id=\"contextCost\" value=\"0\" min=\"0\" step=\"1\" style=\"width:60px\" />\n  Time per step (ms) playback speed:\n  <input type=\"range\" id=\"speed\" min=\"50\" max=\"2000\" step=\"10\" value=\"500\" />\n  <span id=\"speedVal\">500ms</span>\n  Step size (time units per step): <input type=\"number\" id=\"stepSize\" min=\"1\" value=\"1\" style=\"width:60px\"/>\n  <br>\n  <button id=\"startBtn\">Start / Run</button>\n  <button id=\"pauseBtn\">Pause</button>\n  <button id=\"stepForwardBtn\">Step Forward</button>\n  <button id=\"stepBackBtn\">Step Back</button>\n  <button id=\"resetBtn\">Reset</button>\n  <button id=\"fastForwardBtn\">Fast Run to Completion</button>\n  <button id=\"clearLogBtn\">Clear Log</button>\n  <label><input type=\"checkbox\" id=\"autoAging\"/> Aging (increase priority over time)</label>\n</div>\n\n<div class=\"section\">\n  <strong>Process Controls</strong><br>\n  Add / Edit process (CPU bursts comma-separated; IO bursts comma-separated; #IO = #CPU - 1):<br>\n  Name: <input id=\"pName\" value=\"P1\" style=\"width:60px\" />\n  Arrival: <input id=\"pArrival\" type=\"number\" value=\"0\" style=\"width:60px\"\"/>\n  CPU bursts: <input id=\"pCpu\" value=\"5\" style=\"width:160px\" />\n  IO bursts: <input id=\"pIo\" value=\"\" style=\"width:160px\" />\n  Priority: <input id=\"pPriority\" type=\"number\" value=\"1\" style=\"width:60px\" />\n  <button id=\"addProcessBtn\">Add Process</button>\n  <button id=\"randomBtn\">Generate Random</button>\n  <button id=\"presetBtn\">Load Preset</button>\n  <button id=\"importBtn\">Import JSON</button>\n  <button id=\"exportBtn\">Export JSON</button>\n</div>\n\n<div class=\"section\">\n  <strong>Processes</strong><br>\n  <table id=\"processTable\" border=\"1\" class=\"table small\">\n    <thead><tr><th>ID</th><th>Name</th><th>Arrival</th><th>CPU bursts</th><th>IO bursts</th><th>Priority</th><th>State</th><th>Actions</th></tr></thead>\n    <tbody></tbody>\n  </table>\n</div>\n\n<div class=\"section\">\n  <strong>Manual Scheduler Controls (only in Manual algorithm)</strong><br>\n  Ready Queue: <select id=\"manualReady\" style=\"width:200px\"></select>\n  <button id=\"assignCpuBtn\">Assign to CPU (for chosen time slice)</button>\n  Force context switch: <button id=\"forceSwitchBtn\">Force Switch Now</button>\n</div>\n\n<div class=\"section\">\n  <strong>Visualization</strong><br>\n  Current Time: <span id=\"currentTime\">0</span> &nbsp; | &nbsp; CPU: <span id=\"cpuStatus\">idle</span> &nbsp; | &nbsp; CSTimer: <span id=\"csTimer\">0</span><br>\n  Ready Queue: <span id=\"readyStr\"></span><br>\n  Blocked: <span id=\"blockedStr\"></span><br>\n  Completed: <span id=\"completedStr\"></span><br>\n</div>\n\n<div class=\"section\">\n  <strong>Gantt Chart (per time unit)</strong><br>\n  <pre id=\"gantt\" style=\"border:1px solid black; padding:6px; max-height:200px; overflow:auto;\"></pre>\n</div>\n\n<div class=\"section\">\n  <strong>Statistics</strong><br>\n  <div id=\"stats\"></div>\n</div>\n\n<div class=\"section\">\n  <strong>Trace Log</strong> (events): <button id=\"copyLogBtn\">Copy Log</button><br>\n  <textarea id=\"log\" rows=\"8\" style=\"width:100%;\"></textarea>\n</div>\n\n<div class=\"section\">\n  <strong>Scenario Import/Export</strong><br>\n  <textarea id=\"scenarioJson\" rows=\"6\" style=\"width:100%;\"></textarea><br>\n  <button id=\"loadScenarioBtn\">Load Scenario</button>\n  <button id=\"saveScenarioBtn\">Save Current Scenario</button>\n</div>\n\n<script>\n/*\n CPU Scheduling Simulator - single-file interactive app\n Minimal UI, rich controls and workflows, many interactive paths.\n*/\n\n(function(){\n\n// --- State model and initialization ---\nlet state = {\n  time: 0,\n  processes: [], // each: {id,name,arrival,cpuBursts[],ioBursts[],curBurstIndex,remainingCpu,remainingIo,priority,state,firstResponseTime,finishTime,waitingTime,started}\n  running: null, // id of running process or null\n  csTimer: 0,\n  lastPid: 0,\n  gantt: [], // array of entries per time: {t,kind: 'P'/'idle'/'cs', pid}\n  log: [],\n  rrQueue: [], // for RR tracks order\n  history: [], // deep snapshots for step back\n  completedCount: 0,\n  autoRun: false,\n  runningInterval: null,\n};\n\nconst UI = {\n  algo: document.getElementById('algo'),\n  priorityPreempt: document.getElementById('priorityPreempt'),\n  quantum: document.getElementById('quantum'),\n  quantumVal: document.getElementById('quantumVal'),\n  contextCost: document.getElementById('contextCost'),\n  startBtn: document.getElementById('startBtn'),\n  pauseBtn: document.getElementById('pauseBtn'),\n  stepForwardBtn: document.getElementById('stepForwardBtn'),\n  stepBackBtn: document.getElementById('stepBackBtn'),\n  resetBtn: document.getElementById('resetBtn'),\n  fastForwardBtn: document.getElementById('fastForwardBtn'),\n  clearLogBtn: document.getElementById('clearLogBtn'),\n  autoAging: document.getElementById('autoAging'),\n  speed: document.getElementById('speed'),\n  speedVal: document.getElementById('speedVal'),\n  stepSize: document.getElementById('stepSize'),\n  // process controls\n  pName: document.getElementById('pName'),\n  pArrival: document.getElementById('pArrival'),\n  pCpu: document.getElementById('pCpu'),\n  pIo: document.getElementById('pIo'),\n  pPriority: document.getElementById('pPriority'),\n  addProcessBtn: document.getElementById('addProcessBtn'),\n  randomBtn: document.getElementById('randomBtn'),\n  presetBtn: document.getElementById('presetBtn'),\n  importBtn: document.getElementById('importBtn'),\n  exportBtn: document.getElementById('exportBtn'),\n  processTableBody: document.querySelector('#processTable tbody'),\n  manualReady: document.getElementById('manualReady'),\n  assignCpuBtn: document.getElementById('assignCpuBtn'),\n  forceSwitchBtn: document.getElementById('forceSwitchBtn'),\n  // visualization\n  currentTime: document.getElementById('currentTime'),\n  cpuStatus: document.getElementById('cpuStatus'),\n  csTimerSpan: document.getElementById('csTimer'),\n  readyStr: document.getElementById('readyStr'),\n  blockedStr: document.getElementById('blockedStr'),\n  completedStr: document.getElementById('completedStr'),\n  gantt: document.getElementById('gantt'),\n  stats: document.getElementById('stats'),\n  log: document.getElementById('log'),\n  copyLogBtn: document.getElementById('copyLogBtn'),\n  scenarioJson: document.getElementById('scenarioJson'),\n  loadScenarioBtn: document.getElementById('loadScenarioBtn'),\n  saveScenarioBtn: document.getElementById('saveScenarioBtn'),\n  clearLogBtnEl: document.getElementById('clearLogBtn'),\n};\n\n// utility\nfunction logEvent(msg){\n  const s = '[' + state.time + '] ' + msg;\n  state.log.push(s);\n  UI.log.value += s + '\\n';\n  UI.log.scrollTop = UI.log.scrollHeight;\n}\nfunction resetLogArea(){ UI.log.value = state.log.join('\\n'); UI.log.scrollTop = UI.log.scrollHeight; }\n\n// process helpers\nfunction makePid(){ state.lastPid += 1; return 'P' + state.lastPid; }\nfunction parseBurstsCsv(text){\n  if (!text) return [];\n  return text.split(',').map(s => {\n    const v = parseInt(s.trim());\n    return isNaN(v) ? 0 : Math.max(0, v);\n  }).filter(x => x !== null);\n}\nfunction addProcessFromInputs(){\n  const name = UI.pName.value.trim() || makePid();\n  const arrival = Math.max(0, parseInt(UI.pArrival.value) || 0);\n  const cpuBursts = parseBurstsCsv(UI.pCpu.value);\n  if (cpuBursts.length === 0) { alert('At least one CPU burst required'); return; }\n  const ioBursts = parseBurstsCsv(UI.pIo.value);\n  // ioBursts should be length cpuBursts-1; if shorter pad zeros\n  while (ioBursts.length < cpuBursts.length - 1) ioBursts.push(0);\n  const priority = parseInt(UI.pPriority.value) || 0;\n  const p = {\n    id: makePid(),\n    name,\n    arrival,\n    cpuBursts,\n    ioBursts,\n    curBurstIndex: 0,\n    remainingCpu: cpuBursts[0],\n    remainingIo: 0,\n    priority,\n    state: 'new', // new, ready, running, blocked, terminated\n    firstResponseTime: null,\n    finishTime: null,\n    waitingTime: 0,\n    started: false,\n    rrQuota: 0\n  };\n  state.processes.push(p);\n  refreshProcessTable();\n  logEvent('Added process ' + p.name + ' arrival=' + arrival + ' cpu=' + cpuBursts.join(',') + ' io=' + ioBursts.join(',') + ' pr=' + priority);\n}\nfunction refreshProcessTable(){\n  UI.processTableBody.innerHTML = '';\n  state.processes.forEach(p => {\n    const tr = document.createElement('tr');\n    const td = (c)=>{ const t=document.createElement('td'); t.textContent=c; return t; };\n    tr.appendChild(td(p.id));\n    tr.appendChild(td(p.name));\n    tr.appendChild(td(p.arrival));\n    tr.appendChild(td(p.cpuBursts.join(',')));\n    tr.appendChild(td(p.ioBursts.join(',')));\n    tr.appendChild(td(p.priority));\n    tr.appendChild(td(p.state));\n    const actions = document.createElement('td');\n    const edit = document.createElement('button'); edit.textContent='Edit';\n    edit.onclick = ()=>{ editProcess(p.id); };\n    const del = document.createElement('button'); del.textContent='Delete';\n    del.onclick = ()=>{ deleteProcess(p.id); };\n    const toReady = document.createElement('button'); toReady.textContent='Set Ready';\n    toReady.onclick = ()=>{ p.state='ready'; logEvent('Process '+p.name+' forced to ready'); refreshAll(); };\n    actions.appendChild(edit); actions.appendChild(del); actions.appendChild(toReady);\n    tr.appendChild(actions);\n    UI.processTableBody.appendChild(tr);\n  });\n  refreshManualReadySelect();\n}\n\n// Edit/Delete\nfunction editProcess(pid){\n  const p = state.processes.find(x=>x.id===pid);\n  if (!p) return;\n  const n = prompt('Name', p.name); if (n===null) return;\n  p.name = n || p.name;\n  const a = prompt('Arrival', p.arrival); if (a===null) return;\n  p.arrival = Math.max(0, parseInt(a)||0);\n  const cpu = prompt('CPU bursts (comma-separated)', p.cpuBursts.join(',')); if (cpu===null) return;\n  const cpuBursts = parseBurstsCsv(cpu); if (cpuBursts.length>0) p.cpuBursts = cpuBursts;\n  const io = prompt('IO bursts (comma-separated)', p.ioBursts.join(',')); if (io===null) return;\n  const ioBursts = parseBurstsCsv(io); p.ioBursts = ioBursts;\n  p.priority = Math.max(0, parseInt(prompt('Priority', p.priority))||0);\n  // reset remaining fields\n  p.curBurstIndex = Math.min(p.curBurstIndex, p.cpuBursts.length-1);\n  p.remainingCpu = p.cpuBursts[p.curBurstIndex];\n  p.remainingIo = p.ioBursts[p.curBurstIndex] || 0;\n  refreshProcessTable();\n  logEvent('Edited process ' + p.name);\n}\nfunction deleteProcess(pid){\n  const idx = state.processes.findIndex(x=>x.id===pid);\n  if (idx>=0){\n    logEvent('Deleted process ' + state.processes[idx].name);\n    state.processes.splice(idx,1);\n    refreshProcessTable();\n    refreshAll();\n  }\n}\n\n// --- Scheduler decision functions ---\nfunction getReadyQueueAtTime(t){\n  // return array of process objects that are in ready state and arrival <= t\n  return state.processes.filter(p=>p.state==='ready' && p.arrival <= t);\n}\nfunction pickNextProcess(){\n  const algo = UI.algo.value;\n  const ready = getReadyQueueAtTime(state.time);\n  if (ready.length===0) return null;\n  if (algo === 'FCFS') {\n    // earliest arrival then id order\n    ready.sort((a,b)=> (a.arrival - b.arrival) || a.id.localeCompare(b.id));\n    return ready[0];\n  } else if (algo === 'SJF') {\n    // pick shortest next cpu burst (non-preemptive)\n    ready.sort((a,b)=> (a.cpuBursts[a.curBurstIndex] - b.cpuBursts[b.curBurstIndex]) || a.arrival - b.arrival);\n    return ready[0];\n  } else if (algo === 'SRTF') {\n    // pick shortest remaining time of current CPU burst (preemptive)\n    ready.sort((a,b)=> (a.remainingCpu - b.remainingCpu) || a.arrival - b.arrival);\n    return ready[0];\n  } else if (algo === 'Priority') {\n    ready.sort((a,b)=> (a.priority - b.priority) || a.arrival - b.arrival);\n    return ready[0];\n  } else if (algo === 'RR') {\n    // maintain RR queue: state.rrQueue holds ids in order; when ready, ensure they are present in rrQueue\n    // Add missing ready processes in arrival order\n    ready.sort((a,b)=> (a.arrival - b.arrival) || a.id.localeCompare(b.id));\n    ready.forEach(p=>{\n      if (!state.rrQueue.includes(p.id)) state.rrQueue.push(p.id);\n    });\n    // remove non-ready from rrQueue\n    state.rrQueue = state.rrQueue.filter(id => {\n      const p = state.processes.find(x=>x.id===id);\n      return p && p.state==='ready' && p.arrival <= state.time;\n    });\n    // front of rrQueue is next\n    if (state.rrQueue.length===0) return null;\n    const pid = state.rrQueue[0];\n    return state.processes.find(x=>x.id===pid) || null;\n  } else if (algo === 'Manual') {\n    // Manual mode: pick nothing automatically\n    return null;\n  }\n  return null;\n}\n\n// --- Core simulation step ---\nfunction snapshotState(){\n  // store deep clone of necessary state for stepping back\n  const snap = JSON.parse(JSON.stringify({\n    time: state.time,\n    processes: state.processes,\n    running: state.running,\n    csTimer: state.csTimer,\n    gantt: state.gantt,\n    rrQueue: state.rrQueue,\n    log: state.log,\n    completedCount: state.completedCount\n  }));\n  state.history.push(snap);\n  // keep history up to some large limit\n  if (state.history.length > 5000) state.history.shift();\n}\nfunction restoreSnapshot(){\n  if (state.history.length === 0) return false;\n  const snap = state.history.pop();\n  state.time = snap.time;\n  state.processes = JSON.parse(JSON.stringify(snap.processes));\n  state.running = snap.running;\n  state.csTimer = snap.csTimer;\n  state.gantt = JSON.parse(JSON.stringify(snap.gantt));\n  state.rrQueue = JSON.parse(JSON.stringify(snap.rrQueue));\n  state.log = JSON.parse(JSON.stringify(snap.log));\n  state.completedCount = snap.completedCount;\n  refreshAll(true);\n  return true;\n}\n\nfunction stepOneUnit(){\n  // step simulation by one time unit\n  snapshotState();\n  const stepUnits = Math.max(1, parseInt(UI.stepSize.value) || 1);\n  // apply multiple units if stepSize >1 by repeated micro-steps\n  for (let s=0; s<stepUnits; s++){\n    // First, check arrivals\n    state.processes.forEach(p=>{\n      if (p.state === 'new' && p.arrival <= state.time){\n        p.state = 'ready';\n        // remainingCpu should be set\n        if (p.remainingCpu == null) p.remainingCpu = p.cpuBursts[p.curBurstIndex];\n        logEvent('Process ' + p.name + ' arrived and moved to ready');\n      }\n    });\n    // Update blocked processes (IO)\n    state.processes.forEach(p=>{\n      if (p.state === 'blocked'){\n        if (p.remainingIo > 0){\n          p.remainingIo -= 1;\n        }\n        if (p.remainingIo <= 0){\n          p.curBurstIndex = Math.min(p.curBurstIndex + 1, p.cpuBursts.length - 1);\n          p.remainingCpu = p.cpuBursts[p.curBurstIndex];\n          p.state = 'ready';\n          logEvent('Process ' + p.name + ' finished IO and moved to ready');\n          // For RR: add to rrQueue\n          if (UI.algo.value === 'RR' && !state.rrQueue.includes(p.id)) state.rrQueue.push(p.id);\n        }\n      }\n    });\n\n    // Aging: optionally increase priority of waiting processes\n    if (UI.autoAging.checked){\n      state.processes.forEach(p=>{\n        if (p.state === 'ready') {\n          p.priority = Math.max(0, p.priority - 0.001); // minor aging over time\n        }\n      });\n    }\n\n    // If context switch is happening (csTimer > 0), decrement and mark gantt entry as 'cs'\n    if (state.csTimer > 0){\n      state.csTimer -= 1;\n      state.gantt.push({t: state.time, kind: 'cs', pid: null});\n      state.time += 1;\n      continue; // while cs active, CPU doesn't execute process\n    }\n\n    // If CPU idle (no running process), try to pick one\n    if (!state.running){\n      const next = pickNextProcess();\n      if (next){\n        // Start context switch if configured\n        const cost = parseInt(UI.contextCost.value) || 0;\n        if (cost > 0){\n          state.csTimer = cost;\n          // set running only after cs completes; store intended next\n          state.pendingRunning = next.id;\n          logEvent('Context switch scheduled to start ' + next.name + ' (cost ' + cost + ')');\n          // record a 'cs' gantt for this time unit in next iteration; but consume a time unit now\n          state.gantt.push({t: state.time, kind: 'cs', pid: null});\n          state.time += 1;\n          // because we consumed time unit for context switch, need to continue outer loop to next s\n          continue;\n        } else {\n          // no context cost, start running immediately\n          state.running = next.id;\n          next.state = 'running';\n          if (!next.started){\n            next.firstResponseTime = state.time;\n            next.started = true;\n            logEvent('Process ' + next.name + ' started (response time ' + (state.time - next.arrival) + ')');\n          } else {\n            logEvent('Process ' + next.name + ' resumed');\n          }\n        }\n      }\n    } else {\n      // a process is running; but preemption might happen depending on algorithm when new ready exists at this time\n      const runningProc = state.processes.find(p=>p.id===state.running);\n      // In SRTF, if a new process has smaller remaining time then preempt\n      if (runningProc){\n        const algo = UI.algo.value;\n        if (algo === 'SRTF'){\n          const ready = getReadyQueueAtTime(state.time);\n          const shorter = ready.find(p=>p.remainingCpu < runningProc.remainingCpu);\n          if (shorter){\n            // preempt\n            runningProc.state = 'ready';\n            state.running = null;\n            logEvent('Preempting ' + runningProc.name + ' for shorter ' + shorter.name);\n            // In RR also manage rrQueue, push preempted to rrQueue end\n            if (UI.algo.value === 'RR' && !state.rrQueue.includes(runningProc.id)) state.rrQueue.push(runningProc.id);\n            // start next iteration where pickNextProcess will consider new shorter\n            // apply context switch if any\n            const cost = parseInt(UI.contextCost.value) || 0;\n            if (cost>0){\n              state.csTimer = cost;\n              state.gantt.push({t: state.time, kind: 'cs', pid: null});\n              state.time += 1;\n              continue;\n            }\n          }\n        }\n        // Priority preemptive\n        if (UI.algo.value === 'Priority' && UI.priorityPreempt.checked){\n          const ready = getReadyQueueAtTime(state.time);\n          const higher = ready.find(p=>p.priority < runningProc.priority);\n          if (higher){\n            runningProc.state = 'ready';\n            state.running = null;\n            logEvent('Preempting ' + runningProc.name + ' for higher priority ' + higher.name);\n            const cost = parseInt(UI.contextCost.value) || 0;\n            if (cost>0){\n              state.csTimer = cost;\n              state.gantt.push({t: state.time, kind: 'cs', pid: null});\n              state.time += 1;\n              continue;\n            }\n          }\n        }\n      }\n    }\n\n    // Manual mode: if running is null, do nothing else; user must assign\n    if (UI.algo.value === 'Manual'){\n      // record idle time\n      if (!state.running){\n        state.gantt.push({t: state.time, kind: 'idle', pid: null});\n      } else {\n        // run manual assigned process\n        const rp = state.processes.find(p=>p.id===state.running);\n        if (rp){\n          rp.remainingCpu -= 1;\n          state.gantt.push({t: state.time, kind: 'P', pid: rp.id});\n          // mark started if first run\n          if (!rp.started){\n            rp.started = true; rp.firstResponseTime = state.time;\n            logEvent('Manual run: ' + rp.name + ' started');\n          }\n          // increment waiting for ready processes\n          state.processes.forEach(p=> {\n            if (p.state === 'ready') p.waitingTime += 1;\n          });\n          if (rp.remainingCpu <= 0){\n            // finish CPU burst\n            if (rp.curBurstIndex < rp.cpuBursts.length - 1){\n              // move to blocked for IO\n              rp.remainingIo = rp.ioBursts[rp.curBurstIndex];\n              rp.state = 'blocked';\n              logEvent('Manual run: ' + rp.name + ' finished CPU burst and moves to blocked for IO ' + rp.remainingIo);\n            } else {\n              rp.state = 'terminated';\n              rp.finishTime = state.time + 1;\n              state.completedCount += 1;\n              logEvent('Manual run: ' + rp.name + ' terminated at t=' + rp.finishTime);\n            }\n            state.running = null;\n          }\n        } else {\n          // weird: running id not found\n          state.running = null;\n          state.gantt.push({t: state.time, kind: 'idle', pid: null});\n        }\n      }\n      state.time += 1;\n      continue;\n    }\n\n    // If still no running process, pick one now (after context switch checks)\n    if (!state.running){\n      const next = pickNextProcess();\n      if (next){\n        state.running = next.id;\n        next.state = 'running';\n        if (!next.started){\n          next.firstResponseTime = state.time;\n          next.started = true;\n          logEvent('Process ' + next.name + ' started (response time ' + (state.time - next.arrival) + ')');\n        } else {\n          logEvent('Process ' + next.name + ' resumed');\n        }\n      }\n    }\n\n    // If still no running, CPU idle for this time unit\n    if (!state.running){\n      state.gantt.push({t: state.time, kind: 'idle', pid: null});\n      // increment waiting times\n      state.processes.forEach(p=>{ if (p.state === 'ready') p.waitingTime += 1; });\n      state.time += 1;\n      continue;\n    }\n\n    // Execute one unit on running process\n    const proc = state.processes.find(p=>p.id===state.running);\n    if (!proc){\n      state.running = null;\n      state.gantt.push({t: state.time, kind: 'idle', pid: null});\n      state.time += 1;\n      continue;\n    }\n\n    // For RR: manage quantum\n    let rrQuantum = parseInt(UI.quantum.value) || 1;\n    if (UI.algo.value === 'RR'){\n      if (proc.rrQuota == null || proc.rrQuota <= 0){\n        proc.rrQuota = rrQuantum;\n      }\n    }\n\n    // Run for one unit\n    proc.remainingCpu -= 1;\n    state.gantt.push({t: state.time, kind: 'P', pid: proc.id});\n    // increment waiting times for other ready processes\n    state.processes.forEach(p=>{ if (p.state === 'ready') p.waitingTime += 1; });\n\n    // Check if CPU burst finished\n    if (proc.remainingCpu <= 0){\n      if (proc.curBurstIndex < proc.cpuBursts.length - 1){\n        // move to blocked for IO\n        proc.remainingIo = proc.ioBursts[proc.curBurstIndex];\n        proc.state = 'blocked';\n        logEvent('Process ' + proc.name + ' completed CPU burst, will perform IO for ' + proc.remainingIo);\n        // advance will happen after IO completes\n      } else {\n        // terminate\n        proc.state = 'terminated';\n        proc.finishTime = state.time + 1;\n        state.completedCount += 1;\n        logEvent('Process ' + proc.name + ' terminated at t=' + proc.finishTime);\n      }\n      // remove from RR queue if present\n      state.rrQueue = state.rrQueue.filter(id => id !== proc.id);\n      state.running = null;\n      // Apply context switch cost if configured for next process in next iteration\n      const cost = parseInt(UI.contextCost.value) || 0;\n      if (cost > 0){\n        state.csTimer = cost;\n      }\n    } else {\n      // CPU burst not finished - handle RR timeslice expiry\n      if (UI.algo.value === 'RR') {\n        proc.rrQuota -= 1;\n        if (proc.rrQuota <= 0){\n          // timeslice exhausted: preempt to back of queue if other ready processes exist\n          // push to back and remove front\n          if (state.rrQueue.length>0 && state.rrQueue[0] === proc.id){\n            state.rrQueue.shift(); // remove front\n            state.rrQueue.push(proc.id);\n          } else {\n            // ensure present in queue\n            if (!state.rrQueue.includes(proc.id)) state.rrQueue.push(proc.id);\n          }\n          proc.state = 'ready';\n          state.running = null;\n          logEvent('RR: timeslice for ' + proc.name + ' expired; moved back to ready');\n          const cost = parseInt(UI.contextCost.value) || 0;\n          if (cost>0){\n            state.csTimer = cost;\n            state.gantt.push({t: state.time, kind: 'cs', pid: null});\n            // consume a time unit for cs (we will increment time below then keep)\n            state.time += 1;\n            // we already consumed current time unit for execution; but we've added extra cs step - consistent\n            continue;\n          }\n        }\n      }\n      // For preemptive priority: check if a higher priority process arrived this exact time and preempt\n      if (UI.algo.value === 'Priority' && UI.priorityPreempt.checked) {\n        const ready = getReadyQueueAtTime(state.time);\n        const higher = ready.find(p=>p.priority < proc.priority);\n        if (higher){\n          proc.state = 'ready';\n          state.running = null;\n          logEvent('Preempting ' + proc.name + ' for higher priority ' + higher.name);\n          const cost = parseInt(UI.contextCost.value) || 0;\n          if (cost>0){\n            state.csTimer = cost;\n            state.gantt.push({t: state.time, kind: 'cs', pid: null});\n            state.time += 1;\n            continue;\n          }\n        }\n      }\n    }\n\n    // increment simulation time after this micro-step\n    state.time += 1;\n  } // end stepUnits loop\n\n  refreshAll();\n}\n\n// Fast run until all processes terminated or for safety limit\nfunction fastRunToCompletion(){\n  const limit = 10000;\n  let counter = 0;\n  while (state.processes.some(p=>p.state !== 'terminated')){\n    stepOneUnit();\n    counter++;\n    if (counter > limit) { logEvent('Fast run aborted after limit'); break; }\n  }\n  logEvent('Fast run ended at time ' + state.time);\n}\n\n// UI refresh\nfunction refreshAll(skipLogUpdate){\n  UI.currentTime.textContent = state.time;\n  UI.csTimerSpan.textContent = state.csTimer;\n  UI.gantt.textContent = renderGantt();\n  UI.cpuStatus.textContent = state.running ? (state.processes.find(p=>p.id===state.running)?.name || state.running) : 'idle';\n  UI.readyStr.textContent = getReadyQueueAtTime(state.time).map(p=>p.name).join(', ');\n  UI.blockedStr.textContent = state.processes.filter(p=>p.state==='blocked').map(p=>p.name + '(io=' + p.remainingIo + ')').join(', ');\n  UI.completedStr.textContent = state.processes.filter(p=>p.state==='terminated').map(p=>p.name).join(', ');\n  refreshProcessTable();\n  refreshStats();\n  if (!skipLogUpdate) resetLogArea();\n  UI.quantumVal.textContent = UI.quantum.value;\n  UI.speedVal.textContent = UI.speed.value + 'ms';\n}\n\nfunction renderGantt(){\n  // produce a simple textual gantt with time indices\n  if (state.gantt.length === 0) return '';\n  // compress into blocks where consecutive same pid or idle/cs grouped\n  let out = '';\n  const blocks = [];\n  for (let i=0;i<state.gantt.length;i++){\n    const e = state.gantt[i];\n    const key = e.kind === 'P' ? e.pid : e.kind;\n    if (blocks.length === 0 || blocks[blocks.length-1].key !== key){\n      blocks.push({key, start: e.t, end: e.t+1});\n    } else {\n      blocks[blocks.length-1].end = e.t+1;\n    }\n  }\n  // build two-line display: labels then times\n  let line1 = '';\n  let line2 = '';\n  blocks.forEach(b=>{\n    const label = b.key === 'idle' ? 'idle' : (b.key === 'cs' ? 'CS' : b.key);\n    const width = b.end - b.start;\n    const cell = '[' + label + ' x' + width + ']';\n    line1 += cell;\n  });\n  // show time range\n  line2 = '0..' + state.time;\n  out = line1 + '\\n' + line2;\n  return out;\n}\n\nfunction refreshStats(){\n  const procs = state.processes.filter(p=>p.cpuBursts && p.cpuBursts.length);\n  const completed = procs.filter(p=>p.state==='terminated');\n  const n = procs.length;\n  const avgTurn = completed.length ? (completed.reduce((acc,p)=>acc + (p.finishTime - p.arrival),0) / completed.length) : 0;\n  const avgWait = completed.length ? (completed.reduce((acc,p)=>acc + p.waitingTime,0) / completed.length) : 0;\n  const avgResp = completed.length ? (completed.reduce((acc,p)=>acc + (p.firstResponseTime - p.arrival),0) / completed.length) : 0;\n  const throughput = state.time > 0 ? (completed.length / state.time) : 0;\n  // CPU utilization: proportion of non-idle and non-cs entries\n  const nonIdle = state.gantt.filter(e=> e.kind === 'P').length;\n  const utilization = state.time>0 ? Math.round((nonIdle / state.time)*10000)/100 : 0;\n  UI.stats.innerHTML = `\n    Processes: ${n} | Completed: ${completed.length}<br>\n    Avg Turnaround: ${avgTurn.toFixed(2)} | Avg Waiting: ${avgWait.toFixed(2)} | Avg Response: ${avgResp.toFixed(2)}<br>\n    Throughput: ${throughput.toFixed(3)} per time unit | CPU Utilization: ${utilization}% \n  `;\n}\n\n// --- UI event hookups ---\nUI.addProcessBtn.onclick = ()=> addProcessFromInputs();\nUI.presetBtn.onclick = ()=> {\n  // load a preset scenario with IO bursts\n  state.processes = [];\n  state.lastPid = 0;\n  const preset = [\n    {name:'P1', arrival:0, cpu:[5,3], io:[4], priority:2},\n    {name:'P2', arrival:2, cpu:[3], io:[], priority:1},\n    {name:'P3', arrival:4, cpu:[2,2,3], io:[3,2], priority:3},\n    {name:'P4', arrival:6, cpu:[4], io:[], priority:2},\n  ];\n  preset.forEach(x=>{\n    const p={ id: makePid(), name:x.name, arrival:x.arrival, cpuBursts:x.cpu.slice(), ioBursts:x.io.slice(), curBurstIndex:0, remainingCpu:x.cpu[0], remainingIo:0, priority:x.priority, state:'new', firstResponseTime:null, finishTime:null, waitingTime:0, started:false, rrQuota:0 };\n    state.processes.push(p);\n  });\n  state.time = 0;\n  state.gantt = [];\n  state.log = [];\n  state.history = [];\n  state.running = null;\n  state.lastPid = state.processes.length;\n  refreshAll();\n  logEvent('Loaded preset scenario');\n};\nUI.randomBtn.onclick = ()=> {\n  const count = parseInt(prompt('Number of processes', '6')) || 6;\n  const maxArrival = parseInt(prompt('Max arrival time', '8')) || 8;\n  const maxBurst = parseInt(prompt('Max CPU burst', '8')) || 8;\n  // clear and generate\n  state.processes = [];\n  state.lastPid = 0;\n  for (let i=0;i<count;i++){\n    const cpuCount = Math.random() < 0.3 ? 2 : 1;\n    const cpuBursts = [];\n    const ioBursts = [];\n    for (let j=0;j<cpuCount;j++){\n      cpuBursts.push(1 + Math.floor(Math.random()*maxBurst));\n      if (j < cpuCount-1) ioBursts.push(1 + Math.floor(Math.random()*maxBurst));\n    }\n    const p = { id: makePid(), name:'P' + (i+1), arrival: Math.floor(Math.random()*(maxArrival+1)), cpuBursts, ioBursts, curBurstIndex:0, remainingCpu:cpuBursts[0], remainingIo:0, priority: 1 + Math.floor(Math.random()*5), state:'new', firstResponseTime:null, finishTime:null, waitingTime:0, started:false, rrQuota:0 };\n    state.processes.push(p);\n  }\n  state.time = 0; state.gantt = []; state.log = []; state.history=[];\n  refreshAll();\n  logEvent('Generated random scenario with ' + count + ' processes');\n};\nUI.importBtn.onclick = ()=> {\n  const txt = UI.scenarioJson.value.trim();\n  if (!txt) { alert('Paste JSON into Scenario text area first'); return; }\n  try {\n    const s = JSON.parse(txt);\n    if (Array.isArray(s)){\n      state.processes = [];\n      state.lastPid = 0;\n      s.forEach(x=>{\n        const p = {\n          id: x.id || makePid(),\n          name: x.name || x.id || 'P?',\n          arrival: x.arrival || 0,\n          cpuBursts: x.cpuBursts || [1],\n          ioBursts: x.ioBursts || [],\n          curBurstIndex: x.curBurstIndex || 0,\n          remainingCpu: (x.remainingCpu != null) ? x.remainingCpu : (x.cpuBursts ? x.cpuBursts[0] : 1),\n          remainingIo: x.remainingIo || 0,\n          priority: x.priority || 0,\n          state: x.state || 'new',\n          firstResponseTime: x.firstResponseTime || null,\n          finishTime: x.finishTime || null,\n          waitingTime: x.waitingTime || 0,\n          started: x.started || false,\n          rrQuota: x.rrQuota || 0\n        };\n        state.processes.push(p);\n        const idNum = parseInt(p.id.replace(/\\D/g,'')) || 0;\n        if (idNum > state.lastPid) state.lastPid = idNum;\n      });\n      state.time = 0; state.gantt = []; state.log = []; state.history=[];\n      refreshAll();\n      logEvent('Imported scenario with ' + state.processes.length + ' processes');\n    } else {\n      alert('JSON should be an array of process objects');\n    }\n  } catch (err){\n    alert('Invalid JSON: ' + err.message);\n  }\n};\nUI.exportBtn.onclick = ()=> {\n  const exportData = state.processes.map(p=>{\n    return {\n      id: p.id, name: p.name, arrival: p.arrival, cpuBursts: p.cpuBursts, ioBursts: p.ioBursts, priority: p.priority, state: p.state\n    };\n  });\n  UI.scenarioJson.value = JSON.stringify(exportData, null, 2);\n  logEvent('Exported scenario JSON to text area');\n};\n\nUI.startBtn.onclick = ()=>{\n  if (state.runningInterval) return;\n  state.autoRun = true;\n  const ms = parseInt(UI.speed.value) || 500;\n  state.runningInterval = setInterval(()=> {\n    stepOneUnit();\n    // stop if nothing left to run\n    if (!state.processes.some(p=>p.state !== 'terminated') && state.csTimer <= 0 && !state.running){\n      clearInterval(state.runningInterval); state.runningInterval = null; state.autoRun = false;\n      logEvent('Run complete');\n    }\n  }, ms);\n  logEvent('Started running (play)');\n};\nUI.pauseBtn.onclick = ()=>{\n  if (state.runningInterval){\n    clearInterval(state.runningInterval); state.runningInterval = null; state.autoRun = false;\n    logEvent('Paused');\n  }\n};\nUI.stepForwardBtn.onclick = ()=> { stepOneUnit(); };\nUI.stepBackBtn.onclick = ()=> {\n  const ok = restoreSnapshot();\n  if (ok) logEvent('Stepped back');\n  else logEvent('No history to step back');\n};\nUI.resetBtn.onclick = ()=> {\n  if (!confirm('Reset simulation? This will clear timeline and set time to 0 but keep processes (states reset).')) return;\n  state.time = 0;\n  state.gantt = [];\n  state.log = [];\n  state.history = [];\n  state.running = null;\n  state.csTimer = 0;\n  state.rrQueue = [];\n  state.processes.forEach(p=>{\n    p.curBurstIndex = 0;\n    p.remainingCpu = p.cpuBursts[0];\n    p.remainingIo = 0;\n    p.state = 'new';\n    p.firstResponseTime = null;\n    p.finishTime = null;\n    p.waitingTime = 0;\n    p.started = false;\n    p.rrQuota = 0;\n  });\n  refreshAll();\n  logEvent('Simulation reset');\n};\nUI.fastForwardBtn.onclick = ()=> { fastRunToCompletion(); refreshAll(); };\nUI.clearLogBtn.onclick = ()=> { state.log=[]; UI.log.value=''; };\n\nUI.quantum.oninput = ()=> { UI.quantumVal.textContent = UI.quantum.value; };\nUI.speed.oninput = ()=> { UI.speedVal.textContent = UI.speed.value + 'ms'; };\n\nUI.assignCpuBtn.onclick = ()=> {\n  const pid = UI.manualReady.value;\n  if (!pid) { alert('Choose a ready process from the dropdown'); return; }\n  // assign for one time slice (user can press step to run)\n  const p = state.processes.find(x=>x.id===pid);\n  if (!p) return;\n  state.running = p.id;\n  p.state = 'running';\n  logEvent('Manual: assigned ' + p.name + ' to CPU');\n  refreshAll();\n};\nUI.forceSwitchBtn.onclick = ()=> {\n  if (state.running){\n    const rp = state.processes.find(p=>p.id===state.running);\n    if (rp){\n      rp.state = 'ready';\n      logEvent('Force switching out ' + rp.name);\n    }\n  }\n  state.running = null;\n  const cost = parseInt(UI.contextCost.value)||0;\n  if (cost>0) state.csTimer = cost;\n  refreshAll();\n};\n\nUI.copyLogBtn.onclick = ()=> {\n  UI.log.select();\n  document.execCommand('copy');\n  alert('Log copied to clipboard');\n};\n\nUI.loadScenarioBtn.onclick = ()=> {\n  UI.importBtn.onclick();\n};\nUI.saveScenarioBtn.onclick = ()=> {\n  UI.exportBtn.onclick();\n};\n\n// manual-ready dropdown refresh\nfunction refreshManualReadySelect(){\n  UI.manualReady.innerHTML = '';\n  const ready = getReadyQueueAtTime(state.time);\n  ready.forEach(p=>{\n    const opt = document.createElement('option');\n    opt.value = p.id; opt.textContent = p.name + ' (remCpu=' + p.remainingCpu + ')';\n    UI.manualReady.appendChild(opt);\n  });\n}\n\n// Copy log quickly on some button\nUI.clearLogBtnEl.onclick = ()=> { state.log=[]; UI.log.value=''; };\n\n// --- Scenario import/export using scenarioJson area -> simple save/load ---\nUI.scenarioJson.value = '';\n\n\n// Initialize with an empty scenario\nrefreshAll();\n\n// Expose debug functions in window for advanced exploration (user may open dev console)\nwindow.__sim = {\n  state, stepOneUnit, fastRunToCompletion, pickNextProcess, snapshotState, restoreSnapshot\n};\n\nlogEvent('Simulator ready. Add processes and use controls to simulate CPU scheduling.');\n\n})(); // end closure\n</script>\n\n</body>\n</html>"
