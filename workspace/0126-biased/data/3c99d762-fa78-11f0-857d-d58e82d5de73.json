    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>TCP/IP Concept - Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');\n\n  /* Root and base */\n  :root {\n    --clr-primary: #1E88E5;\n    --clr-primary-light: #42A5F5;\n    --clr-primary-dark: #1565C0;\n\n    --clr-secondary: #00C49A;\n    --clr-secondary-dark: #00875A;\n    --clr-secondary-light: #33D6B1;\n\n    --clr-bg: #0F131A;\n    --clr-bg-light: #1A1F29;\n    --clr-text-primary: #E0E6F0;\n    --clr-text-secondary: #9AA6BC;\n\n    --animation-duration: 4s;\n    --border-radius: 1rem;\n    --font-base: 'Inter', system-ui, sans-serif;\n  }\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0F131A 0%, #151B26 100%);\n    color: var(--clr-text-primary);\n    font-family: var(--font-base);\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    min-height: 100vh;\n    padding: 2rem 1rem 4rem;\n  }\n\n  h1 {\n    font-weight: 900;\n    font-size: 3.25rem;\n    letter-spacing: 0.04em;\n    margin-bottom: 0.25rem;\n    color: var(--clr-primary);\n    text-align: center;\n    text-shadow: 0 0 15px var(--clr-primary-light);\n    user-select: none;\n  }\n\n  h2 {\n    font-weight: 700;\n    font-size: 1.25rem;\n    color: var(--clr-secondary-light);\n    margin: 0 0 2rem 0;\n    text-align: center;\n    user-select: none;\n  }\n\n  p.description {\n    max-width: 600px;\n    color: var(--clr-text-secondary);\n    text-align: center;\n    line-height: 1.5;\n    font-weight: 400;\n    font-size: 1.1rem;\n    margin-bottom: 3.5rem;\n    user-select: none;\n  }\n\n  /* Container holding visualization */\n  .visual-container {\n    position: relative;\n    width: 900px;\n    max-width: 95vw;\n    height: 580px;\n    background: linear-gradient(135deg, #1A2240, #101623);\n    border-radius: var(--border-radius);\n    box-shadow:\n      0 10px 30px rgba(30,136,229,0.3),\n      inset 0 0 40px rgba(33,42,70,0.7);\n    overflow: visible;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n  }\n\n  /* The layered TCP/IP stacks */\n  .stack {\n    position: relative;\n    width: 260px;\n    height: 440px;\n    background: #222a40;\n    border-radius: 1.25rem;\n    box-shadow:\n      0 0 30px rgba(30,136,229,0.6),\n      inset 0 0 15px rgba(30,136,229,0.4);\n    display: flex;\n    flex-direction: column;\n    justify-content: space-evenly;\n    padding: 1.75rem;\n    user-select: none;\n    transition: box-shadow 0.3s ease;\n  }\n\n  .stack.tcp {\n    margin-right: 4rem;\n    background: #133f6b;\n    box-shadow:\n      0 0 35px rgba(30,136,229,0.8),\n      inset 0 0 18px rgba(21,42,75,0.85);\n  }\n\n  .stack.ip {\n    background: #005259;\n    box-shadow:\n      0 0 35px rgba(0,196,154,0.9),\n      inset 0 0 18px rgba(0,100,88,0.85);\n  }\n\n  .stack h3 {\n    color: var(--clr-text-primary);\n    font-weight: 800;\n    font-size: 1.6rem;\n    margin-bottom: 1.4rem;\n    letter-spacing: 0.04em;\n    text-align: center;\n    text-shadow:\n      0 0 8px rgba(255 255 255 / 0.09),\n      0 0 16px rgba(0 196 154 / 0.6);\n  }\n\n  /* Individual layer boxes */\n  .layer {\n    background: linear-gradient(135deg, #1e293b, #274262);\n    border-radius: 1rem;\n    padding: 12px 20px;\n    margin: 9px 0;\n    box-shadow:\n      inset 0 0 12px rgba(255 255 255 / 0.13),\n      0 0 10px rgba(0,196,154,0.25);\n    color: #a4d8cb;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.02em;\n    user-select: none;\n    position: relative;\n    overflow: visible;\n  }\n\n  .layer::before {\n    content: \"\";\n    position: absolute;\n    left: -16px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 14px;\n    height: 14px;\n    background: linear-gradient(135deg, #00C49A 0%, #00875A 100%);\n    border-radius: 50%;\n    box-shadow:\n      0 0 12px #00c49a,\n      inset 0 0 8px #00c49a;\n  }\n\n  /* Connecting network wires (lines) */\n  svg.connector {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 420px;\n    height: 280px;\n    transform: translate(-50%, -50%);\n    overflow: visible;\n    pointer-events: none;\n    user-select: none;\n    filter: drop-shadow(0 0 3px rgba(30,136,229,0.4));\n  }\n\n  /* Glowing circles representing packets */\n  .packet {\n    position: absolute;\n    border-radius: 50%;\n    background: var(--clr-primary-light);\n    box-shadow:\n      0 0 12px var(--clr-primary-light),\n      inset 0 0 8px #7ec8ff;\n    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  /* Animations for packet movement on paths */\n  @keyframes packetFlow1 {\n    0% {\n      offset-distance: 0%;\n      opacity: 1;\n      transform: scale(0.75);\n    }\n    50% {\n      opacity: 1;\n      transform: scale(1.1);\n    }\n    100% {\n      offset-distance: 100%;\n      opacity: 0;\n      transform: scale(0.75);\n    }\n  }\n  @keyframes packetFlow2 {\n    0% {\n      offset-distance: 0%;\n      opacity: 1;\n      transform: scale(0.75);\n    }\n    50% {\n      opacity: 1;\n      transform: scale(1.1);\n    }\n    100% {\n      offset-distance: 100%;\n      opacity: 0;\n      transform: scale(0.75);\n    }\n  }\n\n  /* Packet blob sizes */\n  .packet.tcp {\n    width: 18px;\n    height: 18px;\n    animation: packetFlow1 var(--animation-duration) linear infinite;\n    offset-path: path(\"M20 380 C180 100 300 230 380 160\");\n  }\n\n  .packet.ip {\n    width: 14px;\n    height: 14px;\n    background: var(--clr-secondary-light);\n    box-shadow:\n      0 0 14px var(--clr-secondary-light),\n      inset 0 0 8px #4cf4c2;\n    animation: packetFlow2 var(--animation-duration) linear infinite;\n    animation-delay: 2s;\n    offset-path: path(\"M390 130 C420 230 490 180 560 330\");\n  }\n\n  /* Layer descriptions on hover minor highlight */\n  .layer:hover {\n    box-shadow:\n      inset 0 0 16px #77e1cb,\n      0 0 16px rgba(0,196,154,0.6);\n    cursor: default;\n  }\n\n  /* Footer with button */\n  footer {\n    margin-top: 3rem;\n    user-select: none;\n  }\n\n  button {\n    background: linear-gradient(135deg, var(--clr-primary-light), var(--clr-primary));\n    border: none;\n    padding: 0.8rem 2.5rem;\n    border-radius: 2rem;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    font-size: 1rem;\n    color: white;\n    cursor: pointer;\n    box-shadow:\n      0 6px 20px rgba(66,165,245,0.5);\n    transition: background 0.3s ease, box-shadow 0.3s ease, transform 0.15s ease;\n    user-select: none;\n  }\n\n  button:hover {\n    background: linear-gradient(135deg, var(--clr-primary-dark), var(--clr-primary));\n    box-shadow:\n      0 10px 30px rgba(30,136,229,0.85);\n    transform: translateY(-2px);\n  }\n\n  button:active {\n    transform: translateY(0);\n    box-shadow: 0 4px 15px rgba(30,136,229,0.7);\n  }\n\n  /* Tooltip style */\n  .tooltip {\n    position: absolute;\n    background: rgba(33, 42, 70, 0.9);\n    color: #a4d8cb;\n    padding: 0.35rem 0.75rem;\n    font-size: 0.85rem;\n    border-radius: 0.7rem;\n    pointer-events: none;\n    user-select: none;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    white-space: nowrap;\n    z-index: 9999;\n  }\n\n  .tooltip.visible {\n    opacity: 1;\n  }\n\n</style>\n</head>\n<body>\n\n<h1>TCP/IP Stack</h1>\n<h2>A Visual Exploration of Core Networking Protocol Layers</h2>\n<p class=\"description\">\n  The TCP/IP suite is the fundamental communication protocol for the internet, enabling devices to exchange data efficiently and reliably. This visualization highlights the two key stacks – TCP and IP – showing their primary layers and packet flows.\n</p>\n\n<div class=\"visual-container\" aria-label=\"TCP and IP protocol stack visualization\" role=\"img\" aria-describedby=\"desc\">\n  <div class=\"stack tcp\" aria-label=\"TCP Stack\">\n    <h3>TCP Stack</h3>\n    <div class=\"layer\" data-tooltip=\"Application Layer: Interfaces with software applications\">Application</div>\n    <div class=\"layer\" data-tooltip=\"Transport Layer: TCP manages reliable data transmission\">Transport (TCP)</div>\n    <div class=\"layer\" data-tooltip=\"Network Layer: IP handles routing and addressing\">Network (IP)</div>\n    <div class=\"layer\" data-tooltip=\"Data Link Layer: Framing and error detection\">Data Link</div>\n    <div class=\"layer\" data-tooltip=\"Physical Layer: Physical transmission of bits\">Physical</div>\n  </div>\n\n  <svg class=\"connector\" width=\"420\" height=\"280\" aria-hidden=\"true\" focusable=\"false\" >\n    <defs>\n      <linearGradient id=\"gradTCP\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n        <stop offset=\"0%\" stop-color=\"#42A5F5\" stop-opacity=\"0.8\"/>\n        <stop offset=\"100%\" stop-color=\"#1565C0\" stop-opacity=\"0.2\"/>\n      </linearGradient>\n      <linearGradient id=\"gradIP\" x1=\"1\" y1=\"0\" x2=\"0\" y2=\"1\">\n        <stop offset=\"0%\" stop-color=\"#33D6B1\" stop-opacity=\"0.85\"/>\n        <stop offset=\"100%\" stop-color=\"#00875A\" stop-opacity=\"0.3\"/>\n      </linearGradient>\n    </defs>\n    <!-- Blue tcp flow curve -->\n    <path id=\"pathTCP\" d=\"M20 380 C180 100 300 230 380 160\" stroke=\"url(#gradTCP)\" stroke-width=\"5\" fill=\"none\" filter=\"drop-shadow(0 0 15px #42A5F5)\" />\n    <!-- Green ip flow curve -->\n    <path id=\"pathIP\" d=\"M390 130 C420 230 490 180 560 330\" stroke=\"url(#gradIP)\" stroke-width=\"5\" fill=\"none\" filter=\"drop-shadow(0 0 20px #33D6B1)\" />\n  </svg>\n\n  <!-- Animated packets following the paths -->\n  <div class=\"packet tcp\" aria-label=\"TCP Packet\"></div>\n  <div class=\"packet ip\" aria-label=\"IP Packet\"></div>\n</div>\n\n<footer>\n  <button id=\"toggleAnimationBtn\" aria-pressed=\"true\" aria-label=\"Pause or resume packet flow animations\">Pause Animation</button>\n</footer>\n\n<!-- Tooltip container -->\n<div class=\"tooltip\" role=\"tooltip\" id=\"tooltip\"></div>\n\n<script>\n  // Tooltip on layers showing brief descriptions\n  const layers = document.querySelectorAll('.layer[data-tooltip]');\n  const tooltip = document.getElementById('tooltip');\n\n  let tooltipTimeout;\n\n  layers.forEach(layer => {\n    layer.addEventListener('mouseenter', (e) => {\n      clearTimeout(tooltipTimeout);\n      const text = layer.getAttribute('data-tooltip');\n      tooltip.textContent = text;\n      tooltip.classList.add('visible');\n      positionTooltip(e);\n    });\n    layer.addEventListener('mousemove', positionTooltip);\n    layer.addEventListener('mouseleave', () => {\n      tooltipTimeout = setTimeout(() => {\n        tooltip.classList.remove('visible');\n      }, 200);\n    });\n  });\n\n  function positionTooltip(event) {\n    tooltip.style.top = (event.clientY + 20) + 'px';\n    let leftPos = event.clientX + 20;\n    // Prevent overflow right\n    if (leftPos + tooltip.offsetWidth > window.innerWidth) {\n      leftPos = event.clientX - tooltip.offsetWidth - 20;\n    }\n    tooltip.style.left = leftPos + 'px';\n  }\n\n  // Animation toggle button\n  const toggleBtn = document.getElementById('toggleAnimationBtn');\n  const packets = document.querySelectorAll('.packet');\n\n  toggleBtn.addEventListener('click', () => {\n    const isPaused = toggleBtn.getAttribute('aria-pressed') === 'true';\n    if(isPaused) {\n      packets.forEach(p => p.style.animationPlayState = 'paused');\n      toggleBtn.textContent = 'Resume Animation';\n      toggleBtn.setAttribute('aria-pressed', 'false');\n      toggleBtn.setAttribute('aria-label', 'Resume packet flow animations');\n    } else {\n      packets.forEach(p => p.style.animationPlayState = 'running');\n      toggleBtn.textContent = 'Pause Animation';\n      toggleBtn.setAttribute('aria-pressed', 'true');\n      toggleBtn.setAttribute('aria-label', 'Pause packet flow animations');\n    }\n  });\n</script>\n\n</body>\n</html>"
