eIn 1s ease-out;\n        }\n        \n        .subtitle {\n            font-weight: 300;\n            color: white;\n            font-size: 1.2rem;\n            max-width: 700px;\n            margin: 0 auto;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 0.3s forwards;\n        }\n        \n        .multiset-display {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin: 4rem 0;\n        }\n        \n        .multiset-container {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n            gap: 1.5rem;\n            margin: 2rem 0;\n            perspective: 1000px;\n        }\n        \n        .multiset-element {\n            width: 100px;\n            height: 100px;\n            background: white;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: 700;\n            font-size: 1.5rem;\n            color: var(--dark);\n            box-shadow: 0 10px 20px rgba(0,0,0,0.1);\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .multiset-element::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: var(--gradient);\n            z-index: -1;\n            opacity: 0.2;\n            transform: rotate(45deg);\n            transition: transform 0.5s ease;\n        }\n        \n        .multiset-element:hover {\n            transform: translateY(-10px) scale(1.05);\n        }\n        \n        .multiset-element:hover::before {\n            transform: rotate(405deg);\n        }\n        \n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto;\n            background: white;\n            padding: 2.5rem;\n            border-radius: 15px;\n            box-shadow: 0 20px 40px rgba(0,0,0,0.05);\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .explanation::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            right: 0;\n            width: 100px;\n            height: 100px;\n            background: var(--gradient);\n            border-radius: 0 0 0 100%;\n            z-index: -1;\n            opacity: 0.2;\n        }\n        \n        h2 {\n            font-family: 'Playfair Display', serif;\n            color: var(--primary);\n            margin-bottom: 1.5rem;\n            font-size: 2rem;\n        }\n        \n        p {\n            margin-bottom: 1.5rem;\n            font-size: 1.1rem;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1.5rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            padding: 0.8rem 1.8rem;\n            border: none;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 500;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .btn-primary {\n            background: var(--primary);\n            color: white;\n            box-shadow: 0 5px 15px rgba(108, 99, 255, 0.4);\n        }\n        \n        .btn-secondary {\n            background: transparent;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n        }\n        \n        button::after {\n            content: '';\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 5px;\n            height: 5px;\n            background: rgba(255,255,255,0.5);\n            opacity: 0;\n            border-radius: 100%;\n            transform: scale(1, 1) translate(-50%);\n            transform-origin: 50% 50%;\n        }\n        \n        button:focus:not(:active)::after {\n            animation: ripple 1s ease-out;\n        }\n        \n        footer {\n            text-align: center;\n            padding: 2rem;\n            margin-top: auto;\n            color: var(--dark);\n            font-size: 0.9rem;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes ripple {\n            0% {\n                transform: scale(0, 0);\n                opacity: 1;\n            }\n            100% {\n                transform: scale(20, 20);\n                opacity: 0;\n            }\n        }\n        \n        .highlight {\n            color: var(--primary);\n            font-weight: 700;\n        }\n        \n        .card-container {\n            display: flex;\n            justify-content: space-around;\n            flex-wrap: wrap;\n            gap: 2rem;\n            margin: 3rem 0;\n        }\n        \n        .card {\n            background: white;\n            border-radius: 15px;\n            padding: 2rem;\n            width: 280px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.05);\n            transition: all 0.3s ease;\n        }\n        \n        .card:hover {\n            transform: translateY(-10px);\n            box-shadow: 0 15px 35px rgba(0,0,0,0.1);\n        }\n        \n        .card h3 {\n            color: var(--accent);\n            margin-bottom: 1rem;\n            font-family: 'Playfair Display', serif;\n        }\n        \n        .card-icon {\n            font-size: 2.5rem;\n            color: var(--primary);\n            margin-bottom: 1rem;\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .multiset-element {\n                width: 80px;\n                height: 80px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <div class=\"container\">\n            <h1>Multisets</h1>\n            <p class=\"subtitle\">An elegant generalization of the concept of a set that allows for multiple instances of its elements</p>\n        </div>\n    </header>\n    \n    <div class=\"container\">\n        <div class=\"multiset-display\">\n            <h2>Visualizing a Multiset</h2>\n            <p>Here's an example multiset containing elements with their multiplicities:</p>\n            \n            <div class=\"multiset-container\">\n                <div class=\"multiset-element\">A</div>\n                <div class=\"multiset-element\">A</div>\n                <div class=\"multiset-element\">B</div>\n                <div class=\"multiset-element\">C</div>\n                <div class=\"multiset-element\">C</div>\n                <div class=\"multiset-element\">C</div>\n            </div>\n            \n            <p>The same elements appear multiple times, representing distinct occurrences in the multiset.</p>\n            \n            <div class=\"controls\">\n                <button class=\"btn-primary\" id=\"animateBtn\">Animate</button>\n                <button class=\"btn-secondary\" id=\"resetBtn\">Reset</button>\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>What is a Multiset?</h2>\n            <p>A <span class=\"highlight\">multiset</span> (also called a bag) is a generalization of a set that allows for multiple instances of its elements. Unlike classical sets where each element appears exactly once, elements in a multiset can appear any number of times.</p>\n            \n            <p>The <span class=\"highlight\">multiplicity</span> of an element is the number of times it appears in the multiset. For example, in our visualization above, element \"A\" has multiplicity 2, \"B\" has multiplicity 1, and \"C\" has multiplicity 3.</p>\n            \n            <p>Multisets are used in many areas of mathematics and computer science, including combinatorics, database theory, and graph theory.</p>\n        </div>\n        \n        <div class=\"card-container\">\n            <div class=\"card\">\n                <div class=\"card-icon\">🔢</div>\n                <h3>Cardinality</h3>\n                <p>The cardinality of a multiset is the sum of the multiplicities of all its elements, representing the total number of element occurrences.</p>\n            </div>\n            \n            <div class=\"card\">\n                <div class=\"card-icon\">➕</div>\n                <h3>Operations</h3>\n                <p>Multisets support operations like union, intersection, and sum, each handling multiplicities in specific ways while combining multisets.</p>\n            </div>\n            \n            <div class=\"card\">\n                <div class=\"card-icon\">🔄</div>\n                <h3>Applications</h3>\n                <p>Used in combinatorics, database systems (as bags), network packet counting, and anywhere multiple instances of elements matter.</p>\n            </div>\n        </div>\n    </div>\n    \n    <footer>\n        <div class=\"container\">\n            <p>An interactive visualization of multiset concepts | Designed with elegance in mind</p>\n        </div>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const elements = document.querySelectorAll('.multiset-element');\n            const animateBtn = document.getElementById('animateBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            // Initial animation\n            setTimeout(() => {\n                elements.forEach((el, index) => {\n                    setTimeout(() => {\n                        el.style.animation = 'fadeIn 0.5s ease-out forwards';\n                    }, index * 100);\n                });\n            }, 500);\n            \n            // Animate button effect\n            animateBtn.addEventListener('click', function() {\n                elements.forEach((el, index) => {\n                    el.style.transform = 'translateY(-20px) scale(1.1)';\n                    el.style.boxShadow = '0 15px 30px rgba(0,0,0,0.15)';\n                    \n                    setTimeout(() => {\n                        el.style.transform = 'translateY(0) scale(1)';\n                        el.style.boxShadow = '0 10px 20px rgba(0,0,0,0.1)';\n                    }, 500 + index * 100);\n                });\n            });\n            \n            // Reset button effect\n            resetBtn.addEventListener('click', function() {\n                elements.forEach(el => {\n                    el.style.transform = '';\n                    el.style.boxShadow = '';\n                });\n            });\n            \n            // Ripple effect for buttons\n            const buttons = document.querySelectorAll('button');\n            buttons.forEach(button => {\n                button.addEventListener('click', function(e) {\n                    e.preventDefault();\n                    \n                    const rect = button.getBoundingClientRect();\n                    const x = e.clientX - rect.left;\n                    const y = e.clientY - rect.top;\n                    \n                    const ripple = document.createElement('span');\n                    ripple.className = 'ripple';\n                    ripple.style.left = x + 'px';\n                    ripple.style.top = y + 'px';\n                    \n                    this.appendChild(ripple);\n                    \n                    setTimeout(() => {\n                        ripple.remove();\n                    }, 600);\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
