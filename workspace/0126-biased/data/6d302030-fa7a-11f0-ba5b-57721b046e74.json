  "question": "Context Switching",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Context Switching Simulator</title>\n    <style>\n        body {\n            font-family: Arial, margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-bottom: 20px;\n        }\n        .task {\n            margin: 10px 0;\n            padding: 10px;\n            border: 1px solid #eee;\n        }\n        button, select, input {\n            margin: 5px;\n        }\n        .hidden {\n            display: none;\n        }\n        .active {\n            background-color: #f0f0f0;\n        }\n        .stats {\n            position: fixed;\n            top: 10px;\n            right: 10px;\n            border: 1px solid #000;\n            padding: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Context Switching Simulator</h1>\n    <div class=\"stats\">\n        <div>Switches: <span id=\"switchCount\">0</span></div>\n        <div>Time Lost: <span id=\"timeLost\">0</span>s</div>\n        <div>Current Context: <span id=\"currentContext\">None</span></div>\n    </div>\n\n    <div class=\"container\">\n        <h2>Task Manager</h2>\n        <div>\n            <input type=\"text\" id=\"newTask\" placeholder=\"New task name\">\n            <button onclick=\"addTask()\">Add Task</button>\n            <select id=\"taskPriority\">\n                <option value=\"1\">Low</option>\n                <option value=\"2\" selected>Medium</option>\n                <option value=\"3\">High</option>\n            </select>\n        </div>\n        <div id=\"taskList\"></div>\n    </div>\n\n    <div class=\"container\">\n        <h2>Context Controls</h2>\n        <div>\n            <label>Switch Cost (seconds): </label>\n            <input type=\"range\" id=\"switchCost\" min=\"1\" max=\"30\" value=\"5\" oninput=\"updateSwitchCost()\">\n            <span id=\"costValue\">5</span>\n        </div>\n        <div>\n            <button onclick=\"simulateInterruption()\">Simulate Interruption</button>\n            <button onclick=\"forceSwitch()\">Force Context Switch</button>\n        </div>\n        <div>\n            <label>Interruption Frequency (seconds): </label>\n            <input type=\"range\" id=\"interruptFreq\" min=\"5\" max=\"120\" value=\"30\" oninput=\"updateInterruptFreq()\">\n            <span id=\"freqValue\">30</span>\n        </div>\n    </div>\n\n    <div class=\"container\">\n        <h2>Work Simulation</h2>\n        <div>\n            <button onclick=\"startWork()\">Start Working</button>\n            <button onclick=\"pauseWork()\">Pause</button>\n            <button onclick=\"resetAll()\">Reset All</button>\n        </div>\n        <div id=\"workLog\"></div>\n    </div>\n\n    <div class=\"container\">\n        <h2>Context Explorer</h2>\n        <div>\n            <button onclick=\"showContextDetails()\">Show Current Context Details</button>\n            <button onclick=\"showAllTasks()\">Show All Tasks</button>\n        </div>\n        <div id=\"contextDetails\" class=\"hidden\">\n            <h3>Context Details</h3>\n            <div id=\"detailsContent\"></div>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let tasks = [];\n        let currentTask = null;\n        let switchCount = 0;\n        let timeLost = 0;\n        let switchCost = 5;\n        let interruptInterval;\n        let interruptFreq = 30;\n        let workInterval;\n        let isWorking = false;\n        let contextStack = [];\n        let startTime = null;\n\n        // DOM elements\n        const taskListEl = document.getElementById('taskList');\n        const switchCountEl = document.getElementById('switchCount');\n        const timeLostEl = document.getElementById('timeLost');\n        const currentContextEl = document.getElementById('currentContext');\n        const workLogEl = document.getElementById('workLog');\n        const costValueEl = document.getElementById('costValue');\n        const freqValueEl = document.getElementById('freqValue');\n        const contextDetailsEl = document.getElementById('contextDetails');\n        const detailsContentEl = document.getElementById('detailsContent');\n\n        // Functions\n        function addTask() {\n            const name = document.getElementById('newTask').value;\n            const priority = parseInt(document.getElementById('taskPriority').value);\n            if (!name) return;\n            \n            const task = {\n                id: Date.now(),\n                name,\n                priority,\n                timeSpent: 0,\n                completed: false,\n                context: {\n                    memory: Math.random().toFixed(2),\n                    focus: Math.random().toFixed(2),\n                    state: 'New task state ' + Math.floor(Math.random() * 100)\n                }\n            };\n            \n            tasks.push(task);\n            renderTasks();\n            document.getElementById('newTask').value = '';\n        }\n\n        function renderTasks() {\n            taskListEl.innerHTML = '';\n            tasks.forEach(task => {\n                const taskEl = document.createElement('div');\n                taskEl.className = `task ${currentTask?.id === task.id ? 'active' : ''}`;\n                taskEl.innerHTML = `\n                    <h3>${task.name} (Priority: ${task.priority})</h3>\n                    <p>Time spent: ${task.timeSpent}s</p>\n                    <p>Status: ${task.completed ? 'Completed' : 'Pending'}</p>\n                    <button onclick=\"switchToTask(${task.id})\">Switch to this task</button>\n                    <button onclick=\"completeTask(${task.id})\">Complete</button>\n                    <button onclick=\"deleteTask(${task.id})\">Delete</button>\n                `;\n                taskListEl.appendChild(taskEl);\n            });\n        }\n\n        function switchToTask(taskId) {\n            if (isWorking) {\n                logWorkEvent(`Interrupted while working on ${currentTask?.name || 'nothing'}`);\n                pauseWork();\n            }\n\n            const task = tasks.find(t => t.id === taskId);\n            if (!task) return;\n\n            if (currentTask) {\n                // Save current context\n                contextStack.push({\n                    task: currentTask,\n                    time: Date.now()\n                });\n                timeLost += switchCost;\n                switchCount++;\n                logWorkEvent(`Switched from ${currentTask.name} to ${task.name} (Cost: ${switchCost}s)`);\n            } else {\n                logWorkEvent(`Started working on ${task.name}`);\n            }\n\n            currentTask = task;\n            currentContextEl.textContent = task.name;\n            switchCountEl.textContent = switchCount;\n            timeLostEl.textContent = timeLost;\n            renderTasks();\n        }\n\n        function completeTask(taskId) {\n            const task = tasks.find(t => t.id === taskId);\n            if (!task) return;\n            \n            task.completed = true;\n            if (currentTask?.id === taskId) {\n                currentTask = null;\n                currentContextEl.textContent = 'None';\n            }\n            renderTasks();\n            logWorkEvent(`Completed task: ${task.name}`);\n        }\n\n        function deleteTask(taskId) {\n            tasks = tasks.filter(t => t.id !== taskId);\n            if (currentTask?.id === taskId) {\n                currentTask = null;\n                currentContextEl.textContent = 'None';\n            }\n            renderTasks();\n        }\n\n        function updateSwitchCost() {\n            switchCost = parseInt(document.getElementById('switchCost').value);\n            costValueEl.textContent = switchCost;\n        }\n\n        function updateInterruptFreq() {\n            interruptFreq = parseInt(document.getElementById('interruptFreq').value);\n            freqValueEl.textContent = interruptFreq;\n            if (interruptInterval) {\n                clearInterval(interruptInterval);\n                startInterruptions();\n            }\n        }\n\n        function startInterruptions() {\n            interruptInterval = setInterval(() => {\n                if (isWorking && currentTask && Math.random() > 0.3) {\n                    simulateInterruption();\n                }\n            }, interruptFreq * 1000);\n        }\n\n        function simulateInterruption() {\n            if (!currentTask) return;\n            \n            const availableTasks = tasks.filter(t => !t.completed && t.id !== currentTask.id);\n            if (availableTasks.length === 0) return;\n            \n            const randomTask = availableTasks[Math.floor(Math.random() * availableTasks.length)];\n            switchToTask(randomTask.id);\n        }\n\n        function forceSwitch() {\n            if (!currentTask) return;\n            simulateInterruption();\n        }\n\n        function startWork() {\n            if (isWorking) return;\n            \n            if (!currentTask) {\n                const availableTasks = tasks.filter(t => !t.completed);\n                if (availableTasks.length === 0) return;\n                switchToTask(availableTasks[0].id);\n            }\n            \n            isWorking = true;\n            startTime = Date.now();\n            workInterval = setInterval(updateWork, 1000);\n            startInterruptions();\n            logWorkEvent('Started working session');\n        }\n\n        function pauseWork() {\n            if (!isWorking) return;\n            \n            clearInterval(workInterval);\n            clearInterval(interruptInterval);\n            isWorking = false;\n            \n            if (currentTask) {\n                const workTime = Math.floor((Date.now() - startTime) / 1000);\n                currentTask.timeSpent += workTime;\n                logWorkEvent(`Paused working on ${currentTask.name} after ${workTime}s`);\n            }\n            \n            renderTasks();\n        }\n\n        function updateWork() {\n            if (!currentTask) {\n                pauseWork();\n                return;\n            }\n            \n            const workTime = Math.floor((Date.now() - startTime) / 1000);\n            currentTask.timeSpent += 1;\n            logWorkEvent(`Working on ${currentTask.name} (${workTime}s)`);\n            renderTasks();\n        }\n\n        function logWorkEvent(message) {\n            const now = new Date();\n            const timeStr = now.toLocaleTimeString();\n            const entry = document.createElement('div');\n            entry.textContent = `[${timeStr}] ${message}`;\n            workLogEl.prepend(entry);\n        }\n\n        function resetAll() {\n            pauseWork();\n            tasks = [];\n            currentTask = null;\n            switchCount = 0;\n            timeLost = 0;\n            contextStack = [];\n            switchCountEl.textContent = '0';\n            timeLostEl.textContent = '0';\n            currentContextEl.textContent = 'None';\n            workLogEl.innerHTML = '';\n            taskListEl.innerHTML = '';\n            contextDetailsEl.classList.add('hidden');\n        }\n\n        function showContextDetails() {\n            if (!currentTask) {\n                detailsContentEl.textContent = 'No active task';\n                contextDetailsEl.classList.remove('hidden');\n                return;\n            }\n            \n            detailsContentEl.innerHTML = `\n                <h4>${currentTask.name}</h4>\n                <p>Memory state: ${currentTask.context.memory}</p>\n                <p>Focus level: ${currentTask.context.focus}</p>\n                <p>Task state: ${currentTask.context.state}</p>\n                <p>Time spent: ${currentTask.timeSpent}s</p>\n                <h4>Context Stack</h4>\n                <ul>\n                    ${contextStack.map(ctx => \n                        `<li>${ctx.task.name} (switched ${Math.floor((Date.now() - ctx.time)/1000)}s ago)</li>`\n                    ).join('') || '<li>Empty</li>'}\n                </ul>\n            `;\n            contextDetailsEl.classList.remove('hidden');\n        }\n\n        function showAllTasks() {\n            detailsContentEl.innerHTML = `\n                <h4>All Tasks</h4>\n                <table border=\"1\">\n                    <tr>\n                        <th>Name</th>\n                        <th>Priority</th>\n                        <th>Time Spent</th>\n                        <th>Status</th>\n                        <th>Memory</th>\n                        <th>Focus</th>\n                    </tr>\n                    ${tasks.map(task => `\n                        <tr>\n                            <td>${task.name}</td>\n                            <td>${task.priority}</td>\n                            <td>${task.timeSpent}s</td>\n                            <td>${task.completed ? 'Completed' : 'Pending'}</td>\n                            <td>${task.context.memory}</td>\n                            <td>${task.context.focus}</td>\n                        </tr>\n                    `).join('')}\n                </table>\n            `;\n            contextDetailsEl.classList.remove('hidden');\n        }\n\n        // Initialize\n        updateSwitchCost();\n        updateInterruptFreq();\n    </script>\n</body>\n</html>"
  },
