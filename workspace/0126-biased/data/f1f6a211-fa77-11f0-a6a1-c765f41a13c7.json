    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>PageRank — Visual Demonstration</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071427;\n    --glass: rgba(255,255,255,0.04);\n    --accent: #6EE7B7;\n    --accent-2: #60A5FA;\n    --muted: rgba(255,255,255,0.65);\n    --glass-border: rgba(255,255,255,0.06);\n    --card-glow: rgba(96,165,250,0.12);\n    --soft: rgba(255,255,255,0.03);\n    --node-glow: rgba(110,231,183,0.14);\n  }\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(96,165,250,0.06), transparent 8%),\n                radial-gradient(1000px 600px at 90% 90%, rgba(110,231,183,0.04), transparent 8%),\n                linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n    color:#fff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  .stage {\n    position:relative;\n    height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n  }\n\n  .card {\n    width:1100px;\n    max-width:calc(100% - 96px);\n    height:720px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 20px 40px rgba(2,6,23,0.6), 0 8px 18px rgba(2,6,23,0.45);\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    overflow:hidden;\n    position:relative;\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n\n  /* subtle decorative shapes */\n  .card::before, .card::after{\n    content:\"\";\n    position:absolute;\n    border-radius:50%;\n    filter:blur(36px);\n    opacity:0.18;\n    pointer-events:none;\n  }\n  .card::before{\n    width:420px;height:420px;\n    right:-120px; top:-80px;\n    background: conic-gradient(from 180deg at 50% 50%, rgba(96,165,250,0.28), rgba(110,231,183,0.12));\n  }\n  .card::after{\n    width:340px;height:340px;\n    left:-120px; bottom:-120px;\n    background: radial-gradient(circle, rgba(255,255,255,0.02), transparent 40%);\n  }\n\n  /* left main visualization area */\n  .visual {\n    padding:32px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .canvas-wrap {\n    width:100%;\n    height:100%;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.02);\n    overflow:hidden;\n    position:relative;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  /* right panel */\n  .panel {\n    padding:28px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.006), rgba(255,255,255,0.01));\n    border-left:1px solid rgba(255,255,255,0.02);\n  }\n\n  .title {\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .logo {\n    width:56px;height:56px;\n    border-radius:12px;\n    display:flex;align-items:center;justify-content:center;\n    background:linear-gradient(135deg,var(--accent),var(--accent-2));\n    box-shadow: 0 8px 24px rgba(96,165,250,0.14), inset 0 -6px 10px rgba(255,255,255,0.06);\n    font-weight:700;\n    font-size:18px;\n    color:#04263a;\n  }\n  .h1 {\n    font-size:20px;\n    line-height:1;\n    font-weight:600;\n    letter-spacing:-0.02em;\n  }\n  .muted {\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.35;\n  }\n\n  .controls {\n    margin-top:8px;\n    display:flex;\n    gap:10px;\n  }\n\n  .btn {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    padding:10px 14px;\n    border-radius:10px;\n    color:var(--muted);\n    cursor:pointer;\n    font-weight:600;\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    transition: all 240ms cubic-bezier(.2,.9,.2,1);\n    backdrop-filter: blur(6px);\n  }\n  .btn:hover{\n    transform:translateY(-4px);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.5);\n    color:white;\n  }\n  .btn.play {\n    background: linear-gradient(90deg, rgba(110,231,183,0.12), rgba(96,165,250,0.08));\n    border:1px solid rgba(110,231,183,0.18);\n    color:white;\n  }\n\n  .legend {\n    margin-top:6px;\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.5;\n  }\n\n  .stats {\n    margin-top:12px;\n    display:flex;\n    gap:12px;\n    flex-wrap:wrap;\n  }\n  .stat {\n    flex:1 1 120px;\n    padding:12px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.004));\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .stat strong{\n    display:block;\n    font-size:18px;\n    color:white;\n  }\n  .stat span{\n    display:block;\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  .explain {\n    margin-top:8px;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.45;\n  }\n\n  /* subtle footer */\n  .credit {\n    margin-top:auto;\n    font-size:12px;\n    color:var(--muted);\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n  }\n\n  /* svg styling */\n  svg { width:100%; height:100%; display:block; }\n  .edge { fill:none; stroke-width:2.6; stroke-linecap:round; stroke-linejoin:round; mix-blend-mode:screen; opacity:0.95; transition: stroke-width 600ms ease, opacity 300ms ease; }\n  .edge-muted { opacity:0.35; }\n  .node {\n    cursor:default;\n    transition: transform 600ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease;\n    transform-origin:center center;\n  }\n  .node .circle {\n    transition: r 600ms cubic-bezier(.2,.9,.2,1), fill 600ms ease, filter 600ms ease;\n    stroke:rgba(255,255,255,0.06);\n    stroke-width:1;\n  }\n  .node .label {\n    font-weight:700;\n    font-size:13px;\n    fill:rgba(255,255,255,0.94);\n    pointer-events:none;\n    text-anchor:middle;\n    transition: transform 600ms ease, opacity 300ms ease;\n  }\n  .node .value {\n    font-weight:600;\n    font-size:12px;\n    fill:rgba(255,255,255,0.9);\n    pointer-events:none;\n    text-anchor:middle;\n    transition: transform 600ms ease, opacity 300ms ease;\n  }\n\n  .pulse {\n    filter: drop-shadow(0 6px 24px rgba(110,231,183,0.12));\n  }\n\n  /* small moving particles */\n  .particle { fill:rgba(255,255,255,0.9); opacity:0.92; }\n\n  /* responsive */\n  @media (max-width:1000px){\n    .card{ height:760px; grid-template-columns:1fr; grid-template-rows: 1fr 300px; width:calc(100% - 48px); }\n    .panel{ border-left:none; border-top:1px solid rgba(255,255,255,0.02); }\n  }\n\n  /* little micro-animations for delight */\n  .sparkle {\n    position:absolute;\n    right:28px;\n    top:28px;\n    width:96px;\n    height:64px;\n    background:linear-gradient(90deg, rgba(110,231,183,0.06), rgba(96,165,250,0.04));\n    border-radius:12px;\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    font-weight:600;\n    font-size:12px;\n    backdrop-filter: blur(6px);\n  }\n</style>\n</head>\n<body>\n<div class=\"stage\">\n  <div class=\"card\" role=\"main\" aria-label=\"PageRank Visual Demonstration\">\n    <div class=\"visual\">\n      <div class=\"canvas-wrap\" id=\"viz\">\n        <!-- Decorative corner label -->\n        <div style=\"position:absolute;left:26px;top:18px;color:rgba(255,255,255,0.9);font-weight:700;font-size:13px;\">PageRank • Flow Visualization</div>\n        <svg id=\"svg\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"g-edge-a\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#6EE7B7\" stop-opacity=\"0.98\"/>\n              <stop offset=\"1\" stop-color=\"#60A5FA\" stop-opacity=\"0.98\"/>\n            </linearGradient>\n            <radialGradient id=\"g-node\" cx=\"50%\" cy=\"30%\">\n              <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.9\" />\n              <stop offset=\"20%\" stop-color=\"#bfeee0\" stop-opacity=\"0.18\" />\n              <stop offset=\"100%\" stop-color=\"#062036\" stop-opacity=\"0.75\" />\n            </radialGradient>\n            <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"12\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n            <marker id=\"arrow\" markerWidth=\"8\" markerHeight=\"10\" refX=\"6\" refY=\"5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n              <path d=\"M0,0 L6,5 L0,10 L2,5 z\" fill=\"#9AD6FF\"></path>\n            </marker>\n          </defs>\n\n          <!-- Edges group -->\n          <g id=\"edges\"></g>\n\n          <!-- Particles group -->\n          <g id=\"particles\"></g>\n\n          <!-- Nodes group -->\n          <g id=\"nodes\">\n            <!-- nodes will be injected here -->\n          </g>\n\n        </svg>\n\n        <!-- subtle info overlay -->\n        <div style=\"position:absolute;left:26px;bottom:18px;color:var(--muted);font-size:12px;\">\n          Iterative ranking with damping factor — watch the ranks stabilize\n        </div>\n\n      </div>\n    </div>\n\n    <aside class=\"panel\" aria-hidden=\"false\">\n      <div class=\"title\">\n        <div class=\"logo\">PR</div>\n        <div>\n          <div class=\"h1\">PageRank • Elegant Visualization</div>\n          <div class=\"muted\">Directed graph with animated probability flow</div>\n        </div>\n      </div>\n\n      <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n        <button id=\"playBtn\" class=\"btn play\" title=\"Play / Pause animation\" aria-pressed=\"true\">Pause</button>\n        <button id=\"resetBtn\" class=\"btn\" title=\"Reset ranks\">Reset</button>\n      </div>\n\n      <div class=\"legend\">\n        • Nodes sized by PageRank value • Flow particles indicate probability mass moving along links\n      </div>\n\n      <div class=\"stats\" aria-hidden=\"true\">\n        <div class=\"stat\">\n          <strong id=\"iter\">Iter: 0</strong>\n          <span>Iterations</span>\n        </div>\n        <div class=\"stat\">\n          <strong id=\"damping\">0.85</strong>\n          <span>Damping factor (d)</span>\n        </div>\n        <div class=\"stat\">\n          <strong id=\"converge\">—</strong>\n          <span>Convergence Δ</span>\n        </div>\n      </div>\n\n      <div class=\"explain\">\n        PageRank assigns an importance score to each page based on the link structure.\n        At each iteration, rank flows from a node to its outlinks; the algorithm converges\n        when scores stabilize. Observe how node sizes and flow intensities settle over time.\n      </div>\n\n      <div class=\"credit\">\n        <div style=\"opacity:0.9\">Static graph • Minimal controls</div>\n        <div style=\"font-size:12px;color:var(--muted)\">Designed for clarity & beauty</div>\n      </div>\n    </aside>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Configuration\n  const damping = 0.85;\n  const nodesData = [\n    { id: 'A', x: 200, y: 140 },\n    { id: 'B', x: 420, y: 100 },\n    { id: 'C', x: 640, y: 140 },\n    { id: 'D', x: 360, y: 320 },\n    { id: 'E', x: 520, y: 340 },\n    { id: 'F', x: 700, y: 320 },\n    { id: 'G', x: 120, y: 360 }\n  ];\n\n  // Directed edges list\n  const edgesData = [\n    { from: 'A', to: 'B' },\n    { from: 'A', to: 'C' },\n\n    { from: 'B', to: 'C' },\n    { from: 'B', to: 'D' },\n\n    { from: 'C', to: 'A' },\n    { from: 'C', to: 'B' },\n    { from: 'C', to: 'D' },\n\n    { from: 'D', to: 'C' },\n    { from: 'D', to: 'E' },\n    { from: 'D', to: 'F' },\n\n    { from: 'E', to: 'F' },\n    { from: 'E', to: 'G' },\n\n    { from: 'F', to: 'E' },\n\n    { from: 'G', to: 'D' },\n  ];\n\n  const N = nodesData.length;\n  const svg = document.getElementById('svg');\n  const edgesGroup = document.getElementById('edges');\n  const nodesGroup = document.getElementById('nodes');\n  const particlesGroup = document.getElementById('particles');\n\n  // Build node map\n  const nodeMap = new Map();\n  nodesData.forEach(n => nodeMap.set(n.id, Object.assign({}, n, { out: [], in: [] })));\n\n  edgesData.forEach(e => {\n    const a = nodeMap.get(e.from);\n    const b = nodeMap.get(e.to);\n    if (a && b) {\n      a.out.push(b.id);\n      b.in.push(a.id);\n    }\n  });\n\n  // PageRank state\n  let ranks = {};\n  let iter = 0;\n  let animating = true;\n  let lastDelta = 0;\n  const particles = []; // moving particle objects\n\n  // Initialize ranks equal\n  function resetRanks(){\n    ranks = {};\n    nodesData.forEach(n => ranks[n.id] = 1 / N);\n    iter = 0;\n    lastDelta = 0;\n    document.getElementById('iter').textContent = iter;\n    document.getElementById('converge').textContent = '—';\n  }\n\n  resetRanks();\n\n  // Draw edges as curved paths\n  function pathFor(a,b){\n    const dx = b.x - a.x;\n    const dy = b.y - a.y;\n    const dr = Math.sqrt(dx*dx + dy*dy);\n    // create a gentle quadratic curve\n    const mx = (a.x + b.x) / 2 + (dy * 0.12);\n    const my = (a.y + b.y) / 2 - (dx * 0.12);\n    return `M ${a.x} ${a.y} Q ${mx} ${my} ${b.x} ${b.y}`;\n  }\n\n  // create edge elements\n  const edgeElements = [];\n  edgesData.forEach((e, idx) => {\n    const a = nodeMap.get(e.from);\n    const b = nodeMap.get(e.to);\n    const pathStr = pathFor(a,b);\n\n    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n    g.setAttribute('data-from', e.from);\n    g.setAttribute('data-to', e.to);\n\n    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n    path.setAttribute('d', pathStr);\n    path.setAttribute('class', 'edge');\n    path.setAttribute('stroke', 'url(#g-edge-a)');\n    path.setAttribute('marker-end', 'url(#arrow)');\n    path.setAttribute('stroke-opacity', '0.9');\n    path.setAttribute('id', `edge-${idx}`);\n\n    // for hover subtle highlight (not interactive heavily)\n    path.addEventListener('mouseenter', ()=> { path.setAttribute('stroke-opacity','1'); });\n    path.addEventListener('mouseleave', ()=> { path.setAttribute('stroke-opacity','0.9'); });\n\n    g.appendChild(path);\n    edgesGroup.appendChild(g);\n\n    edgeElements.push({ e, path, g });\n  });\n\n  // Create nodes\n  const nodeElems = new Map();\n  nodesData.forEach(n => {\n    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n    g.setAttribute('class', 'node');\n    g.setAttribute('transform', `translate(${n.x},${n.y})`);\n    g.setAttribute('data-id', n.id);\n\n    const defsCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n    defsCircle.setAttribute('class','shadow');\n    defsCircle.setAttribute('r', 36);\n    defsCircle.setAttribute('fill','url(#g-node)');\n    defsCircle.setAttribute('filter','url(#softGlow)');\n    defsCircle.setAttribute('opacity','0.9');\n    defsCircle.setAttribute('cx',0);\n    defsCircle.setAttribute('cy',0);\n\n    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n    circle.setAttribute('class','circle pulse');\n    circle.setAttribute('r', 28);\n    circle.setAttribute('fill','url(#g-node)');\n    circle.setAttribute('cx',0);\n    circle.setAttribute('cy',0);\n\n    const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n    label.setAttribute('class','label');\n    label.setAttribute('x',0);\n    label.setAttribute('y', -2);\n    label.textContent = n.id;\n\n    const val = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n    val.setAttribute('class','value');\n    val.setAttribute('x',0);\n    val.setAttribute('y', 22);\n    val.textContent = (ranks[n.id]).toFixed(3);\n\n    // subtle ring\n    const ring = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n    ring.setAttribute('r', 46);\n    ring.setAttribute('fill','none');\n    ring.setAttribute('stroke','rgba(255,255,255,0.02)');\n    ring.setAttribute('stroke-width','1');\n\n    g.appendChild(ring);\n    g.appendChild(defsCircle);\n    g.appendChild(circle);\n    g.appendChild(label);\n    g.appendChild(val);\n    nodesGroup.appendChild(g);\n\n    nodeElems.set(n.id, { g, circle, label, val, defsCircle, ring });\n  });\n\n  // Particles creation: for each edge create a set of moving particles. We'll create small circles and animate their position.\n  function createParticlesForEdge(edgeIdx, count=5){\n    const path = edgeElements[edgeIdx].path;\n    const length = path.getTotalLength();\n    const list = [];\n    for (let i=0;i<count;i++){\n      const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      c.setAttribute('r', 3);\n      c.setAttribute('class', 'particle');\n      c.setAttribute('fill','white');\n      c.setAttribute('opacity','0.9');\n      particlesGroup.appendChild(c);\n      list.push({ el: c, offset: (i/count) * length * 1.0, length });\n    }\n    return list;\n  }\n\n  // create particle pools for edges\n  edgeElements.forEach((edgeEl, idx) => {\n    const p = createParticlesForEdge(idx, 6);\n    particles.push({ idx, pool: p });\n  });\n\n  // PageRank iteration step\n  function iteratePageRank(){\n    const newRanks = {};\n    // initialize\n    nodesData.forEach(n => newRanks[n.id] = (1 - damping) / N);\n\n    // dangling mass (nodes with no outlinks)\n    let danglingMass = 0;\n    nodesData.forEach(n => {\n      const out = nodeMap.get(n.id).out.length;\n      if (out === 0) danglingMass += ranks[n.id];\n    });\n\n    // distribute contributions\n    nodesData.forEach(n => {\n      const out = nodeMap.get(n.id).out;\n      if (out.length === 0) return;\n      const share = ranks[n.id] / out.length;\n      out.forEach(toId => {\n        newRanks[toId] += damping * share;\n      });\n    });\n\n    // distribute dangling mass evenly\n    const dangAdd = damping * danglingMass / N;\n    nodesData.forEach(n => newRanks[n.id] += dangAdd);\n\n    // compute delta\n    let delta = 0;\n    nodesData.forEach(n => delta += Math.abs(newRanks[n.id] - ranks[n.id]));\n\n    ranks = newRanks;\n    iter++;\n    lastDelta = delta;\n\n    document.getElementById('iter').textContent = iter;\n    document.getElementById('converge').textContent = delta.toFixed(6);\n\n    // update visuals: node sizes, labels, edge widths\n    updateVisuals();\n\n    // return delta for convergence checking\n    return delta;\n  }\n\n  // Visual update to reflect current ranks\n  function updateVisuals(){\n    // compute min/max for scaling\n    const values = nodesData.map(n => ranks[n.id]);\n    const maxV = Math.max(...values);\n    const minV = Math.min(...values);\n\n    nodesData.forEach(n => {\n      const el = nodeElems.get(n.id);\n      const val = ranks[n.id];\n      // scale radius: between 18 and 52\n      const r = 18 + ( (val - minV) / (maxV - minV + 1e-9) ) * 38;\n      el.circle.setAttribute('r', r.toFixed(2));\n      el.defsCircle.setAttribute('r', (r + 8).toFixed(2));\n      el.ring.setAttribute('r', (r + 18).toFixed(2));\n      el.val.textContent = val.toFixed(3);\n\n      // glow intensity by rank\n      const glow = 0.06 + 0.22 * ((val - minV) / (maxV - minV + 1e-9));\n      el.defsCircle.setAttribute('opacity', 0.6 + 0.4 * ((val - minV) / (maxV - minV + 1e-9)));\n      el.circle.setAttribute('fill', `url(#g-node)`);\n      el.circle.style.filter = `drop-shadow(0 10px 30px rgba(96,165,250,${( (val - minV) / (maxV - minV + 1e-9))*0.12 + 0.02}))`;\n      // subtle transform to emphasize\n      const scale = 0.92 + 0.12 * ((val - minV) / (maxV - minV + 1e-9));\n      el.g.setAttribute('transform', `translate(${n.x},${n.y}) scale(${scale})`);\n    });\n\n    // update edges: stroke-width proportional to source outflow * rank\n    edgeElements.forEach(edgeEl => {\n      const fromId = edgeEl.e.from;\n      const outdeg = nodeMap.get(fromId).out.length || 1;\n      const flux = ranks[fromId] / outdeg;\n      const width = 1.2 + 8 * flux * N; // scaled for visibility\n      edgeEl.path.setAttribute('stroke-width', width.toFixed(2));\n      edgeEl.path.style.opacity = 0.45 + Math.min(0.55, flux * 18);\n    });\n  }\n\n  // Animate particles along edges to represent probability flow\n  let lastTime = null;\n  function animateParticles(t){\n    if (!lastTime) lastTime = t;\n    const dt = (t - lastTime) / 1000; // seconds\n    lastTime = t;\n\n    // speed base\n    const speedBase = 40; // pixels per second\n\n    particles.forEach(group => {\n      const edge = edgeElements[group.idx];\n      if (!edge) return;\n      const path = edge.path;\n      const length = path.getTotalLength();\n\n      // compute current edge flux: use from node rank divided by outdegree\n      const fromId = edge.e.from;\n      const outdeg = nodeMap.get(fromId).out.length || 1;\n      const flux = ranks[fromId] / outdeg; // fraction\n      const groupSpeed = speedBase * (0.5 + flux * 8); // vary with flux\n\n      group.pool.forEach(p => {\n        p.offset += groupSpeed * dt;\n        // wrap-around\n        if (p.offset > length) p.offset -= length;\n        // get position\n        const pt = path.getPointAtLength(p.offset);\n        p.el.setAttribute('cx', pt.x);\n        p.el.setAttribute('cy', pt.y);\n        // scale particle by flux\n        const scale = 0.5 + Math.min(1.6, 4.2 * flux);\n        p.el.setAttribute('r', (2.2 * scale).toFixed(2));\n        // opacity by flux\n        p.el.setAttribute('opacity', Math.min(1, 0.2 + flux * 7));\n      });\n    });\n\n    // continue loop if animating\n    if (animating) requestAnimationFrame(animateParticles);\n  }\n\n  // iterative timer for PageRank steps\n  let iterTimer = null;\n  function startIterating(){\n    if (iterTimer) return;\n    iterTimer = setInterval(() => {\n      const d = iteratePageRank();\n      // stop iterating automatically if converged tightly\n      if (d < 1e-6 && iter > 20){\n        clearInterval(iterTimer); iterTimer = null;\n      }\n    }, 1200);\n  }\n  function stopIterating(){\n    if (iterTimer) { clearInterval(iterTimer); iterTimer = null; }\n  }\n\n  // controls\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  playBtn.addEventListener('click', ()=>{\n    animating = !animating;\n    playBtn.textContent = animating ? 'Pause' : 'Play';\n    playBtn.setAttribute('aria-pressed', animating ? 'true' : 'false');\n    if (animating) {\n      startIterating();\n      lastTime = null;\n      requestAnimationFrame(animateParticles);\n    } else {\n      stopIterating();\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    // reset ranks and visuals\n    resetRanks();\n    updateVisuals();\n  });\n\n  // Initial render & start animation\n  updateVisuals();\n  // small warm-up: run one iteration to create slight flow\n  iteratePageRank();\n\n  // begin loops\n  requestAnimationFrame(animateParticles);\n  startIterating();\n\n  // accessibility: pause animation when tab not visible\n  document.addEventListener('visibilitychange', ()=>{\n    if (document.hidden){\n      if (animating) { stopIterating(); }\n    } else {\n      if (animating) startIterating();\n    }\n  });\n\n  // a tiny easing loop to gently breathe nodes for aesthetics\n  let breathe = 0;\n  function breatheLoop(){\n    breathe += 0.01;\n    const t = Math.sin(breathe) * 0.015 + 0.985;\n    nodesData.forEach(n => {\n      const el = nodeElems.get(n.id);\n      const s = 1.0 + (Math.sin((n.x + n.y) * 0.02 + breathe) * 0.008);\n      // apply tiny transform multiplicatively\n      const transform = el.g.getAttribute('transform') || `translate(${n.x},${n.y})`;\n      // extract translate part\n      const m = transform.match(/translate\\(([-0-9.]+),([-0-9.]+)\\)(?:\\s*scale\\(([-0-9.]+)\\))?/);\n      let tx = n.x, ty = n.y, sc = 1;\n      if (m){\n        tx = parseFloat(m[1]);\n        ty = parseFloat(m[2]);\n        if (m[3]) sc = parseFloat(m[3]);\n      }\n      const newScale = (sc * s).toFixed(4);\n      el.g.setAttribute('transform', `translate(${tx},${ty}) scale(${newScale})`);\n    });\n    requestAnimationFrame(breatheLoop);\n  }\n  requestAnimationFrame(breatheLoop);\n\n  // resize handling: re-compute paths on window size change for crispness (positions are static here)\n  window.addEventListener('resize', ()=>{\n    // recompute path strings in case of svg scaling artifacts (positions are absolute, so leave as is)\n    edgeElements.forEach(edgeEl => {\n      const a = nodeMap.get(edgeEl.e.from);\n      const b = nodeMap.get(edgeEl.e.to);\n      edgeEl.path.setAttribute('d', pathFor(a,b));\n      // update particle lengths\n      const idx = edgeElements.indexOf(edgeEl);\n      const pgroup = particles.find(p => p.idx === idx);\n      if (pgroup){\n        pgroup.pool.forEach(p => {\n          p.length = edgeEl.path.getTotalLength();\n          if (p.offset > p.length) p.offset = p.offset % p.length;\n        });\n      }\n    });\n  });\n\n})();\n</script>\n</body>\n</html>"
