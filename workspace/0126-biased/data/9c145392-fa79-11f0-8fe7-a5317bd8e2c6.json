  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Dijkstra Interactive Demonstration</title>\n<style>\n  /* Extremely minimal visual design - plain black text on white background, basic layout */\n  html,body { height:100%; margin:0; font-family: Arial, sans-serif; color: #000; background: #fff; }\n  #container { display: flex; height: 100%; }\n  #controls { width: 360px; padding:10px; box-sizing:border-box; border-right:1px solid #000; overflow:auto; }\n  #canvasWrap { flex:1; position:relative; }\n  canvas { width:100%; height:100%; display:block; background:#fff; cursor:default; }\n  label { display:block; margin-top:8px; font-size:13px; }\n  .row { margin-top:6px; }\n  button { margin-right:6px; margin-top:6px; }\n  input[type=\"text\"], input[type=\"number\"], select, textarea { width:100%; box-sizing:border-box; margin-top:4px; font-size:13px; }\n  textarea { height:80px; }\n  .small { width:80px; display:inline-block; }\n  .inline { display:inline-block; vertical-align:middle; margin-right:6px; }\n  .infoBox { margin-top:8px; padding:6px; border:1px solid #000; height:120px; overflow:auto; white-space:pre-wrap; font-family: monospace; font-size:12px; }\n  .controlsGroup { margin-bottom:10px; padding-bottom:6px; border-bottom:1px solid #000; }\n</style>\n</head>\n<body>\n<div id=\"container\">\n  <div id=\"controls\">\n    <h3>Dijkstra - Interactive</h3>\n\n    <div class=\"controlsGroup\">\n      <label>Mode</label>\n      <div>\n        <button id=\"modePointer\">Pointer / Drag</button>\n        <button id=\"modeAddNode\">Add Node</button>\n        <button id=\"modeAddEdge\">Add Edge</button>\n        <button id=\"modeDelete\">Delete</button>\n      </div>\n      <div class=\"row\">\n        <label>New Node Label (optional)</label>\n        <input id=\"nodeLabelInput\" type=\"text\" placeholder=\"auto label\">\n      </div>\n      <div class=\"row\">\n        <label>Edge weight (number)</label>\n        <input id=\"edgeWeightInput\" type=\"number\" value=\"1\" step=\"1\">\n      </div>\n      <div class=\"row\">\n        <label><input id=\"directedCheckbox\" type=\"checkbox\"> Directed edges</label>\n        <label><input id=\"allowMultiCheckbox\" type=\"checkbox\"> Allow multiple edges (no merging)</label>\n      </div>\n    </div>\n\n    <div class=\"controlsGroup\">\n      <label>Source / Target</label>\n      <div>\n        <button id=\"pickSourceBtn\">Pick Source (click node)</button>\n        <button id=\"pickTargetBtn\">Pick Target (click node)</button>\n      </div>\n      <div class=\"row\">\n        <label>Source: <span id=\"sourceLabel\">none</span> &nbsp; Target: <span id=\"targetLabel\">none</span></label>\n      </div>\n    </div>\n\n    <div class=\"controlsGroup\">\n      <label>Algorithm Control</label>\n      <div>\n        <button id=\"initBtn\">Initialize (set distances)</button>\n        <button id=\"runBtn\">Run Complete</button>\n        <button id=\"stepForwardBtn\">Step Forward</button>\n        <button id=\"stepBackBtn\">Step Back</button>\n        <button id=\"playPauseBtn\">Play</button>\n        <label>Speed <input id=\"speedRange\" type=\"range\" min=\"100\" max=\"2000\" value=\"800\"></label>\n      </div>\n      <div class=\"row\">\n        <label><input id=\"autoStopOnTarget\" type=\"checkbox\"> Stop automatically when target popped</label>\n      </div>\n      <div class=\"row\">\n        <label>Manual learning tools</label>\n        <div>\n          <button id=\"manualRelaxBtn\">Manual Relax Selected Edge</button>\n          <button id=\"forceVisitBtn\">Force Visit Selected Node</button>\n        </div>\n        <div>\n          <small>To select edge/node: click it with Pointer mode.</small>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"controlsGroup\">\n      <label>Graph Utilities</label>\n      <div>\n        <button id=\"clearBtn\">Clear Graph</button>\n        <button id=\"resetStateBtn\">Reset Algorithm State</button>\n        <button id=\"randomBtn\">Random Graph</button>\n      </div>\n      <div class=\"row\">\n        <label>Random graph: nodes <input id=\"randN\" type=\"number\" value=\"8\" class=\"small\"> density (0-1) <input id=\"randDensity\" type=\"number\" step=\"0.05\" value=\"0.3\" class=\"small\"> max weight <input id=\"randW\" type=\"number\" value=\"10\" class=\"small\"></label>\n      </div>\n      <div class=\"row\">\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n      </div>\n      <div class=\"row\">\n        <label>Save/Load (JSON)</label>\n        <textarea id=\"saveLoadArea\" placeholder=\"Graph JSON appears here\"></textarea>\n        <button id=\"saveBtn\">Save to JSON</button>\n        <button id=\"loadBtn\">Load from JSON</button>\n      </div>\n    </div>\n\n    <div class=\"controlsGroup\">\n      <label>View Options</label>\n      <div>\n        <label><input id=\"showPQ\" type=\"checkbox\" checked> Show Priority Queue</label>\n        <label><input id=\"showPrev\" type=\"checkbox\" checked> Show Prev pointers</label>\n        <label><input id=\"showDist\" type=\"checkbox\" checked> Show Distances in nodes</label>\n        <label><input id=\"showVisited\" type=\"checkbox\" checked> Show Visited Mark</label>\n      </div>\n    </div>\n\n    <div class=\"controlsGroup\">\n      <label>Info / PQ / Logs</label>\n      <div class=\"infoBox\" id=\"infoBox\">Instructions:\n- Use modes to add nodes/edges or drag/delete.\n- Pick a source then 'Initialize'. Use Step Forward to watch Dijkstra.\n- Manual relax allows you to practice edge relaxations.\n- Undo/Redo works across edits and algorithm steps.\n</div>\n    </div>\n\n  </div>\n\n  <div id=\"canvasWrap\">\n    <canvas id=\"canvas\"></canvas>\n  </div>\n</div>\n\n<script>\n/*\n Extremely feature-rich interactive Dijkstra demo with minimal visual styling.\n Author: AI-generated interactive demonstration\n*/\n\n(function(){\n  // Basic drawing constants\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  // Set canvas resolution properly\n  function resizeCanvas(){\n    canvas.width = canvas.clientWidth;\n    canvas.height = canvas.clientHeight;\n    draw();\n  }\n  window.addEventListener('resize', resizeCanvas);\n  resizeCanvas();\n\n  // Data structures\n  let nodes = []; // {id,label,x,y,dist,prev,visited}\n  let edges = []; // {id,from,to,weight,directed}\n  let nodeIdCounter = 1;\n  let edgeIdCounter = 1;\n\n  // Interaction state\n  let mode = 'pointer'; // pointer, addNode, addEdge, delete\n  const modeButtons = {\n    pointer: document.getElementById('modePointer'),\n    addNode: document.getElementById('modeAddNode'),\n    addEdge: document.getElementById('modeAddEdge'),\n    delete: document.getElementById('modeDelete')\n  };\n  function setMode(m){ mode = m; updateModeButtons(); clearTempSelection(); }\n  function updateModeButtons(){\n    for(let k in modeButtons){\n      modeButtons[k].disabled = (k === mode);\n    }\n  }\n  updateModeButtons();\n\n  // Selections\n  let hoveredNode = null;\n  let hoveredEdge = null;\n  let selectedNode = null;\n  let selectedEdge = null;\n  let edgeCreationFrom = null;\n\n  // Algorithm state\n  let sourceId = null;\n  let targetId = null;\n  let generator = null;\n  let snapshots = []; // for undo\n  let futureSnapshots = []; // redo\n  let algoSnapshots = []; // snapshots of algorithm progression for stepping\n  let currentAlgoIndex = -1; // index in algoSnapshots\n  let playing = false;\n  let playTimer = null;\n  const infoBox = document.getElementById('infoBox');\n\n  // Controls references\n  const nodeLabelInput = document.getElementById('nodeLabelInput');\n  const edgeWeightInput = document.getElementById('edgeWeightInput');\n  const directedCheckbox = document.getElementById('directedCheckbox');\n  const allowMultiCheckbox = document.getElementById('allowMultiCheckbox');\n  const pickSourceBtn = document.getElementById('pickSourceBtn');\n  const pickTargetBtn = document.getElementById('pickTargetBtn');\n  const sourceLabel = document.getElementById('sourceLabel');\n  const targetLabel = document.getElementById('targetLabel');\n  const initBtn = document.getElementById('initBtn');\n  const runBtn = document.getElementById('runBtn');\n  const stepForwardBtn = document.getElementById('stepForwardBtn');\n  const stepBackBtn = document.getElementById('stepBackBtn');\n  const playPauseBtn = document.getElementById('playPauseBtn');\n  const speedRange = document.getElementById('speedRange');\n  const autoStopOnTarget = document.getElementById('autoStopOnTarget');\n  const manualRelaxBtn = document.getElementById('manualRelaxBtn');\n  const forceVisitBtn = document.getElementById('forceVisitBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const resetStateBtn = document.getElementById('resetStateBtn');\n  const randomBtn = document.getElementById('randomBtn');\n  const randN = document.getElementById('randN');\n  const randDensity = document.getElementById('randDensity');\n  const randW = document.getElementById('randW');\n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n  const saveLoadArea = document.getElementById('saveLoadArea');\n  const saveBtn = document.getElementById('saveBtn');\n  const loadBtn = document.getElementById('loadBtn');\n  const showPQ = document.getElementById('showPQ');\n  const showPrev = document.getElementById('showPrev');\n  const showDist = document.getElementById('showDist');\n  const showVisited = document.getElementById('showVisited');\n\n  // Mode buttons events\n  modeButtons.pointer.addEventListener('click', ()=>setMode('pointer'));\n  modeButtons.addNode.addEventListener('click', ()=>setMode('addNode'));\n  modeButtons.addEdge.addEventListener('click', ()=>setMode('addEdge'));\n  modeButtons.delete.addEventListener('click', ()=>setMode('delete'));\n\n  // Utility functions\n  function cloneState(){\n    return {\n      nodes: nodes.map(n=>({...n})),\n      edges: edges.map(e=>({...e})),\n      sourceId, targetId,\n      nodeIdCounter, edgeIdCounter\n    };\n  }\n  function restoreState(s){\n    nodes = s.nodes.map(n=>({...n}));\n    edges = s.edges.map(e=>({...e}));\n    sourceId = s.sourceId;\n    targetId = s.targetId;\n    nodeIdCounter = s.nodeIdCounter;\n    edgeIdCounter = s.edgeIdCounter;\n    // Ensure fields exist\n    nodes.forEach(n=>{\n      if(n.dist===undefined) n.dist = Infinity;\n      if(n.prev===undefined) n.prev = null;\n      if(n.visited===undefined) n.visited = false;\n    });\n    updateSourceTargetLabels();\n    draw();\n  }\n  function pushSnapshot(){\n    snapshots.push(cloneState());\n    // clear redo\n    futureSnapshots = [];\n    updateUndoRedoButtons();\n  }\n  function updateUndoRedoButtons(){\n    undoBtn.disabled = snapshots.length === 0;\n    redoBtn.disabled = futureSnapshots.length === 0;\n  }\n  function undo(){\n    if(snapshots.length===0) return;\n    const s = snapshots.pop();\n    futureSnapshots.push(cloneState());\n    restoreState(s);\n    info(\"Undo\");\n    updateUndoRedoButtons();\n  }\n  function redo(){\n    if(futureSnapshots.length===0) return;\n    const s = futureSnapshots.pop();\n    snapshots.push(cloneState());\n    restoreState(s);\n    info(\"Redo\");\n    updateUndoRedoButtons();\n  }\n\n  // Canvas interaction\n  const NODE_RADIUS = 20;\n  function getNodeAt(x,y){\n    for(let i=nodes.length-1;i>=0;i--){\n      const n = nodes[i];\n      const dx=x-n.x, dy=y-n.y;\n      if(dx*dx+dy*dy <= NODE_RADIUS*NODE_RADIUS) return n;\n    }\n    return null;\n  }\n  function getEdgeAt(x,y){\n    // find approximate click near any edge segment\n    for(let i=0;i<edges.length;i++){\n      const e = edges[i];\n      const a = nodes.find(n=>n.id===e.from);\n      const b = nodes.find(n=>n.id===e.to);\n      if(!a || !b) continue;\n      const d = pointSegmentDistance(x,y,a.x,a.y,b.x,b.y);\n      if(d < 8) return e;\n    }\n    return null;\n  }\n  function pointSegmentDistance(px,py,x1,y1,x2,y2){\n    const l2 = ((x2-x1)**2 + (y2-y1)**2);\n    if(l2===0) return Math.hypot(px-x1,py-y1);\n    let t = ((px-x1)*(x2-x1)+(py-y1)*(y2-y1)) / l2;\n    t = Math.max(0, Math.min(1,t));\n    const projx = x1 + t*(x2-x1);\n    const projy = y1 + t*(y2-y1);\n    return Math.hypot(px-projx,py-projy);\n  }\n\n  // Drawing\n  function draw(){\n    if(!ctx) return;\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n    // edges\n    ctx.lineWidth = 1;\n    edges.forEach(e=>{\n      const a = nodes.find(n=>n.id===e.from);\n      const b = nodes.find(n=>n.id===e.to);\n      if(!a || !b) return;\n      ctx.beginPath();\n      ctx.moveTo(a.x,a.y);\n      ctx.lineTo(b.x,b.y);\n      ctx.strokeStyle = \"#000\";\n      ctx.stroke();\n      // weight label\n      const mx = (a.x+b.x)/2, my = (a.y+b.y)/2;\n      ctx.font = \"12px Arial\";\n      ctx.fillStyle = \"#000\";\n      ctx.textAlign = \"center\";\n      ctx.textBaseline = \"middle\";\n      ctx.fillText(String(e.weight), mx, my);\n      // arrow for directed\n      if(e.directed){\n        drawArrowHead(a.x,a.y,b.x,b.y);\n      }\n      if(selectedEdge && selectedEdge.id===e.id){\n        // highlight selected edge by thicker line using overdraw\n        ctx.beginPath();\n        ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);\n        ctx.lineWidth = 3;\n        ctx.stroke();\n        ctx.lineWidth = 1;\n      }\n    });\n    // nodes\n    nodes.forEach(n=>{\n      // circle\n      ctx.beginPath();\n      ctx.arc(n.x,n.y,NODE_RADIUS,0,Math.PI*2);\n      ctx.strokeStyle = \"#000\";\n      ctx.stroke();\n      // label and distance\n      ctx.fillStyle = \"#000\";\n      ctx.textAlign = \"center\";\n      ctx.textBaseline = \"middle\";\n      const labelText = (n.label!==undefined? n.label : (\"n\"+n.id));\n      ctx.fillText(labelText, n.x, n.y-6);\n      if(showDist.checked){\n        const d = (n.dist===Infinity ? \"∞\" : String(n.dist));\n        ctx.fillText(d, n.x, n.y+10);\n      }\n      if(showPrev.checked && n.prev!=null){\n        ctx.font = \"10px Arial\";\n        ctx.fillText(\"←\"+n.prev, n.x, n.y + 22);\n        ctx.font = \"12px Arial\";\n      }\n      if(showVisited.checked && n.visited){\n        ctx.font = \"10px Arial\";\n        ctx.fillText(\"visited\", n.x, n.y - 20);\n        ctx.font = \"12px Arial\";\n      }\n      // selection stroke\n      if(selectedNode && selectedNode.id===n.id){\n        ctx.beginPath();\n        ctx.arc(n.x,n.y,NODE_RADIUS+3,0,Math.PI*2);\n        ctx.stroke();\n      }\n      if(sourceId === n.id){\n        ctx.font = \"10px Arial\";\n        ctx.fillText(\"S\", n.x - NODE_RADIUS - 8, n.y - NODE_RADIUS - 8);\n        ctx.font = \"12px Arial\";\n      }\n      if(targetId === n.id){\n        ctx.font = \"10px Arial\";\n        ctx.fillText(\"T\", n.x + NODE_RADIUS + 8, n.y + NODE_RADIUS + 8);\n        ctx.font = \"12px Arial\";\n      }\n    });\n    // PQ display (textual) if enabled\n    if(showPQ.checked && algoSnapshots.length>0 && currentAlgoIndex>=0){\n      const st = algoSnapshots[currentAlgoIndex];\n      if(st && st.pq){\n        const text = \"PQ: \" + st.pq.map(item=>`(${item.id},${item.dist})`).join(\", \");\n        ctx.font = \"12px Arial\";\n        ctx.textAlign = \"left\";\n        ctx.fillText(text, 10, canvas.height - 10);\n      }\n    }\n    // highlight hovered\n    if(hoveredNode){\n      ctx.beginPath();\n      ctx.arc(hoveredNode.x, hoveredNode.y, NODE_RADIUS+2,0,Math.PI*2);\n      ctx.stroke();\n    }\n    if(hoveredEdge){\n      const a = nodes.find(n=>n.id===hoveredEdge.from);\n      const b = nodes.find(n=>n.id===hoveredEdge.to);\n      if(a && b){\n        ctx.beginPath();\n        ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);\n        ctx.lineWidth = 2; ctx.stroke();\n        ctx.lineWidth = 1;\n      }\n    }\n  }\n  function drawArrowHead(x1,y1,x2,y2){\n    // minimal arrowhead\n    const ang = Math.atan2(y2-y1,x2-x1);\n    const len = 8;\n    ctx.beginPath();\n    ctx.moveTo(x2,y2);\n    ctx.lineTo(x2 - len*Math.cos(ang-0.3), y2 - len*Math.sin(ang-0.3));\n    ctx.lineTo(x2 - len*Math.cos(ang+0.3), y2 - len*Math.sin(ang+0.3));\n    ctx.closePath();\n    ctx.fillStyle = \"#000\";\n    ctx.fill();\n  }\n\n  // Canvas mouse events\n  let draggingNode = null;\n  let dragOffset = {x:0,y:0};\n  let pickMode = null; // 'source' or 'target'\n  canvas.addEventListener('mousedown', function(e){\n    const rect=canvas.getBoundingClientRect();\n    const x = (e.clientX - rect.left) * (canvas.width/canvas.clientWidth);\n    const y = (e.clientY - rect.top) * (canvas.height/canvas.clientHeight);\n    hoveredNode = getNodeAt(x,y);\n    hoveredEdge = getEdgeAt(x,y);\n    selectedNode = hoveredNode;\n    selectedEdge = hoveredEdge;\n    draw();\n    if(mode === 'addNode'){\n      const label = nodeLabelInput.value.trim() || null;\n      pushSnapshot();\n      addNode(x,y,label);\n      pushInfo(`Node added`);\n      draw();\n      return;\n    }\n    if(mode === 'addEdge'){\n      if(!edgeCreationFrom && hoveredNode){\n        edgeCreationFrom = hoveredNode;\n        pushInfo(\"Edge start selected: \" + edgeCreationFrom.labelOrId);\n      } else if(edgeCreationFrom && hoveredNode){\n        // create edge from edgeCreationFrom to hoveredNode\n        const w = Number(edgeWeightInput.value) || 1;\n        pushSnapshot();\n        addEdge(edgeCreationFrom.id, hoveredNode.id, w, directedCheckbox.checked);\n        edgeCreationFrom = null;\n        draw();\n      }\n      return;\n    }\n    if(mode === 'delete'){\n      if(hoveredNode){\n        pushSnapshot();\n        deleteNode(hoveredNode.id);\n        draw();\n      } else if(hoveredEdge){\n        pushSnapshot();\n        deleteEdge(hoveredEdge.id);\n        draw();\n      }\n      return;\n    }\n    if(mode === 'pointer'){\n      if(hoveredNode){\n        // start dragging\n        draggingNode = hoveredNode;\n        dragOffset.x = x - hoveredNode.x;\n        dragOffset.y = y - hoveredNode.y;\n      }\n    }\n    if(pickMode === 'source' && hoveredNode){\n      pushSnapshot();\n      sourceId = hoveredNode.id;\n      pickMode = null;\n      updateSourceTargetLabels();\n      info(`Source set to ${hoveredNode.labelOrId}`);\n      draw();\n      return;\n    }\n    if(pickMode === 'target' && hoveredNode){\n      pushSnapshot();\n      targetId = hoveredNode.id;\n      pickMode = null;\n      updateSourceTargetLabels();\n      info(`Target set to ${hoveredNode.labelOrId}`);\n      draw();\n      return;\n    }\n  });\n  canvas.addEventListener('mousemove', function(e){\n    const rect=canvas.getBoundingClientRect();\n    const x = (e.clientX - rect.left) * (canvas.width/canvas.clientWidth);\n    const y = (e.clientY - rect.top) * (canvas.height/canvas.clientHeight);\n    if(draggingNode){\n      draggingNode.x = x - dragOffset.x;\n      draggingNode.y = y - dragOffset.y;\n      draw();\n      return;\n    }\n    hoveredNode = getNodeAt(x,y);\n    hoveredEdge = getEdgeAt(x,y);\n    draw();\n  });\n  window.addEventListener('mouseup', function(){\n    if(draggingNode){\n      pushSnapshot();\n      draggingNode = null;\n      draw();\n    }\n  });\n\n  // Node/edge manipulation functions\n  function addNode(x,y,label){\n    const id = nodeIdCounter++;\n    const n = { id, label: label || (\"n\"+id), x, y, dist: Infinity, prev: null, visited: false };\n    Object.defineProperty(n, 'labelOrId', { get(){ return this.label || (\"n\"+this.id); }, configurable:true });\n    nodes.push(n);\n    return n;\n  }\n  function addEdge(from,to,weight,directed){\n    // check duplicate merging unless allowed\n    if(!allowMultiCheckbox.checked){\n      for(let e of edges){\n        if(e.from===from && e.to===to && e.weight===weight && e.directed===directed) return null;\n      }\n    }\n    const id = edgeIdCounter++;\n    const e = { id, from, to, weight: Number(weight), directed: !!directed };\n    edges.push(e);\n    return e;\n  }\n  function deleteNode(id){\n    nodes = nodes.filter(n=>n.id!==id);\n    edges = edges.filter(e=>e.from!==id && e.to!==id);\n    if(sourceId===id) sourceId=null;\n    if(targetId===id) targetId=null;\n    updateSourceTargetLabels();\n  }\n  function deleteEdge(id){\n    edges = edges.filter(e=>e.id!==id);\n  }\n  function updateSourceTargetLabels(){\n    sourceLabel.textContent = sourceId ? (nodes.find(n=>n.id===sourceId)?.label || (\"n\"+sourceId)) : \"none\";\n    targetLabel.textContent = targetId ? (nodes.find(n=>n.id===targetId)?.label || (\"n\"+targetId)) : \"none\";\n  }\n\n  // Buttons and controls binding\n  pickSourceBtn.addEventListener('click', ()=>{ pickMode = 'source'; info('Click a node to set as source'); });\n  pickTargetBtn.addEventListener('click', ()=>{ pickMode = 'target'; info('Click a node to set as target'); });\n  initBtn.addEventListener('click', ()=>{\n    if(sourceId==null){ info('Set source before initializing'); return; }\n    pushSnapshot();\n    initializeAlgorithm();\n    info('Initialized distances. Ready to step.');\n  });\n  runBtn.addEventListener('click', ()=>{\n    if(sourceId==null){ info('Set source before running'); return; }\n    pushSnapshot();\n    initializeAlgorithm();\n    startRunFull();\n  });\n  stepForwardBtn.addEventListener('click', ()=>stepForward());\n  stepBackBtn.addEventListener('click', ()=>stepBack());\n  playPauseBtn.addEventListener('click', ()=>togglePlay());\n  manualRelaxBtn.addEventListener('click', ()=>manualRelax());\n  forceVisitBtn.addEventListener('click', ()=>forceVisit());\n  clearBtn.addEventListener('click', ()=>{ pushSnapshot(); nodes=[]; edges=[]; sourceId=null; targetId=null; updateSourceTargetLabels(); draw(); info('Graph cleared'); });\n  resetStateBtn.addEventListener('click', ()=>{ pushSnapshot(); nodes.forEach(n=>{ n.dist=Infinity; n.prev=null; n.visited=false; }); algoSnapshots=[]; currentAlgoIndex=-1; draw(); info('Algorithm state reset'); });\n  randomBtn.addEventListener('click', ()=>{ pushSnapshot(); generateRandomGraph(Number(randN.value)||8, Number(randDensity.value)||0.3, Number(randW.value)||10); info('Random graph generated'); draw(); });\n  undoBtn.addEventListener('click', undo);\n  redoBtn.addEventListener('click', redo);\n  saveBtn.addEventListener('click', ()=>{ saveLoadArea.value = JSON.stringify({nodes,edges,nodeIdCounter,edgeIdCounter,sourceId,targetId}); info('Graph JSON created'); });\n  loadBtn.addEventListener('click', ()=>{ try{ const obj=JSON.parse(saveLoadArea.value); pushSnapshot(); nodes = obj.nodes || []; edges = obj.edges || []; nodeIdCounter = obj.nodeIdCounter || 1; edgeIdCounter = obj.edgeIdCounter || 1; sourceId = obj.sourceId || null; targetId = obj.targetId || null; nodes.forEach(n=>{ if(n.dist===undefined){ n.dist=Infinity; n.prev=null; n.visited=false;} }); updateSourceTargetLabels(); draw(); info('Graph loaded'); }catch(e){ info('Invalid JSON'); }});\n  undoBtn.disabled = true;\n  redoBtn.disabled = true;\n\n  // Info log\n  function info(msg){\n    const t = new Date().toLocaleTimeString();\n    infoBox.textContent = `${t} - ${msg}\\n` + infoBox.textContent;\n  }\n\n  // Algorithm core: generator producing step-by-step snapshots.\n  function initializeAlgorithm(){\n    // set all distances to Infinity, prev null, visited false\n    nodes.forEach(n=>{ n.dist = Infinity; n.prev = null; n.visited = false; });\n    const src = nodes.find(n=>n.id===sourceId);\n    if(!src){ info('Source not found among nodes'); return; }\n    src.dist = 0;\n    // Prepare algoSnapshots initial\n    algoSnapshots = [];\n    currentAlgoIndex = -1;\n    recordAlgoSnapshot(\"init\", buildPQArray());\n    // Create generator\n    generator = dijkstraGenerator();\n  }\n\n  function* dijkstraGenerator(){\n    // local copies refer to nodes/edges arrays (we modify nodes in place)\n    // We'll implement classic Dijkstra using simple array-based PQ for clarity.\n    function getPQ(){\n      const arr = nodes.filter(n=>!n.visited && n.dist<Infinity).map(n=>({id:n.id,dist:n.dist}));\n      arr.sort((a,b)=>a.dist - b.dist);\n      return arr;\n    }\n    while(true){\n      // pick min\n      let candidates = nodes.filter(n=>!n.visited && n.dist<Infinity);\n      if(candidates.length===0) {\n        recordAlgoSnapshot(\"done\", getPQ());\n        break;\n      }\n      candidates.sort((a,b)=>a.dist - b.dist);\n      const u = candidates[0];\n      // pop u\n      u.visited = true;\n      recordAlgoSnapshot(`pop ${u.id}`, getPQ());\n      if(targetId!==null && u.id===targetId){\n        recordAlgoSnapshot(\"target popped\", getPQ());\n        break;\n      }\n      // relax edges out of u\n      const outEdges = edges.filter(e=>e.from===u.id || (!e.directed && e.to===u.id)).slice();\n      // For undirected edges, treat neighbor appropriately\n      for(let e of outEdges){\n        let vId = (e.from===u.id ? e.to : e.from);\n        let v = nodes.find(n=>n.id===vId);\n        if(!v) continue;\n        // attempt relaxation\n        const alt = u.dist + Number(e.weight);\n        recordAlgoSnapshot(`relax attempt ${u.id}->${v.id} (alt=${alt})`, getPQ(), {edgeId:e.id, from:u.id, to:v.id});\n        if(alt < v.dist){\n          v.dist = alt;\n          v.prev = u.id;\n          recordAlgoSnapshot(`relaxed ${u.id}->${v.id} (newDist=${v.dist})`, getPQ(), {edgeId:e.id, from:u.id, to:v.id});\n        } else {\n          // no change snapshot already recorded above\n        }\n      }\n      yield; // yield control to allow step-by-step\n    }\n    return;\n  }\n\n  function recordAlgoSnapshot(action, pqArray, extra){\n    const snap = {\n      action: action || \"\",\n      nodes: nodes.map(n=>({id:n.id,dist:n.dist,prev:n.prev,visited:n.visited})),\n      pq: pqArray ? pqArray.slice() : [],\n      extra: extra || null\n    };\n    algoSnapshots.push(snap);\n    currentAlgoIndex = algoSnapshots.length - 1;\n    draw();\n    displayAlgoInfo(snap);\n  }\n\n  function buildPQArray(){\n    return nodes.filter(n=>!n.visited && n.dist<Infinity).map(n=>({id:n.id,dist:n.dist})).sort((a,b)=>a.dist-b.dist);\n  }\n\n  // Step controls\n  function stepForward(){\n    if(!generator){ info('Initialize first'); return; }\n    const res = generator.next();\n    if(!res.done){\n      // state already updated inside generator via node modifications and recordAlgoSnapshot calls\n      draw();\n    } else {\n      info('Algorithm finished');\n    }\n  }\n  function stepBack(){\n    // allow going back in algoSnapshots by restoring snapshot items\n    if(algoSnapshots.length===0 || currentAlgoIndex<=0){\n      info('No more steps back');\n      return;\n    }\n    currentAlgoIndex--;\n    const s = algoSnapshots[currentAlgoIndex];\n    // restore nodes' dist/prev/visited from snapshot\n    // We'll find matching nodes by id\n    s.nodes.forEach(sn=>{\n      const n = nodes.find(x=>x.id===sn.id);\n      if(n){\n        n.dist = sn.dist;\n        n.prev = sn.prev;\n        n.visited = sn.visited;\n      }\n    });\n    draw();\n    displayAlgoInfo(s);\n  }\n  function displayAlgoInfo(snap){\n    if(!snap) return;\n    let lines = [];\n    lines.push(\"Action: \" + snap.action);\n    lines.push(\"PQ: \" + snap.pq.map(x=>`(${x.id},${x.dist})`).join(\", \"));\n    if(snap.extra) lines.push(\"Extra: \" + JSON.stringify(snap.extra));\n    infoBox.textContent = lines.join(\"\\n\") + \"\\n\\n\" + infoBox.textContent;\n  }\n\n  // Play/pause functionality\n  function togglePlay(){\n    if(playing){\n      stopPlay();\n    } else {\n      startPlay();\n    }\n  }\n  function startPlay(){\n    if(!generator){ info('Initialize first'); return; }\n    playing = true;\n    playPauseBtn.textContent = \"Pause\";\n    const interval = Number(speedRange.value) || 800;\n    playTimer = setInterval(()=>{ \n      if(!generator) { stopPlay(); return; }\n      // step once\n      const res = generator.next();\n      if(res.done){\n        stopPlay();\n        info('Algorithm finished while playing');\n        return;\n      }\n      // auto stop condition\n      if(autoStopOnTarget.checked && nodes.find(n=>n.id===targetId && n.visited)){\n        stopPlay();\n        info('Stopped: target visited');\n      }\n    }, interval);\n  }\n  function stopPlay(){\n    playing = false;\n    playPauseBtn.textContent = \"Play\";\n    if(playTimer){ clearInterval(playTimer); playTimer = null; }\n  }\n  function startRunFull(){\n    // run generator to completion but animate snapshots quickly\n    if(!generator){ info('Initialize first'); return; }\n    const prevInterval = Number(speedRange.value) || 800;\n    const fastInterval = Math.max(50, prevInterval/4);\n    const intervalId = setInterval(()=>{\n      const res = generator.next();\n      if(res.done){\n        clearInterval(intervalId);\n        info('Run complete');\n      }\n      if(autoStopOnTarget.checked && nodes.find(n=>n.id===targetId && n.visited)){\n        clearInterval(intervalId);\n        info('Stopped on target');\n      }\n    }, fastInterval);\n  }\n\n  // Manual relax and force visit\n  function manualRelax(){\n    if(!selectedEdge){ info('Select an edge first (pointer mode)'); return; }\n    pushSnapshot();\n    const e = edges.find(x=>x.id===selectedEdge.id);\n    if(!e) return;\n    // find u (source in sense of current view) and v (other)\n    const u = nodes.find(n=>n.id===e.from);\n    const v = nodes.find(n=>n.id===e.to);\n    if(!u || !v) return;\n    const alt = u.dist + e.weight;\n    if(alt < v.dist){\n      v.dist = alt;\n      v.prev = u.id;\n      info(`Relaxed: ${u.labelOrId} -> ${v.labelOrId}, new dist ${v.dist}`);\n    } else {\n      info(`No relaxation: alt=${alt} >= ${v.dist}`);\n    }\n    draw();\n  }\n  function forceVisit(){\n    if(!selectedNode){ info('Select a node first (pointer mode)'); return; }\n    pushSnapshot();\n    const n = nodes.find(x=>x.id===selectedNode.id);\n    if(!n) return;\n    n.visited = true;\n    info(`Node ${n.labelOrId} forced visited`);\n    draw();\n  }\n\n  // Helper: selected* binding from canvas events - expose selection externally\n  canvas.addEventListener('click', function(e){\n    // in pointer mode selecting should toggle selected node/edge\n    if(mode !== 'pointer') return;\n    const rect=canvas.getBoundingClientRect();\n    const x = (e.clientX - rect.left) * (canvas.width/canvas.clientWidth);\n    const y = (e.clientY - rect.top) * (canvas.height/canvas.clientHeight);\n    const n = getNodeAt(x,y);\n    const ed = getEdgeAt(x,y);\n    selectedNode = n;\n    selectedEdge = ed;\n    draw();\n  });\n\n  // Random graph generator\n  function generateRandomGraph(n,density,maxW){\n    nodes = []; edges = [];\n    nodeIdCounter = 1; edgeIdCounter = 1;\n    const padding = 40;\n    for(let i=0;i<n;i++){\n      const x = padding + Math.random()*(canvas.width - padding*2);\n      const y = padding + Math.random()*(canvas.height - padding*2);\n      addNode(x,y, \"n\"+(i+1));\n    }\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i===j) continue;\n        if(Math.random() < density){\n          const w = Math.ceil(Math.random()*maxW);\n          addEdge(nodes[i].id, nodes[j].id, w, directedCheckbox.checked);\n        }\n      }\n    }\n  }\n\n  // Save/Load exposed earlier - already implemented\n\n  // Utility: build label getters\n  Object.defineProperty(Object.prototype, 'labelOrId', {\n    get: function(){ return this.label || (\"n\"+this.id); },\n    configurable: true\n  });\n\n  // Additional UI niceties\n  function clearTempSelection(){ edgeCreationFrom = null; pickMode = null; selectedEdge = null; selectedNode = null; draw(); }\n  function pushInfo(msg){ info(msg); }\n\n  // Expose a minimal inspect command in infoBox by clicking lines\n  infoBox.addEventListener('dblclick', ()=>{ infoBox.textContent = \"Double-click detected. Use controls to interact.\"; });\n\n  // Initialize minimal example graph\n  function initExample(){\n    nodes = []; edges = [];\n    nodeIdCounter = 1; edgeIdCounter = 1;\n    const a = addNode(100,100,\"A\");\n    const b = addNode(260,90,\"B\");\n    const c = addNode(180,200,\"C\");\n    const d = addNode(360,200,\"D\");\n    addEdge(a.id,b.id,4,true);\n    addEdge(a.id,c.id,2,true);\n    addEdge(c.id,b.id,1,true);\n    addEdge(b.id,d.id,5,true);\n    addEdge(c.id,d.id,8,true);\n    draw();\n  }\n\n  // Expose some keyboard shortcuts for power users (minimal)\n  window.addEventListener('keydown', function(e){\n    if(e.key === 'z' && (e.ctrlKey||e.metaKey)){ undo(); }\n    if(e.key === 'y' && (e.ctrlKey||e.metaKey)){ redo(); }\n    if(e.key === ' ') { togglePlay(); e.preventDefault(); }\n  });\n\n  // Initial example\n  initExample();\n  info(\"Example graph loaded. Set source and initialize to start.\");\n\n})();\n</script>\n\n</body>\n</html>"
