  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Greedy Algorithms Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        .algorithm-section {\n            margin-bottom: 20px;\n        }\n        button {\n            padding: 5px 10px;\n            margin: 5px;\n        }\n        input, select {\n            padding: 5px;\n            margin: 5px;\n        }\n        .visualization {\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 100px;\n            font-family: monospace;\n            white-space: pre;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            align-items: center;\n        }\n        .control-group {\n            margin-right: 20px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n        }\n        td, th {\n            border: 1px solid #000;\n            padding: 5px;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Greedy Algorithms Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Algorithm Selection</h2>\n            <select id=\"algorithm-selector\">\n                <option value=\"coin\">Coin Change Problem</option>\n                <option value=\"fractional\">Fractional Knapsack</option>\n                <option value=\"activity\">Activity Selection</option>\n                <option value=\"huffman\">Huffman Coding</option>\n            </select>\n            <button id=\"select-algorithm\">Load Algorithm</button>\n        </div>\n        \n        <div id=\"algorithm-container\">\n            <!-- Algorithm-specific content will be loaded here -->\n        </div>\n    </div>\n\n    <script>\n        // Global state\n        let currentAlgorithm = null;\n        let algorithmState = {};\n        \n        // DOM elements\n        const algorithmContainer = document.getElementById('algorithm-container');\n        const algorithmSelector = document.getElementById('algorithm-selector');\n        const selectAlgorithmBtn = document.getElementById('select-algorithm');\n        \n        // Algorithm templates\n        const algorithms = {\n            coin: {\n                name: \"Coin Change Problem\",\n                description: \"Find the minimum number of coins to make a given amount using a greedy approach.\",\n                init: initCoinChange,\n                state: {\n                    coins: [25, 10, 5, 1],\n                    amount: 63,\n                    solution: []\n                }\n            },\n            fractional: {\n                name: \"Fractional Knapsack\",\n                description: \"Maximize value in a knapsack with limited capacity by taking fractions of items.\",\n                init: initFractionalKnapsack,\n                state: {\n                    items: [\n                        {weight: 10, value: 60},\n                        {weight: 20, value: 100},\n                        {weight: 30, value: 120}\n                    ],\n                    capacity: 50,\n                    solution: []\n                }\n            },\n            activity: {\n                name: \"Activity Selection\",\n                description: \"Select maximum number of non-overlapping activities that can be performed by a single person.\",\n                init: initActivitySelection,\n                state: {\n                    activities: [\n                        {start: 1, end: 4},\n                        {start: 3, end: 5},\n                        {start: 0, end: 6},\n                        {start: 5, end: 7},\n                        {start: 3, end: 9},\n                        {start: 5, end: 9},\n                        {start: 6, end: 10},\n                        {start: 8, end: 11},\n                        {start: 8, end: 12},\n                        {start: 2, end: 14},\n                        {start: 12, end: 16}\n                    ],\n                    solution: []\n                }\n            },\n            huffman: {\n                name: \"Huffman Coding\",\n                description: \"Create optimal prefix codes for data compression using character frequencies.\",\n                init: initHuffmanCoding,\n                state: {\n                    characters: [\n                        {char: 'a', freq: 5},\n                        {char: 'b', freq: 9},\n                        {char: 'c', freq: 12},\n                        {char: 'd', freq: 13},\n                        {char: 'e', freq: 16},\n                        {char: 'f', freq: 45}\n                    ],\n                    codes: {}\n                }\n            }\n        };\n        \n        // Initialize the selected algorithm\n        selectAlgorithmBtn.addEventListener('click', () => {\n            const selected = algorithmSelector.value;\n            currentAlgorithm = algorithms[selected];\n            algorithmState = JSON.parse(JSON.stringify(currentAlgorithm.state)); // Deep copy\n            currentAlgorithm.init();\n        });\n        \n        // Coin Change Problem\n        function initCoinChange() {\n            algorithmContainer.innerHTML = `\n                <div class=\"algorithm-section\">\n                    <h2>${currentAlgorithm.name}</h2>\n                    <p>${currentAlgorithm.description}</p>\n                    \n                    <div class=\"controls\">\n                        <div class=\"control-group\">\n                            <label>Coin Denominations:</label>\n                            <input type=\"text\" id=\"coin-input\" value=\"${algorithmState.coins.join(', ')}\">\n                            <button id=\"update-coins\">Update Coins</button>\n                        </div>\n                        <div class=\"control-group\">\n                            <label>Amount:</label>\n                            <input type=\"number\" id=\"amount-input\" value=\"${algorithmState.amount}\">\n                            <button id=\"solve-coin\">Solve</button>\n                        </div>\n                    </div>\n                    \n                    <div class=\"visualization\" id=\"coin-visualization\">\n                        ${renderCoinChangeVisualization()}\n                    </div>\n                    \n                    <div>\n                        <h3>How it works:</h3>\n                        <ol>\n                            <li>Sort coins in descending order</li>\n                            <li>Take as many as possible of the largest coin first</li>\n                            <li>Move to next largest coin and repeat</li>\n                            <li>Continue until amount is zero</li>\n                        </ol>\n                    </div>\n                </div>\n            `;\n            \n            document.getElementById('update-coins').addEventListener('click', () => {\n                const coinsInput = document.getElementById('coin-input').value;\n                algorithmState.coins = coinsInput.split(',').map(coin => parseInt(coin.trim())).filter(coin => !isNaN(coin));\n                algorithmState.coins.sort((a, b) => b - a);\n                document.getElementById('coin-visualization').innerHTML = renderCoinChangeVisualization();\n            });\n            \n            document.getElementById('solve-coin').addEventListener('click', () => {\n                const amount = parseInt(document.getElementById('amount-input').value);\n                if (!isNaN(amount)) {\n                    algorithmState.amount = amount;\n                    solveCoinChange();\n                    document.getElementById('coin-visualization').innerHTML = renderCoinChangeVisualization();\n                }\n            });\n        }\n        \n        function solveCoinChange() {\n            let remaining = algorithmState.amount;\n            algorithmState.solution = [];\n            \n            for (const coin of algorithmState.coins) {\n                if (remaining <= 0) break;\n                const count = Math.floor(remaining / coin);\n                if (count > 0) {\n                    algorithmState.solution.push({coin, count});\n                    remaining -= count * coin;\n                }\n            }\n        }\n        \n        function renderCoinChangeVisualization() {\n            let html = `<h3>Solution for ${algorithmState.amount}:</h3>`;\n            \n            if (algorithmState.solution.length === 0) {\n                html += \"<p>Click 'Solve' to find solution</p>\";\n            } else {\n                html += \"<table><tr><th>Coin</th><th>Count</th><th>Subtotal</th></tr>\";\n                let totalCoins = 0;\n                \n                for (const item of algorithmState.solution) {\n                    html += `<tr><td>${item.coin}</td><td>${item.count}</td><td>${item.coin * item.count}</td></tr>`;\n                    totalCoins += item.count;\n                }\n                \n                html += `<tr><td><strong>Total</strong></td><td><strong>${totalCoins}</strong></td><td><strong>${algorithmState.amount}</strong></td></tr>`;\n                html += \"</table>\";\n            }\n            \n            return html;\n        }\n        \n        // Fractional Knapsack\n        function initFractionalKnapsack() {\n            algorithmContainer.innerHTML = `\n                <div class=\"algorithm-section\">\n                    <h2>${currentAlgorithm.name}</h2>\n                    <p>${currentAlgorithm.description}</p>\n                    \n                    <div class=\"controls\">\n                        <div class=\"control-group\">\n                            <label>Capacity:</label>\n                            <input type=\"number\" id=\"capacity-input\" value=\"${algorithmState.capacity}\">\n                            <button id=\"update-capacity\">Update</button>\n                        </div>\n                        <div class=\"control-group\">\n                            <button id=\"add-item\">Add Item</button>\n                            <button id=\"solve-knapsack\">Solve</button>\n                        </div>\n                    </div>\n                    \n                    <div id=\"items-container\">\n                        ${renderKnapsackItems()}\n                    </div>\n                    \n                    <div class=\"visualization\" id=\"knapsack-visualization\">\n                        ${renderKnapsackSolution()}\n                    </div>\n                    \n                    <div>\n                        <h3>How it works:</h3>\n                        <ol>\n                            <li>Calculate value/weight ratio for each item</li>\n                            <li>Sort items by ratio in descending order</li>\n                            <li>Take as much as possible of the highest ratio item</li>\n                            <li>Continue with next items until capacity is full</li>\n                        </ol>\n                    </div>\n                </div>\n            `;\n            \n            document.getElementById('update-capacity').addEventListener('click', () => {\n                const capacity = parseInt(document.getElementById('capacity-input').value);\n                if (!isNaN(capacity)) {\n                    algorithmState.capacity = capacity;\n                    document.getElementById('knapsack-visualization').innerHTML = renderKnapsackSolution();\n                }\n            });\n            \n            document.getElementById('add-item').addEventListener('click', () => {\n                const weight = Math.floor(Math.random() * 30) + 5;\n                const value = Math.floor(Math.random() * 100) + 20;\n                algorithmState.items.push({weight, value});\n                document.getElementById('items-container').innerHTML = renderKnapsackItems();\n            });\n            \n            document.getElementById('solve-knapsack').addEventListener('click', () => {\n                solveFractionalKnapsack();\n                document.getElementById('knapsack-visualization').innerHTML = renderKnapsackSolution();\n            });\n        }\n        \n        function solveFractionalKnapsack() {\n            // Calculate value per unit weight and sort\n            const items = algorithmState.items.map(item => ({\n                ...item,\n                ratio: item.value / item.weight\n            })).sort((a, b) => b.ratio - a.ratio);\n            \n            let remainingCapacity = algorithmState.capacity;\n            algorithmState.solution = [];\n            \n            for (const item of items) {\n                if (remainingCapacity <= 0) break;\n                \n                const taken = Math.min(item.weight, remainingCapacity);\n                const fraction = taken / item.weight;\n                const valueTaken = fraction * item.value;\n                \n                algorithmState.solution.push({\n                    weight: item.weight,\n                    value: item.value,\n                    taken,\n                    fraction,\n                    valueTaken\n                });\n                \n                remainingCapacity -= taken;\n            }\n        }\n        \n        function renderKnapsackItems() {\n            let html = \"<h3>Items:</h3><table><tr><th>Weight</th><th>Value</th><th>Value/Weight</th></tr>\";\n            \n            for (const item of algorithmState.items) {\n                const ratio = (item.value / item.weight).toFixed(2);\n                html += `<tr><td>${item.weight}</td><td>${item.value}</td><td>${ratio}</td></tr>`;\n            }\n            \n            html += \"</table>\";\n            return html;\n        }\n        \n        function renderKnapsackSolution() {\n            if (algorithmState.solution.length === 0) {\n                return \"<p>Click 'Solve' to find solution</p>\";\n            }\n            \n            let html = \"<h3>Solution:</h3><table><tr><th>Weight</th><th>Value</th><th>Fraction Taken</th><th>Value Taken</th></tr>\";\n            let totalWeight = 0;\n            let totalValue = 0;\n            \n            for (const item of algorithmState.solution) {\n                html += `<tr>\n                    <td>${item.weight}</td>\n                    <td>${item.value}</td>\n                    <td>${item.fraction.toFixed(2)}</td>\n                    <td>${item.valueTaken.toFixed(2)}</td>\n                </tr>`;\n                totalWeight += item.taken;\n                totalValue += item.valueTaken;\n            }\n            \n            html += `<tr>\n                <td><strong>${totalWeight.toFixed(2)}/${algorithmState.capacity}</strong></td>\n                <td colspan=\"3\"><strong>Total Value: ${totalValue.toFixed(2)}</strong></td>\n            </tr>`;\n            html += \"</table>\";\n            \n            return html;\n        }\n        \n        // Activity Selection\n        function initActivitySelection() {\n            algorithmContainer.innerHTML = `\n                <div class=\"algorithm-section\">\n                    <h2>${currentAlgorithm.name}</h2>\n                    <p>${currentAlgorithm.description}</p>\n                    \n                    <div class=\"controls\">\n                        <button id=\"add-activity\">Add Random Activity</button>\n                        <button id=\"solve-activity\">Solve</button>\n                        <button id=\"reset-activities\">Reset</button>\n                    </div>\n                    \n                    <div id=\"activities-container\">\n                        ${renderActivities()}\n                    </div>\n                    \n                    <div class=\"visualization\" id=\"activity-visualization\">\n                        ${renderActivitySolution()}\n                    </div>\n                    \n                    <div>\n                        <h3>How it works:</h3>\n                        <ol>\n                            <li>Sort activities by finish time</li>\n                            <li>Select first activity</li>\n                            <li>For each remaining activity, if it doesn't conflict with last selected, select it</li>\n                        </ol>\n                    </div>\n                </div>\n            `;\n            \n            document.getElementById('add-activity').addEventListener('click', () => {\n                const duration = Math.floor(Math.random() * 5) + 1;\n                const start = Math.floor(Math.random() * 20);\n                algorithmState.activities.push({\n                    start,\n                    end: start + duration\n                });\n                document.getElementById('activities-container').innerHTML = renderActivities();\n            });\n            \n            document.getElementById('solve-activity').addEventListener('click', () => {\n                solveActivitySelection();\n                document.getElementById('activity-visualization').innerHTML = renderActivitySolution();\n            });\n            \n            document.getElementById('reset-activities').addEventListener('click', () => {\n                algorithmState.activities = [];\n                algorithmState.solution = [];\n                document.getElementById('activities-container').innerHTML = renderActivities();\n                document.getElementById('activity-visualization').innerHTML = renderActivitySolution();\n            });\n        }\n        \n        function solveActivitySelection() {\n            // Sort activities by finish time\n            const activities = [...algorithmState.activities].sort((a, b) => a.end - b.end);\n            \n            algorithmState.solution = [];\n            let lastFinish = -Infinity;\n            \n            for (const activity of activities) {\n                if (activity.start >= lastFinish) {\n                    algorithmState.solution.push(activity);\n                    lastFinish = activity.end;\n                }\n            }\n        }\n        \n        function renderActivities() {\n            if (algorithmState.activities.length === 0) {\n                return \"<p>No activities. Click 'Add Random Activity' to add some.</p>\";\n            }\n            \n            let html = \"<h3>Activities:</h3><table><tr><th>Start</th><th>End</th></tr>\";\n            \n            for (const activity of algorithmState.activities) {\n                html += `<tr><td>${activity.start}</td><td>${activity.end}</td></tr>`;\n            }\n            \n            html += \"</table>\";\n            return html;\n        }\n        \n        function renderActivitySolution() {\n            if (algorithmState.solution.length === 0) {\n                return \"<p>Click 'Solve' to find solution</p>\";\n            }\n            \n            let html = \"<h3>Selected Activities:</h3><table><tr><th>Start</th><th>End</th></tr>\";\n            \n            for (const activity of algorithmState.solution) {\n                html += `<tr><td>${activity.start}</td><td>${activity.end}</td></tr>`;\n            }\n            \n            html += `<tr><td colspan=\"2\"><strong>Total: ${algorithmState.solution.length} activities</strong></td></tr>`;\n            html += \"</table>\";\n            \n            return html;\n        }\n        \n        // Huffman Coding\n        function initHuffmanCoding() {\n            algorithmContainer.innerHTML = `\n                <div class=\"algorithm-section\">\n                    <h2>${currentAlgorithm.name}</h2>\n                    <p>${currentAlgorithm.description}</p>\n                    \n                    <div class=\"controls\">\n                        <button id=\"add-character\">Add Random Character</button>\n                        <button id=\"solve-huffman\">Generate Codes</button>\n                        <button id=\"reset-huffman\">Reset</button>\n                    </div>\n                    \n                    <div id=\"characters-container\">\n                        ${renderCharacters()}\n                    </div>\n                    \n                    <div class=\"visualization\" id=\"huffman-visualization\">\n                        ${renderHuffmanCodes()}\n                    </div>\n                    \n                    <div>\n                        <h3>How it works:</h3>\n                        <ol>\n                            <li>Create leaf node for each character with frequency</li>\n                            <li>While more than one node in queue:\n                                <ul>\n                                    <li>Remove two nodes with lowest frequency</li>\n                                    <li>Create new internal node with these as children</li>\n                                    <li>Add new node back to queue</li>\n                                </ul>\n                            </li>\n                            <li>Assign binary codes by traversing the tree</li>\n                        </ol>\n                    </div>\n                </div>\n            `;\n            \n            document.getElementById('add-character').addEventListener('click', () => {\n                const char = String.fromCharCode(Math.floor(Math.random() * 26) + 97);\n                const freq = Math.floor(Math.random() * 20) + 1;\n                algorithmState.characters.push({char, freq});\n                document.getElementById('characters-container').innerHTML = renderCharacters();\n            });\n            \n            document.getElementById('solve-huffman').addEventListener('click', () => {\n                generateHuffmanCodes();\n                document.getElementById('huffman-visualization').innerHTML = renderHuffmanCodes();\n            });\n            \n            document.getElementById('reset-huffman').addEventListener('click', () => {\n                algorithmState.characters = [];\n                algorithmState.codes = {};\n                document.getElementById('characters-container').innerHTML = renderCharacters();\n                document.getElementById('huffman-visualization').innerHTML = renderHuffmanCodes();\n            });\n        }\n        \n        function generateHuffmanCodes() {\n            // Create nodes for each character\n            const nodes = algorithmState.characters.map(char => ({\n                type: 'leaf',\n                char: char.char,\n                freq: char.freq\n            }));\n            \n            // Sort nodes by frequency\n            nodes.sort((a, b) => a.freq - b.freq);\n            \n            // Build Huffman tree\n            while (nodes.length > 1) {\n                const left = nodes.shift();\n                const right = nodes.shift();\n                \n                const newNode = {\n                    type: 'node',\n                    left,\n                    right,\n                    freq: left.freq + right.freq\n                };\n                \n                // Insert new node in correct position\n                let insertAt = 0;\n                while (insertAt < nodes.length && nodes[insertAt].freq < newNode.freq) {\n                    insertAt++;\n                }\n                nodes.splice(insertAt, 0, newNode);\n            }\n            \n            // Generate codes by traversing the tree\n            algorithmState.codes = {};\n            if (nodes.length > 0) {\n                traverseTree(nodes[0], '');\n            }\n        }\n        \n        function traverseTree(node, code) {\n            if (node.type === 'leaf') {\n                algorithmState.codes[node.char] = code || '0'; // Handle single character case\n            } else {\n                if (node.left) traverseTree(node.left, code + '0');\n                if (node.right) traverseTree(node.right, code + '1');\n            }\n        }\n        \n        function renderCharacters() {\n            if (algorithmState.characters.length === 0) {\n                return \"<p>No characters. Click 'Add Random Character' to add some.</p>\";\n            }\n            \n            let html = \"<h3>Characters:</h3><table><tr><th>Character</th><th>Frequency</th></tr>\";\n            \n            for (const char of algorithmState.characters) {\n                html += `<tr><td>${char.char}</td><td>${char.freq}</td></tr>`;\n            }\n            \n            html += \"</table>\";\n            return html;\n        }\n        \n        function renderHuffmanCodes() {\n            if (Object.keys(algorithmState.codes).length === 0) {\n                return \"<p>Click 'Generate Codes' to create Huffman codes</p>\";\n            }\n            \n            let html = \"<h3>Huffman Codes:</h3><table><tr><th>Character</th><th>Code</th><th>Length</th></tr>\";\n            \n            for (const [char, code] of Object.entries(algorithmState.codes)) {\n                html += `<tr><td>${char}</td><td>${code}</td><td>${code.length}</td></tr>`;\n            }\n            \n            // Calculate average code length\n            let totalFreq = 0;\n            let weightedLength = 0;\n            \n            for (const char of algorithmState.characters) {\n                totalFreq += char.freq;\n                weightedLength += char.freq * algorithmState.codes[char.char].length;\n            }\n            \n            const avgLength = weightedLength / totalFreq;\n            \n            html += `<tr><td colspan=\"3\"><strong>Average code length: ${avgLength.toFixed(2)}</strong></td></tr>`;\n            html += \"</table>\";\n            \n            return html;\n        }\n        \n        // Initialize with first algorithm\n        window.addEventListener('load', () => {\n            currentAlgorithm = algorithms.coin;\n            algorithmState = JSON.parse(JSON.stringify(currentAlgorithm.state));\n            currentAlgorithm.init();\n        });\n    </script>\n</body>\n</html>"
  },
