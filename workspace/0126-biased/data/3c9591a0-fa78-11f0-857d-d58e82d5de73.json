    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Circular Linked List Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&family=Raleway&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #1f1c2c 0%, #928dab 100%);\n    font-family: 'Raleway', sans-serif;\n    color: #e6e8f0;\n    overflow: hidden;\n    user-select: none;\n  }\n  h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 2.8rem;\n    color: #f0f4f8;\n    text-align: center;\n    margin-top: 2rem;\n    letter-spacing: 0.06em;\n  }\n\n  /* Container for visualization */\n  #container {\n    position: relative;\n    width: 90vmin;\n    height: 90vmin;\n    max-width: 700px;\n    max-height: 700px;\n    margin: 3rem auto 5rem auto;\n    perspective: 1200px;\n  }\n\n  /* Circular linked list ring */\n  #circle {\n    position: relative;\n    width: 100%;\n    height: 100%;\n    border-radius: 50%;\n    box-shadow:\n      inset 0 0 50px 5px rgba(255 255 255 / 0.15),\n      0 0 20px 2px rgba(240 244 248 / 0.25);\n    background:\n      radial-gradient(circle at center, #3a324b 15%, #1f1c2c 85%);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    filter: drop-shadow(0 0 18px #9fa6cca6);\n  }\n\n  svg {\n    width: 100%; height: 100%;\n  }\n\n  /* Each node */\n  .node-group {\n    cursor: default;\n    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    transform-origin: center center;\n  }\n  .node-circle {\n    fill: #5d5ba7dd;\n    stroke: #9090cacc;\n    stroke-width: 2;\n    filter:\n      drop-shadow(0 2px 3px rgba(60,60,110,0.3));\n    transition: fill 0.3s ease, filter 0.3s ease;\n  }\n  .node-text {\n    fill: #e6e8f0ee;\n    font-weight: 600;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1.15rem;\n    user-select: none;\n    pointer-events: none;\n    filter: drop-shadow(0 0 6px #b4bbe677);\n  }\n\n  /* Arrow styling */\n  .arrowed-path {\n    fill: none;\n    stroke: #a8a4d0cc;\n    stroke-width: 3;\n    filter:\n      drop-shadow(0 0 8px #bcbdd9cc);\n    opacity: 0.85;\n    transition: stroke 0.4s ease;\n  }\n  .arrowhead {\n    fill: #b0afe0bb;\n    filter: drop-shadow(0 0 6px #a5a2dba8);\n    transition: fill 0.3s ease;\n    opacity: 0.9;\n  }\n\n  /* Highlight current node */\n  .current node-circle {\n    fill: #ffd166ff;\n    stroke: #ffca0077;\n    filter:\n      drop-shadow(0 0 10px #ffea7dcc);\n  }\n  .current .node-text {\n    fill: #4a3400;\n    filter: drop-shadow(0 0 12px #d9b340cc);\n  }\n\n  /* Buttons container */\n  #buttons {\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n    margin-bottom: 3rem;\n  }\n\n  button {\n    background: #5D5BA7;\n    border: none;\n    border-radius: 12px;\n    padding: 1rem 2.2rem;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1.15rem;\n    color: #f0f4f8;\n    box-shadow:\n      0 10px 25px rgba(93, 91, 167, 0.5);\n    cursor: pointer;\n    transition:\n      background-color 0.25s ease,\n      box-shadow 0.3s ease,\n      transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n    user-select: none;\n  }\n  button:hover {\n    background: #7e7adb;\n    box-shadow:\n      0 15px 35px rgba(126, 122, 219, 0.8);\n    transform: translateY(-3px);\n  }\n  button:active {\n    transform: translateY(1px);\n    box-shadow: 0 6px 15px rgba(93, 91, 167, 0.4);\n  }\n\n  /* Footer text */\n  footer {\n    text-align: center;\n    font-size: 0.85rem;\n    color: #a8a6bfaa;\n    font-family: 'Raleway', sans-serif;\n    margin-bottom: 1rem;\n  }\n\n</style>\n</head>\n<body>\n\n<h1>Circular Linked List Concept</h1>\n\n<div id=\"container\" aria-label=\"Circular linked list visualization with nodes and arrows\">\n  <svg aria-hidden=\"true\" id=\"visual-svg\" viewBox=\"0 0 700 700\" role=\"img\" >\n    <defs>\n      <marker id=\"arrowhead\" markerWidth=\"14\" markerHeight=\"11\" refX=\"12\" refY=\"5.5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n        <path d=\"M 0 0 L 12 5.5 L 0 11 z\" class=\"arrowhead\"/>\n      </marker>\n      <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\" >\n        <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"6\" flood-color=\"#f0e68cff\" flood-opacity=\"0.65\"/>\n      </filter>\n    </defs>\n    <!-- Circle ring for subtle glow -->\n    <circle cx=\"350\" cy=\"350\" r=\"320\" fill=\"none\" stroke=\"url(#gradientRing)\" stroke-width=\"20\" filter=\"url(#glow)\" opacity=\"0.15\" />\n  </svg>\n</div>\n\n<div id=\"buttons\" aria-label=\"Controls for circular linked list visualization\">\n  <button id=\"btnNext\" aria-label=\"Highlight next node\">Next</button>\n  <button id=\"btnReset\" aria-label=\"Reset to first node\">Reset</button>\n</div>\n\n<footer>\n  &copy; 2024 &nbsp; | &nbsp; Visualizing Data Structure Concepts \n</footer>\n\n<script>\n(() => {\n  const SVG_NS = \"http://www.w3.org/2000/svg\";\n  const container = document.getElementById('container');\n  const svg = document.getElementById('visual-svg');\n\n  // Configuration\n  const NODE_COUNT = 10;\n  const CENTER = { x: 350, y: 350 };\n  const RADIUS = 270;\n  const NODE_RADIUS = 32;\n\n  // Data for nodes (simple indices as values)\n  const nodes = Array.from({ length: NODE_COUNT }, (_, i) => ({\n    id: i,\n    value: `${i + 1}`\n  }));\n\n  // Hold references to node group elements for highlighting\n  const nodeGroups = [];\n\n  // Build arrowed curved path between nodes\n  function createArrowedLink(from, to) {\n    /* \n      For a smooth curved arrow between two points on circle\n      We'll use a quadratic bezier curve, with control point shifted towards outside of circle\n    */\n    const startAngle = from.angle;\n    const endAngle = to.angle;\n\n    // Calculate start and end points on circle circumference\n    const startX = CENTER.x + (RADIUS) * Math.cos(startAngle);\n    const startY = CENTER.y + (RADIUS) * Math.sin(startAngle);\n    const endX = CENTER.x + (RADIUS) * Math.cos(endAngle);\n    const endY = CENTER.y + (RADIUS) * Math.sin(endAngle);\n\n    // Control Point for bezier - hang outward from circle to create subtle arch\n    // Mid angle between start and end\n    let midAngle = (startAngle + endAngle) / 2;\n\n    // For angles crossing zero line, adjust midAngle within [0, 2pi]\n    if ((endAngle < startAngle) && (startAngle - endAngle > Math.PI)) {\n      midAngle += Math.PI;\n    }\n\n    // Adjust midAngle so arch bulges outside the circle\n    const controlRadius = RADIUS + 70; \n    const cx = CENTER.x + controlRadius * Math.cos(midAngle);\n    const cy = CENTER.y + controlRadius * Math.sin(midAngle);\n\n    // Path string quadratic bezier\n    const d = `M ${startX.toFixed(3)} ${startY.toFixed(3)} Q ${cx.toFixed(3)} ${cy.toFixed(3)} ${endX.toFixed(3)} ${endY.toFixed(3)}`;\n    return d;\n  }\n\n  // Create a node group with circle and text\n  function createNode(node, angleRad, index) {\n    const group = document.createElementNS(SVG_NS, 'g');\n    group.classList.add('node-group');\n    group.setAttribute('aria-label', `Node ${node.value}`);\n    group.setAttribute('role', 'listitem');\n\n    // Position around circle\n    const x = CENTER.x + RADIUS * Math.cos(angleRad);\n    const y = CENTER.y + RADIUS * Math.sin(angleRad);\n\n    group.setAttribute('transform', `translate(${x},${y})`);\n\n    // Circle\n    const circle = document.createElementNS(SVG_NS, 'circle');\n    circle.classList.add('node-circle');\n    circle.setAttribute('r', NODE_RADIUS);\n    circle.setAttribute('cx', 0);\n    circle.setAttribute('cy', 0);\n    group.appendChild(circle);\n\n    // Text\n    const text = document.createElementNS(SVG_NS, 'text');\n    text.classList.add('node-text');\n    text.setAttribute('x', 0);\n    text.setAttribute('y', 7); // approximate vertical centering\n    text.setAttribute('text-anchor', 'middle');\n    text.textContent = node.value;\n    group.appendChild(text);\n\n    svg.appendChild(group);\n\n    return { group, angle: angleRad };\n  }\n\n  // Create arrowed link path element\n  function createLink(d) {\n    const path = document.createElementNS(SVG_NS, 'path');\n    path.setAttribute('d', d);\n    path.setAttribute('stroke-linecap', 'round');\n    path.setAttribute('marker-end', 'url(#arrowhead)');\n    path.classList.add('arrowed-path');\n    svg.appendChild(path);\n    return path;\n  }\n\n  // Prepare nodes with positions and elements\n  nodes.forEach((node, i) => {\n    const angleRad = (i / NODE_COUNT) * 2 * Math.PI - Math.PI / 2;\n    node.angle = angleRad;\n  });\n\n  // Create nodes in SVG\n  for(let i=0; i < NODE_COUNT; i++) {\n    const { group } = createNode(nodes[i], nodes[i].angle, i);\n    nodeGroups.push(group);\n  }\n\n  // Create circular links between nodes (last to first as well)\n  const links = [];\n  for(let i=0; i < NODE_COUNT; i++) {\n    const fromNode = nodes[i];\n    const toNode = nodes[(i+1)%NODE_COUNT];\n    const d = createArrowedLink(fromNode, toNode);\n    links.push(createLink(d));\n  }\n\n  // Highlight logic\n  let currentIndex = 0;\n\n  function updateHighlight(newIndex) {\n    // Remove current highlights\n    nodeGroups.forEach(g => g.classList.remove('current'));\n    currentIndex = ((newIndex % NODE_COUNT) + NODE_COUNT) % NODE_COUNT;\n    nodeGroups[currentIndex].classList.add('current');\n    animatePulse(nodeGroups[currentIndex].querySelector('.node-circle'));\n  }\n\n  // Pulse animation on current node's circle\n  function animatePulse(circle) {\n    circle.animate([\n      { filter: 'drop-shadow(0 0 10px #ffea7dcc)', r: NODE_RADIUS},\n      { filter: 'drop-shadow(0 0 16px #ffea7dff)', r: NODE_RADIUS + 6 },\n      { filter: 'drop-shadow(0 0 10px #ffea7dcc)', r: NODE_RADIUS }\n    ], {\n      duration: 900,\n      easing: 'ease-out',\n      iterations: 1\n    });\n  }\n\n  // Initial highlight\n  updateHighlight(0);\n\n  // Button event handlers\n  document.getElementById('btnNext').addEventListener('click', () => {\n    updateHighlight(currentIndex + 1);\n  });\n\n  document.getElementById('btnReset').addEventListener('click', () => {\n    updateHighlight(0);\n  });\n\n  // Extra subtle continuous slow rotation of the entire circle for mesmerizing effect\n  let rotation = 0;\n  function rotateCircle() {\n    rotation += 0.05;\n    svg.style.transform = `rotate(${rotation}deg)`;\n    requestAnimationFrame(rotateCircle);\n  }\n  // Start rotation after short delay to not conflict with load animations\n  setTimeout(() => requestAnimationFrame(rotateCircle), 800);\n\n})();\n</script>\n\n</body>\n</html>"
