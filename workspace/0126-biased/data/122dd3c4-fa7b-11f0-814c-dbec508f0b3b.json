    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Typing</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n        }\n        \n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        \n        .header h1 {\n            font-size: 24px;\n            font-weight: bold;\n            margin-bottom: 10px;\n        }\n        \n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .button:hover {\n            background-color: #ccc;\n        }\n        \n        .input-field {\n            padding: 10px;\n            font-size: 16px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .input-field input[type=\"text\"] {\n            width: 100%;\n        }\n        \n        .button-container {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-top: 20px;\n        }\n        \n        .button-container button {\n            margin-right: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Dynamic Typing</h1>\n        </div>\n        <div class=\"button-container\">\n            <button class=\"button\">Button 1</button>\n            <button class=\"button\">Button 2</button>\n            <button class=\"button\">Button 3</button>\n            <button class=\"button\">Button 4</button>\n            <button class=\"button\">Button 5</button>\n            <button class=\"button\">Button 6</button>\n            <button class=\"button\">Button 7</button>\n            <button class=\"button\">Button 8</button>\n            <button class=\"button\">Button 9</button>\n            <button class=\"button\">Button 10</button>\n            <button class=\"button\">Button 11</button>\n            <button class=\"button\">Button 12</button>\n            <button class=\"button\">Button 13</button>\n            <button class=\"button\">Button 14</button>\n            <button class=\"button\">Button 15</button>\n            <button class=\"button\">Button 16</button>\n            <button class=\"button\">Button 17</button>\n            <button class=\"button\">Button 18</button>\n            <button class=\"button\">Button 19</button>\n            <button class=\"button\">Button 20</button>\n        </div>\n        <div class=\"input-field\">\n            <input type=\"text\" placeholder=\"Enter your name\">\n            <button class=\"button\">Submit</button>\n        </div>\n    </div>\n    <script>\n        let buttonCount = 0;\n        let inputField = document.querySelector('.input-field');\n        let inputFieldInput = document.querySelector('input[type=\"text\"]');\n        \n        inputFieldInput.addEventListener('input', function() {\n            buttonCount++;\n            document.querySelector('.button-container button').textContent = buttonCount;\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value.toUpperCase();\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value.toLowerCase();\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value.charAt(0).toUpperCase() + inputFieldInput.value.slice(1);\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + 'Hello';\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + ' World';\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + ' ' + inputFieldInput.value;\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + ' ' + inputFieldInput.value.charAt(0).toUpperCase() + inputFieldInput.value.slice(1);\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + ' ' + inputFieldInput.value.charAt(0).toUpperCase() + inputFieldInput.value.slice(1).toLowerCase();\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + ' ' + inputFieldInput.value.charAt(0).toUpperCase() + inputFieldInput.value.slice(1).toUpperCase();\n        });\n        \n        document.querySelector('.button-container button').addEventListener('click', function() {\n            inputFieldInput.value = inputFieldInput.value + ' ' + inputFieldInput.value.charAt(0).toUpperCase() + inputFieldInput.value.slice(1).toLowerCase().toUpperCase();\n        });\n        \n        document.querySe