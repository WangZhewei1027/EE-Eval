    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>SQL Concept — Exceptional Visual Design</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;700&family=Roboto+Slab:wght@700&display=swap');\n\n  /* Root & Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #010f24 0%, #0a2239 60%, #163a70 100%);\n    font-family: 'Roboto Slab', serif;\n    color: #e1e9f0;\n    overflow-x: hidden;\n  }\n\n  /* Container */\n  .container {\n    max-width: 960px;\n    margin: 0 auto;\n    padding: 3rem 2rem 5rem 2rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    user-select: none;\n  }\n\n  /* Title */\n  h1 {\n    font-size: 4rem;\n    letter-spacing: 0.15em;\n    font-weight: 700;\n    text-transform: uppercase;\n    margin-bottom: 0.25em;\n    background: linear-gradient(90deg, #6c9ef8, #50e3c2);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    filter: drop-shadow(0 0 6px #50e3c2aa);\n    animation: hueShift 15s linear infinite;\n  }\n  @keyframes hueShift {\n    0% { filter: drop-shadow(0 0 6px #50e3c2aa); }\n    50% { filter: drop-shadow(0 0 10px #6c9ef8cc); }\n    100% { filter: drop-shadow(0 0 6px #50e3c2aa); }\n  }\n\n  /* Subtitle */\n  .subtitle {\n    font-family: 'Fira Code', monospace;\n    font-size: 1.25rem;\n    font-weight: 400;\n    color: #a3b1cc;\n    margin-bottom: 3rem;\n    letter-spacing: 0.07em;\n  }\n\n  /* SQL Visual Diagram */\n  .sql-diagram {\n    position: relative;\n    background: rgba(30, 57, 100, 0.4);\n    border-radius: 1.25rem;\n    padding: 2.5rem 3rem;\n    box-shadow:\n      inset 0 0 25px 1px rgba(80, 230, 194, 0.3),\n      0 0 50px 6px rgba(80, 227, 194, 0.15);\n    backdrop-filter: saturate(180%) blur(12px);\n    width: 100%;\n    max-width: 900px;\n    user-select: none;\n  }\n\n  /* Tables Container */\n  .tables {\n    display: flex;\n    justify-content: space-around;\n    gap: 2.5rem;\n    flex-wrap: wrap;\n  }\n\n  /* Single Table */\n  .table {\n    background: linear-gradient(145deg, #164a82, #0b2b57);\n    border-radius: 1rem;\n    width: 260px;\n    box-shadow:\n      5px 5px 15px #0a1b2fcc,\n      -5px -5px 15px #245b9ecc;\n    transition: transform 0.3s ease;\n    cursor: default;\n  }\n  .table:hover {\n    transform: translateY(-10px) scale(1.05);\n  }\n\n  /* Table Title */\n  .table-title {\n    background: linear-gradient(120deg, #50e3c2, #6c9ef8);\n    padding: 1rem 1.25rem;\n    border-top-left-radius: 1rem;\n    border-top-right-radius: 1rem;\n    font-size: 1.35rem;\n    font-weight: 700;\n    color: #fff;\n    text-align: center;\n    letter-spacing: 0.07em;\n    box-shadow: 0 0 20px #50e3c2aa;\n    user-select: text;\n  }\n\n  /* Columns List */\n  ul.columns {\n    list-style: none;\n    padding: 1.5rem 1.5rem 1.5rem 1.5rem;\n    margin: 0;\n    font-family: 'Fira Code', monospace;\n    font-weight: 500;\n    font-size: 1rem;\n    line-height: 1.6;\n    color: #a3b1cc;\n  }\n\n  ul.columns li {\n    position: relative;\n    padding-left: 1.75rem;\n    margin-bottom: 1rem;\n    transition: color 0.3s ease;\n  }\n\n  ul.columns li:last-child {\n    margin-bottom: 0;\n  }\n\n  /* Highlight Primary Key & Foreign Key */\n  ul.columns li.pk::before {\n    content: \"PK\";\n    position: absolute;\n    left: 0;\n    top: 50%;\n    transform: translateY(-50%);\n    background: #50e3c2;\n    color: #04272f;\n    font-weight: 700;\n    font-size: 0.7rem;\n    font-family: 'Fira Code', monospace;\n    padding: 0.15rem 0.4rem;\n    border-radius: 0.3rem;\n    letter-spacing: 0.1em;\n    user-select: none;\n    box-shadow: 0 0 6px #47cfb6aa;\n  }\n  ul.columns li.fk::before {\n    content: \"FK\";\n    position: absolute;\n    left: 0;\n    top: 50%;\n    transform: translateY(-50%);\n    background: #6c9ef8;\n    color: #0b2660;\n    font-weight: 700;\n    font-size: 0.7rem;\n    font-family: 'Fira Code', monospace;\n    padding: 0.15rem 0.4rem;\n    border-radius: 0.3rem;\n    letter-spacing: 0.1em;\n    user-select: none;\n    box-shadow: 0 0 6px #5b8dfb99;\n  }\n\n  /* SQL Keywords Glossary */\n  .glossary {\n    margin-top: 4rem;\n    padding: 2rem 3rem;\n    background: rgba(80, 230, 194, 0.1);\n    border-radius: 2rem;\n    box-shadow: 0 0 40px #50e3c277;\n    max-width: 900px;\n    font-family: 'Fira Code', monospace;\n    font-size: 1rem;\n    color: #ccf8f1dd;\n  }\n  .glossary h2 {\n    font-family: 'Roboto Slab', serif;\n    font-weight: 700;\n    color: #50e3c2;\n    font-size: 2rem;\n    margin-bottom: 1.25rem;\n    letter-spacing: 0.07em;\n    user-select: text;\n  }\n\n  .glossary dl {\n    display: grid;\n    grid-template-columns: max-content 1fr;\n    row-gap: 1rem;\n    column-gap: 2rem;\n  }\n  .glossary dt {\n    color: #a3b1cc;\n    font-weight: 700;\n    user-select: text;\n    letter-spacing: 0.05em;\n  }\n  .glossary dd {\n    margin: 0;\n    color: #d0f7f0cc;\n    user-select: text;\n    font-weight: 500;\n    line-height: 1.4;\n  }\n\n  /* Button */\n  .btn-container {\n    margin-top: 3.5rem;\n    display: flex;\n    gap: 2rem;\n    justify-content: center;\n  }\n  button {\n    background: linear-gradient(135deg, #50e3c2 0%, #6c9ef8 100%);\n    border: none;\n    color: #04272f;\n    font-family: 'Fira Code', monospace;\n    font-weight: 700;\n    padding: 0.9rem 2.3rem;\n    font-size: 1rem;\n    letter-spacing: 0.1em;\n    border-radius: 3rem;\n    box-shadow: 0 0 20px #50e3c2cc;\n    cursor: pointer;\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n    user-select: none;\n    outline-offset: 3px;\n  }\n  button:focus-visible {\n    outline: 2px solid #99f6f2;\n    outline-offset: 4px;\n  }\n  button:hover {\n    transform: scale(1.1);\n    box-shadow: 0 0 35px #6c9ef8cc;\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Glow Animations */\n  @keyframes glowPulse {\n    0%, 100% {\n      box-shadow: 0 0 12px #50e3c2dd, 0 0 35px #6c9ef8aa;\n    }\n    50% {\n      box-shadow: 0 0 25px #50e3c2ff, 0 0 60px #6c9ef8ff;\n    }\n  }\n\n  /* Connections lines */\n  svg.connections {\n    position: absolute;\n    pointer-events: none;\n    top: 0; left: 0;\n    width: 100%; height: 100%;\n    overflow: visible;\n  }\n  path.connection-line {\n    fill: none;\n    stroke: #50e3c2cc;\n    stroke-width: 3;\n    filter: drop-shadow(0 0 4px #50e3c2aa);\n    stroke-linecap: round;\n    opacity: 0.85;\n    transition: stroke 0.3s ease;\n  }\n  path.connection-line.highlight {\n    stroke: #6c9ef8ff;\n    opacity: 1;\n    stroke-width: 4;\n    filter: drop-shadow(0 0 10px #6c9ef8dd);\n  }\n\n  /* Responsive typography */\n  @media (max-width: 480px) {\n    h1 {\n      font-size: 3rem;\n    }\n    .table {\n      width: 100%;\n      max-width: 320px;\n    }\n    .tables {\n      flex-direction: column;\n      align-items: center;\n      gap: 3rem;\n    }\n    .glossary {\n      padding: 1.5rem 1.75rem;\n      font-size: 0.9rem;\n    }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\" role=\"main\" aria-label=\"SQL Concept Visualization\">\n\n  <h1>SQL</h1>\n  <p class=\"subtitle\">Structured Query Language — Organizing & Querying Data</p>\n\n  <div class=\"sql-diagram\" aria-describedby=\"desc-diagram\" tabindex=\"0\">\n    <p id=\"desc-diagram\" class=\"sr-only\">Diagram showing three database tables with keys and links representing relations.</p>\n    <div class=\"tables\" aria-label=\"Database Tables\">\n\n      <section class=\"table\" id=\"table-customers\" aria-labelledby=\"title-customers\" tabindex=\"-1\">\n        <h3 class=\"table-title\" id=\"title-customers\">Customers</h3>\n        <ul class=\"columns\">\n          <li class=\"pk\">customer_id</li>\n          <li>first_name</li>\n          <li>last_name</li>\n          <li>email</li>\n        </ul>\n      </section>\n\n      <section class=\"table\" id=\"table-orders\" aria-labelledby=\"title-orders\" tabindex=\"-1\">\n        <h3 class=\"table-title\" id=\"title-orders\">Orders</h3>\n        <ul class=\"columns\">\n          <li class=\"pk\">order_id</li>\n          <li class=\"fk\">customer_id</li>\n          <li>order_date</li>\n          <li>status</li>\n        </ul>\n      </section>\n\n      <section class=\"table\" id=\"table-products\" aria-labelledby=\"title-products\" tabindex=\"-1\">\n        <h3 class=\"table-title\" id=\"title-products\">Products</h3>\n        <ul class=\"columns\">\n          <li class=\"pk\">product_id</li>\n          <li>name</li>\n          <li>price</li>\n        </ul>\n      </section>\n\n    </div>\n\n    <svg class=\"connections\" aria-hidden=\"true\" focusable=\"false\" preserveAspectRatio=\"none\">\n      <path id=\"line-cust-orders\" class=\"connection-line\" />\n    </svg>\n\n  </div>\n\n  <div class=\"glossary\" aria-label=\"SQL keywords glossary\">\n    <h2>Essential SQL Keywords</h2>\n    <dl>\n      <dt>SELECT</dt>\n      <dd>Retrieve data from one or more tables.</dd>\n      <dt>FROM</dt>\n      <dd>Specify the tables to retrieve data from.</dd>\n      <dt>WHERE</dt>\n      <dd>Filter rows based on conditions.</dd>\n      <dt>JOIN</dt>\n      <dd>Combine rows from two or more tables based on related columns.</dd>\n      <dt>INSERT</dt>\n      <dd>Add new data rows to a table.</dd>\n      <dt>UPDATE</dt>\n      <dd>Modify existing data in a table.</dd>\n      <dt>DELETE</dt>\n      <dd>Remove data rows from a table.</dd>\n    </dl>\n  </div>\n\n  <div class=\"btn-container\">\n    <button id=\"btn-toggle-connections\" aria-pressed=\"true\" aria-label=\"Toggle display of relation lines\">Toggle Relations</button>\n    <button id=\"btn-highlight-fk\" aria-label=\"Highlight foreign key columns\">Highlight Foreign Keys</button>\n  </div>\n\n</div>\n\n<script>\n  // Smooth line drawing between customer_id in Customers and Orders.customer_id\n  const svg = document.querySelector('svg.connections');\n  const lineCustOrders = document.getElementById('line-cust-orders');\n  const customersTable = document.getElementById('table-customers');\n  const ordersTable = document.getElementById('table-orders');\n  const fkItems = document.querySelectorAll('ul.columns li.fk');\n  const btnToggle = document.getElementById('btn-toggle-connections');\n  const btnHighlight = document.getElementById('btn-highlight-fk');\n  let fkHighlighted = false;\n  let relationsShown = true;\n\n  function getColumnCenter(table, columnClass) {\n    const col = table.querySelector('ul.columns li.' + columnClass);\n    if (!col) return null;\n    const rectCol = col.getBoundingClientRect();\n    const rectTbl = table.getBoundingClientRect();\n    // relative position inside .sql-diagram container\n    const containerRect = svg.parentElement.getBoundingClientRect();\n    const x = rectCol.left + rectCol.width / 2 - containerRect.left;\n    const y = rectCol.top + rectCol.height / 2 - containerRect.top;\n    return { x, y };\n  }\n\n  function updateConnectionLines() {\n    if (!relationsShown) return;\n    const start = getColumnCenter(customersTable, 'pk');\n    const end = getColumnCenter(ordersTable, 'fk');\n    if(!start || !end) return;\n\n    // Cubic Bezier curve path: horizontal S curve\n    const path = `\n      M ${start.x} ${start.y}\n      C ${start.x + 80} ${start.y},\n        ${end.x - 80} ${end.y},\n        ${end.x} ${end.y}\n    `;\n    lineCustOrders.setAttribute('d', path);\n  }\n\n  function toggleRelations() {\n    relationsShown = !relationsShown;\n    lineCustOrders.style.display = relationsShown ? 'block' : 'none';\n    btnToggle.setAttribute('aria-pressed', relationsShown);\n  }\n\n  function toggleFKHighlight() {\n    fkHighlighted = !fkHighlighted;\n    fkItems.forEach(li => {\n      if (fkHighlighted) {\n        li.style.color = '#6c9ef8';\n        li.style.textShadow = '0 0 6px #6c9ef8cc';\n      } else {\n        li.style.color = '';\n        li.style.textShadow = '';\n      }\n    });\n  }\n\n  // Initial setup\n  updateConnectionLines();\n\n  // Handle window resize to adjust lines\n  window.addEventListener('resize', () => {\n    updateConnectionLines();\n  });\n\n  // Button events\n  btnToggle.addEventListener('click', () => {\n    toggleRelations();\n  });\n\n  btnHighlight.addEventListener('click', () => {\n    toggleFKHighlight();\n  });\n\n  // Animate subtle text glow on primary key columns\n  const pkItems = document.querySelectorAll('ul.columns li.pk');\n  pkItems.forEach(pk => {\n    pk.style.animation = 'glowPulse 3s ease-in-out infinite alternate';\n  });\n</script>\n\n<!-- Invisible aria helper for screen readers -->\n<style>\n  .sr-only {\n    position: absolute !important;\n    width: 1px !important;\n    height: 1px !important;\n    padding: 0 !important;\n    margin: -1px !important;\n    overflow: hidden !important;\n    clip: rect(0,0,0,0) !important;\n    border: 0 !important;\n  }\n</style>\n</body>\n</html>"
  },
