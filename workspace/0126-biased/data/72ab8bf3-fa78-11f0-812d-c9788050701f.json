    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deadlock: A Visual Elegy</title>\n    <style>\n        :root {\n            --primary: #4a4e69;\n            --secondary: #9a8c98;\n            --accent: #c9ada7;\n            --light: #f2e9e4;\n            --dark: #22223b;\n            --highlight: #e63946;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Avenir Next', 'Segoe UI', sans-serif;\n            background: var(--dark);\n            color: var(--light);\n            height: 100vh;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 900px;\n            padding: 2rem;\n            position: relative;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            text-align: center;\n            margin-bottom: 2rem;\n            letter-spacing: 1px;\n            color: var(--accent);\n            text-shadow: 0 2px 10px rgba(0,0,0,0.2);\n        }\n\n        .subtitle {\n            text-align: center;\n            font-size: 1.2rem;\n            margin-bottom: 3rem;\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 600px;\n            margin-left: auto;\n            margin-right: auto;\n            line-height: 1.6;\n        }\n\n        .deadlock-visualization {\n            height: 400px;\n            position: relative;\n            margin: 3rem 0;\n        }\n\n        .resource {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            color: var(--dark);\n            box-shadow: 0 10px 30px rgba(0,0,0,0.3);\n            transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);\n            z-index: 2;\n        }\n\n        .resource-a {\n            background: var(--accent);\n            top: 50%;\n            left: 30%;\n            transform: translate(-50%, -50%);\n        }\n\n        .resource-b {\n            background: var(--highlight);\n            top: 50%;\n            left: 70%;\n            transform: translate(-50%, -50%);\n        }\n\n        .process {\n            position: absolute;\n            width: 100px;\n            height: 100px;\n            border-radius: 5px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            box-shadow: 0 5px 20px rgba(0,0,0,0.2);\n            transition: all 1.5s cubic-bezier(0.19, 1, 0.22, 1);\n            z-index: 1;\n        }\n\n        .process-1 {\n            background: var(--primary);\n            top: 30%;\n            left: 30%;\n            color: var(--light);\n        }\n\n        .process-2 {\n            background: var(--secondary);\n            top: 30%;\n            left: 70%;\n            color: var(--dark);\n        }\n\n        .connection {\n            position: absolute;\n            height: 4px;\n            background: var(--light);\n            transform-origin: left center;\n            z-index: 0;\n            opacity: 0.6;\n            transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n        }\n\n        button {\n            background: transparent;\n            border: 1px solid var(--accent);\n            color: var(--accent);\n            padding: 0.8rem 2rem;\n            font-size: 1rem;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            outline: none;\n            margin: 0 1rem;\n        }\n\n        button:hover {\n            background: var(--accent);\n            color: var(--dark);\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n            gap: 2rem;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 3px;\n            margin-right: 0.5rem;\n        }\n\n        .legend-text {\n            font-size: 0.9rem;\n            opacity: 0.8;\n        }\n\n        .explanation {\n            max-width: 600px;\n            margin: 3rem auto 0;\n            text-align: center;\n            font-size: 1rem;\n            line-height: 1.6;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 1s ease;\n        }\n\n        .show-explanation {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Deadlock</h1>\n        <p class=\"subtitle\">A state where two or more processes are unable to proceed because each is waiting for the other to release a resource</p>\n        \n        <div class=\"deadlock-visualization\">\n            <div class=\"resource resource-a\">R1</div>\n            <div class=\"resource resource-b\">R2</div>\n            \n            <div class=\"process process-1\">P1</div>\n            <div class=\"process process-2\">P2</div>\n            \n            <div class=\"connection connection-1\"></div>\n            <div class=\"connection connection-2\"></div>\n            <div class=\"connection connection-3\"></div>\n            <div class=\"connection connection-4\"></div>\n        </div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--primary);\"></div>\n                <div class=\"legend-text\">Process 1</div>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--secondary);\"></div>\n                <div class=\"legend-text\">Process 2</div>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--accent); border-radius: 50%;\"></div>\n                <div class=\"legend-text\">Resource 1</div>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--highlight); border-radius: 50%;\"></div>\n                <div class=\"legend-text\">Resource 2</div>\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"animate-btn\">Animate Deadlock</button>\n            <button id=\"reset-btn\">Reset</button>\n        </div>\n        \n        <div class=\"explanation\" id=\"explanation\">\n            In this deadlock scenario:\n            <br><br>\n            • Process 1 holds Resource 1 and requests Resource 2\n            <br>\n            • Process 2 holds Resource 2 and requests Resource 1\n            <br><br>\n            Neither process can proceed until the other releases its resource, resulting in a permanent blocking state.\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const animateBtn = document.getElementById('animate-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            const explanation = document.getElementById('explanation');\n            \n            const process1 = document.querySelector('.process-1');\n            const process2 = document.querySelector('.process-2');\n            const resourceA = document.querySelector('.resource-a');\n            const resourceB = document.querySelector('.resource-b');\n            const connection1 = document.querySelector('.connection-1');\n            const connection2 = document.querySelector('.connection-2');\n            const connection3 = document.querySelector('.connection-3');\n            const connection4 = document.querySelector('.connection-4');\n            \n            function animateDeadlock() {\n                // Move processes to resources\n                process1.style.top = '50%';\n                process1.style.left = '70%';\n                \n                process2.style.top = '50%';\n                process2.style.left = '30%';\n                \n                // Move resources slightly\n                resourceA.style.top = '30%';\n                resourceB.style.top = '70%';\n                \n                // Draw connections\n                setTimeout(() => {\n                    // P1 holds R1 (already has it)\n                    connection1.style.width = '80px';\n                    connection1.style.left = '30%';\n                    connection1.style.top = '50%';\n                    connection1.style.transform = 'rotate(45deg)';\n                    \n                    // P1 requests R2\n                    connection2.style.width = '150px';\n                    connection2.style.left = '30%';\n                    connection2.style.top = '50%';\n                    connection2.style.transform = 'rotate(135deg)';\n                    \n                    // P2 holds R2\n                    connection3.style.width = '80px';\n                    connection3.style.left = '70%';\n                    connection3.style.top = '50%';\n                    connection3.style.transform = 'rotate(-45deg)';\n                    \n                    // P2 requests R1\n                    connection4.style.width = '150px';\n                    connection4.style.left = '70%';\n                    connection4.style.top = '50%';\n                    connection4.style.transform = 'rotate(-135deg)';\n                    \n                    // Pulse the processes to show they're stuck\n                    process1.classList.add('pulse');\n                    process2.classList.add('pulse');\n                    \n                    // Show explanation\n                    setTimeout(() => {\n                        explanation.classList.add('show-explanation');\n                    }, 1000);\n                }, 1000);\n                \n                animateBtn.disabled = true;\n            }\n            \n            function resetAnimation() {\n                // Reset positions\n                process1.style.top = '30%';\n                process1.style.left = '30%';\n                \n                process2.style.top = '30%';\n                process2.style.left = '70%';\n                \n                resourceA.style.top = '50%';\n                resourceB.style.top = '50%';\n                \n                // Hide connections\n                connection1.style.width = '0';\n                connection2.style.width = '0';\n                connection3.style.width = '0';\n                connection4.style.width = '0';\n                \n                // Remove pulse\n                process1.classList.remove('pulse');\n                process2.classList.remove('pulse');\n                \n                // Hide explanation\n                explanation.classList.remove('show-explanation');\n                \n                animateBtn.disabled = false;\n            }\n            \n            animateBtn.addEventListener('click', animateDeadlock);\n            resetBtn.addEventListener('click', resetAnimation);\n            \n            // Initial reset to ensure proper positioning\n            resetAnimation();\n        });\n    </script>\n</body>\n</html>"
