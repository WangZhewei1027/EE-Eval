    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Tree Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: #f4f4f9;\n            margin: 0;\n            padding: 20px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        h1 {\n            text-align: center;\n            color: #333;\n            margin-bottom: 20px;\n        }\n        #tree {\n            position: relative;\n            height: 500px;\n            width: 100%;\n            max-width: 800px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        .node {\n            width: 60px;\n            height: 60px;\n            background: #3a7bd5;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-size: 24px;\n            position: absolute;\n            transition: transform 0.3s ease;\n        }\n        .line {\n            position: absolute;\n            height: 2px;\n            background: #aaa;\n            transition: all 0.3s ease;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Binary Tree Visualization</h1>\n    <div id=\"tree\"></div>\n    <button id=\"animateBtn\">Animate Tree</button>\n\n    <script>\n        const tree = document.getElementById(\"tree\");\n        const animateBtn = document.getElementById(\"animateBtn\");\n        let animated = false;\n\n        function createNode(value, x, y) {\n            const node = document.createElement(\"div\");\n            node.className = \"node\";\n            node.innerHTML = value;\n            node.style.transform = `translate(-50%, -50%) translate(${x}px, ${y}px)`;\n            return node;\n        }\n\n        function createLine(x1, y1, x2, y2) {\n            const line = document.createElement(\"div\");\n            line.className = \"line\";\n            const x = Math.min(x1, x2) + Math.abs(x2 - x1) / 2;\n            const y = Math.min(y1, y2) + Math.abs(y2 - y1) / 2;\n            line.style.left = `${x}px`;\n            line.style.top = `${y}px`;\n            line.style.width = `${Math.abs(x2 - x1)}px`;\n            line.style.transform = `translate(-50%, -50%) rotate(${Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI}deg)`;\n            return line;\n        }\n\n        function drawTree() {\n            const nodesData = [\n                { value: '1', x: 400, y: 50 },\n                { value: '2', x: 200, y: 150 },\n                { value: '3', x: 600, y: 150 },\n                { value: '4', x: 100, y: 250 },\n                { value: '5', x: 300, y: 250 },\n                { value: '6', x: 500, y: 250 },\n                { value: '7', x: 700, y: 250 }\n            ];\n\n            nodesData.forEach(nodeData => {\n                const node = createNode(nodeData.value, nodeData.x, nodeData.y);\n                tree.appendChild(node);\n            });\n\n            const edges = [\n                { from: { x: 400, y: 50 }, to: { x: 200, y: 150 } },\n                { from: { x: 400, y: 50 }, to: { x: 600, y: 150 } },\n                { from: { x: 200, y: 150 }, to: { x: 100, y: 250 } },\n                { from: { x: 200, y: 150 }, to: { x: 300, y: 250 } },\n                { from: { x: 600, y: 150 }, to: { x: 500, y: 250 } },\n                { from: { x: 600, y: 150 }, to: { x: 700, y: 250 } }\n            ];\n\n            edges.forEach(edge => {\n                const line = createLine(edge.from.x, edge.from.y, edge.to.x, edge.to.y);\n                tree.appendChild(line);\n            });\n        }\n\n        animateBtn.addEventListener(\"click\", () => {\n            if (!animated) {\n                tree.style.transform = \"translateY(-10px)\";\n                setTimeout(() => {\n                    tree.style.transform = \"translateY(10px)\";\n                }, 200);\n                setTimeout(() => {\n                    tree.style.transform = \"translateY(0)\";\n                }, 400);\n                animated = true;\n            } else {\n                alert(\"Animation already played!\");\n            }\n        });\n\n        drawTree();\n\n    </script>\n</body>\n</html>"
