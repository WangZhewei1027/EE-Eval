rest Neighbors Visualization</h1>\n    </div>\n    <div class=\"canvas\" id=\"canvas\"></div>\n    <button class=\"button\" onclick=\"generateData()\">Generate New Data</button>\n</div>\n\n<script>\n    const canvas = document.getElementById('canvas');\n    \n    function generateData() {\n        canvas.innerHTML = ''; // Clear previous points\n        const points = 50;\n\n        for (let i = 0; i < points; i++) {\n            const pointDiv = document.createElement('div');\n            const x = Math.random() * 100; \n            const y = Math.random() * 100; \n            pointDiv.classList.add('point');\n            pointDiv.style.width = '10px';\n            pointDiv.style.height = '10px';\n            pointDiv.style.backgroundColor = Math.random() > 0.5 ? '#ff6347' : '#1e90ff';\n            pointDiv.style.left = `${x}%`;\n            pointDiv.style.top = `${y}%`;\n            canvas.appendChild(pointDiv);\n        }\n    }\n\n    // Generate initial data on load\n    generateData();\n</script>\n\n</body>\n</html>"
