    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\" />\n<title>Abstract Syntax Tree Interactive Explorer</title>\n<style>\n/* Extremely minimal styling - plain black text on white background */\nbody { margin: 10px; font-family: monospace; color: black; background: white; }\nbutton, input, select, textarea { font-family: monospace; }\n.container { display: flex; gap: 10px; }\n.column { flex: 1 1 0; min-width: 200px; max-width: 50%; }\n.section { margin-bottom: 10px; }\n.small { font-size: 12px; }\n.tree { white-space: pre; overflow: auto; max-height: 480px; border: 1px solid #000; padding: 6px; }\n.jsonarea { width: 100%; height: 220px; }\ntextarea { width: 100%; }\n.controls { display: flex; gap: 6px; flex-wrap: wrap; }\n.node-row { margin: 2px 0; }\n.list { max-height: 140px; overflow: auto; border: 1px solid #000; padding: 4px; }\n.rightpanel { display: flex; flex-direction: column; gap: 8px; }\nlabel { margin-right: 4px; }\n</style>\n</head>\n<body>\n\n<h2>Abstract Syntax Tree - Interactive Explorer</h2>\n\n<div class=\"container\">\n  <div class=\"column\" id=\"leftColumn\">\n    <div class=\"section\">\n      <div><strong>Code / Input</strong></div>\n      <textarea id=\"codeInput\" rows=\"10\" cols=\"60\">a = 2 + 3 * (4 - 1);\nb = a * 5;\na + b</textarea>\n      <div class=\"controls\">\n        <label for=\"parserSelect\">Parser:</label>\n        <select id=\"parserSelect\">\n          <option value=\"expr\">Expression/Statements Parser</option>\n          <option value=\"json\">AST JSON (paste AST)</option>\n        </select>\n        <button id=\"parseBtn\">Parse → AST</button>\n        <button id=\"resetBtn\">Reset</button>\n        <button id=\"loadSampleBtn\">Load Samples</button>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Samples</strong></div>\n      <select id=\"sampleSelect\" size=\"4\" class=\"list\">\n        <option value=\"simple\">Simple arithmetic (a = 2 + 3 * (4 - 1);)</option>\n        <option value=\"calls\">Function calls (f(x, y + 1))</option>\n        <option value=\"assigns\">Sequence & assigns (x=1; y=x+2; z=y*3)</option>\n        <option value=\"manual\">Manual AST example (JSON)</option>\n      </select>\n      <div class=\"controls\">\n        <button id=\"applySampleBtn\">Load into Input</button>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Traversal Controls</strong></div>\n      <div class=\"controls\">\n        <label for=\"traversalSelect\">Order:</label>\n        <select id=\"traversalSelect\">\n          <option value=\"pre\">Pre-order</option>\n          <option value=\"post\">Post-order</option>\n          <option value=\"breadth\">Breadth-first</option>\n        </select>\n        <button id=\"startTraversalBtn\">Start</button>\n        <button id=\"stepBackBtn\">Step ←</button>\n        <button id=\"stepForwardBtn\">Step →</button>\n        <button id=\"stopTraversalBtn\">Stop</button>\n        <label for=\"speedRange\">Speed</label>\n        <input id=\"speedRange\" type=\"range\" min=\"100\" max=\"2000\" step=\"100\" value=\"600\">\n      </div>\n      <div id=\"traversalStatus\" class=\"small\">Traversal status: stopped</div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Search</strong></div>\n      <input id=\"searchInput\" placeholder=\"Regex on type or value\" />\n      <button id=\"searchBtn\">Search</button>\n      <button id=\"clearSearchBtn\">Clear</button>\n      <div id=\"searchResults\" class=\"small\"></div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Snapshots & History</strong></div>\n      <div class=\"controls\">\n        <input id=\"snapshotName\" placeholder=\"snapshot name\" />\n        <button id=\"saveSnapBtn\">Save Snapshot</button>\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n      </div>\n      <div id=\"snapList\" class=\"list small\"></div>\n    </div>\n\n  </div>\n\n  <div class=\"column\" id=\"centerColumn\">\n    <div class=\"section\">\n      <div><strong>AST View</strong></div>\n      <div class=\"controls\">\n        <button id=\"expandAllBtn\">Expand All</button>\n        <button id=\"collapseAllBtn\">Collapse All</button>\n        <label for=\"collapseDepth\">Collapse to depth</label>\n        <input id=\"collapseDepth\" type=\"number\" min=\"0\" value=\"2\" style=\"width:60px\">\n        <button id=\"applyCollapseBtn\">Apply</button>\n        <button id=\"showJsonBtn\">Show AST JSON</button>\n        <button id=\"exportJsonBtn\">Export JSON</button>\n      </div>\n      <div id=\"astTree\" class=\"tree\" tabindex=\"0\"></div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Code Generation / Evaluation</strong></div>\n      <div class=\"controls\">\n        <button id=\"genCodeBtn\">Generate Code</button>\n        <button id=\"evalBtn\">Evaluate (if possible)</button>\n        <button id=\"prettyPrintBtn\">Pretty Print AST</button>\n        <button id=\"manualEditBtn\">Edit AST JSON Manually</button>\n      </div>\n      <textarea id=\"codeOutput\" rows=\"6\" cols=\"60\" readonly></textarea>\n      <div id=\"evalOutput\" class=\"small\"></div>\n    </div>\n\n  </div>\n\n  <div class=\"column rightpanel\" id=\"rightColumn\">\n    <div class=\"section\">\n      <div><strong>Node Inspector</strong></div>\n      <div id=\"selectedPath\" class=\"small\">No node selected</div>\n      <div id=\"nodeDetails\" class=\"node-row\">\n        <label>Type:</label><input id=\"nodeType\" />\n        <label>Value:</label><input id=\"nodeValue\" />\n      </div>\n      <div class=\"controls\">\n        <button id=\"updateNodeBtn\">Update Node</button>\n        <button id=\"deleteNodeBtn\">Delete Node</button>\n        <button id=\"addChildBtn\">Add Child</button>\n        <button id=\"wrapNodeBtn\">Wrap Node</button>\n      </div>\n      <div class=\"small\">Add child: type and optional value</div>\n      <input id=\"newChildType\" placeholder=\"type\" style=\"width:60px\" />\n      <input id=\"newChildValue\" placeholder=\"value\" style=\"width:90px\" />\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Transforms</strong></div>\n      <div class=\"controls\">\n        <button id=\"constFoldBtn\">Constant Fold</button>\n        <button id=\"renameBtn\">Rename Identifier</button>\n        <input id=\"renameFrom\" placeholder=\"from\" style=\"width:70px\" />\n        <input id=\"renameTo\" placeholder=\"to\" style=\"width:70px\" />\n        <button id=\"removeDeadBtn\">Remove Dead Assignments</button>\n      </div>\n      <div class=\"small\">Custom transform (JS): function transform(node, utils) { ...; return node; }</div>\n      <textarea id=\"customTransform\" rows=\"6\" class=\"jsonarea\">// Example: inline constant folding for binops\nfunction transform(node, utils) {\n  if (node.type === 'BinaryExpression') {\n    node.children = node.children.map(c => transform(c, utils));\n    if (node.children.length === 2 &&\n        node.children[0].type === 'Literal' &&\n        node.children[1].type === 'Literal') {\n      return utils.evalBinary(node.value, node.children[0].value, node.children[1].value);\n    }\n  }\n  return node;\n}</textarea>\n      <div class=\"controls\">\n        <button id=\"runCustomBtn\">Run Custom Transform</button>\n        <button id=\"previewBtn\">Preview Only</button>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>AST JSON / Manual Editor</strong></div>\n      <textarea id=\"astJsonArea\" class=\"jsonarea\"></textarea>\n      <div class=\"controls\">\n        <button id=\"applyJsonBtn\">Apply JSON to AST</button>\n        <button id=\"loadAstToEditorBtn\">Load AST into Editor</button>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n// AST Interactive Explorer - Single-file implementation\n\n// Basic AST node helper\nlet idCounter = 1;\nfunction createNode(type, value, children) {\n  return {\n    id: String(idCounter++),\n    type: type || 'Node',\n    value: value === undefined ? null : value,\n    children: Array.isArray(children) ? children : []\n  };\n}\nfunction cloneAst(ast) {\n  return JSON.parse(JSON.stringify(ast));\n}\n\n// State\nlet AST = null;\nlet selectedNodeId = null;\nlet collapsed = new Set();\nlet traversal = { order: [], index: -1, timer: null };\nlet history = { past: [], future: [] };\nlet snapshots = []; // list of {name, ast}\nlet searchMatches = [];\n\n// Utility: find node by id and parent info\nfunction findNodeAndParent(node, id, parent=null) {\n  if (!node) return null;\n  if (node.id === id) return { node, parent };\n  for (let child of node.children || []) {\n    let res = findNodeAndParent(child, id, node);\n    if (res) return res;\n  }\n  return null;\n}\n\n// Parser: a simple expression & statement parser\nfunction tokenize(input) {\n  const re = /\\s*([A-Za-z_][A-Za-z0-9_]*|[0-9]+(?:\\.[0-9]+)?|==|!=|<=|>=|&&|\\|\\||[:;,\\+\\-\\*\\/\\=\\(\\)\\{\\}]|.)/g;\n  let m, tokens = [];\n  while ((m = re.exec(input)) !== null) {\n    let t = m[1];\n    if (t.trim() === '') continue;\n    tokens.push(t);\n  }\n  return tokens;\n}\n\nfunction parseProgram(tokens) {\n  let pos = 0;\n  function peek() { return tokens[pos]; }\n  function consume(tok) {\n    if (tok && tokens[pos] === tok) { pos++; return tok; }\n    return null;\n  }\n  function isIdent(t) { return /^[A-Za-z_][A-Za-z0-9_]*$/.test(t); }\n  function isNumber(t) { return /^[0-9]+(?:\\.[0-9]+)?$/.test(t); }\n\n  function parsePrimary() {\n    let t = peek();\n    if (t === '(') {\n      consume('(');\n      let expr = parseAssign();\n      consume(')');\n      return expr;\n    }\n    if (isNumber(t)) {\n      consume(t);\n      return createNode('Literal', Number(t), []);\n    }\n    if (isIdent(t)) {\n      consume(t);\n      if (peek() === '(') {\n        consume('(');\n        let args = [];\n        if (peek() !== ')') {\n          while (true) {\n            args.push(parseAssign());\n            if (consume(',') == null) break;\n          }\n        }\n        consume(')');\n        return createNode('CallExpression', t, args);\n      } else {\n        return createNode('Identifier', t, []);\n      }\n    }\n    // fallback - consume token as literal\n    consume(t);\n    return createNode('Literal', t, []);\n  }\n\n  function parseFactor() {\n    return parsePrimary();\n  }\n\n  function parseTerm() {\n    let node = parseFactor();\n    while (peek() === '*' || peek() === '/') {\n      let op = consume(peek());\n      let right = parseFactor();\n      node = createNode('BinaryExpression', op, [node, right]);\n    }\n    return node;\n  }\n\n  function parseExpr() {\n    let node = parseTerm();\n    while (peek() === '+' || peek() === '-') {\n      let op = consume(peek());\n      let right = parseTerm();\n      node = createNode('BinaryExpression', op, [node, right]);\n    }\n    return node;\n  }\n\n  function parseAssign() {\n    // a = b = c  (right associative)\n    let left = parseExpr();\n    if (peek() === '=') {\n      if (left.type === 'Identifier') {\n        consume('=');\n        let right = parseAssign();\n        return createNode('AssignmentExpression', '=', [left, right]);\n      }\n    }\n    return left;\n  }\n\n  function parseStatement() {\n    let stmt = parseAssign();\n    // optional semicolon\n    if (peek() === ';') consume(';');\n    return createNode('ExpressionStatement', null, [stmt]);\n  }\n\n  let body = [];\n  while (pos < tokens.length) {\n    body.push(parseStatement());\n  }\n  return createNode('Program', null, body);\n}\n\n// Code generator from AST\nfunction generateCode(node) {\n  if (!node) return '';\n  switch (node.type) {\n    case 'Program':\n      return node.children.map(generateCode).join('\\n');\n    case 'ExpressionStatement':\n      return generateCode(node.children[0]) + ';';\n    case 'AssignmentExpression':\n      return generateCode(node.children[0]) + ' ' + node.value + ' ' + generateCode(node.children[1]);\n    case 'BinaryExpression':\n      return '(' + generateCode(node.children[0]) + ' ' + node.value + ' ' + generateCode(node.children[1]) + ')';\n    case 'Identifier':\n      return node.value;\n    case 'Literal':\n      return typeof node.value === 'string' ? JSON.stringify(node.value) : String(node.value);\n    case 'CallExpression':\n      return node.value + '(' + node.children.map(generateCode).join(', ') + ')';\n    default:\n      // Generic fallback print\n      if (node.children && node.children.length) {\n        return node.type + '(' + (node.value || '') + ' ' + node.children.map(generateCode).join(', ') + ')';\n      }\n      return node.type + (node.value !== null ? ':' + node.value : '');\n  }\n}\n\n// Evaluation (very small interpreter for our AST - handles assignments, binary, literals, calls to Math.* safe)\nfunction evaluateAst(node, env) {\n  env = env || {};\n  function evalNode(n) {\n    if (!n) return undefined;\n    switch (n.type) {\n      case 'Program':\n        let res;\n        for (let s of n.children) res = evalNode(s);\n        return res;\n      case 'ExpressionStatement':\n        return evalNode(n.children[0]);\n      case 'AssignmentExpression': {\n        let name = n.children[0].value;\n        let val = evalNode(n.children[1]);\n        env[name] = val;\n        return val;\n      }\n      case 'BinaryExpression': {\n        let a = evalNode(n.children[0]);\n        let b = evalNode(n.children[1]);\n        switch (n.value) {\n          case '+': return a + b;\n          case '-': return a - b;\n          case '*': return a * b;\n          case '/': return a / b;\n          default: return null;\n        }\n      }\n      case 'Literal':\n        return n.value;\n      case 'Identifier':\n        return env[n.value];\n      case 'CallExpression': {\n        // Support Math functions and simple builtins\n        if (n.value in Math) {\n          let args = n.children.map(evalNode);\n          return Math[n.value].apply(null, args);\n        } else {\n          // dummy: return string\n          return '[' + n.value + '(' + n.children.map(evalNode).join(',') + ')]';\n        }\n      }\n      default:\n        return null;\n    }\n  }\n  return evalNode(node);\n}\n\n// Rendering AST as nested list text (clickable)\nfunction renderAST() {\n  let container = document.getElementById('astTree');\n  container.innerHTML = '';\n  if (!AST) { container.textContent = '(no AST)'; return; }\n\n  function renderNode(n, depth, path) {\n    const div = document.createElement('div');\n    div.className = 'node';\n    const indent = '  '.repeat(depth);\n    let line = indent + n.type + (n.value !== null && n.value !== undefined ? ' [' + n.value + ']' : '');\n    line += ' (id=' + n.id + ')';\n    // mark search match\n    if (searchMatches.indexOf(n.id) >= 0) line += '  <<MATCH>>';\n    const collapsedIndicator = (n.children && n.children.length) ? (collapsed.has(n.id) ? ' [+] ' : ' [-] ') : '     ';\n    const btn = document.createElement('button');\n    btn.textContent = collapsedIndicator.trim();\n    btn.style.fontSize = '10px';\n    btn.addEventListener('click', (e) => {\n      e.stopPropagation();\n      if (collapsed.has(n.id)) collapsed.delete(n.id); else collapsed.add(n.id);\n      renderAST();\n    });\n    const txt = document.createElement('span');\n    txt.textContent = ' ' + line;\n    txt.style.cursor = 'pointer';\n    txt.addEventListener('click', (e) => {\n      e.stopPropagation();\n      selectNodeById(n.id);\n    });\n    if (traversal.order[traversal.index] === n.id) {\n      // mark current traversal node by adding annotation\n      const curMark = document.createElement('strong');\n      curMark.textContent = '  <<CURRENT>>';\n      txt.appendChild(curMark);\n    }\n    // Append elements\n    div.appendChild(btn);\n    div.appendChild(txt);\n    container.appendChild(div);\n\n    if (!collapsed.has(n.id)) {\n      for (let child of n.children || []) {\n        renderNode(child, depth + 1, path.concat(n.type));\n      }\n    }\n  }\n\n  renderNode(AST, 0, []);\n}\n\n// Selection\nfunction selectNodeById(id) {\n  selectedNodeId = id;\n  updateInspector();\n  renderAST();\n}\n\nfunction updateInspector() {\n  const selPath = document.getElementById('selectedPath');\n  const typeInput = document.getElementById('nodeType');\n  const valueInput = document.getElementById('nodeValue');\n  if (!selectedNodeId) {\n    selPath.textContent = 'No node selected';\n    typeInput.value = '';\n    valueInput.value = '';\n    return;\n  }\n  const res = findNodeAndParent(AST, selectedNodeId);\n  if (!res) { selPath.textContent = 'Selected node not found'; return; }\n  const n = res.node;\n  selPath.textContent = 'Selected: ' + n.type + (n.value !== null ? ' [' + n.value + ']' : '') + ' (id=' + n.id + ')';\n  typeInput.value = n.type;\n  valueInput.value = n.value === null ? '' : String(n.value);\n}\n\n// Node operations\nfunction updateNodeFromInspector() {\n  if (!selectedNodeId) return alert('No node selected');\n  const res = findNodeAndParent(AST, selectedNodeId);\n  if (!res) return alert('Node missing');\n  const n = res.node;\n  const type = document.getElementById('nodeType').value.trim();\n  const valueRaw = document.getElementById('nodeValue').value.trim();\n  let val = valueRaw === '' ? null : interpretValue(valueRaw);\n  n.type = type || n.type;\n  n.value = val;\n  pushHistory();\n  renderAST();\n  updateInspector();\n}\n\nfunction interpretValue(v) {\n  if (/^[0-9]+(\\.[0-9]+)?$/.test(v)) return Number(v);\n  if (v === 'null') return null;\n  if (v === 'true') return true;\n  if (v === 'false') return false;\n  return v;\n}\n\nfunction deleteSelectedNode() {\n  if (!selectedNodeId) return alert('No node selected');\n  if (AST.id === selectedNodeId) {\n    if (!confirm('Deleting root will clear AST. Proceed?')) return;\n    AST = null;\n    selectedNodeId = null;\n    pushHistory();\n    renderAST();\n    updateInspector();\n    return;\n  }\n  const res = findNodeAndParent(AST, selectedNodeId);\n  if (!res || !res.parent) return alert('Parent not found');\n  res.parent.children = res.parent.children.filter(c => c.id !== selectedNodeId);\n  selectedNodeId = null;\n  pushHistory();\n  renderAST();\n  updateInspector();\n}\n\nfunction addChildToSelected() {\n  if (!selectedNodeId) return alert('No node selected');\n  const type = document.getElementById('newChildType').value.trim();\n  if (!type) return alert('Child type required');\n  const valueRaw = document.getElementById('newChildValue').value.trim();\n  const child = createNode(type, valueRaw === '' ? null : interpretValue(valueRaw), []);\n  const res = findNodeAndParent(AST, selectedNodeId);\n  if (!res) return alert('Node not found');\n  res.node.children.push(child);\n  pushHistory();\n  renderAST();\n}\n\n// Wrap node: replace selected node with new node and put selected as child\nfunction wrapNode() {\n  if (!selectedNodeId) return alert('No node selected');\n  const type = prompt('Enter wrapper node type', 'Wrapper');\n  if (!type) return;\n  const res = findNodeAndParent(AST, selectedNodeId);\n  if (!res || !res.parent) {\n    // wrapping root\n    const oldRoot = AST;\n    const newRoot = createNode(type, null, [oldRoot]);\n    AST = newRoot;\n    pushHistory();\n    renderAST();\n    return;\n  }\n  const parent = res.parent;\n  const idx = parent.children.findIndex(c => c.id === selectedNodeId);\n  if (idx < 0) return alert('Child index not found');\n  const oldNode = res.node;\n  const wrapper = createNode(type, null, [oldNode]);\n  parent.children[idx] = wrapper;\n  pushHistory();\n  renderAST();\n}\n\n// Traversal generation\nfunction buildTraversal(order) {\n  traversal.order = [];\n  traversal.index = -1;\n  function pre(n) {\n    traversal.order.push(n.id);\n    for (let c of n.children || []) pre(c);\n  }\n  function post(n) {\n    for (let c of n.children || []) post(c);\n    traversal.order.push(n.id);\n  }\n  function breadth(root) {\n    let q = [root];\n    while (q.length) {\n      let n = q.shift();\n      traversal.order.push(n.id);\n      for (let c of n.children || []) q.push(c);\n    }\n  }\n  if (!AST) return;\n  if (order === 'pre') pre(AST);\n  else if (order === 'post') post(AST);\n  else breadth(AST);\n}\n\nfunction startTraversal() {\n  if (!AST) return alert('No AST');\n  const order = document.getElementById('traversalSelect').value;\n  buildTraversal(order);\n  traversal.index = -1;\n  const speed = parseInt(document.getElementById('speedRange').value, 10) || 600;\n  function step() {\n    traversal.index++;\n    if (traversal.index >= traversal.order.length) {\n      stopTraversal();\n      return;\n    }\n    renderAST();\n    document.getElementById('traversalStatus').textContent = 'Traversal: running, node ' + (traversal.index+1) + '/' + traversal.order.length;\n    traversal.timer = setTimeout(step, speed);\n  }\n  if (traversal.timer) clearTimeout(traversal.timer);\n  step();\n}\n\nfunction stopTraversal() {\n  if (traversal.timer) clearTimeout(traversal.timer);\n  traversal.timer = null;\n  document.getElementById('traversalStatus').textContent = 'Traversal status: stopped';\n  renderAST();\n}\n\nfunction stepForward() {\n  if (!AST) return;\n  if (!traversal.order.length) buildTraversal(document.getElementById('traversalSelect').value);\n  traversal.index = Math.min(traversal.order.length - 1, traversal.index + 1);\n  document.getElementById('traversalStatus').textContent = 'Traversal status: manual step ' + (traversal.index+1);\n  renderAST();\n}\n\nfunction stepBack() {\n  if (!AST) return;\n  if (!traversal.order.length) buildTraversal(document.getElementById('traversalSelect').value);\n  traversal.index = Math.max(0, traversal.index - 1);\n  document.getElementById('traversalStatus').textContent = 'Traversal status: manual step ' + (traversal.index+1);\n  renderAST();\n}\n\n// Search\nfunction searchNodes() {\n  const q = document.getElementById('searchInput').value.trim();\n  searchMatches = [];\n  if (!q) { renderAST(); document.getElementById('searchResults').textContent = ''; return; }\n  let re;\n  try { re = new RegExp(q); } catch (e) { alert('Invalid regex: ' + e.message); return; }\n  function walk(n) {\n    if (re.test(n.type + ' ' + (n.value === null ? '' : String(n.value)))) searchMatches.push(n.id);\n    for (let c of n.children || []) walk(c);\n  }\n  if (AST) walk(AST);\n  document.getElementById('searchResults').textContent = 'Matches: ' + searchMatches.length;\n  renderAST();\n}\n\n// Snapshots and history\nfunction pushHistory() {\n  if (!AST) return;\n  history.past.push(cloneAst(AST));\n  history.future = [];\n  updateSnapList();\n}\n\nfunction undo() {\n  if (!history.past.length) return alert('Nothing to undo');\n  history.future.push(cloneAst(AST));\n  AST = history.past.pop();\n  selectedNodeId = null;\n  renderAST();\n  updateInspector();\n  updateSnapList();\n}\n\nfunction redo() {\n  if (!history.future.length) return alert('Nothing to redo');\n  history.past.push(cloneAst(AST));\n  AST = history.future.pop();\n  selectedNodeId = null;\n  renderAST();\n  updateInspector();\n  updateSnapList();\n}\n\nfunction saveSnapshot() {\n  const name = document.getElementById('snapshotName').value.trim() || ('snap' + (snapshots.length+1));\n  snapshots.push({ name, ast: cloneAst(AST) });\n  updateSnapList();\n}\n\nfunction updateSnapList() {\n  const el = document.getElementById('snapList');\n  el.innerHTML = '';\n  let html = '';\n  history.past.forEach((h, i) => {\n    const d = document.createElement('div');\n    d.textContent = 'H[' + i + ']';\n    el.appendChild(d);\n  });\n  snapshots.forEach((s, i) => {\n    const row = document.createElement('div');\n    const btn = document.createElement('button');\n    btn.textContent = 'Load';\n    btn.addEventListener('click', () => {\n      AST = cloneAst(s.ast);\n      selectedNodeId = null;\n      pushHistory();\n      renderAST();\n      updateInspector();\n    });\n    const del = document.createElement('button');\n    del.textContent = 'Delete';\n    del.addEventListener('click', () => {\n      snapshots.splice(i,1);\n      updateSnapList();\n    });\n    row.textContent = s.name + ' ';\n    row.appendChild(btn);\n    row.appendChild(del);\n    el.appendChild(row);\n  });\n}\n\n// JSON editor interactions\nfunction loadAstToEditor() {\n  document.getElementById('astJsonArea').value = JSON.stringify(AST, null, 2);\n}\n\nfunction applyJsonToAst() {\n  try {\n    const parsed = JSON.parse(document.getElementById('astJsonArea').value);\n    // ensure IDs exist; reassign if missing\n    function fix(node) {\n      if (!node.id) node.id = String(idCounter++);\n      if (!node.children) node.children = [];\n      for (let c of node.children) fix(c);\n    }\n    fix(parsed);\n    AST = parsed;\n    pushHistory();\n    renderAST();\n    updateInspector();\n  } catch (e) {\n    alert('Invalid JSON: ' + e.message);\n  }\n}\n\n// Transformations\nfunction constantFold(root) {\n  function fold(node) {\n    if (!node) return node;\n    node.children = node.children.map(fold);\n    if (node.type === 'BinaryExpression') {\n      const a = node.children[0], b = node.children[1];\n      if (a && b && a.type === 'Literal' && b.type === 'Literal') {\n        const res = evalBinary(node.value, a.value, b.value);\n        return createNode('Literal', res, []);\n      }\n    }\n    return node;\n  }\n  AST = fold(AST);\n  pushHistory();\n  renderAST();\n}\n\nfunction evalBinary(op, a, b) {\n  switch (op) {\n    case '+': return a + b;\n    case '-': return a - b;\n    case '*': return a * b;\n    case '/': return a / b;\n    default: return null;\n  }\n}\n\n// Rename identifiers\nfunction renameIdentifiers(from, to) {\n  function walk(n) {\n    if (n.type === 'Identifier' && n.value === from) n.value = to;\n    if (n.children) n.children.forEach(walk);\n  }\n  walk(AST);\n  pushHistory();\n  renderAST();\n}\n\n// Remove dead assignments: simplistic remove assignments to variables never used\nfunction removeDeadAssignments() {\n  // gather used identifiers (excluding left-hand of assignments)\n  const used = new Set();\n  function collectUses(n, inLHS=false) {\n    if (!n) return;\n    if (n.type === 'Identifier') {\n      if (!inLHS) used.add(n.value);\n      return;\n    }\n    if (n.type === 'AssignmentExpression') {\n      // left is LHS\n      collectUses(n.children[1], false);\n      collectUses(n.children[0], true);\n      return;\n    }\n    for (let c of n.children || []) collectUses(c, false);\n  }\n  collectUses(AST, false);\n  // remove ExpressionStatements with AssignmentExpression to var not in used\n  function prune(n) {\n    if (!n.children) return n;\n    n.children = n.children.filter(child => {\n      if (child.type === 'ExpressionStatement' &&\n          child.children[0] &&\n          child.children[0].type === 'AssignmentExpression') {\n        const lhs = child.children[0].children[0];\n        if (lhs && lhs.type === 'Identifier' && !used.has(lhs.value)) {\n          return false;\n        }\n      }\n      return true;\n    });\n    for (let c of n.children) prune(c);\n  }\n  prune(AST);\n  pushHistory();\n  renderAST();\n}\n\n// Custom transform execution\nfunction runCustomTransform(previewOnly=false) {\n  const src = document.getElementById('customTransform').value;\n  let fn;\n  try {\n    fn = new Function('node', 'utils', src + '\\n return transform(node, utils);');\n  } catch (e) { alert('Error compiling transform: ' + e.message); return; }\n  const utils = {\n    evalBinary: evalBinary,\n    createNode: createNode,\n    clone: cloneAst\n  };\n  function applyRec(n) {\n    let result;\n    try {\n      result = fn(n, utils);\n    } catch (e) {\n      // if user function expects to call transform recursively, allow fallback:\n      try {\n        // attempt to call transform declared inside with node param\n        result = (typeof window.transform === 'function') ? window.transform(n, utils) : n;\n      } catch (ex) {\n        result = n;\n      }\n    }\n    if (!result) return null;\n    // ensure children are processed if not handled by transform\n    if (result.children && result.children.length) {\n      result.children = result.children.map(ch => applyRec(ch)).filter(Boolean);\n    }\n    return result;\n  }\n  let newAst;\n  try {\n    newAst = applyRec(cloneAst(AST));\n  } catch (e) { alert('Error during transform: ' + e.message); return; }\n  if (previewOnly) {\n    document.getElementById('astJsonArea').value = JSON.stringify(newAst, null, 2);\n    alert('Preview written to AST Editor. Use \"Apply JSON to AST\" to persist.');\n  } else {\n    AST = newAst;\n    pushHistory();\n    renderAST();\n    updateInspector();\n  }\n}\n\n// Misc utilities\nfunction exportJson() {\n  if (!AST) return alert('No AST');\n  const data = JSON.stringify(AST, null, 2);\n  const win = window.open('', '_blank');\n  win.document.write('<pre>' + escapeHtml(data) + '</pre>');\n}\n\nfunction escapeHtml(s) {\n  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n}\n\n// Initialize with parse and UI wiring\nfunction init() {\n  document.getElementById('parseBtn').addEventListener('click', () => {\n    const parser = document.getElementById('parserSelect').value;\n    const input = document.getElementById('codeInput').value;\n    if (parser === 'expr') {\n      try {\n        const tokens = tokenize(input);\n        AST = parseProgram(tokens);\n        pushHistory();\n        renderAST();\n        updateInspector();\n        document.getElementById('codeOutput').value = generateCode(AST);\n      } catch (e) {\n        alert('Parse error: ' + e.message);\n      }\n    } else {\n      // JSON\n      try {\n        const parsed = JSON.parse(input);\n        AST = parsed;\n        pushHistory();\n        renderAST();\n        updateInspector();\n      } catch (e) {\n        alert('Invalid JSON: ' + e.message);\n      }\n    }\n  });\n\n  document.getElementById('resetBtn').addEventListener('click', () => {\n    if (!confirm('Reset the workspace?')) return;\n    AST = null;\n    selectedNodeId = null;\n    history = { past: [], future: [] };\n    snapshots = [];\n    collapsed = new Set();\n    traversal = { order: [], index: -1, timer: null };\n    document.getElementById('astTree').textContent = '(no AST)';\n    document.getElementById('codeOutput').value = '';\n    updateInspector();\n    updateSnapList();\n  });\n\n  document.getElementById('loadSampleBtn').addEventListener('click', () => {\n    document.getElementById('sampleSelect').focus();\n  });\n\n  document.getElementById('applySampleBtn').addEventListener('click', () => {\n    const sel = document.getElementById('sampleSelect').value;\n    if (sel === 'simple') {\n      document.getElementById('codeInput').value = 'a = 2 + 3 * (4 - 1);\\nb = a * 5;\\na + b';\n    } else if (sel === 'calls') {\n      document.getElementById('codeInput').value = 'x = max(3, 4+1);\\ny = sin(3.14/2);\\nx + y';\n    } else if (sel === 'assigns') {\n      document.getElementById('codeInput').value = 'x = 1; y = x + 2; z = y * 3; z';\n    } else if (sel === 'manual') {\n      document.getElementById('codeInput').value = JSON.stringify({\n        id: \"1\", type: \"Program\", value: null, children: [\n          { id: \"2\", type: \"ExpressionStatement\", value: null, children: [\n             { id: \"3\", type: \"AssignmentExpression\", value: \"=\", children: [\n               { id: \"4\", type: \"Identifier\", value: \"x\", children: [] },\n               { id: \"5\", type: \"BinaryExpression\", value: \"+\", children: [\n                 { id: \"6\", type: \"Literal\", value: 2, children: []},\n                 { id: \"7\", type: \"Literal\", value: 3, children: []}\n               ]}\n             ]}\n          ]}\n        ]\n      }, null, 2);\n    }\n  });\n\n  document.getElementById('startTraversalBtn').addEventListener('click', startTraversal);\n  document.getElementById('stopTraversalBtn').addEventListener('click', stopTraversal);\n  document.getElementById('stepForwardBtn').addEventListener('click', stepForward);\n  document.getElementById('stepBackBtn').addEventListener('click', stepBack);\n\n  document.getElementById('searchBtn').addEventListener('click', searchNodes);\n  document.getElementById('clearSearchBtn').addEventListener('click', () => { document.getElementById('searchInput').value=''; searchMatches=[]; renderAST(); });\n\n  document.getElementById('saveSnapBtn').addEventListener('click', saveSnapshot);\n  document.getElementById('undoBtn').addEventListener('click', undo);\n  document.getElementById('redoBtn').addEventListener('click', redo);\n\n  document.getElementById('expandAllBtn').addEventListener('click', () => { collapsed = new Set(); renderAST(); });\n  document.getElementById('collapseAllBtn').addEventListener('click', () => { /* collapse all children of root */ collapsed = new Set(); function walk(n){ if(n.children && n.children.length){ for(let c of n.children){ collapsed.add(c.id); walk(c); } } } if(AST) walk(AST); renderAST(); });\n  document.getElementById('applyCollapseBtn').addEventListener('click', () => {\n    const d = parseInt(document.getElementById('collapseDepth').value || '0', 10);\n    collapsed = new Set();\n    function walk(n, depth) {\n      if (depth > d) { collapsed.add(n.id); return; }\n      for (let c of n.children || []) walk(c, depth+1);\n    }\n    if (AST) walk(AST, 0);\n    renderAST();\n  });\n\n  document.getElementById('showJsonBtn').addEventListener('click', () => { if (!AST) return alert('No AST'); document.getElementById('astJsonArea').value = JSON.stringify(AST, null, 2); window.scrollTo(0,document.body.scrollHeight); });\n  document.getElementById('exportJsonBtn').addEventListener('click', exportJson);\n\n  document.getElementById('genCodeBtn').addEventListener('click', () => {\n    if (!AST) return alert('No AST');\n    document.getElementById('codeOutput').value = generateCode(AST);\n  });\n\n  document.getElementById('evalBtn').addEventListener('click', () => {\n    if (!AST) return alert('No AST');\n    try {\n      const res = evaluateAst(AST, {});\n      document.getElementById('evalOutput').textContent = 'Result: ' + JSON.stringify(res);\n    } catch (e) { document.getElementById('evalOutput').textContent = 'Eval error: ' + e.message; }\n  });\n\n  document.getElementById('prettyPrintBtn').addEventListener('click', () => { if (!AST) return; document.getElementById('astJsonArea').value = JSON.stringify(AST, null, 2); });\n\n  document.getElementById('manualEditBtn').addEventListener('click', () => { document.getElementById('astJsonArea').value = AST ? JSON.stringify(AST, null, 2) : ''; });\n\n  document.getElementById('nodeType').addEventListener('keydown', (e) => { if (e.key === 'Enter') updateNodeFromInspector(); });\n  document.getElementById('updateNodeBtn').addEventListener('click', updateNodeFromInspector);\n  document.getElementById('deleteNodeBtn').addEventListener('click', deleteSelectedNode);\n  document.getElementById('addChildBtn').addEventListener('click', addChildToSelected);\n  document.getElementById('wrapNodeBtn').addEventListener('click', wrapNode);\n\n  document.getElementById('constFoldBtn').addEventListener('click', () => { if (!AST) return alert('No AST'); constantFold(AST); });\n  document.getElementById('renameBtn').addEventListener('click', () => {\n    const f = document.getElementById('renameFrom').value.trim();\n    const t = document.getElementById('renameTo').value.trim();\n    if (!f || !t) return alert('Provide both from and to');\n    renameIdentifiers(f, t);\n  });\n  document.getElementById('removeDeadBtn').addEventListener('click', removeDeadAssignments);\n\n  document.getElementById('runCustomBtn').addEventListener('click', () => runCustomTransform(false));\n  document.getElementById('previewBtn').addEventListener('click', () => runCustomTransform(true));\n\n  document.getElementById('applyJsonBtn').addEventListener('click', applyJsonToAst);\n  document.getElementById('loadAstToEditorBtn').addEventListener('click', loadAstToEditor);\n\n  // keyboard navigation: arrow up/down moves traversal\n  document.getElementById('astTree').addEventListener('keydown', (e) => {\n    if (e.key === 'ArrowRight') stepForward();\n    if (e.key === 'ArrowLeft') stepBack();\n  });\n\n  document.getElementById('searchInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') searchNodes(); });\n\n  // initial parse from textarea\n  document.getElementById('parseBtn').click();\n}\n\ninit();\n\n</script>\n\n</body>\n</html>"
