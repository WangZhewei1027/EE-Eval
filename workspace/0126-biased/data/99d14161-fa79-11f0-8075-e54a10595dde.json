    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Nearest Neighbors Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        h1 { font-size: 20px; }\n        .control { margin: 10px 0; }\n    </style>\n</head>\n<body>\n    <h1>K-Nearest Neighbors Interactive Demo</h1>\n\n    <div class=\"control\">\n        <label for=\"data-points\">Number of Data Points (1-10): </label>\n        <input type=\"number\" id=\"data-points\" min=\"1\" max=\"10\" value=\"5\">\n        <button id=\"generate-points\">Generate Points</button>\n    </div>\n\n    <div id=\"points\"></div>\n\n    <div class=\"control\">\n        <label for=\"k-value\">K (1-10): </label>\n        <input type=\"number\" id=\"k-value\" min=\"1\" max=\"10\" value=\"3\">\n    </div>\n\n    <div class=\"control\">\n        <label for=\"new-point\">Add New Point (x,y): </label>\n        <input type=\"text\" id=\"new-point\" placeholder=\"e.g. 4,5\">\n        <button id=\"add-point\">Add Point</button>\n    </div>\n\n    <button id=\"run-knn\">Run K-NN</button>\n\n    <h2>Results</h2>\n    <div id=\"results\"></div>\n\n    <script>\n        let dataPoints = [];\n\n        document.getElementById('generate-points').onclick = function() {\n            const numPoints = parseInt(document.getElementById('data-points').value);\n            dataPoints = [];\n            for (let i = 0; i < numPoints; i++) {\n                const x = Math.floor(Math.random() * 10);\n                const y = Math.floor(Math.random() * 10);\n                dataPoints.push({ x, y });\n            }\n            renderPoints();\n        };\n\n        document.getElementById('add-point').onclick = function() {\n            const input = document.getElementById('new-point').value.split(',');\n            if (input.length === 2) {\n                const x = parseFloat(input[0].trim());\n                const y = parseFloat(input[1].trim());\n                dataPoints.push({ x, y });\n                renderPoints();\n            }\n        };\n\n        function renderPoints() {\n            const pointsDiv = document.getElementById('points');\n            pointsDiv.innerHTML = '<h3>Data Points</h3>' + dataPoints.map(p => `(${p.x}, ${p.y})`).join('<br>');\n        }\n\n        document.getElementById('run-knn').onclick = function() {\n            const k = parseInt(document.getElementById('k-value').value);\n            if (dataPoints.length < k) {\n                alert('Number of data points is less than K.');\n                return;\n            }\n            const distances = dataPoints.map(point => {\n                const lastPoint = dataPoints[dataPoints.length - 1]; // last point is the new point we added\n                const distance = Math.sqrt(Math.pow(point.x - lastPoint.x, 2) + Math.pow(point.y - lastPoint.y, 2));\n                return { point, distance };\n            });\n\n            distances.sort((a, b) => a.distance - b.distance);\n            const nearestNeighbors = distances.slice(0, k).map(d => d.point);\n            const resultsDiv = document.getElementById('results');\n            resultsDiv.innerHTML = `<strong>Nearest Neighbors:</strong><br>` + nearestNeighbors.map(p => `(${p.x}, ${p.y})`).join('<br>');\n        };\n    </script>\n</body>\n</html>"
  },
