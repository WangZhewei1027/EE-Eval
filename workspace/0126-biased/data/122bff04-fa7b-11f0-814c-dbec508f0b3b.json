  function startAlgorithm() {\n            document.querySelector('.algorithm-container').innerHTML = 'Starting Prim\\'s Algorithm...';\n\n            // Initialize graph\n            const graph = {\n                vertices: ['A', 'B', 'C', 'D'],\n                edges: [\n                    { source: 'A', target: 'B', weight: 2 },\n                    { source: 'A', target: 'C', weight: 3 },\n                    { source: 'B', target: 'C', weight: 1 },\n                    { source: 'B', target: 'D', weight: 4 },\n                    { source: 'C', target: 'D', weight: 2 },\n                ],\n            };\n\n            // Find minimum spanning tree\n            const mst = findMST(graph);\n\n            // Remove edges incident to minimum spanning tree\n            document.querySelector('.algorithm-container').innerHTML += ' Removed edges incident to MST: ';\n            for (const edge of mst.edges) {\n                const edgeString = `${edge.source} -> ${edge.target} (weight: ${edge.weight})`;\n                document.querySelector('.algorithm-container').innerHTML += edgeString + '<br>';\n            }\n\n            // Repeat process until no more edges can be removed\n            while (true) {\n                const newMST = findMST(graph);\n                if (!newMST) break;\n                document.querySelector('.algorithm-container').innerHTML += ' Removed edges incident to new MST: ';\n                for (const edge of newMST.edges) {\n                    const edgeString = `${edge.source} -> ${edge.target} (weight: ${edge.weight})`;\n                    document.querySelector('.algorithm-container').innerHTML += edgeString + '<br>';\n                }\n            }\n\n            // Show all algorithm steps\n            document.querySelector('.algorithm-container').innerHTML += '\\nAlgorithm Steps:\\n';\n            for (const step of ['Find MST', 'Remove edges incident to MST', 'Repeat process until no more edges can be removed']) {\n                document.querySelector('.algorithm-container').innerHTML += step + '<br>';\n            }\n        }\n\n        function resetAlgorithm() {\n            document.querySelector('.algorithm-container').innerHTML = '';\n        }\n\n        function showAll() {\n            const graph = {\n                vertices: ['A', 'B', 'C', 'D'],\n                edges: [\n                    { source: 'A', target: 'B', weight: 2 },\n                    { source: 'A', target: 'C', weight: 3 },\n                    { source: 'B', target: 'C', weight: 1 },\n                    { source: 'B', target: 'D', weight: 4 },\n                    { source: 'C', target: 'D', weight: 2 },\n                ],\n            };\n            const mst = findMST(graph);\n            document.querySelector('.algorithm-container').innerHTML = 'Algorithm Steps:\\n' + 'Find MST: ' + mst + '\\n' + 'Remove edges incident to MST: ' + mst.edges.map(edge => `${edge.source} -> ${edge.target} (weight: ${edge.weight})`).join('\\n') + '\\n' + 'Repeat process until no more edges can be removed: ' + mst;\n        }\n\n        function showAllWithMinSpanningTree() {\n            const graph = {\n                vertices: ['A', 'B', 'C', 'D'],\n                edges: [\n                    { source: 'A', target: 'B', weight: 2 },\n                    { source: 'A', target: 'C', weight: 3 },\n                    { source: 'B', target: 'C', weight: 1 },\n                    { source: 'B', target: 'D', weight: 4 },\n                    { source: 'C', target: 'D', weight: 2 },\n                ],\n            };\n            const mst = findMST(graph);\n            const mstEdges = mst.edges;\n            const minSpanningTree = mstEdges.map(edge => ({ source: edge.source, target: edge.target, weight: edge.weight }));\n            document.querySelector('.algorithm-container').innerHTML = 'Algorithm Steps:\\n' + 'Find MST: ' + mst + '\\n' + 'Remove edges incident to MST: ' + mstEdges.map(edge => `${edg