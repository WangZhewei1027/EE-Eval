    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Quick Sort — Visual Elegance</title>\n<style>\n  :root{\n    --bg-1:#081225;\n    --bg-2:#071826;\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --accent-1: #7bd389;\n    --accent-2: #6aa7ff;\n    --muted: rgba(255,255,255,0.65);\n    --tile-h: 120px;\n    --tile-w: 64px;\n    --duration: 420ms;\n    --soft: 24px;\n  }\n\n  /* Reset */\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{height:100%}\n  body{\n    min-height:100vh;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 12% 18%, rgba(106,167,255,0.06), transparent 6%),\n                radial-gradient(900px 500px at 86% 82%, rgba(123,211,137,0.04), transparent 5%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #e8f0ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:48px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:32px;\n    overflow:hidden;\n  }\n\n  /* Decorative orbs */\n  .orbit{\n    position:absolute;\n    filter: blur(40px) saturate(120%);\n    mix-blend-mode:screen;\n    opacity:0.9;\n    pointer-events:none;\n  }\n  .orb-1{width:420px;height:420px;left:-160px;top:-120px;background:conic-gradient(from 140deg,#6aa7ff, #7bd389 40%, rgba(122,160,255,0.02)); border-radius:50%;}\n  .orb-2{width:300px;height:300px;right:-120px;bottom:-160px;background:radial-gradient(circle at 30% 30%, rgba(123,211,137,0.2), transparent 30%),linear-gradient(90deg, rgba(106,167,255,0.08), rgba(123,211,137,0.02)); border-radius:50%;}\n  .grain{\n    position:absolute;inset:0;opacity:0.06;background-image:radial-gradient(rgba(255,255,255,0.02) 1px, transparent 1px);background-size:4px 4px;pointer-events:none;\n  }\n\n  /* Card */\n  .stage{\n    width:1100px;\n    max-width:calc(100vw - 96px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    box-shadow: 0 10px 40px rgba(6,14,26,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    padding:28px;\n    display:flex;\n    flex-direction:column;\n    gap:20px;\n    position:relative;\n    overflow:visible;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  .header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n  }\n  .title{\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .label{\n    font-size:20px;\n    font-weight:700;\n    letter-spacing: -0.02em;\n    color: #ecf8ff;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .subtitle{\n    font-size:13px;\n    color:var(--muted);\n    max-width:56ch;\n  }\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    --bgh: rgba(255,255,255,0.03);\n    padding:10px 14px;\n    background: linear-gradient(180deg,var(--bgh), rgba(255,255,255,0.01));\n    color: #eaf6ff;\n    border-radius:12px;\n    border: 1px solid rgba(255,255,255,0.04);\n    font-weight:600;\n    cursor:pointer;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition:transform 220ms cubic-bezier(.2,.9,.2,1), box-shadow 220ms;\n    box-shadow: 0 6px 18px rgba(2,8,23,0.45);\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n  .btn:active{transform:translateY(1px) scale(.998);}\n  .btn:disabled{opacity:.45;cursor:not-allowed; transform:none}\n  .btn.play{\n    background: linear-gradient(90deg,var(--accent-2), var(--accent-1));\n    color:#041223;\n    font-weight:700;\n    border:none;\n    box-shadow: 0 8px 28px rgba(106,167,255,0.12), 0 2px 8px rgba(123,211,137,0.06);\n  }\n\n  /* Visualization area */\n  .viz{\n    display:flex;\n    gap:16px;\n    align-items:center;\n    justify-content:center;\n    padding:22px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.02);\n    position:relative;\n    overflow:visible;\n    min-height:240px;\n  }\n\n  .lane{\n    width:100%;\n    height:var(--tile-h);\n    position:relative;\n    display:block;\n    user-select:none;\n  }\n\n  /* Tiles */\n  .tile{\n    position:absolute;\n    bottom:8px;\n    width:var(--tile-w);\n    height: calc(var(--tile-h) - 16px);\n    border-radius:14px;\n    display:flex;\n    align-items:flex-end;\n    justify-content:center;\n    transition: transform var(--duration) cubic-bezier(.2,.9,.2,1), box-shadow 200ms, filter 200ms;\n    will-change:transform;\n    padding:8px;\n    gap:6px;\n    box-shadow: 0 6px 22px rgba(2,8,23,0.6);\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(6px) saturate(120%);\n    cursor:default;\n  }\n  .tile .bar{\n    width:100%;\n    background: linear-gradient(180deg, rgba(122,160,255,0.18), rgba(123,211,137,0.06));\n    border-radius:10px;\n    display:flex;\n    align-items:flex-end;\n    justify-content:center;\n    color:#021723;\n    font-weight:800;\n    font-size:12px;\n    padding-bottom:10px;\n    letter-spacing: -0.02em;\n    box-shadow: inset 0 6px 18px rgba(255,255,255,0.02);\n  }\n  .tile .num{\n    position:absolute;\n    top:-22px;\n    font-size:12px;\n    color:var(--muted);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    padding:6px 8px;\n    border-radius:8px;\n    border:1px solid rgba(255,255,255,0.03);\n    transform:translateY(-2px);\n    white-space:nowrap;\n  }\n\n  /* Highlights */\n  .pivot{\n    box-shadow: 0 12px 34px rgba(123,211,137,0.12), 0 4px 12px rgba(106,167,255,0.06);\n    transform: translateY(-6px) scale(1.02);\n    z-index:30;\n    outline: 2px solid rgba(123,211,137,0.12);\n  }\n  .compare{\n    transform: translateY(-4px) scale(1.01);\n    box-shadow: 0 8px 28px rgba(106,167,255,0.08);\n    z-index:20;\n    outline: 1px dashed rgba(106,167,255,0.08);\n  }\n  .swap{\n    transform: translateY(-10px) scale(1.05);\n    box-shadow: 0 22px 48px rgba(106,167,255,0.14);\n    z-index:40;\n    filter: saturate(140%);\n  }\n\n  /* Small info row */\n  .info{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n    margin-top:6px;\n  }\n  .badge{\n    padding:8px 12px;\n    border-radius:999px;\n    background: rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.02);\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    font-weight:600;\n    color:var(--muted);\n  }\n\n  /* Footer decorative code preview */\n  .footer{\n    display:flex;\n    align-items:center;\n    gap:12px;\n    justify-content:space-between;\n    margin-top:8px;\n  }\n  .mini{\n    font-size:12px;\n    color:var(--muted);\n    display:flex;\n    gap:8px;\n    align-items:center;\n  }\n\n  /* Responsiveness */\n  @media (max-width:900px){\n    .stage{padding:18px;}\n    .title .label{font-size:18px}\n    .viz{padding:14px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"orbit orb-1\"></div>\n  <div class=\"orbit orb-2\"></div>\n  <div class=\"grain\"></div>\n\n  <main class=\"stage\" aria-label=\"Quick Sort visualization\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <div class=\"label\">\n          Quick Sort\n          <svg width=\"36\" height=\"24\" viewBox=\"0 0 36 24\" fill=\"none\" aria-hidden>\n            <defs>\n              <linearGradient id=\"g\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#6aa7ff\"/>\n                <stop offset=\"1\" stop-color=\"#7bd389\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"0\" y=\"0\" width=\"36\" height=\"24\" rx=\"6\" fill=\"url(#g)\" opacity=\"0.14\"/>\n            <path d=\"M8 15l6-6 6 6\" stroke=\"#fff\" stroke-opacity=\"0.92\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n        <div class=\"subtitle\">Divide · Conquer · Elegance — Observe Quick Sort partitioning, pivots, and swaps with a graceful animation.</div>\n      </div>\n\n      <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n        <button class=\"btn\" id=\"shuffleBtn\" title=\"Shuffle the array\">Shuffle</button>\n        <button class=\"btn play\" id=\"playBtn\" title=\"Run Quick Sort\">Play</button>\n      </div>\n    </div>\n\n    <section class=\"viz\" aria-hidden=\"false\">\n      <div class=\"lane\" id=\"lane\" aria-live=\"polite\"></div>\n    </section>\n\n    <div class=\"info\">\n      <div class=\"badge\" id=\"status\">Status: Idle</div>\n      <div class=\"mini\">Elements: <strong id=\"count\">14</strong></div>\n      <div class=\"mini\">Steps: <strong id=\"steps\">0</strong></div>\n      <div class=\"mini\" style=\"margin-left:auto;color:var(--muted)\">Pivot highlighted in green • Comparisons glow blue • Swaps lift tiles</div>\n    </div>\n  </main>\n\n<script>\n(function(){\n  const lane = document.getElementById('lane');\n  const playBtn = document.getElementById('playBtn');\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const status = document.getElementById('status');\n  const stepsEl = document.getElementById('steps');\n  const countEl = document.getElementById('count');\n\n  const COUNT = 14;\n  const TILE_W = 64;\n  const GAP = 16;\n  const DURATION = 420; // ms, should match CSS --duration\n\n  let values = [];\n  let nodes = [];\n  let running = false;\n  let steps = 0;\n\n  function randUnique(n, min=6, max=98){\n    const set = new Set();\n    while(set.size < n){\n      set.add(Math.floor(Math.random()*(max-min+1))+min);\n    }\n    return Array.from(set);\n  }\n\n  function createTiles(arr){\n    lane.innerHTML = '';\n    nodes = [];\n    const lw = (TILE_W + GAP) * arr.length - GAP;\n    lane.style.width = lw + 'px';\n    lane.style.height = '160px';\n\n    arr.forEach((v,i)=>{\n      const el = document.createElement('div');\n      el.className = 'tile';\n      el.style.left = (i*(TILE_W + GAP)) + 'px';\n      el.style.transitionDuration = DURATION + 'ms';\n      el.dataset.value = v;\n      el.dataset.index = i;\n      el.innerHTML = `\n        <div class=\"num\">${v}</div>\n        <div class=\"bar\" style=\"height:${Math.max(12, Math.round((v/100)*100))}%\">\n          <div style=\"width:100%;height:100%\"></div>\n        </div>\n      `;\n      lane.appendChild(el);\n      nodes.push(el);\n    });\n\n    // small hairline arrangement for more polished aesthetic: slight staggered heights\n    nodes.forEach((nd, idx)=> {\n      nd.style.transform = `translateY(0) translateX(0)`;\n    });\n\n    countEl.textContent = arr.length;\n  }\n\n  function layout(){\n    nodes.forEach((nd, idx)=>{\n      nd.style.left = (idx*(TILE_W + GAP)) + 'px';\n      nd.style.zIndex = 10 + idx;\n    });\n  }\n\n  function shuffleArray(){\n    if(running) return;\n    values = randUnique(COUNT);\n    createTiles(values);\n    steps = 0;\n    stepsEl.textContent = steps;\n    status.textContent = 'Status: Shuffled';\n  }\n\n  function sleep(ms){ return new Promise(r=>setTimeout(r, ms)); }\n\n  function highlight(idx, cls){\n    if(idx < 0 || idx >= nodes.length) return;\n    nodes[idx].classList.add(cls);\n  }\n  function unhighlight(idx, cls){\n    if(idx < 0 || idx >= nodes.length) return;\n    nodes[idx].classList.remove(cls);\n  }\n\n  // Swap nodes in place (DOM positions are absolute, so swap nodes array and update left)\n  function swap(i,j){\n    if(i===j) return;\n    const tmp = nodes[i];\n    nodes[i] = nodes[j];\n    nodes[j] = tmp;\n    // animate by updating left positions\n    layout();\n  }\n\n  // Visual quick sort with async steps\n  async function quickSortVisual(){\n    running = true;\n    playBtn.textContent = 'Running…';\n    playBtn.disabled = true;\n    shuffleBtn.disabled = true;\n    status.textContent = 'Status: Sorting — Quick Sort in progress';\n    steps = 0;\n    stepsEl.textContent = steps;\n\n    async function partition(l, r){\n      // pivot is nodes[r]\n      highlight(r, 'pivot');\n      await sleep(180);\n      let pivotVal = parseInt(nodes[r].dataset.value,10);\n      let i = l - 1;\n\n      for(let j = l; j <= r - 1; j++){\n        highlight(j, 'compare');\n        steps++; stepsEl.textContent = steps;\n        await sleep(260);\n\n        const curVal = parseInt(nodes[j].dataset.value,10);\n        if(curVal <= pivotVal){\n          i++;\n          if(i !== j){\n            // visual swap\n            highlight(i,'swap'); highlight(j,'swap');\n            swap(i,j);\n            // update dataset indices (not mandatory but helpful)\n            await sleep(DURATION + 40);\n            unhighlight(i, 'swap'); unhighlight(j, 'swap');\n          }\n        }\n        unhighlight(j, 'compare');\n      }\n\n      // place pivot\n      if(i+1 !== r){\n        highlight(i+1,'swap'); highlight(r,'swap');\n        swap(i+1, r);\n        await sleep(DURATION + 40);\n        unhighlight(i+1,'swap'); unhighlight(r,'swap');\n      }\n      unhighlight(i+1,'pivot');\n      return i+1;\n    }\n\n    async function qsort(l, r, depth=0){\n      if(l >= r) return;\n      // show recursion depth (visual subtle)\n      status.textContent = `Status: Sorting — depth ${depth}`;\n      const p = await partition(l, r);\n      // recursing left\n      await qsort(l, p-1, depth+1);\n      // recursing right\n      await qsort(p+1, r, depth+1);\n    }\n\n    await qsort(0, nodes.length - 1, 0);\n\n    status.textContent = 'Status: Sorted — Completed';\n    playBtn.textContent = 'Play';\n    playBtn.disabled = false;\n    shuffleBtn.disabled = false;\n    running = false;\n  }\n\n  // Initial setup\n  shuffleArray();\n\n  // Interactions\n  shuffleBtn.addEventListener('click', ()=>{\n    shuffleArray();\n  });\n\n  playBtn.addEventListener('click', ()=>{\n    if(running) return;\n    // Reset any highlighting\n    nodes.forEach(n=> n.classList.remove('pivot','compare','swap'));\n    quickSortVisual();\n  });\n\n  // Small flourish: gentle idle animation for tiles to give life\n  let idle = true;\n  setInterval(()=>{\n    if(running) return;\n    // subtle bobbing\n    nodes.forEach((nd, i)=>{\n      const t = 1 + (Math.sin((Date.now()/1200) + i*0.4) * 0.8);\n      nd.style.transform = `translateY(${(Math.sin((Date.now()/900) + i*0.3) * 4)}px)`;\n    });\n  }, 60);\n\n  // Initialize layout after fonts/styles loaded to ensure crisp positions\n  window.addEventListener('load', ()=>{\n    layout();\n  });\n\n  // Accessibility: expose initial instructions briefly\n  setTimeout(()=> {\n    status.textContent = 'Status: Ready — Shuffle to randomize, Play to watch Quick Sort';\n  }, 800);\n\n})();\n</script>\n</body>\n</html>"
