    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Deadlock — Visual Demonstration</title>\n<style>\n  :root{\n    --bg-0: #071028;\n    --bg-1: linear-gradient(180deg,#081026 0%, #061627 40%, #07142a 100%);\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --accent-1: #56e0d8; /* teal */\n    --accent-2: #ffb86b; /* warm */\n    --danger: #ff6b6b; /* red */\n    --gold: #ffd66b;\n    --soft: rgba(255,255,255,0.02);\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --shadow: 0 10px 30px rgba(2,6,23,0.7);\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(86,224,216,0.06), transparent 8%),\n                radial-gradient(900px 400px at 95% 90%, rgba(255,184,107,0.04), transparent 10%),\n                var(--bg-1);\n    color: #e8f0ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Stage */\n  .wrap{\n    height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n  }\n\n  .panel{\n    width:min(1200px,94%);\n    max-width:1200px;\n    height:min(760px,86vh);\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    position:relative;\n    overflow:hidden;\n    padding:36px;\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:28px;\n    backdrop-filter: blur(6px) saturate(110%);\n  }\n\n  /* Left: visual stage */\n  .stage{\n    position:relative;\n    border-radius:16px;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,0.015), rgba(0,0,0,0.02)),\n      radial-gradient(400px 240px at 80% 10%, rgba(86,224,216,0.03), transparent 10%),\n      transparent;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    padding:28px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .stage-inner{\n    width:700px;\n    height:700px;\n    display:block;\n    position:relative;\n  }\n\n  /* center emblem */\n  .core{\n    position:absolute;\n    left:50%;\n    top:50%;\n    width:220px;\n    height:220px;\n    transform:translate(-50%,-50%);\n    border-radius:50%;\n    background: radial-gradient(circle at 30% 30%, rgba(86,224,216,0.08), rgba(86,224,216,0.02) 20%, transparent 30%),\n                linear-gradient(135deg, rgba(255,255,255,0.02), rgba(0,0,0,0.02));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 20px 60px rgba(2,8,20,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    transition:transform 800ms cubic-bezier(.2,.9,.1,1);\n  }\n\n  .core .title {\n    text-align:center;\n    font-size:18px;\n    letter-spacing:1px;\n    text-transform:uppercase;\n    color:var(--muted);\n    font-weight:600;\n  }\n\n  .core .big{\n    font-size:36px;\n    font-weight:700;\n    margin-top:8px;\n    background: linear-gradient(90deg, var(--accent-1), var(--accent-2));\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    text-shadow: 0 6px 28px rgba(86,224,216,0.06);\n  }\n\n  /* nodes */\n  .node{\n    position:absolute;\n    width:150px;\n    height:110px;\n    border-radius:16px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    gap:8px;\n    padding:12px;\n    box-sizing:border-box;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 8px 30px rgba(2,8,20,0.5), inset 0 1px 0 rgba(255,255,255,0.02);\n    transition:transform 600ms cubic-bezier(.2,.9,.1,1), box-shadow 400ms;\n  }\n\n  .node .pid{\n    font-weight:700;\n    letter-spacing:0.6px;\n    color: #e6f9f5;\n  }\n  .node .desc{\n    color: rgba(236,240,255,0.65);\n    font-size:13px;\n  }\n\n  /* resources (locks) next to nodes */\n  .resource{\n    position:absolute;\n    width:86px;\n    height:46px;\n    border-radius:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:10px;\n    padding:8px;\n    box-sizing:border-box;\n    font-weight:700;\n    color:var(--muted);\n    box-shadow: 0 10px 30px rgba(3,9,22,0.5);\n    transition:transform 400ms, box-shadow 350ms;\n  }\n\n  .res-lock{\n    width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.02));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  /* arrows (svg) */\n  .arrows{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n  }\n\n  /* positioning the four nodes/res */\n  /* Node 0: top-right */\n  .node.n0{ left:58%; top:22%; transform:translate(-50%,-50%); }\n  .node.n1{ left:82%; top:58%; transform:translate(-50%,-50%); }\n  .node.n2{ left:42%; top:82%; transform:translate(-50%,-50%); }\n  .node.n3{ left:12%; top:58%; transform:translate(-50%,-50%); }\n\n  /* resources positioned clockwise near each node's right side (they hold one resource) */\n  .res.r0{ left:70%; top:30%; transform:translate(-50%,-50%); }\n  .res.r1{ left:88%; top:66%; transform:translate(-50%,-50%); }\n  .res.r2{ left:50%; top:90%; transform:translate(-50%,-50%); }\n  .res.r3{ left:2%; top:66%; transform:translate(-50%,-50%); }\n\n  /* arrows style */\n  .arrow-path{ stroke-width:3.2; stroke-linecap:round; fill:none; stroke:rgba(255,255,255,0.06); filter:url(#glow); transition:stroke 400ms; }\n  .arrow-flow{ stroke-dasharray: 300; stroke-dashoffset: 300; animation:dash 2.2s linear infinite; stroke: url(#gradFlow); }\n  @keyframes dash {\n    0%{ stroke-dashoffset:300;}\n    100%{ stroke-dashoffset:0;}\n  }\n\n  /* hold arrows (solid) */\n  .hold{ stroke:rgba(86,224,216,0.18); stroke-width:5; stroke-linecap:round; }\n\n  /* request arrows (animated) */\n  .req{ stroke:rgba(255,184,107,0.27); stroke-width:4; stroke-linecap:round; opacity:0.0; transform-origin:center; transition:opacity 300ms; }\n\n  /* glowing ring for deadlock cycle */\n  .dead-ring{\n    position:absolute; left:50%; top:50%; transform:translate(-50%,-50%) scale(0.9);\n    width:540px; height:540px; border-radius:50%;\n    pointer-events:none;\n    box-shadow: 0 0 160px rgba(255,107,107,0.06), inset 0 0 80px rgba(255,107,107,0.02);\n    opacity:0; transform-origin:center;\n    transition:opacity 800ms ease, transform 800ms cubic-bezier(.2,.9,.1,1);\n  }\n\n  /* deadlock accent lines connecting resources in cycle */\n  .cycle-line{\n    position:absolute; inset:0; pointer-events:none;\n  }\n\n  /* state classes toggled by JS */\n  .state-init .node{ transform:translate(-50%,-50%) scale(0.98); opacity:0.9; filter:grayscale(0.15); }\n  .state-acquire .node{ transform:translate(-50%,-50%) scale(1); filter:grayscale(0); }\n  .state-acquire .res .res-lock{ box-shadow: 0 8px 28px rgba(86,224,216,0.14), inset 0 1px 0 rgba(255,255,255,0.02); }\n  .state-wait .req{ opacity:1; animation-play-state:running; }\n  .state-dead .core{ transform:translate(-50%,-50%) scale(1.06) rotate(-2deg); box-shadow: 0 24px 90px rgba(2,8,20,0.7); }\n  .state-dead .dead-ring{ opacity:1; transform:translate(-50%,-50%) scale(1); }\n  .state-dead .node{ box-shadow: 0 10px 40px rgba(2,8,20,0.6), 0 0 30px rgba(255,107,107,0.06); }\n  .state-dead .res .res-lock{ background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(0,0,0,0.02)); box-shadow: 0 8px 30px rgba(255,107,107,0.12); }\n  .state-dead .req{ stroke: var(--danger); opacity:1; filter: drop-shadow(0 4px 16px rgba(255,107,107,0.14)); }\n  .state-dead .hold{ stroke:var(--accent-1); opacity:0.85; filter: drop-shadow(0 8px 28px rgba(86,224,216,0.06)); }\n\n  /* icons and locks */\n  .icon{\n    width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n  .pid-badge{ font-size:13px; color:var(--muted); letter-spacing:0.6px; }\n\n  /* right panel - explanation */\n  .info{\n    padding:22px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:stretch;\n  }\n\n  .hdr{\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .badge{\n    width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    display:flex;align-items:center;justify-content:center;font-weight:800;color:#052024;\n    box-shadow: 0 8px 30px rgba(86,224,216,0.12);\n  }\n  h1{\n    margin:0;\n    font-size:20px;\n    color:#eaffe7;\n    letter-spacing:0.2px;\n  }\n  p.lead{\n    margin:0;\n    color:rgba(255,255,255,0.75);\n    font-size:13px;\n    line-height:1.45;\n  }\n\n  .explain{\n    margin-top:6px;\n    display:flex;\n    flex-direction:column;\n    gap:8px;\n  }\n\n  .explain .step{\n    display:flex;\n    gap:12px;\n    align-items:flex-start;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:12px;\n    padding:12px;\n    box-shadow: 0 6px 18px rgba(0,0,0,0.35);\n  }\n  .step .dot{\n    width:14px;height:14px;border-radius:6px;background:rgba(255,255,255,0.04);flex:0 0 14px;margin-top:6px;\n  }\n  .step .text{\n    font-size:13px;color:rgba(255,255,255,0.78);\n    line-height:1.35;\n  }\n  .muted{\n    color:rgba(255,255,255,0.44);\n    font-size:13px;\n  }\n\n  /* control button */\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:auto;\n    align-items:center;\n    justify-content:flex-end;\n  }\n  .btn{\n    appearance:none;border:0;padding:12px 18px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--accent-1);font-weight:700;letter-spacing:0.6px;cursor:pointer;box-shadow: 0 6px 20px rgba(2,8,20,0.45);\n    transition:transform 200ms, box-shadow 200ms;\n  }\n  .btn:active{ transform:translateY(2px) }\n  .btn .icon-sm{ margin-right:8px; display:inline-block; vertical-align:middle; opacity:0.9; }\n\n  /* small footer */\n  .meta{\n    margin-top:6px;color:rgba(255,255,255,0.33);font-size:12px;text-align:right;\n  }\n\n  /* little sparkles/particles */\n  .particles{\n    position:absolute;\n    inset:0; pointer-events:none; overflow:hidden;\n  }\n  .particle{\n    position:absolute;\n    opacity:0;\n    width:8px;height:8px;border-radius:100%;\n    background:linear-gradient(90deg, rgba(86,224,216,0.85), rgba(255,184,107,0.9));\n    box-shadow: 0 10px 30px rgba(86,224,216,0.08);\n    filter:blur(4px);\n    animation: float 8s linear infinite;\n  }\n  @keyframes float{\n    0%{ transform: translateY(0px) scale(0.8); opacity:0; }\n    10%{ opacity:0.6;}\n    50%{ transform: translateY(-40px) scale(1.2); opacity:0.9; }\n    100%{ transform: translateY(40px) scale(0.8); opacity:0; }\n  }\n\n  /* responsive */\n  @media (max-width:1080px){\n    .panel{ grid-template-columns: 1fr; height:auto; padding:22px; }\n    .stage{ margin-bottom:20px; }\n    .stage-inner{ width:620px;height:620px; }\n    .info{ padding:12px; }\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"panel state-init\" id=\"mainPanel\" aria-hidden=\"false\">\n    <div class=\"stage\">\n      <div class=\"stage-inner\" id=\"stage\">\n        <!-- central emblem -->\n        <div class=\"core\" id=\"core\">\n          <div>\n            <div class=\"title\">SYSTEM STATE</div>\n            <div class=\"big\" id=\"coreLabel\">Awaiting...</div>\n          </div>\n        </div>\n\n        <!-- deadlock glowing ring -->\n        <div class=\"dead-ring\" id=\"deadRing\"></div>\n\n        <!-- nodes -->\n        <div class=\"node n0\" id=\"n0\">\n          <div class=\"icon\" title=\"Process 0\">\n            <!-- stylized cpu icon -->\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><rect x=\"5\" y=\"5\" width=\"14\" height=\"14\" rx=\"2\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1.4\"/><path d=\"M9 9h6v6H9z\" fill=\"rgba(255,255,255,0.06)\"/></svg>\n          </div>\n          <div class=\"pid\">P0</div>\n          <div class=\"desc muted\">holding R0</div>\n        </div>\n\n        <div class=\"node n1\" id=\"n1\">\n          <div class=\"icon\" title=\"Process 1\">\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><rect x=\"5\" y=\"5\" width=\"14\" height=\"14\" rx=\"2\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1.4\"/><circle cx=\"12\" cy=\"12\" r=\"2\" fill=\"rgba(255,255,255,0.06)\"/></svg>\n          </div>\n          <div class=\"pid\">P1</div>\n          <div class=\"desc muted\">holding R1</div>\n        </div>\n\n        <div class=\"node n2\" id=\"n2\">\n          <div class=\"icon\" title=\"Process 2\">\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><rect x=\"5\" y=\"5\" width=\"14\" height=\"14\" rx=\"2\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1.4\"/><path d=\"M8 12h8\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.6\"/></svg>\n          </div>\n          <div class=\"pid\">P2</div>\n          <div class=\"desc muted\">holding R2</div>\n        </div>\n\n        <div class=\"node n3\" id=\"n3\">\n          <div class=\"icon\" title=\"Process 3\">\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><rect x=\"5\" y=\"5\" width=\"14\" height=\"14\" rx=\"2\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1.4\"/><path d=\"M9 9l6 6M9 15l6-6\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.4\"/></svg>\n          </div>\n          <div class=\"pid\">P3</div>\n          <div class=\"desc muted\">holding R3</div>\n        </div>\n\n        <!-- resources -->\n        <div class=\"resource res r0\" id=\"res0\">\n          <div class=\"res-lock\" id=\"lock0\" aria-hidden=\"true\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><path d=\"M7 11v-2a5 5 0 0110 0v2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><rect x=\"4\" y=\"11\" width=\"16\" height=\"9\" rx=\"2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\"/></svg>\n          </div>\n          <div style=\"font-size:13px;font-weight:700;color:rgba(255,255,255,0.85)\">R0</div>\n        </div>\n\n        <div class=\"resource res r1\" id=\"res1\">\n          <div class=\"res-lock\" id=\"lock1\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><path d=\"M7 11v-2a5 5 0 0110 0v2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><rect x=\"4\" y=\"11\" width=\"16\" height=\"9\" rx=\"2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\"/></svg>\n          </div>\n          <div style=\"font-size:13px;font-weight:700;color:rgba(255,255,255,0.85)\">R1</div>\n        </div>\n\n        <div class=\"resource res r2\" id=\"res2\">\n          <div class=\"res-lock\" id=\"lock2\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><path d=\"M7 11v-2a5 5 0 0110 0v2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><rect x=\"4\" y=\"11\" width=\"16\" height=\"9\" rx=\"2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\"/></svg>\n          </div>\n          <div style=\"font-size:13px;font-weight:700;color:rgba(255,255,255,0.85)\">R2</div>\n        </div>\n\n        <div class=\"resource res r3\" id=\"res3\">\n          <div class=\"res-lock\" id=\"lock3\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden><path d=\"M7 11v-2a5 5 0 0110 0v2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><rect x=\"4\" y=\"11\" width=\"16\" height=\"9\" rx=\"2\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1.6\"/></svg>\n          </div>\n          <div style=\"font-size:13px;font-weight:700;color:rgba(255,255,255,0.85)\">R3</div>\n        </div>\n\n        <!-- svg overlay for arrows -->\n        <svg class=\"arrows\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden>\n          <defs>\n            <linearGradient id=\"gradFlow\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ffd66b\"/>\n              <stop offset=\"1\" stop-color=\"#56e0d8\"/>\n            </linearGradient>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"3.2\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- Hold arrows (from node to its held resource) - subtle -->\n          <path id=\"h0\" class=\"arrow-path hold\" d=\"M62 29 C66 32,69 36,70 40\" marker-end=\"url(#arrow)\" />\n          <path id=\"h1\" class=\"arrow-path hold\" d=\"M86 66 C82 68,78 70,74 73\" />\n          <path id=\"h2\" class=\"arrow-path hold\" d=\"M56 90 C52 86,48 82,44 78\" />\n          <path id=\"h3\" class=\"arrow-path hold\" d=\"M10 66 C14 64,18 62,24 58\" />\n\n          <!-- Request arrows (animated lines forming cycle) -->\n          <path id=\"r0\" class=\"arrow-path req\" d=\"M68 36 C76 34,82 38,86 56\" />\n          <path id=\"r1\" class=\"arrow-path req\" d=\"M88 60 C82 78,68 86,56 86\" />\n          <path id=\"r2\" class=\"arrow-path req\" d=\"M52 88 C36 86,24 78,20 64\" />\n          <path id=\"r3\" class=\"arrow-path req\" d=\"M18 60 C30 38,48 34,62 30\" />\n\n          <!-- decorative cycle highlight (thin arc) -->\n          <circle id=\"cycleArc\" cx=\"50\" cy=\"50\" r=\"26\" fill=\"none\" stroke=\"rgba(255,107,107,0.0)\" stroke-width=\"3\" />\n        </svg>\n\n        <!-- cycle connecting lines (for dead state) -->\n        <svg class=\"cycle-line\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" aria-hidden>\n          <defs>\n            <linearGradient id=\"redRing\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"rgba(255,107,107,0.9)\"/>\n              <stop offset=\"1\" stop-color=\"rgba(255,107,107,0.2)\"/>\n            </linearGradient>\n          </defs>\n          <path id=\"c0\" d=\"M68 36 C76 34,82 38,86 56\" stroke=\"url(#redRing)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0\" />\n          <path id=\"c1\" d=\"M88 60 C82 78,68 86,56 86\" stroke=\"url(#redRing)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0\" />\n          <path id=\"c2\" d=\"M52 88 C36 86,24 78,20 64\" stroke=\"url(#redRing)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0\" />\n          <path id=\"c3\" d=\"M18 60 C30 38,48 34,62 30\" stroke=\"url(#redRing)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0\" />\n        </svg>\n\n        <!-- subtle particles -->\n        <div class=\"particles\" aria-hidden=\"true\" id=\"particles\">\n          <div class=\"particle\" style=\"left:6%;top:12%;animation-delay:-1s;width:6px;height:6px;\"></div>\n          <div class=\"particle\" style=\"left:86%;top:22%;animation-delay:-3s;width:8px;height:8px;\"></div>\n          <div class=\"particle\" style=\"left:52%;top:6%;animation-delay:-5s;width:7px;height:7px;\"></div>\n          <div class=\"particle\" style=\"left:34%;top:82%;animation-delay:-2s;\"></div>\n          <div class=\"particle\" style=\"left:96%;top:84%;animation-delay:-6s;width:10px;height:10px;\"></div>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"info\">\n      <div class=\"hdr\">\n        <div class=\"badge\">DL</div>\n        <div>\n          <h1>Deadlock — Cyclic Resource Wait</h1>\n          <div class=\"lead\">An animated, conceptual demonstration of a deadlock: multiple processes each hold a resource and simultaneously wait for another, creating a cycle that prevents progress.</div>\n        </div>\n      </div>\n\n      <div class=\"explain\">\n        <div class=\"step\">\n          <div class=\"dot\" style=\"background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\"></div>\n          <div class=\"text\"><strong>Mutual Exclusion:</strong> Resources are held exclusively by processes (locks are closed).</div>\n        </div>\n        <div class=\"step\">\n          <div class=\"dot\" style=\"background:rgba(255,255,255,0.06)\"></div>\n          <div class=\"text\"><strong>Hold and Wait:</strong> Each process holds one resource while requesting another.</div>\n        </div>\n        <div class=\"step\">\n          <div class=\"dot\" style=\"background:rgba(255,255,255,0.06)\"></div>\n          <div class=\"text\"><strong>Circular Wait:</strong> Requests form a cycle — no process can proceed, causing deadlock.</div>\n        </div>\n      </div>\n\n      <div class=\"muted\">This visualization emphasizes the structure and visual tension of a deadlock. Use the control to replay the animation.</div>\n\n      <div class=\"controls\">\n        <button class=\"btn\" id=\"replayBtn\" title=\"Replay animation\">\n          <span class=\"icon-sm\" aria-hidden>\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M21 12a9 9 0 10-2.6 6.06\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          </span>\n          Replay\n        </button>\n      </div>\n\n      <div class=\"meta\">Visual: Four processes, four resources — locked in a circular wait.</div>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function(){\n    // Minimal, deliberate JS to orchestrate timeline (one control: Replay)\n    const panel = document.getElementById('mainPanel');\n    const coreLabel = document.getElementById('coreLabel');\n    const replayBtn = document.getElementById('replayBtn');\n\n    const reqs = ['r0','r1','r2','r3'].map(id => document.getElementById(id));\n    const holds = ['h0','h1','h2','h3'].map(id => document.getElementById(id));\n    const locks = [ 'lock0','lock1','lock2','lock3' ].map(id => document.getElementById(id));\n    const cPaths = ['c0','c1','c2','c3'].map(id => document.getElementById(id));\n    const cycleArc = document.getElementById('cycleArc');\n\n    let timers = [];\n\n    function clearTimers(){\n      timers.forEach(t => clearTimeout(t));\n      timers = [];\n    }\n\n    function resetVisuals(){\n      clearTimers();\n      panel.classList.remove('state-acquire','state-wait','state-dead');\n      panel.classList.add('state-init');\n      coreLabel.textContent = 'Awaiting...';\n      // reset reqs opacity and stroke dashoffset\n      reqs.forEach(r => {\n        r.style.opacity = '0';\n        r.style.stroke = 'rgba(255,184,107,0.27)';\n        r.style.animationPlayState = 'paused';\n      });\n      holds.forEach(h => { h.style.opacity = '1'; });\n      cPaths.forEach(p => { p.style.opacity = '0'; });\n      cycleArc.style.stroke = 'rgba(255,107,107,0.0)';\n      locks.forEach(l => {\n        l.querySelector('svg path')?.setAttribute('stroke','rgba(255,255,255,0.12)');\n        l.style.boxShadow = '';\n      });\n      // core label\n      coreLabel.style.background = '';\n    }\n\n    function stepAcquire(){\n      panel.classList.add('state-acquire');\n      panel.classList.remove('state-init');\n      coreLabel.textContent = 'Acquiring resources';\n      locks.forEach((l, i) => {\n        // animate lock color to indicate locked\n        l.style.transition = 'box-shadow 600ms, transform 600ms';\n        l.style.transform = 'translateY(-2px)';\n        l.style.boxShadow = '0 8px 28px rgba(86,224,216,0.12), inset 0 1px 0 rgba(255,255,255,0.02)';\n      });\n    }\n\n    function stepRequest(){\n      panel.classList.add('state-wait');\n      coreLabel.textContent = 'Requests issued';\n      // animate reqs to be visible and moving\n      reqs.forEach((r, idx) => {\n        r.style.opacity = '1';\n        r.style.animationPlayState = 'running';\n      });\n    }\n\n    function stepDeadlock(){\n      panel.classList.add('state-dead');\n      coreLabel.textContent = 'Deadlock — Circular Wait';\n      // enhance red cycle paths\n      cPaths.forEach((p, i) => {\n        p.style.transition = 'opacity 800ms, stroke 600ms';\n        p.style.opacity = '1';\n      });\n      cycleArc.style.transition = 'stroke 900ms, opacity 900ms';\n      cycleArc.style.stroke = 'rgba(255,107,107,0.14)';\n      // animate locks to red-tinge\n      locks.forEach((l, i) => {\n        l.style.boxShadow = '0 10px 34px rgba(255,107,107,0.14)';\n        // tweak internal svg color\n        const svgPath = l.querySelector('svg path, svg rect');\n        if(svgPath) svgPath.setAttribute('stroke','rgba(255,120,120,0.95)');\n      });\n      // small subtle core effect\n      const core = document.getElementById('core');\n      core.animate([\n        { transform: 'translate(-50%,-50%) scale(1)', boxShadow: '0 20px 60px rgba(2,8,20,0.6)' },\n        { transform: 'translate(-50%,-50%) scale(1.06)', boxShadow: '0 28px 120px rgba(255,107,107,0.12)' },\n        { transform: 'translate(-50%,-50%) scale(1)', boxShadow: '0 20px 60px rgba(2,8,20,0.6)' }\n      ],{ duration:1500, iterations: Infinity });\n    }\n\n    function runSequence(){\n      resetVisuals();\n      // sequence with tasteful pauses\n      timers.push(setTimeout(()=> stepAcquire(), 400));\n      timers.push(setTimeout(()=> stepRequest(), 1400));\n      timers.push(setTimeout(()=> stepDeadlock(), 3000));\n    }\n\n    // initial run\n    runSequence();\n\n    replayBtn.addEventListener('click', ()=>{\n      // simple ripple effect on button\n      replayBtn.animate([{transform:'translateY(0)'},{transform:'translateY(-4px)'},{transform:'translateY(0)'}],{duration:420});\n      runSequence();\n    });\n\n    // keep layout responsive for svg paths by adapting viewBox scale on resize\n    function updatePaths(){\n      // no-op placeholder but could compute dynamic paths; kept minimal intentionally\n    }\n    window.addEventListener('resize', updatePaths);\n\n    // expose minimal accessibility: pressing R replays\n    window.addEventListener('keydown', (e)=> {\n      if(e.key.toLowerCase() === 'r'){\n        replayBtn.click();\n      }\n    });\n\n  })();\n</script>\n</body>\n</html>"
