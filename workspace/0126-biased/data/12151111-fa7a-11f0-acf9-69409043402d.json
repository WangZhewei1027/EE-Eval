  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Big-O Notation Interactive Explorer</title>\n<style>\n  /* Minimal styling - only basic layout */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input[type=number], select {\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin: 0.3em 0 0.6em 0;\n    width: 100%;\n    box-sizing: border-box;\n  }\n  button {\n    margin: 0.2em 0.4em 0.6em 0;\n  }\n  label {\n    font-weight: normal;\n    font-size: 14px;\n  }\n  #output {\n    white-space: pre-wrap;\n    border: 1px solid #000;\n    min-height: 4em;\n    padding: 0.5em;\n    margin-top: 0.3em;\n  }\n  #graphContainer {\n    margin-top: 1em;\n  }\n  input[type=range] {\n    width: 100%;\n  }\n</style>\n</head>\n<body>\n<h1>Big-O Notation Interactive Explorer</h1>\n\n<section aria-label=\"Algorithm selection and input data\">\n  <label for=\"algoSelect\">Choose an Algorithm or Data Structure:</label><br />\n  <select id=\"algoSelect\" aria-describedby=\"algoDesc\">\n    <option value=\"\">-- Select an example --</option>\n    <option value=\"linear_search\">Linear Search</option>\n    <option value=\"binary_search\">Binary Search</option>\n    <option value=\"bubble_sort\">Bubble Sort</option>\n    <option value=\"merge_sort\">Merge Sort</option>\n    <option value=\"binary_tree_traversal\">Binary Tree Traversal</option>\n    <option value=\"hashmap_get\">HashMap Lookup</option>\n    <option value=\"fibonacci_recursive\">Fibonacci Recursive (Naive)</option>\n    <option value=\"fibonacci_dp\">Fibonacci with DP (Memoized)</option>\n    <option value=\"factorial_recursive\">Factorial Recursive</option>\n    <option value=\"exponential_powerset\">Generate Power Set (Exponential)</option>\n  </select><br />\n  <div id=\"algoDesc\" aria-live=\"polite\" style=\"margin-top:0.1em; font-style: italic;\"></div>\n\n  <label for=\"inputSize\">Input Size (N):</label><br />\n  <input type=\"number\" id=\"inputSize\" min=\"1\" max=\"100000\" step=\"1\" value=\"10\" aria-describedby=\"sizeHelp\" />\n  <small id=\"sizeHelp\">Choose input size; for certain algorithms, large values might cause delays.</small><br />\n\n  <label for=\"customInput\" id=\"customInputLabel\" hidden>Custom Input (JSON Array or Number):</label><br />\n  <textarea id=\"customInput\" rows=\"5\" style=\"font-family: monospace;\" hidden aria-describedby=\"customInputHelp\"></textarea>\n  <small id=\"customInputHelp\" hidden>Enter a JSON-formatted input array or simple number depending on algorithm.</small>\n\n  <button id=\"generateInputBtn\" type=\"button\">Generate Random Input</button>\n  <button id=\"resetInputBtn\" type=\"button\">Reset Input</button>\n</section>\n\n<section aria-label=\"Algorithm execution controls\" style=\"margin-top:1em;\">\n  <button id=\"runBtn\" type=\"button\">Run Algorithm</button>\n  <button id=\"stepBtn\" type=\"button\" disabled>Step Through Algorithm</button>\n  <button id=\"resetBtn\" type=\"button\" disabled>Reset Execution</button>\n</section>\n\n<section aria-label=\"Execution controls for step speed\" style=\"margin-top:1em;\">\n  <label for=\"stepSpeedRange\">Step Speed (ms): <output id=\"stepSpeedOutput\">500</output></label><br />\n  <input type=\"range\" id=\"stepSpeedRange\" min=\"100\" max=\"2000\" step=\"100\" value=\"500\" />\n</section>\n\n<section aria-label=\"State output and analysis\" style=\"margin-top:1em;\">\n  <h2>Execution Output / Trace</h2>\n  <div id=\"output\" aria-live=\"polite\" tabindex=\"0\" aria-label=\"Algorithm execution output\">\n    Select an algorithm, generate input, and run to see output here.\n  </div>\n</section>\n\n<section aria-label=\"Analysis and Big-O exploration\" style=\"margin-top:1em;\">\n  <h2>Big-O Complexity Exploration</h2>\n  <p>\n    <label><input type=\"checkbox\" id=\"showComplexity\" /> Show theoretical Big-O complexity formulas for selected algorithm</label><br />\n    <label><input type=\"checkbox\" id=\"plotGraph\" /> Plot time complexity vs. input size graph</label>\n  </p>\n\n  <div id=\"graphContainer\"></div>\n\n  <label for=\"manualInputN\">Manually vary input size for timing test (N):</label><br />\n  <input type=\"number\" id=\"manualInputN\" min=\"1\" max=\"100000\" step=\"1\" value=\"10\" />\n  <button id=\"timeTestBtn\" type=\"button\">Run Timing Test</button>\n  <p id=\"timingResult\" aria-live=\"polite\"></p>\n</section>\n\n<section aria-label=\"Custom complexity function and tester\" style=\"margin-top:2em;\">\n  <h2>Custom Complexity Function Tester</h2>\n  <label for=\"customComplexityFunc\">Enter Big-O complexity function f(n) using variable <code>n</code> (e.g., \"n\", \"n*log2(n)\", \"n*n\", \"2^n\"):</label><br />\n  <input type=\"text\" id=\"customComplexityFunc\" placeholder=\"e.g. n * Math.log2(n)\" style=\"width: 100%;\" />\n  <button id=\"customFuncTestBtn\" type=\"button\">Evaluate for N values</button><br />\n  <label for=\"customFuncNvalues\" style=\"margin-top:0.6em;\">N values (comma separated):</label><br />\n  <input type=\"text\" id=\"customFuncNvalues\" placeholder=\"e.g. 10,100,1000\" style=\"width: 100%;\" />\n  <pre id=\"customFuncResult\" aria-live=\"polite\" style=\"white-space: pre-wrap; border:1px solid #000; padding:0.4em; margin-top:0.3em; min-height:4em;\"></pre>\n</section>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // Algorithms metadata and code snippets\n  const algorithms = {\n    linear_search: {\n      name: \"Linear Search\",\n      desc: \"Searches a value by scanning each element linearly. Time: O(N)\",\n      requiresInput: true,\n      generateInput: (n) => {\n        // generate array of n random integers [0..n*10)\n        const arr = [];\n        for(let i=0;i<n;i++) arr.push(Math.floor(Math.random()*n*10));\n        return arr;\n      },\n      inputType: \"array\",\n      run: function(input, options, stepCallback){\n        // input: array, options: {searchFor:number}\n        let arr = input;\n        let target = options.searchFor ?? arr[Math.floor(arr.length/2)];\n        let i=0;\n        let foundIndex = -1;\n        while(i<arr.length){\n          stepCallback && stepCallback({type:\"check\",index:i,value:arr[i],target});\n          if(arr[i]===target){\n            foundIndex = i;\n            break;\n          }\n          i++;\n        }\n        stepCallback && stepCallback({type:\"done\",foundIndex,target});\n        return foundIndex;\n      },\n      stepIterator: function*(input, options){\n        let arr = input;\n        let target = options.searchFor ?? arr[Math.floor(arr.length/2)];\n        for(let i=0;i<arr.length;i++){\n          yield {type:\"check\",index:i,value:arr[i],target};\n          if(arr[i]===target){\n            yield {type:\"done\",foundIndex:i,target};\n            return i;\n          }\n        }\n        yield {type:\"done\",foundIndex:-1,target};\n        return -1;\n      },\n      complexity: \"O(N)\",\n      complexityFunc: (n) => n,\n      complexityDescription: \"Linear search checks each element until the target is found or the list ends.\",\n    },\n\n    binary_search: {\n      name: \"Binary Search\",\n      desc: \"Searches sorted array by repeatedly dividing search interval. Time: O(log N)\",\n      requiresInput: true,\n      generateInput: (n) => {\n        // sorted array [0,2,4,6,...]\n        const arr = [];\n        for(let i=0;i<n;i++) arr.push(i*2);\n        return arr;\n      },\n      inputType: \"array\",\n      run: function(input, options, stepCallback){\n        let arr=input;\n        let target = options.searchFor ?? arr[Math.floor(arr.length/2)];\n        let left=0, right=arr.length-1, mid;\n        while(left<=right){\n          mid = Math.floor((left+right)/2);\n          stepCallback && stepCallback({type:\"check\",left,right,mid,value:arr[mid],target});\n          if(arr[mid]===target){\n            stepCallback && stepCallback({type:\"done\",foundIndex:mid,target});\n            return mid;\n          } else if(arr[mid]<target){\n            left = mid+1;\n          } else {\n            right = mid-1;\n          }\n        }\n        stepCallback && stepCallback({type:\"done\",foundIndex:-1,target});\n        return -1;\n      },\n      stepIterator: function *(input, options){\n        let arr=input;\n        let target = options.searchFor ?? arr[Math.floor(arr.length/2)];\n        let left=0, right=arr.length-1, mid;\n        while(left<=right){\n          mid = Math.floor((left+right)/2);\n          yield {type:\"check\",left,right,mid,value:arr[mid],target};\n          if(arr[mid]===target){\n            yield {type:\"done\",foundIndex:mid,target};\n            return mid;\n          } else if(arr[mid]<target){\n            left=mid+1;\n          } else {\n            right=mid-1;\n          }\n        }\n        yield {type:\"done\",foundIndex:-1,target};\n        return -1;\n      },\n      complexity: \"O(log N)\",\n      complexityFunc: (n) => Math.log2(n),\n      complexityDescription: \"Binary search halves the search space until the target is found or not present.\",\n    },\n\n    bubble_sort: {\n      name: \"Bubble Sort\",\n      desc: \"Repeatedly swaps adjacent out-of-order elements. Time: O(N²)\",\n      requiresInput: true,\n      generateInput: (n) => {\n        // generate random array of n integers\n        const arr = [];\n        for(let i=0;i<n;i++) arr.push(Math.floor(Math.random()*n*10));\n        return arr;\n      },\n      inputType: \"array\",\n      run: function(input, options, stepCallback){\n        let arr = input.slice();\n        let n = arr.length;\n        let swapped;\n        do {\n          swapped = false;\n          for(let i=1;i<n;i++){\n            stepCallback && stepCallback({type:\"compare\",i1:i-1,v1:arr[i-1],i2:i,v2:arr[i]});\n            if(arr[i-1]>arr[i]){\n              let tmp=arr[i-1]; arr[i-1]=arr[i]; arr[i]=tmp; swapped=true;\n              stepCallback && stepCallback({type:\"swap\",i1:i-1,i2:i,v1:arr[i-1],v2:arr[i]});\n            }\n          }\n          n--;\n        } while(swapped);\n        stepCallback && stepCallback({type:\"done\",sortedArray:arr});\n        return arr;\n      },\n      stepIterator: function *(input, options){\n        let arr = input.slice();\n        let n = arr.length;\n        let swapped;\n        do {\n          swapped = false;\n          for(let i=1;i<n;i++){\n            yield {type:\"compare\",i1:i-1,v1:arr[i-1],i2:i,v2:arr[i]};\n            if(arr[i-1]>arr[i]){\n              let tmp=arr[i-1]; arr[i-1]=arr[i]; arr[i]=tmp; swapped=true;\n              yield {type:\"swap\",i1:i-1,i2:i,v1:arr[i-1],v2:arr[i],array:arr.slice()};\n            }\n          }\n          n--;\n        } while(swapped);\n        yield {type:\"done\",sortedArray:arr};\n        return arr;\n      },\n      complexity: \"O(N²)\",\n      complexityFunc: (n) => n*n,\n      complexityDescription: \"Bubble sort compares and swaps adjacent elements repeatedly until sorted.\",\n    },\n\n    merge_sort: {\n      name: \"Merge Sort\",\n      desc: \"Divide and conquer sorting by splitting and merging. Time: O(N log N)\",\n      requiresInput: true,\n      generateInput: (n) => {\n        const arr=[];\n        for(let i=0;i<n;i++) arr.push(Math.floor(Math.random()*n*10));\n        return arr;\n      },\n      inputType: \"array\",\n      run: function(input, options, stepCallback){\n        // full implementation with simple trace inside\n        function merge(left, right){\n          let i=0,j=0,result=[];\n          while(i<left.length && j<right.length){\n            stepCallback && stepCallback({type:\"compareMerge\",leftVal:left[i],rightVal:right[j]});\n            if(left[i]<=right[j]) {\n              result.push(left[i]);\n              i++;\n            } else {\n              result.push(right[j]);\n              j++;\n            }\n          }\n          while(i<left.length) result.push(left[i++]);\n          while(j<right.length) result.push(right[j++]);\n          stepCallback && stepCallback({type:\"merged\",result:result.slice()});\n          return result;\n        }\n        function mergeSort(arr){\n          if(arr.length <= 1) return arr.slice();\n          let mid = Math.floor(arr.length/2);\n          let left = mergeSort(arr.slice(0, mid));\n          let right = mergeSort(arr.slice(mid));\n          return merge(left, right);\n        }\n        let sorted = mergeSort(input);\n        stepCallback && stepCallback({type:\"done\",sortedArray:sorted});\n        return sorted;\n      },\n      stepIterator: function *(input, options){\n        // This is complex to step through recursively; we simulate it non-recursively by a queue of subarrays to sort and merge\n        // For richness - do a level-based iterative merge sort showing merges at each step.\n        let arr = input.slice();\n        let n = arr.length;\n        let width = 1;\n        while(width < n){\n          for(let i=0; i<n; i+=2*width){\n            let left = arr.slice(i, i+width);\n            let right = arr.slice(i+width, i+2*width);\n            yield {type:\"prepareMerge\",left:left.slice(), right:right.slice()};\n            let iL=0; let iR=0; let merged=[];\n            while(iL < left.length && iR < right.length){\n              yield {type:\"compareMerge\",leftVal:left[iL],rightVal:right[iR]};\n              if(left[iL]<=right[iR]){\n                merged.push(left[iL]);\n                iL++;\n              } else {\n                merged.push(right[iR]);\n                iR++;\n              }\n            }\n            while(iL<left.length) merged.push(left[iL++]);\n            while(iR<right.length) merged.push(right[iR++]);\n            yield {type:\"merged\",result:merged.slice()};\n            // put merged into arr\n            for(let k=0;k<merged.length;k++){\n              arr[i+k]=merged[k];\n            }\n            yield {type:\"arrayUpdated\",array:arr.slice()};\n          }\n          width*=2;\n        }\n        yield {type:\"done\",sortedArray:arr};\n        return arr;\n      },\n      complexity: \"O(N log N)\",\n      complexityFunc: (n) => n*Math.log2(n),\n      complexityDescription: \"Merge sort splits arrays and merges sorted halves efficiently.\",\n    },\n\n    binary_tree_traversal: {\n      name: \"Binary Tree Traversal (In-Order)\",\n      desc: \"Traverse all nodes in a binary tree in in-order. Time: O(N)\",\n      requiresInput: false,\n      inputType: \"tree\",\n      generateInput: (n) => {\n        // generate a balanced binary tree with n nodes\n        // nodes numbered 1..n in-order property does not hold necessarily\n        if(n<=0) return null;\n        // recursive build balanced tree\n        function buildTree(start,end){\n          if(start>end) return null;\n          const mid = Math.floor((start+end)/2);\n          return {val: mid, left:buildTree(start,mid-1), right:buildTree(mid+1,end)};\n        }\n        return buildTree(1,n);\n      },\n      run: function(input, options, stepCallback){\n        // in-order: left, root, right\n        let res = [];\n        function inorder(node){\n          if(!node) return;\n          stepCallback && stepCallback({type:\"visit\",phase:\"left\",node:node.val});\n          inorder(node.left);\n          stepCallback && stepCallback({type:\"visit\",phase:\"root\",node:node.val});\n          res.push(node.val);\n          stepCallback && stepCallback({type:\"visit\",phase:\"right\",node:node.val});\n          inorder(node.right);\n        }\n        inorder(input);\n        stepCallback && stepCallback({type:\"done\",order: res});\n        return res;\n      },\n      stepIterator: function *(input, options){\n        // explicit stack simulating recursion for step-wise stepper with phases left, root, right\n        if(!input) {\n          yield {type:\"done\",order:[]};\n          return [];\n        }\n        let stack = [];\n        // phases: 'start', 'left', 'root', 'right', 'done'\n        let output = [];\n        stack.push({node: input, phase: \"start\"});\n        while(stack.length){\n          let top = stack.pop();\n          let n = top.node;\n          let p = top.phase;\n          if(!n) continue;\n          if(p === \"start\"){\n            // go left\n            stack.push({node:n, phase:\"root\"});\n            stack.push({node:n.left, phase:\"start\"});\n            yield {type:\"visit\",phase:\"left\",node:n.val};\n          } else if(p===\"root\"){\n            output.push(n.val);\n            yield {type:\"visit\",phase:\"root\",node:n.val};\n            stack.push({node:n.right, phase:\"start\"});\n            yield {type:\"visit\",phase:\"right\",node:n.val};\n          }\n        }\n        yield {type:\"done\",order:output};\n        return output;\n      },\n      complexity: \"O(N)\",\n      complexityFunc: (n) => n,\n      complexityDescription: \"Traversing all nodes in a binary tree once.\",\n    },\n\n    hashmap_get: {\n      name: \"HashMap Lookup (Average case)\",\n      desc: \"Access a key in HashMap. Time: O(1) average case\",\n      requiresInput: false,\n      inputType: \"map\",\n      generateInput: (n) => {\n        // generate a map with keys \"key0\"..\"key{n-1}\" with values random numbers\n        let m = {};\n        for(let i=0;i<n;i++){\n          m[\"key\"+i] = Math.floor(Math.random()*n*10);\n        }\n        return m;\n      },\n      run: function(input, options, stepCallback){\n        // lookup key \"key{random}\" or given key in options\n        let map = input;\n        let keys = Object.keys(map);\n        let keyToFind = options.searchFor ?? keys[Math.floor(keys.length/2)];\n        stepCallback && stepCallback({type:\"lookup\",key:keyToFind});\n        let value = map[keyToFind];\n        stepCallback && stepCallback({type:\"done\",key:keyToFind,value});\n        return value;\n      },\n      stepIterator: function *(input, options){\n        let map = input;\n        let keys = Object.keys(map);\n        let keyToFind = options.searchFor ?? keys[Math.floor(keys.length/2)];\n        yield {type:\"lookup\",key:keyToFind};\n        let value = map[keyToFind];\n        yield {type:\"done\",key:keyToFind,value};\n        return value;\n      },\n      complexity: \"O(1) average case\",\n      complexityFunc: (n) => 1,\n      complexityDescription: \"HashMap average lookup time is constant.\",\n    },\n\n    fibonacci_recursive: {\n      name: \"Fibonacci Recursive (Naive)\",\n      desc: \"Calculates Fibonacci number using naive recursion. Time: O(2^N)\",\n      requiresInput: false,\n      inputType: \"number\",\n      generateInput: (n) => Math.min(n,40), // limit to max 40 because exponential\n      run: function(n, options, stepCallback){\n        let calls=0;\n        function fib(x){\n          calls++;\n          stepCallback && stepCallback({type:\"call\",x});\n          if(x<=1) return x;\n          return fib(x-1) + fib(x-2);\n        }\n        let result=fib(n);\n        stepCallback && stepCallback({type:\"done\",result,calls});\n        return result;\n      },\n      stepIterator: null, \n      complexity: \"O(2^N)\",\n      complexityFunc: (n) => Math.pow(2,n),\n      complexityDescription: \"Naive recursive Fibonacci explodes exponentially in calls.\",\n    },\n\n    fibonacci_dp: {\n      name: \"Fibonacci with DP (Memoized)\",\n      desc: \"Calculates Fibonacci using memoization. Time: O(N)\",\n      requiresInput: false,\n      inputType: \"number\",\n      generateInput: (n) => Math.min(n,1000),\n      run: function(n, options, stepCallback){\n        let dp = {};\n        function fib(x){\n          stepCallback && stepCallback({type:\"call\",x});\n          if(x<=1) return x;\n          if(dp[x]!==undefined) {\n            stepCallback && stepCallback({type:\"memoHit\",x});\n            return dp[x];\n          }\n          dp[x]=fib(x-1)+fib(x-2);\n          return dp[x];\n        }\n        let result=fib(n);\n        stepCallback && stepCallback({type:\"done\",result});\n        return result;\n      },\n      stepIterator: null,\n      complexity: \"O(N)\",\n      complexityFunc: (n) => n,\n      complexityDescription: \"Using memoization reduces calls to linear count.\",\n    },\n\n    factorial_recursive: {\n      name: \"Factorial Recursive\",\n      desc: \"Computes factorial with simple recursion. Time: O(N)\",\n      requiresInput: false,\n      inputType: \"number\",\n      generateInput: (n) => Math.min(n, 170), // limit for safe factorial (JS number)\n      run: function(n, options, stepCallback){\n        function fact(x){\n          stepCallback && stepCallback({type:\"call\",x});\n          if(x<=1) return 1;\n          return x * fact(x-1);\n        }\n        let result = fact(n);\n        stepCallback && stepCallback({type:\"done\",result});\n        return result;\n      },\n      stepIterator: null,\n      complexity: \"O(N)\",\n      complexityFunc: (n) => n,\n      complexityDescription: \"Simple linear recursion.\",\n    },\n\n    exponential_powerset: {\n      name: \"Generate Power Set (Exponential)\",\n      desc: \"Generate all subsets of a set. Time: O(2^N)\",\n      requiresInput: true,\n      generateInput: (n) => {\n        // array [0..n-1]\n        let arr = [];\n        for(let i=0;i<n;i++) arr.push(i);\n        return arr;\n      },\n      inputType: \"array\",\n      run: function(input, options, stepCallback){\n        let res = [[]];\n        for(let elem of input){\n          let newSubsets = [];\n          for(let subset of res){\n            stepCallback && stepCallback({type:\"creatingSubset\",current:subset,adding:elem});\n            newSubsets.push(subset.concat([elem]));\n          }\n          res = res.concat(newSubsets);\n        }\n        stepCallback && stepCallback({type:\"done\",resultCount:res.length});\n        return res;\n      },\n      stepIterator: null,\n      complexity: \"O(2^N)\",\n      complexityFunc: (n) => Math.pow(2,n),\n      complexityDescription: \"Power set doubles size with each additional element.\",\n    },\n  };\n\n  // State variables\n  let currentAlgorithm = null;\n  let inputData = null;\n  let executionIterator = null;\n  let executionRunning = false;\n  let executionStepTimeout = null;\n  let executionSpeedMs = 500;\n  let customInputManuallyEdited = false;\n  let manualTimingTestRunning = false;\n\n  // Cached elements\n  const algoSelect = document.getElementById(\"algoSelect\");\n  const algoDesc = document.getElementById(\"algoDesc\");\n  const inputSize = document.getElementById(\"inputSize\");\n  const customInput = document.getElementById(\"customInput\");\n  const customInputLabel = document.getElementById(\"customInputLabel\");\n  const customInputHelp = document.getElementById(\"customInputHelp\");\n  const generateInputBtn = document.getElementById(\"generateInputBtn\");\n  const resetInputBtn = document.getElementById(\"resetInputBtn\");\n\n  const runBtn = document.getElementById(\"runBtn\");\n  const stepBtn = document.getElementById(\"stepBtn\");\n  const resetBtn = document.getElementById(\"resetBtn\");\n\n  const stepSpeedRange = document.getElementById(\"stepSpeedRange\");\n  const stepSpeedOutput = document.getElementById(\"stepSpeedOutput\");\n\n  const outputDiv = document.getElementById(\"output\");\n\n  const showComplexityChk = document.getElementById(\"showComplexity\");\n  const plotGraphChk = document.getElementById(\"plotGraph\");\n  const graphContainer = document.getElementById(\"graphContainer\");\n  const manualInputN = document.getElementById(\"manualInputN\");\n  const timeTestBtn = document.getElementById(\"timeTestBtn\");\n  const timingResult = document.getElementById(\"timingResult\");\n\n  const customComplexityFuncInput = document.getElementById(\"customComplexityFunc\");\n  const customFuncNvaluesInput = document.getElementById(\"customFuncNvalues\");\n  const customFuncTestBtn = document.getElementById(\"customFuncTestBtn\");\n  const customFuncResult = document.getElementById(\"customFuncResult\");\n\n  // Small utils\n  function sleep(ms){\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  function clearOutput(){\n    outputDiv.textContent = \"\";\n  }\n\n  function appendOutput(text){\n    outputDiv.textContent += text + \"\\n\";\n    outputDiv.scrollTop = outputDiv.scrollHeight;\n  }\n\n  function printOutput(text){\n    outputDiv.textContent = text + \"\\n\";\n  }\n\n  // Safe JSON parse with error reporting\n  function safeJsonParse(str){\n    try {\n      return {value: JSON.parse(str), error:null};\n    } catch(e){\n      return {value:null, error: e.message};\n    }\n  }\n\n  // Format big number with commas for console output\n  function formatNumber(n){\n    if(typeof n !== \"number\") return n;\n    if(Math.abs(n)>=1e9) return (n/1e9).toFixed(2)+\"B\";\n    if(Math.abs(n)>=1e6) return (n/1e6).toFixed(2)+\"M\";\n    if(Math.abs(n)>=1e3) return (n/1e3).toFixed(2)+\"K\";\n    return n.toString();\n  }\n\n  // Show algorithm description and setup inputs\n  function onAlgorithmChange(){\n    const val = algoSelect.value;\n    currentAlgorithm = val ? algorithms[val] : null;\n    clearOutput();\n\n    if(!currentAlgorithm){\n      algoDesc.textContent = \"\";\n      inputData = null;\n      customInputLabel.hidden = true;\n      customInputHelp.hidden = true;\n      customInput.hidden = true;\n      generateInputBtn.disabled = true;\n      resetInputBtn.disabled = true;\n      runBtn.disabled = true;\n      stepBtn.disabled = true;\n      resetBtn.disabled = true;\n      return;\n    }\n\n    algoDesc.textContent = currentAlgorithm.desc;\n\n    // Show or hide custom input\n    if(currentAlgorithm.requiresInput){\n      generateInputBtn.disabled = false;\n      resetInputBtn.disabled = false;\n      runBtn.disabled = false;\n    } else {\n      generateInputBtn.disabled = true;\n      resetInputBtn.disabled = true;\n      runBtn.disabled = false; // allowed to run algorithms without input to produce results\n    }\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n\n    // Show custom input field if algorithm requires or if input type is array or number\n    if (currentAlgorithm.inputType === \"array\" || currentAlgorithm.inputType === \"map\" || currentAlgorithm.inputType === \"number\") {\n      customInputLabel.hidden = false;\n      customInputHelp.hidden = false;\n      customInput.hidden = false;\n    } else {\n      customInputLabel.hidden = true;\n      customInputHelp.hidden = true;\n      customInput.hidden = true;\n    }\n\n    // Clear and initialize input data\n    generateInput();\n  }\n\n  // Generate Input Data and fill customInput textarea if applicable\n  function generateInput(){\n    if(!currentAlgorithm) return;\n    let n = parseInt(inputSize.value,10);\n    if(isNaN(n) || n < 1) n = 10;\n    inputSize.value = n;\n\n    if(currentAlgorithm.requiresInput){\n      try {\n        inputData = currentAlgorithm.generateInput(n);\n      } catch(e){\n        inputData = null;\n      }\n      if(typeof inputData === \"object\" && inputData !== null){\n        try {\n          customInput.value = JSON.stringify(inputData,null,2);\n        } catch(e){\n          customInput.value = \"\";\n        }\n      } else if(typeof inputData === \"number\"){\n        customInput.value = inputData.toString();\n      } else {\n        customInput.value = \"\";\n      }\n    } else {\n      inputData = null;\n      customInput.value = \"\";\n    }\n    customInputManuallyEdited = false;\n    clearOutput();\n  }\n\n  // Reset input to last generated\n  function resetInput(){\n    if(!currentAlgorithm) return;\n    generateInput();\n  }\n\n  // Try loading inputData from textarea custom input field if shown\n  function parseCustomInput(){\n    if(customInput.hidden) return true;\n    const val = customInput.value.trim();\n    if(val === \"\") {\n      inputData = null;\n      return true;\n    }\n    let parsed;\n    if(currentAlgorithm.inputType === \"number\"){\n      let numval = Number(val);\n      if(isNaN(numval)){\n        appendOutput(\"Input error: Expected a number.\");\n        return false;\n      } else {\n        inputData = numval;\n        return true;\n      }\n    }\n    // else parse JSON\n    const parsedRes = safeJsonParse(val);\n    if(parsedRes.error){\n      appendOutput(\"Input JSON parse error: \" + parsedRes.error);\n      return false;\n    }\n    inputData = parsedRes.value;\n    return true;\n  }\n\n  // Run entire algorithm at once\n  async function runAlgorithmFull(){\n    if(executionRunning) return;\n    clearOutput();\n    // parse input\n    if(!parseCustomInput()) return;\n    if(!currentAlgorithm) return;\n\n    const stepCallback = (step) => {\n      // append and interpret step info in full runs after completion\n      // Minimal step info for full runs to keep output readable\n      if(step.type===\"done\"){\n        if(\"foundIndex\" in step){\n          appendOutput(`Target found at index: ${step.foundIndex}, target=${step.target}`);\n        } else if(\"sortedArray\" in step){\n          appendOutput(\"Sorted array: \"+JSON.stringify(step.sortedArray));\n        } else if(\"order\" in step){\n          appendOutput(\"Traversal order: \"+step.order.join(\", \"));\n        } else if(\"value\" in step && \"key\" in step){\n          appendOutput(`Lookup key: ${step.key}, value: ${step.value}`);\n        } else if(\"resultCount\" in step){\n          appendOutput(\"Power set generated with subsets count: \"+step.resultCount);\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+JSON.stringify(step.result));\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+JSON.stringify(step.result));\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+step.result);\n        } else if(\"resultCount\" in step){\n          appendOutput(\"Result count: \"+step.resultCount);\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+step.result);\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+step.result);\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+step.result);\n        } else if(\"result\" in step){\n          appendOutput(\"Result: \"+step.result);\n        }\n        else {\n          appendOutput(\"Execution finished.\");\n        }\n      }\n    };\n\n    try {\n      let res = currentAlgorithm.run(inputData, {}, stepCallback);\n      if(res && typeof res.then === \"function\"){\n        res = await res;\n      }\n      if(res !== undefined && res !== null && !Array.isArray(res)) {\n        appendOutput(\"Result: \" + JSON.stringify(res));\n      }\n    } catch(e) {\n      appendOutput(\"Error during algorithm execution: \" + e.message);\n    }\n    stepBtn.disabled = !currentAlgorithm.stepIterator;\n    resetBtn.disabled = true;\n  }\n\n  // Variables used for stepping\n  let currentStepDetails = { iterator: null, lastResult: null };\n\n  // Run the step iterator with interactivity\n  async function stepNext(){\n    if(!currentStepDetails.iterator) return;\n    try {\n      let {value, done} = currentStepDetails.iterator.next();\n      if(done){\n        currentStepDetails.lastResult = value;\n        appendOutput(\"*** Execution finished ***\");\n        stepBtn.disabled = true;\n        resetBtn.disabled = false;\n        executionRunning = false;\n        return;\n      }\n      interpretStep(value);\n    } catch(e){\n      appendOutput(\"Error during step: \" + e.message);\n      stepBtn.disabled = true;\n      resetBtn.disabled = false;\n      executionRunning = false;\n    }\n  }\n\n  // Interpret a single step and print info to output\n  function interpretStep(step){\n    if(!step || typeof step !== \"object\") return;\n    switch(step.type){\n      case \"check\":\n        if(\"index\" in step){\n          appendOutput(`Checking index ${step.index}, value=${step.value} vs target=${step.target}`);\n        } else {\n          appendOutput(`Search Range [${step.left}..${step.right}], mid=${step.mid}, value=${step.value}, target=${step.target}`);\n        }\n        break;\n      case \"done\":\n        if (\"foundIndex\" in step) {\n          appendOutput(`Done: target (${step.target}) found at index ${step.foundIndex}`);\n        } else if (\"sortedArray\" in step){\n          appendOutput(\"Done: sorted array: \"+JSON.stringify(step.sortedArray));\n        } else if (\"order\" in step){\n          appendOutput(\"Done: in-order traversal order: \"+step.order.join(\", \"));\n        } else if (\"value\" in step && \"key\" in step){\n          appendOutput(`Done: lookup key: ${step.key} value: ${step.value}`);\n        } else if (\"resultCount\" in step){\n          appendOutput(\"Done: power set subset count: \"+step.resultCount);\n        } else if (\"result\" in step){\n          appendOutput(\"Done: result: \"+JSON.stringify(step.result));\n        } else {\n          appendOutput(\"Done.\");\n        }\n        break;\n\n      case \"compare\":\n        appendOutput(`Compare indices ${step.i1} (${step.v1}) and ${step.i2} (${step.v2})`);\n        break;\n      case \"swap\":\n        appendOutput(`Swap elements at indices ${step.i1} and ${step.i2}. New values: ${step.v1}, ${step.v2}`);\n        break;\n\n      case \"prepareMerge\":\n        appendOutput(\"Merge Sort - preparing merge left: \"+JSON.stringify(step.left)+\" right: \"+JSON.stringify(step.right));\n        break;\n      case \"compareMerge\":\n        appendOutput(`Compare merge values: ${step.leftVal} and ${step.rightVal}`);\n        break;\n      case \"merged\":\n        appendOutput(\"Merged result: \"+JSON.stringify(step.result));\n        break;\n      case \"arrayUpdated\":\n        appendOutput(\"Array updated: \"+JSON.stringify(step.array));\n        break;\n\n      case \"visit\":\n        appendOutput(\"Visit node \"+step.node+\" during phase: \"+step.phase);\n        break;\n\n      case \"lookup\":\n        appendOutput(\"Lookup key: \"+step.key);\n        break;\n\n      case \"call\":\n        appendOutput(\"Function call with argument: \"+step.x);\n        break;\n\n      case \"memoHit\":\n        appendOutput(\"Memoized result accessed for argument: \"+step.x);\n        break;\n\n      case \"creatingSubset\":\n        appendOutput(\"Power set: adding element \"+step.adding+\" to subset \"+JSON.stringify(step.current));\n        break;\n\n      default:\n        appendOutput(\"Step: \"+JSON.stringify(step));\n    }\n  }\n\n  // Start step-wise execution\n  async function runSteps(){\n    if(executionRunning) return;\n    clearOutput();\n    if(!currentAlgorithm) return;\n    if(!currentAlgorithm.stepIterator) {\n      appendOutput(\"Step execution not available for this algorithm.\");\n      return;\n    }\n    if(!parseCustomInput()) return;\n    executionIterator = currentAlgorithm.stepIterator(inputData, {});\n    currentStepDetails.iterator = executionIterator;\n    executionRunning = true;\n    runBtn.disabled=true;\n    stepBtn.disabled=false;\n    resetBtn.disabled=false;\n    await stepNext();\n  }\n\n  // Reset execution state\n  function resetExecution(){\n    executionRunning = false;\n    runBtn.disabled = false;\n    stepBtn.disabled = !currentAlgorithm || !currentAlgorithm.stepIterator;\n    resetBtn.disabled = true;\n    clearOutput();\n  }\n\n  // Handle automated stepping with speed control\n  let autoSteppingInterval = null;\n  let autoSteppingEnabled = false;\n\n  function startAutoStepping(){\n    if(autoSteppingEnabled || !executionRunning) return;\n    autoSteppingEnabled = true;\n    stepBtn.disabled = true;\n    runBtn.disabled = true;\n    resetBtn.disabled = false;\n    autoSteppingInterval = setInterval(() => {\n      if(!executionRunning){\n        stopAutoStepping();\n        return;\n      }\n      stepNext().then(() => {\n        if(!executionRunning){\n          stopAutoStepping();\n        }\n      });\n    }, executionSpeedMs);\n  }\n\n  function stopAutoStepping(){\n    if(!autoSteppingEnabled) return;\n    autoSteppingEnabled = false;\n    if(autoSteppingInterval) clearInterval(autoSteppingInterval);\n    autoSteppingInterval = null;\n    stepBtn.disabled = executionRunning ? false : true;\n    runBtn.disabled = executionRunning ? true : false;\n  }\n\n  // Respond to step speed slider change\n  function onStepSpeedChange(){\n    let val = parseInt(stepSpeedRange.value,10);\n    executionSpeedMs = val;\n    stepSpeedOutput.textContent = val;\n    if(autoSteppingEnabled){\n      stopAutoStepping();\n      startAutoStepping();\n    }\n  }\n\n  // Show or hide complexity description on demand\n  function onShowComplexityChange(){\n    clearAnalysisOutput();\n    if(showComplexityChk.checked && currentAlgorithm){\n      appendAnalysisOutput(`Algorithm: ${currentAlgorithm.name}\\nTime Complexity: ${currentAlgorithm.complexity}\\n${currentAlgorithm.complexityDescription}`);\n    }\n    if(plotGraphChk.checked) plotComplexityGraph();\n  }\n\n  // Plot time complexity graph as ASCII chart\n  function plotComplexityGraph(){\n    graphContainer.innerHTML = \"\";\n    if(!plotGraphChk.checked || !currentAlgorithm) return;\n\n    // Generate points for N and complexityFunc(N) for N = linearly spaced over max range\n    const maxN = Math.min(1000, Number(inputSize.value) || 100);\n    const points = [];\n    const f = currentAlgorithm.complexityFunc;\n    if(typeof f !== \"function\") {\n      graphContainer.textContent = \"No complexity function available for graph.\";\n      return;\n    }\n    for(let n=1; n<=maxN; n*=1.2){\n      points.push({n: n, val: f(n)});\n    }\n    // Normalize and plot in text simple bar chart\n    let maxVal = Math.max(...points.map(p=>p.val));\n    let lines = [\"N | Complexity (approx)\"];\n    for(let p of points){\n      let norm = Math.round((p.val/maxVal)*40);\n      let bar = \"*\".repeat(norm);\n      lines.push(p.n.toFixed(0).padStart(4,\" \")+\" | \"+bar);\n    }\n    graphContainer.textContent = lines.join(\"\\n\");\n  }\n\n  function clearAnalysisOutput(){\n    graphContainer.textContent=\"\";\n    timingResult.textContent=\"\";\n  }\n\n  function appendAnalysisOutput(txt){\n    graphContainer.textContent += txt + \"\\n\";\n  }\n\n  // Run timing test for algorithm for given N manually inputted\n  async function runTimingTest(){\n    if(manualTimingTestRunning) return;\n    clearAnalysisOutput();\n    if(!currentAlgorithm) {\n      timingResult.textContent = \"No algorithm selected.\";\n      return;\n    }\n    let n = Number(manualInputN.value);\n    if(isNaN(n) || n < 1){\n      timingResult.textContent = \"Invalid N value.\";\n      return;\n    }\n    timingResult.textContent = \"Running timing test for N=\"+n+\"...\";\n    // Generate input (or direct input)\n    try {\n      let input;\n      if(currentAlgorithm.requiresInput){\n        input = currentAlgorithm.generateInput(n);\n      } else {\n        input = n;\n      }\n      const start = performance.now();\n      // Run algorithm (single run)\n      let res = currentAlgorithm.run(input, {});\n      if(res && typeof res.then === \"function\"){\n        res = await res;\n      }\n      const end = performance.now();\n      let durationMS = end-start;\n      timingResult.textContent = `Execution time for N=${n}: ${durationMS.toFixed(3)} ms. Result (truncated): ${JSON.stringify(typeof res === \"object\" ? (Array.isArray(res) ? res.slice(0,5) : res) : res)}`;\n    } catch(e){\n      timingResult.textContent = \"Error during timing test: \" + e.message;\n    }\n  }\n\n  // Evaluate custom complexity function string for several N values\n  function evaluateCustomComplexity(){\n    customFuncResult.textContent = \"\";\n    let funcStr = customComplexityFuncInput.value.trim();\n    let nvalsStr = customFuncNvaluesInput.value.trim();\n    if(!funcStr){\n      customFuncResult.textContent = \"Please enter a complexity function.\";\n      return;\n    }\n    if(!nvalsStr){\n      customFuncResult.textContent = \"Please enter N values separated by commas.\";\n      return;\n    }\n    // Parse n values\n    let nvals = nvalsStr.split(\",\").map(s => s.trim()).map(s => Number(s)).filter(x => !isNaN(x) && x>=0);\n    if(nvals.length===0){\n      customFuncResult.textContent = \"No valid N values to evaluate.\";\n      return;\n    }\n    let results = [];\n    // Wrap function in safe try-catch and sandbox\n    for(let n of nvals){\n      try {\n        // We allow standard JS Math with Math. - provide helper alias \"log2\" Math.log2(n)\n        let funcEval = new Function(\"n\",\"Math\",\"log2\",\"pow\",\"exp\",\"sqrt\",\"abs\",\"min\",\"max\",\"floor\",\"ceil\",\"round\",\"sin\",\"cos\",\"tan\",\n          \"return \"+funcStr);\n        let val = funcEval(n, Math, Math.log2, Math.pow, Math.exp, Math.sqrt, Math.abs, Math.min, Math.max, Math.floor, Math.ceil, Math.round, Math.sin, Math.cos, Math.tan);\n        results.push(`f(${n}) = ${formatNumber(val)}`);\n      } catch(e){\n        results.push(`f(${n}) = ERROR (${e.message})`);\n      }\n    }\n    customFuncResult.textContent = results.join(\"\\n\");\n  }\n\n  // Events & wiring\n\n  algoSelect.addEventListener(\"change\", () => {\n    onAlgorithmChange();\n  });\n\n  inputSize.addEventListener(\"input\", () => {\n    // Restrict input range\n    let n = Number(inputSize.value);\n    if(n > 100000) inputSize.value = 100000;\n    if(n < 1) inputSize.value = 1;\n  });\n\n  inputSize.addEventListener(\"change\", () => {\n    generateInput();\n  });\n\n  generateInputBtn.addEventListener(\"click\", () => {\n    generateInput();\n  });\n  resetInputBtn.addEventListener(\"click\", () => {\n    resetInput();\n  });\n\n  customInput.addEventListener(\"input\", () => {\n    customInputManuallyEdited = true;\n  });\n\n  runBtn.addEventListener(\"click\", () => {\n    runAlgorithmFull();\n  });\n\n  stepBtn.addEventListener(\"click\", () => {\n    if(!executionRunning){\n      runSteps();\n    } else {\n      stepNext();\n    }\n  });\n\n  resetBtn.addEventListener(\"click\", () => {\n    resetExecution();\n  });\n\n  stepSpeedRange.addEventListener(\"input\", () => {\n    onStepSpeedChange();\n  });\n  onStepSpeedChange();\n\n  showComplexityChk.addEventListener(\"change\", () => {\n    onShowComplexityChange();\n  });\n\n  plotGraphChk.addEventListener(\"change\", () => {\n    onShowComplexityChange();\n  });\n\n  timeTestBtn.addEventListener(\"click\", runTimingTest);\n\n  customFuncTestBtn.addEventListener(\"click\", evaluateCustomComplexity);\n\n  // Init page\n  onAlgorithmChange();\n\n})();\n</script>\n\n</body>\n</html>"
