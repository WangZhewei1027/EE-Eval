    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Space Complexity — A Visual Art</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;600&display=swap');\n\n  /* Root and base variables */\n  :root {\n    --color-bg: #0f1624;\n    --color-primary: #5a84ff;\n    --color-accent: #ff6e91;\n    --color-light: #e6ebf5;\n    --color-muted: #748094;\n    --color-glow: #729bf5;\n    --font-main: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n  }\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: var(--color-bg);\n    color: var(--color-light);\n    font-family: var(--font-main);\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  /* Container */\n  .container {\n    max-width: 960px;\n    margin: 4rem auto 6rem;\n    padding: 0 2rem;\n    text-align: center;\n  }\n\n  /* Heading */\n  h1 {\n    font-weight: 600;\n    font-size: clamp(2.25rem, 5vw, 3.5rem);\n    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 0.02em;\n    margin-bottom: 0.2em;\n    filter: drop-shadow(0 3px 5px rgba(90, 132, 255, 0.5));\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: var(--color-muted);\n    margin-top: 0;\n    margin-bottom: 3rem;\n    letter-spacing: 0.04em;\n  }\n\n  /* Description panel */\n  .description {\n    font-size: 1.125rem;\n    line-height: 1.6;\n    max-width: 660px;\n    margin: 0 auto 4rem;\n    color: var(--color-light);\n    text-shadow: 0 1px 3px rgba(0,0,0,0.3);\n  }\n\n  /* Space Complexity visualization area */\n  .viz-wrapper {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 1.7 / 1;\n    background: radial-gradient(ellipse at center, #1a2240 30%, #0f1624 90%);\n    border-radius: 1.25rem;\n    box-shadow:\n      inset 0 0 140px 35px var(--color-primary),\n      0 8px 25px rgb(90 132 255 / 0.48);\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Grid for space units */\n  .space-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-gap: 8px;\n    padding: 48px 56px;\n    width: 100%;\n    height: 100%;\n    position: relative;\n  }\n\n  /* Space block */\n  .space-cell {\n    background: linear-gradient(145deg, #243857, #1c2849);\n    border-radius: 0.7rem;\n    box-shadow:\n      3px 3px 6px #15203d,\n      -3px -3px 6px #2d438b;\n    position: relative;\n    cursor: default;\n    overflow: hidden;\n    transition: background 0.45s ease, box-shadow 0.45s ease;\n  }\n  .space-cell::before {\n    content: '';\n    position: absolute;\n    inset: 2.4px;\n    background: linear-gradient(45deg, #1c2a53, #273d8f);\n    border-radius: 0.5rem;\n    opacity: 0.7;\n    filter: drop-shadow(0 0 2px var(--color-glow));\n    transition: opacity 0.35s ease;\n  }\n\n  /* Filled space cells representing used space */\n  .space-cell.used {\n    background: linear-gradient(145deg, var(--color-primary), var(--color-accent));\n    box-shadow: 0 0 15px var(--color-accent);\n    cursor: default;\n  }\n  .space-cell.used::before {\n    opacity: 1;\n    background: linear-gradient(45deg, var(--color-primary), var(--color-accent));\n    filter: drop-shadow(0 0 15px var(--color-accent));\n  }\n\n  /* Animate cells fill */\n  .space-cell.used.animate-fill {\n    animation: fillPulse 1.6s ease infinite alternate;\n  }\n  @keyframes fillPulse {\n    0%   { box-shadow: 0 0 15px var(--color-accent); }\n    100% { box-shadow: 0 0 30px var(--color-primary); }\n  }\n\n  /* Labels */\n  .label-container {\n    position: absolute;\n    left: 28px;\n    top: 48px;\n    text-align: right;\n    font-weight: 600;\n    font-size: 1rem;\n    color: var(--color-muted);\n    user-select: none;\n    letter-spacing: 0.06em;\n    line-height: 1.5;\n    pointer-events: none;\n  }\n  .label-container .title {\n    font-size: 1.4rem;\n    color: var(--color-light);\n    margin-bottom: 0.4em;\n    letter-spacing: 0.08em;\n  }\n\n  /* Info bar */\n  .info-bar {\n    margin-top: 2.4rem;\n    background: #191f36;\n    border-radius: 1rem;\n    padding: 1.4rem 2rem;\n    max-width: 480px;\n    margin-left: auto;\n    margin-right: auto;\n    box-shadow:\n      inset 0 0 10px 1.5px var(--color-primary);\n    font-size: 1rem;\n    line-height: 1.45;\n    font-weight: 400;\n    color: var(--color-light);\n    letter-spacing: 0.02em;\n  }\n\n  /* Buttons container */\n  .btn-container {\n    margin-top: 3.8rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.4rem;\n  }\n  button {\n    background: var(--color-primary);\n    color: var(--color-bg);\n    font-weight: 600;\n    font-size: 1rem;\n    border: none;\n    border-radius: 9999px;\n    padding: 0.75rem 2.3rem;\n    cursor: pointer;\n    box-shadow:\n      0 4px 12px rgb(90 132 255 / 0.48);\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.3s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus-visible {\n    background: var(--color-accent);\n    box-shadow: 0 6px 26px rgb(255 110 145 / 0.68);\n    outline-offset: 3px;\n    transform: translateY(-3px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow: 0 2px 8px rgb(255 110 145 / 0.45);\n  }\n\n  /* Footer with subtle credit */\n  footer {\n    font-size: 0.85rem;\n    font-weight: 300;\n    color: var(--color-muted);\n    text-align: center;\n    margin-top: 6rem;\n    user-select: none;\n  }\n\n  /* Scrollbar for smaller screens */\n  @media (max-width: 600px) {\n    .space-grid {\n      grid-template-columns: repeat(8, 1fr);\n      grid-gap: 6px;\n      padding: 32px 24px;\n    }\n    .label-container {\n      font-size: 0.9rem;\n      left: 16px;\n      top: 32px;\n    }\n    h1 {\n      font-size: 2.4rem;\n    }\n  }\n\n</style>\n</head>\n<body>\n\n<div class=\"container\" role=\"main\" aria-label=\"Space Complexity Visual Demonstration\">\n  <h1>Space Complexity</h1>\n  <h2>Understanding Memory Usage in Algorithms</h2>\n\n  <div class=\"description\" id=\"description\">\n    Space complexity quantifies the amount of memory an algorithm needs to run relative to the input size. Unlike time complexity, which measures speed, space complexity focuses on how efficiently memory is utilized.<br/><br/>\n    <strong>Visualized below</strong> is an abstract memory grid representing fixed and dynamic memory allocations, illustrating the concept of auxiliary space and total space consumption.\n  </div>\n\n  <div class=\"viz-wrapper\" aria-label=\"Visual representation of space complexity memory blocks\">\n    <div class=\"label-container\" aria-hidden=\"true\">\n      <div class=\"title\">Memory Blocks</div>\n      <div>Blue: Fixed Memory<br>Pink: Dynamic (Auxiliary) Memory<br><br>Total: Input + Aux</div>\n    </div>\n    <div class=\"space-grid\" id=\"spaceGrid\" aria-hidden=\"true\">\n      <!-- 12 columns x 6 rows = 72 cells -->\n    </div>\n  </div>\n\n  <div class=\"btn-container\" role=\"region\" aria-label=\"Controls for memory fill visualization\">\n    <button id=\"fillBtn\" aria-pressed=\"false\">Show Example Space Usage</button>\n    <button id=\"resetBtn\" aria-pressed=\"false\" disabled>Reset</button>\n  </div>\n\n  <div class=\"info-bar\" id=\"infoBar\" aria-live=\"polite\" aria-atomic=\"true\">\n    Click <strong>Show Example Space Usage</strong> to see how memory is consumed based on given input and auxiliary space.\n  </div>\n</div>\n\n<footer>\n  &copy; 2024 &bull; Space Complexity Visualized &bull; Designed for clarity & aesthetics\n</footer>\n\n<script>\n  (() => {\n    const spaceGrid = document.getElementById('spaceGrid');\n    const fillBtn = document.getElementById('fillBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const infoBar = document.getElementById('infoBar');\n\n    // Create 72 cells (12 cols x 6 rows)\n    const totalCells = 72;\n    for(let i = 0; i < totalCells; i++) {\n      const cell = document.createElement('div');\n      cell.className = 'space-cell';\n      cell.setAttribute('data-index', i);\n      spaceGrid.appendChild(cell);\n    }\n\n    // Definitions:\n    // For this demonstration:\n    // Input size 'n' = 36 (blue blocks fixed)\n    // Auxiliary memory = 15 blocks (pink blocks)\n    // Total space = n + aux = 51 blocks\n    // Rest are unused memory blocks\n    \n    // We will animate fill of these blocks sequentially\n    \n    const inputSize = 36;  // blue blocks count\n    const auxSize = 15;    // pink (auxiliary)\n    let animationTimeouts = [];\n\n    function animateFillBlocks() {\n      clearAnimationTimeouts();\n      const cells = Array.from(spaceGrid.children);\n      infoBar.textContent = 'Visualizing space complexity memory usage...';\n\n      // Reset all first\n      cells.forEach(c => {\n        c.classList.remove('used', 'animate-fill');\n        c.style.background = '';\n      });\n\n      // Step 1: Fill Input memory blocks (blue)\n      for(let i = 0; i < inputSize; i++) {\n        animationTimeouts.push(setTimeout(() => {\n          const cell = cells[i];\n          cell.classList.add('used');\n          cell.classList.add('animate-fill');\n          // Blue gradient\n          cell.style.background = 'linear-gradient(145deg, #5a84ff, #729bf5)';\n          cell.style.boxShadow = '0 0 15px #5a84ff';\n          cell.style.setProperty('--color-accent', '#729bf5');\n        }, i * 40));\n      }\n\n      // Step 2: Fill Auxiliary memory blocks (pink)\n      for(let i = inputSize; i < inputSize + auxSize; i++) {\n        animationTimeouts.push(setTimeout(() => {\n          const cell = cells[i];\n          cell.classList.add('used');\n          cell.classList.add('animate-fill');\n          // Pink gradient\n          cell.style.background = 'linear-gradient(145deg, #ff6e91, #ff859d)';\n          cell.style.boxShadow = '0 0 18px #ff6e91';\n          cell.style.setProperty('--color-accent', '#ff6e91');\n        }, (i) * 40 + 400));\n      }\n\n      // Step 3: Update info bar with final explanation\n      animationTimeouts.push(setTimeout(() => {\n        infoBar.innerHTML =\n          `<strong>Memory Use Breakdown:</strong><br>\n           <mark style=\"background:#5A84FF; color:#0f1624; padding:0 6px; border-radius:4px;\">Input memory blocks (n): ${inputSize}</mark><br>\n           <mark style=\"background:#FF6E91; color:#0f1624; padding:0 6px; border-radius:4px;\">Auxiliary memory blocks: ${auxSize}</mark><br>\n           <mark style=\"background:#748094; color:#0f1624; padding:0 6px; border-radius:4px;\">Unused memory blocks: ${totalCells - (inputSize + auxSize)}</mark><br><br>\n           <strong>Total Space Complexity:</strong> O(n) (Input + Auxiliary space)\n           <br><br>Press <strong>Reset</strong> to clear visualization.`;\n        fillBtn.setAttribute('aria-pressed', 'true');\n        resetBtn.disabled = false;\n      }, (inputSize + auxSize) * 40 + 600));\n    }\n\n    function clearAnimationTimeouts() {\n      animationTimeouts.forEach(t => clearTimeout(t));\n      animationTimeouts = [];\n    }\n\n    function resetGrid() {\n      clearAnimationTimeouts();\n      const cells = Array.from(spaceGrid.children);\n      cells.forEach(c => {\n        c.classList.remove('used', 'animate-fill');\n        c.style.background = '';\n      });\n      infoBar.textContent = 'Click Show Example Space Usage to see how memory is consumed based on given input and auxiliary space.';\n      fillBtn.setAttribute('aria-pressed', 'false');\n      resetBtn.disabled = true;\n    }\n\n    fillBtn.addEventListener('click', () => {\n      fillBtn.disabled = true;\n      animateFillBlocks();\n      // Re-enable button after animation + 2 seconds\n      setTimeout(() => {\n        fillBtn.disabled = false;\n      }, 3000);\n    });\n\n    resetBtn.addEventListener('click', () => {\n      resetGrid();\n    });\n\n    // Initial reset just to ensure clean start\n    resetGrid();\n  })();\n</script>\n\n</body>\n</html>"
