    "content": "<html>\n<head>\n    <title>Interactive Unit Testing Playground</title>\n    <script>\n        // Application state\n        let testResults = {\n            passed: 0,\n            failed: 0,\n            total: 0,\n            testCases: []\n        };\n\n        let currentTestSuite = {\n            name: '',\n            description: '',\n            tests: []\n        };\n\n        let testHistory = [];\n        let assertionLibrary = 'assert';\n        // Test functions\n        function addTest() {\n            const testName = document.getElementById('testName').value;\n            const testCode = document.getElementById('testCode').value;\n            \n            if (testName && testCode) {\n                currentTestSuite.tests.push({\n                    name: testName,\n                    code: testCode,\n                    status: 'not run'\n                });\n                updateTestList();\n                document.getElementById('testName').value = '';\n                document.getElementById('testCode').value = '';\n            }\n        }\n\n        function runTests() {\n            testResults = {\n                passed: 0,\n                failed: 0,\n                total: currentTestSuite.tests.length,\n                testCases: []\n            };\n\n            currentTestSuite.tests.forEach((test, index) => {\n                try {\n                    // This is a simplified evaluation - in real world you'd want better sandboxing\n                    const testFunc = new Function('assert', test.code);\n                    const customAssert = createAssertionLibrary();\n                    testFunc(customAssert);\n                    \n                    testResults.passed++;\n                    test.status = 'passed';\n                    testResults.testCases.push({\n                        name: test.name,\n                        status: 'passed',\n                        message: 'Test passed'\n                    });\n                } catch (e) {\n                    testResults.failed++;\n                    test.status = 'failed';\n                    testResults.testCases.push({\n                        name: test.name,\n                        status: 'failed',\n                        message: e.message\n                    });\n                }\n            });\n\n            testHistory.push({\n                suite: currentTestSuite.name,\n                timestamp: new Date(),\n                results: {...testResults}\n            });\n\n            updateResults();\n            updateHistory();\n            updateTestList();\n        }\n\n        function createAssertionLibrary() {\n            return {\n                equal: (actual, expected, message) => {\n                    if (actual != expected) {\n                        throw new Error(message || `Expected ${expected} but got ${actual}`);\n                    }\n                },\n                strictEqual: (actual, expected, message) => {\n                    if (actual !== expected) {\n                        throw new Error(message || `Expected ${expected} but got ${actual}`);\n                    }\n                },\n                truthy: (value, message) => {\n                    if (!value) {\n                        throw new Error(message || `Expected truthy value but got ${value}`);\n                    }\n                },\n                throws: (fn, errorType, message) => {\n                    try {\n                        fn();\n                        throw new Error(message || 'Expected function to throw but it did not');\n                    } catch (e) {\n                        if (errorType && !(e instanceof errorType)) {\n                            throw new Error(message || `Expected error of type ${errorType.name} but got ${e.constructor.name}`);\n                        }\n                    }\n                }\n            };\n        }\n\n        function updateTestList() {\n            const testList = document.getElementById('testList');\n            testList.innerHTML = '';\n            \n            currentTestSuite.tests.forEach((test, index) => {\n                const li = document.createElement('li');\n                li.textContent = `${test.name} - ${test.status}`;\n                li.style.color = test.status === 'passed' ? 'green' : \n                                 test.status === 'failed' ? 'red' : 'black';\n                \n                const deleteBtn = document.createElement('button');\n                deleteBtn.textContent = 'Delete';\n                deleteBtn.onclick = () => {\n                    currentTestSuite.tests.splice(index, 1);\n                    updateTestList();\n                };\n                \n                li.appendChild(deleteBtn);\n                testList.appendChild(li);\n            });\n        }\n\n        function updateResults() {\n            document.getElementById('passedCount').textContent = testResults.passed;\n            document.getElementById('failedCount').textContent = testResults.failed;\n            document.getElementById('totalCount').textContent = testResults.total;\n            \n            const resultsList = document.getElementById('resultsList');\n            resultsList.innerHTML = '';\n            \n            testResults.testCases.forEach(result => {\n                const li = document.createElement('li');\n                li.textContent = `${result.name}: ${result.status} - ${result.message}`;\n                li.style.color = result.status === 'passed' ? 'green' : 'red';\n                resultsList.appendChild(li);\n            });\n        }\n\n        function updateHistory() {\n            const historyList = document.getElementById('historyList');\n            historyList.innerHTML = '';\n            \n            testHistory.forEach((run, index) => {\n                const li = document.createElement('li');\n                li.textContent = `${run.suite} - ${run.timestamp.toLocaleTimeString()}: ${run.results.passed}/${run.results.total} passed`;\n                li.onclick = () => {\n                    document.getElementById('historyDetails').textContent = \n                        `Suite: ${run.suite}\\n` +\n                        `Time: ${run.timestamp.toLocaleString()}\\n` +\n                        `Passed: ${run.results.passed}\\n` +\n                        `Failed: ${run.results.failed}\\n` +\n                        `Total: ${run.results.total}`;\n                };\n                historyList.appendChild(li);\n            });\n        }\n\n        function createNewSuite() {\n            const suiteName = document.getElementById('suiteName').value;\n            const suiteDesc = document.getElementById('suiteDescription').value;\n            \n            if (suiteName) {\n                currentTestSuite = {\n                    name: suiteName,\n                    description: suiteDesc,\n                    tests: []\n                };\n                document.getElementById('currentSuite').textContent = suiteName;\n                document.getElementById('suiteName').value = '';\n                document.getElementById('suiteDescription').value = '';\n                updateTestList();\n            }\n        }\n\n        function changeAssertionLibrary() {\n            assertionLibrary = document.getElementById('assertionLibrary').value;\n        }\n\n        function showSection(sectionId) {\n            document.querySelectorAll('.section').forEach(section => {\n                section.style.display = 'none';\n            });\n            document.getElementById(sectionId).style.display = 'block';\n        }\n\n        function loadExample() {\n            const example = document.getElementById('exampleSelect').value;\n            if (example === 'math') {\n                currentTestSuite.tests = [\n                    {\n                        name: 'Addition test',\n                        code: 'assert.equal(2 + 2, 4, \"2+2 should be 4\");',\n                        status: 'not run'\n                    },\n                    {\n                        name: 'Multiplication test',\n                        code: 'assert.equal(3 * 3, 9, \"3*3 should be 9\");',\n                        status: 'not run'\n                    },\n                    {\n                        name: 'Division test',\n                        code: 'assert.throws(() => { const x = 1/0; }, Error, \"Division by zero should throw\");',\n                        status: 'not run'\n                    }\n                ];\n            } else if (example === 'string') {\n                currentTestSuite.tests = [\n                    {\n                        name: 'String length',\n                        code: 'assert.equal(\"hello\".length, 5, \"hello should have length 5\");',\n                        status: 'not run'\n                    },\n                    {\n                        name: 'String concatenation',\n                        code: 'assert.equal(\"a\" + \"b\", \"ab\", \"a + b should be ab\");',\n                        status: 'not run'\n                    }\n                ];\n            }\n            updateTestList();\n        }\n    </script>\n</head>\n<body>\n    <h1>Unit Testing Playground</h1>\n    \n    <div>\n        <button onclick=\"showSection('suiteSection')\">Test Suite</button>\n        <button onclick=\"showSection('testSection')\">Add Tests</button>\n        <button onclick=\"showSection('runSection')\">Run Tests</button>\n        <button onclick=\"showSection('historySection')\">History</button>\n        <button onclick=\"showSection('examplesSection')\">Examples</button>\n    </div>\n    \n    <div id=\"suiteSection\" class=\"section\" style=\"display: block;\">\n        <h2>Test Suite Configuration</h2>\n        <div>\n            <label>Suite Name:</label>\n            <input type=\"text\" id=\"suiteName\">\n        </div>\n        <div>\n            <label>Description:</label>\n            <textarea id=\"suiteDescription\"></textarea>\n        </div>\n        <button onclick=\"createNewSuite()\">Create New Suite</button>\n        <div>\n            <p>Current Suite: <span id=\"currentSuite\">None</span></p>\n        </div>\n    </div>\n    \n    <div id=\"testSection\" class=\"section\" style=\"display: none;\">\n        <h2>Add Tests</h2>\n        <div>\n            <label>Test Name:</label>\n            <input type=\"text\" id=\"testName\">\n        </div>\n        <div>\n            <label>Test Code:</label>\n            <textarea id=\"testCode\" rows=\"4\" cols=\"50\"></textarea>\n        </div>\n        <button onclick=\"addTest()\">Add Test</button>\n        \n        <h3>Current Tests</h3>\n        <ul id=\"testList\"></ul>\n    </div>\n    \n    <div id=\"runSection\" class=\"section\" style=\"display: none;\">\n        <h2>Run Tests</h2>\n        <div>\n            <label>Assertion Library:</label>\n            <select id=\"assertionLibrary\" onchange=\"changeAssertionLibrary()\">\n                <option value=\"assert\">Basic Assertions</option>\n                <option value=\"chai\">Chai-style</option>\n                <option value=\"jasmine\">Jasmine-style</option>\n            </select>\n        </div>\n        <button onclick=\"runTests()\">Run All Tests</button>\n        \n        <h3>Results</h3>\n        <p>Passed: <span id=\"passedCount\">0</span> | \n           Failed: <span id=\"failedCount\">0</span> | \n           Total: <span id=\"totalCount\">0</span></p>\n        \n        <ul id=\"resultsList\"></ul>\n    </div>\n    \n    <div id=\"historySection\" class=\"section\" style=\"display: none;\">\n        <h2>Test History</h2>\n        <ul id=\"historyList\"></ul>\n        <div id=\"historyDetails\" style=\"white-space: pre-line; border: 1px solid #ccc; padding: 10px; margin-top: 10px;\"></div>\n    </div>\n    \n    <div id=\"examplesSection\" class=\"section\" style=\"display: none;\">\n        <h2>Load Examples</h2>\n        <select id=\"exampleSelect\">\n            <option value=\"math\">Math Operations</option>\n            <option value=\"string\">String Operations</option>\n        </select>\n        <button onclick=\"loadExample()\">Load Example</button>\n    </div>\n</body>\n</html>"
