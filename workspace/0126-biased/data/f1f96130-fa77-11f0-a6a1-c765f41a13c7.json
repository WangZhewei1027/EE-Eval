    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Decision Trees — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #081325;\n      --glass: rgba(255,255,255,0.06);\n      --accent1: #7ce3d4;\n      --accent2: #7b8cff;\n      --muted: rgba(255,255,255,0.65);\n      --soft: rgba(255,255,255,0.04);\n      --card: rgba(255,255,255,0.03);\n      --glass-border: rgba(255,255,255,0.06);\n      --shadow: 0 10px 30px rgba(3,7,18,0.6);\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(123,140,255,0.12), transparent 8%),\n                  radial-gradient(900px 500px at 90% 90%, rgba(124,227,212,0.06), transparent 6%),\n                  linear-gradient(180deg,var(--bg1),var(--bg2));\n      color: #e9f0ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Stage */\n    .stage{\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap:32px;\n      align-items:start;\n      padding:48px;\n      height:100vh;\n      box-sizing:border-box;\n    }\n\n    /* Header / controls */\n    .panel-left{\n      max-width:900px;\n    }\n    header.title{\n      display:flex;\n      align-items:flex-start;\n      gap:20px;\n      margin-bottom:18px;\n    }\n    .logo{\n      width:64px;\n      height:64px;\n      border-radius:12px;\n      background: linear-gradient(135deg,var(--accent2),var(--accent1));\n      box-shadow: 0 8px 32px rgba(123,140,255,0.18), inset 0 -6px 18px rgba(0,0,0,0.12);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:800;\n      font-family: \"Playfair Display\", serif;\n      color:rgba(5,6,11,0.98);\n      transform:skewX(-6deg);\n    }\n    .title-block{\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n    }\n    h1{\n      margin:0;\n      font-family:\"Playfair Display\", serif;\n      font-weight:600;\n      letter-spacing:-0.02em;\n      font-size:28px;\n      color: #fbfdff;\n    }\n    p.lede{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    /* Controls */\n    .controls{\n      margin-top:18px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      border:0;\n      padding:12px 18px;\n      font-size:14px;\n      border-radius:12px;\n      cursor:pointer;\n      background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      color:var(--muted);\n      box-shadow: var(--shadow);\n      transition: all 280ms cubic-bezier(.2,.9,.3,1);\n      backdrop-filter: blur(6px) saturate(120%);\n      border:1px solid rgba(255,255,255,0.04);\n    }\n    .btn:active{ transform:translateY(1px) scale(0.998); }\n    .btn.primary{\n      background: linear-gradient(135deg,var(--accent1),var(--accent2));\n      color:#061226;\n      font-weight:600;\n      box-shadow: 0 12px 40px rgba(124,227,212,0.08), inset 0 -3px 8px rgba(255,255,255,0.06);\n      border: 1px solid rgba(255,255,255,0.08);\n    }\n    .btn.ghost{\n      background:transparent;\n      border:1px dashed rgba(255,255,255,0.04);\n      color:var(--muted);\n      font-weight:600;\n    }\n\n    /* Stage canvas */\n    .canvas{\n      margin-top:18px;\n      height:72vh;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n      overflow:visible;\n      pointer-events:none; /* visual-only */\n    }\n\n    /* Glass right panel */\n    .info{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:16px;\n      padding:22px;\n      box-shadow: var(--shadow);\n      border:1px solid var(--glass-border);\n      backdrop-filter: blur(8px) saturate(120%);\n      height:fit-content;\n    }\n    .info h3{\n      margin:0;\n      font-size:16px;\n      color:#fff;\n      font-weight:700;\n      font-family:\"Playfair Display\", serif;\n    }\n    .info p{\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.45;\n      margin-top:10px;\n    }\n    .meta{\n      margin-top:16px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .chip{\n      background:var(--card);\n      border-radius:10px;\n      padding:8px 10px;\n      display:flex;\n      gap:10px;\n      align-items:center;\n      color:var(--muted);\n      font-size:13px;\n      border:1px solid rgba(255,255,255,0.02);\n    }\n\n    /* Decorative floating orbs */\n    .orb{\n      position:absolute;\n      border-radius:50%;\n      filter:blur(40px) saturate(130%);\n      opacity:0.18;\n      pointer-events:none;\n    }\n    .orb.one{\n      width:420px;\n      height:420px;\n      background: radial-gradient(circle at 30% 20%, rgba(123,140,255,0.9), rgba(123,140,255,0.12) 20%, transparent 50%);\n      left:-80px;\n      top:-140px;\n      transform:rotate(12deg);\n      mix-blend-mode:screen;\n    }\n    .orb.two{\n      width:320px;\n      height:320px;\n      background: radial-gradient(circle at 70% 80%, rgba(124,227,212,0.9), rgba(124,227,212,0.06) 18%, transparent 40%);\n      right:-120px;\n      bottom:-60px;\n      transform:rotate(-12deg);\n      mix-blend-mode:screen;\n    }\n\n    /* SVG tree styles */\n    .tree-wrap{\n      width:100%;\n      max-width:980px;\n      height:680px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      pointer-events:none;\n    }\n    svg{\n      width:100%;\n      height:100%;\n      overflow:visible;\n      filter: drop-shadow(0 30px 60px rgba(2,6,23,0.5));\n    }\n\n    /* Edges */\n    .edge{\n      fill:none;\n      stroke: url(#grad-edge);\n      stroke-width:3.5;\n      stroke-linecap:round;\n      opacity:0.95;\n      stroke-dasharray: 1200;\n      stroke-dashoffset: 1200;\n      transition: stroke-dashoffset 1s cubic-bezier(.2,.9,.3,1);\n    }\n    .played .edge{\n      stroke-dashoffset: 0;\n    }\n\n    /* Nodes */\n    .node{\n      transform-origin:center;\n      transition: transform 650ms cubic-bezier(.2,.9,.3,1), opacity 380ms ease;\n      transform: scale(0);\n      opacity:0;\n      pointer-events:auto;\n    }\n    .played .node{\n      transform: scale(1);\n      opacity:1;\n    }\n\n    /* Node visuals */\n    .node .halo{\n      fill: url(#grad-halo);\n      opacity:0.9;\n      filter: blur(8px);\n    }\n    .node .core{\n      fill: linear-gradient(180deg, #fff, #eee);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1;\n      box-shadow: 0 10px 30px rgba(4,8,18,0.6);\n    }\n    .core-circle{\n      fill: url(#grad-core);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1;\n    }\n\n    /* Node card for internal decision nodes */\n    .card{\n      fill: url(#card-gradient);\n      stroke: rgba(255,255,255,0.03);\n      filter: drop-shadow(0 6px 20px rgba(2,8,24,0.6));\n      rx:12;\n      ry:12;\n    }\n    .card-text{\n      font-size:12px;\n      fill:#eaf6f0;\n      font-weight:600;\n    }\n    .small{\n      font-size:11px;\n      fill:rgba(255,255,255,0.7);\n      font-weight:500;\n    }\n\n    /* Leaf panels */\n    .leaf{\n      transform-origin:center;\n      transition: transform 650ms cubic-bezier(.2,.9,.3,1), opacity 400ms ease;\n      transform: translateY(18px) scale(0.96);\n      opacity:0;\n    }\n    .played .leaf{\n      transform: translateY(0) scale(1);\n      opacity:1;\n    }\n    .leaf .leaf-body{\n      fill: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      stroke: rgba(255,255,255,0.03);\n      rx:10;\n      ry:10;\n    }\n\n    /* labels (toggle) */\n    .label{\n      opacity:0;\n      transform: translateY(-6px);\n      transition: opacity 420ms ease, transform 420ms ease;\n      pointer-events:none;\n    }\n    .labels-visible .label{\n      opacity:1;\n      transform: translateY(0);\n    }\n\n    /* micro charts inside leaves */\n    .bar{\n      fill: url(#bar-grad);\n      rx:3;\n      ry:3;\n      opacity:0.95;\n    }\n\n    /* subtle hover (visual only) */\n    svg .node-group:hover .card,\n    svg .node-group:hover .core-circle,\n    svg .node-group:hover .leaf-body{\n      transform: translateY(-6px);\n      transition: transform 240ms ease;\n    }\n\n    /* Footer note */\n    .note{\n      margin-top:14px;\n      color:var(--muted);\n      font-size:12px;\n    }\n\n    /* Responsive */\n    @media (max-width:980px){\n      .stage{ grid-template-columns: 1fr; padding:24px; gap:18px; }\n      .tree-wrap{ height:580px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\" role=\"main\">\n    <div class=\"panel-left\">\n      <header class=\"title\" aria-hidden=\"false\">\n        <div class=\"logo\">DT</div>\n        <div class=\"title-block\">\n          <h1>Decision Trees</h1>\n          <p class=\"lede\">A visual introduction to how decision trees split data, route decisions, and produce predictions — rendered as a living diagram.</p>\n        </div>\n      </header>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"animateBtn\" class=\"btn primary\" aria-label=\"Animate growth\">Animate Growth</button>\n        <button id=\"labelsBtn\" class=\"btn ghost\" aria-pressed=\"false\" aria-label=\"Toggle labels\">Toggle Labels</button>\n        <div style=\"flex:1\"></div>\n      </div>\n\n      <div class=\"canvas\" aria-hidden=\"true\">\n        <div class=\"orb one\"></div>\n        <div class=\"tree-wrap\" id=\"stage\">\n          <!-- SVG decision tree -->\n          <svg viewBox=\"0 0 1100 760\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Decision tree diagram\">\n            <defs>\n              <linearGradient id=\"grad-edge\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7ce3d4\"/>\n                <stop offset=\"1\" stop-color=\"#7b8cff\"/>\n              </linearGradient>\n\n              <radialGradient id=\"grad-halo\" cx=\"50%\" cy=\"30%\">\n                <stop offset=\"0%\" stop-color=\"#7b8cff\" stop-opacity=\"0.8\"/>\n                <stop offset=\"100%\" stop-color=\"#7ce3d4\" stop-opacity=\"0.05\"/>\n              </radialGradient>\n\n              <linearGradient id=\"grad-core\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#fff\" stop-opacity=\"0.96\"/>\n                <stop offset=\"1\" stop-color=\"#eaf6f0\" stop-opacity=\"0.95\"/>\n              </linearGradient>\n\n              <linearGradient id=\"card-gradient\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"rgba(255,255,255,0.03)\"/>\n                <stop offset=\"1\" stop-color=\"rgba(255,255,255,0.01)\"/>\n              </linearGradient>\n\n              <linearGradient id=\"bar-grad\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7ce3d4\"/>\n                <stop offset=\"1\" stop-color=\"#7b8cff\"/>\n              </linearGradient>\n\n              <filter id=\"soft-blur\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"6\" />\n              </filter>\n            </defs>\n\n            <!-- Edges: root to left and right -->\n            <g class=\"edges\">\n              <path class=\"edge\" d=\"M550 120 C430 220, 310 300, 260 420\" />\n              <path class=\"edge\" d=\"M550 120 C670 220, 810 300, 840 420\" />\n              <path class=\"edge\" d=\"M260 460 C290 520, 320 600, 360 680\" />\n              <path class=\"edge\" d=\"M260 460 C200 520, 140 600, 120 680\" />\n              <path class=\"edge\" d=\"M840 460 C820 520, 760 600, 700 680\" />\n              <path class=\"edge\" d=\"M840 460 C900 520, 960 600, 1000 680\" />\n              <!-- small thin connectors -->\n              <path class=\"edge\" d=\"M430 280 C460 300, 500 330, 550 360\" style=\"stroke-width:1.2; opacity:0.5; stroke:rgba(255,255,255,0.06)\"/>\n            </g>\n\n            <!-- Root node -->\n            <g class=\"node-group\" transform=\"translate(550,120)\">\n              <g class=\"node\" id=\"node-root\" transform=\"scale(1)\">\n                <circle class=\"halo\" cx=\"0\" cy=\"0\" r=\"46\" />\n                <circle class=\"core-circle\" cx=\"0\" cy=\"0\" r=\"28\" />\n                <rect x=\"-88\" y=\"42\" width=\"176\" height=\"54\" class=\"card\" rx=\"12\" />\n                <text x=\"0\" y=\"66\" text-anchor=\"middle\" class=\"card-text\">Feature: Petal length</text>\n                <text x=\"0\" y=\"82\" text-anchor=\"middle\" class=\"small\">Is petal_length ≤ 2.45?</text>\n\n                <g class=\"label\" transform=\"translate(-170,-30)\">\n                  <rect x=\"0\" y=\"0\" width=\"140\" height=\"46\" rx=\"8\" fill=\"rgba(6,10,20,0.6)\" stroke=\"rgba(255,255,255,0.02)\"/>\n                  <text x=\"10\" y=\"22\" fill=\"#dff7f0\" font-size=\"12\" font-weight=\"600\">Root split</text>\n                  <text x=\"10\" y=\"36\" fill=\"rgba(255,255,255,0.6)\" font-size=\"11\">Most informative feature</text>\n                </g>\n              </g>\n            </g>\n\n            <!-- Left internal node -->\n            <g class=\"node-group\" transform=\"translate(260,420)\">\n              <g class=\"node\" id=\"node-left\">\n                <circle class=\"halo\" cx=\"0\" cy=\"-6\" r=\"36\" />\n                <circle class=\"core-circle\" cx=\"0\" cy=\"-6\" r=\"20\" />\n                <rect x=\"-84\" y=\"18\" width=\"168\" height=\"48\" class=\"card\" rx=\"10\" />\n                <text x=\"0\" y=\"44\" text-anchor=\"middle\" class=\"card-text\">Feature: Sepal width</text>\n                <text x=\"0\" y=\"58\" text-anchor=\"middle\" class=\"small\">≤ 3.0 ?</text>\n\n                <g class=\"label\" transform=\"translate(-170,-8)\">\n                  <rect x=\"0\" y=\"0\" width=\"140\" height=\"46\" rx=\"8\" fill=\"rgba(6,10,20,0.6)\" stroke=\"rgba(255,255,255,0.02)\"/>\n                  <text x=\"10\" y=\"22\" fill=\"#dff7f0\" font-size=\"12\" font-weight=\"600\">Decision node</text>\n                  <text x=\"10\" y=\"36\" fill=\"rgba(255,255,255,0.6)\" font-size=\"11\">Further splits data</text>\n                </g>\n              </g>\n            </g>\n\n            <!-- Right internal node -->\n            <g class=\"node-group\" transform=\"translate(840,420)\">\n              <g class=\"node\" id=\"node-right\">\n                <circle class=\"halo\" cx=\"0\" cy=\"-6\" r=\"36\" />\n                <circle class=\"core-circle\" cx=\"0\" cy=\"-6\" r=\"20\" />\n                <rect x=\"-84\" y=\"18\" width=\"168\" height=\"48\" class=\"card\" rx=\"10\" />\n                <text x=\"0\" y=\"44\" text-anchor=\"middle\" class=\"card-text\">Feature: Petal width</text>\n                <text x=\"0\" y=\"58\" text-anchor=\"middle\" class=\"small\">≤ 1.75 ?</text>\n\n                <g class=\"label\" transform=\"translate(30,-8)\">\n                  <rect x=\"0\" y=\"0\" width=\"140\" height=\"46\" rx=\"8\" fill=\"rgba(6,10,20,0.6)\" stroke=\"rgba(255,255,255,0.02)\"/>\n                  <text x=\"10\" y=\"22\" fill=\"#dff7f0\" font-size=\"12\" font-weight=\"600\">Decision node</text>\n                  <text x=\"10\" y=\"36\" fill=\"rgba(255,255,255,0.6)\" font-size=\"11\">Refines branches</text>\n                </g>\n              </g>\n            </g>\n\n            <!-- Left-left leaf -->\n            <g class=\"node-group\" transform=\"translate(120,680)\">\n              <g class=\"leaf\" id=\"leaf-ll\">\n                <rect x=\"-92\" y=\"-28\" width=\"184\" height=\"64\" class=\"leaf-body\" rx=\"10\" />\n                <text x=\"0\" y=\"-2\" text-anchor=\"middle\" class=\"card-text\">Class: Setosa</text>\n                <text x=\"0\" y=\"14\" text-anchor=\"middle\" class=\"small\">Confidence: 98%</text>\n                <!-- micro bar -->\n                <rect x=\"-60\" y=\"20\" width=\"120\" height=\"8\" class=\"bar\" rx=\"4\" />\n                <g class=\"label\" transform=\"translate(-170,-30)\">\n                  <rect x=\"0\" y=\"0\" width=\"140\" height=\"46\" rx=\"8\" fill=\"rgba(6,10,20,0.6)\" stroke=\"rgba(255,255,255,0.02)\"/>\n                  <text x=\"10\" y=\"22\" fill=\"#dff7f0\" font-size=\"12\" font-weight=\"600\">Leaf node</text>\n                  <text x=\"10\" y=\"36\" fill=\"rgba(255,255,255,0.6)\" font-size=\"11\">Final prediction</text>\n                </g>\n              </g>\n            </g>\n\n            <!-- Left-right leaf -->\n            <g class=\"node-group\" transform=\"translate(360,680)\">\n              <g class=\"leaf\" id=\"leaf-lr\">\n                <rect x=\"-92\" y=\"-28\" width=\"184\" height=\"64\" class=\"leaf-body\" rx=\"10\" />\n                <text x=\"0\" y=\"-2\" text-anchor=\"middle\" class=\"card-text\">Class: Versicolor</text>\n                <text x=\"0\" y=\"14\" text-anchor=\"middle\" class=\"small\">Confidence: 72%</text>\n                <!-- micro bar -->\n                <rect x=\"-60\" y=\"20\" width=\"86\" height=\"8\" class=\"bar\" rx=\"4\" />\n              </g>\n            </g>\n\n            <!-- Right-left leaf -->\n            <g class=\"node-group\" transform=\"translate(700,680)\">\n              <g class=\"leaf\" id=\"leaf-rl\">\n                <rect x=\"-92\" y=\"-28\" width=\"184\" height=\"64\" class=\"leaf-body\" rx=\"10\" />\n                <text x=\"0\" y=\"-2\" text-anchor=\"middle\" class=\"card-text\">Class: Versicolor</text>\n                <text x=\"0\" y=\"14\" text-anchor=\"middle\" class=\"small\">Confidence: 55%</text>\n                <rect x=\"-60\" y=\"20\" width=\"66\" height=\"8\" class=\"bar\" rx=\"4\" />\n              </g>\n            </g>\n\n            <!-- Right-right leaf -->\n            <g class=\"node-group\" transform=\"translate(1000,680)\">\n              <g class=\"leaf\" id=\"leaf-rr\">\n                <rect x=\"-92\" y=\"-28\" width=\"184\" height=\"64\" class=\"leaf-body\" rx=\"10\" />\n                <text x=\"0\" y=\"-2\" text-anchor=\"middle\" class=\"card-text\">Class: Virginica</text>\n                <text x=\"0\" y=\"14\" text-anchor=\"middle\" class=\"small\">Confidence: 88%</text>\n                <rect x=\"-60\" y=\"20\" width=\"106\" height=\"8\" class=\"bar\" rx=\"4\" />\n              </g>\n            </g>\n\n            <!-- tiny legend -->\n            <g transform=\"translate(36,688)\">\n              <rect x=\"0\" y=\"-44\" width=\"220\" height=\"46\" rx=\"10\" fill=\"rgba(3,6,18,0.45)\" stroke=\"rgba(255,255,255,0.02)\"/>\n              <text x=\"12\" y=\"-20\" fill=\"#cfeff0\" font-size=\"12\" font-weight=\"700\">Flow</text>\n              <text x=\"12\" y=\"-6\" fill=\"rgba(255,255,255,0.6)\" font-size=\"11\">Paths show splits & routing of examples</text>\n            </g>\n          </svg>\n        </div>\n        <div class=\"orb two\"></div>\n      </div>\n\n      <div class=\"note\" style=\"margin-top:14px;\">\n        Tip: Click \"Animate Growth\" to watch the tree unfurl. \"Toggle Labels\" will reveal concise annotations.\n      </div>\n    </div>\n\n    <aside class=\"info\" aria-label=\"Information\">\n      <h3>How Decision Trees Work</h3>\n      <p>Decision trees split data by asking simple feature-based questions at internal nodes, routing instances left or right until they reach a leaf node that assigns a prediction. They are intuitive, easy to visualize, and form the basis for more complex ensembles.</p>\n\n      <div class=\"meta\">\n        <div class=\"chip\">\n          <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"#7b8cff\"/></svg>\n          Explainable\n        </div>\n        <div class=\"chip\">\n          <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"3\" fill=\"#7ce3d4\"/></svg>\n          Fast inference\n        </div>\n      </div>\n\n      <p style=\"margin-top:14px; color:var(--muted); font-size:13px\">This visual focuses on aesthetics and clarity: watch the structure grow from the root through internal decision nodes to final leaf predictions. Labels can be toggled for additional context.</p>\n    </aside>\n  </div>\n\n  <script>\n    (function(){\n      const stage = document.getElementById('stage');\n      const animateBtn = document.getElementById('animateBtn');\n      const labelsBtn = document.getElementById('labelsBtn');\n      const body = document.body;\n\n      // Elements we animate\n      const container = document.querySelector('.stage');\n      const playedClass = 'played';\n      const labelsClass = 'labels-visible';\n\n      // Initialize: add small stagger delays to nodes/leaf elements via style\n      const nodeGroups = Array.from(document.querySelectorAll('.node-group'));\n      nodeGroups.forEach((g, i) => {\n        // compute delay based on vertical position for nicer effect\n        const bbox = g.getAttribute('transform') || '';\n        let y = 0;\n        const m = /translate\\([^\\d.-]*([-\\d.]+),\\s*([-\\d.]+)\\)/.exec(g.getAttribute('transform'));\n        if(m){ y = parseFloat(m[2]); }\n        // delay maps smaller y (top) to smaller delay\n        const delay = Math.max(0, (y / 900) * 1.2); // up to ~1.2s\n        // also vary slightly by index\n        const adj = (i % 3) * 0.08;\n        g.style.transitionDelay = (delay + adj) + 's';\n        // for edges we set dashoffset transition delay via style\n      });\n\n      // Make edges animate slightly after nodes\n      const edges = document.querySelectorAll('.edge');\n      edges.forEach((e, idx) => {\n        e.style.transitionDelay = (0.35 + idx * 0.09) + 's';\n      });\n\n      // Play animation: toggles 'played' class with reflow to restart\n      function play() {\n        // remove if exists\n        container.classList.remove(playedClass);\n        // force reflow\n        void container.offsetWidth;\n        // then add\n        container.classList.add(playedClass);\n      }\n\n      // initial auto-play with a gentle delay\n      setTimeout(()=> {\n        play();\n      }, 480);\n\n      animateBtn.addEventListener('click', () => {\n        play();\n        // micro feedback\n        animateBtn.animate([\n          { transform: 'translateY(0) scale(1)' },\n          { transform: 'translateY(-3px) scale(1.02)' },\n          { transform: 'translateY(0) scale(1)' }\n        ], { duration: 360, easing: 'cubic-bezier(.2,.9,.3,1)' });\n      });\n\n      // Labels toggle\n      let labelsOn = false;\n      labelsBtn.addEventListener('click', () => {\n        labelsOn = !labelsOn;\n        if(labelsOn){\n          container.classList.add(labelsClass);\n          labelsBtn.setAttribute('aria-pressed','true');\n          labelsBtn.textContent = 'Hide Labels';\n        } else {\n          container.classList.remove(labelsClass);\n          labelsBtn.setAttribute('aria-pressed','false');\n          labelsBtn.textContent = 'Toggle Labels';\n        }\n        // soft button highlight\n        labelsBtn.animate([\n          { opacity: 0.86 },\n          { opacity: 1 }\n        ], { duration: 260, easing: 'ease-out' });\n      });\n\n      // Accessibility: keyboard triggers for buttons\n      animateBtn.addEventListener('keyup', (e)=>{ if(e.key === 'Enter' || e.key === ' ') animateBtn.click(); });\n      labelsBtn.addEventListener('keyup', (e)=>{ if(e.key === 'Enter' || e.key === ' ') labelsBtn.click(); });\n\n      // Decorative slight motion for orbs\n      const orb1 = document.querySelector('.orb.one');\n      const orb2 = document.querySelector('.orb.two'