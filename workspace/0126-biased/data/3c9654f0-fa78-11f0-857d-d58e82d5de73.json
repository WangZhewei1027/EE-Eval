    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Red-Black Tree Visualization — Elegant Demo</title>\n<style>\n  /* === Reset and base === */\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0; background: #121418; color: #E6E8EA;\n    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\n    overflow-x: hidden;\n    user-select: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n  h1 {\n    font-weight: 700; font-size: 2.8rem; color: #F5F7FA;\n    letter-spacing: 1.1px; margin-bottom: .2em;\n    text-align: center;\n  }\n  h2 {\n    font-weight: 600; font-size: 1.4rem; color: #8AA1B1;\n    text-align: center;\n    margin-top: 0;\n    margin-bottom: 1.5em;\n    font-style: italic;\n  }\n  /* Container */\n  #app {\n    max-width: 960px;\n    margin: 2rem auto 3rem;\n    padding: 0 20px 64px;\n    display: flex; flex-direction: column; align-items: center;\n  }\n  /* Control buttons container */\n  #controls {\n    margin-bottom: 2em;\n    display: flex; gap: 1.5rem;\n  }\n  button {\n    background: linear-gradient(145deg, #2A2F38, #262B33);\n    border: none; border-radius: 12px;\n    padding: 0.75em 1.6em;\n    font-weight: 600;\n    font-size: 1rem;\n    color: #A3B1C2;\n    letter-spacing: 0.03em;\n    cursor: pointer;\n    box-shadow:\n       inset 3px 3px 6px #1E2229,\n       inset -3px -3px 6px #343C4A,\n       4px 4px 7px rgba(20,23,30,0.4);\n    transition:\n      color 0.3s ease,\n      box-shadow 0.4s ease,\n      background 0.5s ease;\n    user-select: none;\n  }\n  button:hover, button:focus {\n    color: #DDE6EA;\n    box-shadow:\n       inset 2px 2px 5px #3F4558,\n       inset -2px -2px 5px #222831,\n       6px 6px 13px rgba(30,40,60,0.7);\n    background: linear-gradient(145deg, #343A48, #2B303C);\n    outline: none;\n  }\n  button:active {\n    box-shadow:\n       inset 1px 1px 3px #20252C,\n       inset -1px -1px 3px #3D4453;\n    background: linear-gradient(145deg, #292F39, #232832);\n    color: #C1D0E0;\n  }\n\n  /* === SVG Tree Container === */\n  #tree-container {\n    width: 100%;\n    max-width: 960px;\n    aspect-ratio: 16 / 9;\n    position: relative;\n    filter:\n      drop-shadow(0 0 4px #FF3C3C88)\n      drop-shadow(0 0 7px #ED5858BB)\n      drop-shadow(0 0 18px #FC6262AA);\n  }\n\n  svg {\n    display: block;\n    width: 100%; height: 100%;\n  }\n\n  /* Lines between nodes */\n  .link {\n    stroke: #7A869B55;\n    stroke-width: 2;\n    stroke-linecap: round;\n    transition: stroke 0.5s ease;\n  }\n  .link:hover {\n    stroke: #FC6262EE;\n    stroke-width: 3.5;\n  }\n\n  /* Node style */\n  .node {\n    cursor: default;\n    filter:\n      drop-shadow(0 0 2px rgba(0,0,0,0.25));\n    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  .node:hover {\n    transform: scale(1.1);\n  }\n  /* Circle base */\n  .node circle {\n    transition:\n      fill 0.6s ease,\n      stroke 0.4s ease;\n    stroke-width: 3.5;\n    stroke: #1A2133;\n    filter:\n      drop-shadow(0 5px 8px rgba(0,0,0,0.22));\n  }\n\n  /* Red node fill */\n  .node.red circle {\n    fill: #FF4545;\n    stroke: #991B1B;\n    filter:\n      drop-shadow(0 0 12px #FF555580);\n  }\n  /* Black node fill */\n  .node.black circle {\n    fill: #1A2133;\n    stroke: #666F86;\n    filter:\n      drop-shadow(0 0 7px #3A4B9B50);\n  }\n\n  /* Node text */\n  .node text {\n    fill: #E6E8EA;\n    font-weight: 700;\n    font-size: 1.3rem;\n    pointer-events: none;\n    user-select: none;\n    font-feature-settings: \"tnum\";\n    text-shadow:\n      0 0 4px #0009;\n  }\n\n  /* Highlight node on insertion step */\n  .highlight circle {\n    stroke: #FCEC3D !important;\n    stroke-width: 5 !important;\n    filter:\n      drop-shadow(0 0 16px #FCEC3DCC);\n  }\n  /* Subtitle below node value */\n  .node .subtitle {\n    font-weight: 400;\n    font-size: 0.7rem;\n    fill: #8899B2AA;\n    font-style: italic;\n    user-select:none;\n    pointer-events:none;\n    text-anchor: middle;\n    dominant-baseline: hanging;\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    font-size: 0.8rem;\n    color: #556677;\n    margin-top: 6rem;\n  }\n  footer a {\n    color: #8899B2;\n    text-decoration: none;\n    transition: color 0.3s ease;\n  }\n  footer a:hover {\n    color: #FC6262;\n  }\n\n</style>\n</head>\n<body>\n  <div id=\"app\" aria-label=\"Red-Black Tree Visualization\">\n    <h1>Red-Black Tree</h1>\n    <h2>Balanced Binary Search Tree — Visualized Elegantly</h2>\n    <div id=\"controls\" role=\"group\" aria-label=\"Simple controls\">\n      <button id=\"btnReset\" aria-label=\"Reset tree\">Reset</button>\n      <button id=\"btnStep\" aria-label=\"Next insertion step\">Next Step</button>\n    </div>\n    <div id=\"tree-container\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <svg id=\"tree-svg\" viewBox=\"0 0 960 540\" role=\"img\" aria-describedby=\"desc-tree\" aria-label=\"Red-Black Tree graph\"></svg>\n    </div>\n  </div>\n\n  <footer>\n    &copy; 2024 — Aesthetic Data Structures Demo\n  </footer>\n\n<script>\n(() => {\n  /*\n  Red-Black Tree Visualization Demo\n  Limited interactivity: Reset & Step insertion\n  */\n\n  // === Data Structures ===\n\n  // We'll visualize insertion of a fixed sequence of keys into an initially empty tree,\n  // showing each step. The tree will re-balance as per Red-Black tree rules.\n\n  // Red-Black tree node class\n  class RBNode {\n    constructor(key, color='red', left=null, right=null, parent=null) {\n      this.key = key;\n      this.color = color; // 'red' or 'black'\n      this.left = left;\n      this.right = right;\n      this.parent = parent;\n    }\n  }\n\n  // Red-Black Tree class, only insertion implemented here\n  class RedBlackTree {\n    constructor() {\n      this.NIL = new RBNode(null, 'black'); // Sentinel NIL node\n      this.root = this.NIL;\n    }\n\n    leftRotate(x) {\n      let y = x.right;\n      x.right = y.left;\n      if (y.left !== this.NIL) y.left.parent = x;\n      y.parent = x.parent;\n      if (x.parent === null) this.root = y;\n      else if (x === x.parent.left) x.parent.left = y;\n      else x.parent.right = y;\n      y.left = x;\n      x.parent = y;\n    }\n\n    rightRotate(y) {\n      let x = y.left;\n      y.left = x.right;\n      if (x.right !== this.NIL) x.right.parent = y;\n      x.parent = y.parent;\n      if (y.parent === null) this.root = x;\n      else if (y === y.parent.right) y.parent.right = x;\n      else y.parent.left = x;\n      x.right = y;\n      y.parent = x;\n    }\n\n    insert(key) {\n      let newNode = new RBNode(key);\n      newNode.left = this.NIL;\n      newNode.right = this.NIL;\n\n      let y = null;\n      let x = this.root;\n\n      while (x !== this.NIL) {\n        y = x;\n        if (newNode.key < x.key) x = x.left;\n        else x = x.right;\n      }\n      newNode.parent = y;\n      if (y === null) this.root = newNode;\n      else if (newNode.key < y.key) y.left = newNode;\n      else y.right = newNode;\n\n      newNode.color = 'red';\n\n      this.insertFixup(newNode);\n      return newNode;\n    }\n\n    insertFixup(z) {\n      while (z.parent && z.parent.color === 'red') {\n        if (z.parent === z.parent.parent.left) {\n          let y = z.parent.parent.right;\n          if (y.color === 'red') {\n            z.parent.color = 'black';\n            y.color = 'black';\n            z.parent.parent.color = 'red';\n            z = z.parent.parent;\n          } else {\n            if (z === z.parent.right) {\n              z = z.parent;\n              this.leftRotate(z);\n            }\n            z.parent.color = 'black';\n            z.parent.parent.color = 'red';\n            this.rightRotate(z.parent.parent);\n          }\n        } else {\n          let y = z.parent.parent.left;\n          if (y.color === 'red') {\n            z.parent.color = 'black';\n            y.color = 'black';\n            z.parent.parent.color = 'red';\n            z = z.parent.parent;\n          } else {\n            if (z === z.parent.left) {\n              z = z.parent;\n              this.rightRotate(z);\n            }\n            z.parent.color = 'black';\n            z.parent.parent.color = 'red';\n            this.leftRotate(z.parent.parent);\n          }\n        }\n      }\n      this.root.color = 'black';\n    }\n\n    // Helper for visualization: returns array of nodes in tree with positions\n    // We'll compute x,y positions for each node for the SVG layout.\n    computePositions() {\n      const positions = [];\n      const nodePositions = new Map();\n\n      let maxDepth = 0;\n\n      // step 1: BFS to assign depth and gather nodes per depth level\n      let levels = [];\n      function dfs(node, depth = 0) {\n        if (node === null || node.key === null) return;\n        if (!levels[depth]) levels[depth] = [];\n        levels[depth].push(node);\n        if(depth > maxDepth) maxDepth = depth;\n        dfs(node.left, depth+1);\n        dfs(node.right, depth+1);\n      }\n      dfs(this.root);\n\n      // horizontal spacing constants\n      const svgWidth = 960;\n      const svgHeight = 540;\n      const marginX = 80;\n      const marginY = 40;\n\n      // For each level, assign x positions spread evenly\n      for (let d = 0; d <= maxDepth; d++) {\n        const levelNodes = levels[d] || [];\n        const count = levelNodes.length;\n        for (let i = 0; i < count; i++) {\n          const node = levelNodes[i];\n          // x spread equally within marginX..svgWidth-marginX\n          const x = marginX + i * ((svgWidth - 2*marginX)/ (count ? count : 1));\n          // y in steps by depth\n          const y = marginY + d * ((svgHeight - 2 * marginY)/ (maxDepth ? maxDepth : 1));\n          nodePositions.set(node, {x, y});\n        }\n      }\n\n      // Step 2: Return node-positions map and also parent-child connections for lines\n      const links = [];\n      for (let d = 0; d <= maxDepth; d++) {\n        (levels[d] || []).forEach(node => {\n          if(node.left && node.left.key !== null)\n            links.push([node, node.left]);\n          if(node.right && node.right.key !== null)\n            links.push([node, node.right]);\n        });\n      }\n\n      return { nodePositions, links };\n    }\n  }\n\n\n  // === Visualization ===\n\n  const svg = document.getElementById('tree-svg');\n  const btnReset = document.getElementById('btnReset');\n  const btnStep = document.getElementById('btnStep');\n\n  // Insertion sequence fixed (balanced-ish)\n  const insertionSequence = [11, 2, 14, 1, 7, 15, 5, 8, 4];\n\n  let tree = null;\n  let currentStep = 0;\n  let highlightNode = null;\n\n  // Clear SVG children utility\n  function clearSVG() {\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  // Create SVG element helper\n  function createSVGElement(tag, attrs = {}) {\n    const ns = \"http://www.w3.org/2000/svg\";\n    const el = document.createElementNS(ns, tag);\n    Object.entries(attrs).forEach(([k,v]) => {\n      if (v != null) el.setAttribute(k,v);\n    });\n    return el;\n  }\n\n  // Render the current tree state\n  function renderTree(tree, highlightNode=null) {\n    clearSVG();\n\n    if (tree.root === tree.NIL) {\n      // empty tree message\n      const emptyText = createSVGElement('text', {\n        x: '50%', y: '50%',\n        fill: '#8899AA55',\n        'text-anchor': 'middle',\n        'dominant-baseline': 'middle',\n        'font-size': '2rem',\n        'font-weight': '600',\n        'font-style': 'italic',\n        'pointer-events': 'none',\n        'user-select': 'none'\n      });\n      emptyText.textContent = 'Tree is empty';\n      svg.appendChild(emptyText);\n      return;\n    }\n\n    // compute positions\n    const { nodePositions, links } = tree.computePositions();\n\n    // Draw edges (links) - curved smooth lines\n    links.forEach(([p,c]) => {\n      const pPos = nodePositions.get(p);\n      const cPos = nodePositions.get(c);\n\n      // Draw a nice smooth cubic Bezier curve\n      // control points horizontally between parent and child\n      const dx = Math.abs(cPos.x - pPos.x);\n      // create path d attribute\n      const d = `\n        M${pPos.x} ${pPos.y + 27}\n        C${pPos.x} ${pPos.y + 27 + dx*0.45},\n         ${cPos.x} ${cPos.y - 27 - dx*0.45},\n         ${cPos.x} ${cPos.y - 27}\n      `;\n\n      const link = createSVGElement('path', {\n        d: d.trim(),\n        class: 'link',\n        'aria-hidden': 'true',\n        fill: 'none'\n      });\n      svg.appendChild(link);\n    });\n\n    // Draw nodes\n    // Sorting nodes by depth (y) descending so circles with higher y (lower nodes) appear below parent nodes for neat shadows\n    const nodesToDraw = Array.from(nodePositions.entries()).sort((a,b) => a[1].y - b[1].y);\n\n    nodesToDraw.forEach(([node, pos]) => {\n      const group = createSVGElement('g', {class: 'node ' + node.color});\n      group.setAttribute('transform', `translate(${pos.x},${pos.y})`);\n\n      if (node === highlightNode) {\n        group.classList.add('highlight');\n      }\n\n      // Circle\n      const circle = createSVGElement('circle', {\n        r: 27,\n        role: 'img',\n        'aria-label': `${node.key}, ${node.color} node`\n      });\n      group.appendChild(circle);\n\n      // Node key text\n      const text = createSVGElement('text', {\n        'text-anchor': 'middle',\n        'dominant-baseline': 'central',\n        role: 'presentation',\n        'pointer-events': 'none',\n      });\n      text.textContent = node.key;\n      group.appendChild(text);\n\n      svg.appendChild(group);\n    });\n  }\n\n  // === Step logic ===\n\n  // We'll reveal the tree step by step, each step inserting next node\n\n  function resetTree() {\n    tree = new RedBlackTree();\n    currentStep = 0;\n    highlightNode = null;\n    renderTree(tree);\n  }\n\n  function nextStep() {\n    if (currentStep >= insertionSequence.length) {\n      highlightNode = null;\n      btnStep.disabled = true;\n      return;\n    }\n    const key = insertionSequence[currentStep];\n    const insertedNode = tree.insert(key);\n    highlightNode = insertedNode;\n    renderTree(tree, highlightNode);\n    currentStep++;\n\n    if (currentStep >= insertionSequence.length) {\n      btnStep.disabled = true;\n      highlightNode = null;\n    }\n  }\n\n  // === Initialization ===\n\n  // On load\n  resetTree();\n\n  btnReset.addEventListener('click', () => {\n    btnStep.disabled = false;\n    resetTree();\n  });\n\n  btnStep.addEventListener('click', () => {\n    nextStep();\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
