    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Dynamic Array — Visual Demo</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071029;\n    --glass: rgba(255,255,255,0.06);\n    --accent: linear-gradient(135deg,#7b7be6 0%,#4bd1c6 100%);\n    --accent-2: linear-gradient(135deg,#ff7eb6 0%, #7b61ff 100%);\n    --muted: rgba(255,255,255,0.15);\n    --slot-empty: rgba(255,255,255,0.04);\n    --slot-border: rgba(255,255,255,0.06);\n    --glass-2: rgba(255,255,255,0.03);\n    --glass-3: rgba(255,255,255,0.02);\n    color-scheme: dark;\n  }\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(600px 400px at 10% 10%, rgba(123,123,230,0.12), transparent 8%),\n                radial-gradient(400px 300px at 90% 90%, rgba(75,209,198,0.06), transparent 8%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2));\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Subtle floating particles */\n  .scene {\n    position:relative;\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:60px 28px;\n    overflow:hidden;\n  }\n  .particles{\n    pointer-events:none;\n    position:absolute;\n    inset:0;\n    overflow:hidden;\n    z-index:0;\n  }\n  .particle{\n    position:absolute;\n    width:12px;\n    height:12px;\n    border-radius:50%;\n    background:linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));\n    filter:blur(6px);\n    opacity:0.8;\n    transform:translate3d(0,0,0);\n    animation: drift 16s linear infinite;\n  }\n  @keyframes drift{\n    0%{ transform:translateY(0) translateX(0) scale(1); opacity:0.9; }\n    50%{ transform:translateY(-60vh) translateX(20vw) scale(0.8); opacity:0.5;}\n    100%{ transform:translateY(-120vh) translateX(-10vw) scale(1.2); opacity:0.0;}\n  }\n\n  /* Main card */\n  .card {\n    position:relative;\n    z-index:2;\n    width:1100px;\n    max-width:100%;\n    min-height:560px;\n    border-radius:18px;\n    padding:34px;\n    box-sizing:border-box;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    display:flex;\n    gap:28px;\n    align-items:stretch;\n    overflow:hidden;\n  }\n\n  /* Left: title */\n  .panel-left{\n    width:320px;\n    min-width:260px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n  }\n  .logo{\n    display:flex;\n    align-items:center;\n    gap:14px;\n  }\n  .sig {\n    width:68px;\n    height:68px;\n    border-radius:14px;\n    background:linear-gradient(135deg,#7b7be6 0%, #4bd1c6 100%);\n    box-shadow: 0 8px 30px rgba(75,209,198,0.14), 0 1px 0 rgba(255,255,255,0.06) inset;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:white;\n    font-weight:800;\n    font-family:\"Playfair Display\", serif;\n    font-size:22px;\n    transform:rotate(-8deg);\n  }\n  .title{\n    color:whitesmoke;\n  }\n  .title h1{\n    margin:0;\n    font-size:20px;\n    letter-spacing:-0.4px;\n    font-weight:700;\n    font-family:\"Playfair Display\", serif;\n  }\n  .title p{\n    margin:0;\n    margin-top:6px;\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.2;\n  }\n\n  /* Stats card */\n  .stats {\n    margin-top:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:14px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n  }\n  .stat-row {\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n  }\n  .stat {\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .stat .big {\n    color:white;\n    font-weight:700;\n    font-size:18px;\n  }\n  .stat .small {\n    color:var(--muted);\n    font-size:12px;\n  }\n\n  /* Buttons */\n  .controls {\n    margin-top:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn {\n    border:0;\n    padding:12px 18px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:12px;\n    color:whitesmoke;\n    cursor:pointer;\n    font-weight:600;\n    transition: all 220ms cubic-bezier(.2,.9,.2,1);\n    box-shadow: 0 6px 20px rgba(2,6,23,0.45);\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    font-size:14px;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .btn:active{ transform:translateY(1px) scale(0.999); }\n  .btn.primary {\n    background: var(--accent);\n    background-size:200% 200%;\n    box-shadow: 0 10px 30px rgba(123,123,230,0.16), 0 2px 0 rgba(255,255,255,0.03) inset;\n    color:white;\n  }\n  .btn.ghost {\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.06);\n    color:var(--muted);\n  }\n  .btn[disabled] { opacity:0.5; cursor:default; }\n\n  /* Right: visualization */\n  .viz {\n    flex:1;\n    padding:22px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.025);\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .viz-top {\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n\n  .legend {\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .chip {\n    padding:8px 12px;\n    border-radius:10px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    font-size:13px;\n    color:var(--muted);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  .display-area {\n    margin-top:8px;\n    flex:1;\n    display:flex;\n    gap:18px;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Buffers */\n  .buffer-wrap{\n    position:relative;\n    width:100%;\n    max-width:820px;\n    min-height:240px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    perspective:1000px;\n  }\n  .buffer {\n    width:88%;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border-radius:14px;\n    padding:18px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 12px 30px rgba(2,6,23,0.5);\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:center;\n    transform-style:preserve-3d;\n  }\n\n  .slots {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:center;\n    flex-wrap:wrap;\n  }\n  .slot {\n    width:86px;\n    height:68px;\n    border-radius:12px;\n    background:var(--slot-empty);\n    border:1px dashed var(--slot-border);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    font-weight:700;\n    letter-spacing:0.6px;\n    font-size:15px;\n    transition: all 420ms cubic-bezier(.2,.9,.2,1);\n    position:relative;\n    overflow:visible;\n  }\n  .slot .index {\n    position:absolute;\n    top:8px;\n    right:10px;\n    font-size:11px;\n    color:rgba(255,255,255,0.35);\n  }\n\n  .slot.filled {\n    background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 6px 22px rgba(4,10,30,0.5);\n    color:whitesmoke;\n    transform:translateY(-6px);\n  }\n  .cell {\n    width:70px;\n    height:50px;\n    border-radius:10px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    font-size:18px;\n    letter-spacing:0.6px;\n    text-shadow: 0 2px 12px rgba(0,0,0,0.6);\n  }\n\n  .cell.val {\n    background: linear-gradient(135deg,#7b7be6 0%, #4bd1c6 100%);\n    box-shadow: 0 10px 20px rgba(75,209,198,0.12);\n    color:white;\n  }\n  .empty .cell {\n    background:transparent;\n    color:var(--muted);\n    font-weight:600;\n    font-size:13px;\n  }\n\n  /* overlay for moving clones */\n  .stage {\n    pointer-events:none;\n    position:absolute;\n    inset:0;\n    z-index:5;\n  }\n\n  /* operation log */\n  .log {\n    margin-top:6px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .message {\n    flex:1;\n    padding:12px 14px;\n    border-radius:12px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    font-size:13px;\n  }\n  .badge {\n    padding:10px 12px;\n    border-radius:10px;\n    background:linear-gradient(90deg, rgba(123,123,230,0.13), rgba(75,209,198,0.06));\n    color:white;\n    font-weight:700;\n    font-size:13px;\n    box-shadow: 0 8px 20px rgba(75,209,198,0.06);\n  }\n\n  /* subtle labels */\n  .caption {\n    color: rgba(255,255,255,0.22);\n    font-size:12px;\n  }\n\n  /* Resize animation helpers */\n  .ghost-slot {\n    position:absolute;\n    width:86px;\n    height:68px;\n    border-radius:12px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    color:white;\n    z-index:60;\n    transform-origin:center;\n    transition: transform 600ms cubic-bezier(.2,.9,.2,1), opacity 300ms;\n  }\n\n  /* responsive */\n  @media (max-width:920px){\n    .card {\n      flex-direction:column;\n      padding:20px;\n    }\n    .panel-left{ width:100%; order:2;}\n    .viz{ order:1; }\n    .buffer{ width:100%; }\n    .buffer-wrap{ min-height:220px; }\n  }\n</style>\n</head>\n<body>\n<div class=\"scene\" aria-hidden=\"false\">\n  <div class=\"particles\" id=\"particles\"></div>\n\n  <div class=\"card\" role=\"region\" aria-label=\"Dynamic Array Visualization\">\n    <div class=\"panel-left\">\n      <div class=\"logo\">\n        <div class=\"sig\">DA</div>\n        <div class=\"title\">\n          <h1>Dynamic Array</h1>\n          <p>Elegant visualization of capacity, size, and resize operations.</p>\n        </div>\n      </div>\n\n      <div class=\"stats\" aria-hidden=\"true\">\n        <div class=\"stat-row\">\n          <div class=\"stat\">\n            <div class=\"small caption\">Size</div>\n            <div class=\"big\" id=\"sizeDisplay\">0</div>\n          </div>\n          <div class=\"stat\">\n            <div class=\"small caption\">Capacity</div>\n            <div class=\"big\" id=\"capDisplay\">4</div>\n          </div>\n        </div>\n        <div style=\"height:10px\"></div>\n        <div class=\"stat-row\">\n          <div class=\"stat\">\n            <div class=\"small caption\">Next value</div>\n            <div class=\"big\" id=\"nextDisplay\">1</div>\n          </div>\n          <div style=\"flex:1\"></div>\n        </div>\n      </div>\n\n      <div style=\"height:8px\"></div>\n\n      <div class=\"controls\" role=\"group\" aria-label=\"controls\">\n        <button id=\"addBtn\" class=\"btn primary\" title=\"Append a new element to the dynamic array\">\n          <!-- svg plus -->\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"filter:drop-shadow(0 2px 6px rgba(0,0,0,0.35))\">\n            <path d=\"M12 5v14M5 12h14\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n          Add Element\n        </button>\n        <button id=\"resetBtn\" class=\"btn ghost\" title=\"Reset to initial empty array\">\n          Reset\n        </button>\n      </div>\n\n      <div style=\"height:18px\"></div>\n\n      <div class=\"caption\">Note: Click \"Add Element\" to append. Watch capacity double when full — the copying is animated for clarity.</div>\n    </div>\n\n    <div class=\"viz\">\n      <div class=\"viz-top\">\n        <div class=\"legend\">\n          <div class=\"chip\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"margin-right:6px\">\n              <rect x=\"3\" y=\"6\" width=\"18\" height=\"12\" rx=\"3\" fill=\"url(#g1)\"></rect>\n              <defs>\n                <linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7b7be6\"/><stop offset=\"1\" stop-color=\"#4bd1c6\"/></linearGradient>\n              </defs>\n            </svg>\n            Filled slot\n          </div>\n          <div class=\"chip\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"margin-right:6px\">\n              <rect x=\"3\" y=\"6\" width=\"18\" height=\"12\" rx=\"3\" fill=\"none\" stroke=\"rgba(255,255,255,0.06)\"></rect>\n            </svg>\n            Empty slot\n          </div>\n        </div>\n        <div style=\"display:flex; gap:12px; align-items:center;\">\n          <div class=\"badge\" id=\"opBadge\">Idle</div>\n        </div>\n      </div>\n\n      <div class=\"display-area\">\n        <div class=\"buffer-wrap\" aria-hidden=\"false\">\n          <div class=\"buffer\" id=\"bufferRoot\" aria-live=\"polite\" aria-atomic=\"true\">\n            <div class=\"slots\" id=\"slots\"></div>\n          </div>\n          <div class=\"stage\" id=\"stage\"></div>\n        </div>\n      </div>\n\n      <div class=\"log\">\n        <div class=\"message\" id=\"message\">Welcome — observe how dynamic arrays manage capacity. Start by adding elements.</div>\n        <div class=\"badge caption\" id=\"hint\">Doubling strategy</div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n/*\n  Dynamic Array Visual Demo\n  - Minimal interactivity: Add Element, Reset\n  - Animations for simple append and resize (doubling)\n*/\n\nconst config = {\n  initialCapacity: 4,\n  slotWidth: 86,\n  slotHeight: 68,\n  spacing: 12\n};\n\nlet state = {\n  capacity: config.initialCapacity,\n  size: 0,\n  nextValue: 1,\n  values: []\n};\n\nconst slotsEl = document.getElementById('slots');\nconst sizeDisplay = document.getElementById('sizeDisplay');\nconst capDisplay = document.getElementById('capDisplay');\nconst nextDisplay = document.getElementById('nextDisplay');\nconst message = document.getElementById('message');\nconst opBadge = document.getElementById('opBadge');\nconst addBtn = document.getElementById('addBtn');\nconst resetBtn = document.getElementById('resetBtn');\nconst stage = document.getElementById('stage');\n\nlet busy = false;\n\nfunction createSlot(index, val=null){\n  const slot = document.createElement('div');\n  slot.className = 'slot' + (val!==null ? ' filled' : ' empty');\n  slot.dataset.index = index;\n  const idx = document.createElement('div');\n  idx.className = 'index';\n  idx.textContent = index;\n  const cell = document.createElement('div');\n  cell.className = 'cell ' + (val !== null ? 'val' : 'empty');\n  cell.textContent = val !== null ? val : '';\n  slot.appendChild(idx);\n  slot.appendChild(cell);\n  return slot;\n}\n\nfunction renderSlots(){\n  slotsEl.innerHTML = '';\n  for(let i=0;i<state.capacity;i++){\n    const val = (i < state.size) ? state.values[i] : null;\n    const slot = createSlot(i, val);\n    slotsEl.appendChild(slot);\n  }\n  sizeDisplay.textContent = state.size;\n  capDisplay.textContent = state.capacity;\n  nextDisplay.textContent = state.nextValue;\n}\n\nfunction setMessage(text){\n  message.textContent = text;\n}\n\nfunction setBadge(text){\n  opBadge.textContent = text;\n}\n\n/* Utility: compute absolute position of slot element for animation */\nfunction getSlotRect(index){\n  const slot = slotsEl.querySelector(`.slot[data-index='${index}']`);\n  return slot.getBoundingClientRect();\n}\n\n/* Create a floating ghost element to animate from -> to */\nfunction makeGhost(value, rect){\n  const g = document.createElement('div');\n  g.className = 'ghost-slot';\n  g.style.left = rect.left + 'px';\n  g.style.top = rect.top + 'px';\n  g.style.width = rect.width + 'px';\n  g.style.height = rect.height + 'px';\n  g.style.display = 'flex';\n  g.style.alignItems = 'center';\n  g.style.justifyContent = 'center';\n  g.style.borderRadius = '12px';\n  g.style.background = 'linear-gradient(135deg,#7b7be6 0%, #4bd1c6 100%)';\n  g.style.boxShadow = '0 18px 40px rgba(75,209,198,0.12)';\n  g.style.color = 'white';\n  g.style.fontWeight = 800;\n  g.style.fontSize = '18px';\n  g.style.zIndex = 1000;\n  g.style.position = 'fixed';\n  g.textContent = value;\n  document.body.appendChild(g);\n  return g;\n}\n\n/* Disable controls while animating */\nfunction setBusy(flag){\n  busy = flag;\n  addBtn.disabled = flag;\n  resetBtn.disabled = flag;\n  addBtn.style.pointerEvents = flag ? 'none' : '';\n  resetBtn.style.pointerEvents = flag ? 'none' : '';\n}\n\n/* Append without resizing: animate element fly-in to target slot */\nasync function animateAppend(value){\n  setBusy(true);\n  setBadge('Appending');\n  setMessage(`Appending value ${value}...`);\n  // Create a floating element near Add button\n  const addRect = addBtn.getBoundingClientRect();\n  const targetRect = getSlotRect(state.size);\n  const ghost = makeGhost(value, {\n    left: addRect.left + (addRect.width/2 - config.slotWidth/2),\n    top: addRect.top - 40,\n    width: config.slotWidth,\n    height: config.slotHeight\n  });\n  await animateTo(ghost, targetRect, 520);\n  ghost.style.transition = 'transform 160ms ease, opacity 160ms ease';\n  ghost.style.opacity = '0';\n  await delay(180);\n  ghost.remove();\n  // commit\n  state.values.push(value);\n  state.size++;\n  renderSlots();\n  setMessage(`Value ${value} appended. Size is now ${state.size}.`);\n  setBadge('Idle');\n  setBusy(false);\n}\n\n/* Animate copying all elements to new buffer (doubling) */\nasync function animateResize(newCapacity){\n  setBusy(true);\n  setBadge('Resizing');\n  setMessage(`Capacity reached. Resizing buffer to ${newCapacity} (doubling).`);\n  // Create a visual target: duplicate buffer area to the right\n  const bufferRect = slotsEl.getBoundingClientRect();\n  const canvas = document.createElement('div');\n  canvas.style.position = 'fixed';\n  canvas.style.left = bufferRect.left + 'px';\n  canvas.style.top = bufferRect.top + 'px';\n  canvas.style.width = bufferRect.width + 'px';\n  canvas.style.height = bufferRect.height + 'px';\n  canvas.style.pointerEvents = 'none';\n  canvas.style.zIndex = 900;\n  document.body.appendChild(canvas);\n\n  // Create an offscreen new buffer representation to the right\n  const newCanvas = document.createElement('div');\n  newCanvas.style.position = 'fixed';\n  newCanvas.style.left = (bufferRect.right + 30) + 'px';\n  newCanvas.style.top = bufferRect.top + 'px';\n  newCanvas.style.width = bufferRect.width + 'px';\n  newCanvas.style.height = bufferRect.height + 'px';\n  newCanvas.style.pointerEvents = 'none';\n  newCanvas.style.zIndex = 890;\n  document.body.appendChild(newCanvas);\n\n  // Draw placeholder slots in new buffer (empty)\n  const newSlots = [];\n  for(let i=0;i<newCapacity;i++){\n    const s = document.createElement('div');\n    s.style.width = config.slotWidth + 'px';\n    s.style.height = config.slotHeight + 'px';\n    s.style.borderRadius = '12px';\n    s.style.display = 'inline-flex';\n    s.style.alignItems = 'center';\n    s.style.justifyContent = 'center';\n    s.style.marginRight = config.spacing + 'px';\n    s.style.background = 'rgba(255,255,255,0.02)';\n    s.style.border = '1px dashed rgba(255,255,255,0.06)';\n    s.style.color = 'rgba(255,255,255,0.28)';\n    s.textContent = (i < state.size) ? '' : '';\n    newCanvas.appendChild(s);\n    newSlots.push(s);\n  }\n\n  // Fade in new buffer\n  newCanvas.style.opacity = '0';\n  newCanvas.style.transition = 'opacity 420ms ease';\n  await delay(20);\n  newCanvas.style.opacity = '1';\n  await delay(360);\n\n  // For each existing value, animate copying from old slot to new slot\n  const ghosts = [];\n  for(let i=0;i<state.size;i++){\n    const fromRect = getSlotRect(i);\n    const targetRect = {\n      left: newCanvas.getBoundingClientRect().left + i*(config.slotWidth + config.spacing),\n      top: newCanvas.getBoundingClientRect().top,\n      width: config.slotWidth,\n      height: config.slotHeight\n    };\n    const g = makeGhost(state.values[i], fromRect);\n    ghosts.push({g, targetRect});\n    await delay(90); // stagger\n  }\n\n  // Move all ghosts to new positions\n  await Promise.all(ghosts.map((o, idx) => animateTo(o.g, o.targetRect, 560 + idx*20)));\n  // Small flourish\n  await delay(180);\n\n  // remove ghosts and canvases\n  ghosts.forEach(o => o.g.remove());\n  canvas.remove();\n  newCanvas.remove();\n\n  // Commit new capacity\n  state.capacity = newCapacity;\n  // (values remain the same)\n  renderSlots();\n  setMessage(`Resize complete. New capacity: ${state.capacity}. Values copied.`);\n  setBadge('Idle');\n  setBusy(false);\n}\n\n/* Animate a DOM element (ghost) to a target rect */\nfunction animateTo(ghost, targetRect, dur=500){\n  return new Promise(resolve=>{\n    const from = ghost.getBoundingClientRect();\n    const dx = targetRect.left - from.left;\n    const dy = targetRect.top - from.top;\n    const sx = targetRect.width / from.width;\n    const sy = targetRect.height / from.height;\n    ghost.style.transition = `transform ${Math.round(dur)}ms cubic-bezier(.2,.9,.2,1), opacity 220ms linear`;\n    ghost.style.transform = `translate(${dx}px, ${dy}px) scale(${sx}, ${sy})`;\n    // Wait\n    setTimeout(()=>{\n      resolve();\n    }, dur + 40);\n  });\n}\n\nfunction delay(ms){ return new Promise(r=>setTimeout(r, ms)); }\n\nasync function handleAdd(){\n  if(busy) return;\n  const val = state.nextValue;\n  setBadge('Prepare');\n  if(state.size < state.capacity){\n    await animateAppend(val);\n  } else {\n    // need to resize: double capacity then append\n    const newCap = state.capacity * 2;\n    // animate resize (copying)\n    await animateResize(newCap);\n    // After resize, animate append\n    await animateAppend(val);\n  }\n  state.nextValue++;\n}\n\nfunction handleReset(){\n  if(busy) return;\n  state.capacity = config.initialCapacity;\n  state.size = 0;\n  state.values = [];\n  state.nextValue = 1;\n  renderSlots();\n  setMessage('Array reset. Start adding elements to see resizing.');\n  setBadge('Idle');\n}\n\n/* Particles generation for ambience */\nfunction seedParticles(){\n  const container = document.getElementById('particles');\n  for(let i=0;i<14;i++){\n    const p = document.createElement('div');\n    p.className = 'particle';\n    p.style.left = (Math.random()*100) + '%';\n    p.style.top = (Math.random()*100 + 20) + '%';\n    p.style.width = (6 + Math.random()*24) + 'px';\n    p.style.height = p.style.width;\n    p.style.opacity = (0.18 + Math.random()*0.8);\n    p.style.animationDuration = (12 + Math.random()*16) + 's';\n    p.style.animationDelay = (-Math.random()*20) + 's';\n    p.style.transform = `translate3d(0,0,0) rotate(${Math.random()*360}deg)`;\n    container.appendChild(p);\n  }\n}\n\n/* initial render */\nrenderSlots();\nseedParticles();\nsetBadge('Idle');\n\naddBtn.addEventListener('click', () => handleAdd());\nresetBtn.addEventListener('click', () => handleReset());\n\n/* Accessibility: keyboard support for Enter/Escape on buttons */\naddBtn.addEventListener('keydown', (e)=>{\n  if(e.key === 'Enter') handleAdd();\n});\nresetBtn.addEventListener('keydown', (e)=>{\n  if(e.key === 'Enter') handleReset();\n});\n\n</script>\n</body>\n</html>"
