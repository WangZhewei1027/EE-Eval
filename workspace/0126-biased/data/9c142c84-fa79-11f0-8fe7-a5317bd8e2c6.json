  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Ternary Search Interactive Explorer</title>\n<style>\n  /* Extremely minimal visual design: plain black text on white background */\n  html,body { font-family: Arial, Helvetica, sans-serif; margin: 8px; padding: 0; color: #000; background: #fff; }\n  h1,h2 { font-size: 16px; margin: 6px 0; }\n  label { display: inline-block; margin: 4px 0; }\n  input[type=\"text\"], input[type=\"number\"], textarea, select { padding: 4px; margin: 2px 0; }\n  button { margin: 4px 4px 4px 0; padding: 6px; }\n  .row { display: flex; gap: 12px; align-items: flex-start; }\n  .col { display: flex; flex-direction: column; gap: 8px; }\n  .panel { border: 1px solid #000; padding: 8px; max-height: 720px; overflow: auto; }\n  canvas { border: 1px solid #000; display: block; }\n  table { border-collapse: collapse; }\n  table td, table th { border: 1px solid #000; padding: 4px; }\n  pre { background: #fff; border: 1px solid #000; padding: 8px; white-space: pre-wrap; }\n  .small { font-size: 12px; }\n  .controls-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }\n</style>\n</head>\n<body>\n<h1>Ternary Search Explorer (Maximum Finder)</h1>\n\n<div class=\"row\">\n  <div class=\"col\" style=\"flex: 1;\">\n    <div class=\"panel\">\n      <h2>Mode and Problem Setup</h2>\n      <label>\n        Mode:\n        <select id=\"modeSelect\">\n          <option value=\"continuous\">Continuous Unimodal Function (real domain)</option>\n          <option value=\"discrete\">Discrete Array (integer indices)</option>\n        </select>\n      </label>\n      <div id=\"continuousControls\">\n        <label>Function expression in x (use Math functions):</label>\n        <input type=\"text\" id=\"funcExpr\" value=\"-(x-2)*(x-2)+5\" style=\"width:100%\">\n        <div class=\"small\">Examples: \"Math.sin(x)*x\", \"-(x-2)*(x-2)+5\", \"Math.exp(-x*x)\"</div>\n        <label>Left (L): <input type=\"number\" id=\"leftInput\" value=\"-5\" step=\"any\"></label>\n        <label>Right (R): <input type=\"number\" id=\"rightInput\" value=\"5\" step=\"any\"></label>\n        <label>Sample points for graph: <input id=\"sampleCount\" type=\"number\" value=\"400\" min=\"50\" max=\"2000\"></label>\n      </div>\n\n      <div id=\"discreteControls\" style=\"display:none;\">\n        <label>Array length: <input id=\"arrayLength\" type=\"number\" value=\"21\" min=\"3\" max=\"500\"></label>\n        <label>Unimodal generator:\n          <select id=\"arrayGen\">\n            <option value=\"singlePeak\">single peak with noise</option>\n            <option value=\"symmetricPeak\">symmetric triangular peak</option>\n            <option value=\"manual\">manual edit</option>\n          </select>\n        </label>\n        <div>\n          <button id=\"genArrayBtn\">Generate Array</button>\n          <button id=\"randomizeArrayBtn\">Randomize Values</button>\n          <button id=\"clearArrayBtn\">Clear</button>\n        </div>\n        <div id=\"arrayEditorContainer\"></div>\n      </div>\n\n      <hr>\n\n      <h2>Search Parameters</h2>\n      <label>Goal:\n        <select id=\"goalSelect\">\n          <option value=\"max\">Find maximum</option>\n          <option value=\"min\">Find minimum</option>\n        </select>\n      </label>\n      <label>Epsilon / tolerance: <input id=\"epsInput\" type=\"number\" value=\"0.001\" step=\"any\"></label>\n      <label>Max iterations: <input id=\"maxIter\" type=\"number\" value=\"200\" min=\"1\"></label>\n      <label>Auto-run speed (ms per step): <input id=\"speedInput\" type=\"number\" value=\"250\" min=\"10\"></label>\n      <label>Comparison override:\n        <select id=\"compareMode\">\n          <option value=\"auto\">Automatic compare (f(m1) ? f(m2))</option>\n          <option value=\"manual\">Manual override (choose direction)</option>\n        </select>\n      </label>\n      <div id=\"manualDecision\" style=\"display:none\">\n        <button id=\"decideLeftBtn\">Decide: m1 better (move right boundary)</button>\n        <button id=\"decideRightBtn\">Decide: m2 better (move left boundary)</button>\n      </div>\n\n      <hr>\n\n      <h2>Controls</h2>\n      <div>\n        <button id=\"initBtn\">Initialize</button>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"backBtn\">Back</button>\n        <button id=\"runBtn\">Run</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <button id=\"finishBtn\">Run to Completion</button>\n        <button id=\"resetBtn\">Reset</button>\n        <button id=\"bruteforceBtn\">Brute-force (global check)</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n        <button id=\"listSnapshotsBtn\">List Snapshots</button>\n        <button id=\"clearSnapshotsBtn\">Clear Snapshots</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label><input type=\"checkbox\" id=\"showPartitionBox\" checked> Show partitions on graph</label>\n        <label><input type=\"checkbox\" id=\"traceHistoryBox\"> Trace interval history</label>\n      </div>\n\n      <hr>\n      <h2>State & Info</h2>\n      <div id=\"stateInfo\" class=\"small\">Not initialized.</div>\n      <div id=\"bestInfo\" class=\"small\"></div>\n    </div>\n\n    <div class=\"panel\" style=\"margin-top:8px;\">\n      <h2>Snapshots / Branches</h2>\n      <div id=\"snapshotsList\"></div>\n      <div class=\"small\">Snapshots capture full algorithm state and allow branching. Click a snapshot to load or fork from it.</div>\n    </div>\n  </div>\n\n  <div class=\"col\" style=\"flex: 2;\">\n    <div class=\"panel\">\n      <h2>Visualization (Canvas)</h2>\n      <canvas id=\"plot\" width=\"800\" height=\"320\"></canvas>\n      <div class=\"small\">Canvas shows function/array and current ternary partition points. Very minimal rendering.</div>\n      <div style=\"margin-top:8px;\">\n        <label>Zoom / pan: change L and R inputs then click \"Initialize\" to update plot.</label>\n      </div>\n    </div>\n\n    <div class=\"panel\" style=\"margin-top:8px;\">\n      <h2>Execution Log</h2>\n      <pre id=\"log\"></pre>\n      <div class=\"small\">Logs show each step, comparisons, and decisions. You can edit earlier snapshots and fork alternate runs.</div>\n    </div>\n\n    <div class=\"panel\" style=\"margin-top:8px;\">\n      <h2>Explain / Manual Explore</h2>\n      <div>\n        <button id=\"explainStepBtn\">Explain Next Step</button>\n        <button id=\"explainHistoryBtn\">Explain History (all steps)</button>\n      </div>\n      <div style=\"margin-top:8px;\">\n        <textarea id=\"explainOutput\" rows=\"6\" style=\"width:100%\"></textarea>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  Ternary Search Explorer\n  - Supports continuous unimodal functions and discrete arrays\n  - Many interactive controls: step, back, run, pause, save snapshots, branch, manual decision\n  - Minimal visual design, plain black on white\n*/\n\n/* ------------------------\n   Utility Functions\n   ------------------------ */\nfunction clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }\nfunction idGen(prefix) { return prefix + '_' + Math.random().toString(36).substr(2,9); }\nfunction deepCopy(obj) { return JSON.parse(JSON.stringify(obj)); }\n\n/* ------------------------\n   Global State\n   ------------------------ */\nconst S = {\n  mode: 'continuous', // continuous | discrete\n  initialized: false,\n  running: false,\n  intervalId: null,\n  states: [], // history stack of states for stepping back\n  currentIndex: -1, // index into states\n  snapshots: {}, // id -> snapshot\n  rootStateId: null,\n  traceHistory: [],\n};\n\n/* ------------------------\n   DOM references\n   ------------------------ */\nconst modeSelect = document.getElementById('modeSelect');\nconst continuousControls = document.getElementById('continuousControls');\nconst discreteControls = document.getElementById('discreteControls');\n\nconst funcExprInput = document.getElementById('funcExpr');\nconst leftInput = document.getElementById('leftInput');\nconst rightInput = document.getElementById('rightInput');\nconst sampleCountInput = document.getElementById('sampleCount');\n\nconst arrayLengthInput = document.getElementById('arrayLength');\nconst arrayGenSelect = document.getElementById('arrayGen');\nconst genArrayBtn = document.getElementById('genArrayBtn');\nconst randomizeArrayBtn = document.getElementById('randomizeArrayBtn');\nconst clearArrayBtn = document.getElementById('clearArrayBtn');\nconst arrayEditorContainer = document.getElementById('arrayEditorContainer');\n\nconst goalSelect = document.getElementById('goalSelect');\nconst epsInput = document.getElementById('epsInput');\nconst maxIterInput = document.getElementById('maxIter');\nconst speedInput = document.getElementById('speedInput');\n\nconst compareMode = document.getElementById('compareMode');\nconst manualDecision = document.getElementById('manualDecision');\nconst decideLeftBtn = document.getElementById('decideLeftBtn');\nconst decideRightBtn = document.getElementById('decideRightBtn');\n\nconst initBtn = document.getElementById('initBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst backBtn = document.getElementById('backBtn');\nconst runBtn = document.getElementById('runBtn');\nconst pauseBtn = document.getElementById('pauseBtn');\nconst finishBtn = document.getElementById('finishBtn');\nconst resetBtn = document.getElementById('resetBtn');\nconst bruteforceBtn = document.getElementById('bruteforceBtn');\n\nconst saveSnapshotBtn = document.getElementById('saveSnapshotBtn');\nconst listSnapshotsBtn = document.getElementById('listSnapshotsBtn');\nconst clearSnapshotsBtn = document.getElementById('clearSnapshotsBtn');\nconst snapshotsList = document.getElementById('snapshotsList');\n\nconst showPartitionBox = document.getElementById('showPartitionBox');\nconst traceHistoryBox = document.getElementById('traceHistoryBox');\n\nconst stateInfo = document.getElementById('stateInfo');\nconst bestInfo = document.getElementById('bestInfo');\n\nconst plot = document.getElementById('plot');\nconst ctx = plot.getContext('2d');\n\nconst logEl = document.getElementById('log');\n\nconst explainStepBtn = document.getElementById('explainStepBtn');\nconst explainHistoryBtn = document.getElementById('explainHistoryBtn');\nconst explainOutput = document.getElementById('explainOutput');\n\nconst saveSnapshotListBtn = document.getElementById('saveSnapshotBtn'); // alias\n\n/* ------------------------\n   Algorithm State Representation\n   state = {\n     id, parent, step, mode,\n     L, R, m1, m2, f_m1, f_m2,\n     iterations, done, reason,\n     array (for discrete mode),\n     samples (for plotting),\n     history: [{L,R,m1,m2,f_m1,f_m2}] for trace\n   }\n-------------------------*/\n\nfunction defaultState() {\n  return {\n    id: idGen('state'),\n    parent: null,\n    step: 0,\n    mode: S.mode,\n    L: 0,\n    R: 1,\n    m1: null,\n    m2: null,\n    f_m1: null,\n    f_m2: null,\n    iterations: 0,\n    done: false,\n    reason: null,\n    array: null,\n    samples: null,\n    history: [],\n  };\n}\n\n/* ------------------------\n   Function parsing and evaluation\n-------------------------*/\nfunction parseFunction(expr) {\n  // return function f(x)\n  try {\n    const body = 'with(Math){return (' + expr + '); }';\n    const f = new Function('x', body);\n    // test\n    const t = f(0);\n    return f;\n  } catch (e) {\n    throw new Error('Invalid function expression: ' + e.message);\n  }\n}\n\n/* ------------------------\n   Array editor\n-------------------------*/\nfunction renderArrayEditor(arr) {\n  const len = arr.length;\n  const table = document.createElement('table');\n  const header = table.insertRow();\n  for (let i = 0; i < len; i++) {\n    const th = document.createElement('th');\n    th.textContent = i;\n    header.appendChild(th);\n  }\n  const row = table.insertRow();\n  for (let i = 0; i < len; i++) {\n    const cell = row.insertCell();\n    const inp = document.createElement('input');\n    inp.type = 'number';\n    inp.value = arr[i];\n    inp.style.width = '60px';\n    inp.addEventListener('change', ()=> {\n      arr[i] = Number(inp.value);\n      redraw();\n    });\n    cell.appendChild(inp);\n  }\n  arrayEditorContainer.innerHTML = '';\n  arrayEditorContainer.appendChild(table);\n}\n\n/* ------------------------\n   Generators for unimodal arrays\n-------------------------*/\nfunction generateUnimodalArray(type, length) {\n  const arr = new Array(length).fill(0);\n  if (type === 'singlePeak') {\n    const peak = Math.floor(Math.random()*(length-2)) + 1;\n    for (let i=0;i<length;i++) {\n      const dist = Math.abs(i - peak);\n      arr[i] = Math.max(0, 100 - dist*5 + (Math.random()*10-5));\n    }\n  } else if (type === 'symmetricPeak') {\n    const peak = Math.floor(length/2);\n    for (let i=0;i<length;i++) {\n      const dist = Math.abs(i - peak);\n      arr[i] = Math.max(0, 100 - dist*8);\n    }\n  } else {\n    for (let i=0;i<length;i++) arr[i] = 0;\n  }\n  return arr;\n}\n\n/* ------------------------\n   Initialize state\n-------------------------*/\nfunction initialize() {\n  S.mode = modeSelect.value;\n  // clear running\n  stopRun();\n\n  const st = defaultState();\n  st.mode = S.mode;\n  st.parent = null;\n  st.step = 0;\n  st.iterations = 0;\n  st.done = false;\n  st.reason = null;\n  st.history = [];\n\n  if (S.mode === 'continuous') {\n    const L = Number(leftInput.value);\n    const R = Number(rightInput.value);\n    if (!(isFinite(L) && isFinite(R) && R > L)) {\n      alert('Invalid L/R');\n      return;\n    }\n    st.L = L;\n    st.R = R;\n    st.samples = sampleFunctionForPlot();\n    st.array = null;\n  } else {\n    const len = Math.max(3, Math.floor(Number(arrayLengthInput.value) || 0));\n    // if user has edited array, reuse it\n    if (st.array && st.array.length === len) {\n      // keep\n    }\n    let arr;\n    // If array editor has existing, parse\n    const ed = arrayEditorContainer.querySelector('input[type=number]');\n    if (ed) {\n      // try to read entire table\n      const inputs = Array.from(arrayEditorContainer.querySelectorAll('input[type=number]'));\n      arr = inputs.map(i=>Number(i.value));\n    } else {\n      arr = generateUnimodalArray(arrayGenSelect.value, len);\n    }\n    st.array = arr;\n    st.L = 0;\n    st.R = arr.length - 1;\n  }\n\n  S.states = [deepCopy(st)];\n  S.currentIndex = 0;\n  S.initialized = true;\n  S.rootStateId = st.id;\n  S.traceHistory = [];\n  log('Initialized. Mode: ' + S.mode + '. Iterations reset.');\n  updateUI();\n  redraw();\n}\n\n/* ------------------------\n   Sampling for plot (continuous)\n-------------------------*/\nfunction sampleFunctionForPlot() {\n  const expr = funcExprInput.value;\n  let f;\n  try {\n    f = parseFunction(expr);\n  } catch (e) {\n    log('Function parse error: ' + e.message);\n    f = x => 0;\n  }\n  const L = Number(leftInput.value);\n  const R = Number(rightInput.value);\n  const count = Math.max(50, Math.min(2000, Number(sampleCountInput.value) || 400));\n  const samples = [];\n  for (let i=0;i<count;i++) {\n    const t = i/(count-1);\n    const x = L + t*(R-L);\n    let y;\n    try { y = Number(f(x)); if (!isFinite(y)) y = NaN; } catch(e) { y = NaN; }\n    samples.push({x,y});\n  }\n  return {samples, L, R};\n}\n\n/* ------------------------\n   Helper: current state\n-------------------------*/\nfunction currentState() {\n  if (!S.initialized || S.currentIndex < 0) return null;\n  return S.states[S.currentIndex];\n}\n\n/* ------------------------\n   Logging\n-------------------------*/\nfunction log(msg) {\n  const t = new Date().toLocaleTimeString();\n  logEl.textContent = `[${t}] ${msg}\\n` + logEl.textContent;\n}\n\n/* ------------------------\n   Step of ternary search (single iteration)\n-------------------------*/\nfunction stepOnce(autoDecision) {\n  if (!S.initialized) {\n    log('Not initialized. Click Initialize first.');\n    return;\n  }\n  const prev = deepCopy(currentState());\n  if (!prev) return;\n  if (prev.done) {\n    log('Search already completed: ' + prev.reason);\n    return;\n  }\n\n  const goal = goalSelect.value; // max | min\n  const eps = Number(epsInput.value);\n  const maxIter = Math.max(1, Number(maxIterInput.value));\n\n  // Create new state as copy\n  const st = deepCopy(prev);\n  st.parent = prev.id;\n  st.id = idGen('state');\n  st.step = prev.step + 1;\n  st.iterations = prev.iterations + 1;\n\n  // discrete vs continuous behaviors\n  if (st.mode === 'continuous') {\n    // termination\n    if (Math.abs(st.R - st.L) <= eps) {\n      st.done = true;\n      st.reason = 'Interval width <= eps';\n      pushState(st);\n      log(`Terminated: interval width ${Math.abs(st.R - st.L)} <= eps`);\n      return;\n    }\n    if (st.iterations > maxIter) {\n      st.done = true;\n      st.reason = 'Exceeded max iterations';\n      pushState(st);\n      log('Terminated: exceeded max iterations');\n      return;\n    }\n\n    // choose m1,m2\n    const len = st.R - st.L;\n    const m1 = st.L + len/3;\n    const m2 = st.R - len/3;\n    st.m1 = m1; st.m2 = m2;\n\n    // evaluate function\n    const f = (() => {\n      try { return parseFunction(funcExprInput.value); } catch(e) { log('Error parsing function: '+e.message); return x=>NaN; }\n    })();\n\n    let f_m1 = NaN, f_m2 = NaN;\n    try { f_m1 = Number(f(m1)); } catch(e) { f_m1 = NaN; }\n    try { f_m2 = Number(f(m2)); } catch(e) { f_m2 = NaN; }\n    st.f_m1 = f_m1; st.f_m2 = f_m2;\n\n    // make decision: auto or manual\n    const compare = compareMode.value;\n    let decision = null; // 'left' means discard left third? we'll define precisely below\n    // For maximum: if f(m1) < f(m2) => m1 worse => move L=m1 (keep right part)\n    if (compare === 'auto' || autoDecision) {\n      if (!isFinite(f_m1) || !isFinite(f_m2)) {\n        st.done = true; st.reason = 'Function evaluation produced non-finite values';\n        pushState(st);\n        log('Terminated due to non-finite function values at midpoints.');\n        return;\n      }\n      if (goal === 'max') {\n        if (f_m1 < f_m2) {\n          decision = 'keepRight'; // move L to m1\n        } else {\n          decision = 'keepLeft'; // move R to m2\n        }\n      } else {\n        if (f_m1 > f_m2) {\n          decision = 'keepRight';\n        } else {\n          decision = 'keepLeft';\n        }\n      }\n    } else {\n      // manual mode: we wait for user action and should not auto-proceed\n      // push this state and wait for manual button to call continueManualDecision(st, 'left'|'right')\n      pushState(st);\n      log(`Paused for manual decision. f(m1)=${f_m1}, f(m2)=${f_m2}`);\n      return;\n    }\n\n    // apply decision\n    if (decision === 'keepRight') {\n      st.L = st.m1;\n      log(`Iter ${st.iterations}: f(m1)=${f_m1} < f(m2)=${f_m2} -> move L to m1 (${st.L})`);\n    } else if (decision === 'keepLeft') {\n      st.R = st.m2;\n      log(`Iter ${st.iterations}: f(m1)=${f_m1} >= f(m2)=${f_m2} -> move R to m2 (${st.R})`);\n    }\n\n    st.history = st.history || [];\n    st.history.push({L:st.L,R:st.R,m1:st.m1,m2:st.m2,f_m1:st.f_m1,f_m2:st.f_m2});\n\n    // check termination\n    if (Math.abs(st.R - st.L) <= eps) {\n      st.done = true;\n      st.reason = 'Interval width <= eps';\n      // compute best approximate\n      const xbest = (st.L + st.R)/2;\n      const ffun = parseFunction(funcExprInput.value);\n      let ybest = NaN;\n      try { ybest = Number(ffun(xbest)); } catch(e){ ybest = NaN; }\n      log(`Converged. Approximate best x=${xbest}, f(x)=${ybest}`);\n    } else if (st.iterations >= maxIter) {\n      st.done = true;\n      st.reason = 'Exceeded max iterations';\n      log('Stopped: reached max iterations');\n    }\n\n    pushState(st);\n\n  } else {\n    // discrete array mode\n    const arr = st.array;\n    if (!Array.isArray(arr) || arr.length < 3) {\n      st.done = true;\n      st.reason = 'Array invalid or too small';\n      pushState(st);\n      log('Array invalid or too small');\n      return;\n    }\n    let L = Math.floor(st.L);\n    let R = Math.floor(st.R);\n    if (R - L < 2) {\n      st.done = true;\n      st.reason = 'Interval length < 2 (no more ternary choices)';\n      pushState(st);\n      log('Terminated: discrete interval too small');\n      return;\n    }\n    if (st.iterations > maxIter) {\n      st.done = true;\n      st.reason = 'Exceeded max iterations';\n      pushState(st);\n      log('Terminated: exceeded max iterations');\n      return;\n    }\n\n    // Compute integer m1,m2\n    const third = Math.floor((R - L) / 3);\n    const m1 = L + third;\n    const m2 = R - third;\n    st.m1 = m1; st.m2 = m2;\n    st.f_m1 = arr[m1];\n    st.f_m2 = arr[m2];\n\n    // decision\n    const compare = compareMode.value;\n    let decision = null;\n    if (compare === 'auto' || autoDecision) {\n      if (goalSelect.value === 'max') {\n        if (st.f_m1 < st.f_m2) {\n          decision = 'keepRight';\n        } else {\n          decision = 'keepLeft';\n        }\n      } else {\n        if (st.f_m1 > st.f_m2) {\n          decision = 'keepRight';\n        } else {\n          decision = 'keepLeft';\n        }\n      }\n    } else {\n      pushState(st);\n      log(`Discrete mode paused for manual decision. arr[m1]=${st.f_m1}, arr[m2]=${st.f_m2}`);\n      return;\n    }\n\n    if (decision === 'keepRight') {\n      st.L = st.m1;\n      log(`Iter ${st.iterations} (discrete): arr[m1]=${st.f_m1} < arr[m2]=${st.f_m2} -> move L to m1 (${st.L})`);\n    } else {\n      st.R = st.m2;\n      log(`Iter ${st.iterations} (discrete): arr[m1]=${st.f_m1} >= arr[m2]=${st.f_m2} -> move R to m2 (${st.R})`);\n    }\n\n    st.history = st.history || [];\n    st.history.push({L:st.L,R:st.R,m1:st.m1,m2:st.m2,f_m1:st.f_m1,f_m2:st.f_m2});\n\n    // termination after narrowing if small interval\n    if (st.R - st.L <= 2) {\n      // check brute in final range\n      let bestIdx = st.L;\n      let bestVal = st.array[st.L];\n      for (let i = st.L+1;i<=st.R;i++) {\n        const v = st.array[i];\n        if (goalSelect.value==='max') {\n          if (v > bestVal) { bestVal = v; bestIdx = i; }\n        } else {\n          if (v < bestVal) { bestVal = v; bestIdx = i; }\n        }\n      }\n      st.done = true;\n      st.reason = 'Final brute force over small discrete interval';\n      log(`Discrete final brute force: best index ${bestIdx}, value ${bestVal}`);\n    } else if (st.iterations >= maxIter) {\n      st.done = true;\n      st.reason = 'Exceeded max iterations';\n      log('Terminated: exceeded max iterations for discrete');\n    }\n\n    pushState(st);\n  }\n}\n\n/* ------------------------\n   State stack operations\n-------------------------*/\nfunction pushState(st) {\n  // If we've stepped back and then create a new branch, trim forward states\n  if (S.currentIndex < S.states.length - 1) {\n    S.states = S.states.slice(0, S.currentIndex + 1);\n  }\n  S.states.push(deepCopy(st));\n  S.currentIndex = S.states.length - 1;\n  updateUI();\n  redraw();\n}\n\nfunction stepBack() {\n  if (!S.initialized) { log('Not initialized'); return; }\n  if (S.currentIndex > 0) {\n    S.currentIndex--;\n    updateUI();\n    redraw();\n    log('Stepped back to index ' + S.currentIndex);\n  } else {\n    log('Already at initial state');\n  }\n}\n\n/* ------------------------\n   Run / Pause\n-------------------------*/\nfunction runAuto() {\n  if (!S.initialized) { log('Initialize first'); return; }\n  if (S.running) return;\n  S.running = true;\n  const speed = Math.max(10, Number(speedInput.value) || 250);\n  S.intervalId = setInterval(()=> {\n    const st = currentState();\n    if (!st) { stopRun(); return; }\n    if (st.done) { stopRun(); log('Run stopped: algorithm completed'); return; }\n    // If compare mode is manual and we are paused for a decision, stop the run\n    if (compareMode.value === 'manual') {\n      // if last state has m1/m2 but no decision applied, detect and pause:\n      const hasPending = (st.m1 !== null && st.m2 !== null && st.f_m1 !== null && st.f_m2 !== null && !st.done && st.iterations === S.states[S.currentIndex].iterations);\n      // In practice, we just do one automatic step per loop if manual mode: so pause\n      stopRun();\n      log('Run paused due to manual compare mode. Use manual decision buttons.');\n      return;\n    }\n    stepOnce(true);\n  }, speed);\n}\n\nfunction stopRun() {\n  if (S.intervalId) {\n    clearInterval(S.intervalId); S.intervalId = null;\n  }\n  S.running = false;\n}\n\nfunction runToCompletion() {\n  if (!S.initialized) { log('Initialize first'); return; }\n  stopRun();\n  // perform synchronous steps until done or max iterations\n  const maxSteps = 5000;\n  let steps = 0;\n  while(true) {\n    const st = currentState();\n    if (!st) break;\n    if (st.done) break;\n    if (compareMode.value === 'manual') { log('Stopped because manual compare mode active'); break; }\n    stepOnce(true);\n    steps++;\n    if (steps > maxSteps) { log('Stopped: reached runtime safety limit'); break; }\n  }\n}\n\n/* ------------------------\n   Snapshot management & branching\n-------------------------*/\nfunction saveSnapshot() {\n  const st = currentState();\n  if (!st) { alert('Nothing to snapshot'); return; }\n  const sid = idGen('snap');\n  S.snapshots[sid] = {\n    id: sid,\n    timestamp: new Date().toISOString(),\n    state: deepCopy(st),\n    note: 'Snapshot at step ' + st.step\n  };\n  renderSnapshots();\n  log('Saved snapshot ' + sid);\n}\n\nfunction renderSnapshots() {\n  snapshotsList.innerHTML = '';\n  const keys = Object.keys(S.snapshots);\n  if (keys.length === 0) {\n    snapshotsList.textContent = 'No snapshots saved.';\n    return;\n  }\n  const ul = document.createElement('div');\n  keys.forEach(k => {\n    const snap = S.snapshots[k];\n    const d = document.createElement('div');\n    d.textContent = k + ' | ' + snap.note + ' | ' + snap.timestamp;\n    d.style.cursor = 'pointer';\n    d.addEventListener('click', () => {\n      // Load snapshot replace current history (option to fork)\n      const action = confirm('Load this snapshot into current state? (OK = load as current, Cancel = fork and append state after snapshot)');\n      if (action) {\n        S.states = [deepCopy(snap.state)];\n        S.currentIndex = 0;\n        S.initialized = true;\n        log('Loaded snapshot ' + k + ' as current root');\n        updateUI(); redraw();\n      } else {\n        // Fork: replace current tail with snapshot then continue\n        S.states = S.states.slice(0, S.currentIndex+1);\n        const newSt = deepCopy(snap.state);\n        newSt.parent = S.states[S.currentIndex].id;\n        S.states.push(newSt);\n        S.currentIndex = S.states.length - 1;\n        S.initialized = true;\n        log('Forked from snapshot ' + k + ' into current history');\n        updateUI(); redraw();\n      }\n    });\n    const del = document.createElement('button');\n    del.textContent = 'Delete';\n    del.addEventListener('click', (ev)=> {\n      ev.stopPropagation();\n      delete S.snapshots[k];\n      renderSnapshots();\n      log('Deleted snapshot ' + k);\n    });\n    d.appendChild(document.createTextNode(' '));\n    d.appendChild(del);\n    ul.appendChild(d);\n  });\n  snapshotsList.appendChild(ul);\n}\n\nfunction clearSnapshots() {\n  if (confirm('Clear all snapshots?')) {\n    S.snapshots = {};\n    renderSnapshots();\n    log('Cleared all snapshots');\n  }\n}\n\n/* ------------------------\n   UI updates\n-------------------------*/\nfunction updateUI() {\n  const st = currentState();\n  if (!st) {\n    stateInfo.textContent = 'Not initialized';\n    bestInfo.textContent = '';\n    return;\n  }\n  stateInfo.textContent = `Step: ${st.step}, Iterations: ${st.iterations}, L=${st.L}, R=${st.R}, done=${st.done ? st.reason : 'no'}`;\n  if (st.mode === 'continuous') {\n    if (st.done) {\n      // compute best approximate\n      const xbest = (st.L + st.R)/2;\n      let ybest = NaN;\n      try { ybest = Number(parseFunction(funcExprInput.value)(xbest)); } catch(e) { ybest = NaN; }\n      bestInfo.textContent = `Approx best x ≈ ${xbest}, f(x) ≈ ${ybest}`;\n    } else {\n      bestInfo.textContent = `m1=${st.m1}, f(m1)=${st.f_m1}, m2=${st.m2}, f(m2)=${st.f_m2}`;\n    }\n  } else {\n    if (st.array) {\n      if (st.done) {\n        // final brute\n        let bestIdx = st.L;\n        let bestVal = st.array[st.L];\n        for (let i=st.L+1;i<=st.R;i++) {\n          if (goalSelect.value==='max') {\n            if (st.array[i] > bestVal) { bestVal = st.array[i]; bestIdx = i; }\n          } else {\n            if (st.array[i] < bestVal) { bestVal = st.array[i]; bestIdx = i; }\n          }\n        }\n        bestInfo.textContent = `Discrete best index ≈ ${bestIdx}, value ≈ ${bestVal}`;\n      } else {\n        bestInfo.textContent = `m1=${st.m1}, arr[m1]=${st.f_m1}, m2=${st.m2}, arr[m2]=${st.f_m2}`;\n      }\n    } else {\n      bestInfo.textContent = 'Array not set';\n    }\n  }\n  renderSnapshots();\n}\n\n/* ------------------------\n   Redraw plot/canvas\n-------------------------*/\nfunction redraw() {\n  ctx.clearRect(0,0,plot.width, plot.height);\n  const st = currentState();\n  if (!st) {\n    // draw axes\n    ctx.beginPath();\n    ctx.moveTo(0, plot.height/2);\n    ctx.lineTo(plot.width, plot.height/2);\n    ctx.stroke();\n    return;\n  }\n\n  if (st.mode === 'continuous') {\n    // sample data\n    let samp = st.samples;\n    if (!samp || samp.L !== st.L || samp.R !== st.R) {\n      samp = sampleFunctionForPlot();\n      st.samples = samp;\n    }\n    // compute y range among finite samples\n    const pts = samp.samples.filter(p=>isFinite(p.y));\n    let ymin = 0;\n    let ymax = 1;\n    if (pts.length > 0) {\n      ymin = Math.min(...pts.map(p=>p.y));\n      ymax = Math.max(...pts.map(p=>p.y));\n      if (ymin === ymax) { ymin -= 1; ymax += 1; }\n    } else {\n      ymin = -1; ymax = 1;\n    }\n    const pad = 0.05*(ymax - ymin);\n    ymin -= pad; ymax += pad;\n\n    // map function\n    const mapX = x => (x - samp.L) / (samp.R - samp.L) * plot.width;\n    const mapY = y => plot.height - (y - ymin) / (ymax - ymin) * plot.height;\n\n    // draw polyline\n    ctx.beginPath();\n    let started = false;\n    for (let i=0;i<samp.samples.length;i++) {\n      const p = samp.samples[i];\n      if (!isFinite(p.y)) { started = false; continue; }\n      const x = mapX(p.x), y = mapY(p.y);\n      if (!started) { ctx.moveTo(x,y); started = true; } else ctx.lineTo(x,y);\n    }\n    ctx.stroke();\n\n    // draw partitions if enabled\n    if (showPartitionBox.checked) {\n      // draw L,R,m1,m2\n      const cur = st;\n      if (cur.L !== null && cur.R !== null) {\n        // L\n        ctx.beginPath();\n        ctx.moveTo(mapX(cur.L), 0); ctx.lineTo(mapX(cur.L), plot.height);\n        ctx.stroke();\n        ctx.beginPath();\n        ctx.moveTo(mapX(cur.R), 0); ctx.lineTo(mapX(cur.R), plot.height);\n        ctx.stroke();\n      }\n      if (cur.m1 !== null) {\n        ctx.beginPath();\n        ctx.moveTo(mapX(cur.m1), 0); ctx.lineTo(mapX(cur.m1), plot.height);\n        ctx.stroke();\n      }\n      if (cur.m2 !== null) {\n        ctx.beginPath();\n        ctx.moveTo(mapX(cur.m2), 0); ctx.lineTo(mapX(cur.m2), plot.height);\n        ctx.stroke();\n      }\n    }\n\n    // point at mid values\n    if (st.m1 !== null) {\n      const f = parseFunction(funcExprInput.value);\n      let y1 = NaN, y2 = NaN;\n      try { y1 = Number(f(st.m1)); } catch(e) { y1 = NaN; }\n      try { y2 = Number(f(st.m2)); } catch(e) { y2 = NaN; }\n      if (isFinite(y1)) {\n        const x = mapX(st.m1), y = mapY(y1);\n        ctx.fillRect(x-3,y-3,6,6);\n      }\n      if (isFinite(y2)) {\n        const x = mapX(st.m2), y = mapY(y2);\n        ctx.fillRect(x-3,y-3,6,6);\n      }\n    }\n\n    // trace history intervals lightly (just draw thin lines)\n    if (traceHistoryBox.checked && st.history && st.history.length>0) {\n      st.history.forEach(h=>{\n        ctx.beginPath();\n        ctx.moveTo(mapX(h.L), 0); ctx.lineTo(mapX(h.L), plot.height);\n        ctx.stroke();\n        ctx.beginPath();\n        ctx.moveTo(mapX(h.R), 0); ctx.lineTo(mapX(h.R), plot.height);\n        ctx.stroke();\n      });\n    }\n\n  } else {\n    // discrete: draw bar chart of array\n    const arr = st.array || [];\n    if (arr.length === 0) {\n      ctx.fillText('No array to display', 10, 20);\n      return;\n    }\n    const n = arr.length;\n    const barW = plot.width / n;\n    let ymin = Math.min(...arr), ymax = Math.max(...arr);\n    if (ymin === ymax) { ymin -= 1; ymax += 1; }\n    const mapY = v => plot.height - (v - ymin)/(ymax-ymin) * plot.height;\n    for (let i=0;i<n;i++) {\n      const x = i*barW;\n      const y = mapY(arr[i]);\n      const h = plot.height - y;\n      ctx.fillRect(x+1, y, barW-2, h);\n    }\n    // draw L,R,m1,m2 lines\n    if (showPartitionBox.checked) {\n      if (st.L !== null) {\n        ctx.beginPath();\n        ctx.moveTo(st.L*barW,0); ctx.lineTo(st.L*barW,plot.height); ctx.stroke();\n      }\n      if (st.R !== null) {\n        ctx.beginPath();\n        ctx.moveTo((st.R+1)*barW,0); ctx.lineTo((st.R+1)*barW,plot.height); ctx.stroke();\n      }\n      if (st.m1 !== null) {\n        ctx.beginPath();\n        ctx.moveTo((st.m1+0.5)*barW,0); ctx.lineTo((st.m1+0.5)*barW,plot.height); ctx.stroke();\n      }\n      if (st.m2 !== null) {\n        ctx.beginPath();\n        ctx.moveTo((st.m2+0.5)*barW,0); ctx.lineTo((st.m2+0.5)*barW,plot.height); ctx.stroke();\n      }\n    }\n\n    // highlight current interval\n    if (traceHistoryBox.checked && st.history && st.history.length>0) {\n      st.history.forEach(h=>{\n        ctx.beginPath();\n        ctx.moveTo((h.L+0.5)*barW,0); ctx.lineTo((h.L+0.5)*barW,plot.height); ctx.stroke();\n        ctx.beginPath();\n        ctx.moveTo((h.R+0.5)*barW,0); ctx.lineTo((h.R+0.5)*barW,plot.height); ctx.stroke();\n      });\n    }\n  }\n}\n\n/* ------------------------\n   Manual decision handlers\n-------------------------*/\nfunction manualDecisionApply(choice) {\n  // choice: 'leftBetter' means m1 is better? we defined earlier: 'keepRight' if m1 < m2 for max\n  // We'll directly apply: if user chooses \"m1 better\", then we move R to m2; if \"m2 better\", move L to m1\n  if (!S.initialized) { alert('Initialize first'); return; }\n  const stOld = currentState();\n  if (!stOld) return;\n  // create a copy and apply decision\n  const st = deepCopy(stOld);\n  st.id = idGen('state');\n  st.parent = stOld.id;\n  st.step = stOld.step + 1;\n  st.iterations = stOld.iterations + 1;\n\n  if (st.mode === 'continuous') {\n    if (choice === 'm1Better') {\n      st.R = st.m2;\n      log('Manual decision: m1 considered better -> move R to m2');\n    } else {\n      st.L = st.m1;\n      log('Manual decision: m2 considered better -> move L to m1');\n    }\n    st.history = st.history || [];\n    st.history.push({L:st.L,R:st.R,m1:st.m1,m2:st.m2,f_m1:st.f_m1,f_m2:st.f_m2});\n    // check termination\n    if (Math.abs(st.R - st.L) <= Number(epsInput.value)) {\n      st.done = true; st.reason = 'Interval <= eps (manual)';\n    }\n  } else {\n    if (choice === 'm1Better') {\n      st.R = st.m2;\n      log('Manual decision (discrete): m1 better -> move R to m2');\n    } else {\n      st.L = st.m1;\n      log('Manual decision (discrete): m2 better -> move L to m1');\n    }\n    st.history = st.history || [];\n    st.history.push({L:st.L,R:st.R,m1:st.m1,m2:st.m2,f_m1:st.f_m1,f_m2:st.f_m2});\n    if (st.R - st.L <= 2) {\n      // do final brute\n      let bestIdx = st.L; let bestVal = st.array[st.L];\n      for (let i=st.L+1;i<=st.R;i++) {\n        const v = st.array[i];\n        if (goalSelect.value==='max') {\n          if (v > bestVal) { bestVal = v; bestIdx = i; }\n        } else {\n          if (v < bestVal) { bestVal = v; bestIdx = i; }\n        }\n      }\n      st.done = true;\n      st.reason = 'Final brute force after manual decision';\n      log(`Manual final brute: best index ${bestIdx} val ${bestVal}`);\n    }\n  }\n  pushState(st);\n}\n\n/* ------------------------\n   Explain functions\n-------------------------*/\nfunction explainNext() {\n  const st = currentState();\n  if (!st) { explainOutput.value = 'Not initialized'; return; }\n  if (st.done) { explainOutput.value = 'Algorithm done: ' + st.reason; return; }\n  let out = '';\n  if (st.mode === 'continuous') {\n    out += `Interval [${st.L}, ${st.R}]\\n`;\n    const len = st.R - st.L;\n    const m1 = st.L + len/3, m2 = st.R - len/3;\n    out += `Compute m1 = L + (R-L)/3 = ${m1}\\n`;\n    out += `Compute m2 = R - (R-L)/3 = ${m2}\\n`;\n    out += `Evaluate f(m1), f(m2). If maximizing and f(m1) < f(m2) -> discard left third (L=m1). Otherwise discard right third (R=m2).\\n`;\n    out += `This reduces the interval guaranteed to contain the unimodal maximum.\\n`;\n    explainOutput.value = out;\n  } else {\n    out += `Discrete array indices L=${st.L}, R=${st.R}.\\nCompute integer m1 and m2: m1 = L + floor((R-L)/3), m2 = R - floor((R-L)/3)\\nCompare arr[m1] and arr[m2]; narrow interval accordingly.\\nWhen R-L <= 2, inspect the small interval directly.\\n`;\n    explainOutput.value = out;\n  }\n}\n\nfunction explainHistory() {\n  const st = currentState();\n  if (!st) { explainOutput.value = 'Not initialized'; return; }\n  if (!st.history || st.history.length === 0) {\n    explainOutput.value = 'No history (no steps yet).';\n    return;\n  }\n  let out = '';\n  st.history.forEach((h,i)=>{\n    out += `Step ${i+1}: L=${h.L}, R=${h.R}, m1=${h.m1} (f=${h.f_m1}), m2=${h.m2} (f=${h.f_m2})\\n`;\n  });\n  explainOutput.value = out;\n}\n\n/* ------------------------\n   Brute force verification\n-------------------------*/\nfunction bruteForceCheck() {\n  if (!S.initialized) { log('Initialize first'); return; }\n  const st = currentState();\n  if (!st) return;\n  if (st.mode === 'continuous') {\n    // sample densely to find approximate global maximum on [L,R]\n    const f = parseFunction(funcExprInput.value);\n    const L = st.L, R = st.R;\n    const N = 1001;\n    let bestX = L; let bestY = -Infinity;\n    for (let i=0;i<N;i++) {\n      const x = L + (R-L)*i/(N-1);\n      let y = NaN;\n      try { y = Number(f(x)); } catch(e) { y = NaN; }\n      if (!isFinite(y)) continue;\n      if (goalSelect.value === 'max') {\n        if (y > bestY) { bestY = y; bestX = x; }\n      } else {\n        if (y < bestY || bestY===-Infinity) { bestY = y; bestX = x; }\n      }\n    }\n    log(`Brute-force sample best at x≈${bestX}, f≈${bestY}`);\n    alert('Brute-force sample best at x≈' + bestX + ', f≈' + bestY);\n  } else {\n    // discrete brute check entire array\n    const arr = st.array;\n    if (!arr) { log('No array'); return; }\n    let best = 0; let bestIdx = 0;\n    for (let i=0;i<arr.length;i++) {\n      if (i===0) { best = arr[i]; bestIdx = i; }\n      if (goalSelect.value==='max') {\n        if (arr[i] > best) { best = arr[i]; bestIdx = i; }\n      } else {\n        if (arr[i] < best) { best = arr[i]; bestIdx = i; }\n      }\n    }\n    log(`Brute-force discrete best index ${bestIdx}, value ${best}`);\n    alert('Brute-force discrete best index ' + bestIdx + ', value ' + best);\n  }\n}\n\n/* ------------------------\n   Event bindings\n-------------------------*/\nmodeSelect.addEventListener('change', ()=> {\n  if (modeSelect.value === 'continuous') {\n    continuousControls.style.display = '';\n    discreteControls.style.display = 'none';\n  } else {\n    continuousControls.style.display = 'none';\n    discreteControls.style.display = '';\n  }\n});\n\ngenArrayBtn.addEventListener('click', ()=> {\n  const len = Math.max(3, Math.floor(Number(arrayLengthInput.value) || 0));\n  const arr = generateUnimodalArray(arrayGenSelect.value, len);\n  renderArrayEditor(arr);\n});\n\nrandomizeArrayBtn.addEventListener('click', ()=> {\n  // randomize existing array slightly\n  const inputs = Array.from(arrayEditorContainer.querySelectorAll('input[type=number]'));\n  if (inputs.length === 0) {\n    alert('No array in editor. Generate one first.');\n    return;\n  }\n  inputs.forEach(inp=>{\n    const v = Number(inp.value);\n    inp.value = Math.round((v + (Math.random()*20-10))*10)/10;\n  });\n  // update state\n  const arr = inputs.map(i=>Number(i.value));\n  const st = currentState();\n  if (st && st.mode==='discrete') {\n    const newSt = deepCopy(st);\n    newSt.array = arr;\n    pushState(newSt);\n    log('Randomized array and pushed new state.');\n  }\n});\n\nclearArrayBtn.addEventListener('click', ()=> {\n  arrayEditorContainer.innerHTML = '';\n});\n\ninitBtn.addEventListener('click', initialize);\nstepBtn.addEventListener('click', ()=> stepOnce(false));\nbackBtn.addEventListener('click', stepBack);\nrunBtn.addEventListener('click', runAuto);\npauseBtn.addEventListener('click', stopRun);\nfinishBtn.addEventListener('click', runToCompletion);\nresetBtn.addEventListener('click', ()=> {\n  S.states = [];\n  S.currentIndex = -1;\n  S.initialized = false;\n  stopRun();\n  log('Reset explorer.');\n  updateUI();\n  redraw();\n});\nbruteforceBtn.addEventListener('click', bruteForceCheck);\n\nsaveSnapshotBtn.addEventListener('click', saveSnapshot);\nlistSnapshotsBtn.addEventListener('click', renderSnapshots);\nclearSnapshotsBtn.addEventListener('click', clearSnapshots);\n\ncompareMode.addEventListener('change', ()=> {\n  if (compareMode.value === 'manual') manualDecision.style.display = '';\n  else manualDecision.style.display = 'none';\n});\n\ndecideLeftBtn.addEventListener('click', ()=> manualDecisionApply('m1Better'));\ndecideRightBtn.addEventListener('click', ()=> manualDecisionApply('m2Better'));\n\nexplainStepBtn.addEventListener('click', explainNext);\nexplainHistoryBtn.addEventListener('click', explainHistory);\n\n/* Hotkeys for power users */\ndocument.addEventListener('keydown', (e)=> {\n  if (e.key === ' ') { e.preventDefault(); stepOnce(false); } // space = step\n  if (e.key === 'r' && e.ctrlKey) { runAuto(); } // ctrl+r run\n});\n\n/* ------------------------\n   Initial setup: render default array editor\n-------------------------*/\n(function initialSetup() {\n  // generate default array editor for discrete mode\n  const arr = generateUnimodalArray('singlePeak', Number(arrayLengthInput.value));\n  renderArrayEditor(arr);\n  renderSnapshots();\n  redraw();\n})();\n</script>\n</body>\n</html>"
