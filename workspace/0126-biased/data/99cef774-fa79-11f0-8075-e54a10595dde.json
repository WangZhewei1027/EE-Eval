    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ternary Search Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        input, button {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Ternary Search Interactive Demo</h1>\n<p>Enter an array of numbers (comma separated):</p>\n<input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 10, 20, 30, 40, 50\">\n<br>\n<p>Enter the number to search for:</p>\n<input type=\"number\" id=\"targetInput\" placeholder=\"Target Number\">\n<br>\n<button onclick=\"performTernarySearch()\">Search</button>\n<button onclick=\"reset()\">Reset</button>\n<p id=\"result\"></p>\n<p id=\"steps\"></p>\n\n<script>\n    function performTernarySearch() {\n        const arrayInput = document.getElementById('arrayInput').value.split(',').map(Number);\n        const target = Number(document.getElementById('targetInput').value);\n        const resultElement = document.getElementById('result');\n        const stepsElement = document.getElementById('steps');\n\n        if (!Array.isArray(arrayInput) || arrayInput.length === 0 || isNaN(target)) {\n            resultElement.textContent = \"Please provide a valid input.\";\n            stepsElement.textContent = \"\";\n            return;\n        }\n\n        const sortedArray = arrayInput.sort((a, b) => a - b);\n        const searchResult = ternarySearch(sortedArray, target, 0, sortedArray.length - 1, stepsElement);\n        resultElement.textContent = searchResult !== -1 ? `Found at index: ${searchResult}` : \"Not found\";\n    }\n\n    function ternarySearch(arr, target, left, right, stepsElement) {\n        if (left > right) {\n            return -1;\n        }\n\n        const thirdLength = Math.floor((right - left) / 3);\n        const mid1 = left + thirdLength;\n        const mid2 = right - thirdLength;\n\n        let steps = `Searching in range [${left}-${right}]: mid1 = ${mid1}, mid2 = ${mid2} - values: ${arr[mid1]}, ${arr[mid2]}\\n`;\n        \n        if (arr[mid1] === target) {\n            stepsElement.textContent += steps;\n            return mid1;\n        }\n        if (arr[mid2] === target) {\n            stepsElement.textContent += steps;\n            return mid2;\n        }\n        \n        if (target < arr[mid1]) {\n            stepsElement.textContent += steps;\n            return ternarySearch(arr, target, left, mid1 - 1, stepsElement);\n        } else if (target > arr[mid2]) {\n            stepsElement.textContent += steps;\n            return ternarySearch(arr, target, mid2 + 1, right, stepsElement);\n        }\n        \n        stepsElement.textContent += steps;\n        return ternarySearch(arr, target, mid1 + 1, mid2 - 1, stepsElement);\n    }\n\n    function reset() {\n        document.getElementById('arrayInput').value = '';\n        document.getElementById('targetInput').value = '';\n        document.getElementById('result').textContent = '';\n        document.getElementById('steps').textContent = '';\n    }\n</script>\n\n</body>\n</html>"
