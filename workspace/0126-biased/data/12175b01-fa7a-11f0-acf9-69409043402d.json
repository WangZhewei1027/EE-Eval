  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Random Forest Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    line-height: 1.4;\n  }\n  label, button {\n    display: inline-block;\n    margin: 0.3em 0.5em 0.3em 0;\n  }\n  input[type=number], input[type=text] {\n    width: 4em;\n  }\n  textarea {\n    width: 100%;\n    height: 12em;\n    margin: 0.5em 0;\n  }\n  pre {\n    background: #f0f0f0;\n    padding: 0.3em 0.5em;\n    overflow-x: auto;\n  }\n  fieldset {\n    margin-bottom: 1em;\n    padding: 0.7em 1em 0.7em 1em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Random Forest Interactive Explorer</h1>\n\n<p>This tool lets you build, train, visualize, and explore Random Forests step-by-step with maximum interactive user control.</p>\n\n<fieldset>\n  <legend>1. Data Input & Configuration</legend>\n\n  <label for=\"datasetSelect\">Select Dataset:</label>\n  <select id=\"datasetSelect\" aria-label=\"Select Dataset\">\n    <option value=\"custom\">Custom CSV input</option>\n    <option value=\"iris\">Iris (Classic classification)</option>\n    <option value=\"synthetic\">Synthetic binary classification</option>\n  </select>\n  <button id=\"loadDatasetBtn\">Load Dataset</button>\n  <br />\n\n  <label for=\"dataTextarea\">Dataset (CSV format):</label><br />\n  <textarea id=\"dataTextarea\" aria-label=\"Dataset CSV input\" placeholder=\"Paste CSV data here, first line is header\"></textarea>\n  <small>Note: last column is treated as target label (classification). Features must be numeric.</small>\n  <br />\n\n  <label for=\"maxDepthInput\">Max Tree Depth:</label>\n  <input type=\"number\" id=\"maxDepthInput\" min=\"1\" max=\"20\" value=\"5\" aria-label=\"Max Tree Depth\" />\n  <label for=\"nTreesInput\">Number of Trees:</label>\n  <input type=\"number\" id=\"nTreesInput\" min=\"1\" max=\"100\" value=\"10\" aria-label=\"Number of Trees\" />\n  <label for=\"minSamplesSplitInput\">Min Samples Split:</label>\n  <input type=\"number\" id=\"minSamplesSplitInput\" min=\"2\" max=\"20\" value=\"2\" aria-label=\"Minimum Samples Split\" />\n  <button id=\"buildForestBtn\">Build and Train Forest</button>\n</fieldset>\n\n<fieldset>\n  <legend>2. Random Forest State and Interaction</legend>\n\n  <button id=\"showForestSummaryBtn\">Show Forest Summary</button>\n  <button id=\"listTreesBtn\">List All Trees</button>\n  <button id=\"resetForestBtn\">Reset Forest</button>\n  <p id=\"statusArea\" aria-live=\"polite\"></p>\n  <pre id=\"outputArea\" tabindex=\"0\" aria-label=\"Output Area\"></pre>\n</fieldset>\n\n<fieldset>\n  <legend>3. Detailed Tree Exploration</legend>\n  <label for=\"treeIndexInput\">Choose Tree Index (0-based):</label>\n  <input type=\"number\" id=\"treeIndexInput\" min=\"0\" value=\"0\" aria-label=\"Tree Index\" />\n  <button id=\"showTreeBtn\">Show Tree Structure</button>\n  <br />\n  <label for=\"nodePathInput\">Navigate Node (path sequence, e.g. \"L,R,L\"):</label>\n  <input type=\"text\" id=\"nodePathInput\" placeholder=\"e.g. L,R,L\" aria-label=\"Node Path\" />\n  <button id=\"showNodeBtn\">Show Node Info</button>\n  <button id=\"goToParentBtn\">Go To Parent Node</button>\n  <button id=\"goToRootBtn\">Go To Root Node</button>\n  <p>Current Node Path: <span id=\"currentNodePath\">(root)</span></p>\n  <pre id=\"nodeOutputArea\" tabindex=\"0\" aria-label=\"Node Output Area\"></pre>\n</fieldset>\n\n<fieldset>\n  <legend>4. Prediction Interface</legend>\n  <p>Enter feature values for prediction using trained forest:</p>\n  <div id=\"predictionInputsArea\" aria-label=\"Feature inputs area for prediction\"></div>\n  <button id=\"predictBtn\">Predict</button>\n  <p>Prediction Result: <strong id=\"predictionResult\"></strong></p>\n</fieldset>\n\n<script>\n// Core data structures and functions for Random Forest from scratch\n\n/*\nWe implement:\n\n- Decision tree nodes (binary trees)\n- Tree training with feature subsampling and bootstrap sample\n- Random Forest training as ensemble of trees\n- Prediction by majority vote\n- Dataset parsing and validation\n- Interactive state and navigation of trees and nodes\n\n*/\n\n// Utility functions\n\nfunction parseCSV(str) {\n  // Very simple CSV parse, comma separated, quote ignored, split by lines.\n  const lines = str.trim().split(/\\r?\\n/);\n  if(lines.length < 2) throw 'Dataset must have at least one data line and a header line.';\n  const headers = lines[0].split(',').map(h=>h.trim());\n  const data = [];\n  for(let i=1; i<lines.length; i++){\n    if(!lines[i].trim()) continue;\n    const row = lines[i].split(',').map(s=>s.trim());\n    if(row.length !== headers.length) throw `Line ${i+1} length mismatch with header`;\n    data.push(row);\n  }\n  return {headers, data};\n}\n\nfunction isNumeric(str) {\n  if(str === '') return false;\n  return !isNaN(str);\n}\n\n// Split dataset into features matrix X and label vector y\n// Converts features to numbers, leaves y as string label\nfunction datasetToXY(parsed) {\n  const X = [];\n  const y = [];\n  for(let row of parsed.data){\n    let features = row.slice(0, row.length-1);\n    let target = row[row.length-1];\n    // Ensure all feature numeric\n    let fnums = features.map(f=>{\n      if(!isNumeric(f)) throw 'Feature non-numeric value: ' + f;\n      return Number(f);\n    });\n    X.push(fnums);\n    y.push(target);\n  }\n  return {X, y, featureNames: parsed.headers.slice(0, parsed.headers.length-1), targetName: parsed.headers[parsed.headers.length-1]};\n}\n\n// Unique values array\nfunction unique(arr) {\n  return Array.from(new Set(arr));\n}\n\n// Count occurrences per class label\nfunction countLabels(labels) {\n  let counts = {};\n  for(const l of labels) {\n    counts[l] = (counts[l] || 0) + 1;\n  }\n  return counts;\n}\n\n// Majority class label\nfunction majorityLabel(labels) {\n  let counts = countLabels(labels);\n  let maxCount = -1;\n  let majority = null;\n  for(let lbl in counts) {\n    if(counts[lbl] > maxCount){\n      maxCount = counts[lbl];\n      majority = lbl;\n    }\n  }\n  return majority;\n}\n\n// Entropy\nfunction entropy(labels) {\n  let counts = countLabels(labels);\n  let total = labels.length;\n  let ent = 0;\n  for(let lbl in counts) {\n    let p = counts[lbl]/total;\n    ent -= p * Math.log2(p);\n  }\n  return ent;\n}\n\n// Gini impurity\nfunction gini(labels) {\n  let counts = countLabels(labels);\n  let total = labels.length;\n  let impurity = 1;\n  for(let lbl in counts) {\n    let p = counts[lbl]/total;\n    impurity -= p*p;\n  }\n  return impurity;\n}\n\n// Check if all labels identical\nfunction allSame(labels) {\n  if(labels.length === 0) return true;\n  let first = labels[0];\n  for(let l of labels) if(l !== first) return false;\n  return true;\n}\n\n// Bootstrap sample indices from dataset size N\nfunction bootstrapSampleIndices(N) {\n  let sample = [];\n  for(let i=0; i<N; i++){\n    sample.push(Math.floor(Math.random()*N));\n  }\n  return sample;\n}\n\n// Random subset of features\nfunction randomFeaturesIndices(nFeatures, maxFeatures) {\n  let indices = [];\n  for(let i=0; i<nFeatures; i++) indices.push(i);\n  for(let i = indices.length - 1; i>0; i--){\n    let j = Math.floor(Math.random()*(i+1));\n    [indices[i], indices[j]] = [indices[j], indices[i]];\n  }\n  return indices.slice(0, maxFeatures);\n}\n\n// Tree structure\n\nclass TreeNode {\n  constructor() {\n    this.isLeaf = false;\n    this.prediction = null;  // for leaf\n    this.featureIndex = null; // for split\n    this.threshold = null;\n    this.left = null;\n    this.right = null;\n    this.samplesIndices = []; // indices of samples in this node (optional for debug)\n    this.depth = 0;\n    this.parent = null; // usable for navigation\n  }\n}\n\nclass DecisionTree {\n  constructor(options) {\n    this.maxDepth = options.maxDepth || 5;\n    this.minSamplesSplit = options.minSamplesSplit || 2;\n    this.nFeatures = options.nFeatures || null; // total number of features in dataset\n    this.maxFeatures = options.maxFeatures || null; // number of features to consider at splits\n    this.X = null;\n    this.y = null;\n    this.root = null;\n    this.featureNames = options.featureNames || [];\n  }\n\n  fit(X, y, sampleIndices=null) {\n    // Save dataset reference\n    this.X = X;\n    this.y = y;\n    this.sampleIndices = sampleIndices || X.map((_,i)=>i);\n    this.nFeatures = X[0].length;\n    if(!this.maxFeatures) {\n      this.maxFeatures = Math.floor(Math.sqrt(this.nFeatures)) || 1;\n    }\n    this.root = new TreeNode();\n    this.root.samplesIndices = this.sampleIndices;\n    this.root.depth = 0;\n    this.root.parent = null;\n    this._buildTree(this.root);\n  }\n\n  _buildTree(node) {\n    let indices = node.samplesIndices;\n    let labels = indices.map(i=>this.y[i]);\n    if(allSame(labels) || node.depth >= this.maxDepth || indices.length < this.minSamplesSplit) {\n      node.isLeaf = true;\n      node.prediction = majorityLabel(labels);\n      return;\n    }\n\n    // Select random subset of features to consider\n    let featuresConsidered = randomFeaturesIndices(this.nFeatures, this.maxFeatures);\n    let bestFeature = null;\n    let bestThreshold = null;\n    let bestInfoGain = -Infinity;\n    let bestSplits = null;\n\n    // Calculate impurity of current node\n    let baseGini = gini(labels);\n\n    for (let fIdx of featuresConsidered) {\n      // Get sorted unique values on this feature in current samples\n      let featVals = indices.map(i=>this.X[i][fIdx]);\n      let uniqueVals = unique(featVals).sort((a,b)=>a-b);\n      if(uniqueVals.length <= 1) continue; // no split possible\n\n      // Candidate thresholds are midpoints between sorted unique feature values\n      let thresholds = [];\n      for(let i=0; i<uniqueVals.length-1; i++){\n        thresholds.push((uniqueVals[i]+uniqueVals[i+1])/2);\n      }\n\n      for(let thresh of thresholds) {\n        // Split samples left/right\n        let leftIndices = indices.filter(i=>this.X[i][fIdx] <= thresh);\n        let rightIndices = indices.filter(i=>this.X[i][fIdx] > thresh);\n        if(leftIndices.length === 0 || rightIndices.length === 0) continue;\n        let leftLabels = leftIndices.map(i=>this.y[i]);\n        let rightLabels = rightIndices.map(i=>this.y[i]);\n\n        // Weighted impurity\n        let pLeft = leftIndices.length / indices.length;\n        let pRight = rightIndices.length / indices.length;\n        let infoGain = baseGini - (pLeft*gini(leftLabels) + pRight*gini(rightLabels));\n        if(infoGain > bestInfoGain) {\n          bestFeature = fIdx;\n          bestThreshold = thresh;\n          bestInfoGain = infoGain;\n          bestSplits = {left: leftIndices, right: rightIndices};\n        }\n      }\n    }\n\n    if(bestInfoGain === -Infinity || bestFeature === null) {\n      // No valid split found, make leaf\n      node.isLeaf = true;\n      node.prediction = majorityLabel(labels);\n      return;\n    }\n\n    // Create left and right nodes\n    node.featureIndex = bestFeature;\n    node.threshold = bestThreshold;\n\n    node.left = new TreeNode();\n    node.left.samplesIndices = bestSplits.left;\n    node.left.depth = node.depth + 1;\n    node.left.parent = node;\n\n    node.right = new TreeNode();\n    node.right.samplesIndices = bestSplits.right;\n    node.right.depth = node.depth + 1;\n    node.right.parent = node;\n\n    // Recursive build\n    this._buildTree(node.left);\n    this._buildTree(node.right);\n  }\n\n  predictSingle(x) {\n    let node = this.root;\n    while(!node.isLeaf) {\n      if(x[node.featureIndex] <= node.threshold){\n        node = node.left;\n      } else {\n        node = node.right;\n      }\n    }\n    return node.prediction;\n  }\n\n  toJSON() {\n    function nodeToJson(node) {\n      if(!node) return null;\n      if(node.isLeaf) {\n        return {leaf:true, prediction: node.prediction, samples: node.samplesIndices.length};\n      }\n      return {\n        leaf:false,\n        featureIndex: node.featureIndex,\n        featureName: this.featureNames[node.featureIndex] || ('f'+node.featureIndex),\n        threshold: node.threshold,\n        samples: node.samplesIndices.length,\n        left: nodeToJson.call(this, node.left),\n        right: nodeToJson.call(this, node.right)\n      }\n    }\n    return nodeToJson.call(this, this.root);\n  }\n}\n\nclass RandomForest {\n  constructor(options) {\n    this.nTrees = options.nTrees || 10;\n    this.maxDepth = options.maxDepth || 5;\n    this.minSamplesSplit = options.minSamplesSplit || 2;\n    this.trees = [];\n    this.X = null;\n    this.y = null;\n    this.featureNames = options.featureNames || [];\n  }\n\n  fit(X, y) {\n    this.X = X;\n    this.y = y;\n    this.trees = [];\n    let nSamples = X.length;\n    let nFeatures = X[0].length;\n    for(let i=0; i<this.nTrees; i++){\n      let sampleIndices = bootstrapSampleIndices(nSamples);\n      let tree = new DecisionTree({\n        maxDepth: this.maxDepth,\n        minSamplesSplit: this.minSamplesSplit,\n        nFeatures: nFeatures,\n        maxFeatures: Math.floor(Math.sqrt(nFeatures)) || 1,\n        featureNames: this.featureNames\n      });\n      tree.fit(X, y, sampleIndices);\n      this.trees.push(tree);\n    }\n  }\n\n  predictSingle(x) {\n    let votes = {};\n    for(const tree of this.trees){\n      let p = tree.predictSingle(x);\n      votes[p] = (votes[p] || 0) + 1;\n    }\n    let majority = null;\n    let maxVotes = -1;\n    for(let c in votes){\n      if(votes[c] > maxVotes){\n        maxVotes = votes[c];\n        majority = c;\n      }\n    }\n    return majority;\n  }\n\n  summary() {\n    if(this.trees.length === 0) return 'No trees trained.';\n    let lines = [];\n    lines.push(`Random Forest with ${this.trees.length} trees:`);\n    for(let i=0; i<this.trees.length; i++){\n      let tree = this.trees[i];\n      let leaves = countLeaves(tree.root);\n      lines.push(`Tree ${i}: max depth ${tree.maxDepth}, leaves ${leaves}`);\n    }\n    return lines.join('\\n');\n  }\n}\n\nfunction countLeaves(node) {\n  if(!node) return 0;\n  if(node.isLeaf) return 1;\n  return countLeaves(node.left) + countLeaves(node.right);\n}\n\n// GLOBAL STATE\nconst RandomForestState = {\n  forest: null,\n  trained: false,\n  dataset: null,\n  X: null,\n  y: null,\n  featureNames: [],\n  targetName: null,\n  // Current tree and current node navigation for exploration\n  currentTreeIndex: 0,\n  currentNodePath: [], // e.g. ['L', 'R', 'L']\n  // Cached reference to current node object\n  currentNodeRef: null,\n  treeNodeCache: null // {treeIndex: rootNode}\n};\n\n// UI elements\nconst elements = {\n  datasetSelect: document.getElementById('datasetSelect'),\n  loadDatasetBtn: document.getElementById('loadDatasetBtn'),\n  dataTextarea: document.getElementById('dataTextarea'),\n  maxDepthInput: document.getElementById('maxDepthInput'),\n  nTreesInput: document.getElementById('nTreesInput'),\n  minSamplesSplitInput: document.getElementById('minSamplesSplitInput'),\n  buildForestBtn: document.getElementById('buildForestBtn'),\n  showForestSummaryBtn: document.getElementById('showForestSummaryBtn'),\n  listTreesBtn: document.getElementById('listTreesBtn'),\n  resetForestBtn: document.getElementById('resetForestBtn'),\n  statusArea: document.getElementById('statusArea'),\n  outputArea: document.getElementById('outputArea'),\n\n  treeIndexInput: document.getElementById('treeIndexInput'),\n  showTreeBtn: document.getElementById('showTreeBtn'),\n  nodePathInput: document.getElementById('nodePathInput'),\n  showNodeBtn: document.getElementById('showNodeBtn'),\n  goToParentBtn: document.getElementById('goToParentBtn'),\n  goToRootBtn: document.getElementById('goToRootBtn'),\n  currentNodePathSpan: document.getElementById('currentNodePath'),\n  nodeOutputArea: document.getElementById('nodeOutputArea'),\n\n  predictionInputsArea: document.getElementById('predictionInputsArea'),\n  predictBtn: document.getElementById('predictBtn'),\n  predictionResult: document.getElementById('predictionResult')\n};\n\n// Handling dataset loading\n\nconst predefinedDatasets = {\n  iris: `sepal_length,sepal_width,petal_length,petal_width,species\n5.1,3.5,1.4,0.2,setosa\n4.9,3.0,1.4,0.2,setosa\n4.7,3.2,1.3,0.2,setosa\n4.6,3.1,1.5,0.2,setosa\n5.0,3.6,1.4,0.2,setosa\n5.4,3.9,1.7,0.4,setosa\n4.6,3.4,1.4,0.3,setosa\n5.0,3.4,1.5,0.2,setosa\n4.4,2.9,1.4,0.2,setosa\n4.9,3.1,1.5,0.1,setosa\n5.4,3.7,1.5,0.2,setosa\n4.8,3.4,1.6,0.2,setosa\n4.8,3.0,1.4,0.1,setosa\n4.3,3.0,1.1,0.1,setosa\n5.8,4.0,1.2,0.2,setosa\n5.7,4.4,1.5,0.4,setosa\n5.4,3.9,1.3,0.4,setosa\n5.1,3.5,1.4,0.3,setosa\n5.7,3.8,1.7,0.3,setosa\n5.1,3.8,1.5,0.3,setosa\n6.7,3.1,4.7,1.5,versicolor\n6.3,2.3,4.4,1.3,versicolor\n5.8,2.7,4.1,1.0,versicolor\n6.1,2.8,4.7,1.2,versicolor\n6.4,2.9,4.3,1.3,versicolor\n6.6,3.0,4.4,1.4,versicolor\n6.8,2.8,4.8,1.4,versicolor\n6.7,3.0,5.0,1.7,versicolor\n6.0,2.9,4.5,1.5,versicolor\n5.7,2.6,3.5,1.0,versicolor\n5.5,2.4,3.8,1.1,versicolor\n5.5,2.4,3.7,1.0,versicolor\n5.8,2.7,3.9,1.2,versicolor\n6.0,2.7,5.1,1.6,versicolor\n5.4,3.0,4.5,1.5,versicolor\n6.0,3.4,4.5,1.6,versicolor\n6.7,3.1,4.7,1.5,versicolor\n6.3,2.3,4.4,1.3,versicolor\n5.6,3.0,4.1,1.3,versicolor\n5.5,2.5,4.0,1.3,versicolor\n6.0,3.0,4.8,1.4,versicolor\n6.1,2.8,4.0,1.3,versicolor\n6.1,2.6,5.6,1.4,virginica\n7.7,3.0,6.1,2.3,virginica\n6.3,3.3,6.0,2.5,virginica\n7.2,3.6,6.1,2.5,virginica\n6.7,3.0,5.2,2.3,virginica\n6.5,3.0,5.5,1.8,virginica\n6.2,3.4,5.4,2.3,virginica\n5.9,3.0,5.1,1.8,virginica\n6.7,3.1,5.6,2.4,virginica\n6.9,3.1,5.1,2.3,virginica\n5.8,2.7,5.1,1.9,virginica\n6.8,3.2,5.9,2.3,virginica\n6.7,3.3,5.7,2.5,virginica\n6.7,3.0,5.2,2.3,virginica\n6.3,2.5,5.0,1.9,virginica\n6.5,3.0,5.2,2.0,virginica\n6.2,3.4,5.4,2.3,virginica\n5.9,3.0,5.1,1.8,virginica\n`,\n  synthetic: `feature1,feature2,target\n0.1,0.2,A\n0.3,0.1,A\n0.25,0.5,A\n0.4,0.6,B\n0.45,0.7,B\n0.6,0.4,B\n0.7,0.5,B\n0.8,0.7,B\n0.6,0.2,A\n0.5,0.4,A\n0.55,0.8,B\n`\n};\n\nfunction loadSelectedDataset() {\n  const sel = elements.datasetSelect.value;\n  if(sel === 'custom'){\n    // Just clear textarea for user's paste\n    elements.dataTextarea.value = '';\n  } else {\n    elements.dataTextarea.value = predefinedDatasets[sel] || '';\n  }\n  setStatus(`Dataset \"${sel}\" loaded. Paste or modify data as needed.`);\n}\n\n// Status and output helper functions\n\nfunction setStatus(msg) {\n  elements.statusArea.textContent = msg;\n}\n\nfunction appendOutput(text) {\n  elements.outputArea.textContent += text + '\\n';\n  elements.outputArea.scrollTop = elements.outputArea.scrollHeight;\n}\n\nfunction clearOutput() {\n  elements.outputArea.textContent = '';\n}\n\nfunction clearNodeOutput() {\n  elements.nodeOutputArea.textContent = '';\n}\n\nfunction updatePredictionInputs() {\n  // Rebuild feature input fields based on current dataset features\n  const area = elements.predictionInputsArea;\n  area.innerHTML = '';\n  if(!RandomForestState.featureNames || RandomForestState.featureNames.length === 0) {\n    area.textContent = '(No features to predict. Load dataset and train forest first.)';\n    return;\n  }\n  RandomForestState.featureNames.forEach((fname, idx)=>{\n    let lbl = document.createElement('label');\n    lbl.textContent = fname + ':';\n    lbl.htmlFor = 'predict_feature_' + idx;\n    let inp = document.createElement('input');\n    inp.type = 'number';\n    inp.id = 'predict_feature_' + idx;\n    inp.setAttribute('aria-label', 'Input feature ' + fname);\n    inp.step = 'any';\n    inp.value = '';\n    area.appendChild(lbl);\n    area.appendChild(inp);\n    area.appendChild(document.createElement('br'));\n  });\n}\n\nfunction getPredictionFeatures() {\n  let features = [];\n  const fcount = RandomForestState.featureNames.length;\n  for(let i=0; i<fcount; i++){\n    let inp = document.getElementById('predict_feature_' + i);\n    let val = inp.value.trim();\n    if(val === '') return {error: `Feature \"${RandomForestState.featureNames[i]}\" input is empty.`};\n    let num = Number(val);\n    if(isNaN(num)) return {error: `Feature \"${RandomForestState.featureNames[i]}\" input is not numeric.`};\n    features.push(num);\n  }\n  return {features};\n}\n\n\n// Navigation: from root node of a tree, follow path string: array of 'L' or 'R'\nfunction getNodeByPath(root, pathArray) {\n  let node = root;\n  for(let dir of pathArray){\n    if(!node) return null;\n    if(node.isLeaf) return null;\n    if(dir === 'L') node = node.left;\n    else if(dir === 'R') node = node.right;\n    else return null;\n  }\n  return node;\n}\n\nfunction pathArrayToString(pathArray) {\n  if(pathArray.length === 0) return '(root)';\n  return pathArray.join(',');\n}\n\nfunction displayNodeInfo(node) {\n  if(!node) return 'Node not found.';\n  let lines = [];\n  lines.push(`Depth: ${node.depth}`);\n  lines.push(`Samples in node: ${node.samplesIndices.length}`);\n  if(node.isLeaf) {\n    lines.push(`Node type: Leaf`);\n    lines.push(`Prediction: ${node.prediction}`);\n  } else {\n    lines.push(`Node type: Internal`);\n    let fName = RandomForestState.featureNames[node.featureIndex] || `f${node.featureIndex}`;\n    lines.push(`Split feature: ${fName} (index ${node.featureIndex})`);\n    lines.push(`Threshold: <= ${node.threshold.toFixed(6)}`);\n  }\n  return lines.join('\\n');\n}\n\nfunction displayTreeStructure(treeIndex) {\n  function recurse(node, indent) {\n    if(!node) return '';\n    let prefix = ' '.repeat(indent);\n    if(node.isLeaf) {\n      return prefix + `Leaf: predict=${node.prediction} (samples=${node.samplesIndices.length})\\n`;\n    }\n    let fName = RandomForestState.featureNames[node.featureIndex] || `f${node.featureIndex}`;\n    let s = prefix + `Node: [${fName} <= ${node.threshold.toFixed(4)}] (samples=${node.samplesIndices.length})\\n`;\n    s += recurse(node.left, indent+2);\n    s += recurse(node.right, indent+2);\n    return s;\n  }\n  if(!RandomForestState.trained) return 'Forest is not trained.';\n  if(treeIndex < 0 || treeIndex >= RandomForestState.forest.trees.length) return 'Tree index out of range.';\n  let tree = RandomForestState.forest.trees[treeIndex];\n  return recurse(tree.root, 0);\n}\n\n// HANDLERS\n\nelements.loadDatasetBtn.addEventListener('click', ()=>{\n  try {\n    loadSelectedDataset();\n    RandomForestState.trained = false;\n    clearOutput();\n    clearNodeOutput();\n    setStatus('Dataset loaded. You can build and train the forest now.');\n  } catch(e) {\n    setStatus('Error loading dataset: ' + e);\n  }\n});\n\nelements.buildForestBtn.addEventListener('click', ()=> {\n  try {\n    clearOutput();\n    clearNodeOutput();\n    setStatus('Parsing dataset...');\n    let csvText = elements.dataTextarea.value;\n    let parsed = parseCSV(csvText);\n    let prepared = datasetToXY(parsed);\n    RandomForestState.X = prepared.X;\n    RandomForestState.y = prepared.y;\n    RandomForestState.featureNames = prepared.featureNames;\n    RandomForestState.targetName = prepared.targetName;\n    setStatus('Dataset parsed. Training Random Forest...');\n    let maxDepth = parseInt(elements.maxDepthInput.value);\n    let nTrees = parseInt(elements.nTreesInput.value);\n    let minSamplesSplit = parseInt(elements.minSamplesSplitInput.value);\n    if(isNaN(maxDepth) || maxDepth < 1 || maxDepth > 20) {\n      setStatus('Invalid max depth. Between 1 and 20.');\n      return;\n    }\n    if(isNaN(nTrees) || nTrees < 1 || nTrees > 100) {\n      setStatus('Invalid number of trees. Between 1 and 100.');\n      return;\n    }\n    if(isNaN(minSamplesSplit) || minSamplesSplit < 2 || minSamplesSplit > 20) {\n      setStatus('Invalid minimum samples split. Between 2 and 20.');\n      return;\n    }\n    RandomForestState.forest = new RandomForest({\n      nTrees,\n      maxDepth,\n      minSamplesSplit,\n      featureNames: prepared.featureNames\n    });\n    RandomForestState.forest.fit(prepared.X, prepared.y);\n    RandomForestState.trained = true;\n    RandomForestState.currentTreeIndex = 0;\n    RandomForestState.currentNodePath = [];\n    setStatus(`Random Forest trained with ${nTrees} trees, max depth ${maxDepth}.`);\n    clearOutput();\n    clearNodeOutput();\n    updatePredictionInputs();\n    elements.treeIndexInput.max = nTrees-1;\n    elements.treeIndexInput.value = 0;\n  } catch(e) {\n    setStatus('Error training forest: ' + e);\n  }\n});\n\nelements.showForestSummaryBtn.addEventListener('click', ()=> {\n  clearOutput();\n  clearNodeOutput();\n  if(!RandomForestState.trained) {\n    setStatus('No forest trained yet.');\n    return;\n  }\n  let summary = RandomForestState.forest.summary();\n  elements.outputArea.textContent = summary;\n  setStatus('Forest summary displayed.');\n});\n\nelements.listTreesBtn.addEventListener('click', ()=> {\n  clearOutput();\n  clearNodeOutput();\n  if(!RandomForestState.trained) {\n    setStatus('No forest trained yet.');\n    return;\n  }\n  let lines = [];\n  lines.push(`Forest has ${RandomForestState.forest.trees.length} trees.`);\n  for(let i=0; i<RandomForestState.forest.trees.length; i++){\n    lines.push(`- Tree ${i}`);\n  }\n  elements.outputArea.textContent = lines.join('\\n');\n  setStatus('Listed all trees by index.');\n});\n\nelements.resetForestBtn.addEventListener('click', ()=> {\n  RandomForestState.forest = null;\n  RandomForestState.trained = false;\n  RandomForestState.dataset = null;\n  RandomForestState.X = null;\n  RandomForestState.y = null;\n  RandomForestState.featureNames = [];\n  RandomForestState.targetName = null;\n  RandomForestState.currentNodePath = [];\n  RandomForestState.currentTreeIndex = 0;\n  clearOutput();\n  clearNodeOutput();\n  setStatus('Random Forest state reset. Load or input dataset to start again.');\n  updatePredictionInputs();\n});\n\nelements.showTreeBtn.addEventListener('click', ()=> {\n  clearOutput();\n  clearNodeOutput();\n  if(!RandomForestState.trained){\n    setStatus('Train a forest first.');\n    return;\n  }\n  let idx = parseInt(elements.treeIndexInput.value);\n  if(isNaN(idx) || idx < 0 || idx >= RandomForestState.forest.trees.length) {\n    setStatus('Invalid tree index.');\n    return;\n  }\n  RandomForestState.currentTreeIndex = idx;\n  RandomForestState.currentNodePath = [];\n  let text = displayTreeStructure(idx);\n  elements.outputArea.textContent = text;\n  elements.currentNodePathSpan.textContent = pathArrayToString(RandomForestState.currentNodePath);\n  clearNodeOutput();\n  setStatus(`Displayed tree ${idx} structure.`);\n});\n\nelements.showNodeBtn.addEventListener('click', ()=> {\n  clearNodeOutput();\n  if(!RandomForestState.trained){\n    setStatus('Train a forest first.');\n    return;\n  }\n  let idx = RandomForestState.currentTreeIndex;\n  if(idx < 0 || idx >= RandomForestState.forest.trees.length){\n    setStatus('Current tree index invalid.');\n    return;\n  }\n  let root = RandomForestState.forest.trees[idx].root;\n  let pathInputRaw = elements.nodePathInput.value.trim();\n  let pathArray;\n  if(pathInputRaw === '') {\n    // If empty, use current node path state\n    pathArray = RandomForestState.currentNodePath;\n  } else {\n    // Parse path string, allow commas or spaces, uppercase L/R only\n    pathArray = pathInputRaw.toUpperCase().split(/[,\\s]+/).filter(s=>s==='L' || s==='R');\n    if(pathArray.length === 0 && pathInputRaw !== '') {\n      setStatus('Invalid node path input. Use L and R separated by commas or spaces.');\n      return;\n    }\n  }\n  let node = getNodeByPath(root, pathArray);\n  if(!node){\n    setStatus('Node not found at path: ' + pathArray.join(','));\n    return;\n  }\n  RandomForestState.currentNodePath = pathArray;\n  elements.currentNodePathSpan.textContent = pathArrayToString(pathArray);\n  let info = displayNodeInfo(node);\n  elements.nodeOutputArea.textContent = info;\n  setStatus('Displayed node info.');\n});\n\nelements.goToParentBtn.addEventListener('click', () => {\n  let path = RandomForestState.currentNodePath;\n  if(path.length === 0) {\n    setStatus('Already at root node, no parent.');\n    return;\n  }\n  let newPath = path.slice(0, path.length-1);\n  RandomForestState.currentNodePath = newPath;\n  elements.currentNodePathSpan.textContent = pathArrayToString(newPath);\n  elements.nodePathInput.value = newPath.join(',');\n  // Refresh node info for new path\n  elements.showNodeBtn.click();\n});\n\nelements.goToRootBtn.addEventListener('click', () => {\n  RandomForestState.currentNodePath = [];\n  elements.currentNodePathSpan.textContent = '(root)';\n  elements.nodePathInput.value = '';\n  elements.showNodeBtn.click();\n});\n\nelements.predictBtn.addEventListener('click', () => {\n  elements.predictionResult.textContent = '';\n  if(!RandomForestState.trained){\n    setStatus('Train a forest first.');\n    return;\n  }\n  let {features, error} = getPredictionFeatures();\n  if(error){\n    setStatus(error);\n    return;\n  }\n  try {\n    let pred = RandomForestState.forest.predictSingle(features);\n    elements.predictionResult.textContent = pred;\n    setStatus('Prediction completed.');\n  } catch(e){\n    setStatus('Error during prediction: ' + e);\n  }\n});\n\n// On dataset select change, load default dataset text automatically\nelements.datasetSelect.addEventListener('change', loadSelectedDataset);\n\n// On page load initialize\nloadSelectedDataset();\nupdatePredictionInputs();\n\n</script>\n\n</body>\n</html>"
