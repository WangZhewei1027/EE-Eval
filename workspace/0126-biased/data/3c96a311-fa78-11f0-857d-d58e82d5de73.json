    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Directed Graph Concept — Visual Illustration</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n\n  :root {\n    --bg-dark: #1e1e2f;\n    --graph-node: #60a5fa;\n    --graph-arrow: #93c5fd;\n    --graph-shadow: rgba(30, 30, 47, 0.7);\n    --highlight: #facc15;\n    --text-primary: #e0e7ff;\n    --text-secondary: #a5b4fc;\n    --button-bg: #3b82f6;\n    --button-bg-hover: #2563eb;\n    --button-shadow: rgba(37, 99, 235, 0.7);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #1e1e2f, #111123);\n    color: var(--text-primary);\n    font-family: 'Poppins', sans-serif;\n    overflow: hidden;\n    display: flex;\n    flex-direction: column;\n    height: 100vh;\n  }\n\n  header {\n    padding: 1.4rem 2.5rem;\n    text-align: center;\n    border-bottom: 1px solid #323245;\n    box-shadow: inset 0 -1px 0 #323245;\n  }\n\n  header h1 {\n    margin: 0;\n    font-weight: 600;\n    font-size: 2.8rem;\n    letter-spacing: 0.06em;\n    background: linear-gradient(90deg, #a5b4fc, #60a5fa);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    user-select: none;\n  }\n\n  main {\n    flex-grow: 1;\n    position: relative;\n  }\n\n  #graph-canvas {\n    width: 100%;\n    height: 100%;\n    display: block;\n    background: radial-gradient(circle at center, #2e2e48, #1e1e2f 80%);\n  }\n\n  footer {\n    padding: 1rem 2.5rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.5rem;\n    background: #111123;\n    border-top: 1px solid #323245;\n  }\n\n  button {\n    padding: 0.6rem 1.6rem;\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    color: var(--text-primary);\n    background-color: var(--button-bg);\n    border: none;\n    border-radius: 0.4rem;\n    cursor: pointer;\n    box-shadow: 0 5px 15px var(--button-shadow);\n    transition:\n      background-color 0.3s ease,\n      box-shadow 0.3s ease,\n      transform 0.15s ease;\n    user-select: none;\n  }\n\n  button:hover,\n  button:focus-visible {\n    background-color: var(--button-bg-hover);\n    box-shadow: 0 8px 22px var(--button-shadow);\n    outline: none;\n  }\n\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Tooltip styling */\n\n  .tooltip {\n    position: absolute;\n    padding: 0.4rem 0.8rem;\n    background: #222233dd;\n    color: var(--text-primary);\n    border-radius: 0.4rem;\n    font-size: 0.85rem;\n    pointer-events: none;\n    transform: translate(-50%, -130%);\n    user-select: none;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    white-space: nowrap;\n    font-weight: 600;\n  }\n\n  .tooltip.visible {\n    opacity: 1;\n  }\n\n</style>\n</head>\n<body>\n<header>\n  <h1>Directed Graph Concept</h1>\n</header>\n<main>\n  <canvas id=\"graph-canvas\" aria-label=\"Directed graph illustration\" role=\"img\"></canvas>\n  <div id=\"tooltip\" class=\"tooltip\" role=\"tooltip\" aria-hidden=\"true\"></div>\n</main>\n<footer>\n  <button id=\"btn-toggle-arrows\" aria-pressed=\"true\" aria-label=\"Toggle arrow animation\">Pause Arrows</button>\n  <button id=\"btn-reset\" aria-label=\"Reset graph animation\">Reset</button>\n</footer>\n\n<script>\n(() => {\n  const canvas = document.getElementById('graph-canvas');\n  const ctx = canvas.getContext('2d');\n  const tooltip = document.getElementById('tooltip');\n  let width, height, dpr;\n\n  // Nodes and edges definition for a conceptual directed graph\n  // Node positions calculated relative to canvas size for responsiveness\n\n  /* \n   Graph nodes:\n   id, label, normalized position (x:0-1, y:0-1)\n  */\n  const nodes = [\n    { id: 'A', label: 'A', x: 0.22, y: 0.17 },\n    { id: 'B', label: 'B', x: 0.50, y: 0.10 },\n    { id: 'C', label: 'C', x: 0.78, y: 0.17 },\n    { id: 'D', label: 'D', x: 0.30, y: 0.45 },\n    { id: 'E', label: 'E', x: 0.70, y: 0.40 },\n    { id: 'F', label: 'F', x: 0.41, y: 0.75 },\n    { id: 'G', label: 'G', x: 0.59, y: 0.75 },\n    { id: 'H', label: 'H', x: 0.50, y: 0.90 }\n  ];\n\n  /*\n   Directed edges connecting nodes by id.\n   Each edge has a subtle animation parameter to move arrow \"pulse\".\n  */\n  const edges = [\n    { from: 'A', to: 'B' },\n    { from: 'B', to: 'C' },\n    { from: 'A', to: 'D' },\n    { from: 'B', to: 'E' },\n    { from: 'C', to: 'E' },\n    { from: 'D', to: 'F' },\n    { from: 'E', to: 'G' },\n    { from: 'F', to: 'H' },\n    { from: 'G', to: 'H' },\n    { from: 'E', to: 'D' } // A backward edge emphasizing directionality\n  ];\n\n  // Canvas sizing & scaling\n  function resize() {\n    dpr = window.devicePixelRatio || 1;\n    width = window.innerWidth;\n    height = window.innerHeight - (header.offsetHeight + footer.offsetHeight);\n\n    canvas.width = width * dpr;\n    canvas.height = height * dpr;\n    canvas.style.width = width + 'px';\n    canvas.style.height = height + 'px';\n    ctx.setTransform(1, 0, 0, 1, 0, 0);\n    ctx.scale(dpr, dpr);\n  }\n\n  // Draw utilities\n\n  const NODE_RADIUS = 24;\n  const FONT = '600 18px Poppins, sans-serif';\n\n  function drawNode(node, isHover = false) {\n    const cx = node.x * width;\n    const cy = node.y * height;\n\n    // Node shadow glow\n    ctx.shadowColor = 'rgba(96, 165, 250, 0.6)';\n    ctx.shadowBlur = isHover ? 16 : 8;\n\n    // Node circle base\n    ctx.beginPath();\n    const gradient = ctx.createRadialGradient(cx, cy, NODE_RADIUS * 0.3, cx, cy, NODE_RADIUS);\n    gradient.addColorStop(0, '#60a5fa');\n    gradient.addColorStop(1, '#1e40af');\n    ctx.fillStyle = gradient;\n    ctx.strokeStyle = isHover ? '#fde68a' : '#93c5fd';\n    ctx.lineWidth = isHover ? 4 : 2;\n    ctx.arc(cx, cy, NODE_RADIUS, 0, Math.PI * 2);\n    ctx.fill();\n    ctx.stroke();\n    ctx.shadowBlur = 0;\n\n    // Node label\n    ctx.fillStyle = 'white';\n    ctx.font = FONT;\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n    ctx.fillText(node.label, cx, cy);\n  }\n\n  // Arrow drawing from point A to B with a smooth curved edge, arrowhead and pulse animation\n  function drawDirectedEdge(fromNode, toNode, progress = 0) {\n    // Coordinates\n    const start = { x: fromNode.x * width, y: fromNode.y * height };\n    const end = { x: toNode.x * width, y: toNode.y * height };\n\n    // Control points for Bezier curve for elegance\n    // Control points perpendicularly offset by 70px with direction awareness\n    const dx = end.x - start.x;\n    const dy = end.y - start.y;\n    const distance = Math.sqrt(dx * dx + dy * dy);\n\n    const offset = 70;\n    const nx = -dy / distance;\n    const ny = dx / distance;\n\n    const cp1 = {\n      x: start.x + dx * 0.25 + nx * offset,\n      y: start.y + dy * 0.25 + ny * offset\n    };\n\n    const cp2 = {\n      x: start.x + dx * 0.75 + nx * offset,\n      y: start.y + dy * 0.75 + ny * offset\n    };\n\n    // Setup stroke style\n    const gradient = ctx.createLinearGradient(start.x, start.y, end.x, end.y);\n    gradient.addColorStop(0, '#93c5fd');\n    gradient.addColorStop(1, '#60a5fa');\n    ctx.strokeStyle = gradient;\n    ctx.lineWidth = 3;\n    ctx.lineCap = 'round';\n    ctx.shadowColor = 'rgba(96, 165, 250, 0.8)';\n    ctx.shadowBlur = 8;\n\n    // Draw curve line\n    ctx.beginPath();\n    ctx.moveTo(start.x, start.y);\n    ctx.bezierCurveTo(cp1.x, cp1.y, cp2.x, cp2.y, end.x, end.y);\n    ctx.stroke();\n\n    // Draw arrowhead\n    // Calculate arrowhead position (close to end, offset back by NODE_RADIUS + 5)\n    const t = 0.96;\n    // Cubic Bezier formula for t\n    function cubicBezier(t, p0, p1, p2, p3) {\n      const mt = 1 - t;\n      return mt * mt * mt * p0 + 3 * mt * mt * t * p1 + 3 * mt * t * t * p2 + t * t * t * p3;\n    }\n    const ax = cubicBezier(t, start.x, cp1.x, cp2.x, end.x);\n    const ay = cubicBezier(t, start.y, cp1.y, cp2.y, end.y);\n\n    // Derivative for angle\n    function cubicBezierDeriv(t, p0, p1, p2, p3) {\n      const mt = 1 - t;\n      return 3 * mt * mt * (p1 - p0) + 6 * mt * t * (p2 - p1) + 3 * t * t * (p3 - p2);\n    }\n    const dxArrow = cubicBezierDeriv(t, start.x, cp1.x, cp2.x, end.x);\n    const dyArrow = cubicBezierDeriv(t, start.y, cp1.y, cp2.y, end.y);\n    const angle = Math.atan2(dyArrow, dxArrow);\n\n    // Arrowhead style\n    const arrowLength = 14;\n    const arrowWidth = 9;\n\n    ctx.fillStyle = 'rgba(96, 165, 250, 0.85)';\n    ctx.shadowBlur = 12;\n\n    ctx.save();\n    ctx.translate(ax, ay);\n    ctx.rotate(angle);\n\n    // Arrowhead triangle path with a smooth shape\n    ctx.beginPath();\n    ctx.moveTo(0, 0);\n    ctx.lineTo(-arrowLength, arrowWidth / 2);\n    ctx.quadraticCurveTo(-arrowLength * 0.75, 0, -arrowLength, -arrowWidth / 2);\n    ctx.closePath();\n    ctx.fill();\n\n    ctx.restore();\n    ctx.shadowBlur = 0;\n\n    // Animated pulse traveling on curve - subtle glowing circle\n    if (progress !== null) {\n      const pulseT = progress % 1;\n\n      const pulseX = cubicBezier(pulseT, start.x, cp1.x, cp2.x, end.x);\n      const pulseY = cubicBezier(pulseT, start.y, cp1.y, cp2.y, end.y);\n\n      const pulseRadius = 7 + Math.sin(pulseT * Math.PI * 2) * 2; // pulsate radius\n\n      const pulseGradient = ctx.createRadialGradient(pulseX, pulseY, 0, pulseX, pulseY, pulseRadius);\n      pulseGradient.addColorStop(0, 'rgba(250, 250, 100, 0.9)');\n      pulseGradient.addColorStop(1, 'rgba(250, 250, 100, 0)');\n\n      ctx.fillStyle = pulseGradient;\n      ctx.beginPath();\n      ctx.arc(pulseX, pulseY, pulseRadius, 0, Math.PI * 2);\n      ctx.fill();\n    }\n  }\n\n  // Find node at mouse coordinate for hover\n  function findNodeAt(x, y) {\n    for (const node of nodes) {\n      const nx = node.x * width;\n      const ny = node.y * height;\n      const dist = Math.hypot(nx - x, ny - y);\n      if (dist <= NODE_RADIUS + 8) return node;\n    }\n    return null;\n  }\n\n  // Animation control variables\n  let animationId = null;\n  let startTime = null;\n  let paused = false;\n  let arrowAnimationProgress = 0;\n\n  function draw(time = 0) {\n    if (!startTime) startTime = time;\n    const elapsed = time - startTime;\n\n    ctx.clearRect(0, 0, width, height);\n\n    // Draw all edges with animation progress incremented\n    const pulseFrequency = 0.0015; // controls speed\n    arrowAnimationProgress += paused ? 0 : pulseFrequency * elapsed;\n    arrowAnimationProgress %= 1;\n\n    // Draw edges\n    let edgeIndex = 0;\n    for (const edge of edges) {\n      // Stagger pulses on edges\n      const progress = (arrowAnimationProgress + edgeIndex * 0.1) % 1;\n      drawDirectedEdge(\n        nodes.find(n => n.id === edge.from),\n        nodes.find(n => n.id === edge.to),\n        paused ? null : progress\n      );\n      edgeIndex++;\n    }\n\n    // Draw nodes above edges\n    for (const node of nodes) {\n      drawNode(node, hoveredNode === node);\n    }\n\n    // Request next frame\n    if (!paused) {\n      animationId = requestAnimationFrame(draw);\n    } else {\n      animationId = null;\n    }\n  }\n\n  // Hover handling\n  let hoveredNode = null;\n\n  function onMouseMove(e) {\n    const rect = canvas.getBoundingClientRect();\n    const x = e.clientX - rect.left;\n    const y = e.clientY - rect.top;\n    const node = findNodeAt(x, y);\n\n    if (node !== hoveredNode) {\n      hoveredNode = node;\n      renderTooltip(node, e.clientX, e.clientY);\n      if (!paused && !animationId) {\n        animationId = requestAnimationFrame(draw);\n      }\n    }\n  }\n\n  function renderTooltip(node, clientX, clientY) {\n    if (!node) {\n      tooltip.classList.remove('visible');\n      tooltip.setAttribute('aria-hidden', 'true');\n      return;\n    }\n    tooltip.textContent = `Node ${node.label}`;\n    tooltip.style.left = clientX + 'px';\n    tooltip.style.top = clientY + 'px';\n    tooltip.classList.add('visible');\n    tooltip.setAttribute('aria-hidden', 'false');\n  }\n\n  function onMouseLeave() {\n    hoveredNode = null;\n    renderTooltip(null);\n    if (!paused && !animationId) animationId = requestAnimationFrame(draw);\n  }\n\n  // Control buttons\n  const btnToggleArrows = document.getElementById('btn-toggle-arrows');\n  const btnReset = document.getElementById('btn-reset');\n  const header = document.querySelector('header');\n  const footer = document.querySelector('footer');\n\n  btnToggleArrows.addEventListener('click', () => {\n    paused = !paused;\n    btnToggleArrows.textContent = paused ? 'Play Arrows' : 'Pause Arrows';\n    btnToggleArrows.setAttribute('aria-pressed', paused ? 'false' : 'true');\n    if (!paused && !animationId) {\n      startTime = performance.now();\n      animationId = requestAnimationFrame(draw);\n    }\n  });\n\n  btnReset.addEventListener('click', () => {\n    arrowAnimationProgress = 0;\n    if (!paused && !animationId) {\n      startTime = performance.now();\n      animationId = requestAnimationFrame(draw);\n    }\n  });\n\n  // Init & event bindings\n  function init() {\n    resize();\n    window.addEventListener('resize', () => {\n      resize();\n      if (!paused && !animationId) {\n        animationId = requestAnimationFrame(draw);\n      } else {\n        draw(0);\n      }\n    });\n\n    canvas.addEventListener('mousemove', onMouseMove);\n    canvas.addEventListener('mouseleave', onMouseLeave);\n\n    draw(0);\n  }\n\n  document.fonts.ready.then(init);\n})();\n</script>\n</body>\n</html>"
