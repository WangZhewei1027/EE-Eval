    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SQL Database</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        \n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .header {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px;\n            text-align: center;\n        }\n        \n        .header h1 {\n            font-size: 24px;\n        }\n        \n        .main {\n            padding: 20px;\n        }\n        \n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .button:hover {\n            background-color: #3e8e41;\n        }\n        \n        .footer {\n            background-color: #f0f0f0;\n            padding: 10px;\n            text-align: center;\n        }\n        \n        .footer p {\n            margin: 0;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>SQL Database</h1>\n        </div>\n        <div class=\"main\">\n            <h2>SQL Basics</h2>\n            <p>SQL is a programming language designed for managing relational databases. It uses a query language to store, manipulate, and retrieve data.</p>\n        </div>\n        <div class=\"footer\">\n            <p>&copy; 2023 SQL Database</p>\n        </div>\n    </div>\n    <script>\n        const db = {\n            users: [\n                { id: 1, name: 'John Doe', email: 'john.doe@example.com' },\n                { id: 2, name: 'Jane Doe', email: 'jane.doe@example.com' }\n            ]\n        };\n\n        const displayUsers = () => {\n            const usersList = document.getElementById('users-list');\n            usersList.innerHTML = '';\n            db.users.forEach(user => {\n                const userHTML = `\n                    <li>\n                        <span>${user.name}</span>\n                        <span>${user.email}</span>\n                    </li>\n                `;\n                usersList.insertAdjacentHTML('beforeend', userHTML);\n            });\n        };\n\n        const addNewUser = () => {\n            const newUserForm = document.getElementById('new-user-form');\n            newUserForm.addEventListener('submit', (e) => {\n                e.preventDefault();\n                const newUser = {\n                    id: Math.floor(Math.random() * 100),\n                    name: document.getElementById('name-input').value,\n                    email: document.getElementById('email-input').value\n                };\n                db.users.push(newUser);\n                displayUsers();\n                document.getElementById('new-user-form').reset();\n            });\n        };\n\n        const displayUsersList = () => {\n            const usersList = document.getElementById('users-list');\n            usersList.innerHTML = '';\n            db.users.forEach(user => {\n                const userHTML = `\n                    <li>\n                        <span>${user.name}</span>\n                        <span>${user.email}</span>\n                    </li>\n                `;\n                usersList.insertAdjacentHTML('beforeend', userHTML);\n            });\n        };\n\n        const addNewUserForm = document.getElementById('new-user-form');\n        addNewUserForm.addEventListener('submit', (e) => {\n            e.preventDefault();\n            addNewUser();\n        });\n\n        displayUsersList();\n    </script>\n</body>\n</html>"
