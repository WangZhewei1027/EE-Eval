    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Trie Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-bottom: 10px;\n        }\n        .trie-container {\n            border: 1px solid #000;\n            padding: 20px;\n            min-height: 300px;\n            position: relative;\n        }\n        .node {\n            display: inline-block;\n            margin: 1px;\n            padding: 5px;\n            border: 1px solid #000;\n            position: relative;\n        }\n        .node-end {\n            background-color: #f0f0f0;\n        }\n        .children {\n            margin-left: 20px;\n            display: flex;\n            flex-wrap: wrap;\n        }\n        .node {\n            display: inline-block;\n            margin: 0 5px;\n        }\n        .highlight {\n            border: 2px solid red;\n        }\n        .search-results {\n            margin-top: 20px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Trie Visualization</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Trie Operations</h3>\n                <input type=\"text\" id=\"wordInput\" placeholder=\"Enter word\">\n                <button onclick=\"insertWord()\">Insert Word</button>\n                <button onclick=\"deleteWord()\">Delete Word</button>\n                <button onclick=\"searchWord()\">Search Word</button>\n                <button onclick=\"clearTrie()\">Clear Trie</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Bulk Operations</h3>\n                <textarea id=\"bulkWords\" placeholder=\"Enter multiple words, one per line\"></textarea>\n                <button onclick=\"insertBulkWords()\">Insert All</button>\n                <button onclick=\"deleteBulkWords()\">Delete All</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Auto-generation</h3>\n                <input type=\"number\" id=\"wordCount\" min=\"1\" max=\"20\" value=\"5\">\n                <button onclick=\"generateRandomWords()\">Generate Random Words</button>\n                <div>\n                    <label>\n                        <input type=\"checkbox\" id=\"autoInsert\" checked>\n                        Auto-insert generated words\n                    </label>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Visualization Options</h3>\n                <label>\n                    <input type=\"checkbox\" id=\"showCharLabels\" checked>\n                    Show character labels\n                </label>\n                <label>\n                    <input type=\"checkbox\" id=\"showEndMarkers\" checked>\n                    Show end-of-word markers\n                </label>\n                <label>\n                    <input type=\"checkbox\" id=\"compactView\">\n                    Compact view\n                </label>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Prefix Operations</h3>\n                <input type=\"text\" id=\"prefixInput\" placeholder=\"Enter prefix\">\n                <button onclick=\"findAllWithPrefix()\">Find Words with Prefix</button>\n                <button onclick=\"deletePrefix()\">Delete Prefix</button>\n                <div id=\"prefixResults\" class=\"search-results\"></div>\n            </div>\n        </div>\n        \n        <div class=\"trie-container\" id=\"trieVisualization\">\n            <p>Trie will be visualized here</p>\n        </div>\n        \n        <div class=\"operation-log\" id=\"operationLog\">\n            <h3>Operation Log</h3>\n            <div id=\"logContent\"></div>\n        </div>\n    </div>\n\n    <script>\n        class TrieNode {\n            constructor() {\n                this.children = {};\n                this.isEndOfWord = false;\n            }\n        }\n\n        class Trie {\n            constructor() {\n                this.root = new TrieNode();\n            }\n            \n            insert(word) {\n                let node = this.root;\n                for (const char of word) {\n                    if (!node.children[char]) {\n                        node.children[char] = new TrieNode();\n                    }\n                    node = node.children[char];\n                }\n                node.isEndOfWord = true;\n            }\n            \n            search(word) {\n                let node = this.root;\n                for (const char of word) {\n                    if (!node.children[char]) {\n                        return false;\n                    }\n                    node = node.children[char];\n                }\n                return node.isEndOfWord;\n            }\n            \n            startsWith(prefix) {\n                let node = this.root;\n                for (const char of prefix) {\n                    if (!node.children[char]) {\n                        return false;\n                    }\n                    node = node.children[char];\n                }\n                return true;\n            }\n            \n            delete(word) {\n                this._delete(this.root, word, 0);\n            }\n            \n            _delete(node, word, index) {\n                if (index === word.length) {\n                    if (!node.isEndOfWord) {\n                        return false;\n                    }\n                    node.isEndOfWord = false;\n                    return Object.keys(node.children).length === 0;\n                }\n                \n                const char = word[index];\n                if (!node.children[char]) {\n                    return false;\n                }\n                \n                const shouldDeleteChild = this._delete(node.children[char], word, index + 1);\n                \n                if (shouldDeleteChild) {\n                    delete node.children[char];\n                    return Object.keys(node.children).length === 0 && !node.isEndOfWord;\n                }\n                \n                return false;\n            }\n            \n            getAllWords() {\n                const words = [];\n                this._getAllWords(this.root, '', words);\n                return words;\n            }\n            \n            _getAllWords(node, currentWord, words) {\n                if (node.isEndOfWord) {\n                    words.push(currentWord);\n                }\n                \n                for (const [char, childNode] of Object.entries(node.children)) {\n                    this._getAllWords(childNode, currentWord + char, words);\n                }\n            }\n            \n            getWordsWithPrefix(prefix) {\n                let node = this.root;\n                for (const char of prefix) {\n                    if (!node.children[char]) {\n                        return [];\n                    }\n                    node = node.children[char];\n                }\n                \n                const words = [];\n                this._getAllWords(node, prefix, words);\n                return words;\n            }\n            \n            deletePrefix(prefix) {\n                if (prefix === '') return false;\n                \n                let node = this.root;\n                const path = [node];\n                \n                for (const char of prefix) {\n                    if (!node.children[char]) {\n                        return false;\n                    }\n                    node = node.children[char];\n                    path.push(node);\n                }\n                \n                // Delete the entire subtree\n                const firstChar = prefix[0];\n                if (path.length === 1) {\n                    delete this.root.children[firstChar];\n                } else {\n                    const parent = path[path.length - 2];\n                    delete parent.children[prefix[prefix.length - 1]];\n                }\n                \n                return true;\n            }\n        }\n\n        const trie = new Trie();\n        let highlightedNodes = [];\n        \n        function renderTrie() {\n            const container = document.getElementById('trieVisualization');\n            container.innerHTML = '';\n            \n            const showCharLabels = document.getElementById('showCharLabels').checked;\n            const showEndMarkers = document.getElementById('showEndMarkers').checked;\n            const compactView = document.getElementById('compactView').checked;\n            \n            function renderNode(node, currentPath = '') {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                \n                if (node.isEndOfWord && showEndMarkers) {\n                    nodeElement.classList.add('node-end');\n                }\n                \n                if (highlightedNodes.includes(currentPath)) {\n                    nodeElement.classList.add('highlight');\n                }\n                \n                if (showCharLabels && currentPath) {\n                    const charLabel = document.createElement('div');\n                    charLabel.className = 'node-char';\n                    charLabel.textContent = currentPath.slice(-1);\n                    nodeElement.appendChild(charLabel);\n                }\n                \n                if (!compactView && Object.keys(node.children).length > 0) {\n                    const childrenContainer = document.createElement('div');\n                    childrenContainer.className = 'children';\n                    \n                    for (const [char, childNode] of Object.entries(node.children)) {\n                        childrenContainer.appendChild(renderNode(childNode, currentPath + char));\n                    }\n                    \n                    nodeElement.appendChild(childrenContainer);\n                }\n                \n                return nodeElement;\n            }\n            \n            container.appendChild(renderNode(trie.root));\n            \n            if (compactView) {\n                const words = trie.getAllWords();\n                const wordsContainer = document.createElement('div');\n                wordsContainer.className = 'words-list';\n                \n                words.forEach(word => {\n                    const wordElement = document.createElement('div');\n                    wordElement.className = 'word';\n                    wordElement.textContent = word;\n                    if (highlightedNodes.includes(word)) {\n                        wordElement.classList.add('highlight');\n                    }\n                    wordsContainer.appendChild(wordElement);\n                });\n                \n                container.appendChild(wordsContainer);\n            }\n        }\n        \n        function logOperation(message) {\n            const logContent = document.getElementById('logContent');\n            const entry = document.createElement('div');\n            entry.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;\n            logContent.prepend(entry);\n        }\n        \n        function insertWord() {\n            const word = document.getElementById('wordInput').value.trim();\n            if (!word) return;\n            \n            trie.insert(word);\n            logOperation(`Inserted word: \"${word}\"`);\n            renderTrie();\n        }\n        \n        function deleteWord() {\n            const word = document.getElementById('wordInput').value.trim();\n            if (!word) return;\n            \n            if (trie.search(word)) {\n                trie.delete(word);\n                logOperation(`Deleted word: \"${word}\"`);\n            } else {\n                logOperation(`Word not found: \"${word}\"`);\n            }\n            renderTrie();\n        }\n        \n        function searchWord() {\n            const word = document.getElementById('wordInput').value.trim();\n            if (!word) return;\n            \n            highlightedNodes = [];\n            let node = trie.root;\n            let currentPath = '';\n            \n            for (const char of word) {\n                if (!node.children[char]) {\n                    logOperation(`Search failed for: \"${word}\" (stopped at \"${currentPath}\")`);\n                    renderTrie();\n                    return;\n                }\n                currentPath += char;\n                highlightedNodes.push(currentPath);\n                node = node.children[char];\n            }\n            \n            if (node.isEndOfWord) {\n                logOperation(`Found word: \"${word}\"`);\n                highlightedNodes.push(word);\n            } else {\n                logOperation(`Prefix found but not complete word: \"${word}\"`);\n            }\n            \n            renderTrie();\n        }\n        \n        function clearTrie() {\n            trie.root = new TrieNode();\n            highlightedNodes = [];\n            logOperation('Cleared entire trie');\n            renderTrie();\n        }\n        \n        function insertBulkWords() {\n            const bulkText = document.getElementById('bulkWords').value.trim();\n            if (!bulkText) return;\n            \n            const words = bulkText.split('\\n').map(w => w.trim()).filter(w => w);\n            words.forEach(word => trie.insert(word));\n            \n            logOperation(`Inserted ${words.length} words from bulk input`);\n            renderTrie();\n        }\n        \n        function deleteBulkWords() {\n            const bulkText = document.getElementById('bulkWords').value.trim();\n            if (!bulkText) return;\n            \n            const words = bulkText.split('\\n').map(w => w.trim()).filter(w => w);\n            let deletedCount = 0;\n            \n            words.forEach(word => {\n                if (trie.search(word)) {\n                    trie.delete(word);\n                    deletedCount++;\n                }\n            });\n            \n            logOperation(`Deleted ${deletedCount} words from bulk input`);\n            renderTrie();\n        }\n        \n        function generateRandomWords() {\n            const count = parseInt(document.getElementById('wordCount').value) || 5;\n            const words = [];\n            const chars = 'abcdefghijklmnopqrstuvwxyz';\n            \n            for (let i = 0; i < count; i++) {\n                const length = Math.floor(Math.random() * 5) + 3;\n                let word = '';\n                for (let j = 0; j < length; j++) {\n                    word += chars[Math.floor(Math.random() * chars.length)];\n                }\n                words.push(word);\n            }\n            \n            document.getElementById('bulkWords').value = words.join('\\n');\n            if (document.getElementById('autoInsert').checked) {\n                insertBulkWords();\n            } else {\n                logOperation(`Generated ${count} random words`);\n            }\n        }\n        \n        function findAllWithPrefix() {\n            const prefix = document.getElementById('prefixInput').value.trim();\n            if (!prefix) return;\n            \n            const words = trie.getWordsWithPrefix(prefix);\n            const resultsDiv = document.getElementById('prefixResults');\n            resultsDiv.innerHTML = '';\n            \n            if (words.length > 0) {\n                resultsDiv.textContent = `Words with prefix \"${prefix}\": ${words.join(', ')}`;\n                logOperation(`Found ${words.length} words with prefix \"${prefix}\"`);\n                \n                // Highlight the prefix path\n                highlightedNodes = [];\n                let node = trie.root;\n                let currentPath = '';\n                \n                for (const char of prefix) {\n                    if (!node.children[char]) break;\n                    currentPath += char;\n                    highlightedNodes.push(currentPath);\n                    node = node.children[char];\n                }\n            } else {\n                resultsDiv.textContent = `No words found with prefix \"${prefix}\"`;\n                logOperation(`No words found with prefix \"${prefix}\"`);\n            }\n            \n            renderTrie();\n        }\n        \n        function deletePrefix() {\n            const prefix = document.getElementById('prefixInput').value.trim();\n            if (!prefix) return;\n            \n            if (trie.deletePrefix(prefix)) {\n                logOperation(`Deleted all words starting with prefix: \"${prefix}\"`);\n            } else {\n                logOperation(`No words found with prefix: \"${prefix}\"`);\n            }\n            \n            document.getElementById('prefixResults').textContent = '';\n            renderTrie();\n        }\n        \n        // Initialize with some sample words\n        trie.insert('apple');\n        trie.insert('app');\n        trie.insert('application');\n        trie.insert('banana');\n        trie.insert('band');\n        trie.insert('bandana');\n        trie.insert('cat');\n        trie.insert('category');\n        trie.insert('dog');\n        renderTrie();\n        logOperation('Initialized with sample words');\n        \n        // Set up event handlers for visualization options\n        document.getElementById('showCharLabels').addEventListener('change', renderTrie);\n        document.getElementById('showEndMarkers').addEventListener('change', renderTrie);\n        document.getElementById('compactView').addEventListener('change', renderTrie);\n    </script>\n</body>\n</html>"
  },
