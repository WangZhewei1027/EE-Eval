  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Hash Table Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    background: white;\n    color: black;\n  }\n  input[type=number], input[type=text] {\n    width: 120px;\n  }\n  button {\n    margin: 2px 4px 2px 0;\n  }\n  .section {\n    margin-top: 15px;\n    margin-bottom: 15px;\n    border-top: 1px solid black;\n    padding-top: 10px;\n  }\n  label {\n    margin-right: 8px;\n  }\n  textarea {\n    width: 100%;\n    height: 120px;\n    font-family: monospace;\n  }\n  .small-input {\n    width: 50px;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 5px;\n  }\n  th, td {\n    border: 1px solid black;\n    padding: 4px 6px;\n    text-align: center;\n    font-size: 13px;\n  }\n  .status {\n    margin-top: 10px;\n    white-space: pre-line;\n    font-family: monospace;\n  }\n</style>\n</head>\n<body>\n<h1>Hash Table Interactive Demo</h1>\n\n<div class=\"section\" id=\"hashInitSection\">\n  <label for=\"tableSizeInput\">Table Size (number of buckets):</label>\n  <input type=\"number\" id=\"tableSizeInput\" min=\"1\" max=\"499\" value=\"11\" />\n  <button id=\"initTableBtn\">Initialize Hash Table</button>\n  <br />\n  <small>Note: Keeping table size prime improves distribution quality.</small>\n</div>\n\n<div class=\"section\" id=\"hashFunctionSection\" style=\"display:none;\">\n  <b>Hash Function Setup</b><br/>\n  <label for=\"hashFunctionSelect\">Choose a hash function:</label>\n  <select id=\"hashFunctionSelect\">\n    <option value=\"mod\">Simple mod of integer (key % size)</option>\n    <option value=\"folding\">Folding Method for strings</option>\n    <option value=\"sumChars\">Sum char codes mod size (for strings)</option>\n    <option value=\"customMath\">Custom math hash (key treated as number)</option>\n  </select>\n  <button id=\"setHashFunctionBtn\">Set Hash Function</button><br/>\n  <div id=\"hashFunctionDesc\" style=\"margin-top:5px; white-space: pre-wrap;\"></div>\n</div>\n\n<div class=\"section\" id=\"collisionSection\" style=\"display:none;\">\n  <b>Collision Resolution Method</b><br/>\n  <label><input type=\"radio\" name=\"collisionMethod\" value=\"chaining\" checked /> Separate Chaining</label>\n  <label><input type=\"radio\" name=\"collisionMethod\" value=\"linear\" /> Linear Probing</label>\n  <label><input type=\"radio\" name=\"collisionMethod\" value=\"quadratic\" /> Quadratic Probing</label>\n  <label><input type=\"radio\" name=\"collisionMethod\" value=\"double\" /> Double Hashing</label>\n  <button id=\"setCollisionMethodBtn\">Apply Collision Method</button>\n  <br /><br />\n  <div id=\"doubleHashInput\" style=\"display:none;\">\n    <label for=\"doubleHashPrime\">Double Hash Prime (less than table size):</label>\n    <input type=\"number\" id=\"doubleHashPrime\" min=\"2\" />\n    <button id=\"setDoubleHashPrimeBtn\">Set Double Hash Prime</button>\n  </div>\n</div>\n\n<div class=\"section\" id=\"keyOperationsSection\" style=\"display:none;\">\n  <b>Insert / Search / Delete Keys</b><br/>\n\n  <label for=\"keyInput\">Key:</label>\n  <input type=\"text\" id=\"keyInput\" placeholder=\"Enter key (string or int)\" />\n  <button id=\"insertKeyBtn\">Insert Key</button>\n  <button id=\"searchKeyBtn\">Search Key</button>\n  <button id=\"deleteKeyBtn\">Delete Key</button>\n  <button id=\"clearAllBtn\" style=\"margin-left:20px;\">Clear Hash Table</button>\n  <br/>\n  <small>Keys are treated as strings. Integer keys affect some hash functions.</small>\n</div>\n\n<div class=\"section\" id=\"tableViewSection\" style=\"display:none;\">\n  <b>Current Hashtable State</b><br/>\n  <div id=\"hashTableDisplay\" style=\"overflow-x:auto;\"></div>\n</div>\n\n<div class=\"section\" id=\"statisticsSection\" style=\"display:none;\">\n  <b>Statistics & Metrics</b><br/>\n  <div id=\"statisticsDisplay\" style=\"white-space: pre-wrap; font-family: monospace;\"></div>\n</div>\n\n<div class=\"section\" id=\"explorationSection\" style=\"display:none;\">\n  <b>Deep Exploration / Testing</b><br/>\n  <label for=\"bulkKeysInput\">Bulk Insert Keys (comma or newline separated):</label><br/>\n  <textarea id=\"bulkKeysInput\" placeholder=\"e.g. key1,key2,key3 or 123\\n456\\n789\"></textarea><br/>\n  <button id=\"bulkInsertBtn\">Bulk Insert</button>\n  <button id=\"bulkDeleteBtn\">Bulk Delete</button><br/><br/>\n\n  <button id=\"randomInsertBtn\">Random Insert (Random int keys)</button>\n  <input type=\"number\" id=\"randomCount\" min=\"1\" max=\"500\" value=\"10\" style=\"width:50px\" /> keys, range:\n  <input type=\"number\" id=\"randomMin\" value=\"0\" style=\"width:60px\" />\n  to\n  <input type=\"number\" id=\"randomMax\" value=\"999\" style=\"width:60px\" />\n  <br/><br/>\n\n  <button id=\"loadPresetBtn\">Load Preset Test Data</button>\n  <button id=\"clearStatsBtn\">Reset Stats</button><br/><br/>\n\n  <b>Resize Table</b><br/>\n  <label for=\"newTableSizeInput\">New Table Size:</label>\n  <input type=\"number\" id=\"newTableSizeInput\" min=\"1\" max=\"499\" value=\"23\" />\n  <button id=\"resizeTableBtn\">Resize Table (Rehash all keys)</button>\n  <br/><small>Note: Resizing requires rehashing all keys.</small>\n</div>\n\n<div class=\"section\" id=\"logSection\" style=\"display:none;\">\n  <b>Operation Log / Details</b><br/>\n  <textarea id=\"operationLog\" readonly></textarea><br/>\n  <button id=\"clearLogBtn\">Clear Log</button>\n</div>\n\n<script>\n(() => {\n  // --- internal state ---\n  let tableSize = 11;\n  let collisionMethod = 'chaining';\n  let doubleHashPrime = null;\n  // hashTable structure depends on collision method:\n  // - chaining: array of arrays (linked lists)\n  // - linear, quadratic, double: array of entries or null\n  let hashTable = null; \n  // for probing methods, store null or {key:string, originalKey:string}\n  // statistics\n  let stats = {\n    insertions: 0,\n    searches: 0,\n    deletions: 0,\n    collisions: 0,\n    maxProbeLength: 0,\n    totalProbeCount: 0,\n    operationsLog: [],\n  };\n\n  // helper: all keys inserted - for resizing\n  let storedKeys = [];\n\n  // --- hash functions ---\n  // returns a number mod tableSize\n  function hash_mod(key) {\n    if (/^-?\\d+$/.test(key)) {\n      return (parseInt(key,10) % tableSize + tableSize) % tableSize;\n    }\n    else {\n      let codeSum = 0;\n      for (let i=0; i<key.length; i++) {\n        codeSum += key.charCodeAt(i);\n      }\n      return codeSum % tableSize;\n    }\n  }\n  // sum char codes mod table size\n  function hash_sumChars(key) {\n    let sum = 0;\n    for (let i=0; i<key.length; i++) sum += key.charCodeAt(i);\n    return sum % tableSize;\n  }\n  // string folding method\n  // break string into groups of 4 chars, combine char codes as 32bit int, sum all groups mod tableSize\n  function hash_folding(key) {\n    let sum = 0;\n    for (let i=0; i<key.length; i+=4) {\n      let chunk = key.substring(i, i+4);\n      let val = 0;\n      for (let j=0; j<chunk.length; j++) {\n        val = (val << 8) + chunk.charCodeAt(j);\n      }\n      sum += val;\n    }\n    return (sum % tableSize + tableSize) % tableSize;\n  }\n  // custom math hash treating key as integer with a simple multiply and mod\n  function hash_customMath(key) {\n    if (!/^-?\\d+$/.test(key)) return hash_sumChars(key);\n    let n = parseInt(key, 10);\n    n = ((n * 2654435761) >>> 0) % tableSize; // Knuth's multiplicative method simplified\n    return n;\n  }\n\n  let currentHashFunction = hash_mod;\n  function describeHashFunction(name) {\n    switch(name) {\n      case 'mod': return 'Simple modulo hashing:\\nInteger keys: key % tableSize\\nStrings: sum of char codes % tableSize';\n      case 'folding': return 'Folding method:\\nBreak string into 4-char chunks,\\ncombine chunks as integers,\\nsum and mod tableSize';\n      case 'sumChars': return 'Sum of all character codes modulo table size.';\n      case 'customMath': return 'Custom math for integer keys:\\nMultiply key by a prime constant and mod table size.\\nStrings fallback to sumChars.';\n      default: return 'No description';\n    }\n  }\n\n  // --- utilities ---\n  // Check prime (simple, for table size)\n  function isPrime(n) {\n    if (n < 2) return false;\n    if (n === 2) return true;\n    if (n % 2 === 0) return false;\n    for (let i=3; i<=Math.sqrt(n); i+=2) {\n      if (n % i === 0) return false;\n    }\n    return true;\n  }\n\n  // Next prime >= n\n  function nextPrime(n) {\n    while(!isPrime(n)) n++;\n    return n;\n  }\n\n  // safe parse int\n  function tryParseInt(str) {\n    let val = parseInt(str, 10);\n    return isNaN(val) ? null : val;\n  }\n\n  // Log operation\n  function logOp(str) {\n    stats.operationsLog.push(str);\n    updateOperationLog();\n  }\n\n  // clear UI log\n  function clearOpLog() {\n    stats.operationsLog = [];\n    updateOperationLog();\n  }\n\n  // --- collision resolution & basic table impl ---\n  // Insert and Search interface:\n  // For chaining: array of arrays\n  // For probing: array of entries or null\n\n  // Utilities for probing methods\n  // Returns probing sequence as array of indices for given key and collisionMethod\n  function probeSequence(key) {\n    let hash1 = currentHashFunction(key);\n    if (collisionMethod === 'linear') {\n      let seq = [];\n      for (let i=0; i < tableSize; i++) {\n        seq.push((hash1 + i) % tableSize);\n      }\n      return seq;\n    }\n    else if (collisionMethod === 'quadratic') {\n      let seq = [];\n      for (let i=0; i < tableSize; i++) {\n        let idx = (hash1 + i*i) % tableSize;\n        seq.push(idx);\n      }\n      return seq;\n    }\n    else if (collisionMethod === 'double') {\n      if (doubleHashPrime === null || doubleHashPrime >= tableSize) return null;\n      // secondary hash, must not be 0\n      function secondaryHash(k) {\n        if (/^-?\\d+$/.test(k)) {\n          let val = parseInt(k,10);\n          let res = doubleHashPrime - (val % doubleHashPrime + doubleHashPrime) % doubleHashPrime;\n          return res === 0 ? 1 : res;\n        }\n        else {\n          let sum = 0;\n          for (let i=0; i<k.length; i++) sum += k.charCodeAt(i);\n          let res = doubleHashPrime - (sum % doubleHashPrime);\n          return res===0 ? 1 : res;\n        }\n      }\n      let hash2 = secondaryHash(key);\n      let seq = [];\n      for (let i=0; i < tableSize; i++) {\n        seq.push((hash1 + i * hash2) % tableSize);\n      }\n      return seq;\n    }\n    else { // chaining or unknown\n      return [hash1];\n    }\n  }\n\n  // Insert key into hashTable (returns true if inserted, false if failed)\n  // For probing methods: if key exists, no duplicate insert, report as \"already present\"\n  function insertKey(key) {\n    key = key.trim();\n    if (key.length === 0) return false;\n    stats.insertions++;\n    if (collisionMethod === 'chaining') {\n      let idx = currentHashFunction(key);\n      let chain = hashTable[idx];\n      for (let item of chain) {\n        if (item === key) {\n          logOp(`Insert \"${key}\": Already present at chain[${idx}]`);\n          return false; // already present\n        }\n      }\n      if (chain.length > 0) stats.collisions++;\n      chain.push(key);\n      storedKeys.push(key);\n      logOp(`Insert \"${key}\": Inserted into chain[${idx}]. Chain length is now ${chain.length}`);\n      return true;\n    }\n    else {\n      // probing methods\n      let seq = probeSequence(key);\n      if (!seq) {\n        logOp(`Insert \"${key}\": Invalid double hashing configuration.`);\n        return false;\n      }\n      for (let i=0; i<seq.length; i++) {\n        let idx = seq[i];\n        let entry = hashTable[idx];\n        if (entry === null) {\n          hashTable[idx] = key;\n          storedKeys.push(key);\n          if (i > 0) {\n            stats.collisions++;\n            if (i > stats.maxProbeLength) stats.maxProbeLength = i;\n          }\n          stats.totalProbeCount += i+1;\n          logOp(`Insert \"${key}\": Inserted at index ${idx} after ${i} probes.`);\n          return true;\n        }\n        else if (entry === key) {\n          logOp(`Insert \"${key}\": Already present at index ${idx}.`);\n          return false;\n        }\n      }\n      logOp(`Insert \"${key}\": Table full, insertion failed.`);\n      return false;\n    }\n  }\n\n  // Search key, returns {found:boolean, index:number or null, probes:number}\n  function searchKey(key) {\n    key = key.trim();\n    if (key.length === 0) return {found:false, index:null, probes:0};\n    stats.searches++;\n    if (collisionMethod === 'chaining') {\n      let idx = currentHashFunction(key);\n      let chain = hashTable[idx];\n      let probes = 1;\n      for (let item of chain) {\n        if (item === key) {\n          logOp(`Search \"${key}\": Found in chain[${idx}] after ${probes} probes.`);\n          return {found:true, index:idx, probes:probes};\n        }\n        probes++;\n      }\n      logOp(`Search \"${key}\": Not found in chain[${idx}] after ${chain.length} probes.`);\n      return {found:false, index:idx, probes:probes - 1};\n    }\n    else {\n      let seq = probeSequence(key);\n      if (!seq) {\n        logOp(`Search \"${key}\": Invalid double hashing config.`);\n        return {found:false, index:null, probes:0};\n      }\n      for (let i=0; i<seq.length; i++) {\n        let idx = seq[i];\n        let entry = hashTable[idx];\n        if (entry === null) {\n          logOp(`Search \"${key}\": Not found, empty slot at index ${idx} after ${i+1} probes.`);\n          return {found:false, index:null, probes:i+1};\n        }\n        else if (entry === key) {\n          logOp(`Search \"${key}\": Found at index ${idx} after ${i+1} probes.`);\n          if (i > stats.maxProbeLength) stats.maxProbeLength = i;\n          stats.totalProbeCount += i+1;\n          return {found:true, index:idx, probes:i+1};\n        }\n      }\n      logOp(`Search \"${key}\": Not found in entire table after full probing.`);\n      return {found:false, index:null, probes:tableSize};\n    }\n  }\n\n  // Delete key, returns true if deleted, false if not found\n  // For probing: to keep probing correct, deleted slots get special tombstone value (e.g. a fixed object)\n  const DELETED = '__DELETED__';\n\n  function deleteKey(key) {\n    key = key.trim();\n    if (key.length === 0) return false;\n    stats.deletions++;\n    if (collisionMethod === 'chaining') {\n      let idx = currentHashFunction(key);\n      let chain = hashTable[idx];\n      for (let i=0; i < chain.length; i++) {\n        if (chain[i] === key) {\n          chain.splice(i,1);\n          // remove from storedKeys\n          let si = storedKeys.indexOf(key);\n          if (si >= 0) storedKeys.splice(si,1);\n          logOp(`Delete \"${key}\": Removed from chain[${idx}].`);\n          return true;\n        }\n      }\n      logOp(`Delete \"${key}\": Not found in chain[${idx}].`);\n      return false;\n    }\n    else {\n      let seq = probeSequence(key);\n      if (!seq) {\n        logOp(`Delete \"${key}\": Invalid double hashing config.`);\n        return false;\n      }\n      for (let i=0; i<seq.length; i++) {\n        let idx = seq[i];\n        let entry = hashTable[idx];\n        if (entry === null) {\n          logOp(`Delete \"${key}\": Not found, empty slot at index ${idx}.`);\n          return false;\n        }\n        else if (entry === key) {\n          hashTable[idx] = DELETED;\n          let si = storedKeys.indexOf(key);\n          if (si >= 0) storedKeys.splice(si,1);\n          logOp(`Delete \"${key}\": Marked deleted at index ${idx}.`);\n          return true;\n        }\n      }\n      logOp(`Delete \"${key}\": Not found after full probe.`);\n      return false;\n    }\n  }\n\n  // Clear table and stats\n  function clearTable() {\n    stats = {\n      insertions: 0,\n      searches: 0,\n      deletions: 0,\n      collisions: 0,\n      maxProbeLength: 0,\n      totalProbeCount: 0,\n      operationsLog: [],\n    };\n    storedKeys = [];\n    if (collisionMethod === 'chaining') {\n      hashTable = new Array(tableSize);\n      for (let i=0; i<tableSize; i++) hashTable[i] = [];\n    }\n    else {\n      hashTable = new Array(tableSize).fill(null);\n    }\n    updateOperationLog();\n  }\n\n  // Rehash all stored keys into new table\n  function rehashAll() {\n    let keysCopy = storedKeys.slice();\n    clearTable();\n    let inserted = 0;\n    for (let key of keysCopy) {\n      let success = insertKey(key);\n      if (success) inserted++;\n    }\n    logOp(`Rehash completed. Reinserted ${inserted} keys.`);\n  }\n\n  // --- UI updates ---\n  function updateHashTableDisplay() {\n    let container = document.getElementById('hashTableDisplay');\n    container.innerHTML = '';\n    let tbl = document.createElement('table');\n    let thead = document.createElement('thead');\n    let thr = document.createElement('tr');\n    let hidx = document.createElement('th');\n    hidx.textContent = 'Index';\n    let hdata = document.createElement('th');\n    hdata.textContent = 'Content';\n    thr.appendChild(hidx);\n    thr.appendChild(hdata);\n    thead.appendChild(thr);\n    tbl.appendChild(thead);\n    let tbody = document.createElement('tbody');\n\n    if (collisionMethod === 'chaining') {\n      for (let i=0; i<tableSize; i++) {\n        let tr = document.createElement('tr');\n        let tdidx = document.createElement('td');\n        tdidx.textContent = i;\n        let tddata = document.createElement('td');\n        tddata.textContent = hashTable[i].length === 0 ? '(empty)' : hashTable[i].join(' -> ');\n        tr.appendChild(tdidx);\n        tr.appendChild(tddata);\n        tbody.appendChild(tr);\n      }\n    }\n    else {\n      for (let i=0; i<tableSize; i++) {\n        let tr = document.createElement('tr');\n        let tdidx = document.createElement('td');\n        tdidx.textContent = i;\n        let tddata = document.createElement('td');\n        let val = hashTable[i];\n        if (val === null) tddata.textContent = '(empty)';\n        else if (val === DELETED) tddata.textContent = '(deleted)';\n        else tddata.textContent = val;\n        tr.appendChild(tdidx);\n        tr.appendChild(tddata);\n        tbody.appendChild(tr);\n      }\n    }\n    tbl.appendChild(tbody);\n    container.appendChild(tbl);\n  }\n\n  function updateStatisticsDisplay() {\n    let container = document.getElementById('statisticsDisplay');\n    let loadFactor;\n    if (collisionMethod === 'chaining') {\n      let totalItems = 0;\n      for (let chain of hashTable) totalItems += chain.length;\n      loadFactor = (totalItems/tableSize).toFixed(3);\n    }\n    else {\n      let totalItems = 0;\n      for (let v of hashTable) if (v !== null && v !== DELETED) totalItems++;\n      loadFactor = (totalItems/tableSize).toFixed(3);\n    }\n    let avgProbe = stats.searches > 0 ? (stats.totalProbeCount / stats.searches).toFixed(3) : '0';\n    let s = '';\n    s += `Table Size (Buckets): ${tableSize}\\n`;\n    s += `Collision Method: ${collisionMethod}\\n`;\n    s += `Load Factor (approx): ${loadFactor}\\n`;\n    s += `Total Insertions: ${stats.insertions}\\n`;\n    s += `Total Searches: ${stats.searches}\\n`;\n    s += `Total Deletions: ${stats.deletions}\\n`;\n    s += `Total Collisions Encountered: ${stats.collisions}\\n`;\n    s += `Max Probe Length Seen (if probing): ${stats.maxProbeLength}\\n`;\n    s += `Average Probes per Search (if probing): ${avgProbe}\\n`;\n    s += `Total Keys Stored: ${storedKeys.length}\\n`;\n    container.textContent = s;\n  }\n\n  function updateOperationLog() {\n    let ta = document.getElementById('operationLog');\n    ta.value = stats.operationsLog.slice(-100).join('\\n');\n    ta.scrollTop = ta.scrollHeight;\n  }\n\n  // --- event handlers ---\n  function onInitializeTable() {\n    let val = tryParseInt(document.getElementById('tableSizeInput').value);\n    if (!val || val < 1 || val > 499) {\n      alert('Invalid table size. Must be between 1 and 499.');\n      return;\n    }\n    tableSize = val;\n    // keep doubleHashPrime reset\n    doubleHashPrime = null;\n    collisionMethod = 'chaining';\n\n    // use chaining as default\n    let collisionRadios = document.getElementsByName('collisionMethod');\n    collisionRadios.forEach(r => { if (r.value === 'chaining') r.checked = true; });\n\n    if (collisionMethod === 'chaining') {\n      hashTable = new Array(tableSize);\n      for (let i=0; i<tableSize; i++) hashTable[i] = [];\n    }\n    else {\n      hashTable = new Array(tableSize).fill(null);\n    }\n    currentHashFunction = hash_mod;\n\n    // show next section\n    document.getElementById('hashFunctionSection').style.display = 'block';\n    document.getElementById('collisionSection').style.display = 'none';\n    document.getElementById('keyOperationsSection').style.display = 'none';\n    document.getElementById('tableViewSection').style.display = 'none';\n    document.getElementById('statisticsSection').style.display = 'none';\n    document.getElementById('explorationSection').style.display = 'none';\n    document.getElementById('logSection').style.display = 'none';\n\n    document.getElementById('hashFunctionSelect').value = 'mod';\n    document.getElementById('hashFunctionDesc').textContent = describeHashFunction('mod');\n    logOp(`Initialized empty hash table with size ${tableSize}, default collision chaining, default hash mod.`);\n  }\n\n  function onSetHashFunction() {\n    let hf = document.getElementById('hashFunctionSelect').value;\n    switch (hf) {\n      case 'mod': currentHashFunction = hash_mod; break;\n      case 'folding': currentHashFunction = hash_folding; break;\n      case 'sumChars': currentHashFunction = hash_sumChars; break;\n      case 'customMath': currentHashFunction = hash_customMath; break;\n      default: currentHashFunction = hash_mod;\n    }\n    document.getElementById('hashFunctionDesc').textContent = describeHashFunction(hf);\n    // Move to collision section\n    document.getElementById('collisionSection').style.display = 'block';\n    document.getElementById('keyOperationsSection').style.display = 'none';\n    document.getElementById('tableViewSection').style.display = 'none';\n    document.getElementById('statisticsSection').style.display = 'none';\n    document.getElementById('explorationSection').style.display = 'none';\n    document.getElementById('logSection').style.display = 'none';\n\n    logOp(`Hash function set to: ${hf}. Waiting for collision method selection.`);\n  }\n\n  function onCollisionMethodChange() {\n    let val = document.querySelector('input[name=collisionMethod]:checked').value;\n    if (val === 'double') {\n      document.getElementById('doubleHashInput').style.display = 'inline-block';\n      // default doubleHashPrime to smaller prime than tableSize for convenience\n      let defaultPrime = nextPrime(Math.max(2, Math.floor(tableSize/4)));\n      document.getElementById('doubleHashPrime').value = defaultPrime;\n    }\n    else {\n      document.getElementById('doubleHashInput').style.display = 'none';\n    }\n  }\n\n  function onSetCollisionMethod() {\n    let val = document.querySelector('input[name=collisionMethod]:checked').value;\n    if (val === 'double') {\n      let dHP = tryParseInt(document.getElementById('doubleHashPrime').value);\n      if (!dHP || dHP<2 || dHP>=tableSize) {\n        alert('Invalid Double Hash Prime. Must be >= 2 and less than table size.');\n        return;\n      }\n      doubleHashPrime = dHP;\n    } else {\n      doubleHashPrime = null;\n    }\n    collisionMethod = val;\n    clearTable();\n    // show all interactive sections\n    document.getElementById('keyOperationsSection').style.display = 'block';\n    document.getElementById('tableViewSection').style.display = 'block';\n    document.getElementById('statisticsSection').style.display = 'block';\n    document.getElementById('explorationSection').style.display = 'block';\n    document.getElementById('logSection').style.display = 'block';\n\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n    logOp(`Collision method set to: ${collisionMethod}, table reset.`);\n  }\n\n  function onInsertKey() {\n    let key = document.getElementById('keyInput').value;\n    if (key.trim().length === 0) {\n      alert('Please enter a key to insert.');\n      return;\n    }\n    let success = insertKey(key);\n    if (success) {\n      alert(`Key \"${key}\" inserted.`);\n    } else {\n      alert(`Key \"${key}\" was not inserted (maybe duplicate or error).`);\n    }\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n  }\n  function onSearchKey() {\n    let key = document.getElementById('keyInput').value;\n    if (key.trim().length === 0) {\n      alert('Please enter a key to search.');\n      return;\n    }\n    let res = searchKey(key);\n    if (res.found) {\n      alert(`Key \"${key}\" found after ${res.probes} probe(s).`);\n    }\n    else {\n      alert(`Key \"${key}\" NOT found after ${res.probes} probe(s).`);\n    }\n    updateStatisticsDisplay();\n  }\n  function onDeleteKey() {\n    let key = document.getElementById('keyInput').value;\n    if (key.trim().length === 0) {\n      alert('Please enter a key to delete.');\n      return;\n    }\n    let success = deleteKey(key);\n    if (success) {\n      alert(`Key \"${key}\" deleted.`);\n    } else {\n      alert(`Key \"${key}\" not found, deletion not performed.`);\n    }\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n  }\n  function onClearAll() {\n    if (!confirm('Clear entire hash table and reset stats?')) return;\n    clearTable();\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n    clearOpLog();\n  }\n\n  // Bulk insert / delete\n  function onBulkInsert() {\n    let raw = document.getElementById('bulkKeysInput').value;\n    let keys = raw.split(/[\\n,]+/).map(k => k.trim()).filter(k => k.length > 0);\n    let inserted = 0;\n    for (let k of keys) {\n      if(insertKey(k)) inserted++;\n    }\n    alert(`Bulk insert: attempted ${keys.length} keys, inserted ${inserted}.`);\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n  }\n  function onBulkDelete() {\n    let raw = document.getElementById('bulkKeysInput').value;\n    let keys = raw.split(/[\\n,]+/).map(k => k.trim()).filter(k => k.length > 0);\n    let deleted = 0;\n    for (let k of keys) {\n      if(deleteKey(k)) deleted++;\n    }\n    alert(`Bulk delete: attempted ${keys.length} keys, deleted ${deleted}.`);\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n  }\n\n  // Random insert\n  function onRandomInsert() {\n    let count = tryParseInt(document.getElementById('randomCount').value);\n    if (!count || count < 1) {\n      alert('Invalid random insert count.');\n      return;\n    }\n    let min = tryParseInt(document.getElementById('randomMin').value);\n    let max = tryParseInt(document.getElementById('randomMax').value);\n    if (min === null || max === null || min > max) {\n      alert('Invalid random range.');\n      return;\n    }\n    let inserted = 0;\n    for (let i=0; i<count; i++) {\n      let randKey = '' + (Math.floor(Math.random() * (max - min + 1)) + min);\n      if(insertKey(randKey)) inserted++;\n    }\n    alert(`Random insert: attempted ${count} keys, inserted ${inserted}.`);\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n  }\n\n  // Load preset test data\n  function onLoadPreset() {\n    let presetKeys = [\n      \"apple\", \"banana\", \"orange\", \"grape\", \"cherry\",\n      \"27\", \"42\", \"15\", \"88\", \"33\", \"7\",\n      \"key\", \"lock\", \"door\", \"window\", \"roof\",\n      \"123456\", \"654321\", \"314159\", \"271828\", \"161803\"\n    ];\n    for (let key of presetKeys) {\n      insertKey(key);\n    }\n    alert(`Loaded preset test data (${presetKeys.length} keys).`);\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n  }\n\n  // Resize table (rehash all keys)\n  function onResizeTable() {\n    let newSize = tryParseInt(document.getElementById('newTableSizeInput').value);\n    if (!newSize || newSize < 1 || newSize > 499) {\n      alert('Invalid new table size.');\n      return;\n    }\n\n    if (collisionMethod === 'double' && doubleHashPrime !== null && doubleHashPrime >= newSize) {\n      alert(`Double Hash Prime (${doubleHashPrime}) must be less than new table size (${newSize}). Adjust it first or change collision method.`);\n      return;\n    }\n\n    tableSize = newSize;\n    if (collisionMethod === 'chaining') {\n      hashTable = new Array(tableSize);\n      for (let i=0; i<tableSize; i++) hashTable[i] = [];\n    }\n    else {\n      hashTable = new Array(tableSize).fill(null);\n    }\n    rehashAll();\n    updateHashTableDisplay();\n    updateStatisticsDisplay();\n    alert(`Resized table to ${tableSize} buckets and rehashed all keys.`);\n  }\n\n  function onClearLog() {\n    clearOpLog();\n  }\n\n  // --- setup event listeners ---\n  document.getElementById('initTableBtn').addEventListener('click', onInitializeTable);\n  document.getElementById('setHashFunctionBtn').addEventListener('click', onSetHashFunction);\n  document.getElementsByName('collisionMethod').forEach(r => r.addEventListener('change', onCollisionMethodChange));\n  document.getElementById('setCollisionMethodBtn').addEventListener('click', onSetCollisionMethod);\n  document.getElementById('insertKeyBtn').addEventListener('click', onInsertKey);\n  document.getElementById('searchKeyBtn').addEventListener('click', onSearchKey);\n  document.getElementById('deleteKeyBtn').addEventListener('click', onDeleteKey);\n  document.getElementById('clearAllBtn').addEventListener('click', onClearAll);\n  document.getElementById('bulkInsertBtn').addEventListener('click', onBulkInsert);\n  document.getElementById('bulkDeleteBtn').addEventListener('click', onBulkDelete);\n  document.getElementById('randomInsertBtn').addEventListener('click', onRandomInsert);\n  document.getElementById('loadPresetBtn').addEventListener('click', onLoadPreset);\n  document.getElementById('resizeTableBtn').addEventListener('click', onResizeTable);\n  document.getElementById('clearLogBtn').addEventListener('click', onClearLog);\n  document.getElementById('setDoubleHashPrimeBtn').addEventListener('click', () => {\n    let val = tryParseInt(document.getElementById('doubleHashPrime').value);\n    if (!val || val < 2 || val >= tableSize) {\n      alert('Invalid double hash prime. Must be >= 2 and less than table size.');\n    } else {\n      doubleHashPrime = val;\n      alert(`Double hash prime set to ${doubleHashPrime}.`);\n      logOp(`Double hash prime changed to ${doubleHashPrime}.`);\n    }\n  });\n\n  // initial UI state\n  clearTable();\n  updateHashTableDisplay();\n  updateStatisticsDisplay();\n  document.getElementById('hashFunctionDesc').textContent = describeHashFunction('mod');\n\n})();\n</script>\n\n</body>\n</html>"
