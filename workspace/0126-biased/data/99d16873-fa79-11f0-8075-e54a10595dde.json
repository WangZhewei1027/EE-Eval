    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hash Functions Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #output {\n            margin-top: 20px;\n            white-space: pre-wrap;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Hash Functions Interactive Demo</h1>\n\n<div>\n    <label for=\"inputText\">Input Text:</label>\n    <input type=\"text\" id=\"inputText\" value=\"Hello World\">\n</div>\n\n<div>\n    <label for=\"hashFunction\">Select Hash Function:</label>\n    <select id=\"hashFunction\">\n        <option value=\"md5\">MD5</option>\n        <option value=\"sha256\">SHA-256</option>\n        <option value=\"sha512\">SHA-512</option>\n    </select>\n</div>\n\n<div>\n    <label for=\"customSalt\">Custom Salt:</label>\n    <input type=\"text\" id=\"customSalt\" placeholder=\"Optional Salt\">\n</div>\n\n<div>\n    <button id=\"computeHash\">Compute Hash</button>\n</div>\n\n<div id=\"output\">\n    <strong>Output:</strong>\n    <div id=\"hashOutput\"></div>\n    <div id=\"hashLength\"></div>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/crypto-js/3.1.9-1/crypto-js.js\"></script>\n<script>\n    document.getElementById('computeHash').addEventListener('click', function() {\n        const inputText = document.getElementById('inputText').value;\n        const hashFunction = document.getElementById('hashFunction').value;\n        const customSalt = document.getElementById('customSalt').value;\n        let hash;\n\n        if (customSalt) {\n            inputText += customSalt;\n        }\n\n        switch (hashFunction) {\n            case 'md5':\n                hash = CryptoJS.MD5(inputText).toString();\n                break;\n            case 'sha256':\n                hash = CryptoJS.SHA256(inputText).toString();\n                break;\n            case 'sha512':\n                hash = CryptoJS.SHA512(inputText).toString();\n                break;\n            default:\n                hash = 'Invalid hash function';\n        }\n\n        document.getElementById('hashOutput').innerText = hash;\n        document.getElementById('hashLength').innerText = 'Length: ' + hash.length;\n    });\n\n    // Enable deep exploration with additional inputs\n    const explorationDiv = document.createElement('div');\n    document.body.appendChild(explorationDiv);\n\n    function addDynamicInput() {\n        const wrapper = document.createElement('div');\n        const input = document.createElement('input');\n        const button = document.createElement('button');\n        button.textContent = 'Compute with this Input';\n        \n        button.addEventListener('click', function() {\n            const customInputText = input.value;\n            const hashFunction = document.getElementById('hashFunction').value;\n            let hash;\n\n            switch (hashFunction) {\n                case 'md5':\n                    hash = CryptoJS.MD5(customInputText).toString();\n                    break;\n                case 'sha256':\n                    hash = CryptoJS.SHA256(customInputText).toString();\n                    break;\n                case 'sha512':\n                    hash = CryptoJS.SHA512(customInputText).toString();\n                    break;\n            }\n\n            const output = document.createElement('div');\n            output.innerText = `Hash of \"${customInputText}\": ${hash} (Length: ${hash.length})`;\n            wrapper.appendChild(output);\n        });\n\n        wrapper.appendChild(input);\n        wrapper.appendChild(button);\n        explorationDiv.appendChild(wrapper);\n    }\n\n    for (let i = 0; i < 3; i++) {\n        addDynamicInput();\n    }\n</script>\n\n</body>\n</html>"
