    "content": "<html>\n<head>\n    <title>Interactive Max Heap</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        .heap-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        .heap-level {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .heap-node {\n            border: 1px solid black;\n            width: 50px;\n            height: 50px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            margin: 0 10px;\n            position: relative;\n        }\n        .heap-node.highlight {\n            background-color: #f0f0f0;\n        }\n        .heap-node.active {\n            font-weight: bold;\n            border-width: 2px;\n        }\n        .heap-node.max {\n            border-color: red;\n        }\n        .heap-lines {\n            position: absolute;\n            width: 100%;\n            height: 20px;\n            top: -20px;\n        }\n        .line-left, .line-right {\n            position: absolute;\n            width: 25px;\n            height: 20px;\n            border-top: 1px solid black;\n        }\n        .line-left {\n            left: 0;\n            border-right: 1px solid black;\n        }\n        .line-right {\n            right: 0;\n            border-left: 1px solid black;\n        }\n        .explanation {\n            margin-top: 20px;\n            border-top: 1px solid #ccc;\n            padding-top: 10px;\n        }\n        input[type=\"number\"] {\n            width: 60px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Max Heap</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Heap Operations</h3>\n                <button id=\"insert-btn\">Insert Random</button>\n                <button id=\"extract-max-btn\">Extract Max</button>\n                <button id=\"heapify-btn\">Heapify Array</button>\n                <button id=\"clear-btn\">Clear Heap</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Manual Insert</h3>\n                <input type=\"number\" id=\"insert-value\" min=\"-100\" max=\"100\" value=\"10\">\n                <button id=\"manual-insert-btn\">Insert Value</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Heap Size</h3>\n                <input type=\"range\" id=\"heap-size-slider\" min=\"0\" max=\"15\" value=\"0\">\n                <span id=\"heap-size-value\">0</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Animation Speed</h3>\n                <input type=\"range\" id=\"speed-slider\" min=\"100\" max=\"2000\" value=\"500\">\n                <span id=\"speed-value\">500ms</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Heap Array</h3>\n                <div id=\"heap-array\"></div>\n            </div>\n        </div>\n        \n        <div class=\"heap-container\" id=\"heap-visualization\">\n            <!-- Heap will be rendered here -->\n        </div>\n        \n        <div class=\"explanation\" id=\"explanation\">\n            <h3>Current Operation</h3>\n            <p>No operation in progress. Use the controls above to interact with the heap.</p>\n        </div>\n    </div>\n\n    <script>\n        class MaxHeap {\n            constructor() {\n                this.heap = [];\n                this.animationSpeed = 500;\n                this.operationInProgress = false;\n            }\n            \n            insert(value) {\n                if (this.operationInProgress) return;\n                this.operationInProgress = true;\n                \n                this.updateExplanation(`Inserting ${value} into the heap...`);\n                this.heap.push(value);\n                this.renderHeap();\n                \n                let currentIndex = this.heap.length - 1;\n                this.highlightNode(currentIndex);\n                \n                const bubbleUp = () => {\n                    if (currentIndex === 0) {\n                        this.completeOperation(`Insertion complete. ${value} is now in the heap.`);\n                        return;\n                    }\n                    \n                    const parentIndex = Math.floor((currentIndex - 1) / 2);\n                    this.highlightNode(parentIndex);\n                    \n                    setTimeout(() => {\n                        if (this.heap[currentIndex] > this.heap[parentIndex]) {\n                            this.updateExplanation(`Swapping ${this.heap[currentIndex]} with parent ${this.heap[parentIndex]}...`);\n                            [this.heap[currentIndex], this.heap[parentIndex]] = [this.heap[parentIndex], this.heap[currentIndex]];\n                            this.renderHeap();\n                            currentIndex = parentIndex;\n                            this.highlightNode(currentIndex);\n                            setTimeout(bubbleUp, this.animationSpeed);\n                        } else {\n                            this.completeOperation(`Insertion complete. ${value} is now in the heap.`);\n                        }\n                    }, this.animationSpeed);\n                };\n                \n                setTimeout(bubbleUp, this.animationSpeed);\n            }\n            \n            extractMax() {\n                if (this.operationInProgress || this.heap.length === 0) return;\n                this.operationInProgress = true;\n                \n                const maxValue = this.heap[0];\n                this.updateExplanation(`Extracting max value (${maxValue}) from the heap...`);\n                this.highlightNode(0);\n                \n                setTimeout(() => {\n                    if (this.heap.length === 1) {\n                        this.heap.pop();\n                        this.renderHeap();\n                        this.completeOperation(`Extracted max value: ${maxValue}. Heap is now empty.`);\n                        return;\n                    }\n                    \n                    this.heap[0] = this.heap.pop();\n                    this.updateExplanation(`Replaced root with ${this.heap[0]}. Now heapifying down...`);\n                    this.renderHeap();\n                    this.highlightNode(0);\n                    \n                    let currentIndex = 0;\n                    const heapifyDown = () => {\n                        const leftChildIndex = 2 * currentIndex + 1;\n                        const rightChildIndex = 2 * currentIndex + 2;\n                        let largestIndex = currentIndex;\n                        \n                        if (leftChildIndex < this.heap.length) {\n                            this.highlightNode(leftChildIndex, 'highlight');\n                        }\n                        if (rightChildIndex < this.heap.length) {\n                            this.highlightNode(rightChildIndex, 'highlight');\n                        }\n                        \n                        setTimeout(() => {\n                            if (leftChildIndex < this.heap.length && this.heap[leftChildIndex] > this.heap[largestIndex]) {\n                                largestIndex = leftChildIndex;\n                            }\n                            \n                            if (rightChildIndex < this.heap.length && this.heap[rightChildIndex] > this.heap[largestIndex]) {\n                                largestIndex = rightChildIndex;\n                            }\n                            \n                            if (largestIndex !== currentIndex) {\n                                this.updateExplanation(`Swapping ${this.heap[currentIndex]} with ${this.heap[largestIndex]}...`);\n                                [this.heap[currentIndex], this.heap[largestIndex]] = [this.heap[largestIndex], this.heap[currentIndex]];\n                                this.renderHeap();\n                                currentIndex = largestIndex;\n                                this.highlightNode(currentIndex);\n                                setTimeout(heapifyDown, this.animationSpeed);\n                            } else {\n                                this.completeOperation(`Extracted max value: ${maxValue}. Heap property restored.`);\n                            }\n                        }, this.animationSpeed);\n                    };\n                    \n                    setTimeout(heapifyDown, this.animationSpeed);\n                }, this.animationSpeed);\n            }\n            \n            heapify(array) {\n                if (this.operationInProgress) return;\n                this.operationInProgress = true;\n                \n                this.heapSize = array.length;\n                this.heap = [...array];\n                this.renderHeap();\n                this.updateExplanation(`Building max heap from array [${array.join(', ')}]...`);\n                \n                const startIdx = Math.floor(this.heap.length / 2) - 1;\n                \n                const heapifyAt = (index, callback) => {\n                    this.highlightNode(index);\n                    \n                    setTimeout(() => {\n                        const left = 2 * index + 1;\n                        const right = 2 * index + 2;\n                        let largest = index;\n                        \n                        if (left < this.heap.length) this.highlightNode(left, 'highlight');\n                        if (right < this.heap.length) this.highlightNode(right, 'highlight');\n                        \n                        setTimeout(() => {\n                            if (left < this.heap.length && this.heap[left] > this.heap[largest]) {\n                                largest = left;\n                            }\n                            \n                            if (right < this.heap.length && this.heap[right] > this.heap[largest]) {\n                                largest = right;\n                            }\n                            \n                            if (largest !== index) {\n                                this.updateExplanation(`Swapping ${this.heap[index]} with ${this.heap[largest]}...`);\n                                [this.heap[index], this.heap[largest]] = [this.heap[largest], this.heap[index]];\n                                this.renderHeap();\n                                this.highlightNode(largest);\n                                setTimeout(() => heapifyAt(largest, callback), this.animationSpeed);\n                            } else {\n                                callback();\n                            }\n                        }, this.animationSpeed);\n                    }, this.animationSpeed);\n                };\n                \n                const processIndexes = (i) => {\n                    if (i < 0) {\n                        this.completeOperation(`Heap built successfully. Max heap property satisfied.`);\n                        return;\n                    }\n                    \n                    heapifyAt(i, () => {\n                        processIndexes(i - 1);\n                    });\n                };\n                \n                processIndexes(startIdx);\n            }\n            \n            renderHeap() {\n                const container = document.getElementById('heap-visualization');\n                container.innerHTML = '';\n                \n                if (this.heap.length === 0) {\n                    container.innerHTML = '<p>Heap is empty</p>';\n                    document.getElementById('heap-array').textContent = '[]';\n                    return;\n                }\n                \n                document.getElementById('heap-array').textContent = `[${this.heap.join(', ')}]`;\n                \n                const levels = Math.ceil(Math.log2(this.heap.length + 1));\n                \n                for (let level = 0; level < levels; level++) {\n                    const levelStart = Math.pow(2, level) - 1;\n                    const levelEnd = Math.min(Math.pow(2, level + 1) - 1, this.heap.length);\n                    \n                    const levelDiv = document.createElement('div');\n                    levelDiv.className = 'heap-level';\n                    \n                    for (let i = levelStart; i < levelEnd; i++) {\n                        const node = document.createElement('div');\n                        node.className = 'heap-node';\n                        node.textContent = this.heap[i];\n                        node.dataset.index = i;\n                        \n                        if (i === 0) {\n                            node.classList.add('max');\n                        }\n                        \n                        // Add lines to children if they exist\n                        if (2 * i + 1 < this.heap.length || 2 * i + 2 < this.heap.length) {\n                            const lines = document.createElement('div');\n                            lines.className = 'heap-lines';\n                            \n                            if (2 * i + 1 < this.heap.length) {\n                                const lineLeft = document.createElement('div');\n                                lineLeft.className = 'line-left';\n                                lines.appendChild(lineLeft);\n                            }\n                            \n                            if (2 * i + 2 < this.heap.length) {\n                                const lineRight = document.createElement('div');\n                                lineRight.className = 'line-right';\n                                lines.appendChild(lineRight);\n                            }\n                            \n                            node.appendChild(lines);\n                        }\n                        \n                        levelDiv.appendChild(node);\n                    }\n                    \n                    container.appendChild(levelDiv);\n                }\n            }\n            \n            highlightNode(index, className = 'active') {\n                const nodes = document.querySelectorAll('.heap-node');\n                nodes.forEach(node => node.classList.remove('active', 'highlight'));\n                \n                if (index >= 0 && index < nodes.length) {\n                    nodes[index].classList.add(className);\n                }\n            }\n            \n            updateExplanation(text) {\n                document.getElementById('explanation').innerHTML = `\n                    <h3>Current Operation</h3>\n                    <p>${text}</p>\n                `;\n            }\n            \n            completeOperation(text) {\n                this.updateExplanation(text);\n                this.operationInProgress = false;\n                this.renderHeap();\n            }\n        }\n        \n        // Initialize heap and UI\n        const heap = new MaxHeap();\n        \n        // Event listeners\n        document.getElementById('insert-btn').addEventListener('click', () => {\n            const value = Math.floor(Math.random() * 100) + 1;\n            heap.insert(value);\n        });\n        \n        document.getElementById('manual-insert-btn').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('insert-value').value);\n            if (!isNaN(value)) {\n                heap.insert(value);\n            }\n        });\n        \n        document.getElementById('extract-max-btn').addEventListener('click', () => {\n            heap.extractMax();\n        });\n        \n        document.getElementById('heapify-btn').addEventListener('click', () => {\n            const size = parseInt(document.getElementById('heap-size-slider').value);\n            const array = [];\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * 100) + 1);\n            }\n            heap.heapify(array);\n        });\n        \n        document.getElementById('clear-btn').addEventListener('click', () => {\n            heap.heap = [];\n            heap.renderHeap();\n            heap.updateExplanation('Heap cleared.');\n        });\n        \n        document.getElementById('heap-size-slider').addEventListener('input', (e) => {\n            document.getElementById('heap-size-value').textContent = e.target.value;\n        });\n        \n        document.getElementById('speed-slider').addEventListener('input', (e) => {\n            heap.animationSpeed = parseInt(e.target.value);\n            document.getElementById('speed-value').textContent = `${e.target.value}ms`;\n        });\n        \n        // Initial render\n        heap.renderHeap();\n    </script>\n</body>\n</html>"
