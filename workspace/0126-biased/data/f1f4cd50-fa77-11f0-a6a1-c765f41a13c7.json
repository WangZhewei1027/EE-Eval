    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Hash Map — Visual Concept</title>\n  <style>\n    :root{\n      --bg-1: #071028;\n      --bg-2: #0b2a45;\n      --glass: rgba(255,255,255,0.04);\n      --accent-1: #7ee7f7;\n      --accent-2: #7ad3ff;\n      --accent-3: #7b6cff;\n      --muted: rgba(255,255,255,0.7);\n      --glass-2: rgba(255,255,255,0.03);\n      --card-shadow: 0 10px 30px rgba(2,8,23,0.6);\n      --radius: 16px;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      min-height:100vh;\n      background: radial-gradient(1200px 500px at 10% 10%, rgba(123,108,255,0.14), transparent),\n                  radial-gradient(800px 400px at 90% 80%, rgba(122,211,255,0.08), transparent),\n                  linear-gradient(180deg, var(--bg-1), var(--bg-2));\n      color: #eaf6ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n      overflow:hidden;\n    }\n\n    /* subtle animated star field */\n    .stars{\n      position:fixed; inset:0; pointer-events:none; z-index:0;\n      background-image: radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.06), transparent),\n                        radial-gradient(1px 1px at 50% 40%, rgba(255,255,255,0.04), transparent),\n                        radial-gradient(1px 1px at 80% 70%, rgba(255,255,255,0.03), transparent);\n      opacity:0.9;\n      mix-blend-mode:overlay;\n      animation: drift 12s linear infinite;\n      filter: blur(0.2px);\n    }\n    @keyframes drift{ 0%{transform:translateY(0)} 50%{transform:translateY(-8px)} 100%{transform:translateY(0)} }\n\n    .container{\n      position:relative;\n      width:1100px;\n      max-width:calc(100% - 80px);\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius: calc(var(--radius) + 6px);\n      padding:36px;\n      box-shadow: var(--card-shadow);\n      backdrop-filter: blur(6px) saturate(120%);\n      border: 1px solid rgba(255,255,255,0.04);\n      z-index:2;\n      overflow:visible;\n    }\n\n    header{\n      display:flex;\n      align-items:center;\n      gap:20px;\n      margin-bottom:18px;\n    }\n\n    .title{\n      font-size:28px;\n      line-height:1;\n      letter-spacing:0.2px;\n      font-weight:700;\n      margin:0;\n      display:flex;\n      flex-direction:column;\n    }\n    .title small{\n      font-weight:600;\n      font-size:12px;\n      color:var(--accent-2);\n      letter-spacing:1px;\n      text-transform:uppercase;\n      margin-bottom:8px;\n    }\n\n    .desc{\n      color:var(--muted);\n      font-size:13px;\n      max-width:620px;\n      margin-top:4px;\n    }\n\n    .ui-row{\n      display:flex;\n      gap:20px;\n      margin-top:18px;\n      align-items:flex-start;\n    }\n\n    /* Left card: Pool of keys */\n    .panel{\n      flex: 0 0 320px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;\n      padding:18px;\n      border:1px solid var(--glass-2);\n      box-shadow: 0 6px 20px rgba(4,10,20,0.4);\n      position:relative;\n      overflow:visible;\n    }\n\n    .panel h3{\n      margin:0 0 12px 0;\n      font-size:14px;\n      color:var(--accent-2);\n      letter-spacing:0.6px;\n    }\n\n    .pool{\n      position:relative;\n      height:320px;\n      width:100%;\n      border-radius:8px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px dashed rgba(255,255,255,0.03);\n      padding:14px;\n      display:flex;\n      flex-wrap:wrap;\n      gap:10px;\n      align-content:flex-start;\n      overflow:visible;\n    }\n\n    .chip{\n      position:relative;\n      display:inline-flex;\n      align-items:center;\n      gap:8px;\n      height:40px;\n      padding:0 14px;\n      border-radius:999px;\n      background:linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border:1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 6px 18px rgba(2,8,23,0.45), inset 0 -6px 14px rgba(255,255,255,0.02);\n      transition: transform 0.25s ease, box-shadow 0.25s ease;\n      color:var(--muted);\n      font-weight:600;\n      font-size:13px;\n      cursor:default;\n      user-select:none;\n    }\n    .chip .dot{\n      width:12px; height:12px; border-radius:50%;\n      background:linear-gradient(180deg,var(--accent-1),var(--accent-2));\n      box-shadow: 0 6px 14px rgba(122,211,255,0.08), 0 0 14px rgba(122,211,255,0.12);\n      flex:0 0 12px;\n    }\n    .chip:hover{ transform: translateY(-4px); box-shadow: 0 10px 30px rgba(2,8,23,0.55); }\n\n    /* central visual: hash function */\n    .center{\n      position:relative;\n      flex:1;\n      min-height:380px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color:var(--muted);\n    }\n\n    .hash-card{\n      position:relative;\n      width:100%;\n      height:100%;\n      border-radius:16px;\n      padding:28px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      background: linear-gradient(135deg, rgba(123,108,255,0.06), rgba(122,211,255,0.02));\n      border:1px solid rgba(255,255,255,0.02);\n      box-shadow: inset 0 -40px 140px rgba(6,12,28,0.18);\n    }\n\n    .morph{\n      width:650px;\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:18px;\n    }\n\n    .box{\n      flex:0 0 220px;\n      height:220px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      align-items:center;\n      justify-content:center;\n      padding:16px;\n      position:relative;\n      color:var(--muted);\n      box-shadow: 0 12px 30px rgba(2,8,23,0.4);\n    }\n\n    .box h4{\n      margin:0;\n      font-size:13px;\n      color: var(--accent-2);\n      letter-spacing:0.8px;\n      margin-bottom:10px;\n      text-transform:uppercase;\n    }\n\n    .fhash{\n      font-weight:800;\n      font-size:54px;\n      letter-spacing:-1px;\n      background: linear-gradient(90deg, var(--accent-1), var(--accent-3));\n      -webkit-background-clip: text;\n      background-clip:text;\n      color:transparent;\n      text-shadow: 0 6px 18px rgba(123,108,255,0.12);\n    }\n\n    .arrow{\n      width:160px;\n      height:64px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n    }\n\n    .arrow svg{ width:100%; height:100%; filter:drop-shadow(0 8px 18px rgba(7,20,40,0.45)); }\n\n    /* Right: buckets */\n    .buckets{\n      flex: 0 0 360px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border-radius:12px;\n      padding:18px;\n      border:1px solid var(--glass-2);\n      box-shadow: 0 6px 20px rgba(4,10,20,0.4);\n      position:relative;\n      height:380px;\n      overflow:hidden;\n    }\n\n    .buckets h3{\n      margin:0 0 12px 0;\n      font-size:14px;\n      color:var(--accent-3);\n      letter-spacing:0.6px;\n    }\n\n    .bucket-list{\n      display:flex;\n      gap:8px;\n      flex-direction:column;\n      align-items:stretch;\n      height:100%;\n      padding:8px;\n    }\n\n    .bucket{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      padding:10px;\n      border-radius:12px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.015), rgba(255,255,255,0.007));\n      border:1px solid rgba(255,255,255,0.02);\n      box-shadow: 0 8px 20px rgba(2,8,23,0.28);\n      transition: transform 0.2s ease;\n      position:relative;\n    }\n    .bucket:hover{ transform: translateY(-6px); }\n\n    .index{\n      width:60px; height:60px; border-radius:10px;\n      display:flex; align-items:center; justify-content:center;\n      font-weight:700; font-size:18px;\n      color:var(--muted);\n      background: linear-gradient(180deg, rgba(255,255,255,0.008), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      box-shadow: inset 0 -4px 12px rgba(255,255,255,0.02);\n      flex:0 0 60px;\n    }\n\n    .values{\n      display:flex; gap:8px; flex-wrap:wrap; align-items:center;\n      color:var(--muted);\n      font-weight:600;\n    }\n\n    .values .chip{\n      height:34px; padding:0 12px; font-size:13px;\n      box-shadow: 0 6px 18px rgba(2,8,23,0.45), inset 0 -6px 10px rgba(255,255,255,0.02);\n    }\n\n    /* svg overlay for lines */\n    svg.overlay{\n      position:absolute; inset:0; z-index:1; pointer-events:none;\n      overflow:visible;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      margin-left:auto;\n    }\n    .btn{\n      border:0;\n      padding:10px 16px;\n      border-radius:10px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:var(--accent-1);\n      font-weight:700;\n      letter-spacing:0.6px;\n      cursor:pointer;\n      box-shadow: 0 8px 18px rgba(2,8,23,0.36);\n      transition: transform 0.18s ease, opacity 0.18s ease;\n      border: 1px solid rgba(122,211,255,0.06);\n    }\n    .btn:active{ transform: translateY(2px); }\n    .btn.primary{\n      background: linear-gradient(90deg, rgba(122,211,255,0.12), rgba(123,108,255,0.08));\n      color:white;\n      border: 1px solid rgba(255,255,255,0.06);\n    }\n    .small{\n      font-size:13px; padding:8px 12px;\n    }\n\n    .legend{\n      margin-top:12px;\n      font-size:12px;\n      color:rgba(255,255,255,0.6);\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n\n    .hash-info{\n      position:absolute;\n      bottom:18px;\n      left:36px;\n      font-size:12px;\n      color:rgba(255,255,255,0.65);\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n\n    /* subtle glow around some elements */\n    .glow{\n      position:absolute;\n      width:220px;\n      height:220px;\n      left:-40px;\n      top:-60px;\n      background: radial-gradient(closest-side, rgba(123,108,255,0.10), transparent 40%);\n      filter:blur(24px);\n      pointer-events:none;\n    }\n\n    @media (max-width:1000px){\n      .morph{ flex-direction:column; gap:16px; align-items:center; }\n      .panel,.buckets{ flex:1 1 auto; width:100%;}\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"stars\"></div>\n  <div class=\"container\" role=\"main\" aria-label=\"Hash Map visualization\">\n    <header>\n      <div class=\"title\">\n        <small>Data Structures • Mapping</small>\n        <div style=\"display:flex; align-items:center; gap:14px;\">\n          <h1 style=\"margin:0; font-size:26px;\">Hash Map</h1>\n          <div style=\"font-size:12px; color:var(--muted); font-weight:700; padding:6px 10px; border-radius:8px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.03);\">Array + Hashing</div>\n        </div>\n        <div class=\"desc\" style=\"margin-top:10px;\">\n          A hash map (associative array) stores key-value pairs. Each key is passed through a hash function to compute an index — the bucket — where the value is stored. Collisions are handled by chaining into the same bucket.\n        </div>\n      </div>\n\n      <div class=\"controls\" style=\"margin-left:auto;\">\n        <button id=\"animate\" class=\"btn primary small\" title=\"Animate mapping\">Animate Mapping</button>\n        <button id=\"reset\" class=\"btn small\" title=\"Reset layout\">Reset</button>\n      </div>\n    </header>\n\n    <div class=\"ui-row\">\n      <div class=\"panel\" aria-hidden=\"false\">\n        <h3>Key Pool</h3>\n        <div class=\"pool\" id=\"pool\">\n          <!-- chips are generated by JS for crisp absolute positioning -->\n        </div>\n        <div class=\"legend\" style=\"margin-top:10px;\">\n          <div style=\"display:flex;gap:8px;align-items:center;\">\n            <div style=\"width:10px;height:10px;border-radius:2px;background:linear-gradient(90deg,var(--accent-1),var(--accent-3)); box-shadow:0 6px 16px rgba(123,108,255,0.12);\"></div>\n            <div style=\"opacity:0.9;\">Keys</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"center\">\n        <div class=\"hash-card\">\n          <div class=\"morph\">\n            <div class=\"box\">\n              <h4>Keys</h4>\n              <div style=\"display:flex;gap:8px;flex-wrap:wrap; justify-content:center;\">\n                <div style=\"background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); padding:6px 10px; border-radius:999px; font-weight:700; letter-spacing:0.4px;\">String → int</div>\n              </div>\n            </div>\n\n            <div class=\"arrow\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 200 64\" preserveAspectRatio=\"none\">\n                <defs>\n                  <linearGradient id=\"g\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7ee7f7\"/><stop offset=\"1\" stop-color=\"#7b6cff\"/></linearGradient>\n                  <filter id=\"f\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                    <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n                    <feBlend in=\"SourceGraphic\" in2=\"b\"/>\n                  </filter>\n                </defs>\n                <path d=\"M12 32 C60 0, 140 0, 188 32\" fill=\"none\" stroke=\"url(#g)\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\"0.95\" filter=\"url(#f)\"/>\n                <path d=\"M160 16 L188 32 L160 48\" fill=\"none\" stroke=\"url(#g)\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                <text x=\"98\" y=\"18\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.12)\" font-size=\"10\" font-weight=\"700\">hash(key) % N</text>\n              </svg>\n            </div>\n\n            <div class=\"box\">\n              <h4>Buckets</h4>\n              <div style=\"display:flex;gap:6px;align-items:center;\">\n                <div style=\"font-weight:800; font-size:22px; background:linear-gradient(90deg,var(--accent-1),var(--accent-3)); -webkit-background-clip:text; background-clip:text; color:transparent;\">N = 7</div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"hash-info\">\n            <div style=\"display:flex;align-items:center;gap:8px;\">\n              <div style=\"opacity:0.8;\">Hash preview:</div>\n              <div style=\"font-weight:700; font-size:12px; padding:6px 10px; border-radius:8px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.03);\">sum(charCodes) % 7</div>\n            </div>\n          </div>\n\n          <div class=\"glow\" aria-hidden=\"true\"></div>\n        </div>\n\n        <!-- overlay SVG for connection lines -->\n        <svg class=\"overlay\" id=\"svgOverlay\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n      </div>\n\n      <div class=\"buckets\" aria-hidden=\"false\">\n        <h3>Buckets</h3>\n        <div class=\"bucket-list\" id=\"bucketList\">\n          <!-- buckets generated by JS -->\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      // Data configuration\n      const keys = [\"Cat\",\"Tree\",\"Sky\",\"River\",\"Stone\",\"Cloud\",\"Light\",\"Night\",\"Fire\",\"Leaf\"];\n      const N = 7; // bucket count\n\n      const poolEl = document.getElementById('pool');\n      const bucketList = document.getElementById('bucketList');\n      const svg = document.getElementById('svgOverlay');\n      const animateBtn = document.getElementById('animate');\n      const resetBtn = document.getElementById('reset');\n\n      // utility hash: sum char codes mod N\n      function hash(key){\n        let s = 0;\n        for(let i=0;i<key.length;i++) s += key.charCodeAt(i);\n        return s % N;\n      }\n\n      // Prepare buckets\n      const buckets = [];\n      for(let i=0;i<N;i++){\n        const b = document.createElement('div');\n        b.className = 'bucket';\n        b.dataset.index = i;\n        b.innerHTML = `<div class=\"index\">${i}</div><div class=\"values\" id=\"bucket-${i}\"></div>`;\n        bucketList.appendChild(b);\n        buckets.push(b);\n      }\n\n      // Create chip elements in pool\n      let chipEls = [];\n      keys.forEach((k, idx) => {\n        const chip = document.createElement('div');\n        chip.className = 'chip';\n        chip.dataset.key = k;\n        chip.dataset.index = idx;\n        chip.innerHTML = `<div class=\"dot\" style=\"background:linear-gradient(90deg,var(--accent-1),var(--accent-3));\"></div><div class=\"label\">${k}</div>`;\n        poolEl.appendChild(chip);\n        chipEls.push(chip);\n      });\n\n      // For smooth absolute animation, set chips to absolute positioned clones in pool area\n      // We'll store original order and positions\n      const initialState = [];\n      function snapshotInitial(){\n        chipEls.forEach((chip, i) => {\n          const rect = chip.getBoundingClientRect();\n          const poolRect = poolEl.getBoundingClientRect();\n          const left = rect.left - poolRect.left;\n          const top = rect.top - poolRect.top;\n          // convert chip to absolute positioned inside the pool\n          chip.style.position = 'absolute';\n          chip.style.left = left + 'px';\n          chip.style.top = top + 'px';\n          chip.style.margin = '0';\n          chip.style.zIndex = 3;\n          initialState.push({chip, left, top, parent: poolEl});\n        });\n        // Make pool height auto (we already have height)\n      }\n\n      // After initial layout, snapshot\n      window.requestAnimationFrame(()=>{\n        snapshotInitial();\n      });\n\n      // compute mapping (key -> bucket index)\n      const mapping = chipEls.map(ch => ({ key: ch.dataset.key, idx: hash(ch.dataset.key) }));\n\n      // Prepare small utility to create smooth bezier path between two points\n      function createPath(x1,y1,x2,y2){\n        // control points for a pleasing curve\n        const dx = Math.abs(x2-x1);\n        const dir = x2 > x1 ? 1 : -1;\n        const cx1 = x1 + dir * Math.min(120, dx*0.4);\n        const cy1 = y1;\n        const cx2 = x2 - dir * Math.min(120, dx*0.4);\n        const cy2 = y2;\n        return `M ${x1} ${y1} C ${cx1} ${cy1}, ${cx2} ${cy2}, ${x2} ${y2}`;\n      }\n\n      // Create paths but keep them hidden until animate\n      const paths = [];\n      function buildPaths(){\n        // clear svg\n        while(svg.firstChild) svg.removeChild(svg.firstChild);\n        const poolRect = poolEl.getBoundingClientRect();\n        const bucketsRects = buckets.map(b => b.getBoundingClientRect());\n        mapping.forEach((m, i)=>{\n          const chip = chipEls[i];\n          const chipRect = chip.getBoundingClientRect();\n          // start: center of chip relative to svg viewport\n          const startX = chipRect.left + chipRect.width/2;\n          const startY = chipRect.top + chipRect.height/2;\n          // target: bucket center (values area)\n          const targetBucket = buckets[m.idx];\n          const valEl = targetBucket.querySelector('.values');\n          const valRect = valEl.getBoundingClientRect();\n          const endX = valRect.left + 20; // aim toward left side inside bucket values\n          const endY = valRect.top + valRect.height/2;\n          const d = createPath(startX, startY, endX, endY);\n          const p = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n          p.setAttribute('d', d);\n          p.setAttribute('fill', 'none');\n          p.setAttribute('stroke', 'url(#grad-' + i + ')'); // assign gradient id (we'll create gradients)\n          p.setAttribute('stroke-width', '3');\n          p.setAttribute('stroke-linecap', 'round');\n          p.setAttribute('stroke-linejoin', 'round');\n          p.setAttribute('opacity', '0.9');\n          p.style.filter = 'drop-shadow(0 8px 16px rgba(0,0,0,0.45))';\n          // create gradient for each path\n          const defs = document.createElementNS(\"http://www.w3.org/2000/svg\",\"defs\");\n          const lg = document.createElementNS(\"http://www.w3.org/2000/svg\",\"linearGradient\");\n          const gid = 'grad-' + i;\n          lg.setAttribute('id', gid);\n          lg.setAttribute('x1','0'); lg.setAttribute('x2','1');\n          const stop1 = document.createElementNS(\"http://www.w3.org/2000/svg\",\"stop\");\n          stop1.setAttribute('offset','0%'); stop1.setAttribute('stop-color','#7ee7f7');\n          const stop2 = document.createElementNS(\"http://www.w3.org/2000/svg\",\"stop\");\n          stop2.setAttribute('offset','100%'); stop2.setAttribute('stop-color','#7b6cff');\n          lg.appendChild(stop1); lg.appendChild(stop2);\n          defs.appendChild(lg);\n          svg.appendChild(defs);\n          svg.appendChild(p);\n          paths.push({path:p, startX,startY,endX,endY, chip, bucketIdx:m.idx});\n        });\n      }\n\n      // Build paths initially (after layout)\n      window.addEventListener('load', buildPaths);\n      window.addEventListener('resize', () => {\n        // rebuild positions on resize\n        buildPaths();\n      });\n\n      // Animate mapping: draw path and move chips into buckets (with chaining)\n      let animating = false;\n      animateBtn.addEventListener('click', async ()=>{\n        if(animating) return;\n        animating = true;\n        animateBtn.disabled = true;\n        // Rebuild paths to ensure coordinates are current\n        buildPaths();\n        // clear existing bucket values\n        for(let b of buckets){\n          const vals = b.querySelector('.values');\n          vals.innerHTML = '';\n        }\n        // We'll create a promise sequence to stagger animations\n        const seqDelay = 90; // ms per chip\n        const promises = [];\n        paths.forEach((obj, i) => {\n          const {path, chip, bucketIdx} = obj;\n          // prepare stroke drawing\n          const totalLength = path.getTotalLength();\n          path.style.strokeDasharray = totalLength;\n          path.style.strokeDashoffset = totalLength;\n          path.style.transition = 'stroke-dashoffset 700ms cubic-bezier(.2,.9,.3,1)';\n          path.style.opacity = '1';\n          // schedule drawing with small stagger\n          setTimeout(()=>{\n            path.style.strokeDashoffset = '0';\n            // animate chip movement along the path (approximate by translating to end coords)\n            const chipRect = chip.getBoundingClientRect();\n            const endBucket = buckets[bucketIdx];\n            const valEl = endBucket.querySelector('.values');\n            const valRect = valEl.getBoundingClientRect();\n            const svgRect = svg.getBoundingClientRect();\n\n            // compute target location inside bucket values\n            const targetX = valRect.left + 8 - (poolEl.getBoundingClientRect().left);\n            const targetY = valRect.top + 8 - (poolEl.getBoundingClientRect().top);\n            // Compute deltas from current absolute pos\n            const fromLeft = parseFloat(chip.style.left);\n            const fromTop = parseFloat(chip.style.top);\n            // compute absolute end relative to pool (so we can animate inside pool)\n            const absEndLeft = (valRect.left - poolEl.getBoundingClientRect().left) + 4;\n            const absEndTop = (valRect.top - poolEl.getBoundingClientRect().top) + 8;\n            // move chip with transform to end position (we must compute delta)\n            const dx = absEndLeft - fromLeft;\n            const dy = absEndTop - fromTop;\n            chip.style.transition = 'transform 900ms cubic-bezier(.2,.9,.3,1), opacity 350ms ease';\n            chip.style.transform = `translate(${dx}px, ${dy}px) scale(0.95)`;\n            chip.style.opacity = '0.98';\n            // after move completes, attach chip to bucket values area\n            const p = new Promise(resolve=>{\n              setTimeout(()=>{\n                // remove path gracefully\n                path.style.transition = 'opacity 420ms ease';\n                path.style.opacity = '0';\n                // finalize chip inside bucket\n                chip.style.transition = '';\n                chip.style.transform = '';\n                chip.style.position = 'relative';\n                chip.style.left = '';\n                chip.style.top = '';\n                chip.style.margin = '0';\n                chip.style.zIndex = '';\n                // append to bucket values\n                valEl.appendChild(chip);\n                resolve();\n              }, 980);\n            });\n            promises.push(p);\n          }, i*seqDelay + 120);\n        });\n\n        // Wait until all done\n        const all = new Promise(resolve=>{\n          const check = setInterval(()=>{\n            if(promises.length === keys.length){\n              Promise.all(promises).then(()=>{ clearInterval(check); resolve(); });\n            }\n          }, 120);\n          // fallback after 6s\n          setTimeout(()=>{ clearInterval(check); resolve(); }, 6500);\n        });\n\n        await all;\n        animating = false;\n        animateBtn.disabled = false;\n      });\n\n      // Reset: move chips back to pool initial positions\n      resetBtn.addEventListener('click', ()=>{\n        if(animating) return;\n        // Remove any svg paths\n        while(svg.firstChild) svg.removeChild(svg.firstChild);\n        // Move chips back to pool\n        initialState.forEach((st, i) => {\n          const {chip, left, top, parent} = st;\n          // If chip is inside a bucket, bring it back\n          if(chip.parentElement !== poolEl){\n            poolEl.appendChild(chip);\n          }\n          // make absolute again and animate to initial coords\n          chip.style.position = 'absolute';\n          // current left/top might be empty; set to current rect\n          const rect = chip.getBoundingClientRect();\n          const poolRect = poolEl.getBoundingClientRect();\n          // compute current offset relative to pool\n          let curLeft = parseFloat(chip.style.left);\n          let curTop = parseFloat(chip.style.top);\n          if(isNaN(curLeft) || isNaN(curTop)){\n            curLeft = rect.left - poolRect.left;\n            curTop = rect.top - poolRect.top;\n            chip.style.left = curLeft + 'px';\n            chip.style.top = curTop + 'px';\n          }\n          chip.style.transition = 'transform 700ms cubic-bezier(.2,.9,.3,1), left 700ms ease, top 700ms ease';\n          // animate via transform\n          const dx = left - curLeft;\n          const dy = top - curTop;\n          chip.style.transform = `translate(${dx}px, ${dy}px)`;\n          setTimeout(()=>{\n            chip.style.transition = '';\n            chip.style.transform = '';\n            chip.style.left = left + 'px';\n            chip.style.top = top + 'px';\n            chip.style.position = 'absolute';\n            chip.style.zIndex = 3;\n            chip.style.opacity = '1';\n          }, 720);\n        });\n      });\n\n      // little enhancement: clicking a bucket will highlight its chain briefly (but we limit interactivity to avoid complexity)\n      bucketList.addEventListener('click', (ev)=>{\n        const b = ev.target.closest('.bucket');\n        if(!b) return;\n        b.animate([\n          { transform: 'translateY(0)', boxShadow: '0 8px 20px rgba(2,8,23,0.28)' },\n          { transform: 'translateY(-8px)', boxShadow: '0 18px 36px rgba(2,8,23,0.42)' },\n          { transform: 'translateY(0)' }\n        ], { duration: 420, easing: 'cubic-bezier(.2,.9,.3,1)' });\n      });\n\n      // accessibility: keyboard shortcuts (very minimal and optional)\n      window.addEventListener('keydown', (e)=>{\n        if(e.key === 'Enter') animateBtn.click();\n        if(e.key === 'Escape') resetBtn.click();\n      });\n    })();\n  </script>\n</body>\n</html>"
