    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>TimSort — Elegant Visual Demonstration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071028;\n      --glass: rgba(255,255,255,0.04);\n      --muted: rgba(255,255,255,0.6);\n      --accent: #7dd3fc;\n      --accent-2: #a78bfa;\n      --accent-3: #60a5fa;\n      --success: #34d399;\n      --danger: #fb7185;\n      --card: rgba(255,255,255,0.03);\n      --glass-2: rgba(255,255,255,0.02);\n      font-synthesis: none;\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(124,58,237,0.14), transparent 6%),\n                  radial-gradient(1000px 500px at 90% 90%, rgba(56,189,248,0.06), transparent 8%),\n                  linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);\n      color: #e6eef8;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:32px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    .stage {\n      width: 1100px;\n      max-width: calc(100% - 64px);\n      border-radius: 20px;\n      padding: 28px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 8px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(8px) saturate(120%);\n      position:relative;\n      overflow:hidden;\n    }\n\n    .header {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:16px;\n      margin-bottom:18px;\n    }\n\n    .title {\n      display:flex;\n      align-items:center;\n      gap:14px;\n    }\n    .logo {\n      width:64px;\n      height:64px;\n      border-radius:12px;\n      background: linear-gradient(135deg, rgba(167,139,250,0.18), rgba(125,211,252,0.08));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      box-shadow: 0 6px 18px rgba(99,102,241,0.08), inset 0 1px 0 rgba(255,255,255,0.02);\n      flex-shrink:0;\n    }\n    .logo svg { filter: drop-shadow(0 6px 18px rgba(124,58,237,0.12)); }\n\n    h1 {\n      margin:0;\n      font-family: \"Playfair Display\", serif;\n      font-weight:600;\n      font-size:20px;\n      letter-spacing: -0.02em;\n      color: #f8fbff;\n    }\n    .subtitle {\n      margin:0;\n      font-size:12px;\n      color:var(--muted);\n      font-weight:400;\n    }\n\n    .controls {\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn {\n      border:0;\n      padding:10px 14px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color: var(--muted);\n      cursor:pointer;\n      font-weight:600;\n      letter-spacing:0.01em;\n      transition: all 220ms ease;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n    }\n    .btn:hover { transform: translateY(-3px); color: #fff; }\n    .btn.primary {\n      background: linear-gradient(90deg, rgba(125,211,252,0.12), rgba(167,139,250,0.08));\n      color: #e8faff;\n      box-shadow: 0 8px 24px rgba(124,58,237,0.12);\n    }\n    .btn.ghost {\n      background: transparent;\n      color: var(--muted);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n\n    .canvas {\n      display:flex;\n      gap:24px;\n      align-items:stretch;\n      margin-top:18px;\n    }\n\n    .panel {\n      flex:1;\n      min-height:360px;\n      border-radius:14px;\n      padding: 22px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n      overflow:hidden;\n    }\n\n    .left {\n      width: 100%;\n    }\n\n    .subtitle-block {\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      gap:12px;\n      margin-bottom:12px;\n    }\n\n    .explain {\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.35;\n      max-width:520px;\n    }\n\n    .visual {\n      margin-top:12px;\n      height:260px;\n      position:relative;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      padding:18px;\n      overflow:visible;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    .playfield {\n      width:100%;\n      height:200px;\n      position:relative;\n      overflow:visible;\n      border-radius:10px;\n      background: linear-gradient(180deg, rgba(8,12,20,0.3), rgba(8,12,20,0.15));\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n      display:block;\n    }\n\n    .tiles {\n      position:absolute;\n      left:18px;\n      right:18px;\n      top:28px;\n      bottom:18px;\n      height: calc(100% - 46px);\n      display:block;\n    }\n\n    .tile {\n      position:absolute;\n      bottom:6px;\n      width:20px;\n      border-radius:6px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n      box-shadow: 0 6px 16px rgba(2,6,23,0.6), inset 0 2px 6px rgba(255,255,255,0.03);\n      display:flex;\n      align-items:flex-end;\n      justify-content:center;\n      color: rgba(255,255,255,0.9);\n      font-weight:700;\n      font-size:11px;\n      transform-origin: center bottom;\n      transition: left 700ms cubic-bezier(.2,.9,.2,1), top 480ms ease, transform 420ms cubic-bezier(.2,.9,.2,1), filter 360ms ease, box-shadow 360ms ease;\n      will-change: transform, left;\n      padding-bottom:6px;\n    }\n\n    .tile .value {\n      font-size:10px;\n      opacity:0.85;\n      color: rgba(10,14,20,0.95);\n      mix-blend-mode: multiply;\n      background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(255,255,255,0.96));\n      padding: 4px 8px;\n      border-radius:999px;\n      margin-bottom:6px;\n      box-shadow: 0 2px 6px rgba(2,6,23,0.45);\n    }\n\n    .run-overlay {\n      position:absolute;\n      height:100%;\n      top:0;\n      bottom:0;\n      pointer-events:none;\n    }\n\n    .legend {\n      margin-top:12px;\n      display:flex;\n      gap:10px;\n      color:var(--muted);\n      font-size:13px;\n      align-items:center;\n    }\n\n    .chip {\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n      padding:8px 12px;\n      border-radius:999px;\n      background: rgba(255,255,255,0.02);\n      color:var(--muted);\n      font-weight:600;\n    }\n    .chip .dot {\n      width:10px;\n      height:10px;\n      border-radius:50%;\n      box-shadow: 0 4px 12px rgba(2,6,23,0.5);\n    }\n\n    .right {\n      width:320px;\n      margin-left:18px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n\n    .panel.small {\n      padding:16px;\n      min-height:140px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n      justify-content:flex-start;\n    }\n\n    .status {\n      font-size:13px;\n      color:var(--muted);\n    }\n\n    .stack {\n      display:flex;\n      gap:10px;\n      flex-wrap:wrap;\n    }\n\n    .run-pill {\n      padding:8px 12px;\n      border-radius:999px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color: var(--muted);\n      font-weight:600;\n      min-width:44px;\n      text-align:center;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n    }\n\n    footer.credit {\n      position:absolute;\n      left:28px;\n      right:28px;\n      bottom:18px;\n      display:flex;\n      justify-content:space-between;\n      color: rgba(255,255,255,0.06);\n      font-size:12px;\n    }\n\n    /* colors for runs */\n    .run-color-0 { background: linear-gradient(180deg,#7dd3fc 0%, #60a5fa 100%); color:#071028; }\n    .run-color-1 { background: linear-gradient(180deg,#a78bfa 0%, #7c3aed 100%); color:#fff; }\n    .run-color-2 { background: linear-gradient(180deg,#34d399 0%, #10b981 100%); color:#052e1f; }\n    .run-color-3 { background: linear-gradient(180deg,#f472b6 0%, #fb7185 100%); color:#3a0710; }\n    .run-color-4 { background: linear-gradient(180deg,#fbbf24 0%, #fb923c 100%); color:#2a1400; }\n    .run-highlight {\n      filter: drop-shadow(0 12px 30px rgba(124,58,237,0.12));\n      transform: translateY(-6px) scale(1.04);\n      z-index: 50;\n    }\n\n    .note {\n      font-size:12px;\n      color:var(--muted);\n      line-height:1.35;\n    }\n\n    @media (max-width: 980px){\n      .canvas { flex-direction:column; }\n      .right { width:100%; margin-left:0; }\n      .visual { height:220px }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"stage\" role=\"application\" aria-label=\"TimSort Visualization\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg width=\"44\" height=\"44\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"8\" y=\"8\" width=\"84\" height=\"84\" rx=\"20\" fill=\"url(#g1)\"/>\n            <path d=\"M28 64 L44 36 L56 56 L72 28\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.96\"/>\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#7dd3fc\" stop-opacity=\"0.95\"/>\n                <stop offset=\"100%\" stop-color=\"#a78bfa\" stop-opacity=\"0.9\"/>\n              </linearGradient>\n            </defs>\n          </svg>\n        </div>\n        <div>\n          <h1>TimSort — Elegant Visual</h1>\n          <p class=\"subtitle\">Observe how TimSort discovers runs and merges them into a stable sorted array — aesthetic-first visualization.</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button id=\"playBtn\" class=\"btn primary\">Play</button>\n        <button id=\"shuffleBtn\" class=\"btn ghost\">Shuffle</button>\n      </div>\n    </div>\n\n    <div class=\"canvas\">\n      <div class=\"panel left\">\n        <div class=\"subtitle-block\">\n          <div class=\"explain\">\n            TimSort is a hybrid stable sorting algorithm that identifies naturally occurring runs in the data, optionally extends them, then merges runs with a set of invariants for efficient performance. This cinematic demonstration highlights run detection and the graceful merging process.\n          </div>\n          <div class=\"legend\" aria-hidden=\"true\">\n            <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(90deg,#7dd3fc,#60a5fa)\"></span> Runs</div>\n            <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(90deg,#a78bfa,#7c3aed)\"></span> Merges</div>\n          </div>\n        </div>\n\n        <div class=\"visual\">\n          <div class=\"playfield\" id=\"playfield\" aria-hidden=\"false\">\n            <div class=\"tiles\" id=\"tiles\"></div>\n            <div class=\"run-overlay\" id=\"runOverlay\"></div>\n          </div>\n\n          <div style=\"position:absolute; right:28px; top:18px; text-align:right;\">\n            <div style=\"font-weight:700; font-size:12px; color:#e8f7ff\">TimSort • Natural Runs</div>\n            <div style=\"color:var(--muted); font-size:12px; margin-top:6px;\">Watch as runs are detected and then merged smoothly into the final sorted sequence.</div>\n          </div>\n        </div>\n\n        <div class=\"legend\" style=\"margin-top:12px;\">\n          <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(90deg,#7dd3fc,#60a5fa)\"></span> Detected runs</div>\n          <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(90deg,#a78bfa,#7c3aed)\"></span> Active merge</div>\n          <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(90deg,#34d399,#10b981)\"></span> Done</div>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div class=\"panel small\">\n          <div style=\"display:flex; align-items:center; justify-content:space-between;\">\n            <div style=\"font-weight:700; font-size:13px;\">Run Stack</div>\n            <div class=\"status\" id=\"status\">Idle</div>\n          </div>\n          <div class=\"stack\" id=\"runStack\" aria-hidden=\"true\"></div>\n          <div class=\"note\" style=\"margin-top:6px;\">The stack shows contiguous runs (lengths). TimSort merges them respecting invariants to maintain efficiency and balance.</div>\n        </div>\n\n        <div class=\"panel small\">\n          <div style=\"font-weight:700; font-size:13px;\">Steps</div>\n          <div style=\"color:var(--muted); font-size:13px; margin-top:6px;\" id=\"stepLog\">Press Play to begin the guided animation.</div>\n        </div>\n      </div>\n    </div>\n\n    <footer class=\"credit\" aria-hidden=\"true\">\n      <div>Designed with care — TimSort visual</div>\n      <div>Minimal controls • Smooth animations</div>\n    </footer>\n  </div>\n\n  <script>\n    (function(){\n      // Config\n      const COUNT = 36;\n      const MIN_VAL = 1;\n      const MAX_VAL = 100;\n      const TILE_GAP = 6;\n      const ANIM_DURATION = 700; // ms for position transitions\n      const RUN_HIGHLIGHT_DURATION = 800;\n      const MERGE_HIGHLIGHT_DURATION = 900;\n      const COLORS = [\"run-color-0\",\"run-color-1\",\"run-color-2\",\"run-color-3\",\"run-color-4\"];\n\n      // Elements\n      const tilesEl = document.getElementById('tiles');\n      const runOverlay = document.getElementById('runOverlay');\n      const playBtn = document.getElementById('playBtn');\n      const shuffleBtn = document.getElementById('shuffleBtn');\n      const runStackEl = document.getElementById('runStack');\n      const statusEl = document.getElementById('status');\n      const stepLogEl = document.getElementById('stepLog');\n      const playfield = document.getElementById('playfield');\n\n      // State\n      let arr = [];\n      let nodes = []; // DOM nodes for tiles, aligned to arr indices\n      let running = false;\n      let animationQueue = Promise.resolve();\n      let currentRuns = [];\n      let operationQueue = [];\n      let cancelFlag = false;\n\n      function randomArray(n){\n        // generate distinct-ish values for visual variation\n        const vals = [];\n        for(let i=0;i<n;i++){\n          vals.push(Math.round(MIN_VAL + (MAX_VAL-MIN_VAL)*i/(n-1) + (Math.random()-0.5)*(MAX_VAL/(n*0.5))));\n        }\n        // shuffle\n        for(let i=vals.length-1;i>0;i--){\n          const j = Math.floor(Math.random()*(i+1));\n          [vals[i],vals[j]] = [vals[j],vals[i]];\n        }\n        return vals;\n      }\n\n      function init(){\n        arr = randomArray(COUNT);\n        cancelFlag = false;\n        running = false;\n        playBtn.textContent = \"Play\";\n        statusEl.textContent = \"Idle\";\n        stepLogEl.textContent = \"Press Play to begin the guided animation.\";\n        currentRuns = [];\n        operationQueue = [];\n        renderTiles();\n        clearRunOverlay();\n        updateStackDisplay([]);\n      }\n\n      function renderTiles(){\n        tilesEl.innerHTML = '';\n        nodes = [];\n        const rect = tilesEl.getBoundingClientRect();\n        const width = rect.width;\n        const tileWidth = computeTileWidth(width);\n        const maxHeight = rect.height - 10;\n        const minVal = Math.min(...arr);\n        const maxVal = Math.max(...arr);\n\n        for(let i=0;i<arr.length;i++){\n          const v = arr[i];\n          const h = Math.max(22, Math.round((v - minVal) / (maxVal - minVal || 1) * (maxHeight - 24)) + 28);\n          const tile = document.createElement('div');\n          tile.className = 'tile';\n          tile.style.width = tileWidth + 'px';\n          tile.style.height = h + 'px';\n          tile.style.left = (i * (tileWidth + TILE_GAP)) + 'px';\n          tile.style.background = `linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02))`;\n          tile.style.transition = `left ${ANIM_DURATION}ms cubic-bezier(.2,.9,.2,1), transform 420ms cubic-bezier(.2,.9,.2,1), filter 360ms ease, box-shadow 360ms ease`;\n          tile.dataset.index = i;\n          tile.dataset.value = v;\n          const label = document.createElement('div');\n          label.className = 'value';\n          label.textContent = v;\n          tile.appendChild(label);\n          tilesEl.appendChild(tile);\n          nodes.push(tile);\n        }\n      }\n\n      function computeTileWidth(containerWidth){\n        // compute width so all tiles fit nicely\n        let tentative = Math.floor((containerWidth - (arr.length-1)*TILE_GAP) / arr.length);\n        tentative = Math.max(12, Math.min(36, tentative));\n        return tentative;\n      }\n\n      function clearRunOverlay(){\n        runOverlay.innerHTML = '';\n      }\n\n      function findRuns(a){\n        const runs = [];\n        let i = 0;\n        while(i < a.length){\n          let start = i;\n          i++;\n          if(i === a.length){\n            runs.push({start:start, end:i, length:1, desc:false});\n            break;\n          }\n          // detect direction\n          if(a[i-1] <= a[i]){ // ascending\n            while(i < a.length && a[i-1] <= a[i]) i++;\n            runs.push({start:start, end:i, length:i-start, desc:false});\n          } else { // descending\n            while(i < a.length && a[i-1] > a[i]) i++;\n            runs.push({start:start, end:i, length:i-start, desc:true});\n          }\n        }\n        return runs;\n      }\n\n      function annotateRuns(runs){\n        // show overlay stripes for runs\n        runOverlay.innerHTML = '';\n        const rect = tilesEl.getBoundingClientRect();\n        const tileWidth = computeTileWidth(rect.width);\n        runs.forEach((r, idx)=>{\n          const el = document.createElement('div');\n          el.className = 'run-chunk';\n          const left = r.start * (tileWidth + TILE_GAP);\n          const width = (r.end - r.start) * (tileWidth + TILE_GAP) - TILE_GAP;\n          el.style.position = 'absolute';\n          el.style.left = left + 'px';\n          el.style.top = '0px';\n          el.style.height = '100%';\n          el.style.width = Math.max(8, width) + 'px';\n          el.style.borderRadius = '10px';\n          el.style.background = 'linear-gradient(180deg, rgba(125,211,252,0.06), rgba(167,139,250,0.04))';\n          el.style.pointerEvents = 'none';\n          el.style.transition = 'opacity 420ms ease, transform 420ms cubic-bezier(.2,.9,.2,1)';\n          el.style.opacity = '0.18';\n          runOverlay.appendChild(el);\n        });\n      }\n\n      function updateStackDisplay(stack){\n        runStackEl.innerHTML = '';\n        stack.forEach((r, idx)=>{\n          const pill = document.createElement('div');\n          pill.className = 'run-pill';\n          pill.textContent = `${r.length}`;\n          if (r.active) pill.style.boxShadow = '0 10px 28px rgba(124,58,237,0.12)';\n          runStackEl.appendChild(pill);\n        });\n      }\n\n      function sleep(ms){ return new Promise(res => setTimeout(res, ms)); }\n\n      // Merge utilities\n      function mergeSegments(arr, aStart, aEnd, bStart, bEnd){\n        // standard stable merge returning new array slice\n        const left = arr.slice(aStart, aEnd);\n        const right = arr.slice(bStart, bEnd);\n        const merged = [];\n        let i=0,j=0;\n        while(i<left.length && j<right.length){\n          if(left[i] <= right[j]) merged.push(left[i++]);\n          else merged.push(right[j++]);\n        }\n        while(i<left.length) merged.push(left[i++]);\n        while(j<right.length) merged.push(right[j++]);\n        return merged;\n      }\n\n      // Produce TimSort-like merge operations (indices)\n      function planTimSortRuns(runs){\n        // We'll simulate TimSort stack merging logic.\n        // runs is array of {start,end,length,desc}\n        const stack = [];\n        const ops = []; // each op: {type:'merge', i, j} where i and j are indices into runs array (adjacent runs)\n        // push runs\n        for(let i=0;i<runs.length;i++){\n          stack.push({start:runs[i].start, length:runs[i].length});\n          // collapse per TimSort invariants\n          while(true){\n            const n = stack.length;\n            if(n >= 3){\n              const A = stack[n-3].length;\n              const B = stack[n-2].length;\n              const C = stack[n-1].length;\n              if(A <= B + C){\n                if(A < C){\n                  // merge A and B (n-3 and n-2)\n                  ops.push({mergeIndex: n-3});\n                  // merge in stack\n                  const newLen = stack[n-3].length + stack[n-2].length;\n                  stack.splice(n-3, 2, {start: stack[n-3].start, length: newLen});\n                  continue;\n                } else {\n                  // merge B and C\n                  ops.push({mergeIndex: n-2});\n                  const newLen = stack[n-2].length + stack[n-1].length;\n                  stack.splice(n-2, 2, {start: stack[n-2].start, length: newLen});\n                  continue;\n                }\n              }\n            }\n            if(stack.length >= 2){\n              const n = stack.length;\n              const B = stack[n-2].length;\n              const C = stack[n-1].length;\n              if(B <= C){\n                ops.push({mergeIndex: n-2});\n                const newLen = stack[n-2].length + stack[n-1].length;\n                stack.splice(n-2, 2, {start: stack[n-2].start, length: newLen});\n                continue;\n              }\n            }\n            break;\n          }\n        }\n        // finally merge remaining runs left-to-right\n        while(stack.length > 1){\n          ops.push({mergeIndex: 0});\n          const newLen = stack[0].length + stack[1].length;\n          stack.splice(0,2, {start: stack[0].start, length: newLen});\n        }\n        return ops;\n      }\n\n      // Animations orchestrator\n      async function runVisualization(){\n        if(running) return;\n        running = true;\n        cancelFlag = false;\n        playBtn.textContent = \"Pause\";\n        statusEl.textContent = \"Detecting runs\";\n\n        // Step 1: detect runs\n        stepLogEl.textContent = \"Detecting natural runs...\";\n        let runs = findRuns(arr);\n        // reverse descending runs and animate that\n        annotateRuns(runs);\n        updateStackDisplay(runs.map(r => ({length:r.length})));\n        await highlightRunsSequence(runs);\n        // After highlight, ensure descending runs are reversed in data\n        for(let r of runs){\n          if(r.desc){\n            arr = arr.slice(0);\n            const rev = arr.slice(r.start, r.end).reverse();\n            arr.splice(r.start, r.end - r.start, ...rev);\n          }\n        }\n        renderTiles(); // re-render heights/positions after reversing\n        annotateRuns(runs);\n\n        // Build TimSort merge plan\n        stepLogEl.textContent = \"Planning merges (TimSort invariants)...\";\n        await sleep(900);\n        const ops = planTimSortRuns(runs);\n        operationQueue = ops.slice();\n\n        // Build a run list for dynamic merging\n        let runList = runs.map(r => ({start:r.start, length:r.length}));\n        updateStackDisplay(runList.map(r => ({length:r.length})));\n\n        // Execute merge operations sequentially\n        for(let stepIndex=0; stepIndex<operationQueue.length; stepIndex++){\n          if(cancelFlag) break;\n          const op = operationQueue[stepIndex];\n          // op.mergeIndex refers to index in current runList\n          const idx = op.mergeIndex;\n          if(idx < 0 || idx >= runList.length - 1) continue;\n          const a = runList[idx];\n          const b = runList[idx+1];\n          // animate highlight of the two runs\n          statusEl.textContent = `Merging runs (lengths ${a.length} + ${b.length})`;\n          stepLogEl.textContent = `Merging runs at positions ${a.start}..${a.start+a.length-1} and ${b.start}..${b.start+b.length-1}`;\n          await highlightMerge(a.start, a.length, b.start, b.length);\n          // perform merge of array segments\n          const merged = mergeSegments(arr, a.start, a.start + a.length, b.start, b.start + b.length);\n          // place merged into arr\n          arr.splice(a.start, a.length + b.length, ...merged);\n          // animate tiles reposition to reflect merged order\n          await animateReorder(a.start, a.length + b.length);\n          // update runList\n          const newRun = {start: a.start, length: a.length + b.length};\n          runList.splice(idx, 2, newRun);\n          // reflow runList starts\n          for(let j=idx+1;j<runList.length;j++){\n            runList[j].start = runList[j-1].start + runList[j-1].length;\n          }\n          updateStackDisplay(runList.map(r => ({length:r.length, active: r === newRun})));\n          await sleep(220);\n        }\n\n        // final flourish\n        if(!cancelFlag){\n          statusEl.textContent = \"Completed\";\n          stepLogEl.textContent = \"Array fully sorted. TimSort has merged all runs into a single sorted sequence.\";\n          await finalGlow();\n        } else {\n          statusEl.textContent = \"Paused\";\n          stepLogEl.textContent = \"Visualization paused.\";\n        }\n\n        running = false;\n        playBtn.textContent = \"Play\";\n      }\n\n      async function highlightRunsSequence(runs){\n        // highlight runs one by one with color\n        const rect = tilesEl.getBoundingClientRect();\n        const tileWidth = computeTileWidth(rect.width);\n        // For each run, add subtle animation to each tile in run\n        for(let idx=0; idx<runs.length; idx++){\n          if(cancelFlag) break;\n          const r = runs[idx];\n          // apply color class to tiles in run\n          for(let i=r.start;i<r.end;i++){\n            const node = nodes[i];\n            const colorClass = COLORS[idx % COLORS.length];\n            node.classList.remove(...COLORS);\n            node.classList.add(colorClass);\n            node.style.zIndex = 20;\n            node.style.transform = 'translateY(-8px) scale(1.02)';\n            node.style.boxShadow = '0 14px 36px rgba(2,6,23,0.6)';\n          }\n          updateStackDisplay(runs.map((s,i)=>({length:s.length, active: i===idx})));\n          await sleep(RUN_HIGHLIGHT_DURATION - 120);\n          // revert slight transform\n          for(let i=r.start;i<r.end;i++){\n            const node = nodes[i];\n            node.style.transform = '';\n            node.style.boxShadow = '';\n            node.style.zIndex = '';\n          }\n          await sleep(120);\n        }\n      }\n\n      async function highlightMerge(aStart, aLen, bStart, bLen){\n        // Highlight involved tiles and animate a brief lift\n        const rect = tilesEl.getBoundingClientRect();\n        const total = aLen + bLen;\n        const involved = [];\n        for(let i=aStart;i<aStart+aLen;i++) involved.push(nodes[i]);\n        for(let i=bStart;i<bStart+bLen;i++) involved.push(nodes[i]);\n        // color left and right differently\n        const leftColor = 'run-color-1';\n        const rightColor = 'run-color-3';\n        for(let i=0;i<involved.length;i++){\n          const nd = involved[i];\n          nd.style.zIndex = 60;\n          nd.style.transform = 'translateY(-12px) scale(1.06)';\n          nd.style.filter = 'brightness(1.02)';\n          nd.style.boxShadow = '0 18px 44px rgba(2,6,23,0.7)';\n          // subtle color overlay by adding class\n          if(i < aLen){\n            nd.classList.remove(...COLORS);\n            nd.classList.add(leftColor);\n          } else {\n            nd.classList.remove(...COLORS);\n            nd.classList.add(rightColor);\n          }\n        }\n        await sleep(MERGE_HIGHLIGHT_DURATION);\n        // revert visuals\n        for(const nd of involved){\n          nd.style.transform = '';\n          nd.style.zIndex = '';\n          nd.style.filter = '';\n          nd.style.boxShadow = '';\n        }\n      }\n\n      async function animateReorder(rangeStart, rangeLength){\n        // After arr mutated, we must reposition tiles to new left positions based on new indices.\n        // But nodes currently reference old positions. We should reorder nodes array to match arr values.\n        // We'll match by value; values may not be unique — but our generated numbers are mostly unique.\n        // To be safe, we will match by dataset index if possible: before splice, we stored dataset.value; after merge, we want nodes corresponding to each arr value in order.\n\n        // Build mapping of current DOM nodes by a small token (value + unique id)\n        // To ensure uniqueness, attach an id to each node on creation.\n        if(!nodes.every(n => n.dataset.uid)){\n          nodes.forEach((n, idx)=> {\n            n.dataset.uid = 'u' + Math.random().toString(36).slice(2,9) + idx;\n            n.dataset.origValue = n.dataset.value;\n          });\n        }\n\n        // We will create a pool of nodes corresponding to current arr state (by matching dataset.origValue, shifting as needed)\n        // But we must update nodes array ordering to match arr array.\n        // Strategy: for each value in arr, find the nearest node with matching dataset.origValue that hasn't been used yet.\n        const used = new Set();\n        const newNodes = [];\n        for(let i=0;i<arr.length;i++){\n          const val = String(arr[i]);\n          // find first unused node with dataset.origValue==val\n          let found = null;\n          for(let j=0;j<nodes.length;j++){\n            const cand = nodes[j];\n            if(used.has(cand.dataset.uid)) continue;\n            if(String(cand.dataset.origValue) === val){\n              found = cand; break;\n            }\n          }\n          // fallback: use any unused node\n          if(!found){\n            for(let j=0;j<nodes.length;j++){\n              const cand = nodes[j];\n              if(!used.has(cand.dataset.uid)){ found = cand; break; }\n            }\n          }\n          if(found){\n            used.add(found.dataset.uid);\n            newNodes.push(found);\n            // update label if value changed\n            found.dataset.value = arr[i];\n            if(found.firstChild) found.firstChild.textContent = arr[i];\n          }\n        }\n        // if there's mismatch in counts, but likely not\n        nodes = newNodes;\n\n        // reposition nodes with smooth left transitions\n        const rect = tilesEl.getBoundingClientRect();\n        const tileWidth = computeTileWidth(rect.width);\n        for(let i=0;i<nodes.length;i++){\n          const nd = nodes[i];\n          nd.style.left = (i * (tileWidth + TILE_GAP)) + 'px';\n        }\n\n        // wait for transition to finish\n        await sleep(ANIM_DURATION + 80);\n      }\n\n      async function finalGlow(){\n        // Subtle final animation: brighten and cascade\n        for(let i=0;i<nodes.length;i++){\n          const n = nodes[i];\n          (function(node, delay){\n            setTimeout(()=>{\n              node.style.transform = 'translateY(-10px) scale(1.04)';\n              node.style.boxShadow = '0 20px 48px rgba(124,58,237,0.12)';\n              node.style.filter = 'brightness(1.06)';\n              setTimeout(()=>{\n                node.style.transform = '';\n                node.style.boxShadow = '';\n                node.style.filter = '';\n              }, 420);\n            }, delay);\n          })(n, i*18);\n        }\n        await sleep(800 + nodes.length*18);\n      }\n\n      // Control bindings\n      playBtn.addEventListener('click', async ()=>{\n        if(running){\n          // Pause\n          cancelFlag = true;\n          running = false;\n          playBtn.textContent = \"Play\";\n          statusEl.textContent = \"Paused\";\n          stepLogEl.textContent = \"Visualization paused. Press Play to resume.\";\n        } else {\n          // Start or resume\n          cancelFlag = false;\n          runVisualization();\n        }\n      });\n\n      shuffleBtn.addEventListener('click', ()=>{\n        cancelFlag = true;\n        running = false;\n        init();\n      });\n\n      // responsiveness: re-render tile positions on resize\n      let resizeTimer = null;\n      window.addEventListener('resize', ()=>{\n        clearTimeout(resizeTimer);\n        resizeTimer = setTimeout(()=>{\n          renderTiles();\n          // reposition tiles per arr and nodes\n          const rect = tilesEl.getBoundingClientRect();\n          const tileWidth = computeTileWidth(rect.width);\n          for(let i=0;i<nodes.length;i++){\n            nodes[i].style.width = tileWidth + 'px';\n            nodes[i].style.left = (i * (tileWidth + TILE_GAP)) + 'px';\n          }\n          // refresh overlays\n          const runs = findRuns(arr);\n          annotateRuns(runs);\n        }, 120);\n      });\n\n      // initial\n      init();\n\n    })();\n  </script>\n</body>\n</html>"
