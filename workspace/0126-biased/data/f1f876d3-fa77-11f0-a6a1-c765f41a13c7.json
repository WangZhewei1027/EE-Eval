  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Git — Visual Elegance</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071226;\n    --accent: #7c5cff;\n    --accent-2: #00e0b8;\n    --muted: rgba(255,255,255,0.08);\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --text: #e6eef8;\n    --sub: rgba(230,238,248,0.75);\n    --card-radius: 18px;\n    font-synthesis: none;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Global layout */\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.18), transparent 6%),\n                radial-gradient(1000px 480px at 90% 90%, rgba(0,224,184,0.07), transparent 6%),\n                linear-gradient(180deg,var(--bg1), var(--bg2));\n    color:var(--text);\n    overflow:hidden;\n  }\n\n  /* Subtle animated ambient shapes */\n  .ambience{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    mix-blend-mode:screen;\n  }\n  .orb{\n    position:absolute;\n    filter:blur(80px);\n    opacity:0.55;\n    transform: translateZ(0);\n    will-change: transform, opacity;\n  }\n  .orb.one{width:520px;height:520px;background:linear-gradient(135deg, #7c5cff, #5a9bff); left:-10%; top:5%; animation: float1 12s ease-in-out infinite alternate;}\n  .orb.two{width:360px;height:360px;background:linear-gradient(135deg, #00e0b8, #7c5cff); right:-8%; bottom:-5%; animation: float2 14s ease-in-out infinite alternate;}\n  .orb.three{width:260px;height:260px;background:linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02)); left:20%; bottom:15%; animation: float3 18s linear infinite;}\n  @keyframes float1{from{transform:translateY(0) rotate(0deg)} to{transform:translateY(-28px) rotate(6deg)}}\n  @keyframes float2{from{transform:translateY(0) rotate(0deg)} to{transform:translateY(36px) rotate(-6deg)}}\n  @keyframes float3{from{transform:translateY(0)} to{transform:translateY(-20px)}}\n\n  /* Header */\n  header{\n    position:relative;\n    z-index:2;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    padding:28px 48px;\n    gap:24px;\n  }\n  .brand{\n    display:flex;\n    align-items:center;\n    gap:18px;\n    user-select:none;\n  }\n  .logo{\n    width:64px;height:64px;border-radius:14px;\n    background:linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    box-shadow: 0 6px 30px rgba(10,10,20,0.5), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;align-items:center;justify-content:center;\n    position:relative;overflow:hidden;\n    border:1px solid rgba(255,255,255,0.04);\n  }\n  .logo svg{width:44px;height:44px; filter: drop-shadow(0 6px 16px rgba(124,92,255,0.15));}\n  h1{font-size:20px;margin:0;font-weight:700;letter-spacing:-0.3px;color:var(--text)}\n  p.lead{margin:0;color:var(--sub);font-size:13px}\n\n  /* Controls */\n  .controls{display:flex;gap:12px;align-items:center}\n  .btn{\n    --btn-bg: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    background:var(--btn-bg);\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--text);\n    padding:10px 14px;\n    font-weight:600;\n    border-radius:12px;\n    cursor:pointer;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    backdrop-filter: blur(6px);\n    transition: transform .18s cubic-bezier(.2,.9,.3,1), box-shadow .18s;\n    box-shadow: 0 6px 24px rgba(3,6,23,0.45);\n  }\n  .btn:active{transform: translateY(2px) scale(.998)}\n  .btn.primary{\n    background:linear-gradient(90deg,var(--accent), #5a9bff);\n    box-shadow: 0 10px 40px rgba(92,66,255,0.18);\n    border: none;\n    color:white;\n  }\n  .btn.ghost{\n    background:transparent;\n    border:1px dashed rgba(255,255,255,0.04);\n    color:var(--sub);\n  }\n  .btn svg{opacity:0.95}\n\n  /* Main canvas */\n  .stage{\n    position:relative;\n    z-index:2;\n    display:flex;\n    gap:28px;\n    padding:24px 48px 64px 48px;\n    align-items:flex-start;\n  }\n\n  .panel{\n    flex:1 1 720px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius: var(--card-radius);\n    padding:28px;\n    box-shadow: 0 30px 80px rgba(3,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Graph area */\n  .graph-wrap{\n    position:relative;\n    height:520px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  .graph{\n    width:930px;\n    height:420px;\n    position:relative;\n    user-select:none;\n  }\n\n  /* Commit visuals */\n  svg.commit-graph{width:100%;height:100%}\n  .edge{\n    fill:none;\n    stroke:linear-gradient(90deg,#fff,#fff);\n    stroke-width:3.5;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    stroke-opacity:0.12;\n    transition: stroke-opacity .45s ease;\n  }\n  .edge.active{stroke-opacity:0.9; filter:url(#glow);}\n  .edge.master{stroke: url(#grad-main); stroke-width:3.5}\n  .edge.feature{stroke: url(#grad-feature); stroke-width:3.5; stroke-dasharray:6 8}\n  .node{\n    transform-origin:center;\n    transition: transform .28s cubic-bezier(.17,.85,.3,1), opacity .28s;\n    opacity:0; transform:scale(.4);\n    filter: drop-shadow(0 8px 24px rgba(2,4,20,0.6));\n  }\n  .node.visible{opacity:1; transform:scale(1)}\n  .commit-dot{stroke:#0f1724; stroke-width:2}\n  .commit-dot.master{fill: url(#grad-main)}\n  .commit-dot.feature{fill: url(#grad-feature) }\n\n  /* Commit labels (card-like) */\n  .commit-card{\n    position:absolute;\n    right:28px;\n    top:28px;\n    width:260px;\n    padding:16px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 10px 30px rgba(3,6,23,0.45);\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--sub);\n    font-size:13px;\n    display:flex;\n    gap:10px;\n    align-items:flex-start;\n  }\n  .commit-card .meta{display:flex;flex-direction:column;gap:6px}\n  .commit-card .meta .msg{color:var(--text);font-weight:700}\n  .commit-card .meta .details{font-size:12px;color:rgba(230,238,248,0.65)}\n\n  /* Side info panels */\n  .side{\n    width:320px;\n    display:flex;\n    flex-direction:column;\n    gap:20px;\n  }\n  .info{\n    padding:18px;border-radius:14px;background:linear-gradient(180deg,var(--glass),var(--glass-2));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 30px rgba(3,6,23,0.45);\n    color:var(--sub);\n    font-size:13px;\n  }\n  .info h3{margin:0 0 8px 0;color:var(--text);font-size:14px}\n  .pill{display:inline-flex;padding:8px 12px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);font-weight:700;color:var(--sub);}\n\n  /* small legend */\n  .legend{display:flex;gap:12px;align-items:center;margin-top:12px}\n  .legend .dot{width:12px;height:12px;border-radius:50%}\n  .legend .lbl{font-size:12px;color:var(--sub)}\n\n  /* Footer */\n  footer{position:fixed;left:20px;bottom:18px;color:rgba(255,255,255,0.06);font-size:12px;z-index:2}\n\n  /* responsive */\n  @media (max-width:980px){\n    .stage{flex-direction:column;padding:18px}\n    .panel{width:100%}\n    .side{width:100%}\n    header{padding:18px}\n    .logo{width:52px;height:52px}\n  }\n\n  /* subtle micro interactions */\n  .btn:focus{outline:3px solid rgba(124,92,255,0.12);outline-offset:3px}\n  .node:hover{transform:scale(1.06)}\n  .commit-card .sha{font-family:monospace;font-size:12px;color:rgba(255,255,255,0.5)}\n  /* hide pointer events for ambience */\n  .ambience{pointer-events:none}\n</style>\n</head>\n<body>\n  <div class=\"ambience\" aria-hidden=\"true\">\n    <div class=\"orb one\"></div>\n    <div class=\"orb two\"></div>\n    <div class=\"orb three\"></div>\n  </div>\n\n  <header>\n    <div class=\"brand\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <!-- stylized git logo -->\n        <svg viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"lg1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"1\" stop-color=\"#00e0b8\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"0\" y=\"0\" width=\"64\" height=\"64\" rx=\"12\" fill=\"url(#lg1)\"/>\n          <g transform=\"translate(8,8)\" fill=\"#0b1020\">\n            <path d=\"M10 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4zm28 24a2 2 0 1 1 0 4 2 2 0 0 1 0-4zM10 36a2 2 0 1 1 0 4 2 2 0 0 1 0-4z\" opacity=\"0.95\"/>\n            <path d=\"M15 6c6 0 16 6 20 10 2 2 6 7 5 11-1 5-6 6-10 6-4 0-6-3-8-4-3 1-9 2-13-1 0-5 3-15 6-18 2-2 3-4 0-0z\" fill=\"#0b1020\" opacity=\"0.96\" transform=\"translate(0,0)\"/>\n          </g>\n        </svg>\n      </div>\n      <div>\n        <h1>Git — Flow & History</h1>\n        <p class=\"lead\">A beautiful visual exploration of commits, branches, and merges.</p>\n      </div>\n    </div>\n\n    <div class=\"controls\" role=\"toolbar\" aria-label=\"Animation controls\">\n      <button class=\"btn primary\" id=\"animateBtn\" title=\"Animate the Git flow\">\n        <!-- Play Icon -->\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"/>\n        </svg>\n        Animate\n      </button>\n      <button class=\"btn ghost\" id=\"resetBtn\" title=\"Reset visualization\">\n        <!-- Reset Icon -->\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M21 12A9 9 0 1 0 6.2 4.3\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M21 3v6h-6\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        Reset\n      </button>\n    </div>\n  </header>\n\n  <main class=\"stage\" role=\"main\">\n    <section class=\"panel\" aria-label=\"Git commit graph\">\n      <div class=\"graph-wrap\" aria-hidden=\"false\">\n        <div class=\"graph\" id=\"graphContainer\">\n          <!-- SVG Graph -->\n          <svg class=\"commit-graph\" viewBox=\"0 0 930 420\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\" id=\"svgGraph\">\n            <defs>\n              <linearGradient id=\"grad-main\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n                <stop offset=\"1\" stop-color=\"#5a9bff\"/>\n              </linearGradient>\n              <linearGradient id=\"grad-feature\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#00e0b8\"/>\n                <stop offset=\"1\" stop-color=\"#7c5cff\"/>\n              </linearGradient>\n              <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n                <feMerge>\n                  <feMergeNode in=\"coloredBlur\"/>\n                  <feMergeNode in=\"SourceGraphic\"/>\n                </feMerge>\n              </filter>\n            </defs>\n\n            <!-- Background soft grid (aesthetic) -->\n            <g opacity=\"0.06\">\n              <rect x=\"0\" y=\"0\" width=\"930\" height=\"420\" fill=\"none\" stroke=\"rgba(255,255,255,0.02)\" stroke-width=\"1\"/>\n              <!-- some faint radial lines -->\n              <circle cx=\"420\" cy=\"210\" r=\"200\" stroke=\"rgba(255,255,255,0.01)\" fill=\"none\" />\n            </g>\n\n            <!-- Edges -->\n            <g id=\"edgesGroup\">\n              <!-- master path: linear top -->\n              <path id=\"edge-1\" class=\"edge master\" d=\"M120 80 L260 80\" stroke-linecap=\"round\" />\n              <path id=\"edge-2\" class=\"edge master\" d=\"M320 80 L460 80\" stroke-linecap=\"round\" />\n              <path id=\"edge-3\" class=\"edge master\" d=\"M560 80 L700 80\" stroke-linecap=\"round\" />\n              <path id=\"edge-merge\" class=\"edge master\" d=\"M460 80 C540 140 620 160 640 220\" stroke-linecap=\"round\" />\n\n              <!-- master continuation -->\n              <path id=\"edge-4\" class=\"edge master\" d=\"M700 80 L820 80\" stroke-linecap=\"round\" />\n\n              <!-- feature branch: diverge downward -->\n              <path id=\"edge-f1\" class=\"edge feature\" d=\"M460 80 C500 130 520 160 520 220\" stroke-linecap=\"round\" />\n              <path id=\"edge-f2\" class=\"edge feature\" d=\"M520 220 L620 220\" stroke-linecap=\"round\" />\n            </g>\n\n            <!-- Nodes (commits) group -->\n            <g id=\"nodesGroup\">\n              <!-- master commits -->\n              <g id=\"c1\" class=\"node\" transform=\"translate(120,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n              <g id=\"c2\" class=\"node\" transform=\"translate(260,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n              <g id=\"c3\" class=\"node\" transform=\"translate(320,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n              <g id=\"c4\" class=\"node\" transform=\"translate(460,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n              <g id=\"c5\" class=\"node\" transform=\"translate(560,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n              <g id=\"c6\" class=\"node\" transform=\"translate(700,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n              <g id=\"c7\" class=\"node\" transform=\"translate(820,80)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"12\"/>\n              </g>\n\n              <!-- feature commits -->\n              <g id=\"f1\" class=\"node\" transform=\"translate(520,220)\">\n                <circle class=\"commit-dot feature\" cx=\"0\" cy=\"0\" r=\"11\"/>\n              </g>\n              <g id=\"f2\" class=\"node\" transform=\"translate(620,220)\">\n                <circle class=\"commit-dot feature\" cx=\"0\" cy=\"0\" r=\"11\"/>\n              </g>\n\n              <!-- merge commit located near 700,120 (visual) -->\n              <g id=\"m1\" class=\"node\" transform=\"translate(640,220)\">\n                <circle class=\"commit-dot master\" cx=\"0\" cy=\"0\" r=\"13\"/>\n              </g>\n            </g>\n\n            <!-- faint branch labels -->\n            <g id=\"labels\" font-family=\"Inter, Arial\" font-size=\"12\" fill=\"rgba(255,255,255,0.65)\">\n              <text x=\"90\" y=\"42\">master</text>\n              <text x=\"520\" y=\"260\">feature/login</text>\n            </g>\n          </svg>\n\n          <!-- Commit meta card -->\n          <div class=\"commit-card\" id=\"commitCard\" aria-live=\"polite\">\n            <div style=\"width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,#7c5cff,#00e0b8);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:14px\">G</div>\n            <div class=\"meta\">\n              <div class=\"msg\" id=\"cardMsg\">Repository ready</div>\n              <div class=\"details\" id=\"cardDetails\">Press Animate to see commits appear in an elegant flow.</div>\n              <div class=\"sha\" id=\"cardSha\" style=\"margin-top:6px;opacity:0.8\">—</div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </section>\n\n    <aside class=\"side\" aria-label=\"Information panel\">\n      <div class=\"info\" aria-hidden=\"false\">\n        <h3>Concepts illustrated</h3>\n        <div style=\"display:flex;flex-direction:column;gap:10px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div>\n              <div style=\"font-weight:700;color:var(--text)\">Commits</div>\n              <div style=\"color:var(--sub);font-size:13px\">Snapshots of work—appearing as polished nodes</div>\n            </div>\n            <div class=\"pill\">Atomic</div>\n          </div>\n\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div>\n              <div style=\"font-weight:700;color:var(--text)\">Branches</div>\n              <div style=\"color:var(--sub);font-size:13px\">Isolated lines of development (master & feature)</div>\n            </div>\n            <div class=\"pill\">Parallel</div>\n          </div>\n\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div>\n              <div style=\"font-weight:700;color:var(--text)\">Merge</div>\n              <div style=\"color:var(--sub);font-size:13px\">Feature merges back into master elegantly</div>\n            </div>\n            <div class=\"pill\">Resolve</div>\n          </div>\n        </div>\n\n        <div class=\"legend\" style=\"margin-top:14px\">\n          <div style=\"display:flex;align-items:center;gap:8px\">\n            <div class=\"dot\" style=\"background:linear-gradient(90deg,#7c5cff,#5a9bff)\"></div>\n            <div class=\"lbl\">master</div>\n          </div>\n          <div style=\"display:flex;align-items:center;gap:8px\">\n            <div class=\"dot\" style=\"background:linear-gradient(90deg,#00e0b8,#7c5cff)\"></div>\n            <div class=\"lbl\">feature/login</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"info\">\n        <h3>How this works</h3>\n        <div style=\"color:var(--sub);font-size:13px;line-height:1.4\">\n          A graceful sequence draws edges and reveals commits. Each node represents a commit; dashed strokes indicate feature branch work. Merges are shown with curved connectors. Visuals emphasize flow and clarity.\n        </div>\n      </div>\n\n    </aside>\n  </main>\n\n  <footer>Designed with care — Minimal interaction. Observe the flow.</footer>\n\n<script>\n(function(){\n  // Minimal, single-purpose animation control\n  const animateBtn = document.getElementById('animateBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const svg = document.getElementById('svgGraph');\n  const nodes = [\n    'c1','c2','c3','c4','c5','c6','c7','f1','f2','m1'\n  ];\n  const edges = [\n    'edge-1','edge-2','edge-3','edge-4','edge-f1','edge-f2','edge-merge'\n  ];\n\n  const cardMsg = document.getElementById('cardMsg');\n  const cardDetails = document.getElementById('cardDetails');\n  const cardSha = document.getElementById('cardSha');\n\n  // commit metadata sequence (simple)\n  const timeline = [\n    {id:'c1',msg:'Init repository',details:'First commit — project scaffolded.',sha:'a1b2c3d'},\n    {id:'c2',msg:'Add README',details:'Documentation added.',sha:'d4e5f6a'},\n    {id:'c3',msg:'Core API',details:'Core functionality implemented.',sha:'b7c8d9e'},\n    {id:'c4',msg:'Create branch',details:'feature/login branch created.',sha:'f1e2d3c'},\n    {id:'f1',msg:'Feature work',details:'Login form and UI pieces.',sha:'9a8b7c6'},\n    {id:'f2',msg:'Feature complete',details:'Feature ready for merge.',sha:'4b5c6d7'},\n    {id:'m1',msg:'Merge feature',details:'Merged feature/login into master.',sha:'c0ffee0'},\n    {id:'c5',msg:'Refactor',details:'Minor refactors on master.',sha:'deadbe1'},\n    {id:'c6',msg:'Release prep',details:'Version bump and tests.',sha:'bead12f'},\n    {id:'c7',msg:'Release',details:'Tagged release v1.0.0',sha:'feedb33'}\n  ];\n\n  // utility: show/hide nodes and edges\n  function resetScene(){\n    // hide nodes\n    nodes.forEach(id=>{\n      const el = document.getElementById(id);\n      if(el) el.classList.remove('visible');\n    });\n    // hide edges by removing animation stroke dash\n    edges.forEach(id=>{\n      const el = document.getElementById(id);\n      if(el){\n        el.classList.remove('active');\n        // prepare stroke-dasharray trick\n        el.style.transition = 'none';\n        // compute length then set dasharray to full length to hide\n        const len = el.getTotalLength ? el.getTotalLength() : 300;\n        el.style.strokeDasharray = len;\n        el.style.strokeDashoffset = len;\n        // force reflow then remove style\n        void el.getBoundingClientRect();\n        el.style.transition = '';\n      }\n    });\n    // reset card\n    cardMsg.textContent = 'Repository ready';\n    cardDetails.textContent = 'Press Animate to see commits appear in an elegant flow.';\n    cardSha.textContent = '—';\n  }\n\n  // animate a specific edge by id\n  function animateEdge(id, duration=700, delay=0){\n    return new Promise(resolve=>{\n      const el = document.getElementById(id);\n      if(!el) return resolve();\n      const len = el.getTotalLength ? el.getTotalLength() : 300;\n      el.style.transition = 'none';\n      el.style.strokeDasharray = len;\n      el.style.strokeDashoffset = len;\n      // small timeout to apply\n      setTimeout(()=>{\n        el.classList.add('active');\n        el.style.transition = `stroke-dashoffset ${duration}ms cubic-bezier(.2,.9,.3,1), stroke-opacity ${duration/2}ms`;\n        el.style.strokeDashoffset = '0';\n        setTimeout(()=>resolve(), duration + 30);\n      }, delay);\n    });\n  }\n\n  // reveal node with pop\n  function revealNode(id, delay=0){\n    return new Promise(resolve=>{\n      const el = document.getElementById(id);\n      if(!el) return resolve();\n      setTimeout(()=>{\n        el.classList.add('visible');\n        // subtle bounce\n        el.animate([{transform:'scale(0.6)'},{transform:'scale(1.08)'},{transform:'scale(1)'}], {duration:420, easing:'cubic-bezier(.2,.9,.3,1)'});\n        setTimeout(()=>resolve(), 420);\n      }, delay);\n    });\n  }\n\n  // sequence orchestrator\n  async function playSequence(){\n    animateBtn.disabled = true;\n    resetBtn.disabled = true;\n    resetScene();\n\n    // start: draw initial master edges and reveal first 3 commits\n    await animateEdge('edge-1', 480);\n    await revealNode('c1'); updateCardFor('c1');\n    await animateEdge('edge-2', 480);\n    await revealNode('c2'); updateCardFor('c2');\n    await animateEdge('edge-3', 520);\n    await revealNode('c3'); updateCardFor('c3');\n\n    // create branch: reveal node c4\n    await revealNode('c4'); updateCardFor('c4');\n\n    // feature branch edges\n    await animateEdge('edge-f1', 640);\n    await revealNode('f1'); updateCardFor('f1');\n\n    await animateEdge('edge-f2', 420);\n    await revealNode('f2'); updateCardFor('f2');\n\n    // merge visual path and merge node\n    await animateEdge('edge-merge', 720);\n    await revealNode('m1'); updateCardFor('m1');\n\n    // continue master forward\n    await animateEdge('edge-4', 520);\n    await revealNode('c5'); updateCardFor('c5');\n    await revealNode('c6'); updateCardFor('c6');\n    await revealNode('c7'); updateCardFor('c7');\n\n    // final flourish\n    cardMsg.textContent = 'Flow complete';\n    cardDetails.textContent = 'Branches merged; history preserved with clarity.';\n    cardSha.textContent = '—';\n    // enable reset\n    animateBtn.disabled = false;\n    resetBtn.disabled = false;\n  }\n\n  function updateCardFor(id){\n    const found = timeline.find(t=>t.id===id);\n    if(found){\n      cardMsg.textContent = found.msg;\n      cardDetails.textContent = found.details;\n      cardSha.textContent = found.sha;\n    }\n  }\n\n  // prepare edges: set dash arrays to hide initially\n  function initEdges(){\n    edges.forEach(id=>{\n      const el = document.getElementById(id);\n      if(el){\n        const len = el.getTotalLength ? el.getTotalLength() : 300;\n        el.style.strokeDasharray = len;\n        el.style.strokeDashoffset = len;\n      }\n    });\n  }\n\n  // initial setup\n  resetScene();\n  initEdges();\n\n  // event listeners\n  animateBtn.addEventListener('click', ()=>{\n    // only one simple action\n    playSequence();\n  });\n  resetBtn.addEventListener('click', ()=>{\n    resetScene();\n  });\n\n  // subtle entrance animation when page loads (aesthetic)\n  window.addEventListener('load', ()=>{\n    // gentle reveal of main panel nodes (none visible initially)\n    document.querySelectorAll('.panel').forEach((p,i)=>{\n      p.animate([{opacity:0, transform:'translateY(18px)'},{opacity:1, transform:'translateY(0)'}],{duration:800, easing:'cubic-bezier(.2,.9,.3,1)', fill:'forwards', delay:120*i});\n    });\n  });\n\n})();\n</script>\n</body>\n</html>"
