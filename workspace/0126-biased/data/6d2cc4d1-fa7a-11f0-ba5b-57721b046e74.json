    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Hash Map Explorer</title>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #000;\n            padding: 10px;\n        }\n        button, input, select {\n            margin: 5px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n        }\n        th, td {\n            border: 1px solid #000;\n            padding: 5px;\n            text-align: left;\n        }\n        .bucket {\n            margin: 5px 0;\n            padding: 5px;\n            border: 1px dashed #000;\n        }\n        .key-value-pair {\n            display: inline-block;\n            margin: 2px;\n            padding: 2px 5px;\n            border: 1px solid #000;\n        }\n        .collision {\n            background-color: #f0e0e0;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Hash Map Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Hash Map Configuration</h2>\n            <div>\n                <tr>\n                    <td>Initial Size:</td>\n                    <td><input type=\"range\" id=\"sizeSlider\" min=\"1\" max=\"20\" value=\"5\"> <span id=\"sizeValue\">5</span></td>\n                </tr>\n                <tr>\n                    <td>Load Factor:</td>\n                    <td><input type=\"range\" id=\"loadFactorSlider\" min=\"10\" max=\"90\" value=\"75\"> <span id=\"loadFactorValue\">0.75</span></td>\n                </tr>\n                <tr>\n                    <td>Hash Function:</td>\n                    <td>\n                        <select id=\"hashFunctionSelect\">\n                            <option value=\"simple\">Simple (key % size)</option>\n                            <option value=\"complex\">Complex (custom hash)</option>\n                            <option value=\"random\">Random (for testing)</option>\n                        </select>\n                    </td>\n                </tr>\n                <tr>\n                    <td>Collision Resolution:</td>\n                    <td>\n                        <select id=\"collisionMethodSelect\">\n                            <option value=\"chaining\">Chaining</option>\n                            <option value=\"linear\">Linear Probing</option>\n                            <option value=\"quadratic\">Quadratic Probing</option>\n                        </select>\n                    </td>\n                </tr>\n            </div>\n            <button id=\"resetBtn\">Reset Hash Map</button>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Hash Map Operations</h2>\n            <div>\n                <input type=\"text\" id=\"keyInput\" placeholder=\"Key\">\n                <input type=\"text\" id=\"valueInput\" placeholder=\"Value\">\n                <button id=\"insertBtn\">Insert</button>\n                <button id=\"getBtn\">Get</button>\n                <button id=\"removeBtn\">Remove</button>\n                <button id=\"batchInsertBtn\">Batch Insert (10 random)</button>\n                <button id=\"clearBtn\">Clear All</button>\n            </div>\n            <div id=\"operationResult\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Hash Map Visualization</h2>\n            <div id=\"hashMapVisualization\"></div>\n            <div>\n                <p>Current Size: <span id=\"currentSize\">5</span></p>\n                <p>Current Load: <span id=\"currentLoad\">0</span>/<span id=\"currentCapacity\">5</span> (<span id=\"currentLoadPercent\">0</span>%)</p>\n                <p>Collisions: <span id=\"collisionCount\">0</span></p>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Hash Function Details</h2>\n            <div>\n                <input type=\"text\" id=\"hashTestInput\" placeholder=\"Test key\">\n                <button id=\"hashTestBtn\">Calculate Hash</button>\n                <div id=\"hashCalculationSteps\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        class HashMap {\n            constructor(size = 5, loadFactor = 0.75, hashFunction = 'simple', collisionMethod = 'chaining') {\n                this.size = size;\n                this.loadFactor = loadFactor;\n                this.hashFunction = hashFunction;\n                this.collisionMethod = collisionMethod;\n                this.buckets = Array(size).fill(null).map(() => []);\n                this.collisionCount = 0;\n                this.itemCount = 0;\n            }\n            \n            hash(key) {\n                if (this.hashFunction === 'complex') {\n                    let hash = 0;\n                    for (let i = 0; i < key.length; i++) {\n                        hash = (hash << 5) - hash + key.charCodeAt(i);\n                        hash |= 0;\n                    }\n                    return Math.abs(hash) % this.size;\n                } else if (this.hashFunction === 'random') {\n                    return Math.floor(Math.random() * this.size);\n                } else {\n                    // Simple hash\n                    return key.length % this.size;\n                }\n            }\n            \n            findIndex(key) {\n                const index = this.hash(key);\n                \n                if (this.collisionMethod === 'chaining') {\n                    return { bucketIndex: index, itemIndex: null };\n                }\n                \n                // For open addressing methods\n                let i = 0;\n                let currentIndex = index;\n                \n                while (true) {\n                    const bucket = this.buckets[currentIndex];\n                    if (bucket.length === 0 || bucket[0].key === key) {\n                        return { bucketIndex: currentIndex, itemIndex: 0 };\n                    }\n                    \n                    if (this.collisionMethod === 'linear') {\n                        currentIndex = (index + i) % this.size;\n                    } else { // quadratic\n                        currentIndex = (index + i * i) % this.size;\n                    }\n                    \n                    i++;\n                    if (i >= this.size) break;\n                }\n                \n                return { bucketIndex: -1, itemIndex: -1 };\n            }\n            \n            insert(key, value) {\n                if (this.itemCount / this.size >= this.loadFactor) {\n                    this.resize();\n                }\n                \n                const { bucketIndex, itemIndex } = this.findIndex(key);\n                \n                if (bucketIndex === -1) {\n                    return false; // No space found\n                }\n                \n                if (this.collisionMethod === 'chaining') {\n                    const bucket = this.buckets[bucketIndex];\n                    const existingIndex = bucket.findIndex(item => item.key === key);\n                    \n                    if (existingIndex >= 0) {\n                        bucket[existingIndex].value = value;\n                    } else {\n                        if (bucket.length > 0) this.collisionCount++;\n                        bucket.push({ key, value });\n                        this.itemCount++;\n                    }\n                } else {\n                    if (this.buckets[bucketIndex].length > 0 && this.buckets[bucketIndex][0].key !== key) {\n                        this.collisionCount++;\n                    }\n                    this.buckets[bucketIndex] = [{ key, value }];\n                    this.itemCount++;\n                }\n                \n                return true;\n            }\n            \n            get(key) {\n                const { bucketIndex, itemIndex } = this.findIndex(key);\n                \n                if (bucketIndex === -1) return undefined;\n                \n                if (this.collisionMethod === 'chaining') {\n                    const item = this.buckets[bucketIndex].find(item => item.key === key);\n                    return item ? item.value : undefined;\n                } else {\n                    if (this.buckets[bucketIndex].length > 0 && this.buckets[bucketIndex][0].key === key) {\n                        return this.buckets[bucketIndex][0].value;\n                    }\n                    return undefined;\n                }\n            }\n            \n            remove(key) {\n                const { bucketIndex, itemIndex } = this.findIndex(key);\n                \n                if (bucketIndex === -1) return false;\n                \n                if (this.collisionMethod === 'chaining') {\n                    const bucket = this.buckets[bucketIndex];\n                    const index = bucket.findIndex(item => item.key === key);\n                    if (index >= 0) {\n                        bucket.splice(index, 1);\n                        this.itemCount--;\n                        return true;\n                    }\n                } else {\n                    if (this.buckets[bucketIndex].length > 0 && this.buckets[bucketIndex][0].key === key) {\n                        this.buckets[bucketIndex] = [];\n                        this.itemCount--;\n                        return true;\n                    }\n                }\n                \n                return false;\n            }\n            \n            resize() {\n                const oldBuckets = this.buckets;\n                this.size *= 2;\n                this.buckets = Array(this.size).fill(null).map(() => []);\n                this.collisionCount = 0;\n                this.itemCount = 0;\n                \n                for (const bucket of oldBuckets) {\n                    for (const item of bucket) {\n                        this.insert(item.key, item.value);\n                    }\n                }\n            }\n            \n            clear() {\n                this.buckets = Array(this.size).fill(null).map(() => []);\n                this.collisionCount = 0;\n                this.itemCount = 0;\n            }\n        }\n\n        // UI Setup\n        const hashMap = new HashMap();\n        \n        // DOM Elements\n        const sizeSlider = document.getElementById('sizeSlider');\n        const sizeValue = document.getElementById('sizeValue');\n        const loadFactorSlider = document.getElementById('loadFactorSlider');\n        const loadFactorValue = document.getElementById('loadFactorValue');\n        const hashFunctionSelect = document.getElementById('hashFunctionSelect');\n        const collisionMethodSelect = document.getElementById('collisionMethodSelect');\n        const resetBtn = document.getElementById('resetBtn');\n        \n        const keyInput = document.getElementById('keyInput');\n        const valueInput = document.getElementById('valueInput');\n        const insertBtn = document.getElementById('insertBtn');\n        const getBtn = document.getElementById('getBtn');\n        const removeBtn = document.getElementById('removeBtn');\n        const batchInsertBtn = document.getElementById('batchInsertBtn');\n        const clearBtn = document.getElementById('clearBtn');\n        const operationResult = document.getElementById('operationResult');\n        \n        const hashMapVisualization = document.getElementById('hashMapVisualization');\n        const currentSize = document.getElementById('currentSize');\n        const currentLoad = document.getElementById('currentLoad');\n        const currentCapacity = document.getElementById('currentCapacity');\n        const currentLoadPercent = document.getElementById('currentLoadPercent');\n        const collisionCount = document.getElementById('collisionCount');\n        \n        const hashTestInput = document.getElementById('hashTestInput');\n        const hashTestBtn = document.getElementById('hashTestBtn');\n        const hashCalculationSteps = document.getElementById('hashCalculationSteps');\n        \n        // Event Listeners\n        sizeSlider.addEventListener('input', () => {\n            sizeValue.textContent = sizeSlider.value;\n        });\n        \n        loadFactorSlider.addEventListener('input', () => {\n            loadFactorValue.textContent = (loadFactorSlider.value / 100).toFixed(2);\n        });\n        \n        resetBtn.addEventListener('click', () => {\n            hashMap.size = parseInt(sizeSlider.value);\n            hashMap.loadFactor = parseFloat(loadFactorSlider.value / 100);\n            hashMap.hashFunction = hashFunctionSelect.value;\n            hashMap.collisionMethod = collisionMethodSelect.value;\n            hashMap.clear();\n            updateVisualization();\n            operationResult.textContent = 'Hash map reset with new configuration.';\n        });\n        \n        insertBtn.addEventListener('click', () => {\n            const key = keyInput.value.trim();\n            const value = valueInput.value.trim();\n            \n            if (!key) {\n                operationResult.textContent = 'Please enter a key.';\n                return;\n            }\n            \n            const success = hashMap.insert(key, value);\n            updateVisualization();\n            if (success) {\n                operationResult.textContent = `Inserted: ${key} => ${value}`;\n            } else {\n                operationResult.textContent = `Failed to insert ${key} (no space found with current collision method).`;\n            }\n        });\n        \n        getBtn.addEventListener('click', () => {\n            const key = keyInput.value.trim();\n            \n            if (!key) {\n                operationResult.textContent = 'Please enter a key.';\n                return;\n            }\n            \n            const value = hashMap.get(key);\n            if (value !== undefined) {\n                operationResult.textContent = `Found: ${key} => ${value}`;\n            } else {\n                operationResult.textContent = `Key ${key} not found.`;\n            }\n        });\n        \n        removeBtn.addEventListener('click', () => {\n            const key = keyInput.value.trim();\n            \n            if (!key) {\n                operationResult.textContent = 'Please enter a key.';\n                return;\n            }\n            \n            const success = hashMap.remove(key);\n            updateVisualization();\n            if (success) {\n                operationResult.textContent = `Removed key: ${key}`;\n            } else {\n                operationResult.textContent = `Key ${key} not found.`;\n            }\n        });\n        \n        batchInsertBtn.addEventListener('click', () => {\n            const randomWords = ['apple', 'banana', 'cherry', 'date', 'elderberry', \n                               'fig', 'grape', 'honeydew', 'kiwi', 'lemon'];\n            \n            for (let i = 0; i < 10; i++) {\n                const word = randomWords[Math.floor(Math.random() * randomWords.length)];\n                hashMap.insert(word + i, `value-${Math.random().toString(36).substr(2, 5)}`);\n            }\n            \n            updateVisualization();\n            operationResult.textContent = 'Inserted 10 random key-value pairs.';\n        });\n        \n        clearBtn.addEventListener('click', () => {\n            hashMap.clear();\n            updateVisualization();\n            operationResult.textContent = 'Cleared all entries from hash map.';\n        });\n        \n        hashTestBtn.addEventListener('click', () => {\n            const key = hashTestInput.value.trim();\n            \n            if (!key) {\n                hashCalculationSteps.textContent = 'Please enter a key to test.';\n                return;\n            }\n            \n            let steps = '';\n            if (hashMap.hashFunction === 'complex') {\n                steps += 'Complex hash calculation:\\n';\n                steps += `Key: \"${key}\"\\n\\n`;\n                \n                let hash = 0;\n                steps += 'Initialize hash = 0\\n';\n                \n                for (let i = 0; i < key.length; i++) {\n                    const charCode = key.charCodeAt(i);\n                    steps += `Character '${key[i]}' (ASCII ${charCode}):\\n`;\n                    steps += `  hash = (hash << 5) - hash + ${charCode}\\n`;\n                    hash = (hash << 5) - hash + charCode;\n                    steps += `  hash = ${hash}\\n`;\n                    steps += `  hash = ${hash} | 0 (convert to 32-bit integer)\\n`;\n                    hash |= 0;\n                    steps += `  Current hash: ${hash}\\n\\n`;\n                }\n                \n                const finalHash = Math.abs(hash) % hashMap.size;\n                steps += `Final hash: Math.abs(${hash}) % ${hashMap.size} = ${finalHash}\\n`;\n            } else if (hashMap.hashFunction === 'random') {\n                steps += 'Random hash (for testing only):\\n';\n                steps += `Random index between 0 and ${hashMap.size - 1}\\n`;\n                steps += `Result: ${hashMap.hash(key)}`;\n            } else {\n                steps += 'Simple hash calculation:\\n';\n                steps += `key.length % size = ${key.length} % ${hashMap.size} = ${hashMap.hash(key)}`;\n            }\n            \n            hashCalculationSteps.textContent = steps;\n        });\n        \n        function updateVisualization() {\n            hashMapVisualization.innerHTML = '';\n            \n            currentSize.textContent = hashMap.size;\n            currentLoad.textContent = hashMap.itemCount;\n            currentCapacity.textContent = hashMap.size;\n            currentLoadPercent.textContent = Math.round((hashMap.itemCount / hashMap.size) * 100);\n            collisionCount.textContent = hashMap.collisionCount;\n            \n            for (let i = 0; i < hashMap.buckets.length; i++) {\n                const bucketDiv = document.createElement('div');\n                bucketDiv.className = 'bucket';\n                \n                const bucketHeader = document.createElement('div');\n                bucketHeader.textContent = `Bucket ${i}:`;\n                bucketDiv.appendChild(bucketHeader);\n                \n                const bucket = hashMap.buckets[i];\n                if (bucket.length === 0) {\n                    const emptySpan = document.createElement('span');\n                    emptySpan.textContent = ' (empty)';\n                    bucketDiv.appendChild(emptySpan);\n                } else {\n                    bucket.forEach((item, index) => {\n                        const pairDiv = document.createElement('div');\n                        pairDiv.className = 'key-value-pair' + (index > 0 ? ' collision' : '');\n                        pairDiv.textContent = `${item.key} => ${item.value}`;\n                        pairDiv.title = `Hash: ${hashMap.hash(item.key)}`;\n                        bucketDiv.appendChild(pairDiv);\n                    });\n                }\n                \n                hashMapVisualization.appendChild(bucketDiv);\n            }\n        }\n        \n        // Initialize\n        updateVisualization();\n    </script>\n</body>\n</html>"
