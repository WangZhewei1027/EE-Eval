    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Time Complexity Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #2c3e50;\n            color: #ecf0f1;\n            overflow: hidden;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n        }\n        h1 {\n            font-size: 3em;\n            margin-bottom: 20px;\n            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.5);\n        }\n        .graph-container {\n            position: relative;\n            width: 80%;\n            max-width: 800px;\n            height: 400px;\n            border: 2px solid #ecf0f1;\n            border-radius: 10px;\n            overflow: hidden;\n            background: linear-gradient(135deg, #3498db 0%, #9b59b6 100%);\n            box-shadow: 0 0 30px rgba(0, 0, 0, 0.3);\n        }\n        .bar {\n            position: absolute;\n            bottom: 0;\n            background-color: #e74c3c;\n            transition: height 0.4s ease-in-out, transform 0.4s ease-in-out;\n            border-radius: 5px 5px 0 0;\n        }\n        button {\n            margin-top: 20px;\n            padding: 10px 20px;\n            background-color: #16a085;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            font-size: 1.2em;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.3);\n            transition: background 0.3s, transform 0.3s;\n        }\n        button:hover {\n            background-color: #1abc9c;\n            transform: scale(1.05);\n        }\n        button:focus {\n            outline: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Time Complexity Visualization</h1>\n        <div class=\"graph-container\" id=\"graph-container\">\n            <!-- Bars will be created here -->\n        </div>\n        <button id=\"visualizeButton\">Visualize Complexity</button>\n    </div>\n\n    <script>\n        const complexities = [\n            { name: 'O(1)', height: 40 },\n            { name: 'O(log n)', height: 70 },\n            { name: 'O(n)', height: 100 },\n            { name: 'O(n log n)', height: 150 },\n            { name: 'O(n^2)', height: 200 },\n            { name: 'O(2^n)', height: 300 },\n            { name: 'O(n!)', height: 350 },\n        ];\n\n        const graphContainer = document.getElementById('graph-container');\n        const visualizeButton = document.getElementById('visualizeButton');\n\n        visualizeButton.onclick = () => {\n            graphContainer.innerHTML = '';\n            complexities.forEach((complexity, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.width = `${(index + 1) * 10}%`;\n                bar.style.height = `${complexity.height}px`;\n                bar.style.transform = `translateX(${10 * index}%)`;\n                bar.innerText = complexity.name;\n                bar.style.display = 'flex';\n                bar.style.alignItems = 'center';\n                bar.style.justifyContent = 'center';\n                bar.style.color = '#ecf0f1';\n                bar.style.fontSize = '1.2em';\n                bar.style.marginLeft = `${5}px`;\n                graphContainer.appendChild(bar);\n                bar.style.transitionDelay = `${index * 100}ms`; // stagger the animation\n            });\n        };\n    </script>\n</body>\n</html>"
