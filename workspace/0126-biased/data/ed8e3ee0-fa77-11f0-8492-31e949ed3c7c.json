    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Two Pointers Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #1d1f21;\n            color: #f5f5f5;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            text-align: center;\n            position: relative;\n            width: 80%;\n            max-width: 800px;\n            background: #282c34;\n            border-radius: 12px;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);\n            overflow: hidden;\n        }\n        .title {\n            font-size: 2.5rem;\n            margin: 20px 0;\n            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);\n        }\n        .array-container {\n            display: flex;\n            justify-content: space-around;\n            align-items: flex-end;\n            height: 250px;\n            margin: 20px 0;\n        }\n        .bar {\n            width: 60px;\n            background: #007bff;\n            transition: height 0.4s ease;\n        }\n        .pointer {\n            background: #ff5722;\n            position: relative;\n            margin: 0 10px;\n            border-radius: 5px;\n            animation: pulse 1s infinite;\n        }\n        button {\n            background-color: #28a745;\n            border: none;\n            border-radius: 5px;\n            color: white;\n            font-size: 1.2rem;\n            padding: 10px 20px;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n            margin: 20px;\n        }\n        button:hover {\n            background-color: #218838;\n        }\n        @keyframes pulse {\n            0% {\n                transform: scale(1);\n            }\n            50% {\n                transform: scale(1.1);\n            }\n            100% {\n                transform: scale(1);\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"title\">Two Pointers Visualization</div>\n        <div class=\"array-container\" id=\"arrayContainer\">\n            <!-- Bars will be dynamically added here -->\n        </div>\n        <button id=\"startBtn\">Visualize Two Pointers</button>\n    </div>\n\n    <script>\n        const arrayContainer = document.getElementById('arrayContainer');\n        const startBtn = document.getElementById('startBtn');\n\n        const array = [4, 2, 7, 3, 5, 1, 6, 8];\n        let leftPointer = 0;\n        let rightPointer = array.length - 1;\n\n        function createBars() {\n            arrayContainer.innerHTML = '';\n            array.forEach((value, index) => {\n                const bar = document.createElement('div');\n                bar.classList.add('bar');\n                bar.style.height = `${value * 30}px`;\n                if (index === leftPointer || index === rightPointer) {\n                    const pointerDiv = document.createElement('div');\n                    pointerDiv.classList.add('pointer');\n                    pointerDiv.style.height = `${value * 30}px`;\n                    bar.appendChild(pointerDiv);\n                }\n                arrayContainer.appendChild(bar);\n            });\n        }\n\n        function visualize() {\n            createBars();\n            if (leftPointer < rightPointer) {\n                leftPointer++;\n                rightPointer--;\n            }\n            if (leftPointer <= rightPointer) {\n                setTimeout(visualize, 1000);\n            }\n        }\n\n        startBtn.addEventListener('click', () => {\n            leftPointer = 0;\n            rightPointer = array.length - 1;\n            visualize();\n        });\n\n        createBars();\n    </script>\n</body>\n</html>"
