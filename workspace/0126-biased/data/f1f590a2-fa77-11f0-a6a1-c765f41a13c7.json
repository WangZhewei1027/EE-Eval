    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Insertion Sort — Visual Elegance</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@500;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #081124;\n    --glass: rgba(255,255,255,0.06);\n    --accent: #7dd3fc;\n    --accent-2: #a78bfa;\n    --muted: #bcd5e8;\n    --success: #34d399;\n    --danger: #fb7185;\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n  }\n\n  * { box-sizing: border-box; }\n  html,body { height:100%; margin:0; font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background: radial-gradient(1200px 600px at 10% 20%, rgba(122,106,255,0.12), transparent 6%), radial-gradient(900px 350px at 90% 80%, rgba(29,78,216,0.08), transparent 8%), linear-gradient(180deg,var(--bg-1), var(--bg-2)); color: #dbeafe; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;}\n  .scene {\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* gentle floating orbs */\n  .orb {\n    position:absolute;\n    border-radius:50%;\n    filter:blur(40px);\n    opacity:0.16;\n    transform:translate3d(0,0,0);\n    will-change:transform,opacity;\n  }\n  .orb.one { width:360px;height:360px; left:-8%; top:8%; background:linear-gradient(135deg,#7dd3fc,#60a5fa); animation:float 18s ease-in-out infinite; }\n  .orb.two { width:300px;height:300px; right:-6%; bottom:6%; background:linear-gradient(135deg,#a78bfa,#60a5fa); animation:float 20s ease-in-out infinite reverse; }\n  @keyframes float { 0% { transform:translateY(-10px); } 50% { transform:translateY(18px) translateX(6px); } 100% { transform:translateY(-10px); } }\n\n  .card {\n    width:1100px;\n    max-width:96vw;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.04);\n    padding:28px;\n    position:relative;\n    overflow:visible;\n  }\n\n  .header {\n    display:flex;\n    gap:18px;\n    align-items:center;\n    margin-bottom:20px;\n  }\n  .logo {\n    width:84px;height:84px;border-radius:14px;\n    background: linear-gradient(135deg, rgba(125,211,252,0.12), rgba(167,139,250,0.12));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 6px 20px rgba(10,20,40,0.45), inset 0 -6px 20px rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    flex:0 0 84px;\n  }\n  .logo svg{ filter:drop-shadow(0 4px 10px rgba(0,0,0,0.4)); }\n  .title {\n    display:flex;flex-direction:column;\n  }\n  .title h1 { margin:0; font-family: 'Playfair Display', serif; font-weight:700; letter-spacing:-0.02em; color: #e6eefc; font-size:22px; }\n  .title p { margin:6px 0 0 0; color:var(--muted); font-size:13px; }\n\n  .main {\n    display:flex;\n    gap:28px;\n    align-items:flex-start;\n  }\n\n  .visual {\n    flex:1 1 680px;\n    position:relative;\n    padding:26px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 30px rgba(3,10,30,0.5);\n    min-height:320px;\n  }\n\n  /* grid area for array */\n  .arena {\n    position:relative;\n    height:220px;\n    width:100%;\n    margin-top:8px;\n    display:block;\n    overflow:visible;\n  }\n\n  /* subtle floor */\n  .arena::after{\n    content:\"\";\n    position:absolute;left:50%;transform:translateX(-50%);bottom:-12px;\n    width:88%;height:28px;border-radius:12px;\n    background:linear-gradient(180deg, rgba(0,0,0,0.25), transparent);\n    filter:blur(18px);\n    opacity:0.25;\n  }\n\n  .slot {\n    position:absolute;\n    bottom:26px;\n    width:72px;\n    height:140px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px dashed rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n    transform:translateY(0);\n    transition: transform 450ms cubic-bezier(.2,.9,.3,1);\n  }\n\n  .item {\n    position:absolute;\n    bottom:26px;\n    width:72px;\n    height:140px;\n    border-radius:14px;\n    display:flex;\n    align-items:end;\n    justify-content:center;\n    padding:14px;\n    color:#061025;\n    font-weight:700;\n    font-size:14px;\n    letter-spacing:0.02em;\n    transition: transform 500ms cubic-bezier(.2,.9,.3,1), left 500ms cubic-bezier(.2,.9,.3,1), bottom 300ms ease;\n    box-shadow: 0 8px 30px rgba(2,8,23,0.5);\n    will-change:transform,left,bottom;\n    cursor:default;\n  }\n\n  .value {\n    display:block;\n    width:100%;\n    text-align:center;\n    margin-bottom:8px;\n    font-weight:800;\n    color: rgba(255,255,255,0.95);\n    text-shadow: 0 1px 0 rgba(255,255,255,0.02);\n    font-size:14px;\n  }\n\n  .bar {\n    width:60%;\n    height: var(--h,50%);\n    border-radius:10px;\n    margin:0 auto 8px;\n    box-shadow: inset 0 -12px 20px rgba(255,255,255,0.06), 0 6px 18px rgba(0,0,0,0.4);\n    transition: height 500ms cubic-bezier(.2,.9,.3,1), background 500ms ease;\n  }\n\n  /* types */\n  .item.sorted { filter:brightness(1.06) saturate(1.05); }\n  .item.key { transform: translateY(-38px) scale(1.06); z-index:50; box-shadow:0 25px 60px rgba(10,20,60,0.6); }\n  .item.compare { box-shadow: 0 12px 40px rgba(23,40,90,0.7); transform: translateY(-8px) scale(1.02); z-index:40; }\n\n  /* color palettes for bars */\n  .bar.p1 { background: linear-gradient(180deg,#7dd3fc,#60a5fa); }\n  .bar.p2 { background: linear-gradient(180deg,#93c5fd,#60a5fa); }\n  .bar.p3 { background: linear-gradient(180deg,#a78bfa,#7c3aed); }\n  .bar.p4 { background: linear-gradient(180deg,#fda4af,#fb7185); }\n  .bar.p5 { background: linear-gradient(180deg,#86efac,#34d399); }\n\n  /* right panel */\n  .side {\n    width:260px;\n    min-width:220px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:stretch;\n  }\n\n  .panel {\n    padding:18px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n  }\n\n  .controls {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:space-between;\n  }\n\n  .btn {\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--accent);\n    border: 1px solid rgba(125,211,252,0.12);\n    padding:10px 14px;\n    border-radius:10px;\n    cursor:pointer;\n    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms;\n    font-weight:600;\n    font-size:13px;\n  }\n  .btn:hover { transform:translateY(-4px); box-shadow: 0 10px 30px rgba(3,10,40,0.45); }\n  .btn.play { background: linear-gradient(90deg,#7dd3fc,#a78bfa); color:#061025; border:none; }\n  .btn.secondary { color:var(--muted); border:1px solid rgba(255,255,255,0.03); }\n\n  .legend { display:flex; gap:12px; flex-wrap:wrap; margin-top:12px; }\n  .legend .chip { display:inline-flex; gap:8px; align-items:center; padding:8px 10px; border-radius:999px; background: rgba(255,255,255,0.015); font-size:13px; color:var(--muted); }\n  .dot { width:12px;height:12px;border-radius:50%;box-shadow:0 4px 12px rgba(2,8,23,0.6), inset 0 -4px 8px rgba(255,255,255,0.03); }\n\n  .step {\n    margin-top:12px;\n    font-size:14px;\n    color:var(--muted);\n    min-height:48px;\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .step strong { color:#e6eefc; font-size:13px; font-weight:700; font-family:'Playfair Display', serif; }\n\n  .footer {\n    margin-top:18px;\n    color:rgba(255,255,255,0.06);\n    font-size:12px;\n    display:flex;justify-content:space-between;align-items:center;\n  }\n\n  /* tiny accents */\n  .glowline {\n    position:absolute;left:0;right:0;height:1px;top:16px;background:linear-gradient(90deg,transparent,#7dd3fc,transparent);opacity:0.06;\n  }\n\n  @media (max-width:900px){\n    .main { flex-direction:column; }\n    .side { width:100%; }\n    .logo { display:none; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"scene\">\n    <div class=\"orb one\" aria-hidden=\"true\"></div>\n    <div class=\"orb two\" aria-hidden=\"true\"></div>\n\n    <div class=\"card\" role=\"main\" aria-label=\"Insertion sort visualization\">\n      <div class=\"glowline\"></div>\n      <div class=\"header\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg width=\"46\" height=\"46\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"2\" y=\"2\" width=\"44\" height=\"44\" rx=\"10\" fill=\"url(#g1)\"/>\n            <path d=\"M14 32L20.5 20L26 28L34 12\" stroke=\"#061025\" stroke-width=\"2.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7dd3fc\"/>\n                <stop offset=\"1\" stop-color=\"#a78bfa\"/>\n              </linearGradient>\n            </defs>\n          </svg>\n        </div>\n        <div class=\"title\">\n          <h1>Insertion Sort — A Cinematic Demonstration</h1>\n          <p>Observe the graceful movement as elements are picked, compared, shifted and inserted.</p>\n        </div>\n      </div>\n\n      <div class=\"main\">\n        <div class=\"visual\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n            <div style=\"font-weight:700;font-family:Playfair Display, serif;font-size:16px;color:#e6eefc;\">Array Arena</div>\n            <div style=\"font-size:12px;color:var(--muted);\">Algorithm: Insertion Sort · Complexity: O(n²)</div>\n          </div>\n\n          <div class=\"arena\" id=\"arena\" aria-hidden=\"false\"></div>\n\n          <div style=\"margin-top:18px; display:flex;justify-content:space-between;align-items:center;\">\n            <div style=\"color:var(--muted); font-size:13px;\">Step <span id=\"stepCounter\">0</span> / <span id=\"stepTotal\">0</span></div>\n            <div style=\"color:var(--muted); font-size:13px;\">Auto-play speed: <strong id=\"speedLabel\">Normal</strong></div>\n          </div>\n\n        </div>\n\n        <div class=\"side\">\n          <div class=\"panel\">\n            <div class=\"controls\">\n              <button class=\"btn play\" id=\"playPause\" aria-pressed=\"false\" title=\"Play / Pause\">\n                <svg id=\"ppIcon\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"#061025\"></path></svg>\n                <span id=\"playLabel\">Pause</span>\n              </button>\n              <button class=\"btn secondary\" id=\"shuffle\" title=\"Shuffle & replay\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\"><path d=\"M3 3h6l8 8h4\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path><path d=\"M21 21h-6l-8-8H3\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n                Restart\n              </button>\n            </div>\n\n            <div class=\"legend\" style=\"margin-top:14px;\">\n              <div class=\"chip\"><span class=\"dot\" style=\"background:#60a5fa\"></span> Active Key</div>\n              <div class=\"chip\"><span class=\"dot\" style=\"background:#a78bfa\"></span> Comparing</div>\n              <div class=\"chip\"><span class=\"dot\" style=\"background:#34d399\"></span> Sorted</div>\n            </div>\n\n            <div class=\"step\" id=\"explanation\" style=\"margin-top:18px;\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 6v6l4 2\" stroke=\"#7dd3fc\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n              <div><strong>Initializing</strong><div style=\"font-size:13px;color:var(--muted);margin-top:6px;\">Preparing an elegant array…</div></div>\n            </div>\n\n            <div class=\"footer\">\n              <div style=\"display:flex;gap:10px;align-items:center;\">\n                <div style=\"width:10px;height:10px;border-radius:50%;background:linear-gradient(90deg,#7dd3fc,#a78bfa);box-shadow:0 6px 16px rgba(124,58,237,0.14)\"></div>\n                <div style=\"font-size:12px;color:var(--muted);\">Visual-only · Minimal controls</div>\n              </div>\n              <div style=\"font-size:12px;color:var(--muted);\">v1.0</div>\n            </div>\n          </div>\n\n          <div class=\"panel\" style=\"margin-top:10px;\">\n            <div style=\"font-weight:700;margin-bottom:8px;color:#e6eefc;\">Narrative</div>\n            <div style=\"font-size:13px;color:var(--muted);line-height:1.5;\">\n              Each element is gently lifted as the \"key\" and compares leftwards. Larger elements glide right to make room until the key finds its place, creating a calm choreography of order.\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Elegant insertion sort visualization with minimal controls: Play/Pause and Restart.\n  const arena = document.getElementById('arena');\n  const playPauseBtn = document.getElementById('playPause');\n  const playLabel = document.getElementById('playLabel');\n  const ppIcon = document.getElementById('ppIcon');\n  const shuffleBtn = document.getElementById('shuffle');\n  const explanation = document.getElementById('explanation');\n  const stepCounter = document.getElementById('stepCounter');\n  const stepTotal = document.getElementById('stepTotal');\n  const speedLabel = document.getElementById('speedLabel');\n\n  let items = [];\n  let values = [];\n  let positions = [];\n  let animating = true;\n  let stopSignal = false;\n  let speed = 600; // ms per micro-action\n  speedLabel.textContent = 'Normal';\n\n  // Config\n  const COUNT = 10;\n  const BAR_CLASSES = ['p1','p2','p3','p4','p5'];\n\n  // Utilities\n  const rand = (a,b) => Math.floor(Math.random()*(b-a+1))+a;\n  const sleep = (ms) => new Promise(res => setTimeout(res, ms));\n\n  // Responsive layout: compute slot positions\n  function computeSlots() {\n    const rect = arena.getBoundingClientRect();\n    const width = rect.width;\n    const slotWidth = Math.min(90, Math.max(60, Math.floor(width / COUNT) - 6));\n    const total = slotWidth * COUNT + (COUNT-1)*12;\n    const start = (width - total) / 2;\n    let slots = [];\n    for (let i=0;i<COUNT;i++){\n      const left = start + i*(slotWidth+12);\n      slots.push({left, width:slotWidth});\n    }\n    return slots;\n  }\n\n  function renderArray(vals) {\n    arena.innerHTML = '';\n    items = [];\n    values = vals.slice();\n    positions = computeSlots();\n\n    for (let i=0;i<COUNT;i++){\n      const v = values[i];\n      const slot = document.createElement('div');\n      slot.className = 'slot';\n      slot.style.left = positions[i].left + 'px';\n      slot.style.width = positions[i].width + 'px';\n      slot.setAttribute('aria-hidden','true');\n      arena.appendChild(slot);\n\n      const el = document.createElement('div');\n      el.className = 'item';\n      el.style.left = positions[i].left + 'px';\n      el.style.width = positions[i].width + 'px';\n      el.style.bottom = '26px';\n      el.setAttribute('data-index', i);\n      el.setAttribute('role','img');\n      el.setAttribute('aria-label', 'Value ' + v);\n      // Create bar\n      const bar = document.createElement('div');\n      bar.className = 'bar ' + BAR_CLASSES[i % BAR_CLASSES.length];\n      const h = Math.max(20, Math.round((v / 100) * 96));\n      bar.style.setProperty('--h', h + '%');\n      el.appendChild(bar);\n\n      const val = document.createElement('span');\n      val.className = 'value';\n      val.textContent = v;\n      el.appendChild(val);\n\n      arena.appendChild(el);\n      items.push(el);\n\n      // slight entrance animation\n      el.style.transform = 'translateY(12px) scale(0.98)';\n      el.style.opacity = '0.95';\n      (function(e){\n        requestAnimationFrame(() => {\n          e.style.transition = 'transform 800ms cubic-bezier(.18,.9,.32,1), left 500ms cubic-bezier(.2,.9,.3,1)';\n          e.style.transform = 'translateY(0) scale(1)';  \n        });\n      })(el);\n    }\n    stepCounter.textContent = '0';\n    stepTotal.textContent = '?';\n  }\n\n  // Update a single element's position by index\n  function placeAt(el, index, instant=false) {\n    const pos = positions[index];\n    el.setAttribute('data-index', index);\n    if (instant) {\n      el.style.transition = 'none';\n      el.style.left = pos.left + 'px';\n      // force reflow to apply\n      void el.offsetWidth;\n      el.style.transition = 'transform 500ms cubic-bezier(.2,.9,.3,1), left 500ms cubic-bezier(.2,.9,.3,1)';\n    } else {\n      el.style.left = pos.left + 'px';\n    }\n  }\n\n  // Helper to update value visuals when moved\n  function updateBar(el, value, idx) {\n    const bar = el.querySelector('.bar');\n    const val = el.querySelector('.value');\n    const cls = BAR_CLASSES[idx % BAR_CLASSES.length];\n    bar.className = 'bar ' + cls;\n    const h = Math.max(20, Math.round((value / 100) * 96));\n    bar.style.setProperty('--h', h + '%');\n    val.textContent = value;\n    el.setAttribute('aria-label','Value ' + value);\n  }\n\n  // Pause control utilities\n  let resumePromise = null;\n  function waitWhilePaused() {\n    if (animating) return Promise.resolve();\n    if (!resumePromise) {\n      resumePromise = new Promise(res => { resumePromise = res; });\n    }\n    return resumePromise;\n  }\n\n  function togglePlayPause() {\n    animating = !animating;\n    if (animating && resumePromise) {\n      resumePromise();\n      resumePromise = null;\n    }\n    playPauseBtn.setAttribute('aria-pressed', String(!animating));\n    playLabel.textContent = animating ? 'Pause' : 'Play';\n    // change icon\n    if (animating) {\n      ppIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"#061025\"></path>';\n      playPauseBtn.classList.add('play');\n    } else {\n      ppIcon.innerHTML = '<path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"#7dd3fc\"></path>';\n      playPauseBtn.classList.remove('play');\n    }\n  }\n\n  playPauseBtn.addEventListener('click', () => {\n    togglePlayPause();\n  });\n\n  shuffleBtn.addEventListener('click', async () => {\n    stopSignal = true;\n    // small visual feedback\n    shuffleBtn.disabled = true;\n    shuffleBtn.style.transform = 'translateY(-2px)';\n    await sleep(220);\n    shuffleBtn.style.transform = '';\n    await sleep(120);\n    initAndRun();\n    shuffleBtn.disabled = false;\n  });\n\n  // Main animation: insertion sort with animated moves\n  async function runInsertionSort() {\n    stopSignal = false;\n    const n = values.length;\n    stepTotal.textContent = (n * n / 2).toFixed(0);\n    let stepIdx = 0;\n\n    // mark first as sorted\n    if (items[0]) items[0].classList.add('sorted');\n\n    for (let i = 1; i < n; i++) {\n      if (stopSignal) return;\n      await waitWhilePaused();\n\n      // pick key\n      const keyVal = values[i];\n      const keyEl = items[i];\n      explanation.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 6v6l4 2\" stroke=\"#7dd3fc\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><div><strong>Pick key</strong><div style=\"font-size:13px;color:var(--muted);margin-top:6px;\">Lifting value ' + keyVal + ' from position ' + i + '</div></div>';\n      keyEl.classList.add('key');\n      keyEl.classList.remove('sorted');\n      keyEl.classList.remove('compare');\n      keyEl.style.zIndex = 90;\n      await sleep(speed * 0.5);\n      stepIdx++; stepCounter.textContent = stepIdx;\n\n      let j = i - 1;\n\n      // compare loop, shifting greater elements right\n      while (j >= 0 && values[j] > keyVal) {\n        if (stopSignal) return;\n        await waitWhilePaused();\n\n        // highlight compare\n        items[j].classList.add('compare');\n        explanation.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 6v6l4 2\" stroke=\"#a78bfa\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><div><strong>Comparing</strong><div style=\"font-size:13px;color:var(--muted);margin-top:6px;\">' + values[j] + ' &gt; ' + keyVal + ' — shifting right</div></div>';\n        await sleep(speed * 0.45);\n\n        // shift items[j] to position j+1\n        values[j+1] = values[j];\n        updateBar(items[j+1], values[j+1], j+1);\n        // move DOM element from j to j+1 visually (we'll swap references)\n        const movingEl = items[j];\n        // place movingEl to j+1\n        placeAt(movingEl, j+1);\n        // swap in items array\n        items[j+1] = movingEl;\n\n        // small pause to let transition occur\n        await sleep(speed * 0.8);\n        stepIdx++; stepCounter.textContent = stepIdx;\n\n        // cleanup compare highlight\n        movingEl.classList.remove('compare');\n        j = j - 1;\n      }\n\n      // insert key into j+1\n      values[j+1] = keyVal;\n      updateBar(keyEl, keyVal, j+1);\n      placeAt(keyEl, j+1);\n      keyEl.classList.remove('key');\n      keyEl.classList.add('sorted');\n      keyEl.style.zIndex = 20;\n\n      // rebuild items reference to ensure correct order\n      // After shifting, keyEl resides at some previous items[i] position, we need to reorder the array elements\n      // We'll find and reorder by value and DOM positions.\n      // Simpler: create a mapping by data-index attribute\n      const newItems = [];\n      for (let idx=0; idx<COUNT; idx++){\n        // find element with data-index == idx\n        for (let k=0;k<items.length;k++){\n          if (String(items[k].getAttribute('data-index')) === String(idx)) {\n            newItems[idx] = items[k];\n            break;\n          }\n        }\n      }\n      items = newItems;\n\n      await sleep(speed * 0.6);\n      stepIdx++; stepCounter.textContent = stepIdx;\n\n      // mark all below i as sorted (for subtle effect)\n      for (let s=0;s<=i;s++) {\n        items[s].classList.add('sorted');\n      }\n    }\n\n    // completion flourish\n    explanation.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M20 6L9 17l-5-5\" stroke=\"#34d399\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><div><strong>Sorted</strong><div style=\"font-size:13px;color:var(--muted);margin-top:6px;\">All elements are in order — completion achieved</div></div>';\n    stepCounter.textContent = stepIdx;\n    // subtle celebration: gentle pulse on sorted items\n    items.forEach((it, idx) => {\n      it.style.transition = 'transform 360ms ease';\n      setTimeout(()=> { it.style.transform = 'translateY(-6px)'; }, idx*40);\n      setTimeout(()=> { it.style.transform = ''; }, 420 + idx*40);\n    });\n  }\n\n  // Initialize and auto-run\n  function generateValues() {\n    const arr = [];\n    // create aesthetically pleasing distribution\n    for (let i=0;i<COUNT;i++){\n      arr.push(rand(18,96));\n    }\n    return arr;\n  }\n\n  async function initAndRun() {\n    animating = true;\n    playLabel.textContent = 'Pause';\n    ppIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"#061025\"></path>';\n    playPauseBtn.classList.add('play');\n    stopSignal = true;\n    // small wait to stop previous run\n    await sleep(60);\n    stopSignal = false;\n\n    const vals = generateValues();\n    renderArray(vals);\n    await sleep(220);\n    // auto choose speed label\n    speed = 600;\n    speedLabel.textContent = 'Normal';\n    // start run\n    await runInsertionSort();\n  }\n\n  // Handle window resize: re-compute slots and reposition instantly\n  let resizeTimer = null;\n  window.addEventListener('resize', () => {\n    clearTimeout(resizeTimer);\n    resizeTimer = setTimeout(() => {\n      positions = computeSlots();\n      items.forEach((el, idx) => {\n        if (!el) return;\n        el.style.transition = 'none';\n        el.style.left = positions[idx].left + 'px';\n        el.style.width = positions[idx].width + 'px';\n        // restore transition\n        requestAnimationFrame(() => {\n          el.style.transition = 'transform 500ms cubic-bezier(.2,.9,.3,1), left 500ms cubic-bezier(.2,.9,.3,1)';\n        });\n      });\n    }, 140);\n  });\n\n  // Initialize automatically on first paint\n  window.addEventListener('load', () => {\n    initAndRun();\n  });\n\n  // Accessibility: keyboard control (space toggles)\n  window.addEventListener('keydown', (e) => {\n    if (e.code === 'Space') {\n      e.preventDefault();\n      togglePlayPause();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
