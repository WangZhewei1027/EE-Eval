    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>AVL Tree Concept Showcase</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@300;500;700&family=Playfair+Display:wght@600&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0; padding: 0;\n    background: linear-gradient(135deg, #1f242f, #3a4762);\n    color: #e0e6f1;\n    font-family: 'Fira Sans', sans-serif;\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  header {\n    width: 100%;\n    padding: 2rem 0 1rem;\n    text-align: center;\n    color: #94a6d3;\n    font-family: 'Playfair Display', serif;\n    font-weight: 600;\n    font-size: 2.25rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    text-shadow:\n      0 0 8px rgba(77, 120, 251, 0.8),\n      0 0 25px rgba(77, 120, 251, 0.7);\n  }\n  header small {\n    display: block;\n    font-weight: 300;\n    font-size: 1rem;\n    margin-top: 0.4rem;\n    color: #7688b3cc;\n    letter-spacing: 0.12em;\n  }\n\n  main {\n    flex-grow: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding-bottom: 4rem;\n    width: 100%;\n    max-width: 1200px;\n  }\n\n  #avl-container {\n    position: relative;\n    width: 920px;\n    height: 540px;\n    background: radial-gradient(circle at center, #292e3e 35%, #1e2332 90%);\n    border-radius: 18px;\n    box-shadow:\n      inset 0 0 70px #3651a5cc,\n      0 0 30px rgba(85, 105, 230, 0.8),\n      0 20px 40px rgba(30, 40, 70, 0.8);\n    overflow: visible;\n  }\n\n  svg {\n    display: block;\n    margin: auto;\n    overflow: visible;\n  }\n\n  /* Node Styles */\n  .node-circle {\n    fill: #466ef2;\n    filter: drop-shadow(0 0 6px #78aaffcc);\n    stroke: #aac6ff;\n    stroke-width: 3px;\n    transition: fill 0.4s ease, filter 0.4s ease;\n    cursor: default;\n  }\n  .node-circle.balance-pos {\n    fill: #5fc97f;\n    filter: drop-shadow(0 0 10px #7eeaa3cc);\n  }\n  .node-circle.balance-neg {\n    fill: #f26e66;\n    filter: drop-shadow(0 0 10px #fb928dcc);\n  }\n\n  /* Node text */\n  .node-text {\n    font-family: 'Fira Sans', sans-serif;\n    font-weight: 700;\n    font-size: 20px;\n    fill: #e2e8ff;\n    pointer-events: none;\n    user-select: none;\n    filter: drop-shadow(0 0 2px #374978cc);\n  }\n\n  /* Balance factor text small circle */\n  .balance-circle {\n    fill: #1b264fcc;\n    stroke: transparent;\n    stroke-width: 0;\n  }\n  .balance-text {\n    fill: #a7bbffcc;\n    font-family: 'Fira Sans', sans-serif;\n    font-weight: 600;\n    font-size: 13px;\n    pointer-events: none;\n    user-select: none;\n  }\n\n  /* Edges */\n  .edge-line {\n    stroke: #8ea0d3cc;\n    stroke-width: 3;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 8px #7b8ccadd);\n    transition: stroke 0.5s ease;\n  }\n\n  /* Glow keyframe for balanced nodes */\n  @keyframes glowPulse {\n    0%, 100% {\n      filter: drop-shadow(0 0 12px #7eeaa3cc);\n    }\n    50% {\n      filter: drop-shadow(0 0 20px #aaffcc99);\n    }\n  }\n  .node-circle.balanced {\n    animation: glowPulse 3s ease-in-out infinite;\n  }\n\n  /* Buttons styling */\n  #controls {\n    margin-top: 20px;\n    display: flex;\n    gap: 16px;\n  }\n  button {\n    background: #2f3b7a;\n    border: none;\n    border-radius: 25px;\n    padding: 12px 28px;\n    font-family: 'Fira Sans', sans-serif;\n    font-weight: 600;\n    font-size: 15px;\n    color: #cbd5ff;\n    box-shadow:\n      0 0 8px #5473d7cc,\n      inset 0 -3px 6px #20336a;\n    cursor: pointer;\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.5s ease,\n      transform 0.15s ease;\n    user-select: none;\n    letter-spacing: 0.05em;\n  }\n  button:hover, button:focus {\n    outline: none;\n    background: #5273f5;\n    box-shadow:\n      0 0 20px #799dffdd,\n      inset 0 -3px 7px #2f4ac9;\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow: 0 0 10px #4661c1cc inset;\n  }\n\n  /* Tooltip style on nodes to show balance factor meaning */\n  #tip {\n    position: absolute;\n    padding: 7px 14px;\n    background: #222946dd;\n    border-radius: 14px;\n    box-shadow:\n      0 0 13px 4px #567adcaa;\n    color: #d1defd;\n    font-family: 'Fira Sans', sans-serif;\n    font-weight: 500;\n    font-size: 13px;\n    pointer-events: none;\n    opacity: 0;\n    transition: opacity 0.12s ease;\n    user-select: none;\n    white-space: nowrap;\n  }\n\n  /* Footer */\n  footer {\n    font-family: 'Fira Sans', sans-serif;\n    font-weight: 300;\n    font-size: 13px;\n    color: #7688b3aa;\n    margin-top: 8px;\n    letter-spacing: 0.1em;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n<header>\n  AVL TREE CONCEPT\n  <small>Balanced Binary Search Tree Visualization</small>\n</header>\n\n<main>\n  <div id=\"avl-container\" aria-label=\"AVL Tree visualization\" role=\"img\" aria-live=\"polite\">\n    <svg id=\"avl-svg\" width=\"920\" height=\"540\" viewBox=\"0 0 920 540\" aria-hidden=\"true\" focusable=\"false\" >\n      <!-- Edges and nodes will be drawn here -->\n    </svg>\n    <div id=\"tip\" role=\"tooltip\" aria-hidden=\"true\"></div>\n  </div>\n</main>\n\n<div id=\"controls\" role=\"region\" aria-label=\"AVL Tree controls\">\n  <button id=\"btn-rotate\" aria-describedby=\"btn-desc-rotate\" title=\"Show next rotation example\">Next Rotation</button>\n  <button id=\"btn-reset\" aria-describedby=\"btn-desc-reset\" title=\"Reset to balanced state\">Reset</button>\n</div>\n<div style=\"position: absolute; width: 1px; height: 1px; overflow: hidden; left: -10000px;\" id=\"btn-desc-rotate\">Demonstrates the next AVL tree rotation to restore balance</div>\n<div style=\"position: absolute; width: 1px; height: 1px; overflow: hidden; left: -10000px;\" id=\"btn-desc-reset\">Resets the tree to the initial balanced state</div>\n\n<footer>\n  Crafted for exceptional visual clarity & aesthetics — © 2024\n</footer>\n\n<script>\n/**\n * AVL Tree Visualization with polished aesthetics and minimal interactivity.\n * We present a single AVL tree that transitions between different rotation states.\n */\n\n(() => {\n  const svg = document.getElementById('avl-svg');\n  const tip = document.getElementById('tip');\n  const btnRotate = document.getElementById('btn-rotate');\n  const btnReset = document.getElementById('btn-reset');\n\n  // Layout constants\n  const width = 920, height = 540;\n  const nodeRadius = 30;\n  const verticalGap = 130;\n  const horizontalGap = 180;\n\n  /**\n   * AVL node structure for drawing\n   * Each node has:\n   * - id: unique identifier\n   * - value: displayed number\n   * - bf: balance factor (-1,0,1)\n   * - x, y: position on canvas\n   * - children: [leftNode, rightNode]\n   */\n  class Node {\n    constructor(id, value, bf, x, y, left = null, right = null) {\n      this.id = id;\n      this.value = value;\n      this.bf = bf;\n      this.x = x;\n      this.y = y;\n      this.left = left;\n      this.right = right;\n    }\n  }\n\n  // We will show a sequence of 4 AVL tree states illustrating \"Next Rotation\":\n  // 1) Balanced tree\n  // 2) Imbalanced left-left\n  // 3) After right rotation (balanced again)\n  // 4) Imbalanced left-right (for more nuance)\n\n  // Coordinates for root centered at (460,80)\n\n  // STATES: array of root nodes with full subtree structure and positioning\n\n  // Helper to create node with children including position\n  // This info is hardcoded for beautiful layout, balanced by eye with symmetry.\n\n  // State 0: Balanced AVL Tree\n  const state0 = new Node('n1', 30, 0, 460, 80,\n    new Node('n2', 20, 0, 280, 210,\n      new Node('n4', 10, 0, 170, 340),\n      new Node('n5', 25, 0, 370, 340)\n    ),\n    new Node('n3', 40, 0, 640, 210,\n      null,\n      new Node('n6', 50, 0, 740, 340)\n    )\n  );\n\n  // State 1: Imbalanced left-left (bf = +2 at root), requires right rotation\n  const state1 = new Node('n1', 30, +2, 460, 80,\n    new Node('n2', 20, +1, 280, 210,\n      new Node('n4', 10, 0, 170, 340),\n      null\n    ),\n    new Node('n3', 40, 0, 640, 210, null, null)\n  );\n\n  // State 2: After right rotation - balanced\n  const state2 = new Node('n2', 20, 0, 460, 80,\n    new Node('n4', 10, 0, 280, 210),\n    new Node('n1', 30, 0, 640, 210,\n      null,\n      new Node('n3', 40, 0, 740, 340)\n    )\n  );\n\n  // State 3: Imbalanced left-right (bf at root = +2, left child bf = -1)\n  // This will demonstrate needing Left-Right rotation\n  const state3 = new Node('n1', 30, +2, 460, 80,\n    new Node('n2', 20, -1, 280, 210,\n      null,\n      new Node('n5', 25, 0, 370, 340)\n    ),\n    new Node('n3', 40, 0, 640, 210)\n  );\n\n  // State 4: After left-right double rotation balanced (for Reset, same as state0)\n  const states = [state0, state1, state2, state3];\n\n  let currentIndex = 0;\n\n  // Clear SVG children\n  function clearSVG() {\n    while (svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  // Create an SVG element with namespace\n  function createSVGElement(name, attrs = {}) {\n    const el = document.createElementNS(\"http://www.w3.org/2000/svg\", name);\n    for (let key in attrs) {\n      if (attrs[key] !== null && attrs[key] !== undefined) {\n        el.setAttribute(key, attrs[key]);\n      }\n    }\n    return el;\n  }\n\n  // Traverse nodes and draw edges and nodes recursively\n  function drawTree(root) {\n    clearSVG();\n\n    // We'll create edges before nodes, so edges are beneath nodes\n    const edgesGroup = createSVGElement('g', {class: 'edges'});\n    const nodesGroup = createSVGElement('g', {class: 'nodes'});\n\n    // Recursively collect edges and nodes for the tree\n    function traverse(node) {\n      if (!node) return;\n\n      const {x, y} = node;\n      // Draw edges to left child\n      if (node.left) {\n        drawEdge(x, y, node.left.x, node.left.y, edgesGroup);\n        traverse(node.left);\n      }\n      // Draw edges to right child\n      if (node.right) {\n        drawEdge(x, y, node.right.x, node.right.y, edgesGroup);\n        traverse(node.right);\n      }\n\n      // Draw the node after edges\n      drawNode(node, nodesGroup);\n    }\n\n    // Draw edges as smooth curved paths\n    function drawEdge(x1, y1, x2, y2, container) {\n      // We'll draw a quadratic Bezier curve to create a smooth edge\n\n      // Control point is horizontally centered between nodes, vertical is y1 + (y2 - y1)/2\n      const cx = (x1 + x2) / 2;\n      const cy = y1 + (y2 - y1)/2;\n\n      const path = createSVGElement('path', {\n        d: `M ${x1} ${y1 + nodeRadius} Q ${cx} ${cy} ${x2} ${y2 - nodeRadius}`,\n        class: 'edge-line',\n        'aria-hidden': 'true',\n      });\n      container.appendChild(path);\n    }\n\n    // Draw single node circle with text and small bf circle\n    function drawNode(node, container) {\n      const g = createSVGElement('g', {class: 'node-group', 'aria-label': `Node ${node.value} balance factor ${node.bf}`, role: 'img'});\n\n      // Node circle color based on bf value:\n      // bf === 0 balanced, bf > 0 left-heavy, bf < 0 right-heavy\n      let circleClass = 'node-circle';\n      if (node.bf === 0) circleClass += ' balanced';\n      else if (node.bf > 0) circleClass += ' balance-pos';\n      else if (node.bf < 0) circleClass += ' balance-neg';\n\n      const circle = createSVGElement('circle', {\n        class: circleClass,\n        cx: node.x,\n        cy: node.y,\n        r: nodeRadius,\n        tabindex: -1,\n      });\n      g.appendChild(circle);\n\n      // Node value text\n      const text = createSVGElement('text', {\n        class: 'node-text',\n        x: node.x,\n        y: node.y + 7,\n        'text-anchor': 'middle',\n        'aria-hidden': 'true',\n        tabindex: -1,\n      });\n      text.textContent = node.value;\n      g.appendChild(text);\n\n      // Small circle for balance factor on lower right\n      const bfCircleRadius = 14;\n      const bfCircleX = node.x + nodeRadius - bfCircleRadius + 2;\n      const bfCircleY = node.y + nodeRadius - bfCircleRadius + 4;\n\n      const bfCircle = createSVGElement('circle', {\n        class: 'balance-circle',\n        cx: bfCircleX,\n        cy: bfCircleY,\n        r: bfCircleRadius,\n        tabindex: -1,\n        'aria-hidden': 'true',\n      });\n      g.appendChild(bfCircle);\n\n      // BF text inside small circle\n      const bfText = createSVGElement('text', {\n        class: 'balance-text',\n        x: bfCircleX,\n        y: bfCircleY + 5,\n        'text-anchor': 'middle',\n        'aria-hidden': 'true',\n        tabindex: -1,\n      });\n      bfText.textContent = node.bf;\n      g.appendChild(bfText);\n\n      // Hover tooltip note for balance factor\n      g.addEventListener('mouseenter', () => {\n        const desc = describeBF(node.bf);\n        showTip(`${desc}`, bfCircleX + 25, bfCircleY);\n      });\n      g.addEventListener('mouseleave', hideTip);\n\n      container.appendChild(g);\n    }\n\n    traverse(root);\n\n    svg.appendChild(edgesGroup);\n    svg.appendChild(nodesGroup);\n  }\n\n  // Describe the balance factor for tooltip\n  function describeBF(bf){\n    if (bf === 0) return \"Balance Factor: 0 (Perfectly balanced)\";\n    if (bf === 1) return \"Balance Factor: +1 (Slightly left-heavy)\";\n    if (bf === -1) return \"Balance Factor: -1 (Slightly right-heavy)\";\n    if (bf === 2) return \"Balance Factor: +2 (Unbalanced - heavy on left)\";\n    if (bf === -2) return \"Balance Factor: -2 (Unbalanced - heavy on right)\";\n    if (bf > 2) return `Balance Factor: +${bf} (Severely left-heavy)`;\n    if (bf < -2) return `Balance Factor: ${bf} (Severely right-heavy)`;\n    return `Balance Factor: ${bf}`;\n  }\n\n  // Tooltip functions\n  function showTip(text, x, y) {\n    tip.textContent = text;\n    tip.style.left = (x + 15) + 'px';\n    tip.style.top = (y + 15) + 'px';\n    tip.style.opacity = '1';\n    tip.setAttribute('aria-hidden', 'false');\n  }\n  function hideTip() {\n    tip.style.opacity = '0';\n    tip.setAttribute('aria-hidden', 'true');\n  }\n\n  // Animate transitions by morphing between states\n  // For simplicity, we just redraw new tree for each state with fade effect\n\n  function fadeOut(el, duration = 400) {\n    el.style.transition = `opacity ${duration}ms ease`;\n    el.style.opacity = 0;\n    return new Promise(resolve => setTimeout(resolve, duration));\n  }\n  function fadeIn(el, duration = 400) {\n    el.style.transition = `opacity ${duration}ms ease`;\n    el.style.opacity = 1;\n    return new Promise(resolve => setTimeout(resolve, duration));\n  }\n\n  // Render a given state index\n  async function renderState(index) {\n    const root = states[index];\n    await fadeOut(svg);\n    drawTree(root);\n    await fadeIn(svg);\n  }\n\n  // Initial render\n  renderState(currentIndex);\n\n  // Button Handlers\n  btnRotate.addEventListener('click', () => {\n    currentIndex++;\n    if (currentIndex >= states.length) currentIndex = 0;\n    renderState(currentIndex);\n  });\n\n  btnReset.addEventListener('click', () => {\n    currentIndex = 0;\n    renderState(currentIndex);\n  });\n\n  // Responsive resizing - adjust the container for smaller screens\n  function resize() {\n    const container = document.getElementById('avl-container');\n    if (window.innerWidth < 980) {\n      container.style.width = '100%';\n      container.style.height = 'auto';\n      svg.setAttribute('width', Math.min(window.innerWidth - 40, 900));\n      svg.setAttribute('height', Math.min((window.innerWidth - 40)/1.7, 540));\n    } else {\n      container.style.width = '920px';\n      container.style.height = '540px';\n      svg.setAttribute('width', 920);\n      svg.setAttribute('height', 540);\n    }\n  }\n  window.addEventListener('resize', resize);\n  resize();\n\n})();\n</script>\n</body>\n</html>"
  },
