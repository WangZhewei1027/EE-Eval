    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Congestion Control Simulation</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .control { margin: 10px 0; }\n        #status { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Congestion Control Simulation</h1>\n\n    <div class=\"control\">\n        <label for=\"bandwidth\">Set Bandwidth (Mbps): </label>\n        <input type=\"number\" id=\"bandwidth\" value=\"10\" min=\"1\" max=\"100\">\n    </div>\n\n    <div class=\"control\">\n        <label for=\"delay\">Set Delay (ms): </label>\n        <input type=\"number\" id=\"delay\" value=\"0\" min=\"0\" max=\"500\">\n    </div>\n\n    <div class=\"control\">\n        <button id=\"startButton\">Start Simulation</button>\n    </div>\n\n    <div class=\"control\">\n        <button id=\"increaseButton\">Increase Congestion</button>\n        <button id=\"decreaseButton\">Decrease Congestion</button>\n    </div>\n\n    <div class=\"control\">\n        <label for=\"packets\">Current Packets in Flight: </label>\n        <input type=\"number\" id=\"packets\" value=\"0\" min=\"0\" max=\"100\" readonly>\n    </div>\n\n    <div class=\"control\">\n        <label for=\"congestionLevel\">Congestion Level: </label>\n        <input type=\"number\" id=\"congestionLevel\" value=\"0\" min=\"0\" max=\"100\" readonly>\n    </div>\n\n    <button id=\"resetButton\">Reset</button>\n\n    <div id=\"status\"></div>\n\n    <script>\n        let bandwidth = 0;\n        let delay = 0;\n        let packetsInFlight = 0;\n        let congestionLevel = 0;\n        let interval;\n        \n        document.getElementById('startButton').onclick = function() {\n            bandwidth = parseInt(document.getElementById('bandwidth').value);\n            delay = parseInt(document.getElementById('delay').value);\n            packetsInFlight = 0;\n            congestionLevel = 0;\n\n            document.getElementById('status').innerText = \"Simulation Started. Bandwidth: \" + bandwidth + \" Mbps, Delay: \" + delay + \" ms\";\n            interval = setInterval(simulateNetwork, 1000);\n        };\n\n        document.getElementById('increaseButton').onclick = function() {\n            congestionLevel = Math.min(congestionLevel + 10, 100);\n            updateStatus(\"Increased Congestion Level: \" + congestionLevel);\n        };\n\n        document.getElementById('decreaseButton').onclick = function() {\n            congestionLevel = Math.max(congestionLevel - 10, 0);\n            updateStatus(\"Decreased Congestion Level: \" + congestionLevel);\n        };\n\n        document.getElementById('resetButton').onclick = function() {\n            clearInterval(interval);\n            resetSimulation();\n            updateStatus(\"Simulation Reset.\");\n        };\n\n        function simulateNetwork() {\n            if (congestionLevel >= 100) {\n                clearInterval(interval);\n                updateStatus(\"Congestion Level at maximum. Simulation Stopped.\");\n                return;\n            }\n\n            packetsInFlight = Math.min(packetsInFlight + (bandwidth - congestionLevel), 100);\n            document.getElementById('packets').value = packetsInFlight;\n            document.getElementById('congestionLevel').value = congestionLevel;\n        }\n\n        function resetSimulation() {\n            packetsInFlight = 0;\n            congestionLevel = 0;\n            document.getElementById('packets').value = packetsInFlight;\n            document.getElementById('congestionLevel').value = congestionLevel;\n            document.getElementById('status').innerText = \"\";\n            document.getElementById('bandwidth').value = 10;\n            document.getElementById('delay').value = 0;\n        }\n\n        function updateStatus(message) {\n            document.getElementById('status').innerText = message;\n        }\n    </script>\n</body>\n</html>"
