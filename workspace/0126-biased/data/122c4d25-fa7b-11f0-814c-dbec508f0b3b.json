    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sliding Window</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        .control-group {\n            display: flex;\n            flex-direction: column;\n            margin-bottom: 20px;\n        }\n        .control-label {\n            font-weight: bold;\n            margin-bottom: 5px;\n        }\n        .control-input {\n            padding: 5px;\n            border: none;\n            border-radius: 5px;\n            font-size: 16px;\n            width: 100%;\n        }\n        .control-button {\n            padding: 5px;\n            border: none;\n            border-radius: 5px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        .slider {\n            width: 50%;\n            margin-bottom: 20px;\n        }\n        .button-group {\n            display: flex;\n            flex-direction: column;\n            margin-bottom: 20px;\n        }\n        .button {\n            padding: 5px;\n            border: none;\n            border-radius: 5px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h2>Sliding Window</h2>\n        <form>\n            <div class=\"control-group\">\n                <label for=\"width\">Window Width:</label>\n                <input type=\"range\" id=\"width\" min=\"10\" max=\"100\" value=\"50\" step=\"10\">\n                <span id=\"width-value\">50</span>\n            </div>\n            <div class=\"control-group\">\n                <label for=\"height\">Window Height:</label>\n                <input type=\"range\" id=\"height\" min=\"10\" max=\"100\" value=\"50\" step=\"10\">\n                <span id=\"height-value\">50</span>\n            </div>\n            <div class=\"control-group\">\n                <label for=\"duration\">Duration:</label>\n                <input type=\"range\" id=\"duration\" min=\"1\" max=\"60\" value=\"10\" step=\"1\">\n                <span id=\"duration-value\">10</span>\n            </div>\n            <div class=\"button-group\">\n                <button class=\"button\" id=\"start-button\">Start</button>\n                <button class=\"button\" id=\"stop-button\">Stop</button>\n                <button class=\"button\" id=\"reset-button\">Reset</button>\n            </div>\n        </form>\n        <div id=\"result\"></div>\n    </div>\n\n    <script>\n        const width = document.getElementById('width');\n        const height = document.getElementById('height');\n        const duration = document.getElementById('duration');\n        const startButton = document.getElementById('start-button');\n        const stopButton = document.getElementById('stop-button');\n        const resetButton = document.getElementById('reset-button');\n        const resultDiv = document.getElementById('result');\n\n        startButton.addEventListener('click', () => {\n            const value = parseInt(document.getElementById('width-value').textContent);\n            const result = `Window Width: ${value}px`;\n            resultDiv.textContent = result;\n            width.value = value;\n        });\n\n        stopButton.addEventListener('click', () => {\n            const value = parseInt(document.getElementById('width-value').textContent);\n            const result = `Window Width: ${value}px`;\n            resultDiv.textContent = result;\n            width.value = value;\n        });\n\n        resetButton.addEventListener('click', () => {\n            width.value = 50;\n            resultDiv.textContent = `Window Width: ${width.value}px`;\n        });\n\n        function updateResult() {\n            const value = parseInt(document.getElementById('width-value').textContent);\n            const result = `Window Width: ${value}px`;\n            resultDiv.textContent = result;\n            width.value = value;\n        }\n\n        duration.addEventListener('input', () => {\n            const value = parseInt(document.getElementById('duration-value').textContent);\n            const result = `Duration: ${value} seconds`;\n            resultDiv.textContent = result;\n            duration.value = value;\n        });\n\n        duration.value = 10;\n    </script>\n</body>\n</html>"
