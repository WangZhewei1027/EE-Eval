    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Overfitting Visualization — Elegance in Machine Learning</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap');\n\n  :root {\n    --color-bg: #0f172a; /* dark midnight blue */\n    --color-primary: #4cd1a1; /* mint green */\n    --color-secondary: #a0aec0; /* soft gray */\n    --color-accent: #fbcfe8; /* soft pink */\n    --color-error: #ef4444; /* vivid red */\n    --color-white: #e0e6f3;\n    --color-shadow: rgba(12, 17, 42, 0.85);\n    --ease: cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0; padding: 0;\n    background: var(--color-bg);\n    color: var(--color-white);\n    font-family: 'Poppins', sans-serif;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  main {\n    max-width: 960px;\n    margin: 4rem auto 6rem;\n    padding: 0 1.5rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 700;\n    font-size: 3.4rem;\n    line-height: 1.1;\n    margin-bottom: 0.3rem;\n    letter-spacing: -0.02em;\n    background: linear-gradient(90deg, #4cd1a1, #fbcfe8);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    filter: drop-shadow(0 4px 8px rgba(76, 209, 161, 0.75));\n  }\n\n  subtitle {\n    color: var(--color-secondary);\n    font-weight: 500;\n    font-size: 1.2rem;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    margin-bottom: 2.4rem;\n    display: inline-block;\n    opacity: 0.75;\n  }\n\n  /* Visualization container */\n\n  .viz-container {\n    background: linear-gradient(145deg, #111827, #182c4e);\n    border-radius: 18px;\n    box-shadow:\n      0 8px 30px rgba(76, 209, 161, 0.3),\n      inset 0 0 12px 1px rgba(76, 209, 161, 0.15);\n    padding: 2.6rem 2rem 3.6rem;\n    position: relative;\n    overflow: visible;\n    user-select: none;\n  }\n\n  .canvas-holder {\n    width: 100%;\n    height: 450px;\n    position: relative;\n  }\n\n  /* Axes styling */\n\n  .axis {\n    stroke: var(--color-secondary);\n    stroke-width: 1.25px;\n    shape-rendering: crispEdges;\n  }\n\n  .axis-label {\n    fill: var(--color-secondary);\n    font-weight: 400;\n    font-size: 0.925rem;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  /* Curve styles */\n\n  .curve {\n    fill: none;\n    stroke-width: 3.2;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter: drop-shadow(0 3px 6px rgba(76, 209, 161, 0.3));\n  }\n\n  .curve-true {\n    stroke: url(#gradientTrue);\n  }\n\n  .curve-underfit {\n    stroke: url(#gradientUnderfit);\n    stroke-dasharray: 12 8;\n    opacity: 0.7;\n  }\n\n  .curve-overfit {\n    stroke: url(#gradientOverfit);\n    filter: drop-shadow(0 0 30px #ef4444cc);\n  }\n\n  /* Data points */\n\n  .datapoint {\n    stroke: var(--color-bg);\n    stroke-width: 1.8px;\n    filter: drop-shadow(0 1.8px 2.5px rgba(0,0,0,0.25));\n    cursor: default;\n    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);\n  }\n\n  .datapoint.train {\n    fill: var(--color-primary);\n  }\n  .datapoint.test {\n    fill: var(--color-accent);\n  }\n\n  /* Legend */\n\n  .legend {\n    display: flex;\n    justify-content: center;\n    margin-top: 28px;\n    gap: 2.2rem;\n    font-weight: 500;\n    font-size: 1rem;\n    color: var(--color-secondary);\n    user-select: none;\n  }\n  .legend-item {\n    display: flex; gap: 0.7rem; align-items: center;\n  }\n  .legend-symbol {\n    width: 18px;\n    height: 3.8px;\n    border-radius: 2px;\n    display: inline-block;\n  }\n  .legend-symbol.true {\n    background: linear-gradient(90deg, #4cd1a1 0%, #fbcfe8 100%);\n    box-shadow: 0 0 10px #b2f0cf;\n  }\n  .legend-symbol.underfit {\n    background: linear-gradient(90deg, #7dd3fc 0%, #60a5fa 100%);\n    opacity: 0.7;\n    border: 1px dashed var(--color-secondary);\n  }\n  .legend-symbol.overfit {\n    background: #ef4444;\n    box-shadow: 0 0 20px #ef4444cc;\n  }\n  .legend-symbol.train {\n    border-radius: 50%;\n    width: 12px;\n    height: 12px;\n    box-shadow:\n      0 2px 6px var(--color-primary);\n  }\n  .legend-symbol.test {\n    border-radius: 50%;\n    width: 12px;\n    height: 12px;\n    background-color: var(--color-accent);\n    box-shadow:\n      0 2px 6px var(--color-accent);\n  }\n\n  /* Buttons */\n\n  .controls {\n    margin-top: 3.8rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.8rem;\n  }\n\n  button {\n    background: transparent;\n    border: 2.6px solid var(--color-primary);\n    color: var(--color-primary);\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.75rem 2.2rem;\n    border-radius: 12px;\n    cursor: pointer;\n    transition:\n      background-color 0.4s var(--ease),\n      color 0.4s var(--ease),\n      box-shadow 0.5s ease;\n    box-shadow:\n      inset 0 0 10px var(--color-primary);\n    text-transform: uppercase;\n    letter-spacing: 0.07em;\n    user-select: none;\n    position: relative;\n    overflow: hidden;\n  }\n  button:hover, button:focus {\n    outline: none;\n    background-color: var(--color-primary);\n    color: var(--color-bg);\n    box-shadow: 0 0 30px var(--color-primary);\n  }\n  button:active {\n    transform: scale(0.96);\n    box-shadow: none;\n  }\n\n  /* Footer with subtle branding */\n\n  footer {\n    text-align: center;\n    margin: 6rem 0 2rem;\n    color: var(--color-secondary);\n    font-weight: 300;\n    font-size: 0.9rem;\n    user-select: none;\n  }\n\n  /* Animations for curves */\n\n  .line-dash-animated {\n    stroke-dasharray: 1200;\n    stroke-dashoffset: 1200;\n    animation-fill-mode: forwards;\n  }\n\n  .animate-true {\n    animation: dashIn 2s var(--ease) forwards;\n  }\n\n  .animate-underfit {\n    animation: dashIn 2.6s var(--ease) 0.6s forwards;\n  }\n\n  .animate-overfit {\n    animation: dashIn 2.4s var(--ease) 1.3s forwards;\n  }\n\n  @keyframes dashIn {\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n\n</style>\n</head>\n<body>\n<main role=\"main\" aria-label=\"Visualization of Overfitting in Machine Learning\">\n  <h1>Overfitting</h1>\n  <subtitle>Understanding Model Complexity and Generalization</subtitle>\n\n  <section class=\"viz-container\" aria-describedby=\"desc\">\n    <p id=\"desc\" class=\"sr-only\">This visualization displays data points from training and test sets, along with three model fits: underfitting (too simple), good fit (true model), and overfitting (too complex). The curves animate in sequence, illustrating the concept of overfitting to training data and poor generalization on test data.</p>\n    <svg aria-hidden=\"true\" role=\"img\" class=\"canvas-holder\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 920 460\" preserveAspectRatio=\"none\" >\n      <defs>\n        <linearGradient id=\"gradientTrue\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\" stop-color=\"#4cd1a1\" />\n          <stop offset=\"100%\" stop-color=\"#fbcfe8\" />\n        </linearGradient>\n\n        <linearGradient id=\"gradientUnderfit\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\" stop-color=\"#7dd3fc\" />\n          <stop offset=\"100%\" stop-color=\"#60a5fa\" />\n        </linearGradient>\n\n        <linearGradient id=\"gradientOverfit\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\" stop-color=\"#ef4444\" />\n          <stop offset=\"100%\" stop-color=\"#b91c1c\" />\n        </linearGradient>\n      </defs>\n      <!-- Axes and grid -->\n\n      <g aria-hidden=\"true\" class=\"axes\">\n        <!-- Horizontal grid lines -->\n        <line class=\"axis\" x1=\"40\" y1=\"400\" x2=\"880\" y2=\"400\" />\n        <line class=\"axis\" x1=\"40\" y1=\"320\" x2=\"880\" y2=\"320\" />\n        <line class=\"axis\" x1=\"40\" y1=\"240\" x2=\"880\" y2=\"240\" />\n        <line class=\"axis\" x1=\"40\" y1=\"160\" x2=\"880\" y2=\"160\" />\n        <line class=\"axis\" x1=\"40\" y1=\"80\" x2=\"880\" y2=\"80\" />\n\n        <!-- Vertical grid lines -->\n        <line class=\"axis\" x1=\"115\" y1=\"420\" x2=\"115\" y2=\"20\" />\n        <line class=\"axis\" x1=\"230\" y1=\"420\" x2=\"230\" y2=\"20\" />\n        <line class=\"axis\" x1=\"345\" y1=\"420\" x2=\"345\" y2=\"20\" />\n        <line class=\"axis\" x1=\"460\" y1=\"420\" x2=\"460\" y2=\"20\" />\n        <line class=\"axis\" x1=\"575\" y1=\"420\" x2=\"575\" y2=\"20\" />\n        <line class=\"axis\" x1=\"690\" y1=\"420\" x2=\"690\" y2=\"20\" />\n        <line class=\"axis\" x1=\"805\" y1=\"420\" x2=\"805\" y2=\"20\" />\n      </g>\n\n      <!-- Axes labels -->\n      <text class=\"axis-label\" x=\"460\" y=\"455\" text-anchor=\"middle\" dominant-baseline=\"middle\" aria-hidden=\"true\">Input Feature (x)</text>\n      <text class=\"axis-label\" x=\"10\" y=\"230\" text-anchor=\"middle\" dominant-baseline=\"middle\" transform=\"rotate(-90, 10, 230)\">Output (y)</text>\n\n      <!-- Data points: training -->\n      <!-- Training points are along a smooth curve around y = sin(x) with noise -->\n\n      <g aria-label=\"Training data points\" aria-hidden=\"false\" role=\"list\" tabindex=\"-1\">\n        <circle class=\"datapoint train\" cx=\"75\"  cy=\"345\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"140\" cy=\"230\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"205\" cy=\"190\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"280\" cy=\"220\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"340\" cy=\"200\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"400\" cy=\"160\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"455\" cy=\"155\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"525\" cy=\"210\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"590\" cy=\"230\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"665\" cy=\"245\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"730\" cy=\"270\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint train\" cx=\"785\" cy=\"300\" r=\"7\" role=\"listitem\" />\n      </g>\n\n      <!-- Data points: test -->\n      <g aria-label=\"Test data points\" aria-hidden=\"false\" role=\"list\" tabindex=\"-1\">\n        <circle class=\"datapoint test\" cx=\"105\" cy=\"320\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"185\" cy=\"240\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"255\" cy=\"195\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"335\" cy=\"180\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"420\" cy=\"150\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"490\" cy=\"170\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"560\" cy=\"225\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"630\" cy=\"230\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"700\" cy=\"260\" r=\"7\" role=\"listitem\" />\n        <circle class=\"datapoint test\" cx=\"770\" cy=\"285\" r=\"7\" role=\"listitem\" />\n      </g>\n\n      <!-- Curves -->\n\n      <!-- Underfitting (Too Simple) — Almost Linear -->\n      <path aria-label=\"Underfit model curve (too simple)\" role=\"presentation\" aria-hidden=\"true\"\n        class=\"curve curve-underfit line-dash-animated animate-underfit\"\n        d=\"M 40 400\n           L 125 370\n           L 230 340\n           L 345 300\n           L 460 280\n           L 575 260\n           L 690 245\n           L 805 235\n           L 880 230\"\n      />\n\n      <!-- True Model (Ideal fit) — Smooth Sinusoidal -->\n      <path aria-label=\"True model curve (ideal fit)\" role=\"presentation\" aria-hidden=\"true\"\n        class=\"curve curve-true line-dash-animated animate-true\"\n        d=\"M 40 365 \n           C 100 215, 170 155, 230 200\n           S 350 325, 450 195\n           S 580 90, 700 205\n           S 845 340, 880 345\"\n      />\n\n      <!-- Overfitting (Too Complex) — Jagged/Noisy -->\n      <path aria-label=\"Overfit model curve (too complex)\" role=\"presentation\" aria-hidden=\"true\"\n        class=\"curve curve-overfit line-dash-animated animate-overfit\"\n        d=\"M 40 400 \n           C 90 320, 130 395, 165 240\n           S 198 362, 235 280\n           S 265 380, 300 310\n           S 340 360, 380 260\n           S 410 200, 455 300\n           S 500 400, 545 210\n           S 580 280, 620 230\n           S 660 305, 700 260\n           S 735 240, 777 330\n           S 820 290, 865 385\"\n      />\n    </svg>\n\n    <div class=\"legend\" aria-label=\"Legend for curves and data points\">\n      <div class=\"legend-item\">\n        <span aria-hidden=\"true\" class=\"legend-symbol underfit\"></span>\n        <span>Underfit Model</span>\n      </div>\n      <div class=\"legend-item\">\n        <span aria-hidden=\"true\" class=\"legend-symbol true\"></span>\n        <span>True Model</span>\n      </div>\n      <div class=\"legend-item\">\n        <span aria-hidden=\"true\" class=\"legend-symbol overfit\"></span>\n        <span>Overfit Model</span>\n      </div>\n      <div class=\"legend-item\">\n        <span aria-hidden=\"true\" class=\"legend-symbol train\"></span>\n        <span>Training Data</span>\n      </div>\n      <div class=\"legend-item\">\n        <span aria-hidden=\"true\" class=\"legend-symbol test\"></span>\n        <span>Test Data</span>\n      </div>\n    </div>\n\n    <div class=\"controls\" aria-label=\"Control animations\">\n      <button id=\"btnReplay\" aria-live=\"polite\" aria-label=\"Replay animation\">Replay Animation</button>\n    </div>\n  </section>\n</main>\n\n<footer>\n  &copy; 2024 &mdash; Visualizing Machine Learning Concepts with Elegance\n</footer>\n\n<script>\n  (() => {\n    const curves = {\n      true: document.querySelector('.curve-true'),\n      underfit: document.querySelector('.curve-underfit'),\n      overfit: document.querySelector('.curve-overfit')\n    };\n\n    function resetAnimation() {\n      // Remove animation classes to reset strokes dash offset\n      Object.values(curves).forEach(path => {\n        path.classList.remove('animate-true', 'animate-underfit', 'animate-overfit');\n        // Trigger reflow for restarting CSS animation\n        void path.offsetWidth;\n      });\n    }\n\n    function startAnimation() {\n      resetAnimation();\n      // Stagger animations with slight delay for elegance\n      setTimeout(() => curves.true.classList.add('animate-true'), 100);\n      setTimeout(() => curves.underfit.classList.add('animate-underfit'), 700);\n      setTimeout(() => curves.overfit.classList.add('animate-overfit'), 1300);\n    }\n\n    document.getElementById('btnReplay').addEventListener('click', () => {\n      startAnimation();\n      document.getElementById('btnReplay').focus();\n    });\n\n    // Initialize animation on load with a gentle delay for smooth effect\n    window.addEventListener('load', () => {\n      setTimeout(startAnimation, 400);\n    });\n  })();\n</script>\n\n<!-- Accessibility helper -->\n<style>\n  .sr-only {\n    position: absolute !important;\n    width: 1px !important;\n    height: 1px !important;\n    padding: 0 !important;\n    margin: -1px !important;\n    overflow: hidden !important;\n    clip: rect(0,0,0,0) !important;\n    white-space: nowrap !important;\n    border: 0 !important;\n  }\n</style>\n</body>\n</html>"
