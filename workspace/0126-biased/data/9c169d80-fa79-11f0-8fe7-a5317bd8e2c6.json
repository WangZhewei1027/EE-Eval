  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Dynamic Typing Explorer</title>\n  <style>\n    /* Extremely minimal styling - keep plain black text on white background */\n    html,body { margin:10px; padding:0; font-family: sans-serif; color: #000; background:#fff; }\n    .section { margin-bottom:18px; }\n    label { display:inline-block; margin-right:6px; }\n    input, select, textarea, button { margin-right:6px; margin-bottom:6px; }\n    textarea { width:80%; height:80px; }\n    .vars { max-height:240px; overflow:auto; border:1px solid #000; padding:6px; }\n    .varrow { padding:4px 0; border-bottom:1px dotted #000; }\n    .compact { font-size:90%; }\n    pre { background: #fff; border:1px solid #000; padding:6px; white-space:pre-wrap; }\n    .small { font-size:90%; }\n    /* no colors, no fancy layout */\n  </style>\n</head>\n<body>\n  <h2>Dynamic Typing Explorer</h2>\n  <div class=\"section\">\n    <div class=\"small\">Create variables of many runtime types, coerce, apply operations, build workflows, fuzz and inspect how dynamic typing behaves.</div>\n  </div>\n\n  <!-- Variable creation -->\n  <div class=\"section\" id=\"create-section\">\n    <div><strong>Create / Update Variable</strong></div>\n    <label for=\"var-name\">Name:</label><input id=\"var-name\" placeholder=\"e.g. a\" />\n    <label for=\"var-type\">Type:</label>\n    <select id=\"var-type\">\n      <option>Number</option>\n      <option>String</option>\n      <option>Boolean</option>\n      <option>Null</option>\n      <option>Undefined</option>\n      <option>Object</option>\n      <option>Array</option>\n      <option>Function</option>\n      <option>Date</option>\n      <option>RegExp</option>\n      <option>Symbol</option>\n      <option>BigInt</option>\n    </select>\n    <div id=\"value-controls\" style=\"margin-top:6px;\">\n      <!-- dynamic controls inserted here -->\n    </div>\n    <button id=\"create-btn\">Create / Update</button>\n    <button id=\"delete-btn\">Delete</button>\n    <button id=\"random-btn\">Randomize Example</button>\n    <button id=\"clear-all-btn\">Clear All</button>\n  </div>\n\n  <!-- Variables list -->\n  <div class=\"section\">\n    <div><strong>Variables</strong></div>\n    <div class=\"vars\" id=\"vars-list\" aria-live=\"polite\"></div>\n  </div>\n\n  <!-- Inspector -->\n  <div class=\"section\">\n    <div><strong>Inspector / Actions on Selected Variable</strong></div>\n    <div id=\"inspector\">No variable selected.</div>\n    <div style=\"margin-top:8px;\">\n      <label for=\"coerce-to\">Coerce to:</label>\n      <select id=\"coerce-to\">\n        <option>Number</option><option>String</option><option>Boolean</option><option>Null</option><option>Undefined</option>\n        <option>Object</option><option>Array</option><option>Function</option><option>Date</option><option>RegExp</option><option>Symbol</option><option>BigInt</option>\n      </select>\n      <button id=\"coerce-btn\">Coerce</button>\n      <button id=\"clone-btn\">Clone Variable</button>\n      <button id=\"toggle-pin-btn\">Pin/Unpin</button>\n    </div>\n    <div style=\"margin-top:8px;\">\n      <label for=\"apply-method-name\">Call method / property name:</label>\n      <input id=\"apply-method-name\" placeholder=\"e.g. toString, slice, custom\" />\n      <button id=\"apply-method-btn\">Access / Call</button>\n    </div>\n  </div>\n\n  <!-- Operation builder -->\n  <div class=\"section\">\n    <div><strong>Operation Builder</strong></div>\n    <label for=\"op-left\">Left:</label>\n    <select id=\"op-left\"><option value=\"_literal\">Literal...</option></select>\n    <input id=\"op-left-lit\" placeholder=\"literal value (if selected)\" />\n\n    <label for=\"op-op\">Operator:</label>\n    <select id=\"op-op\">\n      <option value=\"+\">+</option><option value=\"-\">-</option><option value=\"*\">*</option><option value=\"/\">/</option>\n      <option value=\"%\">%</option><option value=\"concat\">concat (string/array)</option>\n      <option value=\"==\">==</option><option value=\"===\">===</option><option value=\"in\">in</option>\n      <option value=\"instanceof\">instanceof</option><option value=\"typeof\">typeof</option><option value=\"prop\">property access</option>\n    </select>\n\n    <label for=\"op-right\">Right:</label>\n    <select id=\"op-right\"><option value=\"_literal\">Literal...</option></select>\n    <input id=\"op-right-lit\" placeholder=\"literal value (if selected)\" />\n    <label for=\"result-name\">Result name:</label><input id=\"result-name\" placeholder=\"result\" />\n    <button id=\"exec-op-btn\">Execute Operation</button>\n    <div id=\"op-trace\" style=\"margin-top:6px;\"></div>\n  </div>\n\n  <!-- Workflow builder -->\n  <div class=\"section\">\n    <div><strong>Workflow / Sequence Builder</strong></div>\n    <div id=\"workflow-steps\"></div>\n    <button id=\"add-step-btn\">Add Step</button>\n    <button id=\"run-workflow-btn\">Run Workflow</button>\n    <button id=\"step-back-btn\">Step Back (undo last workflow run)</button>\n    <button id=\"clear-workflow-btn\">Clear Steps</button>\n    <div id=\"workflow-log\" style=\"margin-top:6px;\"></div>\n  </div>\n\n  <!-- Function editor -->\n  <div class=\"section\">\n    <div><strong>Function Editor (dynamic)</strong></div>\n    <div class=\"small\">Write a JavaScript function body. It runs in a sandboxed local eval. Use args[0], args[1], ... to access variables provided below.</div>\n    <textarea id=\"fn-body\">// return args[0] + args[1];</textarea>\n    <div style=\"margin-top:6px;\">\n      <label for=\"fn-args\">Use variables (comma separated names):</label>\n      <input id=\"fn-args\" placeholder=\"a,b\" />\n      <label for=\"fn-result-name\">Result name:</label><input id=\"fn-result-name\" />\n      <button id=\"run-fn-btn\">Run Function</button>\n    </div>\n    <div id=\"fn-output\" style=\"margin-top:6px;\"></div>\n  </div>\n\n  <!-- Fuzzer -->\n  <div class=\"section\">\n    <div><strong>Fuzzer / Mutator</strong></div>\n    <label for=\"fuzz-var\">Target variable:</label>\n    <select id=\"fuzz-var\"></select>\n    <label for=\"fuzz-iterations\">Iterations:</label><input id=\"fuzz-iterations\" type=\"number\" value=\"10\" style=\"width:60px;\" />\n    <button id=\"run-fuzz-btn\">Run Fuzz</button>\n    <button id=\"stop-fuzz-btn\">Stop</button>\n    <div id=\"fuzz-log\" style=\"margin-top:6px;\"></div>\n  </div>\n\n  <!-- Persistence -->\n  <div class=\"section\">\n    <div><strong>Save / Load Workspace</strong></div>\n    <button id=\"save-workspace-btn\">Export JSON</button>\n    <button id=\"load-workspace-btn\">Import JSON</button>\n    <button id=\"download-workspace-btn\">Download JSON file</button>\n    <textarea id=\"workspace-json\" placeholder=\"Paste workspace JSON here to import...\" style=\"height:120px;\"></textarea>\n  </div>\n\n  <!-- History / Trace -->\n  <div class=\"section\">\n    <div><strong>History / Trace</strong></div>\n    <div id=\"history-log\" style=\"max-height:200px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n    <button id=\"clear-history-btn\">Clear History</button>\n  </div>\n\n<script>\n(function(){\n  // Minimal, plain UI; heavy interactivity implemented here.\n\n  // State\n  const state = {\n    vars: {}, // name -> {value, type, pinned:false}\n    history: [], // actions\n    undoStack: [],\n    workflow: [], // steps\n    fuzzHandle: null\n  };\n\n  // Utility: determine precise runtime \"type label\"\n  function detectType(v){\n    if (v === null) return 'Null';\n    if (v === undefined) return 'Undefined';\n    if (typeof v === 'number') {\n      if (Number.isNaN(v)) return 'Number(NaN)';\n      return 'Number';\n    }\n    if (typeof v === 'string') return 'String';\n    if (typeof v === 'boolean') return 'Boolean';\n    if (typeof v === 'bigint') return 'BigInt';\n    if (typeof v === 'symbol') return 'Symbol';\n    if (typeof v === 'function') return 'Function';\n    if (v instanceof Date) return 'Date';\n    if (v instanceof RegExp) return 'RegExp';\n    if (Array.isArray(v)) return 'Array';\n    if (typeof v === 'object') return 'Object';\n    return typeof v;\n  }\n\n  function previewValue(v){\n    try {\n      if (typeof v === 'function') {\n        return v.toString().split('\\n').slice(0,2).join(' ') + (v.length ? '...' : '');\n      }\n      if (typeof v === 'symbol') return v.toString();\n      if (typeof v === 'bigint') return v.toString() + 'n';\n      if (v instanceof Date) return v.toString();\n      if (v instanceof RegExp) return v.toString();\n      if (typeof v === 'object') {\n        let s = JSON.stringify(v);\n        if (s && s.length > 80) s = s.slice(0,80) + '...';\n        return s;\n      }\n      return String(v);\n    } catch(e) {\n      return String(v);\n    }\n  }\n\n  // DOM elements\n  const els = {\n    varName: document.getElementById('var-name'),\n    varType: document.getElementById('var-type'),\n    valueControls: document.getElementById('value-controls'),\n    createBtn: document.getElementById('create-btn'),\n    deleteBtn: document.getElementById('delete-btn'),\n    randomBtn: document.getElementById('random-btn'),\n    clearAllBtn: document.getElementById('clear-all-btn'),\n    varsList: document.getElementById('vars-list'),\n    inspector: document.getElementById('inspector'),\n    coerceTo: document.getElementById('coerce-to'),\n    coerceBtn: document.getElementById('coerce-btn'),\n    cloneBtn: document.getElementById('clone-btn'),\n    togglePinBtn: document.getElementById('toggle-pin-btn'),\n    applyMethodName: document.getElementById('apply-method-name'),\n    applyMethodBtn: document.getElementById('apply-method-btn'),\n    opLeft: document.getElementById('op-left'),\n    opRight: document.getElementById('op-right'),\n    opLeftLit: document.getElementById('op-left-lit'),\n    opRightLit: document.getElementById('op-right-lit'),\n    opOp: document.getElementById('op-op'),\n    execOpBtn: document.getElementById('exec-op-btn'),\n    opTrace: document.getElementById('op-trace'),\n    resultName: document.getElementById('result-name'),\n    workflowSteps: document.getElementById('workflow-steps'),\n    addStepBtn: document.getElementById('add-step-btn'),\n    runWorkflowBtn: document.getElementById('run-workflow-btn'),\n    stepBackBtn: document.getElementById('step-back-btn'),\n    workflowLog: document.getElementById('workflow-log'),\n    clearWorkflowBtn: document.getElementById('clear-workflow-btn'),\n    fnBody: document.getElementById('fn-body'),\n    fnArgs: document.getElementById('fn-args'),\n    fnResultName: document.getElementById('fn-result-name'),\n    runFnBtn: document.getElementById('run-fn-btn'),\n    fnOutput: document.getElementById('fn-output'),\n    fuzzVar: document.getElementById('fuzz-var'),\n    fuzzIterations: document.getElementById('fuzz-iterations'),\n    runFuzzBtn: document.getElementById('run-fuzz-btn'),\n    stopFuzzBtn: document.getElementById('stop-fuzz-btn'),\n    fuzzLog: document.getElementById('fuzz-log'),\n    saveWorkspaceBtn: document.getElementById('save-workspace-btn'),\n    loadWorkspaceBtn: document.getElementById('load-workspace-btn'),\n    downloadWorkspaceBtn: document.getElementById('download-workspace-btn'),\n    workspaceJson: document.getElementById('workspace-json'),\n    historyLog: document.getElementById('history-log'),\n    clearHistoryBtn: document.getElementById('clear-history-btn'),\n    pinToggle: document.getElementById('toggle-pin-btn')\n  };\n\n  // Dynamic value input UI\n  function renderValueControls(type, initValue){\n    const container = els.valueControls;\n    container.innerHTML = '';\n    function addLabel(text){ const l = document.createElement('label'); l.textContent = text; container.appendChild(l); }\n    if (type === 'Number') {\n      addLabel('Number value:');\n      const inp = document.createElement('input'); inp.type='number'; inp.id='val-number';\n      if (initValue !== undefined && typeof initValue === 'number') inp.value = initValue;\n      container.appendChild(inp);\n      container.appendChild(document.createTextNode(' (use NaN by typing NaN, Infinity allowed)'));\n    } else if (type === 'String') {\n      addLabel('String value:');\n      const inp = document.createElement('input'); inp.id='val-string';\n      inp.value = (initValue!==undefined?String(initValue):'');\n      container.appendChild(inp);\n    } else if (type === 'Boolean') {\n      addLabel('Boolean:');\n      const cb = document.createElement('input'); cb.type='checkbox'; cb.id='val-boolean';\n      if (initValue !== undefined) cb.checked = !!initValue;\n      container.appendChild(cb);\n    } else if (type === 'Null') {\n      container.appendChild(document.createTextNode('Value will be null'));\n    } else if (type === 'Undefined') {\n      container.appendChild(document.createTextNode('Value will be undefined'));\n    } else if (type === 'Object') {\n      addLabel('JSON object:');\n      const ta = document.createElement('textarea'); ta.id='val-object'; ta.style.width='60%';\n      ta.value = (initValue && typeof initValue === 'object' && !Array.isArray(initValue)) ? JSON.stringify(initValue, null, 2) : '{}';\n      container.appendChild(ta);\n    } else if (type === 'Array') {\n      addLabel('Array JSON:');\n      const ta = document.createElement('textarea'); ta.id='val-array'; ta.style.width='60%';\n      ta.value = (Array.isArray(initValue) ? JSON.stringify(initValue, null, 2) : '[]');\n      container.appendChild(ta);\n    } else if (type === 'Function') {\n      addLabel('Function body (use args array):');\n      const ta = document.createElement('textarea'); ta.id='val-fn'; ta.style.width='60%';\n      ta.value = (typeof initValue === 'function') ? initValue.toString() : '// return args[0];';\n      container.appendChild(ta);\n      container.appendChild(document.createTextNode(' Example: return args[0] + args[1];'));\n    } else if (type === 'Date') {\n      addLabel('Date string:');\n      const inp = document.createElement('input'); inp.id='val-date';\n      inp.placeholder = '2020-01-01T00:00:00Z';\n      if (initValue instanceof Date) inp.value = initValue.toISOString();\n      container.appendChild(inp);\n    } else if (type === 'RegExp') {\n      addLabel('Pattern:');\n      const pat = document.createElement('input'); pat.id='val-regexp';\n      const flags = document.createElement('input'); flags.id='val-regexp-flags'; flags.placeholder='flags';\n      pat.value = (initValue instanceof RegExp) ? initValue.source : '';\n      flags.value = (initValue instanceof RegExp) ? initValue.flags : '';\n      container.appendChild(pat); container.appendChild(flags);\n    } else if (type === 'Symbol') {\n      addLabel('Symbol description:');\n      const inp = document.createElement('input'); inp.id='val-symbol';\n      inp.value = (typeof initValue === 'symbol') ? String(initValue).slice(7,-1) : '';\n      container.appendChild(inp);\n    } else if (type === 'BigInt') {\n      addLabel('BigInt (integer):');\n      const inp = document.createElement('input'); inp.id='val-bint';\n      if (typeof initValue === 'bigint') inp.value = initValue.toString();\n      container.appendChild(inp);\n    } else {\n      container.appendChild(document.createTextNode('No editor for this type.'));\n    }\n  }\n\n  // Initialize value controls\n  renderValueControls(els.varType.value);\n\n  els.varType.addEventListener('change', ()=> renderValueControls(els.varType.value));\n\n  // Create or update variable\n  function readValueFromControls(type){\n    try {\n      if (type === 'Number') {\n        const el = document.getElementById('val-number');\n        if (!el) return NaN;\n        const s = el.value;\n        if (s === 'NaN') return NaN;\n        if (s === 'Infinity') return Infinity;\n        if (s === '-Infinity') return -Infinity;\n        const n = Number(s);\n        return n;\n      } else if (type === 'String') {\n        return document.getElementById('val-string').value;\n      } else if (type === 'Boolean') {\n        return document.getElementById('val-boolean').checked;\n      } else if (type === 'Null') {\n        return null;\n      } else if (type === 'Undefined') {\n        return undefined;\n      } else if (type === 'Object') {\n        const s = document.getElementById('val-object').value;\n        return JSON.parse(s);\n      } else if (type === 'Array') {\n        const s = document.getElementById('val-array').value;\n        return JSON.parse(s);\n      } else if (type === 'Function') {\n        const s = document.getElementById('val-fn').value;\n        // create function: new Function('args', body) but user expects to use args[]; we'll wrap\n        const body = s;\n        const fn = function(){};\n        try {\n          const f = new Function('args', body);\n          return f;\n        } catch(e) {\n          throw new Error('Function body parse error: ' + e.message);\n        }\n      } else if (type === 'Date') {\n        const s = document.getElementById('val-date').value;\n        return new Date(s || undefined);\n      } else if (type === 'RegExp') {\n        const pattern = document.getElementById('val-regexp').value;\n        const flags = document.getElementById('val-regexp-flags').value;\n        return new RegExp(pattern, flags);\n      } else if (type === 'Symbol') {\n        const desc = document.getElementById('val-symbol').value;\n        return Symbol(desc);\n      } else if (type === 'BigInt') {\n        const s = document.getElementById('val-bint').value;\n        return BigInt(s || '0');\n      }\n    } catch(e){\n      throw e;\n    }\n  }\n\n  function saveVar(name, value){\n    const prev = state.vars[name];\n    state.undoStack.push({type:'set', name, prev});\n    state.vars[name] = {value, type: detectType(value), pinned: prev?prev.pinned:false};\n    pushHistory('set variable ' + name + ' = ' + previewValue(value) + ' (' + state.vars[name].type + ')');\n    refreshUI();\n  }\n\n  function deleteVar(name){\n    if (!state.vars[name]) return;\n    state.undoStack.push({type:'delete', name, prev: state.vars[name]});\n    delete state.vars[name];\n    pushHistory('deleted variable ' + name);\n    refreshUI();\n  }\n\n  // Create button\n  els.createBtn.addEventListener('click', ()=>{\n    const name = els.varName.value.trim();\n    if (!name) { alert('Provide variable name'); return; }\n    const type = els.varType.value;\n    try {\n      const value = readValueFromControls(type);\n      saveVar(name, value);\n      els.varName.value = name;\n    } catch(e){\n      alert('Error creating variable: ' + e.message);\n    }\n  });\n\n  els.deleteBtn.addEventListener('click', ()=>{\n    const name = els.varName.value.trim();\n    if (!name) { alert('Provide variable name to delete'); return; }\n    if (!state.vars[name]) { alert('Variable not found'); return; }\n    if (!confirm('Delete variable ' + name + '?')) return;\n    deleteVar(name);\n  });\n\n  els.clearAllBtn.addEventListener('click', ()=>{\n    if (!confirm('Clear all variables?')) return;\n    state.undoStack.push({type:'clearAll', prev: JSON.parse(serializeWorkspace())});\n    state.vars = {};\n    pushHistory('cleared all variables');\n    refreshUI();\n  });\n\n  // Random example\n  els.randomBtn.addEventListener('click', ()=>{\n    // Create a few sample variables demonstrating types\n    const examples = {\n      a: 42,\n      b: \"hello\",\n      c: true,\n      d: null,\n      e: undefined,\n      f: {x:1, y:'z'},\n      g: [1,\"two\",null],\n      h: function(args){ return (args[0]||0) + (args[1]||0); },\n      i: new Date(),\n      j: /ab\\d+/gi,\n      k: Symbol('sym'),\n      l: BigInt(9007199254740991)\n    };\n    state.undoStack.push({type:'setMany', prev: JSON.parse(serializeWorkspace())});\n    state.vars = {};\n    Object.keys(examples).forEach(n => {\n      state.vars[n] = {value: examples[n], type: detectType(examples[n]), pinned:false};\n    });\n    pushHistory('loaded random example variables');\n    refreshUI();\n  });\n\n  // Render variables list\n  function refreshUI(){\n    // Vars list\n    const list = els.varsList;\n    list.innerHTML = '';\n    const names = Object.keys(state.vars).sort();\n    if (names.length === 0) {\n      list.textContent = '(no variables)';\n    } else {\n      names.forEach(name => {\n        const row = document.createElement('div'); row.className='varrow';\n        const v = state.vars[name];\n        const btn = document.createElement('button'); btn.textContent = 'Select';\n        btn.addEventListener('click', ()=> selectVar(name));\n        row.appendChild(btn);\n        const txt = document.createElement('span');\n        txt.textContent = ' ' + name + ' : ' + v.type + ' = ' + previewValue(v.value) + (v.pinned ? ' [pinned]' : '');\n        row.appendChild(txt);\n        const editBtn = document.createElement('button'); editBtn.textContent='Edit';\n        editBtn.addEventListener('click', ()=> {\n          els.varName.value = name;\n          // set type select to best match (one of options)\n          const t = v.type.split('(')[0];\n          for (let i=0;i<els.varType.options.length;i++){\n            if (els.varType.options[i].value === t) { els.varType.selectedIndex = i; break; }\n          }\n          renderValueControls(els.varType.value, v.value);\n        });\n        row.appendChild(editBtn);\n        const delBtn = document.createElement('button'); delBtn.textContent='Delete';\n        delBtn.addEventListener('click', ()=> { if(confirm('Delete '+name+'?')) deleteVar(name); });\n        row.appendChild(delBtn);\n        const pinBtn = document.createElement('button'); pinBtn.textContent = v.pinned ? 'Unpin' : 'Pin';\n        pinBtn.addEventListener('click', ()=> { state.vars[name].pinned = !state.vars[name].pinned; refreshUI(); });\n        row.appendChild(pinBtn);\n        list.appendChild(row);\n      });\n    }\n\n    // Update op selects and fuzz, inspector selection if any\n    updateOpSelects();\n    updateFuzzSelect();\n    renderWorkflowSteps();\n    renderHistory();\n  }\n\n  function pushHistory(msg){\n    const t = new Date().toISOString();\n    state.history.push({t, msg, snapshot: JSON.parse(serializeWorkspace())});\n    renderHistory();\n  }\n\n  function renderHistory(){\n    const out = els.historyLog;\n    out.innerHTML = '';\n    state.history.slice().reverse().forEach(h => {\n      const d = document.createElement('div');\n      d.textContent = '['+h.t+'] ' + h.msg;\n      out.appendChild(d);\n    });\n  }\n\n  // Select variable: show inspector\n  let selectedVar = null;\n  function selectVar(name){\n    selectedVar = name;\n    const info = document.createElement('div');\n    const v = state.vars[name];\n    if (!v) { els.inspector.textContent = 'No variable selected.'; return; }\n    info.appendChild(document.createTextNode('Name: ' + name));\n    info.appendChild(document.createElement('br'));\n    info.appendChild(document.createTextNode('Type: ' + v.type));\n    info.appendChild(document.createElement('br'));\n    info.appendChild(document.createTextNode('Preview: ' + previewValue(v.value)));\n    info.appendChild(document.createElement('br'));\n    // Deep inspection\n    const btn = document.createElement('button'); btn.textContent='Show details';\n    btn.addEventListener('click', ()=> {\n      const det = inspectValue(v.value);\n      alert('Details for ' + name + ':\\n\\n' + det);\n    });\n    info.appendChild(btn);\n    // Show properties if object/array\n    if (typeof v.value === 'object' && v.value !== null) {\n      try {\n        info.appendChild(document.createElement('br'));\n        const keys = Object.keys(v.value);\n        info.appendChild(document.createTextNode('Keys: ' + (keys.length ? keys.join(', ') : '(none)')));\n      } catch(e){}\n    }\n    els.inspector.innerHTML = '';\n    els.inspector.appendChild(info);\n  }\n\n  function inspectValue(val){\n    try {\n      let out = '';\n      out += 'Runtime typeof: ' + typeof val + '\\n';\n      out += 'Detected type label: ' + detectType(val) + '\\n';\n      out += 'Preview: ' + previewValue(val) + '\\n';\n      out += 'Is truthy: ' + (!!val) + '\\n';\n      out += 'Is finite number: ' + (typeof val === 'number' && Number.isFinite(val)) + '\\n';\n      out += 'Is NaN: ' + (typeof val === 'number' && Number.isNaN(val)) + '\\n';\n      out += 'Is array: ' + Array.isArray(val) + '\\n';\n      out += 'Is Date: ' + (val instanceof Date) + '\\n';\n      out += 'Is RegExp: ' + (val instanceof RegExp) + '\\n';\n      out += 'Is function: ' + (typeof val === 'function') + '\\n';\n      try {\n        out += 'JSON: ' + JSON.stringify(val, null, 2) + '\\n';\n      } catch(e){\n        out += 'JSON: (could not stringify) ' + e.message + '\\n';\n      }\n      if (typeof val === 'object' && val !== null) {\n        out += 'Own keys: ' + Object.keys(val).join(', ') + '\\n';\n        out += 'Prototype chain: ';\n        let proto = Object.getPrototypeOf(val);\n        const parts = [];\n        while (proto) {\n          parts.push(proto.constructor && proto.constructor.name ? proto.constructor.name : String(proto));\n          proto = Object.getPrototypeOf(proto);\n        }\n        out += parts.join(' <- ') + '\\n';\n      }\n      return out;\n    } catch(e){\n      return 'Error inspecting: ' + e.message;\n    }\n  }\n\n  // Coerce logic - examples of JS coercion but we'll implement explicit conversions\n  function coerceValue(val, targetType){\n    if (targetType === 'Number') {\n      if (typeof val === 'bigint') return Number(val);\n      if (typeof val === 'symbol') return NaN;\n      return Number(val);\n    }\n    if (targetType === 'String') {\n      if (typeof val === 'symbol') return String(val);\n      if (typeof val === 'function') return val.toString();\n      return String(val);\n    }\n    if (targetType === 'Boolean') {\n      return Boolean(val);\n    }\n    if (targetType === 'Null') return null;\n    if (targetType === 'Undefined') return undefined;\n    if (targetType === 'Object') {\n      if (val === null || val === undefined) return {value: val};\n      if (typeof val === 'object') return val;\n      // primitives to wrapper\n      return {value: val};\n    }\n    if (targetType === 'Array') {\n      if (Array.isArray(val)) return val;\n      if (val === null || val === undefined) return [val];\n      if (typeof val === 'string') return val.split('');\n      return [val];\n    }\n    if (targetType === 'Function') {\n      if (typeof val === 'function') return val;\n      // Wrap primitive into function returning it\n      return function(){ return val; };\n    }\n    if (targetType === 'Date') {\n      return new Date(val);\n    }\n    if (targetType === 'RegExp') {\n      return new RegExp(String(val));\n    }\n    if (targetType === 'Symbol') {\n      return Symbol(String(val));\n    }\n    if (targetType === 'BigInt') {\n      try { return BigInt(val); } catch(e) { return BigInt(0); }\n    }\n    return val;\n  }\n\n  // Coerce button\n  els.coerceBtn.addEventListener('click', ()=>{\n    if (!selectedVar) { alert('Select a variable first'); return; }\n    const target = els.coerceTo.value;\n    const cur = state.vars[selectedVar];\n    try {\n      const newVal = coerceValue(cur.value, target);\n      saveVar(selectedVar, newVal);\n      pushHistory('coerced ' + selectedVar + ' to ' + target);\n      selectVar(selectedVar);\n    } catch(e){\n      alert('Coercion error: ' + e.message);\n    }\n  });\n\n  // Clone\n  els.cloneBtn.addEventListener('click', ()=>{\n    if (!selectedVar) { alert('Select a variable to clone'); return; }\n    let newName = prompt('Clone name:', selectedVar + '_copy');\n    if (!newName) return;\n    // deep clone best-effort\n    const orig = state.vars[selectedVar];\n    let copyVal;\n    try {\n      if (typeof orig.value === 'function') {\n        copyVal = orig.value;\n      } else if (typeof orig.value === 'symbol') {\n        copyVal = Symbol(String(orig.value).slice(7,-1));\n      } else {\n        copyVal = JSON.parse(JSON.stringify(orig.value));\n      }\n    } catch(e) { copyVal = orig.value; }\n    saveVar(newName, copyVal);\n    pushHistory('cloned ' + selectedVar + ' to ' + newName);\n  });\n\n  // Toggle pin\n  els.togglePinBtn.addEventListener('click', ()=>{\n    if (!selectedVar) { alert('Select a variable'); return; }\n    state.vars[selectedVar].pinned = !state.vars[selectedVar].pinned;\n    refreshUI();\n  });\n\n  // Apply method/property\n  els.applyMethodBtn.addEventListener('click', ()=>{\n    if (!selectedVar) { alert('Select a variable'); return; }\n    const name = els.applyMethodName.value.trim();\n    if (!name) { alert('Provide method/property name'); return; }\n    const v = state.vars[selectedVar].value;\n    try {\n      if (typeof v === 'object' && v !== null && name in v) {\n        const prop = v[name];\n        if (typeof prop === 'function') {\n          // call with no args\n          const res = prop.call(v);\n          const resName = prompt('Result variable name (leave empty to overwrite):', selectedVar + '_' + name);\n          if (resName) saveVar(resName, res);\n          pushHistory('called method ' + name + ' on ' + selectedVar);\n        } else {\n          const resName = prompt('Result variable name to store property value:', selectedVar + '_' + name);\n          if (resName) saveVar(resName, prop);\n          pushHistory('read property ' + name + ' from ' + selectedVar);\n        }\n      } else if (typeof v === 'string' || Array.isArray(v)) {\n        // attempt to access property or method\n        const prop = v[name];\n        if (typeof prop === 'function') {\n          const res = prop.call(v);\n          const rn = prompt('Result variable name:', selectedVar + '_' + name);\n          if (rn) saveVar(rn, res);\n          pushHistory('called method ' + name + ' on ' + selectedVar);\n        } else {\n          const rn = prompt('Result variable name:', selectedVar + '_' + name);\n          if (rn) saveVar(rn, prop);\n          pushHistory('read property ' + name + ' from ' + selectedVar);\n        }\n      } else {\n        alert('Property/method not found on value.');\n      }\n    } catch(e){\n      alert('Error calling property/method: ' + e.message);\n    }\n  });\n\n  // Operation builder - update selects with variables\n  function updateOpSelects(){\n    const vars = Object.keys(state.vars).sort();\n    [els.opLeft, els.opRight].forEach(sel => {\n      const prev = sel.value;\n      sel.innerHTML = '';\n      const litOpt = document.createElement('option'); litOpt.value = '_literal'; litOpt.textContent = '(literal)';\n      sel.appendChild(litOpt);\n      vars.forEach(n => {\n        const o = document.createElement('option'); o.value = n; o.textContent = n;\n        sel.appendChild(o);\n      });\n      if (Array.from(sel.options).some(o => o.value === prev)) sel.value = prev;\n    });\n  }\n\n  // parse literal input string to JS value best-effort\n  function parseLiteral(s){\n    s = s.trim();\n    if (s === '') return '';\n    if (s === 'null') return null;\n    if (s === 'undefined') return undefined;\n    if (s === 'NaN') return NaN;\n    if (s === 'Infinity') return Infinity;\n    if (s === '-Infinity') return -Infinity;\n    if (s === 'true') return true;\n    if (s === 'false') return false;\n    if (/^-?\\d+n$/.test(s)) return BigInt(s.slice(0,-1));\n    // try number\n    if (!isNaN(Number(s))) return Number(s);\n    // try JSON parse (object, array)\n    try {\n      return JSON.parse(s);\n    } catch(e){}\n    // string literal without quotes\n    if ((s.startsWith('\"') && s.endsWith('\"')) || (s.startsWith(\"'\") && s.endsWith(\"'\"))) {\n      return s.slice(1,-1);\n    }\n    return s;\n  }\n\n  // Execute operation\n  els.execOpBtn.addEventListener('click', ()=>{\n    const leftVal = (els.opLeft.value === '_literal') ? parseLiteral(els.opLeftLit.value) : (state.vars[els.opLeft.value] && state.vars[els.opLeft.value].value);\n    const rightVal = (els.opRight.value === '_literal') ? parseLiteral(els.opRightLit.value) : (state.vars[els.opRight.value] && state.vars[els.opRight.value].value);\n    const op = els.opOp.value;\n    const resultName = els.resultName.value.trim() || 'result_' + Math.floor(Math.random()*1000);\n    let result;\n    let trace = '';\n    try {\n      if (op === '+') {\n        trace = `Performing + between (${detectType(leftVal)}) and (${detectType(rightVal)})`;\n        result = leftVal + rightVal;\n      } else if (op === '-') {\n        result = leftVal - rightVal;\n      } else if (op === '*') {\n        result = leftVal * rightVal;\n      } else if (op === '/') {\n        result = leftVal / rightVal;\n      } else if (op === '%') {\n        result = leftVal % rightVal;\n      } else if (op === 'concat') {\n        if (Array.isArray(leftVal) && Array.isArray(rightVal)) result = leftVal.concat(rightVal);\n        else result = String(leftVal).concat(String(rightVal));\n      } else if (op === '==') {\n        result = leftVal == rightVal;\n      } else if (op === '===') {\n        result = leftVal === rightVal;\n      } else if (op === 'in') {\n        // right should be object or prototype chain\n        result = (rightVal != null) && (String(leftVal) in rightVal);\n      } else if (op === 'instanceof') {\n        // rightVal expected to be function/constructor\n        try { result = leftVal instanceof rightVal; } catch(e){ result = 'error: ' + e.message; }\n      } else if (op === 'typeof') {\n        result = typeof leftVal;\n      } else if (op === 'prop') {\n        result = leftVal && leftVal[rightVal];\n      } else {\n        throw new Error('Unsupported operator');\n      }\n      saveVar(resultName, result);\n      els.opTrace.textContent = 'Executed. ' + trace + ' -> ' + previewValue(result) + ' (' + detectType(result) + ')';\n      pushHistory('operation ' + op + ' -> ' + resultName);\n    } catch(e){\n      els.opTrace.textContent = 'Operation error: ' + e.message;\n      pushHistory('operation error: ' + e.message);\n    }\n  });\n\n  // Workflow builder (simple: list of operations)\n  function renderWorkflowSteps(){\n    const container = els.workflowSteps;\n    container.innerHTML = '';\n    state.workflow.forEach((step, idx) => {\n      const div = document.createElement('div');\n      div.className='compact';\n      div.textContent = (idx+1) + '. ' + step.desc;\n      const up = document.createElement('button'); up.textContent='↑'; up.addEventListener('click', ()=> { if (idx>0){ const s = state.workflow.splice(idx,1)[0]; state.workflow.splice(idx-1,0,s); renderWorkflowSteps(); } });\n      const down = document.createElement('button'); down.textContent='↓'; down.addEventListener('click', ()=> { if (idx<state.workflow.length-1){ const s = state.workflow.splice(idx,1)[0]; state.workflow.splice(idx+1,0,s); renderWorkflowSteps(); } });\n      const del = document.createElement('button'); del.textContent='Del'; del.addEventListener('click', ()=> { state.workflow.splice(idx,1); renderWorkflowSteps(); });\n      div.appendChild(up); div.appendChild(down); div.appendChild(del);\n      container.appendChild(div);\n    });\n    if (state.workflow.length === 0) container.textContent = '(no workflow steps)';\n  }\n\n  els.addStepBtn.addEventListener('click', ()=>{\n    // Prompt user to create a single op step (simple formatted)\n    const left = prompt('Left operand (var name or literal prefix with L:), e.g. a or L:42', '');\n    if (left === null) return;\n    const op = prompt('Operator (e.g. +, -, concat, ==, ===, typeof, prop, in, instanceof):','+');\n    if (op === null) return;\n    const right = prompt('Right operand (var name or literal prefix with L:), leave blank if none','');\n    if (right === null) return;\n    const target = prompt('Result variable name','step'+(state.workflow.length+1));\n    if (target === null) return;\n    const desc = left + ' ' + op + ' ' + right + ' -> ' + target;\n    state.workflow.push({left, op, right, target, desc});\n    renderWorkflowSteps();\n  });\n\n  els.runWorkflowBtn.addEventListener('click', ()=>{\n    if (state.workflow.length === 0) { alert('No steps'); return; }\n    // Snapshot for undo\n    state.undoStack.push({type:'setMany', prev: JSON.parse(serializeWorkspace())});\n    const log = [];\n    for (let i=0;i<state.workflow.length;i++){\n      const s = state.workflow[i];\n      // resolve operand\n      const leftVal = s.left.startsWith('L:') ? parseLiteral(s.left.slice(2)) : (state.vars[s.left] && state.vars[s.left].value);\n      const rightVal = s.right && s.right.startsWith('L:') ? parseLiteral(s.right.slice(2)) : (s.right ? (state.vars[s.right] && state.vars[s.right].value) : undefined);\n      // reuse operation execution logic minimally\n      let result;\n      try {\n        if (s.op === '+') result = leftVal + rightVal;\n        else if (s.op === '-') result = leftVal - rightVal;\n        else if (s.op === 'concat') result = (Array.isArray(leftVal) ? leftVal.concat(rightVal) : String(leftVal)+String(rightVal));\n        else if (s.op === 'typeof') result = typeof leftVal;\n        else if (s.op === '==') result = leftVal == rightVal;\n        else if (s.op === '===') result = leftVal === rightVal;\n        else if (s.op === 'in') result = rightVal && (String(leftVal) in rightVal);\n        else if (s.op === 'prop') result = leftVal && leftVal[rightVal];\n        else result = undefined;\n        state.vars[s.target] = {value: result, type: detectType(result), pinned:false};\n        log.push('Step ' + (i+1) + ': ' + s.desc + ' => ' + previewValue(result) + ' (' + detectType(result) + ')');\n      } catch(e){\n        log.push('Step ' + (i+1) + ': error - ' + e.message);\n      }\n    }\n    pushHistory('ran workflow with ' + state.workflow.length + ' steps');\n    els.workflowLog.textContent = log.join('\\n');\n    refreshUI();\n  });\n\n  els.stepBackBtn.addEventListener('click', ()=>{\n    // Undo last setMany if available\n    if (state.undoStack.length === 0) { alert('Nothing to undo'); return; }\n    const u = state.undoStack.pop();\n    if (u && u.type === 'setMany') {\n      loadWorkspaceFromObj(u.prev);\n      pushHistory('undid workflow run');\n    } else if (u && u.type === 'set') {\n      if (u.prev) state.vars[u.name] = u.prev; else delete state.vars[u.name];\n      pushHistory('undid set ' + u.name);\n    } else {\n      alert('Undo not applicable');\n    }\n    refreshUI();\n  });\n\n  els.clearWorkflowBtn.addEventListener('click', ()=> { state.workflow = []; renderWorkflowSteps(); });\n\n  // Function editor run\n  els.runFnBtn.addEventListener('click', ()=>{\n    const body = els.fnBody.value;\n    const argNames = els.fnArgs.value.split(',').map(s => s.trim()).filter(Boolean);\n    const resultName = els.fnResultName.value.trim() || ('fnres' + Math.floor(Math.random()*1000));\n    const args = argNames.map(n => state.vars[n] ? state.vars[n].value : undefined);\n    try {\n      const f = new Function('args', body);\n      const res = f(args);\n      saveVar(resultName, res);\n      els.fnOutput.textContent = 'Result saved as ' + resultName + ': ' + previewValue(res);\n      pushHistory('ran dynamic function -> ' + resultName);\n    } catch(e){\n      els.fnOutput.textContent = 'Function error: ' + e.message;\n      pushHistory('function error: ' + e.message);\n    }\n  });\n\n  // Fuzzer\n  function randomValueOfType(t){\n    if (t === 'Number') return (Math.random()*200-100).toFixed(2) * 1;\n    if (t === 'String') return Math.random().toString(36).slice(2,8);\n    if (t === 'Boolean') return Math.random() > 0.5;\n    if (t === 'Null') return null;\n    if (t === 'Undefined') return undefined;\n    if (t === 'Object') return {r:Math.random(), n: Math.floor(Math.random()*10)};\n    if (t === 'Array') return [Math.random(), Math.random().toString(36).slice(2,4)];\n    if (t === 'Function') return function(args){ return args; };\n    if (t === 'Date') return new Date(Date.now() + Math.floor(Math.random()*1000000000));\n    if (t === 'RegExp') return new RegExp('x'+Math.floor(Math.random()*10));\n    if (t === 'Symbol') return Symbol(Math.random().toString(36).slice(2,6));\n    if (t === 'BigInt') return BigInt(Math.floor(Math.random()*100000));\n    return null;\n  }\n\n  function updateFuzzSelect(){\n    const s = els.fuzzVar;\n    const prev = s.value;\n    s.innerHTML = '';\n    Object.keys(state.vars).sort().forEach(n => {\n      const o = document.createElement('option'); o.value=n; o.textContent=n;\n      s.appendChild(o);\n    });\n    if (prev && Array.from(s.options).some(o => o.value === prev)) s.value = prev;\n  }\n\n  els.runFuzzBtn.addEventListener('click', ()=>{\n    const name = els.fuzzVar.value;\n    if (!name || !state.vars[name]) { alert('Select target variable'); return; }\n    const iters = Math.max(1, Number(els.fuzzIterations.value) || 10);\n    els.fuzzLog.textContent = 'Running fuzz...';\n    let count = 0;\n    if (state.fuzzHandle) { alert('Fuzzer already running'); return; }\n    state.fuzzHandle = setInterval(()=> {\n      count++;\n      // mutate randomly: change type randomly, or alter property if object/array\n      const types = ['Number','String','Boolean','Null','Undefined','Object','Array','Function','Date','RegExp','Symbol','BigInt'];\n      const t = types[Math.floor(Math.random()*types.length)];\n      const newVal = randomValueOfType(t);\n      state.vars[name] = {value: newVal, type: detectType(newVal), pinned:false};\n      pushHistory('fuzz: set ' + name + ' to ' + previewValue(newVal));\n      refreshUI();\n      els.fuzzLog.textContent = 'Fuzz iteration ' + count + ' set ' + name + ' -> ' + previewValue(newVal) + ' (' + detectType(newVal) + ')';\n      if (count >= iters) {\n        clearInterval(state.fuzzHandle);\n        state.fuzzHandle = null;\n        els.fuzzLog.textContent += ' (done)';\n      }\n    }, 150);\n  });\n\n  els.stopFuzzBtn.addEventListener('click', ()=> {\n    if (state.fuzzHandle) { clearInterval(state.fuzzHandle); state.fuzzHandle = null; els.fuzzLog.textContent = 'Stopped.'; }\n  });\n\n  // Save/Load workspace\n  function serializeWorkspace(){\n    // Custom serializer: functions and symbols handled specially\n    const out = {};\n    Object.keys(state.vars).forEach(name => {\n      const v = state.vars[name];\n      out[name] = serializeValue(v.value);\n      out[name].pinned = v.pinned;\n      out[name].type = v.type;\n    });\n    return JSON.stringify(out);\n  }\n\n  function serializeValue(v){\n    if (v === null) return {__type:'Null', value:null};\n    if (v === undefined) return {__type:'Undefined'};\n    if (typeof v === 'number') return {__type:'Number', value:v};\n    if (typeof v === 'string') return {__type:'String', value:v};\n    if (typeof v === 'boolean') return {__type:'Boolean', value:v};\n    if (typeof v === 'bigint') return {__type:'BigInt', value: v.toString()};\n    if (typeof v === 'symbol') return {__type:'Symbol', value: String(v).slice(7,-1)};\n    if (typeof v === 'function') return {__type:'Function', value: v.toString()};\n    if (v instanceof Date) return {__type:'Date', value: v.toISOString()};\n    if (v instanceof RegExp) return {__type:'RegExp', value: v.toString()};\n    if (Array.isArray(v)) return {__type:'Array', value: v.map(serializeValue)};\n    if (typeof v === 'object') {\n      const o = {};\n      Object.keys(v).forEach(k => o[k] = serializeValue(v[k]));\n      return {__type:'Object', value:o};\n    }\n    return {__type: typeof v, value:String(v)};\n  }\n\n  function deserializeValue(s){\n    if (!s || typeof s !== 'object' || !s.__type) return undefined;\n    const t = s.__type;\n    if (t === 'Null') return null;\n    if (t === 'Undefined') return undefined;\n    if (t === 'Number') return Number(s.value);\n    if (t === 'String') return s.value;\n    if (t === 'Boolean') return !!s.value;\n    if (t === 'BigInt') return BigInt(s.value);\n    if (t === 'Symbol') return Symbol(s.value);\n    if (t === 'Function') {\n      try {\n        return new Function('args', s.value.replace(/^function\\s*\\(.*\\)\\s*{/, '').replace(/}$/, ''));\n      } catch(e){\n        // best effort wrap\n        return function(){};\n      }\n    }\n    if (t === 'Date') return new Date(s.value);\n    if (t === 'RegExp') {\n      // format: /pattern/flags\n      const m = s.value.match(/^\\/(.+)\\/([gimsuy]*)$/);\n      if (m) return new RegExp(m[1], m[2]);\n      return new RegExp(s.value);\n    }\n    if (t === 'Array') return s.value.map(deserializeValue);\n    if (t === 'Object') {\n      const o = {};\n      Object.keys(s.value||{}).forEach(k => o[k] = deserializeValue(s.value[k]));\n      return o;\n    }\n    return s.value;\n  }\n\n  els.saveWorkspaceBtn.addEventListener('click', ()=>{\n    const out = serializeWorkspace();\n    els.workspaceJson.value = out;\n    alert('Workspace JSON placed in textarea below.');\n  });\n\n  els.downloadWorkspaceBtn.addEventListener('click', ()=>{\n    const blob = new Blob([serializeWorkspace()], {type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a'); a.href = url; a.download = 'workspace.json';\n    document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n  });\n\n  els.loadWorkspaceBtn.addEventListener('click', ()=>{\n    const txt = els.workspaceJson.value.trim();\n    if (!txt) { alert('Paste JSON into the textarea first'); return; }\n    try {\n      const obj = JSON.parse(txt);\n      loadWorkspaceFromObj(obj);\n      pushHistory('loaded workspace from JSON');\n      refreshUI();\n    } catch(e){\n      alert('Invalid JSON: ' + e.message);\n    }\n  });\n\n  function loadWorkspaceFromObj(obj){\n    state.vars = {};\n    Object.keys(obj).forEach(n => {\n      const entry = obj[n];\n      const v = deserializeValue(entry);\n      state.vars[n] = {value: v, type: detectType(v), pinned: !!entry.pinned};\n    });\n  }\n\n  // History clear\n  els.clearHistoryBtn.addEventListener('click', ()=> { state.history = []; renderHistory(); });\n\n  // Initial render\n  refreshUI();\n\n  // Expose some helpful console utilities for power users\n  window.DT = {\n    state,\n    saveVar,\n    deleteVar,\n    coerceValue,\n    detectType,\n    previewValue,\n    inspectValue,\n    serializeWorkspace\n  };\n\n  // Small helper: populate op selects on startup\n  updateOpSelects();\n  updateFuzzSelect();\n\n  // Allow pressing enter on varName to create\n  els.varName.addEventListener('keydown', (e)=> { if (e.key === 'Enter') els.createBtn.click(); });\n\n  // Keyboard shortcuts for convenience\n  document.addEventListener('keydown', (e)=>{\n    if (e.ctrlKey && e.key === 's') {\n      e.preventDefault();\n      els.saveWorkspaceBtn.click();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
