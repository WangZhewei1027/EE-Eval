    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Merge Sort — Visual Elegance</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;500;700;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071021;\n    --card: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.04);\n    --accent-1: #6EE7B7;\n    --accent-2: #7C6CFF;\n    --muted: rgba(255,255,255,0.7);\n    --soft: rgba(255,255,255,0.06);\n    --glass-2: rgba(255,255,255,0.02);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,108,255,0.12), transparent 6%),\n                radial-gradient(900px 400px at 95% 90%, rgba(110,231,183,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2));\n    color: #e9eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Decorative floating blurs */\n  .halo{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    overflow:hidden;\n  }\n  .glow {\n    position:absolute;\n    filter: blur(60px) saturate(140%);\n    opacity:0.9;\n    transform:translate3d(0,0,0);\n  }\n  .g1{width:520px;height:520px;left:-8%;top:6%;background:linear-gradient(135deg, rgba(124,108,255,0.35), rgba(124,108,255,0.12));border-radius:50%}\n  .g2{width:420px;height:420px;right:-6%;bottom:8%;background:linear-gradient(180deg, rgba(110,231,183,0.28), rgba(110,231,183,0.08));border-radius:50%}\n  .g3{width:220px;height:220px;left:24%;bottom:10%;background:linear-gradient(180deg, rgba(124,108,255,0.12), rgba(110,231,183,0.08));border-radius:50%}\n\n  .app {\n    position:relative;\n    z-index:5;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    height:100vh;\n    padding:48px;\n  }\n\n  .panel {\n    width:min(1150px,96vw);\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    border-radius:20px;\n    padding:28px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6);\n    border: 1px solid rgba(255,255,255,0.035);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:visible;\n  }\n\n  .header {\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:16px;\n    margin-bottom:18px;\n  }\n  .title{\n    display:flex;\n    gap:16px;\n    align-items:center;\n  }\n  .logo {\n    width:72px;height:72px;border-radius:14px;\n    background:linear-gradient(135deg,var(--accent-2), var(--accent-1));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 6px 30px rgba(124,108,255,0.18), inset 0 -6px 20px rgba(255,255,255,0.05);\n    transform:translateZ(0);\n  }\n  .logo svg {filter: drop-shadow(0 6px 14px rgba(0,0,0,0.35));}\n  .hdr-text{\n    display:flex;flex-direction:column;\n  }\n  .hdr-text .main{\n    font-family:\"Playfair Display\", serif;\n    font-size:20px;\n    letter-spacing:0.2px;\n    color: #fff;\n    font-weight:700;\n  }\n  .hdr-text .sub{\n    font-size:13px;\n    color:var(--muted);\n    margin-top:3px;\n    font-weight:500;\n  }\n\n  .controls{\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn{\n    --b:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.018));\n    background:var(--b);\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    padding:10px 14px;\n    border-radius:12px;\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    cursor:pointer;\n    transition:all 240ms cubic-bezier(.2,.9,.2,1);\n    font-weight:600;\n    font-size:13px;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n  }\n  .btn:hover{transform:translateY(-3px); color:#fff; border-color:rgba(124,108,255,0.6)}\n  .btn.play{\n    background:linear-gradient(90deg, rgba(124,108,255,0.16), rgba(110,231,183,0.06));\n    border:1px solid rgba(124,108,255,0.18);\n    color:#fff;\n  }\n  .btn .icon{width:18px;height:18px;display:inline-block;opacity:0.95}\n\n  .stage {\n    margin-top:12px;\n    height:520px;\n    position:relative;\n    display:flex;\n    align-items:flex-start;\n    justify-content:center;\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.006));\n    border:1px solid rgba(255,255,255,0.02);\n    overflow:hidden;\n  }\n\n  /* decorative ribbon */\n  .ribbon {\n    position:absolute;left:48px;top:28px;\n    padding:8px 12px;border-radius:999px;\n    background: linear-gradient(90deg, rgba(124,108,255,0.14), rgba(110,231,183,0.06));\n    font-size:12px;color:#fff;font-weight:700;letter-spacing:0.4px;\n    box-shadow: 0 6px 20px rgba(2,6,23,0.45);\n  }\n\n  /* central visual canvas */\n  .canvas {\n    position:relative;\n    width:92%;\n    height:100%;\n    display:block;\n    overflow:visible;\n    perspective:1000px;\n  }\n\n  /* legend */\n  .legend {\n    position:absolute;\n    right:28px;bottom:20px;\n    width:260px;\n    padding:12px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.02);\n    font-size:13px;color:var(--muted);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.45);\n  }\n  .legend .op{\n    display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;\n  }\n  .legend .op strong{color:#fff;font-weight:700}\n\n  /* tiles */\n  .tile {\n    position:absolute;\n    width:48px;\n    height:48px;\n    border-radius:10px;\n    display:flex;\n    align-items:flex-end;\n    justify-content:center;\n    transform-origin:center center;\n    transition:transform 650ms cubic-bezier(.2,.9,.2,1), box-shadow 300ms, opacity 300ms;\n    will-change:transform, opacity;\n    box-shadow: 0 8px 22px rgba(3,7,18,0.6);\n    color:#fff;\n    font-weight:700;\n    letter-spacing:0.6px;\n    font-size:12px;\n    padding:6px;\n    overflow:visible;\n    border:1px solid rgba(255,255,255,0.05);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  .tile .val {\n    position:relative;\n    z-index:2;\n    pointer-events:none;\n  }\n  .tile .bar {\n    position:absolute;\n    left:8px;right:8px;bottom:8px;\n    height:calc(100% - 24px);\n    border-radius:8px;\n    z-index:1;\n    opacity:0.9;\n    transform-origin:center bottom;\n    transition:height 600ms cubic-bezier(.2,.9,.2,1);\n  }\n\n  .tile[data-state=\"active\"] { transform:translateZ(30px) scale(1.045); box-shadow: 0 20px 50px rgba(124,108,255,0.18) }\n  .tile[data-state=\"merging\"] { box-shadow: 0 22px 70px rgba(110,231,183,0.12); }\n\n  /* subtle connecting arcs */\n  .arc{\n    position:absolute;\n    left:0;top:0;\n    pointer-events:none;\n  }\n\n  /* small status footer */\n  .status {\n    position:absolute;\n    left:28px;bottom:22px;\n    font-size:13px;color:var(--muted);\n    display:flex;gap:12px;align-items:center;\n  }\n  .status .dot{\n    width:10px;height:10px;border-radius:50%;\n    background:linear-gradient(90deg,var(--accent-2),var(--accent-1));\n    box-shadow: 0 6px 18px rgba(124,108,255,0.18);\n  }\n\n  /* responsive tweaks */\n  @media (max-width:860px){\n    .panel{padding:18px}\n    .logo{width:56px;height:56px}\n    .hdr-text .main{font-size:18px}\n    .stage{height:480px}\n    .legend{display:none}\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"halo\" aria-hidden=\"true\">\n    <div class=\"glow g1\"></div>\n    <div class=\"glow g2\"></div>\n    <div class=\"glow g3\"></div>\n  </div>\n\n  <div class=\"app\">\n    <div class=\"panel\" role=\"main\" aria-label=\"Merge Sort Visualization\">\n      <div class=\"header\">\n        <div class=\"title\">\n          <div class=\"logo\" aria-hidden=\"true\">\n            <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\">\n              <rect x=\"2\" y=\"3\" width=\"20\" height=\"18\" rx=\"4\" fill=\"white\" opacity=\"0.06\"/>\n              <path d=\"M7 8L12 13L17 8\" stroke=\"white\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.98\"/>\n              <path d=\"M7 12L12 17L17 12\" stroke=\"white\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.65\"/>\n            </svg>\n          </div>\n          <div class=\"hdr-text\">\n            <div class=\"main\">Merge Sort</div>\n            <div class=\"sub\">Elegant visual demonstration of the divide-and-conquer sorting process</div>\n          </div>\n        </div>\n\n        <div class=\"controls\" role=\"region\" aria-label=\"Controls\">\n          <button class=\"btn play\" id=\"playPause\" title=\"Play / Pause\">\n            <svg class=\"icon\" viewBox=\"0 0 24 24\"><path id=\"playIcon\" d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"/></svg>\n            <span id=\"playText\">Play</span>\n          </button>\n          <button class=\"btn\" id=\"shuffleBtn\" title=\"Shuffle & Restart\">\n            <svg class=\"icon\" viewBox=\"0 0 24 24\"><path d=\"M3 6h6l3 6-3 6H3\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/><path d=\"M16 5l5 3-5 3\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/><path d=\"M16 19l5-3-5-3\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/></svg>\n            <span>Shuffle</span>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"stage\">\n        <div class=\"ribbon\">Divide • Merge • Compose</div>\n        <div class=\"canvas\" id=\"canvas\" aria-hidden=\"false\"></div>\n\n        <div class=\"legend\" aria-hidden=\"true\">\n          <div style=\"font-weight:700;margin-bottom:8px;color:#fff\">What's happening</div>\n          <div class=\"op\"><span>Operation</span><strong id=\"opName\">Preparing…</strong></div>\n          <div class=\"op\"><span>Range</span><strong id=\"opRange\">—</strong></div>\n          <div style=\"font-size:12px;color:var(--muted)\">Observe how the array is split recursively and merged back in sorted order. Tiles glide smoothly across levels—minimal interaction for maximal focus.</div>\n        </div>\n\n        <div class=\"status\" aria-hidden=\"true\">\n          <div class=\"dot\"></div>\n          <div style=\"font-weight:700\">Visualizing Merge Sort</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Config\n  const N = 16; // number of elements\n  const TILE_W = 48;\n  const tileGap = 10;\n  const depthGap = 88;\n  const splitDuration = 700;\n  const pauseBetween = 340;\n  const mergeDuration = 900;\n\n  const canvas = document.getElementById('canvas');\n  const playBtn = document.getElementById('playPause');\n  const playText = document.getElementById('playText');\n  const playIcon = document.getElementById('playIcon');\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const opName = document.getElementById('opName');\n  const opRange = document.getElementById('opRange');\n\n  let tiles = {}; // id -> element\n  let values = [];\n  let events = [];\n  let maxDepth = 0;\n  let isPlaying = false;\n  let running = false;\n  let stopRequested = false;\n\n  // Easing helper\n  const sleep = (ms) => new Promise(res => setTimeout(res, ms));\n\n  // Create a gorgeous gradient color for tile based on value\n  function tileStyleForValue(v, min, max){\n    const t = (v - min) / (max - min || 1);\n    // gradient between teal and violet\n    const left = interpolateColor([124,108,255], [110,231,183], t);\n    const right = interpolateColor([48, 33, 79], [10, 56, 38], 1-t);\n    return {\n      background: `linear-gradient(180deg, rgba(${left.join(',')},0.95), rgba(${right.join(',')},0.88))`,\n      barColor: `linear-gradient(180deg, rgba(${left.join(',')},0.98), rgba(${right.join(',')},0.9))`\n    }\n  }\n  function interpolateColor(a,b,t){\n    return [Math.round(a[0] + (b[0]-a[0])*t), Math.round(a[1] + (b[1]-a[1])*t), Math.round(a[2] + (b[2]-a[2])*t)];\n  }\n\n  function init() {\n    stopRequested = false;\n    canvas.innerHTML = '';\n    tiles = {};\n    events = [];\n    maxDepth = 0;\n\n    values = generateArray(N);\n    buildVisualization(values);\n    // autoplay\n    requestAnimationFrame(() => start());\n  }\n\n  function generateArray(n){\n    const arr = [];\n    for (let i=0;i<n;i++){\n      const v = Math.round(20 + Math.random()*80);\n      arr.push({id:i, val:v});\n    }\n    // shuffle visually but keep deterministic-ish\n    for (let i = n-1; i>0; i--) {\n      const j = Math.floor(Math.random()*(i+1));\n      [arr[i],arr[j]] = [arr[j],arr[i]];\n    }\n    return arr;\n  }\n\n  // Build DOM tiles and compute events from merge sort while building tree layout\n  function buildVisualization(initArr) {\n    // compute min/max for coloring\n    const valsOnly = initArr.map(x=>x.val);\n    const minV = Math.min(...valsOnly);\n    const maxV = Math.max(...valsOnly);\n\n    // Create DOM tiles\n    initArr.forEach((o, idx) => {\n      const el = document.createElement('div');\n      el.className = 'tile';\n      el.dataset.id = o.id;\n      el.dataset.state = 'idle';\n      el.style.width = TILE_W + 'px';\n      el.style.height = TILE_W + 'px';\n      const st = tileStyleForValue(o.val, minV, maxV);\n      el.style.background = st.background;\n\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      // height relative to value\n      const h = 14 + (o.val - minV) / (maxV - minV || 1) * (TILE_W - 24);\n      bar.style.height = h + 'px';\n      bar.style.background = st.barColor;\n      el.appendChild(bar);\n\n      const val = document.createElement('div');\n      val.className = 'val';\n      val.textContent = o.val;\n      el.appendChild(val);\n\n      canvas.appendChild(el);\n      tiles[o.id] = {el, val:o.val};\n    });\n\n    // Build events and tree nodes with centers & widths (relative: 0..1)\n    // We'll work on a shallow copy array used for algorithmic simulation\n    const arr = initArr.map(x => ({id:x.id, val:x.val}));\n    function buildNode(l, r, depth, center, width){\n      maxDepth = Math.max(maxDepth, depth);\n      const ids = arr.slice(l, r+1).map(x => x.id);\n      const node = {l, r, depth, center, width, ids};\n      events.push({type:'split', node});\n      if (l < r) {\n        const mid = Math.floor((l + r) / 2);\n        // left center moves left by width/4\n        const left = buildNode(l, mid, depth+1, center - width/4, width/2);\n        const right = buildNode(mid+1, r, depth+1, center + width/4, width/2);\n        // perform merge on arr to record merge order\n        let i = l, j = mid+1;\n        const merged = [];\n        while (i <= mid && j <= r) {\n          if (arr[i].val <= arr[j].val) merged.push(arr[i++]);\n          else merged.push(arr[j++]);\n        }\n        while (i <= mid) merged.push(arr[i++]);\n        while (j <= r) merged.push(arr[j++]);\n        // replace arr segment\n        for (let k = l; k <= r; k++) arr[k] = merged[k - l];\n        const orderIds = merged.map(x => x.id);\n        events.push({type:'merge', node, order:orderIds});\n      }\n      return node;\n    }\n    buildNode(0, initArr.length-1, 0, 0.5, 0.92);\n    // Position initial tiles at root positions\n    layoutAllAtDepth(0);\n    updateLegend('Ready', '—');\n  }\n\n  function layoutAllAtDepth(depth) {\n    // find topmost root node at depth 0 to compute root center and width from events\n    const rootSplit = events.find(e => e.type === 'split' && e.node.depth === 0);\n    if (!rootSplit) return;\n    const root = rootSplit.node;\n    placeTilesInNode(root);\n  }\n\n  function placeTilesInNode(node, orderIds = null, immediate = true) {\n    // Compute positions within node for each id\n    const ids = orderIds || node.ids;\n    const cw = canvas.clientWidth;\n    const ch = canvas.clientHeight;\n    const centerX = node.center * cw;\n    const widthPx = node.width * cw;\n    const tileW = TILE_W;\n    const spacing = tileGap;\n    const totalWidth = ids.length * tileW + Math.max(0, ids.length-1) * spacing;\n    let startX = centerX - totalWidth/2;\n    const y = 28 + node.depth * depthGap;\n\n    ids.forEach((id, idx) => {\n      const t = tiles[id];\n      if (!t) return;\n      const x = startX + idx * (tileW + spacing);\n      moveTileTo(t.el, x, y, immediate);\n    });\n  }\n\n  function moveTileTo(el, x, y, immediate = false) {\n    // translate using transforms\n    const rect = canvas.getBoundingClientRect();\n    const tx = Math.round(x);\n    const ty = Math.round(y);\n    if (immediate) {\n      el.style.transition = 'none';\n      el.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;\n      // force reflow\n      void el.offsetWidth;\n      el.style.transition = '';\n    } else {\n      el.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;\n    }\n  }\n\n  // Animation engine processing event queue\n  async function runEvents() {\n    if (running) return;\n    running = true;\n    stopRequested = false;\n    let idx = 0;\n\n    while (idx < events.length && !stopRequested) {\n      // wait while paused\n      while (!isPlaying && !stopRequested) {\n        await sleep(120);\n      }\n      if (stopRequested) break;\n\n      const ev = events[idx];\n      if (ev.type === 'split') {\n        updateLegend('Splitting', `[${ev.node.l} … ${ev.node.r}]`);\n        // animate tiles moving into this node's depth layout\n        // set active states\n        ev.node.ids.forEach((id) => {\n          const t = tiles[id];\n          if (!t) return;\n          t.el.dataset.state = 'active';\n          t.el.style.zIndex = 300 + ev.node.depth;\n        });\n        // move them\n        placeTilesInNode(ev.node, null, false);\n        await waitFor(splitDuration);\n        // subtle settle\n        ev.node.ids.forEach(id => {\n          const t = tiles[id];\n          if (!t) return;\n          t.el.dataset.state = 'idle';\n        });\n        await sleep(120);\n      } else if (ev.type === 'merge') {\n        updateLegend('Merging', `[${ev.node.l} … ${ev.node.r}]`);\n        // highlight merging\n        ev.node.order.forEach((id, i) => {\n          const t = tiles[id];\n          if (!t) return;\n          t.el.dataset.state = 'merging';\n          t.el.style.zIndex = 600 + ev.node.depth;\n        });\n        // Compute intermediate: animate tiles upward slightly (like they lift) and move to parent center area\n        // Step 1: compress into a row at slightly lower depth\n        const parentDepth = Math.max(0, ev.node.depth - 1);\n        const tempCenter = ev.node.center;\n        const tempWidth = ev.node.width;\n        // create virtual parent node layout for positions to animate through\n        const virtualParent = {center: tempCenter, width: tempWidth, depth: parentDepth};\n        // Move all merging tiles to virtual parent positions but keep their current relative order\n        placeTilesInNode(virtualParent, ev.node.ids, false);\n        await waitFor(280);\n        // Final reorder to sorted order and move to the node's parent depth position (shallower)\n        const targetNode = {center: ev.node.center, width: ev.node.width, depth: parentDepth};\n        placeTilesInNode(targetNode, ev.order, false);\n        await waitFor(mergeDuration);\n        // set final positions at parent depth or at this node depth? For clarity, place them at node.depth (like merged into parent)\n        const parentNode = findParentNode(ev.node);\n        if (parentNode) {\n          placeTilesInNode(parentNode, null, false);\n        } else {\n          // place back at root\n          placeTilesInNode(ev.node, ev.order, false);\n        }\n        // release states\n        ev.node.order.forEach((id) => {\n          const t = tiles[id];\n          if (!t) return;\n          t.el.dataset.state = 'idle';\n          t.el.style.zIndex = 200;\n        });\n        await sleep(180);\n      }\n      idx++;\n    }\n\n    updateLegend('Completed', '—');\n    isPlaying = false;\n    playText.textContent = 'Play';\n    // reset state\n    running = false;\n  }\n\n  function findParentNode(node) {\n    // parent depth is node.depth - 1, find split event with same center and width at that depth\n    if (node.depth === 0) return null;\n    const depth = node.depth - 1;\n    // Find split node that spans this node range (has l <= node.l && r >= node.r && depth matches)\n    for (let i=0;i<events.length;i++){\n      const e = events[i];\n      if (e.type === 'split' && e.node.depth === depth && e.node.l <= node.l && e.node.r >= node.r) {\n        return e.node;\n      }\n    }\n    return null;\n  }\n\n  function waitFor(ms) {\n    // returns a promise that resolves after ms but sensitive to pause/resume\n    return new Promise(async (res) => {\n      const start = performance.now();\n      while (performance.now() - start < ms) {\n        if (stopRequested) return res();\n        if (!isPlaying) {\n          await sleep(120);\n        } else {\n          await sleep(40);\n        }\n      }\n      res();\n    });\n  }\n\n  function updateLegend(op, range) {\n    opName.textContent = op;\n    opRange.textContent = range;\n  }\n\n  // Play / Pause handlers\n  async function start() {\n    if (running) {\n      isPlaying = true;\n      playText.textContent = 'Pause';\n      setPlayIconPause();\n      return;\n    }\n    isPlaying = true;\n    playText.textContent = 'Pause';\n    setPlayIconPause();\n    await runEvents();\n  }\n\n  function pause() {\n    isPlaying = false;\n    playText.textContent = 'Play';\n    setPlayIconPlay();\n  }\n\n  function togglePlay(){\n    if (isPlaying) {\n      pause();\n    } else {\n      start();\n    }\n  }\n\n  function setPlayIconPause(){\n    playIcon.setAttribute('d','M6 5h3v14H6zM15 5h3v14h-3z'); // pause\n  }\n  function setPlayIconPlay(){\n    playIcon.setAttribute('d','M5 3v18l15-9L5 3z'); // play\n  }\n\n  function stopAndReset() {\n    stopRequested = true;\n    isPlaying = false;\n    running = false;\n    playText.textContent = 'Play';\n    setPlayIconPlay();\n  }\n\n  // Shuffle / Reset\n  shuffleBtn.addEventListener('click', () => {\n    stopAndReset();\n    // little visual fade\n    canvas.style.opacity = '0.65';\n    setTimeout(() => {\n      init();\n      canvas.style.opacity = '';\n    }, 280);\n  });\n\n  playBtn.addEventListener('click', () => {\n    togglePlay();\n  });\n\n  // utility: find tile by id, move them\n  function repositionAllToRoot() {\n    const root = events.find(e => e.type==='split' && e.node.depth===0);\n    if (root) placeTilesInNode(root.node);\n  }\n\n  // initialize\n  init();\n\n  // Expose keyboard space for play/pause (very limited)\n  document.addEventListener('keydown', (e) => {\n    if (e.code === 'Space') {\n      e.preventDefault();\n      togglePlay();\n    }\n  });\n})();\n</script>\n</body>\n</html>"
  },
