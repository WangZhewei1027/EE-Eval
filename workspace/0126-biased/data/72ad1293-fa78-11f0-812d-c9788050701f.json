    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Garbage Collection: A Visual Symphony</title>\n    <style>\n        :root {\n            --primary: #2a3a4a;\n            --secondary: #4a6b8a;\n            --accent: #8ac4d0;\n            --light: #f4f9f9;\n            --dark: #1a2a3a;\n            --highlight: #ff9a76;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, var(--primary), var(--dark));\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--accent), var(--highlight));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            position: relative;\n            height: 500px;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 20px;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);\n            overflow: hidden;\n            margin-bottom: 3rem;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: all 0.5s ease;\n        }\n\n        .visualization:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\n        }\n\n        .memory-pool {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 80%;\n            height: 80%;\n            border-radius: 15px;\n            background: rgba(42, 58, 74, 0.7);\n            border: 2px dashed rgba(138, 196, 208, 0.3);\n            display: flex;\n            flex-wrap: wrap;\n            padding: 15px;\n            gap: 10px;\n            align-content: flex-start;\n        }\n\n        .memory-block {\n            width: 50px;\n            height: 50px;\n            border-radius: 8px;\n            background: var(--secondary);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: var(--light);\n            font-weight: bold;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .memory-block::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent);\n        }\n\n        .memory-block.allocated {\n            background: var(--accent);\n            transform: scale(1.05);\n        }\n\n        .memory-block.marked {\n            background: var(--highlight);\n            animation: pulse 1.5s infinite;\n        }\n\n        .memory-block.swept {\n            opacity: 0;\n            transform: scale(0);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-bottom: 3rem;\n        }\n\n        button {\n            padding: 1rem 2rem;\n            font-size: 1.1rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(to right, var(--accent), var(--secondary));\n            color: white;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(to right, rgba(255, 255, 255, 0.1), transparent);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);\n        }\n\n        button:active {\n            transform: translateY(1px);\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-bottom: 2rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .free {\n            background: var(--secondary);\n        }\n\n        .allocated {\n            background: var(--accent);\n        }\n\n        .marked {\n            background: var(--highlight);\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 2rem;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            line-height: 1.8;\n            font-size: 1.1rem;\n            margin-bottom: 3rem;\n            border-left: 3px solid var(--accent);\n        }\n\n        .explanation h2 {\n            color: var(--accent);\n            margin-bottom: 1rem;\n            font-weight: 400;\n        }\n\n        footer {\n            text-align: center;\n            padding: 2rem;\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 154, 118, 0.7); }\n            70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(255, 154, 118, 0); }\n            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 154, 118, 0); }\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n        }\n\n        .particle {\n            position: absolute;\n            width: 2px;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.5);\n            border-radius: 50%;\n            animation: float 15s infinite linear;\n        }\n\n        @keyframes float {\n            0% { transform: translateY(0) translateX(0); opacity: 0; }\n            10% { opacity: 1; }\n            90% { opacity: 1; }\n            100% { transform: translateY(-500px) translateX(100px); opacity: 0; }\n        }\n\n        .gc-cycle {\n            position: absolute;\n            bottom: 2rem;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 1.2rem;\n            background: rgba(0, 0, 0, 0.3);\n            padding: 0.5rem 1rem;\n            border-radius: 50px;\n            opacity: 0.8;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Garbage Collection</h1>\n            <p class=\"subtitle\">A visual journey through automatic memory management in modern programming languages</p>\n        </header>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color free\"></div>\n                <span>Free Memory</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color allocated\"></div>\n                <span>Allocated Memory</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color marked\"></div>\n                <span>Marked for Collection</span>\n            </div>\n        </div>\n\n        <div class=\"visualization\">\n            <div class=\"memory-pool\" id=\"memoryPool\"></div>\n            <div class=\"particles\" id=\"particles\"></div>\n            <div class=\"gc-cycle\" id=\"gcCycle\">GC Cycle: 0</div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"allocateBtn\">Allocate Memory</button>\n            <button id=\"collectBtn\">Run GC Cycle</button>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>How Garbage Collection Works</h2>\n            <p>Garbage collection is an automatic memory management process that identifies and reclaims memory occupied by objects that are no longer in use by the program. This visualization demonstrates the mark-and-sweep algorithm:</p>\n            <ol>\n                <li><strong>Allocation:</strong> Memory blocks are allocated as the program runs.</li>\n                <li><strong>Marking:</strong> The GC identifies which blocks are still reachable (in use).</li>\n                <li><strong>Sweeping:</strong> Unmarked blocks are reclaimed as free memory.</li>\n            </ol>\n            <p>Modern garbage collectors use sophisticated algorithms to minimize pause times and maximize efficiency, making memory management nearly transparent to developers.</p>\n        </div>\n    </div>\n\n    <footer>\n        <p>© 2023 Visual Computing Studio | An artistic representation of garbage collection</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const memoryPool = document.getElementById('memoryPool');\n            const allocateBtn = document.getElementById('allocateBtn');\n            const collectBtn = document.getElementById('collectBtn');\n            const gcCycleDisplay = document.getElementById('gcCycle');\n            const particlesContainer = document.getElementById('particles');\n            \n            let gcCycle = 0;\n            let allocatedBlocks = [];\n            let activeBlocks = [];\n            const totalBlocks = 40;\n            \n            // Create initial memory blocks\n            for (let i = 0; i < totalBlocks; i++) {\n                const block = document.createElement('div');\n                block.className = 'memory-block';\n                block.textContent = i + 1;\n                block.dataset.id = i;\n                memoryPool.appendChild(block);\n            }\n            \n            // Create floating particles\n            for (let i = 0; i < 50; i++) {\n                const particle = document.createElement('div');\n                particle.className = 'particle';\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.animationDelay = `${Math.random() * 15}s`;\n                particle.style.opacity = Math.random() * 0.5;\n                particlesContainer.appendChild(particle);\n            }\n            \n            // Allocate memory blocks\n            allocateBtn.addEventListener('click', () => {\n                const blocks = document.querySelectorAll('.memory-block:not(.allocated)');\n                if (blocks.length === 0) return;\n                \n                // Random number of blocks to allocate (1-3)\n                const count = Math.min(Math.floor(Math.random() * 3) + 1, blocks.length);\n                \n                for (let i = 0; i < count; i++) {\n                    const randomIndex = Math.floor(Math.random() * blocks.length);\n                    const block = blocks[randomIndex];\n                    \n                    block.classList.add('allocated');\n                    allocatedBlocks.push(block.dataset.id);\n                    activeBlocks.push(block.dataset.id);\n                    \n                    // Animate allocation\n                    setTimeout(() => {\n                        block.style.transform = 'scale(1)';\n                    }, 100);\n                }\n            });\n            \n            // Run garbage collection\n            collectBtn.addEventListener('click', () => {\n                gcCycle++;\n                gcCycleDisplay.textContent = `GC Cycle: ${gcCycle}`;\n                \n                // Mark phase - randomly mark some blocks as unreachable\n                const blocksToKeep = [];\n                const blocksToCollect = [];\n                \n                allocatedBlocks.forEach(id => {\n                    const block = document.querySelector(`.memory-block[data-id=\"${id}\"]`);\n                    if (Math.random() > 0.4) { // 60% chance to keep\n                        blocksToKeep.push(id);\n                        block.classList.add('marked');\n                    } else {\n                        blocksToCollect.push(id);\n                    }\n                });\n                \n                // Animate marking\n                setTimeout(() => {\n                    // Sweep phase - remove unmarked blocks\n                    blocksToCollect.forEach(id => {\n                        const block = document.querySelector(`.memory-block[data-id=\"${id}\"]`);\n                        block.classList.add('swept');\n                        \n                        setTimeout(() => {\n                            block.classList.remove('allocated', 'marked', 'swept');\n                            block.style.opacity = '1';\n                            block.style.transform = 'scale(1)';\n                        }, 1000);\n                    });\n                    \n                    allocatedBlocks = blocksToKeep;\n                }, 1500);\n            });\n            \n            // Auto-animate some allocations on load\n            setTimeout(() => {\n                allocateBtn.click();\n            }, 500);\n            \n            setTimeout(() => {\n                allocateBtn.click();\n            }, 1500);\n            \n            setTimeout(() => {\n                allocateBtn.click();\n            }, 2500);\n            \n            // Auto-run GC after some allocations\n            setTimeout(() => {\n                collectBtn.click();\n            }, 4000);\n        });\n    </script>\n</body>\n</html>"
