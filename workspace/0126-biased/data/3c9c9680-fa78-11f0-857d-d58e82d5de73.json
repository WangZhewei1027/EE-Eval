e') {\n        // button disables itself while animating; prevent retriggering\n        return;\n      }\n      animateBtn.setAttribute('aria-pressed', 'true');\n      animateBtn.textContent = btnPressedText;\n\n      // Add animation by toggling class\n      arrows.forEach(arrow => {\n        arrow.parentElement.classList.add('animate');\n      });\n      playAnimation();\n\n      // After animation complete (~1.6s), remove animation class and reset button\n      setTimeout(() => {\n        arrows.forEach(arrow => arrow.parentElement.classList.remove('animate'));\n        animateBtn.setAttribute('aria-pressed', 'false');\n        animateBtn.textContent = btnIdleText;\n      }, 1700);\n    });\n  })();\n</script>\n</body>\n</html>"
