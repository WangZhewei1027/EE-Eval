: relative;\n    width: 100%;\n    max-width: 900px;\n    height: 330px;\n    margin: 0 auto;\n    pointer-events: none;\n  }\n\n  /* Common element styles */\n  .key-pair, .message, .ciphertext, .plain-text, .tooltip {\n    font-family: 'Roboto Mono', monospace;\n    font-weight: 700;\n    border-radius: 1rem;\n    padding: 1.45rem 2rem;\n    user-select: none;\n    color: white;\n    text-align: center;\n    letter-spacing: 0.075em;\n    font-size: 1.15rem;\n    text-shadow: 0 0 4px #0008;\n    box-shadow:\n      0 0 20px 2px #3870ff88,\n      inset 0 0 10px 1.5px #70a0ffcc;\n    background: linear-gradient(135deg, #396fffcc 15%, #2549c4dd 80%);\n    position: relative;\n  }\n\n  /* Public Key style */\n  .public-key {\n    background: linear-gradient(135deg, #41d6a7dd 10%, #14854cdd 90%);\n    box-shadow:\n      0 0 22px 3px #38f7b477,\n      inset 0 0 8px 3px #2bb96cbb;\n    text-shadow: 0 0 5px #075724;\n  }\n\n  /* Private Key style */\n  .private-key {\n    background: linear-gradient(135deg, #f0676eff 10%, #b73031cc 90%);\n    box-shadow:\n      0 0 26px 3px #f23c3c88,\n      inset 0 0 10px 3px #b9212100;\n    text-shadow: 0 0 6px #530e0e;\n  }\n\n  /* Message style */\n  .message {\n    background: linear-gradient(135deg, #5867ffdd 10%, #2a458edd 90%);\n    box-shadow:\n      0 0 18px 2px #35a0ffcc,\n      inset 0 0 9px 2px #5486ffaa;\n  }\n\n  /* Ciphertext style */\n  .ciphertext {\n    background: linear-gradient(135deg, #d680ffcc 20%, #7a3dbadd 80%);\n    box-shadow:\n      0 0 20px 3px #b851f8dd,\n      inset 0 0 12px 3px #be5ac5bb;\n  }\n\n  /* Plain text style */\n  .plaintext {\n    background: linear-gradient(135deg, #ffe677dd 20%, #bba418cc 80%);\n    box-shadow:\n      0 0 20px 2px #bb9a1fff,\n      inset 0 0 14px 3px #bcab2711;\n    color: #2a2100;\n    font-weight: 700;\n  }\n\n  /* Boxes container for left side (keys) and right side (message & enc/dec) */\n  .column {\n    display: flex;\n    flex-direction: column;\n    gap: 3rem;\n    flex: 1;\n  }\n\n  /* Horizontal layout */\n  .row {\n    display: flex;\n    justify-content: space-between;\n    gap: 3.5rem;\n    align-items: center;\n    margin-bottom: 1rem;\n  }\n\n  /* Labels above each box */\n  .label {\n    position: absolute;\n    font-size: 0.95rem;\n    top: 0.4rem;\n    left: 50%;\n    transform: translateX(-50%);\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.15em;\n    color: #abb8ffcc;\n    text-shadow: 0 0 4px #19284fbb;\n    pointer-events: none;\n  }\n\n  /* Key pairs at top left side */\n  .key-pair {\n    position: relative;\n    min-width: 195px;\n    max-width: 220px;\n    user-select: none;\n  }\n\n  /* Message and results blocks */\n  .msg-block {\n    position: relative;\n    min-width: 250px;\n    max-width: 320px;\n  }\n\n  /* Arrows with animations */\n  svg.arrow {\n    width: 140px;\n    height: 80px;\n    flex-shrink: 0;\n    fill: none;\n    stroke-width: 4.3;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    filter:\n      drop-shadow(0 0 5px #5394ffcc);\n    cursor: default;\n  }\n\n  /* Arrow stroke and animation */\n  .arrow path {\n    stroke-dasharray: 140;\n    stroke-dashoffset: 140;\n    animation: drawArrow 1.6s ease forwards;\n  }\n\n  .arrow.animate path {\n    animation-play-state: running;\n  }\n\n  /* Arrow colors */\n  .arrow.enc path {\n    stroke: #3e96f8;\n  }\n  .arrow.dec path {\n    stroke: #f74185;\n  }\n\n  @keyframes drawArrow {\n    0% {\n      stroke-dashoffset: 140;\n    }\n    100% {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Glowing background circles (blurred blobs behind keys) */\n  .glow-container {\n    position: absolute;\n    top: -70px;\n    left: 25px;\n    width: 360px;\n    height: 350px;\n    pointer-events: none;\n    z-index: 0;\n  }\n  .glow-public, .glow-private {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(70px);\n    opacity: 0.45;\n    animation: pulse 6s ease-in-out infinite alternate;\n  }\n  .glow-public {\n    width: 170px;\n    height: 170px;\n    background: #47f8c0;\n    top: 22px;\n    left: 0;\n    animation-delay: 0s;\n  }\n  .glow-private {\n    width: 180px;\n    height: 180px;\n    background: #ff6770;\n    bottom: 34px;\n    left: 140px;\n    animation-delay: 3s;\n  }\n\n  @keyframes pulse {\n    0% {\n      opacity: 0.35;\n      transform: scale(0.9);\n    }\n    100% {\n      opacity: 0.55;\n      transform: scale(1.1);\n    }\n  }\n\n  /* Button panel */\n  .controls {\n    margin-top: 3.2rem;\n    text-align: center;\n    user-select: none;\n  }\n  button.btn {\n    background: linear-gradient(135deg, #3978f7cc, #1f2a77cc);\n    color: #a6c3f7;\n    font-family: 'Roboto Mono', monospace;\n    font-weight: 700;\n    border: none;\n    border-radius: 1.25rem;\n    padding: 0.85rem 2.5rem;\n    font-size: 1.15rem;\n    letter-spacing: 0.07em;\n    cursor: pointer;\n    box-shadow:\n      0 0 12px 1.5px #2a43abaa,\n      inset 0 0 11px 2px #688ce0bb;\n    transition: all 0.35s ease;\n    user-select: none;\n    outline-offset: 3px;\n  }\n  button.btn:hover,\n  button.btn:focus {\n    background: linear-gradient(135deg, #4b90ffdd, #2952a4dd);\n    box-shadow:\n      0 0 18px 3px #527effcc,\n      inset 0 0 18px 4px #a3b6f5cc;\n    color: #e8f0ff;\n    outline: 3px solid #a0c0ffcc;\n  }\n\n  /* Tooltip */\n  .tooltip {\n    position: absolute;\n    background: #0d1438bb;\n    backdrop-filter: blur(10px);\n    border-radius: 0.9rem;\n    padding: 0.7rem 1.15rem;\n    right: -130px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 140px;\n    font-size: 0.85rem;\n    color: #b0b8dfdd;\n    text-align: left;\n    line-height: 1.4;\n    box-shadow:\n      0 0 20px 4px #4466cc99,\n      inset 0 0 12px 3px #6388ffaa;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* COMPONENTS layout */\n  .left-column {\n    position: relative;\n  }\n\n  /* Small fade overlays */\n  .fade-top {\n    position: absolute;\n    top: -25px;\n    left: 0;\n    right: 0;\n    height: 50px;\n    background: linear-gradient(180deg, #0f1117 0%, transparent 100%);\n    pointer-events: none;\n  }\n  .fade-bottom {\n    position: absolute;\n    bottom: -28px;\n    left: 0;\n    right: 0;\n    height: 55px;\n    background: linear-gradient(0deg, #0f1117 0%, transparent 100%);\n    pointer-events: none;\n  }\n\n  /* RESPONSIVE text scaling */\n  @media (max-width: 760px) {\n    h1 {\n      font-size: 3.1rem;\n    }\n    h2 {\n      font-size: 1.5rem;\n      margin-bottom: 2rem;\n      padding: 0 1rem;\n    }\n    .container {\n      padding: 2rem 2.5rem 4rem 2.5rem;\n    }\n    .crypto-visual {\n      height: 430px;\n      max-width: 100%;\n      flex-wrap: wrap;\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 2rem 2.4rem;\n    }\n    .column {\n      gap: 2.4rem;\n    }\n    .key-pair {\n      max-width: 100%;\n      min-width: auto;\n    }\n    .msg-block {\n      max-width: 100%;\n      min-width: auto;\n    }\n    svg.arrow {\n      width: 100px;\n      height: 60px;\n    }\n    .tooltip {\n      display: none;\n    }\n    .controls {\n      margin-top: 2rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <section class=\"container\" aria-label=\"Asymmetric Cryptography concept visualization\">\n    <h1>ASYMMETRIC CRYPTOGRAPHY</h1>\n    <h2>A Stunning Visualization of Public-Key Encryption</h2>\n\n    <p class=\"info-text\" aria-live=\"polite\" aria-atomic=\"true\">\n      Explore the core of asymmetric cryptography: a pair of mathematically linked keys — one public and one private — enabling secure message exchange without sharing secret keys openly.\n    </p>\n\n    <div class=\"crypto-visual\" aria-hidden=\"true\">\n\n      <!-- Glowing blobs behind keys -->\n      <div class=\"glow-container\" aria-hidden=\"true\">\n        <div class=\"glow-public\"></div>\n        <div class=\"glow-private\"></div>\n      </div>\n\n      <!-- Left Column: Keys -->\n      <div class=\"column left-column\" aria-label=\"Key pairs\" role=\"list\">\n\n        <article class=\"key-pair public-key\" role=\"listitem\" tabindex=\"0\" aria-describedby=\"desc-pubkey\">\n          <div class=\"label\">Public Key</div>\n          <code id=\"desc-pubkey\">🔑 &nbsp; 0x049a3c...17af5a</code>\n          <div class=\"tooltip\" aria-hidden=\"true\">\n            Shared publicly.<br />\n            Used to encrypt messages.<br />\n            Cannot decrypt.\n          </div>\n        </article>\n\n        <article class=\"key-pair private-key\" role=\"listitem\" tabindex=\"0\" aria-describedby=\"desc-privatekey\">\n          <div class=\"label\">Private Key</div>\n          <code id=\"desc-privatekey\">🔒 &nbsp; 0x7f2b89...d9e3c1</code>\n          <div class=\"tooltip\" aria-hidden=\"true\">\n            Kept secret.<br />\n            Used to decrypt.<br />\n            Enables message authenticity.\n          </div>\n        </article>\n\n      </div>\n\n      <!-- Center Column: Arrows -->\n      <div aria-hidden=\"true\" style=\"width:140px; display:flex; flex-direction:column; justify-content: space-between;\">\n\n        <svg class=\"arrow enc\" viewBox=\"0 0 140 80\" aria-hidden=\"true\" focusable=\"false\">\n          <path d=\"M4 76 L128 4 L134 11 L128 18 L4 76z\"></path>\n        </svg>\n\n        <svg class=\"arrow dec\" viewBox=\"0 0 140 80\" aria-hidden=\"true\" focusable=\"false\" style=\"margin-top: 50px;\">\n          <path d=\"M136 4 L12 76 L6 69 L12 62 L136 4z\"></path>\n        </svg>\n\n      </div>\n\n      <!-- Right Column: Message, Cipher, Plain -->\n      <div class=\"column\" aria-label=\"Encryption and Decryption process\" role=\"list\">\n\n        <article class=\"msg-block message\" role=\"listitem\" tabindex=\"0\" aria-describedby=\"desc-message\">\n          <div class=\"label\">Message</div>\n          <code id=\"desc-message\">HELLO WORLD</code>\n          <div class=\"tooltip\" aria-hidden=\"true\">\n            Plaintext to send.<br />\n            Readable