    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Time Complexity Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        button, input, select {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Time Complexity Interactive Demo</h1>\n\n    <label for=\"algorithm\">Choose Algorithm:</label>\n    <select id=\"algorithm\">\n        <option value=\"constant\">O(1) - Constant Time</option>\n        <option value=\"linear\">O(n) - Linear Time</option>\n        <option value=\"quadratic\">O(n^2) - Quadratic Time</option>\n    </select>\n\n    <label for=\"inputSize\">Input Size (n):</label>\n    <input type=\"number\" id=\"inputSize\" value=\"10\" min=\"1\" max=\"100\">\n\n    <label for=\"repeat\">Number of Repeats:</label>\n    <input type=\"number\" id=\"repeat\" value=\"1\" min=\"1\" max=\"10\">\n\n    <button id=\"run\">Run Simulation</button>\n    \n    <h2>Output:</h2>\n    <pre id=\"output\"></pre>\n\n    <script>\n        document.getElementById('run').onclick = function() {\n            const algorithm = document.getElementById('algorithm').value;\n            const inputSize = parseInt(document.getElementById('inputSize').value);\n            const repeats = parseInt(document.getElementById('repeat').value);\n            let timeComplexity = 0;\n\n            switch (algorithm) {\n                case 'constant':\n                    timeComplexity = constantTime(inputSize, repeats);\n                    break;\n                case 'linear':\n                    timeComplexity = linearTime(inputSize, repeats);\n                    break;\n                case 'quadratic':\n                    timeComplexity = quadraticTime(inputSize, repeats);\n                    break;\n            }\n\n            document.getElementById('output').textContent = \n                `Algorithm: ${algorithm}\\nInput Size: ${inputSize}\\nRepeats: ${repeats}\\nTotal Operations: ${timeComplexity}`;\n        };\n\n        function constantTime(n, repeats) {\n            return repeats * 1; // O(1)\n        }\n\n        function linearTime(n, repeats) {\n            return repeats * n; // O(n)\n        }\n\n        function quadraticTime(n, repeats) {\n            return repeats * n * n; // O(n^2)\n        }\n    </script>\n</body>\n</html>"
