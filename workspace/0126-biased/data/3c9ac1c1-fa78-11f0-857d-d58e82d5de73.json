    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Git Concept - Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');\n\n  /* Root & Body */\n  :root {\n    --color-bg: #0e1117;\n    --color-primary: #1db954;\n    --color-accent: #ff6f61;\n    --color-light: #eaeaea;\n    --color-muted: #767676;\n    --font-sans: 'Inter', sans-serif;\n    --transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: var(--color-bg);\n    font-family: var(--font-sans);\n    color: var(--color-light);\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n  }\n\n  /* Container */\n  .container {\n    max-width: 1100px;\n    margin: 3rem auto 5rem auto;\n    padding: 0 2rem;\n    display: flex;\n    flex-direction: column;\n    gap: 3rem;\n  }\n\n  /* Header */\n  header {\n    text-align: center;\n    user-select: none;\n  }\n  header h1 {\n    font-size: 3.6rem;\n    font-weight: 900;\n    background: linear-gradient(90deg, #1db954, #53d488, #1db954);\n    background-clip: text;\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 0.15em;\n    margin-bottom: 0.4rem;\n    transition: color var(--transition);\n  }\n  header p.subheading {\n    font-weight: 600;\n    font-size: 1.3rem;\n    color: var(--color-muted);\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n  }\n\n  /* Visual concept area */\n  .visualization {\n    background: linear-gradient(135deg, #0f121a 45%, #181c28 100%);\n    border-radius: 20px;\n    padding: 2.5rem;\n    box-shadow:\n      0 8px 20px rgb(29 185 84 / 0.25),\n      inset 0 0 60px rgb(29 185 84 / 0.3);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 440px;\n  }\n\n  /* Git graph container */\n  .git-graph {\n    position: relative;\n    width: 700px;\n    height: 360px;\n    user-select: none;\n  }\n\n  /* Branch lines */\n  .branch-line {\n    position: absolute;\n    width: 6px;\n    border-radius: 3px;\n    background: var(--color-primary);\n    box-shadow: 0 0 10px var(--color-primary);\n    transition: background-color var(--transition), box-shadow var(--transition);\n  }\n  .branch-main {\n    left: 350px;\n    top: 20px;\n    height: 320px;\n    background: linear-gradient(180deg, #1db954, #148c3c);\n    box-shadow: 0 0 20px #1db954;\n  }\n  .branch-feature {\n    left: 520px;\n    top: 100px;\n    height: 240px;\n    background: linear-gradient(180deg, #53d488, #1b5e2a);\n    box-shadow: 0 0 18px #53d488;\n    border-radius: 10px;\n  }\n  .branch-hotfix {\n    left: 190px;\n    top: 180px;\n    height: 140px;\n    background: linear-gradient(180deg, #ff6f61, #b9423b);\n    box-shadow: 0 0 18px #ff6f61;\n    border-radius: 10px;\n  }\n\n  /* Commit nodes */\n  .commit {\n    position: absolute;\n    width: 30px;\n    height: 30px;\n    border-radius: 50%;\n    background: var(--color-bg);\n    border: 4px solid var(--color-primary);\n    box-shadow: 0 0 8px var(--color-primary);\n    cursor: default;\n    transition: border-color 0.3s ease, box-shadow 0.3s ease;\n    filter: drop-shadow(0 0 2px var(--color-primary));\n  }\n  .commit.feature {\n    border-color: #53d488;\n    box-shadow: 0 0 12px #53d488;\n    filter: drop-shadow(0 0 4px #53d488);\n  }\n  .commit.hotfix {\n    border-color: #ff6f61;\n    box-shadow: 0 0 12px #ff6f61;\n    filter: drop-shadow(0 0 4px #ff6f61);\n  }\n  .commit:hover {\n    border-width: 6px;\n    box-shadow:\n      0 0 15px var(--color-primary),\n      0 0 25px var(--color-primary);\n    z-index: 10;\n  }\n  .commit.feature:hover {\n    border-width: 6px;\n    box-shadow:\n      0 0 15px #53d488,\n      0 0 30px #53d488;\n    z-index: 10;\n  }\n  .commit.hotfix:hover {\n    border-width: 6px;\n    box-shadow:\n      0 0 15px #ff6f61,\n      0 0 30px #ff6f61;\n    z-index: 10;\n  }\n\n  /* Positions of commits on main branch */\n  .commit.main-0 { top: 40px; left: 340px; }\n  .commit.main-1 { top: 100px; left: 345px; }\n  .commit.main-2 { top: 160px; left: 335px; }\n  .commit.main-3 { top: 220px; left: 350px; }\n  .commit.main-4 { top: 280px; left: 345px; }\n\n  /* Feature branch commits */\n  .commit.feature-0 { top: 120px; left: 510px; }\n  .commit.feature-1 { top: 180px; left: 520px; }\n  .commit.feature-2 { top: 240px; left: 510px; }\n\n  /* Hotfix branch commits */\n  .commit.hotfix-0 { top: 200px; left: 180px; }\n  .commit.hotfix-1 { top: 260px; left: 190px; }\n\n  /* Merge arcs and lines using SVG */\n  .merge-svg {\n    position: absolute;\n    top: 0; left: 0;\n    width: 700px;\n    height: 360px;\n    pointer-events: none;\n    overflow: visible;\n  }\n  .merge-path {\n    fill: none;\n    stroke-width: 4px;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 5px var(--color-primary));\n    transition: stroke var(--transition);\n  }\n  .merge-main {\n    stroke: var(--color-primary);\n  }\n  .merge-feature {\n    stroke: #53d488;\n  }\n  .merge-hotfix {\n    stroke: #ff6f61;\n  }\n\n  /* Labels for branches and commits */\n  .label-branch {\n    position: absolute;\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: var(--color-muted);\n    user-select: none;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n  }\n  .label-main {\n    top: 5px;\n    left: 320px;\n    color: #1db954;\n    font-weight: 900;\n    font-size: 1.25rem;\n    text-shadow: 0 0 8px #1db954;\n  }\n  .label-feature {\n    top: 90px;\n    left: 480px;\n    color: #53d488;\n    font-weight: 900;\n    font-size: 1.15rem;\n    text-shadow: 0 0 8px #53d488;\n  }\n  .label-hotfix {\n    top: 170px;\n    left: 150px;\n    color: #ff6f61;\n    font-weight: 900;\n    font-size: 1.15rem;\n    text-shadow: 0 0 8px #ff6f61;\n  }\n  .label-commit {\n    position: absolute;\n    font-size: 0.8rem;\n    font-weight: 600;\n    background: var(--color-bg);\n    padding: 2px 6px;\n    border-radius: 6px;\n    white-space: nowrap;\n    user-select: none;\n    transform: translateX(-50%);\n    color: var(--color-light);\n    letter-spacing: 0.05em;\n    opacity: 0.75;\n    transition: opacity 0.3s ease;\n  }\n  .label-commit:hover {\n    opacity: 1;\n  }\n  /* Commit labels on main */\n  .label-main-0 { top: 15px; left: 340px; }\n  .label-main-1 { top: 75px; left: 345px; }\n  .label-main-2 { top: 135px; left: 335px; }\n  .label-main-3 { top: 195px; left: 350px; }\n  .label-main-4 { top: 255px; left: 345px; }\n  /* Feature commits labels */\n  .label-feature-0 { top: 95px; left: 510px; }\n  .label-feature-1 { top: 155px; left: 520px; }\n  .label-feature-2 { top: 215px; left: 510px; }\n  /* Hotfix commits labels */\n  .label-hotfix-0 { top: 175px; left: 180px; }\n  .label-hotfix-1 { top: 235px; left: 190px; }\n\n  /* Buttons container */\n  .controls {\n    text-align: center;\n    margin-top: auto;\n  }\n  .btn {\n    background: transparent;\n    border: 2.5px solid var(--color-primary);\n    color: var(--color-primary);\n    padding: 0.65rem 2.2rem;\n    font-weight: 700;\n    font-size: 1.1rem;\n    border-radius: 50px;\n    cursor: pointer;\n    transition: background-color 0.4s, color 0.4s, box-shadow 0.4s;\n    user-select: none;\n    box-shadow:\n      0 0 8px var(--color-primary);\n  }\n  .btn:hover {\n    background-color: var(--color-primary);\n    color: var(--color-bg);\n    box-shadow:\n      0 0 20px var(--color-primary),\n      0 0 30px var(--color-primary);\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    padding: 2rem 0 1rem 0;\n    font-size: 0.85rem;\n    color: var(--color-muted);\n    font-weight: 600;\n    user-select: none;\n  }\n\n  /* Animations for commits */\n  @keyframes pulseGlow {\n    0%, 100% { box-shadow: 0 0 12px var(--color-primary); }\n    50% { box-shadow: 0 0 25px var(--color-primary); }\n  }\n  .commit.pulse-main {\n    animation: pulseGlow 3.6s ease-in-out infinite;\n  }\n  .commit.pulse-feature {\n    animation: pulseGlow 4s ease-in-out infinite;\n    box-shadow: 0 0 15px #53d488;\n  }\n  .commit.pulse-hotfix {\n    animation: pulseGlow 3.2s ease-in-out infinite;\n    box-shadow: 0 0 15px #ff6f61;\n  }\n\n</style>\n</head>\n<body>\n<header>\n  <h1>GIT</h1>\n  <p class=\"subheading\">Distributed Version Control Visualized</p>\n</header>\n\n<main class=\"container\" role=\"region\" aria-label=\"Git Visual Concept\">\n  <section class=\"visualization\" aria-label=\"Git branch and commit visualization\">\n    <div class=\"git-graph\" aria-hidden=\"true\">\n      <!-- Branch Lines -->\n      <div class=\"branch-line branch-main\"></div>\n      <div class=\"branch-line branch-feature\"></div>\n      <div class=\"branch-line branch-hotfix\"></div>\n\n      <!-- Commits - Main Branch -->\n      <div class=\"commit main-0 pulse-main\" title=\"Commit: Initial commit\"></div>\n      <div class=\"commit main-1 pulse-main\" title=\"Commit: Set up CI/CD pipeline\"></div>\n      <div class=\"commit main-2 pulse-main\" title=\"Commit: Add README\"></div>\n      <div class=\"commit main-3 pulse-main\" title=\"Commit: Refactor architecture\"></div>\n      <div class=\"commit main-4 pulse-main\" title=\"Commit: Release v1.0.0\"></div>\n\n      <!-- Commits - Feature Branch -->\n      <div class=\"commit feature feature-0 pulse-feature\" title=\"Commit: Feature A start\"></div>\n      <div class=\"commit feature feature-1 pulse-feature\" title=\"Commit: Feature A progress\"></div>\n      <div class=\"commit feature feature-2 pulse-feature\" title=\"Commit: Feature A ready\"></div>\n\n      <!-- Commits - Hotfix Branch -->\n      <div class=\"commit hotfix hotfix-0 pulse-hotfix\" title=\"Commit: Hotfix critical bug\"></div>\n      <div class=\"commit hotfix hotfix-1 pulse-hotfix\" title=\"Commit: Hotfix test passed\"></div>\n\n      <!-- Branch Labels -->\n      <div class=\"label-branch label-main\">main</div>\n      <div class=\"label-branch label-feature\">feature/A</div>\n      <div class=\"label-branch label-hotfix\">hotfix/bugfix</div>\n\n      <!-- Commit Labels -->\n      <span class=\"label-commit label-main-0\" title=\"Commit: Initial commit\">Initial commit</span>\n      <span class=\"label-commit label-main-1\" title=\"Commit: Set up CI/CD pipeline\">CI/CD Pipeline</span>\n      <span class=\"label-commit label-main-2\" title=\"Commit: Add README\">Add README</span>\n      <span class=\"label-commit label-main-3\" title=\"Commit: Refactor architecture\">Refactor</span>\n      <span class=\"label-commit label-main-4\" title=\"Commit: Release v1.0.0\">Release v1.0.0</span>\n\n      <span class=\"label-commit label-feature-0\" title=\"Commit: Feature A start\">Feature Start</span>\n      <span class=\"label-commit label-feature-1\" title=\"Commit: Feature A progress\">Feature Progress</span>\n      <span class=\"label-commit label-feature-2\" title=\"Commit: Feature A ready\">Feature Ready</span>\n\n      <span class=\"label-commit label-hotfix-0\" title=\"Commit: Hotfix critical bug\">Hotfix Bug</span>\n      <span class=\"label-commit label-hotfix-1\" title=\"Commit: Hotfix test passed\">Hotfix Pass</span>\n\n      <!-- Merge Arcs SVG -->\n      <svg class=\"merge-svg\" viewBox=\"0 0 700 360\" aria-hidden=\"true\" focusable=\"false\" >\n        <!-- Merge feature -> main -->\n        <path class=\"merge-path merge-feature\" d=\"M520 250 C480 280, 400 280, 350 285\" stroke-linejoin=\"round\"/>\n        <path class=\"merge-path merge-feature\" d=\"M510 250 L510 250\" />\n\n        <!-- Merge hotfix -> main -->\n        <path class=\"merge-path merge-hotfix\" d=\"M190 210 C230 200, 330 190, 350 200\" stroke-linejoin=\"round\"/>\n        <path class=\"merge-path merge-hotfix\" d=\"M180 210 L180 210\" />\n      </svg>\n    </div>\n  </section>\n\n  <div class=\"controls\" aria-label=\"Controls for Git visualization\">\n    <button class=\"btn\" id=\"toggleGlowBtn\" aria-pressed=\"true\" aria-label=\"Toggle Pulsing Glow Animation\">\n      Toggle Glow Animation\n    </button>\n  </div>\n</main>\n\n<footer>\n  &copy; 2024 &bull; Designed for clarity & elegance by ChatGPT\n</footer>\n\n<script>\n  (function(){\n    const toggleBtn = document.getElementById('toggleGlowBtn');\n    const commits = document.querySelectorAll('.commit');\n\n    let glowOn = true;\n\n    toggleBtn.addEventListener('click', () => {\n      glowOn = !glowOn;\n      commits.forEach(commit => {\n        if (glowOn) {\n          if (commit.classList.contains('main-0') || commit.classList.contains('main-1') || commit.classList.contains('main-2') || commit.classList.contains('main-3') || commit.classList.contains('main-4')) {\n            commit.classList.add('pulse-main');\n          } else if (commit.classList.contains('feature')) {\n            commit.classList.add('pulse-feature');\n          } else if (commit.classList.contains('hotfix')) {\n            commit.classList.add('pulse-hotfix');\n          }\n        } else {\n          commit.classList.remove('pulse-main', 'pulse-feature', 'pulse-hotfix');\n        }\n      });\n      toggleBtn.setAttribute('aria-pressed', glowOn.toString());\n    });\n  })();\n</script>\n</body>\n</html>"
