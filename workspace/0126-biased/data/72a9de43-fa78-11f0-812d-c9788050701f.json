    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bucket Sort Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n        \n        body {\n            background: linear-gradient(135deg, var(--light), #dfe6e9);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 2rem;\n            animation: fadeIn 1s ease-out;\n        }\n        \n        h1 {\n            font-size: 3rem;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            font-weight: 800;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n        \n        .visualization-container {\n            width: 90%;\n            max-width: 1200px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            margin-bottom: 2rem;\n            overflow: hidden;\n            position: relative;\n            animation: slideUp 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            animation: fadeIn 1s ease-out 0.3s both;\n        }\n        \n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: var(--primary);\n            color: white;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .array-display {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 2rem;\n            flex-wrap: wrap;\n            gap: 0.5rem;\n        }\n        \n        .array-element {\n            width: 50px;\n            height: 50px;\n            background: var(--secondary);\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n        }\n        \n        .buckets-container {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 1rem;\n            justify-content: center;\n            margin-bottom: 2rem;\n        }\n        \n        .bucket {\n            min-width: 120px;\n            min-height: 150px;\n            background: rgba(255, 255, 255, 0.8);\n            border-radius: 15px;\n            padding: 1rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            border: 2px dashed rgba(108, 92, 231, 0.3);\n            transition: all 0.3s ease;\n        }\n        \n        .bucket-title {\n            font-size: 0.9rem;\n            font-weight: 600;\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n        }\n        \n        .bucket-elements {\n            display: flex;\n            flex-direction: column;\n            gap: 0.5rem;\n            width: 100%;\n            align-items: center;\n            flex-grow: 1;\n        }\n        \n        .bucket-element {\n            width: 40px;\n            height: 40px;\n            background: var(--accent);\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1rem;\n            transition: all 0.3s ease;\n            box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);\n        }\n        \n        .sorted-array {\n            display: flex;\n            justify-content: center;\n            flex-wrap: wrap;\n            gap: 0.5rem;\n            margin-top: 2rem;\n            padding-top: 2rem;\n            border-top: 1px solid rgba(0, 0, 0, 0.1);\n            opacity: 0;\n            transform: translateY(20px);\n        }\n        \n        .sorted-element {\n            width: 50px;\n            height: 50px;\n            background: var(--primary);\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n        }\n        \n        .explanation {\n            max-width: 800px;\n            text-align: center;\n            margin: 2rem auto;\n            line-height: 1.6;\n            color: var(--dark);\n            opacity: 0.8;\n            animation: fadeIn 1s ease-out 0.6s both;\n        }\n        \n        .highlight {\n            background: linear-gradient(to right, var(--accent), var(--primary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            font-weight: 600;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n        \n        .pulse {\n            animation: pulse 0.5s ease;\n        }\n        \n        footer {\n            margin-top: 2rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n            animation: fadeIn 1s ease-out 0.9s both;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Bucket Sort</h1>\n        <p class=\"subtitle\">A beautiful visualization of the distribution sort algorithm</p>\n    </header>\n    \n    <div class=\"controls\">\n        <button id=\"start-btn\">Start Visualization</button>\n    </div>\n    \n    <div class=\"visualization-container\">\n        <div class=\"array-display\" id=\"original-array\">\n            <!-- Original array elements will be inserted here -->\n        </div>\n        \n        <div class=\"buckets-container\" id=\"buckets\">\n            <!-- Buckets will be inserted here -->\n        </div>\n        \n        <div class=\"sorted-array\" id=\"sorted-array\">\n            <!-- Sorted array will be inserted here -->\n        </div>\n    </div>\n    \n    <div class=\"explanation\">\n        <p><span class=\"highlight\">Bucket Sort</span> is a distribution sort algorithm that works by distributing the elements of an array into a number of buckets. Each bucket is then sorted individually, either using a different sorting algorithm or by recursively applying the bucket sort.</p>\n    </div>\n    \n    <footer>\n        Created with ❤️ for beautiful algorithm visualizations\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Sample array to sort\n            const array = [29, 25, 3, 49, 9, 37, 21, 43, 15, 31, 7, 45, 13, 27, 5, 19, 41, 11, 33, 17];\n            \n            // Initialize visualization\n            renderOriginalArray(array);\n            \n            // Event listener for the start button\n            document.getElementById('start-btn').addEventListener('click', () => {\n                startVisualization(array);\n            });\n        });\n        \n        function renderOriginalArray(array) {\n            const container = document.getElementById('original-array');\n            container.innerHTML = '';\n            \n            array.forEach(num => {\n                const element = document.createElement('div');\n                element.className = 'array-element';\n                element.textContent = num;\n                container.appendChild(element);\n            });\n        }\n        \n        function createBuckets(array, bucketCount) {\n            const max = Math.max(...array);\n            const min = Math.min(...array);\n            const range = (max - min + 1) / bucketCount;\n            \n            const buckets = Array.from({ length: bucketCount }, () => []);\n            \n            array.forEach(num => {\n                const bucketIndex = Math.floor((num - min) / range);\n                buckets[bucketIndex].push(num);\n            });\n            \n            return buckets;\n        }\n        \n        function renderBuckets(buckets) {\n            const container = document.getElementById('buckets');\n            container.innerHTML = '';\n            \n            buckets.forEach((bucket, index) => {\n                const bucketElement = document.createElement('div');\n                bucketElement.className = 'bucket';\n                \n                const title = document.createElement('div');\n                title.className = 'bucket-title';\n                title.textContent = `Bucket ${index + 1}`;\n                bucketElement.appendChild(title);\n                \n                const elementsContainer = document.createElement('div');\n                elementsContainer.className = 'bucket-elements';\n                \n                bucket.forEach(num => {\n                    const element = document.createElement('div');\n                    element.className = 'bucket-element';\n                    element.textContent = num;\n                    elementsContainer.appendChild(element);\n                });\n                \n                bucketElement.appendChild(elementsContainer);\n                container.appendChild(bucketElement);\n            });\n        }\n        \n        function renderSortedArray(sortedArray) {\n            const container = document.getElementById('sorted-array');\n            container.innerHTML = '';\n            \n            sortedArray.forEach(num => {\n                const element = document.createElement('div');\n                element.className = 'sorted-element';\n                element.textContent = num;\n                container.appendChild(element);\n            });\n            \n            // Animate the appearance of the sorted array\n            setTimeout(() => {\n                container.style.opacity = '1';\n                container.style.transform = 'translateY(0)';\n            }, 500);\n        }\n        \n        async function startVisualization(array) {\n            const startBtn = document.getElementById('start-btn');\n            startBtn.disabled = true;\n            startBtn.textContent = 'Sorting...';\n            \n            // Highlight original array\n            const originalElements = document.querySelectorAll('#original-array .array-element');\n            originalElements.forEach(el => el.classList.add('pulse'));\n            \n            await new Promise(resolve => setTimeout(resolve, 1000));\n            \n            // Create and display buckets\n            const buckets = createBuckets(array, 5);\n            renderBuckets(buckets);\n            \n            // Animate distribution to buckets\n            await distributeToBuckets(array, buckets);\n            \n            // Sort each bucket\n            await sortBuckets(buckets);\n            \n            // Concatenate buckets to get sorted array\n            const sortedArray = [].concat(...buckets);\n            renderSortedArray(sortedArray);\n            \n            startBtn.textContent = 'Completed!';\n        }\n        \n        async function distributeToBuckets(array, buckets) {\n            const max = Math.max(...array);\n            const min = Math.min(...array);\n            const range = (max - min + 1) / buckets.length;\n            \n            const originalElements = document.querySelectorAll('#original-array .array-element');\n            const bucketElements = document.querySelectorAll('.bucket-elements');\n            \n            for (let i = 0; i < array.length; i++) {\n                const num = array[i];\n                const bucketIndex = Math.floor((num - min) / range);\n                \n                // Highlight current element\n                originalElements[i].style.transform = 'scale(1.1)';\n                originalElements[i].style.boxShadow = '0 0 15px rgba(253, 121, 168, 0.7)';\n                \n                await new Promise(resolve => setTimeout(resolve, 300));\n                \n                // Create a copy of the element that will move to the bucket\n                const movingElement = originalElements[i].cloneNode(true);\n                movingElement.style.position = 'absolute';\n                movingElement.style.left = originalElements[i].offsetLeft + 'px';\n                movingElement.style.top = originalElements[i].offsetTop + 'px';\n                document.body.appendChild(movingElement);\n                \n                // Calculate target position in bucket\n                const targetBucket = document.querySelectorAll('.bucket')[bucketIndex];\n                const targetPosition = targetBucket.getBoundingClientRect();\n                const targetX = targetPosition.left + targetPosition.width / 2 - 20;\n                const targetY = targetPosition.top + 60 + (buckets[bucketIndex].length * 45);\n                \n                // Animate movement to bucket\n                movingElement.style.transition = 'all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)';\n                movingElement.style.transform = `translate(${targetX - movingElement.offsetLeft}px, ${targetY - movingElement.offsetTop}px)`;\n                \n                await new Promise(resolve => setTimeout(resolve, 600));\n                \n                // Remove the moving element and update the actual bucket display\n                movingElement.remove();\n                renderBuckets(buckets);\n                \n                // Reset original element style\n                originalElements[i].style.transform = '';\n                originalElements[i].style.boxShadow = '';\n                \n                await new Promise(resolve => setTimeout(resolve, 200));\n            }\n        }\n        \n        async function sortBuckets(buckets) {\n            for (let i = 0; i < buckets.length; i++) {\n                if (buckets[i].length > 0) {\n                    // Highlight the bucket being sorted\n                    const bucketElement = document.querySelectorAll('.bucket')[i];\n                    bucketElement.style.transform = 'scale(1.05)';\n                    bucketElement.style.borderColor = 'var(--accent)';\n                    bucketElement.style.boxShadow = '0 10px 25px rgba(253, 121, 168, 0.2)';\n                    \n                    await new Promise(resolve => setTimeout(resolve, 500));\n                    \n                    // Sort the bucket (using insertion sort for simplicity)\n                    buckets[i].sort((a, b) => a - b);\n                    renderBuckets(buckets);\n                    \n                    // Pulse the bucket elements to show they're sorted\n                    const elements = bucketElement.querySelectorAll('.bucket-element');\n                    for (const el of elements) {\n                        el.classList.add('pulse');\n                        await new Promise(resolve => setTimeout(resolve, 150));\n                    }\n                    \n                    // Reset bucket style\n                    bucketElement.style.transform = '';\n                    bucketElement.style.borderColor = '';\n                    bucketElement.style.boxShadow = '';\n                    \n                    await new Promise(resolve => setTimeout(resolve, 500));\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
