  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Amortized Analysis Interactive Explorer</title>\n<style>\n  html, body {\n    margin: 0; padding: 8px; font-family: monospace, monospace; background: white; color: black;\n  }\n  button, input, select, label {\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin: 2px 4px 8px 0;\n  }\n  textarea {\n    width: 100%;\n    height: 150px;\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin-top: 8px;\n    white-space: pre-wrap;\n  }\n  fieldset {\n    margin-bottom: 20px;\n  }\n  legend {\n    font-weight: bold;\n  }\n  .inlineblock {\n    display: inline-block;\n    vertical-align: middle;\n  }\n  .log {\n    border: 1px solid black;\n    height: 120px;\n    overflow-y: scroll;\n    padding: 4px;\n    white-space: pre-wrap;\n    font-family: monospace, monospace;\n    font-size: 13px;\n  }\n  #amortizedResult {\n    font-weight: bold;\n    margin-top: 8px;\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n<h1>Amortized Analysis Interactive Explorer</h1>\n\n<p>This tool allows you to experiment with different data structures and sequences of operations to see <em>amortized</em> costs in action.</p>\n\n<fieldset id=\"structure-select\">\n  <legend>1. Choose Data Structure</legend>\n  <label><input type=\"radio\" name=\"structure\" value=\"dynamicArray\" checked /> Dynamic Array (Vector) Resize</label><br />\n  <label><input type=\"radio\" name=\"structure\" value=\"stackWithMultipop\" /> Stack with Multipop</label><br />\n  <label><input type=\"radio\" name=\"structure\" value=\"aggregateMethod\" /> Aggregate Method Example</label><br />\n  <label><input type=\"radio\" name=\"structure\" value=\"accountingMethod\" /> Accounting Method Example</label><br />\n  <label><input type=\"radio\" name=\"structure\" value=\"potentialMethod\" /> Potential Method Example</label><br />\n</fieldset>\n\n<fieldset id=\"parameters-section\">\n  <legend>2. Configure Parameters and Execute Operations</legend>\n  <div id=\"dynamicArrayParams\" class=\"param-block\">\n    <label>Initial Capacity:&nbsp;<input type=\"number\" min=\"1\" max=\"100000\" value=\"4\" id=\"daCapacity\" /></label><br />\n    <label>Number of Insert Operations:&nbsp;<input type=\"number\" min=\"1\" max=\"10000\" value=\"20\" id=\"daOps\" /></label><br />\n    <label>\n      Resize Factor:&nbsp;\n      <select id=\"daResizeFactor\">\n        <option value=\"2\" selected>2 (doubling)</option>\n        <option value=\"3\">3 (tripling)</option>\n        <option value=\"1.5\">1.5</option>\n        <option value=\"1.25\">1.25</option>\n      </select>\n    </label><br />\n    <button id=\"daRunOps\">Run Insertions & Analyze</button>\n  </div>\n\n  <div id=\"stackWithMultipopParams\" class=\"param-block\" style=\"display:none;\">\n    <label>Number of Push Operations:&nbsp;<input type=\"number\" min=\"0\" max=\"10000\" value=\"10\" id=\"stackPushCount\" /></label><br />\n    <label>Number of Multipop Operations:&nbsp;<input type=\"number\" min=\"0\" max=\"10000\" value=\"5\" id=\"stackMultipopCount\" /></label><br />\n    <button id=\"stackRunOps\">Run Stack Operations & Analyze</button>\n  </div>\n\n  <div id=\"aggregateMethodParams\" class=\"param-block\" style=\"display:none;\">\n    <label>Number of Operations:&nbsp;<input type=\"number\" min=\"1\" max=\"10000\" value=\"50\" id=\"aggOpsCount\" /></label><br />\n    <button id=\"aggRunOps\">Run Aggregate Method Example</button>\n  </div>\n\n  <div id=\"accountingMethodParams\" class=\"param-block\" style=\"display:none;\">\n    <label>Number of Operations:&nbsp;<input type=\"number\" min=\"1\" max=\"10000\" value=\"50\" id=\"acctOpsCount\" /></label><br />\n    <button id=\"acctRunOps\">Run Accounting Method Example</button>\n  </div>\n\n  <div id=\"potentialMethodParams\" class=\"param-block\" style=\"display:none;\">\n    <label>Number of Operations:&nbsp;<input type=\"number\" min=\"1\" max=\"10000\" value=\"50\" id=\"potOpsCount\" /></label><br />\n    <button id=\"potRunOps\">Run Potential Method Example</button>\n  </div>\n</fieldset>\n\n<fieldset id=\"operations-sequence\" style=\"display:none;\">\n  <legend>3. Interactive Operations Workflow</legend>\n  <div id=\"interactiveSection\"></div>\n  <button id=\"resetWorkflowBtn\" style=\"display:none;\">Reset Workflow</button>\n</fieldset>\n\n<fieldset>\n  <legend>4. Analysis Log Output</legend>\n  <div id=\"logOutput\" class=\"log\" aria-live=\"polite\" aria-atomic=\"true\" tabindex=\"0\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>5. Amortized Cost Summary</legend>\n  <pre id=\"amortizedResult\"></pre>\n</fieldset>\n\n<script>\n(function(){\n  const structureRadios = document.querySelectorAll('input[name=\"structure\"]');\n  const paramBlocks = {\n    dynamicArray: document.getElementById('dynamicArrayParams'),\n    stackWithMultipop: document.getElementById('stackWithMultipopParams'),\n    aggregateMethod: document.getElementById('aggregateMethodParams'),\n    accountingMethod: document.getElementById('accountingMethodParams'),\n    potentialMethod: document.getElementById('potentialMethodParams')\n  };\n  const operationsSequence = document.getElementById('operations-sequence');\n  const interactiveSection = document.getElementById('interactiveSection');\n  const resetWorkflowBtn = document.getElementById('resetWorkflowBtn');\n  const logOutput = document.getElementById('logOutput');\n  const amortizedResult = document.getElementById('amortizedResult');\n\n  function clearLog(){\n    logOutput.textContent = '';\n  }\n  function appendLog(text){\n    logOutput.textContent += text + '\\n';\n    logOutput.scrollTop = logOutput.scrollHeight;\n  }\n  function setAmortizedResult(text){\n    amortizedResult.textContent = text;\n  }\n  function clearAmortizedResult(){\n    amortizedResult.textContent = '';\n  }\n\n  // Hide all param blocks except the chosen one\n  function updateParamBlocks() {\n    const selected = getSelectedStructure();\n    Object.entries(paramBlocks).forEach(([key,el]) => {\n      el.style.display = (key === selected) ? '' : 'none';\n    });\n    operationsSequence.style.display = 'none';\n    interactiveSection.innerHTML = '';\n    resetWorkflowBtn.style.display = 'none';\n    clearLog();\n    clearAmortizedResult();\n  }\n\n  function getSelectedStructure(){\n    for(let r of structureRadios){\n      if(r.checked) return r.value;\n    }\n  }\n\n  structureRadios.forEach(radio => radio.addEventListener('change', () => {\n    updateParamBlocks();\n  }));\n\n  // =============== Dynamic Array Simulator ===============\n  // Simulate inserting items one by one, resizing underlying array when capacity exceeded\n  // Cost model: insert cost is 1 unit each, resizing costs copying all elements\n  // Amortized cost is calculated and displayed\n\n  function runDynamicArraySimulation(){\n    clearLog();\n    clearAmortizedResult();\n    const initialCapacity = Number(document.getElementById('daCapacity').value);\n    const insertOps = Number(document.getElementById('daOps').value);\n    const resizeFactor = Number(document.getElementById('daResizeFactor').value);\n    if(isNaN(initialCapacity) || initialCapacity < 1 || initialCapacity > 100000){\n      appendLog('Invalid Initial Capacity');\n      return;\n    }\n    if(isNaN(insertOps) || insertOps < 1 || insertOps > 10000){\n      appendLog('Invalid number of insert operations');\n      return;\n    }\n    if(isNaN(resizeFactor) || resizeFactor <= 1){\n      appendLog('Invalid resize factor');\n      return;\n    }\n\n    appendLog(`Dynamic Array Simulation`);\n    appendLog(`Initial Capacity: ${initialCapacity}`);\n    appendLog(`Resize Factor: ${resizeFactor}`);\n    appendLog(`Number of insertions: ${insertOps}`);\n\n    let capacity = initialCapacity;\n    let size = 0;\n    let totalCost = 0;\n    let costEachOperation = [];\n    let resizeEvents = [];\n\n    for(let i = 1; i <= insertOps; i++){\n      if(size === capacity){\n        // Resize needed\n        let copyingCost = size;\n        capacity = Math.floor(capacity * resizeFactor);\n        appendLog(`Operation ${i}: Resize triggered. New capacity: ${capacity}. Copying cost: ${copyingCost}`);\n        totalCost += copyingCost;\n        costEachOperation.push(copyingCost);\n\n        resizeEvents.push({index:i, cost:copyingCost, newCapacity:capacity});\n      } else {\n        appendLog(`Operation ${i}: Insert`);\n        costEachOperation.push(1);\n        totalCost += 1;\n      }\n      size++;\n    }\n\n    const amortized = totalCost / insertOps;\n    appendLog(`-----------------------------------`);\n    appendLog(`Total Cost over ${insertOps} insertions: ${totalCost}`);\n    appendLog(`Average Amortized Cost per insertion: ${amortized.toFixed(4)}`);\n\n    setAmortizedResult(`=== Amortized Cost Summary ===\nOperations: ${insertOps} insertions\nResizes triggered: ${resizeEvents.length}\nTotal cost (primitive ops): ${totalCost}\nAverage amortized cost per insertion: ${amortized.toFixed(4)}`);\n\n  }\n\n  // =============== Stack with Multipop ===============\n  // Stack supports push, pop and multipop(k) operations.\n  // Cost model: push and pop cost 1 unit each.\n  // Multipop(k) costs up to k pops, but bounded by current stack size.\n  // Amortized analysis shows constant amortized time per operation over sequence.\n\n  class StackWithMultipop {\n    constructor(){\n      this.stack = [];\n      this.totalCost = 0;\n      this.history = [];\n    }\n    push(x){\n      this.stack.push(x);\n      this.totalCost += 1;\n      this.history.push({op:\"push\", element: x, cost: 1, stackSize:this.stack.length});\n    }\n    pop(){\n      if(this.stack.length === 0) return null;\n      this.stack.pop();\n      this.totalCost += 1;\n      this.history.push({op:\"pop\", cost: 1, stackSize:this.stack.length});\n      return true;\n    }\n    multipop(k){\n      const count = Math.min(k, this.stack.length);\n      for(let i=0; i < count; i++){\n        this.stack.pop();\n      }\n      this.totalCost += count;\n      this.history.push({op:\"multipop\", count: count, cost: count, stackSize:this.stack.length});\n    }\n    getTotalCost(){ return this.totalCost;}\n    getSize(){ return this.stack.length;}\n  }\n\n  function runStackWithMultipop(){\n    clearLog();\n    clearAmortizedResult();\n    const pushCount = Number(document.getElementById('stackPushCount').value);\n    const multipopCount = Number(document.getElementById('stackMultipopCount').value);\n    if(isNaN(pushCount) || pushCount < 0 || pushCount > 10000){\n      appendLog('Invalid push count');\n      return;\n    }\n    if(isNaN(multipopCount) || multipopCount < 0 || multipopCount > 10000){\n      appendLog('Invalid multipop count');\n      return;\n    }\n    appendLog('Stack with Multipop Simulation');\n    appendLog(`Push operations: ${pushCount}`);\n    appendLog(`Multipop operations: ${multipopCount}, each with random k`);\n\n    const stack = new StackWithMultipop();\n\n    // We'll generate a sequence:\n    // Arrange push and multipop interleaved randomly, to explore state complexities.\n    // multipop k will be random between 1 and current stack size + 5 (to test bounds)\n    // We'll log each operation, cost and stack size.\n\n    // Generate sequence length = pushCount + multipopCount\n    // Heuristic: Randomly interleave pushes and multipops\n\n    let operations = [];\n    for(let i = 0; i < pushCount; i++) operations.push(\"push\");\n    for(let i = 0; i < multipopCount; i++) operations.push(\"multipop\");\n    // shuffle operations randomly\n    for(let i=operations.length -1; i>0; i--){\n      let j = Math.floor(Math.random()*(i+1));\n      [operations[i], operations[j]] = [operations[j], operations[i]];\n    }\n\n    for(let i=0; i < operations.length; i++){\n      const op = operations[i];\n      if(op === \"push\"){\n        // arbitrary element pushed\n        stack.push('X');\n        appendLog(`Op#${i+1}: push; Cost=1; Stack size=${stack.getSize()}`);\n      } else {\n        // multipop k random in [1, stackSize+5], if stack empty choose k=0 (noop)\n        let k = 0;\n        if(stack.getSize() > 0){\n          k = Math.floor(Math.random()*(stack.getSize()+5)) + 1;\n        }\n        stack.multipop(k);\n        appendLog(`Op#${i+1}: multipop(${k}); Cost=${Math.min(k, stack.getSize()+k)}; Stack size=${stack.getSize()}`);\n      }\n    }\n\n    const n = operations.length;\n    const totalCost = stack.getTotalCost();\n    const amortized = totalCost / n;\n\n    appendLog('-------------------------------');\n    appendLog(`Total operations: ${n}`);\n    appendLog(`Total cost: ${totalCost}`);\n    appendLog(`Amortized cost per operation: ${amortized.toFixed(4)}`);\n\n    setAmortizedResult(`=== Amortized Cost Summary ===\nOperations: ${n}\nTotal cost: ${totalCost}\nAmortized cost per operation: ${amortized.toFixed(4)}`);\n  }\n\n\n  // =============== Aggregate Method Example ===============\n  // Example: A data structure where operation i costs i if i is power of 2, else 1.\n  // Aggregate cost over n operations = O(n)\n  // User inputs n, we simulate and show total and amortized.\n\n  function isPowerOfTwo(x){\n    return (x & (x-1)) === 0;\n  }\n\n  function runAggregateMethodExample(){\n    clearLog();\n    clearAmortizedResult();\n    let n = Number(document.getElementById('aggOpsCount').value);\n    if(isNaN(n) || n < 1 || n > 10000){\n      appendLog('Invalid number of operations');\n      return;\n    }\n    appendLog(`Aggregate Method Example`);\n    appendLog(`Number of operations: ${n}`);\n\n    let totalCost = 0;\n    for(let i=1; i <= n; i++){\n      let cost = isPowerOfTwo(i) ? i : 1;\n      appendLog(`Operation ${i}: cost = ${cost}`);\n      totalCost += cost;\n    }\n\n    let amortized = totalCost / n;\n    appendLog('---------------------------');\n    appendLog(`Total cost: ${totalCost}`);\n    appendLog(`Amortized cost per operation: ${amortized.toFixed(4)}`);\n    setAmortizedResult(`=== Amortized Cost Summary ===\nOperations: ${n}\nTotal cost: ${totalCost}\nAmortized cost per operation: ${amortized.toFixed(4)}`);\n  }\n\n\n  // =============== Accounting Method Example ===============\n  // Suppose operation costs 1 normally, but on certain steps you pay a credit (extra charge) stored to pay for expensive steps.\n  // Simulate a scenario illustrating accounting method with credits.\n\n  function runAccountingMethodExample(){\n    clearLog();\n    clearAmortizedResult();\n    let n = Number(document.getElementById('acctOpsCount').value);\n    if(isNaN(n) || n < 1 || n > 10000){\n      appendLog('Invalid number of operations');\n      return;\n    }\n    appendLog(`Accounting Method Example`);\n    appendLog(`Number of operations: ${n}`);\n\n    // Example: Dynamic array insert with doubling\n    // Cost of insert normally 1\n    // When resize happens, pay extra charge upfront to cover copying later\n    // Credit stored in internal state\n\n    let capacity = 1;\n    let size = 0;\n    let credit = 0;\n    let totalActualCost = 0;\n    let totalAmortizedCost = 0;\n\n    // Charge per insertion = 3 units (1 for insertion + 2 cred for future copy)\n    // Actual cost is 1 normally, plus resize cost copying all elements when resize triggered\n\n    for(let i=1; i<=n; i++){\n      if(size === capacity){\n        // resize occurs\n        appendLog(`Op ${i}: Resize triggered. Copying ${size} elements from old array.`);\n        totalActualCost += size; // copying cost\n        // credit pays for copying, so deduct credit accordingly\n        if(credit < size){\n          appendLog(`Warning: Not enough credit to cover copying. Need to pay extra.`);\n          totalAmortizedCost += (size - credit);\n          credit = 0;\n        } else {\n          credit -= size;\n        }\n        capacity *= 2;\n      }\n      // actual cost of insert is 1\n      totalActualCost +=1;\n\n      // amortized cost is set at 3 per operation (1 insert + 2 credit)\n      totalAmortizedCost += 3;\n      credit += 2; // save 2 credits for future copying\n      size++;\n\n      appendLog(`Op ${i}: Insert; actual cost=1; credit=${credit}`);\n    }\n    appendLog('--------------------------------------');\n    appendLog(`Total actual cost: ${totalActualCost}`);\n    appendLog(`Total amortized cost (charged): ${totalAmortizedCost}`);\n    appendLog(`Final credit leftover: ${credit}`);\n\n    setAmortizedResult(`=== Amortized Cost Summary ===\nOperations: ${n}\nTotal actual cost: ${totalActualCost}\nTotal amortized cost (charged): ${totalAmortizedCost}\nFinal credit left: ${credit}\nAmortized cost per operation charged: ${(totalAmortizedCost/n).toFixed(4)}`);\n  }\n\n\n  // =============== Potential Method Example ===============\n  // Similar to accounting but with potential function representing stored work.\n  // We'll simulate stack operations showing potential changes.\n\n  function runPotentialMethodExample(){\n    clearLog();\n    clearAmortizedResult();\n    let n = Number(document.getElementById('potOpsCount').value);\n    if(isNaN(n) || n < 1 || n > 10000){\n      appendLog('Invalid number of operations');\n      return;\n    }\n    appendLog(`Potential Method Example`);\n    appendLog(`Number of operations: ${n}`);\n\n    // Model: stack with push (cost=1), pop (cost=1),\n    // Potential function Φ = number of elements in stack\n\n    let stackSize = 0;\n    let actualCost = 0;\n    let potential = 0;\n    let totalAmortizedCost = 0;\n\n    // We'll do a sequence that alternates push and pop to stay balanced\n\n    for(let i=1; i <= n; i++){\n      if(i % 2 === 1){\n        // push operation\n        let cost = 1;\n        let oldPotential = potential;\n        stackSize++;\n        potential = stackSize;\n        let amortized = cost + (potential - oldPotential);\n        actualCost += cost;\n        totalAmortizedCost += amortized;\n        appendLog(`Op ${i}: push; cost=${cost}; oldΦ=${oldPotential}; newΦ=${potential}; amortized cost=${amortized.toFixed(2)}; stackSize=${stackSize}`);\n      } else {\n        // pop operation if stack not empty\n        let cost = (stackSize > 0) ? 1 : 0;\n        let oldPotential = potential;\n        if(stackSize > 0) stackSize--;\n        potential = stackSize;\n        let amortized = cost + (potential - oldPotential);\n        actualCost += cost;\n        totalAmortizedCost += amortized;\n        appendLog(`Op ${i}: pop; cost=${cost}; oldΦ=${oldPotential}; newΦ=${potential}; amortized cost=${amortized.toFixed(2)}; stackSize=${stackSize}`);\n      }\n    }\n\n    appendLog('--------------------------------------');\n    appendLog(`Total actual cost: ${actualCost}`);\n    appendLog(`Total amortized cost: ${totalAmortizedCost.toFixed(2)}`);\n    appendLog(`Final potential: ${potential}`);\n\n    setAmortizedResult(`=== Amortized Cost Summary ===\nOperations: ${n}\nTotal actual cost: ${actualCost}\nTotal amortized cost: ${totalAmortizedCost.toFixed(2)}\nFinal potential: ${potential}\nAverage amortized cost per operation: ${(totalAmortizedCost / n).toFixed(4)}`);\n  }\n\n  // =============== Interactive Workflow for Dynamic Array (example) ===============\n  // Provide the ability for user to step through insertion operations one by one\n  // See when resizes happen, cost per operation, total cost\n  // Allow user to undo last operation\n  // Allow user to run till end or reset\n\n  function startDynamicArrayWorkflow(){\n    operationsSequence.style.display = '';\n    interactiveSection.innerHTML = '';\n\n    // Controls: \n    // Show current size & capacity\n    // Buttons: Insert Next, Undo Last, Run To End, Reset Workflow\n    // Log area updated as operations progress\n\n    let capacity = Number(document.getElementById('daCapacity').value);\n    let resizeFactor = Number(document.getElementById('daResizeFactor').value);\n    let maxOps = Number(document.getElementById('daOps').value);\n\n    if(isNaN(capacity) || capacity < 1 || capacity > 100000){\n      appendLog('Invalid Initial Capacity');\n      return;\n    }\n    if(isNaN(maxOps) || maxOps < 1 || maxOps > 10000){\n      appendLog('Invalid number of insert operations');\n      return;\n    }\n    if(isNaN(resizeFactor) || resizeFactor <= 1){\n      appendLog('Invalid resize factor');\n      return;\n    }\n    clearLog();\n    clearAmortizedResult();\n\n    let size = 0;\n    let totalCost = 0;\n    let history = [];\n\n    // UI elements\n    let infoDiv = document.createElement('div');\n    infoDiv.textContent = `Capacity: ${capacity} | Size: ${size} | Resizes: 0 | Total cost: 0`;\n    interactiveSection.appendChild(infoDiv);\n\n    let btnInsertNext = document.createElement('button');\n    btnInsertNext.textContent = 'Insert Next';\n    interactiveSection.appendChild(btnInsertNext);\n\n    let btnUndoLast = document.createElement('button');\n    btnUndoLast.textContent = 'Undo Last';\n    btnUndoLast.disabled = true;\n    interactiveSection.appendChild(btnUndoLast);\n\n    let btnRunToEnd = document.createElement('button');\n    btnRunToEnd.textContent = 'Run To End';\n    interactiveSection.appendChild(btnRunToEnd);\n\n    resetWorkflowBtn.style.display = '';\n\n    let resizeCount = 0;\n\n    function updateInfo(){\n      infoDiv.textContent = `Capacity: ${capacity} | Size: ${size} | Resizes: ${resizeCount} | Total cost: ${totalCost}`;\n    }\n    function appendLogLine(line){\n      appendLog(line);\n    }\n    function updateButtons(){\n      btnUndoLast.disabled = history.length === 0;\n      btnInsertNext.disabled = size >= maxOps;\n      if (size >= maxOps) {\n        appendLogLine('All insertions completed.');\n        btnInsertNext.disabled = true;\n        btnRunToEnd.disabled = true;\n      }\n    }\n\n    btnInsertNext.addEventListener('click', () => {\n      if(size >= maxOps) return;\n\n      if(size === capacity){\n        // resize\n        let oldCap = capacity;\n        let copyingCost = size;\n        capacity = Math.floor(capacity * resizeFactor);\n        resizeCount++;\n        totalCost += copyingCost;\n        history.push({type:'resize', oldCapacity:oldCap, newCapacity:capacity, cost:copyingCost, size:size});\n        appendLogLine(`Insert ${size+1}: Resize triggered. Capacity ${oldCap} -> ${capacity}, cost=${copyingCost}`);\n      }\n      // insert cost 1\n      size++;\n      totalCost += 1;\n      history.push({type:'insert', cost:1});\n      appendLogLine(`Insert ${size}: cost=1`);\n      updateInfo();\n      updateButtons();\n      setAmortizedResult(`Completed insertions: ${size} / ${maxOps}\nResizes so far: ${resizeCount}\nTotal cost so far: ${totalCost}\nCurrent amortized cost per insertion: ${(totalCost/size).toFixed(4)}`);\n    });\n\n    btnUndoLast.addEventListener('click', () => {\n      if(history.length === 0) return;\n      let last = history.pop();\n\n      if(last.type === 'insert'){\n        size--;\n        totalCost -= last.cost;\n        appendLogLine(`Undo Insert. Removed element. size now ${size}`);\n      } else if(last.type === 'resize'){\n        capacity = last.oldCapacity;\n        resizeCount--;\n        totalCost -= last.cost;\n        appendLogLine(`Undo Resize. capacity back to ${capacity}`);\n      }\n      updateInfo();\n      updateButtons();\n      if(size === 0){\n        clearAmortizedResult();\n      } else {\n        setAmortizedResult(`Completed insertions: ${size} / ${maxOps}\nResizes so far: ${resizeCount}\nTotal cost so far: ${totalCost}\nCurrent amortized cost per insertion: ${(totalCost/size).toFixed(4)}`);\n      }\n    });\n\n    btnRunToEnd.addEventListener('click', () => {\n      while(size < maxOps) btnInsertNext.click();\n    });\n\n    resetWorkflowBtn.onclick = () => {\n      operationsSequence.style.display = 'none';\n      interactiveSection.innerHTML = '';\n      resetWorkflowBtn.style.display = 'none';\n      clearLog();\n      clearAmortizedResult();\n    };\n\n    updateInfo();\n    updateButtons();\n  }\n\n  // Attach event listeners for param block buttons\n\n  document.getElementById('daRunOps').addEventListener('click', () => {\n    runDynamicArraySimulation();\n  });\n\n  document.getElementById('stackRunOps').addEventListener('click', () => {\n    runStackWithMultipop();\n  });\n\n  document.getElementById('aggRunOps').addEventListener('click', () => {\n    runAggregateMethodExample();\n  });\n\n  document.getElementById('acctRunOps').addEventListener('click', () => {\n    runAccountingMethodExample();\n  });\n\n  document.getElementById('potRunOps').addEventListener('click', () => {\n    runPotentialMethodExample();\n  });\n\n  // Add deeper interactive workflows (only for dynamic array here to not overcomplicate)\n\n  document.getElementById('dynamicArrayParams').insertAdjacentHTML('beforeend','<button id=\"daStartWorkflow\">Start Step-by-Step Workflow</button>');\n  document.getElementById('daStartWorkflow').addEventListener('click', () => {\n    startDynamicArrayWorkflow();\n  });\n\n  // On load:\n  updateParamBlocks();\n\n})();\n</script>\n</body>\n</html>"
  },
