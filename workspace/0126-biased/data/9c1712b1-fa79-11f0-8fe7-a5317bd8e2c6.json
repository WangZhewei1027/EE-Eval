  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Encryption Interactive Playground</title>\n<style>\n/* Minimal/non-decorative CSS only to ensure layout works; no colors or animations */\nbody { margin: 8px; font-family: monospace; font-size: 13px; }\nsection { margin-bottom: 12px; }\nlabel { display: inline-block; min-width: 120px; vertical-align: middle; }\ntextarea { width: 98%; height: 80px; }\ninput[type=\"text\"] { width: 300px; }\ninput[type=\"number\"] { width: 80px; }\nselect { width: 240px; }\nbutton { margin: 2px; }\npre { white-space: pre-wrap; word-wrap: break-word; max-height: 250px; overflow: auto; }\nul { margin: 4px 0 8px 20px; padding: 0; }\nfieldset { margin: 6px 0; padding: 6px; }\nsmall { display: block; margin-top: 2px; }\n</style>\n</head>\n<body>\n<h3>Encryption Interactive Playground</h3>\n\n<section>\n<label for=\"plaintext\">Plaintext</label><br>\n<textarea id=\"plaintext\" placeholder=\"Enter plaintext here...\">Hello, Encryption!</textarea>\n</section>\n\n<section>\n<label for=\"ciphertext\">Ciphertext / Output</label><br>\n<textarea id=\"ciphertext\" placeholder=\"Ciphertext appears here...\"></textarea>\n</section>\n\n<section>\n<label for=\"algoSelect\">Single-step Algorithm</label>\n<select id=\"algoSelect\">\n  <option value=\"caesar\">Caesar (shift letters)</option>\n  <option value=\"vigenere\">Vigenère (repeating key)</option>\n  <option value=\"xor\">XOR (text key)</option>\n  <option value=\"aesgcm\">AES-GCM (password)</option>\n  <option value=\"base64\">Base64 Encode/Decode</option>\n  <option value=\"hex\">Hex Encode/Decode</option>\n  <option value=\"reverse\">Reverse Text/Bytes</option>\n</select>\n</section>\n\n<section id=\"paramsArea\">\n<!-- Dynamic parameters appear here -->\n</section>\n\n<section>\n<button id=\"encryptBtn\">Encrypt / Apply</button>\n<button id=\"decryptBtn\">Decrypt / Reverse</button>\n<button id=\"stepEncryptBtn\">Step Encrypt (show steps)</button>\n<button id=\"stepDecryptBtn\">Step Decrypt</button>\n<button id=\"swapBtn\">Swap Plain/Cipher</button>\n</section>\n\n<hr>\n\n<section>\n<h4>Pipeline: Chain multiple operations</h4>\n<label for=\"pipelineName\">Pipeline name</label>\n<input id=\"pipelineName\" type=\"text\" value=\"My pipeline\">\n<button id=\"addStepBtn\">Add current operation to pipeline</button>\n<button id=\"runPipelineBtn\">Run pipeline (encrypt)</button>\n<button id=\"runPipelineReverseBtn\">Run pipeline reverse (decrypt)</button>\n<button id=\"stepPipelineNext\">Next step</button>\n<button id=\"stepPipelinePrev\">Previous step</button>\n<button id=\"clearPipelineBtn\">Clear pipeline</button>\n<button id=\"savePipelineBtn\">Save pipeline (download JSON)</button>\n<input type=\"file\" id=\"loadPipelineFile\" style=\"display:inline-block\">\n<fieldset>\n<legend>Pipeline steps</legend>\n<ul id=\"pipelineList\"></ul>\n</fieldset>\n</section>\n\n<hr>\n\n<section>\n<h4>Tools & Explorers</h4>\n<button id=\"freqBtn\">Frequency analysis (selected or plaintext)</button>\n<button id=\"bruteCaesarBtn\">Brute-force Caesar</button>\n<button id=\"mutateBtn\">Flip bit in ciphertext</button>\n<label for=\"mutateIndex\">index</label>\n<input type=\"number\" id=\"mutateIndex\" value=\"0\" min=\"0\">\n<label for=\"mutateBit\">bit (0-7)</label>\n<input type=\"number\" id=\"mutateBit\" value=\"0\" min=\"0\" max=\"7\">\n<button id=\"attemptDecryptMutBtn\">Attempt decrypt mutated (using pipeline reverse)</button>\n</section>\n\n<hr>\n\n<section>\n<h4>Key & Entropy Tools</h4>\n<label for=\"randomKeyLen\">Random key length (bytes)</label>\n<input id=\"randomKeyLen\" type=\"number\" value=\"16\" min=\"1\" max=\"64\">\n<button id=\"genKeyBtn\">Generate random key</button>\n<input id=\"generatedKey\" type=\"text\" placeholder=\"hex key appears here\">\n<br>\n<button id=\"startEntropy\">Start entropy capture</button>\n<button id=\"stopEntropy\">Stop entropy capture</button>\n<small id=\"entropyStatus\">Entropy: 0 samples</small>\n</section>\n\n<hr>\n\n<section>\n<h4>Brute-force Dictionary Attack (password-based)</h4>\n<label>Dictionary words (one per line)</label><br>\n<textarea id=\"dictArea\" placeholder=\"password1\\npassword2\\n...\"></textarea><br>\n<button id=\"runDictAttackBtn\">Run dictionary attack on ciphertext with AES-GCM pipeline step</button>\n<button id=\"abortAttackBtn\">Abort attack</button>\n<small id=\"attackStatus\"></small>\n</section>\n\n<hr>\n\n<section>\n<h4>History & Snapshots</h4>\n<button id=\"saveSnapshotBtn\">Save snapshot</button>\n<button id=\"clearSnapshotsBtn\">Clear snapshots</button>\n<ol id=\"snapshotsList\"></ol>\n</section>\n\n<hr>\n\n<section>\n<h4>Logs & Step Output</h4>\n<pre id=\"log\" aria-live=\"polite\"></pre>\n</section>\n\n<script>\n/*\n  Encryption Interactive Playground\n  - Many interactive controls\n  - Pipeline of string-transform operations\n  - Single-step algorithms and parameters\n  - AES-GCM via Web Crypto; PBKDF2 for key derivation\n  - Brute force for Caesar and dictionary attack for AES password\n  - Entropy capture via mouse movement\n  - Undo/Redo for main state (simple)\n*/\n\n/* Utilities */\nfunction utf8ToBytes(str) {\n  return new TextEncoder().encode(str);\n}\nfunction bytesToUtf8(bytes) {\n  return new TextDecoder().decode(bytes);\n}\nfunction bytesToHex(bytes) {\n  return Array.from(bytes).map(b=>b.toString(16).padStart(2,'0')).join('');\n}\nfunction hexToBytes(hex) {\n  if (hex.length % 2) hex = '0' + hex;\n  const out = new Uint8Array(hex.length/2);\n  for (let i=0;i<out.length;i++) out[i]=parseInt(hex.substr(i*2,2),16);\n  return out;\n}\nfunction bytesToBase64(bytes) {\n  let binary = '';\n  const chunk = 0x8000;\n  for (let i=0;i<bytes.length;i+=chunk) {\n    binary += String.fromCharCode.apply(null, bytes.subarray(i, i+chunk));\n  }\n  return btoa(binary);\n}\nfunction base64ToBytes(b64) {\n  const bin = atob(b64);\n  const arr = new Uint8Array(bin.length);\n  for (let i=0;i<bin.length;i++) arr[i]=bin.charCodeAt(i);\n  return arr;\n}\nfunction base64EncodeString(str) { return bytesToBase64(utf8ToBytes(str)); }\nfunction base64DecodeToString(b64) { return bytesToUtf8(base64ToBytes(b64)); }\nfunction log(msg) {\n  const el = document.getElementById('log');\n  el.textContent = msg + \"\\n\\n\" + el.textContent;\n}\n\n/* State */\nlet pipeline = []; // array of step objects {type, params}\nlet pipelineIndex = -1;\nlet intermediateOutputs = []; // outputs after each step during stepping\nlet snapshots = [];\nlet entropySamples = [];\nlet capturingEntropy = false;\nlet attackAbortFlag = false;\n\n/* UI elements */\nconst algoSelect = document.getElementById('algoSelect');\nconst paramsArea = document.getElementById('paramsArea');\nconst plaintextEl = document.getElementById('plaintext');\nconst ciphertextEl = document.getElementById('ciphertext');\n\nfunction createParamsUI() {\n  paramsArea.innerHTML = '';\n  const type = algoSelect.value;\n  if (type === 'caesar') {\n    const f = document.createElement('div');\n    f.innerHTML = '<label>Shift</label> <input id=\"paramShift\" type=\"range\" min=\"-25\" max=\"25\" value=\"3\"><input id=\"paramShiftNum\" type=\"number\" min=\"-25\" max=\"25\" value=\"3\">';\n    paramsArea.appendChild(f);\n    const r = document.getElementById('paramShift');\n    const n = document.getElementById('paramShiftNum');\n    r.addEventListener('input', ()=>n.value = r.value);\n    n.addEventListener('input', ()=>r.value = n.value);\n    const opt = document.createElement('div');\n    opt.innerHTML = '<label>Preserve non-letters?</label> <input id=\"paramPreserve\" type=\"checkbox\" checked>';\n    paramsArea.appendChild(opt);\n  } else if (type === 'vigenere') {\n    const f = document.createElement('div');\n    f.innerHTML = '<label>Key</label> <input id=\"paramVigKey\" type=\"text\" value=\"KEY\">';\n    paramsArea.appendChild(f);\n    const o = document.createElement('div');\n    o.innerHTML = '<label>Non-letters ignore</label> <input id=\"paramVigIgnore\" type=\"checkbox\" checked>';\n    paramsArea.appendChild(o);\n  } else if (type === 'xor') {\n    const f = document.createElement('div');\n    f.innerHTML = '<label>Key (text)</label> <input id=\"paramXorKey\" type=\"text\" value=\"secret\">';\n    paramsArea.appendChild(f);\n    const enc = document.createElement('div');\n    enc.innerHTML = '<label>Output encoding</label> <select id=\"paramXorEnc\"><option value=\"base64\">base64</option><option value=\"hex\">hex</option></select>';\n    paramsArea.appendChild(enc);\n  } else if (type === 'aesgcm') {\n    const f = document.createElement('div');\n    f.innerHTML = '<label>Password</label> <input id=\"paramAesPass\" type=\"text\" value=\"password\">';\n    paramsArea.appendChild(f);\n    const s = document.createElement('div');\n    s.innerHTML = '<label>PBKDF2 iterations</label> <input id=\"paramAesIter\" type=\"number\" value=\"100000\" min=\"1000\" max=\"1000000\">';\n    paramsArea.appendChild(s);\n    const sl = document.createElement('div');\n    sl.innerHTML = '<label>Salt (hex) optional</label> <input id=\"paramAesSalt\" type=\"text\" placeholder=\"leave blank to randomize\">';\n    paramsArea.appendChild(sl);\n    const iv = document.createElement('div');\n    iv.innerHTML = '<label>IV length bytes</label> <input id=\"paramAesIvLen\" type=\"number\" value=\"12\" min=\"8\" max=\"16\">';\n    paramsArea.appendChild(iv);\n    const enc = document.createElement('div');\n    enc.innerHTML = '<label>Output format</label> <select id=\"paramAesFormat\"><option value=\"json\">JSON (iv,salt,ct base64)</option><option value=\"compact\">compact base64</option></select>';\n    paramsArea.appendChild(enc);\n  } else if (type === 'base64') {\n    paramsArea.innerHTML = '<div><label>Mode</label> <select id=\"paramB64Mode\"><option value=\"encode\">Encode</option><option value=\"decode\">Decode</option></select></div>';\n  } else if (type === 'hex') {\n    paramsArea.innerHTML = '<div><label>Mode</label> <select id=\"paramHexMode\"><option value=\"encode\">Encode</option><option value=\"decode\">Decode</option></select></div>';\n  } else if (type === 'reverse') {\n    paramsArea.innerHTML = '<div><label>Interpret as bytes?</label> <input id=\"paramReverseBytes\" type=\"checkbox\"></div>';\n  }\n}\ncreateParamsUI();\nalgoSelect.addEventListener('change', createParamsUI);\n\n/* Algorithms as string->Promise<string> and reverse functions */\nconst operations = {\n  caesar: {\n    async enc(input, params) {\n      const shift = Number(params.shift)||0;\n      const preserve = params.preserve !== false;\n      return applyCaesar(input, shift, preserve);\n    },\n    async dec(input, params) {\n      const shift = Number(params.shift)||0;\n      const preserve = params.preserve !== false;\n      return applyCaesar(input, -shift, preserve);\n    }\n  },\n  vigenere: {\n    async enc(input, params) {\n      return applyVigenere(input, params.key||'KEY', true, params.ignore);\n    },\n    async dec(input, params) {\n      return applyVigenere(input, params.key||'KEY', false, params.ignore);\n    }\n  },\n  xor: {\n    async enc(input, params) {\n      const out = xorStringToEncoded(input, params.key||'secret', params.encoding||'base64');\n      return out;\n    },\n    async dec(input, params) {\n      const out = xorEncodedToString(input, params.key||'secret', params.encoding||'base64');\n      return out;\n    }\n  },\n  aesgcm: {\n    async enc(input, params) {\n      const pass = params.password||'password';\n      const iterations = Number(params.iterations)||100000;\n      let salt = params.saltHex ? hexToBytes(params.saltHex) : crypto.getRandomValues(new Uint8Array(16));\n      const iv = crypto.getRandomValues(new Uint8Array(Number(params.ivLen)||12));\n      const key = await deriveKeyPBKDF2(pass, salt, iterations, 'AES-GCM', 256);\n      const ct = new Uint8Array(await crypto.subtle.encrypt({name:'AES-GCM', iv:iv}, key, utf8ToBytes(input)));\n      const payload = {\n        algo: 'aes-gcm',\n        iv: bytesToBase64(iv),\n        salt: bytesToBase64(salt),\n        iterations: iterations,\n        ct: bytesToBase64(ct)\n      };\n      if (params.format === 'compact') {\n        // compact: base64(iv || salt || ciphertext) - not standard but a compact option\n        const combined = new Uint8Array(iv.length + salt.length + ct.length);\n        combined.set(iv,0); combined.set(salt, iv.length); combined.set(ct, iv.length+salt.length);\n        return bytesToBase64(combined);\n      } else {\n        return JSON.stringify(payload);\n      }\n    },\n    async dec(input, params) {\n      // input may be JSON or compact base64; if params.providePassword, use it else try to parse input\n      let parsed;\n      let pass = params.password || '';\n      if (params.format === 'compact') {\n        const combined = base64ToBytes(input);\n        const ivLen = Number(params.ivLen)||12;\n        const saltLen = 16;\n        const iv = combined.slice(0,ivLen);\n        const salt = combined.slice(ivLen, ivLen+saltLen);\n        const ct = combined.slice(ivLen+saltLen);\n        const iterations = Number(params.iterations)||100000;\n        const key = await deriveKeyPBKDF2(pass, salt, iterations, 'AES-GCM', 256);\n        const plain = await crypto.subtle.decrypt({name:'AES-GCM', iv:iv}, key, ct);\n        return bytesToUtf8(new Uint8Array(plain));\n      } else {\n        try {\n          parsed = JSON.parse(input);\n        } catch(e) { throw new Error('Invalid AES payload JSON'); }\n        const iv = base64ToBytes(parsed.iv);\n        const salt = base64ToBytes(parsed.salt);\n        const iterations = Number(parsed.iterations || params.iterations || 100000);\n        pass = params.password || params.passwordFromInput || params.password;\n        if (!pass) throw new Error('Password required for AES decryption');\n        const key = await deriveKeyPBKDF2(pass, salt, iterations, 'AES-GCM', 256);\n        try {\n          const pt = await crypto.subtle.decrypt({name:'AES-GCM', iv:iv}, key, base64ToBytes(parsed.ct));\n          return bytesToUtf8(new Uint8Array(pt));\n        } catch(e) {\n          throw new Error('Decryption failed: ' + e.message);\n        }\n      }\n    }\n  },\n  base64: {\n    async enc(input, params) {\n      return bytesToBase64(utf8ToBytes(input));\n    },\n    async dec(input, params) {\n      try { return bytesToUtf8(base64ToBytes(input)); } catch(e) { throw new Error('Invalid base64'); }\n    }\n  },\n  hex: {\n    async enc(input, params) {\n      return bytesToHex(utf8ToBytes(input));\n    },\n    async dec(input, params) {\n      try { return bytesToUtf8(hexToBytes(input)); } catch(e) { throw new Error('Invalid hex'); }\n    }\n  },\n  reverse: {\n    async enc(input, params) {\n      if (params.asBytes) {\n        const b = utf8ToBytes(input);\n        return bytesToHex(b.reverse());\n      } else {\n        return input.split('').reverse().join('');\n      }\n    },\n    async dec(input, params) {\n      if (params.asBytes) {\n        const b = hexToBytes(input);\n        return bytesToUtf8((new Uint8Array(b)).reverse());\n      } else {\n        return input.split('').reverse().join('');\n      }\n    }\n  }\n};\n\n/* Implementations for Caesar and Vigenere and XOR utilities */\nfunction applyCaesar(text, shift, preserve=true) {\n  const s = Number(shift)|0;\n  return text.split('').map(ch=>{\n    const code = ch.charCodeAt(0);\n    if (code >= 65 && code <= 90) {\n      const base = 65;\n      return String.fromCharCode(((code - base + s + 26*100) % 26) + base);\n    } else if (code >= 97 && code <= 122) {\n      const base = 97;\n      return String.fromCharCode(((code - base + s + 26*100) % 26) + base);\n    } else {\n      return preserve ? ch : '';\n    }\n  }).join('');\n}\nfunction applyVigenere(text, key, encrypt=true, ignore=true) {\n  const k = key.replace(/[^A-Za-z]/g,'').toUpperCase();\n  if (!k) return text;\n  let ki = 0;\n  return text.split('').map(ch=>{\n    const code = ch.charCodeAt(0);\n    const keyChar = k[ki % k.length];\n    if ((code >= 65 && code <= 90) || (code >=97 && code<=122)) {\n      const isUpper = code < 97;\n      const base = isUpper ? 65 : 97;\n      const keyShift = keyChar.charCodeAt(0) - 65;\n      const s = encrypt ? keyShift : -keyShift;\n      const out = String.fromCharCode(((code - base + s + 26*100) % 26) + base);\n      ki++;\n      return out;\n    } else {\n      if (ignore) return ch;\n      else return '';\n    }\n  }).join('');\n}\nfunction xorStringToEncoded(text, key, encoding='base64') {\n  const tb = utf8ToBytes(text);\n  const kb = utf8ToBytes(key);\n  const out = new Uint8Array(tb.length);\n  for (let i=0;i<tb.length;i++) out[i] = tb[i] ^ kb[i % kb.length];\n  if (encoding === 'hex') return bytesToHex(out);\n  return bytesToBase64(out);\n}\nfunction xorEncodedToString(encoded, key, encoding='base64') {\n  let bytes;\n  if (encoding === 'hex') bytes = hexToBytes(encoded);\n  else bytes = base64ToBytes(encoded);\n  const kb = utf8ToBytes(key);\n  const out = new Uint8Array(bytes.length);\n  for (let i=0;i<bytes.length;i++) out[i] = bytes[i] ^ kb[i % kb.length];\n  return bytesToUtf8(out);\n}\n\n/* WebCrypto helpers */\nasync function deriveKeyPBKDF2(password, saltBytes, iterations, alg, length) {\n  const enc = new TextEncoder();\n  const passKey = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveKey','deriveBits']);\n  const key = await crypto.subtle.deriveKey(\n    {name:'PBKDF2', salt: saltBytes, iterations: iterations, hash: 'SHA-256'},\n    passKey,\n    {name: alg, length: length},\n    false,\n    ['encrypt','decrypt']\n  );\n  return key;\n}\n\n/* Single-step UI actions */\ndocument.getElementById('encryptBtn').addEventListener('click', async ()=>{\n  try {\n    const type = algoSelect.value;\n    const params = readParamsFromUI(type);\n    const input = plaintextEl.value;\n    const out = await operations[type].enc(input, params);\n    ciphertextEl.value = out;\n    log(`Applied ${type} (encrypt) - result length ${out.length}`);\n  } catch(e) {\n    log('Error: '+e.message);\n  }\n});\ndocument.getElementById('decryptBtn').addEventListener('click', async ()=>{\n  try {\n    const type = algoSelect.value;\n    const params = readParamsFromUI(type);\n    const input = ciphertextEl.value;\n    const out = await operations[type].dec(input, params);\n    plaintextEl.value = out;\n    log(`Applied ${type} (decrypt)`);\n  } catch(e) {\n    log('Error: '+e.message);\n  }\n});\ndocument.getElementById('stepEncryptBtn').addEventListener('click', async ()=>{\n  // Show internal steps for chosen alg if available\n  const type = algoSelect.value;\n  const params = readParamsFromUI(type);\n  log(`Step trace for ${type} (encrypt):`);\n  if (type === 'caesar') {\n    const shift = Number(params.shift);\n    const example = plaintextEl.value;\n    for (let s = 0; s <= shift; s++) {\n      const intermediate = applyCaesar(example, s, params.preserve);\n      log(`shift ${s}: ${intermediate}`);\n    }\n  } else {\n    log('Detailed step tracing not implemented for this algorithm. Use pipeline stepping to explore combinations.');\n  }\n});\ndocument.getElementById('stepDecryptBtn').addEventListener('click', async ()=>{\n  const type = algoSelect.value;\n  const params = readParamsFromUI(type);\n  log(`Step trace for ${type} (decrypt):`);\n  if (type === 'caesar') {\n    const example = ciphertextEl.value;\n    for (let s = -25; s <= 25; s++) {\n      log(`shift ${s}: ${applyCaesar(example, s, params.preserve)}`);\n    }\n  } else {\n    log('Detailed step tracing not implemented for this algorithm.');\n  }\n});\ndocument.getElementById('swapBtn').addEventListener('click', ()=>{\n  const pt = plaintextEl.value;\n  plaintextEl.value = ciphertextEl.value;\n  ciphertextEl.value = pt;\n});\n\n/* Read parameters from UI */\nfunction readParamsFromUI(type) {\n  const p = {};\n  if (type === 'caesar') {\n    p.shift = Number(document.getElementById('paramShift').value);\n    p.preserve = document.getElementById('paramPreserve').checked;\n  } else if (type === 'vigenere') {\n    p.key = document.getElementById('paramVigKey').value;\n    p.ignore = document.getElementById('paramVigIgnore').checked;\n  } else if (type === 'xor') {\n    p.key = document.getElementById('paramXorKey').value;\n    p.encoding = document.getElementById('paramXorEnc').value;\n  } else if (type === 'aesgcm') {\n    p.password = document.getElementById('paramAesPass').value;\n    p.iterations = Number(document.getElementById('paramAesIter').value);\n    const s = document.getElementById('paramAesSalt').value.trim();\n    p.saltHex = s ? s : null;\n    p.ivLen = Number(document.getElementById('paramAesIvLen').value);\n    p.format = document.getElementById('paramAesFormat').value;\n  } else if (type === 'base64') {\n    p.mode = document.getElementById('paramB64Mode').value;\n  } else if (type === 'hex') {\n    p.mode = document.getElementById('paramHexMode').value;\n  } else if (type === 'reverse') {\n    p.asBytes = document.getElementById('paramReverseBytes').checked;\n  }\n  return p;\n}\n\n/* Pipeline management */\nfunction renderPipeline() {\n  const list = document.getElementById('pipelineList');\n  list.innerHTML = '';\n  pipeline.forEach((step, idx)=>{\n    const li = document.createElement('li');\n    const text = `${idx+1}. ${step.type} ${JSON.stringify(step.params)}`;\n    li.textContent = text;\n    const up = document.createElement('button'); up.textContent = '↑'; up.addEventListener('click', ()=>{ swapSteps(idx, idx-1); });\n    const down = document.createElement('button'); down.textContent = '↓'; down.addEventListener('click', ()=>{ swapSteps(idx, idx+1); });\n    const edit = document.createElement('button'); edit.textContent = 'edit'; edit.addEventListener('click', ()=>{ editStep(idx); });\n    const remove = document.createElement('button'); remove.textContent = 'remove'; remove.addEventListener('click', ()=>{ pipeline.splice(idx,1); renderPipeline(); });\n    li.appendChild(up); li.appendChild(down); li.appendChild(edit); li.appendChild(remove);\n    list.appendChild(li);\n  });\n}\nfunction swapSteps(a,b) {\n  if (a<0||b<0||a>=pipeline.length||b>=pipeline.length) return;\n  const t = pipeline[a]; pipeline[a]=pipeline[b]; pipeline[b]=t; renderPipeline();\n}\nfunction editStep(idx) {\n  const step = pipeline[idx];\n  const newParams = prompt('Edit JSON params for step: ' + step.type, JSON.stringify(step.params));\n  if (newParams !== null) {\n    try {\n      step.params = JSON.parse(newParams);\n      renderPipeline();\n    } catch(e) { alert('Invalid JSON'); }\n  }\n}\ndocument.getElementById('addStepBtn').addEventListener('click', ()=>{\n  const type = algoSelect.value;\n  const params = readParamsFromUI(type);\n  pipeline.push({type, params});\n  renderPipeline();\n});\ndocument.getElementById('clearPipelineBtn').addEventListener('click', ()=>{ pipeline=[]; renderPipeline(); });\ndocument.getElementById('savePipelineBtn').addEventListener('click', ()=>{\n  const name = (document.getElementById('pipelineName').value || 'pipeline') + '.json';\n  const blob = new Blob([JSON.stringify(pipeline,null,2)], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a'); a.href = url; a.download = name; a.click();\n  URL.revokeObjectURL(url);\n});\ndocument.getElementById('loadPipelineFile').addEventListener('change', (e)=>{\n  const f = e.target.files[0];\n  if (!f) return;\n  const r = new FileReader(); r.onload = ()=> {\n    try { pipeline = JSON.parse(r.result); renderPipeline(); } catch(e){ alert('Invalid pipeline JSON'); }\n  }; r.readAsText(f);\n});\n\n/* Run pipeline forward (encrypt) */\nasync function runPipelineForward(input) {\n  intermediateOutputs = [input];\n  let cur = input;\n  for (let i=0;i<pipeline.length;i++) {\n    const step = pipeline[i];\n    const op = operations[step.type];\n    if (!op) throw new Error('Unknown op '+step.type);\n    log(`Pipeline step ${i+1}: ${step.type}`);\n    cur = await op.enc(cur, step.params);\n    intermediateOutputs.push(cur);\n  }\n  return cur;\n}\nasync function runPipelineReverse(input) {\n  intermediateOutputs = [input];\n  let cur = input;\n  for (let i=pipeline.length-1;i>=0;i--) {\n    const step = pipeline[i];\n    const op = operations[step.type];\n    log(`Pipeline reverse step ${i+1}: ${step.type}`);\n    cur = await op.dec(cur, step.params);\n    intermediateOutputs.push(cur);\n  }\n  return cur;\n}\ndocument.getElementById('runPipelineBtn').addEventListener('click', async ()=>{\n  try {\n    const input = plaintextEl.value;\n    const out = await runPipelineForward(input);\n    ciphertextEl.value = out;\n    log('Pipeline finished (encrypt).');\n  } catch(e) { log('Pipeline error: '+e.message); }\n});\ndocument.getElementById('runPipelineReverseBtn').addEventListener('click', async ()=>{\n  try {\n    const input = ciphertextEl.value;\n    const out = await runPipelineReverse(input);\n    plaintextEl.value = out;\n    log('Pipeline finished (reverse/decrypt).');\n  } catch(e) { log('Pipeline reverse error: '+e.message); }\n});\n\ndocument.getElementById('stepPipelineNext').addEventListener('click', async ()=>{\n  try {\n    if (pipelineIndex < pipeline.length - 1) {\n      pipelineIndex++;\n      const input = (pipelineIndex === 0) ? plaintextEl.value : intermediateOutputs[pipelineIndex];\n      // run only this step\n      const step = pipeline[pipelineIndex];\n      const out = await operations[step.type].enc(intermediateOutputs[pipelineIndex], step.params);\n      intermediateOutputs[pipelineIndex+1] = out;\n      ciphertextEl.value = out;\n      log(`Step ${pipelineIndex+1} applied: ${step.type}`);\n    } else {\n      log('Already at end of pipeline.');\n    }\n  } catch(e) { log('Step error: '+e.message); }\n});\ndocument.getElementById('stepPipelinePrev').addEventListener('click', async ()=>{\n  try {\n    if (pipelineIndex > -1) {\n      pipelineIndex--;\n      const out = (pipelineIndex === -1) ? plaintextEl.value : intermediateOutputs[pipelineIndex+1];\n      ciphertextEl.value = out;\n      log(`Stepped back to ${pipelineIndex+1}`);\n    } else {\n      log('Already at pipeline start.');\n    }\n  } catch(e) { log('Step error: '+e.message); }\n});\n\n/* Frequency analysis and brute-force Caesar */\ndocument.getElementById('freqBtn').addEventListener('click', ()=>{\n  const txt = window.getSelection().toString() || plaintextEl.value || ciphertextEl.value;\n  if (!txt) { log('No text for frequency analysis.'); return; }\n  const freq = {};\n  for (let ch of txt) {\n    freq[ch] = (freq[ch]||0) + 1;\n  }\n  const arr = Object.keys(freq).map(k=>({k,count:freq[k]})).sort((a,b)=>b.count-a.count);\n  log('Frequency analysis:\\n' + arr.map(a=>`${a.k}: ${a.count}`).join('\\n'));\n});\ndocument.getElementById('bruteCaesarBtn').addEventListener('click', ()=>{\n  const txt = ciphertextEl.value || plaintextEl.value;\n  if (!txt) { log('No text to brute force'); return; }\n  const outputs = [];\n  for (let s = -25; s<=25; s++) {\n    outputs.push(`${s}: ${applyCaesar(txt, s, true)}`);\n  }\n  log('Caesar brute force:\\n' + outputs.join('\\n'));\n});\n\n/* Mutate ciphertext bit flipping */\ndocument.getElementById('mutateBtn').addEventListener('click', ()=>{\n  const idx = Number(document.getElementById('mutateIndex').value);\n  const bit = Number(document.getElementById('mutateBit').value);\n  const ct = ciphertextEl.value;\n  if (!ct) { log('No ciphertext'); return; }\n  // treat ciphertext as base64 or hex or raw text; try base64 decode first\n  let bytes;\n  try { bytes = base64ToBytes(ct); }\n  catch(e) {\n    try { bytes = hexToBytes(ct); } catch(e2) { bytes = utf8ToBytes(ct); }\n  }\n  if (idx < 0 || idx >= bytes.length) { log('Index out of range'); return; }\n  const mutated = new Uint8Array(bytes);\n  mutated[idx] = mutated[idx] ^ (1 << bit);\n  ciphertextEl.value = bytesToBase64(mutated);\n  log(`Flipped bit ${bit} at index ${idx}. New ciphertext (base64).`);\n});\ndocument.getElementById('attemptDecryptMutBtn').addEventListener('click', async ()=>{\n  try {\n    const out = await runPipelineReverse(ciphertextEl.value);\n    plaintextEl.value = out;\n    log('Attempted decryption of mutated ciphertext with pipeline reverse completed.');\n  } catch(e) { log('Decrypt mutated error: '+e.message); }\n});\n\n/* Key generation and entropy capture */\ndocument.getElementById('genKeyBtn').addEventListener('click', ()=>{\n  const len = Number(document.getElementById('randomKeyLen').value) || 16;\n  const arr = crypto.getRandomValues(new Uint8Array(len));\n  document.getElementById('generatedKey').value = bytesToHex(arr);\n  log('Random key generated (hex).');\n});\ndocument.getElementById('startEntropy').addEventListener('click', ()=>{\n  entropySamples = [];\n  capturingEntropy = true;\n  document.getElementById('entropyStatus').textContent = 'Entropy: 0 samples (move mouse over page)';\n});\ndocument.getElementById('stopEntropy').addEventListener('click', ()=>{\n  capturingEntropy = false;\n  document.getElementById('entropyStatus').textContent = `Entropy stopped: ${entropySamples.length} samples`;\n});\ndocument.addEventListener('mousemove', (e)=>{\n  if (!capturingEntropy) return;\n  // collect low-entropy samples of position and timestamp\n  entropySamples.push((e.clientX & 0xff) ^ (e.clientY & 0xff) ^ (Date.now() & 0xff));\n  document.getElementById('entropyStatus').textContent = `Entropy: ${entropySamples.length} samples`;\n  if (entropySamples.length > 256) capturingEntropy = false;\n});\n\n/* Dictionary attack for AES-GCM-like payload in pipeline */\ndocument.getElementById('runDictAttackBtn').addEventListener('click', async ()=>{\n  attackAbortFlag = false;\n  const dict = document.getElementById('dictArea').value.split(/\\r?\\n/).map(s=>s.trim()).filter(Boolean);\n  if (!dict.length) { log('Dictionary empty'); return; }\n  const ct = ciphertextEl.value;\n  if (!ct) { log('No ciphertext'); return; }\n  document.getElementById('attackStatus').textContent = 'Running...';\n  for (let i=0;i<dict.length;i++) {\n    if (attackAbortFlag) { log('Attack aborted'); document.getElementById('attackStatus').textContent = 'Aborted'; return; }\n    const pass = dict[i];\n    try {\n      // attempt decrypt using AES-GCM step if pipeline contains AES or assume single aesgcm\n      // We'll try decrypting directly as AES JSON or compact\n      let success = false;\n      try {\n        const parsed = JSON.parse(ct);\n        if (parsed.algo === 'aes-gcm') {\n          const salt = base64ToBytes(parsed.salt);\n          const iv = base64ToBytes(parsed.iv);\n          const iters = Number(parsed.iterations||100000);\n          const key = await deriveKeyPBKDF2(pass, salt, iters, 'AES-GCM', 256);\n          const pt = await crypto.subtle.decrypt({name:'AES-GCM', iv:iv}, key, base64ToBytes(parsed.ct));\n          const txt = bytesToUtf8(new Uint8Array(pt));\n          log(`Password found: ${pass}\\nPlaintext: ${txt}`);\n          document.getElementById('attackStatus').textContent = `Found: ${pass}`;\n          success = true;\n          break;\n        }\n      } catch(e) {\n        // maybe compact base64: attempt simple decode\n        try {\n          const combined = base64ToBytes(ct);\n          // try many possible iv sizes and salt sizes - heuristic\n          const ivLen = 12; const saltLen = 16;\n          if (combined.length > ivLen + saltLen) {\n            const iv = combined.slice(0,ivLen);\n            const salt = combined.slice(ivLen, ivLen+saltLen);\n            const ctbytes = combined.slice(ivLen+saltLen);\n            const iters = 100000;\n            const key = await deriveKeyPBKDF2(pass, salt, iters, 'AES-GCM', 256);\n            const pt = await crypto.subtle.decrypt({name:'AES-GCM', iv:iv}, key, ctbytes);\n            const txt = bytesToUtf8(new Uint8Array(pt));\n            log(`Password found (compact): ${pass}\\nPlaintext: ${txt}`);\n            document.getElementById('attackStatus').textContent = `Found: ${pass}`;\n            success = true;\n            break;\n          }\n        } catch(e2){ /* failed for this pass */ }\n      }\n    } catch(e) {}\n    if (i % 5 === 0) {\n      document.getElementById('attackStatus').textContent = `Tried ${i+1}/${dict.length}`;\n      await new Promise(r=>setTimeout(r,50));\n    }\n  }\n  if (!attackAbortFlag) document.getElementById('attackStatus').textContent = 'Finished';\n});\ndocument.getElementById('abortAttackBtn').addEventListener('click', ()=>{ attackAbortFlag = true; });\n\n/* History & snapshots */\ndocument.getElementById('saveSnapshotBtn').addEventListener('click', ()=>{\n  const s = {\n    time: new Date().toISOString(),\n    plaintext: plaintextEl.value,\n    ciphertext: ciphertextEl.value,\n    pipeline: pipeline\n  };\n  snapshots.push(s);\n  renderSnapshots();\n  log('Snapshot saved.');\n});\ndocument.getElementById('clearSnapshotsBtn').addEventListener('click', ()=>{ snapshots = []; renderSnapshots(); log('Snapshots cleared'); });\nfunction renderSnapshots() {\n  const list = document.getElementById('snapshotsList');\n  list.innerHTML = '';\n  snapshots.forEach((s, idx)=> {\n    const li = document.createElement('li');\n    const loadBtn = document.createElement('button'); loadBtn.textContent = 'load'; loadBtn.addEventListener('click', ()=>{\n      plaintextEl.value = s.plaintext;\n      ciphertextEl.value = s.ciphertext;\n      pipeline = s.pipeline || [];\n      renderPipeline();\n      log('Snapshot loaded: ' + s.time);\n    });\n    const delBtn = document.createElement('button'); delBtn.textContent = 'del'; delBtn.addEventListener('click', ()=>{ snapshots.splice(idx,1); renderSnapshots(); });\n    li.textContent = `${s.time} `;\n    li.appendChild(loadBtn); li.appendChild(delBtn);\n    list.appendChild(li);\n  });\n}\n\n/* Undo/Redo (simple): track a small stack of states */\nlet undoStack = [], redoStack = [];\nfunction pushState() {\n  undoStack.push({plaintext: plaintextEl.value, ciphertext: ciphertextEl.value, pipeline: JSON.parse(JSON.stringify(pipeline))});\n  if (undoStack.length > 50) undoStack.shift();\n  redoStack = [];\n}\ndocument.addEventListener('input', (e)=>{ pushState(); }, true); // naive but works\nfunction undo() {\n  if (!undoStack.length) return;\n  const s = undoStack.pop();\n  redoStack.push({plaintext: plaintextEl.value, ciphertext: ciphertextEl.value, pipeline: JSON.parse(JSON.stringify(pipeline))});\n  plaintextEl.value = s.plaintext; ciphertextEl.value = s.ciphertext; pipeline = s.pipeline; renderPipeline();\n}\nfunction redo() {\n  if (!redoStack.length) return;\n  const s = redoStack.pop();\n  undoStack.push({plaintext: plaintextEl.value, ciphertext: ciphertextEl.value, pipeline: JSON.parse(JSON.stringify(pipeline))});\n  plaintextEl.value = s.plaintext; ciphertextEl.value = s.ciphertext; pipeline = s.pipeline; renderPipeline();\n}\ndocument.addEventListener('keydown', (e)=> {\n  if ((e.ctrlKey || e.metaKey) && e.key === 'z') { undo(); e.preventDefault(); }\n  if ((e.ctrlKey || e.metaKey) && e.key === 'y') { redo(); e.preventDefault(); }\n});\n\n/* Initialize */\nrenderPipeline();\nlog('Ready. Use the controls to experiment with encryption. Many different workflows are possible: single-step ops, build pipelines, step through, mutate bits and attempt decryption, or run small dictionary attacks.');\n\n/* End of script */\n</script>\n</body>\n</html>"
