    "content": "<html lang=\"en\" >\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Random Forest • Concept Visualization</title>\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n    /* Root colors */\n    :root {\n      --color-bg: #1e1e2f;\n      --color-primary: #4ade80; /* Green 400 */\n      --color-secondary: #2563eb; /* Blue 600 */\n      --color-accent: #fbbf24; /* Amber 400 */\n      --color-text-primary: #e0e0e0;\n      --color-text-secondary: #a0a0b5;\n      --color-shadow: rgba(0, 0, 0, 0.25);\n    }\n\n    *, *::before, *::after {\n      box-sizing: border-box;\n    }\n\n    body {\n      margin: 0;\n      background: var(--color-bg);\n      font-family: 'Poppins', sans-serif;\n      color: var(--color-text-primary);\n      overflow-x: hidden;\n      user-select: none;\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n    }\n\n    .container {\n      max-width: 960px;\n      margin: 2rem auto 4rem;\n      padding: 0 1.5rem;\n      text-align: center;\n    }\n\n    header h1 {\n      font-weight: 600;\n      font-size: 3rem;\n      letter-spacing: 0.12em;\n      color: var(--color-accent);\n      margin-bottom: 0.2rem;\n      text-shadow: 0 0 12px var(--color-accent);\n    }\n\n    header p {\n      font-weight: 300;\n      font-size: 1.15rem;\n      color: var(--color-text-secondary);\n      margin-top: 0;\n      margin-bottom: 2.5rem;\n      letter-spacing: 0.04em;\n    }\n\n    /* BUTTON */\n    .btn {\n      background: transparent;\n      border: 2.8px solid var(--color-secondary);\n      color: var(--color-secondary);\n      padding: 0.65rem 1.4rem;\n      font-size: 1.1rem;\n      font-weight: 600;\n      border-radius: 12px;\n      letter-spacing: 0.1em;\n      cursor: pointer;\n      transition:\n        background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),\n        color 0.4s cubic-bezier(0.4, 0, 0.2, 1),\n        border-color 0.4s cubic-bezier(0.4, 0, 0.2, 1),\n        box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n      user-select: none;\n      box-shadow:\n        0 0 8px #2563eb7a,\n        inset 0 0 8px #2563eb80;\n      backdrop-filter: saturate(180%) blur(12px);\n      -webkit-backdrop-filter: saturate(180%) blur(12px);\n    }\n    .btn:hover, .btn:focus {\n      background-color: var(--color-secondary);\n      color: var(--color-bg);\n      border-color: var(--color-secondary);\n      box-shadow:\n        0 0 30px #2563ebcc,\n        inset 0 0 26px #2563ebdd;\n      outline: none;\n    }\n\n    /* RANDOM FOREST VISUALIZATION ROOT ELEMENT */\n    #forest {\n      position: relative;\n      width: 100%;\n      height: 600px;\n      max-width: 900px;\n      margin: 0 auto 3rem;\n      filter: drop-shadow(0 0 5px rgba(37, 99, 235, 0.4));\n      user-select: none;\n    }\n\n    /* Tree trunks */\n    .trunk {\n      stroke: #3a3f5c;\n      stroke-width: 5;\n      stroke-linecap: round;\n      filter: drop-shadow(0 1px 1px rgba(25, 25, 45, 0.8));\n      transform-origin: bottom center;\n      transform-box: fill-box;\n      transition: stroke 0.4s ease;\n    }\n\n    .trunk.highlight {\n      stroke: var(--color-primary);\n      filter: drop-shadow(0 0 10px var(--color-primary));\n    }\n\n    /* Leaves style and animation */\n    .leaf {\n      fill-opacity: 0.85;\n      filter: drop-shadow(0 1px 2px rgba(30, 180, 60, 0.75));\n      transform-origin: center bottom;\n      transition: fill-opacity 0.7s ease;\n      will-change: transform;\n    }\n    .leaf-green {\n      fill: var(--color-primary);\n      filter: drop-shadow(0 1px 3px #4ade8077);\n    }\n\n    .leaf-blue {\n      fill: var(--color-secondary);\n      filter: drop-shadow(0 1px 3px #2563eb77);\n    }\n\n    .leaf-amber {\n      fill: var(--color-accent);\n      filter: drop-shadow(0 1px 3px #fbbf2477);\n    }\n\n    /* Leaf gentle swaying animation */\n    @keyframes sway {\n      0%, 100% {\n        transform: rotate(0deg);\n      }\n      50% {\n        transform: rotate(3deg);\n      }\n    }\n\n    .leaf.sway {\n      animation: sway 6s ease-in-out infinite;\n      will-change: transform;\n    }\n    .leaf.sway-delayed {\n      animation-delay: 3s;\n    }\n\n    /* Circle packages - tree canopy - representing randomness */\n    .canopy {\n      fill-opacity: 0.4;\n      stroke: none;\n      filter: drop-shadow(0 0 15px var(--color-secondary));\n      transition: fill-opacity 0.5s ease;\n    }\n\n    /* Legend */\n    .legend {\n      max-width: 300px;\n      margin: 2rem auto 0;\n      background: #2a2c45dd;\n      border-radius: 14px;\n      box-shadow:\n        0 12px 24px rgba(0,0,0,0.7),\n        inset 0 0 10px #3a3f5cbb;\n      padding: 18px 22px;\n      color: var(--color-text-secondary);\n      user-select: none;\n      font-weight: 300;\n      font-size: 0.95rem;\n      letter-spacing: 0.05em;\n      line-height: 1.47;\n    }\n    .legend strong {\n      color: var(--color-text-primary);\n      font-weight: 600;\n    }\n    .legend .dot {\n      display: inline-block;\n      width: 16px;\n      height: 16px;\n      border-radius: 50%;\n      margin-right: 10px;\n      vertical-align: middle;\n      box-shadow: 0 0 8px rgba(0,0,0,0.12);\n    }\n    .dot-green {\n      background: var(--color-primary);\n      box-shadow: 0 0 10px var(--color-primary);\n    }\n    .dot-blue {\n      background: var(--color-secondary);\n      box-shadow: 0 0 10px var(--color-secondary);\n    }\n    .dot-amber {\n      background: var(--color-accent);\n      box-shadow: 0 0 10px var(--color-accent);\n    }\n\n    /* Tooltip */\n    #tooltip {\n      position: fixed;\n      pointer-events: none;\n      background: #31344a;\n      border-radius: 10px;\n      padding: 8px 16px;\n      font-size: 0.8rem;\n      color: var(--color-accent);\n      font-weight: 600;\n      letter-spacing: 0.05em;\n      box-shadow: 0 5px 15px rgba(0,0,0,0.25);\n      opacity: 0;\n      transition: opacity 0.3s ease;\n      z-index: 10;\n      user-select: none;\n      white-space: nowrap;\n    }\n\n    /* FOOTER */\n    footer {\n      font-size: 0.82rem;\n      text-align: center;\n      color: var(--color-text-secondary);\n      font-weight: 300;\n      letter-spacing: 0.1em;\n      margin-bottom: 1.2rem;\n      user-select: none;\n      mix-blend-mode: difference;\n      opacity: 0.2;\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\" aria-label=\"Random Forest Visualization\">\n    <header>\n      <h1>R A N D O M &nbsp; F O R E S T</h1>\n      <p>Visualizing the ensemble magic of decision trees</p>\n    </header>\n\n    <svg id=\"forest\" viewBox=\"0 0 900 600\" aria-hidden=\"true\" focusable=\"false\" role=\"img\" >\n      <!-- Random Forest: Multiple Trees with Canopies and Roots -->\n\n      <!-- Tree 1 -->\n      <g class=\"tree\" transform=\"translate(180,540)\">\n        <line class=\"trunk\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"-125\" />\n        <circle class=\"canopy\" cx=\"0\" cy=\"-140\" r=\"52\" />\n        <!-- Leaves -->\n        <circle class=\"leaf leaf-green sway\" cx=\"-20\" cy=\"-170\" r=\"10\" />\n        <circle class=\"leaf leaf-amber\" cx=\"0\" cy=\"-190\" r=\"12\" />\n        <circle class=\"leaf leaf-blue sway-delayed\" cx=\"18\" cy=\"-168\" r=\"10\" />\n        <circle class=\"leaf leaf-green\" cx=\"34\" cy=\"-152\" r=\"8\" />\n        <circle class=\"leaf leaf-blue sway\" cx=\"-24\" cy=\"-134\" r=\"9\" />\n      </g>\n\n      <!-- Tree 2 -->\n      <g class=\"tree\" transform=\"translate(440,560)\">\n        <line class=\"trunk\" x1=\"0\" y1=\"0\" x2=\"5\" y2=\"-150\" />\n        <circle class=\"canopy\" cx=\"7\" cy=\"-165\" r=\"60\" />\n        <!-- Leaves -->\n        <circle class=\"leaf leaf-green\" cx=\"-30\" cy=\"-200\" r=\"11\" />\n        <circle class=\"leaf leaf-blue sway\" cx=\"-15\" cy=\"-180\" r=\"13\" />\n        <circle class=\"leaf leaf-amber sway-delayed\" cx=\"10\" cy=\"-212\" r=\"10\" />\n        <circle class=\"leaf leaf-green sway\" cx=\"30\" cy=\"-190\" r=\"9\" />\n        <circle class=\"leaf leaf-amber\" cx=\"42\" cy=\"-165\" r=\"8\" />\n      </g>\n\n      <!-- Tree 3 -->\n      <g class=\"tree\" transform=\"translate(700,540)\">\n        <line class=\"trunk\" x1=\"0\" y1=\"0\" x2=\"-2\" y2=\"-120\" />\n        <circle class=\"canopy\" cx=\"-5\" cy=\"-135\" r=\"55\" />\n        <!-- Leaves -->\n        <circle class=\"leaf leaf-amber\" cx=\"-33\" cy=\"-150\" r=\"10\" />\n        <circle class=\"leaf leaf-blue sway\" cx=\"-12\" cy=\"-175\" r=\"12\" />\n        <circle class=\"leaf leaf-green sway-delayed\" cx=\"15\" cy=\"-190\" r=\"11\" />\n        <circle class=\"leaf leaf-blue\" cx=\"32\" cy=\"-165\" r=\"9\" />\n        <circle class=\"leaf leaf-amber sway\" cx=\"40\" cy=\"-140\" r=\"8\" />\n      </g>\n\n      <!-- Roots & Baseline -->\n      <line x1=\"0\" y1=\"540\" x2=\"900\" y2=\"540\" stroke=\"#2d3050\" stroke-width=\"8\" filter=\"drop-shadow(0 2px 5px rgba(0,0,0,0.6))\" />\n      <line x1=\"200\" y1=\"540\" x2=\"200\" y2=\"565\" stroke=\"#3e445f\" stroke-width=\"5\" />\n      <line x1=\"445\" y1=\"560\" x2=\"445\" y2=\"580\" stroke=\"#3e445f\" stroke-width=\"5\" />\n      <line x1=\"698\" y1=\"540\" x2=\"698\" y2=\"565\" stroke=\"#3e445f\" stroke-width=\"5\" />\n    </svg>\n\n    <div class=\"container\" style=\"max-width: 470px; margin-top: -2.5rem;\">\n      <button id=\"highlightBtn\" class=\"btn\" aria-pressed=\"false\" aria-label=\"Toggle Highlight on Trees\">\n        🌲 Highlight Trees\n      </button>\n    </div>\n\n    <section class=\"legend\" aria-label=\"Random Forest legend\">\n      <p><span class=\"dot dot-green\"></span><strong>Green Leaves</strong> — Individual tree decisions</p>\n      <p><span class=\"dot dot-blue\"></span><strong>Blue Leaves</strong> — Ensemble consensus</p>\n      <p><span class=\"dot dot-amber\"></span><strong>Amber Leaves</strong> — Randomness & feature diversity</p>\n      <p style=\"margin-top:12px; font-style: italic; font-weight: 300;\">The trunks symbolize each decision tree, growing independently. The combined canopy represents the random forest's collective wisdom.</p>\n    </section>\n\n  </div>\n\n  <footer>\n    Concept &amp; Design &mdash; Random Forest Visualization &mdash; &copy; 2024\n  </footer>\n\n  <script>\n    // Extremely limited interactivity: highlight toggling trunks and canopy brighten\n    (() => {\n      const button = document.getElementById('highlightBtn');\n      const trunks = document.querySelectorAll('.trunk');\n      const canopies = document.querySelectorAll('.canopy');\n      let highlighted = false;\n\n      button.addEventListener('click', () => {\n        highlighted = !highlighted;\n\n        trunks.forEach(trunk => {\n          trunk.classList.toggle('highlight', highlighted);\n        });\n        canopies.forEach(canopy => {\n          canopy.style.fillOpacity = highlighted ? '0.75' : '0.4';\n          canopy.style.filter = highlighted ? 'drop-shadow(0 0 25px var(--color-primary))' : 'drop-shadow(0 0 15px var(--color-secondary))';\n        });\n\n        button.setAttribute('aria-pressed', highlighted.toString());\n        button.textContent = highlighted ? '🌲 Trees Highlighted' : '🌲 Highlight Trees';\n      });\n    })();\n  </script>\n</body>\n</html>"
