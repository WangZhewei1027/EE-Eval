    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Max Heap Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #2c3e50;\n            color: #ecf0f1;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 20px;\n            text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.7);\n        }\n\n        #heap-container {\n            position: relative;\n            margin: 20px 0;\n            width: 300px;\n            height: 300px;\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n        }\n\n        .heap-node {\n            width: 40px;\n            height: 40px;\n            background-color: #e74c3c;\n            border-radius: 20px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.2em;\n            position: absolute;\n            transition: transform 0.3s ease;\n        }\n\n        #controls {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        button {\n            padding: 10px 20px;\n            background-color: #3498db;\n            border: none;\n            border-radius: 5px;\n            color: white;\n            font-size: 1em;\n            cursor: pointer;\n            transition: background-color 0.3s;\n            margin: 5px 0;\n        }\n\n        button:hover {\n            background-color: #2980b9;\n        }\n    </style>\n</head>\n\n<body>\n    <h1>Max Heap Visualization</h1>\n    <div id=\"heap-container\"></div>\n    <div id=\"controls\">\n        <button onclick=\"startHeap()\">Start</button>\n        <button onclick=\"resetHeap()\">Reset</button>\n    </div>\n\n    <script>\n        const heapContainer = document.getElementById('heap-container');\n        let heap = [30, 20, 25, 15, 10, 5];\n\n        function clearHeap() {\n            heapContainer.innerHTML = '';\n        }\n\n        function displayHeap() {\n            clearHeap();\n            const positions = getPositions(heap.length);\n            heap.forEach((value, index) => {\n                const node = document.createElement('div');\n                node.className = 'heap-node';\n                node.innerText = value;\n                const { top, left } = positions[index];\n                node.style.transform = `translate(${left}px, ${top}px)`;\n                heapContainer.appendChild(node);\n            });\n        }\n\n        function getPositions(count) {\n            const positions = [];\n            const levels = Math.ceil(Math.log2(count + 1));\n            const spacing = 80; // space between nodes\n            for (let level = 0; level < levels; level++) {\n                const nodesInLevel = Math.pow(2, level);\n                for (let i = 0; i < nodesInLevel && (i + Math.pow(2, level) - 1) < count; i++) {\n                    const x = (i - nodesInLevel / 2 + 0.5) * spacing * (levels - level);\n                    const y = -level * spacing;\n                    positions.push({ top: y, left: x });\n                }\n            }\n            return positions;\n        }\n\n        function startHeap() {\n            displayHeap();\n        }\n\n        function resetHeap() {\n            heap = [30, 20, 25, 15, 10, 5];\n            displayHeap();\n        }\n    </script>\n</body>\n\n</html>"
