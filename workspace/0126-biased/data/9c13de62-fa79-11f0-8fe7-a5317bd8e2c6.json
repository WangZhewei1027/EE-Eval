    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Quick Sort Interactive Simulator</title>\n  <style>\n    /* Minimal plain styling only to keep layout readable. No colors, no animations. */\n    html,body { font-family: monospace; margin: 10px; padding: 0; }\n    .row { display: block; margin-bottom: 8px; }\n    label { margin-right: 6px; }\n    input[type=\"text\"], input[type=\"number\"], select { width: 160px; }\n    button { margin-right: 6px; }\n    pre { background: none; border: 1px solid #000; padding: 6px; white-space: pre-wrap; }\n    .pane { display: inline-block; vertical-align: top; margin-right: 10px; }\n    .pane small { display:block; margin-top:4px; }\n    .array-item { display:inline-block; padding:2px 6px; margin-right:4px; border:1px solid #000; }\n    .control-group { border: 1px solid #000; padding:8px; margin-bottom:8px; }\n    .list { max-height: 300px; overflow:auto; border:1px solid #000; padding:6px; }\n    .btn-small { padding:2px 6px; }\n  </style>\n</head>\n<body>\n  <h2>Quick Sort Interactive Simulator</h2>\n\n  <div class=\"control-group\">\n    <div class=\"row\">\n      <label>Array (comma separated):</label>\n      <input id=\"arrayInput\" type=\"text\" value=\"8,3,7,1,9,2,5,4,6\">\n      <button id=\"applyArray\">Apply</button>\n      <button id=\"shuffleArray\">Shuffle</button>\n      <button id=\"randomArray\">Random</button>\n      <label>Size:</label><input id=\"randSize\" type=\"number\" value=\"10\" min=\"1\" style=\"width:60px\">\n      <label>Min:</label><input id=\"randMin\" type=\"number\" value=\"1\" style=\"width:60px\">\n      <label>Max:</label><input id=\"randMax\" type=\"number\" value=\"20\" style=\"width:60px\">\n    </div>\n\n    <div class=\"row\">\n      <label>Partition scheme:</label>\n      <select id=\"partitionScheme\">\n        <option value=\"lomuto\">Lomuto</option>\n        <option value=\"hoare\">Hoare</option>\n      </select>\n\n      <label>Pivot strategy:</label>\n      <select id=\"pivotStrategy\">\n        <option value=\"last\">Last element</option>\n        <option value=\"first\">First element</option>\n        <option value=\"middle\">Middle element</option>\n        <option value=\"random\">Random</option>\n        <option value=\"median3\">Median of three</option>\n        <option value=\"manual\">Manual (click to set)</option>\n      </select>\n\n      <label>Order:</label>\n      <select id=\"order\">\n        <option value=\"asc\">Ascending</option>\n        <option value=\"desc\">Descending</option>\n      </select>\n\n      <label>Break on depth >=</label>\n      <input id=\"breakDepth\" type=\"number\" value=\"999\" style=\"width:60px\">\n    </div>\n\n    <div class=\"row\">\n      <button id=\"startBtn\">Start Sort</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"backBtn\">Step Back</button>\n      <button id=\"runPartitionBtn\">Run Current Partition</button>\n      <button id=\"runRecursionBtn\">Finish Current Recursion</button>\n      <button id=\"fastForwardBtn\">Run To End</button>\n      <label>Speed (ms):</label><input id=\"speed\" type=\"range\" min=\"10\" max=\"2000\" value=\"300\">\n      <span id=\"speedVal\">300</span>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"undoBtn\">Undo (history back)</button>\n      <button id=\"redoBtn\">Redo (history forward)</button>\n      <button id=\"exportBtn\">Export State</button>\n      <button id=\"importBtn\">Import State</button>\n      <input id=\"importArea\" type=\"text\" placeholder=\"Paste JSON here\" style=\"width:360px\">\n    </div>\n\n    <div class=\"row\">\n      <label>Manual swap indices (i,j):</label>\n      <input id=\"swapI\" type=\"number\" style=\"width:60px\">\n      <input id=\"swapJ\" type=\"number\" style=\"width:60px\">\n      <button id=\"manualSwapBtn\">Swap</button>\n      <label>Set element at idx to value:</label>\n      <input id=\"setIdx\" type=\"number\" style=\"width:60px\">\n      <input id=\"setVal\" type=\"number\" style=\"width:80px\">\n      <button id=\"setValBtn\">Set</button>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"compareStrategiesBtn\">Compare Strategies</button>\n      <label>Compare with:</label>\n      <select id=\"compareStrategy\">\n        <option value=\"median3\">Median of three</option>\n        <option value=\"random\">Random</option>\n        <option value=\"first\">First</option>\n        <option value=\"last\">Last</option>\n      </select>\n      <button id=\"resetAllBtn\">Reset All</button>\n    </div>\n  </div>\n\n  <div class=\"row\">\n    <div class=\"pane\" style=\"width:60%;\">\n      <div><strong>Array view (click an element when pivot strategy = Manual to choose pivot):</strong></div>\n      <div id=\"arrayView\" style=\"min-height:40px; margin-top:6px;\"></div>\n      <small>Markers: [p]=pivot index; < = left pointer; > = right pointer; * = compared; S = sorted element</small>\n    </div>\n\n    <div class=\"pane\" style=\"width:35%;\">\n      <div><strong>Call stack / Segments</strong></div>\n      <div id=\"stackView\" class=\"list\" style=\"width:320px\"></div>\n      <div style=\"margin-top:8px\"><strong>Stats</strong></div>\n      <div id=\"statsView\"></div>\n    </div>\n  </div>\n\n  <div class=\"row\">\n    <div style=\"width:49%; display:inline-block; vertical-align:top;\">\n      <div><strong>History (click to jump)</strong></div>\n      <div id=\"historyView\" class=\"list\" style=\"width:100%;\"></div>\n    </div>\n\n    <div style=\"width:49%; display:inline-block; vertical-align:top;\">\n      <div><strong>Log / Operations</strong></div>\n      <div id=\"logView\" class=\"list\" style=\"width:100%;\"></div>\n    </div>\n  </div>\n\n  <script>\n    // Quick Sort Interactive Simulator\n    (function(){\n      // Utilities\n      function cloneArr(a){ return a.slice(); }\n      function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }\n      function parseArrayText(txt){\n        const items = txt.split(',').map(s=>s.trim()).filter(s=>s.length);\n        const nums = items.map(s=>Number(s));\n        if (nums.some(n=>Number.isNaN(n))) return null;\n        return nums;\n      }\n\n      // DOM refs\n      const arrayInput = document.getElementById('arrayInput');\n      const applyArrayBtn = document.getElementById('applyArray');\n      const shuffleArrayBtn = document.getElementById('shuffleArray');\n      const randomArrayBtn = document.getElementById('randomArray');\n      const randSize = document.getElementById('randSize');\n      const randMin = document.getElementById('randMin');\n      const randMax = document.getElementById('randMax');\n\n      const partitionSchemeSel = document.getElementById('partitionScheme');\n      const pivotStrategySel = document.getElementById('pivotStrategy');\n      const orderSel = document.getElementById('order');\n\n      const startBtn = document.getElementById('startBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const backBtn = document.getElementById('backBtn');\n      const runPartitionBtn = document.getElementById('runPartitionBtn');\n      const runRecursionBtn = document.getElementById('runRecursionBtn');\n      const fastForwardBtn = document.getElementById('fastForwardBtn');\n      const speed = document.getElementById('speed');\n      const speedVal = document.getElementById('speedVal');\n\n      const breakDepthInput = document.getElementById('breakDepth');\n\n      const arrayView = document.getElementById('arrayView');\n      const stackView = document.getElementById('stackView');\n      const historyView = document.getElementById('historyView');\n      const logView = document.getElementById('logView');\n      const statsView = document.getElementById('statsView');\n\n      const undoBtn = document.getElementById('undoBtn');\n      const redoBtn = document.getElementById('redoBtn');\n      const exportBtn = document.getElementById('exportBtn');\n      const importBtn = document.getElementById('importBtn');\n      const importArea = document.getElementById('importArea');\n\n      const swapI = document.getElementById('swapI');\n      const swapJ = document.getElementById('swapJ');\n      const manualSwapBtn = document.getElementById('manualSwapBtn');\n      const setIdx = document.getElementById('setIdx');\n      const setVal = document.getElementById('setVal');\n      const setValBtn = document.getElementById('setValBtn');\n\n      const compareStrategiesBtn = document.getElementById('compareStrategiesBtn');\n      const compareStrategySel = document.getElementById('compareStrategy');\n      const resetAllBtn = document.getElementById('resetAllBtn');\n\n      // State\n      let baseArray = parseArrayText(arrayInput.value) || [8,3,7,1,9,2,5,4,6];\n      let currentStateIndex = 0;\n      let history = []; // array of state objects\n      let branches = {}; // branchId => list of states (ids)\n      let branchCounter = 1;\n      let running = false;\n      let paused = false;\n      let autoTimer = null;\n      let genController = null; // object controlling generator and resume values\n      let redoStack = [];\n\n      // Stats accumulation for current \"run\" (per branch)\n      function makeInitialState(arr){\n        return {\n          arr: cloneArr(arr),\n          pointers: {i:null,j:null,pivot:null,low:null,high:null},\n          op: 'init',\n          desc: 'Initial array',\n          stack: [],\n          stats: {swaps:0,comps:0,calls:0,maxDepth:0},\n          timestamp: Date.now(),\n          branchId: 0,\n          parent: null,\n          id: history.length\n        };\n      }\n\n      // Initialize history\n      function resetHistory(arr){\n        history = [];\n        branches = {};\n        branchCounter = 1;\n        const s = makeInitialState(arr);\n        s.branchId = 0;\n        branches[0] = [0];\n        history.push(s);\n        currentStateIndex = 0;\n        redoStack = [];\n        genController = null;\n        running = false;\n        paused = false;\n        updateViews();\n      }\n\n      // Render array view with markers\n      function renderArrayView(state){\n        arrayView.innerHTML = '';\n        const arr = state.arr;\n        const p = state.pointers;\n        for (let idx=0; idx<arr.length; idx++){\n          const span = document.createElement('span');\n          span.className = 'array-item';\n          span.dataset.index = idx;\n          let label = String(arr[idx]);\n          let markers = [];\n          if (p.pivot === idx) markers.push('[p]');\n          if (p.i === idx) markers.push('<');\n          if (p.j === idx) markers.push('>');\n          if (p.compared && p.compared.indexOf(idx)!==-1) markers.push('*');\n          if (p.sortedRange && p.sortedRange.includes(idx)) markers.push('S');\n          if (markers.length) label += ' ' + markers.join('');\n          span.textContent = label;\n          span.onclick = onArrayItemClick;\n          arrayView.appendChild(span);\n        }\n      }\n\n      function renderStackView(state){\n        stackView.innerHTML = '';\n        const s = state.stack || [];\n        if (!s.length) stackView.textContent = '(empty)';\n        else {\n          s.slice().reverse().forEach((seg, idx)=>{\n            const div = document.createElement('div');\n            div.textContent = 'depth ' + (s.length-idx) + ': [' + seg.lo + ',' + seg.hi + '] ' + (seg.note || '');\n            stackView.appendChild(div);\n          });\n        }\n      }\n\n      function renderStats(state){\n        const st = state.stats || {};\n        statsView.innerHTML = '';\n        statsView.appendChild(document.createTextNode('Comparisons: ' + (st.comps||0)));\n        statsView.appendChild(document.createElement('br'));\n        statsView.appendChild(document.createTextNode('Swaps: ' + (st.swaps||0)));\n        statsView.appendChild(document.createElement('br'));\n        statsView.appendChild(document.createTextNode('Calls: ' + (st.calls||0)));\n        statsView.appendChild(document.createElement('br'));\n        statsView.appendChild(document.createTextNode('Max depth seen: ' + (st.maxDepth||0)));\n      }\n\n      function renderHistory(){\n        historyView.innerHTML = '';\n        history.forEach((st, idx)=>{\n          const div = document.createElement('div');\n          div.textContent = idx + ': ' + st.op + ' | ' + st.desc;\n          div.style.cursor = 'pointer';\n          if (idx === currentStateIndex) div.textContent = '* ' + div.textContent;\n          div.onclick = ()=>{ jumpToState(idx); };\n          historyView.appendChild(div);\n        });\n      }\n\n      function log(msg){\n        const d = document.createElement('div');\n        d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + msg;\n        logView.insertBefore(d, logView.firstChild);\n      }\n\n      function updateViews(){\n        const state = history[currentStateIndex];\n        renderArrayView(state);\n        renderStackView(state);\n        renderStats(state);\n        renderHistory();\n      }\n\n      // Manage history snapshots, branching\n      function pushState(state){\n        // state is snapshot-like (we will clone to freeze)\n        const s = {\n          arr: cloneArr(state.arr),\n          pointers: JSON.parse(JSON.stringify(state.pointers || {})),\n          op: state.op || 'op',\n          desc: state.desc || '',\n          stack: JSON.parse(JSON.stringify(state.stack || [])),\n          stats: JSON.parse(JSON.stringify(state.stats || {})),\n          timestamp: Date.now(),\n          parent: currentStateIndex,\n          branchId: state.branchId !== undefined ? state.branchId : (history[currentStateIndex] ? history[currentStateIndex].branchId : 0),\n          id: history.length\n        };\n\n        // If we're not at the tip of history (currentStateIndex !== last), we create a branch\n        if (currentStateIndex !== history.length - 1){\n          s.parent = currentStateIndex;\n          s.branchId = branchCounter++;\n          branches[s.branchId] = [];\n          log('Created new branch ' + s.branchId + ' from state ' + s.parent);\n        }\n\n        history.push(s);\n        currentStateIndex = history.length - 1;\n        if (!branches[s.branchId]) branches[s.branchId] = [];\n        branches[s.branchId].push(s.id);\n        redoStack = [];\n        updateViews();\n      }\n\n      function jumpToState(idx){\n        if (idx < 0 || idx >= history.length) return;\n        currentStateIndex = idx;\n        updateViews();\n      }\n\n      function stepBack(){\n        if (currentStateIndex > 0){\n          currentStateIndex--;\n          updateViews();\n        }\n      }\n\n      // Export/Import\n      function exportState(){\n        const data = {history: history, current: currentStateIndex, branches: branches};\n        return JSON.stringify(data);\n      }\n      function importState(json){\n        try {\n          const parsed = JSON.parse(json);\n          if (!parsed.history) throw 'Invalid JSON';\n          history = parsed.history;\n          currentStateIndex = parsed.current || 0;\n          branches = parsed.branches || {};\n          updateViews();\n        } catch(e){\n          alert('Import failed: ' + e);\n        }\n      }\n\n      // QuickSort operation generator\n      // We yield operation objects. Controller will act, push states, and can resume generator with value for manual pivot.\n      function* quicksortGenerator(arr, options){\n        // options: partition: 'lomuto'|'hoare', pivotStrategy, order asc|desc, breakDepth int\n        // We'll implement iterative stack controlling recursion depth explicitly for clearer visuals.\n        const a = arr;\n        const n = a.length;\n        const stats = {swaps:0, comps:0, calls:0, maxDepth:0};\n        // stack frames: {lo,hi,stage,depth}\n        let stack = [];\n        stack.push({lo:0, hi:n-1, stage:'enter', depth:1});\n        while (stack.length){\n          const frame = stack.pop();\n          stats.calls++;\n          stats.maxDepth = Math.max(stats.maxDepth, frame.depth);\n          // update display: entering a call\n          yield {op:'callEnter', desc:'Enter ['+frame.lo+','+frame.hi+']', stack: stack.concat([frame]), stats: {...stats}, pointers:{low:frame.lo, high:frame.hi}};\n          if (frame.lo >= frame.hi){\n            // nothing to sort\n            // mark as sorted range\n            yield {op:'doneSegment', desc:'Range ['+frame.lo+','+frame.hi+'] sorted (base case)', stack: stack.concat([frame]), stats:{...stats}, pointers:{low:frame.lo, high:frame.hi, sortedRange:range(frame.lo, frame.hi)}};\n            continue;\n          }\n\n          // Breakpoint by depth\n          if (frame.depth >= (options.breakDepth||9999)){\n            yield {op:'breakpoint', desc:'Breakpoint at depth ' + frame.depth, stack: stack.concat([frame]), stats:{...stats}, pointers:{low:frame.lo, high:frame.hi}, control:'await'};\n            // controller can decide to continue or modify options\n          }\n\n          // Choose pivot index based on strategy. If 'manual' and controller returns an index, support that via next(value).\n          let pivotIndex = choosePivot(a, frame.lo, frame.hi, options.pivotStrategy);\n          if (options.pivotStrategy === 'manual'){\n            // Ask controller for manual pivot\n            const manual = yield {op:'awaitPivot', desc:'Await manual pivot for ['+frame.lo+','+frame.hi+']', stack: stack.concat([frame]), stats:{...stats}, pointers:{low:frame.lo, high:frame.hi}};\n            if (typeof manual === 'number' && manual >= frame.lo && manual <= frame.hi){\n              pivotIndex = manual;\n            } else {\n              pivotIndex = Math.max(frame.lo, Math.min(frame.hi, Math.floor((frame.lo+frame.hi)/2)));\n            }\n          }\n\n          yield {op:'selectPivot', desc:'Selected pivot index ' + pivotIndex + ' value ' + String(a[pivotIndex]), stack: stack.concat([frame]), stats:{...stats}, pointers:{pivot:pivotIndex, low:frame.lo, high:frame.hi}};\n\n          // Partition using chosen scheme\n          if (options.partition === 'lomuto'){\n            // Move pivot to end\n            if (pivotIndex !== frame.hi){\n              swap(a, pivotIndex, frame.hi);\n              stats.swaps++;\n              yield {op:'swap', desc:'Swap pivot into end: '+pivotIndex+'<->'+frame.hi, stack: stack.concat([frame]), stats:{...stats}, pointers:{i:pivotIndex, j:frame.hi}};\n              pivotIndex = frame.hi;\n            }\n            // Lomuto partition\n            let store = frame.lo;\n            for (let k = frame.lo; k < frame.hi; k++){\n              stats.comps++;\n              yield {op:'compare', desc:'Compare a['+k+'] vs pivot', stack: stack.concat([frame]), stats:{...stats}, pointers:{i:k, pivot:pivotIndex, low:frame.lo, high:frame.hi}, compared:[k,pivotIndex]};\n              let cond = options.order === 'asc' ? a[k] < a[pivotIndex] : a[k] > a[pivotIndex];\n              if (cond){\n                if (k !== store){\n                  swap(a, k, store);\n                  stats.swaps++;\n                  yield {op:'swap', desc:'Swap '+k+' <-> '+store, stack: stack.concat([frame]), stats:{...stats}, pointers:{i:k, j:store}};\n                } else {\n                  yield {op:'nop', desc:'No-op swap at '+k, stack: stack.concat([frame]), stats:{...stats}, pointers:{i:k}};\n                }\n                store++;\n              }\n            }\n            // final swap pivot to correct position\n            if (store !== frame.hi){\n              swap(a, store, frame.hi);\n              stats.swaps++;\n              yield {op:'swap', desc:'Place pivot at index '+store+' (swap '+store+'<->'+frame.hi+')', stack: stack.concat([frame]), stats:{...stats}, pointers:{i:store, j:frame.hi}};\n            } else {\n              yield {op:'nop', desc:'Pivot already in place at '+store, stack: stack.concat([frame]), stats:{...stats}, pointers:{i:store}};\n            }\n            // After partition complete\n            const pivotPos = store;\n            yield {op:'partition', desc:'Partition finished at '+pivotPos, stack: stack.concat([frame]), stats:{...stats}, pointers:{pivot:pivotPos, low:frame.lo, high:frame.hi}, sortedRange:range(frame.lo,frame.hi)};\n            // push right and left segments\n            // push larger segment first to keep stack size smaller if we wanted to emulate tail call optimization (not necessary)\n            const leftLen = pivotPos - frame.lo;\n            const rightLen = frame.hi - pivotPos;\n            // push bigger first so smaller processed next (to keep depth smaller)\n            if (leftLen < rightLen){\n              if (pivotPos+1 < frame.hi) stack.push({lo:pivotPos+1, hi:frame.hi, stage:'enter', depth:frame.depth+1});\n              if (frame.lo < pivotPos-1) stack.push({lo:frame.lo, hi:pivotPos-1, stage:'enter', depth:frame.depth+1});\n            } else {\n              if (frame.lo < pivotPos-1) stack.push({lo:frame.lo, hi:pivotPos-1, stage:'enter', depth:frame.depth+1});\n              if (pivotPos+1 < frame.hi) stack.push({lo:pivotPos+1, hi:frame.hi, stage:'enter', depth:frame.depth+1});\n            }\n          } else { // hoare\n            // choose pivot value and set two indices\n            const pv = a[pivotIndex];\n            yield {op:'pivotValue', desc:'Hoare pivot value ' + pv, stack: stack.concat([frame]), stats:{...stats}, pointers:{pivot:pivotIndex, low:frame.lo, high:frame.hi}};\n            let i = frame.lo - 1;\n            let j = frame.hi + 1;\n            while (true){\n              do {\n                i++;\n                stats.comps++;\n                yield {op:'compare', desc:'Compare a['+i+'] with pivot', stack: stack.concat([frame]), stats:{...stats}, pointers:{i:i, pivot:pivotIndex}, compared:[i,pivotIndex]};\n              } while ( (options.order==='asc') ? a[i] < pv : a[i] > pv );\n              do {\n                j--;\n                stats.comps++;\n                yield {op:'compare', desc:'Compare a['+j+'] with pivot', stack: stack.concat([frame]), stats:{...stats}, pointers:{j:j, pivot:pivotIndex}, compared:[j,pivotIndex]};\n              } while ( (options.order==='asc') ? a[j] > pv : a[j] < pv );\n              if (i >= j){\n                yield {op:'partition', desc:'Hoare partition returned j='+j, stack: stack.concat([frame]), stats:{...stats}, pointers:{i:i,j:j}};\n                // push subranges\n                if (frame.lo < j) stack.push({lo:frame.lo, hi:j, stage:'enter', depth:frame.depth+1});\n                if (j+1 < frame.hi) stack.push({lo:j+1, hi:frame.hi, stage:'enter', depth:frame.depth+1});\n                break;\n              }\n              swap(a,i,j);\n              stats.swaps++;\n              yield {op:'swap', desc:'Swap '+i+' <-> '+j, stack: stack.concat([frame]), stats:{...stats}, pointers:{i:i,j:j}};\n            }\n          }\n        }\n        // finished\n        yield {op:'done', desc:'Array fully sorted', stack:[], stats:{...stats}, pointers:{}, final:true};\n      }\n\n      // Helpers for generator\n      function range(lo,hi){\n        const arr = [];\n        for (let i=lo;i<=hi;i++) arr.push(i);\n        return arr;\n      }\n      function swap(a,i,j){\n        const tmp = a[i];\n        a[i] = a[j];\n        a[j] = tmp;\n      }\n      function choosePivot(a, lo, hi, strategy){\n        if (strategy === 'last') return hi;\n        if (strategy === 'first') return lo;\n        if (strategy === 'middle') return Math.floor((lo+hi)/2);\n        if (strategy === 'random') return randInt(lo,hi);\n        if (strategy === 'median3'){\n          const mid = Math.floor((lo+hi)/2);\n          const trio = [[a[lo],lo],[a[mid],mid],[a[hi],hi]];\n          trio.sort((x,y)=> (x[0]-y[0]));\n          return trio[1][1];\n        }\n        if (strategy === 'manual') return Math.floor((lo+hi)/2);\n        return hi;\n      }\n\n      // Controller to run generator and integrate with UI/history\n      function startSortController(){\n        if (genController) {\n          // already running sorts; ignore or restart?\n          log('A sort is already active. Pause and reset to start new.');\n          return;\n        }\n        // Use current array as starting point of run\n        const startState = history[currentStateIndex];\n        const arrCopy = cloneArr(startState.arr);\n        const options = {\n          partition: partitionSchemeSel.value,\n          pivotStrategy: pivotStrategySel.value,\n          order: orderSel.value,\n          breakDepth: Number(breakDepthInput.value) || 9999\n        };\n        const gen = quicksortGenerator(arrCopy, options);\n        genController = {gen:gen, arr:arrCopy, options:options, lastYield:null};\n        running = true; paused = false;\n        log('Started sort with options: ' + JSON.stringify(options));\n        // Create a run root state tying to parent current\n        const base = {\n          arr: arrCopy,\n          pointers: {},\n          op: 'runStart',\n          desc: 'Start run',\n          stack: [],\n          stats: {swaps:0,comps:0,calls:0,maxDepth:0},\n          branchId: history[currentStateIndex].branchId\n        };\n        pushState(base);\n        proceedGenerator(); // step once to process until first yield\n      }\n\n      function proceedGenerator(resumeValue){\n        if (!genController) return;\n        const {gen} = genController;\n        let step;\n        try {\n          step = gen.next(resumeValue);\n        } catch (e){\n          log('Generator error: ' + e);\n          genController = null;\n          running = false;\n          paused = false;\n          return;\n        }\n        if (step.done){\n          // final state\n          const final = {arr: genController.arr, pointers:{}, op: step.value && step.value.op ? step.value.op : 'done', desc: step.value && step.value.desc ? step.value.desc : 'Finished', stack:[], stats: step.value && step.value.stats ? step.value.stats : {}};\n          pushState(final);\n          log('Sort finished.');\n          genController = null;\n          running = false;\n          paused = false;\n          return;\n        } else {\n          const op = step.value;\n          // Apply the op to genController.arr if it modified directly (generator already mutated arr)\n          const snapshot = {\n            arr: genController.arr,\n            pointers: op.pointers || {},\n            op: op.op || 'op',\n            desc: op.desc || '',\n            stack: op.stack || [],\n            stats: op.stats || {},\n            branchId: history[currentStateIndex].branchId\n          };\n          pushState(snapshot);\n          log('Op: ' + snapshot.op + ' - ' + snapshot.desc);\n          genController.lastYield = op;\n\n          // Special control messages: awaitPivot or breakpoint\n          if (op.op === 'awaitPivot' || op.op === 'breakpoint'){\n            paused = true;\n            running = false;\n            log('Paused at ' + op.op + ': ' + op.desc);\n            return;\n          }\n\n          // If not paused, and running, schedule auto next step\n          if (!paused && running){\n            scheduleAutoStep();\n          }\n        }\n      }\n\n      // Auto step scheduling\n      function scheduleAutoStep(){\n        clearTimeout(autoTimer);\n        const delay = Number(speed.value) || 300;\n        autoTimer = setTimeout(()=>{ proceedGenerator(); }, delay);\n      }\n\n      // Pause, resume functions\n      function pauseSort(){\n        paused = true;\n        running = false;\n        clearTimeout(autoTimer);\n        log('Paused.');\n      }\n      function resumeSort(){\n        if (!genController){\n          log('No active sort to resume.');\n          return;\n        }\n        paused = false;\n        running = true;\n        log('Resuming sort...');\n        scheduleAutoStep();\n      }\n\n      // Step execution: single step from generator\n      function stepOnce(){\n        if (!genController){\n          // user can create a new sort implicitly via step?\n          startSortController();\n          return;\n        }\n        if (paused) { paused = false; proceedGenerator(); paused = true; } else {\n          proceedGenerator();\n        }\n      }\n\n      // Step back handled by history-based approach (no need to manipulate generator)\n      // If user steps back and then steps forward while generator exists, we'll resume from generator's internal state (not aligned). So we disallow stepping back while active generator exists.\n      function safeStepBack(){\n        if (genController){\n          // Cancel generator to avoid mismatch\n          const ok = confirm('Stepping back will cancel the active run. Proceed?');\n          if (!ok) return;\n          genController = null;\n          running = false;\n          paused = false;\n        }\n        stepBack();\n      }\n\n      // Run partition: we finish until next partition op completes\n      function runPartition(){\n        if (!genController){\n          startSortController();\n          return;\n        }\n        paused = false;\n        running = true;\n        function loop(){\n          if (!genController) return;\n          const last = genController.lastYield;\n          proceedGenerator();\n          const nextLast = genController && genController.lastYield ? genController.lastYield.op : null;\n          if (!genController) return;\n          if (nextLast !== 'partition' && nextLast !== 'done' && nextLast !== 'doneSegment'){\n            // continue\n            setTimeout(loop, 10);\n          } else {\n            paused = true; running = false;\n            log('Partition completed and paused.');\n          }\n        }\n        loop();\n      }\n\n      // Finish current recursion call: run until callExit or return to parent (we detect callEnter/callExit by stack length changes)\n      function runRecursion(){\n        if (!genController){\n          startSortController();\n          return;\n        }\n        paused = false;\n        running = true;\n        let initialDepth = (genController.lastYield && genController.lastYield.stack) ? genController.lastYield.stack.length : 0;\n        function loop(){\n          if (!genController) return;\n          proceedGenerator();\n          if (!genController) return;\n          const curDepth = genController.lastYield && genController.lastYield.stack ? genController.lastYield.stack.length : 0;\n          if (curDepth < initialDepth){\n            paused = true; running = false;\n            log('Returned from recursion and paused.');\n            return;\n          }\n          setTimeout(loop, 10);\n        }\n        loop();\n      }\n\n      // Fast forward to end\n      function runToEnd(){\n        if (!genController){\n          startSortController();\n          return;\n        }\n        paused = false;\n        running = true;\n        function loop(){\n          if (!genController) return;\n          proceedGenerator();\n          if (!genController) return;\n          setTimeout(loop, 0);\n        }\n        loop();\n      }\n\n      // Event handlers\n      applyArrayBtn.onclick = ()=>{\n        const txt = arrayInput.value;\n        const parsed = parseArrayText(txt);\n        if (!parsed){\n          alert('Invalid array input. Use comma separated numbers.');\n          return;\n        }\n        baseArray = parsed;\n        resetHistory(baseArray);\n        log('Applied new array.');\n      };\n\n      shuffleArrayBtn.onclick = ()=>{\n        const idx = currentStateIndex;\n        const a = cloneArr(history[idx].arr);\n        for (let i=a.length-1;i>0;i--){\n          const j = randInt(0,i);\n          swap(a,i,j);\n        }\n        const s = {arr:a, pointers:{}, op:'shuffle', desc:'Shuffled array', branchId: history[idx].branchId};\n        pushState(s);\n        log('Shuffled array relative to state ' + idx);\n      };\n\n      randomArrayBtn.onclick = ()=>{\n        const size = Number(randSize.value)||10;\n        const min = Number(randMin.value)||1;\n        const max = Number(randMax.value)||20;\n        const a = [];\n        for (let i=0;i<size;i++) a.push(randInt(min,max));\n        arrayInput.value = a.join(',');\n        baseArray = a;\n        resetHistory(baseArray);\n        log('Generated random array.');\n      };\n\n      startBtn.onclick = ()=> startSortController();\n      pauseBtn.onclick = ()=> { if (running) pauseSort(); else if (genController) resumeSort(); else log('No active run.'); };\n      stepBtn.onclick = ()=> { stepOnce(); };\n      backBtn.onclick = ()=> { safeStepBack(); };\n      runPartitionBtn.onclick = ()=> { runPartition(); };\n      runRecursionBtn.onclick = ()=> { runRecursion(); };\n      fastForwardBtn.onclick = ()=> { runToEnd(); };\n\n      speed.oninput = ()=> { speedVal.textContent = speed.value; };\n\n      undoBtn.onclick = ()=> { stepBack(); };\n      redoBtn.onclick = ()=> {\n        if (currentStateIndex < history.length - 1){\n          currentStateIndex++;\n          updateViews();\n        }\n      };\n      exportBtn.onclick = ()=> { importArea.value = exportState(); log('Exported state to text box.'); };\n      importBtn.onclick = ()=> {\n        if (importArea.value.trim()){\n          importState(importArea.value.trim());\n          log('Imported state.');\n        } else {\n          alert('Paste JSON into the box first.');\n        }\n      };\n\n      manualSwapBtn.onclick = ()=>{\n        const i = Number(swapI.value);\n        const j = Number(swapJ.value);\n        if (!Number.isInteger(i) || !Number.isInteger(j)) { alert('Indices must be integers'); return; }\n        const st = history[currentStateIndex];\n        const arr = cloneArr(st.arr);\n        if (i < 0 || i >= arr.length || j < 0 || j >= arr.length) { alert('Index out of bounds'); return; }\n        swap(arr,i,j);\n        const s = {arr:arr, pointers:{i:i,j:j}, op:'manualSwap', desc:'Manual swap '+i+'<->'+j, branchId: st.branchId};\n        pushState(s);\n        log('Manual swap executed.');\n      };\n\n      setValBtn.onclick = ()=>{\n        const idx = Number(setIdx.value);\n        const val = Number(setVal.value);\n        if (!Number.isInteger(idx)) { alert('Index must be integer'); return; }\n        const st = history[currentStateIndex];\n        const arr = cloneArr(st.arr);\n        if (idx < 0 || idx >= arr.length) { alert('Index out of bounds'); return; }\n        arr[idx] = val;\n        const s = {arr:arr, pointers:{}, op:'setValue', desc:'Set a['+idx+']='+val, branchId: st.branchId};\n        pushState(s);\n        log('Element set manually.');\n      };\n\n      compareStrategiesBtn.onclick = ()=>{\n        // Run two strategies on copies of the array and compare stats (synchronously, non-visual)\n        const base = history[currentStateIndex].arr;\n        const stratA = pivotStrategySel.value;\n        const stratB = compareStrategySel.value;\n        // Run quicksort twice to gather stats\n        function runOnce(arrCopy, options){\n          // We'll run the generator to completion and gather the last stats object\n          const gen = quicksortGenerator(arrCopy, options);\n          let last = null;\n          while (true){\n            const val = gen.next();\n            if (val.done){\n              if (val.value && val.value.stats) last = val.value.stats;\n              break;\n            } else {\n              last = val.value.stats || last;\n            }\n          }\n          return {arr:arrCopy, stats:last};\n        }\n        const optA = {partition: partitionSchemeSel.value, pivotStrategy: stratA, order: orderSel.value, breakDepth: 9999};\n        const optB = {partition: partitionSchemeSel.value, pivotStrategy: stratB, order: orderSel.value, breakDepth: 9999};\n        const copyA = cloneArr(base);\n        const copyB = cloneArr(base);\n        const resA = runOnce(copyA, optA);\n        const resB = runOnce(copyB, optB);\n        // Present comparative result as a new state snapshot with info\n        const desc = 'Comparison ' + stratA + ' vs ' + stratB + ' | A comps/swaps: ' + resA.stats.comps + '/' + resA.stats.swaps + ' B comps/swaps: ' + resB.stats.comps + '/' + resB.stats.swaps;\n        const s = {arr: cloneArr(base), pointers:{}, op:'compare', desc:desc, branchId: history[currentStateIndex].branchId};\n        pushState(s);\n        log('Strategy comparison pushed. ' + desc);\n        alert('Comparison result:\\n' + desc);\n      };\n\n      resetAllBtn.onclick = ()=> {\n        if (!confirm('Reset history and generator?')) return;\n        baseArray = parseArrayText(arrayInput.value) || baseArray;\n        resetHistory(baseArray);\n        genController = null;\n        running = false;\n        paused = false;\n        log('Reset all.');\n      };\n\n      // Handle clicking on array items (for manual pivot selection and for setting indices)\n      function onArrayItemClick(e){\n        const idx = Number(e.currentTarget.dataset.index);\n        if (pivotStrategySel.value === 'manual' && genController && genController.lastYield && genController.lastYield.op === 'awaitPivot'){\n          // resume generator with this index\n          log('Manual pivot chosen at index ' + idx);\n          // resume generator passing index\n          paused = false; running = true;\n          proceedGenerator(idx);\n          paused = true; running = false;\n        } else {\n          // not in manual pivot mode; we can still set the current pointer to highlight this element (user-driven exploration)\n          const st = cloneArr(history[currentStateIndex].arr);\n          const s = {arr: st, pointers:{selected: idx}, op:'select', desc:'Selected index '+idx, branchId: history[currentStateIndex].branchId};\n          pushState(s);\n          log('Selected element ' + idx + ' for exploration.');\n        }\n      }\n\n      // Initialize\n      resetHistory(baseArray);\n      updateViews();\n\n      // Informational log\n      log('Simulator ready. Load an array and use controls to explore Quick Sort.');\n\n      // Expose some internals for advanced exploration in console (if user wants)\n      window._qsSim = {\n        history: ()=> history,\n        jump: jumpToState,\n        pushState: (s)=> pushState(s),\n        generator: ()=> genController\n      };\n\n    })();\n  </script>\n</body>\n</html>"
