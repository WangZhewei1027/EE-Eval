  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Queue — Visual Concept</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071127;\n    --glass: rgba(255,255,255,0.06);\n    --accent: linear-gradient(90deg,#7b61ff,#00e0ff 60%);\n    --accent-solid: #7b61ff;\n    --muted: rgba(255,255,255,0.65);\n    --card: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.03);\n    --success: #72f0c1;\n    --danger: #ff647c;\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    --glass-outline: rgba(255,255,255,0.03);\n    font-synthesis: none;\n  }\n\n  /* Base layout */\n  *{box-sizing: border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 700px at 10% 20%, rgba(123,97,255,0.10), transparent 6%),\n                radial-gradient(1000px 600px at 90% 90%, rgba(0,224,255,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    padding:48px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Background ambient */\n  .ambience{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    mix-blend-mode:screen;\n    opacity:0.22;\n  }\n  .glow-orb{\n    position:absolute;\n    width:520px;height:520px;\n    border-radius:50%;\n    filter:blur(70px);\n    transform:translate3d(-50%,-50%,0);\n    opacity:0.9;\n  }\n  .orb-a{left:8%;top:18%;background:radial-gradient(circle at 30% 30%, rgba(123,97,255,0.9), rgba(123,97,255,0.12) 30%, transparent 60%);}\n  .orb-b{right:6%;bottom:10%;background:radial-gradient(circle at 60% 40%, rgba(0,224,255,0.85), rgba(0,224,255,0.06) 28%, transparent 60%);}\n  .particle-field{\n    position:absolute;inset:0;mix-blend-mode:overlay;\n    background-image:\n      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.02) 0 2px, transparent 3px),\n      radial-gradient(circle at 60% 70%, rgba(255,255,255,0.015) 0 2px, transparent 3px);\n    opacity:0.9;filter:blur(0.4px);\n  }\n\n  /* Stage */\n  .stage{\n    width:min(1120px,95vw);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:22px;\n    padding:34px;\n    box-shadow: var(--shadow);\n    border:1px solid rgba(255,255,255,0.04);\n    position:relative;\n    overflow:hidden;\n    backdrop-filter: blur(8px) saturate(120%);\n  }\n\n  header.title{\n    display:flex;\n    gap:20px;\n    align-items:center;\n    margin-bottom:22px;\n  }\n  .logo{\n    width:68px;height:68px;border-radius:14px;\n    background:linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 6px 20px rgba(12,12,30,0.6), inset 0 -6px 18px rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    position:relative; overflow:hidden;\n  }\n  .logo svg{filter:drop-shadow(0 10px 30px rgba(123,97,255,0.14));}\n  h1{\n    font-weight:700;margin:0;font-size:22px;letter-spacing:-0.02em;\n    display:flex;flex-direction:column;line-height:1;\n  }\n  h1 small{\n    font-weight:500;font-size:13px;color:var(--muted);margin-top:6px;\n  }\n\n  .controls{\n    margin-left:auto; display:flex; gap:12px; align-items:center;\n  }\n  .btn{\n    -webkit-tap-highlight-color:transparent;\n    background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.04);\n    color:inherit;padding:10px 14px;border-radius:10px;\n    font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:10px;\n    transition:all 250ms cubic-bezier(.2,.9,.2,1);\n    box-shadow: 0 6px 16px rgba(2,6,23,0.5);\n  }\n  .btn:active{transform:translateY(1px) scale(0.998)}\n  .icon{\n    width:18px;height:18px;display:inline-block;\n  }\n\n  /* Main visual */\n  .visual{\n    display:flex;gap:28px;align-items:center;\n  }\n\n  /* left panel explanation */\n  .info{\n    width:340px;\n    padding:20px;border-radius:14px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.45);\n    min-height:300px;\n  }\n  .info h2{margin:0;font-size:16px}\n  .info p{color:var(--muted);font-size:13px;line-height:1.5;margin-top:12px}\n  .legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}\n  .chip{padding:8px 10px;border-radius:9px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);font-weight:600;font-size:13px;color:var(--muted)}\n  .stat{\n    margin-top:18px;padding:14px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n    display:flex;justify-content:space-between;align-items:center;border:1px solid rgba(255,255,255,0.02)\n  }\n  .stat strong{font-size:20px}\n  .muted{color:var(--muted);font-size:13px}\n\n  /* queue container */\n  .queue-stage{\n    padding:28px;border-radius:18px;background:\n      linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    width:620px;min-height:300px;border:1px solid rgba(255,255,255,0.03);position:relative;\n    box-shadow: 0 20px 40px rgba(2,6,23,0.6), inset 0 -4px 30px rgba(255,255,255,0.02);\n  }\n\n  .track{\n    display:flex;align-items:center;gap:18px;height:140px;position:relative;padding:20px 12px;\n  }\n\n  .source, .sink{\n    width:110px;height:110px;border-radius:18px;background:linear-gradient(135deg, rgba(123,97,255,0.12), rgba(0,224,255,0.04));\n    border:1px solid rgba(255,255,255,0.03);display:flex;flex-direction:column;align-items:center;justify-content:center;\n    box-shadow: 0 8px 26px rgba(10,10,30,0.5);\n    position:relative;flex:0 0 110px;\n  }\n  .source .label,.sink .label{font-weight:700;font-size:12px;color:#eaf6ff;opacity:0.95}\n  .source .sub,.sink .sub{font-size:11px;color:var(--muted);margin-top:6px}\n\n  .slots{\n    display:flex;gap:12px;padding:10px 6px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:14px;padding-left:18px;padding-right:18px;flex:1;height:120px;align-items:center;justify-content:center;\n    border:1px dashed rgba(255,255,255,0.03);\n    position:relative;\n  }\n\n  .slot{\n    width:74px;height:86px;border-radius:12px;background:var(--glass-2);\n    display:flex;align-items:center;justify-content:center;flex-direction:column;\n    border:1px solid rgba(255,255,255,0.02);position:relative;overflow:visible;\n    transition:transform 420ms cubic-bezier(.2,.9,.2,1), box-shadow 300ms;\n  }\n  .slot .index{position:absolute;top:6px;left:8px;font-size:11px;color:var(--muted)}\n  .slot.empty{background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));}\n  .slot.filled{box-shadow:0 8px 20px rgba(2,6,23,0.4)}\n  .slot .placeholder{\n    width:44px;height:38px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--muted);font-size:13px;letter-spacing:-0.02em;\n  }\n\n  /* node cards */\n  .node{\n    width:58px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;\n    font-weight:800;color:#02111a;font-size:14px;\n    background:linear-gradient(90deg,#7b61ff 0%, #00e0ff 100%);\n    box-shadow: 0 12px 30px rgba(123,97,255,0.18), inset 0 -8px 20px rgba(255,255,255,0.06);\n    transform:translateZ(0);\n  }\n\n  .floating{\n    position:fixed;left:0;top:0;will-change:transform,opacity;\n    pointer-events:none;z-index:1200;\n    transition:transform 680ms cubic-bezier(.2,.9,.2,1), opacity 420ms ease;\n  }\n\n  /* pointers */\n  .pointer{\n    position:absolute;top:-22px;left:12px;padding:6px 10px;border-radius:999px;background:linear-gradient(90deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));\n    font-weight:700;font-size:12px;color:var(--muted);display:flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,0.03);\n    transform-origin:left center;\n    transition:transform 420ms cubic-bezier(.2,.9,.2,1), opacity 300ms;\n  }\n  .pointer .dot{width:8px;height:8px;border-radius:50%;background:var(--accent-solid);box-shadow:0 6px 18px rgba(123,97,255,0.22)}\n  .pointer.tail{left:auto;right:12px;transform-origin:right center}\n\n  /* head/tail label lines */\n  .slot::after{\n    content:'';position:absolute;bottom:-12px;left:50%;transform:translateX(-50%);width:2px;height:12px;background:transparent;\n  }\n\n  /* tiny info */\n  .footer{\n    margin-top:18px;color:var(--muted);font-size:13px;display:flex;gap:12px;align-items:center;justify-content:space-between;\n  }\n\n  /* responsiveness */\n  @media (max-width:920px){\n    .visual{flex-direction:column}\n    .info{width:100%}\n    .queue-stage{width:100%}\n  }\n\n  /* subtle animations */\n  @keyframes pulse {\n    0%{transform:scale(1);opacity:0.9}\n    50%{transform:scale(1.07);opacity:1}\n    100%{transform:scale(1);opacity:0.9}\n  }\n\n  .source .pulse{\n    width:40px;height:40px;border-radius:10px;background:linear-gradient(90deg, rgba(123,97,255,0.12), rgba(0,224,255,0.06));\n    position:absolute;filter:blur(12px);opacity:0.9;animation:pulse 3.6s ease-in-out infinite;\n  }\n\n  /* small label for pauses */\n  .paused-overlay{\n    position:absolute;inset:0;background:linear-gradient(180deg, rgba(3,6,14,0.35), rgba(3,6,14,0.4));\n    display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--muted);border-radius:18px;\n    pointer-events:none;opacity:0;transition:opacity 280ms;\n  }\n  .paused-overlay.show{opacity:1}\n</style>\n</head>\n<body>\n  <div class=\"ambience\">\n    <div class=\"glow-orb orb-a\"></div>\n    <div class=\"glow-orb orb-b\"></div>\n    <div class=\"particle-field\"></div>\n  </div>\n\n  <main class=\"stage\" role=\"main\" aria-label=\"Queue visualization\">\n    <header class=\"title\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" >\n          <defs>\n            <linearGradient id=\"gA\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7b61ff\"/>\n              <stop offset=\"1\" stop-color=\"#00e0ff\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"0\" y=\"0\" width=\"24\" height=\"24\" rx=\"6\" fill=\"url(#gA)\" opacity=\"0.18\"/>\n          <path d=\"M6 8h12v2H6zM8 12h8v2H8zM10 16h4v2h-4z\" fill=\"#fff\" opacity=\"0.95\"/>\n        </svg>\n      </div>\n\n      <h1>\n        Queue\n        <small>First-In, First-Out — orderly flow of elements</small>\n      </h1>\n\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button id=\"toggleBtn\" class=\"btn\" title=\"Pause or resume automatic flow\">\n          <svg class=\"icon\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"#cfeeff\" opacity=\"0.95\"></path>\n          </svg>\n          Pause\n        </button>\n      </div>\n    </header>\n\n    <div class=\"visual\">\n      <aside class=\"info\" aria-hidden=\"true\">\n        <h2>What is a Queue?</h2>\n        <p>A queue is an ordered collection that follows the First-In, First-Out (FIFO) principle. Elements enter at the tail and exit from the head — like people lining up for service.</p>\n\n        <div class=\"legend\" aria-hidden=\"true\">\n          <div class=\"chip\">Enqueue →</div>\n          <div class=\"chip\">Dequeue ←</div>\n          <div class=\"chip\">Head</div>\n          <div class=\"chip\">Tail</div>\n        </div>\n\n        <div class=\"stat\" aria-hidden=\"true\" style=\"margin-top:16px;\">\n          <div>\n            <div class=\"muted\">Current Size</div>\n            <strong id=\"sizeDisplay\">0</strong>\n          </div>\n          <div style=\"text-align:right\">\n            <div class=\"muted\">Capacity</div>\n            <strong id=\"capDisplay\">8</strong>\n          </div>\n        </div>\n\n        <p style=\"margin-top:14px;color:var(--muted)\">The animation automatically enqueues new items and dequeues them in order. Use the pause control to freeze the flow and observe positions. This visualization emphasizes the elegance of order and movement — minimal controls, maximal clarity.</p>\n      </aside>\n\n      <section class=\"queue-stage\" aria-live=\"polite\">\n        <div class=\"track\">\n          <div class=\"source\" id=\"source\">\n            <div class=\"pulse\" aria-hidden=\"true\"></div>\n            <div class=\"label\">Source</div>\n            <div class=\"sub\">Enqueue</div>\n          </div>\n\n          <div class=\"slots\" id=\"slots\" aria-hidden=\"false\">\n            <!-- slots created by JS -->\n          </div>\n\n          <div class=\"sink\" id=\"sink\">\n            <div class=\"label\">Sink</div>\n            <div class=\"sub\">Dequeued</div>\n          </div>\n        </div>\n\n        <div id=\"headPointer\" class=\"pointer\" style=\"left:24px\">\n          <div class=\"dot\"></div>\n          <div>HEAD</div>\n        </div>\n\n        <div id=\"tailPointer\" class=\"pointer tail\" style=\"right:24px\">\n          <div>TAIL</div>\n          <div class=\"dot\"></div>\n        </div>\n\n        <div class=\"paused-overlay\" id=\"pausedOverlay\">Paused — animations suspended</div>\n\n        <div class=\"footer\">\n          <div class=\"muted\">Auto-flow pace: gentle. Visual emphasis on shape, color, and motion.</div>\n          <div class=\"muted\">Design-first demonstration</div>\n        </div>\n      </section>\n    </div>\n  </main>\n\n<script>\n(function(){\n  // Configuration\n  const CAPACITY = 8;\n  const ENQ_INTERVAL = 1600; // ms\n  const DEQ_INTERVAL = 2600;\n  const ENQ_TRANSITION = 680;\n  const DEQ_TRANSITION = 620;\n\n  // State\n  let queue = [];\n  let nextId = 1;\n  let enqTimer = null;\n  let deqTimer = null;\n  let paused = false;\n\n  // DOM\n  const slotsEl = document.getElementById('slots');\n  const sourceEl = document.getElementById('source');\n  const sinkEl = document.getElementById('sink');\n  const sizeDisplay = document.getElementById('sizeDisplay');\n  const capDisplay = document.getElementById('capDisplay');\n  const headPointer = document.getElementById('headPointer');\n  const tailPointer = document.getElementById('tailPointer');\n  const toggleBtn = document.getElementById('toggleBtn');\n  const pausedOverlay = document.getElementById('pausedOverlay');\n\n  capDisplay.textContent = CAPACITY;\n\n  // Create slots\n  for(let i=0;i<CAPACITY;i++){\n    const s = document.createElement('div');\n    s.className = 'slot empty';\n    s.dataset.index = i;\n    s.innerHTML = `<div class=\"index\">${i}</div><div class=\"placeholder\"></div>`;\n    slotsEl.appendChild(s);\n  }\n\n  const slotNodes = Array.from(document.querySelectorAll('.slot'));\n\n  // Utility: get center coords\n  function getCenter(el){\n    const r = el.getBoundingClientRect();\n    return {x: r.left + r.width/2, y: r.top + r.height/2};\n  }\n\n  // Create a floating node at source and animate to a slot position\n  function animateEnqueue(value, targetIndex){\n    const sourceCenter = getCenter(sourceEl);\n    const targetSlot = slotNodes[targetIndex];\n    const targetCenter = getCenter(targetSlot);\n\n    const node = document.createElement('div');\n    node.className = 'floating';\n    node.innerHTML = `<div class=\"node\">${value}</div>`;\n    document.body.appendChild(node);\n\n    // start position\n    const startX = sourceCenter.x - 29; // center adjustment for node width ~58/2\n    const startY = sourceCenter.y - 18;\n    node.style.transform = `translate3d(${startX}px, ${startY}px, 0)`;\n    node.style.opacity = '0.98';\n\n    // force reflow to ensure transition\n    node.getBoundingClientRect();\n\n    // compute target position (center of target)\n    const endX = targetCenter.x - 29;\n    const endY = targetCenter.y - 18;\n\n    // small curved motion via translate + rotate\n    node.style.transition = `transform ${ENQ_TRANSITION}ms cubic-bezier(.2,.9,.2,1), opacity 380ms ease`;\n    node.style.transform = `translate3d(${endX}px, ${endY}px, 0) rotate(${Math.random()*8 - 4}deg)`;\n\n    // after transition, place node into slot and remove floating\n    const cleanup = () => {\n      node.removeEventListener('transitionend', cleanup);\n      const slot = slotNodes[targetIndex];\n      slot.classList.remove('empty');\n      slot.classList.add('filled');\n      slot.querySelector('.placeholder').remove();\n      const settled = document.createElement('div');\n      settled.className = 'node';\n      settled.textContent = value;\n      // stamp into slot\n      slot.appendChild(settled);\n      // fade out floating\n      node.style.opacity = '0';\n      setTimeout(()=>node.remove(),120);\n      updatePointers();\n    };\n    node.addEventListener('transitionend', cleanup);\n  }\n\n  // Animate dequeue from head to sink\n  function animateDequeue(fromIndex){\n    const slot = slotNodes[fromIndex];\n    const node = slot.querySelector('.node');\n    if(!node) return;\n    // compute start and end centers\n    const startCenter = getCenter(node);\n    const sinkCenter = getCenter(sinkEl);\n\n    // create floating clone\n    const clone = document.createElement('div');\n    clone.className = 'floating';\n    clone.style.opacity = '1';\n    clone.innerHTML = `<div class=\"node\">${node.textContent}</div>`;\n    document.body.appendChild(clone);\n\n    const startX = startCenter.x - 29;\n    const startY = startCenter.y - 18;\n    clone.style.transform = `translate3d(${startX}px, ${startY}px, 0)`;\n\n    // remove original node from slot visually\n    slot.classList.remove('filled');\n    slot.classList.add('empty');\n    slot.querySelector('.node').remove();\n    // re-add placeholder\n    const placeholder = document.createElement('div');\n    placeholder.className = 'placeholder';\n    slot.appendChild(placeholder);\n\n    // animate to sink\n    // small rotation and fade\n    requestAnimationFrame(()=> {\n      clone.getBoundingClientRect();\n      const endX = sinkCenter.x - 29;\n      const endY = sinkCenter.y - 18;\n      clone.style.transition = `transform ${DEQ_TRANSITION}ms cubic-bezier(.22,.9,.2,1), opacity ${DEQ_TRANSITION/2}ms ease`;\n      clone.style.transform = `translate3d(${endX}px, ${endY}px, 0) rotate(${15+Math.random()*20}deg)`;\n      clone.style.opacity = '0.06';\n    });\n\n    setTimeout(()=>{ clone.remove(); updatePointers(); }, DEQ_TRANSITION+80);\n  }\n\n  // Enqueue function\n  function enqueue(){\n    if(paused) return;\n    if(queue.length >= CAPACITY) return;\n    const value = nextId++;\n    queue.push(value);\n    updateDisplays();\n    animateEnqueue(value, queue.length-1);\n  }\n\n  // Dequeue function\n  function dequeue(){\n    if(paused) return;\n    if(queue.length === 0) return;\n    const removed = queue.shift();\n    updateDisplays();\n    animateDequeue(0); // always from head slot 0\n    // After shifting, we must visually slide nodes left to fill gaps\n    setTimeout(shiftSlotsLeft, 80);\n  }\n\n  // After a dequeue, slide all filled slot nodes left to their new index\n  function shiftSlotsLeft(){\n    // For each slot, if it has a node and the previous slot is empty, move the node DOM into the previous slot with gentle transform\n    for(let i=0;i<CAPACITY;i++){\n      const slot = slotNodes[i];\n      const node = slot.querySelector('.node');\n      if(!node) continue;\n      // compute its current logical index in DOM; we want to place node into slot index = position in queue\n      // We'll rebuild: clear all filled states and repopulate from queue array values\n    }\n    // Rebuild slot content according to queue array\n    slotNodes.forEach(s=>{\n      s.classList.remove('filled');\n      s.classList.add('empty');\n      const ph = s.querySelector('.placeholder');\n      if(!ph){\n        const p = document.createElement('div');\n        p.className = 'placeholder';\n        // remove any existing children nodes that aren't index label\n        const extra = Array.from(s.children).filter(c=>!c.classList.contains('index'));\n        extra.forEach(e=>e.remove());\n        s.appendChild(p);\n      } else {\n        // ensure placeholder exists and no node children\n        const extras = Array.from(s.children).filter(c=>!c.classList.contains('index') && !c.classList.contains('placeholder'));\n        extras.forEach(e=>e.remove());\n      }\n    });\n\n    queue.forEach((v, idx)=>{\n      const s = slotNodes[idx];\n      s.classList.remove('empty');\n      s.classList.add('filled');\n      const ph = s.querySelector('.placeholder');\n      if(ph) ph.remove();\n      const node = document.createElement('div');\n      node.className = 'node';\n      node.textContent = v;\n      node.style.opacity = '0';\n      s.appendChild(node);\n      // Fade in\n      requestAnimationFrame(()=>{ node.style.transition = 'opacity 420ms ease'; node.style.opacity = '1'; });\n    });\n\n    updatePointers();\n  }\n\n  // Update displays\n  function updateDisplays(){\n    sizeDisplay.textContent = queue.length;\n  }\n\n  // Update head/tail pointer positions\n  function updatePointers(){\n    // Head points to first filled slot or to first slot if empty\n    const headIndex = queue.length>0 ? 0 : 0;\n    const tailIndex = queue.length>0 ? queue.length-1 : -1;\n\n    const headSlot = slotNodes[Math.max(0, headIndex)];\n    const tailSlot = tailIndex >= 0 ? slotNodes[tailIndex] : slotNodes[0];\n\n    const hRect = headSlot.getBoundingClientRect();\n    const tRect = tailSlot.getBoundingClientRect();\n    const containerRect = document.querySelector('.queue-stage').getBoundingClientRect();\n\n    // position pointers relative to container\n    const headLeft = (hRect.left - containerRect.left) + 6;\n    headPointer.style.left = headLeft + 'px';\n    headPointer.style.opacity = queue.length>0 ? '1' : '0.7';\n    headPointer.style.transform = 'translateY(0)';\n\n    const tailRight = containerRect.right - (tRect.right) + 6;\n    tailPointer.style.right = tailRight + 'px';\n    tailPointer.style.opacity = queue.length>0 ? '1' : '0.7';\n    tailPointer.style.transform = 'translateY(0)';\n\n    // update pointer labels subtle color\n    headPointer.querySelector('.dot').style.background = queue.length>0 ? 'linear-gradient(90deg,#72f0c1,#00e0ff)' : 'rgba(255,255,255,0.06)';\n  }\n\n  // Timers control\n  function startTimers(){\n    if(enqTimer) clearInterval(enqTimer);\n    if(deqTimer) clearInterval(deqTimer);\n    enqTimer = setInterval(()=>{ enqueue(); }, ENQ_INTERVAL);\n    deqTimer = setInterval(()=>{ dequeue(); }, DEQ_INTERVAL);\n  }\n  function stopTimers(){\n    if(enqTimer){ clearInterval(enqTimer); enqTimer = null; }\n    if(deqTimer){ clearInterval(deqTimer); deqTimer = null; }\n  }\n\n  // Toggle pause/resume\n  toggleBtn.addEventListener('click', ()=>{\n    paused = !paused;\n    if(paused){\n      stopTimers();\n      toggleBtn.innerHTML = `<svg class=\"icon\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M6 5h12l-6 14z\" fill=\"#ffffff\" opacity=\"0.95\"></path></svg> Resume`;\n      pausedOverlay.classList.add('show');\n    } else {\n      startTimers();\n      toggleBtn.innerHTML = `<svg class=\"icon\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"#cfeeff\" opacity=\"0.95\"></path></svg> Pause`;\n      pausedOverlay.classList.remove('show');\n    }\n  });\n\n  // Initialize auto-flow\n  function init(){\n    updatePointers();\n    // small pre-seed with one element for aesthetics\n    enqueue();\n    // queue some staggered enqueues\n    setTimeout(()=>enqueue(), 500);\n    setTimeout(()=>dequeue(), 2100);\n    // start normal timers\n    startTimers();\n    // keep pointers updated on resize\n    window.addEventListener('resize', ()=>{ updatePointers(); });\n  }\n\n  // Kick off\n  init();\n\n  // Aesthetic micro-animation: slight bob for filled slots\n  setInterval(()=>{\n    slotNodes.forEach((s,i)=>{\n      if(s.classList.contains('filled')){\n        s.style.transform = `translateY(${(Math.sin((Date.now()/900)+(i*0.6))*3)}px)`;\n      } else {\n        s.style.transform = 'translateY(0)';\n      }\n    });\n  }, 80);\n\n})();\n</script>\n</body>\n</html>"
