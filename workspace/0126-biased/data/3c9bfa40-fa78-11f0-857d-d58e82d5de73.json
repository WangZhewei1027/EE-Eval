    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Decision Trees • Visual Concept</title>\n<style>\n  /* Reset and base */\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');\n\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin:0; \n    min-height: 100vh;\n    background: linear-gradient(135deg, #141e30 0%, #243b55 100%);\n    font-family: 'Montserrat', sans-serif;\n    color: #f2f2f2;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 2rem;\n  }\n\n  header {\n    text-align: center;\n    max-width: 700px;\n    margin-bottom: 2rem;\n  }\n\n  header h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.4rem;\n    letter-spacing: 0.1em;\n    margin: 0;\n    color: #f0f8ff;\n    text-shadow:\n      0 0 6px rgba(240,248,255,0.8),\n      0 4px 12px rgba(35,70,130,0.6);\n    user-select: none;\n  }\n  header p {\n    font-size: 1.15rem;\n    color: #a2b9d8cc;\n    margin-top: 0.5rem;\n    line-height: 1.5;\n    user-select: none;\n  }\n\n  /* Container for tree */\n  #tree-container {\n    position: relative;\n    width: 100%;\n    max-width: 900px;\n    aspect-ratio: 4 / 3;\n    background: radial-gradient(circle at top center, #314A72, #1b2a47);\n    border-radius: 1.25rem;\n    box-shadow:\n      inset 0 0 80px 15px rgba(100,140,200,0.25),\n      0 20px 60px rgba(0,0,0,0.6);\n    overflow: visible;\n    padding: 40px 0 80px 0;\n    user-select: none;\n  }\n\n  /* The decision tree visual will be an SVG with stylized nodes and edges */\n  svg {\n    width: 100%;\n    height: 100%;\n  }\n\n  /* Node styling */\n  .node {\n    cursor: default;\n    fill: #335C81;\n    stroke: #A7C7E7;\n    stroke-width: 3px;\n    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4));\n    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);\n  }\n  .node:hover {\n    filter: drop-shadow(0 0 12px #A7C7E7);\n  }\n\n  .node-decision {\n    fill: #3B6AA0;\n    rx: 14;\n    ry: 14;\n  }\n\n  .node-leaf {\n    fill: #65AADD;\n    rx: 20;\n    ry: 20;\n  }\n\n  .node-text {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 14px;\n    fill: #E0E7FF;\n    pointer-events: none;\n    user-select: none;\n    text-shadow: 0 0 2px #2c3e50bb;\n  }\n\n  /* Edge styling */\n  .edge {\n    fill: none;\n    stroke: #9cc7ffdd;\n    stroke-width: 2.5px;\n    filter: drop-shadow(0 0 3px #8bb5ffcc);\n    transition: stroke 0.4s ease;\n  }\n  .edge.path-highlight {\n    stroke: #ffd369cc;\n    stroke-width: 3.8px;\n    filter: drop-shadow(0 0 14px #ffd369dd);\n  }\n\n  /* Labels on edges */\n  .edge-label {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 12px;\n    fill: #c9d1ffcc;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Buttons */\n  #controls {\n    margin-top: 1.5rem;\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n  button {\n    background: linear-gradient(145deg, #38598c, #2b4264);\n    border: none;\n    padding: 0.75rem 1.8rem;\n    border-radius: 50px;\n    box-shadow:\n      3px 3px 8px #1d2a43,\n      -3px -3px 10px #4a6998;\n    color: #dce6ff;\n    font-weight: 600;\n    font-size: 1rem;\n    letter-spacing: 0.05em;\n    cursor: pointer;\n    transition:\n      background-color 0.25s ease,\n      box-shadow 0.35s ease;\n    user-select: none;\n  }\n  button:hover, button:focus {\n    outline: none;\n    background: linear-gradient(145deg, #4d6ea6, #3a5181);\n    box-shadow:\n      4px 4px 14px #5f83bc,\n      -4px -4px 16px #2e4383;\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 3rem;\n    text-align: center;\n    font-size: 0.85rem;\n    color: #7a8ebf88;\n    user-select: none;\n  }\n\n  /* Animations for node entrance */\n  .node-group {\n    transform-origin: center center;\n    animation: nodeAppear 0.6s ease forwards;\n    opacity: 0;\n  }\n  .node-group:nth-child(1) {\n    animation-delay: 0.1s;\n  }\n  .node-group:nth-child(2) {\n    animation-delay: 0.25s;\n  }\n  .node-group:nth-child(3) {\n    animation-delay: 0.4s;\n  }\n  .node-group:nth-child(4) {\n    animation-delay: 0.55s;\n  }\n  .node-group:nth-child(5) {\n    animation-delay: 0.7s;\n  }\n  .node-group:nth-child(6) {\n    animation-delay: 0.85s;\n  }\n\n  @keyframes nodeAppear {\n    0% {\n      transform: scale(0.5) translateY(20px);\n      opacity: 0;\n      filter: drop-shadow(0 0 0 transparent);\n    }\n    100% {\n      transform: scale(1) translateY(0);\n      opacity: 1;\n      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4));\n    }\n  }\n\n</style>\n</head>\n<body>\n<header>\n  <h1>Decision Trees</h1>\n  <p>\n    A decision tree is a flowchart-like structure in machine learning and statistics that represents decisions and their possible consequences. Nodes denote decisions or outcomes; edges capture branching conditions.\n  </p>\n</header>\n<div id=\"tree-container\" aria-label=\"Decision Tree Visualization\">\n  <svg viewBox=\"0 0 800 600\" role=\"img\" aria-describedby=\"desc\">\n    <desc id=\"desc\">Illustration of a decision tree with nodes and branches.</desc>\n\n    <!-- Edges (Bezier curves) with labels -->\n    <path id=\"e1\" class=\"edge\" d=\"M400 130 C 400 210, 260 230, 260 310\" />\n    <text class=\"edge-label\" x=\"320\" y=\"200\" text-anchor=\"middle\">Yes</text>\n\n    <path id=\"e2\" class=\"edge\" d=\"M400 130 C 400 210, 540 230, 540 310\" />\n    <text class=\"edge-label\" x=\"480\" y=\"200\" text-anchor=\"middle\">No</text>\n\n    <path id=\"e3\" class=\"edge\" d=\"M260 310 C 260 350, 180 360, 180 420\" />\n    <text class=\"edge-label\" x=\"220\" y=\"360\" text-anchor=\"middle\">True</text>\n\n    <path id=\"e4\" class=\"edge\" d=\"M260 310 C 260 350, 340 360, 340 420\" />\n    <text class=\"edge-label\" x=\"300\" y=\"360\" text-anchor=\"middle\">False</text>\n\n    <path id=\"e5\" class=\"edge\" d=\"M540 310 C 540 350, 600 360, 600 420\" />\n    <text class=\"edge-label\" x=\"570\" y=\"360\" text-anchor=\"middle\">Over 50%</text>\n\n    <path id=\"e6\" class=\"edge\" d=\"M540 310 C 540 350, 480 360, 480 420\" />\n    <text class=\"edge-label\" x=\"510\" y=\"360\" text-anchor=\"middle\">Under 50%</text>\n\n    <!-- Node groups (circle + text) -->\n    <g class=\"node-group\" id=\"node-root\" transform=\"translate(400 130)\" tabindex=\"0\" aria-label=\"Root Decision Node: Is Outlook Sunny?\">\n      <rect class=\"node node-decision\" x=\"-90\" y=\"-35\" width=\"180\" height=\"70\" rx=\"14\" ry=\"14\" />\n      <text class=\"node-text\" x=\"0\" y=\"8\" text-anchor=\"middle\" dominant-baseline=\"middle\">Is Outlook Sunny?</text>\n    </g>\n\n    <g class=\"node-group\" id=\"node-left\" transform=\"translate(260 310)\" tabindex=\"0\" aria-label=\"Decision Node: Is Humidity High?\">\n      <rect class=\"node node-decision\" x=\"-80\" y=\"-35\" width=\"160\" height=\"70\" rx=\"14\" ry=\"14\" />\n      <text class=\"node-text\" x=\"0\" y=\"8\" text-anchor=\"middle\" dominant-baseline=\"middle\">Is Humidity High?</text>\n    </g>\n    <g class=\"node-group\" id=\"node-right\" transform=\"translate(540 310)\" tabindex=\"0\" aria-label=\"Decision Node: Is Wind Strong?\">\n      <rect class=\"node node-decision\" x=\"-80\" y=\"-35\" width=\"160\" height=\"70\" rx=\"14\" ry=\"14\" />\n      <text class=\"node-text\" x=\"0\" y=\"8\" text-anchor=\"middle\" dominant-baseline=\"middle\">Is Wind Strong?</text>\n    </g>\n\n    <g class=\"node-group\" id=\"node-left-true\" transform=\"translate(180 420)\" tabindex=\"0\" aria-label=\"Leaf Node: Don't Play\">\n      <ellipse class=\"node node-leaf\" cx=\"0\" cy=\"0\" rx=\"90\" ry=\"35\" />\n      <text class=\"node-text\" x=\"0\" y=\"5\" text-anchor=\"middle\" dominant-baseline=\"middle\">Don't Play</text>\n    </g>\n\n    <g class=\"node-group\" id=\"node-left-false\" transform=\"translate(340 420)\" tabindex=\"0\" aria-label=\"Leaf Node: Play\">\n      <ellipse class=\"node node-leaf\" cx=\"0\" cy=\"0\" rx=\"90\" ry=\"35\" />\n      <text class=\"node-text\" x=\"0\" y=\"5\" text-anchor=\"middle\" dominant-baseline=\"middle\">Play</text>\n    </g>\n\n    <g class=\"node-group\" id=\"node-right-false\" transform=\"translate(480 420)\" tabindex=\"0\" aria-label=\"Leaf Node: Play\">\n      <ellipse class=\"node node-leaf\" cx=\"0\" cy=\"0\" rx=\"90\" ry=\"35\" />\n      <text class=\"node-text\" x=\"0\" y=\"5\" text-anchor=\"middle\" dominant-baseline=\"middle\">Play</text>\n    </g>\n\n    <g class=\"node-group\" id=\"node-right-true\" transform=\"translate(600 420)\" tabindex=\"0\" aria-label=\"Leaf Node: Don't Play\">\n      <ellipse class=\"node node-leaf\" cx=\"0\" cy=\"0\" rx=\"90\" ry=\"35\" />\n      <text class=\"node-text\" x=\"0\" y=\"5\" text-anchor=\"middle\" dominant-baseline=\"middle\">Don't Play</text>\n    </g>\n\n  </svg>\n</div>\n\n<div id=\"controls\" aria-label=\"Controls to highlight decision paths\">\n  <button id=\"btn-reset\" aria-label=\"Reset highlighting\">Reset Highlighting</button>\n  <button id=\"btn-highlight\" aria-label=\"Highlight sample decision path\">Highlight Example Path</button>\n</div>\n\n<footer>\n  <small>© 2024 Decision Tree Visual Concept — Crafted with care &amp; css artistry</small>\n</footer>\n\n<script>\n  (() => {\n    const edges = {\n      e1: document.getElementById('e1'),\n      e2: document.getElementById('e2'),\n      e3: document.getElementById('e3'),\n      e4: document.getElementById('e4'),\n      e5: document.getElementById('e5'),\n      e6: document.getElementById('e6')\n    };\n\n    // Define an example path for highlighting:\n    // Root (Is Outlook Sunny?) → Yes (left) → Is Humidity High? → False → Play\n    // Corresponding edges to highlight: e1 (root to left), e4 (left to left-false)\n    // and nodes along those edges: node-root, node-left, node-left-false\n\n    const nodesToHighlight = [\n      'node-root',\n      'node-left',\n      'node-left-false'\n    ];\n    const edgesToHighlight = ['e1', 'e4'];\n\n    const allEdges = Object.values(edges);\n    const allNodes = [...document.querySelectorAll('.node-group')];\n\n    const highlightClass = 'path-highlight';\n\n    function resetHighlight() {\n      allEdges.forEach(e => e.classList.remove(highlightClass));\n      allNodes.forEach(n => n.querySelector('.node').style.filter = '');\n    }\n\n    function highlightExamplePath() {\n      resetHighlight();\n      edgesToHighlight.forEach(id => {\n        edges[id].classList.add(highlightClass);\n      });\n      nodesToHighlight.forEach(id => {\n        const group = document.getElementById(id);\n        if (!group) return;\n        const nodeShape = group.querySelector('.node');\n        nodeShape.style.filter = 'drop-shadow(0 0 12px #ffd369cc)';\n      });\n    }\n\n    document.getElementById('btn-reset').addEventListener('click', resetHighlight);\n    document.getElementById('btn-highlight').addEventListener('click', highlightExamplePath);\n\n    // Initial: no highlight, so no action\n\n    // Accessibility hint: allow focus highlight override\n    allNodes.forEach(node => {\n      node.addEventListener('focus', () => {\n        const shape = node.querySelector('.node');\n        shape.style.filter = 'drop-shadow(0 0 14px #ffd369cc)';\n      });\n      node.addEventListener('blur', () => {\n        const shape = node.querySelector('.node');\n        shape.style.filter = '';\n      });\n    });\n  })();\n</script>\n</body>\n</html>"
