    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Process Concept — Visual Showcase</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;700&display=swap');\n\n  /* Reset and base */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n  body {\n    background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);\n    font-family: 'Manrope', sans-serif;\n    color: #e8f0f7;\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 1rem 5rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 700;\n    font-size: 3.5rem;\n    letter-spacing: 0.12em;\n    margin-bottom: 0.4rem;\n    background: linear-gradient(90deg, #00ffee, #0077ff);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    text-transform: uppercase;\n    filter: drop-shadow(0 0 6px #00ffeecc);\n  }\n\n  h2 {\n    font-weight: 600;\n    color: #a0c1ffcc;\n    font-size: 1.2rem;\n    letter-spacing: 0.15em;\n    margin-bottom: 3.5rem;\n    text-transform: uppercase;\n  }\n\n  /* Container for the process */\n  #process-container {\n    position: relative;\n    max-width: 860px;\n    width: 100%;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n\n  /* Steps layout */\n  .step {\n    position: relative;\n    flex: 1 1 0;\n    max-width: 140px;\n    background: rgba(255 255 255 / 0.05);\n    padding: 2.6rem 1.8rem 2.6rem;\n    border-radius: 25px;\n    box-shadow:\n      0 4px 25px rgb(0 119 255 / 0.35),\n      inset 0 -6px 12px rgb(0 255 235 / 0.15);\n    text-align: center;\n    color: #C1DFFF;\n    font-weight: 600;\n    font-size: 1.05rem;\n    letter-spacing: 0.045em;\n    transition: transform 0.45s ease, box-shadow 0.4s ease;\n    cursor: default;\n    user-select: none;\n    z-index: 1;\n  }\n  .step:not(:last-child) {\n    margin-right: 2.6rem;\n  }\n  .step:hover {\n    transform: scale(1.14) translateY(-12px);\n    box-shadow:\n      0 8px 35px #00b8ffcc,\n      inset 0 -10px 20px #00ffe8cc,\n      0 0 18px #00ffe8cc;\n    color: #d0faff;\n  }\n\n  /* Step number – a luminous orb */\n  .step-number {\n    position: absolute;\n    top: -32px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: radial-gradient(circle at center, #00ffe8, #0077ff);\n    width: 68px;\n    height: 68px;\n    border-radius: 50%;\n    box-shadow:\n      0 0 8px #00ffe8ee,\n      0 0 22px #00b8ffdd,\n      0 0 40px #00aaffff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 2rem;\n    font-weight: 700;\n    letter-spacing: 0.15em;\n    color: #fff;\n    user-select: none;\n  }\n\n  /* Step title text */\n  .step-title {\n    margin-top: 3rem;\n    font-weight: 700;\n    font-size: 1.25rem;\n    color: #a0cdfd;\n    text-shadow: 0 0 7px #60b3ffbb;\n  }\n\n  /* Step description */\n  .step-desc {\n    margin-top: 0.7rem;\n    color: #b5d9ffcc;\n    font-weight: 400;\n    font-size: 0.93rem;\n    line-height: 1.3;\n    font-style: italic;\n    user-select: none;\n  }\n\n  /* Connecting line with bokeh glow */\n  #connector {\n    position: absolute;\n    top: 5px;\n    left: 130px;\n    right: 140px;\n    height: 8px;\n    border-radius: 20px;\n    background: linear-gradient(90deg, #0077ffdd, #00aaffdd);\n    filter: drop-shadow(0 0 10px #00bbffcc);\n    z-index: 0;\n    transition: background 0.4s ease;\n  }\n  #connector::before {\n    content: '';\n    position: absolute;\n    height: 100%;\n    width: 45%;\n    background:\n      radial-gradient(circle at 0% 50%, #00ffeeaa, transparent 70%),\n      radial-gradient(circle at 100% 50%, #0077ffcc, transparent 70%);\n    border-radius: 20px;\n    top: 0; left: 0;\n    filter: blur(7px);\n    pointer-events: none;\n  }\n\n  /* Animations: subtle glowing \"process pulse\" */\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n        0 0 10px #00b8ffcc,\n        0 0 22px #00dfffbb,\n        0 0 40px #0099ffdd;\n      color: #c7eaff;\n    }\n    50% {\n      box-shadow:\n        0 0 18px #00efffcc,\n        0 0 35px #00cfffcc,\n        0 0 60px #00aaffff;\n      color: #e0fcff;\n    }\n  }\n\n  /* Highlighted step for demonstration */\n  .active-step {\n    animation: pulseGlow 3s ease-in-out infinite;\n    transform: scale(1.15) translateY(-10px);\n    box-shadow:\n      0 0 16px #00cfffdd,\n      inset 0 -11px 20px #00efffcc;\n    color: #e0f9ff;\n    cursor: default;\n  }\n\n  /* Caption & controls */\n  #caption {\n    margin-top: 4rem;\n    max-width: 560px;\n    text-align: center;\n    font-size: 1.12rem;\n    font-weight: 400;\n    color: #aaccffcc;\n    user-select: none;\n    line-height: 1.48;\n  }\n\n  footer {\n    margin-top: 5rem;\n    user-select: none;\n  }\n\n  /* Simple button style */\n  .btn {\n    margin-top: 2rem;\n    background: linear-gradient(135deg, #0077ffcc, #00ffe8cc);\n    border: none;\n    border-radius: 40px;\n    padding: 0.9rem 3rem;\n    font-size: 1.15rem;\n    font-weight: 700;\n    letter-spacing: 0.09em;\n    color: #0a1a2a;\n    text-shadow: 0 0 5px #0077ffaa;\n    box-shadow:\n      0 3px 15px #00aaffbb;\n    cursor: pointer;\n    user-select: none;\n    transition:\n      box-shadow 0.33s ease,\n      transform 0.22s ease,\n      background 0.33s ease;\n  }\n  .btn:hover {\n    background: linear-gradient(135deg, #00dfffcc, #00ffe8ff);\n    box-shadow:\n      0 0 18px #00eaffee,\n      0 0 32px #00dfffdd;\n    transform: scale(1.1);\n  }\n  .btn:active {\n    transform: scale(0.96);\n    box-shadow: none;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width: 700px) {\n    #process-container {\n      flex-wrap: wrap;\n      justify-content: center;\n    }\n    .step {\n      max-width: 90vw;\n      margin-bottom: 2.8rem !important;\n    }\n    .step:not(:last-child) {\n      margin-right: 0 !important;\n    }\n    #connector {\n      display: none;\n    }\n  }\n</style>\n</head>\n<body>\n\n<header>\n  <h1>PROCESS</h1>\n  <h2>THE JOURNEY OF CREATION</h2>\n</header>\n\n<main>\n  <section id=\"process-container\" aria-label=\"Process steps\">\n    <div class=\"step\" data-index=\"0\" aria-describedby=\"desc0\" role=\"group\" tabindex=\"0\">\n      <div class=\"step-number\">1</div>\n      <div class=\"step-title\">Ideation</div>\n      <div class=\"step-desc\" id=\"desc0\">Seed the spark — where concepts are born in creativity.</div>\n    </div>\n    <div class=\"step\" data-index=\"1\" aria-describedby=\"desc1\" role=\"group\" tabindex=\"0\">\n      <div class=\"step-number\">2</div>\n      <div class=\"step-title\">Planning</div>\n      <div class=\"step-desc\" id=\"desc1\">Shape the vision — structuring and strategizing ahead.</div>\n    </div>\n    <div class=\"step active-step\" data-index=\"2\" aria-describedby=\"desc2\" role=\"group\" tabindex=\"0\">\n      <div class=\"step-number\">3</div>\n      <div class=\"step-title\">Execution</div>\n      <div class=\"step-desc\" id=\"desc2\">Bring to life — action fuels progress and transformation.</div>\n    </div>\n    <div class=\"step\" data-index=\"3\" aria-describedby=\"desc3\" role=\"group\" tabindex=\"0\">\n      <div class=\"step-number\">4</div>\n      <div class=\"step-title\">Revision</div>\n      <div class=\"step-desc\" id=\"desc3\">Refinement & polish — perfecting with care and insight.</div>\n    </div>\n    <div class=\"step\" data-index=\"4\" aria-describedby=\"desc4\" role=\"group\" tabindex=\"0\">\n      <div class=\"step-number\">5</div>\n      <div class=\"step-title\">Delivery</div>\n      <div class=\"step-desc\" id=\"desc4\">Reveal the masterpiece — completion births fruition.</div>\n    </div>\n    <div id=\"connector\" aria-hidden=\"true\"></div>\n  </section>\n\n  <p id=\"caption\">\n    Process is the elegant flow from inception to fulfillment — each step glowing with intent, movement, and purpose.\n  </p>\n\n  <div style=\"text-align:center;\">\n    <button class=\"btn\" id=\"advanceStep\" aria-label=\"Advance active step\">Next Step</button>\n  </div>\n</main>\n\n<footer aria-hidden=\"true\" style=\"text-align:center; margin-top: 4rem; color: #224466aa; font-size: 0.9rem; user-select:none;\">\n  &copy; 2024 &bull; Visual Concept by AI\n</footer>\n\n<script>\n  (function(){\n    const steps = document.querySelectorAll('.step');\n    const button = document.getElementById('advanceStep');\n\n    let activeIndex = 2; // initially Execution step active\n\n    function updateActiveStep(newIndex){\n      if(newIndex < 0) newIndex = steps.length - 1;\n      else if(newIndex >= steps.length) newIndex = 0;\n\n      steps[activeIndex].classList.remove('active-step');\n      activeIndex = newIndex;\n      steps[activeIndex].classList.add('active-step');\n\n      steps[activeIndex].focus();\n    }\n\n    button.addEventListener('click', () => {\n      updateActiveStep(activeIndex + 1);\n    });\n\n    // Keyboard navigation for accessibility\n    steps.forEach((step, i) => {\n      step.addEventListener('keydown', e => {\n        if(e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n          e.preventDefault();\n          updateActiveStep(i+1);\n        }\n        else if(e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n          e.preventDefault();\n          updateActiveStep(i-1);\n        }\n      });\n    });\n  })();\n</script>\n</body>\n</html>"
