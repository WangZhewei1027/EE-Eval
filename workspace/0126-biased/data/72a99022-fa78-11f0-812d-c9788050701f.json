    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .container {\n            width: 90%;\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            background-color: rgba(255, 255, 255, 0.9);\n            border-radius: 20px;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n\n        h1 {\n            text-align: center;\n            margin-bottom: 1.5rem;\n            font-weight: 700;\n            font-size: 2.5rem;\n            color: var(--primary);\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);\n        }\n\n        .subtitle {\n            text-align: center;\n            margin-bottom: 2rem;\n            font-size: 1.1rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 400;\n        }\n\n        .visualization {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 400px;\n            margin: 2rem 0;\n            padding: 1rem;\n            background: linear-gradient(to bottom, rgba(255,255,255,0.8), rgba(255,255,255,0.3));\n            border-radius: 15px;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .bar {\n            width: 40px;\n            margin: 0 5px;\n            background: linear-gradient(to top, var(--primary), var(--secondary));\n            border-radius: 8px 8px 0 0;\n            transition: all 0.3s ease;\n            position: relative;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n        }\n\n        .bar::after {\n            content: attr(data-value);\n            position: absolute;\n            bottom: -25px;\n            color: var(--dark);\n            font-weight: 600;\n            font-size: 0.9rem;\n        }\n\n        .bar.active {\n            background: linear-gradient(to top, var(--accent), #ff7675);\n            transform: scale(1.05);\n            box-shadow: 0 8px 15px rgba(253, 121, 168, 0.4);\n        }\n\n        .bar.comparing {\n            background: linear-gradient(to top, var(--success), #55efc4);\n            transform: scale(1.05);\n            box-shadow: 0 8px 15px rgba(0, 184, 148, 0.4);\n        }\n\n        .bar.sorted {\n            background: linear-gradient(to top, #00b894, #55efc4);\n            box-shadow: 0 4px 6px rgba(0, 184, 148, 0.3);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 1.5rem;\n        }\n\n        button {\n            padding: 0.8rem 1.8rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 7px 20px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(to right, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.3));\n            transform: translateX(-100%);\n            transition: transform 0.3s ease;\n        }\n\n        button:hover::after {\n            transform: translateX(0);\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 1.5rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .legend-text {\n            font-size: 0.9rem;\n            color: var(--dark);\n        }\n\n        .explanation {\n            margin-top: 2rem;\n            padding: 1.5rem;\n            background: rgba(255, 255, 255, 0.7);\n            border-radius: 15px;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.5rem;\n        }\n\n        .explanation p {\n            line-height: 1.6;\n            margin-bottom: 1rem;\n            color: var(--dark);\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .particle {\n            position: absolute;\n            background: rgba(108, 92, 231, 0.2);\n            border-radius: 50%;\n            animation: float 15s infinite linear;\n        }\n\n        @keyframes float {\n            0% {\n                transform: translateY(0) rotate(0deg);\n                opacity: 0;\n            }\n            10% {\n                opacity: 1;\n            }\n            90% {\n                opacity: 1;\n            }\n            100% {\n                transform: translateY(-1000px) rotate(720deg);\n                opacity: 0;\n            }\n        }\n\n        @media (max-width: 768px) {\n            .container {\n                width: 95%;\n                padding: 1.5rem;\n            }\n            \n            h1 {\n                font-size: 2rem;\n            }\n            \n            .bar {\n                width: 30px;\n                margin: 0 3px;\n            }\n            \n            .controls {\n                flex-direction: column;\n                align-items: center;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <h1>Bubble Sort Visualization</h1>\n        <p class=\"subtitle\">Watch the elegant dance of elements as they find their perfect order</p>\n        \n        <div class=\"visualization\" id=\"visualization\"></div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to top, var(--primary), var(--secondary));\"></div>\n                <span class=\"legend-text\">Normal</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to top, var(--accent), #ff7675);\"></div>\n                <span class=\"legend-text\">Active</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to top, var(--success), #55efc4);\"></div>\n                <span class=\"legend-text\">Comparing</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to top, #00b894, #55efc4);\"></div>\n                <span class=\"legend-text\">Sorted</span>\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Sorting</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>About Bubble Sort</h2>\n            <p>Bubble Sort is a simple sorting algorithm that repeatedly steps through the list, compares adjacent elements and swaps them if they are in the wrong order. The pass through the list is repeated until the list is sorted.</p>\n            <p>The algorithm gets its name from the way smaller elements \"bubble\" to the top of the list. While simple, Bubble Sort is not efficient for large datasets as its average and worst-case time complexity is O(n²).</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Create floating particles\n            createParticles();\n            \n            // Initialize visualization\n            const visualization = document.getElementById('visualization');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let bars = [];\n            let values = [];\n            let isSorting = false;\n            \n            function initialize() {\n                visualization.innerHTML = '';\n                bars = [];\n                values = [];\n                \n                // Generate random values\n                for (let i = 0; i < 15; i++) {\n                    values.push(Math.floor(Math.random() * 90) + 10);\n                }\n                \n                // Create bars\n                values.forEach((value, index) => {\n                    const bar = document.createElement('div');\n                    bar.className = 'bar';\n                    bar.style.height = `${value * 3}px`;\n                    bar.setAttribute('data-value', value);\n                    bar.setAttribute('data-index', index);\n                    visualization.appendChild(bar);\n                    bars.push(bar);\n                });\n            }\n            \n            async function bubbleSort() {\n                if (isSorting) return;\n                isSorting = true;\n                startBtn.disabled = true;\n                \n                let n = values.length;\n                let swapped;\n                \n                do {\n                    swapped = false;\n                    \n                    for (let i = 0; i < n - 1; i++) {\n                        // Highlight current bars being compared\n                        bars[i].classList.add('comparing');\n                        bars[i + 1].classList.add('comparing');\n                        \n                        // Add slight delay for visualization\n                        await new Promise(resolve => setTimeout(resolve, 300));\n                        \n                        if (values[i] > values[i + 1]) {\n                            // Highlight the bars that will be swapped\n                            bars[i].classList.remove('comparing');\n                            bars[i + 1].classList.remove('comparing');\n                            bars[i].classList.add('active');\n                            bars[i + 1].classList.add('active');\n                            \n                            await new Promise(resolve => setTimeout(resolve, 200));\n                            \n                            // Swap values\n                            let temp = values[i];\n                            values[i] = values[i + 1];\n                            values[i + 1] = temp;\n                            \n                            // Update heights\n                            bars[i].style.height = `${values[i] * 3}px`;\n                            bars[i + 1].style.height = `${values[i + 1] * 3}px`;\n                            \n                            // Update displayed values\n                            bars[i].setAttribute('data-value', values[i]);\n                            bars[i + 1].setAttribute('data-value', values[i + 1]);\n                            \n                            swapped = true;\n                            \n                            await new Promise(resolve => setTimeout(resolve, 300));\n                            \n                            // Remove active state\n                            bars[i].classList.remove('active');\n                            bars[i + 1].classList.remove('active');\n                        } else {\n                            // Remove comparing state if no swap happened\n                            bars[i].classList.remove('comparing');\n                            bars[i + 1].classList.remove('comparing');\n                        }\n                    }\n                    \n                    // Mark the last element as sorted\n                    bars[n - 1].classList.add('sorted');\n                    n--;\n                    \n                } while (swapped);\n                \n                // Mark all remaining bars as sorted\n                for (let i = 0; i < n; i++) {\n                    bars[i].classList.add('sorted');\n                    await new Promise(resolve => setTimeout(resolve, 100));\n                }\n                \n                isSorting = false;\n                startBtn.disabled = false;\n            }\n            \n            function createParticles() {\n                const particlesContainer = document.getElementById('particles');\n                const particleCount = 30;\n                \n                for (let i = 0; i < particleCount; i++) {\n                    const particle = document.createElement('div');\n                    particle.classList.add('particle');\n                    \n                    // Random properties\n                    const size = Math.random() * 20 + 5;\n                    const posX = Math.random() * 100;\n                    const delay = Math.random() * 15;\n                    const duration = Math.random() * 10 + 15;\n                    const opacity = Math.random() * 0.3 + 0.1;\n                    \n                    particle.style.width = `${size}px`;\n                    particle.style.height = `${size}px`;\n                    particle.style.left = `${posX}%`;\n                    particle.style.bottom = `-${size}px`;\n                    particle.style.animationDelay = `${delay}s`;\n                    particle.style.animationDuration = `${duration}s`;\n                    particle.style.opacity = opacity;\n                    \n                    particlesContainer.appendChild(particle);\n                }\n            }\n            \n            // Event listeners\n            startBtn.addEventListener('click', bubbleSort);\n            resetBtn.addEventListener('click', () => {\n                if (!isSorting) {\n                    initialize();\n                }\n            });\n            \n            // Initialize on load\n            initialize();\n        });\n    </script>\n</body>\n</html>"
