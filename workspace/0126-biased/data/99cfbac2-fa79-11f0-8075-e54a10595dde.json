    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Process Demonstrator</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            position: relative;\n            padding: 20px;\n        }\n        .hidden {\n            display: none;\n        }\n        .step {\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Interactive Process Demonstrator</h1>\n\n<div id=\"workflowContainer\">\n    <div class=\"step\" id=\"step1\">\n        <h2>Step 1: Choose an Action</h2>\n        <button onclick=\"nextStep(1)\">Start Process</button>\n    </div>\n\n    <div class=\"step hidden\" id=\"step2\">\n        <h2>Step 2: Configure Options</h2>\n        <label for=\"inputA\">Option A:</label>\n        <input type=\"text\" id=\"inputA\" placeholder=\"Type something...\">\n        <br>\n        <label for=\"sliderB\">Slider B:</label>\n        <input type=\"range\" id=\"sliderB\" min=\"0\" max=\"100\" value=\"50\" oninput=\"updateSliderValueB();\">\n        <span id=\"sliderBValue\">50</span>\n        <br>\n        <button onclick=\"nextStep(2)\">Next Step</button>\n        <button onclick=\"previousStep(2)\">Back</button>\n    </div>\n\n    <div class=\"step hidden\" id=\"step3\">\n        <h2>Step 3: Confirm Options</h2>\n        <p>Option A: <span id=\"displayInputA\"></span></p>\n        <p>Slider B Value: <span id=\"displaySliderB\"></span></p>\n        <button onclick=\"nextStep(3)\">Confirm</button>\n        <button onclick=\"previousStep(3)\">Back</button>\n    </div>\n\n    <div class=\"step hidden\" id=\"step4\">\n        <h2>Step 4: Review Process</h2>\n        <p>Thank you for configuring your options!</p>\n        <button onclick=\"resetProcess()\">Reset Process</button>\n    </div>\n</div>\n\n<script>\n    function nextStep(currentStep) {\n        document.getElementById('step' + currentStep).classList.add('hidden');\n\n        if (currentStep === 1) {\n            document.getElementById('step2').classList.remove('hidden');\n        } else if (currentStep === 2) {\n            const inputA = document.getElementById('inputA').value;\n            const sliderBValue = document.getElementById('sliderB').value;\n            document.getElementById('displayInputA').textContent = inputA;\n            document.getElementById('displaySliderB').textContent = sliderBValue;\n            document.getElementById('step3').classList.remove('hidden');\n        } else if (currentStep === 3) {\n            document.getElementById('step4').classList.remove('hidden');\n        }\n    }\n\n    function previousStep(currentStep) {\n        document.getElementById('step' + currentStep).classList.add('hidden');\n\n        if (currentStep === 2) {\n            document.getElementById('step1').classList.remove('hidden');\n        } else if (currentStep === 3) {\n            document.getElementById('step2').classList.remove('hidden');\n        }\n    }\n\n    function updateSliderValueB() {\n        const sliderBValue = document.getElementById('sliderB').value;\n        document.getElementById('sliderBValue').textContent = sliderBValue;\n    }\n\n    function resetProcess() {\n        for (let i = 1; i <= 4; i++) {\n            document.getElementById('step' + i).classList.add('hidden');\n        }\n        document.getElementById('step1').classList.remove('hidden');\n        document.getElementById('inputA').value = '';\n        document.getElementById('sliderB').value = 50;\n        document.getElementById('sliderBValue').textContent = '50';\n        document.getElementById('displayInputA').textContent = '';\n        document.getElementById('displaySliderB').textContent = '';\n    }\n</script>\n\n</body>\n</html>"
