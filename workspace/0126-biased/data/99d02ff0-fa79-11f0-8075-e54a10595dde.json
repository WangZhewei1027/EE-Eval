    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NoSQL Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n\n<h1>NoSQL Interactive Demo</h1>\n\n<p>Add a new record to the NoSQL Database:</p>\n<label for=\"recordKey\">Record Key:</label>\n<input type=\"text\" id=\"recordKey\" placeholder=\"Enter record key\"><br>\n<label for=\"recordValue\">Record Value:</label>\n<input type=\"text\" id=\"recordValue\" placeholder=\"Enter record value\"><br>\n<button onclick=\"addRecord()\">Add Record</button>\n\n<h2>Existing Records:</h2>\n<ul id=\"recordList\"></ul>\n\n<h2>Search for a Record:</h2>\n<label for=\"searchKey\">Search Key:</label>\n<input type=\"text\" id=\"searchKey\" placeholder=\"Enter key to search\">\n<button onclick=\"searchRecord()\">Search</button>\n<p id=\"searchResult\"></p>\n\n<h2>Update a Record:</h2>\n<label for=\"updateKey\">Key to Update:</label>\n<input type=\"text\" id=\"updateKey\" placeholder=\"Enter key to update\"><br>\n<label for=\"updateValue\">New Value:</label>\n<input type=\"text\" id=\"updateValue\" placeholder=\"Enter new value\"><br>\n<button onclick=\"updateRecord()\">Update Record</button>\n\n<h2>Delete a Record:</h2>\n<label for=\"deleteKey\">Key to Delete:</label>\n<input type=\"text\" id=\"deleteKey\" placeholder=\"Enter key to delete\">\n<button onclick=\"deleteRecord()\">Delete Record</button>\n\n<script>\n    let database = {};\n\n    function addRecord() {\n        const key = document.getElementById('recordKey').value;\n        const value = document.getElementById('recordValue').value;\n        if (key && value) {\n            database[key] = value;\n            refreshRecordList();\n            clearFields();\n        } else {\n            alert(\"Please input both key and value.\");\n        }\n    }\n\n    function refreshRecordList() {\n        const recordList = document.getElementById('recordList');\n        recordList.innerHTML = '';\n        for (const key in database) {\n            const li = document.createElement('li');\n            li.textContent = `${key}: ${database[key]}`;\n            recordList.appendChild(li);\n        }\n    }\n\n    function searchRecord() {\n        const key = document.getElementById('searchKey').value;\n        const resultText = database[key] !== undefined ? `Value: ${database[key]}` : 'Record not found.';\n        document.getElementById('searchResult').textContent = resultText;\n    }\n\n    function updateRecord() {\n        const key = document.getElementById('updateKey').value;\n        const newValue = document.getElementById('updateValue').value;\n        if (key && newValue) {\n            if (database[key] !== undefined) {\n                database[key] = newValue;\n                refreshRecordList();\n                clearFields();\n            } else {\n                alert(\"Record not found for the given key.\");\n            }\n        } else {\n            alert(\"Please input both key and new value.\");\n        }\n    }\n\n    function deleteRecord() {\n        const key = document.getElementById('deleteKey').value;\n        if (key) {\n            if (database[key] !== undefined) {\n                delete database[key];\n                refreshRecordList();\n                clearFields();\n            } else {\n                alert(\"Record not found for the given key.\");\n            }\n        } else {\n            alert(\"Please input a key to delete.\");\n        }\n    }\n\n    function clearFields() {\n        document.getElementById('recordKey').value = '';\n        document.getElementById('recordValue').value = '';\n        document.getElementById('searchKey').value = '';\n        document.getElementById('updateKey').value = '';\n        document.getElementById('updateValue').value = '';\n        document.getElementById('deleteKey').value = '';\n        document.getElementById('searchResult').textContent = '';\n    }\n</script>\n\n</body>\n</html>"
