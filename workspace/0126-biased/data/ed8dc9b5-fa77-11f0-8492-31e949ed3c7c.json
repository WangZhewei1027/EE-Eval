    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kruskal's Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(to right, #74ebd5, #acb6e5);\n            color: #333;\n            margin: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            position: relative;\n            width: 80vw;\n            height: 80vh;\n            border: 2px solid #2c3e50;\n            border-radius: 20px;\n            overflow: hidden;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);\n            background: white;\n        }\n        .button {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            padding: 10px 20px;\n            font-size: 16px;\n            color: white;\n            background-color: #3498db;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n        .button:hover {\n            background-color: #2980b9;\n        }\n        #graph {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <svg id=\"graph\"></svg>\n        <button class=\"button\" id=\"startBtn\">Start Visualization</button>\n    </div>\n    <script>\n        const svg = document.getElementById('graph');\n        const edges = [\n            { start: [50, 50], end: [200, 100], weight: 4 },\n            { start: [200, 100], end: [300, 40], weight: 1 },\n            { start: [50, 50], end: [250, 300], weight: 2 },\n            { start: [250, 300], end: [400, 200], weight: 3 },\n            { start: [200, 100], end: [400, 200], weight: 5 },\n            { start: [50, 50], end: [400, 200], weight: 6 },\n        ];\n\n        function drawEdge(edge, strokeWidth) {\n            const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n            line.setAttribute('x1', edge.start[0]);\n            line.setAttribute('y1', edge.start[1]);\n            line.setAttribute('x2', edge.end[0]);\n            line.setAttribute('y2', edge.end[1]);\n            line.setAttribute('stroke', '#34495e');\n            line.setAttribute('stroke-width', strokeWidth);\n            svg.appendChild(line);\n        }\n\n        function visualizeKruskal() {\n            svg.innerHTML = ''; // Clear previous graph\n            const sortedEdges = edges.slice().sort((a, b) => a.weight - b.weight);\n\n            // For visual effect, animate edges being added\n            const animationDelay = 800;\n            let currentDelay = 0;\n\n            sortedEdges.forEach(edge => {\n                setTimeout(() => {\n                    drawEdge(edge, 4);\n                    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n                    circle.setAttribute('cx', (edge.start[0] + edge.end[0]) / 2);\n                    circle.setAttribute('cy', (edge.start[1] + edge.end[1]) / 2);\n                    circle.setAttribute('r', 5);\n                    circle.setAttribute('fill', '#e74c3c');\n                    svg.appendChild(circle);\n                }, currentDelay);\n                currentDelay += animationDelay;\n            });\n        }\n\n        document.getElementById('startBtn').addEventListener('click', visualizeKruskal);\n    </script>\n</body>\n</html>"
