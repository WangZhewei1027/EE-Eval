    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bellman-Ford Algorithm</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"number\"] {\n            width: 50px;\n        }\n        input[type=\"range\"] {\n            width: 50px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bellman-Ford Algorithm</h1>\n    <p>This algorithm is used to find the shortest paths from a source to all other nodes in a weighted graph.</p>\n    <button id=\"start-button\">Start</button>\n    <button id=\"reset-button\">Reset</button>\n    <button id=\"display-button\">Display</button>\n    <button id=\"plot-button\">Plot</button>\n\n    <div id=\"graph-container\">\n        <canvas id=\"graph\" width=\"400\" height=\"400\"></canvas>\n    </div>\n\n    <script>\n        const startButton = document.getElementById('start-button');\n        const resetButton = document.getElementById('reset-button');\n        const displayButton = document.getElementById('display-button');\n        const plotButton = document.getElementById('plot-button');\n        const graphContainer = document.getElementById('graph-container');\n\n        let graph = null;\n        let distances = null;\n        let previous = null;\n\n        let inputFields = {};\n\n        function createGraph() {\n            graph = new Array(10).fill(0).map(() => new Array(10).fill(0));\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    graph[i][j] = Math.random();\n                }\n            }\n            distances = new Array(10).fill(Infinity);\n            previous = new Array(10).fill(null);\n        }\n\n        function updateGraph() {\n            graph = new Array(10).fill(0).map(() => new Array(10).fill(0));\n            distances = new Array(10).fill(Infinity);\n            previous = new Array(10).fill(null);\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    distances[i][j] = graph[i][j];\n                }\n            }\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    if (distances[i][j] === Infinity) {\n                        distances[i][j] = 0;\n                    }\n                }\n            }\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    if (graph[i][j] > 0 && distances[i][j] > distances[i][previous[j]]) {\n                        distances[i][j] = distances[i][previous[j]];\n                        previous[j] = i;\n                    }\n                }\n            }\n        }\n\n        function updateInputFields() {\n            for (let i = 0; i < 10; i++) {\n                inputFields[i] = document.createElement('input');\n                inputFields[i].type = 'number';\n                inputFields[i].value = distances[i][0];\n                graphContainer.appendChild(inputFields[i]);\n            }\n        }\n\n        function updateDisplayButton() {\n            for (let i = 0; i < 10; i++) {\n                const value = inputFields[i].value;\n                if (value === Infinity) {\n                    distances[i] = 0;\n                    previous[i] = null;\n                } else {\n                    distances[i] = value;\n                    previous[i] = null;\n                }\n                updateGraph();\n            }\n        }\n\n        function updateResetButton() {\n            for (let i = 0; i < 10; i++) {\n                graph[i][i] = 0;\n            }\n            distances = null;\n            previous = null;\n            updateGraph();\n        }\n\n        function updatePlotButton() {\n            const canvas = document.getElementById('graph');\n            const ctx = canvas.getContext('2d');\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    ctx.beginPath();\n                    ctx.arc(j * 20 + 100, i * 20 + 100, 10, 0, 2 * Math.PI);\n                    ctx.fillStyle = 'black';\n                    ctx.fill();\n                }\n            }\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    if (distances[i][j] === Infinity) {\n                        ctx.beginPath();\n                        ctx.arc(j * 20 + 100, i * 20 + 100, 10, 0, 2 * Math.PI);\n                        ctx.fillStyle = 'black';\n                        ctx.fill();\n                    }\n                }\n            }\n            const minDistance = Math.min(...Object.values(distances));\n            for (let i = 0; i < 10; i++) {\n                if (distances[i] === minDistance) {\n                    const text = document.createElement('span');\n                    text.textContent = `Node ${i} has distance ${minDistance}`;\n                    graphContainer.appendChild(text);\n                }\n            }\n        }\n\n        startButton.addEventListener('click', createGraph);\n        resetButton.addEventListener('click', updateResetButton);\n        displayButton.addEventListener('click', updateDisplayButton);\n        plotButton.addEventListener('click', updatePlotButton);\n\n        updateInputFields();\n        updateDisplayButton();\n        updateResetButton();\n    </script>\n    <script src=\"script.js\"></script>\n</body>\n</html>"
