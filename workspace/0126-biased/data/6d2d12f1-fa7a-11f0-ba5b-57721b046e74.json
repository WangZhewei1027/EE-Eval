  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Binary Search Tree Interactive</title>\n    <style>\n        body { font-family: monospace; margin: 20px; }\n        .node { margin: 10px; padding: 5px; border: 1px solid black; display: inline-block; }\n        .controls { margin: 20px 0; border: 1px solid #ccc; padding: 10px; }\n        .control-group { margin: 10px 0; }\n        .tree-container { margin: 20px 0; }\n        .highlight { background-color: #eee; }\n        .path { font-weight: bold; }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree Interactive</h1>\n    \n    <div class=\"controls\">\n        <div class=\"control-group\">\n            <h3>Tree Operations</h3>\n            <input type=\"insertValue\" id=\"insertValue\" placeholder=\"Enter value\">\n            <button onclick=\"insertNode()\">Insert</button>\n            <input type=\"deleteValue\" id=\"deleteValue\" placeholder=\"Enter value\">\n            <button onclick=\"deleteNode()\">Delete</button>\n            <input type=\"searchValue\" id=\"searchValue\" placeholder=\"Enter value\">\n            <button onclick=\"searchNode()\">Search</button>\n            <button onclick=\"clearTree()\">Clear Tree</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Traversal</h3>\n            <button onclick=\"traverse('inorder')\">Inorder</button>\n            <button onclick=\"traverse('preorder')\">Preorder</button>\n            <button onclick=\"traverse('postorder')\">Postorder</button>\n            <button onclick=\"traverse('levelorder')\">Level Order</button>\n            <div id=\"traversalResult\"></div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Tree Properties</h3>\n            <button onclick=\"getMin()\">Find Min</button>\n            <button onclick=\"getMax()\">Find Max</button>\n            <button onclick=\"getHeight()\">Get Height</button>\n            <button onclick=\"countNodes()\">Count Nodes</button>\n            <div id=\"propertyResult\"></div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Visualization</h3>\n            <button onclick=\"toggleBalance()\">Toggle Balance</button>\n            <button onclick=\"togglePaths()\">Toggle Paths</button>\n            <button onclick=\"randomTree()\">Generate Random Tree</button>\n            <div>\n                <label>Node Count: <input type=\"range\" id=\"nodeCount\" min=\"1\" max=\"20\" value=\"10\" onchange=\"updateNodeCount()\"></label>\n                <span id=\"nodeCountValue\">10</span>\n            </div>\n        </div>\n    </div>\n    \n    <div id=\"treeContainer\"></div>\n    <div id=\"status\"></div>\n    \n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n                this.parent = null;\n            }\n        }\n        \n        let root = null;\n        let showBalance = false;\n        let showPaths = false;\n        \n        function insertNode() {\n            const value = parseInt(document.getElementById('insertValue').value);\n            if (isNaN(value)) {\n                updateStatus(\"Please enter a valid number\");\n                return;\n            }\n            \n            const newNode = new Node(value);\n            if (root === null) {\n                root = newNode;\n            } else {\n                insertNodeHelper(root, newNode);\n            }\n            renderTree();\n            updateStatus(`Inserted node with value ${value}`);\n        }\n        \n        function insertNodeHelper(node, newNode) {\n            if (newNode.value < node.value) {\n                if (node.left === null) {\n                    node.left = newNode;\n                    newNode.parent = node;\n                } else {\n                    insertNodeHelper(node.left, newNode);\n                }\n            } else if (newNode.value > node.value) {\n                if (node.right === null) {\n                    node.right = newNode;\n                    newNode.parent = node;\n                } else {\n                    insertNodeHelper(node.right, newNode);\n                }\n            }\n        }\n        \n        function deleteNode() {\n            const value = parseInt(document.getElementById('deleteValue').value);\n            if (isNaN(value)) {\n                updateStatus(\"Please enter a valid number\");\n                return;\n            }\n            \n            root = deleteNodeHelper(root, value);\n            renderTree();\n            updateStatus(`Deleted node with value ${value} (if found)`);\n        }\n        \n        function deleteNodeHelper(node, value) {\n            if (node) {\n                if (value < node.value) {\n                    node.left = deleteNodeHelper(node.left, value);\n                } else if (value > node.value) {\n                    node.right = deleteNodeHelper(node.right, value);\n                } else {\n                    if (node.left === null && node.right === null) {\n                        node = null;\n                    } else if (node.left === null) {\n                        node = node.right;\n                    } else if (node.right === null) {\n                        node = node.left;\n                    } else {\n                        const minRight = findMinNode(node.right);\n                        node.value = minRight.value;\n                        node.right = deleteNodeHelper(node.right, minRight.value);\n                    }\n                }\n            }\n            return node;\n        }\n        \n        function searchNode() {\n            const value = parseInt(document.getElementById('searchValue').value);\n            if (isNaN(value)) {\n                updateStatus(\"Please enter a valid number\");\n                return;\n            }\n            \n            const path = [];\n            const found = searchNodeHelper(root, value, path);\n            \n            renderTree();\n            if (found) {\n                highlightPath(path);\n                updateStatus(`Found node with value ${value}`);\n            } else {\n                updateStatus(`Node with value ${value} not found`);\n            }\n        }\n        \n        function searchNodeHelper(node, value, path) {\n            if (node === null) return false;\n            \n            path.push(node);\n            \n            if (value === node.value) return true;\n            if (value < node.value) return searchNodeHelper(node.left, value, path);\n            return searchNodeHelper(node.right, value, path);\n        }\n        \n        function highlightPath(path) {\n            const nodes = document.querySelectorAll('.node');\n            nodes.forEach(node => {\n                node.classList.remove('highlight');\n                node.classList.remove('path');\n            });\n            \n            path.forEach(node => {\n                const element = document.querySelector(`.node[data-value=\"${node.value}\"]`);\n                if (element) {\n                    element.classList.add('highlight');\n                    if (showPaths) {\n                        element.classList.add('path');\n                    }\n                }\n            });\n        }\n        \n        function traverse(order) {\n            let result = [];\n            switch(order) {\n                case 'inorder':\n                    inorder(root, result);\n                    break;\n                case 'preorder':\n                    preorder(root, result);\n                    break;\n                case 'postorder':\n                    postorder(root, result);\n                    break;\n                case 'levelorder':\n                    levelorder(root, result);\n                    break;\n            }\n            document.getElementById('traversalResult').textContent = `${order}: ${result.join(' → ')}`;\n        }\n        \n        function inorder(node, result) {\n            if (node) {\n                inorder(node.left, result);\n                result.push(node.value);\n                inorder(node.right, result);\n            }\n        }\n        \n        function preorder(node, result) {\n            if (node) {\n                result.push(node.value);\n                preorder(node.left, result);\n                preorder(node.right, result);\n            }\n        }\n        \n        function postorder(node, result) {\n            if (node) {\n                postorder(node.left, result);\n                postorder(node.right, result);\n                result.push(node.value);\n            }\n        }\n        \n        function levelorder(node, result) {\n            if (!node) return;\n            \n            const queue = [node];\n            while (queue.length > 0) {\n                const current = queue.shift();\n                result.push(current.value);\n                \n                if (current.left) queue.push(current.left);\n                if (current.right) queue.push(current.right);\n            }\n        }\n        \n        function getMin() {\n            if (!root) {\n                document.getElementById('propertyResult').textContent = \"Tree is empty\";\n                return;\n            }\n            const minNode = findMinNode(root);\n            document.getElementById('propertyResult').textContent = `Minimum value: ${minNode.value}`;\n            \n            const path = [];\n            findPathToNode(root, minNode.value, path);\n            highlightPath(path);\n        }\n        \n        function getMax() {\n            if (!root) {\n                document.getElementById('propertyResult').textContent = \"Tree is empty\";\n                return;\n            }\n            const maxNode = findMaxNode(root);\n            document.getElementById('propertyResult').textContent = `Maximum value: ${maxNode.value}`;\n            \n            const path = [];\n            findPathToNode(root, maxNode.value, path);\n            highlightPath(path);\n        }\n        \n        function getHeight() {\n            const height = calculateHeight(root);\n            document.getElementById('propertyResult').textContent = `Tree height: ${height}`;\n        }\n        \n        function countNodes() {\n            const count = countNodesHelper(root);\n            document.getElementById('propertyResult').textContent = `Node count: ${count}`;\n        }\n        \n        function findMinNode(node) {\n            while (node && node.left) {\n                node = node.left;\n            }\n            return node;\n        }\n        \n        function findMaxNode(node) {\n            while (node && node.right) {\n                node = node.right;\n            }\n            return node;\n        }\n        \n        function calculateHeight(node) {\n            if (!node) return -1;\n            return 1 + Math.max(calculateHeight(node.left), calculateHeight(node.right));\n        }\n        \n        function countNodesHelper(node) {\n            if (!node) return 0;\n            return 1 + countNodesHelper(node.left) + countNodesHelper(node.right);\n        }\n        \n        function findPathToNode(node, value, path) {\n            if (!node) return false;\n            \n            path.push(node);\n            \n            if (node.value === value) return true;\n            if (value < node.value && findPathToNode(node.left, value, path)) return true;\n            if (value > node.value && findPathToNode(node.right, value, path)) return true;\n            \n            path.pop();\n            return false;\n        }\n        \n        function clearTree() {\n            root = null;\n            renderTree();\n            updateStatus(\"Tree cleared\");\n            document.getElementById('traversalResult').textContent = \"\";\n            document.getElementById('propertyResult').textContent = \"\";\n        }\n        \n        function toggleBalance() {\n            showBalance = !showBalance;\n            renderTree();\n        }\n        \n        function togglePaths() {\n            showPaths = !showPaths;\n            renderTree();\n        }\n        \n        function randomTree() {\n            clearTree();\n            const count = parseInt(document.getElementById('nodeCount').value);\n            const values = new Set();\n            \n            while (values.size < count) {\n                const value = Math.floor(Math.random() * 100);\n                values.add(value);\n            }\n            \n            values.forEach(value => {\n                const newNode = new Node(value);\n                if (root === null) {\n                    root = newNode;\n                } else {\n                    insertNodeHelper(root, newNode);\n                }\n            });\n            \n            renderTree();\n            updateStatus(`Generated random tree with ${count} nodes`);\n        }\n        \n        function updateNodeCount() {\n            const value = document.getElementById('nodeCount').value;\n            document.getElementById('nodeCountValue').textContent = value;\n        }\n        \n        function renderTree() {\n            const container = document.getElementById('treeContainer');\n            container.innerHTML = '';\n            \n            if (!root) {\n                container.textContent = \"Tree is empty\";\n                return;\n            }\n            \n            const levels = [];\n            const queue = [{node: root, level: 0}];\n            \n            while (queue.length > 0) {\n                const current = queue.shift();\n                if (!levels[current.level]) {\n                    levels[current.level] = [];\n                }\n                levels[current.level].push(current.node);\n                \n                if (current.node.left) {\n                    queue.push({node: current.node.left, level: current.level + 1});\n                }\n                if (current.node.right) {\n                    queue.push({node: current.node.right, level: current.level + 1});\n                }\n            }\n            \n            levels.forEach((levelNodes, levelIndex) => {\n                const levelDiv = document.createElement('div');\n                levelDiv.className = 'level';\n                \n                levelNodes.forEach(node => {\n                    const nodeDiv = document.createElement('div');\n                    nodeDiv.className = 'node';\n                    nodeDiv.textContent = node.value;\n                    nodeDiv.setAttribute('data-value', node.value);\n                    \n                    if (showBalance) {\n                        const balance = calculateHeight(node.right) - calculateHeight(node.left);\n                        nodeDiv.textContent += ` (${balance})`;\n                    }\n                    \n                    levelDiv.appendChild(nodeDiv);\n                });\n                \n                container.appendChild(levelDiv);\n            });\n        }\n        \n        function updateStatus(message) {\n            document.getElementById('status').textContent = message;\n        }\n        \n        // Initialize\n        renderTree();\n    </script>\n</body>\n</html>"
  },
