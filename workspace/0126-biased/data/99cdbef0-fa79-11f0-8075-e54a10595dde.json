    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Array Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        input, button, select {\n            margin: 5px;\n        }\n        #arrayDisplay {\n            margin-top: 20px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            width: 300px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Dynamic Array Manipulation</h1>\n\n<label for=\"elementInput\">Add Element:</label>\n<input type=\"number\" id=\"elementInput\">\n<button id=\"addButton\">Add</button>\n\n<label for=\"removeIndex\">Remove Element at Index:</label>\n<input type=\"number\" id=\"removeIndex\">\n<button id=\"removeButton\">Remove</button>\n\n<button id=\"resetButton\">Reset Array</button>\n\n<label for=\"bulkInput\">Bulk Add Elements (comma separated):</label>\n<input type=\"text\" id=\"bulkInput\">\n<button id=\"bulkAddButton\">Bulk Add</button>\n\n<h2>Current Array:</h2>\n<div id=\"arrayDisplay\">Array is empty</div>\n\n<script>\n    let dynamicArray = [];\n\n    const arrayDisplay = document.getElementById('arrayDisplay');\n    const elementInput = document.getElementById('elementInput');\n    const removeIndex = document.getElementById('removeIndex');\n    const bulkInput = document.getElementById('bulkInput');\n\n    const updateDisplay = () => {\n        arrayDisplay.innerText = dynamicArray.length > 0 ? JSON.stringify(dynamicArray) : 'Array is empty';\n    };\n\n    document.getElementById('addButton').addEventListener('click', () => {\n        const value = Number(elementInput.value);\n        if (!isNaN(value)) {\n            dynamicArray.push(value);\n            elementInput.value = '';\n            updateDisplay();\n        }\n    });\n\n    document.getElementById('removeButton').addEventListener('click', () => {\n        const index = Number(removeIndex.value);\n        if (!isNaN(index) && index >= 0 && index < dynamicArray.length) {\n            dynamicArray.splice(index, 1);\n            removeIndex.value = '';\n            updateDisplay();\n        }\n    });\n\n    document.getElementById('resetButton').addEventListener('click', () => {\n        dynamicArray = [];\n        updateDisplay();\n    });\n\n    document.getElementById('bulkAddButton').addEventListener('click', () => {\n        const values = bulkInput.value.split(',').map(val => Number(val.trim()));\n        for (let value of values) {\n            if (!isNaN(value)) {\n                dynamicArray.push(value);\n            }\n        }\n        bulkInput.value = '';\n        updateDisplay();\n    });\n</script>\n\n</body>\n</html>"
