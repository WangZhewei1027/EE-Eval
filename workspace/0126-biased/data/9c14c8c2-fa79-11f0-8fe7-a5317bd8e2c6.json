  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Backtracking Explorer - Interactive Demo</title>\n<style>\n/* Minimal styling only to keep layout usable. No colors, no animations. */\nbody { font-family: sans-serif; margin: 12px; color: #000; background: #fff; }\nsection { margin-bottom: 12px; }\nlabel { display: inline-block; margin-right: 8px; }\ninput[type=\"text\"], input[type=\"number\"], select, textarea { font-family: monospace; }\ntextarea { width: 100%; height: 120px; }\nbutton { margin: 2px; }\npre { background: #fff; padding: 6px; border: 1px solid #000; overflow: auto; max-height: 240px; }\ndetails { margin-bottom: 8px; }\nfieldset { margin-bottom: 8px; }\n</style>\n</head>\n<body>\n<h1>Backtracking Explorer</h1>\n\n<section>\n  <fieldset>\n    <legend>Problem Templates / Configuration</legend>\n    <label for=\"templateSelect\">Template:</label>\n    <select id=\"templateSelect\">\n      <option value=\"nqueens\">N-Queens</option>\n      <option value=\"subset\">Subset Sum</option>\n      <option value=\"graphcolor\">Graph Coloring</option>\n      <option value=\"custom\">Custom Problem (JS)</option>\n    </select>\n\n    <div id=\"templateParams\">\n      <div id=\"nqueensParams\">\n        <label for=\"nSize\">N (board size):</label>\n        <input id=\"nSize\" type=\"number\" min=\"1\" max=\"12\" value=\"8\">\n      </div>\n      <div id=\"subsetParams\" style=\"display:none\">\n        <label for=\"itemsList\">Items (comma integers):</label>\n        <input id=\"itemsList\" type=\"text\" value=\"3,34,4,12,5,2\" size=\"30\">\n        <label for=\"targetSum\">Target:</label>\n        <input id=\"targetSum\" type=\"number\" value=\"9\" min=\"0\">\n      </div>\n      <div id=\"graphParams\" style=\"display:none\">\n        <label for=\"graphAdj\">Graph (adj lists, semicolon):</label>\n        <input id=\"graphAdj\" type=\"text\" value=\"1:2;2:1,3;3:2,4;4:3\" size=\"40\">\n        <label for=\"colorCount\">Colors:</label>\n        <input id=\"colorCount\" type=\"number\" value=\"3\" min=\"1\">\n      </div>\n      <div id=\"customParams\" style=\"display:none\">\n        <label for=\"customVars\">Variables (comma):</label>\n        <input id=\"customVars\" type=\"text\" size=\"30\" placeholder=\"x,y,z\">\n        <label for=\"customDomains\">Domains (JSON map):</label>\n        <input id=\"customDomains\" type=\"text\" size=\"40\" placeholder='{\"x\":[1,2],\"y\":[1,2]}' />\n        <div>\n          <label for=\"customConstraints\">Constraint code (return true if partial assignment valid):</label>\n          <textarea id=\"customConstraints\">// Example: return !assignment.x || !assignment.y || assignment.x !== assignment.y;\n// You can access \"assignment\" object. Return true if consistent so far.</textarea>\n        </div>\n      </div>\n\n    </div>\n\n    <div style=\"margin-top:8px\">\n      <button id=\"initBtn\">Initialize Problem</button>\n      <button id=\"resetBtn\">Full Reset</button>\n      <button id=\"clearLogBtn\">Clear Log</button>\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Solver Controls</legend>\n    <div>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"runBtn\">Run</button>\n      <button id=\"pauseBtn\" disabled>Pause</button>\n      <button id=\"nextSolBtn\">Next Solution</button>\n      <button id=\"findAllBtn\">Find All (limit)</button>\n    </div>\n\n    <div style=\"margin-top:6px\">\n      <label for=\"heuristicSelect\">Heuristic:</label>\n      <select id=\"heuristicSelect\">\n        <option value=\"static\">Static Order</option>\n        <option value=\"mrv\">MRV (Minimum Remaining Values)</option>\n        <option value=\"random\">Random Variable</option>\n      </select>\n\n      <label for=\"orderSelect\">Value Order:</label>\n      <select id=\"orderSelect\">\n        <option value=\"asc\">Ascending</option>\n        <option value=\"desc\">Descending</option>\n        <option value=\"random\">Random</option>\n      </select>\n\n      <label><input id=\"forwardChk\" type=\"checkbox\" checked> Forward checking</label>\n      <label><input id=\"stopFirstChk\" type=\"checkbox\"> Stop at first solution</label>\n    </div>\n\n    <div style=\"margin-top:6px\">\n      <label for=\"speedRange\">Speed (ms):</label>\n      <input id=\"speedRange\" type=\"range\" min=\"50\" max=\"2000\" value=\"250\">\n      <label for=\"maxNodes\">Max Nodes:</label>\n      <input id=\"maxNodes\" type=\"number\" value=\"10000\" min=\"1\" style=\"width:80px\">\n      <label for=\"depthLimit\">Depth Limit (0 = none):</label>\n      <input id=\"depthLimit\" type=\"number\" value=\"0\" min=\"0\" style=\"width:80px\">\n    </div>\n\n    <div style=\"margin-top:6px\">\n      <label><input id=\"manualMode\" type=\"checkbox\"> Manual decision mode</label>\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n      <button id=\"saveStateBtn\">Save State (JSON)</button>\n      <input id=\"loadStateFile\" type=\"file\" style=\"display:inline-block\">\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Interactive Exploration & Tree</legend>\n    <div>\n      <button id=\"exportTreeBtn\">Export Tree JSON</button>\n      <button id=\"importTreeBtn\">Import Tree JSON (paste)</button>\n    </div>\n    <div style=\"display:flex; gap:12px; margin-top:8px\">\n      <div style=\"flex:1; min-width:220px;\">\n        <label>Searchable Assignment / Current State:</label>\n        <pre id=\"assignPre\">{}</pre>\n        <label>Domains:</label>\n        <pre id=\"domainsPre\">{}</pre>\n        <label>Counters:</label>\n        <pre id=\"countersPre\">nodesVisited: 0\nsolutions: 0\ndepth: 0\nstackSize: 0</pre>\n      </div>\n\n      <div style=\"flex:2; min-width:320px;\">\n        <label>Backtrack Tree (click node to view):</label>\n        <div id=\"treeDiv\" style=\"border:1px solid #000; padding:6px; max-height:520px; overflow:auto;\">\n          <div id=\"treeRoot\">[empty]</div>\n        </div>\n        <div style=\"margin-top:6px\">\n          <button id=\"jumpToNodeBtn\" disabled>Explore from Selected Node</button>\n          <button id=\"pruneNodeBtn\" disabled>Mark Selected Node as Pruned</button>\n          <button id=\"expandAllBtn\">Expand All</button>\n        </div>\n      </div>\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Solutions & Logs</legend>\n    <label>Solutions Found:</label>\n    <div id=\"solutionsDiv\" style=\"border:1px solid #000; padding:6px; max-height:120px; overflow:auto;\"><em>none</em></div>\n\n    <label>Event Log:</label>\n    <textarea id=\"logArea\"></textarea>\n  </fieldset>\n</section>\n\n<!-- Import area for tree JSON -->\n<section>\n  <fieldset>\n    <legend>Advanced / Developer (manual import/export)</legend>\n    <label for=\"importText\">Import JSON:</label>\n    <textarea id=\"importText\" placeholder=\"Paste exported tree or state JSON here\"></textarea>\n    <div>\n      <button id=\"doImportBtn\">Import</button>\n      <button id=\"downloadStateBtn\">Download Current State</button>\n    </div>\n  </fieldset>\n</section>\n\n<script>\n/*\n  Backtracking Explorer - JavaScript logic\n  - Multiple templates\n  - Iterative backtracking with stack and domain snapshots\n  - Heuristics, forward checking, manual mode, undo/redo, state save/load\n  - Tree of exploration\n  Minimal UI. No external libs.\n*/\n\n/* Utilities */\nfunction deepCopy(obj) {\n  return JSON.parse(JSON.stringify(obj));\n}\nfunction log(msg) {\n  const area = document.getElementById('logArea');\n  area.value = new Date().toLocaleTimeString() + ' - ' + msg + '\\\\n' + area.value;\n}\nfunction download(filename, text) {\n  const a = document.createElement('a');\n  a.href = URL.createObjectURL(new Blob([text], {type: 'application/json'}));\n  a.download = filename;\n  a.click();\n}\n\n/* Templates */\nconst templates = {\n  nqueens: {\n    name: \"N-Queens\",\n    build: (params) => {\n      const N = Math.max(1, Math.min(12, Number(params.n || 8)));\n      const vars = [];\n      const domains = {};\n      for (let r=0;r<N;r++) {\n        const v = 'r' + r;\n        vars.push(v);\n        const dom = [];\n        for (let c=0;c<N;c++) dom.push(c);\n        domains[v] = dom;\n      }\n      // constraint function: no two queens same column or diagonal\n      function constraint(assignment) {\n        const keys = Object.keys(assignment);\n        for (let i=0;i<keys.length;i++) {\n          for (let j=i+1;j<keys.length;j++) {\n            const r1 = parseInt(keys[i].slice(1));\n            const r2 = parseInt(keys[j].slice(1));\n            const c1 = assignment[keys[i]];\n            const c2 = assignment[keys[j]];\n            if (c1 === c2) return false;\n            if (Math.abs(r1 - r2) === Math.abs(c1 - c2)) return false;\n          }\n        }\n        return true;\n      }\n      return {vars, domains, constraints: [constraint], text: 'Place N queens so none attack.'};\n    }\n  },\n\n  subset: {\n    name: \"Subset Sum\",\n    build: (params) => {\n      const items = (params.items || \"3,34,4,12,5,2\").split(',').map(s=>Number(s.trim())).filter(n=>!Number.isNaN(n));\n      const target = Number(params.target || 9);\n      const vars = items.map((_,i)=>'i'+i);\n      const domains = {};\n      vars.forEach((v,i)=> domains[v] = [0,1]); // 0 = excluded, 1 = included\n      function constraint(assignment) {\n        // partial check: sum included so far cannot exceed target\n        let sum = 0, remainingMax = 0;\n        for (let k=0;k<items.length;k++) {\n          const v = 'i'+k;\n          if (assignment[v] === 1) sum += items[k];\n          else if (assignment[v] === 0) { /* excluded */ }\n          else remainingMax += items[k];\n        }\n        if (sum > target) return false;\n        // if all assigned, require equality\n        const allAssigned = vars.every(v=>assignment.hasOwnProperty(v));\n        if (allAssigned) return sum === target;\n        return true;\n      }\n      return {vars, domains, constraints: [constraint], text: 'Choose subset equal to target.'};\n    }\n  },\n\n  graphcolor: {\n    name: \"Graph Coloring\",\n    build: (params) => {\n      // parse adjacency like \"1:2;2:1,3;3:2,4;4:3\"\n      const adjStr = (params.adj || \"1:2;2:1,3;3:2,4;4:3\");\n      const colorCount = Math.max(1, Number(params.colors || 3));\n      const nodes = [];\n      const adj = {};\n      const parts = adjStr.split(';').map(s=>s.trim()).filter(Boolean);\n      parts.forEach(p=>{\n        const [k,rest] = p.split(':');\n        const key = k.trim();\n        nodes.push(key);\n        adj[key] = (rest || '').split(',').map(x=>x.trim()).filter(Boolean);\n      });\n      const vars = nodes.slice();\n      const domains = {};\n      vars.forEach(v=> domains[v] = Array.from({length:colorCount}, (_,i)=>i+1));\n      function constraint(assignment) {\n        for (let v in assignment) {\n          const col = assignment[v];\n          const neighbors = adj[v] || [];\n          for (let nb of neighbors) {\n            if (assignment.hasOwnProperty(nb) && assignment[nb] === col) return false;\n          }\n        }\n        return true;\n      }\n      return {vars, domains, constraints: [constraint], text: 'Color graph so adjacent nodes differ.'};\n    }\n  },\n\n  custom: {\n    name: \"Custom\",\n    build: (params) => {\n      const vars = (params.vars || '').split(',').map(s=>s.trim()).filter(Boolean);\n      let domains = {};\n      try {\n        domains = params.domains ? JSON.parse(params.domains) : {};\n      } catch(e) {\n        domains = {};\n      }\n      // ensure domains arrays\n      vars.forEach(v=>{\n        if (!Array.isArray(domains[v])) domains[v] = domains[v] === undefined ? [0,1] : [domains[v]];\n      });\n      // constraint code provided by user\n      let fn;\n      try {\n        const code = params.constraintCode || 'return true;';\n        fn = new Function('assignment', code);\n      } catch(e) {\n        fn = ()=>true;\n      }\n      return {vars, domains, constraints: [fn], text: 'Custom constraints.'};\n    }\n  }\n};\n\n/* Solver state */\nlet PROBLEM = null;\nlet ASSIGNMENT = {};\nlet DOMAINS = {};\nlet STACK = []; // frames: {var, index, domainsBefore, parentNode}\nlet TREE = null; // root node\nlet CURRENT_NODE = null;\nlet NODES_VISITED = 0;\nlet SOLUTIONS = [];\nlet SOL_LIMIT = 1000;\nlet RUN_TIMER = null;\nlet HISTORY = [];\nlet HISTORY_INDEX = -1;\n\n/* Tree node id generator */\nlet nodeIdCounter = 0;\nfunction makeNode(parent, varName, value, assignmentSnapshot) {\n  return {\n    id: ++nodeIdCounter,\n    parent: parent ? parent.id : null,\n    var: varName,\n    value: value,\n    status: 'trying', // trying, pruned, solution, backtracked\n    children: [],\n    assignment: deepCopy(assignmentSnapshot || {})\n  };\n}\n\n/* Initialize or reset */\nfunction initProblemFromUI() {\n  const tpl = document.getElementById('templateSelect').value;\n  const params = {};\n  if (tpl === 'nqueens') {\n    params.n = Number(document.getElementById('nSize').value);\n  } else if (tpl === 'subset') {\n    params.items = document.getElementById('itemsList').value;\n    params.target = Number(document.getElementById('targetSum').value);\n  } else if (tpl === 'graphcolor') {\n    params.adj = document.getElementById('graphAdj').value;\n    params.colors = Number(document.getElementById('colorCount').value);\n  } else if (tpl === 'custom') {\n    params.vars = document.getElementById('customVars').value;\n    params.domains = document.getElementById('customDomains').value;\n    params.constraintCode = document.getElementById('customConstraints').value;\n  }\n  const builder = templates[tpl].build;\n  const prob = builder(params);\n  PROBLEM = {\n    name: templates[tpl].name,\n    vars: prob.vars,\n    domainsTemplate: deepCopy(prob.domains),\n    constraints: prob.constraints,\n    text: prob.text\n  };\n  resetSolver();\n  log('Initialized problem: ' + PROBLEM.name + ' with ' + PROBLEM.vars.length + ' variables.');\n  updateUI();\n}\n\n/* Reset solver state to initial problem */\nfunction resetSolver() {\n  ASSIGNMENT = {};\n  DOMAINS = deepCopy(PROBLEM ? PROBLEM.domainsTemplate : {});\n  STACK = [];\n  TREE = { id: 0, parent: null, var: null, value: null, status: 'root', children: [], assignment: {} };\n  CURRENT_NODE = TREE;\n  NODES_VISITED = 0;\n  SOLUTIONS = [];\n  nodeIdCounter = 0;\n  HISTORY = [];\n  HISTORY_INDEX = -1;\n  saveHistorySnapshot('initial');\n  updateTreeView();\n  updateUI();\n}\n\n/* Save snapshot for undo/redo */\nfunction saveHistorySnapshot(note) {\n  try {\n    const snap = {\n      assignment: deepCopy(ASSIGNMENT),\n      domains: deepCopy(DOMAINS),\n      stack: deepCopy(STACK),\n      tree: deepCopy(TREE),\n      currentNodeId: CURRENT_NODE ? CURRENT_NODE.id : null,\n      nodesVisited: NODES_VISITED,\n      solutions: deepCopy(SOLUTIONS)\n    };\n    // truncate future if undid\n    if (HISTORY_INDEX < HISTORY.length - 1) HISTORY = HISTORY.slice(0, HISTORY_INDEX + 1);\n    HISTORY.push(snap);\n    HISTORY_INDEX++;\n    // limit history size\n    if (HISTORY.length > 200) HISTORY.shift(), HISTORY_INDEX--;\n  } catch(e) {\n    // ignore heavy snapshots issues\n  }\n}\n\n/* Undo/Redo */\nfunction undo() {\n  if (HISTORY_INDEX <= 0) { log('No more undo'); return; }\n  HISTORY_INDEX--;\n  restoreHistory(HISTORY[HISTORY_INDEX]);\n  log('Undo');\n}\nfunction redo() {\n  if (HISTORY_INDEX >= HISTORY.length - 1) { log('No more redo'); return; }\n  HISTORY_INDEX++;\n  restoreHistory(HISTORY[HISTORY_INDEX]);\n  log('Redo');\n}\nfunction restoreHistory(snap) {\n  if (!snap) return;\n  ASSIGNMENT = deepCopy(snap.assignment);\n  DOMAINS = deepCopy(snap.domains);\n  STACK = deepCopy(snap.stack);\n  TREE = deepCopy(snap.tree);\n  // find node by id to set CURRENT_NODE reference in runtime structure\n  function findNodeById(node, id) {\n    if (!node) return null;\n    if (node.id === id) return node;\n    for (let ch of (node.children||[])) {\n      const found = findNodeById(ch, id);\n      if (found) return found;\n    }\n    return null;\n  }\n  CURRENT_NODE = findNodeById(TREE, snap.currentNodeId) || TREE;\n  NODES_VISITED = snap.nodesVisited || 0;\n  SOLUTIONS = deepCopy(snap.solutions || []);\n  updateTreeView();\n  updateUI();\n}\n\n/* Heuristic selection */\nfunction selectNextVariable() {\n  const heuristic = document.getElementById('heuristicSelect').value;\n  const unassigned = PROBLEM.vars.filter(v => !ASSIGNMENT.hasOwnProperty(v));\n  if (unassigned.length === 0) return null;\n  if (heuristic === 'static') return unassigned[0];\n  if (heuristic === 'random') return unassigned[Math.floor(Math.random() * unassigned.length)];\n  if (heuristic === 'mrv') {\n    // pick var with smallest domain size\n    let best = unassigned[0];\n    let bestLen = (DOMAINS[best] || []).length;\n    for (let v of unassigned) {\n      const len = (DOMAINS[v] || []).length;\n      if (len < bestLen) { best = v; bestLen = len; }\n    }\n    return best;\n  }\n  return unassigned[0];\n}\n\n/* Value order */\nfunction orderValues(arr) {\n  const order = document.getElementById('orderSelect').value;\n  const copy = arr.slice();\n  if (order === 'asc') return copy.sort((a,b)=> (a<b?-1: (a>b?1:0)));\n  if (order === 'desc') return copy.sort((a,b)=> (a>b?-1: (a<b?1:0)));\n  if (order === 'random') {\n    for (let i=copy.length-1;i>0;i--) {\n      const j = Math.floor(Math.random()*(i+1));\n      [copy[i], copy[j]] = [copy[j], copy[i]];\n    }\n    return copy;\n  }\n  return copy;\n}\n\n/* Check constraints: all constraints must return true for partial assignment */\nfunction checkConstraints(assignment) {\n  const fns = PROBLEM.constraints;\n  for (let fn of fns) {\n    try {\n      if (!fn(assignment)) return false;\n    } catch(e) {\n      // If constraint throws, treat as failure but log it\n      log('Constraint error: ' + (e.message || e));\n      return false;\n    }\n  }\n  return true;\n}\n\n/* Forward checking: reduce domains of unassigned vars given current assignment */\nfunction forwardFilterDomains(assignment, domains) {\n  const newDomains = deepCopy(domains);\n  for (let v of PROBLEM.vars) {\n    if (assignment.hasOwnProperty(v)) continue;\n    const avail = newDomains[v] || [];\n    const filtered = avail.filter(val => {\n      const tmp = Object.assign({}, assignment);\n      tmp[v] = val;\n      return checkConstraints(tmp);\n    });\n    newDomains[v] = filtered;\n  }\n  return newDomains;\n}\n\n/* Step the solver once */\nfunction solverStep() {\n  if (!PROBLEM) { log('No problem initialized'); return; }\n  const maxNodes = Math.max(1, Number(document.getElementById('maxNodes').value || 10000));\n  if (NODES_VISITED >= maxNodes) {\n    log('Max nodes reached');\n    stopRun();\n    return;\n  }\n  const depthLimit = Number(document.getElementById('depthLimit').value || 0);\n  // If stack empty, pick next var and push an initial frame\n  if (STACK.length === 0) {\n    const nextVar = selectNextVariable();\n    if (nextVar === null) {\n      // No variables -> trivial solution\n      recordSolution();\n      saveHistorySnapshot('solution');\n      updateUI();\n      return;\n    }\n    // prepare domain ordering\n    const dom = orderValues(DOMAINS[nextVar] || []);\n    // update the underlying DOM representation\n    DOMAINS[nextVar] = dom;\n    // push frame storing domainsBefore as snapshot\n    const frame = { var: nextVar, index: 0, domainsBefore: deepCopy(DOMAINS), parentNode: CURRENT_NODE };\n    STACK.push(frame);\n    saveHistorySnapshot('push frame ' + nextVar);\n    updateUI();\n    return;\n  }\n\n  // operate on top frame\n  const frame = STACK[STACK.length - 1];\n  const v = frame.var;\n  const domList = DOMAINS[v] || [];\n  // domain exhausted -> backtrack\n  if (frame.index >= domList.length) {\n    // mark backtrack on parent node if any\n    // when popping, restore domains and delete assignment if exists\n    if (ASSIGNMENT.hasOwnProperty(v)) {\n      delete ASSIGNMENT[v];\n    }\n    // set current node to parent of frame.parentNode\n    if (frame.parentNode) {\n      // mark that the parent branch is backtracked for UI clarity\n      frame.parentNode.status = frame.parentNode.status || 'backtracked';\n    }\n    // pop\n    STACK.pop();\n    // restore domains to snapshot\n    DOMAINS = deepCopy(frame.domainsBefore);\n    CURRENT_NODE = frame.parentNode || TREE;\n    saveHistorySnapshot('pop ' + v);\n    updateUI();\n    log('Backtracked from var ' + v);\n    return;\n  }\n\n  // try next value\n  const val = domList[frame.index];\n  frame.index++;\n  NODES_VISITED++;\n  // create node in tree\n  const childNode = makeNode(frame.parentNode || CURRENT_NODE, v, val, Object.assign({}, ASSIGNMENT, { [v]: val }));\n  // attach to parent\n  const parentNode = frame.parentNode || CURRENT_NODE;\n  parentNode.children.push(childNode);\n  CURRENT_NODE = childNode;\n\n  // perform assignment\n  ASSIGNMENT[v] = val;\n  saveHistorySnapshot('assign ' + v + '=' + val);\n  log('Try ' + v + ' = ' + JSON.stringify(val));\n  // check constraints\n  if (!checkConstraints(ASSIGNMENT)) {\n    // prune this branch\n    childNode.status = 'pruned';\n    delete ASSIGNMENT[v];\n    // restore domains remain as at top of frame.domainsBefore (we didn't permanently alter them)\n    log('Pruned by constraint: ' + v + '=' + JSON.stringify(val));\n    updateTreeView();\n    updateUI();\n    return;\n  }\n\n  // optionally forward check\n  if (document.getElementById('forwardChk').checked) {\n    const newDom = forwardFilterDomains(ASSIGNMENT, DOMAINS);\n    // if any unassigned var has empty domain -> prune\n    const unassigned = PROBLEM.vars.filter(x => !ASSIGNMENT.hasOwnProperty(x));\n    let dead = false;\n    for (let u of unassigned) {\n      if (!newDom[u] || newDom[u].length === 0) { dead = true; break; }\n    }\n    if (dead) {\n      childNode.status = 'pruned';\n      delete ASSIGNMENT[v];\n      log('Pruned by forward checking at ' + v + '=' + JSON.stringify(val));\n      updateTreeView();\n      updateUI();\n      return;\n    } else {\n      // accept the new domains (propagate)\n      DOMAINS = newDom;\n    }\n  }\n\n  // check if solution\n  const allAssigned = PROBLEM.vars.every(x => ASSIGNMENT.hasOwnProperty(x));\n  if (allAssigned) {\n    childNode.status = 'solution';\n    recordSolution();\n    // after recording solution, prepare to try next choices: remove last assignment and restore domains to frame.domainsBefore\n    delete ASSIGNMENT[v];\n    DOMAINS = deepCopy(frame.domainsBefore);\n    CURRENT_NODE = frame.parentNode || TREE;\n    saveHistorySnapshot('found solution');\n    updateTreeView();\n    updateUI();\n    if (document.getElementById('stopFirstChk').checked) {\n      log('Stopping at first solution.');\n      stopRun();\n    }\n    return;\n  }\n\n  // depth limit check\n  if (depthLimit > 0 && STACK.length >= depthLimit) {\n    childNode.status = 'pruned';\n    delete ASSIGNMENT[v];\n    DOMAINS = deepCopy(frame.domainsBefore);\n    CURRENT_NODE = frame.parentNode || TREE;\n    log('Pruned due to depth limit at ' + v + '=' + JSON.stringify(val));\n    updateTreeView();\n    updateUI();\n    return;\n  }\n\n  // push next variable frame for further exploration\n  const nextVar = selectNextVariable();\n  if (!nextVar) {\n    // should not happen because we checked allAssigned earlier\n    log('No next var available unexpectedly.');\n    delete ASSIGNMENT[v];\n    DOMAINS = deepCopy(frame.domainsBefore);\n    CURRENT_NODE = frame.parentNode || TREE;\n    updateTreeView();\n    updateUI();\n    return;\n  }\n  // order its values according to user selection; update DOMAINS snapshot for that var\n  DOMAINS[nextVar] = orderValues(DOMAINS[nextVar] || []);\n  const newFrame = { var: nextVar, index: 0, domainsBefore: deepCopy(DOMAINS), parentNode: childNode };\n  STACK.push(newFrame);\n  saveHistorySnapshot('push ' + nextVar);\n  updateTreeView();\n  updateUI();\n}\n\n/* Record a solution snapshot */\nfunction recordSolution() {\n  const sol = deepCopy(ASSIGNMENT);\n  SOLUTIONS.push(sol);\n  const solDiv = document.getElementById('solutionsDiv');\n  const entry = document.createElement('div');\n  entry.textContent = JSON.stringify(sol);\n  solDiv.appendChild(entry);\n  log('Solution #' + SOLUTIONS.length + ': ' + JSON.stringify(sol));\n}\n\n/* Run / Pause management */\nfunction startRun() {\n  if (!PROBLEM) { log('Initialize problem first'); return; }\n  if (RUN_TIMER) return;\n  const ms = Number(document.getElementById('speedRange').value || 250);\n  document.getElementById('runBtn').disabled = true;\n  document.getElementById('pauseBtn').disabled = false;\n  log('Run started');\n  RUN_TIMER = setInterval(() => {\n    const stopOnFirst = document.getElementById('stopFirstChk').checked;\n    solverStep();\n    if (RUN_TIMER && stopOnFirst && SOLUTIONS.length > 0) {\n      stopRun();\n    }\n    // stop if reached node limit\n    const maxNodes = Math.max(1, Number(document.getElementById('maxNodes').value || 10000));\n    if (NODES_VISITED >= maxNodes) stopRun();\n  }, ms);\n}\nfunction stopRun() {\n  if (RUN_TIMER) {\n    clearInterval(RUN_TIMER);\n    RUN_TIMER = null;\n    document.getElementById('runBtn').disabled = false;\n    document.getElementById('pauseBtn').disabled = true;\n    log('Run stopped');\n  }\n}\n\n/* Update UI elements to reflect state */\nfunction updateUI() {\n  document.getElementById('assignPre').textContent = JSON.stringify(ASSIGNMENT, null, 2);\n  document.getElementById('domainsPre').textContent = JSON.stringify(DOMAINS, null, 2);\n  document.getElementById('countersPre').textContent =\n    'nodesVisited: ' + NODES_VISITED + '\\\\n' +\n    'solutions: ' + SOLUTIONS.length + '\\\\n' +\n    'depth: ' + STACK.length + '\\\\n' +\n    'stackSize: ' + STACK.length;\n  // enable/disable undo/redo\n  document.getElementById('undoBtn').disabled = (HISTORY_INDEX <= 0);\n  document.getElementById('redoBtn').disabled = (HISTORY_INDEX >= HISTORY.length - 1);\n  // update next solution button\n  document.getElementById('nextSolBtn').disabled = false;\n  // Keep tree view updated\n  updateTreeView();\n}\n\n/* Update tree view rendering (text-only nested structure) */\nfunction updateTreeView() {\n  const container = document.getElementById('treeDiv');\n  container.innerHTML = '';\n  function renderNode(node, depth) {\n    const el = document.createElement('div');\n    el.style = '';\n    const label = document.createElement('span');\n    if (node.id === 0) label.textContent = '[root]';\n    else label.textContent = node.var + ' = ' + JSON.stringify(node.value) + ' (' + node.status + ')';\n    label.style.cursor = 'pointer';\n    label.dataset.nodeId = node.id;\n    label.onclick = () => { selectTreeNode(node.id); };\n    el.appendChild(label);\n    if (node.children && node.children.length > 0) {\n      const chContainer = document.createElement('div');\n      chContainer.style.marginLeft = '12px';\n      for (let ch of node.children) chContainer.appendChild(renderNode(ch, depth+1));\n      el.appendChild(chContainer);\n    }\n    return el;\n  }\n  const rootEl = renderNode(TREE, 0);\n  container.appendChild(rootEl);\n}\n\n/* Selected tree node logic */\nlet SELECTED_NODE_ID = null;\nfunction findNodeById(node, id) {\n  if (!node) return null;\n  if (node.id === id) return node;\n  for (let ch of (node.children||[])) {\n    const f = findNodeById(ch, id);\n    if (f) return f;\n  }\n  return null;\n}\nfunction selectTreeNode(id) {\n  SELECTED_NODE_ID = id;\n  const node = findNodeById(TREE, id);\n  if (!node) return;\n  // show node assignment in a quick preview area\n  document.getElementById('assignPre').textContent = JSON.stringify(node.assignment, null, 2);\n  document.getElementById('jumpToNodeBtn').disabled = false;\n  document.getElementById('pruneNodeBtn').disabled = false;\n}\n\n/* Jump to a selected node: set solver state as if we are at that assignment */\nfunction exploreFromSelectedNode() {\n  if (SELECTED_NODE_ID === null) return;\n  const node = findNodeById(TREE, SELECTED_NODE_ID);\n  if (!node) return;\n  // build assignment from node and set domains by forward filtering\n  ASSIGNMENT = deepCopy(node.assignment || {});\n  DOMAINS = deepCopy(PROBLEM.domainsTemplate);\n  // apply forward filter from current assignment\n  if (document.getElementById('forwardChk').checked) {\n    DOMAINS = forwardFilterDomains(ASSIGNMENT, DOMAINS);\n  }\n  // rebuild stack to a minimal state: push a frame for next variable if any\n  STACK = [];\n  const nextVar = selectNextVariable();\n  if (nextVar) {\n    DOMAINS[nextVar] = orderValues(DOMAINS[nextVar] || []);\n    STACK.push({ var: nextVar, index: 0, domainsBefore: deepCopy(DOMAINS), parentNode: node });\n  }\n  CURRENT_NODE = node;\n  saveHistorySnapshot('explore from node ' + node.id);\n  updateUI();\n  log('Exploring from node ' + node.id);\n}\n\n/* Mark node as pruned manually */\nfunction pruneSelectedNode() {\n  if (SELECTED_NODE_ID === null) return;\n  const node = findNodeById(TREE, SELECTED_NODE_ID);\n  if (!node) return;\n  node.status = 'pruned';\n  saveHistorySnapshot('prune node ' + node.id);\n  updateTreeView();\n  updateUI();\n  log('Node ' + node.id + ' marked pruned by user.');\n}\n\n/* Export / Import tree or full state */\nfunction exportTreeJSON() {\n  const out = JSON.stringify(TREE, null, 2);\n  download('backtrack_tree.json', out);\n}\nfunction importTreeFromText(txt) {\n  try {\n    const obj = JSON.parse(txt);\n    TREE = obj;\n    CURRENT_NODE = TREE;\n    saveHistorySnapshot('import tree');\n    updateTreeView();\n    updateUI();\n    log('Tree imported.');\n  } catch(e) {\n    log('Import failed: ' + e.message);\n  }\n}\nfunction downloadState() {\n  const state = { PROBLEM, ASSIGNMENT, DOMAINS, STACK, TREE, NODES_VISITED, SOLUTIONS };\n  download('bt_state.json', JSON.stringify(state, null, 2));\n}\n\n/* Save / Load state from file input */\ndocument.getElementById('loadStateFile').addEventListener('change', function(e){\n  const f = e.target.files[0];\n  if (!f) return;\n  const reader = new FileReader();\n  reader.onload = function(ev) {\n    try {\n      const obj = JSON.parse(ev.target.result);\n      // restore\n      if (obj.PROBLEM) PROBLEM = obj.PROBLEM;\n      ASSIGNMENT = obj.ASSIGNMENT || {};\n      DOMAINS = obj.DOMAINS || (PROBLEM ? deepCopy(PROBLEM.domainsTemplate) : {});\n      STACK = obj.STACK || [];\n      TREE = obj.TREE || { id: 0, parent: null, var: null, value: null, status: 'root', children: [], assignment: {} };\n      NODES_VISITED = obj.NODES_VISITED || 0;\n      SOLUTIONS = obj.SOLUTIONS || [];\n      CURRENT_NODE = TREE;\n      saveHistorySnapshot('loaded file');\n      updateTreeView();\n      updateUI();\n      log('State loaded from file.');\n    } catch(e) {\n      log('Failed to load state: ' + e.message);\n    }\n  };\n  reader.readAsText(f);\n});\n\n/* Wiring UI controls */\ndocument.getElementById('templateSelect').addEventListener('change', function(e){\n  const val = e.target.value;\n  document.getElementById('nqueensParams').style.display = val === 'nqueens' ? '' : 'none';\n  document.getElementById('subsetParams').style.display = val === 'subset' ? '' : 'none';\n  document.getElementById('graphParams').style.display = val === 'graphcolor' ? '' : 'none';\n  document.getElementById('customParams').style.display = val === 'custom' ? '' : 'none';\n});\n\ndocument.getElementById('initBtn').addEventListener('click', function(){ initProblemFromUI(); });\ndocument.getElementById('resetBtn').addEventListener('click', function(){ if (PROBLEM) resetSolver(); });\ndocument.getElementById('clearLogBtn').addEventListener('click', function(){ document.getElementById('logArea').value = ''; });\n\ndocument.getElementById('stepBtn').addEventListener('click', function(){ solverStep(); });\ndocument.getElementById('runBtn').addEventListener('click', function(){ startRun(); });\ndocument.getElementById('pauseBtn').addEventListener('click', function(){ stopRun(); });\ndocument.getElementById('nextSolBtn').addEventListener('click', function(){\n  // run until next solution or node limit\n  const stopAtFirstBox = document.getElementById('stopFirstChk');\n  const prev = stopAtFirstBox.checked;\n  stopAtFirstBox.checked = true;\n  startRun();\n  // Will stop automatically by stopAtFirst behavior\n  setTimeout(()=> { stopAtFirstBox.checked = prev; }, 1000);\n});\ndocument.getElementById('findAllBtn').addEventListener('click', function(){\n  const limit = Number(prompt('Find up to how many solutions?', '100')) || 100;\n  SOL_LIMIT = limit;\n  const oldStop = document.getElementById('stopFirstChk').checked;\n  document.getElementById('stopFirstChk').checked = false;\n  startRun();\n  // We'll rely on maxNodes or user pause to stop; user can pause.\n});\n\ndocument.getElementById('undoBtn').addEventListener('click', undo);\ndocument.getElementById('redoBtn').addEventListener('click', redo);\ndocument.getElementById('saveStateBtn').addEventListener('click', function(){\n  downloadState();\n});\ndocument.getElementById('stepBtn').addEventListener('dblclick', function(){ // double click to do many steps quickly\n  for (let i=0;i<10;i++) solverStep();\n});\n\ndocument.getElementById('exportTreeBtn').addEventListener('click', exportTreeJSON);\ndocument.getElementById('importTreeBtn').addEventListener('click', function(){\n  const txt = prompt('Paste tree JSON here:');\n  if (!txt) return;\n  importTreeFromText(txt);\n});\n\ndocument.getElementById('jumpToNodeBtn').addEventListener('click', exploreFromSelectedNode);\ndocument.getElementById('pruneNodeBtn').addEventListener('click', pruneSelectedNode);\ndocument.getElementById('expandAllBtn').addEventListener('click', function(){\n  updateTreeView();\n});\n\ndocument.getElementById('doImportBtn').addEventListener('click', function(){\n  const txt = document.getElementById('importText').value;\n  if (!txt) return;\n  // determine if it's a state or a tree\n  try {\n    const obj = JSON.parse(txt);\n    if (obj.TREE || obj.tree) {\n      TREE = obj.TREE || obj.tree;\n      updateTreeView();\n      log('Imported tree from JSON');\n    } else if (obj.PROBLEM || obj.problem) {\n      // assume full state\n      if (obj.PROBLEM) PROBLEM = obj.PROBLEM;\n      ASSIGNMENT = obj.ASSIGNMENT || {};\n      DOMAINS = obj.DOMAINS || (PROBLEM ? deepCopy(PROBLEM.domainsTemplate) : {});\n      STACK = obj.STACK || [];\n      TREE = obj.TREE || { id: 0, parent: null, var: null, value: null, status: 'root', children: [], assignment: {} };\n      NODES_VISITED = obj.NODES_VISITED || 0;\n      SOLUTIONS = obj.SOLUTIONS || [];\n      updateTreeView();\n      updateUI();\n      log('Imported state JSON');\n    } else {\n      TREE = obj;\n      updateTreeView();\n      log('Imported tree');\n    }\n  } catch(e) {\n    log('Import failed: ' + e.message);\n  }\n});\n\ndocument.getElementById('downloadStateBtn').addEventListener('click', downloadState);\n\n/* Node selection by clicking tree label sets SELECTED_NODE_ID */\ndocument.getElementById('treeDiv').addEventListener('click', function(e){\n  const target = e.target;\n  if (target && target.dataset && target.dataset.nodeId) {\n    selectTreeNode(Number(target.dataset.nodeId));\n  }\n});\n\n/* Simple initialization */\n(function boot() {\n  // attach loadStateFile to handler shown above\n  // populate initial problem\n  initProblemFromUI();\n  log('Boot complete');\n})();\n\n</script>\n</body>\n</html>"
