  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Merge Sort Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n  }\n  button, input[type=number], input[type=text], select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin: 0.2em 0.4em 0.2em 0;\n  }\n  #arrayInput {\n    width: 300px;\n  }\n  pre {\n    white-space: pre-wrap;\n    word-wrap: break-word;\n  }\n  label {\n    display: inline-block;\n    margin-top: 0.5em;\n  }\n  fieldset {\n    margin-top: 1em;\n    margin-bottom: 1em;\n    padding: 0.5em;\n    max-width: 720px;\n  }\n  #statesList {\n    max-height: 150px;\n    overflow-y: scroll;\n    border: 1px solid black;\n    padding: 0.3em;\n    margin-top: 0.3em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Merge Sort Interactive Demo</h1>\n\n<p>\nThis tool lets you enter a list of numbers and step through the <strong>Merge Sort</strong> algorithm interactively.\nYou can explore every division, merge, and the evolution of the array.\n</p>\n\n<fieldset>\n<legend>Input & Initialization</legend>\n\n<label for=\"arrayInput\">Enter array (comma, space or newline separated numbers):</label><br />\n<textarea id=\"arrayInput\" rows=\"3\" cols=\"50\" aria-label=\"Array input\"></textarea><br />\n<button id=\"loadArrayBtn\">Load Array & Initialize</button>\n<button id=\"randomArrayBtn\">Generate Random Array</button>\n<label for=\"randomSizeInput\">Size:</label>\n<input type=\"number\" id=\"randomSizeInput\" min=\"2\" max=\"100\" value=\"10\" aria-label=\"Random array size input\" />\n</fieldset>\n\n<fieldset>\n<legend>Algorithm Controls</legend>\n\n<button id=\"stepForwardBtn\" disabled>Step Forward</button>\n<button id=\"stepBackBtn\" disabled>Step Back</button>\n<button id=\"autoPlayBtn\" disabled>Auto Play</button>\n<button id=\"pauseBtn\" disabled>Pause</button>\n<label for=\"speedSlider\">Speed (steps/sec):</label>\n<input type=\"range\" id=\"speedSlider\" min=\"1\" max=\"10\" value=\"3\" aria-label=\"Auto play speed slider\" />\n</fieldset>\n\n<fieldset>\n<legend>Current State</legend>\n<label>Current array state:</label><br />\n<pre id=\"currentArrayPre\">[]</pre>\n\n<label>Current operation:</label><br />\n<pre id=\"currentOperationPre\">Not started</pre>\n\n<label>Split / Merge path (clickable):</label><br />\n<div id=\"statesList\" aria-label=\"List of recorded algorithm states\" tabindex=\"0\">\n<!-- states -->\n</div>\n</fieldset>\n\n<fieldset>\n<legend>Deep Exploration Controls</legend>\n<p>Jump directly to any recorded step or change array on-the-fly:</p>\n\n<label for=\"jumpToInput\">Step number (0 = initial):</label>\n<input type=\"number\" id=\"jumpToInput\" min=\"0\" value=\"0\" style=\"width:5em\" />\n<button id=\"jumpToBtn\" disabled>Jump To Step</button>\n<button id=\"resetBtn\" disabled>Reset</button>\n\n<p>Modify elements of current array state:</p>\n<label for=\"modifyIndexInput\">Index:</label>\n<input type=\"number\" id=\"modifyIndexInput\" min=\"0\" value=\"0\" style=\"width:5em\" disabled aria-label=\"Index of element to modify\" />\n<label for=\"modifyValueInput\">Value:</label>\n<input type=\"number\" id=\"modifyValueInput\" value=\"0\" style=\"width:6em\" disabled aria-label=\"New value of element to modify\" />\n<button id=\"modifyBtn\" disabled>Modify and Recalculate From Here</button>\n\n</fieldset>\n\n<script>\n(() => {\n  // Data model and state management for interactive merge sort exploration\n\n  /*\n    We'll keep an array 'states':\n    Each state is an object:\n    {\n      array: [Number], // current array at this step\n      operation: String, // description text: \"Split L=[...] R=[...]\", or \"Merge indexes x-y with w-z\", or \"Initial array\"\n      leftIndexes: [start, end] or null,\n      rightIndexes: [start, end] or null,\n      isMerge: boolean,\n      mergedFrom: [stateIndex1, stateIndex2] or null,\n      parentIndex: number or null (which step led to this merge)\n    }\n\n    The states array represents the step history, step 0 is initial array state.\n\n    We'll implement merge sort, but recording each split and merge as a separate step.\n\n    Controls update manipulation of the current step index (currentStep)\n  */\n\n  // DOM references\n  const arrayInput = document.getElementById(\"arrayInput\");\n  const loadArrayBtn = document.getElementById(\"loadArrayBtn\");\n  const randomArrayBtn = document.getElementById(\"randomArrayBtn\");\n  const randomSizeInput = document.getElementById(\"randomSizeInput\");\n\n  const stepForwardBtn = document.getElementById(\"stepForwardBtn\");\n  const stepBackBtn = document.getElementById(\"stepBackBtn\");\n  const autoPlayBtn = document.getElementById(\"autoPlayBtn\");\n  const pauseBtn = document.getElementById(\"pauseBtn\");\n  const speedSlider = document.getElementById(\"speedSlider\");\n\n  const currentArrayPre = document.getElementById(\"currentArrayPre\");\n  const currentOperationPre = document.getElementById(\"currentOperationPre\");\n  const statesListDiv = document.getElementById(\"statesList\");\n\n  const jumpToInput = document.getElementById(\"jumpToInput\");\n  const jumpToBtn = document.getElementById(\"jumpToBtn\");\n  const resetBtn = document.getElementById(\"resetBtn\");\n\n  const modifyIndexInput = document.getElementById(\"modifyIndexInput\");\n  const modifyValueInput = document.getElementById(\"modifyValueInput\");\n  const modifyBtn = document.getElementById(\"modifyBtn\");\n\n  // Data state\n  let states = [];\n  let currentStep = 0;\n  let autoPlayTimer = null;\n  let autoPlayIntervalMs = 333; // default for 3 steps/s\n\n  // Utility\n  function parseArrayInput(text) {\n    // parse numbers separated by comma/space/newline\n    const parts = text.trim().split(/[\\s,]+/);\n    const arr = [];\n    for (let p of parts) {\n      if (p === \"\") continue;\n      let n = Number(p);\n      if (!Number.isFinite(n)) return null;\n      arr.push(n);\n    }\n    if (arr.length < 2) return null;\n    return arr;\n  }\n\n  // Given an array, returns a deep copy array\n  function arrCopy(arr) {\n    return arr.slice();\n  }\n\n  // Recursive full merge sort recording all steps into newStates starting from offset\n  // Each step records the subarray state and operation description\n  // Returns the index into newStates of the final sorted array state\n  function mergeSortRecord(arr, startIdx, endIdx, newStates, parentIndex = null) {\n    /*\n      arr: full original array (for reference)\n      startIdx, endIdx: current subarray to sort (inclusive)\n      newStates: array where we'll push new states\n      parentIndex: index in newStates of parent operation that led here (null for first call)\n    */\n\n    if (startIdx === endIdx) {\n      // single element, record and return\n      const singleArr = [arr[startIdx]];\n      const state = {\n        array: singleArr,\n        operation: `Single element at index ${startIdx}: [${singleArr}]`,\n        leftIndexes: [startIdx, startIdx],\n        rightIndexes: null,\n        isMerge: false,\n        mergedFrom: null,\n        parentIndex\n      };\n      newStates.push(state);\n      return newStates.length - 1;\n    }\n\n    // split in middle\n    const mid = Math.floor((startIdx + endIdx) / 2);\n\n    // record splitting step\n    const subArray = arr.slice(startIdx, endIdx + 1);\n\n    const splitState = {\n      array: arrCopy(subArray),\n      operation: `Split subarray indexes ${startIdx} to ${endIdx} into [${startIdx}..${mid}] and [${mid+1}..${endIdx}]`,\n      leftIndexes: [startIdx, mid],\n      rightIndexes: [mid+1, endIdx],\n      isMerge: false,\n      mergedFrom: null,\n      parentIndex\n    };\n    newStates.push(splitState);\n    const splitStepIndex = newStates.length - 1;\n\n    // recurse left and right\n    const leftIdx = mergeSortRecord(arr, startIdx, mid, newStates, splitStepIndex);\n    const rightIdx = mergeSortRecord(arr, mid + 1, endIdx, newStates, splitStepIndex);\n\n    // retrieve the sorted left and right arrays from states\n    const leftArr = newStates[leftIdx].array;\n    const rightArr = newStates[rightIdx].array;\n\n    // merge leftArr and rightArr, producing mergedArr\n    const mergedArr = [];\n    let i = 0, j = 0;\n    while (i < leftArr.length && j < rightArr.length) {\n      if (leftArr[i] <= rightArr[j]) {\n        mergedArr.push(leftArr[i]);\n        i++;\n      } else {\n        mergedArr.push(rightArr[j]);\n        j++;\n      }\n    }\n    while (i < leftArr.length) {\n      mergedArr.push(leftArr[i]);\n      i++;\n    }\n    while (j < rightArr.length) {\n      mergedArr.push(rightArr[j]);\n      j++;\n    }\n\n    const mergedState = {\n      array: mergedArr,\n      operation: `Merge [${startIdx}..${mid}] and [${mid+1}..${endIdx}] into sorted subarray: [${mergedArr.join(\", \")}]`,\n      leftIndexes: [startIdx, mid],\n      rightIndexes: [mid+1, endIdx],\n      isMerge: true,\n      mergedFrom: [leftIdx, rightIdx],\n      parentIndex: splitStepIndex,\n    };\n\n    newStates.push(mergedState);\n    return newStates.length - 1;\n  }\n\n  // Build all states from initial array input\n  function buildAllStatesFromArray(arr) {\n    const allStates = [];\n    // step 0 initial state\n    allStates.push({\n      array: arrCopy(arr),\n      operation: \"Initial array\",\n      leftIndexes: [0, arr.length - 1],\n      rightIndexes: null,\n      isMerge: false,\n      mergedFrom: null,\n      parentIndex: null,\n    });\n    if (arr.length < 2) {\n      // nothing to do, just one element or empty\n      return allStates;\n    }\n    // build merge sort states from arr indexes 0..length-1\n    mergeSortRecord(arr, 0, arr.length - 1, allStates, 0);\n    return allStates;\n  }\n\n  // Refresh the states list panel\n  function renderStatesList() {\n    statesListDiv.innerHTML = \"\";\n    states.forEach((st, idx) => {\n      const el = document.createElement(\"div\");\n      el.textContent = `Step ${idx}: ${st.operation}`;\n      el.style.cursor = \"pointer\";\n      if (idx === currentStep) {\n        el.style.fontWeight = \"bold\";\n        el.style.textDecoration = \"underline\";\n      }\n      el.tabIndex = 0;\n      el.setAttribute(\"role\", \"button\");\n      el.setAttribute(\"aria-pressed\", idx === currentStep);\n      el.addEventListener(\"click\", () => {\n        jumpToStep(idx);\n      });\n      el.addEventListener(\"keydown\", (ev) => {\n        if (ev.key === \"Enter\" || ev.key === \" \") {\n          ev.preventDefault();\n          jumpToStep(idx);\n        }\n      });\n      statesListDiv.appendChild(el);\n    });\n  }\n\n  // Update the display for current step\n  function updateDisplay() {\n    const st = states[currentStep];\n    currentArrayPre.textContent = `[${st.array.join(\", \")}]`;\n    currentOperationPre.textContent = st.operation;\n\n    jumpToInput.value = currentStep.toString();\n    jumpToInput.max = states.length - 1;\n\n    modifyIndexInput.disabled = st.array.length === 0;\n    if (!modifyIndexInput.disabled) {\n      modifyIndexInput.max = st.array.length - 1;\n      if (modifyIndexInput.value > modifyIndexInput.max)\n        modifyIndexInput.value = modifyIndexInput.max;\n    }\n    const enableHistoryNav = states.length > 1;\n    stepForwardBtn.disabled = currentStep >= states.length - 1;\n    stepBackBtn.disabled = currentStep <= 0;\n    jumpToBtn.disabled = !enableHistoryNav;\n    modifyBtn.disabled = modifyIndexInput.disabled;\n    resetBtn.disabled = !enableHistoryNav;\n\n    // Auto play/pause buttons toggle\n    autoPlayBtn.disabled = !enableHistoryNav;\n    pauseBtn.disabled = true;\n\n    renderStatesList();\n  }\n\n  // Change step index within states\n  function jumpToStep(idx) {\n    if (idx < 0) idx = 0;\n    if (idx >= states.length) idx = states.length - 1;\n    currentStep = idx;\n    updateDisplay();\n  }\n\n  // Increment step forward\n  function stepForward() {\n    if (currentStep < states.length - 1) {\n      currentStep++;\n      updateDisplay();\n    }\n  }\n\n  // Step backward in history\n  function stepBack() {\n    if (currentStep > 0) {\n      currentStep--;\n      updateDisplay();\n    }\n  }\n\n  // Auto play controls\n  function startAutoPlay() {\n    if (autoPlayTimer) return; // already running\n    autoPlayBtn.disabled = true;\n    pauseBtn.disabled = false;\n    stepBackBtn.disabled = true;\n    stepForwardBtn.disabled = true;\n    jumpToBtn.disabled = true;\n    modifyBtn.disabled = true;\n    resetBtn.disabled = true;\n    speedSlider.disabled = true;\n    autoPlayTimer = setInterval(() => {\n      if (currentStep < states.length - 1) {\n        currentStep++;\n        updateDisplay();\n      } else {\n        stopAutoPlay();\n      }\n    }, autoPlayIntervalMs);\n  }\n\n  function stopAutoPlay() {\n    if (!autoPlayTimer) return;\n    clearInterval(autoPlayTimer);\n    autoPlayTimer = null;\n    autoPlayBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBackBtn.disabled = false;\n    stepForwardBtn.disabled = false;\n    jumpToBtn.disabled = false;\n    modifyBtn.disabled = false;\n    resetBtn.disabled = false;\n    speedSlider.disabled = false;\n  }\n\n  // Generate random array\n  function generateRandomArray(size) {\n    const arr = [];\n    for (let i = 0; i < size; i++) {\n      // Choose integers between -999 and 999\n      const v = Math.floor(Math.random() * 1999) - 999;\n      arr.push(v);\n    }\n    return arr;\n  }\n\n  // Immediately recalculate states from current array (from user modify or initial load)\n  function recalcStatesFromArray(arr) {\n    if (arr.length < 1) {\n      alert(\"Array must contain at least one element.\");\n      return;\n    }\n    states = buildAllStatesFromArray(arr);\n    currentStep = 0;\n    updateDisplay();\n  }\n\n  // Modify current displayed state array element and recalc from there\n  function modifyCurrentStepAndRecalc(index, newValue) {\n    if (index < 0 || index >= states[currentStep].array.length) {\n      alert(\"Index out of bounds\");\n      return;\n    }\n    // Create a copy of the current array at this step and modify\n    const baseArr = arrCopy(states[currentStep].array);\n    baseArr[index] = newValue;\n\n    // We'll rebuild all states starting from baseArr only for the subarray slice this step shows.\n    // BUT since we can modify arbitrary element, better to recalc entire states from baseArr\n    recalcStatesFromArray(baseArr);\n  }\n\n  // --- Event listeners ---\n\n  loadArrayBtn.addEventListener(\"click\", () => {\n    const arrText = arrayInput.value;\n    const parsedArr = parseArrayInput(arrText);\n    if (!parsedArr) {\n      alert(\"Invalid array input! Enter at least 2 valid numbers separated by commas, spaces or newlines.\");\n      return;\n    }\n    recalcStatesFromArray(parsedArr);\n  });\n\n  randomArrayBtn.addEventListener(\"click\", () => {\n    let size = parseInt(randomSizeInput.value, 10);\n    if (!Number.isInteger(size) || size < 2 || size > 100) {\n      alert(\"Invalid size. Please enter an integer between 2 and 100.\");\n      return;\n    }\n    const randArr = generateRandomArray(size);\n    arrayInput.value = randArr.join(\", \");\n    recalcStatesFromArray(randArr);\n  });\n\n  stepForwardBtn.addEventListener(\"click\", () => {\n    stepForward();\n  });\n\n  stepBackBtn.addEventListener(\"click\", () => {\n    stepBack();\n  });\n\n  autoPlayBtn.addEventListener(\"click\", () => {\n    startAutoPlay();\n  });\n\n  pauseBtn.addEventListener(\"click\", () => {\n    stopAutoPlay();\n  });\n\n  speedSlider.addEventListener(\"input\", () => {\n    const speed = parseInt(speedSlider.value, 10);\n    if (speed > 0) {\n      autoPlayIntervalMs = 1000 / speed;\n      if (autoPlayTimer) {\n        stopAutoPlay();\n        startAutoPlay();\n      }\n    }\n  });\n\n  jumpToBtn.addEventListener(\"click\", () => {\n    let val = parseInt(jumpToInput.value, 10);\n    if (isNaN(val) || val < 0 || val >= states.length) {\n      alert(`Invalid step number. Enter a number between 0 and ${states.length - 1}.`);\n      return;\n    }\n    jumpToStep(val);\n  });\n\n  resetBtn.addEventListener(\"click\", () => {\n    currentStep = 0;\n    updateDisplay();\n  });\n\n  modifyBtn.addEventListener(\"click\", () => {\n    const idx = parseInt(modifyIndexInput.value, 10);\n    const val = Number(modifyValueInput.value);\n    if (!Number.isFinite(val)) {\n      alert(\"Invalid new value.\");\n      return;\n    }\n    modifyCurrentStepAndRecalc(idx, val);\n  });\n\n  // Update modifyValue when index changes\n  modifyIndexInput.addEventListener(\"change\", () => {\n    const idx = parseInt(modifyIndexInput.value, 10);\n    if (idx >= 0 && idx < states[currentStep].array.length) {\n      modifyValueInput.value = states[currentStep].array[idx];\n    }\n  });\n\n  // Keyboard shortcuts:\n  // Right Arrow = step forward\n  // Left Arrow = step backward\n  // Space = auto play / pause toggle\n  window.addEventListener(\"keydown\", (ev) => {\n    if (ev.target.tagName === \"INPUT\" || ev.target.tagName === \"TEXTAREA\" || ev.target.isContentEditable) {\n      return; // do not interfere with typing\n    }\n    if (ev.key === \"ArrowRight\") {\n      ev.preventDefault();\n      stepForward();\n    } else if (ev.key === \"ArrowLeft\") {\n      ev.preventDefault();\n      stepBack();\n    } else if (ev.key === \" \") {\n      ev.preventDefault();\n      if (autoPlayTimer) {\n        stopAutoPlay();\n      } else {\n        startAutoPlay();\n      }\n    }\n  });\n\n  // On page load: Initialize minimal state with empty array and disabled controls\n  function initialSetup() {\n    states = [{\n      array: [],\n      operation: \"No array loaded\",\n      leftIndexes: null,\n      rightIndexes: null,\n      isMerge: false,\n      mergedFrom: null,\n      parentIndex: null\n    }];\n    currentStep = 0;\n    updateDisplay();\n\n    stepForwardBtn.disabled = true;\n    stepBackBtn.disabled = true;\n    autoPlayBtn.disabled = true;\n    pauseBtn.disabled = true;\n    jumpToBtn.disabled = true;\n    modifyBtn.disabled = true;\n    resetBtn.disabled = true;\n    modifyIndexInput.disabled = true;\n    modifyValueInput.disabled = true;\n  }\n\n  // Initialize on page load\n  initialSetup();\n})();\n</script>\n\n</body>\n</html>"
  },
