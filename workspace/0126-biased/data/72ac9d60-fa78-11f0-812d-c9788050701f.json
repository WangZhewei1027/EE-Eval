    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Harmonic Load Balancing</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #00cec9;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n            --warning: #fdcb6e;\n            --danger: #d63031;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Montserrat', sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #2d3436 0%, #000000 100%);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 2px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: rgba(245, 246, 250, 0.7);\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            position: relative;\n            height: 500px;\n            margin: 4rem 0;\n            border-radius: 16px;\n            background: rgba(45, 52, 54, 0.5);\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            overflow: hidden;\n            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);\n            opacity: 0;\n            transform: translateY(30px);\n            animation: fadeInUp 1s ease-out 0.5s forwards;\n        }\n\n        .load-balancer {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 120px;\n            height: 120px;\n            background: rgba(108, 92, 231, 0.2);\n            border-radius: 50%;\n            border: 2px solid var(--primary);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            z-index: 10;\n            box-shadow: 0 0 30px rgba(108, 92, 231, 0.5);\n        }\n\n        .load-balancer::before {\n            content: '';\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            background: rgba(108, 92, 231, 0.4);\n            animation: pulse 3s infinite;\n        }\n\n        .load-balancer-inner {\n            width: 40px;\n            height: 40px;\n            background: var(--primary);\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            z-index: 11;\n        }\n\n        .server {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 8px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.5s ease;\n            z-index: 5;\n        }\n\n        .server-icon {\n            font-size: 1.8rem;\n            margin-bottom: 5px;\n        }\n\n        .server-label {\n            font-size: 0.7rem;\n            font-weight: bold;\n        }\n\n        .server.load {\n            background: rgba(0, 184, 148, 0.2);\n            border: 2px solid var(--success);\n            box-shadow: 0 0 20px rgba(0, 184, 148, 0.3);\n        }\n\n        .server.overload {\n            background: rgba(214, 48, 49, 0.2);\n            border: 2px solid var(--danger);\n            box-shadow: 0 0 20px rgba(214, 48, 49, 0.3);\n            animation: alert 1s infinite;\n        }\n\n        .connection {\n            position: absolute;\n            background: rgba(253, 121, 168, 0.3);\n            height: 2px;\n            transform-origin: left center;\n            z-index: 1;\n            transition: all 0.5s ease;\n        }\n\n        .connection.active {\n            background: var(--accent);\n            box-shadow: 0 0 10px var(--accent);\n        }\n\n        .request {\n            position: absolute;\n            width: 10px;\n            height: 10px;\n            background: var(--accent);\n            border-radius: 50%;\n            z-index: 20;\n            transition: all 0.7s ease;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1s forwards;\n        }\n\n        button {\n            background: rgba(108, 92, 231, 0.3);\n            color: white;\n            border: 1px solid var(--primary);\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            cursor: pointer;\n            font-size: 1rem;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(5px);\n        }\n\n        button:hover {\n            background: rgba(108, 92, 231, 0.5);\n            transform: translateY(-2px);\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n        }\n\n        .stats {\n            display: flex;\n            justify-content: space-around;\n            margin-top: 3rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        .stat-card {\n            background: rgba(45, 52, 54, 0.7);\n            border-radius: 12px;\n            padding: 1.5rem;\n            width: 200px;\n            text-align: center;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: all 0.3s ease;\n        }\n\n        .stat-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);\n        }\n\n        .stat-value {\n            font-size: 2.5rem;\n            font-weight: 300;\n            margin: 0.5rem 0;\n            background: linear-gradient(to right, var(--secondary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n\n        .stat-label {\n            font-size: 0.9rem;\n            color: rgba(245, 246, 250, 0.7);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(30px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); opacity: 0.8; }\n            50% { transform: scale(1.2); opacity: 0; }\n            100% { transform: scale(1); opacity: 0; }\n        }\n\n        @keyframes alert {\n            0% { box-shadow: 0 0 10px rgba(214, 48, 49, 0.5); }\n            50% { box-shadow: 0 0 30px rgba(214, 48, 49, 0.8); }\n            100% { box-shadow: 0 0 10px rgba(214, 48, 49, 0.5); }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            color: rgba(245, 246, 250, 0.5);\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 2s forwards;\n        }\n    </style>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Harmonic Load Balancing</h1>\n            <p class=\"subtitle\">A visual symphony of distributed computing, where requests flow like musical notes across servers, orchestrated by the maestro load balancer.</p>\n        </header>\n\n        <div class=\"visualization\" id=\"visualization\">\n            <div class=\"load-balancer\">\n                <div class=\"load-balancer-inner\">LB</div>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Flow</button>\n            <button id=\"stressBtn\">Stress Test</button>\n        </div>\n\n        <div class=\"stats\">\n            <div class=\"stat-card\">\n                <i class=\"fas fa-server stat-icon\"></i>\n                <div class=\"stat-value\" id=\"requestCount\">0</div>\n                <div class=\"stat-label\">Requests Processed</div>\n            </div>\n            <div class=\"stat-card\">\n                <i class=\"fas fa-tachometer-alt stat-icon\"></i>\n                <div class=\"stat-value\" id=\"avgResponse\">0ms</div>\n                <div class=\"stat-label\">Avg Response Time</div>\n            </div>\n            <div class=\"stat-card\">\n                <i class=\"fas fa-balance-scale stat-icon\"></i>\n                <div class=\"stat-value\" id=\"efficiency\">100%</div>\n                <div class=\"stat-label\">Distribution Efficiency</div>\n            </div>\n        </div>\n\n        <footer>\n            <p>© 2023 Cloud Symphony Visualization | The art of computational harmony</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const visualization = document.getElementById('visualization');\n            const startBtn = document.getElementById('startBtn');\n            const stressBtn = document.getElementById('stressBtn');\n            const requestCount = document.getElementById('requestCount');\n            const avgResponse = document.getElementById('avgResponse');\n            const efficiency = document.getElementById('efficiency');\n\n            // Create servers\n            const servers = [];\n            const serverCount = 5;\n            const radius = 180;\n            const centerX = visualization.offsetWidth / 2;\n            const centerY = visualization.offsetHeight / 2;\n\n            for (let i = 0; i < serverCount; i++) {\n                const angle = (i * (2 * Math.PI / serverCount)) - Math.PI/2;\n                const x = centerX + radius * Math.cos(angle);\n                const y = centerY + radius * Math.sin(angle);\n\n                const server = document.createElement('div');\n                server.className = 'server';\n                server.innerHTML = `\n                    <div class=\"server-icon\"><i class=\"fas fa-server\"></i></div>\n                    <div class=\"server-label\">Server ${i+1}</div>\n                `;\n                server.style.left = `${x}px`;\n                server.style.top = `${y}px`;\n                visualization.appendChild(server);\n\n                // Create connection lines\n                const connection = document.createElement('div');\n                connection.className = 'connection';\n                connection.style.width = `${radius}px`;\n                connection.style.left = `${centerX}px`;\n                connection.style.top = `${centerY}px`;\n                connection.style.transform = `rotate(${angle}rad)`;\n                visualization.appendChild(connection);\n\n                servers.push({\n                    element: server,\n                    connection: connection,\n                    load: 0,\n                    maxLoad: 5,\n                    responseTime: 100 + Math.random() * 50\n                });\n            }\n\n            // Animation variables\n            let requestId = 0;\n            let requestInterval;\n            let stats = {\n                totalRequests: 0,\n                totalResponseTime: 0,\n                balancedCount: 0\n            };\n\n            // Start normal flow\n            startBtn.addEventListener('click', () => {\n                clearInterval(requestInterval);\n                resetServers();\n                requestInterval = setInterval(sendRequest, 800);\n            });\n\n            // Start stress test\n            stressBtn.addEventListener('click', () => {\n                clearInterval(requestInterval);\n                resetServers();\n                requestInterval = setInterval(sendRequest, 200);\n            });\n\n            function resetServers() {\n                servers.forEach(server => {\n                    server.load = 0;\n                    server.element.classList.remove('load', 'overload');\n                    server.connection.classList.remove('active');\n                });\n                stats = {\n                    totalRequests: 0,\n                    totalResponseTime: 0,\n                    balancedCount: 0\n                };\n                updateStats();\n            }\n\n            function sendRequest() {\n                stats.totalRequests++;\n                requestCount.textContent = stats.totalRequests;\n                \n                // Find server with least load\n                let minLoad = Infinity;\n                let candidates = [];\n                \n                servers.forEach(server => {\n                    if (server.load < minLoad) {\n                        minLoad = server.load;\n                        candidates = [server];\n                    } else if (server.load === minLoad) {\n                        candidates.push(server);\n                    }\n                });\n                \n                // Random selection among least loaded\n                const selectedServer = candidates[Math.floor(Math.random() * candidates.length)];\n                stats.balancedCount++;\n                \n                // Visualize request\n                const request = document.createElement('div');\n                request.className = 'request';\n                request.style.left = `${centerX - 5}px`;\n                request.style.top = `${centerY - 5}px`;\n                visualization.appendChild(request);\n                \n                // Animate request to server\n                setTimeout(() => {\n                    request.style.left = `${parseInt(selectedServer.element.style.left) + 35}px`;\n                    request.style.top = `${parseInt(selectedServer.element.style.top) + 40}px`;\n                    \n                    // Highlight connection\n                    selectedServer.connection.classList.add('active');\n                    \n                    setTimeout(() => {\n                        // Process request\n                        selectedServer.load++;\n                        updateServerStatus(selectedServer);\n                        \n                        // Calculate response time with some variance\n                        const responseTime = selectedServer.responseTime * (1 + selectedServer.load/10) * (0.9 + Math.random()*0.2);\n                        stats.totalResponseTime += responseTime;\n                        \n                        // Remove request dot\n                        request.remove();\n                        \n                        // Update stats\n                        updateStats();\n                        \n                        // Release connection\n                        setTimeout(() => {\n                            selectedServer.connection.classList.remove('active');\n                            selectedServer.load--;\n                            updateServerStatus(selectedServer);\n                        }, 2000);\n                        \n                    }, 1000);\n                }, 100);\n            }\n\n            function updateServerStatus(server) {\n                server.element.classList.remove('load', 'overload');\n                if (server.load > 0) {\n                    server.element.classList.add('load');\n                }\n                if (server.load >= server.maxLoad) {\n                    server.element.classList.add('overload');\n                }\n            }\n\n            function updateStats() {\n                avgResponse.textContent = `${Math.round(stats.totalResponseTime / stats.totalRequests)}ms`;\n                efficiency.textContent = `${Math.round((stats.balancedCount / stats.totalRequests) * 100)}%`;\n            }\n\n            // Start with a gentle animation\n            setTimeout(() => {\n                requestInterval = setInterval(sendRequest, 800);\n            }, 3000);\n        });\n    </script>\n</body>\n</html>"
