.getElementById(\"capacityInput\").value);\n            if (!isNaN(capacity) && capacity > 0) {\n                const percentageUsed = (spaceUsage / capacity) * 100;\n                document.getElementById(\"capacityOutput\").innerText = \"Used capacity: \" + percentageUsed.toFixed(2) + \"%\";\n            } else {\n                alert(\"Please enter a valid capacity.\");\n            }\n        }\n    </script>\n</head>\n<body>\n    <h1>Space Complexity Interactive Demo</h1>\n    <p>This demo helps visualize concept of Space Complexity.</p>\n\n    <label for=\"sizeInput\">Enter size to increase/decrease space usage:</label>\n    <input type=\"number\" id=\"sizeInput\" value=\"0\" min=\"1\">\n    <button onclick=\"increaseSpace()\">Increase Space Usage</button>\n    <button onclick=\"decreaseSpace()\">Decrease Space Usage</button>\n    <button onclick=\"resetSpace()\">Reset Space Usage</button>\n    <button onclick=\"toggleDetails()\">Toggle Details</button>\n\n    <div id=\"details\" style=\"display:none;\">\n        <label for=\"capacityInput\">Enter total capacity:</label>\n        <input type=\"number\" id=\"capacityInput\" value=\"0\" min=\"1\">\n        <button onclick=\"calculateCapacity()\">Calculate Capacity Usage</button>\n        <div id=\"capacityOutput\"></div>\n    </div>\n\n    <div id=\"output\">Current Space Usage: 0</div>\n</body>\n</html>"
