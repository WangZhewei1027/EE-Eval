  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Symmetric Cryptography Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .section {\n            margin-bottom: 30px;\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        .control-group {\n            margin: 10px 0;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n        select, input, button {\n            padding: 5px;\n            margin: 5px 0;\n        }\n        .algorithm-options {\n            display: none;\n        }\n        .active {\n            display: block;\n        }\n        .output-area {\n            background-color: #f5f9ff;\n            padding: 10px;\n            margin-top: 10px;\n            border: 1px solid #ddd;\n        }\n    </style>\n</head>\n<body>\n    <h1>Symmetric Cryptography Interactive Explorer</h1>\n    \n    <div class=\"section\">\n        <h2>1. Algorithm Selection</h2>\n        <div class=\"control-group\">\n            <select id=\"algorithm-select\" onchange=\"changeAlgorithm()\">\n                <option value=\"aes\">AES (Advanced Encryption Standard)</option>\n                <option value=\"des\">DES (Data Encryption Standard)</option>\n                <option value=\"3des\">3DES (Triple DES)</option>\n                <option value=\"blowfish\">Blowfish</option>\n                <option value=\"rc4\">RC4</option>\n            </select>\n        </div>\n        \n        <div id=\"aes-options\" class=\"algorithm-options active\">\n            <h3>AES Options</h3>\n            <div class=\"control-group\">\n                Key Size:\n                <select id=\"aes-key-size\">\n                    <option value=\"128\">128 bits</option>\n                    <option value=\"192\">192 bits</option>\n                    <option value=\"256\">256 bits</option>\n                </select>\n            </div>\n            <div class=\"control-group\">\n                Mode:\n                <select id=\"aes-mode\">\n                    <option value=\"CBC\">CBC (Cipher Block Chaining)</option>\n                    <option value=\"ECB\">ECB (Electronic Codebook)</option>\n                    <option value=\"CFB\">CFB (Cipher Feedback)</option>\n                    <option value=\"OFB\">OFB (Output Feedback)</option>\n                    <option value=\"GCM\">GCM (Galois/Counter Mode)</option>\n                </select>\n            </div>\n        </div>\n        \n        <div id=\"des-options\" class=\"algorithm-options\">\n            <h3>DES Options</h3>\n            <div class=\"control-group\">\n                Mode:\n                <select id=\"des-mode\">\n                    <option value=\"CBC\">CBC</option>\n                    <option value=\"ECB\">ECB</option>\n                </select>\n            </div>\n        </div>\n        \n        <div id=\"3des-options\" class=\"algorithm-options\">\n            <h3>3DES Options</h3>\n            <div class=\"control-group\">\n                Keying Option:\n                <select id=\"3des-keying\">\n                    <option value=\"1\">Keying Option 1 (K1 ≠ K2 ≠ K3)</option>\n                    <option value=\"2\">Keying Option 2 (K1 = K3 ≠ K2)</option>\n                    <option value=\"3\">Keying Option 3 (K1 = K2 = K3)</option>\n                </select>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>2. Key Management</h2>\n        <div class=\"control-group\">\n            <button onclick=\"generateKey()\">Generate Random Key</button>\n            <button onclick=\"enterKeyManually()\">Enter Key Manually</button>\n            <button onclick=\"deriveKeyFromPassword()\">Derive Key from Password</button>\n        </div>\n        \n        <div id=\"key-input-area\" style=\"display:none;\">\n            <h3>Key</h3>\n            <textarea id=\"key-input\"></textarea>\n            <div class=\"control-group\">\n                Key Format:\n                <select id=\"key-format\">\n                    <option value=\"hex\">Hexadecimal</option>\n                    <option value=\"base64\">Base64</option>\n                    <option value=\"utf8\">Text (UTF-8)</option>\n                </select>\n                <button onclick=\"setKey()\">Set Key</button>\n            </div>\n        </div>\n        \n        <div id=\"password-input-area\" style=\"display:none;\">\n            <h3>Password-Based Key Derivation</h3>\n            <div class=\"control-group\">\n                Password: <input type=\"password\" id=\"password-input\">\n            </div>\n            <div class=\"control-group\">\n                Salt: <input type=\"text\" id=\"salt-input\" value=\"random salt\">\n                <button onclick=\"generateRandomSalt()\">Random Salt</button>\n            </div>\n            <div class=\"control-group\">\n                Iterations: <input type=\"number\" id=\"iterations\" value=\"10000\" min=\"1000\" max=\"1000000\">\n            </div>\n            <div class=\"control-group\">\n                Key Length (bytes): <input type=\"number\" id=\"key-length\" value=\"32\" min=\"8\" max=\"64\">\n\">\n            </div>\n            <button onclick=\"deriveKey()\">Derive Key</button>\n        </div>\n        \n        <div id=\"current-key-display\" class=\"output-area\">\n            <h3>Current Key</h3>\n            <div id=\"current-key\">No key set</div>\n            <div id=\"key-properties\"></div>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>3. Encryption/Decryption</h2>\n        <div class=\"control-group\">\n            <textarea id=\"plaintext-input\" placeholder=\"Enter plaintext here\"></textarea>\n        </div>\n        <div class=\"control-group\">\n            <button onclick=\"encrypt()\">Encrypt</button>\n            <button onclick=\"decrypt()\">Decrypt</button>\n            <button onclick=\"clearAll()\">Clear All</button>\n        </div>\n        <div class=\"control-group\">\n            <textarea id=\"ciphertext-output\" placeholder=\"Ciphertext will appear here\" readonly></textarea>\n        </div>\n        <div class=\"encryption-details output-area\">\n            <h3>Encryption Details</h3>\n            <div id=\"iv-display\">IV: Not generated yet</div>\n            <div id=\"auth-tag-display\" style=\"display:none;\">Authentication Tag: </div>\n            <div id=\"encryption-time\">Time: </div>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>4. Analysis Tools</h2>\n        <div class=\"control-group\">\n            <button onclick=\"analyzeCiphertext()\">Analyze Ciphertext</button>\n            <button onclick=\"compareAlgorithms()\">Compare Algorithms</button>\n            <button onclick=\"testPerformance()\">Test Performance</button>\n        </div>\n        <div id=\"analysis-results\" class=\"output-area\">\n            <h3>Analysis Results</h3>\n            <div id=\"entropy-analysis\"></div>\n            <div id=\"pattern-analysis\"></div>\n            <div id=\"performance-results\"></div>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>5. Educational Visualizations</h2>\n        <div class=\"control-group\">\n            <button onclick=\"showBlockCipherDiagram()\">Show Block Cipher Diagram</button>\n            <button onclick=\"showFeistelNetwork()\">Show Feistel Network</button>\n            <button onclick=\"showSubstitutionPermutation()\">Show Substitution-Permutation</button>\n        </div>\n        <div id=\"visualization-area\" class=\"output-area\">\n            <h3>Visualization</h3>\n            <div id=\"visualization-content\">Select a visualization above</div>\n        </div>\n    </div>\n    \n    <script>\n        // Global state\n        let currentAlgorithm = 'aes';\n        let currentKey = null;\n        let currentKeyFormat = 'hex';\n        let currentIV = null;\n        let currentAuthTag = null;\n        \n        // Algorithm selection\n        function changeAlgorithm() {\n            const selected = document.getElementById('algorithm-select').value;\n            currentAlgorithm = selected;\n            \n            // Hide all options\n            document.querySelectorAll('.algorithm-options').forEach(el => {\n                el.classList.remove('active');\n            });\n            \n            // Show selected options\n            document.getElementById(`${selected}-options`).classList.add('active');\n            \n            updateKeyProperties();\n        }\n        \n        // Key management\n        function generateKey() {\n            const algorithm = currentAlgorithm;\n            let keyLength;\n            \n            if (algorithm === 'aes') {\n                keyLength = parseInt(document.getElementById('aes-key-size').value) / 8;\n            } else if (algorithm === 'des') {\n                keyLength = 8; // 64 bits, but with 8 parity bits\n            } else if (algorithm === '3des') {\n                const keyingOption = document.getElementById('3des-keying').value;\n                keyLength = keyingOption === '1' ? 24 : 16;\n            } else if (algorithm === 'blowfish') {\n                keyLength = Math.floor(Math.random() * (56 - 4 + 1)) + 4; // 4 to 56 bytes\n            } else if (algorithm === 'rc4') {\n                keyLength = Math.floor(Math.random() * (256 - 5 + 1)) + 5; // 5 to 256 bytes\n            }\n            \n            const keyBytes = new Uint8Array(keyLength);\n            crypto.getRandomValues(keyBytes);\n            \n            currentKey = document.getElementById('key-format').value;\n            displayKey(keyBytes);\n        }\n        \n        function enterKeyManually() {\n            document.getElementById('key-input-area').style.display = 'block';\n            document.getElementById('password-input-area').style.display = 'none';\n        }\n        \n        function deriveKeyFromPassword() {\n            document.getElementById('password-input-area').style.display = 'block';\n            document.getElementById('key-input-area').style.display = 'none';\n        }\n        \n        function setKey() {\n            const format = document.getElementById('key-format').value;\n            const keyInput = document.getElementById('key-input').value;\n            \n            try {\n                let keyBytes;\n                if (format === 'hex') {\n                    if (!/^[0-9a-fA-F]+$/.test(keyInput)) throw new Error(\"Invalid hex characters\");\n                    if (keyInput.length % 2 !== 0) throw new Error(\"Hex string must have even length\");\n                    keyBytes = new Uint8Array(keyInput.match(/../g).map(h => parseInt(h, 16)));\n                } else if (format === 'base64') {\n                    const binaryString = atob(keyInput);\n                    keyBytes = new Uint8Array(binaryString.length);\n                    for (let i = 0; i < binaryString.length; i++) {\n                        keyBytes[i] = binaryString.charCodeAt(i);\n                    }\n                } else { // utf8\n                    const encoder = new TextEncoder();\n                    keyBytes = encoder.encode(keyInput);\n                }\n                \n                currentKey = keyBytes;\n                currentKeyFormat = format;\n                displayKey(keyBytes);\n            } catch (e) {\n                alert(\"Error processing key: \" + e.message);\n            }\n        }\n        \n        function deriveKey() {\n            const password = document.getElementById('password-input').value;\n            const salt = document.getElementById('salt-input').value;\n            const iterations = parseInt(document.getElementById('iterations').value);\n            const keyLength = parseInt(document.getElementById('key-length').value);\n            \n            if (!password) {\n                alert(\"Please enter a password\");\n                return;\n            }\n            \n            const encoder = new TextEncoder();\n            const passwordBuffer = encoder.encode(password);\n            const saltBuffer = encoder.encode(salt);\n            \n            crypto.subtle.importKey(\n                'raw',\n                passwordBuffer,\n                {name: 'PBKDF2'},\n                false,\n                ['deriveBits']\n            ).then(key => {\n                return crypto.subtle.deriveBits(\n                    {\n                        name: 'PBKDF2',\n                        salt: saltBuffer,\n                        iterations: iterations,\n                        hash: 'SHA-256'\n                    },\n                    key,\n                    keyLength * 8\n                );\n            }).then(derivedBits => {\n                currentKey = new Uint8Array(derivedBits);\n                displayKey(currentKey);\n            }).catch(err => {\n                alert(\"Error deriving key: \" + err.message);\n            });\n        }\n        \n        function generateRandomSalt() {\n            const saltBytes = new Uint8Array(16);\n            crypto.getRandomValues(saltBytes);\n            document.getElementById('salt-input').value = Array.from(saltBytes)\n                .map(b => b.toString(16).padStart(2, '0'))\n                .join('');\n        }\n        \n        function displayKey(keyBytes) {\n            const format = currentKeyFormat;\n            let keyDisplay;\n            \n            if (format === 'hex') {\n                keyDisplay = Array.from(keyBytes).map(b => b.toString(16).padStart(2, '0')).join('');\n            } else if (format === 'base64') {\n                let binary = '';\n                keyBytes.forEach(b => binary += String.fromCharCode(b));\n                keyDisplay = btoa(binary);\n            } else { // utf8\n                const decoder = new TextDecoder();\n                keyDisplay = decoder.decode(keyBytes);\n            }\n            \n            document.getElementById('current-key').textContent = keyDisplay;\n            updateKeyProperties();\n        }\n        \n        function updateKeyProperties() {\n            if (!currentKey) {\n                document.getElementById('key-properties').textContent = '';\n                return;\n            }\n            \n            const keyLength = currentKey.length * 8;\n            const algorithm = currentAlgorithm;\n            let valid = true;\n            let message = '';\n            \n            if (algorithm === 'aes') {\n                const allowedLengths = [128, 192, 256];\n                if (!allowedLengths.includes(keyLength)) {\n                    valid = false;\n                    message = `Invalid key length for AES: ${keyLength} bits (must be 128, 192, or 256)`;\n                }\n            } else if (algorithm === 'des') {\n                if (keyLength !== 64) {\n                    valid = false;\n                    message = `Invalid key length for DES: ${keyLength} bits (must be 64 bits, 56 key bits + 8 parity bits)`;\n                }\n            } else if (algorithm === '3des') {\n                const keyingOption = document.getElementById('3des-keying').value;\n                if ((keyingOption === '1' && keyLength !== 192) || \n                    (keyingOption !== '1' && keyLength !== 128)) {\n                    valid = false;\n                    message = `Invalid key length for 3DES with keying option ${keyingOption}: ${keyLength} bits`;\n                }\n            } else if (algorithm === 'blowfish') {\n                if (keyLength < 32 || keyLength > 448) {\n                    valid = false;\n                    message = `Invalid key length for Blowfish: ${keyLength} bits (must be 32-448 bits)`;\n                }\n            } else if (algorithm === 'rc4') {\n                if (keyLength < 40 || keyLength > 2048) {\n                    valid = false;\n                    message = `Invalid key length for RC4: ${keyLength} bits (must be 40-2048 bits)`;\n                }\n            }\n            \n            if (valid) {\n                message = `Key length: ${keyLength} bits\\nAlgorithm: ${algorithm.toUpperCase()}\\nKey is valid for selected algorithm`;\n            }\n            \n            document.getElementById('key-properties').textContent = message;\n            document.getElementById('key-properties').style.color = valid ? 'black' : 'red';\n        }\n        \n        // Encryption/Decryption\n        async function encrypt() {\n            if (!currentKey) {\n                alert(\"Please generate or enter a key first\");\n                return;\n            }\n            \n            const plaintext = document.getElementById('plaintext-input').value;\n            if (!plaintext) {\n                alert(\"Please enter some plaintext to encrypt\");\n                return;\n            }\n            \n            const algorithm = currentAlgorithm;\n            const startTime = performance.now();\n            \n            try {\n                let result;\n                if (algorithm === 'rc4') {\n                    result = await simulateRC4Encryption(plaintext);\n                } else {\n                    result = await performWebCryptoEncryption(plaintext);\n                }\n                \n                const endTime = performance.now();\n                document.getElementById('ciphertext-output').value = result.ciphertext;\n                document.getElementById('iv-display').textContent = `IV: ${result.iv || 'Not applicable'}`;\n                \n                if (result.authTag) {\n                    document.getElementById('auth-tag-display').style.display = 'block';\n                    document.getElementById('auth-tag-display').textContent = `Authentication Tag: ${result.authTag}`;\n                } else {\n                    document.getElementById('auth-tag-display').style.display = 'none';\n                }\n                \n                document.getElementById('encryption-time').textContent = `Time: ${(endTime - startTime).toFixed(2)} ms`;\n            } catch (e) {\n                alert(\"Encryption failed: \" + e.message);\n            }\n        }\n        \n        async function performWebCryptoEncryption(plaintext) {\n            const algorithm = currentAlgorithm;\n            const encoder = new TextEncoder();\n            const plaintextBuffer = encoder.encode(plaintext);\n            \n            // Generate IV if needed\n            let iv;\n            if (algorithm === 'aes') {\n                const mode = document.getElementById('aes-mode').value;\n                if (mode !== 'ECB') {\n                    iv = new Uint8Array(16);\n                    crypto.getRandomValues(iv);\n                    currentIV = iv;\n                }\n            } else if (algorithm === 'des' || algorithm === '3des') {\n                iv = new Uint8Array(8);\n                crypto.getRandomValues(iv);\n                currentIV = iv;\n            }\n            \n            // Prepare algorithm params\n            let algorithmParams;\n            if (algorithm === 'aes') {\n                const mode = document.getElementById('aes-mode').value;\n                algorithmParams = { name: `AES-${mode}`, iv };\n                \n                if (mode === 'GCM') {\n                    algorithmParams.additionalData = encoder.encode(\"additional data\");\n                    algorithmParams.tagLength = 128;\n                }\n            } else if (algorithm === 'des' || algorithm === '3des') {\n                algorithmParams = { name: `3DES-CBC`, iv };\n            } else if (algorithm === 'blowfish') {\n                algorithmParams = { name: 'BLOWFISH-CBC', iv };\n            }\n            \n            // Import key\n            const key = await crypto.subtle.importKey(\n                'raw',\n                currentKey,\n                { name: algorithm === 'aes' ? 'AES-' + document.getElementById('aes-mode').value : \n                  algorithm === 'des' ? 'DES-CBC' :\n                  algorithm === '3des' ? '3DES-CBC' : 'BLOWFISH-CBC' },\n                false,\n                ['encrypt']\n            );\n            \n            // Perform encryption\n            const ciphertextBuffer = await crypto.subtle.encrypt(\n                algorithmParams,\n                key,\n                plaintextBuffer\n            );\n            \n            // Format output\n            const ciphertextBytes = new Uint8Array(ciphertextBuffer);\n            let ciphertext;\n            if (currentKeyFormat === 'hex') {\n                ciphertext = Array.from(ciphertextBytes).map(b => b.toString(16).padStart(2, '0')).join('');\n            } else if (currentKeyFormat === 'base64') {\n                let binary = '';\n                ciphertextBytes.forEach(b => binary += String.fromCharCode(b));\n                ciphertext = btoa(binary);\n            } else {\n                const decoder = new TextDecoder();\n                ciphertext = decoder.decode(ciphertextBytes);\n            }\n            \n            // For GCM mode, extract auth tag\n            let authTag;\n            if (algorithm === 'aes' && document.getElementById('aes-mode').value === 'GCM') {\n                authTag = ciphertext.slice(-32); // Last 16 bytes (32 hex chars) is the tag\n                ciphertext = ciphertext.slice(0, -32);\n            }\n            \n            return {\n                ciphertext,\n                iv: iv ? Array.from(iv).map(b => b.toString(16).padStart(2, '0')).join('') : null,\n                authTag\n            };\n        }\n        \n        function simulateRC4Encryption(plaintext) {\n            // RC4 simulation since Web Crypto doesn't support it\n            const key = Array.from(currentKey);\n            const S = [];\n            for (let i = 0; i < 256; i++) {\n                S[i] = i;\n            }\n            \n            // Key-scheduling algorithm\n            let j = 0;\n            for (let i = 0; i < 256; i++) {\n                j = (j + S[i] + key[i % key.length]) % 256;\n                [S[i], S[j]] = [S[j], S[i]]; // Swap\n            }\n            \n            // Pseudo-random generation algorithm\n            let i = 0;\n            j = 0;\n            const ciphertext = [];\n            const encoder = new TextEncoder();\n            const plaintextBytes = encoder.encode(plaintext);\n            \n            for (let n = 0; n < plaintextBytes.length; n++) {\n                i = (i + 1) % 256;\n                j = (j + S[i]) % 256;\n                [S[i], S[j]] = [S[j], S[i]]; // Swap\n                const K = S[(S[i] + S[j]) % 256];\n                ciphertext.push(plaintextBytes[n] ^ K);\n            }\n            \n            // Format output\n            let ciphertextHex;\n            if (currentKeyFormat === 'hex') {\n                ciphertextHex = ciphertext.map(b => b.toString(16).padStart(2, '0')).join('');\n            } else if (currentKeyFormat === 'base64') {\n                let binary = '';\n                ciphertext.forEach(b => binary += String.fromCharCode(b));\n                ciphertextHex = btoa(binary);\n            } else {\n                const decoder = new TextDecoder();\n                ciphertextHex = decoder.decode(new Uint8Array(ciphertext));\n            }\n            \n            return {\n                ciphertext: ciphertextHex,\n                iv: null,\n                authTag: null\n            };\n        }\n        \n        async function decrypt() {\n            if (!currentKey) {\n                alert(\"Please generate or enter a key first\");\n                return;\n            }\n            \n            const ciphertext = document.getElementById('ciphertext-output').value;\n            if (!ciphertext) {\n                alert(\"Please encrypt some data first\");\n                return;\n            }\n            \n            const algorithm = currentAlgorithm;\n            const startTime = performance.now();\n            \n            try {\n                let result;\n                if (algorithm === 'rc4') {\n                    result = await simulateRC4Decryption(ciphertext);\n                } else {\n                    result = await performWebCryptoDecryption(ciphertext);\n                }\n                \n                const endTime = performance.now();\n                document.getElementById('plaintext-input').value = result.plaintext;\n                document.getElementById('encryption-time').textContent = `Time: ${(endTime - startTime).toFixed(2)} ms`;\n            } catch (e) {\n                alert(\"Decryption failed: \" + e.message);\n            }\n        }\n        \n        async function performWebCryptoDecryption(ciphertext) {\n            const algorithm = currentAlgorithm;\n            \n            // Convert ciphertext to bytes\n            let ciphertextBytes;\n            if (currentKeyFormat === 'hex') {\n                ciphertextBytes = new Uint8Array(ciphertext.match(/../g).map(h => parseInt(h, 16)));\n            } else if (currentKeyFormat === 'base64') {\n                const binaryString = atob(ciphertext);\n                ciphertextBytes = new Uint8Array(binaryString.length);\n                for (let i = 0; i < binaryString.length; i++) {\n                    ciphertextBytes[i] = binaryString.charCodeAt(i);\n                }\n            } else {\n                const encoder = new TextEncoder();\n                ciphertextBytes = encoder.encode(ciphertext);\n            }\n            \n            // Prepare algorithm params\n            let algorithmParams;\n            if (algorithm === 'aes') {\n                const mode = document.getElementById('aes-mode').value;\n                algorithmParams = { name: `AES-${mode}`, iv: currentIV };\n                \n                if (mode === 'GCM') {\n                    algorithmParams.additionalData = new TextEncoder().encode(\"additional data\");\n                    algorithmParams.tagLength = 128;\n                    \n                    // Extract auth tag from ciphertext (last 16 bytes)\n                    const tagBytes = ciphertextBytes.slice(-16);\n                    ciphertextBytes = ciphertextBytes.slice(0, -16);\n                    algorithmParams.tag = tagBytes;\n                }\n            } else if (algorithm === 'des' || algorithm === '3des') {\n                algorithmParams = { name: `3DES-CBC`, iv: currentIV };\n            } else if (algorithm === 'blowfish') {\n                algorithmParams = { name: 'BLOWFISH-CBC', iv: currentIV };\n            }\n            \n            // Import key\n            const key = await crypto.subtle.importKey(\n                'raw',\n                currentKey,\n                { name: algorithm === 'aes' ? 'AES-' + document.getElementById('aes-mode').value : \n                  algorithm === 'des' ? 'DES-CBC' :\n                  algorithm === '3des' ? '3DES-CBC' : 'BLOWFISH-CBC' },\n                false,\n                ['decrypt']\n            );\n            \n            // Perform decryption\n            const plaintextBuffer = await crypto.subtle.decrypt(\n                algorithmParams,\n                key,\n                ciphertextBytes\n            );\n            \n            // Format output\n            const decoder = new TextDecoder();\n            const plaintext = decoder.decode(plaintextBuffer);\n            \n            return { plaintext };\n        }\n        \n        function simulateRC4Decryption(ciphertext) {\n            // RC4 decryption is the same as encryption\n            return simulateRC4Encryption(ciphertext);\n        }\n        \n        function clearAll() {\n            document.getElementById('plaintext-input').value = '';\n            document.getElementById('ciphertext-output').value = '';\n            document.getElementById('iv-display').textContent = 'IV: Not generated yet';\n            document.getElementById('auth-tag-display').style.display = 'none';\n            document.getElementById('encryption-time').textContent = 'Time: ';\n        }\n        \n        // Analysis tools\n        function analyzeCiphertext() {\n            const ciphertext = document.getElementById('ciphertext-output').value;\n            if (!ciphertext) {\n                alert(\"Please encrypt some data first\");\n                return;\n            }\n            \n            // Simple entropy calculation\n            let entropy = 0;\n            const charCounts = {};\n            const length = ciphertext.length;\n            \n            for (let i = 0; i < length; i++) {\n                const char = ciphertext[i];\n                charCounts[char] = (charCounts[char] || 0) + 1;\n            }\n            \n            for (const char in charCounts) {\n                const probability = charCounts[char] / length;\n                entropy -= probability * Math.log2(probability);\n            }\n            \n            // Check for repeating patterns\n            let patternAnalysis = \"No obvious repeating patterns detected\";\n            if (length > 20) {\n                const sample = ciphertext.substring(0, 20);\n                if (ciphertext.indexOf(sample, 20) !== -1) {\n                    patternAnalysis = \"Warning: Repeating patterns detected in ciphertext\";\n                }\n            }\n            \n            document.getElementById('entropy-analysis').textContent = `Entropy: ${entropy.toFixed(2)} bits per symbol (higher is better)`;\n            document.getElementById('pattern-analysis').textContent = patternAnalysis;\n        }\n        \n        function compareAlgorithms() {\n            const plaintext = document.getElementById('plaintext-input').value || \"Sample plaintext for comparison\";\n            const originalAlgorithm = currentAlgorithm;\n            const algorithms = ['aes', 'des', '3des', 'blowfish', 'rc4'];\n            let results = [];\n            \n            algorithms.forEach(alg => {\n                currentAlgorithm = alg;\n                generateKey();\n                const startTime = performance.now();\n                \n                if (alg === 'rc4') {\n                    const result = simulateRC4Encryption(plaintext);\n                    results.push({\n                        algorithm: alg.toUpperCase(),\n                        time: performance.now() - startTime,\n                        ciphertextLength: result.ciphertext.length\n                    });\n                } else {\n                    performWebCryptoEncryption(plaintext).then(result => {\n                        results.push({\n                            algorithm: alg.toUpperCase(),\n                            time: performance.now() - startTime,\n                            ciphertextLength: result.ciphertext.length\n                        });\n                        \n                        if (results.length === algorithms.length) {\n                            displayComparison(results);\n                            currentAlgorithm = originalAlgorithm;\n                        }\n                    });\n                }\n            });\n        }\n        \n        function displayComparison(results) {\n            let comparison = \"Algorithm Comparison:\\n\";\n            results.forEach(res => {\n                comparison += `${res.algorithm}: ${res.time.toFixed(2)} ms, Ciphertext length: ${res.ciphertextLength}\\n`;\n            });\n            \n            document.getElementById('performance-results').textContent = comparison;\n        }\n        \n        async function testPerformance() {\n            const plaintext = \"The quick brown fox jumps over the lazy dog. \".repeat(100);\n            document.getElementById('plaintext-input').value = plaintext;\n            \n            const startTime = performance.now();\n            await encrypt();\n            const endTime = performance.now();\n            \n            const throughput = (plaintext.length * 8) / ((endTime - startTime) / 1000); // bits per second\n            document.getElementById('performance-results').textContent = \n                `Performance: ${(endTime - startTime).toFixed(2)} ms\\n` +\n                `Throughput: ${(throughput / 1000).toFixed(2)} kbps`;\n        }\n        \n        // Educational visualizations\n        function showBlockCipherDiagram() {\n            const content = `\n                <h4>Block Cipher Operation (AES/DES/3DES/Blowfish)</h4>\n                <pre>\n                +---------------+    +---------------+\n                | Plaintext    |    | Key           |\n                | Block        |    |               |\n                +---------------+    +---------------+\n                        |                  |\n                        v                  v\n                +---------------+    +---------------+\n                | Initial      |    | Key           |\n                | Permutation  |    | Schedule      |\n                +---------------+    +---------------+\n                        |                  |\n                        v                  v\n                +-------------------------------+\n                | Round 1:                     |\n                | - SubBytes/Substitution      |\n                | - ShiftRows/Permutation      |\n                | - MixColumns/Diffusion       |\n                | - AddRoundKey/XOR with key   |\n                +-------------------------------+\n                        |\n                        v\n                [Repeat for multiple rounds...]\n                        |\n                        v\n                +-------------------------------+\n                | Final Round:                 |\n                | - SubBytes/Substitution      |\n                | - ShiftRows/Permutation      |\n                | - AddRoundKey/XOR with key   |\n                +-------------------------------+\n                        |\n                        v\n                +---------------+\n                | Ciphertext    |\n                | Block         |\n                +---------------+\n                </pre>\n            `;\n            document.getElementById('visualization-content').innerHTML = content;\n        }\n        \n        function showFeistelNetwork() {\n            const content = `\n                <h4>Feistel Network (Used in DES)</h4>\n                <pre>\n                +---------------+    +---------------+\n                | Plaintext    |    | Key           |\n                | (64 bits)    |    | (56 bits)     |\n                +---------------+    +---------------+\n                        |                  |\n                        v                  v\n                +-------+-------+    +---------------+\n                | Left  | Right |    | Key Schedule  |\n                | (32b) | (32b) |    | (16 rounds)   |\n                +-------+-------+    +---------------+\n                        |                  |\n                        v                  v\n                +-------------------------------+\n                | Round 1:                     |\n                | 1. F(Right, Subkey)          |\n                | 2. XOR with Left            |\n                | 3. Swap Left and Right       |\n                +-------------------------------+\n                        |\n                        v\n                [Repeat for 15 more rounds...]\n                        |\n                        v\n                +-------------------------------+\n                | Final Round:                 |\n                | (No swap in final round)     |\n                +-------------------------------+\n                        |\n                        v\n                +-------+-----------+\n                | Combine           |\n                | Left + Right      |\n                +-------------------+\n                        |\n                        v\n                +---------------+\n                | Ciphertext    |\n                | (64 bits)     |\n                +---------------+\n                </pre>\n            `;\n            document.getElementById('visualization-content').innerHTML = content;\n        }\n        \n        function showSubstitutionPermutation() {\n            const content = `\n                <h4>Substitution-Permutation Network (Used in AES)</h4>\n                <pre>\n                +---------------+    +---------------+\n                | Plaintext    |    | Key           |\n                | (128 bits)   |    | (128/192/256) |\n                +---------------+    +---------------+\n                        |                  |\n                        v                  v\n                +----------------+   +---------------+\n                | Initial       |   | Key Expansion  |\n                | AddRoundKey   |   | (Creates round |\n                | (XOR with key)|   |  keys)         |\n                +----------------+   +---------------+\n                        |\n                        v\n                +----------------+\n                | Round 1:       |\n                | 1. SubBytes    | (Non-linear substitution)\n                | 2. ShiftRows   | (Permutation)\n                | 3. MixColumns  | (Linear transformation)\n                | 4. AddRoundKey | (XOR with round key)\n                +----------------+\n                        |\n                        v\n                [Repeat for 9/11/13 rounds...]\n                        |\n                        v\n                +----------------+\n                | Final Round:   |\n                | 1. SubBytes    |\n                | 2. ShiftRows   |\n                | 3. AddRoundKey |\n                +----------------+\n                        |\n                        v\n                +---------------+\n                | Ciphertext    |\n                | (128 bits)    |\n                +---------------+\n                </pre>\n            `;\n            document.getElementById('visualization-content').innerHTML = content;\n        }\n        \n        // Initialize\n        document.addEventListener('DOMContentLoaded', function() {\n            updateKeyProperties();\n        });\n    </script>\n</body>\n</html>"
