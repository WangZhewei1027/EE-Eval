\n      source: document.getElementById('sourceArea').value,\n      tests: workspace.tests,\n      snapshots: workspace.snapshots\n    };\n    localStorage.setItem('unitTestWorkspace', JSON.stringify(payload));\n  } catch(e){}\n}\nfunction loadWorkspaceFromLocal() {\n  try {\n    const raw = localStorage.getItem('unitTestWorkspace');\n    if (!raw) {\n      document.getElementById('sourceArea').value = defaultSource;\n      workspace.tests = [{ id:'t1', name:'example test', suite:'default', code: document.getElementById('testArea').value, status:'idle', result:null, only:false, skip:false, flaky:false }];\n      refreshTestsList();\n      compileSource();\n      return;\n    }\n    const parsed = JSON.parse(raw);\n    if (parsed.source) document.getElementById('sourceArea').value = parsed.source;\n    if (parsed.tests) workspace.tests = parsed.tests;\n    if (parsed.snapshots) workspace.snapshots = parsed.snapshots;\n    refreshTestsList();\n    compileSource();\n  } catch(e){ log('Load workspace error', e); }\n}\n\n/* ---------- Helpers ---------- */\n\nfunction updateUIState() {\n  document.getElementById('historyCount').textContent = workspace.history.length;\n  document.getElementById('snapshotCount').textContent = Object.keys(workspace.snapshots).length;\n  document.getElementById('coveragePct').textContent = computeCoveragePct() + '%';\n  document.getElementById('coverageBar').value = computeCoveragePct();\n  refreshTestsList();\n}\n\nfunction computeCoveragePct() {\n  const c = workspace.coverage || {};\n  const keys = Object.keys(c);\n  if (keys.length === 0) return 0;\n  const executed = keys.filter(k => c[k] > 0).length;\n  return Math.round((executed/keys.length)*100);\n}\n\nfunction updateCoverageUI() {\n  const pct = computeCoveragePct();\n  document.getElementById('coveragePct').textContent = pct + '%';\n  document.getElementById('coverageBar').value = pct;\n}\n\nfunction download(filename, text) {\n  const a = document.createElement('a');\n  a.href = 