  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Unit Testing Interactive Sandbox</title>\n<style>\n  /* Extremely minimal styling - plain black text on white background */\n  html,body { height:100%; margin:0; font-family: sans-serif; color: #000; background:#fff; }\n  .container { display:flex; height:100vh; gap:8px; padding:8px; box-sizing:border-box; }\n  .col { flex:1; display:flex; flex-direction:column; gap:6px; }\n  textarea { width:100%; height:200px; box-sizing:border-box; font-family: monospace; font-size:13px; }\n  input[type=\"text\"], input[type=\"number\"], select { width:120px; }\n  .toolbar { display:flex; gap:6px; flex-wrap:wrap; align-items:center; }\n  .tests-list { height:200px; overflow:auto; border:1px solid #ccc; padding:4px; }\n  .test-item { padding:4px; border-bottom:1px dashed #ddd; display:flex; align-items:center; gap:6px; }\n  button { padding:4px 6px; }\n  .log { height:260px; overflow:auto; border:1px solid #ccc; padding:6px; font-family: monospace; white-space:pre-wrap; }\n  label { font-size:13px; }\n  .small { font-size:12px; }\n  .row { display:flex; gap:6px; align-items:center; }\n  .flex { flex:1; }\n  .meta { font-size:12px; }\n  details { margin-top:6px; }\n</style>\n</head>\n<body>\n<div style=\"padding:8px;\">\n  <h2>Interactive Unit Testing Sandbox (Minimal UI)</h2>\n  <p class=\"small\">Edit source and tests, run suites, step through generator tests, use spies, snapshots, property tests, mutation toggle, and more. Interface is intentionally plain.</p>\n</div>\n\n<div class=\"container\">\n  <!-- Left column: Source + Controls + Test List -->\n  <div class=\"col\">\n    <label>Source Code (exports.* to expose functions)</label>\n    <textarea id=\"sourceArea\"></textarea>\n\n    <div class=\"toolbar\">\n      <button id=\"compileBtn\">Compile Source</button>\n      <button id=\"resetSourceBtn\">Load Example Source</button>\n      <label>Coverage:</label>\n      <progress id=\"coverageBar\" value=\"0\" max=\"100\" style=\"width:120px;\"></progress>\n      <span id=\"coveragePct\" class=\"meta\">0%</span>\n      <label style=\"margin-left:8px\">Mutation:</label><input type=\"checkbox\" id=\"mutationToggle\">\n      <label style=\"margin-left:8px\">Auto-compile on Run:</label><input type=\"checkbox\" id=\"autoCompile\" checked>\n    </div>\n\n    <details open>\n      <summary>Tests (create, select, edit)</summary>\n      <div style=\"display:flex; gap:6px; margin-top:6px;\">\n        <input id=\"newTestName\" placeholder=\"New test name\" type=\"text\">\n        <select id=\"newTestSuite\"><option>default</option><option>math</option><option>strings</option></select>\n        <button id=\"addTestBtn\">Add Test</button>\n        <button id=\"duplicateTestBtn\">Duplicate</button>\n        <button id=\"deleteTestBtn\">Delete</button>\n      </div>\n\n      <div class=\"row\" style=\"margin-top:6px; gap:12px;\">\n        <label>Filter:</label><input id=\"filterInput\" type=\"text\" placeholder=\"filter tests\">\n        <label>Only/Skip Buttons act on selected</label>\n      </div>\n\n      <div class=\"tests-list\" id=\"testsList\"></div>\n\n      <div class=\"toolbar\">\n        <label>Concurrency:</label>\n        <input id=\"concurrency\" type=\"range\" min=\"1\" max=\"6\" value=\"1\">\n        <span id=\"concurrencyVal\" class=\"meta\">1</span>\n        <label style=\"margin-left:8px\">Timeout(ms):</label>\n        <input id=\"testTimeout\" type=\"number\" value=\"2000\" min=\"0\">\n        <label style=\"margin-left:8px\">Seed:</label>\n        <input id=\"rngSeed\" type=\"number\" value=\"1\" style=\"width:80px\">\n        <label style=\"margin-left:8px\">Iterations:</label>\n        <input id=\"iterations\" type=\"number\" value=\"1\" min=\"1\" max=\"10000\" style=\"width:80px\">\n      </div>\n    </details>\n\n    <div class=\"toolbar\">\n      <button id=\"runAllBtn\">Run All</button>\n      <button id=\"runSelectedBtn\">Run Selected</button>\n      <button id=\"runPropertyBtn\">Run Property</button>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"resumeBtn\">Resume</button>\n      <button id=\"stopBtn\">Stop</button>\n      <button id=\"exportBtn\">Export</button>\n      <button id=\"importBtn\">Import</button>\n      <input type=\"file\" id=\"importFile\" style=\"display:none;\">\n    </div>\n\n    <div class=\"toolbar\">\n      <button id=\"clearLogsBtn\">Clear Logs</button>\n      <button id=\"clearSnapshotsBtn\">Clear Snapshots</button>\n      <button id=\"saveStateBtn\">Save Workspace</button>\n      <button id=\"loadStateBtn\">Load Workspace</button>\n    </div>\n\n  </div>\n\n  <!-- Right column: Test Editor, Assertions, Logs -->\n  <div class=\"col\">\n    <label>Test Editor (function signature: async function(exports, assert, helpers) { ... } or generator function* )</label>\n    <textarea id=\"testArea\"></textarea>\n\n    <div class=\"toolbar\">\n      <button id=\"updateTestBtn\">Update Test</button>\n      <button id=\"markSkipBtn\">Toggle Skip</button>\n      <button id=\"markOnlyBtn\">Toggle Only</button>\n      <button id=\"markFlakyBtn\">Toggle Flaky</button>\n      <button id=\"snapshotBtn\">Snapshot</button>\n      <button id=\"updateSnapshotBtn\">Update Snapshot</button>\n      <button id=\"spyBtn\">Create Spy for selected fn</button>\n    </div>\n\n    <div class=\"toolbar small\">\n      <label>Assertion Helpers Visible:</label>\n      <label><input type=\"checkbox\" id=\"liveAssertionShow\" checked> show assert results in logs</label>\n      <label style=\"margin-left:8px\">Mutation Strength:</label>\n      <input id=\"mutationStrength\" type=\"range\" min=\"0\" max=\"10\" value=\"2\">\n    </div>\n\n    <label>Logs & Results</label>\n    <div class=\"log\" id=\"logArea\"></div>\n\n    <div class=\"toolbar\">\n      <label>Snapshot Count:</label><span id=\"snapshotCount\" class=\"meta\">0</span>\n      <label style=\"margin-left:8px\">History Size:</label><span id=\"historyCount\" class=\"meta\">0</span>\n    </div>\n\n    <details>\n      <summary>Test Execution Details</summary>\n      <div id=\"detailsArea\" class=\"meta\" style=\"white-space:pre-wrap; padding:6px;\"></div>\n    </details>\n  </div>\n</div>\n\n<script>\n/*\n  Interactive Unit Testing Sandbox\n  - Minimal UI\n  - Features: compile/expose exports, create/edit tests, run, step-through generators, spies, snapshots, property testing, mutation toggle, coverage counts.\n*/\n\n/* ---------- State ---------- */\nlet workspace = {\n  source: '',\n  tests: [],\n  snapshots: {},\n  history: [],\n  coverage: {},\n  compiledExports: {},\n  spies: {}\n};\nlet runtime = {\n  paused: false,\n  stepping: false,\n  running: false,\n  stopRequested: false,\n  currentRun: null,\n  rngState: 1,\n  concurrency: 1\n};\n\n/* ---------- Utilities ---------- */\n\nfunction log(...args) {\n  const area = document.getElementById('logArea');\n  area.textContent += args.map(a => {\n    if (typeof a === 'object') try { return JSON.stringify(a, null, 2); } catch(e){ return String(a); }\n    return String(a);\n  }).join(' ') + '\\n';\n  area.scrollTop = area.scrollHeight;\n}\n\nfunction clearLogs() {\n  document.getElementById('logArea').textContent = '';\n}\n\nfunction now() { return Date.now(); }\n\nfunction rng(seed) {\n  let s = seed >>> 0;\n  return function() {\n    s = (s + 0x6D2B79F5) | 0;\n    let t = Math.imul(s ^ s >>> 15, 1 | s);\n    t = t + Math.imul(t ^ (t >>> 7), 61 | t) ^ t;\n    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n  };\n}\n\n/* ---------- Compile Source ---------- */\n\nfunction compileSource() {\n  clearLogs();\n  workspace.coverage = {};\n  workspace.compiledExports = {};\n  workspace.spies = {};\n  const code = document.getElementById('sourceArea').value;\n  try {\n    // Create a wrapper function that receives an 'exports' object and optionally helper functions.\n    const wrapper = new Function('exports','console','createSpy','__coverage','__wrap','__helpers', code + '\\n; return exports;');\n    const localConsole = {\n      log: function(...a){ // capture logs with context\n        workspace.lastConsole = workspace.lastConsole || [];\n        workspace.lastConsole.push({time:now(), args:a});\n        log('[console]', ...a);\n      }\n    };\n    const createSpyLocal = (name, fn) => {\n      return createSpy(name, fn);\n    };\n    // coverage registry: will be incremented by wrappers when functions are called\n    const coverage = workspace.coverage;\n    // helper to wrap functions for instrumentation\n    function __wrap(name, fn) {\n      if (typeof fn !== 'function') return fn;\n      coverage[name] = 0;\n      const wrapped = function(...args) {\n        coverage[name] = (coverage[name] || 0) + 1;\n        return fn.apply(this, args);\n      };\n      // copy properties\n      try { Object.keys(fn).forEach(k => wrapped[k]=fn[k]); } catch(e){}\n      wrapped.__orig = fn;\n      return wrapped;\n    }\n    const helpers = {\n      makeSpy: createSpyLocal,\n      env: { mutation: document.getElementById('mutationToggle').checked }\n    };\n    const exportsObj = {};\n    const compiled = wrapper(exportsObj, localConsole, createSpyLocal, coverage, __wrap, helpers);\n    // instrument discovered functions automatically\n    Object.keys(compiled).forEach(k => {\n      if (typeof compiled[k] === 'function') {\n        compiled[k] = __wrap(k, compiled[k]);\n      }\n    });\n    workspace.compiledExports = compiled;\n    log('Source compiled successfully. Exposed:', Object.keys(compiled).join(', ') || '(none)');\n    updateCoverageUI();\n    return true;\n  } catch (e) {\n    log('Compile error:', e && e.stack ? e.stack : e);\n    return false;\n  }\n}\n\n/* ---------- Example initial content ---------- */\n\nconst defaultSource = `// Example source: expose functions by assigning to exports.<br>// Use: exports.add = function(a,b) { return a+b }<br>exports.add = function(a,b) { return a + b; }<br>exports.div = function(a,b) { if(b===0) throw new Error('divide by zero'); return a/b; }<br>exports.asyncDouble = async function(n) { return new Promise(resolve => setTimeout(() => resolve(n*2), 100)); }<br>exports.generatorCounter = function*(start, step, count) { let v = start; for(let i=0;i<count;i++){ yield v; v += step; } return v; }`;\n\nconst defaultTest = `// Example test. Use assert helpers. This test uses exports.add\\nasync function(exports, assert, helpers) {\\n  // synchronous assertion\\n  assert.equal(exports.add(1,2), 3, '1+2=3');\\n  // async test awaits\\n  const d = await exports.asyncDouble(5);\\n  assert.equal(d, 10, 'async double');\\n  // generator stepping example\\n  const gen = exports.generatorCounter(0,2,3);\\n  assert.deepEqual(Array.from(gen), [0,2,4], 'generator yields');\\n}`;\n\n(function init() {\n  document.getElementById('sourceArea').value = defaultSource;\n  document.getElementById('testArea').value = defaultTest;\n  loadWorkspaceFromLocal();\n  refreshTestsList();\n  updateUIState();\n})();\n\n/* ---------- Tests Management ---------- */\n\nfunction addTest(name = 'test'+(workspace.tests.length+1), suite='default', code = '') {\n  const t = {\n    id: String(Math.random()).slice(2),\n    name,\n    suite,\n    code: code || document.getElementById('testArea').value,\n    status: 'idle',\n    result: null,\n    only: false,\n    skip: false,\n    flaky: false,\n    timeout: Number(document.getElementById('testTimeout').value) || 2000\n  };\n  workspace.tests.push(t);\n  refreshTestsList();\n  selectTestById(t.id);\n  saveWorkspaceToLocal();\n  return t;\n}\n\nfunction updateSelectedTest() {\n  const id = getSelectedTestId();\n  if (!id) return;\n  const t = workspace.tests.find(x=>x.id===id);\n  if (!t) return;\n  t.code = document.getElementById('testArea').value;\n  t.name = document.getElementById('newTestName').value || t.name;\n  t.suite = document.getElementById('newTestSuite').value || t.suite;\n  refreshTestsList();\n  saveWorkspaceToLocal();\n}\n\nfunction deleteSelectedTest() {\n  const id = getSelectedTestId();\n  if (!id) return;\n  workspace.tests = workspace.tests.filter(x=>x.id!==id);\n  refreshTestsList();\n  document.getElementById('testArea').value = '';\n  saveWorkspaceToLocal();\n}\n\nfunction duplicateSelectedTest() {\n  const id = getSelectedTestId();\n  if (!id) return;\n  const t = workspace.tests.find(x=>x.id===id);\n  if (!t) return;\n  addTest(t.name + ' (copy)', t.suite, t.code);\n}\n\nfunction toggleFlagSelected(flag) {\n  const id = getSelectedTestId();\n  if (!id) return;\n  const t = workspace.tests.find(x=>x.id===id);\n  if (!t) return;\n  t[flag] = !t[flag];\n  refreshTestsList();\n  saveWorkspaceToLocal();\n}\n\nfunction selectTestById(id) {\n  const list = document.getElementById('testsList');\n  Array.from(list.querySelectorAll('.test-item')).forEach(el => {\n    el.style.background = '';\n  });\n  const el = list.querySelector(`[data-id=\"${id}\"]`);\n  if (el) el.style.background = '#f0f0f0';\n  // set editor content\n  const t = workspace.tests.find(x=>x.id===id);\n  if (t) {\n    document.getElementById('testArea').value = t.code;\n    document.getElementById('newTestName').value = t.name;\n    document.getElementById('newTestSuite').value = t.suite;\n  }\n}\n\nfunction getSelectedTestId() {\n  const list = document.getElementById('testsList');\n  const sel = list.querySelector('.test-item.selected');\n  if (sel) return sel.getAttribute('data-id');\n  // fallback to first checked\n  const chk = list.querySelector('input[type=\"radio\"]:checked');\n  if (chk) return chk.closest('.test-item').getAttribute('data-id');\n  return null;\n}\n\nfunction refreshTestsList() {\n  const list = document.getElementById('testsList');\n  list.innerHTML = '';\n  const filter = (document.getElementById('filterInput').value || '').toLowerCase();\n  workspace.tests.forEach(t => {\n    if (filter && !((t.name + ' ' + t.suite + ' ' + t.code).toLowerCase().includes(filter))) return;\n    const div = document.createElement('div');\n    div.className = 'test-item';\n    div.setAttribute('data-id', t.id);\n    div.innerHTML = `\n      <input type=\"radio\" name=\"sel\" ${t === workspace._lastSelected ? 'checked' : ''}>\n      <div class=\"flex\"><strong>${escapeHtml(t.name)}</strong> <span class=\"meta\">[${escapeHtml(t.suite)}]</span></div>\n      <div class=\"meta\">${t.status}</div>\n      <div class=\"meta\">${t.result ? t.result : ''}</div>\n      <button class=\"btnEdit small\">Edit</button>\n    `;\n    div.querySelector('input[type=radio]').addEventListener('change', (e) => {\n      Array.from(list.querySelectorAll('.test-item')).forEach(x => x.classList.remove('selected'));\n      div.classList.add('selected');\n      workspace._lastSelected = t;\n      selectTestById(t.id);\n    });\n    div.querySelector('.btnEdit').addEventListener('click', ()=> {\n      Array.from(list.querySelectorAll('.test-item')).forEach(x => x.classList.remove('selected'));\n      div.classList.add('selected');\n      workspace._lastSelected = t;\n      selectTestById(t.id);\n    });\n    // meta buttons small\n    const meta = document.createElement('div');\n    meta.style.marginLeft = '8px';\n    meta.style.display = 'flex';\n    meta.style.gap = '4px';\n    const onlyBtn = document.createElement('button');\n    onlyBtn.textContent = t.only ? 'only' : 'o';\n    onlyBtn.title = 'toggle only';\n    onlyBtn.addEventListener('click', (e)=>{ t.only=!t.only; refreshTestsList(); });\n    const skipBtn = document.createElement('button');\n    skipBtn.textContent = t.skip ? 'skip' : 's';\n    skipBtn.title = 'toggle skip';\n    skipBtn.addEventListener('click', ()=>{ t.skip=!t.skip; refreshTestsList(); });\n    const flakyBtn = document.createElement('button');\n    flakyBtn.textContent = t.flaky ? 'flaky' : 'f';\n    flakyBtn.title = 'toggle flaky';\n    flakyBtn.addEventListener('click', ()=>{ t.flaky=!t.flaky; refreshTestsList(); });\n    div.appendChild(meta);\n    meta.appendChild(onlyBtn);\n    meta.appendChild(skipBtn);\n    meta.appendChild(flakyBtn);\n    list.appendChild(div);\n  });\n  document.getElementById('historyCount').textContent = workspace.history.length || 0;\n}\n\n/* ---------- Assertions ---------- */\n\nconst assert = {\n  equal(a,b,msg){\n    if (a !== b) throw new Error((msg?msg+': ':'') + `expected ${JSON.stringify(a)} === ${JSON.stringify(b)}`);\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.equal] OK', msg || '');\n  },\n  deepEqual(a,b,msg){\n    if (!deepEqual(a,b)) throw new Error((msg?msg+': ':'') + `deepEqual failed: ${JSON.stringify(a)} !== ${JSON.stringify(b)}`);\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.deepEqual] OK', msg || '');\n  },\n  throws(fn, msg){\n    let threw=false;\n    try{ fn(); } catch(e){ threw=true; }\n    if (!threw) throw new Error((msg?msg+': ':'') + 'expected function to throw');\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.throws] OK', msg || '');\n  },\n  ok(v,msg){\n    if(!v) throw new Error((msg?msg+': ':'') + 'expected truthy value');\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.ok] OK', msg || '');\n  },\n  notOk(v,msg){\n    if(v) throw new Error((msg?msg+': ':'') + 'expected falsy value');\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.notOk] OK', msg || '');\n  },\n  approx(a,b,eps=1e-6,msg){\n    if (Math.abs(a-b)>eps) throw new Error((msg?msg+': ':'') + `approx failed ${a} !== ${b}`);\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.approx] OK', msg || '');\n  },\n  contains(hay,needle,msg){\n    if (!String(hay).includes(String(needle))) throw new Error((msg?msg+': ':'') + 'expected to contain');\n    if (document.getElementById('liveAssertionShow').checked) log('[assert.contains] OK', msg || '');\n  }\n};\n\nfunction deepEqual(a,b) {\n  if (a===b) return true;\n  if (typeof a !== typeof b) return false;\n  if (a && b && typeof a === 'object') {\n    if (Array.isArray(a) !== Array.isArray(b)) return false;\n    if (Array.isArray(a)) {\n      if (a.length !== b.length) return false;\n      for (let i=0;i<a.length;i++) if (!deepEqual(a[i], b[i])) return false;\n      return true;\n    } else {\n      const ak = Object.keys(a).sort();\n      const bk = Object.keys(b).sort();\n      if (ak.length !== bk.length) return false;\n      for (let k of ak) if (!deepEqual(a[k], b[k])) return false;\n      return true;\n    }\n  }\n  return false;\n}\n\n/* ---------- Spies & Mocks ---------- */\n\nfunction createSpy(name, origFn) {\n  const record = {calls: []};\n  const spy = function(...args) {\n    record.calls.push({args, time: now()});\n    if (typeof origFn === 'function') {\n      return origFn.apply(this,args);\n    }\n    return undefined;\n  };\n  spy.getCalls = ()=>record.calls;\n  spy.reset = ()=>{ record.calls=[]; };\n  workspace.spies[name] = spy;\n  return spy;\n}\n\n/* ---------- Snapshots ---------- */\n\nfunction snapshotTest(name, value, update=false) {\n  const key = name;\n  const existing = workspace.snapshots[key];\n  if (existing && !update) {\n    if (!deepEqual(existing, value)) throw new Error('Snapshot mismatch for ' + name + '\\nExpected: ' + JSON.stringify(existing) + '\\nReceived: ' + JSON.stringify(value));\n    log('[snapshot] OK', name);\n  } else {\n    workspace.snapshots[key] = value;\n    log('[snapshot] saved', name);\n  }\n  document.getElementById('snapshotCount').textContent = Object.keys(workspace.snapshots).length;\n}\n\n/* ---------- Test Runner (supports async, generator stepping) ---------- */\n\nasync function runAllTests(opts={selectedOnly:false, property:false}) {\n  if (document.getElementById('autoCompile').checked) {\n    if (!compileSource()) {\n      log('Aborting run: compile failed');\n      return;\n    }\n  }\n  runtime.running = true;\n  runtime.stopRequested = false;\n  runtime.paused = false;\n  runtime.stepping = false;\n  runtime.currentRun = {results:[], start:now()};\n  const concurrency = Number(document.getElementById('concurrency').value) || 1;\n  runtime.concurrency = concurrency;\n  const iterations = Number(document.getElementById('iterations').value) || 1;\n  const seed = Number(document.getElementById('rngSeed').value) || 1;\n  const rngFn = rng(seed);\n\n  // choose tests\n  let testsToRun = workspace.tests.filter(t => !t.skip);\n  const only = workspace.tests.some(t=>t.only);\n  if (only) testsToRun = testsToRun.filter(t=>t.only);\n  if (opts.selectedOnly) {\n    const sel = getSelectedTestId();\n    if (sel) testsToRun = testsToRun.filter(t=>t.id===sel);\n  }\n  // start concurrency pool\n  const pool = [];\n  let idx = 0;\n  const results = [];\n  const runNext = async () => {\n    if (runtime.stopRequested) return;\n    const i = idx++;\n    if (i >= testsToRun.length) return;\n    const t = testsToRun[i];\n    const res = await runSingleTest(t, {rngFn, iterations});\n    results.push(res);\n    if (runtime.stopRequested) return;\n    await runNext();\n  };\n  for (let i=0;i<concurrency;i++) pool.push(runNext());\n  await Promise.all(pool);\n  runtime.running = false;\n  runtime.currentRun.end = now();\n  workspace.history.push({time:now(), results});\n  if (workspace.history.length > 100) workspace.history.shift();\n  saveWorkspaceToLocal();\n  updateUIState();\n  log('Run complete. Results:', results.map(r=>({name:r.name,status:r.status,time:r.duration})));\n  return results;\n}\n\nasync function runSingleTest(test, opts={rngFn:()=>Math.random(), iterations:1}) {\n  const res = {name:test.name, id:test.id, status:'unknown', duration:0, error:null};\n  const start = now();\n  test.status = 'running';\n  updateUIState();\n  try {\n    // build test function from code\n    const wrapper = new Function('exports','assert','helpers','snapshot','rng','createSpy','mutation','require','setTimeout','setInterval','clearTimeout','clearInterval', test.code + '\\n; return (typeof test === \"function\") ? test : (typeof exports === \"function\" ? exports : null);');\n    // We call the test as a function that expects (exports, assert, helpers)\n    const sandboxExports = workspace.compiledExports || {};\n    const helpers = {\n      rng: opts.rngFn,\n      seed: document.getElementById('rngSeed').value,\n      mutation: document.getElementById('mutationToggle').checked,\n      createSpy\n    };\n    // The user's test code might define a function directly (async function(...) {}) or return one.\n    const ret = wrapper(sandboxExports, assert, helpers, (v,update)=> snapshotTest(test.name + (update?'.updated':''), v, update), opts.rngFn, createSpy, workspace.mutation);\n    let testFn = null;\n    if (typeof ret === 'function') testFn = ret;\n    else {\n      // try evaluating test.code as an expression that returns a function\n      if (typeof ret === 'object' && ret !== null && typeof ret.default === 'function') testFn = ret.default;\n      else {\n        // fallback: try to create a function wrapper around code that is itself a function body\n        try {\n          testFn = wrapper; // if wrapper returns a callable, use it\n        } catch(e) {}\n      }\n    }\n    if (!testFn) {\n      // try to create from test.code by wrapping as an async function\n      testFn = new Function('exports','assert','helpers', test.code);\n    }\n    // allow generator functions: call and see if returns iterator\n    let out;\n    let timedOut = false;\n    const timeoutMs = test.timeout || Number(document.getElementById('testTimeout').value) || 2000;\n    const timeoutPromise = new Promise((_, rej) => {\n      const id = setTimeout(()=>{ timedOut=true; rej(new Error('Test timed out after ' + timeoutMs + 'ms')); }, timeoutMs);\n      // clear on finish\n      timeoutPromise._clear = ()=>clearTimeout(id);\n    });\n\n    const exec = async () => {\n      try {\n        out = testFn(sandboxExports, assert, helpers);\n        if (isGenerator(out)) {\n          // step through generator fully by default; if stepping enabled we pause on yields.\n          const gen = out;\n          let last;\n          while(true) {\n            if (runtime.stopRequested) throw new Error('Run stopped');\n            if (runtime.paused) {\n              // wait for resume or step\n              log(`[paused] Test ${test.name} paused before next yield.`);\n              await waitFor(() => !runtime.paused || runtime.stopRequested);\n            }\n            const r = gen.next(last);\n            if (r.done) { last = r.value; break; }\n            // yielded value logged and optionally used by user\n            log(`[yield] ${test.name}:`, r.value);\n            last = r.value;\n            if (runtime.stepping) {\n              runtime.paused = true;\n            }\n            if (runtime.paused) {\n              await waitFor(() => !runtime.paused || runtime.stopRequested);\n            }\n          }\n          return last;\n        } else if (isPromise(out)) {\n          return await out;\n        } else {\n          return out;\n        }\n      } catch(e) {\n        throw e;\n      }\n    };\n\n    const result = await Promise.race([exec(), timeoutPromise]).finally(()=> {\n      if (timeoutPromise._clear) timeoutPromise._clear();\n    });\n    res.status = 'passed';\n    test.status = 'passed';\n    test.result = 'ok';\n    res.duration = now() - start;\n    runtime.currentRun && runtime.currentRun.results && runtime.currentRun.results.push(res);\n    updateCoverageUI();\n    updateUIState();\n    return res;\n  } catch (e) {\n    res.status = 'failed';\n    res.error = e && (e.stack || e.message || e);\n    test.status = 'failed';\n    test.result = e && (e.message || String(e));\n    res.duration = now() - start;\n    runtime.currentRun && runtime.currentRun.results && runtime.currentRun.results.push(res);\n    log('Test failed:', test.name, res.error);\n    updateUIState();\n    return res;\n  } finally {\n    updateUIState();\n  }\n}\n\nfunction isGenerator(obj) {\n  return obj && typeof obj.next === 'function' && typeof obj.throw === 'function';\n}\nfunction isPromise(obj) {\n  return obj && typeof obj.then === 'function';\n}\n\nfunction waitFor(cond) {\n  return new Promise(resolve => {\n    const id = setInterval(()=>{ if (cond()) { clearInterval(id); resolve(); } }, 20);\n  });\n}\n\n/* ---------- UI & Wiring ---------- */\n\ndocument.getElementById('compileBtn').addEventListener('click', ()=>{ compileSource(); saveWorkspaceToLocal(); });\ndocument.getElementById('resetSourceBtn').addEventListener('click', ()=>{ document.getElementById('sourceArea').value = defaultSource; compileSource(); });\ndocument.getElementById('addTestBtn').addEventListener('click', ()=>{ addTest(document.getElementById('newTestName').value || 'newTest', document.getElementById('newTestSuite').value || 'default', document.getElementById('testArea').value); });\ndocument.getElementById('updateTestBtn').addEventListener('click', ()=>{ updateSelectedTest(); });\ndocument.getElementById('deleteTestBtn').addEventListener('click', ()=>{ deleteSelectedTest(); });\ndocument.getElementById('duplicateTestBtn').addEventListener('click', ()=>{ duplicateSelectedTest(); });\ndocument.getElementById('markSkipBtn').addEventListener('click', ()=>{ toggleFlagSelected('skip'); });\ndocument.getElementById('markOnlyBtn').addEventListener('click', ()=>{ toggleFlagSelected('only'); });\ndocument.getElementById('markFlakyBtn').addEventListener('click', ()=>{ toggleFlagSelected('flaky'); });\ndocument.getElementById('runAllBtn').addEventListener('click', ()=>{ runAllTests({selectedOnly:false}); });\ndocument.getElementById('runSelectedBtn').addEventListener('click', ()=>{ runAllTests({selectedOnly:true}); });\ndocument.getElementById('runPropertyBtn').addEventListener('click', ()=>{ runAllTests({selectedOnly:true, property:true}); });\ndocument.getElementById('stepBtn').addEventListener('