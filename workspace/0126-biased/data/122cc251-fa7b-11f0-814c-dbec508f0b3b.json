    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Thread</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        #thread {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.2);\n        }\n        #controls {\n            margin-bottom: 20px;\n        }\n        #controls button {\n            margin-right: 10px;\n        }\n        #controls input {\n            padding: 10px;\n            width: 20%;\n        }\n        #controls select {\n            padding: 10px;\n            width: 20%;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Thread</h1>\n\n<div id=\"thread\"></div>\n<div id=\"controls\">\n    <button id=\"create-thread-btn\">Create Thread</button>\n    <button id=\"edit-thread-btn\">Edit Thread</button>\n    <input id=\"thread-title-input\" type=\"text\" placeholder=\"Thread Title\">\n    <input id=\"thread-description-input\" type=\"text\" placeholder=\"Thread Description\">\n    <button id=\"add-thread-btn\">Add Thread</button>\n    <button id=\"delete-thread-btn\">Delete Thread</button>\n</div>\n\n<script>\n    let currentThread = null;\n    let currentThreadId = null;\n    let threads = [];\n\n    // Create thread function\n    function createThread(title, description) {\n        const thread = {\n            id: currentThreadId,\n            title: title,\n            description: description,\n            replies: []\n        };\n        threads.push(thread);\n        updateThreadUI(thread);\n        updateThreadUI(currentThread);\n        currentThreadId++;\n    }\n\n    // Edit thread function\n    function editThread(id, title, description) {\n        const thread = threads.find(t => t.id === id);\n        thread.title = title;\n        thread.description = description;\n        updateThreadUI(thread);\n        updateThreadUI(currentThread);\n    }\n\n    // Add thread function\n    function addThread() {\n        const threadTitle = document.getElementById('thread-title-input').value;\n        const threadDescription = document.getElementById('thread-description-input').value;\n        createThread(threadTitle, threadDescription);\n    }\n\n    // Delete thread function\n    function deleteThread(id) {\n        threads = threads.filter(t => t.id !== id);\n        updateThreadUI(currentThread);\n    }\n\n    // Update thread UI function\n    function updateThreadUI(thread) {\n        document.getElementById('thread-title-input').value = thread.title;\n        document.getElementById('thread-description-input').value = thread.description;\n        if (thread.replies.length > 0) {\n            thread.replies.forEach(reply => {\n                const replyButton = document.createElement('button');\n                replyButton.textContent = `Reply ${thread.replies.length}`;\n                replyButton.onclick = () => {\n                    const reply = {\n                        id: thread.id,\n                        content: replyButton.textContent,\n                        replies: thread.replies\n                    };\n                    addReply(reply);\n                };\n                document.getElementById('controls').appendChild(replyButton);\n            });\n        }\n    }\n\n    // Add reply function\n    function addReply(reply) {\n        const replyButton = document.createElement('button');\n        replyButton.textContent = reply.content;\n        replyButton.onclick = () => {\n            const reply = {\n                id: reply.id,\n                content: replyButton.textContent,\n                replies: reply.replies\n            };\n            thread.replies.push(reply);\n            updateThreadUI(reply);\n            updateThreadUI(thread);\n        };\n        document.getElementById('controls').appendChild(replyButton);\n    }\n\n    // Initialize threads\n    if (threads.length > 0) {\n        const thread = threads[0];\n        updateThreadUI(thread);\n    }\n\n    // Add event listeners\n    document.getElementById('create-thread-btn').addEventListener('click', createThread);\n    document.getElementById('edit-thread-btn').addEventListener('click', editThread);\n    document.getElementById('add-thread-btn').addEventListener('click', addThread);\n    document.getElementById('delete-thread-btn').addEventListener('click', deleteThread);\n</script>\n\n</body>\n</html>"
