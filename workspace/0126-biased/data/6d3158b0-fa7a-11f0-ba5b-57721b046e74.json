    "content": "<html>\n<head>\n    <title>HTTP Interactive Explorer</title>\n    <script>\n        let requestHistory = [];\n        let currentRequest = {\n            method: 'GET',\n            url: 'https://jsonplaceholder.typicode.com/posts/1',\n            headers: [\n                {name: 'Content-Type', value: 'application/json'},\n                {name: 'Accept', value: 'application/json'}\n            ],\n            body: '',\n            auth: {username: '', password: ''}\n        };\n\n        function init() {\n            updateRequestDisplay();\n            document.getElementById('sendRequest').addEventListener('click', sendRequest);\n            document.getElementById('addHeader').addEventListener('click', addHeader);\n            document.getElementById('methodSelect').addEventListener('change', updateMethod);\n            document.getElementById('urlInput').addEventListener('change', updateUrl);\n            document.getElementById('bodyInput').addEventListener('input', updateBody);\n            document.getElementById('authUsername').addEventListener('input', updateAuth);\n            document.getElementById('authPassword').addEventListener('input', updateAuth);\n            document.getElementById('historyList').addEventListener('click', loadFromHistory);\n        }\n\n        function updateRequestDisplay() {\n            document.getElementById('methodSelect').value = currentRequest.method;\n            document.getElementById('urlInput').value = currentRequest.url;\n            document.getElementById('bodyInput').value = currentRequest.body;\n            document.getElementById('authUsername').value = currentRequest.auth.username;\n            document.getElementById('authPassword').value = currentRequest.auth.password;\n            \n            const headersContainer = document.getElementById('headersContainer');\n            headersContainer.innerHTML = '';\n            currentRequest.headers.forEach((header, index) => {\n                const div = document.createElement('div');\n                div.innerHTML = `\n                    <input type=\"text\" value=\"${header.name}\" class=\"header-name\" data-index=\"${index}\">\n                    <input type=\"text\" value=\"${header.value}\" class=\"header-value\" data-index=\"${index}\">\n                    <button class=\"remove-header\" data-index=\"${index}\">Remove</button>\n                `;\n                headersContainer.appendChild(div);\n                \n                div.querySelector('.header-name').addEventListener('change', updateHeader);\n                div.querySelector('.header-value').addEventListener('change', updateHeader);\n                div.querySelector('.remove-header').addEventListener('click', removeHeader);\n            });\n        }\n\n        function updateMethod(e) {\n            currentRequest.method = e.target.value;\n            if (currentRequest.method === 'GET' || currentRequest.method === 'HEAD') {\n                document.getElementById('bodyInput').disabled = true;\n            } else {\n                document.getElementById('bodyInput').disabled = false;\n            }\n        }\n\n        function updateUrl(e) {\n            currentRequest.url = e.target.value;\n        }\n\n        function updateBody(e) {\n            currentRequest.body = e.target.value;\n        }\n\n        function updateAuth(e) {\n            if (e.target.id === 'authUsername') {\n                currentRequest.auth.username = e.target.value;\n            } else {\n                currentRequest.auth.password = e.target.value;\n            }\n        }\n\n        function addHeader() {\n            currentRequest.headers.push({name: '', value: ''});\n            updateRequestDisplay();\n        }\n\n        function updateHeader(e) {\n            const index = parseInt(e.target.dataset.index);\n            if (e.target.classList.contains('header-name')) {\n                currentRequest.headers[index].name = e.target.value;\n            } else {\n                currentRequest.headers[index].value = e.target.value;\n            }\n        }\n\n        function removeHeader(e) {\n            const index = parseInt(e.target.dataset.index);\n            currentRequest.headers.splice(index, 1);\n            updateRequestDisplay();\n        }\n\n        function sendRequest() {\n            const startTime = Date.now();\n            const requestOptions = {\n                method: currentRequest.method,\n                headers: {}\n            };\n\n            // Add headers\n            currentRequest.headers.forEach(header => {\n                if (header.name && header.value) {\n                    requestOptions.headers[header.name] = header.value;\n                }\n            });\n\n            // Add auth if provided\n            if (currentRequest.auth.username || currentRequest.auth.password) {\n                requestOptions.headers['Authorization'] = 'Basic ' + btoa(currentRequest.auth.username + ':' + currentRequest.auth.password);\n            }\n\n            // Add body for applicable methods\n            if (currentRequest.method !== 'GET' && currentRequest.method !== 'HEAD' && currentRequest.body) {\n                requestOptions.body = currentRequest.body;\n            }\n\n            // Display request details\n            const requestDetails = document.getElementById('requestDetails');\n            requestDetails.innerHTML = `\n                <h3>Request</h3>\n                <pre>${currentRequest.method} ${currentRequest.url}</pre>\n                <pre>Headers:\\n${JSON.stringify(requestOptions.headers, null, 2)}</pre>\n                ${currentRequest.body ? `<pre>Body:\\n${currentRequest.body}</pre>` : ''}\n            `;\n\n            // Make the request\n            fetch(currentRequest.url, requestOptions)\n                .then(response => {\n                    const endTime = Date.now();\n                    const duration = endTime - startTime;\n                    \n                    return response.text().then(text => ({\n                        status: response.status,\n                        statusText: response.statusText,\n                        headers: [...response.headers].reduce((obj, [key, value]) => {\n                            obj[key] = value;\n                            return obj;\n                        }, {}),\n                        body: text,\n                        duration: duration\n                    }));\n                })\n                .then(data => {\n                    // Display response\n                    const responseDetails = document.getElementById('responseDetails');\n                    responseDetails.innerHTML = `\n                        <h3>Response (${data.duration}ms)</h3>\n                        <pre>Status: ${data.status} ${data.statusText}</pre>\n                        <pre>Headers:\\n${JSON.stringify(data.headers, null, 2)}</pre>\n                        <pre>Body:\\n${data.body}</pre>\n                    `;\n\n                    // Add to history\n                    const historyItem = {\n                        ...currentRequest,\n                        response: data,\n                        timestamp: new Date().toISOString()\n                    };\n                    requestHistory.unshift(historyItem);\n                    updateHistoryList();\n                })\n                .catch(error => {\n                    const responseDetails = document.getElementById('responseDetails');\n                    responseDetails.innerHTML = `\n                        <h3>Error</h3>\n                        <pre>${error.toString()}</pre>\n                    `;\n                });\n        }\n\n        function updateHistoryList() {\n            const historyList = document.getElementById('historyList');\n            historyList.innerHTML = '';\n            requestHistory.forEach((item, index) => {\n                const li = document.createElement('li');\n                li.dataset.index = index;\n                li.textContent = `${item.method} ${item.url} - ${item.response?.status || 'Error'} (${new Date(item.timestamp).toLocaleTimeString()})`;\n                historyList.appendChild(li);\n            });\n        }\n\n        function loadFromHistory(e) {\n            if (e.target.tagName === 'LI') {\n                const index = parseInt(e.target.dataset.index);\n                currentRequest = {...requestHistory[index]};\n                updateRequestDisplay();\n            }\n        }\n    </script>\n</head>\n<body onload=\"init()\">\n    <h1>HTTP Interactive Explorer</h1>\n    \n    <div>\n        <h2>Request Builder</h2>\n        <div>\n            <label>Method:\n                <select id=\"methodSelect\">\n                    <option>GET</option>\n                    <option>POST</option>\n                    <option>PUT</option>\n                    <option>PATCH</option>\n                    <option>DELETE</option>\n                    <option>HEAD</option>\n                    <option>OPTIONS</option>\n                </select>\n            </label>\n        </div>\n        \n        <div>\n            <label>URL: <input type=\"text\" id=\"urlInput\" size=\"50\"></label>\n        </div>\n        \n        <div>\n            <h3>Headers</h3>\n            <div id=\"headersContainer\"></div>\n            <button id=\"addHeader\">Add Header</button>\n        </div>\n        \n        <div>\n            <h3>Body</h3>\n            <textarea id=\"bodyInput\" rows=\"10\" cols=\"80\"></textarea>\n        </div>\n        \n        <div>\n            <h3>Authentication</h3>\n            <label>Username: <input type=\"text\" id=\"authUsername\"></label>\n            <label>Password: <input type=\"password\" id=\"authPassword\"></label>\n        </div>\n        \n        <button id=\"sendRequest\">Send Request</button>\n    </div>\n    \n    <div>\n        <h2>Request/Response</h2>\n        <div id=\"requestDetails\"></div>\n        <div id=\"responseDetails\"></div>\n    </div>\n    \n    <div>\n        <h2>History</h2>\n        <ul id=\"historyList\"></ul>\n    </div>\n    \n    <div>\n        <h2>HTTP Concepts</h2>\n        <div>\n            <h3>Methods</h3>\n            <ul>\n                <li><strong>GET</strong> - Retrieve a resource</li>\n                <li><strong>POST</strong> - Create a resource</li>\n                <li><strong>PUT</strong> - Replace a resource</li>\n                <li><strong>PATCH</strong> - Partially update a resource</li>\n                <li><strong>DELETE</strong> - Remove a resource</li>\n                <li><strong>HEAD</strong> - Like GET but without body</li>\n                <li><strong>OPTIONS</strong> - Discover available methods</li>\n            </ul>\n        </div>\n        \n        <div>\n            <h3>Status Codes</h3>\n            <ul>\n                <li><strong>1xx</strong> - Informational</li>\n                <li><strong>2xx</strong> - Success (200 OK, 201 Created, 204 No Content)</li>\n                <li><strong>3xx</strong> - Redirection (301 Moved, 304 Not Modified)</li>\n                <li><strong>4xx</strong> - Client errors (400 Bad Request, 401 Unauthorized, 403 Forbidden, 404 Not Found)</li>\n                <li><strong>5xx</strong> - Server errors (500 Internal Server Error, 503 Service Unavailable)</li>\n            </ul>\n        </div>\n    </div>\n</body>\n</html>"
