  "question": "Dynamic Typing",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Dynamic Typing Explorer</title>\n    <style>\n        body {\n            font-family: monospace;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.5;\n        }\n        .container {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-bottom: 10px;\n        }\n        button, select, input {\n            margin: 5px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n            font-family: monospace;\n        }\n        .type-info {\n            font-size: 0.9em;\n            color: #555;\n        }\n    </style>\n</head>\n<body>\n    <h1>Dynamic Typing Explorer</h1>\n    \n    <div class=\"container\">\n        <div>\n            <div class=\"panel\">\n                <h2>Type Creation</h2>\n                <div>\n                    <button id=\"createNumber\">Create Number</button>\n                    <button id=\"createString\">Create String</button>\n                    <button id=\"createBoolean\">Create Boolean</button>\n                    <button id=\"createArray\">Create Array</button>\n                    <button id=\"createObject\">Create Object</button>\n                    <button id=\"createFunction\">Create Function</button>\n                </div>\n                \n                <div>\n                    <label>Custom Value: <input type=\"text\" id=\"customValue\"></label>\n                    <button id=\"evaluateCustom\">Evaluate</button>\n                </div>\n                \n                <div>\n                    <h3>Type Conversion</h3>\n                    <select id=\"conversionType\">\n                        <option value=\"string\">String</option>\n                        <option value=\"number\">Number</option>\n                        <option value=\"boolean\">Boolean</option>\n                    </select>\n                    <button id=\"convertValue\">Convert</button>\n                </div>\n            </div>\n            \n            <div class=\"panel\">\n                <h2>Operations</h2>\n                <div>\n                    <button id=\"addOperation\">+ (Add)</button>\n                    <button id=\"concatOperation\">+ (Concatenate)</button>\n                    <button id=\"compareOperation\">== (Compare)</button>\n                    <button id=\"strictCompareOperation\">=== (Strict Compare)</button>\n                </div>\n                \n                <div>\n                    <h3>Mathematical Operations</h3>\n                    <button id=\"increment\">Increment ++</button>\n                    <button id=\"decrement\">Decrement --</button>\n                    <button id=\"multiply\">Multiply *</button>\n                    <button id=\"divide\">Divide /</button>\n                </div>\n            </div>\n        </div>\n        \n        <div>\n            <div class=\"panel\">\n                <h2>Current Variables</h2>\n                <div id=\"variableList\"></div>\n                <div>\n                    <label>Variable Name: <input type=\"text\" id=\"varName\"></label>\n                    <button id=\"createVar\">Create Variable</button>\n                </div>\n            </div>\n            \n            <div class=\"panel\">\n                <h2>Type Information</h2>\n                <div id=\"typeOutput\"></div>\n                <textarea id=\"codeOutput\" readonly></textarea>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Type Playground</h2>\n        <div>\n            <label>Expression: <input type=\"text\" id=\"expressionInput\" size=\"50\"></label>\n            <button id=\"evaluateExpression\">Evaluate</button>\n        </div>\n        <div id=\"expressionResult\"></div>\n    </div>\n    \n    <script>\n        // State management\n        const variables = {};\n        let lastValue = null;\n        \n        // DOM elements\n        const variableList = document.getElementById('variableList');\n        const typeOutput = document.getElementById('typeOutput');\n        const codeOutput = document.getElementById('codeOutput');\n        const expressionResult = document.getElementById('expressionResult');\n        \n        // Update UI functions\n        function updateVariableList() {\n            variableList.innerHTML = '';\n            for (const [name, value] of Object.entries(variables)) {\n                const div = document.createElement('div');\n                div.innerHTML = `<strong>${name}</strong>: ${value} (${typeof value})`;\n                variableList.appendChild(div);\n            }\n        }\n        \n        function showTypeInfo(value) {\n            lastValue = value;\n            typeOutput.innerHTML = `\n                <p><strong>Value:</strong> ${value}</p>\n                <p><strong>Type:</strong> ${typeof value}</p>\n                <p><strong>Constructor:</strong> ${value?.constructor?.name || 'primitive'}</p>\n                <p class=\"type-info\"><strong>toString():</strong> ${value?.toString()}</p>\n                <p class=\"type-info\"><strong>valueOf():</strong> ${value?.valueOf ? value.valueOf() : 'N/A'}</p>\n            `;\n            \n            codeOutput.value = `// Current value\\nconst value = ${JSON.stringify(value, null, 2)};\\n\\ntypeof value; // ${typeof value}\\nvalue.constructor; // ${value?.constructor?.name || 'primitive'}`;\n        }\n        \n        // Event handlers\n        document.getElementById('createNumber').addEventListener('click', () => {\n            const num = Math.floor(Math.random() * 100);\n            showTypeInfo(num);\n        });\n        \n        document.getElementById('createString').addEventListener('click', () => {\n            const str = 'String ' + Math.random().toString(36).substring(2, 8);\n            showTypeInfo(str);\n        });\n        \n        document.getElementById('createBoolean').addEventListener('click', () => {\n            showTypeInfo(Math.random() > 0.5);\n        });\n        \n        document.getElementById('createArray').addEventListener('click', () => {\n            const arr = [\n                Math.floor(Math.random() * 100),\n                'text',\n                Math.random() > 0.5,\n                { key: 'value' }\n            ];\n            showTypeInfo(arr);\n        });\n        \n        document.getElementById('createObject').addEventListener('click', () => {\n            const obj = {\n                number: Math.floor(Math.random() * 100),\n                string: 'property',\n                boolean: Math.random() > 0.5,\n                method: function() { return this.number; }\n            };\n            showTypeInfo(obj);\n        });\n        \n        document.getElementById('createFunction').addEventListener('click', () => {\n            const func = function(a, b) {\n                return a + b;\n            };\n            showTypeInfo(func);\n        });\n        \n        document.getElementById('evaluateCustom').addEventListener('click', () => {\n            try {\n                const value = eval(document.getElementById('customValue').value);\n                showTypeInfo(value);\n            } catch (e) {\n                showTypeInfo(`Error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('convertValue').addEventListener('click', () => {\n            if (lastValue === null) return;\n            \n            const conversionType = document.getElementById('conversionType').value;\n            let converted;\n            \n            try {\n                switch (conversionType) {\n                    case 'string':\n                        converted = String(lastValue);\n                        break;\n                    case 'number':\n                        converted = Number(lastValue);\n                        break;\n                    case 'boolean':\n                        converted = Boolean(lastValue);\n                        break;\n                }\n                showTypeInfo(converted);\n            } catch (e) {\n                showTypeInfo(`Conversion error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('createVar').addEventListener('click', () => {\n            const varName = document.getElementById('varName').value.trim();\n            if (varName && lastValue !== null) {\n                variables[varName] = lastValue;\n                updateVariableList();\n            }\n        });\n        \n        // Operation handlers\n        document.getElementById('addOperation').addEventListener('click', () => {\n            if (lastValue === null) return;\n            const other = prompt('Enter value to add:');\n            try {\n                const result = lastValue + Number(other);\n                showTypeInfo(result);\n            } catch (e) {\n                showTypeInfo(`Error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('concatOperation').addEventListener('click', () => {\n            if (lastValue === null) return;\n            const other = prompt('Enter value to concatenate:');\n            const result = lastValue + String(other);\n            showTypeInfo(result);\n        });\n        \n        document.getElementById('compareOperation').addEventListener('click', () => {\n            if (lastValue === null) return;\n            const other = prompt('Enter value to compare (==):');\n            try {\n                const result = lastValue == other;\n                showTypeInfo(result);\n            } catch (e) {\n                showTypeInfo(`Error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('strictCompareOperation').addEventListener('click', () => {\n            if (lastValue === null) return;\n            const other = prompt('Enter value to strictly compare (===):');\n            try {\n                const result = lastValue === other;\n                showTypeInfo(result);\n            } catch (e) {\n                showTypeInfo(`Error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('increment').addEventListener('click', () => {\n            if (typeof lastValue === 'number') {\n                showTypeInfo(++lastValue);\n            } else {\n                showTypeInfo(\"Can only increment numbers\");\n            }\n        });\n        \n        document.getElementById('decrement').addEventListener('click', () => {\n            if (typeof lastValue === 'number') {\n                showTypeInfo(--lastValue);\n            } else {\n                showTypeInfo(\"Can only decrement numbers\");\n            }\n        });\n        \n        document.getElementById('multiply').addEventListener('click', () => {\n            if (lastValue === null) return;\n            const other = prompt('Enter value to multiply by:');\n            try {\n                const result = lastValue * Number(other);\n                showTypeInfo(result);\n            } catch (e) {\n                showTypeInfo(`Error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('divide').addEventListener('click', () => {\n            if (lastValue === null) return;\n            const other = prompt('Enter value to divide by:');\n            try {\n                const result = lastValue / Number(other);\n                showTypeInfo(result);\n            } catch (e) {\n                showTypeInfo(`Error: ${e.message}`);\n            }\n        });\n        \n        document.getElementById('evaluateExpression').addEventListener('click', () => {\n            try {\n                const expr = document.getElementById('expressionInput').value;\n                const result = eval(expr);\n                expressionResult.innerHTML = `\n                    <p><strong>Result:</strong> ${result}</p>\n                    <p><strong>Type:</strong> ${typeof result}</p>\n                `;\n            } catch (e) {\n                expressionResult.innerHTML = `<strong>Error:</strong> ${e.message}`;\n            }\n        });\n        \n        // Initialize\n        showTypeInfo(\"Click buttons to explore dynamic typing\");\n    </script>\n</body>\n</html>"
  },
