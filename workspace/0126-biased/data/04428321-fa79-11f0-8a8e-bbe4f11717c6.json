    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Jump Search</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n            margin: 0;\n            padding: 0;\n        }\n\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n\n        .header h1 {\n            font-size: 24px;\n            margin-bottom: 10px;\n        }\n\n        .header p {\n            font-size: 18px;\n            color: #666;\n        }\n\n        .jump-search {\n            position: relative;\n            width: 100%;\n            height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n        }\n\n        .jump-search button {\n            width: 200px;\n            height: 50px;\n            font-size: 18px;\n            font-weight: bold;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 10px;\n            cursor: pointer;\n        }\n\n        .jump-search button:hover {\n            background-color: #3e8e41;\n        }\n\n        .search-bar {\n            width: 100%;\n            padding: 10px;\n            font-size: 18px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n\n        .search-bar input[type=\"text\"] {\n            width: 80%;\n            padding: 10px;\n            font-size: 18px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n\n        .search-results {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            background-color: #fff;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .search-results p {\n            font-size: 18px;\n            color: #666;\n        }\n\n        .search-results button {\n            width: 100%;\n            padding: 10px;\n            font-size: 18px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .search-results button:hover {\n            background-color: #4CAF50;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Jump Search</h1>\n            <p>Discover new things with our efficient search algorithm</p>\n        </div>\n        <div class=\"jump-search\">\n            <button id=\"jump-search-btn\">Start</button>\n            <input type=\"text\" id=\"search-bar\" placeholder=\"Search...\">\n            <div class=\"search-results\"></div>\n        </div>\n    </div>\n\n    <script>\n        let searchResults = [];\n        let jumpSearchButton = document.getElementById('jump-search-btn');\n        let searchBar = document.getElementById('search-bar');\n        let searchResultsDiv = document.getElementById('search-results');\n\n        jumpSearchButton.addEventListener('click', startJumpSearch);\n\n        function startJumpSearch() {\n            let searchQuery = searchBar.value.trim();\n            if (searchQuery !== '') {\n                searchResults = [];\n                searchResultsDiv.innerHTML = '';\n                for (let i = 0; i < 10; i++) {\n                    let result = generateRandomResult();\n                    searchResultsDiv.innerHTML += `<p>${result}</p>`;\n                    searchResults.push(result);\n                }\n                searchResultsDiv.innerHTML = 'Search results: ' + searchResults.join('\\n');\n            }\n        }\n\n        function generateRandomResult() {\n            let genre = Math.floor(Math.random() * 3) + 1;\n            let title = 'Title ' + genre;\n            let author = 'Author ' + genre;\n            return `${title} by ${author}`;\n        }\n    </script>\n</body>\n</html>"
