  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\"/>\n  <title>Deadlock Interactive Simulator</title>\n  <style>\n    /* Minimal plain styling: keep everything default-looking */\n    body { font-family: Arial, sans-serif; color: black; background: white; margin: 12px; }\n    button, input, select, textarea { font: inherit; }\n    .section { margin-bottom: 16px; padding: 6px; border: 1px solid #00000022; }\n    label { margin-right: 6px; }\n    table { border-collapse: collapse; margin-top: 6px; }\n    td, th { padding: 4px 6px; border: 1px solid #ddd; }\n    .small { font-size: 12px; }\n    .mono { font-family: monospace; font-size: 13px; white-space: pre; }\n  </style>\n</head>\n<body>\n  <h2>Deadlock Simulator (Interactive)</h2>\n  <div class=\"section\">\n    <div><strong>Overview:</strong> Create resources and processes that request and release resources. Run step-by-step or auto-run. Use detection and recovery tools, and try many policies (ordering, wait-die/wound-wait, timeouts, preemption). The UI is intentionally plain - focus on interactions.</div>\n  </div>\n\n  <div class=\"section\">\n    <strong>1) Resources</strong><br>\n    <label>Resource name: <input id=\"newResName\" value=\"R1\" size=\"4\"></label>\n    <label>Units: <input id=\"newResUnits\" type=\"number\" min=\"1\" value=\"1\" size=\"4\"></label>\n    <button id=\"addResBtn\">Add Resource</button>\n    <button id=\"clearResBtn\">Clear All Resources</button>\n    <div>\n      <table id=\"resTable\"><thead><tr><th>Res</th><th>Units</th><th>Available</th><th>Allocated</th><th>Actions</th></tr></thead><tbody></tbody></table>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <strong>2) Processes</strong><br>\n    <label>Process name: <input id=\"newProcName\" value=\"P1\" size=\"4\"></label>\n    <label>Priority (higher runs first): <input id=\"newProcPriority\" type=\"number\" value=\"1\" min=\"0\" size=\"4\"></label>\n    <label>Timestamp (for wait-die/wound): <input id=\"newProcTimestamp\" type=\"number\" value=\"1\" min=\"1\" size=\"4\"></label>\n    <button id=\"addProcBtn\">Add Process</button>\n    <button id=\"clearProcBtn\">Clear All Processes</button>\n    <div>\n      <table id=\"procTable\"><thead><tr><th>Proc</th><th>Priority</th><th>TS</th><th>State</th><th>Held</th><th>NextOp</th><th>Actions</th></tr></thead><tbody></tbody></table>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <strong>3) Define Operation Sequence for a Process</strong><br>\n    <label>Proc: <select id=\"opProc\"></select></label>\n    <label>Type: <select id=\"opType\"><option value=\"request\">Request</option><option value=\"release\">Release</option><option value=\"compute\">Compute</option></select></label>\n    <label>Res: <select id=\"opRes\"></select></label>\n    <label>Units: <input id=\"opUnits\" type=\"number\" value=\"1\" min=\"1\" size=\"4\"></label>\n    <label>Duration (compute steps): <input id=\"opDuration\" type=\"number\" value=\"1\" min=\"1\" size=\"4\"></label>\n    <button id=\"addOpBtn\">Append Operation</button>\n    <button id=\"clearOpsBtn\">Clear Ops for Selected Proc</button>\n    <div>\n      <div class=\"small\">Operation sequence (per process) — use this to craft deadlock scenarios.</div>\n      <textarea id=\"procOps\" rows=\"6\" cols=\"80\" class=\"mono\" readonly></textarea>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <strong>4) Scenarios & Generators</strong><br>\n    <button id=\"genDiningBtn\">Generate Dining Philosophers (n)</button>\n    <input id=\"genDiningN\" type=\"number\" min=\"2\" value=\"5\" size=\"3\">\n    <button id=\"genClassicBtn\">Generate Classic 2x2 Deadlock</button>\n    <button id=\"genRandomBtn\">Generate Random Scenario</button>\n    <label>Processes: <input id=\"randP\" type=\"number\" min=\"2\" value=\"4\" size=\"3\"></label>\n    <label>Resources: <input id=\"randR\" type=\"number\" min=\"2\" value=\"3\" size=\"3\"></label>\n    <label>Max units each: <input id=\"randMaxUnits\" type=\"number\" min=\"1\" value=\"2\" size=\"3\"></label>\n  </div>\n\n  <div class=\"section\">\n    <strong>5) Simulation Controls</strong><br>\n    <label>Mode: \n      <select id=\"simMode\">\n        <option value=\"auto\">Auto-run (scheduler)</option>\n        <option value=\"step\">Manual Step (single operation)</option>\n      </select>\n    </label>\n    <label>Scheduler: \n      <select id=\"scheduler\">\n        <option value=\"roundrobin\">Round Robin</option>\n        <option value=\"priority\">Priority</option>\n        <option value=\"fifo\">FIFO</option>\n      </select>\n    </label>\n    <label>Policy: \n      <select id=\"resourcePolicy\">\n        <option value=\"none\">No special policy</option>\n        <option value=\"ordering\">Global resource ordering</option>\n        <option value=\"all_or_nothing\">All-request at once</option>\n        <option value=\"wait_die\">Wait-Die (timestamp)</option>\n        <option value=\"wound_wait\">Wound-Wait (timestamp)</option>\n        <option value=\"timeout\">Timeout</option>\n      </select>\n    </label>\n    <label>Timeout steps: <input id=\"timeoutSteps\" type=\"number\" min=\"1\" value=\"5\" size=\"3\"></label>\n    <label>Allow Preemption: <input id=\"allowPreempt\" type=\"checkbox\"></label>\n    <br><br>\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"runBtn\">Run</button>\n    <button id=\"pauseBtn\">Pause</button>\n    <label>Speed (ms): <input id=\"runSpeed\" type=\"range\" min=\"100\" max=\"2000\" value=\"800\"></label>\n    <span id=\"speedVal\">800</span> ms\n  </div>\n\n  <div class=\"section\">\n    <strong>6) Detection & Recovery</strong><br>\n    <button id=\"detectBtn\">Detect Deadlocks</button>\n    <button id=\"safeCheckBtn\">Banker's Safe-State Check</button>\n    <label>Max claims JSON: <input id=\"maxClaims\" size=\"40\" placeholder='{\"P1\":{\"R1\":1}}'></label>\n    <div>\n      <button id=\"abortSelectedBtn\">Abort Selected Processes</button>\n      <select id=\"abortSelect\" multiple size=\"4\" style=\"vertical-align: top;\"></select>\n      <button id=\"preemptSelectedBtn\">Preempt Resources from Selected Processes</button>\n      <button id=\"releaseAllBtn\">Force Release All Held Resources</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <strong>7) Manual Controls</strong><br>\n    <label>Proc: <select id=\"manualProc\"></select></label>\n    <label>Resource: <select id=\"manualRes\"></select></label>\n    <label>Units: <input id=\"manualUnits\" type=\"number\" min=\"1\" value=\"1\" size=\"4\"></label>\n    <button id=\"manualAllocateBtn\">Allocate to Proc (force)</button>\n    <button id=\"manualRequestBtn\">Make Proc Request (simulate)</button>\n    <button id=\"manualReleaseBtn\">Release from Proc</button>\n    <div>\n      <button id=\"killAllBtn\">Reset Simulator (clear allocations but keep definitions)</button>\n      <button id=\"fullResetBtn\">Full Reset (clear everything)</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <strong>8) Visualizations & Logs</strong><br>\n    <div class=\"small\">Resource Allocation Graph (textual):</div>\n    <textarea id=\"rag\" rows=\"6\" cols=\"100\" readonly class=\"mono\"></textarea>\n    <div class=\"small\">Event Log:</div>\n    <textarea id=\"log\" rows=\"10\" cols=\"100\" readonly class=\"mono\"></textarea>\n  </div>\n\n  <script>\n(function(){\n  // Minimal global-like simulator object\n  const SIM = {\n    resources: {},    // name -> {total, available, allocated: {proc:units}}\n    processes: {},    // name -> {priority, ts, state, ops:[], pc, held: {res:units}, waitingFor: {res,units}, waitSince: null}\n    schedulerQueue: [], // list of process names in order\n    runTimer: null,\n    running: false,\n    config: {\n      mode: 'auto',\n      scheduler: 'roundrobin',\n      policy: 'none',\n      timeoutSteps: 5,\n      allowPreempt: false,\n      globalOrder: null, // resource ordering array if ordering policy\n    },\n    logLines: [],\n    stepCount: 0,\n  };\n\n  // Helpers\n  function log(msg){\n    SIM.logLines.push('Step '+SIM.stepCount+': '+msg);\n    if(SIM.logLines.length>1000) SIM.logLines.shift();\n    document.getElementById('log').value = SIM.logLines.join('\\\\n');\n  }\n\n  function refreshTables(){\n    // Resources table\n    const resT = document.querySelector('#resTable tbody');\n    resT.innerHTML = '';\n    for(const rname of Object.keys(SIM.resources)){\n      const r = SIM.resources[rname];\n      const allocated = Object.entries(r.allocated).map(e=> e[0]+':'+e[1]).join(', ');\n      const tr = document.createElement('tr');\n      tr.innerHTML = '<td>'+rname+'</td><td>'+r.total+'</td><td>'+r.available+'</td><td>'+allocated+'</td>'+\n        '<td><button data-res=\"'+rname+'\" class=\"incUnits\">+1</button> <button data-res=\"'+rname+'\" class=\"decUnits\">-1</button></td>';\n      resT.appendChild(tr);\n    }\n    // Processes table\n    const pT = document.querySelector('#procTable tbody');\n    pT.innerHTML = '';\n    for(const pname of Object.keys(SIM.processes)){\n      const p = SIM.processes[pname];\n      const held = Object.entries(p.held).map(e=> e[0]+':'+e[1]).join(', ') || '';\n      const nextOp = p.ops[p.pc] ? formatOp(p.ops[p.pc]) : '(none)';\n      const tr = document.createElement('tr');\n      tr.innerHTML = '<td>'+pname+'</td><td>'+p.priority+'</td><td>'+p.ts+'</td><td>'+p.state+'</td><td>'+held+'</td><td>'+nextOp+'</td>' +\n        '<td><button data-proc=\"'+pname+'\" class=\"selectProc\">Select</button></td>';\n      pT.appendChild(tr);\n    }\n\n    // Update selects for operations and manual controls\n    updateProcSelects();\n    updateResSelects();\n    updateAbortSelect();\n    updateManualSelects();\n    refreshRAG();\n  }\n\n  function formatOp(op){\n    if(!op) return '';\n    if(op.type==='request') return 'REQ '+op.res+'('+op.units+')';\n    if(op.type==='release') return 'REL '+op.res+'('+op.units+')';\n    if(op.type==='compute') return 'COMPUTE '+op.duration;\n    return JSON.stringify(op);\n  }\n\n  function updateProcSelects(){\n    const opProc = document.getElementById('opProc');\n    const manualProc = document.getElementById('manualProc');\n    opProc.innerHTML = '';\n    manualProc.innerHTML = '';\n    for(const pname of Object.keys(SIM.processes)){\n      const opt = document.createElement('option'); opt.value = pname; opt.text = pname; opProc.appendChild(opt);\n      const opt2 = opt.cloneNode(true); manualProc.appendChild(opt2);\n    }\n    // update procOps textarea\n    const procOps = document.getElementById('procOps');\n    const sel = opProc.value;\n    if(sel && SIM.processes[sel]){\n      procOps.value = SIM.processes[sel].ops.map((o,i)=> i+': '+formatOp(o)).join('\\\\n');\n    } else {\n      // show combined\n      const lines = [];\n      for(const pname of Object.keys(SIM.processes)){\n        lines.push('== '+pname+' ==');\n        lines.push(...SIM.processes[pname].ops.map((o,i)=> i+': '+formatOp(o)));\n      }\n      procOps.value = lines.join('\\\\n');\n    }\n  }\n\n  function updateResSelects(){\n    const opRes = document.getElementById('opRes');\n    const manualRes = document.getElementById('manualRes');\n    opRes.innerHTML = '';\n    manualRes.innerHTML = '';\n    for(const rname of Object.keys(SIM.resources)){\n      const opt = document.createElement('option'); opt.value = rname; opt.text = rname; opRes.appendChild(opt);\n      const opt2 = opt.cloneNode(true); manualRes.appendChild(opt2);\n    }\n  }\n\n  function updateAbortSelect(){\n    const sel = document.getElementById('abortSelect');\n    sel.innerHTML = '';\n    for(const pname of Object.keys(SIM.processes)){\n      const opt = document.createElement('option'); opt.value = pname; opt.text = pname; sel.appendChild(opt);\n    }\n  }\n\n  function updateManualSelects(){\n    document.getElementById('opProc').dispatchEvent(new Event('change'));\n    document.getElementById('manualProc').dispatchEvent(new Event('change'));\n  }\n\n  function addResource(name, units){\n    if(!name) { alert('Resource name required'); return; }\n    if(SIM.resources[name]) { alert('Resource exists'); return; }\n    SIM.resources[name] = { total: units, available: units, allocated: {} };\n    log('Added resource '+name+' units='+units);\n    refreshTables();\n  }\n\n  function changeResourceUnits(rname, delta){\n    const r = SIM.resources[rname];\n    if(!r) return;\n    r.total = Math.max(1, r.total + delta);\n    // adjust available conservatively\n    r.available = Math.max(0, r.total - Object.values(r.allocated).reduce((a,b)=>a+b,0));\n    log('Changed resource '+rname+' total to '+r.total);\n    refreshTables();\n  }\n\n  function addProcess(name, priority, ts){\n    if(!name) { alert('Process name required'); return; }\n    if(SIM.processes[name]) { alert('Process exists'); return; }\n    SIM.processes[name] = { priority: priority, ts: ts, state: 'ready', ops: [], pc: 0, held: {}, waitingFor: null, waitSince: null };\n    SIM.schedulerQueue.push(name);\n    log('Added process '+name+' pr='+priority+' ts='+ts);\n    refreshTables();\n  }\n\n  function clearResources(){\n    SIM.resources = {};\n    log('Cleared resources');\n    refreshTables();\n  }\n  function clearProcesses(){\n    SIM.processes = {};\n    SIM.schedulerQueue = [];\n    log('Cleared processes');\n    refreshTables();\n  }\n\n  function appendOpToProc(pname, op){\n    const p = SIM.processes[pname];\n    if(!p) return;\n    p.ops.push(op);\n    log('Appended op to '+pname+': '+formatOp(op));\n    refreshTables();\n  }\n\n  // Simulation core: try to execute one operation for a given process (atomic attempt)\n  function tryExecute(procName){\n    const p = SIM.processes[procName];\n    if(!p) return false;\n    if(p.state === 'finished' || p.state === 'aborted') return false;\n    const op = p.ops[p.pc];\n    if(!op) { p.state = 'finished'; log(procName+' finished (no more ops)'); return false; }\n\n    if(op.type === 'compute'){\n      // Consume compute step\n      if(!op._remaining) op._remaining = op.duration;\n      op._remaining--;\n      log(procName+' computing, remaining '+op._remaining);\n      if(op._remaining <= 0){\n        p.pc++;\n      }\n      p.state = 'running';\n      p.waitingFor = null;\n      p.waitSince = null;\n      return true;\n    } else if(op.type === 'release'){\n      const r = op.res;\n      const units = op.units || 1;\n      if((p.held[r] || 0) < units){\n        log(procName+' attempted to release '+units+' of '+r+' but holds '+(p.held[r]||0)+' - adjusting to full release');\n      }\n      const toRel = Math.min(units, p.held[r]||0);\n      if(toRel > 0){\n        p.held[r] -= toRel;\n        if(p.held[r] === 0) delete p.held[r];\n        SIM.resources[r].allocated[procName] = (SIM.resources[r].allocated[procName] || 0) - toRel;\n        if(SIM.resources[r].allocated[procName] <= 0) delete SIM.resources[r].allocated[procName];\n        SIM.resources[r].available += toRel;\n        log(procName+' released '+toRel+' of '+r);\n      } else {\n        log(procName+' had nothing to release for '+r);\n      }\n      p.pc++;\n      p.state = 'running';\n      p.waitingFor = null;\n      p.waitSince = null;\n      return true;\n    } else if(op.type === 'request'){\n      const r = op.res;\n      const units = op.units || 1;\n      // Policy checks (ordering/all-or-nothing/wait-die/wound-wait)\n      const policy = SIM.config.policy;\n      if(policy === 'all_or_nothing'){\n        // Check if all future requests can be satisfied at once (simplified: only check remaining requests counts)\n        // Build a claim map: for current pc..end count maximum per resource\n        const claim = {};\n        for(let i=p.pc;i<p.ops.length;i++){\n          const o = p.ops[i];\n          if(o.type === 'request') claim[o.res] = Math.max(claim[o.res]||0, o.units || 1);\n        }\n        // Check availability across all resources (available + held by p)\n        for(const rr in claim){\n          const needed = claim[rr];\n          const available = SIM.resources[rr] ? SIM.resources[rr].available + (p.held[rr]||0) : 0;\n          if(available < needed){\n            // Cannot grant now, must wait\n            log(procName+' (all-or-nothing) cannot obtain full claim; will wait for '+rr);\n            p.state = 'waiting';\n            p.waitingFor = {res: rr, units: claim[rr]};\n            if(!p.waitSince) p.waitSince = SIM.stepCount;\n            return false;\n          }\n        }\n        // All available; grant this request as part of the all-at-once behavior (but we only perform the current request now)\n      }\n      if(policy === 'ordering' && SIM.config.globalOrder){\n        // Enforce that process requests resources in global order (resource names compared by position)\n        const order = SIM.config.globalOrder;\n        // If process holds a resource that has a higher order than r, block or abort depending on config - we will block\n        let maxHeldIndex = -1;\n        for(const hr in p.held){\n          const idx = order.indexOf(hr);\n          if(idx>maxHeldIndex) maxHeldIndex = idx;\n        }\n        const reqIdx = order.indexOf(r);\n        if(reqIdx < 0) {\n          // resource not in ordering, allow\n        } else if(maxHeldIndex > reqIdx){\n          // violates ordering: block and set waiting\n          log(procName+' violates global ordering by requesting '+r+' (will wait/retry)');\n          p.state = 'waiting';\n          p.waitingFor = {res:r, units:units};\n          if(!p.waitSince) p.waitSince = SIM.stepCount;\n          return false;\n        }\n      }\n      // Check availability\n      const resObj = SIM.resources[r];\n      if(!resObj){\n        log(procName+' requested unknown resource '+r+' - will wait');\n        p.state='waiting'; p.waitingFor={res:r, units:units}; if(!p.waitSince) p.waitSince = SIM.stepCount;\n        return false;\n      }\n      if(resObj.available >= units){\n        // grant\n        resObj.available -= units;\n        resObj.allocated[procName] = (resObj.allocated[procName]||0)+units;\n        p.held[r] = (p.held[r]||0) + units;\n        p.pc++;\n        p.state = 'running';\n        p.waitingFor = null;\n        p.waitSince = null;\n        log(procName+' granted '+units+' of '+r);\n        return true;\n      } else {\n        // Not immediately available - handle wait-die / wound-wait / timeout / preemption possibilities\n        if(policy === 'wait_die'){\n          // if ts of requesting older (smaller number) than holder(s) then it waits; otherwise aborts (dies)\n          const holders = Object.keys(resObj.allocated);\n          let shouldWait = true;\n          for(const h of holders){\n            if(SIM.processes[h] && SIM.processes[h].ts < p.ts){\n              // holder older -> requester younger, in wait-die younger -> dies (abort)\n              shouldWait = false;\n            }\n          }\n          if(!shouldWait){\n            // abort requester\n            p.state = 'aborted';\n            log(procName+' wait-die: aborted (dies) because younger than holder');\n            // release held resources\n            releaseAllHeld(pname);\n            return false;\n          } else {\n            // wait\n            p.state = 'waiting';\n            p.waitingFor = {res:r, units:units};\n            if(!p.waitSince) p.waitSince = SIM.stepCount;\n            log(procName+' wait-die: waiting for '+r);\n            return false;\n          }\n        } else if(policy === 'wound_wait'){\n          // if requester older than some holders, wound (preempt) them; otherwise wait\n          const holders = Object.keys(resObj.allocated);\n          let woundedAny = false;\n          for(const h of holders){\n            if(SIM.processes[h] && SIM.processes[h].ts > p.ts){\n              // holder younger - wound it: abort/roll back\n              woundedAny = true;\n              log(procName+' wound-wait: preempting/aborting '+h+' to obtain '+r);\n              abortProcess(h);\n            }\n          }\n          if(woundedAny && resObj.available >= units){\n            // now enough\n            resObj.available -= units;\n            resObj.allocated[procName] = (resObj.allocated[procName]||0)+units;\n            p.held[r] = (p.held[r]||0)+units;\n            p.pc++;\n            p.state='running';\n            p.waitingFor=null;\n            p.waitSince=null;\n            return true;\n          } else {\n            p.state='waiting';\n            p.waitingFor={res:r, units:units};\n            if(!p.waitSince) p.waitSince = SIM.stepCount;\n            log(procName+' wound-wait: waiting for '+r);\n            return false;\n          }\n        } else if(SIM.config.allowPreempt){\n          // Try to preempt some resources from other processes to satisfy\n          let freed = 0;\n          const holders = Object.entries(resObj.allocated);\n          for(const [hname, count] of holders){\n            if(hname === procName) continue;\n            // choose victim if lower priority\n            const victim = SIM.processes[hname];\n            if(!victim) continue;\n            if(victim.priority < SIM.processes[procName].priority){\n              // preempt some from victim\n              const take = Math.min(count, units - freed);\n              SIM.resources[r].allocated[hname] -= take;\n              if(SIM.resources[r].allocated[hname] <= 0) delete SIM.resources[r].allocated[hname];\n              victim.held[r] = (victim.held[r]||0) - take;\n              if(victim.held[r] <= 0) delete victim.held[r];\n              freed += take;\n              log('Preempted '+take+' of '+r+' from '+hname+' to satisfy '+procName);\n              if(freed >= units) break;\n            }\n          }\n          if(freed>0){\n            // increase available by freed amount\n            SIM.resources[r].available += freed;\n          }\n          if(SIM.resources[r].available >= units){\n            SIM.resources[r].available -= units;\n            SIM.resources[r].allocated[procName] = (SIM.resources[r].allocated[procName]||0) + units;\n            p.held[r] = (p.held[r] || 0) + units;\n            p.pc++;\n            p.state='running';\n            p.waitingFor=null; p.waitSince=null;\n            log(procName+' obtained '+units+' of '+r+' after preemption');\n            return true;\n          } else {\n            p.state='waiting'; p.waitingFor={res:r, units:units}; if(!p.waitSince) p.waitSince = SIM.stepCount;\n            log(procName+' waiting for '+r+' (not enough after preemption)');\n            return false;\n          }\n        } else if(policy === 'timeout'){\n          // mark waiting and if waiting long enough abort or force release\n          p.state='waiting'; p.waitingFor={res:r, units:units}; if(!p.waitSince) p.waitSince = SIM.stepCount;\n          if(SIM.stepCount - p.waitSince >= SIM.config.timeoutSteps){\n            // timed out - abort or force\n            log(procName+' timeout: aborting due to waiting too long');\n            abortProcess(procName);\n            return false;\n          }\n          log(procName+' waiting for '+r+' (timeout policy)');\n          return false;\n        } else {\n          // default: wait\n          p.state = 'waiting';\n          p.waitingFor = {res: r, units: units};\n          if(!p.waitSince) p.waitSince = SIM.stepCount;\n          log(procName+' waiting for '+r+' ('+resObj.available+'/'+units+' available)');\n          return false;\n        }\n      }\n    }\n    return false;\n  }\n\n  function scheduleOneStep(){\n    SIM.stepCount++;\n    const order = buildScheduleOrder();\n    if(order.length === 0){\n      log('No processes to schedule');\n      return;\n    }\n    let progressed = false;\n    if(SIM.config.scheduler === 'priority'){\n      order.sort((a,b)=> SIM.processes[b].priority - SIM.processes[a].priority);\n    }\n    for(const pname of order){\n      const p = SIM.processes[pname];\n      if(!p) continue;\n      if(p.state === 'ready' || p.state === 'running' || p.state === 'waiting'){\n        // attempt to execute if not waiting or if waiting try again\n        if(p.state === 'waiting'){\n          // If waiting but waitingFor satisfied, try to grant\n          const wf = p.waitingFor;\n          if(!wf) { p.state='ready'; }\n        }\n        const did = tryExecute(pname);\n        if(did) { progressed = true; if(SIM.config.mode==='step') break; }\n      }\n    }\n    // After attempting, if no progress, increment waiting counters and possibly detect deadlock later\n    if(!progressed) {\n      log('No progress in this scheduling cycle');\n    }\n    refreshTables();\n  }\n\n  function buildScheduleOrder(){\n    if(SIM.config.scheduler === 'fifo') return SIM.schedulerQueue.slice();\n    // default round robin: cycle queue\n    if(SIM.config.scheduler === 'roundrobin'){\n      // rotate queue so next is head\n      return SIM.schedulerQueue.slice();\n    }\n    // priority uses schedule order as listed\n    return SIM.schedulerQueue.slice();\n  }\n\n  function refreshRAG(){\n    // Build textual resource allocation graph: P->R (waiting) and R->P (allocated)\n    const lines = [];\n    for(const pname of Object.keys(SIM.processes)){\n      const p = SIM.processes[pname];\n      if(p.waitingFor){\n        lines.push(pname + ' -> ' + p.waitingFor.res + ' (waiting ' + p.waitingFor.units + ')');\n      }\n      for(const hr in p.held){\n        lines.push(hr + ' -> ' + pname + ' ('+p.held[hr]+')');\n      }\n    }\n    document.getElementById('rag').value = lines.join('\\\\n');\n  }\n\n  function detectDeadlocks(){\n    // Detect cycles in resource-allocation graph: nodes are processes and resources\n    // Build adjacency: process -> resource (if waiting), resource -> process (if allocated)\n    const adj = {};\n    function addEdge(a,b){ adj[a]=adj[a]||[]; adj[a].push(b); }\n    for(const pname in SIM.processes){\n      const p = SIM.processes[pname];\n      if(p.waitingFor){\n        addEdge(pname, p.waitingFor.res);\n      }\n      for(const r in p.held){\n        addEdge(r, pname);\n      }\n    }\n    const visited = {}, stack = {}, cycles = [];\n    function dfs(node, path){\n      if(stack[node]) {\n        // Found cycle\n        const idx = path.indexOf(node);\n        const cycle = path.slice(idx).concat(node);\n        cycles.push(cycle);\n        return;\n      }\n      if(visited[node]) return;\n      visited[node]=true; stack[node]=true;\n      const neigh = adj[node]||[];\n      for(const n of neigh) dfs(n, path.concat(n));\n      stack[node]=false;\n    }\n    for(const n in adj) if(!visited[n]) dfs(n,[n]);\n    if(cycles.length===0){\n      log('Deadlock detection: no cycles found');\n      alert('No deadlock cycles detected.');\n    } else {\n      log('Deadlock detection: cycles found: '+JSON.stringify(cycles));\n      alert('Deadlocks detected (cycles):\\\\n' + cycles.map(c=>c.join(' -> ')).join('\\\\n---\\\\n'));\n    }\n    return cycles;\n  }\n\n  function abortProcess(pname){\n    const p = SIM.processes[pname];\n    if(!p) return;\n    p.state = 'aborted';\n    // release everything\n    releaseAllHeld(pname);\n    p.ops = []; p.pc = 0; p.waitingFor = null;\n    log('Aborted process '+pname);\n    refreshTables();\n  }\n\n  function releaseAllHeld(pname){\n    const p = SIM.processes[pname];\n    if(!p) return;\n    for(const r in p.held){\n      const count = p.held[r];\n      SIM.resources[r].available += count;\n      SIM.resources[r].allocated[pname] = (SIM.resources[r].allocated[pname]||0) - count;\n      if(SIM.resources[r].allocated[pname] <= 0) delete SIM.resources[r].allocated[pname];\n    }\n    p.held = {};\n    refreshTables();\n  }\n\n  function manualAllocate(procName, resName, units){\n    const p = SIM.processes[procName]; const r = SIM.resources[resName];\n    if(!p || !r) { alert('Invalid proc or res'); return; }\n    if(r.available < units){\n      if(!confirm('Not enough units available; force allocation by reducing available (may make negatives)?')) return;\n    }\n    r.available = r.available - units;\n    r.allocated[procName] = (r.allocated[procName]||0) + units;\n    p.held[resName] = (p.held[resName]||0) + units;\n    log('Manually allocated '+units+' of '+resName+' to '+procName);\n    refreshTables();\n  }\n\n  function manualRelease(procName, resName, units){\n    const p = SIM.processes[procName]; const r = SIM.resources[resName];\n    if(!p || !r) { alert('Invalid'); return; }\n    const have = p.held[resName] || 0;\n    const toRel = Math.min(have, units);\n    if(toRel <= 0) { alert('Process holds none'); return; }\n    p.held[resName] -= toRel;\n    if(p.held[resName] <= 0) delete p.held[resName];\n    r.allocated[procName] = (r.allocated[procName]||0) - toRel;\n    if(r.allocated[procName] <= 0) delete r.allocated[procName];\n    r.available += toRel;\n    log('Manually released '+toRel+' of '+resName+' from '+procName);\n    refreshTables();\n  }\n\n  function abortSelected(){\n    const sel = Array.from(document.getElementById('abortSelect').selectedOptions).map(o=>o.value);\n    if(sel.length===0) { alert('Select at least one process to abort'); return; }\n    for(const p of sel) abortProcess(p);\n  }\n\n  function preemptSelected(){\n    const sel = Array.from(document.getElementById('abortSelect').selectedOptions).map(o=>o.value);\n    if(sel.length===0) { alert('Select at least one process to preempt'); return; }\n    // release all held by selected and add to available\n    for(const p of sel){\n      releaseAllHeld(p);\n      SIM.processes[p].state = 'ready';\n    }\n    log('Preempted resources from: '+sel.join(','));\n    refreshTables();\n  }\n\n  function releaseAll(){\n    for(const pname in SIM.processes) releaseAllHeld(pname);\n    log('All held resources released');\n    refreshTables();\n  }\n\n  // Banker's algorithm safe-state check (requires max claims input)\n  function bankersCheck(maxClaimsJSON){\n    // Parse JSON structure: {\"P1\":{\"R1\":2,\"R2\":1}, ...}\n    let maxClaims;\n    try{ maxClaims = JSON.parse(maxClaimsJSON); } catch(e){ alert('Invalid JSON'); return false; }\n    // Build data arrays\n    const procs = Object.keys(SIM.processes);\n    const resNames = Object.keys(SIM.resources);\n    const available = resNames.map(r=> SIM.resources[r].available);\n    const allocation = procs.map(p => resNames.map(r => SIM.processes[p].held[r]||0));\n    const maxC = procs.map(p => resNames.map(r => (maxClaims[p] && maxClaims[p][r]) ? maxClaims[p][r] : 0));\n    const need = allocation.map((alloc,i)=> alloc.map((a,j)=> Math.max(0, maxC[i][j] - a)));\n    // Safety algorithm\n    const work = available.slice();\n    const finish = procs.map(()=>false);\n    const safeOrder = [];\n    for(let iter=0; iter<procs.length; iter++){\n      let found = false;\n      for(let i=0;i<procs.length;i++){\n        if(finish[i]) continue;\n        let ok = true;\n        for(let j=0;j<resNames.length;j++){\n          if(need[i][j] > work[j]) { ok=false; break; }\n        }\n        if(ok){\n          for(let j=0;j<resNames.length;j++) work[j] += allocation[i][j];\n          finish[i] = true;\n          safeOrder.push(procs[i]);\n          found = true;\n        }\n      }\n      if(!found) break;\n    }\n    if(finish.every(x=>x)){\n      alert('System is in a SAFE state. Example safe order: '+safeOrder.join(' -> '));\n      log('Banker: SAFE. Order: '+safeOrder.join(' -> '));\n      return true;\n    } else {\n      alert('System is NOT safe!');\n      log('Banker: NOT SAFE');\n      return false;\n    }\n  }\n\n  // Scenario generators\n  function genDining(n){\n    if(n<2) return;\n    // Clear and create n resources and n processes\n    SIM.resources = {}; SIM.processes = {}; SIM.schedulerQueue=[];\n    for(let i=0;i<n;i++){\n      addResource('R'+(i+1), 1);\n    }\n    for(let i=0;i<n;i++){\n      const pname = 'P'+(i+1);\n      addProcess(pname, 1, i+1);\n      // Each philosopher requests left then right (classic deadlock if all take left)\n      const left = 'R'+((i+1));\n      const right = 'R'+(((i+1)%n)+1);\n      SIM.processes[pname].ops = [\n        {type:'request', res:left, units:1},\n        {type:'compute', duration:1},\n        {type:'request', res:right, units:1},\n        {type:'compute', duration:1},\n        {type:'release', res:left, units:1},\n        {type:'release', res:right, units:1}\n      ];\n    }\n    log('Generated dining philosophers n='+n);\n    refreshTables();\n  }\n\n  function genClassic2x2(){\n    SIM.resources = {}; SIM.processes = {}; SIM.schedulerQueue=[];\n    addResource('R1',1); addResource('R2',1);\n    addProcess('P1',1,1); addProcess('P2',1,2);\n    SIM.processes['P1'].ops = [{type:'request',res:'R1',units:1},{type:'compute',duration:1},{type:'request',res:'R2',units:1}];\n    SIM.processes['P2'].ops = [{type:'request',res:'R2',units:1},{type:'compute',duration:1},{type:'request',res:'R1',units:1}];\n    log('Generated classic 2x2 deadlock');\n    refreshTables();\n  }\n\n  function genRandom(pcount, rcount, maxUnits){\n    SIM.resources = {}; SIM.processes = {}; SIM.schedulerQueue=[];\n    for(let i=0;i<rcount;i++){\n      addResource('R'+(i+1), 1 + Math.floor(Math.random()*maxUnits));\n    }\n    for(let i=0;i<pcount;i++){\n      const pname = 'P'+(i+1);\n      addProcess(pname, Math.floor(Math.random()*3), i+1);\n      const ops = [];\n      const opsCount = 2 + Math.floor(Math.random()*5);\n      for(let j=0;j<opsCount;j++){\n        const t = Math.random();\n        if(t<0.5){\n          // request\n          const r = 'R'+(1+Math.floor(Math.random()*rcount));\n          const u = 1 + Math.floor(Math.random()*maxUnits);\n          ops.push({type:'request', res:r, units:u});\n          // sometimes release later\n          ops.push({type:'release', res:r, units:u});\n        } else {\n          ops.push({type:'compute', duration:1 + Math.floor(Math.random()*3)});\n        }\n      }\n      SIM.processes[pname].ops = ops;\n    }\n    log('Generated random scenario P='+pcount+' R='+rcount);\n    refreshTables();\n  }\n\n  // UI wiring\n  document.getElementById('addResBtn').addEventListener('click', ()=>{\n    const name = document.getElementById('newResName').value.trim();\n    const units = parseInt(document.getElementById('newResUnits').value,10) || 1;\n    addResource(name, units);\n  });\n  document.getElementById('clearResBtn').addEventListener('click', ()=>{ if(confirm('Clear resources?')) { clearResources(); }});\n  document.getElementById('addProcBtn').addEventListener('click', ()=>{\n    const name = document.getElementById('newProcName').value.trim();\n    const pr = parseInt(document.getElementById('newProcPriority').value,10) || 0;\n    const ts = parseInt(document.getElementById('newProcTimestamp').value,10) || (Object.keys(SIM.processes).length+1);\n    addProcess(name, pr, ts);\n  });\n  document.getElementById('clearProcBtn').addEventListener('click', ()=> { if(confirm('Clear processes?')) clearProcesses(); });\n\n  document.getElementById('opProc').addEventListener('change', updateProcSelects);\n  document.getElementById('addOpBtn').addEventListener('click', ()=>{\n    const pname = document.getElementById('opProc').value;\n    const type = document.getElementById('opType').value;\n    const res = document.getElementById('opRes').value;\n    const units = parseInt(document.getElementById('opUnits').value,10) || 1;\n    const duration = parseInt(document.getElementById('opDuration').value,10) || 1;\n    const op = {type: type};\n    if(type === 'request' || type === 'release'){ op.res = res; op.units = units; }\n    if(type === 'compute'){ op.duration = duration; }\n    appendOpToProc(pname, op);\n  });\n  document.getElementById('clearOpsBtn').addEventListener('click', ()=>{\n    const pname = document.getElementById('opProc').value;\n    if(!pname) return;\n    SIM.processes[pname].ops = [];\n    SIM.processes[pname].pc = 0;\n    log('Cleared ops for '+pname);\n    refreshTables();\n  });\n\n  // Generators\n  document.getElementById('genDiningBtn').addEventListener('click', ()=>{\n    const n = parseInt(document.getElementById('genDiningN').value,10) || 5;\n    if(confirm('Generate dining philosophers will wipe current definitions. Continue?')) genDining(n);\n  });\n  document.getElementById('genClassicBtn').addEventListener('click', ()=> {\n    if(confirm('Generate classic will wipe current definitions. Continue?')) genClassic2x2();\n  });\n  document.getElementById('genRandomBtn').addEventListener('click', ()=>{\n    const p = parseInt(document.getElementById('randP').value,10)||4;\n    const r = parseInt(document.getElementById('randR').value,10)||3;\n    const mu = parseInt(document.getElementById('randMaxUnits').value,10)||2;\n    if(confirm('Generate random scenario will wipe current definitions. Continue?')) genRandom(p,r,mu);\n  });\n\n  // Simulation controls\n  document.getElementById('simMode').addEventListener('change', (e)=>{ SIM.config.mode = e.target.value; });\n  document.getElementById('scheduler').addEventListener('change', (e)=>{ SIM.config.scheduler = e.target.value; });\n  document.getElementById('resourcePolicy').addEventListener('change', (e)=>{\n    SIM.config.policy = e.target.value;\n    if(e.target.value === 'ordering'){\n      // set a default ordering\n      SIM.config.globalOrder = Object.keys(SIM.resources).slice();\n      alert('Global ordering will be resource list order. You can reorder resources by removing/adding.');\n    } else SIM.config.globalOrder = null;\n  });\n  document.getElementById('timeoutSteps').addEventListener('change', (e)=> SIM.config.timeoutSteps = parseInt(e.target.value,10) || 5);\n  document.getElementById('allowPreempt').addEventListener('change', (e)=> SIM.config.allowPreempt = e.target.checked);\n\n  document.getElementById('stepBtn').addEventListener('click', ()=>{\n    scheduleOneStep();\n  });\n  document.getElementById('runSpeed').addEventListener('input', (e)=>{ document.getElementById('speedVal').innerText = e.target.value; });\n  document.getElementById('runBtn').addEventListener('click', ()=>{\n    if(SIM.running) return;\n    SIM.running = true;\n    const speed = parseInt(document.getElementById('runSpeed').value,10) || 800;\n    SIM.runTimer = setInterval(()=> {\n      scheduleOneStep();\n    }, speed);\n    log('Auto-run started');\n  });\n  document.getElementById('pauseBtn').addEventListener('click', ()=>{\n    if(SIM.runTimer) clearInterval(SIM.runTimer);\n    SIM.running = false;\n    SIM.runTimer = null;\n    log('Auto-run paused');\n  });\n\n  // Detection & recovery\n  document.getElementById('detectBtn').addEventListener('click', ()=> detectDeadlocks());\n  document.getElementById('safeCheckBtn').addEventListener('click', ()=> {\n    bankersCheck(document.getElementById('maxClaims').value || '{}');\n  });\n  document.getElementById('abortSelectedBtn').addEventListener('click', ()=> abortSelected());\n  document.getElementById('preemptSelectedBtn').addEventListener('click', ()=> preemptSelected());\n  document.getElementById('releaseAllBtn').addEventListener('click', ()=> { if(confirm('Force release all held resources?')) releaseAll(); });\n\n  // Manual control\n  document.getElementById('manualAllocateBtn').addEventListener('click', ()=>{\n    const p = document.getElementById('manualProc').value;\n    const r = document.getElementById('manualRes').value;\n    const u = parseInt(document.getElementById('manualUnits').value,10)||1;\n    manualAllocate(p,r,u);\n  });\n  document.getElementById('manualRequestBtn').addEventListener('click', ()=>{\n    const p = document.getElementById('manualProc').value;\n    const r = document.getElementById('manualRes').value;\n    const u = parseInt(document.getElementById('manualUnits').value,10)||1;\n    // Append a request op immediately at current pc so it will be attempted\n    if(!SIM.processes[p]) return;\n    SIM.processes[p].ops.splice(SIM.processes[p].pc,0,{type:'request', res:r, units:u});\n    log('Inserted immediate request for '+p+' -> '+r+'('+u+')');\n    refreshTables();\n  });\n  document.getElementById('manualReleaseBtn').addEventListener('click', ()=>{\n    const p = document.getElementById('manualProc').value;\n    const r = document.getElementById('manualRes').value;\n    const u = parseInt(document.getElementById('manualUnits').value,10)||1;\n    manualRelease(p,r,u);\n  });\n\n  document.getElementById('killAllBtn').addEventListener('click', ()=>{\n    if(!confirm('Reset simulator state (clear allocations, reset PC) but keep definitions?')) return;\n    // Release all held, reset PCs and states\n    for(const pname in SIM.processes){\n      const p = SIM.processes[pname];\n      for(const r in p.held){\n        const cnt = p.held[r];\n        SIM.resources[r].available += cnt;\n        SIM.resources[r].allocated[pname] = (SIM.resources[r].allocated[pname]||0) - cnt;\n        if(SIM.resources[r].allocated[pname] <= 0) delete SIM.resources[r].allocated[pname];\n      }\n      p.held = {}; p.pc = 0; p.state = 'ready'; p.waitingFor = null; p.waitSince = null;\n    }\n    log('Simulator state reset (allocations cleared)');\n    refreshTables();\n  });\n\n  document.getElementById('fullResetBtn').addEventListener('click', ()=>{\n    if(!confirm('Full reset clears everything. Continue?')) return;\n    SIM.resources = {}; SIM.processes = {}; SIM.schedulerQueue = []; SIM.logLines=[]; SIM.stepCount=0;\n    document.getElementById('log').value = '';\n    refreshTables();\n  });\n\n  // Resource unit increment/decrement buttons (delegate)\n  document.querySelector('#resTable').addEventListener('click', (e)=>{\n    if(e.target.classList.contains('incUnits')){\n      const r = e.target.getAttribute('data-res'); changeResourceUnits(r, 1);\n    } else if(e.target.classList.contains('decUnits')){\n      const r = e.target.getAttribute('data-res'); changeResourceUnits(r, -1);\n    } else if(e.target.classList.contains('selectProc')){\n      const p = e.target.getAttribute('data-proc');\n      // select in opProc and manualProc\n      document.getElementById('opProc').value = p;\n      document.getElementById('manualProc').value = p;\n      updateProcSelects();\n    }\n  });\n\n  // Abort select double click to toggle selection\n  document.getElementById('abortSelect').addEventListener('dblclick', ()=> { /* no-op */ });\n\n  // RAG and log initialization\n  refreshTables();\n\n  // Expose some functions for easy console experiments\n  window.SIM = SIM;\n\n  // preload some scenario for convenience\n  genClassic2x2();\n\n})();\n  </script>\n</body>\n</html>"
