    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Logistic Regression — Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&family=Roboto+Slab:wght@500&display=swap');\n\n  /* Root and base styles */\n  :root {\n    --color-bg: #0f1a24;\n    --color-primary: #4eb8ff;\n    --color-secondary: #ff6e6c;\n    --color-accent: #fbcf7a;\n    --color-light: #d9e6f2;\n    --color-dark: #101b28;\n    --shadow-glow: rgba(78, 184, 255, 0.7);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: var(--color-bg);\n    color: var(--color-light);\n    font-family: 'Montserrat', sans-serif;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    height: 100vh;\n    user-select: none;\n  }\n\n  header {\n    padding: 2rem 3rem 1rem 3rem;\n    text-align: center;\n  }\n\n  header h1 {\n    font-family: 'Roboto Slab', serif;\n    font-weight: 500;\n    font-size: 3.75rem;\n    letter-spacing: 0.06em;\n    margin: 0 0 0.25rem 0;\n    color: var(--color-accent);\n    text-shadow:\n      0 0 10px var(--color-accent),\n      0 0 20px var(--color-accent),\n      0 0 30px var(--color-accent);\n    user-select: none;\n  }\n\n  header p {\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: var(--color-light);\n    user-select: none;\n    opacity: 0.8;\n    margin-top: 0;\n    letter-spacing: 0.03em;\n  }\n\n  main {\n    flex-grow: 1;\n    display: flex;\n    padding: 1rem 3rem 3rem 3rem;\n    gap: 4rem;\n    justify-content: center;\n    align-items: center;\n    position: relative;\n  }\n\n  /* The plot container */\n  .plot-container {\n    background: linear-gradient(135deg, #10293b, #0c1a27);\n    border-radius: 2rem;\n    box-shadow:\n      inset 0 0 25px rgba(255 255 255 / 0.075),\n      0 20px 40px rgba(0,0,0,0.6);\n    width: 600px;\n    height: 600px;\n    position: relative;\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Axes */\n  svg.axes path,\n  svg.axes line {\n    stroke: var(--color-light);\n    stroke-width: 1.2;\n    opacity: 0.5;\n  }\n\n  svg.axes text {\n    fill: var(--color-light);\n    font-size: 14px;\n    font-weight: 600;\n    user-select: none;\n  }\n\n  /* Curve styles */\n  .curve-gradient-path {\n    stroke-width: 5;\n    fill: none;\n    filter: drop-shadow(0 0 8px var(--color-primary));\n  }\n\n  /* Data points */\n  .data-point {\n    cursor: default;\n    transition: transform 0.3s ease, filter 0.3s ease;\n    filter: drop-shadow(0 0 3px rgba(0, 0, 0, 0.5));\n  }\n\n  .data-point.positive {\n    fill: var(--color-primary);\n    stroke: #a6d9ff;\n    stroke-width: 1.25;\n  }\n\n  .data-point.negative {\n    fill: var(--color-secondary);\n    stroke: #ffa2a0;\n    stroke-width: 1.25;\n  }\n\n  /* Logistic sigmoid line highlight */\n  .logistic-line {\n    filter: drop-shadow(0 0 12px var(--color-accent));\n  }\n\n  /* Controls */\n  .controls {\n    position: absolute;\n    bottom: 40px;\n    left: 50%;\n    transform: translateX(-50%);\n    display: flex;\n    gap: 1rem;\n  }\n\n  button {\n    background: var(--color-dark);\n    color: var(--color-light);\n    border: 2.5px solid var(--color-light);\n    border-radius: 1.2rem;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 0.9rem;\n    padding: 0.6rem 1.5rem;\n    cursor: pointer;\n    transition:\n      background-color 0.4s ease,\n      border-color 0.4s ease,\n      color 0.4s ease,\n      box-shadow 0.4s ease;\n    user-select: none;\n  }\n\n  button:hover {\n    background: var(--color-primary);\n    border-color: var(--color-primary);\n    color: var(--color-dark);\n    box-shadow:\n      0 0 15px var(--color-primary),\n      0 0 8px var(--color-primary);\n  }\n\n  /* Tooltip label on hover */\n  .tooltip {\n    position: absolute;\n    padding: 0.3rem 0.6rem;\n    background: var(--color-dark);\n    border-radius: 0.6rem;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 400;\n    font-size: 11px;\n    color: var(--color-accent);\n    pointer-events: none;\n    user-select: none;\n    opacity: 0;\n    transform: translate(-50%, -140%);\n    transition: opacity 0.3s ease;\n    white-space: nowrap;\n    box-shadow:\n      0 0 8px rgba(251, 207, 122, 0.7);\n  }\n\n  /* Sidebar text block */\n  .info-panel {\n    max-width: 350px;\n    font-weight: 300;\n    font-size: 1.1rem;\n    color: var(--color-light);\n    line-height: 1.6;\n    user-select: none;\n    border-radius: 1.6rem;\n    background: linear-gradient(145deg, #121e2f, #0f1822);\n    box-shadow:\n      inset 0 0 15px rgba(255 255 255 / 0.05),\n      0 10px 22px rgba(0,0,0,0.8);\n    padding: 2rem 2.5rem;\n    backdrop-filter: brightness(0.8);\n  }\n\n  .info-panel h2 {\n    font-family: 'Roboto Slab', serif;\n    font-weight: 600;\n    font-size: 2rem;\n    margin-top: 0;\n    margin-bottom: 1rem;\n    color: var(--color-accent);\n  }\n\n  .info-panel p {\n    margin-top: 0.5rem;\n  }\n\n  /* Animations for fade and appear */\n  .fade-in {\n    animation: fadeInUp 1s ease forwards;\n    opacity: 0;\n  }\n\n  @keyframes fadeInUp {\n    0% {\n      opacity: 0;\n      transform: translateY(20px);\n    }\n    100% {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n</style>\n</head>\n<body>\n\n<header>\n  <h1>Logistic Regression</h1>\n  <p>Modeling binary classification through elegant sigmoid curves</p>\n</header>\n\n<main>\n  <section class=\"plot-container\" aria-label=\"Logistic regression plot visualisation\">\n    <svg id=\"plot\" width=\"600\" height=\"600\" viewBox=\"0 0 600 600\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-labelledby=\"title desc\" >\n      <title>Logistic Regression Logistic Curve and Data</title>\n      <desc>Data points scattered and logistic sigmoid curve overlay</desc>\n\n      <!-- Axes group -->\n      <g class=\"axes\">\n        <!-- Horizontal axis -->\n        <line x1=\"50\" y1=\"550\" x2=\"550\" y2=\"550\" />\n        <line x1=\"550\" y1=\"550\" x2=\"540\" y2=\"540\" />\n        <line x1=\"550\" y1=\"550\" x2=\"540\" y2=\"560\" />\n        <!-- Vertical axis -->\n        <line x1=\"50\" y1=\"550\" x2=\"50\" y2=\"50\" />\n        <line x1=\"50\" y1=\"50\" x2=\"40\" y2=\"60\" />\n        <line x1=\"50\" y1=\"50\" x2=\"60\" y2=\"60\" />\n\n        <!-- Axis labels -->\n        <text x=\"555\" y=\"565\" text-anchor=\"middle\" aria-hidden=\"true\">x</text>\n        <text x=\"40\" y=\"45\" text-anchor=\"middle\" aria-hidden=\"true\">Probability</text>\n\n        <!-- Vertical axis ticks and labels -->\n        <line x1=\"45\" y1=\"550\" x2=\"55\" y2=\"550\" />\n        <text x=\"35\" y=\"555\" text-anchor=\"end\" aria-hidden=\"true\">0</text>\n\n        <line x1=\"45\" y1=\"450\" x2=\"55\" y2=\"450\" />\n        <text x=\"35\" y=\"455\" text-anchor=\"end\" aria-hidden=\"true\">0.2</text>\n\n        <line x1=\"45\" y1=\"350\" x2=\"55\" y2=\"350\" />\n        <text x=\"35\" y=\"355\" text-anchor=\"end\" aria-hidden=\"true\">0.4</text>\n\n        <line x1=\"45\" y1=\"250\" x2=\"55\" y2=\"250\" />\n        <text x=\"35\" y=\"255\" text-anchor=\"end\" aria-hidden=\"true\">0.6</text>\n\n        <line x1=\"45\" y1=\"150\" x2=\"55\" y2=\"150\" />\n        <text x=\"35\" y=\"155\" text-anchor=\"end\" aria-hidden=\"true\">0.8</text>\n\n        <line x1=\"45\" y1=\"50\" x2=\"55\" y2=\"50\" />\n        <text x=\"35\" y=\"55\" text-anchor=\"end\" aria-hidden=\"true\">1</text>\n\n        <!-- Horizontal axis ticks and labels -->\n        <line x1=\"50\" y1=\"545\" x2=\"50\" y2=\"555\" />\n        <text x=\"50\" y=\"575\" text-anchor=\"middle\" aria-hidden=\"true\">-6</text>\n\n        <line x1=\"150\" y1=\"545\" x2=\"150\" y2=\"555\" />\n        <text x=\"150\" y=\"575\" text-anchor=\"middle\" aria-hidden=\"true\">-3</text>\n\n        <line x1=\"250\" y1=\"545\" x2=\"250\" y2=\"555\" />\n        <text x=\"250\" y=\"575\" text-anchor=\"middle\" aria-hidden=\"true\">0</text>\n\n        <line x1=\"350\" y1=\"545\" x2=\"350\" y2=\"555\" />\n        <text x=\"350\" y=\"575\" text-anchor=\"middle\" aria-hidden=\"true\">3</text>\n\n        <line x1=\"450\" y1=\"545\" x2=\"450\" y2=\"555\" />\n        <text x=\"450\" y=\"575\" text-anchor=\"middle\" aria-hidden=\"true\">6</text>\n\n        <line x1=\"550\" y1=\"545\" x2=\"550\" y2=\"555\" />\n        <text x=\"550\" y=\"575\" text-anchor=\"middle\" aria-hidden=\"true\">9</text>\n      </g>\n\n      <!-- Logistic sigmoid curve -->\n      <path id=\"logisticCurve\" class=\"curve-gradient-path logistic-line\" d=\"\" />\n\n      <!-- Data points group -->\n      <g id=\"dataPoints\"></g>\n\n    </svg>\n\n    <div class=\"controls\" aria-label=\"Plot controls\">\n      <button id=\"togglePointsBtn\" aria-pressed=\"true\" aria-label=\"Toggle data points visibility\">Hide Points</button>\n      <button id=\"resetCurveBtn\" aria-label=\"Reset sigmoid curve parameters\">Reset Curve</button>\n    </div>\n  </section>\n\n  <aside class=\"info-panel fade-in\" aria-label=\"Logistic Regression Explanation\">\n    <h2>Understanding Logistic Regression</h2>\n    <p>\n      Logistic Regression is a fundamental statistical model used for binary classification tasks. It predicts the probability that a given input belongs to a particular class using the logistic (sigmoid) function.\n    </p>\n    <p>\n      The <strong>sigmoid curve</strong> smoothly maps any real-valued number into the range (0,1), which can be interpreted as a probability:\n    </p>\n    <p style=\"font-family: 'Roboto Slab', serif; font-size:1.3rem; color: var(--color-accent); font-weight: 600; margin: 0 0 1.2rem 0;\">\n      σ(x) = 1 / (1 + e<sup>-(β<sub>0</sub> + β<sub>1</sub>x)</sup>)\n    </p>\n    <p>\n      Data points are plotted on this visualisation with two classes represented by distinct colors.\n      The logistic curve models a smooth decision boundary separating these classes by probabilities.\n    </p>\n    <p style=\"opacity: 0.7; font-size: 0.9rem; margin-top: 2rem;\">\n      <em>Observe how the sigmoid curve seamlessly transitions from near 0 probability on the left to near 1 on the right.</em>\n    </p>\n  </aside>\n</main>\n\n<script>\n  (function() {\n    \"use strict\";\n\n    const svg = document.getElementById(\"plot\");\n    const logisticCurve = document.getElementById(\"logisticCurve\");\n    const dataPointsGroup = document.getElementById(\"dataPoints\");\n    const togglePointsBtn = document.getElementById(\"togglePointsBtn\");\n    const resetCurveBtn = document.getElementById(\"resetCurveBtn\");\n\n    // Coordinate system:\n    // x in [-6,9], mapped to [50,550] pixels\n    // y in [0,1], mapped inverted to [550,50] pixels (y=0 bottom, y=1 top)\n\n    function mapX(x) {\n      return 50 + ((x + 6) / 15) * 500;\n    }\n\n    function mapY(y) {\n      return 550 - y * 500;\n    }\n\n    // Logistic function parameters (initial)\n    let beta0 = -1.5;\n    let beta1 = 0.55;\n\n    // Sigmoid function\n    function sigmoid(x) {\n      const z = beta0 + beta1 * x;\n      return 1 / (1 + Math.exp(-z));\n    }\n\n    // Draw smooth logistic curve path on svg\n    function drawLogisticCurve() {\n      // sample points along x domain\n      const points = [];\n      for(let x = -6; x <= 9; x += 0.1) {\n        const px = mapX(x);\n        const py = mapY(sigmoid(x));\n        points.push([px, py]);\n      }\n      // create smooth cubic Bezier path through points (Catmull-Rom spline)\n      const d = catmullRom2bezier(points);\n      logisticCurve.setAttribute('d', d);\n    }\n\n    // Catmull-Rom to Bezier path generator for smooth curve\n    // Adapted from https://stackoverflow.com/a/7058606\n    function catmullRom2bezier(points) {\n      let d = `M${points[0][0].toFixed(3)} ${points[0][1].toFixed(3)}`;\n      for(let i = 0; i < points.length-1; i++) {\n        const p0 = i === 0 ? points[0] : points[i-1];\n        const p1 = points[i];\n        const p2 = points[i+1];\n        const p3 = i+2 < points.length ? points[i+2] : p2;\n\n        const bp1x = p1[0] + (p2[0] - p0[0]) / 6;\n        const bp1y = p1[1] + (p2[1] - p0[1]) / 6;\n\n        const bp2x = p2[0] - (p3[0] - p1[0]) / 6;\n        const bp2y = p2[1] - (p3[1] - p1[1]) / 6;\n\n        d += ` C${bp1x.toFixed(3)} ${bp1y.toFixed(3)} ${bp2x.toFixed(3)} ${bp2y.toFixed(3)} ${p2[0].toFixed(3)} ${p2[1].toFixed(3)}`;\n      }\n      return d;\n    }\n\n    // Generate synthetic data points for two classes based on sigmoid + noise\n    // Class 1: mostly where sigmoid(x) > 0.5\n    // Class 0: mostly where sigmoid(x) < 0.5\n\n    let dataPoints = [];\n\n    function generateDataPoints(numPoints=80) {\n      dataPoints = [];\n      for(let i = 0; i < numPoints; i++) {\n        // Random x in range [-6,9]\n        const x = (Math.random() * 15) - 6;\n\n        // Calculate probability for class 1\n        const p = sigmoid(x);\n\n        // Assign class based on probability + noise\n        // Randomness simulates real world uncertainty\n        const noise = 0.15 * (Math.random() - 0.5);\n        const probNoisy = Math.min(Math.max(p + noise, 0), 1);\n\n        const cls = probNoisy > 0.5 ? 1 : 0;\n\n        // Map to pixels\n        let y;\n        if(cls === 1) {\n          // Class 1 points scattered near top (high prob)\n          y = probNoisy * 0.8 + 0.15 * Math.random();\n          y = Math.min(1, Math.max(0.5, y)); // keep y in 0.5-1.0 range\n        }\n        else {\n          // Class 0 points scattered near bottom (low prob)\n          y = probNoisy * 0.65 - 0.1 * Math.random();\n          y = Math.min(0.5, Math.max(0, y)); // keep y in 0.0-0.5 range\n        }\n\n        dataPoints.push({\n          x,\n          y,\n          cls\n        });\n      }\n    }\n\n    // Draw data points\n    let pointsVisible = true;\n\n    function drawDataPoints() {\n      dataPointsGroup.innerHTML = '';\n      dataPoints.forEach((pt, idx) => {\n        const cx = mapX(pt.x);\n        const cy = mapY(pt.y);\n        const circle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n        circle.classList.add(\"data-point\");\n        circle.classList.add(pt.cls === 1 ? \"positive\" : \"negative\");\n        circle.setAttribute(\"cx\", cx);\n        circle.setAttribute(\"cy\", cy);\n        circle.setAttribute(\"r\", 8);\n        circle.setAttribute(\"aria-label\", `Data point class ${pt.cls === 1 ? 'One' : 'Zero'}`);\n        circle.style.opacity = pointsVisible ? 1 : 0;\n        dataPointsGroup.appendChild(circle);\n      });\n    }\n\n    // Animate logistic curve pulse on reset\n    function animateCurvePulse() {\n      logisticCurve.style.transition = 'none';\n      logisticCurve.style.filter = 'drop-shadow(0 0 20px var(--color-accent)) drop-shadow(0 0 30px var(--color-accent))';\n      logisticCurve.style.strokeWidth = '8';\n      setTimeout(() => {\n        logisticCurve.style.transition = 'filter 0.6s ease, stroke-width 0.6s ease';\n        logisticCurve.style.filter = 'drop-shadow(0 0 12px var(--color-accent))';\n        logisticCurve.style.strokeWidth = '5';\n      }, 150);\n    }\n\n    // Initialize\n    function init() {\n      generateDataPoints();\n      drawDataPoints();\n      drawLogisticCurve();\n    }\n\n    // Button handlers\n    togglePointsBtn.addEventListener('click', () => {\n      pointsVisible = !pointsVisible;\n      drawDataPoints();\n      togglePointsBtn.textContent = pointsVisible ? \"Hide Points\" : \"Show Points\";\n      togglePointsBtn.setAttribute(\"aria-pressed\", pointsVisible.toString());\n    });\n\n    resetCurveBtn.addEventListener('click', () => {\n      // Reset logistic params to initial values and animate curve\n      beta0 = -1.5;\n      beta1 = 0.55;\n      // Regenerate points to resemble new param distribution\n      generateDataPoints();\n      drawDataPoints();\n      drawLogisticCurve();\n      animateCurvePulse();\n    });\n\n    // Initial load with small fade in for points and curve colors\n    window.addEventListener('load', () => {\n      // Soft fade for points\n      dataPointsGroup.querySelectorAll('circle').forEach(circle => {\n        circle.style.opacity = 0;\n        setTimeout(() => circle.style.transition = 'opacity 1s ease', 0);\n        setTimeout(() => circle.style.opacity = 1, 200);\n      });\n      animateCurvePulse();\n    });\n\n    // Draw components on script load\n    init();\n\n  })();\n</script>\n\n</body>\n</html>"
  },
