    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Dynamic Typing — A Visual Concept</title>\n<style>\n  /* Import a refined serif font for elegance */\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display&family=Source+Code+Pro&display=swap');\n\n  /* CSS Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  \n  html, body {\n    margin: 0; padding: 0; height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Playfair Display', serif;\n    color: #f0f3f7;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    overflow-x: hidden;\n  }\n\n  body {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    padding: 3rem 1.5rem;\n    min-height: 100vh;\n  }\n\n  /* Container card with subtle glass effect */\n  .card {\n    background: rgba(255 255 255 / 0.05);\n    border-radius: 24px;\n    max-width: 720px;\n    width: 90vw;\n    padding: 3.5rem 3rem 3.5rem 3rem;\n    box-shadow:\n      0 0 30px 2px rgba(255 255 255 / 0.1),\n      inset 0 0 60px rgba(255 255 255 / 0.05);\n    backdrop-filter: blur(18px);\n    border: 1.5px solid rgba(255 255 255 / 0.15);\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 700;\n    font-size: 3.8rem;\n    letter-spacing: 0.15em;\n    margin-bottom: 1.2rem;\n    color: #87f1ff;\n    text-shadow:\n      0 0 10px #4dd0ffcc,\n      0 0 25px #09f,\n      0 0 40px #0ff,\n      0 0 60px #0ffee7;\n    text-align: center;\n  }\n\n  /* Subtitle with subtle glow */\n  .subtitle {\n    font-family: 'Source Code Pro', monospace;\n    font-weight: 500;\n    font-size: 1.1rem;\n    color: #a2d9ffcc;\n    text-align: center;\n    margin-bottom: 3rem;\n    letter-spacing: 0.1em;\n  }\n\n  /* Typing area container */\n  .typing-area {\n    position: relative;\n    background: rgba(0 0 0 / 0.18);\n    border-radius: 1rem;\n    padding: 2rem 2.5rem;\n    min-height: 140px;\n    box-shadow: \n      0 4px 30px rgba(0, 255, 255, 0.12),\n      inset 0 0 25px rgba(0, 255, 255, 0.18);\n    font-family: 'Source Code Pro', monospace;\n    color: #a1fffb;\n    font-size: 1.3rem;\n    line-height: 1.6;\n    letter-spacing: 0.06em;\n    overflow-wrap: break-word;\n    cursor: default;\n    user-select: text;\n    position: relative;\n    max-height: 250px;\n    overflow-y: auto;\n  }\n\n  /* Glowing caret effect */\n  .caret {\n    display: inline-block;\n    width: 3px;\n    height: 1.3em;\n    background: #00f9ff;\n    border-radius: 2px;\n    margin-left: 6px;\n    animation: blink 1.3s infinite;\n    vertical-align: bottom;\n    filter: drop-shadow(0 0 2px #00e3ff);\n  }\n\n  @keyframes blink {\n    0%, 20%, 50%, 80%, 100% {\n      opacity: 1;\n    }\n    40%, 60% {\n      opacity: 0;\n    }\n  }\n\n  /* Buttons container */\n  .controls {\n    margin-top: 3rem;\n    text-align: center;\n  }\n\n  button {\n    all: unset;\n    cursor: pointer;\n    font-family: 'Source Code Pro', monospace;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.54em 2.3em;\n    border-radius: 40px;\n    border: 2px solid #00eaff;\n    color: #00eaff;\n    background: transparent;\n    transition:\n      color 0.3s ease,\n      background 0.3s ease,\n      box-shadow 0.3s ease;\n    box-shadow: 0 0 8px #00eaff70;\n    user-select: none;\n  }\n\n  button:hover,\n  button:focus {\n    background: #00eaff22;\n    color: #b1ffff;\n    box-shadow:\n      0 0 14px 3px #00eaffaa,\n      0 0 30px 6px #00eaff44;\n    outline: none;\n  }\n\n  button:active {\n    background: #00eaff44;\n    box-shadow:\n      0 0 7px 3px #00c2eaee,\n      0 0 15px 3px #00c2ea99 inset;\n  }\n\n  /* Scrollbar for typing area */\n  .typing-area::-webkit-scrollbar {\n    width: 8px;\n  }\n\n  .typing-area::-webkit-scrollbar-track {\n    background: rgba(255 255 255 / 0.05);\n    border-radius: 10px;\n  }\n\n  .typing-area::-webkit-scrollbar-thumb {\n    background: #00eaff88;\n    border-radius: 10px;\n    box-shadow: 0 0 12px #00eaffcc inset;\n  }\n\n  /* Info footer with subtle style */\n  footer {\n    margin-top: 4rem;\n    font-family: 'Source Code Pro', monospace;\n    font-weight: 400;\n    font-size: 0.85rem;\n    color: #39e6ff88;\n    user-select: none;\n    letter-spacing: 0.1em;\n  }\n\n  /* Animated background shapes (subtle and elegant) */\n  .background-shapes {\n    pointer-events: none;\n    position: fixed;\n    inset: 0;\n    z-index: 0;\n    overflow: visible;\n  }\n  \n  .shape {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(70px);\n    opacity: 0.14;\n    animation-timing-function: ease-in-out;\n    animation-iteration-count: infinite;\n    animation-direction: alternate;\n    mix-blend-mode: screen;\n  }\n\n  .shape-1 {\n    width: 320px;\n    height: 320px;\n    background: linear-gradient(45deg, #00ffea, #0040ff);\n    top: 15%;\n    left: 10%;\n    animation-name: float1;\n    animation-duration: 20s;\n  }\n\n  .shape-2 {\n    width: 280px;\n    height: 280px;\n    background: linear-gradient(45deg, #ff0099, #6600cc);\n    bottom: 20%;\n    right: 12%;\n    animation-name: float2;\n    animation-duration: 18s;\n  }\n\n  .shape-3 {\n    width: 260px;\n    height: 260px;\n    background: linear-gradient(135deg, #00ffb8, #0082ff);\n    bottom: 35%;\n    left: 15%;\n    animation-name: float3;\n    animation-duration: 22s;\n  }\n\n  @keyframes float1 {\n    0%   { transform: translateY(0) translateX(0) scale(1); }\n    100% { transform: translateY(-24px) translateX(20px) scale(1.1); }\n  }\n\n  @keyframes float2 {\n    0%   { transform: translateY(0) translateX(0) scale(1); }\n    100% { transform: translateY(30px) translateX(-15px) scale(0.92); }\n  }\n\n  @keyframes float3 {\n    0%   { transform: translateY(0) translateX(0) scale(1); }\n    100% { transform: translateY(-15px) translateX(30px) scale(1.07); }\n  }\n</style>\n</head>\n<body>\n  <div class=\"background-shapes\" aria-hidden=\"true\">\n    <div class=\"shape shape-1\"></div>\n    <div class=\"shape shape-2\"></div>\n    <div class=\"shape shape-3\"></div>\n  </div>\n\n  <main class=\"card\" role=\"main\" aria-label=\"Demonstration of Dynamic Typing Concept\">\n    <h1>Dynamic Typing</h1>\n    <p class=\"subtitle\">An elegant visual demonstration of type flexibility & runtime behavior</p>\n    <section aria-live=\"polite\" class=\"typing-area\" id=\"typingArea\" aria-atomic=\"true\" tabindex=\"0\" role=\"textbox\" aria-readonly=\"true\" aria-label=\"Dynamic typing code example output\">\n      <!-- Typed text will appear here -->\n      <span id=\"typedText\"></span><span class=\"caret\"></span>\n    </section>\n\n    <div class=\"controls\" aria-label=\"Controls for the demonstration\">\n      <button id=\"restartBtn\" title=\"Restart Animation\" aria-live=\"polite\" aria-atomic=\"true\">Restart Animation</button>\n    </div>\n  </main>\n\n<script>\n(() => {\n  'use strict';\n  \n  // Lines demonstrating dynamic typing behavior and concept,\n  // visually \"typed\" with pauses and style.\n  const lines = [\n    'let dynamicVariable = 10;',                 // int assignment\n    'console.log(dynamicVariable); // Output: 10',\n    '',\n    'dynamicVariable = \"Now I am a string!\";',  // string reassignment\n    'console.log(dynamicVariable); // Output: \"Now I am a string!\"',\n    '',\n    'dynamicVariable = true;',                    // boolean reassignment\n    'console.log(dynamicVariable); // Output: true',\n    '',\n    '// No fixed type — flexible and powerful.',\n    '// Types are resolved at runtime.',\n  ];\n\n  // Configuration for typing speed and pause durations\n  const TYPE_SPEED = 40;        // ms per char\n  const PAUSE_BETWEEN_LINES = 900; // ms after finishing a line\n\n  // References\n  const typedTextEl = document.getElementById('typedText');\n  const restartBtn = document.getElementById('restartBtn');\n\n  // State variables\n  let lineIndex = 0;\n  let charIndex = 0;\n  let typingTimer = null;\n  let paused = false;\n\n  // Clear all text\n  function clearText() {\n    typedTextEl.textContent = '';\n  }\n\n  // Type one character\n  function typeChar() {\n    if (paused) return;\n    const currentLine = lines[lineIndex];\n    if (charIndex < currentLine.length) {\n      typedTextEl.textContent += currentLine.charAt(charIndex);\n      charIndex++;\n      typingTimer = setTimeout(typeChar, TYPE_SPEED);\n    } else {\n      // Line finished, pause before next line\n      lineIndex++;\n      typingTimer = setTimeout(() => {\n        typedTextEl.textContent += '\\n';\n        charIndex = 0;\n        if (lineIndex < lines.length) {\n          typeChar();\n        } else {\n          // All lines done: glow pulse effect on caret\n          caretPulse();\n        }\n      }, PAUSE_BETWEEN_LINES);\n    }\n  }\n\n  // Pulse the caret indefinitely after typing finished\n  function caretPulse() {\n    const caret = document.querySelector('.caret');\n    caret.style.animation = 'blink 1.3s infinite, pulseGlow 2.5s infinite alternate';\n  }\n\n  // Stop pulse animation (before restart)\n  function resetCaretAnimation() {\n    const caret = document.querySelector('.caret');\n    caret.style.animation = 'blink 1.3s infinite';\n  }\n\n  // Public method to start typing animation from beginning\n  function startTyping() {\n    paused = false;\n    lineIndex = 0;\n    charIndex = 0;\n    clearText();\n    resetCaretAnimation();\n    typeChar();\n  }\n\n  // Restart control button handler\n  restartBtn.addEventListener('click', () => {\n    paused = true;\n    clearTimeout(typingTimer);\n    startTyping();\n    restartBtn.focus();\n  });\n\n  // Trigger animation on page load\n  window.addEventListener('load', startTyping);\n\n  // Additional animation for glow pulse on caret when done\n  const styleSheet = document.createElement('style');\n  styleSheet.type = 'text/css';\n  styleSheet.textContent = `\n    @keyframes pulseGlow {\n      0% { filter: drop-shadow(0 0 3px #00e3ff) drop-shadow(0 0 12px #00e3ffcc);}\n      100% { filter: drop-shadow(0 0 16px #00eaff) drop-shadow(0 0 23px #00eaffcc);}\n    }\n  `;\n  document.head.appendChild(styleSheet);\n})();\n</script>\n</body>\n</html>"
