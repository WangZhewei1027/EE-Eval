    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Index</title>\n    <style>\n        body {\n            background-color: white;\n        }\n        input[type=\"text\"] {\n            width: 50%;\n            height: 20px;\n            margin-bottom: 10px;\n            padding: 10px;\n        }\n        button {\n            width: 20%;\n            height: 30px;\n            margin-bottom: 10px;\n            padding: 10px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <h1>B-Tree Index</h1>\n    <p>Insert 5 records into the B-Tree Index.</p>\n    <form>\n        <input type=\"text\" id=\"record\" placeholder=\"Enter record\">\n        <button id=\"insert\">Insert</button>\n        <button id=\"search\">Search</button>\n        <button id=\"delete\">Delete</button>\n        <button id=\"clear\">Clear</button>\n        <button id=\"add\">Add</button>\n    </form>\n    <div id=\"result\"></div>\n\n    <script>\n        let records = [];\n        let searchResults = [];\n        let deleteIndex = [];\n\n        function insertRecord() {\n            records.push({\n                id: 1,\n                name: \"John Doe\",\n                age: 30\n            });\n            updateResult();\n        }\n\n        function searchRecord() {\n            searchResults = records.filter(record => record.name.toLowerCase().includes(searchInput.value.toLowerCase()));\n            updateResult();\n        }\n\n        function deleteRecord() {\n            deleteIndex = records.filter(record => record.id !== parseInt(idInput.value));\n            updateResult();\n        }\n\n        function clearRecords() {\n            records = [];\n            updateResult();\n        }\n\n        function addRecord() {\n            records.push({\n                id: 2,\n                name: \"Jane Doe\",\n                age: 25\n            });\n            updateResult();\n        }\n\n        function updateResult() {\n            let resultDiv = document.getElementById(\"result\");\n            resultDiv.innerHTML = \"\";\n            records.forEach(record => {\n                let div = document.createElement(\"div\");\n                div.innerHTML = `${record.id} - ${record.name} - ${record.age}`;\n                resultDiv.appendChild(div);\n            });\n        }\n\n        let idInput = document.getElementById(\"record\");\n        let searchInput = document.getElementById(\"search\");\n        let deleteInput = document.getElementById(\"delete\");\n        let clearInput = document.getElementById(\"clear\");\n        let addInput = document.getElementById(\"add\");\n\n        let insertButton = document.getElementById(\"insert\");\n        let searchButton = document.getElementById(\"search\");\n        let deleteButton = document.getElementById(\"delete\");\n        let clearButton = document.getElementById(\"clear\");\n        let addButton = document.getElementById(\"add\");\n\n        insertButton.addEventListener(\"click\", insertRecord);\n        searchButton.addEventListener(\"click\", searchRecord);\n        deleteButton.addEventListener(\"click\", deleteRecord);\n        clearButton.addEventListener(\"click\", clearRecords);\n        addButton.addEventListener(\"click\", addRecord);\n\n        searchInput.addEventListener(\"input\", searchRecord);\n        idInput.addEventListener(\"input\", updateResult);\n        deleteInput.addEventListener(\"input\", updateResult);\n        clearInput.addEventListener(\"input\", updateResult);\n        addInput.addEventListener(\"input\", updateResult);\n    </script>\n</body>\n</html>"
