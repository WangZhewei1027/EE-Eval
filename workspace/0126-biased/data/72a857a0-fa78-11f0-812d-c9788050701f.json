    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Cosmic Linked List</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #1e1e2f, #2d3436);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            padding: 2rem;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            font-weight: 700;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: 1px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.8;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization {\n            position: relative;\n            height: 400px;\n            margin: 4rem 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n        \n        .node {\n            position: absolute;\n            width: 120px;\n            height: 120px;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            border-radius: 50%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\n            transition: var(--transition);\n            z-index: 2;\n            transform: translateY(0);\n            animation: float 4s ease-in-out infinite;\n        }\n        \n        .node:nth-child(2) {\n            background: linear-gradient(135deg, var(--accent), #ff7675);\n            animation-delay: 0.5s;\n        }\n        \n        .node:nth-child(3) {\n            background: linear-gradient(135deg, #00b894, #55efc4);\n            animation-delay: 1s;\n        }\n        \n        .node:nth-child(4) {\n            background: linear-gradient(135deg, #fdcb6e, #e17055);\n            animation-delay: 1.5s;\n        }\n        \n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-20px); }\n        }\n        \n        .node-value {\n            font-size: 1.8rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n        }\n        \n        .node-pointer {\n            font-size: 0.9rem;\n            opacity: 0.7;\n        }\n        \n        .connector {\n            position: absolute;\n            height: 4px;\n            background: linear-gradient(to right, var(--secondary), var(--accent));\n            z-index: 1;\n            transform-origin: left center;\n            transition: var(--transition);\n        }\n        \n        .connector::after {\n            content: '';\n            position: absolute;\n            right: -10px;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 0;\n            height: 0;\n            border-top: 8px solid transparent;\n            border-bottom: 8px solid transparent;\n            border-left: 12px solid var(--accent);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.8rem;\n            font-size: 1rem;\n            font-weight: 600;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 15px 30px rgba(108, 92, 231, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            max-width: 800px;\n            margin: 4rem auto;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            padding: 2rem;\n            border-radius: 20px;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n        \n        h2 {\n            font-family: 'Playfair Display', serif;\n            font-size: 2rem;\n            margin-bottom: 1.5rem;\n            color: var(--secondary);\n        }\n        \n        p {\n            line-height: 1.8;\n            margin-bottom: 1rem;\n        }\n        \n        .highlight {\n            color: var(--accent);\n            font-weight: 600;\n        }\n        \n        .stars {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n        \n        .star {\n            position: absolute;\n            background: white;\n            border-radius: 50%;\n            animation: twinkle var(--duration, 5s) infinite ease-in-out;\n            opacity: 0;\n        }\n        \n        @keyframes twinkle {\n            0%, 100% { opacity: 0; transform: scale(0.5); }\n            50% { opacity: var(--opacity, 0.8); transform: scale(1); }\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .visualization {\n                height: 300px;\n            }\n            \n            .node {\n                width: 80px;\n                height: 80px;\n            }\n            \n            .node-value {\n                font-size: 1.2rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"stars\" id=\"stars\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Linked List Visualization</h1>\n            <p class=\"subtitle\">A cosmic journey through the fundamental data structure that connects nodes in a sequential chain</p>\n        </header>\n        \n        <div class=\"visualization\" id=\"visualization\">\n            <!-- Nodes will be added dynamically -->\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"animateBtn\">Animate Nodes</button>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>The Beauty of Linked Lists</h2>\n            <p>A <span class=\"highlight\">linked list</span> is a linear data structure where each element is a separate object called a <span class=\"highlight\">node</span>. Each node contains two items: the <span class=\"highlight\">data</span> and a reference (<span class=\"highlight\">pointer</span>) to the next node in the sequence.</p>\n            <p>This elegant structure allows for efficient insertion and deletion of elements without the need to reorganize the entire data structure, making it a fundamental building block in computer science.</p>\n            <p>The cosmic visualization above demonstrates how each node is connected to the next, forming a chain that can dynamically grow and shrink as needed.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create stars\n            const starsContainer = document.getElementById('stars');\n            for (let i = 0; i < 100; i++) {\n                const star = document.createElement('div');\n                star.classList.add('star');\n                star.style.left = `${Math.random() * 100}%`;\n                star.style.top = `${Math.random() * 100}%`;\n                star.style.width = `${Math.random() * 3 + 1}px`;\n                star.style.height = star.style.width;\n                star.style.setProperty('--opacity', Math.random() * 0.5 + 0.3);\n                star.style.setProperty('--duration', `${Math.random() * 5 + 3}s`);\n                star.style.animationDelay = `${Math.random() * 5}s`;\n                starsContainer.appendChild(star);\n            }\n            \n            // Create linked list visualization\n            const visualization = document.getElementById('visualization');\n            const nodes = [\n                { value: 'A', next: 'B' },\n                { value: 'B', next: 'C' },\n                { value: 'C', next: 'D' },\n                { value: 'D', next: null }\n            ];\n            \n            let nodeElements = [];\n            let connectorElements = [];\n            \n            function createLinkedList() {\n                visualization.innerHTML = '';\n                nodeElements = [];\n                connectorElements = [];\n                \n                nodes.forEach((node, index) => {\n                    // Create node\n                    const nodeElement = document.createElement('div');\n                    nodeElement.className = 'node';\n                    nodeElement.innerHTML = `\n                        <div class=\"node-value\">${node.value}</div>\n                        <div class=\"node-pointer\">→ ${node.next || 'NULL'}</div>\n                    `;\n                    \n                    // Position nodes horizontally\n                    const left = 100 + index * 200;\n                    nodeElement.style.left = `${left}px`;\n                    \n                    visualization.appendChild(nodeElement);\n                    nodeElements.push(nodeElement);\n                    \n                    // Create connectors between nodes\n                    if (index < nodes.length - 1) {\n                        const connector = document.createElement('div');\n                        connector.className = 'connector';\n                        \n                        const startX = left + 120;\n                        const endX = left + 200;\n                        const length = endX - startX;\n                        const centerY = visualization.offsetHeight / 2;\n                        \n                        connector.style.left = `${startX}px`;\n                        connector.style.top = `${centerY}px`;\n                        connector.style.width = `${length}px`;\n                        \n                        visualization.appendChild(connector);\n                        connectorElements.push(connector);\n                    }\n                });\n                \n                // Adjust for mobile\n                if (window.innerWidth < 768) {\n                    nodeElements.forEach((node, index) => {\n                        const left = 50 + index * 120;\n                        node.style.left = `${left}px`;\n                        \n                        if (index < nodes.length - 1) {\n                            const startX = left + 80;\n                            const endX = left + 120;\n                            const length = endX - startX;\n                            connectorElements[index].style.left = `${startX}px`;\n                            connectorElements[index].style.width = `${length}px`;\n                        }\n                    });\n                }\n            }\n            \n            // Initial creation\n            createLinkedList();\n            \n            // Animation button\n            document.getElementById('animateBtn').addEventListener('click', function() {\n                nodeElements.forEach((node, index) => {\n                    setTimeout(() => {\n                        node.style.transform = 'scale(1.2) translateY(-20px)';\n                        node.style.boxShadow = '0 30px 60px rgba(0, 0, 0, 0.4)';\n                        \n                        if (connectorElements[index]) {\n                            connectorElements[index].style.transform = 'scaleX(1.2)';\n                            connectorElements[index].style.opacity = '1';\n                        }\n                        \n                        setTimeout(() => {\n                            node.style.transform = 'scale(1) translateY(0)';\n                            node.style.boxShadow = '0 20px 40px rgba(0, 0, 0, 0.3)';\n                            \n                            if (connectorElements[index]) {\n                                connectorElements[index].style.transform = 'scaleX(1)';\n                                connectorElements[index].style.opacity = '0.8';\n                            }\n                        }, 500);\n                    }, index * 300);\n                });\n            });\n            \n            // Handle window resize\n            window.addEventListener('resize', function() {\n                createLinkedList();\n            });\n        });\n    </script>\n</body>\n</html>"
