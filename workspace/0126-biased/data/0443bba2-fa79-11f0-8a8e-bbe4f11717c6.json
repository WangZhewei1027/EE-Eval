    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Paging</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .title {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n\n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            margin: 10px auto;\n        }\n\n        .button:hover {\n            background-color: #3e8e41;\n        }\n\n        .pagination {\n            text-align: center;\n            margin-top: 20px;\n        }\n\n        .pagination li {\n            display: inline-block;\n            margin: 0 10px;\n            padding: 5px 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .pagination li.active {\n            background-color: #4CAF50;\n            color: #fff;\n        }\n\n        .pagination li a {\n            color: #fff;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Paging</h1>\n        <p>Beautiful, polished UI with smooth animations and transitions</p>\n        <p>Professional color schemes and typography</p>\n        <p>Visually stunning graphics and layouts</p>\n        <p>Aesthetic appeal as the PRIMARY goal</p>\n\n        <button class=\"button\" onclick=\"page(1)\">Previous</button>\n        <button class=\"button\" onclick=\"page(2)\">Next</button>\n\n        <div class=\"pagination\">\n            <li class=\"active\" onclick=\"page(1)\">1</li>\n            <li onclick=\"page(2)\">2</li>\n            <li onclick=\"page(3)\">3</li>\n            <li onclick=\"page(4)\">4</li>\n            <li onclick=\"page(5)\">5</li>\n        </div>\n    </div>\n\n    <script>\n        function page(pageNumber) {\n            document.querySelector('.pagination li.active').classList.remove('active');\n            document.querySelector(`.pagination li:nth-child(${pageNumber + 1})`).classList.add('active');\n            document.querySelector('.container').style pageTransition = `opacity: ${pageNumber / 5};`;\n        }\n    </script>\n</body>\n</html>"
