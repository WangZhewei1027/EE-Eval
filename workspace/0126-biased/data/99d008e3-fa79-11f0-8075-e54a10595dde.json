    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Relational Database Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Relational Database Demo</h1>\n\n<h2>Add User</h2>\n<input type=\"text\" id=\"username\" placeholder=\"Enter Username\">\n<button onclick=\"addUser()\">Add User</button>\n\n<h2>Users</h2>\n<ul id=\"userList\"></ul>\n\n<h2>Add Post</h2>\n<input type=\"text\" id=\"postContent\" placeholder=\"Enter Post Content\">\n<select id=\"userSelect\"></select>\n<button onclick=\"addPost()\">Add Post</button>\n\n<h2>Posts</h2>\n<ul id=\"postList\"></ul>\n\n<h2>Filter Posts</h2>\n<select id=\"filterUserSelect\" onchange=\"filterPosts()\"></select>\n\n<script>\n    let users = [];\n    let posts = [];\n\n    function addUser() {\n        const username = document.getElementById('username').value;\n        if (username) {\n            users.push(username);\n            document.getElementById('username').value = '';\n            updateUserList();\n            updateUserSelect();\n            updateFilterUserSelect();\n        }\n    }\n\n    function updateUserList() {\n        const userList = document.getElementById('userList');\n        userList.innerHTML = '';\n        users.forEach((user, index) => {\n            const li = document.createElement('li');\n            li.textContent = user;\n            userList.appendChild(li);\n        });\n    }\n\n    function addPost() {\n        const postContent = document.getElementById('postContent').value;\n        const userIndex = document.getElementById('userSelect').value;\n        if (postContent && userIndex !== \"\") {\n            posts.push({ content: postContent, user: users[userIndex] });\n            document.getElementById('postContent').value = '';\n            updatePostList();\n        }\n    }\n\n    function updatePostList() {\n        const postList = document.getElementById('postList');\n        postList.innerHTML = '';\n        posts.forEach(post => {\n            const li = document.createElement('li');\n            li.textContent = `${post.user}: ${post.content}`;\n            postList.appendChild(li);\n        });\n    }\n\n    function updateUserSelect() {\n        const userSelect = document.getElementById('userSelect');\n        userSelect.innerHTML = '';\n        users.forEach((user, index) => {\n            const option = document.createElement('option');\n            option.value = index;\n            option.textContent = user;\n            userSelect.appendChild(option);\n        });\n    }\n\n    function updateFilterUserSelect() {\n        const filterUserSelect = document.getElementById('filterUserSelect');\n        filterUserSelect.innerHTML = '';\n        filterUserSelect.add(new Option(\"All Users\", \"\"));\n        users.forEach((user, index) => {\n            filterUserSelect.add(new Option(user, index));\n        });\n    }\n\n    function filterPosts() {\n        const userIndex = document.getElementById('filterUserSelect').value;\n        const postList = document.getElementById('postList');\n        postList.innerHTML = '';\n        posts.forEach(post => {\n            if (userIndex === \"\" || users[userIndex] === post.user) {\n                const li = document.createElement('li');\n                li.textContent = `${post.user}: ${post.content}`;\n                postList.appendChild(li);\n            }\n        });\n    }\n</script>\n\n</body>\n</html>"
