    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Patterns Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .container { margin: 20px; }\n        .section { margin-bottom: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Design Patterns Demonstration</h1>\n        \n        <div class=\"section\">\n            <h2>1. Singleton Pattern</h2>\n            <button onclick=\"singletonDemo()\">Toggle Singleton Counter</button>\n            <div id=\"singletonOutput\">Initialized: 0</div>\n        </div>\n\n        <div class=\"section\">\n            <h2>2. Factory Pattern</h2>\n            <button onclick=\"createObject('A')\">Create Object A</button>\n            <button onclick=\"createObject('B')\">Create Object B</button>\n            <div id=\"factoryOutput\"></div>\n        </div>\n\n        <div class=\"section\">\n            <h2>3. Observer Pattern</h2>\n            <input type=\"text\" id=\"observerInput\" placeholder=\"Notify Observers...\" />\n            <button onclick=\"notifyObservers()\">Notify Observers</button>\n            <div id=\"observerOutput\"></div>\n        </div>\n\n        <div class=\"section\">\n            <h2>4. Command Pattern</h2>\n            <button onclick=\"executeCommand('Action 1')\">Execute Command 1</button>\n            <button onclick=\"executeCommand('Action 2')\">Execute Command 2</button>\n            <div id=\"commandOutput\">Commands executed:</div>\n        </div>\n        \n        <div class=\"section\">\n            <h2>5. State Pattern</h2>\n            <button onclick=\"changeState()\">Toggle State</button>\n            <div id=\"stateOutput\">Current State: Off</div>\n        </div>\n    </div>\n\n    <script>\n        // Singleton Pattern\n        let Singleton = (function() {\n            let instance;\n            function createInstance() {\n                let count = 0;\n                return {\n                    increment: function() { count++; return count; },\n                    getCount: function() { return count; }\n                };\n            }\n            return {\n                getInstance: function() {\n                    if (!instance) {\n                        instance = createInstance();\n                    }\n                    return instance;\n                }\n            };\n        })();\n\n        function singletonDemo() {\n            const singleton = Singleton.getInstance();\n            const output = singleton.increment();\n            document.getElementById(\"singletonOutput\").innerText = \"Initialized: \" + output;\n        }\n\n        // Factory Pattern\n        function createObject(type) {\n            let output = \"Created: \";\n            switch (type) {\n                case 'A':\n                    output += \"Object A\";\n                    break;\n                case 'B':\n                    output += \"Object B\";\n                    break;\n                default:\n                    output = \"Unknown Object\";\n            }\n            document.getElementById(\"factoryOutput\").innerText += output + \"\\n\";\n        }\n\n        // Observer Pattern\n        let observers = [];\n        function addObserver(observer) {\n            observers.push(observer);\n        }\n        function notifyObservers() {\n            const message = document.getElementById(\"observerInput\").value;\n            observers.forEach(observer => observer(message));\n            document.getElementById(\"observerOutput\").innerText += \"Notification: \" + message + \"\\n\";\n        }\n        addObserver(output => console.log(\"Observer 1 received: \" + output));\n        addObserver(output => console.log(\"Observer 2 received: \" + output));\n\n        // Command Pattern\n        let commandHistory = [];\n        function executeCommand(action) {\n            commandHistory.push(action);\n            document.getElementById(\"commandOutput\").innerText += action + \"\\n\";\n        }\n\n        // State Pattern\n        let currentState = false;\n        function changeState() {\n            currentState = !currentState;\n            document.getElementById(\"stateOutput\").innerText = \"Current State: \" + (currentState ? \"On\" : \"Off\");\n        }\n    </script>\n</body>\n</html>"
