    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Compiler — Visual Concept</title>\n\n  <!-- Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #071029;\n      --bg-2: #081223;\n      --card-glass: rgba(255,255,255,0.04);\n      --accent: #6BE7C4;\n      --accent-2: #6AA8FF;\n      --muted: rgba(255,255,255,0.55);\n      --glass-border: rgba(255,255,255,0.06);\n      --glass-reflect: linear-gradient(120deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      --shadow: 0 10px 30px rgba(2,6,23,0.6);\n      --pipeline-step-bg: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    }\n\n    /* Reset & base */\n    * { box-sizing: border-box; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }\n    html,body{ height:100%; margin:0; font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: #E6F0FF; background: radial-gradient(1200px 600px at 10% 10%, rgba(106,168,255,0.07), transparent), linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%); overflow:hidden;}\n\n    /* Subtle animated background gradient */\n    .bg-shift {\n      position:fixed; inset:0; z-index:0; pointer-events:none; mix-blend-mode:screen;\n      background: radial-gradient(600px 300px at 80% 20%, rgba(107,168,255,0.06), transparent),\n                  radial-gradient(500px 260px at 20% 80%, rgba(107,231,196,0.03), transparent);\n      animation: bgMove 12s infinite alternate ease-in-out;\n    }\n    @keyframes bgMove {\n      0% { transform: translateY(0) scale(1); opacity:0.95; }\n      100% { transform: translateY(-20px) scale(1.03); opacity:1; }\n    }\n\n    /* Main layout */\n    .stage {\n      position:relative; z-index:2; display:flex; align-items:center; justify-content:center; height:100vh; padding:48px;\n    }\n    .panel {\n      width:1200px; max-width:calc(100% - 96px);\n      border-radius:18px; padding:28px; background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: var(--shadow); border:1px solid var(--glass-border); backdrop-filter: blur(8px);\n      display:flex; gap:28px; align-items:stretch;\n      overflow:visible;\n    }\n\n    /* Left info column */\n    .info {\n      width:360px; min-width:260px; display:flex; flex-direction:column; gap:20px;\n    }\n\n    .title {\n      display:flex; gap:12px; align-items:center;\n    }\n    .brand {\n      width:72px; height:72px; border-radius:14px; background: linear-gradient(135deg,var(--accent),var(--accent-2)); display:flex; align-items:center; justify-content:center; box-shadow: 0 6px 24px rgba(107,168,255,0.12);\n      font-weight:800; font-family: \"JetBrains Mono\", monospace; color:#012028; font-size:20px;\n    }\n    .heading {\n      display:flex; flex-direction:column;\n    }\n    h1 {\n      margin:0; font-size:20px; letter-spacing:0.2px; font-weight:800; color: #E9FBF7;\n    }\n    p.sub {\n      margin:0; color:var(--muted); font-size:13px; line-height:1.35;\n    }\n\n    .meta {\n      margin-top:6px; display:flex; gap:8px; align-items:center; flex-wrap:wrap;\n    }\n    .chip {\n      font-size:12px; color:rgba(255,255,255,0.9);\n      background: rgba(255,255,255,0.02); padding:8px 10px; border-radius:999px; border:1px solid rgba(255,255,255,0.03);\n      display:inline-flex; gap:8px; align-items:center;\n    }\n    .chip b { color:var(--accent-2); font-family: \"JetBrains Mono\", monospace; font-weight:600; }\n\n    .desc {\n      color: var(--muted); font-size:13px; line-height:1.5; margin-top:6px;\n    }\n\n    .controls {\n      display:flex; gap:12px; margin-top:auto; align-items:center;\n    }\n\n    .btn {\n      -webkit-tap-highlight-color: transparent;\n      cursor:pointer; border:0; padding:12px 18px; font-size:14px; border-radius:12px; font-weight:600;\n      color: #022; background: linear-gradient(180deg,#BDF2D9, #6BE7C4); box-shadow: 0 6px 22px rgba(107,231,196,0.12); transition:transform .18s ease, box-shadow .18s;\n      display:inline-flex; gap:10px; align-items:center;\n    }\n    .btn.secondary {\n      background: transparent; color:var(--muted); padding:10px 14px; border:1px solid rgba(255,255,255,0.04);\n      box-shadow:none;\n    }\n    .btn:active { transform:translateY(2px); }\n    .btn[disabled] { opacity:0.6; cursor:not-allowed; transform:none; box-shadow:none; }\n\n    .small {\n      font-size:12px; color:var(--muted); display:flex; gap:10px; align-items:center;\n    }\n\n    /* Right visualization area */\n    .visual {\n      flex:1; position:relative; padding:18px; border-radius:12px; background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005)); border:1px solid rgba(255,255,255,0.03);\n      overflow:hidden;\n    }\n\n    /* Source code window */\n    .source {\n      height:150px; border-radius:12px; padding:14px; background: linear-gradient(180deg, rgba(1,6,11,0.45), rgba(2,9,16,0.35));\n      border:1px solid rgba(255,255,255,0.02); box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n      font-family: \"JetBrains Mono\", monospace; color:#CBEFF0; font-size:13px; line-height:1.5; overflow:hidden;\n      position:relative;\n    }\n    .source pre { margin:0; white-space:pre-wrap; word-break:break-word; opacity:0.95; }\n    .code-line { display:block; opacity:.9; }\n\n    /* pipeline */\n    .pipeline {\n      display:flex; gap:18px; align-items:center; margin-top:18px; position:relative; z-index:2; height:120px;\n    }\n\n    .step {\n      width:160px; min-width:120px; height:98px; border-radius:12px; padding:12px; background: var(--pipeline-step-bg);\n      border:1px solid rgba(255,255,255,0.03); display:flex; flex-direction:column; gap:8px; align-items:flex-start; justify-content:center;\n      box-shadow: 0 6px 20px rgba(2,6,23,0.45);\n      position:relative; overflow:visible;\n    }\n    .step .ic {\n      width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:14px; background:rgba(255,255,255,0.015);\n      box-shadow: inset 0 -6px 18px rgba(0,0,0,0.3);\n    }\n    .step b { display:block; font-weight:700; font-size:13px; color:#E9FBF7; }\n    .step small { color:var(--muted); font-size:12px; }\n\n    /* connectors */\n    .connector {\n      height:2px; width:40px; background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.005));\n      position:relative; margin-left:6px; margin-right:6px;\n    }\n    .connector::after {\n      content:''; position:absolute; top:-6px; right:-6px; width:12px; height:12px; border-radius:50%;\n      background: linear-gradient(90deg,var(--accent),var(--accent-2));\n      box-shadow: 0 6px 16px rgba(106,168,255,0.12);\n      transform: scale(0); opacity:0; transition:transform .3s ease, opacity .2s;\n    }\n\n    /* tokens that flow */\n    .token {\n      position:absolute; width:14px; height:14px; border-radius:50%; box-shadow: 0 8px 14px rgba(4,8,15,0.65); transform:translateY(0);\n      background: linear-gradient(180deg,#FFF 0%, rgba(255,255,255,0.1) 100%); opacity:0.95;\n      display:flex; align-items:center; justify-content:center; color:#08202A; font-weight:700; font-size:10px;\n      border:1px solid rgba(255,255,255,0.18);\n    }\n\n    /* flow tracks with keyframes triggered by .running */\n    .flow-area { position:absolute; left:0; right:0; top:0; bottom:0; pointer-events:none; }\n\n    .flow-area .t0 { left:24px; top:64px; animation: move0 3.8s cubic-bezier(.2,.9,.24,1) forwards; opacity:0; }\n    .flow-area .t1 { left:24px; top:64px; animation: move1 4.0s cubic-bezier(.22,.9,.28,1) forwards; opacity:0; }\n    .flow-area .t2 { left:24px; top:64px; animation: move2 4.2s cubic-bezier(.22,.9,.28,1) forwards; opacity:0; }\n    /* placeholder keyframes move tokens across pipeline horizontally, with vertical bobs */\n    @keyframes move0 {\n      0% { transform: translateX(0) translateY(0) scale(.9); opacity:0; }\n      10% { opacity:1; transform: translateX(70px) translateY(-4px) scale(1); }\n      40% { transform: translateX(310px) translateY(6px) scale(1); }\n      70% { transform: translateX(640px) translateY(-6px) scale(0.98); }\n      100% { transform: translateX(980px) translateY(0) scale(1); opacity:1; filter:drop-shadow(0 12px 22px rgba(6,26,38,0.55)); }\n    }\n    @keyframes move1 {\n      0% { transform: translateX(0) translateY(0) scale(.9); opacity:0; }\n      12% { opacity:1; transform: translateX(60px) translateY(4px) scale(1); }\n      44% { transform: translateX(320px) translateY(-8px) scale(1); }\n      76% { transform: translateX(690px) translateY(6px) scale(0.98); }\n      100% { transform: translateX(980px) translateY(0) scale(1); opacity:1; }\n    }\n    @keyframes move2 {\n      0% { transform: translateX(0) translateY(0) scale(.9); opacity:0; }\n      14% { opacity:1; transform: translateX(80px) translateY(-6px) scale(1); }\n      46% { transform: translateX(340px) translateY(6px) scale(1); }\n      78% { transform: translateX(720px) translateY(-6px) scale(0.98); }\n      100% { transform: translateX(980px) translateY(0) scale(1); opacity:1; }\n    }\n\n    /* AST area (center) */\n    .ast {\n      position:absolute; left:50%; top:50%; transform:translate(-50%,-34%); width:640px; height:240px; pointer-events:none;\n      display:flex; align-items:center; justify-content:center;\n    }\n    .ast svg { width:100%; height:100%; overflow:visible; }\n\n    .node {\n      fill: linear-gradient(180deg,#123 0%,#456 100%);\n    }\n\n    /* Draw edges using stroke-dashoffset animation on .active */\n    .edge {\n      stroke: rgba(107,231,196,0.85);\n      stroke-width:2.2; fill:none; stroke-linecap:round; stroke-linejoin:round;\n      stroke-dasharray: 200; stroke-dashoffset:200; opacity:0.0;\n      transition: opacity .3s ease;\n    }\n    .active .edge { animation: drawEdge 1.1s ease forwards; opacity:1; }\n    @keyframes drawEdge {\n      to { stroke-dashoffset:0; opacity:1; }\n    }\n\n    .ast-node {\n      transform-origin:center center;\n      opacity:0; transform: scale(0.6);\n      transition: transform .36s cubic-bezier(.2,.9,.24,1), opacity .28s;\n      filter: drop-shadow(0 10px 18px rgba(6,20,29,0.5));\n    }\n    .active .ast-node { opacity:1; transform:scale(1); }\n\n    .ast-leaf {\n      fill: linear-gradient(180deg,#6BE7C4, #6AA8FF);\n    }\n\n    /* final binary */\n    .binary {\n      position:absolute; right:26px; bottom:18px; width:120px; height:100px; border-radius:12px; background: linear-gradient(180deg,#0E2130, #06121A);\n      border:1px solid rgba(255,255,255,0.03); display:flex; align-items:center; justify-content:center; flex-direction:column; gap:8px; padding:12px;\n      box-shadow: 0 18px 30px rgba(6,12,20,0.6);\n    }\n    .binary .ico {\n      width:48px; height:48px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-weight:800;\n      background: linear-gradient(135deg,#101b2c, #0b1420); color:#79ffd1; font-family: \"JetBrains Mono\", monospace;\n      box-shadow: inset 0 -8px 18px rgba(0,0,0,0.6);\n    }\n    .binary small { color:var(--muted); font-size:12px; }\n\n    /* compile progress overlay */\n    .progress {\n      position:absolute; left:28px; right:28px; bottom:22px; height:10px; border-radius:10px; background:rgba(255,255,255,0.02);\n      overflow:hidden; border:1px solid rgba(255,255,255,0.02);\n    }\n    .bar {\n      height:100%; width:0%; background: linear-gradient(90deg,var(--accent),var(--accent-2));\n      box-shadow: 0 8px 18px rgba(106,231,196,0.10);\n      transition: width .6s cubic-bezier(.2,.9,.24,1);\n    }\n    .pct {\n      position:absolute; right:16px; bottom:34px; color:var(--muted); font-family:\"JetBrains Mono\", monospace; font-size:12px;\n    }\n\n    /* subtle floating code highlight */\n    .code-shimmer {\n      position:absolute; left:14px; top:14px; right:14px; height:40px; border-radius:8px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      filter: blur(12px); opacity:0.15; transform: translateY(-8px);\n      animation: shimmer 3.6s ease-in-out infinite;\n      pointer-events:none;\n    }\n    @keyframes shimmer {\n      0% { transform: translateX(-20%); opacity:0.08; }\n      50% { transform: translateX(80%); opacity:0.18; }\n      100% { transform: translateX(120%); opacity:0.08; }\n    }\n\n    /* tiny footer */\n    .credit { position:absolute; left:22px; top:18px; font-size:12px; color:rgba(255,255,255,0.12); }\n\n    /* active visual emphasis when running */\n    .active .connector::after { transform: scale(1); opacity:1; transition-delay: .26s; }\n    .active .step { transform: translateY(-6px); transition: transform .36s cubic-bezier(.2,.9,.24,1); }\n    .active .step:nth-child(1){ transform: translateY(-18px); }\n    .active .step:nth-child(2){ transform: translateY(-10px); transition-delay:.04s; }\n    .active .step:nth-child(3){ transform: translateY(-6px); transition-delay:.08s; }\n    .active .step:nth-child(4){ transform: translateY(-6px); transition-delay:.12s; }\n    .active .step:nth-child(5){ transform: translateY(-10px); transition-delay:.16s; }\n\n    /* responsiveness */\n    @media (max-width:1000px){\n      .panel { flex-direction:column; align-items:stretch; padding:18px; gap:18px; }\n      .info { width:100%; order:2; flex-direction:row; align-items:center; }\n      .visual { order:1; min-height:300px; }\n      .source { height:120px; }\n      .pipeline { height:140px; overflow-x:auto; }\n      .ast { display:none; }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"bg-shift\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\">\n    <div class=\"panel\" id=\"panel\">\n      <div class=\"info\" aria-hidden=\"false\">\n        <div class=\"title\">\n          <div class=\"brand\">CMP</div>\n          <div class=\"heading\">\n            <h1>Compiler</h1>\n            <p class=\"sub\">Visualizing the stages of translation: from human-readable source to machine-ready artifact.</p>\n          </div>\n        </div>\n\n        <p class=\"desc\">A stylized demonstration of a compiler pipeline: lexing, parsing, AST construction, optimization, and code generation. Observe tokens flow and the abstract syntax tree form — an artistic depiction of compilation.</p>\n\n        <div class=\"meta\" aria-hidden=\"true\">\n          <span class=\"chip\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:.9\"><path d=\"M12 2L15 8L22 9L17 14L18 21L12 18L6 21L7 14L2 9L9 8L12 2Z\" fill=\"white\" opacity=\"0.12\"/></svg> <b>Stages</b> Lex → Parse → AST → Opt → CodeGen</span>\n          <span class=\"chip\" title=\"Aesthetic demo\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"white\" opacity=\"0.06\"/></svg> <b>Focus</b> Visual</span>\n        </div>\n\n        <div class=\"controls\" style=\"gap:10px;\">\n          <button id=\"compileBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Run compilation visualization\">\n            Compile\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"margin-left:4px\">\n              <path d=\"M5 3v18l15-9L5 3z\" fill=\"#022\" opacity=\"0.9\"/>\n            </svg>\n          </button>\n          <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset visuals\">Reset</button>\n        </div>\n\n        <div style=\"height:10px\"></div>\n        <div class=\"small\">Minimal controls — primarily an animated, observational experience.</div>\n      </div>\n\n      <div class=\"visual\" role=\"img\" aria-label=\"Compiler visualization\">\n        <div class=\"credit\">Concept • Compiler • Visual Demo</div>\n\n        <div class=\"source\" aria-hidden=\"true\">\n          <div class=\"code-shimmer\" aria-hidden=\"true\"></div>\n          <pre id=\"sourceCode\">\n<span class=\"code-line\" style=\"color:#93e9d6\">// Example: compute factorial</span>\n<span class=\"code-line\" style=\"color:#c7f1ff\">func factorial(n) {</span>\n<span class=\"code-line\" style=\"color:#9fe3ff\">  if (n &lt;= 1) return 1;</span>\n<span class=\"code-line\" style=\"color:#d4f7e9\">  return n * factorial(n - 1);</span>\n<span class=\"code-line\" style=\"color:#c7f1ff\">}</span>\n          </pre>\n        </div>\n\n        <div class=\"pipeline\" aria-hidden=\"true\" style=\"position:relative; margin-top:18px;\">\n          <div class=\"step\" style=\"z-index:2;\">\n            <div class=\"ic\" aria-hidden=\"true\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2L20 7v10l-8 5-8-5V7z\" fill=\"rgba(255,255,255,0.06)\"/></svg>\n            </div>\n            <b>Lexical Analysis</b>\n            <small>Tokenize source</small>\n          </div>\n\n          <div class=\"connector\" aria-hidden=\"true\"></div>\n\n          <div class=\"step\" style=\"z-index:2;\">\n            <div class=\"ic\" aria-hidden=\"true\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\"><path d=\"M12 3v18M3 12h18\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n            </div>\n            <b>Parsing</b>\n            <small>Produce parse tree</small>\n          </div>\n\n          <div class=\"connector\" aria-hidden=\"true\"></div>\n\n          <div class=\"step\" style=\"z-index:2;\">\n            <div class=\"ic\" aria-hidden=\"true\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\"><path d=\"M12 2C9.243 2 7 4.243 7 7s2.243 5 5 5 5-2.243 5-5S14.757 2 12 2z\" fill=\"rgba(255,255,255,0.04)\"/></svg>\n            </div>\n            <b>AST</b>\n            <small>Abstract Syntax Tree</small>\n          </div>\n\n          <div class=\"connector\" aria-hidden=\"true\"></div>\n\n          <div class=\"step\" style=\"z-index:2;\">\n            <div class=\"ic\" aria-hidden=\"true\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\"><path d=\"M3 12h18M12 3v18\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.6\"/></svg>\n            </div>\n            <b>Optimization</b>\n            <small>Refine &amp; simplify</small>\n          </div>\n\n          <div class=\"connector\" aria-hidden=\"true\"></div>\n\n          <div class=\"step\" style=\"z-index:2;\">\n            <div class=\"ic\" aria-hidden=\"true\">\n              <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\"><path d=\"M5 4h14v16H5z\" fill=\"rgba(255,255,255,0.03)\"/></svg>\n            </div>\n            <b>CodeGen</b>\n            <small>Emit binary</small>\n          </div>\n\n          <!-- flow tokens container -->\n          <div class=\"flow-area\" aria-hidden=\"true\">\n            <div class=\"token t0\" style=\"background:linear-gradient(180deg,#6BE7C4,#6AA8FF); color:#04242a\">T</div>\n            <div class=\"token t1\" style=\"background:linear-gradient(180deg,#FFD36B,#FF9A6B); color:#2b0f00\">K</div>\n            <div class=\"token t2\" style=\"background:linear-gradient(180deg,#C7D3FF,#90B4FF); color:#071132\">L</div>\n          </div>\n        </div>\n\n        <div class=\"ast\" id=\"astArea\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 640 240\" preserveAspectRatio=\"xMidYMid meet\" id=\"astSVG\">\n            <!-- Edges -->\n            <path id=\"e1\" class=\"edge\" d=\"M320 36 C320 36, 240 92, 220 132\" />\n            <path id=\"e2\" class=\"edge\" d=\"M320 36 C320 36, 400 92, 420 132\" />\n            <path id=\"e3\" class=\"edge\" d=\"M220 132 C220 132, 220 186, 260 202\" />\n            <path id=\"e4\" class=\"edge\" d=\"M420 132 C420 132, 420 186, 380 202\" />\n\n            <!-- Nodes (center/top) -->\n            <g id=\"nRoot\" class=\"ast-node\" transform=\"translate(320,36)\">\n              <rect x=\"-48\" y=\"-28\" rx=\"10\" ry=\"10\" width=\"96\" height=\"56\" fill=\"#071728\" stroke=\"rgba(107,231,196,0.06)\"></rect>\n              <text x=\"0\" y=\"6\" fill=\"#8CFFE6\" font-family=\"JetBrains Mono\" font-size=\"14px\" font-weight=\"700\" text-anchor=\"middle\">FUNC</text>\n            </g>\n\n            <!-- Left subtree -->\n            <g id=\"nLeft\" class=\"ast-node\" transform=\"translate(220,132)\">\n              <circle r=\"18\" fill=\"#0f3540\"></circle>\n              <text x=\"0\" y=\"6\" fill=\"#C7F1E8\" font-family=\"JetBrains Mono\" font-size=\"12px\" font-weight=\"700\" text-anchor=\"middle\">if</text>\n            </g>\n\n            <g id=\"nLeftLeaf\" class=\"ast-node\" transform=\"translate(260,202)\">\n              <rect x=\"-30\" y=\"-18\" rx=\"8\" ry=\"8\" width=\"60\" height=\"36\" fill=\"#09232b\"></rect>\n              <text x=\"0\" y=\"6\" fill=\"#A7FBE6\" font-family=\"JetBrains Mono\" font-size=\"11px\" font-weight=\"700\" text-anchor=\"middle\">1</text>\n            </g>\n\n            <!-- Right subtree -->\n            <g id=\"nRight\" class=\"ast-node\" transform=\"translate(420,132)\">\n              <circle r=\"18\" fill=\"#102a33\"></circle>\n              <text x=\"0\" y=\"6\" fill=\"#CBEFF0\" font-family=\"JetBrains Mono\" font-size=\"12px\" font-weight=\"700\" text-anchor=\"middle\">mul</text>\n            </g>\n\n            <g id=\"nRightLeaf\" class=\"ast-node\" transform=\"translate(380,202)\">\n              <rect x=\"-38\" y=\"-18\" rx=\"8\" ry=\"8\" width=\"76\" height=\"36\" fill=\"#071a22\"></rect>\n              <text x=\"0\" y=\"6\" fill=\"#A7FBE6\" font-family=\"JetBrains Mono\" font-size=\"11px\" font-weight=\"700\" text-anchor=\"middle\">rec</text>\n            </g>\n          </svg>\n        </div>\n\n        <div class=\"binary\" aria-hidden=\"true\" id=\"binaryCard\">\n          <div class=\"ico\">0x1F</div>\n          <small>machine-code</small>\n        </div>\n\n        <div class=\"progress\" aria-hidden=\"true\">\n          <div class=\"bar\" id=\"progressBar\" style=\"width:0%\"></div>\n          <div class=\"pct\" id=\"pctLabel\">0%</div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      const panel = document.getElementById('panel');\n      const compileBtn = document.getElementById('compileBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const astArea = document.getElementById('astArea');\n      const progressBar = document.getElementById('progressBar');\n      const pctLabel = document.getElementById('pctLabel');\n      let running = false;\n      let timeline = [];\n\n      function setActive(state){\n        if(state){\n          panel.classList.add('active');\n          compileBtn.setAttribute('disabled','true');\n          compileBtn.setAttribute('aria-pressed','true');\n        } else {\n          panel.classList.remove('active');\n          compileBtn.removeAttribute('disabled');\n          compileBtn.setAttribute('aria-pressed','false');\n        }\n      }\n\n      function animateCompile(){\n        if(running) return;\n        running = true;\n        setActive(true);\n        progressBar.style.width = '6%';\n        pctLabel.textContent = '6%';\n\n        // tokens start (CSS animations start automatically because tokens present)\n        // Show edges and nodes progressively using timeouts\n        timeline.forEach(clearTimeout);\n        timeline = [];\n\n        // Step sequence timings (ms)\n        const timings = {\n          lexEnd: 900,\n          parseStart: 1100,\n          parseEnd: 2000,\n          astBuild: 2300,\n          optStart: 3500,\n          codegenStart: 4700,\n          finish: 5800\n        };\n\n        // Lex stage -> progress jump\n        timeline.push(setTimeout(()=> {\n          progressBar.style.width = '18%';\n          pctLabel.textContent = '18%';\n        }, timings.lexEnd));\n\n        // Parsing: reveal left and right connectors (edges draw)\n        timeline.push(setTimeout(()=> {\n          progressBar.style.width = '36%';\n          pctLabel.textContent = '36%';\n          // trigger edge animations by toggling 'active' class on astArea container\n          astArea.classList.add('active');\n        }, timings.parseStart));\n\n        // Parsing end: show some node pops\n        timeline.push(setTimeout(()=> {\n          progressBar.style.width = '52%';\n          pctLabel.textContent = '52%';\n          // reveal root and child nodes sequentially by toggling CSS (they animate because active class present)\n          const svg = document.getElementById('astSVG');\n          svg.querySelectorAll('.ast-node').forEach((n,i) => {\n            n.style.transitionDelay = (i*80)+'ms';\n          });\n        }, timings.parseEnd));\n\n        // AST build: fully visible\n        timeline.push(setTimeout(()=> {\n          progressBar.style.width = '70%';\n          pctLabel.textContent = '70%';\n          // small glow on binary to indicate incoming compile\n          const bin = document.getElementById('binaryCard');\n          bin.style.transform = 'translateY(-8px) scale(1.02)';\n          bin.style.transition = 'transform .48s cubic-bezier(.2,.9,.24,1)';\n        }, timings.astBuild));\n\n        // Optimization\n        timeline.push(setTimeout(()=> {\n          progressBar.style.width = '86%';\n          pctLabel.textContent = '86%';\n          // color shift on source to show optimization (temporary)\n          document.querySelector('.source').style.boxShadow = 'inset 0 1px 20px rgba(107,231,196,0.04)';\n        }, timings.optStart));\n\n        // CodeGen & finish\n        timeline.push(setTimeout(()=> {\n          progressBar.style.width = '100%';\n          pctLabel.textContent = '100%';\n          // final binary sparkle\n          const bin = document.getElementById('binaryCard');\n          bin.style.boxShadow = '0 26px 44px rgba(6,12,20,0.7), 0 0 40px rgba(107,231,196,0.12)';\n          bin.animate([\n            { transform: 'translateY(-8px) scale(1.02)', boxShadow: '0 26px 44px rgba(6,12,20,0.7)'},\n            { transform: 'translateY(-14px) scale(1.05)', boxShadow: '0 32px 60px rgba(107,231,196,0.18)' },\n            { transform: 'translateY(-8px) scale(1.02)', boxShadow: '0 26px 44px rgba(6,12,20,0.7)'}\n          ], { duration: 900, easing: 'cubic-bezier(.2,.9,.24,1)' });\n\n          // reveal edges if not already\n          astArea.classList.add('active');\n\n          // mark completion\n          compileBtn.textContent = 'Done';\n          compileBtn.style.opacity = '0.9';\n        }, timings.finish));\n\n        // End cleanup: re-enable compile as Replay after a bit\n        timeline.push(setTimeout(()=> {\n          compileBtn.removeAttribute('disabled');\n          compileBtn.textContent = 'Replay';\n          running = false;\n          compileBtn.style.opacity = '1';\n        }, timings.finish + 600));\n      }\n\n      function reset(){\n        // clear timeouts\n        timeline.forEach(clearTimeout);\n        timeline = [];\n        running = false;\n        setActive(false);\n\n        // reset visuals\n        progressBar.style.width = '0%';\n        pctLabel.textContent = '0%';\n        document.querySelectorAll('.token').forEach(t => {\n          // reset by replacing element (stops animation)\n          const clone = t.cloneNode(true);\n          t.parentNode.replaceChild(clone, t);\n        });\n        // reset ast nodes and edges\n        astArea.classList.remove('active');\n        const bin = document.getElementById('binaryCard');\n        bin.style.transform = '';\n        bin.style.boxShadow = '';\n        document.querySelector('.source').style.boxShadow = '';\n        compileBtn.textContent = 'Compile';\n      }\n\n      compileBtn.addEventListener('click', animateCompile);\n      resetBtn.addEventListener('click', reset);\n\n      // initialize subtle entrance animation\n      window.addEventListener('load', ()=> {\n        panel.style.transform = 'translateY(8px)';\n        panel.style.opacity = '0';\n        setTimeout(()=> {\n          panel.style.transition = 'transform .9s cubic-bezier(.2,.9,.24,1), opacity .9s';\n          panel.style.transform = 'translateY(0)';\n          panel.style.opacity = '1';\n        }, 80);\n      });\n\n      // keyboard accessibility: Enter triggers compile\n      compileBtn.addEventListener('keyup', (e) => { if(e.key === 'Enter') animateCompile(); });\n      resetBtn.addEventListener('keyup', (e) => { if(e.key === 'Enter') reset(); });\n\n      // Very small decorative responsive tweak for token start positions\n      function adaptTokens() {\n        const flow = document.querySelector('.flow-area');\n        if(!flow) return;\n        const w = panel.getBoundingClientRect().width;\n        const offsets = [24, 34, 14];\n        flow.querySelectorAll('.token').forEach((t,i)=>{\n          t.style.left = (offsets[i] || 24) + 'px';\n        });\n      }\n      window.addEventListener('resize', adaptTokens);\n      adaptTokens();\n\n      // Provide gentle animation to code lines (observational)\n      const codeLines = document.querySelectorAll('.code-line');\n      codeLines.forEach((ln,i) => {\n        ln.style.transition = 'transform .9s ease, opacity .9s';\n        ln.style.transformOrigin = 'left center';\n        ln.style.opacity = (i===1? '0.98' : '0.85');\n      });\n\n    })();\n  </script>\n</body>\n</html>"
