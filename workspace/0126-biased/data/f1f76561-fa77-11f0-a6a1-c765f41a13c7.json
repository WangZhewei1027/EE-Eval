    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Context Switching — Visual Concept</title>\n<style>\n  :root{\n    --bg1:#071129;\n    --bg2:#081227;\n    --accent1:#6EE7B7;\n    --accent2:#7BD3FF;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --card-glow: rgba(123,210,255,0.12);\n    --shadow: 0 20px 50px rgba(2,6,23,0.6);\n    --glass-border: rgba(255,255,255,0.06);\n    --radius: 18px;\n  }\n\n  /* Reset & base */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: -apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(9,23,54,0.6), transparent 10%),\n                radial-gradient(900px 400px at 90% 80%, rgba(10,30,40,0.55), transparent 10%),\n                linear-gradient(180deg, #041226 0%, #07122a 40%, #041122 100%);\n    color: #eef6ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n  }\n\n  /* Background decorative SVG container */\n  .canvas {\n    position: absolute;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n  }\n\n  /* Stage */\n  .stage {\n    position:relative;\n    z-index:2;\n    width:100%;\n    max-width:1200px;\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:32px;\n    align-items:center;\n    padding:32px;\n  }\n\n  /* Left: Title & description */\n  .panel {\n    padding:28px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(8px) saturate(140%);\n    -webkit-backdrop-filter: blur(8px) saturate(140%);\n    overflow:visible;\n  }\n\n  .title {\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:12px;\n  }\n  .badge {\n    width:68px;\n    height:68px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(123,210,255,0.12), rgba(110,231,183,0.06));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-shrink:0;\n    box-shadow: 0 8px 30px rgba(14,21,40,0.5), 0 2px 6px rgba(123,210,255,0.05) inset;\n    position:relative;\n    overflow:visible;\n  }\n  .badge svg{filter: drop-shadow(0 6px 18px rgba(9,16,35,0.4));}\n\n  h1{\n    font-weight:700;\n    font-size:28px;\n    letter-spacing:-0.02em;\n    margin:0;\n    color: #f5fbff;\n  }\n  p.lead{\n    margin:8px 0 18px 0;\n    color:var(--muted);\n    line-height:1.45;\n  }\n\n  .meta {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    flex-wrap:wrap;\n    margin-top:10px;\n  }\n\n  .pill {\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    padding:8px 12px;\n    border-radius:999px;\n    font-size:13px;\n    color:var(--muted);\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n  }\n\n  .visual {\n    position:relative;\n    height:540px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Card stack */\n  .stack {\n    position:relative;\n    width:460px;\n    height:340px;\n    perspective:1200px;\n    transform-style:preserve-3d;\n    transition: transform 900ms cubic-bezier(.2,.9,.2,1);\n  }\n\n  .context-card {\n    position:absolute;\n    left:50%;\n    top:50%;\n    transform-origin:center;\n    width:380px;\n    height:260px;\n    margin-left:-190px;\n    margin-top:-130px;\n    border-radius:16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 30px 80px rgba(2,8,23,0.6);\n    overflow:hidden;\n    transition: transform 780ms cubic-bezier(.2,.9,.2,1), opacity 520ms ease, filter 780ms cubic-bezier(.2,.9,.2,1);\n    will-change:transform,opacity,filter;\n    display:flex;\n    flex-direction:column;\n    backdrop-filter: blur(6px) saturate(130%);\n  }\n\n  .context-card .top {\n    height:48px;\n    display:flex;\n    align-items:center;\n    gap:12px;\n    padding:10px 14px;\n    border-bottom:1px solid rgba(255,255,255,0.02);\n  }\n  .dot {\n    width:10px;height:10px;border-radius:50%;\n    background:linear-gradient(180deg,#ff6b6b,#ffb08a);\n    box-shadow:0 6px 18px rgba(255,107,107,0.12);\n    margin-right:6px;\n  }\n  .title-small { font-size:13px; color: #eaf7ff; font-weight:600; }\n\n  .content {\n    padding:16px;\n    display:flex;\n    gap:12px;\n    flex:1;\n  }\n\n  /* Faux UI inside cards */\n  .panel-left {\n    width:120px;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n  }\n  .mini {\n    height:14px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n  }\n  .mini.small{height:10px;width:72px}\n  .mini.med{height:12px;width:96px}\n  .mini.tall{height:56px;width:100%}\n  .panel-right {\n    flex:1;\n    display:flex;\n    align-items:flex-start;\n    flex-direction:column;\n    gap:10px;\n  }\n\n  .big-block {\n    flex:1;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(123,210,255,0.04), rgba(110,231,183,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    padding:12px;\n    display:flex;\n    gap:10px;\n  }\n\n  .tag {\n    font-size:12px;\n    color:var(--muted);\n    padding:6px 10px;\n    background:rgba(255,255,255,0.02);\n    border-radius:999px;\n    align-self:flex-start;\n  }\n\n  /* Position states handled by JS classes */\n  .pos-center{ transform: translate3d(0px, -6px, 120px) scale(1) rotateX(8deg);}\n  .pos-left  { transform: translate3d(-220px, 16px, 0px) scale(0.82) rotateY(12deg) rotateX(2deg); opacity:0.9; filter: blur(0.6px) saturate(.9);}\n  .pos-right { transform: translate3d(220px, 18px, 0px) scale(0.82) rotateY(-12deg) rotateX(2deg); opacity:0.9; filter: blur(0.6px) saturate(.9);}\n  .pos-back  { transform: translate3d(0px, 48px, -180px) scale(0.66) rotateX(-10deg); opacity:0.7; filter: blur(1px) saturate(.85); }\n\n  /* Emphasize center card */\n  .context-card.center {\n    box-shadow: 0 40px 120px rgba(4,13,34,0.7), 0 6px 18px rgba(123,210,255,0.06);\n    border: 1px solid rgba(123,210,255,0.08);\n  }\n\n  /* small indicators */\n  .indicator {\n    position:absolute;\n    bottom:18px;\n    left:50%;\n    transform:translateX(-50%);\n    display:flex;\n    gap:8px;\n    z-index:6;\n  }\n  .dot-ind {\n    width:10px;height:10px;border-radius:50%;\n    background:rgba(255,255,255,0.04);\n    transition: transform 360ms cubic-bezier(.2,.9,.2,1), background 360ms;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .dot-ind.active {\n    width:36px;\n    border-radius:99px;\n    background: linear-gradient(90deg,var(--accent2), var(--accent1));\n    box-shadow: 0 8px 30px rgba(123,210,255,0.12), 0 2px 6px rgba(110,231,183,0.05);\n    transform:translateY(-6px);\n  }\n\n  /* tiny animated context label */\n  .context-label {\n    position:absolute;\n    right:18px;\n    top:18px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    padding:8px 12px;\n    border-radius:12px;\n    font-size:13px;\n    color:var(--muted);\n    display:flex;\n    gap:10px;\n    align-items:center;\n    z-index:8;\n  }\n\n  /* controls */\n  .controls {\n    position:absolute;\n    right:36px;\n    bottom:36px;\n    display:flex;\n    gap:12px;\n    z-index:9;\n  }\n  .btn {\n    width:64px;\n    height:64px;\n    border-radius:16px;\n    display:inline-grid;\n    place-items:center;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6);\n    cursor:pointer;\n    transition: transform 220ms cubic-bezier(.2,.9,.2,1), box-shadow 220ms;\n  }\n  .btn:active{ transform: translateY(2px) }\n  .btn svg{ filter: drop-shadow(0 8px 18px rgba(2,10,28,0.65)); }\n\n  .btn.play { width:78px;height:78px;border-radius:20px;background:linear-gradient(135deg,var(--accent2), #5ee6a8); box-shadow: 0 18px 60px rgba(15,32,59,0.66);}\n  .btn.play svg{ filter: drop-shadow(0 10px 30px rgba(12,47,60,0.45)); }\n\n  /* subtle floating motion for center card */\n  @keyframes floaty {\n    0% { transform: translate3d(0px,-6px,120px) scale(1) rotateX(8deg); }\n    50% { transform: translate3d(0px,-12px,120px) scale(1.007) rotateX(7.7deg); }\n    100% { transform: translate3d(0px,-6px,120px) scale(1) rotateX(8deg); }\n  }\n\n  /* small responsive tweaks */\n  @media (max-width:1100px){\n    .stage{ grid-template-columns:1fr; gap:20px; align-items:center }\n    .visual{ order:-1; height:480px }\n    .stack{ width:360px; height:300px }\n    .context-card{ width:320px; height:240px; margin-left:-160px; margin-top:-120px;}\n    .controls{ right:20px; bottom:16px }\n  }\n\n  /* tiny animated ephemeral glow */\n  .glow {\n    position:absolute;\n    inset: -20%;\n    background: radial-gradient(closest-side, rgba(123,210,255,0.06), transparent 25%), radial-gradient(closest-side, rgba(123,150,255,0.03), transparent 30%);\n    filter: blur(30px);\n    z-index:0;\n    pointer-events:none;\n    opacity:0.9;\n    transition:opacity 600ms;\n  }\n\n  /* micro interaction hover */\n  .panel:hover .badge{ transform: translateY(-6px) rotate(-6deg); transition: transform 520ms cubic-bezier(.2,.9,.2,1) }\n  .panel:hover .stack{ transform: translateY(-6px) }\n\n  /* tiny captions */\n  .caption {\n    margin-top:12px;\n    color:rgba(255,255,255,0.45);\n    font-size:13px;\n  }\n\n  /* Decorative connecting lines */\n  .connector {\n    position:absolute;\n    left:0;right:0;top:0;bottom:0;\n    pointer-events:none;\n  }\n\n  /* smooth text appearance for the animated label */\n  .label-pulse {\n    animation: labelPulse 4200ms linear infinite;\n    display:inline-block;\n  }\n  @keyframes labelPulse {\n    0%,30% { opacity:0; transform:translateY(-4px) scale(.98) }\n    40% { opacity:1; transform:translateY(0px) scale(1) }\n    70% { opacity:1; transform:translateY(0px) scale(1) }\n    100% { opacity:0; transform:translateY(-6px) scale(.98) }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"canvas\" aria-hidden=\"true\">\n    <!-- Decorative SVG waves and nodes -->\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 1600 900\" preserveAspectRatio=\"none\" style=\"position:absolute; inset:0; z-index:1;\">\n      <defs>\n        <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#0e2540\" stop-opacity=\"0.8\"/>\n          <stop offset=\"1\" stop-color=\"#062233\" stop-opacity=\"0.6\"/>\n        </linearGradient>\n        <filter id=\"blurMe\" x=\"-100%\" y=\"-100%\" width=\"300%\" height=\"300%\">\n          <feGaussianBlur stdDeviation=\"50\" />\n        </filter>\n      </defs>\n      <g opacity=\"0.75\" filter=\"url(#blurMe)\">\n        <path d=\"M0 220 C220 120 420 400 760 260 C1100 120 1300 420 1600 260 L1600 900 L0 900 Z\" fill=\"#08324a\"></path>\n        <path d=\"M0 480 C240 380 460 640 840 540 C1220 440 1400 740 1600 620 L1600 900 L0 900 Z\" fill=\"#052035\"></path>\n      </g>\n      <!-- floating nodes -->\n      <g fill=\"none\" stroke=\"rgba(123,210,255,0.06)\" stroke-width=\"1.2\">\n        <circle cx=\"140\" cy=\"140\" r=\"60\" />\n        <circle cx=\"300\" cy=\"80\" r=\"44\" />\n        <circle cx=\"1100\" cy=\"90\" r=\"72\" />\n        <circle cx=\"1360\" cy=\"200\" r=\"42\" />\n      </g>\n    </svg>\n    <!-- Soft highlight -->\n    <div class=\"glow\" style=\"mix-blend-mode:screen\"></div>\n  </div>\n\n  <main class=\"stage\" role=\"main\">\n    <section class=\"panel\" aria-labelledby=\"title\">\n      <div class=\"title\">\n        <div class=\"badge\" aria-hidden=\"true\">\n          <!-- abstract brain / nodes icon -->\n          <svg width=\"40\" height=\"40\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"s\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7BD3FF\"/><stop offset=\"1\" stop-color=\"#6EE7B7\"/></linearGradient>\n            </defs>\n            <g fill=\"url(#s)\">\n              <path d=\"M46 18a4 4 0 100-8 4 4 0 000 8zM20 10a4 4 0 110 8 4 4 0 010-8zM10 36a4 4 0 100-8 4 4 0 000 8zM54 40a4 4 0 11-8 0 4 4 0 018 0zM34 54a4 4 0 110 8 4 4 0 010-8z\"/>\n            </g>\n          </svg>\n        </div>\n        <div>\n          <h1 id=\"title\">Context Switching</h1>\n          <p class=\"lead\">A visual exploration of how attention and interfaces shift — cards and ideas sliding into focus, depth and motion conveying transitions between mental and workspace contexts.</p>\n        </div>\n      </div>\n\n      <div class=\"meta\" role=\"list\">\n        <div class=\"pill\" role=\"listitem\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><path d=\"M5 12h14M12 5v14\" stroke=\"rgba(255,255,255,0.85)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></path></svg>\n          Layered Perspectives\n        </div>\n        <div class=\"pill\" role=\"listitem\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><path d=\"M3 12h18M12 3v18\" stroke=\"rgba(255,255,255,0.85)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></path></svg>\n          Smooth Transitions\n        </div>\n        <div class=\"pill\" role=\"listitem\">Minimal Controls</div>\n      </div>\n\n      <p class=\"caption\">Observe the stack: contexts move forward, recede, and transform. Use the play/pause control to pause motion, or reset to return to the beginning.</p>\n    </section>\n\n    <section class=\"visual\" aria-hidden=\"false\">\n      <div class=\"stack\" id=\"stack\" role=\"group\" aria-label=\"Context stack visualization\">\n        <!-- Context cards -->\n        <div class=\"context-card pos-back\" data-index=\"0\" id=\"card-0\">\n          <div class=\"top\">\n            <div class=\"dot\" style=\"background: linear-gradient(180deg,#ffb86b,#ff6b6b)\"></div>\n            <div class=\"title-small\">Workspace • Research</div>\n            <div style=\"flex:1\"></div>\n            <div class=\"tag\" style=\"font-size:12px;color:rgba(255,255,255,0.65);\">23m</div>\n          </div>\n          <div class=\"content\">\n            <div class=\"panel-left\">\n              <div class=\"mini med\"></div>\n              <div class=\"mini small\"></div>\n              <div class=\"mini tall\"></div>\n            </div>\n            <div class=\"panel-right\">\n              <div class=\"big-block\">\n                <!-- faux article lines -->\n                <div style=\"flex:1; display:flex; flex-direction:column; gap:8px;\">\n                  <div style=\"height:12px; width:60%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\"></div>\n                  <div style=\"height:10px; width:90%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\"></div>\n                  <div style=\"height:10px; width:84%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\"></div>\n                  <div style=\"height:10px; width:40%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\"></div>\n                </div>\n                <div style=\"width:64px; height:64px; border-radius:10px; background:linear-gradient(135deg,#0ea5b7,#7bd3ff);\"></div>\n              </div>\n              <div style=\"display:flex; gap:8px;\">\n                <div class=\"tag\">notes.md</div>\n                <div class=\"tag\">research</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"context-card pos-left\" data-index=\"1\" id=\"card-1\">\n          <div class=\"top\">\n            <div class=\"dot\" style=\"background: linear-gradient(180deg,#7bd3ff,#6ee7b7)\"></div>\n            <div class=\"title-small\">Inbox • Messaging</div>\n            <div style=\"flex:1\"></div>\n            <div class=\"tag\" style=\"font-size:12px;color:rgba(255,255,255,0.65);\">2m</div>\n          </div>\n          <div class=\"content\">\n            <div class=\"panel-left\">\n              <div class=\"mini med\"></div>\n              <div class=\"mini small\"></div>\n              <div class=\"mini tall\"></div>\n            </div>\n            <div class=\"panel-right\">\n              <div class=\"big-block\" style=\"background:linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.006));\">\n                <div style=\"display:flex; gap:8px; flex-direction:column; width:100%;\">\n                  <div style=\"display:flex; gap:8px; align-items:center;\">\n                    <div style=\"width:36px; height:36px; border-radius:8px; background:linear-gradient(90deg,#ffd1a8,#ff8fa3)\"></div>\n                    <div style=\"flex:1;\">\n                      <div style=\"height:10px; width:50%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\"></div>\n                      <div style=\"height:8px; width:80%; margin-top:6px; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\"></div>\n                    </div>\n                  </div>\n                  <div style=\"display:flex; gap:8px; align-items:center;\">\n                    <div style=\"width:36px; height:36px; border-radius:8px; background:linear-gradient(90deg,#b6ffef,#7bd3ff)\"></div>\n                    <div style=\"flex:1;\">\n                      <div style=\"height:10px; width:70%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\"></div>\n                      <div style=\"height:8px; width:60%; margin-top:6px; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\"></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div style=\"display:flex; gap:8px;\">\n                <div class=\"tag\">chat</div>\n                <div class=\"tag\">team</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"context-card pos-center center\" data-index=\"2\" id=\"card-2\" style=\"animation: floaty 4200ms ease-in-out infinite;\">\n          <div class=\"top\">\n            <div class=\"dot\" style=\"background: linear-gradient(180deg,#7be3ff,#6EE7B7)\"></div>\n            <div class=\"title-small\">Editor • Focus</div>\n            <div style=\"flex:1\"></div>\n            <div class=\"tag\" style=\"font-size:12px;color:rgba(255,255,255,0.78);\">active</div>\n          </div>\n          <div class=\"content\">\n            <div class=\"panel-left\">\n              <div class=\"mini med\"></div>\n              <div class=\"mini small\"></div>\n              <div class=\"mini tall\"></div>\n            </div>\n            <div class=\"panel-right\">\n              <div class=\"big-block\" style=\"background:linear-gradient(135deg, rgba(123,210,255,0.04), rgba(110,231,183,0.02)); border: 1px solid rgba(255,255,255,0.02);\">\n                <div style=\"display:flex; gap:8px; align-items:flex-start; width:100%;\">\n                  <div style=\"width:38px; height:38px; border-radius:8px; background:linear-gradient(135deg,#7bd3ff,#6ee7b7); box-shadow:0 8px 30px rgba(123,210,255,0.08)\"></div>\n                  <div style=\"flex:1; display:flex; flex-direction:column; gap:8px;\">\n                    <div style=\"height:10px; width:42%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\"></div>\n                    <div style=\"height:12px; width:100%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\"></div>\n                    <div style=\"height:8px; width:86%; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\"></div>\n                  </div>\n                </div>\n              </div>\n              <div style=\"display:flex; gap:8px;\">\n                <div class=\"tag\">editor</div>\n                <div class=\"tag\">writing</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"context-card pos-right\" data-index=\"3\" id=\"card-3\">\n          <div class=\"top\">\n            <div class=\"dot\" style=\"background: linear-gradient(180deg,#c88cff,#a58bff)\"></div>\n            <div class=\"title-small\">Playback • Media</div>\n            <div style=\"flex:1\"></div>\n            <div class=\"tag\" style=\"font-size:12px;color:rgba(255,255,255,0.65);\">5s</div>\n          </div>\n          <div class=\"content\">\n            <div class=\"panel-left\">\n              <div class=\"mini med\"></div>\n              <div class=\"mini small\"></div>\n              <div class=\"mini tall\"></div>\n            </div>\n            <div class=\"panel-right\">\n              <div class=\"big-block\" style=\"background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\">\n                <div style=\"width:100%; height:100%; display:flex; align-items:center; justify-content:center;\">\n                  <svg width=\"76\" height=\"76\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"filter: drop-shadow(0 12px 30px rgba(168,122,255,0.08));\">\n                    <rect width=\"24\" height=\"24\" rx=\"6\" fill=\"#B28BFF\"></rect>\n                    <path d=\"M9 8v8l6-4-6-4z\" fill=\"white\"></path>\n                  </svg>\n                </div>\n              </div>\n              <div style=\"display:flex; gap:8px;\">\n                <div class=\"tag\">video</div>\n                <div class=\"tag\">review</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"indicator\" id=\"indicator\">\n          <div class=\"dot-ind\" data-i=\"0\"></div>\n          <div class=\"dot-ind\" data-i=\"1\"></div>\n          <div class=\"dot-ind active\" data-i=\"2\"></div>\n          <div class=\"dot-ind\" data-i=\"3\"></div>\n        </div>\n\n        <div class=\"context-label\" id=\"contextLabel\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" style=\"opacity:0.9; margin-right:6px;\"><path d=\"M12 2v20M2 12h20\" stroke=\"rgba(255,255,255,0.8)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/></svg>\n          <div style=\"display:flex; flex-direction:column;\">\n            <span style=\"font-size:12px; color:#eaf7ff; font-weight:700\">Active Context</span>\n            <span class=\"label-pulse\" id=\"labelPulse\" style=\"font-size:11px; color:var(--muted)\">Editor • Focus</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button class=\"btn play\" id=\"playBtn\" title=\"Pause animation\" aria-pressed=\"false\" aria-label=\"Pause animation\">\n          <svg id=\"playIcon\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M5 3v18l15-9L5 3z\" fill=\"#042233\"></path>\n          </svg>\n        </button>\n        <button class=\"btn\" id=\"resetBtn\" title=\"Reset to first context\" aria-label=\"Reset contexts\">\n          <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M21 10v6a2 2 0 0 1-2 2H9\" stroke=\"#dbefff\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n            <path d=\"M21 10l-4-4M3 14V8a5 5 0 0 1 5-5h3\" stroke=\"#dbefff\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n          </svg>\n        </button>\n      </div>\n\n    </section>\n  </main>\n\n<script>\n(function(){\n  // Basic context switcher with minimal controls (play/pause & reset)\n  const cards = Array.from(document.querySelectorAll('.context-card'));\n  const indicatorDots = Array.from(document.querySelectorAll('.dot-ind'));\n  const label = document.getElementById('labelPulse');\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const playIcon = document.getElementById('playIcon');\n\n  let active = 2; // start with center card\n  let running = true;\n  let interval = 3000;\n  let timer = null;\n\n  // labels for contexts\n  const labels = [\n    \"Workspace • Research\",\n    \"Inbox • Messaging\",\n    \"Editor • Focus\",\n    \"Playback • Media\"\n  ];\n\n  function applyPositions(activeIndex){\n    // compute positions relative to active\n    const len = cards.length;\n    // mapping: previous, current, next, back\n    // We'll build an array of positions for each index\n    for(let i=0;i<len;i++){\n      const el = cards[i];\n      el.classList.remove('pos-left','pos-right','pos-center','pos-back','center');\n      el.style.zIndex = 10; // default\n    }\n\n    // center\n    const centerEl = cards[activeIndex];\n    centerEl.classList.add('pos-center','center');\n    centerEl.style.zIndex = 50;\n\n    // left: previous element (wrap)\n    const leftIndex = (activeIndex - 1 + len) % len;\n    const rightIndex = (activeIndex + 1) % len;\n    const backIndex = (activeIndex + 2) % len;\n\n    cards[leftIndex].classList.add('pos-left');\n    cards[leftIndex].style.zIndex = 30;\n    cards[rightIndex].classList.add('pos-right');\n    cards[rightIndex].style.zIndex = 30;\n    cards[backIndex].classList.add('pos-back');\n    cards[backIndex].style.zIndex = 10;\n\n    // update indicators\n    indicatorDots.forEach(d => {\n      d.classList.toggle('active', parseInt(d.dataset.i,10) === activeIndex);\n    });\n\n    // update label text\n    label.textContent = labels[activeIndex] || '';\n  }\n\n  function next(){\n    active = (active + 1) % cards.length;\n    applyPositions(active);\n  }\n\n  function start(){\n    if(timer) return;\n    timer = setInterval(next, interval);\n    running = true;\n    playBtn.setAttribute('aria-pressed','false');\n    playBtn.title = \"Pause animation\";\n    // show pause icon (we use play icon as triangle; toggle to pause)\n    playIcon.innerHTML = '<path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"#052233\"></path>';\n  }\n\n  function stop(){\n    if(timer){ clearInterval(timer); timer = null; }\n    running = false;\n    playBtn.setAttribute('aria-pressed','true');\n    playBtn.title = \"Play animation\";\n    playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"#042233\"></path>';\n  }\n\n  // toggle on click\n  playBtn.addEventListener('click', function(){\n    if(running) stop(); else start();\n    // subtle bounce\n    playBtn.animate([\n      { transform: 'scale(1)' },\n      { transform: 'scale(0.92)' },\n      { transform: 'scale(1)' }\n    ], { duration: 280, easing: 'cubic-bezier(.2,.9,.2,1)' });\n  });\n\n  resetBtn.addEventListener('click', function(){\n    active = 0;\n    applyPositions(active);\n    // briefly pause the animation to emphasize reset\n    stop();\n    setTimeout(() => start(), 1200);\n    // subtle feedback\n    resetBtn.animate([{ transform:'translateY(0)'},{ transform:'translateY(2px)'},{ transform:'translateY(0)'}], { duration: 260 });\n  });\n\n  // allow small keyboard control: Space toggles (but nothing else)\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){\n      e.preventDefault();\n      playBtn.click();\n    }\n  });\n\n  // initial\n  applyPositions(active);\n  start();\n\n  // subtle automatic slow rotation for parallax glance\n  const stack = document.getElementById('stack');\n  let mx = 0, my = 0;\n  function onMove(e){\n    const rect = stack.getBoundingClientRect();\n    const cx = rect.left + rect.width/2;\n    const cy = rect.top + rect.height/2;\n    const clientX = e.touches ? e.touches[0].clientX : e.clientX;\n    const clientY = e.touches ? e.touches[0].clientY : e.clientY;\n    const dx = (clientX - cx) / rect.width;\n    const dy = (clientY - cy) / rect.height;\n    mx = dx * 8; my = dy * 8;\n    stack.style.transform = `rotateY(${mx}deg) rotateX(${-my}deg) translateZ(0)`;\n  }\n  // gentle follow on mouse move\n  window.addEventListener('mousemove', function(e){\n    onMove(e);\n  });\n  window.addEventListener('touchmove', function(e){\n    onMove(e);\n  }, {passive:true});\n\n  // idle restoration to neutral\n  let idleTimeout;\n  function resetTilt(){\n    stack.style.transform = '';\n    mx=0; my=0;\n  }\n  window.addEventListener('mousemove', ()=>{\n    clearTimeout(idleTimeout);\n    idleTimeout = setTimeout(resetTilt, 1200);\n  });\n\n  // accessibility: announce active context via title attribute as it changes\n  const contextLabel = document.getElementById('contextLabel');\n  const observer = new MutationObserver(()=> {\n    contextLabel.setAttribute('aria-live','polite');\n    contextLabel.setAttribute('title', label.textContent);\n  });\n  observer.observe(label, {childList:true, characterData:true, subtree:true});\n})();\n</script>\n</body>\n</html>"
