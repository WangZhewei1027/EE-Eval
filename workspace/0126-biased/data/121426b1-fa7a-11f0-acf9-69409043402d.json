  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Exponential Search Interactive Demo</title>\n<style>\n  body { margin: 1em; font-family: monospace, monospace; background: white; color: black; }\n  input, button, select { font-family: monospace, monospace; margin: 0.2em 0; }\n  textarea { font-family: monospace, monospace; width: 100%; height: 7em; }\n  #log { width: 100%; height: 12em; overflow-y: scroll; border: 1px solid #000; white-space: pre-wrap; }\n  label { display: block; margin-top: 0.9em; }\n  fieldset { margin-bottom: 1em; }\n  .inline { display: inline-block; margin-right: 1em; }\n</style>\n</head>\n<body>\n\n<h1>Exponential Search Interactive Demo</h1>\n\n<p>\nThis tool lets you <b>explore, build, and run</b> the Exponential Search algorithm step-by-step on a sorted array.\nYou can input your own array, adjust the value to search, control the search speed, step through each phase, and experiment with different binary search variants used in the algorithm.\n</p>\n\n<form id=\"configForm\" onsubmit=\"return false;\">\n  <fieldset>\n    <legend>1. Input Array (Sorted, ascending)</legend>\n    <label for=\"arrayInput\">Enter numbers separated by commas, spaces, or new lines:</label>\n    <textarea id=\"arrayInput\" aria-label=\"Input array\" placeholder=\"e.g. 1, 3, 5, 7, 9, 11\"></textarea>\n    <button id=\"loadArray\">Load Array</button>\n    <div id=\"arrayValidationMsg\" aria-live=\"polite\" style=\"color: red; font-weight: bold;\"></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>2. Search Value and Settings</legend>\n    <label for=\"searchValue\">Value to Find:</label>\n    <input id=\"searchValue\" type=\"number\" aria-label=\"Value to search\" />\n    <label for=\"delaySlider\" class=\"inline\">Auto-play Step Delay (ms):</label>\n    <input id=\"delaySlider\" type=\"range\" min=\"100\" max=\"2000\" step=\"100\" value=\"500\" aria-label=\"Step delay slider\" class=\"inline\" />\n    <span id=\"delayValue\" class=\"inline\">500</span> ms\n    <br/>\n    <label for=\"binaryVariant\">Binary Search Variant used in Exponential Search:</label>\n    <select id=\"binaryVariant\" aria-label=\"Binary search variant\">\n      <option value=\"standard\">Standard Binary Search</option>\n      <option value=\"first-occurrence\">Find First Occurrence</option>\n      <option value=\"last-occurrence\">Find Last Occurrence</option>\n    </select>\n  </fieldset>\n\n  <fieldset>\n    <legend>3. Controls</legend>\n    <button id=\"resetAll\" type=\"button\">Reset All</button>\n    <button id=\"startSearch\" type=\"button\" disabled>Start Search</button>\n    <button id=\"autoPlay\" type=\"button\" disabled>Auto-Play: Off</button>\n    <button id=\"stepForward\" type=\"button\" disabled>Step Forward ▶</button>\n    <button id=\"stepBackward\" type=\"button\" disabled>Step Back ◀</button>\n  </fieldset>\n</form>\n\n<fieldset>\n  <legend>4. Current Array State</legend>\n  <pre id=\"arrayDisplay\" aria-live=\"polite\" style=\"white-space: pre-wrap;\">(No array loaded)</pre>\n</fieldset>\n\n<fieldset>\n  <legend>5. Search Visualization and Logs</legend>\n  <pre id=\"searchState\" aria-live=\"polite\" style=\"min-height: 8em;\">(No search started)</pre>\n  <div id=\"log\" aria-live=\"polite\">(Logs will appear here)</div>\n</fieldset>\n\n<fieldset>\n  <legend>6. Explore & Experiment</legend>\n  <p>\n    <b>Interactive Workflow:</b> \n    <ul>\n      <li>Load a valid sorted array.</li>\n      <li>Set the target value and select binary search variant.</li>\n      <li>Click <i>Start Search</i> to begin the Exponential Search step-through.</li>\n      <li>Use <i>Step Forward</i> and <i>Step Backward</i> to explore each detailed step or <i>Auto-Play</i> to run automatically.</li>\n      <li>Modify parameters mid-search and <i>Reset All</i> to restart fresh.</li>\n    </ul>\n  </p>\n</fieldset>\n\n<script>\n(function(){\n  // Elements references\n  const arrayInput = document.getElementById('arrayInput');\n  const loadArrayBtn = document.getElementById('loadArray');\n  const arrayValidationMsg = document.getElementById('arrayValidationMsg');\n  const arrayDisplay = document.getElementById('arrayDisplay');\n\n  const searchValueInput = document.getElementById('searchValue');\n  const delaySlider = document.getElementById('delaySlider');\n  const delayValue = document.getElementById('delayValue');\n  const binaryVariantSelect = document.getElementById('binaryVariant');\n\n  const resetAllBtn = document.getElementById('resetAll');\n  const startSearchBtn = document.getElementById('startSearch');\n  const autoPlayBtn = document.getElementById('autoPlay');\n  const stepForwardBtn = document.getElementById('stepForward');\n  const stepBackwardBtn = document.getElementById('stepBackward');\n\n  const searchStatePre = document.getElementById('searchState');\n  const logDiv = document.getElementById('log');\n\n  // Core data state\n  let dataArray = [];\n  let searchValue = null;\n  let binaryVariant = 'standard';\n  let stepDelay = 500;\n\n  // Search internal states and history for stepping\n  let steps = [];\n  let currentStepIndex = -1;\n  let autoPlayTimer = null;\n\n  // Search stages enumeration\n  const Stage = {\n    INIT: 'Init',\n    EXP_STEP_CHECK: 'Exponential Step Check',\n    EXP_STEP_FOUND_RANGE: 'Exponential Found Range',\n    BINARY_SEARCH: 'Binary Search',\n    FINISHED: 'Finished',\n  };\n\n  // Step record schema: \n  // {\n  //   stage: string,\n  //   description: string,\n  //   indices: {low?, high?, i?, range?},\n  //   log: string,\n  //   highlight: function or null (to generate contextual text),\n  //   resultIndex: number|null (final found index),\n  // }\n\n  // Helper for logging with history capture\n  function logStep(step) {\n    steps.push(step);\n  }\n\n  // Utility to parse input array and validate sorted ascending integers\n  function parseAndValidateArray(text) {\n    let raw = text.trim();\n    if(raw === '') return {valid:false, reason:'Array cannot be empty.'};\n    // Split by comma, spaces, new lines\n    let parts = raw.split(/[\\s,]+/);\n    let nums = [];\n    for(let p of parts){\n      if(p === '') continue;\n      let n = Number(p);\n      if(isNaN(n) || !Number.isFinite(n)){\n        return {valid:false, reason: 'All inputs must be valid finite numbers.'};\n      }\n      nums.push(n);\n    }\n    if(nums.length === 0) return {valid:false, reason:'Array cannot be empty.'};\n    // Check sorted ascending\n    for(let i=1; i<nums.length; ++i){\n      if(nums[i] < nums[i-1]){\n        return {valid:false, reason:'Array must be sorted in ascending order (non-decreasing).'};\n      }\n    }\n    return {valid:true, array: nums};\n  }\n\n  // Display array with highlighting on indices, highlight options:\n  // {highlightIndices: Set} or null\n  function displayArray(arr, highlightIndices){\n    if(!arr || arr.length === 0) return '(Empty array)';\n    let out = '';\n    for(let i=0; i<arr.length; i++){\n      let s = arr[i].toString();\n      if(highlightIndices && highlightIndices.has(i)){\n        s = '[' + s + ']';\n      }\n      out += s + (i === arr.length - 1 ? '' : ', ');\n    }\n    return out;\n  }\n\n  // Clear all steps and visualizations\n  function resetSearch(){\n    steps = [];\n    currentStepIndex = -1;\n    clearTimeout(autoPlayTimer);\n    autoPlayTimer = null;\n    startSearchBtn.disabled = (dataArray.length === 0);\n    autoPlayBtn.disabled = true;\n    stepForwardBtn.disabled = true;\n    stepBackwardBtn.disabled = true;\n    searchStatePre.textContent = '(No search started)';\n    logDiv.textContent = '(Logs will appear here)';\n  }\n\n  // Update delay value display\n  delaySlider.addEventListener('input', ()=>{\n    stepDelay = Number(delaySlider.value);\n    delayValue.textContent = stepDelay;\n  });\n\n  // Load array button handler\n  loadArrayBtn.addEventListener('click', e=>{\n    e.preventDefault();\n    const input = arrayInput.value;\n    let validation = parseAndValidateArray(input);\n    if(!validation.valid){\n      arrayValidationMsg.textContent = validation.reason;\n      dataArray = [];\n      arrayDisplay.textContent = '(No array loaded)';\n      resetSearch();\n      startSearchBtn.disabled = true;\n      return;\n    }\n    arrayValidationMsg.textContent = '';\n    dataArray = validation.array;\n    arrayDisplay.textContent = displayArray(dataArray, null);\n    resetSearch();\n    startSearchBtn.disabled = false;\n  });\n\n  // Reset all button clears everything\n  resetAllBtn.addEventListener('click', e=>{\n    e.preventDefault();\n    arrayInput.value = '';\n    searchValueInput.value = '';\n    binaryVariantSelect.value = 'standard';\n    delaySlider.value = 500;\n    delayValue.textContent = '500';\n    dataArray = [];\n    searchValue = null;\n    arrayValidationMsg.textContent = '';\n    arrayDisplay.textContent = '(No array loaded)';\n    resetSearch();\n  });\n\n  // Search value change handler (just store number if valid)\n  searchValueInput.addEventListener('input', ()=>{\n    let val = searchValueInput.value;\n    if(val === '') {\n      searchValue = null;\n    } else {\n      let n = Number(val);\n      searchValue = Number.isFinite(n) ? n : null;\n    }\n  });\n\n  // Update binary variant immediately\n  binaryVariantSelect.addEventListener('change', ()=>{\n    binaryVariant = binaryVariantSelect.value;\n  });\n\n  // Disable or enable controls during searching\n  function setControlsDuringSearch(isRunning){\n    loadArrayBtn.disabled = isRunning;\n    arrayInput.disabled = isRunning;\n    searchValueInput.disabled = isRunning;\n    binaryVariantSelect.disabled = isRunning;\n    startSearchBtn.disabled = isRunning;\n    resetAllBtn.disabled = isRunning;\n  }\n\n  // Display current step state in searchStatePre and logDiv, highlight array elements\n   \n  function renderCurrentStep(){\n    if(currentStepIndex < 0 || currentStepIndex >= steps.length){\n      searchStatePre.textContent = '(No step to display)';\n      logDiv.textContent = '(Logs will appear here)';\n      arrayDisplay.textContent = displayArray(dataArray, null);\n      stepForwardBtn.disabled = true;\n      stepBackwardBtn.disabled = currentStepIndex <= 0;\n      return;\n    }\n    let step = steps[currentStepIndex];\n    searchStatePre.textContent = step.description;\n    logDiv.textContent = step.log || '';\n\n    // Highlight indices on array display\n    if(step.highlightIndices){\n      arrayDisplay.textContent = displayArray(dataArray, step.highlightIndices);\n    } else {\n      arrayDisplay.textContent = displayArray(dataArray, null);\n    }\n\n    stepForwardBtn.disabled = (currentStepIndex >= steps.length - 1);\n    stepBackwardBtn.disabled = (currentStepIndex <= 0);\n\n  }\n\n  // Advance one step forward (if any)\n  function stepForward(){\n    if(currentStepIndex < steps.length -1 ) {\n      currentStepIndex++;\n      renderCurrentStep();\n    }\n  }\n\n  // Step one backward\n  function stepBackward(){\n    if(currentStepIndex > 0) {\n      currentStepIndex--;\n      renderCurrentStep();\n    }\n  }\n\n  stepForwardBtn.addEventListener('click', e=>{ e.preventDefault(); stepForward(); });\n  stepBackwardBtn.addEventListener('click', e=>{ e.preventDefault(); stepBackward(); });\n\n  // Auto play toggle\n  autoPlayBtn.addEventListener('click', e=>{\n    e.preventDefault();\n    if(autoPlayTimer) {\n      // Stop auto play\n      clearTimeout(autoPlayTimer);\n      autoPlayTimer = null;\n      autoPlayBtn.textContent = 'Auto-Play: Off';\n      setControlsDuringSearch(false);\n      stepForwardBtn.disabled = (currentStepIndex >= steps.length - 1);\n      stepBackwardBtn.disabled = (currentStepIndex <= 0);\n      startSearchBtn.disabled = false;\n    } else {\n      // Start auto play from current or next step\n      setControlsDuringSearch(true);\n      autoPlayBtn.textContent = 'Auto-Play: On';\n      startSearchBtn.disabled = true;\n      stepForwardBtn.disabled = true;\n      stepBackwardBtn.disabled = true;\n      autoPlayStep();\n    }\n  });\n\n  function autoPlayStep(){\n    if(currentStepIndex < steps.length -1) {\n      currentStepIndex++;\n      renderCurrentStep();\n      autoPlayTimer = setTimeout(autoPlayStep, stepDelay);\n    } else {\n      // End autoplay\n      autoPlayTimer = null;\n      autoPlayBtn.textContent = 'Auto-Play: Off';\n      setControlsDuringSearch(false);\n      stepForwardBtn.disabled = (currentStepIndex >= steps.length - 1);\n      stepBackwardBtn.disabled = (currentStepIndex <= 0);\n      startSearchBtn.disabled = false;\n    }\n  }\n\n  // Exponential Search implementation with step-by-step logging and all possible detailed steps\n  // Will push each step into steps array with data for visualization and stepping\n\n  // Internal binary search variants for the binary search phase\n  // Standard: first found index of the value (any occurrence)\n  // First-occurrence: leftmost occurrence\n  // Last-occurrence: rightmost occurrence\n  function binarySearch(arr, val, low, high, variant, addStep){\n    let left = low;\n    let right = high;\n    addStep({\n      stage: Stage.BINARY_SEARCH,\n      description: `Binary Search started on range [${left} .. ${right}]`,\n      highlightIndices: new Set(),\n      log: `Beginning binary search for value ${val} in range [${low} .. ${high}].`,\n    });\n\n    let found = -1;\n    while(left <= right){\n      let mid = Math.floor((left + right) / 2);\n      addStep({\n        stage: Stage.BINARY_SEARCH,\n        description: `Checking middle element arr[${mid}] = ${arr[mid]}`,\n        highlightIndices: new Set([mid]),\n        log: `Compare search value ${val} with arr[${mid}] = ${arr[mid]}.`,\n      });\n      if(arr[mid] === val){\n        found = mid;\n        addStep({\n          stage: Stage.BINARY_SEARCH,\n          description: `Found value at index ${mid}.`,\n          highlightIndices: new Set([mid]),\n          log: `Value matched at index ${mid}.`,\n        });\n        // If standard binary, stop immediately\n        if(variant === 'standard'){\n          return found;\n        } else if (variant === 'first-occurrence'){\n          // Continue searching left to find the first occurrence\n          right = mid - 1;\n        } else if (variant === 'last-occurrence'){\n          // Continue searching right to find the last occurrence\n          left = mid + 1;\n        }\n      } else if(val < arr[mid]){\n        addStep({\n          stage: Stage.BINARY_SEARCH,\n          description: `Value less than arr[${mid}], narrowing to left half.`,\n          highlightIndices: new Set(),\n          log: `Value ${val} < ${arr[mid]}. Narrow search to left subarray.`,\n        });\n        right = mid -1;\n      } else {\n        addStep({\n          stage: Stage.BINARY_SEARCH,\n          description: `Value greater than arr[${mid}], narrowing to right half.`,\n          highlightIndices: new Set(),\n          log: `Value ${val} > ${arr[mid]}. Narrow search to right subarray.`,\n        });\n        left = mid + 1;\n      }\n      // Show current search bounds at every iteration end\n      addStep({\n        stage: Stage.BINARY_SEARCH,\n        description: `Binary Search bounds now [${left} .. ${right}]`,\n        highlightIndices: new Set(),\n        log: `Continue search in index range [${left} .. ${right}].`,\n      });\n    }\n    if(found !== -1){\n      addStep({\n        stage: Stage.BINARY_SEARCH,\n        description: `Search complete. Final found index is ${found}.`,\n        highlightIndices: new Set([found]),\n        log: `Binary search complete with final index ${found}.`,\n      });\n    } else {\n      addStep({\n        stage: Stage.BINARY_SEARCH,\n        description: `Search complete. Value NOT found in range.`,\n        highlightIndices: new Set(),\n        log: `Binary search complete without finding value ${val}.`,\n      });\n    }\n    return found;\n  }\n\n  // Exponential search main function, sets up steps\n  function exponentialSearch(arr, val, variant){\n    steps = [];\n    currentStepIndex = -1;\n    if(arr.length === 0){\n      steps.push({\n        stage: Stage.INIT,\n        description: 'Array is empty, nothing to search.',\n        highlightIndices: null,\n        log: '',\n      });\n      return;\n    }\n    // Step 1 - check first element\n    if(arr[0] === val){\n      steps.push({\n        stage: Stage.INIT,\n        description: `First element arr[0] = ${arr[0]} matches the search value.`,\n        highlightIndices: new Set([0]),\n        log: `Search value found at first element.`,\n      });\n      steps.push({\n        stage: Stage.FINISHED,\n        description: `Search finished. Found at index 0.`,\n        highlightIndices: new Set([0]),\n        log: 'Exponential search finished successfully.',\n      });\n      return;\n    } else {\n      steps.push({\n        stage: Stage.INIT,\n        description: `First element arr[0] = ${arr[0]} does NOT match the search value ${val}.`,\n        highlightIndices: new Set([0]),\n        log: `First element not a match, moving to exponential bound search.`,\n      });\n    }\n\n    // Step 2 - find range with exponential stepping\n    let i = 1;\n    steps.push({\n      stage: Stage.EXP_STEP_CHECK,\n      description: `Start exponential index bound search with index i = ${i}.`,\n      highlightIndices: new Set([i]),\n      log: `Initialize exponential bounds: i = 1.`,\n    });\n    while(i < arr.length && arr[i] < val){\n      steps.push({\n        stage: Stage.EXP_STEP_CHECK,\n        description: `Value at arr[${i}] = ${arr[i]} is less than ${val}, doubling i.`,\n        highlightIndices: new Set([i]),\n        log: `arr[${i}] = ${arr[i]} < ${val}, increase i exponentially.`,\n      });\n      i = i * 2;\n      if(i >= arr.length) {\n        i = arr.length - 1;\n        steps.push({\n          stage: Stage.EXP_STEP_CHECK,\n          description: `Index i adjusted to array end: i = ${i}.`,\n          highlightIndices: new Set([i]),\n          log: 'Index i exceeded array length, adjusted to last index.',\n        });\n      } else {\n        steps.push({\n          stage: Stage.EXP_STEP_CHECK,\n          description: `Doubled i, now i = ${i}.`,\n          highlightIndices: new Set([i]),\n          log: '',\n        });\n      }\n    }\n\n    // Now i is >= val or at end\n    let low = Math.floor(i / 2) + 1;\n    let high = i;\n    steps.push({\n      stage: Stage.EXP_STEP_FOUND_RANGE,\n      description: `Found range for binary search between indices [${low} .. ${high}].`,\n      highlightIndices: new Set([low, high]),\n      log: `Exponential search found range from ${low} to ${high} for binary search.`,\n    });\n\n    // Step 3 - binary search in range found\n    let foundIndex = binarySearch(arr, val, low, high, variant, function(step){\n      steps.push(step);\n    });\n\n    // Step 4 - finish\n    if(foundIndex !== -1){\n      steps.push({\n        stage: Stage.FINISHED,\n        description: `Search completed. Value found at index ${foundIndex}.`,\n        highlightIndices: new Set([foundIndex]),\n        log: 'Exponential search finished successfully.',\n        resultIndex: foundIndex,\n      });\n    } else {\n      steps.push({\n        stage: Stage.FINISHED,\n        description: `Search completed. Value NOT found in array.`,\n        highlightIndices: null,\n        log: 'Exponential search finished without finding the value.',\n        resultIndex: -1,\n      });\n    }\n  }\n\n  // Start search button handler\n  startSearchBtn.addEventListener('click', e=>{\n    e.preventDefault();\n    if(dataArray.length === 0){\n      alert('Please load a valid sorted array first.');\n      return;\n    }\n    let val = Number(searchValueInput.value);\n    if(!Number.isFinite(val)){\n      alert('Please enter a valid numerical search value.');\n      return;\n    }\n    searchValue = val;\n    binaryVariant = binaryVariantSelect.value;\n    steps = [];\n    currentStepIndex = -1;\n\n    // Build all steps for the search\n    exponentialSearch(dataArray, searchValue, binaryVariant);\n\n    if(steps.length === 0){\n      searchStatePre.textContent = '(No steps generated)';\n      logDiv.textContent = '';\n      return;\n    }\n\n    currentStepIndex = 0;\n    renderCurrentStep();\n\n    autoPlayBtn.disabled = false;\n    stepForwardBtn.disabled = (steps.length <= 1);\n    stepBackwardBtn.disabled = true;\n\n    setControlsDuringSearch(false);\n  });\n\n  // Initial disable start search\n  startSearchBtn.disabled = true;\n  autoPlayBtn.disabled = true;\n  stepForwardBtn.disabled = true;\n  stepBackwardBtn.disabled = true;\n\n  // Accessibility text for screen readers on load\n  arrayInput.setAttribute('aria-describedby', 'arrayValidationMsg');\n  arrayDisplay.setAttribute('tabindex', '0');\n  searchStatePre.setAttribute('tabindex', '0');\n  logDiv.setAttribute('tabindex', '0');\n\n})();\n</script>\n\n</body>\n</html>"
  },
