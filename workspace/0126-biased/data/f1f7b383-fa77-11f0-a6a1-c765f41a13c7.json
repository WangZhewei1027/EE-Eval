    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>NoSQL — Visual Exposition</title>\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071028;\n      --accent-1: #7ee7c7;\n      --accent-2: #7cc4ff;\n      --accent-3: #ff9ec1;\n      --glass: rgba(255,255,255,0.06);\n      --muted: rgba(255,255,255,0.64);\n      --card-blur: 18px;\n      --glass-border: rgba(255,255,255,0.06);\n      --glass-2: rgba(255,255,255,0.03);\n    }\n    /* Reset */\n    *{box-sizing:border-box;margin:0;padding:0}\n    html,body{height:100%}\n    body{\n      min-height:100vh;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      background: radial-gradient(1200px 800px at 10% 10%, rgba(34,47,68,0.30), transparent),\n                  radial-gradient(800px 600px at 90% 90%, rgba(3,9,23,0.5), transparent),\n                  linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n      color: #e7f3ff;\n      overflow: hidden;\n    }\n\n    /* Ambient shapes */\n    .ambient {\n      position:fixed;\n      inset: -10vmin -20vmin auto auto;\n      width: 70vmin;\n      height: 70vmin;\n      filter: blur(60px) saturate(140%);\n      opacity: 0.9;\n      pointer-events: none;\n      transform: translateZ(0);\n    }\n    .ambient svg{width:100%;height:100%}\n    .ambient .blob{\n      mix-blend-mode: screen;\n      opacity: 0.9;\n      transform-origin:50% 50%;\n      animation: blob-rotate 28s linear infinite;\n    }\n    @keyframes blob-rotate{\n      0%{transform:rotate(0deg) translateY(0)}\n      50%{transform:rotate(180deg) translateY(-4%);}\n      100%{transform:rotate(360deg) translateY(0)}\n    }\n\n    /* Layout */\n    .wrap{\n      position:relative;\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap: 36px;\n      align-items: center;\n      padding: clamp(28px,6vw,48px);\n      max-width: 1300px;\n      margin: 6vh auto;\n      z-index: 3;\n    }\n\n    header.topline{\n      position:fixed;\n      left: clamp(20px,3vw,36px);\n      top: clamp(18px,2.6vw,28px);\n      z-index: 5;\n      display:flex;\n      gap:14px;\n      align-items:center;\n    }\n    .logo{\n      display:flex;\n      align-items:center;\n      gap:12px;\n      cursor: default;\n      user-select: none;\n    }\n    .logo .mark{\n      width:56px;height:56px;border-radius:12px;\n      background: linear-gradient(135deg,var(--accent-1),var(--accent-2));\n      display:grid;place-items:center;\n      box-shadow: 0 6px 28px rgba(24,78,138,0.28), inset 0 2px 8px rgba(255,255,255,0.08);\n    }\n    .logo .mark svg{width:34px;height:34px;filter: drop-shadow(0 6px 18px rgba(0,0,0,0.35));}\n    .logo h1{\n      font-size:18px;\n      letter-spacing:0.6px;\n      color: #ecf9ff;\n      font-weight:700;\n      line-height:1;\n    }\n    .logo p{\n      margin-top:2px;font-size:12px;color:var(--muted);font-weight:500;\n    }\n\n    /* Controls */\n    .controls{\n      position:fixed;\n      right: clamp(20px,3vw,36px);\n      top: clamp(18px,2.6vw,28px);\n      display:flex;\n      gap:12px;\n      z-index: 6;\n    }\n    .btn{\n      -webkit-tap-highlight-color:transparent;\n      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      border: 1px solid var(--glass-border);\n      backdrop-filter: blur(8px) saturate(120%);\n      color: #eaf8ff;\n      padding: 10px 14px;\n      border-radius:10px;\n      font-weight:600;\n      font-size:13px;\n      cursor:pointer;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      transition: transform .28s cubic-bezier(.2,.9,.3,1), box-shadow .28s;\n      box-shadow: 0 6px 22px rgba(3,9,23,0.55);\n    }\n    .btn:active{transform:translateY(1px) scale(.998)}\n    .btn.secondary{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color: var(--accent-2);\n      border: 1px solid rgba(124,196,255,0.14);\n      box-shadow: 0 6px 18px rgba(42,66,98,0.36);\n    }\n\n    /* Scene */\n    .hero{\n      display:flex;\n      gap:36px;\n      align-items:center;\n    }\n\n    .canvas-wrap{\n      position:relative;\n      min-height: 560px;\n      border-radius: 22px;\n      overflow: visible;\n      padding: 36px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid var(--glass-border);\n      box-shadow:\n        0 20px 80px rgba(7,22,42,0.6),\n        inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(var(--card-blur));\n    }\n    .canvas-inner{\n      width: 100%;\n      height: 480px;\n      max-width: 820px;\n      border-radius: 18px;\n      position:relative;\n      overflow: visible;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    /* Central emblem */\n    .emblem{\n      position:absolute;\n      width: 380px;\n      height: 380px;\n      display:grid;\n      place-items:center;\n      border-radius: 50%;\n      transform: translateZ(0);\n      pointer-events:none;\n    }\n    .emblem .ring{\n      position:absolute;inset:0;border-radius:50%;\n      background: conic-gradient(from 120deg, rgba(124,196,255,0.18), rgba(126,231,199,0.12), rgba(255,158,193,0.08), rgba(124,196,255,0.18));\n      filter: blur(22px);\n      opacity: 0.95;\n      animation: spin-slow 26s linear infinite;\n    }\n    @keyframes spin-slow{to{transform: rotate(360deg)}}\n    .emblem .core{\n      width:200px;height:200px;border-radius:50%;\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border: 1px solid rgba(255,255,255,0.06);\n      box-shadow: 0 10px 50px rgba(3,12,29,0.6), inset 0 -6px 40px rgba(0,0,0,0.25);\n      display:grid;place-items:center;\n      transform: translateZ(0);\n      z-index:2;\n    }\n    .emblem .core .title{\n      text-align:center;\n      font-weight:700;\n      font-size:20px;\n      color:#e8fbff;\n      letter-spacing:1px;\n    }\n    .emblem .subtitle{\n      position:absolute;\n      bottom: -44px;\n      font-size:12px;\n      color:var(--muted);\n      display:block;\n      width:100%;\n      text-align:center;\n    }\n\n    /* Floating type badges */\n    .badge{\n      position:absolute;\n      width: 160px;\n      padding:14px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.01));\n      border: 1px solid var(--glass-border);\n      box-shadow: 0 8px 36px rgba(4,18,36,0.56);\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n      transform-origin:center center;\n      animation: floatY 6s ease-in-out infinite;\n      transition: transform .36s cubic-bezier(.2,.9,.3,1);\n      backdrop-filter: blur(10px);\n    }\n    .badge:hover{transform: translateY(-6px) scale(1.01)}\n    @keyframes floatY{\n      0%{transform: translateY(0)}\n      50%{transform: translateY(-10px)}\n      100%{transform: translateY(0)}\n    }\n    .badge .icon{\n      width:48px;height:48px;border-radius:10px;\n      display:grid;place-items:center;\n      color: #021024;\n      font-weight:700;\n      font-size:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.92));\n      box-shadow: 0 6px 22px rgba(2,10,20,0.3);\n    }\n    .badge .content{\n      flex:1;\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n    }\n    .badge .content b{font-size:13px;color:#e8fbff}\n    .badge .sample{\n      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n      font-size:12px;color:var(--muted);line-height:1.2;\n      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\n    }\n\n    /* Positions for badges around emblem */\n    .badge.kv{left: 44px; top: 52px; animation-delay: .2s;}\n    .badge.doc{right: 62px; top: 52px; animation-delay: .8s;}\n    .badge.col{left: 18px; bottom: 40px; animation-delay: 1.4s;}\n    .badge.graph{right: 28px; bottom: 48px; animation-delay: .4s;}\n\n    /* Right column - explanation cards */\n    .info{\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-self:flex-start;\n      margin-top:24px;\n    }\n    .card{\n      padding:18px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.01));\n      border: 1px solid var(--glass-border);\n      box-shadow: 0 16px 50px rgba(3,12,26,0.55);\n      backdrop-filter: blur(14px);\n      transition: transform .36s cubic-bezier(.2,.9,.3,1);\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n    }\n    .card:hover{transform: translateY(-6px)}\n    .card .left{\n      width:56px;height:56px;border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.015));\n      display:grid;place-items:center;font-weight:700;color:#072433;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .card h3{font-size:15px;margin-bottom:4px}\n    .card p{font-size:13px;color:var(--muted);line-height:1.35}\n\n    .tag{\n      margin-left:auto;padding:6px 8px;border-radius:8px;font-size:12px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      color: var(--muted);\n    }\n\n    /* Footer note */\n    .foot{\n      position:fixed;\n      left:0;right:0;bottom:24px;\n      display:flex;justify-content:center;\n      color:rgba(255,255,255,0.06);\n      font-size:12px;\n      pointer-events:none;\n      z-index:2;\n    }\n\n    /* Modal */\n    .modal{\n      position:fixed;inset:0;display:grid;place-items:center;\n      background: linear-gradient(180deg, rgba(2,6,12,0.4), rgba(3,8,14,0.6));\n      backdrop-filter: blur(8px) saturate(120%);\n      z-index: 10;\n      opacity:0;visibility:hidden;transition:opacity .28s, visibility .28s;\n    }\n    .modal.open{opacity:1;visibility:visible}\n    .modal .panel{\n      width: min(760px,92vw);\n      padding:28px;border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.06);\n      box-shadow: 0 24px 80px rgba(3,12,26,0.7);\n      color: #dff7ff;\n    }\n    .modal h2{font-size:20px;margin-bottom:8px}\n    .modal p{color:var(--muted);font-size:14px;line-height:1.55}\n    .modal .close{\n      margin-top:18px;padding:10px 12px;border-radius:10px;background:rgba(255,255,255,0.02);\n      border:1px solid rgba(255,255,255,0.03);cursor:pointer;color:var(--accent-2);font-weight:600;\n    }\n\n    /* Pause state (stops all CSS animations) */\n    body.paused *{animation-play-state: paused !important; transition: none !important}\n    body.paused .btn.paused{box-shadow: inset 0 6px 12px rgba(0,0,0,0.45)}\n    /* accessibility & small screens */\n    @media (max-width:980px){\n      .wrap{grid-template-columns: 1fr; padding:20px; gap:20px}\n      .canvas-wrap{order:2}\n      .info{order:1}\n      .emblem{width:300px;height:300px}\n      .canvas-inner{height:380px}\n      .badge{display:none}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <svg viewBox=\"0 0 800 800\" preserveAspectRatio=\"none\" >\n      <defs>\n        <linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7ee7c7\"/><stop offset=\"1\" stop-color=\"#7cc4ff\"/></linearGradient>\n        <linearGradient id=\"g2\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7cc4ff\"/><stop offset=\"1\" stop-color=\"#ff9ec1\"/></linearGradient>\n      </defs>\n      <g class=\"blob\" transform=\"translate(400 400)\">\n        <path d=\"M -250 -120 C -160 -220 160 -220 250 -120 C 310 -40 340 40 300 120 C 230 260 -230 260 -300 120 C -340 40 -310 -40 -250 -120 Z\" fill=\"url(#g1)\" opacity=\"0.9\"></path>\n      </g>\n      <g class=\"blob\" transform=\"translate(480 200)\">\n        <path d=\"M -160 -80 C -90 -140 90 -140 160 -80 C 200 -30 230 30 190 90 C 120 180 -120 180 -190 90 C -230 30 -200 -30 -160 -80 Z\" fill=\"url(#g2)\" opacity=\"0.85\"></path>\n      </g>\n    </svg>\n  </div>\n\n  <header class=\"topline\" aria-hidden=\"true\">\n    <div class=\"logo\">\n      <div class=\"mark\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"3\" fill=\"white\" opacity=\"0.9\"/><path d=\"M7 8h10M7 12h10M7 16h6\" stroke=\"#083048\" stroke-width=\"1.2\" stroke-linecap=\"round\"/></svg>\n      </div>\n      <div>\n        <h1>NoSQL</h1>\n        <p>Data beyond tables — flexible, scalable, expressive</p>\n      </div>\n    </div>\n  </header>\n\n  <div class=\"controls\" aria-hidden=\"true\">\n    <button class=\"btn\" id=\"pauseBtn\" title=\"Pause animations\">\n      <svg id=\"playIcon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"#ecf9ff\"/></svg>\n      <span id=\"pauseLabel\">Pause</span>\n    </button>\n    <button class=\"btn secondary\" id=\"infoBtn\" title=\"Brief overview\">\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2a10 10 0 1 0 .001 20.001A10 10 0 0 0 12 2Zm0 5a1.25 1.25 0 1 1 0 2.5A1.25 1.25 0 0 1 12 7Zm1 10h-2v-6h2v6Z\" fill=\"#7cc4ff\"/></svg>\n      <span>What is NoSQL?</span>\n    </button>\n  </div>\n\n  <main class=\"wrap\" role=\"main\" aria-labelledby=\"pageTitle\">\n    <section class=\"hero\" aria-label=\"Visual concept of NoSQL\">\n      <div class=\"canvas-wrap\" role=\"img\" aria-label=\"Animated representation of NoSQL data types\">\n        <div class=\"canvas-inner\">\n          <canvas id=\"nebula\" style=\"position:absolute;inset:0;width:100%;height:100%;border-radius:12px;\"></canvas>\n\n          <div class=\"emblem\" aria-hidden=\"true\">\n            <div class=\"ring\" style=\"mix-blend-mode: screen;\"></div>\n            <div class=\"core\">\n              <div>\n                <div class=\"title\">NoSQL</div>\n                <div style=\"font-size:12px;color:var(--muted);margin-top:6px\">Flexible, distributed, schema-optional</div>\n              </div>\n            </div>\n            <div class=\"subtitle\">four main paradigms — document · key-value · column · graph</div>\n          </div>\n\n          <!-- floating badges -->\n          <div class=\"badge kv\" aria-hidden=\"true\" style=\"transform: translate(-30px,-20px) rotate(-6deg);\">\n            <div class=\"icon\" style=\"background:linear-gradient(180deg,#fff 0%,#f2f8ff 100%);\">KV</div>\n            <div class=\"content\">\n              <b>Key–Value</b>\n              <div class=\"sample\">session: { userId: \"7f2a\" }</div>\n            </div>\n          </div>\n\n          <div class=\"badge doc\" aria-hidden=\"true\" style=\"transform: translate(30px,-30px) rotate(4deg);\">\n            <div class=\"icon\" style=\"background:linear-gradient(180deg,#fff 0%,#fff8f9 100%);\">DOC</div>\n            <div class=\"content\">\n              <b>Document</b>\n              <div class=\"sample\">{\"name\":\"Iris\",\"tags\":[\"bot\"]}</div>\n            </div>\n          </div>\n\n          <div class=\"badge col\" aria-hidden=\"true\" style=\"transform: translate(-40px,20px) rotate(-5deg);\">\n            <div class=\"icon\" style=\"background:linear-gradient(180deg,#fff 0%,#fffaf5 100%);\">CF</div>\n            <div class=\"content\">\n              <b>Column</b>\n              <div class=\"sample\">metrics: { date: [95, 123, 88] }</div>\n            </div>\n          </div>\n\n          <div class=\"badge graph\" aria-hidden=\"true\" style=\"transform: translate(40px,18px) rotate(6deg);\">\n            <div class=\"icon\" style=\"background:linear-gradient(180deg,#fff 0%,#fffdfa 100%);\">G</div>\n            <div class=\"content\">\n              <b>Graph</b>\n              <div class=\"sample\">A → B (relationship: \"follows\")</div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </section>\n\n    <aside class=\"info\" aria-label=\"Highlights\">\n      <div class=\"card\" role=\"article\">\n        <div class=\"left\" style=\"background:linear-gradient(180deg,#7ee7c7,#7cc4ff);\">⟂</div>\n        <div>\n          <h3>Schema Freedom</h3>\n          <p>Store evolving structures. Documents and key-value pairs let apps iterate without rigid schema changes.</p>\n        </div>\n        <div class=\"tag\">Agile</div>\n      </div>\n\n      <div class=\"card\" role=\"article\">\n        <div class=\"left\" style=\"background:linear-gradient(180deg,#7cc4ff,#ff9ec1);\">⚡</div>\n        <div>\n          <h3>Scale Horizontally</h3>\n          <p>Scale across nodes and datacenters — partitioning and replication are first-class strategies for throughput.</p>\n        </div>\n        <div class=\"tag\">Distributed</div>\n      </div>\n\n      <div class=\"card\" role=\"article\">\n        <div class=\"left\" style=\"background:linear-gradient(180deg,#ff9ec1,#ffcdb2);\">∑</div>\n        <div>\n          <h3>Modeling Flexibility</h3>\n          <p>Choose the paradigm that fits: documents for nested objects, columns for wide data, graphs for relationships.</p>\n        </div>\n        <div class=\"tag\">Flexible</div>\n      </div>\n\n      <div class=\"card\" role=\"article\">\n        <div class=\"left\" style=\"background:linear-gradient(180deg,#d9f6e9,#cff0ff);\">⚙</div>\n        <div>\n          <h3>Performance & Ops</h3>\n          <p>Optimized for targeted read/write patterns — caches, TTLs, and tunable consistency give operational control.</p>\n        </div>\n        <div class=\"tag\">Practical</div>\n      </div>\n    </aside>\n  </main>\n\n  <div class=\"foot\" aria-hidden=\"true\">Aesthetic exposition — minimal controls. Observe the ecosystems of data.</div>\n\n  <div class=\"modal\" id=\"modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modalTitle\">\n    <div class=\"panel\" role=\"document\">\n      <h2 id=\"modalTitle\">What is NoSQL?</h2>\n      <p>NoSQL is an umbrella of database technologies that depart from traditional table-based relational models. It prioritizes flexibility, horizontal scalability, and specialized data models — document stores, key-value stores, wide-column stores, and graph databases. These patterns let applications store complex, nested, and highly connected data with pragmatic performance characteristics for modern, distributed systems.</p>\n      <button class=\"close\" id=\"modalClose\">Close</button>\n    </div>\n  </div>\n\n  <script>\n    // Nebula canvas animation (gentle particles)\n    (() => {\n      const canvas = document.getElementById('nebula');\n      const dpr = Math.max(1, window.devicePixelRatio || 1);\n      const ctx = canvas.getContext('2d');\n      let width, height;\n      let particles = [];\n      let animId = null;\n      let running = true;\n\n      function resize(){\n        const rect = canvas.getBoundingClientRect();\n        width = Math.round(rect.width);\n        height = Math.round(rect.height);\n        canvas.width = width * dpr;\n        canvas.height = height * dpr;\n        canvas.style.width = width + 'px';\n        canvas.style.height = height + 'px';\n        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n      }\n\n      function seed(n=90){\n        particles = [];\n        for(let i=0;i<n;i++){\n          const angle = Math.random()*Math.PI*2;\n          const r = Math.sqrt(Math.random())*Math.min(width,height)*0.38;\n          const x = width/2 + Math.cos(angle)*r + (Math.random()-0.5)*40;\n          const y = height/2 + Math.sin(angle)*r + (Math.random()-0.5)*40;\n          particles.push({\n            x, y,\n            vx: (Math.random()-0.5)*0.12,\n            vy: (Math.random()-0.5)*0.12,\n            size: 1 + Math.random()*4,\n            hue: 170 + Math.random()*80, // hue shift for colors\n            life: 40 + Math.random()*80,\n            phase: Math.random()*Math.PI*2\n          });\n        }\n      }\n\n      function draw(){\n        ctx.clearRect(0,0,width,height);\n        // soft background radial vignette\n        const grad = ctx.createRadialGradient(width*0.5, height*0.45, Math.min(width,height)*0.12, width*0.5, height*0.45, Math.max(width,height)*0.9);\n        grad.addColorStop(0, 'rgba(24,40,64,0.08)');\n        grad.addColorStop(1, 'rgba(3,8,18,0.64)');\n        ctx.fillStyle = grad;\n        ctx.fillRect(0,0,width,height);\n\n        // draw particles with glow\n        particles.forEach((p, i) => {\n          // subtle orbital motion around center\n          const cx = width/2, cy = height/2;\n          const dx = p.x - cx, dy = p.y - cy;\n          const dist = Math.sqrt(dx*dx + dy*dy);\n          const ang = Math.atan2(dy, dx) + Math.sin((Date.now()/2000)+p.phase)*0.0006;\n          p.x = cx + Math.cos(ang) * dist + p.vx;\n          p.y = cy + Math.sin(ang) * dist + p.vy;\n\n          // draw glow\n          const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size*18);\n          const color1 = `hsla(${p.hue}, 90%, 65%, 0.85)`;\n          const color2 = `hsla(${(p.hue+40)%360}, 85%, 60%, 0.12)`;\n          const color3 = `hsla(${(p.hue+80)%360}, 90%, 55%, 0.02)`;\n          g.addColorStop(0, color1);\n          g.addColorStop(0.25, color2);\n          g.addColorStop(1, color3);\n          ctx.fillStyle = g;\n          ctx.beginPath();\n          ctx.arc(p.x, p.y, p.size*12, 0, Math.PI*2);\n          ctx.fill();\n\n          // small bright core\n          ctx.beginPath();\n          ctx.fillStyle = `rgba(255,255,255,${0.6 - p.size*0.06})`;\n          ctx.arc(p.x, p.y, p.size*0.9, 0, Math.PI*2);\n          ctx.fill();\n        });\n\n        // layered subtle rings from center\n        ctx.save();\n        ctx.translate(width/2, height/2);\n        ctx.rotate((Date.now()/50000) % (Math.PI*2));\n        for(let i=0;i<3;i++){\n          ctx.strokeStyle = `rgba(124,196,255,${0.02 + i*0.01})`;\n          ctx.lineWidth = 1 + i*1;\n          ctx.beginPath();\n          ctx.arc(0,0, 80 + i*26, 0, Math.PI*2);\n          ctx.stroke();\n        }\n        ctx.restore();\n      }\n\n      function tick(){\n        if(!running) return;\n        draw();\n        animId = requestAnimationFrame(tick);\n      }\n\n      function start(){\n        if(running) return;\n        running = true;\n        animId = requestAnimationFrame(tick);\n      }\n      function stop(){\n        running = false;\n        if(animId) cancelAnimationFrame(animId);\n        animId = null;\n      }\n\n      window.addEventListener('resize', () => {\n        resize(); seed(Math.round((canvas.clientWidth*canvas.clientHeight)/4200)); draw();\n      });\n\n      // initialize\n      setTimeout(()=>{ // let layout settle\n        resize();\n        seed(110);\n        tick();\n      }, 80);\n\n      // Expose controls\n      window.__nebulaControl = { stop, start, isRunning: ()=>running };\n    })();\n\n    // Buttons: Pause/Resume and Modal\n    (function(){\n      const pauseBtn = document.getElementById('pauseBtn');\n      const pauseLabel = document.getElementById('pauseLabel');\n      const modal = document.getElementById('modal');\n      const infoBtn = document.getElementById('infoBtn');\n      const modalClose = document.getElementById('modalClose');\n\n      let paused = false;\n      pauseBtn.addEventListener('click', ()=>{\n        paused = !paused;\n        document.body.classList.toggle('paused', paused);\n        if(paused){\n          pauseLabel.textContent = 'Resume';\n          pauseBtn.classList.add('paused');\n          // stop canvas\n          if(window.__nebulaControl) window.__nebulaControl.stop();\n        } else {\n          pauseLabel.textContent = 'Pause';\n          pauseBtn.classList.remove('paused');\n          if(window.__nebulaControl) window.__nebulaControl.start();\n        }\n      });\n\n      infoBtn.addEventListener('click', ()=>{\n        modal.classList.add('open');\n        // pause subtle animations to focus info\n        document.body.classList.add('paused');\n        paused = true;\n        pauseLabel.textContent = 'Resume';\n        pauseBtn.classList.add('paused');\n        if(window.__nebulaControl) window.__nebulaControl.stop();\n      });\n      modalClose.addEventListener('click', ()=>{\n        modal.classList.remove('open');\n        // resume when closing only if the user didn't pause manually\n        paused = true; // keep \"paused\" flag as true because we set when opened; clicking close resumes below:\n        document.body.classList.remove('paused');\n        paused = false;\n        pauseLabel.textContent = 'Pause';\n        pauseBtn.classList.remove('paused');\n        if(window.__nebulaControl) window.__nebulaControl.start();\n      });\n\n      // allow Escape to close modal\n      window.addEventListener('keydown', (e)=>{\n        if(e.key === 'Escape' && modal.classList.contains('open')){\n          modalClose.click();\n        }\n      });\n    })();\n  </script>\n</body>\n</html>"
  },
