    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Socket Programming | Visual Concept</title>\n<style>\n  @import url(\"https://fonts.googleapis.com/css2?family=Space+Mono&display=swap\");\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Space Mono', monospace;\n    color: #e0e6f0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  /* Container to center content */\n  .container {\n    max-width: 900px;\n    width: 90vw;\n    background: rgba(15, 32, 39, 0.85);\n    border-radius: 24px;\n    padding: 40px 60px;\n    box-shadow:\n      0 8px 24px rgba(255, 255, 255, 0.1),\n      0 0 30px rgba(44, 83, 100, 0.7);\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Heading with gradient stroke */\n  h1 {\n    margin: 0 0 14px 0;\n    font-weight: 700;\n    font-size: 3.6rem;\n    background: linear-gradient(90deg, #7fffd4, #40e0d0, #7fffd4);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    filter: drop-shadow(0 3px 6px #16c9c033);\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n  }\n\n  /* Subtitle */\n  p.desc {\n    margin: 0 0 38px 0;\n    font-weight: 400;\n    font-size: 1.15rem;\n    color: #a3bac9dd;\n    letter-spacing: 0.05em;\n    line-height: 1.6;\n  }\n\n  /* Central visual panel */\n  .visual {\n    position: relative;\n    width: 100%;\n    height: 360px;\n    background: radial-gradient(circle at center, #1c3b56 0%, #0b1824 85%);\n    border-radius: 20px;\n    box-shadow:\n      inset 0 0 40px #0ff7ff44,\n      0 0 20px #0ff7ffbb;\n    overflow: visible;\n    margin-bottom: 42px;\n    cursor: default;\n  }\n\n  /* Socket node style */\n  .socket {\n    position: absolute;\n    width: 36px;\n    height: 36px;\n    background: #0ff7ff;\n    border-radius: 50%;\n    box-shadow:\n      0 0 12px #0ff7ffbb,\n      0 0 24px #0ff7ffcc,\n      inset 0 0 4px #a0ffffee;\n    transition: transform 0.3s ease;\n    will-change: transform;\n  }\n\n  /* Socket nodes positions */\n  .socket.client { top: 50%; left: 8%; transform: translate(-50%, -50%);}\n  .socket.server { top: 50%; right: 10%; transform: translate(50%, -50%);}\n  .socket.router { top: 22%; left: 40%; transform: translate(-50%, -50%);}\n  .socket.database { bottom: 26%; left: 60%; transform: translate(-50%, 50%);}\n  .socket.firewall { bottom: 22%; right: 40%; transform: translate(50%, 50%);}\n\n  /* Node labels */\n  .node-label {\n    position: absolute;\n    color: #0ff7ffcc;\n    font-weight: 600;\n    font-size: 0.85rem;\n    letter-spacing: 0.07em;\n    text-transform: uppercase;\n    mix-blend-mode: screen;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  .label-client { top: 54%; left: 8%; transform: translate(-50%, 0); }\n  .label-server { top: 54%; right: 10%; transform: translate(50%, 0); }\n  .label-router { top: 18%; left: 40%; transform: translate(-50%, 0); }\n  .label-database { bottom: 20%; left: 60%; transform: translate(-50%, 0); }\n  .label-firewall { bottom: 18%; right: 40%; transform: translate(50%, 0); }\n\n  /* Curved connection lines using SVG paths */\n  svg.connections {\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 100%;\n    pointer-events: none;\n  }\n\n  path.connection-line {\n    fill: none;\n    stroke: #0ff7ffaa;\n    stroke-width: 2.8;\n    filter: drop-shadow(0 0 6px #0ff7ff66);\n    stroke-linecap: round;\n    animation: pulseStroke 3s ease-in-out infinite;\n  }\n\n  @keyframes pulseStroke {\n    0%, 100% {\n      stroke-dashoffset: 0;\n      stroke-opacity: 0.9;\n    }\n    50% {\n      stroke-dashoffset: 40;\n      stroke-opacity: 0.5;\n    }\n  }\n\n  /* Animated \"Data Packet\" circle traveling along paths */\n  .packet {\n    position: absolute;\n    width: 18px;\n    height: 18px;\n    border-radius: 50%;\n    background: #7fffd4;\n    box-shadow:\n      0 0 12px #7fffd4dd,\n      0 0 20px #40e0d0cc;\n    filter: drop-shadow(0 0 8px #7fffd4bb);\n    pointer-events: none;\n  }\n\n  /* Controls style */\n  .controls {\n    text-align: center;\n  }\n\n  button {\n    font-family: 'Space Mono', monospace;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 12px 28px;\n    margin: 0 14px;\n    border-radius: 32px;\n    border: none;\n    background: linear-gradient(135deg, #7fffd4, #40e0d0);\n    color: #082a2e;\n    letter-spacing: 0.1em;\n    cursor: pointer;\n    box-shadow:\n      0 6px 15px #00ffffaa,\n      inset 0 -2px 6px #00ffefcc;\n    transition: background 0.35s ease, transform 0.25s ease, box-shadow 0.3s ease;\n    user-select: none;\n  }\n\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, #40e0d0, #7fffd4);\n    box-shadow:\n      0 8px 24px #7fffd4ff,\n      inset 0 -2px 12px #a0fff7ff;\n    transform: scale(1.07);\n    outline: none;\n  }\n\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Footer note */\n  .footer-note {\n    margin-top: 38px;\n    font-size: 0.85rem;\n    text-align: center;\n    letter-spacing: 0.04em;\n    color: #40e0d044;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\" aria-label=\"Socket Programming Visual Concept\">\n  <h1>Socket Programming</h1>\n  <p class=\"desc\">\n    Visualizing the seamless interplay of nodes and connections within the socket programming paradigm — illustrating data flow, network sockets, and real-time communication.\n  </p>\n  <div class=\"visual\" aria-hidden=\"true\">\n    <!-- Socket nodes -->\n    <div class=\"socket client\" id=\"socket-client\"></div>\n    <div class=\"socket server\" id=\"socket-server\"></div>\n    <div class=\"socket router\" id=\"socket-router\"></div>\n    <div class=\"socket database\" id=\"socket-database\"></div>\n    <div class=\"socket firewall\" id=\"socket-firewall\"></div>\n\n    <!-- Labels -->\n    <div class=\"node-label label-client\">Client</div>\n    <div class=\"node-label label-server\">Server</div>\n    <div class=\"node-label label-router\">Router</div>\n    <div class=\"node-label label-database\">Database</div>\n    <div class=\"node-label label-firewall\">Firewall</div>\n\n    <!-- SVG connections -->\n    <svg class=\"connections\" viewBox=\"0 0 900 360\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n      <!-- Connections paths -->\n      <path id=\"path-client-router\" class=\"connection-line\" d=\"M72 180 C 200 60, 360 60, 360 80\" />\n      <path id=\"path-router-server\" class=\"connection-line\" d=\"M360 80 C 540 60, 700 180, 820 180\" />\n      <path id=\"path-router-database\" class=\"connection-line\" d=\"M360 80 C 480 140, 540 260, 540 280\" />\n      <path id=\"path-database-firewall\" class=\"connection-line\" d=\"M540 280 C 630 300, 720 280, 760 260\" />\n      <path id=\"path-firewall-server\" class=\"connection-line\" d=\"M760 260 C 800 220, 810 200, 820 180\" />\n    </svg>\n\n    <!-- Data packet element -->\n    <div class=\"packet\" id=\"data-packet\" aria-hidden=\"true\"></div>\n  </div>\n\n  <div class=\"controls\" role=\"region\" aria-label=\"Socket programming data flow controls\">\n    <button id=\"btn-start\" aria-live=\"polite\">Start Flow</button>\n    <button id=\"btn-reset\" aria-live=\"polite\" disabled>Reset</button>\n  </div>\n\n  <p class=\"footer-note\">Crafted with ✨ | Visual concept &amp; animation by AI</p>\n</div>\n\n<script>\n  (function() {\n    const packet = document.getElementById('data-packet');\n    const btnStart = document.getElementById('btn-start');\n    const btnReset = document.getElementById('btn-reset');\n\n    // Define paths for animation - correspond to SVG path IDs\n    const pathIds = [\n      'path-client-router',\n      'path-router-server',\n      'path-router-database',\n      'path-database-firewall',\n      'path-firewall-server'\n    ];\n\n    let paths = [];\n    let pathLengths = [];\n    let totalPathLength = 0;\n\n    for(let i = 0; i < pathIds.length; i++) {\n      const p = document.getElementById(pathIds[i]);\n      paths.push(p);\n      pathLengths.push(p.getTotalLength());\n      totalPathLength += p.getTotalLength();\n    }\n\n    // Flatten the paths into a single linear travel distance\n    // Packet moves along paths in sequence\n\n    // Animation variables\n    let animationId = null;\n    let startTime = null;\n    const duration = 12000; // 12 seconds for a full cycle\n\n    // Function to find point on composite path at normalized t [0..1]\n    function getPointAt(t) {\n      let dist = t * totalPathLength;\n      for(let i = 0; i < paths.length; i++) {\n        if(dist <= pathLengths[i]) {\n          return paths[i].getPointAtLength(dist);\n        } else {\n          dist -= pathLengths[i];\n        }\n      }\n      // fallback last point on last path\n      return paths[paths.length - 1].getPointAtLength(pathLengths[pathLengths.length -1]);\n    }\n\n    // Place packet initially offscreen\n    function resetPacketPosition() {\n      packet.style.transform = 'translate(-50%, -50%) translate3d(-40px, -40px, 0)';\n    }\n\n    // Animate the packet around paths in a loop\n    function animate(time) {\n      if(!startTime) startTime = time;\n      let elapsed = (time - startTime) % duration;\n      let progress = elapsed / duration;\n\n      let point = getPointAt(progress);\n\n      // Adjust for visual position inside the container\n      // The SVG is 900x360, visual container is flexible so we need to scale accordingly\n\n      const container = document.querySelector('.visual');\n      const rect = container.getBoundingClientRect();\n\n      let scaleX = rect.width / 900;\n      let scaleY = rect.height / 360;\n\n      let x = point.x * scaleX;\n      let y = point.y * scaleY;\n\n      packet.style.transform = `translate(-50%, -50%) translate3d(${x}px, ${y}px, 0)`;\n\n      animationId = requestAnimationFrame(animate);\n    }\n\n    // Start animation\n    function startFlow() {\n      btnStart.disabled = true;\n      btnReset.disabled = false;\n      startTime = null;\n      animationId = requestAnimationFrame(animate);\n    }\n\n    // Reset animation and UI\n    function resetFlow() {\n      btnStart.disabled = false;\n      btnReset.disabled = true;\n      cancelAnimationFrame(animationId);\n      animationId = null;\n      resetPacketPosition();\n    }\n\n    // Initial packet position\n    resetPacketPosition();\n\n    btnStart.addEventListener('click', startFlow);\n    btnReset.addEventListener('click', resetFlow);\n\n    // For responsiveness: reposition packet on window resize if animating\n    window.addEventListener('resize', () => {\n      if(animationId === null) {\n        resetPacketPosition();\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
