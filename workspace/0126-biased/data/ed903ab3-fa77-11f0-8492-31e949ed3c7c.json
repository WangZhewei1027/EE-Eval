    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Means Clustering Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n            background: linear-gradient(to right, #6a11cb, #2575fc);\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n        }\n\n        #container {\n            position: relative;\n            width: 80vw;\n            height: 80vh;\n            border-radius: 15px;\n            overflow: hidden;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);\n            background: rgba(255, 255, 255, 0.1);\n        }\n\n        #title {\n            position: absolute;\n            top: 10px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 2.5em;\n            text-align: center;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);\n        }\n\n        #playButton {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            background-color: rgba(255, 255, 255, 0.2);\n            color: white;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            font-size: 1.2em;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n\n        #playButton:hover {\n            background-color: rgba(255, 255, 255, 0.5);\n        }\n\n        .dot {\n            position: absolute;\n            border-radius: 50%;\n            transition: transform 0.3s ease;\n        }\n\n        #clusters {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n        }\n    </style>\n</head>\n\n<body>\n\n    <div id=\"container\">\n        <h1 id=\"title\">K-Means Clustering Visualization</h1>\n        <button id=\"playButton\">Run K-Means</button>\n        <div id=\"clusters\"></div>\n    </div>\n\n    <script>\n        const clustersDiv = document.getElementById('clusters');\n        const playButton = document.getElementById('playButton');\n\n        const numPoints = 100;\n        let points = [];\n        let centroids = [];\n        let numClusters = 3;\n\n        function initPoints() {\n            points = [];\n            for (let i = 0; i < numPoints; i++) {\n                const x = Math.random() * 100;\n                const y = Math.random() * 100;\n                points.push({ x, y });\n            }\n        }\n\n        function initCentroids() {\n            centroids = [];\n            for (let i = 0; i < numClusters; i++) {\n                const x = Math.random() * 100;\n                const y = Math.random() * 100;\n                centroids.push({ x, y });\n            }\n        }\n\n        function drawPoints() {\n            clustersDiv.innerHTML = '';\n            points.forEach((point, index) => {\n                const dot = document.createElement('div');\n                dot.className = 'dot';\n                dot.style.width = '8px';\n                dot.style.height = '8px';\n                dot.style.backgroundColor = `hsl(${(index / numPoints) * 360}, 100%, 50%)`;\n                dot.style.left = `${point.x}%`;\n                dot.style.top = `${point.y}%`;\n                clustersDiv.appendChild(dot);\n            });\n        }\n\n        function drawCentroids() {\n            centroids.forEach(centroid => {\n                const dot = document.createElement('div');\n                dot.className = 'dot';\n                dot.style.width = '15px';\n                dot.style.height = '15px';\n                dot.style.backgroundColor = 'white';\n                dot.style.left = `${centroid.x}%`;\n                dot.style.top = `${centroid.y}%`;\n                clustersDiv.appendChild(dot);\n            });\n        }\n\n        playButton.addEventListener('click', () => {\n            initPoints();\n            initCentroids();\n            drawPoints();\n            drawCentroids();\n        });\n    </script>\n</body>\n\n</html>"
