    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Backpropagation — Visual Experience</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Merriweather:ital,wght@0,700;1,700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #081226;\n      --glass: rgba(255,255,255,0.04);\n      --accent-c: #5ef0ff;\n      --accent-warm: #ff7ad1;\n      --muted: rgba(255,255,255,0.12);\n      --card: rgba(255,255,255,0.03);\n      --glass-border: rgba(255,255,255,0.06);\n      --success: #9be564;\n    }\n\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 800px at 10% 10%, rgba(94,240,255,0.06), transparent 10%),\n                  radial-gradient(900px 500px at 90% 90%, rgba(255,122,209,0.04), transparent 10%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color: #e8f1fb;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n    }\n\n    .wrap{\n      max-width:1200px;\n      margin:48px auto;\n      padding:36px;\n      display:grid;\n      grid-template-columns: 1fr 380px;\n      gap:28px;\n      align-items:stretch;\n    }\n\n    .panel{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      border: 1px solid var(--glass-border);\n      box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      padding:28px;\n      position:relative;\n      overflow:hidden;\n      min-height:520px;\n    }\n\n    .title{\n      display:flex;\n      align-items:center;\n      gap:16px;\n      margin-bottom:18px;\n    }\n\n    .logo{\n      width:64px;height:64px;border-radius:12px;\n      background: linear-gradient(135deg,var(--accent-c), #7bd3ff 40%, var(--accent-warm) 100%);\n      box-shadow: 0 6px 30px rgba(92,196,255,0.12), 0 1px 0 rgba(255,255,255,0.06) inset;\n      display:flex;align-items:center;justify-content:center;font-weight:800;\n      font-family: Merriweather, serif;\n      color:#021223;font-size:20px;\n    }\n\n    h1{\n      font-family: Merriweather, serif;\n      font-weight:700;\n      margin:0;\n      letter-spacing:-0.02em;\n      font-size:22px;\n      color: #e9fbff;\n    }\n\n    .subtitle{\n      font-size:13px;\n      color: #b9dcee;\n      opacity:0.9;\n      margin-top:4px;\n    }\n\n    /* Canvas area */\n    .canvas{\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      height:100%;\n      padding:12px;\n      position:relative;\n    }\n\n    /* glass overlay */\n    .overlay{\n      position:absolute;inset:0;pointer-events:none;\n      background-image:\n        radial-gradient(600px 200px at 15% 80%, rgba(94,240,255,0.03), transparent 7%),\n        radial-gradient(400px 160px at 85% 20%, rgba(255,122,209,0.03), transparent 7%);\n      border-radius:18px;\n    }\n\n    /* right panel */\n    .info{\n      padding:22px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      height:100%;\n    }\n\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;padding:16px;border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 6px 20px rgba(2,6,23,0.55);\n    }\n\n    .headline{\n      font-weight:600;font-size:16px;margin:0 0 8px 0;\n      display:flex;align-items:center;justify-content:space-between;gap:8px;\n    }\n\n    .desc{\n      font-size:13px;color: #cfeaf7;opacity:0.9;line-height:1.45;\n      margin:0;\n    }\n\n    .controls{\n      display:flex;gap:10px;align-items:center;justify-content:center;margin-top:8px;\n    }\n\n    .btn{\n      appearance:none;border:0;padding:10px 14px;border-radius:10px;cursor:pointer;\n      background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      color:var(--accent-c);\n      border:1px solid rgba(94,240,255,0.12);\n      box-shadow: 0 6px 18px rgba(94,240,255,0.04);\n      font-weight:600;\n      transition: transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n    }\n    .btn:active{ transform:translateY(1px) }\n\n    .btn.secondary{\n      color: #ffc7eb;\n      border-color: rgba(255,122,209,0.12);\n      box-shadow: 0 6px 18px rgba(255,122,209,0.03);\n    }\n\n    .btn.ghost{\n      background:transparent;border:0;color:#a8d8ff;font-weight:500;\n    }\n\n    .meta{\n      font-size:12px;color: #87bddf;opacity:0.85;\n      display:flex;align-items:center;gap:10px;justify-content:space-between;\n    }\n\n    /* network svg */\n    svg.neural{\n      width:740px;height:440px;\n      overflow:visible;\n      filter: drop-shadow(0 18px 40px rgba(2,6,23,0.6));\n    }\n\n    /* nodes */\n    .node{\n      fill: url(#nodeGrad);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1.2;\n      filter: drop-shadow(0 8px 30px rgba(6,22,34,0.6));\n      transition: transform .36s cubic-bezier(.2,.9,.2,1), opacity .28s ease;\n      transform-origin:center;\n    }\n    .node.glow{\n      filter: drop-shadow(0 0 18px rgba(94,240,255,0.22)) drop-shadow(0 0 40px rgba(94,240,255,0.12));\n    }\n\n    .node-label{\n      font-family: \"Inter\",sans-serif;\n      font-size:12px; fill: #eaf9ff;\n    }\n    .node-value{\n      font-family: \"Inter\",sans-serif;\n      font-size:11px; fill: rgba(255,255,255,0.9);\n    }\n\n    .link{\n      stroke-width:2.8;\n      stroke-linecap:round;\n      stroke: url(#gradForward);\n      opacity:0.12;\n      transition: opacity .22s ease, stroke-width .22s ease;\n    }\n\n    .link.backward{\n      stroke: url(#gradBackward); opacity:0; stroke-width:2.6;\n    }\n\n    /* moving dash for forward */\n    .moving{\n      stroke-dasharray:60;\n      stroke-dashoffset:60;\n    }\n    .moving.play{\n      animation: dash 1.6s linear forwards;\n    }\n    @keyframes dash{\n      to { stroke-dashoffset:0; opacity:1; }\n    }\n\n    /* activations highlight */\n    .activate{\n      transform:scale(1.08);\n    }\n\n    /* pulse for loss */\n    .loss-pulse{\n      fill: rgba(255,74,121,0.12);\n      stroke: rgba(255,74,121,0.28);\n      stroke-width:1.4;\n      animation: lossPulse 720ms cubic-bezier(.22,.9,.2,1) infinite;\n    }\n    @keyframes lossPulse{\n      0%{ transform:scale(1); opacity:1 }\n      50%{ transform:scale(1.18); opacity:0.48 }\n      100%{ transform:scale(1); opacity:1 }\n    }\n\n    /* gradient change for weight update */\n    .weight-up{\n      transition: stroke .45s ease, stroke-width .45s ease, filter .45s ease;\n      stroke-width:4.8;\n      filter: drop-shadow(0 6px 30px rgba(255,122,209,0.12));\n    }\n\n    /* label pop */\n    .label-pop{ transform: translateY(-12px); opacity:1; transition: transform .32s cubic-bezier(.2,.9,.2,1), opacity .32s ease; }\n    .weight-label{\n      font-size:11px; fill:#cfeefc; opacity:0; transform-origin:center;\n      transition: opacity .28s ease;\n    }\n    .grad-label{\n      font-size:11px; fill:#ffd9f0; opacity:0; transform-origin:center;\n      transition: opacity .28s ease;\n    }\n\n    /* step explanation */\n    .steps{\n      display:flex;flex-direction:column;gap:10px;\n    }\n    .step{\n      display:flex;gap:12px;align-items:flex-start;\n      padding:12px;border-radius:10px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.02);\n      color:#cfeaf7;font-size:13px;opacity:0.85;\n    }\n    .step .num{\n      min-width:28px;height:28px;border-radius:8px;\n      display:flex;align-items:center;justify-content:center;font-weight:700;\n      background: linear-gradient(180deg, rgba(94,240,255,0.08), rgba(255,255,255,0.01));\n      color:#b6fff9;font-size:13px;border:1px solid rgba(94,240,255,0.08);\n    }\n    .step.fade{ opacity:0.22 }\n\n    /* footer */\n    .footer{\n      display:flex;align-items:center;justify-content:space-between;margin-top:10px;color:#93c9e8;font-size:12px;\n    }\n\n    /* center controls overlay */\n    .controls-bar{\n      position:absolute;left:50%;bottom:-26px;transform:translateX(-50%);\n      display:flex;gap:10px;background:transparent;padding:6px;border-radius:12px;\n      z-index:30;\n    }\n\n    /* small badges */\n    .chip{\n      display:inline-flex;padding:8px 10px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.02);\n      color:#bfefff;font-weight:700;font-size:12px;\n    }\n\n    /* responsive */\n    @media (max-width:1060px){\n      .wrap{ grid-template-columns: 1fr; padding:20px }\n      svg.neural{ width:100%; height:360px }\n      .controls-bar{ bottom:12px }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"panel\" aria-hidden=\"false\">\n      <div class=\"title\">\n        <div class=\"logo\">BP</div>\n        <div style=\"flex:1\">\n          <h1>Backpropagation — Visual Narrative</h1>\n          <div class=\"subtitle\">Elegant visualization of forward signal, loss formation and gradient flow.</div>\n        </div>\n        <div style=\"text-align:right\">\n          <div class=\"chip\">Differentiable • Matrix • Chain Rule</div>\n        </div>\n      </div>\n\n      <div class=\"canvas\" id=\"canvas\">\n        <svg class=\"neural\" viewBox=\"0 0 900 560\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"nodeGrad\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#062231\" stop-opacity=\"0.9\"/>\n              <stop offset=\"1\" stop-color=\"#082536\" stop-opacity=\"0.95\"/>\n            </linearGradient>\n\n            <linearGradient id=\"gradForward\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#5ef0ff\" stop-opacity=\"1\"></stop>\n              <stop offset=\"1\" stop-color=\"#84d3ff\" stop-opacity=\"0.95\"></stop>\n            </linearGradient>\n\n            <linearGradient id=\"gradBackward\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ff7ad1\" stop-opacity=\"0.98\"></stop>\n              <stop offset=\"1\" stop-color=\"#ffd4f0\" stop-opacity=\"0.9\"></stop>\n            </linearGradient>\n\n            <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"10\" result=\"b\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"b\"/>\n            </filter>\n          </defs>\n\n          <!-- Input nodes -->\n          <g id=\"inputLayer\" transform=\"translate(60,120)\">\n            <circle id=\"i0\" class=\"node\" cx=\"0\" cy=\"20\" r=\"18\"></circle>\n            <text x=\"0\" y=\"20\" class=\"node-label\" text-anchor=\"middle\" dy=\"-30\">x0</text>\n            <text id=\"v_i0\" x=\"0\" y=\"20\" class=\"node-value\" text-anchor=\"middle\" dy=\"6\">0.9</text>\n\n            <circle id=\"i1\" class=\"node\" cx=\"0\" cy=\"100\" r=\"18\"></circle>\n            <text x=\"0\" y=\"100\" class=\"node-label\" text-anchor=\"middle\" dy=\"-30\">x1</text>\n            <text id=\"v_i1\" x=\"0\" y=\"100\" class=\"node-value\" text-anchor=\"middle\" dy=\"6\">0.3</text>\n\n            <circle id=\"i2\" class=\"node\" cx=\"0\" cy=\"180\" r=\"18\"></circle>\n            <text x=\"0\" y=\"180\" class=\"node-label\" text-anchor=\"middle\" dy=\"-30\">x2</text>\n            <text id=\"v_i2\" x=\"0\" y=\"180\" class=\"node-value\" text-anchor=\"middle\" dy=\"6\">0.6</text>\n          </g>\n\n          <!-- Hidden layer -->\n          <g id=\"hiddenLayer\" transform=\"translate(360,80)\">\n            <circle id=\"h0\" class=\"node\" cx=\"0\" cy=\"20\" r=\"22\"></circle>\n            <text x=\"0\" y=\"20\" class=\"node-label\" text-anchor=\"middle\" dy=\"-36\">h0</text>\n            <text id=\"v_h0\" x=\"0\" y=\"20\" class=\"node-value\" text-anchor=\"middle\" dy=\"8\">0.0</text>\n\n            <circle id=\"h1\" class=\"node\" cx=\"0\" cy=\"100\" r=\"22\"></circle>\n            <text x=\"0\" y=\"100\" class=\"node-label\" text-anchor=\"middle\" dy=\"-36\">h1</text>\n            <text id=\"v_h1\" x=\"0\" y=\"100\" class=\"node-value\" text-anchor=\"middle\" dy=\"8\">0.0</text>\n\n            <circle id=\"h2\" class=\"node\" cx=\"0\" cy=\"180\" r=\"22\"></circle>\n            <text x=\"0\" y=\"180\" class=\"node-label\" text-anchor=\"middle\" dy=\"-36\">h2</text>\n            <text id=\"v_h2\" x=\"0\" y=\"180\" class=\"node-value\" text-anchor=\"middle\" dy=\"8\">0.0</text>\n\n            <circle id=\"h3\" class=\"node\" cx=\"0\" cy=\"260\" r=\"22\"></circle>\n            <text x=\"0\" y=\"260\" class=\"node-label\" text-anchor=\"middle\" dy=\"-36\">h3</text>\n            <text id=\"v_h3\" x=\"0\" y=\"260\" class=\"node-value\" text-anchor=\"middle\" dy=\"8\">0.0</text>\n          </g>\n\n          <!-- Output layer -->\n          <g id=\"outLayer\" transform=\"translate(700,160)\">\n            <circle id=\"o0\" class=\"node\" cx=\"0\" cy=\"80\" r=\"26\"></circle>\n            <text x=\"0\" y=\"80\" class=\"node-label\" text-anchor=\"middle\" dy=\"-46\">ŷ</text>\n            <text id=\"v_o0\" x=\"0\" y=\"80\" class=\"node-value\" text-anchor=\"middle\" dy=\"10\">0.00</text>\n          </g>\n\n          <!-- Links: Input -> Hidden -->\n          <g id=\"linksIH\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <!-- We'll create 3x4 = 12 links -->\n            <!-- i0 -> h0 -->\n            <path id=\"l_i0_h0\" class=\"link moving\" d=\"M120,140 C200,120 300,40 360,40\" />\n            <path id=\"l_i0_h1\" class=\"link moving\" d=\"M120,140 C220,170 300,140 360,100\" />\n            <path id=\"l_i0_h2\" class=\"link moving\" d=\"M120,140 C250,240 300,220 360,180\" />\n            <path id=\"l_i0_h3\" class=\"link moving\" d=\"M120,140 C230,320 300,300 360,260\" />\n\n            <!-- i1 -> hX -->\n            <path id=\"l_i1_h0\" class=\"link moving\" d=\"M120,220 C200,200 300,120 360,40\" />\n            <path id=\"l_i1_h1\" class=\"link moving\" d=\"M120,220 C220,220 300,160 360,100\" />\n            <path id=\"l_i1_h2\" class=\"link moving\" d=\"M120,220 C250,260 300,220 360,180\" />\n            <path id=\"l_i1_h3\" class=\"link moving\" d=\"M120,220 C230,360 300,300 360,260\" />\n\n            <!-- i2 -> hX -->\n            <path id=\"l_i2_h0\" class=\"link moving\" d=\"M120,300 C200,280 300,160 360,40\" />\n            <path id=\"l_i2_h1\" class=\"link moving\" d=\"M120,300 C220,300 300,200 360,100\" />\n            <path id=\"l_i2_h2\" class=\"link moving\" d=\"M120,300 C250,320 300,240 360,180\" />\n            <path id=\"l_i2_h3\" class=\"link moving\" d=\"M120,300 C230,420 300,340 360,260\" />\n          </g>\n\n          <!-- Links: Hidden -> Output -->\n          <g id=\"linksHO\">\n            <path id=\"l_h0_o0\" class=\"link moving\" d=\"M360,40 C520,40 640,60 700,80\" />\n            <path id=\"l_h1_o0\" class=\"link moving\" d=\"M360,100 C520,110 640,120 700,80\" />\n            <path id=\"l_h2_o0\" class=\"link moving\" d=\"M360,180 C520,140 640,110 700,80\" />\n            <path id=\"l_h3_o0\" class=\"link moving\" d=\"M360,260 C520,220 640,100 700,80\" />\n          </g>\n\n          <!-- Backward (invisible until needed): duplicates for gradient flow -->\n          <g id=\"backLinks\">\n            <!-- We'll reuse same paths but with backward style for visibility control -->\n            <path id=\"b_l_h0_i0\" class=\"link backward\" d=\"M360,40 C300,40 200,120 120,140\" />\n            <path id=\"b_l_h1_i0\" class=\"link backward\" d=\"M360,100 C300,80 200,180 120,140\" />\n            <!-- ... many omitted for brevity will be turned on by JS mapping to forward ones -->\n          </g>\n\n          <!-- Weight labels (small transparent until activated) -->\n          <!-- We'll place a few labels along important links -->\n          <text id=\"w_i0_h0\" x=\"230\" y=\"80\" class=\"weight-label\" text-anchor=\"middle\">w=0.45</text>\n          <text id=\"w_i1_h2\" x=\"240\" y=\"200\" class=\"weight-label\" text-anchor=\"middle\">w=0.18</text>\n          <text id=\"w_h2_o0\" x=\"530\" y=\"120\" class=\"weight-label\" text-anchor=\"middle\">w=0.66</text>\n\n          <!-- gradient labels during backprop -->\n          <text id=\"g_w_i0_h0\" x=\"230\" y=\"100\" class=\"grad-label\" text-anchor=\"middle\">∂L/∂w = -0.12</text>\n          <text id=\"g_w_i1_h2\" x=\"240\" y=\"220\" class=\"grad-label\" text-anchor=\"middle\">∂L/∂w = 0.06</text>\n          <text id=\"g_w_h2_o0\" x=\"530\" y=\"140\" class=\"grad-label\" text-anchor=\"middle\">∂L/∂w = -0.21</text>\n\n          <!-- Loss orb -->\n          <g id=\"lossGroup\" transform=\"translate(700,80)\">\n            <circle id=\"lossOrb\" cx=\"0\" cy=\"0\" r=\"46\" fill=\"rgba(255,255,255,0.02)\"></circle>\n            <circle id=\"lossGlow\" cx=\"0\" cy=\"0\" r=\"46\" class=\"\" fill=\"transparent\"></circle>\n            <text id=\"lossText\" x=\"0\" y=\"-6\" class=\"node-label\" text-anchor=\"middle\" style=\"font-size:12px;opacity:0.9\">Loss</text>\n            <text id=\"lossVal\" x=\"0\" y=\"10\" class=\"node-value\" text-anchor=\"middle\" dy=\"0\">0.00</text>\n          </g>\n\n        </svg>\n        <div class=\"overlay\" aria-hidden=\"true\"></div>\n        <div class=\"controls-bar\" role=\"group\" aria-label=\"controls\">\n          <button id=\"playBtn\" class=\"btn\" title=\"Play animation\">Play</button>\n          <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset scene\">Reset</button>\n        </div>\n      </div>\n\n      <div style=\"margin-top:20px;display:flex;justify-content:space-between;align-items:center\">\n        <div style=\"display:flex;gap:12px;align-items:center\">\n          <div style=\"width:44px;height:44px;border-radius:10px;background:linear-gradient(180deg,#061b26,#04202b);display:flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,0.02)\">\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M3 12h18\" stroke=\"#72e7ff\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          </div>\n          <div>\n            <div style=\"font-weight:700\">One-pass visual demo</div>\n            <div style=\"font-size:12px;color:#9fdaf2;opacity:0.85\">Forward → Loss → Backward → Weight update</div>\n          </div>\n        </div>\n\n        <div style=\"text-align:right\">\n          <div style=\"font-size:12px;color:#bfefff\">Chain rule • Gradient descent</div>\n          <div style=\"font-size:11px;color:#8fbfe6;opacity:0.9\">Illustrative, not exhaustive</div>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"info\">\n      <div class=\"card\">\n        <div class=\"headline\">\n          <div>How Backpropagation Works</div>\n          <div style=\"font-size:12px;color:#8ddbf1\">Illustrative steps</div>\n        </div>\n        <p class=\"desc\" style=\"margin:10px 0 0 0\">Backpropagation computes gradients of the loss with respect to model parameters by applying the chain rule backward through the network. Watch the signal (cyan) flow forward, see the loss form, and observe gradients (magenta) propagate backward to update weights.</p>\n      </div>\n\n      <div class=\"card steps\" aria-hidden=\"false\">\n        <div class=\"step\" id=\"step1\">\n          <div class=\"num\">1</div>\n          <div>\n            <div style=\"font-weight:700\">Forward Pass</div>\n            <div style=\"font-size:13px;color:#bfefff;opacity:0.9\">Inputs activate hidden units; signals reach the output to produce prediction ŷ.</div>\n          </div>\n        </div>\n\n        <div class=\"step fade\" id=\"step2\">\n          <div class=\"num\">2</div>\n          <div>\n            <div style=\"font-weight:700\">Loss Computation</div>\n            <div style=\"font-size:13px;color:#ffdbe8;opacity:0.9\">A loss quantifies the error between prediction and target — this drives learning.</div>\n          </div>\n        </div>\n\n        <div class=\"step fade\" id=\"step3\">\n          <div class=\"num\">3</div>\n          <div>\n            <div style=\"font-weight:700\">Backward Pass</div>\n            <div style=\"font-size:13px;color:#ffcce6;opacity:0.9\">Gradients flow back through the network via the chain rule, computing ∂L/∂w for each weight.</div>\n          </div>\n        </div>\n\n        <div class=\"step fade\" id=\"step4\">\n          <div class=\"num\">4</div>\n          <div>\n            <div style=\"font-weight:700\">Weight Update</div>\n            <div style=\"font-size:13px;color:#d7ffd8;opacity:0.9\">Weights are adjusted (w ← w − η ∂L/∂w), nudging the model toward lower loss.</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\" style=\"margin-top:auto\">\n        <div class=\"headline\"><div>Quick Insight</div><div style=\"font-size:12px;color:#98d7f4\">Chain rule in action</div></div>\n        <p class=\"desc\" style=\"margin-top:8px\">If y = f(g(h(x))) then dy/dx = f'(g(h(x))) · g'(h(x)) · h'(x). Backpropagation applies this repeatedly across layers to compute gradients efficiently.</p>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    // Minimal interactive animation controller for demonstration:\n    (function(){\n      // Elements\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n\n      // Node value elements\n      const v_i0 = document.getElementById('v_i0');\n      const v_i1 = document.getElementById('v_i1');\n      const v_i2 = document.getElementById('v_i2');\n      const v_h0 = document.getElementById('v_h0');\n      const v_h1 = document.getElementById('v_h1');\n      const v_h2 = document.getElementById('v_h2');\n      const v_h3 = document.getElementById('v_h3');\n      const v_o0 = document.getElementById('v_o0');\n      const lossVal = document.getElementById('lossVal');\n\n      const nodes = {\n        i0: document.getElementById('i0'),\n        i1: document.getElementById('i1'),\n        i2: document.getElementById('i2'),\n        h0: document.getElementById('h0'),\n        h1: document.getElementById('h1'),\n        h2: document.getElementById('h2'),\n        h3: document.getElementById('h3'),\n        o0: document.getElementById('o0'),\n      };\n\n      const stepEls = [\n        document.getElementById('step1'),\n        document.getElementById('step2'),\n        document.getElementById('step3'),\n        document.getElementById('step4'),\n      ];\n\n      const movingPaths = Array.from(document.querySelectorAll('.link.moving'));\n      const weightLabels = {\n        w_i0_h0: document.getElementById('w_i0_h0'),\n        w_i1_h2: document.getElementById('w_i1_h2'),\n        w_h2_o0: document.getElementById('w_h2_o0'),\n      };\n      const gradLabels = {\n        g_w_i0_h0: document.getElementById('g_w_i0_h0'),\n        g_w_i1_h2: document.getElementById('g_w_i1_h2'),\n        g_w_h2_o0: document.getElementById('g_w_h2_o0'),\n      };\n\n      const links = {\n        // Input->Hidden\n        l_i0_h0: document.getElementById('l_i0_h0'),\n        l_i0_h1: document.getElementById('l_i0_h1'),\n        l_i0_h2: document.getElementById('l_i0_h2'),\n        l_i0_h3: document.getElementById('l_i0_h3'),\n        l_i1_h0: document.getElementById('l_i1_h0'),\n        l_i1_h1: document.getElementById('l_i1_h1'),\n        l_i1_h2: document.getElementById('l_i1_h2'),\n        l_i1_h3: document.getElementById('l_i1_h3'),\n        l_i2_h0: document.getElementById('l_i2_h0'),\n        l_i2_h1: document.getElementById('l_i2_h1'),\n        l_i2_h2: document.getElementById('l_i2_h2'),\n        l_i2_h3: document.getElementById('l_i2_h3'),\n        // Hidden->Output\n        l_h0_o0: document.getElementById('l_h0_o0'),\n        l_h1_o0: document.getElementById('l_h1_o0'),\n        l_h2_o0: document.getElementById('l_h2_o0'),\n        l_h3_o0: document.getElementById('l_h3_o0'),\n      };\n\n      const lossOrb = document.getElementById('lossOrb');\n      const lossGlow = document.getElementById('lossGlow');\n\n      // State\n      let playing = false;\n      let timers = [];\n\n      // initial values for weights (for visual label)\n      let weights = {\n        i0_h0: 0.45,\n        i1_h2: 0.18,\n        h2_o0: 0.66\n      };\n\n      // small rand helper\n      function rnd(n){ return (Math.round(n*100)/100).toFixed(2); }\n\n      // set initial visuals\n      function resetVisuals(){\n        // reset node activations\n        v_h0.textContent = '0.00';\n        v_h1.textContent = '0.00';\n        v_h2.textContent = '0.00';\n        v_h3.textContent = '0.00';\n        v_o0.textContent = '0.00';\n        lossVal.textContent = '0.00';\n\n        // nodes dims\n        Object.values(nodes).forEach(n => {\n          n.classList.remove('activate','glow');\n          n.style.opacity = 1;\n          n.style.transform = 'scale(1)';\n        });\n\n        // links off\n        movingPaths.forEach(p=>{\n          p.classList.remove('play','weight-up');\n          p.style.opacity = 0.12;\n        });\n\n        // hide weight / grad labels\n        Object.values(weightLabels).forEach(l=>{ if(l) { l.style.opacity=0; l.classList.remove('label-pop'); }});\n        Object.values(gradLabels).forEach(l=>{ if(l) { l.style.opacity=0; l.classList.remove('label-pop'); }});\n\n        // hide loss glow\n        lossGlow.classList.remove('loss-pulse');\n        lossGlow.style.fill = 'transparent';\n\n        // reset step panels\n        stepEls.forEach((el,i)=> el.classList.toggle('fade', i !== 0));\n      }\n\n      // forward pass animation sequence\n      function playSequence(){\n        clearTimers();\n        resetVisuals();\n        playing = true;\n        playBtn.textContent = 'Pause';\n\n        // Stage times\n        const t0 = 300; // input activation\n        const t1 = 900; // forward signals start\n        const t2 = 2200; // reach hidden activations\n        const t3 = 3000; // forward to output\n        const t4 = 3600; // loss computed\n        const t5 = 4400; // backprop start\n        const t6 = 6200; // gradient maps\n        const t7 = 7600; // weight update and finish\n\n        // 1. Input activation pulse\n        timers.push(setTimeout(()=>{\n          nodes.i0.classList.add('activate','glow');\n          nodes.i1.classList.add('activate','glow');\n          nodes.i2.classList.add('activate','glow');\n\n          // subtle bounce in labels\n          [v_i0,v_i1,v_i2].forEach((el,idx)=>{\n            el.style.transition = 'transform .36s cubic-bezier(.2,.9,.2,1)';\n            el.style.transform = 'translateY(-4px)';\n            setTimeout(()=>el.style.transform='translateY(0px)',420);\n          });\n          // visual highlight step 1\n          stepEls[0].classList.remove('fade');\n        }, t0));\n\n        // 2. Forward moving dashes i->h\n        timers.push(setTimeout(()=>{\n          Object.values(links).forEach(p=>{ p.style.opacity = 0.9; p.classList.add('play'); });\n          // simulated hidden activations (temp values)\n          const hv = [0.72,0.21,0.54,0.13];\n          [v_h0,v_h1,v_h2,v_h3].forEach((el,i)=>{\n            el.textContent = rnd(hv[i]);\n            // node swell\n            const node = nodes['h'+i];\n            node.classList.add('activate','glow');\n            // small delay for each\n            setTimeout(()=> node.classList.remove('activate'), 900);\n          });\n          // highlight step 1->2\n          stepEls[1].classList.remove('fade');\n        }, t1));\n\n        // 3. Hidden -> Output\n        timers.push(setTimeout(()=>{\n          // animate hidden->output links\n          ['l_h0_o0','l_h1_o0','l_h2_o0','l_h3_o0'].forEach(id=>{\n            const p = links[id];\n            p.style.opacity = 0.9;\n            p.classList.add('play');\n          });\n\n          // compute output visually\n          const outVal = 0.57;\n          v_o0.textContent = rnd(outVal);\n          nodes.o0.classList.add('glow','activate');\n        }, t3));\n\n        // 4. Loss computation pulse\n        timers.push(setTimeout(()=>{\n          // target (for display we don't show target; only loss)\n          const target = 1.0;\n          const pred = parseFloat(v_o0.textContent);\n          const loss = 0.5 * Math.pow((target - pred), 2);\n          lossVal.textContent = rnd(loss);\n          lossGlow.classList.add('loss-pulse');\n          lossGlow.style.fill = 'rgba(255,74,121,0.06)';\n\n          // highlight step 2\n          stepEls[1].classList.remove('fade');\n          stepEls[2].classList.remove('fade');\n        }, t4));\n\n        // 5. Backprop: reveal backward colored links and gradient labels\n        timers.push(setTimeout(()=>{\n          // show backward gradients by adding weight-up class to a few links and reveal gradient labels\n          // We'll emphasize three illustrative weights:\n          // i0->h0, i1->h2, h2->o0\n          const fLinks = [\n            links.l_i0_h0,\n            links.l_i1_h2,\n            links.l_h2_o0\n          ];\n\n          // overlaying backward gradient as magenta stroke overlay:\n          fLinks.forEach((p,idx)=>{\n            // duplicate effect by animating stroke color via CSS class toggle\n            p.classList.add('weight-up');\n            p.style.stroke = 'url(#gradBackward)';\n            // show weight label and gradient label with pop\n            const wkey = Object.keys(weightLabels)[idx];\n            const gkey = Object.keys(gradLabels)[idx];\n            const wlab = weightLabels[wkey];\n            const glab = gradLabels[gkey];\n            wlab.style.opacity = 1; wlab.classList.add('label-pop');\n            glab.style.opacity = 1; glab.classList.add('label-pop');\n\n            // set gradient numbers (visual only)\n            if(glab) glab.textContent = ['∂L/∂w = -0.12','∂L/∂w = 0.06','∂L/∂w = -0.21'][idx];\n            if(wlab){\n              const k = Object.keys(weights)[idx];\n              wlab.textContent = 'w=' + rnd(weights[k]);\n            }\n          });\n\n          // Slightly dim forward color and emphasize backward\n          movingPaths.forEach(p=>{\n            p.style.opacity = 0.35;\n          });\n\n        }, t5));\n\n        // 6. Gradient propagation visuals (node sensitivity)\n        timers.push(setTimeout(()=>{\n          // highlight hidden nodes with gradient sensitivity\n          ['h0','h1','h2','h3'].forEach((h,idx)=>{\n            const n = nodes[h];\n            n.classList.add('glow');\n            setTimeout(()=>n.classList.remove('glow'), 900);\n          });\n          // show grad labels appear more\n          stepEls[2].classList.remove('fade');\n        }, t6));\n\n        // 7. Weight update: reduce weight numbers and show small Δ\n        timers.push(setTimeout(()=>{\n          // adjust the illustrative weights slightly\n          weights.i0_h0 -= 0.02;\n          weights.i1_h2 -= 0.01;\n          weights.h2_o0 -= 0.03;\n\n          // animate label change\n          weightLabels.w_i0_h0.textContent = 'w=' + rnd(weights.i0_h0);\n          weightLabels.w_i1_h2.textContent = 'w=' + rnd(weights.i1_h2);\n          weightLabels.w_h2_o0.textContent = 'w=' + rnd(weights.h2_o0);\n\n          // flash green to indicate update\n          Object.values(weightLabels).forEach(l=>{\n            l.style.fill = 'rgba(180,255,180,0.98)';\n            setTimeout(()=>l.style.fill = '#cfeefc', 900);\n          });\n\n          // lighten final nodes and show step 4\n          stepEls[3].classList.remove('fade');\n\n          // finish: reset moving and make everything subtle\n          setTimeout(()=> {\n            movingPaths.forEach(p=>{ p.classList.remove('play'); p.style.opacity = 0.22; p.classList.remove('weight-up'); p.style.stroke = 'url(#gradForward)'; });\n            nodes.o0.classList.remove('activate');\n            lossGlow.classList.remove('loss-pulse');\n            playing = false;\n            playBtn.textContent = 'Play';\n          }, 700);\n\n        }, t7));\n\n      }\n\n      function pauseSequence(){\n        playing = false;\n        playBtn.textContent = 'Play';\n        // Clear pending timers but keep current visual state (simple)\n        clearTimers();\n      }\n\n      function clearTimers(){\n        while(timers.length) clearTimeout(timers.pop());\n      }\n\n      // Reset button\n      resetBtn.addEventListener('click', ()=>{\n        pauseSequence();\n        resetVisuals();\n      });\n\n      // Play / Pause button\n      playBtn.addEventListener('click', ()=>{\n        if(playing){\n          pauseSequence();\n        } else {\n          playSequence();\n        }\n      });\n\n      // initialize\n      resetVisuals();\n\n      // Accessibility: allow space to toggle play/pause\n      window.addEventListener('keydown', (e)=>{\n        if(e.code === 'Space'){\n          e.preventDefault();\n          playBtn.click();\n        }\n      });\n\n      // small intro auto-play once after load (optional subtle)\n      setTimeout(()=>{ playBtn.click(); }, 650);\n\n    })();\n  </script>\n</body>\n</html>"
  },
