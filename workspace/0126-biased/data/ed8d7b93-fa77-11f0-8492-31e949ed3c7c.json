    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bucket Sort Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            background: linear-gradient(to right, #ffe4e1, #ff7f50);\n            color: #333;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            text-align: center;\n            border-radius: 15px;\n            box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n            background: white;\n            padding: 20px;\n            width: 80%;\n            max-width: 800px;\n        }\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 20px;\n            color: #ff4500;\n        }\n        .buckets {\n            display: flex;\n            justify-content: space-around;\n            align-items: flex-end;\n            width: 100%;\n            height: 300px;\n            border: 2px solid #ff4500;\n            border-radius: 10px;\n            overflow: hidden;\n            position: relative;\n        }\n        .bucket {\n            width: 10%;\n            border-left: 1px solid #ff4500;\n            background: #ffcccb;\n            position: relative;\n            transition: all 0.5s ease-in-out;\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n        }\n        .bar {\n            width: 100%;\n            background: #ff6347;\n            position: absolute;\n            bottom: 0;\n            transition: height 0.5s ease-in-out, background 0.5s ease-in-out;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 1.2em;\n            color: #fff;\n            background: #ff4500;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background 0.3s;\n            margin-top: 20px;\n        }\n        button:hover {\n            background: #ff6347;\n        }\n        .hidden {\n            opacity: 0;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Bucket Sort Visualization</h1>\n        <div class=\"buckets\" id=\"buckets\">\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n            <div class=\"bucket\"><div class=\"bar hidden\" style=\"height: 0%;\"></div></div>\n        </div>\n        <button id=\"startButton\">Start Sorting</button>\n    </div>\n\n    <script>\n        const buckets = document.querySelectorAll('.bucket');\n        const bars = document.querySelectorAll('.bar');\n        const button = document.getElementById('startButton');\n\n        const values = [25, 10, 50, 30, 15, 5, 45, 20, 40, 35];\n\n        function animateBuckets(sortedValues) {\n            sortedValues.forEach((value, index) => {\n                setTimeout(() => {\n                    const bucketIndex = Math.floor(value / 10);\n                    const bar = bars[bucketIndex];\n                    bar.style.height = `${value}%`;\n                    bar.classList.remove('hidden');\n                    bar.style.background = '#228B22';\n                }, index * 500);\n            });\n        }\n\n        button.addEventListener('click', () => {\n            const sortedValues = bucketSort(values);\n            animateBuckets(sortedValues);\n        });\n\n        function bucketSort(arr) {\n            const buckets = Array.from({ length: 10 }, () => []);\n            arr.forEach(value => {\n                const index = Math.floor(value / 10);\n                buckets[index].push(value);\n            });\n            return buckets.flat().sort((a, b) => a - b);\n        }\n    </script>\n</body>\n</html>"
