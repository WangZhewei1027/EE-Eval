    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Hash Table Interactive Explorer</title>\n<style>\n/* Extremely minimal visual styling: plain black on white, basic layout */\nhtml,body { margin:8px; padding:0; font-family: monospace; color: black; background: white; }\nsection { margin-bottom:12px; }\nlabel { display:inline-block; min-width:110px; }\ninput, select, button, textarea { font-family: monospace; font-size:13px; }\ntextarea { width:100%; height:120px; }\n.small { width:60px; }\n.medium { width:140px; }\n.large { width:300px; }\n.inline { display:inline-block; vertical-align:middle; margin-right:8px; }\n.tableView { white-space: pre; font-family: monospace; }\n.controls { margin-bottom:8px; }\n</style>\n</head>\n<body>\n\n<h2>Hash Table Interactive Explorer</h2>\n<p>Plain interface to create and explore hash tables with many controls. Default behaviors: separate chaining or open addressing variants, step-by-step probes, branching, snapshots, rehashing, custom hash function. Interface is intentionally basic.</p>\n\n<section id=\"creation\">\n  <fieldset>\n    <legend>Create / Configure Hash Table</legend>\n    <div class=\"controls\">\n      <label>Capacity (array size):</label>\n      <input id=\"capacity\" class=\"small\" type=\"number\" value=\"11\" min=\"3\" step=\"1\">\n      <label>Resize type:</label>\n      <select id=\"resizeType\">\n        <option value=\"none\">Manual only</option>\n        <option value=\"auto\">Auto when load &gt; threshold</option>\n      </select>\n      <label>Threshold:</label>\n      <input id=\"threshold\" class=\"small\" type=\"number\" value=\"0.7\" step=\"0.05\" min=\"0.05\" max=\"1\">\n    </div>\n\n    <div class=\"controls\">\n      <label>Collision scheme:</label>\n      <select id=\"scheme\">\n        <option value=\"chaining\">Separate Chaining</option>\n        <option value=\"linear\">Open Addressing - Linear Probing</option>\n        <option value=\"quadratic\">Open Addressing - Quadratic Probing</option>\n        <option value=\"double\">Open Addressing - Double Hashing</option>\n      </select>\n      <label>Quadratic c1,c2:</label>\n      <input id=\"c1\" class=\"small\" type=\"number\" value=\"1\" step=\"1\">\n      <input id=\"c2\" class=\"small\" type=\"number\" value=\"3\" step=\"1\">\n      <label>Double hash base:</label>\n      <input id=\"doubleBase\" class=\"small\" type=\"number\" value=\"7\" step=\"1\">\n    </div>\n\n    <div class=\"controls\">\n      <label>Key type:</label>\n      <select id=\"keyType\">\n        <option value=\"string\">String</option>\n        <option value=\"int\">Integer</option>\n      </select>\n      <label>Allow duplicates:</label>\n      <select id=\"allowDup\">\n        <option value=\"no\">No</option>\n        <option value=\"yes\">Yes (chaining only)</option>\n      </select>\n    </div>\n\n    <div class=\"controls\">\n      <button id=\"createBtn\">Create Table</button>\n      <button id=\"clearBtn\">Clear Table (remove all)</button>\n      <button id=\"resetBtn\">Reset Everything</button>\n    </div>\n  </fieldset>\n</section>\n\n<section id=\"hashFunction\">\n  <fieldset>\n    <legend>Hash Function</legend>\n    <div class=\"controls\">\n      <label>Built-in:</label>\n      <select id=\"builtinHash\">\n        <option value=\"default\">Default (int mod, string polynomial)</option>\n        <option value=\"mod10\">Simple mod10 (key mod capacity)</option>\n        <option value=\"sumChars\">Sum of char codes (string)</option>\n        <option value=\"fnv\">Simple FNV-ish</option>\n      </select>\n      <label>Custom (JS expr):</label>\n    </div>\n    <div>\n      <textarea id=\"customHash\" placeholder=\"Example: return (typeof key==='number' ? (key*2654435761) >>> 0 : [...String(key)].reduce((a,c)=>a*31 + c.charCodeAt(0),0)) % cap;\"></textarea>\n    </div>\n    <div class=\"controls\">\n      <button id=\"useCustomBtn\">Use Custom Hash</button>\n      <button id=\"testHashBtn\">Test Hash on sample key</button>\n      <input id=\"testKey\" class=\"medium\" placeholder=\"sample key\">\n      <span id=\"testHashResult\"></span>\n    </div>\n    <div><small>Custom function receives parameters: key, cap, i (probe index). It must return a non-negative integer. Use 'return ...;'.</small></div>\n  </fieldset>\n</section>\n\n<section id=\"operations\">\n  <fieldset>\n    <legend>Operations</legend>\n    <div class=\"controls\">\n      <label>Insert (single or CSV):</label>\n      <input id=\"insertInput\" class=\"large\" placeholder=\"e.g. 5, 12, abc\">\n      <button id=\"insertBtn\">Insert</button>\n      <button id=\"insertStepBtn\">Insert Step-by-Step</button>\n    </div>\n\n    <div class=\"controls\">\n      <label>Search:</label>\n      <input id=\"searchInput\" class=\"large\" placeholder=\"key\">\n      <button id=\"searchBtn\">Search</button>\n      <button id=\"searchStepBtn\">Search Step-by-Step</button>\n    </div>\n\n    <div class=\"controls\">\n      <label>Delete:</label>\n      <input id=\"deleteInput\" class=\"large\" placeholder=\"key\">\n      <button id=\"deleteBtn\">Delete</button>\n      <button id=\"deleteStepBtn\">Delete Step-by-Step</button>\n    </div>\n\n    <div class=\"controls\">\n      <label>Batch random:</label>\n      <input id=\"randCount\" class=\"small\" type=\"number\" value=\"5\">\n      <label>range/min:</label>\n      <input id=\"randMin\" class=\"small\" type=\"number\" value=\"0\">\n      <label>max:</label>\n      <input id=\"randMax\" class=\"small\" type=\"number\" value=\"100\">\n      <button id=\"randInsertBtn\">Generate & Insert</button>\n    </div>\n\n    <div class=\"controls\">\n      <label>Import JSON:</label>\n      <input id=\"importJSON\" class=\"large\" placeholder='[ \"a\", \"b\", 5 ]'>\n      <button id=\"importBtn\">Import</button>\n      <button id=\"exportBtn\">Export Table JSON</button>\n      <button id=\"exportFullBtn\">Export Full State (JSON)</button>\n    </div>\n  </fieldset>\n</section>\n\n<section id=\"stepper\">\n  <fieldset>\n    <legend>Stepper / Execution Controls</legend>\n    <div class=\"controls\">\n      <label>Mode:</label>\n      <select id=\"stepMode\">\n        <option value=\"full\">Operations apply immediately (no stepping)</option>\n        <option value=\"step\">Create step sequence for each operation</option>\n      </select>\n      <label>Auto-run:</label>\n      <input id=\"autorun\" type=\"checkbox\">\n      <label>Speed (ms):</label>\n      <input id=\"speed\" type=\"range\" min=\"100\" max=\"2000\" value=\"600\">\n      <span id=\"speedVal\">600</span>\n    </div>\n\n    <div class=\"controls\">\n      <button id=\"stepPrev\">Step ◀</button>\n      <button id=\"stepNext\">Step ▶</button>\n      <button id=\"playPause\">Play</button>\n      <button id=\"jumpEnd\">Jump End</button>\n      <button id=\"clearSteps\">Clear Steps</button>\n    </div>\n\n    <div class=\"controls\">\n      <label>Snapshot name:</label>\n      <input id=\"snapshotName\" class=\"medium\" placeholder=\"name\">\n      <button id=\"saveSnapshot\">Save Snapshot</button>\n      <button id=\"listSnapshots\">List Snapshots</button>\n      <select id=\"snapshotList\" class=\"medium\"></select>\n      <button id=\"restoreSnapshot\">Restore</button>\n      <button id=\"branchSnapshot\">Branch (duplicate)</button>\n      <button id=\"deleteSnapshot\">Delete</button>\n    </div>\n\n    <div class=\"controls\">\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n    </div>\n  </fieldset>\n</section>\n\n<section id=\"visualization\">\n  <fieldset>\n    <legend>Visualization / Metrics</legend>\n    <div class=\"controls\">\n      <label>Show probes:</label>\n      <input id=\"showProbes\" type=\"checkbox\" checked>\n      <label>Show index numbers:</label>\n      <input id=\"showIndex\" type=\"checkbox\" checked>\n      <label>Compact view:</label>\n      <input id=\"compact\" type=\"checkbox\">\n    </div>\n    <div class=\"controls\">\n      <button id=\"rehashBtn\">Manual Rehash (to capacity)</button>\n      <label>New capacity:</label>\n      <input id=\"manualCap\" class=\"small\" type=\"number\" value=\"23\" min=\"3\">\n      <button id=\"rehashToBtn\">Rehash To</button>\n      <label>Find next prime:</label>\n      <button id=\"nextPrimeBtn\">Next Prime ≥ manual cap</button>\n    </div>\n    <div class=\"controls\">\n      <label>Metrics:</label>\n      <button id=\"computeMetrics\">Compute</button>\n      <div id=\"metrics\" style=\"display:inline-block; margin-left:10px;\"></div>\n    </div>\n  </fieldset>\n</section>\n\n<section id=\"display\">\n  <fieldset>\n    <legend>Table State & Logs</legend>\n    <div>\n      <pre id=\"tableDisplay\" class=\"tableView\"></pre>\n    </div>\n    <div class=\"controls\">\n      <label>Operation Log:</label>\n      <button id=\"clearLog\">Clear Log</button>\n    </div>\n    <textarea id=\"log\" placeholder=\"Log / step descriptions appear here\"></textarea>\n  </fieldset>\n</section>\n\n<script>\n/*\nHash Table Interactive Explorer\n- Supports chaining, linear/quadratic/double hashing\n- Step sequences and stepping controls\n- Snapshots, undo/redo, branching\n- Custom hash function via JS expression\n- Extremely minimal visual style\n*/\n\n// Utilities\nfunction clone(obj) { return JSON.parse(JSON.stringify(obj)); }\nfunction isPrime(n) {\n  if (n < 2) return false;\n  for (let i = 2; i*i <= n; i++) if (n % i === 0) return false;\n  return true;\n}\nfunction nextPrime(n) {\n  while (!isPrime(n)) n++;\n  return n;\n}\nfunction now() { return (new Date()).toISOString(); }\nfunction parseKeys(text, keyType) {\n  if (text === undefined || text === null) return [];\n  const parts = text.split(/[\\n,]+/).map(s=>s.trim()).filter(s=>s.length>0);\n  return parts.map(p => keyType==='int' ? (isNaN(Number(p)) ? p : Number(p)) : p);\n}\n\n// Hash function manager\nconst HashManager = (function(){\n  let customFn = null;\n  let builtin = 'default';\n  function setBuiltin(name) { builtin = name; }\n  function setCustom(code) {\n    if (!code || code.trim()==='') { customFn = null; return true; }\n    try {\n      // Wrap in function constructor\n      const fn = new Function('key','cap','i', code);\n      // test run\n      const r = fn('x', 11, 0);\n      if (typeof r !== 'number') {\n        // allow but coerce later\n      }\n      customFn = fn;\n      return true;\n    } catch(e) {\n      customFn = null;\n      return e.toString();\n    }\n  }\n  function hash(key, cap, i) {\n    // prefer custom\n    if (customFn) {\n      try {\n        let r = customFn(key, cap, i||0);\n        r = Number(r);\n        if (!Number.isFinite(r) || isNaN(r)) r = 0;\n        r = Math.abs(Math.floor(r));\n        return r % cap;\n      } catch(e) {\n        // fallback\n      }\n    }\n    // builtin strategies\n    if (builtin === 'mod10') {\n      let k = typeof key === 'number' ? key : Number(key) || 0;\n      return Math.abs(Math.floor(k)) % cap;\n    }\n    if (builtin === 'sumChars') {\n      const s = String(key);\n      let sum = 0;\n      for (let ch of s) sum += ch.charCodeAt(0);\n      return sum % cap;\n    }\n    if (builtin === 'fnv') {\n      const s = String(key);\n      let h = 2166136261 >>> 0;\n      for (let i2=0;i2<s.length;i2++) {\n        h ^= s.charCodeAt(i2);\n        h = Math.imul(h, 16777619) >>> 0;\n      }\n      return (h >>> 0) % cap;\n    }\n    // default\n    if (typeof key === 'number') {\n      let k = Math.floor(key);\n      k = k >>> 0;\n      // multiplicative hashing\n      const A = 2654435761; // Knuth\n      return ((k * A) >>> 0) % cap;\n    } else {\n      // polynomial rolling\n      const s = String(key);\n      let h = 0;\n      for (let i2=0;i2<s.length;i2++) h = (h*31 + s.charCodeAt(i2)) >>> 0;\n      return h % cap;\n    }\n  }\n  return { setCustom, setBuiltin, hash };\n})();\n\n// HashTable implementation\nclass HashTable {\n  constructor(opts) {\n    this.capacity = opts.capacity || 11;\n    this.scheme = opts.scheme || 'chaining';\n    this.allowDup = !!opts.allowDup;\n    this.keyType = opts.keyType || 'string';\n    this.c1 = opts.c1 || 1;\n    this.c2 = opts.c2 || 3;\n    this.doubleBase = opts.doubleBase || 7;\n    this.threshold = (opts.threshold===undefined?0.7:opts.threshold);\n    // internal structures\n    this.size = 0;\n    this.tombstones = 0;\n    this._initArray();\n  }\n  _initArray() {\n    if (this.scheme === 'chaining') {\n      this.arr = new Array(this.capacity).fill(null).map(()=>[]);\n    } else {\n      this.arr = new Array(this.capacity).fill(null).map(()=>({status:0,key:null}));\n    }\n  }\n\n  toJSON() {\n    return {\n      capacity: this.capacity,\n      scheme: this.scheme,\n      allowDup: this.allowDup,\n      keyType: this.keyType,\n      c1: this.c1,\n      c2: this.c2,\n      doubleBase: this.doubleBase,\n      threshold: this.threshold,\n      size: this.size,\n      tombstones: this.tombstones,\n      arr: clone(this.arr)\n    };\n  }\n\n  loadFactor() {\n    if (this.scheme === 'chaining') {\n      let total = 0;\n      for (let bucket of this.arr) total += bucket.length;\n      return total / this.capacity;\n    } else {\n      return this.size / this.capacity;\n    }\n  }\n\n  // compute probe indices generator\n  *probesFor(key) {\n    const cap = this.capacity;\n    const base = HashManager.hash(key, cap, 0);\n    if (this.scheme === 'chaining') {\n      yield base;\n      return;\n    }\n    if (this.scheme === 'linear') {\n      for (let i=0;i<cap;i++) yield (base + i) % cap;\n    } else if (this.scheme === 'quadratic') {\n      for (let i=0;i<cap;i++) {\n        let idx = (base + this.c1*i + this.c2*i*i) % cap;\n        if (idx<0) idx += cap;\n        yield idx;\n      }\n    } else if (this.scheme === 'double') {\n      // second hash should be non-zero\n      let h2 = HashManager.hash(key, this.doubleBase || (cap-1), 1) % cap;\n      if (h2 === 0) h2 = 1;\n      for (let i=0;i<cap;i++) yield (base + i*h2) % cap;\n    } else {\n      for (let i=0;i<cap;i++) yield (base + i) % cap;\n    }\n  }\n\n  // Return array of probe steps (index, content copy)\n  probeSequenceFor(key) {\n    const seq = [];\n    for (let idx of this.probesFor(key)) {\n      const content = (this.scheme==='chaining') ? clone(this.arr[idx]) : clone(this.arr[idx]);\n      seq.push({idx, content});\n    }\n    return seq;\n  }\n\n  // Insert with optional stepping: produce steps array of snapshots\n  insert(key, options={step:false, allowOverwrite:false}) {\n    const keyVal = this._normalizeKey(key);\n    if (!options.step) {\n      // direct insert\n      if (this.scheme === 'chaining') {\n        if (!this.allowDup) {\n          // check existing\n          for (let b of this.arr) if (b.includes(keyVal)) { return {ok:false, reason:'duplicate'}; }\n        }\n        const idx = HashManager.hash(keyVal, this.capacity, 0);\n        this.arr[idx].push(keyVal);\n        this.size++;\n        return {ok:true, idx};\n      } else {\n        for (let idx of this.probesFor(keyVal)) {\n          const slot = this.arr[idx];\n          if (slot.status === 0 || slot.status === 2) {\n            slot.key = keyVal;\n            if (slot.status !== 1) {\n              if (slot.status === 2) this.tombstones--;\n              slot.status = 1;\n              this.size++;\n            }\n            return {ok:true, idx};\n          } else if (slot.status === 1 && slot.key === keyVal) {\n            if (options.allowOverwrite) {\n              slot.key = keyVal;\n              return {ok:true, idx};\n            } else {\n              return {ok:false, reason:'duplicate'};\n            }\n          }\n        }\n        return {ok:false, reason:'table full'};\n      }\n    } else {\n      // produce steps\n      const steps = [];\n      if (this.scheme === 'chaining') {\n        const base = HashManager.hash(keyVal, this.capacity, 0);\n        steps.push({desc:`Hash(${keyVal}) -> ${base}`, snapshot:this._snapshot()});\n        if (!this.allowDup && this.arr[base].includes(keyVal)) {\n          steps.push({desc:`Duplicate detected at bucket ${base}`, snapshot:this._snapshot()});\n          return steps;\n        }\n        // perform insert\n        const snapshotBefore = this._snapshot();\n        snapshotBefore.desc = `Before insert into bucket ${base}`;\n        steps.push({desc: snapshotBefore.desc, snapshot: clone(snapshotBefore)});\n        // modify actual array (to reflect step)\n        this.arr[base].push(keyVal); this.size++;\n        const snapshotAfter = this._snapshot(); snapshotAfter.desc=`Inserted ${keyVal} into bucket ${base}`;\n        steps.push({desc:snapshotAfter.desc, snapshot: clone(snapshotAfter)});\n        return steps;\n      } else {\n        // open addressing steps\n        let i = 0;\n        for (let idx of this.probesFor(keyVal)) {\n          steps.push({desc:`Probe #${i} -> index ${idx}`, snapshot:this._snapshot()});\n          const slot = this.arr[idx];\n          if (slot.status === 0 || slot.status === 2) {\n            // insert\n            const before = this._snapshot();\n            steps.push({desc:`Inserting at index ${idx}`, snapshot: before});\n            if (slot.status === 2) this.tombstones--;\n            this.arr[idx] = {status:1, key:keyVal};\n            this.size++;\n            const after = this._snapshot();\n            steps.push({desc:`Inserted ${keyVal} at ${idx}`, snapshot: after});\n            return steps;\n          } else if (slot.status === 1 && slot.key === keyVal) {\n            steps.push({desc:`Key ${keyVal} already present at ${idx}`, snapshot:this._snapshot()});\n            return steps;\n          }\n          i++;\n        }\n        steps.push({desc:'Table full, insert failed', snapshot:this._snapshot()});\n        return steps;\n      }\n    }\n  }\n\n  search(key, options={step:false}) {\n    const keyVal = this._normalizeKey(key);\n    if (!options.step) {\n      if (this.scheme === 'chaining') {\n        const idx = HashManager.hash(keyVal, this.capacity, 0);\n        const found = this.arr[idx].includes(keyVal);\n        return {found, idx, bucket: clone(this.arr[idx])};\n      } else {\n        let probes = 0;\n        for (let idx of this.probesFor(keyVal)) {\n          probes++;\n          const slot = this.arr[idx];\n          if (slot.status === 0) return {found:false, idx, probes};\n          if (slot.status === 1 && slot.key === keyVal) return {found:true, idx, probes};\n        }\n        return {found:false};\n      }\n    } else {\n      const steps = [];\n      if (this.scheme === 'chaining') {\n        const base = HashManager.hash(keyVal, this.capacity, 0);\n        steps.push({desc:`Hash(${keyVal}) -> ${base}`, snapshot:this._snapshot()});\n        const bucket = this.arr[base];\n        steps.push({desc:`Inspect bucket ${base} contents: [${bucket.join(', ')}]`, snapshot:this._snapshot()});\n        if (bucket.includes(keyVal)) steps.push({desc:`Found ${keyVal} in bucket ${base}`, snapshot:this._snapshot()});\n        else steps.push({desc:`${keyVal} not found in bucket ${base}`, snapshot:this._snapshot()});\n        return steps;\n      } else {\n        let i=0;\n        for (let idx of this.probesFor(keyVal)) {\n          steps.push({desc:`Probe #${i} -> index ${idx}`, snapshot:this._snapshot()});\n          const slot = this.arr[idx];\n          if (slot.status === 0) {\n            steps.push({desc:`Empty slot at ${idx}, search terminates (not found)`, snapshot:this._snapshot()});\n            return steps;\n          }\n          if (slot.status === 1 && slot.key === keyVal) {\n            steps.push({desc:`Found ${keyVal} at ${idx}`, snapshot:this._snapshot()});\n            return steps;\n          } else {\n            steps.push({desc:`Slot ${idx} contains ${slot.status===1?slot.key:'<tombstone>'}, continue probing`, snapshot:this._snapshot()});\n          }\n          i++;\n        }\n        steps.push({desc:`Exhausted probes, not found`, snapshot:this._snapshot()});\n        return steps;\n      }\n    }\n  }\n\n  delete(key, options={step:false}) {\n    const keyVal = this._normalizeKey(key);\n    if (!options.step) {\n      if (this.scheme === 'chaining') {\n        const idx = HashManager.hash(keyVal, this.capacity, 0);\n        const bucket = this.arr[idx];\n        const ind = bucket.indexOf(keyVal);\n        if (ind >= 0) {\n          bucket.splice(ind,1);\n          this.size--;\n          return {ok:true, idx};\n        }\n        return {ok:false, reason:'not found'};\n      } else {\n        for (let idx of this.probesFor(keyVal)) {\n          const slot = this.arr[idx];\n          if (slot.status === 0) return {ok:false, reason:'not found'};\n          if (slot.status === 1 && slot.key === keyVal) {\n            slot.status = 2; slot.key = null;\n            this.size--; this.tombstones++;\n            return {ok:true, idx};\n          }\n        }\n        return {ok:false, reason:'not found'};\n      }\n    } else {\n      const steps = [];\n      if (this.scheme === 'chaining') {\n        const base = HashManager.hash(keyVal, this.capacity, 0);\n        steps.push({desc:`Hash -> ${base}`, snapshot:this._snapshot()});\n        const bucket = this.arr[base];\n        steps.push({desc:`Bucket ${base} contains [${bucket.join(', ')}]`, snapshot:this._snapshot()});\n        const ind = bucket.indexOf(keyVal);\n        if (ind >= 0) {\n          steps.push({desc:`Deleting ${keyVal} from bucket ${base}`, snapshot:this._snapshot()});\n          bucket.splice(ind,1);\n          this.size--;\n          steps.push({desc:`Deleted`, snapshot:this._snapshot()});\n        } else {\n          steps.push({desc:`Not found in bucket ${base}`, snapshot:this._snapshot()});\n        }\n        return steps;\n      } else {\n        let i=0;\n        for (let idx of this.probesFor(keyVal)) {\n          steps.push({desc:`Probe #${i} -> index ${idx}`, snapshot:this._snapshot()});\n          const slot = this.arr[idx];\n          if (slot.status === 0) {\n            steps.push({desc:`Empty slot at ${idx}, not found`, snapshot:this._snapshot()});\n            return steps;\n          }\n          if (slot.status === 1 && slot.key === keyVal) {\n            steps.push({desc:`Found ${keyVal} at ${idx}, marking tombstone`, snapshot:this._snapshot()});\n            slot.status = 2; slot.key=null; this.size--; this.tombstones++;\n            steps.push({desc:`Deleted`, snapshot:this._snapshot()});\n            return steps;\n          } else {\n            steps.push({desc:`Slot ${idx} contains ${slot.status===1?slot.key:'<tombstone>'}, continue`, snapshot:this._snapshot()});\n          }\n          i++;\n        }\n        steps.push({desc:`Probes exhausted, not found`, snapshot:this._snapshot()});\n        return steps;\n      }\n    }\n  }\n\n  _normalizeKey(k) {\n    if (this.keyType === 'int') {\n      const n = Number(k);\n      return isNaN(n) ? 0 : Math.floor(n);\n    } else {\n      return String(k);\n    }\n  }\n\n  _snapshot() {\n    return this.toJSON();\n  }\n\n  rehashTo(newCap) {\n    const old = this._snapshot();\n    // create new array and insert all existing keys\n    const savedKeys = [];\n    if (this.scheme === 'chaining') {\n      for (let bucket of old.arr) for (let k of bucket) savedKeys.push(k);\n    } else {\n      for (let slot of old.arr) if (slot.status===1) savedKeys.push(slot.key);\n    }\n    // reset\n    this.capacity = newCap;\n    this._initArray();\n    this.size = 0;\n    this.tombstones = 0;\n    // re-insert keys (no stepping)\n    for (let k of savedKeys) {\n      this.insert(k, {step:false});\n    }\n    return {before:old, after:this._snapshot()};\n  }\n\n  statistics() {\n    const stats = {};\n    stats.capacity = this.capacity;\n    stats.size = this.size;\n    if (this.scheme === 'chaining') {\n      const lens = this.arr.map(b => b.length);\n      stats.buckets = lens;\n      stats.load = (lens.reduce((a,b)=>a+b,0)/this.capacity);\n      stats.avgBucket = (lens.reduce((a,b)=>a+b,0)/this.capacity).toFixed(3);\n      stats.maxBucket = Math.max(...lens);\n    } else {\n      const clusters = [];\n      let current = 0;\n      for (let s of this.arr) {\n        if (s.status === 1) current++; else { if (current>0) clusters.push(current); current=0; }\n      }\n      if (current>0) clusters.push(current);\n      stats.clusters = clusters;\n      stats.load = (this.size/this.capacity);\n      stats.tombstones = this.tombstones;\n      // average probe: approximate by checking search length for all keys\n      let totalProbe=0, count=0, maxProbe=0;\n      for (let slot of this.arr) if (slot.status===1) {\n        count++;\n      }\n      for (let i=0;i<this.capacity;i++) {\n        const slot = this.arr[i];\n        if (slot.status===1) {\n          // measure probes required to find this key\n          let p=0;\n          for (let idx of this.probesFor(slot.key)) {\n            p++;\n            if (idx===i) break;\n          }\n          totalProbe += p;\n          if (p>maxProbe) maxProbe=p;\n        }\n      }\n      stats.avgProbe = (count>0? (totalProbe/count).toFixed(3) : 0);\n      stats.maxProbe = maxProbe;\n    }\n    return stats;\n  }\n}\n\n// Application state and UI wiring\nconst App = (function(){\n  let table = null;\n  let steps = []; // current step sequence\n  let stepIndex = -1;\n  let playing = false;\n  let playTimer = null;\n  let history = []; // snapshots for undo\n  let future = []; // redo stack\n  let snapshots = {}; // named snapshots stored\n  const logEl = document.getElementById('log');\n  const tableDisplay = document.getElementById('tableDisplay');\n\n  function log(msg) {\n    const line = `[${now()}] ${msg}`;\n    logEl.value = line + \"\\n\" + logEl.value;\n  }\n\n  function createFromUI() {\n    const cap = Math.max(3, Math.floor(Number(document.getElementById('capacity').value) || 11));\n    const scheme = document.getElementById('scheme').value;\n    const keyType = document.getElementById('keyType').value;\n    const allowDup = document.getElementById('allowDup').value === 'yes';\n    const c1 = Math.floor(Number(document.getElementById('c1').value) || 1);\n    const c2 = Math.floor(Number(document.getElementById('c2').value) || 3);\n    const doubleBase = Math.max(2, Math.floor(Number(document.getElementById('doubleBase').value) || 7));\n    const threshold = parseFloat(document.getElementById('threshold').value) || 0.7;\n    table = new HashTable({capacity:cap, scheme, keyType, allowDup, c1, c2, doubleBase, threshold});\n    steps = []; stepIndex = -1;\n    history = [clone(table._snapshot())]; future = [];\n    updateDisplay();\n    log(`Created table: cap=${cap}, scheme=${scheme}, keyType=${keyType}`);\n  }\n\n  function clearTable() {\n    if (!table) return;\n    table._initArray();\n    table.size = 0;\n    table.tombstones = 0;\n    history.push(clone(table._snapshot())); future=[]; \n    updateDisplay();\n    log('Cleared table contents');\n  }\n\n  function resetAll() {\n    table = null; steps = []; stepIndex = -1; history=[]; future=[]; snapshots={};\n    document.getElementById('log').value = '';\n    document.getElementById('tableDisplay').textContent = '';\n    log('Reset application state');\n  }\n\n  function applyBuiltinHash() {\n    const b = document.getElementById('builtinHash').value;\n    HashManager.setBuiltin(b);\n    log(`Using builtin hash: ${b}`);\n  }\n  function setCustomHash() {\n    const code = document.getElementById('customHash').value;\n    const r = HashManager.setCustom(code);\n    if (r===true) {\n      log('Custom hash set');\n      document.getElementById('testHashResult').textContent = 'Custom set';\n    } else {\n      log('Failed to set custom hash: ' + r);\n      document.getElementById('testHashResult').textContent = 'Error: ' + r;\n    }\n  }\n  function testHashOnSample() {\n    const key = document.getElementById('testKey').value;\n    if (!table) {\n      document.getElementById('testHashResult').textContent = 'No table';\n      return;\n    }\n    try {\n      const v = HashManager.hash(key, table.capacity, 0);\n      document.getElementById('testHashResult').textContent = 'hash -> ' + v;\n    } catch(e) {\n      document.getElementById('testHashResult').textContent = 'error';\n    }\n  }\n\n  function insertHandler(stepMode=false) {\n    if (!table) { log('No table present. Create one first.'); return; }\n    const raw = document.getElementById('insertInput').value;\n    const keys = parseKeys(raw, table.keyType);\n    if (keys.length === 0) { log('No keys to insert'); return; }\n    if (!stepMode && document.getElementById('stepMode').value==='step') stepMode=true;\n    if (!stepMode) {\n      for (let k of keys) {\n        const res = table.insert(k, {step:false});\n        if (res.ok) log(`Inserted ${k} at ${res.idx}`);\n        else log(`Insert ${k} failed: ${res.reason || 'unknown'}`);\n        // auto rehash if enabled\n        autoRehashIfNeeded();\n      }\n      history.push(clone(table._snapshot())); future=[];\n      updateDisplay();\n    } else {\n      // build steps for each key sequentially\n      steps = [];\n      for (let k of keys) {\n        const s = table.insert(k, {step:true});\n        for (let st of s) {\n          steps.push(st);\n        }\n        // after each operation, push a snapshot of the table state (already performed in steps)\n        // continue to next key with table modified by steps\n        autoRehashIfNeeded();\n      }\n      stepIndex = -1;\n      updateDisplay();\n      playStepsIfAuto();\n      log(`Prepared ${steps.length} steps for insertion of ${keys.length} keys`);\n    }\n  }\n\n  function searchHandler(stepMode=false) {\n    if (!table) { log('No table'); return; }\n    const raw = document.getElementById('searchInput').value;\n    const keys = parseKeys(raw, table.keyType);\n    if (keys.length===0) { log('No keys to search'); return; }\n    if (!stepMode && document.getElementById('stepMode').value==='step') stepMode=true;\n    if (!stepMode) {\n      for (let k of keys) {\n        const r = table.search(k, {step:false});\n        if (r.found) log(`Found ${k} at index ${r.idx} after ${r.probes||'?'} probes`);\n        else log(`Not found: ${k}`);\n      }\n      updateDisplay();\n    } else {\n      steps = [];\n      for (let k of keys) {\n        const s = table.search(k, {step:true});\n        for (let st of s) steps.push(st);\n      }\n      stepIndex = -1;\n      updateDisplay(); playStepsIfAuto();\n      log(`Prepared ${steps.length} steps for searching ${keys.length} keys`);\n    }\n  }\n\n  function deleteHandler(stepMode=false) {\n    if (!table) { log('No table'); return; }\n    const raw = document.getElementById('deleteInput').value;\n    const keys = parseKeys(raw, table.keyType);\n    if (keys.length === 0) { log('No keys to delete'); return; }\n    if (!stepMode && document.getElementById('stepMode').value==='step') stepMode=true;\n    if (!stepMode) {\n      for (let k of keys) {\n        const r = table.delete(k, {step:false});\n        if (r.ok) log(`Deleted ${k} at index ${r.idx}`);\n        else log(`Delete failed for ${k}`);\n      }\n      history.push(clone(table._snapshot())); future=[];\n      updateDisplay();\n    } else {\n      steps = [];\n      for (let k of keys) {\n        const s = table.delete(k, {step:true});\n        for (let st of s) steps.push(st);\n      }\n      stepIndex = -1;\n      updateDisplay(); playStepsIfAuto();\n      log(`Prepared ${steps.length} steps for deletion of ${keys.length} keys`);\n    }\n  }\n\n  function randomInsert() {\n    if (!table) { log('No table'); return; }\n    const cnt = Math.max(1, parseInt(document.getElementById('randCount').value) || 1);\n    const min = parseInt(document.getElementById('randMin').value) || 0;\n    const max = parseInt(document.getElementById('randMax').value) || 100;\n    const generated = [];\n    for (let i=0;i<cnt;i++) {\n      let val;\n      if (table.keyType === 'int') {\n        val = Math.floor(Math.random()*(max-min+1)) + min;\n      } else {\n        val = 'r' + Math.random().toString(36).slice(2,8);\n      }\n      generated.push(val);\n      const r = table.insert(val, {step:false});\n      if (r.ok) log(`Random inserted ${val} at ${r.idx}`);\n      else log(`Random insert ${val} failed: ${r.reason||'unknown'}`);\n    }\n    history.push(clone(table._snapshot())); future=[];\n    updateDisplay();\n    log(`Inserted ${generated.length} random keys`);\n  }\n\n  function importJSON() {\n    if (!table) { log('No table'); return; }\n    const raw = document.getElementById('importJSON').value;\n    if (!raw) { log('No JSON'); return; }\n    try {\n      const arr = JSON.parse(raw);\n      if (!Array.isArray(arr)) { log('JSON must be an array'); return; }\n      for (let k of arr) {\n        table.insert(k, {step:false});\n      }\n      history.push(clone(table._snapshot())); future=[];\n      updateDisplay();\n      log(`Imported ${arr.length} items`);\n    } catch(e) {\n      log('Import error: ' + e);\n    }\n  }\n\n  function exportJSON() {\n    if (!table) { log('No table'); return; }\n    let arr=[];\n    if (table.scheme === 'chaining') {\n      for (let b of table.arr) for (let k of b) arr.push(k);\n    } else {\n      for (let s of table.arr) if (s.status===1) arr.push(s.key);\n    }\n    const out = JSON.stringify(arr);\n    copyToClipboard(out);\n    log('Exported table keys JSON to clipboard');\n  }\n\n  function exportFullState() {\n    if (!table) { log('No table'); return; }\n    const out = JSON.stringify(table.toJSON());\n    copyToClipboard(out);\n    log('Exported full state JSON to clipboard');\n  }\n\n  function copyToClipboard(text) {\n    try {\n      navigator.clipboard.writeText(text).then(()=>{}, ()=>{ prompt('Copy (fallback):', text); });\n    } catch(e) { prompt('Copy:', text); }\n  }\n\n  function autoRehashIfNeeded() {\n    if (!table) return;\n    const mode = document.getElementById('resizeType').value;\n    const th = parseFloat(document.getElementById('threshold').value) || table.threshold;\n    if (mode === 'auto') {\n      if (table.loadFactor() > th) {\n        // rehash to next prime roughly double size\n        const target = nextPrime(Math.max(3, Math.floor(table.capacity * 2)));\n        const before = clone(table._snapshot());\n        table.rehashTo(target);\n        history.push(clone(table._snapshot())); future=[];\n        log(`Auto-rehashed: new capacity ${target}`);\n      }\n    }\n  }\n\n  // Stepper controls\n  function updateDisplay() {\n    // show table array\n    if (!table) { tableDisplay.textContent = 'No table created.'; return; }\n    const showIndex = document.getElementById('showIndex').checked;\n    const compact = document.getElementById('compact').checked;\n    let out = '';\n    out += `Capacity: ${table.capacity}    Scheme: ${table.scheme}    Size: ${table.size}    Tombstones: ${table.tombstones}\\n`;\n    out += `Load factor: ${table.loadFactor().toFixed(3)}    KeyType: ${table.keyType}\\n\\n`;\n    if (table.scheme === 'chaining') {\n      for (let i=0;i<table.capacity;i++) {\n        const bucket = table.arr[i];\n        if (compact) out += `${i}: [${bucket.length}]\\n`;\n        else out += (showIndex? (i+': '):'') + '[' + bucket.join(', ') + ']\\n';\n      }\n    } else {\n      for (let i=0;i<table.capacity;i++) {\n        const s = table.arr[i];\n        let rep = s.status===0 ? '<empty>' : (s.status===2?'<tomb>': String(s.key));\n        if (compact) out += `${i}:${rep} `;\n        else out += (showIndex? (i+': '):'') + rep + '\\n';\n      }\n    }\n    // if there is a current step snapshot, show it instead\n    if (stepIndex >= 0 && steps[stepIndex]) {\n      const snap = steps[stepIndex].snapshot;\n      out += '\\n--- Step Snapshot ---\\n';\n      out += `Desc: ${steps[stepIndex].desc}\\n`;\n      out += JSON.stringify(snap, null, 2) + '\\n';\n    }\n    tableDisplay.textContent = out;\n  }\n\n  function playStepsIfAuto() {\n    const autorun = document.getElementById('autorun').checked;\n    if (autorun) {\n      play();\n    }\n  }\n\n  function stepNext() {\n    if (steps.length === 0) { log('No steps prepared'); return; }\n    if (stepIndex < steps.length - 1) {\n      stepIndex++;\n      applyStepSnapshot(stepIndex);\n      log(`Step ${stepIndex+1}/${steps.length}: ${steps[stepIndex].desc}`);\n    } else {\n      log('Already at last step');\n      stopPlaying();\n    }\n  }\n\n  function stepPrev() {\n    if (steps.length === 0) { log('No steps'); return; }\n    if (stepIndex > 0) {\n      stepIndex--;\n      applyStepSnapshot(stepIndex);\n      log(`Step ${stepIndex+1}/${steps.length}: ${steps[stepIndex].desc}`);\n    } else {\n      log('Already at first step');\n    }\n  }\n\n  function applyStepSnapshot(idx) {\n    const snap = steps[idx].snapshot;\n    // restore table state from snapshot\n    if (!table) {\n      // create minimal table if needed\n      table = new HashTable({capacity:snap.capacity, scheme:snap.scheme, keyType:snap.keyType, allowDup:snap.allowDup, c1:snap.c1, c2:snap.c2, doubleBase:snap.doubleBase});\n    }\n    table.capacity = snap.capacity;\n    table.scheme = snap.scheme;\n    table.allowDup = snap.allowDup;\n    table.keyType = snap.keyType;\n    table.c1 = snap.c1;\n    table.c2 = snap.c2;\n    table.doubleBase = snap.doubleBase;\n    table.size = snap.size;\n    table.tombstones = snap.tombstones;\n    table.arr = snap.arr;\n    updateDisplay();\n  }\n\n  function play() {\n    if (playing) return;\n    if (steps.length === 0) { log('No steps to play'); return; }\n    playing = true;\n    document.getElementById('playPause').textContent = 'Pause';\n    const speed = Number(document.getElementById('speed').value) || 600;\n    playTimer = setInterval(()=> {\n      if (stepIndex < steps.length - 1) stepNext();\n      else stopPlaying();\n    }, speed);\n  }\n  function stopPlaying() {\n    playing = false;\n    document.getElementById('playPause').textContent = 'Play';\n    if (playTimer) clearInterval(playTimer);\n    playTimer = null;\n  }\n\n  function jumpEnd() {\n    if (steps.length === 0) return;\n    stepIndex = steps.length - 1;\n    applyStepSnapshot(stepIndex);\n    log(`Jumped to end, step ${stepIndex+1}`);\n  }\n\n  function clearSteps() {\n    steps = []; stepIndex = -1; stopPlaying();\n    log('Cleared step sequence');\n    updateDisplay();\n  }\n\n  function saveSnapshot(name) {\n    if (!table) { log('No table'); return; }\n    const n = name || ('snap_' + Object.keys(snapshots).length);\n    snapshots[n] = clone(table._snapshot());\n    refreshSnapshotList();\n    log(`Saved snapshot: ${n}`);\n  }\n  function listSnapshots() {\n    const keys = Object.keys(snapshots);\n    log('Snapshots: ' + (keys.length? keys.join(', '): '<none>'));\n    refreshSnapshotList();\n  }\n  function refreshSnapshotList() {\n    const sel = document.getElementById('snapshotList');\n    sel.innerHTML = '';\n    for (let k of Object.keys(snapshots)) {\n      const o = document.createElement('option'); o.value=k; o.textContent = k;\n      sel.appendChild(o);\n    }\n  }\n  function restoreSnapshot(name) {\n    const n = name || document.getElementById('snapshotList').value;\n    if (!n || !snapshots[n]) { log('No snapshot selected'); return; }\n    const snap = clone(snapshots[n]);\n    table = new HashTable({capacity:snap.capacity, scheme:snap.scheme, keyType:snap.keyType, allowDup:snap.allowDup, c1:snap.c1, c2:snap.c2, doubleBase:snap.doubleBase});\n    table.capacity = snap.capacity;\n    table.arr = snap.arr;\n    table.size = snap.size;\n    table.tombstones = snap.tombstones;\n    history.push(clone(table._snapshot())); future=[];\n    updateDisplay();\n    log(`Restored snapshot ${n}`);\n  }\n  function branchSnapshot(name) {\n    const n = name || document.getElementById('snapshotList').value;\n    if (!n || !snapshots[n]) { log('No snapshot to branch'); return; }\n    const newName = n + '_branch_' + Object.keys(snapshots).length;\n    snapshots[newName] = clone(snapshots[n]);\n    refreshSnapshotList();\n    log(`Branched ${n} -> ${newName}`);\n  }\n  function deleteSnapshot(name) {\n    const n = name || document.getElementById('snapshotList').value;\n    if (!n || !snapshots[n]) { log('No snapshot to delete'); return; }\n    delete snapshots[n];\n    refreshSnapshotList();\n    log(`Deleted snapshot ${n}`);\n  }\n\n  function undo() {\n    if (!table) return;\n    if (history.length <= 1) { log('Nothing to undo'); return; }\n    const cur = history.pop();\n    future.push(cur);\n    const prev = history[history.length-1];\n    restoreFromSnapshot(prev);\n    log('Undo');\n  }\n  function redo() {\n    if (future.length===0) { log('Nothing to redo'); return; }\n    const s = future.pop();\n    history.push(s);\n    restoreFromSnapshot(s);\n    log('Redo');\n  }\n  function restoreFromSnapshot(snap) {\n    const snapc = clone(snap);\n    table = new HashTable({capacity:snapc.capacity, scheme:snapc.scheme, keyType:snapc.keyType, allowDup:snapc.allowDup, c1:snapc.c1, c2:snapc.c2, doubleBase:snapc.doubleBase});\n    table.capacity = snapc.capacity;\n    table.arr = snapc.arr;\n    table.size = snapc.size;\n    table.tombstones = snapc.tombstones;\n    updateDisplay();\n  }\n\n  function computeMetrics() {\n    if (!table) { log('No table'); return; }\n    const stats = table.statistics();\n    const el = document.getElementById('metrics');\n    el.textContent = JSON.stringify(stats);\n    log('Computed metrics');\n  }\n\n  function rehashManual() {\n    if (!table) { log('No table'); return; }\n    const cap = Math.max(3, parseInt(document.getElementById('capacity').value) || table.capacity);\n    const before = clone(table._snapshot());\n    table.rehashTo(cap);\n    history.push(clone(table._snapshot())); future = [];\n    updateDisplay();\n    log(`Manual rehash to ${cap}`);\n  }\n\n  function rehashTo() {\n    if (!table) { log('No table'); return; }\n    const cap = Math.max(3, parseInt(document.getElementById('manualCap').value) || table.capacity);\n    const before = clone(table._snapshot());\n    table.rehashTo(cap);\n    history.push(clone(table._snapshot())); future = [];\n    updateDisplay();\n    log(`Rehashed to ${cap}`);\n  }\n\n  function findNextPrime() {\n    const cap = Math.max(3, parseInt(document.getElementById('manualCap').value) || 3);\n    const p = nextPrime(cap);\n    document.getElementById('manualCap').value = p;\n    log(`Next prime >= ${cap} is ${p}`);\n  }\n\n  // Event wiring\n  function wire() {\n    document.getElementById('createBtn').addEventListener('click', ()=>createFromUI());\n    document.getElementById('clearBtn').addEventListener('click', ()=>clearTable());\n    document.getElementById('resetBtn').addEventListener('click', ()=>resetAll());\n    document.getElementById('builtinHash').addEventListener('change', applyBuiltinHash);\n    document.getElementById('useCustomBtn').addEventListener('click', setCustomHash);\n    document.getElementById('testHashBtn').addEventListener('click', testHashOnSample);\n\n    document.getElementById('insertBtn').addEventListener('click', ()=>insertHandler(false));\n    document.getElementById('insertStepBtn').addEventListener('click', ()=>insertHandler(true));\n    document.getElementById('searchBtn').addEventListener('click', ()=>searchHandler(false));\n    document.getElementById('searchStepBtn').addEventListener('click', ()=>searchHandler(true));\n    document.getElementById('deleteBtn').addEventListener('click', ()=>deleteHandler(false));\n    document.getElementById('deleteStepBtn').addEventListener('click', ()=>deleteHandler(true));\n\n    document.getElementById('randInsertBtn').addEventListener('click', randomInsert);\n    document.getElementById('importBtn').addEventListener('click', importJSON);\n    document.getElementById('exportBtn').addEventListener('click', exportJSON);\n    document.getElementById('exportFullBtn').addEventListener('click', exportFullState);\n\n    document.getElementById('stepNext').addEventListener('click', stepNext);\n    document.getElementById('stepPrev').addEventListener('click', stepPrev);\n    document.getElementById('playPause').addEventListener('click', ()=>{ if (playing) stopPlaying(); else play(); });\n    document.getElementById('jumpEnd').addEventListener('click', jumpEnd);\n    document.getElementById('clearSteps').addEventListener('click', clearSteps);\n\n    document.getElementById('saveSnapshot').addEventListener('click', ()=>saveSnapshot(document.getElementById('snapshotName').value));\n    document.getElementById('listSnapshots').addEventListener('click', listSnapshots);\n    document.getElementById('restoreSnapshot').addEventListener('click', ()=>restoreSnapshot());\n    document.getElementById('branchSnapshot').addEventListener('click', ()=>branchSnapshot());\n    document.getElementById('deleteSnapshot').addEventListener('click', ()=>deleteSnapshot());\n    document.getElementById('snapshotList').addEventListener('change', ()=>{ /* nothing */ });\n\n    document.getElementById('undoBtn').addEventListener('click', undo);\n    document.getElementById('redoBtn').addEventListener('click', redo);\n\n    document.getElementById('computeMetrics').addEventListener('click', computeMetrics);\n    document.getElementById('rehashBtn').addEventListener('click', rehashManual);\n    document.getElementById('rehashToBtn').addEventListener('click', rehashTo);\n    document.getElementById('nextPrimeBtn').addEventListener('click', findNextPrime);\n    document.getElementById('clearLog').addEventListener('click', ()=>{ document.getElementById('log').value=''; });\n\n    document.getElementById('speed').addEventListener('input', ()=>{ document.getElementById('speedVal').textContent = document.getElementById('speed').value; if (playing) { stopPlaying(); play(); } });\n\n    document.getElementById('exportFullBtn').addEventListener('click', exportFullState);\n    document.getElementById('stepMode').addEventListener('change', ()=>{ log(`Step mode: ${document.getElementById('stepMode').value}`); });\n\n    // initial defaults\n    applyBuiltinHash();\n    updateDisplay();\n  }\n\n  return {\n    init: function(){ wire(); log('Application ready'); }\n  };\n})();\n\nApp.init();\n\n</script>\n</body>\n</html>"
