    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Max Heap Visualization — Elegant Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@600&family=Roboto:wght@400&display=swap');\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin:0;\n    min-height:100vh;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Roboto', sans-serif;\n    color: #e6eaf0;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3.5rem 1rem 5rem 1rem;\n  }\n\n  h1 {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 3rem;\n    letter-spacing: 0.12em;\n    margin-bottom: 0.4rem;\n    color: #ffd95b;\n    text-shadow:\n      0 0 10px #ffd95b90,\n      0 0 30px #ffd95b70,\n      0 0 40px #ffcc33aa;\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.25rem;\n    color: #fff9e8cc;\n    margin-bottom: 3rem;\n    font-style: italic;\n    letter-spacing: 0.06em;\n  }\n\n  .container {\n    max-width: 1100px;\n    width: 100%;\n    background: rgba(35,47,57,0.65);\n    border-radius: 20px;\n    padding: 3rem 2rem 4rem 2rem;\n    box-shadow:\n      inset 0 0 30px #ffd95b33,\n      0 15px 35px rgb(255 217 91 / 0.22);\n    backdrop-filter: blur(14px);\n    position: relative;\n  }\n\n  /* Heap tree container */\n  .heap {\n    display: flex;\n    justify-content: center;\n    position: relative;\n  }\n\n  /* Nodes styling */\n  .node {\n    position: relative;\n    background: linear-gradient(145deg, #ffdc76 0%, #fad84f 80%);\n    width: 70px;\n    height: 70px;\n    border-radius: 50%;\n    box-shadow:\n      0 0 15px #ffdc76aa,\n      inset 0 4px 8px #e5c751,\n      0 6px 15px #b88903;\n    font-family: 'Poppins', sans-serif;\n    font-size: 1.7rem;\n    font-weight: 600;\n    color: #422f01;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    user-select: none;\n    transition: transform 0.45s cubic-bezier(0.5, 0, 0, 1), box-shadow 0.3s;\n    cursor: default;\n    z-index: 10;\n  }\n  .node.hover-glow:hover {\n    box-shadow:\n      0 0 25px #ffd95bcc,\n      inset 0 4px 8px #ffdb60,\n      0 8px 20px #b58a00;\n    transform: scale(1.14) translateY(-4px);\n    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s;\n    cursor: default;\n  }\n\n  /* Connections lines */\n  svg {\n    position: absolute;\n    top: 0;\n    left: 0;\n    pointer-events: none;\n    overflow: visible;\n    width: 100%;\n    height: 100%;\n  }\n  line {\n    stroke: #ffdc76dd;\n    stroke-width: 4;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 1.8px #ffd95bcc);\n    transition: stroke 0.35s ease;\n  }\n\n  /* Layout for heap levels */\n  .level {\n    display: flex;\n    justify-content: center;\n    margin: 1.5rem 0;\n    gap: 3.4rem;\n    position: relative;\n  }\n\n  /* smaller gap on upper levels */\n  .level.level-0 {\n    gap: 0;\n  }\n  .level.level-1 {\n    gap: 6rem;\n  }\n  .level.level-2 {\n    gap: 4rem;\n  }\n\n  /* Button container */\n  .buttons {\n    margin-top: 3.8rem;\n    text-align: center;\n  }\n\n  button {\n    font-family: 'Poppins', sans-serif;\n    background: linear-gradient(145deg, #ffdc76 0%, #fad84f 100%);\n    border: none;\n    border-radius: 12px;\n    padding: 0.85rem 2.8rem;\n    margin: 0 0.9rem;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: #422f01;\n    box-shadow:\n      0 0 14px #ffdd6caa,\n      inset 0 -4px 6px #d5af09;\n    cursor: pointer;\n    user-select: none;\n    transition:\n      box-shadow 0.3s ease,\n      color 0.25s ease,\n      background 0.25s ease,\n      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  button:hover, button:focus-visible {\n    outline-offset: 4px;\n    background: linear-gradient(145deg, #fad84f, #ffeb92);\n    box-shadow:\n      0 0 26px #fff3afcc,\n      inset 0 -4px 10px #ffe752;\n    color: #483400;\n    transform: translateY(-3px) scale(1.07);\n  }\n  button:active {\n    transform: translateY(-1px) scale(1.04);\n    box-shadow:\n      0 0 18px #ffd94a88,\n      inset 0 -4px 6px #c3a403;\n  }\n\n  /* Info box */\n  .info-box {\n    max-width: 550px;\n    margin: 3rem auto 0 auto;\n    color: #f0e9dbdd;\n    font-style: italic;\n    letter-spacing: 0.04em;\n    font-weight: 500;\n    line-height: 1.6;\n    font-size: 1.25rem;\n    background:\n      radial-gradient(circle at bottom right, #fbeebb33 30%, transparent 75%),\n      linear-gradient(268deg, #ffd95b33 0%, #a9840066 85%);\n    padding: 1.6rem 1.9rem 1.8rem 1.9rem;\n    border-radius: 14px;\n    box-shadow:\n      inset 0 0 25px #ffd95b66;\n    user-select: none;\n  }\n\n  /* Responsive adjustments */\n  @media (max-width: 850px) {\n    h1 {\n      font-size: 2.3rem;\n    }\n    h2 {\n      font-size: 1rem;\n      max-width: 450px;\n      margin-bottom: 1.8rem;\n    }\n    .container {\n      padding: 2.5rem 1.6rem 3rem 1.6rem;\n    }\n    .level {\n      gap: 2.7rem !important;\n    }\n    .node {\n      width: 56px;\n      height: 56px;\n      font-size: 1.25rem;\n    }\n    .buttons {\n      margin-top: 2rem;\n    }\n    button {\n      padding: 0.7rem 2.3rem;\n      font-size: 1rem;\n      margin: 0 0.6rem;\n    }\n    .info-box {\n      font-size: 1.05rem;\n      max-width: 90vw;\n      margin-top: 2rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>MAX HEAP</h1>\n  <h2>Elegant Visual Demonstration of Heap (Max)</h2>\n\n  <div class=\"container\" aria-label=\"Max Heap Visualization\">\n    <div class=\"heap\" id=\"heap-visual\">\n      <!-- Levels inserted by JavaScript -->\n    </div>\n\n    <svg aria-hidden=\"true\" id=\"connections\"></svg>\n\n    <div class=\"buttons\" role=\"group\" aria-label=\"Heap controls\">\n      <button id=\"btn-reset\" aria-pressed=\"false\" title=\"Reset to original heap\">Reset</button>\n      <button id=\"btn-extract\" aria-pressed=\"false\" title=\"Extract max element\">Extract Max</button>\n    </div>\n\n    <div class=\"info-box\" aria-live=\"polite\" id=\"info\">\n      Observe the MAX heap structure: Each parent node is greater than or equal to its children.<br /><br />\n      Press <strong>Extract Max</strong> to remove the root (maximum value) visually, showing how the heap reorganizes.<br />\n      Use <strong>Reset</strong> to restore the initial heap shape.\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Max Heap initial array (complete binary tree)\n  const initialHeap = [100, 80, 60, 50, 70, 30, 45];\n\n  // We'll visually construct 3 levels:\n  // Level 0: index 0\n  // Level 1: indices 1..2\n  // Level 2: indices 3..6\n\n  const heapContainer = document.getElementById('heap-visual');\n  const svg = document.getElementById('connections');\n  const btnReset = document.getElementById('btn-reset');\n  const btnExtract = document.getElementById('btn-extract');\n  const infoBox = document.getElementById('info');\n\n  let heap = initialHeap.slice();\n\n  // Store references to nodes DOM for animations & positioning\n  /** @type {HTMLDivElement[]} **/\n  let nodeElements = [];\n\n  // Create level container divs (for layout and spacing)\n  const levels = [];\n  for (let i=0; i<3; i++) {\n    const lvl = document.createElement('div');\n    lvl.classList.add('level', `level-${i}`);\n    heapContainer.appendChild(lvl);\n    levels.push(lvl);\n  }\n\n  // Create nodes elements for heap array, place them by levels:\n  function buildHeapVisual(array) {\n    // Clear previous\n    levels.forEach(lvl => lvl.innerHTML = '');\n    nodeElements = [];\n\n    // Level 0: index 0\n    if(array.length > 0) {\n      const node = createNode(array[0], 0);\n      levels[0].appendChild(node);\n      nodeElements.push(node);\n    }\n    // Level 1: indices 1,2\n    for(let i=1; i<=2; i++){\n      if(i >= array.length) break;\n      const node = createNode(array[i], i);\n      levels[1].appendChild(node);\n      nodeElements.push(node);\n    }\n    // Level 2: indices 3..6\n    for(let i=3; i<=6; i++) {\n      if(i >= array.length) break;\n      const node = createNode(array[i], i);\n      levels[2].appendChild(node);\n      nodeElements.push(node);\n    }\n    // After creating nodes, draw connections\n    drawConnections(array.length);\n  }\n\n  // Create one node circle\n  function createNode(value, index) {\n    const node = document.createElement('div');\n    node.className = 'node hover-glow';\n    node.textContent = value;\n    node.dataset.index = index.toString();\n    return node;\n  }\n\n  // Clear and draw lines between parent and children\n  function drawConnections(length) {\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n\n    // For each node i:\n    // leftChild = 2i + 1, rightChild = 2i + 2\n    // draw line from node i center to children centers\n    for(let i=0; i<length; i++) {\n      const parentNode = nodeElements[i];\n      if(!parentNode) continue;\n      const parentRect = parentNode.getBoundingClientRect();\n\n      const parentCenter = {\n        x: parentRect.left + parentRect.width/2,\n        y: parentRect.top + parentRect.height/2\n      };\n\n      const leftChildIndex = 2*i + 1;\n      const rightChildIndex = 2*i + 2;\n\n      // Draw left line if child exists\n      if(leftChildIndex < length) {\n        const leftNode = nodeElements[leftChildIndex];\n        if(leftNode) {\n          const leftRect = leftNode.getBoundingClientRect();\n          const leftCenter = {\n            x: leftRect.left + leftRect.width/2,\n            y: leftRect.top + leftRect.height/2\n          };\n          drawLine(parentCenter, leftCenter);\n        }\n      }\n      // Draw right line if child exists\n      if(rightChildIndex < length) {\n        const rightNode = nodeElements[rightChildIndex];\n        if(rightNode) {\n          const rightRect = rightNode.getBoundingClientRect();\n          const rightCenter = {\n            x: rightRect.left + rightRect.width/2,\n            y: rightRect.top + rightRect.height/2\n          };\n          drawLine(parentCenter, rightCenter);\n        }\n      }\n    }\n  }\n\n  function drawLine(from, to) {\n    const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n    // Convert from viewport coords to svg coords inside heapContainer\n    // svg position relative to viewport\n    const svgRect = svg.getBoundingClientRect();\n    line.setAttribute('x1', (from.x - svgRect.left).toFixed(2));\n    line.setAttribute('y1', (from.y - svgRect.top).toFixed(2));\n    line.setAttribute('x2', (to.x - svgRect.left).toFixed(2));\n    line.setAttribute('y2', (to.y - svgRect.top).toFixed(2));\n\n    svg.appendChild(line);\n  }\n\n  // On window resize redraw connections to reposition\n  window.addEventListener('resize', () => {\n    drawConnections(heap.length);\n  });\n\n  // Swap animation: animate scaling and shadow glow on involved nodes\n  // Helper: animate and return promise that resolves after animation\n  function animateSwap(nodeA, nodeB) {\n    return new Promise(res => {\n      // Animate nodeA scaling up & moving right, nodeB scaling up & moving left, then swap text\n      const duration = 400;\n\n      // reset transforms on both nodes before\n      nodeA.style.transition = 'none';\n      nodeB.style.transition = 'none';\n      nodeA.style.transform = 'scale(1) translateX(0)';\n      nodeB.style.transform = 'scale(1) translateX(0)';\n      nodeA.style.zIndex = 12;\n      nodeB.style.zIndex = 12;\n\n      // force reflow\n      nodeA.offsetHeight;\n\n      nodeA.style.transition = `transform ${duration}ms cubic-bezier(0.5,0,0,1), box-shadow 0.3s`;\n      nodeB.style.transition = `transform ${duration}ms cubic-bezier(0.5,0,0,1), box-shadow 0.3s`;\n\n      nodeA.style.transform = 'scale(1.15) translateX(20px)';\n      nodeB.style.transform = 'scale(1.15) translateX(-20px)';\n      nodeA.style.boxShadow = '0 0 28px #ffd95bcc, inset 0 8px 15px #ffdd7f, 0 8px 25px #b88600';\n      nodeB.style.boxShadow = '0 0 28px #ffd95bcc, inset 0 8px 15px #ffdd7f, 0 8px 25px #b88600';\n\n      setTimeout(() => {\n        // Swap text content\n        const temp = nodeA.textContent;\n        nodeA.textContent = nodeB.textContent;\n        nodeB.textContent = temp;\n\n        // Reverse animation\n        nodeA.style.transform = 'scale(1) translateX(0)';\n        nodeB.style.transform = 'scale(1) translateX(0)';\n        nodeA.style.boxShadow = '';\n        nodeB.style.boxShadow = '';\n      }, duration);\n\n      setTimeout(() => {\n        nodeA.style.zIndex = 10;\n        nodeB.style.zIndex = 10;\n        res();\n      }, duration * 2);\n    });\n  }\n\n  // Visual extract max: remove root, replace root with last element,\n  // then heapify down with animations.\n  // Disables buttons during operation.\n  async function extractMaxVisual() {\n    if(heap.length === 0) return;\n\n    btnExtract.disabled = true;\n    btnReset.disabled = true;\n\n    infoBox.textContent = \"Extracting max element and reorganizing heap...\";\n\n    // Animate root node 'popped' and faded out\n    const rootNode = nodeElements[0];\n    rootNode.style.transition = 'transform 0.5s ease, opacity 0.5s ease';\n    rootNode.style.transform = 'scale(1.6) translateY(-40px)';\n    rootNode.style.opacity = '0';\n    await new Promise(r => setTimeout(r, 550));\n\n    // Remove root from array, replace with last heap leaf\n    if(heap.length > 1) {\n      heap[0] = heap[heap.length - 1];\n    }\n    heap.pop();\n\n    // Rebuild heap visuals instantly with updated values, but fade in root\n    buildHeapVisual(heap);\n\n    if(heap.length === 0) {\n      infoBox.textContent = \"Heap is now empty.\";\n      btnExtract.disabled = false;\n      btnReset.disabled = false;\n      return;\n    }\n\n    // Animate root appearance\n    const newRootNode = nodeElements[0];\n    newRootNode.style.transform = 'scale(1.6) translateY(-40px)';\n    newRootNode.style.opacity = '0';\n    // let browser catch repaint\n    await new Promise(r => requestAnimationFrame(() => requestAnimationFrame(r)));\n    newRootNode.style.transition = 'transform 0.4s ease, opacity 0.45s ease';\n    newRootNode.style.transform = 'scale(1) translateY(0)';\n    newRootNode.style.opacity = '1';\n    await new Promise(r => setTimeout(r, 500));\n\n    // Heapify down with swap animations\n    let i = 0;\n    const n = heap.length;\n\n    function largerChildIndex(i) {\n      const left = 2*i + 1;\n      const right = 2*i + 2;\n      if(left >= n) return -1;\n      if(right >= n) return left;\n      return (heap[left] > heap[right]) ? left : right;\n    }\n\n    while(true) {\n      let c = largerChildIndex(i);\n      if(c === -1) break;\n      if(heap[i] >= heap[c]) break;\n\n      // Animate swap nodes i and c visually\n      await animateSwap(nodeElements[i], nodeElements[c]);\n\n      // Swap values in heap array\n      [heap[i], heap[c]] = [heap[c], heap[i]];\n\n      // Rebuild visuals text inside nodes to reflect swaps\n      nodeElements[i].textContent = heap[i];\n      nodeElements[c].textContent = heap[c];\n\n      i = c;\n    }\n\n    infoBox.textContent = \"Max extracted. Heap property restored.\";\n    btnExtract.disabled = false;\n    btnReset.disabled = false;\n  }\n\n  // Reset heap visuals & data to initial state\n  function resetHeap() {\n    heap = initialHeap.slice();\n    buildHeapVisual(heap);\n    infoBox.textContent = \"Observe the MAX heap structure: Each parent node is greater than or equal to its children.\\n\\nPress Extract Max to remove the root (maximum value) visually, showing how the heap reorganizes. Use Reset to restore the initial heap shape.\";\n  }\n\n  btnReset.addEventListener('click', () => {\n    resetHeap();\n  });\n\n  btnExtract.addEventListener('click', () => {\n    extractMaxVisual();\n  });\n\n  // Initial load\n  function init() {\n    resetHeap();\n  }\n\n  // Wait for next animation frame to ensure elements have layout before drawing lines\n  function delayedDraw() {\n    requestAnimationFrame(() => {\n      drawConnections(heap.length);\n    });\n  }\n\n  // After heap build & inject to DOM, draw connections when visible & stable\n  const observer = new ResizeObserver(() => {\n    delayedDraw();\n  });\n  observer.observe(heapContainer);\n\n  init();\n})();\n</script>\n</body>\n</html>"
