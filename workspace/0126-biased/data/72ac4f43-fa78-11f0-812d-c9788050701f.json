    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>HTTP: The Beauty of Web Communication</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #00cec9;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --accent: #fd79a8;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n        \n        body {\n            background-color: var(--dark);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            background: radial-gradient(ellipse at bottom, #1B2735 0%, #090A0F 100%);\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            font-weight: 800;\n            letter-spacing: -1px;\n        }\n        \n        .subtitle {\n            font-size: 1.5rem;\n            color: var(--secondary);\n            opacity: 0.8;\n            font-weight: 300;\n            margin-bottom: 2rem;\n        }\n        \n        .visualization {\n            position: relative;\n            height: 400px;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 20px;\n            padding: 2rem;\n            overflow: hidden;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);\n            backdrop-filter: blur(10px);\n            margin-bottom: 3rem;\n            animation: slideUp 1.2s ease-out;\n        }\n        \n        .client-server {\n            display: flex;\n            justify-content: space-between;\n            height: 100%;\n            position: relative;\n        }\n        \n        .client, .server {\n            width: 30%;\n            height: 100%;\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 15px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 1.5rem;\n            position: relative;\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n            transition: transform 0.3s, box-shadow 0.3s;\n        }\n        \n        .client:hover, .server:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.2);\n        }\n        \n        .client-icon, .server-icon {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin-bottom: 1.5rem;\n            font-size: 2.5rem;\n            color: white;\n            background: linear-gradient(135deg, var(--primary), var(--accent));\n        }\n        \n        .server-icon {\n            background: linear-gradient(135deg, var(--secondary), #00b894);\n        }\n        \n        .client-title, .server-title {\n            font-size: 1.5rem;\n            margin-bottom: 1rem;\n            font-weight: 600;\n        }\n        \n        .request-list, .response-list {\n            width: 100%;\n            padding: 1rem;\n            background: rgba(0, 0, 0, 0.2);\n            border-radius: 8px;\n            flex-grow: 1;\n            overflow-y: auto;\n        }\n        \n        .request-item, .response-item {\n            background: rgba(255, 255, 255, 0.1);\n            padding: 0.75rem;\n            border-radius: 6px;\n            margin-bottom: 0.5rem;\n            font-family: monospace;\n            font-size: 0.9rem;\n            color: var(--light);\n            border-left: 3px solid var(--primary);\n            opacity: 0;\n            transform: translateY(10px);\n            animation: fadeInItem 0.5s forwards;\n        }\n        \n        .response-item {\n            border-left-color: var(--secondary);\n        }\n        \n        .protocol-path {\n            position: absolute;\n            top: 50%;\n            left: 0;\n            width: 100%;\n            height: 2px;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);\n        }\n        \n        .request-arrow {\n            position: absolute;\n            top: 50%;\n            left: 30%;\n            width: 40%;\n            height: 50px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            opacity: 0;\n            transform: scale(0.5);\n            animation: pulseArrow 2s infinite, fadeInArrow 1s 0.5s forwards;\n        }\n        \n        .response-arrow {\n            position: absolute;\n            top: 65%;\n            left: 30%;\n            width: 40%;\n            height: 50px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            opacity: 0;\n            transform: scale(0.5) rotate(180deg);\n            animation: pulseArrow 2s 1s infinite, fadeInArrow 1s 1.5s forwards;\n        }\n        \n        .arrow {\n            width: 100%;\n            height: 2px;\n            background: var(--accent);\n            position: relative;\n        }\n        \n        .arrow::after {\n            content: '';\n            position: absolute;\n            right: 0;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 10px;\n            height: 10px;\n            border-right: 2px solid var(--accent);\n            border-top: 2px solid var(--accent);\n            transform: rotate(45deg);\n        }\n        \n        .response-arrow .arrow {\n            background: var(--secondary);\n        }\n        \n        .response-arrow .arrow::after {\n            border-right-color: var(--secondary);\n            border-top-color: var(--secondary);\n        }\n        \n        .status-codes {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        .status-code {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 10px;\n            padding: 1.5rem;\n            text-align: center;\n            transition: transform 0.3s, box-shadow 0.3s;\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n        \n        .status-code:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n        }\n        \n        .status-number {\n            font-size: 2rem;\n            font-weight: 800;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .status-info {\n            font-size: 0.9rem;\n            color: rgba(255, 255, 255, 0.7);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n            gap: 1rem;\n        }\n        \n        .btn {\n            padding: 0.75rem 1.5rem;\n            border-radius: 50px;\n            border: none;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            color: white;\n            font-weight: 600;\n            cursor: pointer;\n            transition: transform 0.2s, box-shadow 0.2s;\n            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.4);\n        }\n        \n        .btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.6);\n        }\n        \n        .btn:active {\n            transform: translateY(0);\n        }\n        \n        .btn-alt {\n            background: rgba(255, 255, 255, 0.1);\n            box-shadow: none;\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding-top: 2rem;\n            border-top: 1px solid rgba(255, 255, 255, 0.1);\n            color: rgba(255, 255, 255, 0.5);\n            font-size: 0.9rem;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes fadeInItem {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulseArrow {\n            0%, 100% {\n                transform: scale(1) translateX(0);\n            }\n            50% {\n                transform: scale(1.05) translateX(5px);\n            }\n        }\n        \n        @keyframes fadeInArrow {\n            to {\n                opacity: 1;\n                transform: scale(1);\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>HTTP Protocol</h1>\n            <p class=\"subtitle\">The elegant foundation of modern web communication</p>\n        </header>\n        \n        <div class=\"visualization\">\n            <div class=\"client-server\">\n                <div class=\"client\">\n                    <div class=\"client-icon\">👤</div>\n                    <h3 class=\"client-title\">Client</h3>\n                    <div class=\"request-list\">\n                        <div class=\"request-item\">GET /index.html HTTP/1.1</div>\n                        <div class=\"request-item\">Host: example.com</div>\n                        <div class=\"request-item\">Accept: text/html</div>\n                    </div>\n                </div>\n                \n                <div class=\"protocol-path\"></div>\n                \n                <div class=\"request-arrow\">\n                    <div class=\"arrow\"></div>\n                </div>\n                \n                <div class=\"response-arrow\">\n                    <div class=\"arrow\"></div>\n                </div>\n                \n                <div class=\"server\">\n                    <div class=\"server-icon\">🖥️</div>\n                    <h3 class=\"server-title\">Server</h3>\n                    <div class=\"response-list\">\n                        <div class=\"response-item\">HTTP/1.1 200 OK</div>\n                        <div class=\"response-item\">Content-Type: text/html</div>\n                        <div class=\"response-item\">&lt;html&gt;...&lt;/html&gt;</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"status-codes\">\n            <div class=\"status-code\">\n                <div class=\"status-number\">200</div>\n                <div class=\"status-info\">OK - Successful request</div>\n            </div>\n            <div class=\"status-code\">\n                <div class=\"status-number\">301</div>\n                <div class=\"status-info\">Moved permanently</div>\n            </div>\n            <div class=\"status-code\">\n                <div class=\"status-number\">404</div>\n                <div class=\"status-info\">Not found</div>\n            </div>\n            <div class=\"status-code\">\n                <div class=\"status-number\">500</div>\n                <div class=\"status-info\">Server error</div>\n            </div>\n            <div class=\"status-code\">\n                <div class=\"status-number\">201</div>\n                <div class=\"status-info\">Created (POST success)</div>\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button class=\"btn\" id=\"newRequest\">New Request</button>\n            <button class=\"btn btn-alt\" id=\"resetView\">Reset</button>\n        </div>\n    </div>\n    \n    <footer>\n        <p>Visualizing the Hypertext Transfer Protocol (HTTP) - The foundation of data communication for the World Wide Web</p>\n    </footer>\n    \n    <script>\n        document.getElementById('newRequest').addEventListener('click', function() {\n            const requestList = document.querySelector('.request-list');\n            const responseList = document.querySelector('.response-list');\n            \n            // Clear previous items\n            requestList.innerHTML = '';\n            responseList.innerHTML = '';\n            \n            // Random request types\n            const methods = ['GET', 'POST', 'PUT', 'DELETE'];\n            const paths = ['/index.html', '/api/data', '/user/profile', '/products/42'];\n            const randomMethod = methods[Math.floor(Math.random() * methods.length)];\n            const randomPath = paths[Math.floor(Math.random() * paths.length)];\n            \n            // Generate new request\n            requestList.innerHTML = `\n                <div class=\"request-item\">${randomMethod} ${randomPath} HTTP/1.1</div>\n                <div class=\"request-item\">Host: example.com</div>\n                <div class=\"request-item\">Accept: application/json</div>\n            `;\n            \n            // Generate response after delay\n            setTimeout(() => {\n                const statusCodes = [\n                    {code: '200', text: 'OK'},\n                    {code: '201', text: 'Created'},\n                    {code: '400', text: 'Bad Request'},\n                    {code: '404', text: 'Not Found'},\n                    {code: '500', text: 'Internal Server Error'}\n                ];\n                const randomStatus = statusCodes[Math.floor(Math.random() * statusCodes.length)];\n                \n                responseList.innerHTML = `\n                    <div class=\"response-item\">HTTP/1.1 ${randomStatus.code} ${randomStatus.text}</div>\n                    <div class=\"response-item\">Content-Type: application/json</div>\n                    <div class=\"response-item\">{ \"status\": \"${randomStatus.code}\", \"message\": \"${randomStatus.text}\" }</div>\n                `;\n                \n                // Animate the new items\n                animateNewItems();\n            }, 800);\n            \n            // Animate request items\n            setTimeout(() => {\n                animateNewItems();\n            }, 100);\n        });\n        \n        document.getElementById('resetView').addEventListener('click', function() {\n            const requestList = document.querySelector('.request-list');\n            const responseList = document.querySelector('.response-list');\n            \n            requestList.innerHTML = `\n                <div class=\"request-item\">GET /index.html HTTP/1.1</div>\n                <div class=\"request-item\">Host: example.com</div>\n                <div class=\"request-item\">Accept: text/html</div>\n            `;\n            \n            responseList.innerHTML = `\n                <div class=\"response-item\">HTTP/1.1 200 OK</div>\n                <div class=\"response-item\">Content-Type: text/html</div>\n                <div class=\"response-item\">&lt;html&gt;...&lt;/html&gt;</div>\n            `;\n            \n            animateNewItems();\n        });\n        \n        function animateNewItems() {\n            const items = document.querySelectorAll('.request-item, .response-item');\n            items.forEach((item, index) => {\n                item.style.opacity = '0';\n                item.style.transform = 'translateY(10px)';\n                setTimeout(() => {\n                    item.style.transition = 'opacity 0.5s, transform 0.5s';\n                    item.style.opacity = '1';\n                    item.style.transform = 'translateY(0)';\n                }, index * 100);\n            });\n        }\n        \n        // Initial animation\n        setTimeout(() => {\n            animateNewItems();\n        }, 300);\n    </script>\n</body>\n</html>"
