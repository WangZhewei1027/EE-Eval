    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Tim Sort Visualization — Elegant Algorithm Showcase</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n\n  :root {\n    --bg-dark: #0f172a;\n    --accent-blue: #3b82f6;\n    --accent-indigo: #6366f1;\n    --text-primary: #e0e7ff;\n    --text-secondary: #a5b4fc;\n    --run-color-start: #2563eb;\n    --run-color-mid: #818cf8;\n    --run-color-end: #a5b4fc;\n    --merge-color-left: #f472b6;\n    --merge-color-right: #fb7185;\n    --merge-color-merged: #fbbf24;\n    --shadow-glow: rgba(99,102,241,0.5);\n  }\n\n  html, body {\n    height: 100%;\n    margin: 0;\n    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);\n    font-family: 'Inter', sans-serif;\n    color: var(--text-primary);\n    overflow: hidden;\n    user-select: none;\n  }\n\n  .container {\n    max-width: 960px;\n    margin: 2rem auto 4rem;\n    padding: 0 1rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 2.75rem;\n    line-height: 1.1;\n    margin-bottom: 0.25rem;\n    letter-spacing: -0.025em;\n    text-align: center;\n    color: var(--accent-indigo);\n    text-shadow: 0 0 8px var(--shadow-glow);\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.1rem;\n    color: var(--text-secondary);\n    margin-bottom: 2rem;\n    text-align: center;\n    font-style: italic;\n  }\n\n  /* Controls */\n  .controls {\n    display: flex;\n    gap: 1rem;\n    margin-bottom: 3rem;\n  }\n\n  button {\n    background: var(--accent-blue);\n    border: none;\n    border-radius: 0.4rem;\n    padding: 0.8rem 1.8rem;\n    font-size: 1rem;\n    font-weight: 600;\n    color: white;\n    cursor: pointer;\n    box-shadow:\n      0 0 8px var(--shadow-glow),\n      0 6px 12px rgb(59 130 246 / 0.4);\n    transition: background-color 0.3s ease, transform 0.15s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: var(--accent-indigo);\n    box-shadow:\n      0 0 16px var(--shadow-glow),\n      0 8px 16px rgb(99 102 241 / 0.5);\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(1px);\n  }\n\n  /* Visualization Canvas */\n  #visualizer {\n    width: 100%;\n    max-width: 920px;\n    height: 400px;\n    border-radius: 1rem;\n    background:\n      radial-gradient(circle at center, #1e293b 0%, #0f172a 95%);\n    box-shadow:\n      inset 0 0 40px #3b82f6aa,\n      0 0 25px #6366f1bb;\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Footer styling */\n  footer {\n    text-align: center;\n    margin-top: 3rem;\n    font-size: 0.85rem;\n    color: var(--text-secondary);\n    user-select: none;\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Tim Sort Visualization</h1>\n    <h2>An elegant blend of insertion & merge sorting</h2>\n\n    <div class=\"controls\" aria-label=\"Controls to replay or generate shuffle\">\n      <button id=\"btnShuffle\" aria-label=\"Shuffle array\">Shuffle Array</button>\n      <button id=\"btnStart\" aria-label=\"Start sorting animation\">Start Sort</button>\n    </div>\n\n    <canvas id=\"visualizer\" aria-label=\"Tim Sort visualization animation\" role=\"img\"></canvas>\n  </div>\n\n  <footer>Made with ♥ showcasing algorithmic beauty — by ChatGPT</footer>\n\n<script>\n(() => {\n  const canvas = document.getElementById('visualizer');\n  const ctx = canvas.getContext('2d');\n\n  // Responsive high-DPI\n  function resize() {\n    const dpr = window.devicePixelRatio || 1;\n    canvas.width = canvas.clientWidth * dpr;\n    canvas.height = canvas.clientHeight * dpr;\n    ctx.setTransform(1, 0, 0, 1, 0, 0);\n    ctx.scale(dpr, dpr);\n  }\n  resize();\n  window.addEventListener('resize', () => {\n    resize();\n    drawArray(state.array, []);\n  });\n\n  // Constants for array\n  const ARRAY_LENGTH = 60;\n  const MAX_VALUE = 100;\n  const BAR_WIDTH = 12;\n  const BAR_SPACING = 3;\n  const RUN_MIN = 32; // TimSort min run size\n\n  // Animation timing\n  const FPS = 60;\n  const FRAME_DURATION = 1000 / FPS;\n  const ANIMATION_SPEED = 1.5; // multiplier for animation speed\n\n  // Colors\n  const Colors = {\n    background: '#0f172a',\n    bar_fill: '#a5b4fc',\n    bar_fill_insertion: '#2563eb',\n    run_color_start: '#2563eb',\n    run_color_mid: '#818cf8',\n    run_color_end: '#a5b4fc',\n    merge_left: '#f472b6',\n    merge_right: '#fb7185',\n    merge_merged: '#fbbf24',\n  };\n\n  // State - central source of truth for the visualization\n  let state = {\n    array: [],\n    runs: [],\n    actions: [],\n    actionIndex: 0,\n    sorting: false,\n    animationFrameId: null,\n    animationProgress: 0,\n    currentAction: null,\n    mergedIndices: new Set(),\n  };\n\n  // Generate a random array\n  function generateArray(len = ARRAY_LENGTH) {\n    return Array.from({length: len}, () => Math.floor(Math.random() * MAX_VALUE) + 5);\n  }\n\n  // Clamp color fade\n  function lerpColor(a, b, t) {\n    const parse = (c) => {\n      if (c.startsWith('#')) {\n        const bigint = parseInt(c.slice(1),16);\n        return [(bigint >> 16) & 255, (bigint >> 8) & 255, bigint & 255];\n      }\n      return [0,0,0];\n    };\n    const [r1,g1,b1] = parse(a);\n    const [r2,g2,b2] = parse(b);\n    const r = Math.round(r1 + (r2-r1)*t);\n    const g = Math.round(g1 + (g2-g1)*t);\n    const b = Math.round(b1 + (b2-b1)*t);\n    return `rgb(${r},${g},${b})`;\n  }\n\n\n  // Draw a single bar (vertical rectangle) with smooth rounded edges\n  function drawBar(x, y, width, height, color) {\n    const radius = Math.min(width / 2, 6);\n    ctx.fillStyle = color;\n    ctx.shadowColor = color + \"aa\";\n    ctx.shadowBlur = 12;\n    ctx.beginPath();\n    ctx.moveTo(x + radius, y);\n    ctx.lineTo(x + width - radius, y);\n    ctx.quadraticCurveTo(x + width, y, x + width, y + radius);\n    ctx.lineTo(x + width, y + height - radius);\n    ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);\n    ctx.lineTo(x + radius, y + height);\n    ctx.quadraticCurveTo(x, y + height, x, y + height - radius);\n    ctx.lineTo(x, y + radius);\n    ctx.quadraticCurveTo(x, y, x + radius, y);\n    ctx.closePath();\n    ctx.fill();\n    ctx.shadowBlur = 0;\n  }\n\n  // Draw entire array with optional highlights\n  // highlights: object {runs: [{start, end}], merging: {left:[], right:[], merged:[]}, insertion: index}\n  function drawArray(arr, highlights) {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n    const cw = canvas.clientWidth;\n    const ch = canvas.clientHeight;\n    const bottomMargin = 48;\n    const maxHeight = ch - bottomMargin;\n    const barFullWidth = BAR_WIDTH + BAR_SPACING;\n    const totalWidth = barFullWidth * arr.length - BAR_SPACING;\n    const startX = (cw - totalWidth) / 2;\n\n    // Draw runs background bent color - gradient highlight\n    if (highlights?.runs && highlights.runs.length) {\n      const gradientRunsColor = (pos, total) => lerpColor(Colors.run_color_start, Colors.run_color_end, pos / total);\n      const totalRuns = highlights.runs.length;\n      highlights.runs.forEach((run, i) => {\n        const runLength = run.end - run.start + 1;\n        const x = startX + run.start * barFullWidth;\n        const width = runLength * barFullWidth - BAR_SPACING;\n        const grad = ctx.createLinearGradient(x, 0, x + width, 0);\n        grad.addColorStop(0, Colors.run_color_start);\n        grad.addColorStop(0.5, Colors.run_color_mid);\n        grad.addColorStop(1, Colors.run_color_end);\n        ctx.fillStyle = grad;\n        ctx.shadowColor = grad;\n        ctx.shadowBlur = 18;\n        ctx.fillRect(x - 4, 6, width + 8, maxHeight - 40);\n        ctx.shadowBlur = 0;\n      });\n    }\n\n    // Draw bars\n    arr.forEach((v,i) => {\n      const height = (v/MAX_VALUE) * (maxHeight - 64);\n      const x = startX + i * barFullWidth;\n      const y = maxHeight - height;\n\n      // Determine bar color with priority: merging > insertion > normal\n      let fillColor = Colors.bar_fill;\n\n      if (highlights?.merging) {\n        if (highlights.merging.left.includes(i)) fillColor = Colors.merge_left;\n        else if (highlights.merging.right.includes(i)) fillColor = Colors.merge_right;\n        else if (highlights.merging.merged.includes(i)) fillColor = Colors.merge_merged;\n      }\n      if (highlights?.insertion === i) {\n        fillColor = Colors.bar_fill_insertion;\n      }\n\n      drawBar(x, y, BAR_WIDTH, height, fillColor);\n\n      // Subtle top shine on each bar\n      ctx.fillStyle = `rgba(255,255,255,0.08)`;\n      ctx.beginPath();\n      ctx.ellipse(x + BAR_WIDTH/2, y + 6, BAR_WIDTH/2.6, 8, 0, 0, Math.PI * 2);\n      ctx.fill();\n    });\n\n  }\n\n\n  // TIM SORT IMPLEMENTATION WITH ACTION LOGS FOR ANIMATION\n  // We will log all the major actions to replay with animation:\n  // Actions: {type: 'run', start, end}, {type: 'merge', leftStart, leftEnd, rightStart, rightEnd, mergedArray}, {type: 'insertion', index}\n\n  // Find min run length (standard TimSort heuristic)\n  function minRunLength(n) {\n    let r = 0;\n    while (n >= 64) {\n      r |= n & 1;\n      n >>=1;\n    }\n    return n + r;\n  }\n\n  // Binary insertion sort for runs\n  function binaryInsertionSort(arr, start, end, actions) {\n    for (let i = start+1; i <= end; i++) {\n      let val = arr[i];\n      actions.push({type:'insertion', index:i});\n      let left = start;\n      let right = i-1;\n      // Binary search to find position\n      while(left <= right) {\n        let mid = Math.floor((left+right)/2);\n        if (arr[mid] > val) right = mid -1;\n        else left = mid +1;\n      }\n      // Move elements\n      for (let j = i -1; j >= left; j--) {\n        arr[j+1] = arr[j];\n      }\n      arr[left] = val;\n    }\n  }\n\n  // Merge two sorted runs and log action\n  function merge(arr, start1, end1, start2, end2, actions) {\n    let left = arr.slice(start1,end1+1);\n    let right = arr.slice(start2,end2+1);\n    let i=0, j=0, k=start1;\n    const mergedArray = [];\n    while(i < left.length && j < right.length) {\n      if (left[i] <= right[j]) {\n        arr[k] = left[i];\n        mergedArray.push(left[i]);\n        i++; k++;\n      } else {\n        arr[k] = right[j];\n        mergedArray.push(right[j]);\n        j++; k++;\n      }\n    }\n    while(i < left.length) {\n      arr[k] = left[i];\n      mergedArray.push(left[i]);\n      i++; k++;\n    }\n    while(j < right.length) {\n      arr[k] = right[j];\n      mergedArray.push(right[j]);\n      j++; k++;\n    }\n    actions.push({type:'merge', leftStart:start1, leftEnd:end1, rightStart:start2, rightEnd:end2, mergedArray});\n  }\n\n  function timSort(arr) {\n    const actions = [];\n\n    const n = arr.length;\n    const minRun = minRunLength(n);\n    let runs = [];\n\n    // Step 1: Create natural runs and extend to minRun with insertion sort\n    let i = 0;\n    while (i < n) {\n      let runStart = i;\n      let runEnd = i + 1;\n\n      if(runEnd === n) {\n        runEnd = n - 1;\n        actions.push({type:'run', start: runStart, end: runEnd});\n        runs.push([runStart, runEnd]);\n        i = n;\n        break;\n      }\n\n      // Detect run direction ascending or descending\n      if(arr[runStart] <= arr[runEnd]) {\n        // Ascending run\n        while (runEnd < n -1 && arr[runEnd] <= arr[runEnd+1]) runEnd++;\n      } else {\n        // Descending run\n        while (runEnd < n -1 && arr[runEnd] > arr[runEnd+1]) runEnd++;\n        // Reverse descending run\n        arr.splice(runStart, runEnd - runStart + 1, ...arr.slice(runStart, runEnd +1).reverse());\n      }\n\n      // Run length found\n      let runLen = runEnd - runStart + 1;\n      // Extend run to minRun by insertion sort if needed\n      if (runLen < minRun) {\n        let extendEnd = Math.min(runStart + minRun - 1, n -1);\n        binaryInsertionSort(arr, runStart, extendEnd, actions);\n        runEnd = extendEnd;\n      }\n\n      // Log this run\n      actions.push({type:'run', start: runStart, end: runEnd});\n      runs.push([runStart, runEnd]);\n      i = runEnd + 1;\n    }\n\n    // Step 2: Merge runs until only one left\n    // We'll use a simple approach: repeatedly merge neighboring runs left to right\n\n    while (runs.length > 1) {\n      const newRuns = [];\n      for (let i = 0; i < runs.length; i += 2) {\n        if (i + 1 === runs.length) {\n          newRuns.push(runs[i]);\n        } else {\n          const left = runs[i];\n          const right = runs[i+1];\n          merge(arr, left[0], left[1], right[0], right[1], actions);\n          newRuns.push([left[0], right[1]]);\n        }\n      }\n      runs = newRuns;\n    }\n\n    return actions;\n  }\n\n\n  // Animate tim sort based on logged actions\n  // Animate frame-by-frame with easing\n\n  // Util easing curve (easeInOutQuad)\n  function easeInOutQuad(t) {\n    return t < 0.5 ? 2*t*t : -1 + (4 - 2*t)*t;\n  }\n\n  // Current animation context for merges\n  let animMergeContext = null;\n\n  function animateAction() {\n    if (state.actionIndex >= state.actions.length) {\n      state.sorting = false;\n      state.currentAction = null;\n      // Final redraw with fully sorted array\n      drawArray(state.array, {});\n      return;\n    }\n\n    if (!state.currentAction) {\n      state.currentAction = state.actions[state.actionIndex];\n      state.animationProgress = 0;\n\n      if(state.currentAction.type === 'merge') {\n        animMergeContext = {\n          leftIndices: [...Array(state.currentAction.leftEnd - state.currentAction.leftStart + 1).keys()]\n            .map(i => i + state.currentAction.leftStart),\n          rightIndices: [...Array(state.currentAction.rightEnd - state.currentAction.rightStart + 1).keys()]\n            .map(i => i + state.currentAction.rightStart),\n          mergedArray: state.currentAction.mergedArray.slice(),\n          leftCopy: state.array.slice(state.currentAction.leftStart, state.currentAction.leftEnd +1),\n          rightCopy: state.array.slice(state.currentAction.rightStart, state.currentAction.rightEnd +1),\n          posLeft: 0,\n          posRight: 0,\n          posMerge: state.currentAction.leftStart,\n          mergedSoFar: [],\n        };\n      }\n\n      if(state.currentAction.type === 'insertion') {\n        // noop initial setup\n      }\n\n      if(state.currentAction.type === 'run') {\n        // noop initial setup\n      }\n    }\n\n    state.animationProgress += (ANIMATION_SPEED*FRAME_DURATION)/800;\n    if(state.animationProgress > 1) state.animationProgress = 1;\n\n    // Depending on action type, draw differently\n    if(state.currentAction.type === 'run') {\n      // Highlight current run in gradient\n      drawArray(state.array, {runs: [{start: state.currentAction.start, end: state.currentAction.end}]});\n    }\n\n    else if(state.currentAction.type === 'insertion') {\n      drawArray(state.array, {insertion: state.currentAction.index});\n    }\n\n    else if(state.currentAction.type === 'merge') {\n      // Animate merge process stepwise\n\n      // Lerp between showing left/right separately and merged combined progressively\n\n      // Calculate progress eased\n      const eProg = easeInOutQuad(state.animationProgress);\n\n      // Number of elements merged so far on progress\n      const total = animMergeContext.mergedArray.length;\n      let mergedCount = Math.floor(eProg * total);\n\n      // Build color groups for bars\n      // Left: indices still to merge in leftCopy (posLeft to end)\n      // Right: indices still to merge in rightCopy (posRight to end)\n      // Merged: indices in mergedSoFar\n\n      // We simulate merging visually from left to right:\n\n      // Determine how mergedCount splits into leftCopy and rightCopy\n      // Because mergedArray is result of interleaving, we simulate picking elements in order\n\n      // We track mergedSoFar (elements already placed) and highlight merged indices orange\n\n      // Also highlight in pink/red the elements currently considered from left and right segments being merged\n\n      // For simplicity at this animation step we just highlight all left items which haven't merged as merge_left,\n      // all right items unmerged as merge_right,\n      // all merged as merge_merged.\n\n      // Actually, to animate smoothly, we will blend merged array progressively replacing the old bars.\n\n      // Visual approach:\n\n      // Keep array bars as in main array state, but overlay colors on left and right runs:\n      // Left run bars: pink\n      // Right run bars: red\n      // Bars merged and replaced: gold (merged_merged)\n\n      // We'll highlight bars on left and right and highlight merged area separately.\n\n      // But the actual array is already updated because merges are done immediately in timSort code.\n\n      // So for visuals, we draw bars with colors according to:\n\n      // - Bars indices in left run which are still part of original leftCopy and have not been mapped merged yet => merge_left color\n      // - Bars indices in right run still present in rightCopy and not merged yet => merge_right color\n      // - Bar indices already merged (from left and right) => merge_merged color\n      // - Bar indices outside merge runs => normal color\n\n      // Calculate number merged from which run:\n      // We iterate leftCopy and rightCopy and compare mergedArray prefix.\n\n      // For performance, precompute merged counts per run on each tick:\n\n      let leftMergedCount = 0;\n      let rightMergedCount = 0;\n\n      for(let mi=0; mi < mergedCount; mi++) {\n        const val = animMergeContext.mergedArray[mi];\n        // Check if val is from leftCopy or rightCopy:\n        if (animMergeContext.leftCopy.includes(val)) leftMergedCount++;\n        else if (animMergeContext.rightCopy.includes(val)) rightMergedCount++;\n      }\n\n      const leftUnmergedIndices = animMergeContext.leftIndices.slice(leftMergedCount);\n      const rightUnmergedIndices = animMergeContext.rightIndices.slice(rightMergedCount);\n      const mergedIndices = animMergeContext.leftIndices.slice(0, leftMergedCount).concat(animMergeContext.rightIndices.slice(0,rightMergedCount));\n\n\n      drawArray(state.array,{\n        merging: {\n          left: leftUnmergedIndices,\n          right: rightUnmergedIndices,\n          merged: mergedIndices,\n        }\n      });\n\n    }\n\n    if (state.animationProgress >= 1) {\n      // Finished this action\n      state.actionIndex++;\n      state.currentAction = null;\n\n      if(state.actionIndex >= state.actions.length) {\n        // Completed all actions - final highlight\n        drawArray(state.array, {});\n      }\n    }\n\n    if(state.sorting) {\n      state.animationFrameId = requestAnimationFrame(animateAction);\n    }\n  }\n\n  // Start the tim sort animation\n  function startSort() {\n    if(state.sorting) return;\n    state.sorting = true;\n    state.actionIndex = 0;\n    state.actions = timSort(state.array.slice());\n    animateAction();\n  }\n\n  // Shuffle and redraw\n  function shuffleArray() {\n    if(state.sorting) return;\n    state.array = generateArray();\n    drawArray(state.array, {});\n  }\n\n  // Initialization\n  state.array = generateArray();\n  drawArray(state.array, {});\n\n  // Buttons hookup\n  document.getElementById('btnShuffle').addEventListener('click', () => {\n    if(state.sorting) return;\n    shuffleArray();\n  });\n\n  document.getElementById('btnStart').addEventListener('click', () => {\n    if(state.sorting) return;\n    startSort();\n  });\n})();\n</script>\n\n</body>\n</html>"
