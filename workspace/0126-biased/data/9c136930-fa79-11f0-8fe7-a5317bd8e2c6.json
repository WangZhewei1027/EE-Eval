  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Binary Tree Interactive Console</title>\n</head>\n<body>\n<h1>Binary Tree Interactive Console</h1>\n\n<div>\n  <strong>Quick controls (use many combos):</strong><br>\n  Create root value: <input id=\"rootValue\" type=\"text\" value=\"10\"> <button id=\"btnCreateRoot\">Create Root</button>\n  Insert BST value: <input id=\"bstValue\" type=\"text\" value=\"5\"> <button id=\"btnInsertBST\">Insert as BST</button>\n  Insert AVL value: <input id=\"avlValue\" type=\"text\" value=\"7\"> <button id=\"btnInsertAVL\">Insert as AVL</button>\n  Clear tree: <button id=\"btnClear\">Clear</button>\n</div>\n\n<hr>\n\n<div>\n  <strong>Manual node operations (select a node from the tree display below first):</strong><br>\n  Selected node id: <span id=\"selectedInfo\">none</span><br>\n  New child value: <input id=\"childValue\" type=\"text\" value=\"X\">\n  <button id=\"btnAddLeft\">Add left child</button>\n  <button id=\"btnAddRight\">Add right child</button>\n  <button id=\"btnReplaceValue\">Replace value</button>\n  <button id=\"btnDeleteSubtree\">Delete subtree</button>\n  <button id=\"btnSwapChildren\">Swap children</button>\n  <button id=\"btnMirror\">Mirror subtree</button>\n  <button id=\"btnCopySubtree\">Copy subtree</button>\n  Paste subtree as: <select id=\"pasteSide\"><option value=\"left\">left</option><option value=\"right\">right</option></select>\n  <button id=\"btnPasteSubtree\">Paste subtree</button>\n</div>\n\n<hr>\n\n<div>\n  <strong>Rotations and re-rooting:</strong><br>\n  <button id=\"btnRotateLeft\">Rotate left at selected</button>\n  <button id=\"btnRotateRight\">Rotate right at selected</button>\n  <button id=\"btnRotateUpStep\">Rotate selected up one step</button>\n  <button id=\"btnRotateToRoot\">Auto-rotate selected to root</button>\n</div>\n\n<hr>\n\n<div>\n  <strong>Build / Generate / Import:</strong><br>\n  Build from array (comma separated): <input id=\"buildArray\" type=\"text\" value=\"8,3,10,1,6,14,4,7,13\">\n  <select id=\"buildMode\"><option value=\"bst\">Insert order -> BST</option><option value=\"balanced\">Balanced from values</option></select>\n  <button id=\"btnBuildArray\">Build</button>\n  Random tree size: <input id=\"randSize\" type=\"range\" min=\"1\" max=\"30\" value=\"9\"> <span id=\"randSizeVal\">9</span>\n  <select id=\"randType\"><option value=\"bst\">Random BST</option><option value=\"random\">Random shape</option><option value=\"full\">Full-ish</option></select>\n  <button id=\"btnRandom\">Generate Random</button>\n  Export JSON: <button id=\"btnExport\">Export</button> Import JSON: <input id=\"importJson\" type=\"text\" value=''> <button id=\"btnImport\">Import</button>\n  Save key: <input id=\"saveKey\" type=\"text\" value=\"myTree\"> <button id=\"btnSave\">Save</button> <button id=\"btnLoad\">Load</button>\n</div>\n\n<hr>\n\n<div>\n  <strong>Traversal & Search (many modes):</strong><br>\n  Traversal type: <select id=\"travType\"><option value=\"inorder\">In-order</option><option value=\"preorder\">Pre-order</option><option value=\"postorder\">Post-order</option><option value=\"levelorder\">Level-order</option></select>\n  <button id=\"btnStartTrav\">Start traversal</button>\n  <button id=\"btnStepTrav\">Step</button>\n  <button id=\"btnPrevTrav\">Prev</button>\n  <button id=\"btnStopTrav\">Stop</button>\n  Auto-play interval (ms): <input id=\"travInterval\" type=\"range\" min=\"100\" max=\"2000\" step=\"100\" value=\"500\"> <span id=\"travIntervalVal\">500</span>\n  <br>\n  Search value: <input id=\"searchValue\" type=\"text\" value=\"7\"> <select id=\"searchMode\"><option value=\"first\">Find first (BST-style step)</option><option value=\"all\">Find all</option></select>\n  <button id=\"btnSearch\">Search (stepable)</button>\n  <button id=\"btnStepSearch\">Step search</button>\n  <button id=\"btnStopSearch\">Stop search</button>\n  <div>Traversal output: <span id=\"travOutput\"></span></div>\n</div>\n\n<hr>\n\n<div>\n  <strong>Analysis / Info:</strong><br>\n  Tree size: <span id=\"infoSize\">0</span>,\n  Height: <span id=\"infoHeight\">-</span>,\n  Leaves: <span id=\"infoLeaves\">0</span>,\n  Is BST: <span id=\"infoIsBST\">-</span>,\n  Root balance (hL-hR): <span id=\"infoRootBal\">-</span>\n  <br>\n  Representation: <select id=\"reprMode\"><option value=\"ascii\">ASCII</option><option value=\"list\">Edge list</option><option value=\"paren\">Parenthesis</option><option value=\"dot\">DOT (Graphviz)</option></select>\n  <button id=\"btnRender\">Render</button>\n</div>\n\n<hr>\n\n<div>\n  <strong>Undo / Redo / History:</strong><br>\n  <button id=\"btnUndo\">Undo</button>\n  <button id=\"btnRedo\">Redo</button>\n  <button id=\"btnClearHistory\">Clear History</button>\n</div>\n\n<hr>\n\n<div>\n  <strong>Canvas (click a node button to select it):</strong>\n  <div id=\"canvasArea\"></div>\n  <pre id=\"asciiArea\"></pre>\n</div>\n\n<hr>\n\n<div>\n  <strong>Log / Steps:</strong>\n  <div id=\"logArea\" style=\"white-space:pre-wrap;\"></div>\n</div>\n\n<script>\n(function(){\n\n// Minimalistic, functional binary tree interactive system.\n// No styling beyond default browser controls.\n\nlet idCounter = 1;\nfunction newId(){ return 'n'+(idCounter++); }\n\nfunction Node(value){\n  this.id = newId();\n  this.value = value;\n  this.left = null;\n  this.right = null;\n  this.parent = null;\n}\n\nlet state = {\n  root: null,\n  selected: null,\n  copyBuffer: null,\n  undoStack: [],\n  redoStack: [],\n  travSequence: [],\n  travIndex: -1,\n  travTimer: null,\n  travInterval: 500,\n  searchIterator: null,\n  searchTimer: null\n};\n\nfunction snapshot(){\n  function cloneNode(n){\n    if(!n) return null;\n    return {\n      id: n.id,\n      value: n.value,\n      left: cloneNode(n.left),\n      right: cloneNode(n.right)\n    };\n  }\n  const s = cloneNode(state.root);\n  return JSON.stringify({root:s, idCounter:idCounter});\n}\n\nfunction restoreSnapshot(json){\n  if(!json) return;\n  const data = JSON.parse(json);\n  idCounter = data.idCounter || idCounter;\n  function build(n, parent){\n    if(!n) return null;\n    const node = new Node(n.value);\n    node.id = n.id;\n    node.parent = parent;\n    node.left = build(n.left, node);\n    node.right = build(n.right, node);\n    return node;\n  }\n  state.root = build(data.root, null);\n  state.selected = null;\n  renderAll();\n}\n\nfunction pushUndo(){\n  state.undoStack.push(snapshot());\n  if(state.undoStack.length>200) state.undoStack.shift();\n  state.redoStack = [];\n  updateInfo();\n}\n\nfunction undo(){\n  if(state.undoStack.length===0) return;\n  const current = snapshot();\n  state.redoStack.push(current);\n  const prev = state.undoStack.pop();\n  restoreSnapshot(prev);\n  log('Undo');\n}\n\nfunction redo(){\n  if(state.redoStack.length===0) return;\n  const cur = snapshot();\n  state.undoStack.push(cur);\n  const next = state.redoStack.pop();\n  restoreSnapshot(next);\n  log('Redo');\n}\n\nfunction log(){\n  const el = document.getElementById('logArea');\n  const txt = Array.from(arguments).join(' ');\n  el.textContent = txt + '\\n' + el.textContent;\n}\n\nfunction renderAll(){\n  renderCanvas();\n  renderAscii();\n  updateInfo();\n}\n\nfunction renderCanvas(){\n  const area = document.getElementById('canvasArea');\n  while(area.firstChild) area.removeChild(area.firstChild);\n  if(!state.root){\n    area.textContent = '(empty)';\n    document.getElementById('selectedInfo').textContent = 'none';\n    return;\n  }\n  // build levels\n  const levels = [];\n  const q = [{node: state.root, level:0}];\n  const visited = new Set();\n  while(q.length){\n    const item = q.shift();\n    const n = item.node;\n    const l = item.level;\n    if(!levels[l]) levels[l]=[];\n    levels[l].push(n);\n    if(n.left) q.push({node:n.left, level:l+1});\n    if(n.right) q.push({node:n.right, level:l+1});\n  }\n  levels.forEach((lvl, idx)=>{\n    const row = document.createElement('div');\n    row.textContent = ''; // ensure element\n    lvl.forEach(n=>{\n      const b = document.createElement('button');\n      b.textContent = n.id + ':' + String(n.value);\n      b.onclick = function(){ selectNodeById(n.id); };\n      if(state.selected && state.selected.id === n.id){\n        // mark selection by enclosing with braces\n        b.textContent = '[' + b.textContent + ']';\n      }\n      row.appendChild(b);\n      row.appendChild(document.createTextNode(' '));\n    });\n    area.appendChild(row);\n  });\n  updateSelectedInfo();\n}\n\nfunction renderAscii(){\n  const out = document.getElementById('asciiArea');\n  if(!state.root){\n    out.textContent = '(empty)';\n    return;\n  }\n  function buildLines(node, prefix, isLeft){\n    if(!node) return [];\n    const line = prefix + (isLeft? 'L- ' : 'R- ') + node.id+':'+node.value;\n    const leftPref = prefix + (isLeft ? '|  ' : '   ');\n    const rightPref = prefix + (isLeft ? '|  ' : '   ');\n    const leftLines = buildLines(node.left, leftPref, true);\n    const rightLines = buildLines(node.right, rightPref, false);\n    return [line].concat(leftLines).concat(rightLines);\n  }\n  const header = state.root.id+':'+state.root.value+' (root)';\n  const lines = [header];\n  if(state.root.left || state.root.right){\n    lines.push.apply(lines, buildLines(state.root.left, '', true));\n    lines.push.apply(lines, buildLines(state.root.right, '', false));\n  }\n  // show pointer to selected in ASCII by marking selection with []\n  const sel = state.selected ? state.selected.id : null;\n  for(let i=0;i<lines.length;i++){\n    if(sel && lines[i].indexOf(sel+':')!==-1){\n      lines[i] = '> ' + lines[i];\n    }\n  }\n  out.textContent = lines.join('\\n');\n}\n\nfunction selectNodeById(id){\n  const node = findById(state.root, id);\n  if(node){\n    state.selected = node;\n    updateSelectedInfo();\n    renderAll();\n    log('Selected', node.id, node.value);\n  }\n}\n\nfunction updateSelectedInfo(){\n  const el = document.getElementById('selectedInfo');\n  if(!state.selected){\n    el.textContent = 'none';\n  } else {\n    el.textContent = state.selected.id + ' : ' + state.selected.value +\n      ' (parent:' + (state.selected.parent?state.selected.parent.id:'-') + \n      ' left:' + (state.selected.left?state.selected.left.id:'-') + \n      ' right:' + (state.selected.right?state.selected.right.id:'-') + ')';\n  }\n}\n\nfunction findById(node, id){\n  if(!node) return null;\n  if(node.id === id) return node;\n  return findById(node.left, id) || findById(node.right, id);\n}\n\nfunction addRoot(value){\n  pushUndo();\n  const n = new Node(value);\n  state.root = n;\n  state.selected = n;\n  renderAll();\n  log('Created root', n.id, value);\n}\n\nfunction addChild(side, value){\n  if(!state.selected){ alert('Select a parent first'); return; }\n  pushUndo();\n  const parent = state.selected;\n  const child = new Node(value);\n  child.parent = parent;\n  if(side==='left'){\n    if(parent.left) { if(!confirm('Left child exists - overwrite entire subtree?')) return; }\n    parent.left = child;\n  } else {\n    if(parent.right) { if(!confirm('Right child exists - overwrite entire subtree?')) return; }\n    parent.right = child;\n  }\n  state.selected = child;\n  renderAll();\n  log('Added', side, 'child', child.id, value, 'to', parent.id);\n}\n\nfunction replaceValue(node, value){\n  if(!node) return;\n  pushUndo();\n  node.value = value;\n  renderAll();\n  log('Replaced value of', node.id, 'with', value);\n}\n\nfunction deleteSubtree(node){\n  if(!node) return;\n  pushUndo();\n  if(!node.parent){\n    state.root = null;\n    state.selected = null;\n    renderAll();\n    log('Deleted entire tree');\n    return;\n  }\n  const p = node.parent;\n  if(p.left && p.left.id === node.id) p.left = null;\n  if(p.right && p.right.id === node.id) p.right = null;\n  state.selected = p;\n  renderAll();\n  log('Deleted subtree at', node.id);\n}\n\nfunction swapChildren(node){\n  if(!node) return;\n  pushUndo();\n  const t = node.left;\n  node.left = node.right;\n  node.right = t;\n  if(node.left) node.left.parent = node;\n  if(node.right) node.right.parent = node;\n  renderAll();\n  log('Swapped children of', node.id);\n}\n\nfunction mirrorSubtree(node){\n  if(!node) return;\n  pushUndo();\n  function mirror(n){\n    if(!n) return;\n    const t = n.left;\n    n.left = n.right;\n    n.right = t;\n    if(n.left) n.left.parent = n;\n    if(n.right) n.right.parent = n;\n    mirror(n.left); mirror(n.right);\n  }\n  mirror(node);\n  renderAll();\n  log('Mirrored subtree at', node.id);\n}\n\nfunction copySubtree(node){\n  if(!node) return;\n  function clone(n){\n    if(!n) return null;\n    const c = {id:n.id, value:n.value, left: clone(n.left), right: clone(n.right)};\n    return c;\n  }\n  state.copyBuffer = clone(node);\n  log('Copied subtree', node.id);\n}\n\nfunction pasteSubtree(targetNode, side){\n  if(!state.copyBuffer){ alert('No copy buffer'); return; }\n  if(!targetNode){ alert('Select a target node'); return; }\n  pushUndo();\n  function build(n, parent){\n    if(!n) return null;\n    const node = new Node(n.value);\n    node.id = newId(); // give new id\n    node.parent = parent;\n    node.left = build(n.left, node);\n    node.right = build(n.right, node);\n    return node;\n  }\n  const subtree = build(state.copyBuffer, targetNode);\n  if(side==='left') targetNode.left = subtree;\n  else targetNode.right = subtree;\n  renderAll();\n  log('Pasted buffer to', targetNode.id, side);\n}\n\nfunction rotateLeft(x){\n  if(!x || !x.right) return false;\n  pushUndo();\n  const y = x.right;\n  const p = x.parent;\n  x.right = y.left;\n  if(y.left) y.left.parent = x;\n  y.left = x;\n  x.parent = y;\n  y.parent = p;\n  if(p){\n    if(p.left && p.left.id === x.id) p.left = y;\n    else if(p.right && p.right.id === x.id) p.right = y;\n  } else {\n    state.root = y;\n  }\n  renderAll();\n  log('Rotate left at', x.id);\n  return true;\n}\n\nfunction rotateRight(x){\n  if(!x || !x.left) return false;\n  pushUndo();\n  const y = x.left;\n  const p = x.parent;\n  x.left = y.right;\n  if(y.right) y.right.parent = x;\n  y.right = x;\n  x.parent = y;\n  y.parent = p;\n  if(p){\n    if(p.left && p.left.id === x.id) p.left = y;\n    else if(p.right && p.right.id === x.id) p.right = y;\n  } else {\n    state.root = y;\n  }\n  renderAll();\n  log('Rotate right at', x.id);\n  return true;\n}\n\nfunction rotateUpStep(selected){\n  if(!selected || !selected.parent) return;\n  const p = selected.parent;\n  if(p.left && p.left.id === selected.id){\n    // rotate right at parent\n    rotateRight(p);\n  } else {\n    rotateLeft(p);\n  }\n}\n\nfunction rotateSelectedToRoot(selected){\n  if(!selected) return;\n  while(selected.parent){\n    rotateUpStep(selected);\n  }\n}\n\nfunction buildFromArray(arr, mode){\n  pushUndo();\n  if(mode==='bst'){\n    state.root = null;\n    arr.forEach(v=>insertBST(v,false));\n  } else { // balanced\n    const sorted = arr.slice().sort((a,b)=> (a<b?-1:(a>b?1:0)));\n    function build(l, r){\n      if(l>r) return null;\n      const m = Math.floor((l+r)/2);\n      const n = new Node(sorted[m]);\n      n.left = build(l, m-1);\n      if(n.left) n.left.parent = n;\n      n.right = build(m+1, r);\n      if(n.right) n.right.parent = n;\n      return n;\n    }\n    state.root = build(0, sorted.length-1);\n  }\n  state.selected = state.root;\n  renderAll();\n  log('Built tree from array', arr.join(','));\n}\n\nfunction generateRandom(size, type){\n  pushUndo();\n  state.root = null;\n  if(type==='bst'){\n    const vals = [];\n    for(let i=0;i<size;i++) vals.push(Math.floor(Math.random()*100));\n    vals.forEach(v=>insertBST(v,false));\n  } else if(type==='random'){\n    // generate random structure by inserting nodes in random available positions\n    const root = new Node(Math.floor(Math.random()*100));\n    state.root = root;\n    const nodes = [root];\n    for(let i=1;i<size;i++){\n      const parent = nodes[Math.floor(Math.random()*nodes.length)];\n      const child = new Node(Math.floor(Math.random()*100));\n      child.parent = parent;\n      if(!parent.left) parent.left = child;\n      else if(!parent.right) parent.right = child;\n      else { // both full, replace some node\n        let p = parent;\n        while(p.left && p.right) p = nodes[Math.floor(Math.random()*nodes.length)];\n        if(!p.left) p.left = child;\n        else p.right = child;\n        child.parent = p;\n      }\n      nodes.push(child);\n    }\n  } else { // full-ish\n    function make(depth){\n      if(depth<=0) return null;\n      const n = new Node(Math.floor(Math.random()*100));\n      if(Math.random()>0.3) { n.left = make(depth-1); if(n.left) n.left.parent = n; }\n      if(Math.random()>0.3) { n.right = make(depth-1); if(n.right) n.right.parent = n; }\n      return n;\n    }\n    state.root = make(Math.ceil(Math.log2(size+1)));\n  }\n  state.selected = state.root;\n  renderAll();\n  log('Generated random', type, 'size', size);\n}\n\n// BST insert (simple)\nfunction insertBST(value, pushU=true){\n  if(pushU) pushUndo();\n  const n = new Node(value);\n  if(!state.root){ state.root = n; state.selected = n; renderAll(); return n; }\n  let cur = state.root;\n  while(true){\n    if(String(value) === String(cur.value)){ // allow duplicates treated go right\n      if(!cur.right){ cur.right = n; n.parent = cur; break; } else { cur = cur.right; continue; }\n    }\n    if(value < cur.value){\n      if(!cur.left){ cur.left = n; n.parent = cur; break; }\n      cur = cur.left;\n    } else {\n      if(!cur.right){ cur.right = n; n.parent = cur; break; }\n      cur = cur.right;\n    }\n  }\n  state.selected = n;\n  renderAll();\n  log('Inserted BST', n.id, value);\n  return n;\n}\n\n// AVL insert (rebalances)\nfunction insertAVL(value){\n  pushUndo();\n  const n = new Node(value);\n  if(!state.root){ state.root = n; state.selected = n; renderAll(); return; }\n  // normal BST insert\n  let cur = state.root, parent=null;\n  while(cur){\n    parent = cur;\n    if(value < cur.value) cur = cur.left;\n    else cur = cur.right;\n  }\n  n.parent = parent;\n  if(value < parent.value) parent.left = n; else parent.right = n;\n  // rebalance from parent upwards\n  function height(x){\n    if(!x) return 0;\n    return 1 + Math.max(height(x.left), height(x.right));\n  }\n  function balanceFactor(x){ return height(x.left) - height(x.right); }\n  function rebalance(node){\n    while(node){\n      const bf = balanceFactor(node);\n      if(bf > 1){\n        if(balanceFactor(node.left) < 0){\n          // LR\n          rotateLeft(node.left);\n        }\n        rotateRight(node);\n      } else if(bf < -1){\n        if(balanceFactor(node.right) > 0){\n          rotateRight(node.right);\n        }\n        rotateLeft(node);\n      }\n      node = node.parent;\n    }\n  }\n  rebalance(n.parent);\n  state.selected = n;\n  renderAll();\n  log('Inserted AVL', n.id, value);\n}\n\nfunction serialize(){\n  function clone(n){\n    if(!n) return null;\n    return {id:n.id, value:n.value, left: clone(n.left), right: clone(n.right)};\n  }\n  return JSON.stringify(clone(state.root), null, 2);\n}\n\nfunction importJson(text){\n  try{\n    const obj = JSON.parse(text);\n    pushUndo();\n    function build(o, parent){\n      if(!o) return null;\n      const n = new Node(o.value);\n      n.id = o.id || newId();\n      n.parent = parent;\n      n.left = build(o.left, n);\n      n.right = build(o.right, n);\n      return n;\n    }\n    state.root = build(obj, null);\n    state.selected = state.root;\n    renderAll();\n    log('Imported JSON');\n  } catch(e){ alert('Invalid JSON'); }\n}\n\nfunction exportDot(){\n  let lines = ['digraph G {'];\n  function traverse(n){\n    if(!n) return;\n    lines.push('  \"'+n.id+'\" [label=\"'+n.id+':'+n.value+'\"];');\n    if(n.left) { lines.push('  \"'+n.id+'\" -> \"'+n.left.id+'\" [label=\"L\"]; traverse(n.left); }\n    if(n.right){ lines.push('  \"'+n.id+'\" -> \"'+n.right.id+'\" [label=\"R\"]; traverse(n.right); }\n  }\n  traverse(state.root);\n  lines.push('}');\n  return lines.join('\\n');\n}\n\nfunction edgeList(){\n  const arr=[];\n  function t(n){\n    if(!n) return;\n    if(n.left) arr.push(n.id+' -L-> '+n.left.id);\n    if(n.right) arr.push(n.id+' -R-> '+n.right.id);\n    t(n.left); t(n.right);\n  }\n  t(state.root);\n  return arr.join('\\n');\n}\n\nfunction parenthesisRep(n){\n  if(!n) return 'null';\n  return n.value + '(' + parenthesisRep(n.left) + ',' + parenthesisRep(n.right) + ')';\n}\n\nfunction countNodes(n){ if(!n) return 0; return 1 + countNodes(n.left) + countNodes(n.right); }\nfunction height(n){ if(!n) return -1; return 1 + Math.max(height(n.left), height(n.right)); }\nfunction countLeaves(n){ if(!n) return 0; if(!n.left && !n.right) return 1; return countLeaves(n.left)+countLeaves(n.right); }\n\nfunction isBST(n, min=-Infinity, max=Infinity){\n  if(!n) return true;\n  if(!(n.value >= min && n.value <= max)) return false;\n  return isBST(n.left, min, Math.min(max, n.value)) && isBST(n.right, Math.max(min, n.value), max);\n}\n\nfunction computeRootBalance(){\n  if(!state.root) return '-';\n  return height(state.root.left) - height(state.root.right);\n}\n\n// Traversals\nfunction produceTraversal(type){\n  const seq = [];\n  function pre(n){ if(!n) return; seq.push(n); pre(n.left); pre(n.right); }\n  function inord(n){ if(!n) return; inord(n.left); seq.push(n); inord(n.right); }\n  function post(n){ if(!n) return; post(n.left); post(n.right); seq.push(n); }\n  function level(n){\n    if(!n) return;\n    const q=[n];\n    while(q.length){\n      const cur=q.shift();\n      seq.push(cur);\n      if(cur.left) q.push(cur.left);\n      if(cur.right) q.push(cur.right);\n    }\n  }\n  if(!state.root) return seq;\n  if(type==='preorder') pre(state.root);\n  else if(type==='inorder') inord(state.root);\n  else if(type==='postorder') post(state.root);\n  else if(type==='levelorder') level(state.root);\n  return seq;\n}\n\nfunction startTraversal(type){\n  stopTraversal();\n  state.travSequence = produceTraversal(type);\n  state.travIndex = -1;\n  document.getElementById('travOutput').textContent = '';\n  if(state.travSequence.length===0) { log('Empty traversal'); return; }\n  playTraversal();\n  log('Started traversal', type);\n}\n\nfunction playTraversal(){\n  // play by interval, stepping through seq\n  stepTraversal(1);\n  state.travTimer = setInterval(()=> stepTraversal(1), state.travInterval);\n}\n\nfunction stepTraversal(dir){\n  if(state.travSequence.length===0) return;\n  state.travIndex += dir;\n  if(state.travIndex < 0) state.travIndex = 0;\n  if(state.travIndex >= state.travSequence.length) {\n    stopTraversal();\n    log('Traversal finished');\n    return;\n  }\n  const node = state.travSequence[state.travIndex];\n  document.getElementById('travOutput').textContent = node.id+':'+node.value + ' ('+(state.travIndex+1)+'/'+state.travSequence.length+')';\n  // highlight node (select)\n  state.selected = node;\n  renderAll();\n}\n\nfunction stopTraversal(){\n  if(state.travTimer) { clearInterval(state.travTimer); state.travTimer = null; }\n}\n\n// Search step-by-step (for demonstration, BFS or BST-style)\nfunction startSearch(value, mode){\n  stopSearch();\n  if(!state.root) return;\n  if(mode==='first'){\n    // BST-style search path (if tree is BST-ish)\n    state.searchIterator = function*(){\n      let cur = state.root;\n      while(cur){\n        yield cur;\n        if(String(value) === String(cur.value)) return;\n        if(value < cur.value) cur = cur.left; else cur = cur.right;\n      }\n    }();\n  } else {\n    // find all using BFS generator\n    state.searchIterator = (function*(){\n      const q=[state.root];\n      while(q.length){\n        const n = q.shift();\n        yield n;\n        if(n.left) q.push(n.left);\n        if(n.right) q.push(n.right);\n      }\n    })();\n  }\n  document.getElementById('travOutput').textContent = '';\n  log('Started search for', value);\n  // optionally start auto-play? We'll not auto-play; user steps.\n}\n\nfunction stepSearch(value, mode){\n  if(!state.searchIterator){ alert('Start search first'); return; }\n  const next = state.searchIterator.next();\n  if(next.done){ stopSearch(); log('Search finished'); return; }\n  const node = next.value;\n  state.selected = node;\n  renderAll();\n  document.getElementById('travOutput').textContent = 'Search at ' + node.id+':'+node.value;\n  if(String(node.value) === String(value)){\n    log('Found match at', node.id, node.value);\n    if(mode==='first'){ stopSearch(); }\n  }\n}\n\nfunction stopSearch(){\n  state.searchIterator = null;\n  log('Stopped search');\n}\n\n// Undo/Redo controls\nfunction clearHistory(){\n  state.undoStack = [];\n  state.redoStack = [];\n  log('Cleared history');\n}\n\n// Utility: update info display\nfunction updateInfo(){\n  document.getElementById('infoSize').textContent = countNodes(state.root);\n  document.getElementById('infoHeight').textContent = state.root ? height(state.root) : '-';\n  document.getElementById('infoLeaves').textContent = countLeaves(state.root);\n  document.getElementById('infoIsBST').textContent = isBST(state.root) ? 'yes' : 'no';\n  document.getElementById('infoRootBal').textContent = computeRootBalance();\n  document.getElementById('randSizeVal').textContent = document.getElementById('randSize').value;\n  document.getElementById('travIntervalVal').textContent = state.travInterval;\n}\n\n// Hook buttons\ndocument.getElementById('btnCreateRoot').onclick = function(){\n  const v = parseInputValue(document.getElementById('rootValue').value);\n  addRoot(v);\n};\n\ndocument.getElementById('btnInsertBST').onclick = function(){\n  const v = parseInputValue(document.getElementById('bstValue').value);\n  pushUndo();\n  insertBST(v);\n};\n\ndocument.getElementById('btnInsertAVL').onclick = function(){\n  const v = parseInputValue(document.getElementById('avlValue').value);\n  insertAVL(v);\n};\n\ndocument.getElementById('btnClear').onclick = function(){\n  if(confirm('Clear entire tree?')){ pushUndo(); state.root = null; state.selected = null; renderAll(); }\n};\n\ndocument.getElementById('btnAddLeft').onclick = function(){ addChild('left', parseInputValue(document.getElementById('childValue').value)); };\ndocument.getElementById('btnAddRight').onclick = function(){ addChild('right', parseInputValue(document.getElementById('childValue').value)); };\ndocument.getElementById('btnReplaceValue').onclick = function(){\n  if(!state.selected){ alert('Select a node'); return; }\n  replaceValue(state.selected, parseInputValue(document.getElementById('childValue').value));\n};\ndocument.getElementById('btnDeleteSubtree').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } if(confirm('Delete subtree at '+state.selected.id+'?')) deleteSubtree(state.selected); };\ndocument.getElementById('btnSwapChildren').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } swapChildren(state.selected); };\ndocument.getElementById('btnMirror').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } mirrorSubtree(state.selected); };\ndocument.getElementById('btnCopySubtree').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } copySubtree(state.selected); };\ndocument.getElementById('btnPasteSubtree').onclick = function(){\n  const side = document.getElementById('pasteSide').value;\n  if(!state.selected){ alert('Select a node to paste to'); return; }\n  pasteSubtree(state.selected, side);\n};\n\ndocument.getElementById('btnRotateLeft').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } rotateLeft(state.selected); };\ndocument.getElementById('btnRotateRight').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } rotateRight(state.selected); };\ndocument.getElementById('btnRotateUpStep').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } rotateUpStep(state.selected); };\ndocument.getElementById('btnRotateToRoot').onclick = function(){ if(!state.selected){ alert('Select a node'); return; } rotateSelectedToRoot(state.selected); };\n\ndocument.getElementById('btnBuildArray').onclick = function(){\n  const txt = document.getElementById('buildArray').value.trim();\n  if(!txt){ alert('Enter values'); return; }\n  const arr = txt.split(',').map(s=>parseInputValue(s.trim()));\n  const mode = document.getElementById('buildMode').value;\n  buildFromArray(arr, mode);\n};\n\ndocument.getElementById('randSize').oninput = updateInfo;\ndocument.getElementById('btnRandom').onclick = function(){\n  const sz = parseInt(document.getElementById('randSize').value,10);\n  const type = document.getElementById('randType').value;\n  generateRandom(sz, type);\n};\n\ndocument.getElementById('btnExport').onclick = function(){\n  const txt = serialize();\n  // simple popup\n  const w = window.open(\"\", \"_blank\");\n  w.document.write('<pre>' + escapeHtml(txt) + '</pre>');\n};\n\ndocument.getElementById('btnImport').onclick = function(){\n  const txt = document.getElementById('importJson').value.trim();\n  if(!txt){ alert('Enter JSON'); return; }\n  importJson(txt);\n};\n\ndocument.getElementById('btnSave').onclick = function(){\n  const key = document.getElementById('saveKey').value || 'tree';\n  localStorage.setItem('binaryTree:'+key, serialize());\n  log('Saved to localStorage key', key);\n};\n\ndocument.getElementById('btnLoad').onclick = function(){\n  const key = document.getElementById('saveKey').value || 'tree';\n  const txt = localStorage.getItem('binaryTree:'+key);\n  if(!txt){ alert('No saved tree under key '+key); return; }\n  importJson(txt);\n};\n\ndocument.getElementById('btnStartTrav').onclick = function(){\n  const type = document.getElementById('travType').value;\n  state.travInterval = parseInt(document.getElementById('travInterval').value,10);\n  startTraversal(type);\n};\n\ndocument.getElementById('btnStepTrav').onclick = function(){ stepTraversal(1); };\ndocument.getElementById('btnPrevTrav').onclick = function(){ stepTraversal(-1); };\ndocument.getElementById('btnStopTrav').onclick = function(){ stopTraversal(); };\ndocument.getElementById('travInterval').oninput = function(){ state.travInterval = parseInt(this.value,10); updateInfo(); if(state.travTimer){ stopTraversal(); playTraversal(); } };\n\ndocument.getElementById('btnSearch').onclick = function(){\n  const v = parseInputValue(document.getElementById('searchValue').value);\n  const mode = document.getElementById('searchMode').value;\n  startSearch(v, mode);\n};\ndocument.getElementById('btnStepSearch').onclick = function(){\n  const v = parseInputValue(document.getElementById('searchValue').value);\n  const mode = document.getElementById('searchMode').value;\n  stepSearch(v, mode);\n};\ndocument.getElementById('btnStopSearch').onclick = function(){ stopSearch(); };\n\ndocument.getElementById('btnRender').onclick = function(){\n  const mode = document.getElementById('reprMode').value;\n  if(!state.root){ alert('Empty'); return; }\n  let out = '';\n  if(mode==='ascii'){\n    renderAscii();\n    return;\n  } else if(mode==='list') out = edgeList();\n  else if(mode==='paren') out = parenthesisRep(state.root);\n  else if(mode==='dot') out = exportDot();\n  const w = window.open(\"\", \"_blank\");\n  w.document.write('<pre>' + escapeHtml(out) + '</pre>');\n};\n\ndocument.getElementById('btnUndo').onclick = undo;\ndocument.getElementById('btnRedo').onclick = redo;\ndocument.getElementById('btnClearHistory').onclick = clearHistory;\n\n// Helper\nfunction parseInputValue(s){\n  if(s === '') return '';\n  // try number\n  const n = Number(s);\n  if(!isNaN(n) && s.trim() !== '') return n;\n  return s;\n}\nfunction escapeHtml(s){ return (s+'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n// initialize\nrenderAll();\nupdateInfo();\nlog('Ready. Create a tree or generate random to begin. Many interactive paths: manual add, rotations, build, traversals, search, copy/paste, undo/redo, export/import.');\n\n// Additional helpful interactive utilities: re-root by path toggle\n// Reconnect parent pointers in case of manual import where parent pointers missing\nfunction fixParents(n, parent=null){\n  if(!n) return;\n  n.parent = parent;\n  fixParents(n.left, n);\n  fixParents(n.right, n);\n}\n// Keep state consistent on import\n(function checkImportedParentFix(){\n  const observer = new MutationObserver(function(){});\n  // call when import button used: attach to import button\n  document.getElementById('btnImport').addEventListener('click', function(){ if(state.root){ fixParents(state.root, null); renderAll(); }});\n})();\n\n})();\n</script>\n</body>\n</html>"
