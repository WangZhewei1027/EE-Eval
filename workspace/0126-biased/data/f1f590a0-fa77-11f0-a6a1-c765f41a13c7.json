  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Bubble Sort — Visual Elegance</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@500;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#071427;\n    --bg-2:#071a2c;\n    --card:#0f1724;\n    --glass: rgba(255,255,255,0.05);\n    --accent1:#7ef9c7; /* mint */\n    --accent2:#7ab0ff; /* sky */\n    --accent3:#ffc48c; /* warm */\n    --muted: rgba(255,255,255,0.65);\n    --glass-border: rgba(255,255,255,0.06);\n    --success: #6ef08a;\n  }\n\n  *{box-sizing:border-box}\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(122,176,255,0.08), transparent 6%),\n                radial-gradient(800px 400px at 90% 90%, rgba(126,249,199,0.05), transparent 6%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color: #eaf6ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n  }\n\n  /* Ambient soft shapes */\n  .auras{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n  }\n  .blob{\n    position:absolute;\n    filter: blur(60px);\n    opacity:0.12;\n    transform: translateZ(0);\n    mix-blend-mode: screen;\n  }\n  .blob.one{ width:580px;height:420px;background:linear-gradient(120deg,var(--accent2),#8a7bff); left:-8%; top:-10%;}\n  .blob.two{ width:420px;height:420px;background:linear-gradient(120deg,var(--accent1),#5de0ff); right:-6%; bottom:-12%;}\n  .blob.three{ width:260px;height:260px;background:linear-gradient(120deg,#ffd3a6,var(--accent3)); left:40%; top:54%; opacity:0.06; filter: blur(40px);}\n\n  /* Card */\n  .card{\n    position:relative;\n    z-index:2;\n    width:min(1100px,96vw);\n    max-width:1100px;\n    border-radius:18px;\n    padding:32px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid var(--glass-border);\n    box-shadow: 0 10px 50px rgba(2,8,23,0.65), inset 0 1px 0 rgba(255,255,255,0.02);\n    overflow:visible;\n    display:grid;\n    grid-template-columns: 380px 1fr;\n    gap:28px;\n    align-items:stretch;\n  }\n\n  /* Left panel */\n  .panel{\n    padding:26px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:20px;\n    min-height:350px;\n  }\n\n  .title{\n    display:flex;\n    gap:12px;\n    align-items:baseline;\n  }\n  .title h1{\n    margin:0;\n    font-family:'Playfair Display', serif;\n    font-weight:700;\n    letter-spacing:-0.6px;\n    font-size:26px;\n    color: #fff;\n  }\n  .title .badge{\n    font-weight:600;\n    font-size:12px;\n    color:var(--muted);\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:6px 10px;\n    border-radius:999px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .desc{\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.5;\n    margin-top:4px;\n  }\n\n  .stats{\n    display:flex;\n    gap:14px;\n    margin-top:6px;\n    flex-wrap:wrap;\n  }\n  .stat{\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    border-radius:10px;\n    padding:10px 12px;\n    min-width:120px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .stat .label{\n    font-size:12px;color:var(--muted);margin-bottom:6px;\n  }\n  .stat .value{\n    font-weight:700;font-size:16px;color:#fff;\n  }\n\n  .controls{\n    margin-top:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    -webkit-tap-highlight-color: transparent;\n    border:0;\n    padding:12px 16px;\n    border-radius:10px;\n    cursor:pointer;\n    font-weight:600;\n    font-size:14px;\n    color:var(--bg-2);\n    transition:all .22s cubic-bezier(.2,.9,.2,1);\n    box-shadow: 0 6px 18px rgba(8,12,20,0.45), inset 0 -3px 16px rgba(255,255,255,0.02);\n  }\n  .btn:active{ transform:translateY(1px) }\n  .btn.primary{\n    background: linear-gradient(90deg,var(--accent1), var(--accent2));\n    color: #052033;\n  }\n  .btn.ghost{\n    background:transparent;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.04);\n  }\n  .micro{\n    font-size:12px;color:var(--muted);\n  }\n\n  /* Right area: visualization */\n  .viz{\n    padding:22px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    border:1px solid rgba(255,255,255,0.03);\n    min-height:360px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .axis{\n    width:100%;\n    height:320px;\n    position:relative;\n    display:flex;\n    align-items:end;\n    justify-content:center;\n    padding:20px 28px 18px;\n  }\n\n  /* bar container */\n  .bars{\n    position:relative;\n    height:100%;\n    width:100%;\n    max-width:1000px;\n  }\n\n  .bar{\n    position:absolute;\n    bottom:20px;\n    width:48px;\n    border-radius:12px 12px 6px 6px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    box-shadow: 0 8px 20px rgba(7,18,30,0.6), 0 1px 0 rgba(255,255,255,0.02);\n    transition: transform 520ms cubic-bezier(.18,.9,.22,1), box-shadow 220ms, background 220ms;\n    display:flex;\n    align-items:end;\n    justify-content:center;\n    overflow:visible;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  .bar::after{\n    content:'';\n    position:absolute;\n    left:0;right:0;top:0;height:40%;\n    background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.0));\n    border-radius:inherit;\n    opacity:0.9;\n    pointer-events:none;\n  }\n\n  .bar .num{\n    position:relative;\n    margin-bottom:10px;\n    font-weight:800;\n    font-family: 'Playfair Display', serif;\n    font-size:14px;\n    color:rgba(255,255,255,0.95);\n    text-shadow: 0 2px 18px rgba(0,0,0,0.5);\n    transform: translateY(0);\n  }\n\n  .bar.comparing{\n    box-shadow: 0 14px 40px rgba(40,150,255,0.12), 0 2px 8px rgba(5,10,16,0.6);\n    transform: translateY(-6px) scale(1.03);\n    z-index:6;\n  }\n  .bar.swapping{\n    box-shadow: 0 24px 68px rgba(255,160,120,0.12);\n    transform: translateY(-14px) scale(1.06);\n    z-index:8;\n  }\n  .bar.sorted{\n    background: linear-gradient(180deg, rgba(110,240,138,0.18), rgba(110,240,138,0.06));\n    border:1px solid rgba(110,240,138,0.12);\n    box-shadow: 0 10px 30px rgba(110,240,138,0.06);\n  }\n\n  /* colored accents for each bar via gradient mask */\n  .bar[data-hue='0']{ background: linear-gradient(180deg,#1f3bff22, #6ab1ff22), var(--glass) }\n  .bar[data-hue='1']{ background: linear-gradient(180deg,#7ef9c722, #40c2a822), var(--glass) }\n  .bar[data-hue='2']{ background: linear-gradient(180deg,#ffd57a22, #ff8b5c22), var(--glass) }\n  .bar[data-hue='3']{ background: linear-gradient(180deg,#b48cff22, #7bb0ff22), var(--glass) }\n\n  /* footer small indicators */\n  .legend{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    font-size:13px;\n    color:var(--muted);\n    margin-top:6px;\n  }\n  .chip{\n    display:flex;\n    gap:8px;\n    align-items:center;\n    padding:6px 10px;\n    border-radius:999px;\n    background: rgba(255,255,255,0.015);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .dot{\n    width:12px;height:12px;border-radius:50%;\n    box-shadow: 0 3px 8px rgba(0,0,0,0.4), inset 0 -2px 6px rgba(255,255,255,0.02);\n  }\n  .dot.compare{ background: linear-gradient(90deg,var(--accent2),var(--accent1)); }\n  .dot.swap{ background: linear-gradient(90deg,var(--accent3),#ffb47a); }\n  .dot.sorted{ background: var(--success); }\n\n  /* subtle responsive */\n  @media (max-width:980px){\n    .card{ grid-template-columns: 1fr; width:96vw; padding:20px; gap:16px;}\n    .panel{ order:2}\n    .viz{ order:1; min-height:420px }\n    .axis{height:360px}\n  }\n\n  /* tiny helpful micro-animations */\n  @keyframes pulse {\n    0%{ transform: scale(1); opacity:0.8}\n    50%{ transform: scale(1.04); opacity:1}\n    100%{ transform: scale(1); opacity:0.8}\n  }\n\n  .brand{\n    font-family:'Playfair Display', serif;\n    font-size:12px;\n    letter-spacing:0.6px;\n    color:var(--muted);\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"auras\" aria-hidden=\"true\">\n    <div class=\"blob one\"></div>\n    <div class=\"blob two\"></div>\n    <div class=\"blob three\"></div>\n  </div>\n\n  <main class=\"card\" role=\"main\" aria-label=\"Bubble sort visualization\">\n    <section class=\"panel\" aria-hidden=\"false\">\n      <div class=\"title\">\n        <h1>Bubble Sort</h1>\n        <div class=\"badge\">O(n²) • Stable</div>\n      </div>\n      <p class=\"desc\">Observe the graceful choreography of the Bubble Sort algorithm. Elements gently compare, swap, and settle — rendered with subtle motion and refined visuals. This demonstration is intentionally minimal in controls so you can enjoy the animation without distraction.</p>\n\n      <div class=\"stats\" aria-hidden=\"true\">\n        <div class=\"stat\">\n          <div class=\"label\">Array size</div>\n          <div class=\"value\" id=\"stat-size\">12</div>\n        </div>\n        <div class=\"stat\">\n          <div class=\"label\">Comparisons</div>\n          <div class=\"value\" id=\"stat-comp\">0</div>\n        </div>\n        <div class=\"stat\">\n          <div class=\"label\">Swaps</div>\n          <div class=\"value\" id=\"stat-swap\">0</div>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button class=\"btn primary\" id=\"startBtn\" title=\"Start the animated sort\">Start Animation</button>\n        <button class=\"btn ghost\" id=\"shuffleBtn\" title=\"Shuffle and reset the array\">Shuffle</button>\n        <div style=\"flex:1\"></div>\n        <div class=\"brand micro\">Concept • Visual Elegance</div>\n      </div>\n\n      <div class=\"legend\" aria-hidden=\"true\" style=\"margin-top:8px\">\n        <div class=\"chip\"><div class=\"dot compare\"></div><div class=\"micro\">Comparing</div></div>\n        <div class=\"chip\"><div class=\"dot swap\"></div><div class=\"micro\">Swapping</div></div>\n        <div class=\"chip\"><div class=\"dot sorted\"></div><div class=\"micro\">In place</div></div>\n      </div>\n    </section>\n\n    <section class=\"viz\" aria-hidden=\"false\">\n      <div style=\"display:flex;flex-direction:column;align-items:center;gap:6px;width:100%;\">\n        <div style=\"display:flex;gap:10px;align-items:baseline;\">\n          <div style=\"font-weight:700;font-family:'Playfair Display', serif;font-size:18px;\">Elegant Bubble Sort</div>\n          <div style=\"font-size:13px;color:var(--muted);\">A slow, poetic demonstration</div>\n        </div>\n        <div style=\"font-size:12px;color:var(--muted);\">Watch as adjacent elements are compared and the largest bubble sinks to the end.</div>\n      </div>\n\n      <div class=\"axis\" role=\"img\" aria-label=\"Array visualization\">\n        <div class=\"bars\" id=\"barsContainer\"></div>\n      </div>\n    </section>\n  </main>\n\n<script>\n  // Visual Bubble Sort Demo\n  (function(){\n    const container = document.getElementById('barsContainer');\n    const startBtn = document.getElementById('startBtn');\n    const shuffleBtn = document.getElementById('shuffleBtn');\n    const statSize = document.getElementById('stat-size');\n    const statComp = document.getElementById('stat-comp');\n    const statSwap = document.getElementById('stat-swap');\n\n    let values = [];\n    let nodes = [];\n    let sorting = false;\n    let comparisons = 0;\n    let swaps = 0;\n    const N = 12; // array size\n    const delay = 420; // ms per step (keeps animation slow/observational)\n\n    statSize.textContent = N;\n\n    function randArray(n){\n      const arr = [];\n      for(let i=0;i<n;i++){\n        arr.push(Math.round(8 + Math.random()*92)); // 8..100\n      }\n      return arr;\n    }\n\n    function createBars(arr){\n      container.innerHTML = '';\n      nodes = [];\n      const width = container.clientWidth;\n      const barWidth = Math.min(72, Math.floor((width - 40) / arr.length) - 8);\n      const gap = Math.max(8, Math.floor((width - (barWidth*arr.length)) / (arr.length+1)));\n      // Bar positions precomputed\n      for(let i=0;i<arr.length;i++){\n        const v = arr[i];\n        const bar = document.createElement('div');\n        bar.className='bar';\n        bar.style.width = `${barWidth}px`;\n        const maxH = container.clientHeight - 48;\n        const h = Math.max(36, Math.round((v/100) * maxH));\n        bar.style.height = `${h}px`;\n        bar.setAttribute('data-index', i);\n        bar.setAttribute('data-value', v);\n        bar.setAttribute('data-hue', i % 4);\n        bar.dataset.pos = i;\n        // horizontal positioning\n        const x = gap + i * (barWidth + gap);\n        bar.style.transform = `translateX(${x}px)`;\n        bar.style.left = '0';\n        // Numeric label\n        const label = document.createElement('div');\n        label.className='num';\n        label.textContent = v;\n        bar.appendChild(label);\n        container.appendChild(bar);\n        nodes.push({\n          node: bar,\n          value: v,\n          pos: i,\n          x: x\n        });\n      }\n      // slight entrance animation\n      container.style.opacity = 0;\n      container.style.transform = 'translateY(6px)';\n      requestAnimationFrame(()=> {\n        container.style.transition = 'opacity 520ms cubic-bezier(.2,.9,.2,1), transform 520ms ease';\n        container.style.opacity = 1;\n        container.style.transform = 'translateY(0)';\n      });\n      setTimeout(()=> { container.style.transition = ''; }, 600);\n    }\n\n    function refreshStats(){\n      statComp.textContent = comparisons;\n      statSwap.textContent = swaps;\n    }\n\n    function reset(){\n      comparisons = 0; swaps = 0;\n      values = randArray(N);\n      createBars(values);\n      refreshStats();\n      // remove any sorted classes\n      nodes.forEach(n => {\n        n.node.classList.remove('sorted','comparing','swapping');\n      });\n    }\n\n    // swap positions in nodes array and animate transforms\n    function animateSwap(i, j){\n      return new Promise(resolve => {\n        const a = nodes[i];\n        const b = nodes[j];\n        // swap x positions\n        const ax = a.x;\n        const bx = b.x;\n        // mark swapping\n        a.node.classList.add('swapping');\n        b.node.classList.add('swapping');\n        // apply transforms\n        a.node.style.transition = `transform ${delay}ms cubic-bezier(.18,.9,.22,1), box-shadow 220ms`;\n        b.node.style.transition = `transform ${delay}ms cubic-bezier(.18,.9,.22,1), box-shadow 220ms`;\n        a.node.style.transform = `translateX(${bx}px)`;\n        b.node.style.transform = `translateX(${ax}px)`;\n\n        // after animation, swap internal data and reset\n        setTimeout(()=> {\n          a.node.classList.remove('swapping');\n          b.node.classList.remove('swapping');\n          // swap nodes in DOM order to keep z-index natural for subsequent transforms\n          // (not strictly necessary, but keep nodes array consistent)\n          container.insertBefore(b.node, a.node);\n          // swap nodes in nodes array\n          const tmp = nodes[i];\n          nodes[i] = nodes[j];\n          nodes[j] = tmp;\n          // update their positions stored\n          nodes[i].x = ax;\n          nodes[j].x = bx;\n          // reset inline transitions\n          a.node.style.transition = '';\n          b.node.style.transition = '';\n          resolve();\n        }, delay + 12);\n      });\n    }\n\n    function highlightCompare(i, j){\n      nodes[i].node.classList.add('comparing');\n      nodes[j].node.classList.add('comparing');\n    }\n    function clearCompare(i, j){\n      nodes[i].node.classList.remove('comparing');\n      nodes[j].node.classList.remove('comparing');\n    }\n\n    async function bubbleSortVisual(){\n      sorting = true;\n      startBtn.disabled = true;\n      shuffleBtn.disabled = true;\n      startBtn.textContent = 'Sorting...';\n\n      const n = nodes.length;\n      for(let pass=0; pass<n-1; pass++){\n        let swapped = false;\n        for(let i=0; i<n-1-pass; i++){\n          // compare nodes[i] and nodes[i+1]\n          highlightCompare(i, i+1);\n          comparisons++;\n          refreshStats();\n          await new Promise(r=>setTimeout(r, delay));\n          const a = nodes[i].value ?? parseInt(nodes[i].node.getAttribute('data-value'));\n          const b = nodes[i+1].value ?? parseInt(nodes[i+1].node.getAttribute('data-value'));\n          if(a > b){\n            swaps++;\n            refreshStats();\n            await animateSwap(i, i+1);\n            swapped = true;\n            // after swap, i stays same because nodes[i] now contains the smaller new element\n          }\n          clearCompare(i, i+1);\n        }\n        // mark the final element of this pass as sorted\n        const sortedIndex = n-1-pass;\n        nodes[sortedIndex].node.classList.add('sorted');\n        nodes[sortedIndex].node.style.transition = 'transform 420ms cubic-bezier(.18,.9,.22,1), box-shadow 320ms';\n        await new Promise(r=>setTimeout(r, 80));\n        if(!swapped) break;\n      }\n      // mark all remaining as sorted (in case early break)\n      for(let k=0;k<n;k++){\n        nodes[k].node.classList.add('sorted');\n      }\n\n      sorting = false;\n      startBtn.disabled = false;\n      shuffleBtn.disabled = false;\n      startBtn.textContent = 'Replay';\n    }\n\n    // handle window resize: reposition bars smoothly\n    let resizeTimer;\n    window.addEventListener('resize', ()=>{\n      clearTimeout(resizeTimer);\n      resizeTimer = setTimeout(()=> {\n        // recompute x positions based on new width\n        const width = container.clientWidth;\n        const barWidth = nodes.length ? nodes[0].node.clientWidth : 48;\n        const gap = Math.max(8, Math.floor((width - (barWidth*nodes.length)) / (nodes.length+1)));\n        nodes.forEach((n,i)=>{\n          const x = gap + i * (barWidth + gap);\n          n.x = x;\n          n.node.style.transition = 'transform 420ms cubic-bezier(.2,.9,.2,1)';\n          n.node.style.transform = `translateX(${x}px)`;\n          setTimeout(()=> { n.node.style.transition = ''; }, 480);\n        });\n      }, 160);\n    });\n\n    // init\n    reset();\n\n    // buttons\n    startBtn.addEventListener('click', async ()=>{\n      if(sorting) return;\n      // If \"Replay\", we should re-create nodes from existing values to replay sorting from unsorted array.\n      // Reset classes\n      nodes.forEach(n=>{\n        n.node.classList.remove('sorted','comparing','swapping');\n      });\n      comparisons = 0; swaps = 0;\n      refreshStats();\n      await bubbleSortVisual();\n    });\n\n    shuffleBtn.addEventListener('click', ()=>{\n      if(sorting) return;\n      reset();\n      startBtn.textContent = 'Start Animation';\n    });\n\n    // accessibility: keyboard shortcut 's' to start, 'r' to reshuffle\n    window.addEventListener('keydown', (e)=>{\n      if(e.key === 's' || e.key === 'S') startBtn.click();\n      if(e.key === 'r' || e.key === 'R') shuffleBtn.click();\n    });\n\n    // tiny visual flourish: subtle floating breathing on bars when idle\n    setInterval(()=>{\n      if(sorting) return;\n      // pick a random bar to pulse\n      const idx = Math.floor(Math.random() * nodes.length);\n      const el = nodes[idx] && nodes[idx].node;\n      if(!el) return;\n      el.style.transition = 'transform 700ms cubic-bezier(.18,.9,.22,1)';\n      el.style.transform = el.style.transform + ' scale(1.02)';\n      setTimeout(()=> {\n        // revert transform to original translateX(x)\n        const tx = nodes[idx].x;\n        el.style.transform = `translateX(${tx}px)`;\n        setTimeout(()=> { el.style.transition = ''; }, 720);\n      }, 480 + Math.random()*360);\n    }, 1900);\n\n    // initial gentle entrance of bars: small stagger\n    nodes.forEach((n,i)=>{\n      n.node.style.opacity = '0';\n      n.node.style.transform = `translateX(${n.x}px) translateY(14px)`;\n      n.node.style.transition = `opacity 640ms ${60*i}ms cubic-bezier(.2,.9,.2,1), transform 640ms ${60*i}ms cubic-bezier(.2,.9,.2,1)`;\n      setTimeout(()=> {\n        n.node.style.opacity = '';\n        n.node.style.transform = `translateX(${n.x}px)`;\n      }, 20);\n      setTimeout(()=> { n.node.style.transition = ''; }, 980);\n    });\n\n  })();\n</script>\n</body>\n</html>"
  },
