    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Unit Testing Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .hidden { display: none; }\n        .output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Unit Testing Interactive Demo</h1>\n    \n    <div>\n        <h2>Run Unit Tests</h2>\n        <button onclick=\"runTests()\">Run Tests</button>\n        <div class=\"output\" id=\"testOutput\"></div>\n    </div>\n\n    <div>\n        <h2>Calculator Tests</h2>\n        <label for=\"calcInputA\">Input A: </label>\n        <input type=\"number\" id=\"calcInputA\"><br>\n        \n        <label for=\"calcInputB\">Input B: </label>\n        <input type=\"number\" id=\"calcInputB\"><br>\n        \n        <button onclick=\"testAddition()\">Test Addition</button>\n        <div class=\"output\" id=\"calcTestOutput\"></div>\n    </div>\n\n    <div>\n        <h2>Complex Functionality</h2>\n        <label for=\"multiplier\">Multiplier: </label>\n        <input type=\"number\" id=\"multiplier\" value=\"1\"><br>\n        \n        <label for=\"baseNumber\">Base Number: </label>\n        <input type=\"number\" id=\"baseNumber\" value=\"1\"><br>\n        \n        <button onclick=\"calculateProduct()\">Calculate Product</button>\n        <div class=\"output\" id=\"productOutput\"></div>\n    </div>\n\n    <script>\n        function runTests() {\n            const output = document.getElementById('testOutput');\n            output.innerHTML = '';\n            let result = \"All Tests Passed!\";\n            const tests = [testAddition];\n            tests.forEach(test => {\n                try {\n                    test();\n                } catch (error) {\n                    result = `Test Failed: ${error.message}`;\n                }\n            });\n            output.innerHTML = result;\n        }\n\n        function testAddition() {\n            const a = 2;\n            const b = 3;\n            const result = add(a, b);\n            if (result !== 5) {\n                throw new Error(`Expected 5 but got ${result}`);\n            }\n            console.log(\"Addition test passed\");\n        }\n\n        function add(x, y) {\n            return x + y;\n        }\n\n        function testAddition() {\n            const a = Number(document.getElementById('calcInputA').value);\n            const b = Number(document.getElementById('calcInputB').value);\n            const expected = add(a, b);\n            if (isNaN(expected)) {\n                document.getElementById('calcTestOutput').innerText = \"Please enter valid numbers.\";\n                return;\n            }\n            document.getElementById('calcTestOutput').innerText = `Result: ${expected}`;\n        }\n\n        function calculateProduct() {\n            const multiplier = Number(document.getElementById('multiplier').value);\n            const baseNumber = Number(document.getElementById('baseNumber').value);\n            const product = multiplier * baseNumber;\n            document.getElementById('productOutput').innerText = `Product: ${product}`;\n        }\n    </script>\n</body>\n</html>"
