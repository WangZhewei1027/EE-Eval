    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Branch & Bound — Visual Demo</title>\n\n  <!-- Elegant fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,500;0,700;1,700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071728;\n      --card: rgba(255,255,255,0.04);\n      --accent: #7de3d1;\n      --accent-2: #8a7dff;\n      --muted: rgba(255,255,255,0.12);\n      --glass: rgba(255,255,255,0.03);\n      --gold: #ffd166;\n      --danger: #ff6b6b;\n      --text: rgba(255,255,255,0.94);\n    }\n\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 800px at 10% 10%, rgba(122,100,255,0.08), transparent),\n                  radial-gradient(900px 600px at 85% 90%, rgba(125,227,209,0.06), transparent),\n                  linear-gradient(180deg,var(--bg1), var(--bg2));\n      color:var(--text);\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Subtle animated background particles */\n    .nebula {\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      opacity:0.9;\n      mix-blend-mode:screen;\n      filter:blur(20px) saturate(120%);\n      background:\n        radial-gradient(800px 500px at 10% 20%, rgba(138,125,255,0.12), transparent),\n        radial-gradient(900px 600px at 90% 80%, rgba(125,227,209,0.12), transparent);\n      transition:opacity .6s ease;\n    }\n\n    .stage {\n      position:absolute;\n      left:50%;\n      top:50%;\n      transform:translate(-50%,-50%);\n      width:min(1200px, 94vw);\n      height:min(700px, 88vh);\n      display:grid;\n      grid-template-columns: 1fr 360px;\n      gap:28px;\n      align-items:center;\n    }\n\n    .panel {\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      box-shadow: 0 8px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      padding:28px;\n      backdrop-filter: blur(8px) saturate(120%);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n\n    .visual.card {\n      position:relative;\n      min-height:520px;\n      overflow:visible;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    .controlbar {\n      display:flex;\n      align-items:center;\n      gap:12px;\n      margin-bottom:18px;\n    }\n\n    h1.title {\n      font-family: \"Playfair Display\", serif;\n      font-size:20px;\n      margin:0;\n      font-weight:700;\n      letter-spacing: -0.02em;\n      color:var(--text);\n    }\n    p.lead {\n      margin:8px 0 0 0;\n      color:rgba(255,255,255,0.72);\n      font-size:13px;\n    }\n\n    /* Buttons */\n    .buttons {\n      margin-top:18px;\n      display:flex;\n      gap:10px;\n    }\n\n    button.btn {\n      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      border: 1px solid rgba(255,255,255,0.06);\n      color:var(--text);\n      padding:10px 14px;\n      border-radius:10px;\n      font-weight:600;\n      cursor:pointer;\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n      transition:transform .18s ease, box-shadow .18s ease, background .2s;\n      user-select:none;\n    }\n    button.btn:active{ transform:translateY(1px) scale(.998); }\n    .btn.primary {\n      background: linear-gradient(90deg, rgba(138,125,255,0.18), rgba(125,227,209,0.12));\n      border: 1px solid rgba(255,255,255,0.06);\n      color: white;\n    }\n\n    .statusbar {\n      margin-top:14px;\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n\n    .stat {\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n    }\n    .stat .label {\n      font-size:12px;\n      color:rgba(255,255,255,0.56);\n    }\n    .stat .value {\n      font-size:18px;\n      font-weight:700;\n      color:var(--text);\n    }\n\n    /* Right explanation pane */\n    .info.card {\n      padding:26px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      height:520px;\n    }\n\n    .legend {\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n    }\n\n    .legend .item {\n      display:flex;\n      gap:12px;\n      align-items:center;\n      color:rgba(255,255,255,0.82);\n      font-size:13px;\n    }\n    .swatch {\n      width:14px;height:14px;border-radius:4px;\n      box-shadow: 0 3px 10px rgba(2,6,23,0.45), inset 0 1px 0 rgba(255,255,255,0.04);\n      flex:0 0 auto;\n    }\n\n    .swatch.best { background: linear-gradient(90deg,var(--gold), #ffea9a); }\n    .swatch.active { background: linear-gradient(90deg,var(--accent-2),var(--accent)); }\n    .swatch.pruned { background: linear-gradient(90deg, rgba(180,180,200,0.12), rgba(120,120,140,0.06)); border:1px solid rgba(255,255,255,0.02); opacity:0.9; }\n    .swatch.ub { background: linear-gradient(90deg,#8ad5c9,#b39fff); border-radius:999px; width:10px; height:10px; }\n\n    .explain {\n      color:rgba(255,255,255,0.75);\n      font-size:13px;\n      line-height:1.45;\n    }\n\n    .footer {\n      margin-top:auto;\n      font-size:12px;\n      color:rgba(255,255,255,0.44);\n    }\n\n    /* SVG tree styling */\n    svg.tree {\n      width:100%;\n      height:100%;\n      overflow:visible;\n    }\n\n    .edge {\n      stroke: rgba(255,255,255,0.08);\n      stroke-width:3;\n      fill:none;\n      stroke-linecap:round;\n      transition:stroke .18s ease, opacity .18s ease;\n      filter: drop-shadow(0 8px 18px rgba(9,13,40,0.6));\n    }\n    .edge.active {\n      stroke: url(#edgeGradient);\n      stroke-width:4.6;\n      opacity:1;\n    }\n    .edge.pruned {\n      stroke: rgba(255,255,255,0.04);\n      opacity:0.35;\n      stroke-dasharray:6 6;\n    }\n\n    .node {\n      cursor:default;\n      transition:transform .28s cubic-bezier(.22,.9,.36,1), opacity .28s ease;\n      transform-origin:center;\n    }\n    .node .bubble {\n      transition: r .22s ease, fill .22s ease, stroke .22s ease;\n      fill: linear-gradient(180deg,#fff,#000);\n      stroke: rgba(255,255,255,0.06);\n    }\n    .node circle {\n      cx:0;cy:0;r:30;\n      fill: var(--glass);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1;\n      transition: fill .22s ease, transform .22s ease, stroke .22s ease;\n      filter: drop-shadow(0 6px 18px rgba(2,6,23,0.5));\n    }\n\n    .node .ub {\n      font-size:11px;\n      fill:rgba(255,255,255,0.76);\n      font-weight:700;\n      text-anchor:middle;\n      transform:translateY(-22px);\n      opacity:0.95;\n    }\n    .node .val {\n      font-size:13px;\n      fill:rgba(255,255,255,0.9);\n      font-weight:800;\n      text-anchor:middle;\n      transform:translateY(6px);\n      opacity:0;\n      transition: opacity .22s ease;\n    }\n\n    .node.active {\n      transform:scale(1.08);\n    }\n    .node.explored circle{\n      fill: linear-gradient(90deg,var(--accent-2),var(--accent));\n      stroke: rgba(255,255,255,0.12);\n    }\n    .node.best circle{\n      fill: radial-gradient(circle at 30% 25%, #fff6d8 0%, #ffd166 10%, #ffb347 45%, #f09a30 80%);\n      stroke: rgba(255,160,30,0.16);\n      box-shadow:0 8px 20px rgba(240,154,48,0.24);\n      filter: drop-shadow(0 10px 30px rgba(255,170,50,0.12));\n    }\n\n    .node.pruned {\n      opacity:0.36;\n      transform:scale(.98);\n      pointer-events:none;\n    }\n    .node.pruned .val { opacity:0; }\n    .node.pruned .ub { opacity:0.42; }\n\n    .node .halo {\n      fill:none;\n      stroke: rgba(138,125,255,0.14);\n      stroke-width:10;\n      stroke-linecap:round;\n      opacity:0;\n      transition:opacity .25s ease;\n      filter: blur(6px);\n    }\n    .node.active .halo { opacity:1; stroke-width:12; }\n\n    .node .glow {\n      position:absolute;\n    }\n\n    /* Cross mark for pruned node */\n    .xline {\n      stroke: rgba(255,255,255,0.9);\n      stroke-width:2.6;\n      stroke-linecap:round;\n      stroke-linejoin:round;\n      stroke-dasharray: 40;\n      stroke-dashoffset: 40;\n      opacity:0.9;\n      transition: stroke-dashoffset .5s cubic-bezier(.2,.9,.24,1);\n    }\n    .xline.visible{ stroke-dashoffset:0; stroke: rgba(255,255,255,0.92); opacity:1; }\n\n    /* Header micro styles */\n    .meta {\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-bottom:8px;\n    }\n    .logo {\n      width:44px;height:44px;border-radius:10px;\n      background:linear-gradient(135deg,var(--accent-2),var(--accent));\n      display:flex;align-items:center;justify-content:center;\n      box-shadow: 0 8px 28px rgba(10,10,30,0.5);\n      color:white;font-weight:800;font-size:18px;\n    }\n\n    /* responsive tweaks */\n    @media (max-width:980px){\n      .stage { grid-template-columns: 1fr; width:94vw; height:92vh; gap:16px; }\n      .info.card { height:auto; }\n    }\n\n    /* small flourish: animated highlight at top */\n    .glint {\n      position:absolute;\n      inset:auto 0 0 0;\n      height:240px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n      pointer-events:none;\n      mix-blend-mode:overlay;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"nebula\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\" role=\"main\" aria-label=\"Branch and Bound demonstration\">\n    <div class=\"panel visual card\" style=\"display:flex;flex-direction:column;\">\n      <div class=\"meta\">\n        <div class=\"logo\">B&B</div>\n        <div>\n          <h1 class=\"title\">Branch & Bound — Live Illustration</h1>\n          <p class=\"lead\">A concise visual depiction of exploring a search tree, updating the incumbent solution, and pruning subtrees using upper bounds.</p>\n        </div>\n      </div>\n\n      <div style=\"display:flex;align-items:center;gap:18px;\">\n        <div style=\"flex:1;\">\n          <div class=\"controlbar\">\n            <div class=\"buttons\">\n              <button id=\"playBtn\" class=\"btn primary\" title=\"Play or pause the demo\">\n                ▶ Play\n              </button>\n              <button id=\"resetBtn\" class=\"btn\" title=\"Restart the demonstration\">\n                ⟲ Restart\n              </button>\n            </div>\n          </div>\n\n          <div class=\"statusbar\" style=\"margin-top:6px;\">\n            <div class=\"stat\">\n              <div class=\"label\">Current Incumbent</div>\n              <div id=\"incumbent\" class=\"value\">—</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"label\">Exploration</div>\n              <div id=\"stepLabel\" class=\"value\">Idle</div>\n            </div>\n            <div class=\"stat\" style=\"text-align:right;\">\n              <div class=\"label\">Nodes Visited</div>\n              <div id=\"visitedCount\" class=\"value\">0</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- SVG visualization -->\n      <div style=\"flex:1; display:flex; align-items:center; justify-content:center; padding:20px 10px;\">\n        <svg class=\"tree\" viewBox=\"0 0 1000 520\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"false\" role=\"img\">\n          <defs>\n            <linearGradient id=\"edgeGradient\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#8a7dff\" stop-opacity=\"0.96\"/>\n              <stop offset=\"1\" stop-color=\"#7de3d1\" stop-opacity=\"0.96\"/>\n            </linearGradient>\n\n            <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- Edges -->\n          <g id=\"edges\" transform=\"translate(0,0)\">\n            <path id=\"e-root-right\" class=\"edge\" d=\"M500 90 C620 160, 700 220, 700 320\"></path>\n            <path id=\"e-root-left\" class=\"edge\" d=\"M500 90 C380 160, 300 220, 300 320\"></path>\n\n            <path id=\"e-right-left\" class=\"edge\" d=\"M700 320 C650 360, 630 400, 610 440\"></path>\n            <path id=\"e-right-right\" class=\"edge\" d=\"M700 320 C750 360, 770 400, 790 440\"></path>\n\n            <path id=\"e-left-left\" class=\"edge\" d=\"M300 320 C250 360, 230 400, 210 440\"></path>\n            <path id=\"e-left-right\" class=\"edge\" d=\"M300 320 C350 360, 370 400, 390 440\"></path>\n          </g>\n\n          <!-- Nodes: positions created relative to central coords -->\n          <g id=\"nodes\" transform=\"translate(0,0)\">\n            <!-- root -->\n            <g id=\"node-root\" class=\"node\" transform=\"translate(500,90)\" data-id=\"root\" aria-label=\"Root node\">\n              <circle r=\"36\"></circle>\n              <circle class=\"halo\" r=\"64\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-22\">UB 80</text>\n              <text class=\"val\" x=\"0\" y=\"6\">—</text>\n            </g>\n\n            <!-- right child -->\n            <g id=\"node-right\" class=\"node\" transform=\"translate(700,320)\" data-id=\"right\">\n              <circle r=\"34\"></circle>\n              <circle class=\"halo\" r=\"58\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-22\">UB 80</text>\n              <text class=\"val\" x=\"0\" y=\"6\">—</text>\n            </g>\n\n            <!-- left child -->\n            <g id=\"node-left\" class=\"node\" transform=\"translate(300,320)\" data-id=\"left\">\n              <circle r=\"34\"></circle>\n              <circle class=\"halo\" r=\"58\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-22\">UB 60</text>\n              <text class=\"val\" x=\"0\" y=\"6\">—</text>\n            </g>\n\n            <!-- right-left leaf (B1) -->\n            <g id=\"node-right-left\" class=\"node\" transform=\"translate(610,440)\" data-id=\"b1\">\n              <circle r=\"28\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-20\">UB 75</text>\n              <text class=\"val\" x=\"0\" y=\"6\">75</text>\n            </g>\n\n            <!-- right-right leaf (B2) -->\n            <g id=\"node-right-right\" class=\"node\" transform=\"translate(790,440)\" data-id=\"b2\">\n              <circle r=\"28\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-20\">UB 65</text>\n              <text class=\"val\" x=\"0\" y=\"6\">62</text>\n            </g>\n\n            <!-- left-left leaf (A1) -->\n            <g id=\"node-left-left\" class=\"node\" transform=\"translate(210,440)\" data-id=\"a1\">\n              <circle r=\"28\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-20\">UB 50</text>\n              <text class=\"val\" x=\"0\" y=\"6\">45</text>\n            </g>\n\n            <!-- left-right leaf (A2) -->\n            <g id=\"node-left-right\" class=\"node\" transform=\"translate(390,440)\" data-id=\"a2\">\n              <circle r=\"28\"></circle>\n              <text class=\"ub\" x=\"0\" y=\"-20\">UB 60</text>\n              <text class=\"val\" x=\"0\" y=\"6\">60</text>\n            </g>\n          </g>\n\n          <!-- Cross lines inserted for pruned nodes (will animate) -->\n          <g id=\"xmarks\" transform=\"translate(0,0)\">\n            <line id=\"x-b1\" class=\"xline\" x1=\"594\" y1=\"426\" x2=\"626\" y2=\"454\" />\n            <line id=\"x-b1b\" class=\"xline\" x1=\"626\" y1=\"426\" x2=\"594\" y2=\"454\" />\n\n            <line id=\"x-b2\" class=\"xline\" x1=\"774\" y1=\"426\" x2=\"806\" y2=\"454\" />\n            <line id=\"x-b2b\" class=\"xline\" x1=\"806\" y1=\"426\" x2=\"774\" y2=\"454\" />\n\n            <line id=\"x-a1\" class=\"xline\" x1=\"194\" y1=\"426\" x2=\"226\" y2=\"454\" />\n            <line id=\"x-a1b\" class=\"xline\" x1=\"226\" y1=\"426\" x2=\"194\" y2=\"454\" />\n\n            <line id=\"x-a2\" class=\"xline\" x1=\"374\" y1=\"426\" x2=\"406\" y2=\"454\" />\n            <line id=\"x-a2b\" class=\"xline\" x1=\"406\" y1=\"426\" x2=\"374\" y2=\"454\" />\n          </g>\n\n        </svg>\n      </div>\n\n      <div class=\"glint\" style=\"opacity:0.06\"></div>\n    </div>\n\n    <aside class=\"panel info card\">\n      <div>\n        <h3 style=\"margin:0;font-weight:700;font-size:16px;\">How this demo works</h3>\n        <p class=\"explain\" style=\"margin-top:10px;\">\n          The visualization performs a depth-first exploration of a small search tree. Each node shows an upper bound (UB)\n          — an optimistic estimate of the best value attainable below that node. When we find a solution (a leaf) with a value\n          exceeding the current incumbent, we update the incumbent. Any subtree whose UB is not better than the incumbent can be\n          safely pruned (skipped), saving exploration time.\n        </p>\n      </div>\n\n      <div class=\"legend\" aria-hidden=\"true\">\n        <div class=\"item\"><div class=\"swatch active\"></div> Active node being expanded</div>\n        <div class=\"item\"><div class=\"swatch best\"></div> Incumbent / Best found solution</div>\n        <div class=\"item\"><div class=\"swatch pruned\"></div> Pruned subtree (skipped)</div>\n        <div class=\"item\"><div class=\"swatch ub\"></div> Upper Bound estimate</div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <strong style=\"display:block;margin-bottom:8px;\">Steps shown</strong>\n        <ol style=\"padding-left:18px;color:rgba(255,255,255,0.78);\">\n          <li style=\"margin-bottom:6px;\">Explore right subtree first — find a strong solution.</li>\n          <li style=\"margin-bottom:6px;\">Update incumbent to best leaf found.</li>\n          <li style=\"margin-bottom:6px;\">Backtrack — prune the left subtree because its UB ≤ incumbent.</li>\n        </ol>\n      </div>\n\n      <div class=\"footer\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n          <div>Elegant demo • Branch & Bound</div>\n          <div>Minimal controls • Pure observation</div>\n        </div>\n      </div>\n    </aside>\n  </div>\n\n  <script>\n    (function(){\n      // Elements\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const incumbentEl = document.getElementById('incumbent');\n      const stepLabel = document.getElementById('stepLabel');\n      const visitedCountEl = document.getElementById('visitedCount');\n\n      const nodes = {\n        root: document.getElementById('node-root'),\n        left: document.getElementById('node-left'),\n        right: document.getElementById('node-right'),\n        b1: document.getElementById('node-right-left'),\n        b2: document.getElementById('node-right-right'),\n        a1: document.getElementById('node-left-left'),\n        a2: document.getElementById('node-left-right')\n      };\n\n      const edges = {\n        'root-right': document.getElementById('e-root-right'),\n        'root-left': document.getElementById('e-root-left'),\n        'right-left': document.getElementById('e-right-left'),\n        'right-right': document.getElementById('e-right-right'),\n        'left-left': document.getElementById('e-left-left'),\n        'left-right': document.getElementById('e-left-right')\n      };\n\n      const xmarks = {\n        b1: [document.getElementById('x-b1'), document.getElementById('x-b1b')],\n        b2: [document.getElementById('x-b2'), document.getElementById('x-b2b')],\n        a1: [document.getElementById('x-a1'), document.getElementById('x-a1b')],\n        a2: [document.getElementById('x-a2'), document.getElementById('x-a2b')]\n      };\n\n      let state = {\n        running: false,\n        timer: null,\n        step: 0,\n        visited: 0,\n        incumbent: -Infinity\n      };\n\n      // Predefined tree data\n      const tree = {\n        id: 'root',\n        ub: 80,\n        left: {\n          id: 'left',\n          ub: 60,\n          left: { id:'a1', ub:50, leaf:true, value:45 },\n          right:{ id:'a2', ub:60, leaf:true, value:60 }\n        },\n        right:{\n          id: 'right',\n          ub: 80,\n          left: { id:'b1', ub:75, leaf:true, value:75 },\n          right:{ id:'b2', ub:65, leaf:true, value:62 }\n        }\n      };\n\n      // Steps queued to animate deterministic DFS (right-first) and pruning\n      // Sequence:\n      // 1 root active\n      // 2 explore right child\n      // 3 explore b1 (leaf) evaluate 75 -> incumbent=75\n      // 4 explore b2 evaluate 62 (no update)\n      // 5 back to root, check left.ub <= incumbent -> prune left subtree (a1,a2,left)\n      // 6 highlight best and finish\n      let steps = [];\n\n      function composeSteps(){\n        steps = [\n          { action: 'highlight', node: 'root', label: 'Start at root' },\n          { action: 'edgeOn', edge: 'root-right' },\n          { action: 'highlight', node: 'right', label: 'Branch to right child' },\n          { action: 'edgeOn', edge: 'right-left' },\n          { action: 'highlight', node: 'b1', label: 'Evaluate leaf B1' },\n          { action: 'visitLeaf', node: 'b1' },\n          { action: 'edgeOff', edge: 'right-left' },\n\n          { action: 'edgeOn', edge: 'right-right' },\n          { action: 'highlight', node: 'b2', label: 'Evaluate leaf B2' },\n          { action: 'visitLeaf', node: 'b2' },\n          { action: 'edgeOff', edge: 'right-right' },\n\n          { action: 'edgeOff', edge: 'root-right' },\n          { action: 'highlight', node: 'right', label: 'Finished right subtree' },\n\n          // Check left.ub <= incumbent -> prune\n          { action: 'checkPrune', node: 'left', label: 'Left UB ≤ incumbent → prune left subtree' },\n\n          { action: 'pruneNode', node: 'a1' },\n          { action: 'pruneNode', node: 'a2' },\n          { action: 'pruneNode', node: 'left' },\n\n          { action: 'finalize', node: 'b1', label: 'Best solution found' }\n        ];\n      }\n\n      function resetVisuals(){\n        // Clear classes\n        Object.values(nodes).forEach(n => {\n          n.classList.remove('active','explored','pruned','best');\n          const val = n.querySelector('.val');\n          if (val) val.style.opacity = '0';\n        });\n        Object.values(edges).forEach(e => {\n          e.classList.remove('active','pruned');\n        });\n        Object.values(xmarks).forEach(arr => arr.forEach(x => x.classList.remove('visible')));\n        state.visited = 0;\n        state.incumbent = -Infinity;\n        incumbentEl.textContent = \"—\";\n        visitedCountEl.textContent = \"0\";\n        stepLabel.textContent = \"Idle\";\n        // Reset play button text\n        playBtn.innerText = '▶ Play';\n        state.step = 0;\n        clearTimer();\n      }\n\n      function start(){\n        if (state.running) return;\n        state.running = true;\n        playBtn.innerText = '⏸ Pause';\n        if (state.step >= steps.length) {\n          // restart from beginning if finished\n          resetVisuals();\n          composeSteps();\n        }\n        scheduleNext();\n      }\n\n      function pause(){\n        state.running = false;\n        playBtn.innerText = '▶ Play';\n        clearTimer();\n      }\n\n      function clearTimer(){\n        if (state.timer) { clearTimeout(state.timer); state.timer = null; }\n      }\n\n      function scheduleNext(){\n        if (!state.running) return;\n        if (state.step >= steps.length) {\n          // finished\n          state.running = false;\n          playBtn.innerText = '▶ Play';\n          stepLabel.textContent = 'Complete';\n          return;\n        }\n        const s = steps[state.step];\n        // timing: more importance on leaf visits\n        const baseDelay = 850;\n        const leafDelay = 1100;\n        const pruneDelay = 700;\n        let delay = baseDelay;\n        if (s.action === 'visitLeaf') delay = leafDelay;\n        if (s.action === 'pruneNode') delay = pruneDelay;\n        if (s.action === 'finalize') delay = 1200;\n\n        runStep(s);\n        state.step++;\n        state.timer = setTimeout(scheduleNext, delay);\n      }\n\n      // Utility to set node active\n      function setActive(nodeId){\n        // clear previous active\n        Object.values(nodes).forEach(n => n.classList.remove('active'));\n        const node = nodes[nodeId];\n        if (node) node.classList.add('active');\n      }\n\n      function runStep(s){\n        stepLabel.textContent = s.label || '';\n        switch(s.action){\n          case 'highlight':\n            setActive(s.node);\n            pulseEdgeIfExists(s.node);\n            break;\n          case 'edgeOn':\n            if (edges[s.edge]) edges[s.edge].classList.add('active');\n            break;\n          case 'edgeOff':\n            if (edges[s.edge]) edges[s.edge].classList.remove('active');\n            break;\n          case 'visitLeaf':\n            visitLeaf(s.node);\n            break;\n          case 'checkPrune':\n            // show small pulse on left node and its UB\n            setActive(s.node);\n            // small highlight then decision handled by prune steps\n            break;\n          case 'pruneNode':\n            pruneNode(s.node);\n            break;\n          case 'finalize':\n            finalizeBest(s.node);\n            break;\n        }\n      }\n\n      function pulseEdgeIfExists(nodeId){\n        // light up edge leading to node (if any)\n        // mapping: b1 & b2 -> edges starting from their parents\n        // We'll handle minimal mapping\n        if (nodeId === 'right') edges['root-right'].classList.add('active');\n        if (nodeId === 'left') edges['root-left'].classList.add('active');\n      }\n\n      function visitLeaf(nodeId){\n        const n = nodes[nodeId];\n        if (!n) return;\n        // show value text\n        const valTxt = n.querySelector('.val');\n        if (valTxt) {\n          valTxt.style.opacity = '1';\n        }\n        // mark explored\n        n.classList.add('explored','active');\n        // Simulate reading leaf value from text content\n        const v = parseFloat((valTxt && valTxt.textContent) || '0') || 0;\n        state.visited++;\n        visitedCountEl.textContent = state.visited;\n        // update incumbent if better\n        if (v > state.incumbent) {\n          state.incumbent = v;\n          incumbentEl.textContent = v;\n          // visually mark previous best cleared and new best\n          // remove previous best class\n          Object.values(nodes).forEach(nd => nd.classList.remove('best'));\n          n.classList.add('best');\n        }\n        // tiny glow on node\n        setTimeout(()=>{ n.classList.remove('active'); }, 600);\n      }\n\n      function pruneNode(nodeId){\n        // find node and its group to fade and draw X\n        const n = nodes[nodeId];\n        if (!n) return;\n        n.classList.add('pruned');\n        // dim edges connecting to this subtree\n        // map names to edges for simple demonstration\n        if (nodeId === 'a1') edges['left-left'] && edges['left-left'].classList.add('pruned');\n        if (nodeId === 'a2') edges['left-right'] && edges['left-right'].classList.add('pruned');\n        if (nodeId === 'left') edges['root-left'] && edges['root-left'].classList.add('pruned');\n        if (nodeId === 'b1') edges['right-left'] && edges['right-left'].classList.add('pruned');\n        if (nodeId === 'b2') edges['right-right'] && edges['right-right'].classList.add('pruned');\n\n        // show X-lines\n        const arr = xmarks[nodeId];\n        if (arr) {\n          arr.forEach(x => {\n            // animate stroke-dashoffset\n            x.classList.add('visible');\n          });\n        }\n      }\n\n      function finalizeBest(nodeId){\n        // emphasize best node with golden halo and slight scale\n        const n = nodes[nodeId];\n        if (!n) return;\n        n.classList.add('best');\n        Object.values(nodes).forEach(nd => nd.classList.remove('active'));\n        stepLabel.textContent = 'Completed — solution selected';\n      }\n\n      // Wire buttons\n      playBtn.addEventListener('click', ()=>{\n        if (!state.running) start();\n        else pause();\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        pause();\n        resetVisuals();\n        composeSteps();\n      });\n\n      // Initialize\n      composeSteps();\n      resetVisuals();\n\n      // Start paused and let user play\n      // But for immediate polish, do a subtle intro animation\n      window.addEventListener('load', ()=>{\n        // small intro: lightly pulse root then return to idle\n        const root = nodes.root;\n        root.classList.add('active');\n        setTimeout(()=>root.classList.remove('active'), 900);\n      });\n\n      // Accessibility: keyboard shortcuts (space to play/pause, R to reset)\n      window.addEventListener('keydown', (e)=>{\n        if (e.code === 'Space') { e.preventDefault(); playBtn.click(); }\n        if (e.key.toLowerCase() === 'r') { resetBtn.click(); }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
