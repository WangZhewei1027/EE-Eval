    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linked List Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Root variables for easy theming */\n  :root {\n    --bg-dark: #0f172a;\n    --bg-gradient-start: #0f172a;\n    --bg-gradient-end: #1e293b;\n    --node-bg: #2563eb;\n    --node-border: #3b82f6;\n    --node-shadow: rgba(37, 99, 235, 0.65);\n    --pointer-color: #facc15;\n    --text-primary: #e0e7ff;\n    --text-secondary: #93c5fd;\n    --font-family: 'Poppins', sans-serif;\n    --btn-bg: #3b82f6;\n    --btn-bg-hover: #2563eb;\n    --btn-text: #f0f9ff;\n  }\n\n  /* Reset and base styles */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));\n    font-family: var(--font-family);\n    color: var(--text-primary);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 3rem;\n    user-select: none;\n  }\n\n  main {\n    max-width: 900px;\n    width: 100%;\n    text-align: center;\n  }\n\n  header {\n    margin-bottom: 3rem;\n    letter-spacing: 0.15em;\n  }\n\n  header h1 {\n    font-weight: 600;\n    font-size: 3.6rem;\n    line-height: 1.1;\n    color: var(--text-primary);\n    filter: drop-shadow(0 0 8px #60a5fa88);\n  }\n\n  header p {\n    margin-top: 0.6rem;\n    font-weight: 300;\n    font-size: 1.15rem;\n    color: var(--text-secondary);\n    font-style: italic;\n  }\n\n  /* Linked list container */\n  .linked-list {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 4rem;\n    padding: 1rem 0;\n  }\n\n  /* Node container with relative to position arrows */\n  .node {\n    background: linear-gradient(145deg, #1a40d8, #345ed9);\n    border-radius: 1.25rem;\n    box-shadow:\n      0 5px 15px var(--node-shadow),\n      inset 0 0 10px #60a5faaa;\n    width: 130px;\n    height: 130px;\n    filter: drop-shadow(0 0 12px #60a5faf2);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    position: relative;\n    transition: transform 0.4s ease;\n  }\n\n  .node:hover {\n    transform: scale(1.1);\n    box-shadow:\n      0 8px 25px var(--node-shadow),\n      inset 0 0 18px #93c5fdcc;\n  }\n\n  .node .label {\n    font-weight: 600;\n    color: #dbeafe;\n    font-size: 1.1rem;\n    user-select: none;\n    margin-bottom: 0.6rem;\n    letter-spacing: 0.05em;\n    text-shadow: 0 0 4px #bfdbfeaa;\n  }\n\n  .node .value {\n    font-family: 'Courier New', Courier, monospace;\n    font-size: 2.7rem;\n    color: #bfdbfe;\n    font-weight: 700;\n    text-shadow:\n      0 0 4px #93c5fddd,\n      0 0 12px #60a5faee;\n  }\n\n  /* Special null node styling */\n  .node.null-node {\n    background: linear-gradient(145deg, #6b7280, #4b5563);\n    box-shadow:\n      0 5px 15px rgba(75, 85, 99, 0.7),\n      inset 0 0 10px #9ca3afaa;\n  }\n\n  .node.null-node .value {\n    font-size: 1.6rem;\n    font-weight: 600;\n    color: #cbd5e1;\n    user-select: none;\n    text-shadow: none;\n  }\n\n  /* Arrow style */\n  .arrow {\n    position: absolute;\n    top: 50%;\n    right: -90px;\n    width: 80px;\n    height: 12px;\n    display: flex;\n    align-items: center;\n    transform: translateY(-50%);\n    filter: drop-shadow(0 0 5px var(--pointer-color));\n  }\n\n  .arrow line {\n    stroke: var(--pointer-color);\n    stroke-width: 3;\n    stroke-linecap: round;\n    stroke-dasharray: 140;\n    stroke-dashoffset: 140;\n    animation: dash 1.6s forwards ease-in-out;\n  }\n  .arrow polygon {\n    fill: var(--pointer-color);\n    opacity: 0;\n    animation: fadeInArrow 0.5s forwards ease-in-out;\n    animation-delay: 1.6s;\n  }\n  .arrow.delay-1 line {\n    animation-delay: 0.3s;\n  }\n  .arrow.delay-2 line {\n    animation-delay: 0.6s;\n  }\n  .arrow.delay-3 line {\n    animation-delay: 0.9s;\n  }\n\n  @keyframes dash {\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n  @keyframes fadeInArrow {\n    to {\n      opacity: 1;\n    }\n  }\n\n  /* Controls */\n  .controls {\n    margin-top: 4rem;\n  }\n\n  button {\n    cursor: pointer;\n    background: var(--btn-bg);\n    border: none;\n    padding: 0.9rem 2rem;\n    border-radius: 9999px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: var(--btn-text);\n    box-shadow:\n      0 4px 14px #2563ebcc;\n    transition: all 0.3s ease;\n    user-select: none;\n    letter-spacing: 0.05em;\n  }\n  button:focus {\n    outline: 3px solid #fde68a;\n    outline-offset: 4px;\n  }\n  button:hover {\n    background: var(--btn-bg-hover);\n    box-shadow:\n      0 6px 20px #1d4ed8cc;\n  }\n  button:active {\n    transform: scale(0.97);\n  }\n\n  /* Subtle fade transition on value changes */\n  .node .value {\n    transition: color 0.6s ease, text-shadow 0.6s ease;\n  }\n\n  /* Footer info */\n  footer {\n    margin-top: 6rem;\n    font-size: 0.875rem;\n    color: var(--text-secondary);\n    opacity: 0.6;\n    font-weight: 300;\n    letter-spacing: 0.09em;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n<main role=\"main\" aria-label=\"Linked List Visualization\">\n  <header>\n    <h1>Linked List</h1>\n    <p>Sequential nodes linked by pointers</p>\n  </header>\n\n  <section class=\"linked-list\" aria-label=\"Linked list diagram\">\n    <!-- Node 1 -->\n    <div class=\"node\" id=\"node-0\" aria-label=\"Node 1\">\n      <div class=\"label\">Node</div>\n      <div class=\"value\" aria-live=\"polite\" aria-atomic=\"true\">10</div>\n      <svg class=\"arrow delay-1\" aria-hidden=\"true\" width=\"80\" height=\"12\" viewBox=\"0 0 80 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <line x1=\"2\" y1=\"6\" x2=\"78\" y2=\"6\" />\n        <polygon points=\"65,2 78,6 65,10\" />\n      </svg>\n    </div>\n\n    <!-- Node 2 -->\n    <div class=\"node\" id=\"node-1\" aria-label=\"Node 2\">\n      <div class=\"label\">Node</div>\n      <div class=\"value\" aria-live=\"polite\" aria-atomic=\"true\">23</div>\n      <svg class=\"arrow delay-2\" aria-hidden=\"true\" width=\"80\" height=\"12\" viewBox=\"0 0 80 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <line x1=\"2\" y1=\"6\" x2=\"78\" y2=\"6\" />\n        <polygon points=\"65,2 78,6 65,10\" />\n      </svg>\n    </div>\n\n    <!-- Node 3 -->\n    <div class=\"node\" id=\"node-2\" aria-label=\"Node 3\">\n      <div class=\"label\">Node</div>\n      <div class=\"value\" aria-live=\"polite\" aria-atomic=\"true\">35</div>\n      <svg class=\"arrow delay-3\" aria-hidden=\"true\" width=\"80\" height=\"12\" viewBox=\"0 0 80 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <line x1=\"2\" y1=\"6\" x2=\"78\" y2=\"6\" />\n        <polygon points=\"65,2 78,6 65,10\" />\n      </svg>\n    </div>\n\n    <!-- Null Node -->\n    <div class=\"node null-node\" aria-label=\"Null pointer (end)\">\n      <div class=\"label\">NULL</div>\n      <div class=\"value\" aria-hidden=\"true\">∅</div>\n    </div>\n  </section>\n\n  <div class=\"controls\" aria-label=\"Linked list controls\">\n    <button id=\"btn-change\" aria-pressed=\"false\">Change Values</button>\n  </div>\n\n  <footer>\n    &copy; 2024 &nbsp;&bull;&nbsp; Visual Learning\n  </footer>\n</main>\n\n<script>\n  (() => {\n    const valuesSets = [\n      [10, 23, 35],\n      [7, 14, 21],\n      [19, 42, 58],\n      [5, 11, 18],\n    ];\n    let currentIndex = 0;\n\n    const btn = document.getElementById('btn-change');\n    const nodes = [\n      document.querySelector('#node-0 .value'),\n      document.querySelector('#node-1 .value'),\n      document.querySelector('#node-2 .value'),\n    ];\n\n    btn.addEventListener('click', () => {\n      // Cycle to next values set\n      currentIndex = (currentIndex + 1) % valuesSets.length;\n      const newValues = valuesSets[currentIndex];\n\n      nodes.forEach((nodeValueEl, i) => {\n        // Animate color pulse for update\n        nodeValueEl.style.color = 'var(--pointer-color)';\n        nodeValueEl.style.textShadow = '0 0 10px var(--pointer-color)';\n        setTimeout(() => {\n          nodeValueEl.textContent = newValues[i];\n          // Return to normal styles smoothly\n          nodeValueEl.style.color = '';\n          nodeValueEl.style.textShadow = '';\n        }, 300);\n      });\n\n      // Toggle aria-pressed for accessibility\n      const pressedState = btn.getAttribute('aria-pressed') === 'true';\n      btn.setAttribute('aria-pressed', String(!pressedState));\n    });\n  })();\n</script>\n</body>\n</html>"
