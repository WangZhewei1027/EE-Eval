    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interpolation Search</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #f0f0f0;\n        }\n        \n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .header {\n            background-color: #333;\n            color: #fff;\n            padding: 10px;\n            text-align: center;\n        }\n        \n        .header h1 {\n            font-size: 24px;\n            margin-bottom: 10px;\n        }\n        \n        .footer {\n            background-color: #333;\n            color: #fff;\n            padding: 10px;\n            text-align: center;\n            clear: both;\n        }\n        \n        .footer p {\n            margin-bottom: 20px;\n        }\n        \n        .search-bar {\n            width: 100%;\n            padding: 10px;\n            font-size: 18px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);\n        }\n        \n        .search-bar input {\n            width: 100%;\n            padding: 10px;\n            font-size: 18px;\n            border: none;\n            border-radius: 5px 0 0 5px;\n            background-color: #f0f0f0;\n        }\n        \n        .search-results {\n            padding: 20px;\n            font-size: 16px;\n            font-family: Arial, sans-serif;\n        }\n        \n        .search-results p {\n            margin-bottom: 10px;\n        }\n        \n        .search-results button {\n            width: 100%;\n            padding: 10px 20px;\n            font-size: 16px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        \n        .search-results button:hover {\n            background-color: #3e8e41;\n        }\n        \n        .search-results button:disabled {\n            opacity: 0.5;\n            cursor: not-allowed;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Interpolation Search</h1>\n        </div>\n        <div class=\"search-bar\">\n            <input type=\"search\" id=\"search-input\" placeholder=\"Search...\">\n            <button id=\"search-button\">Search</button>\n        </div>\n        <div class=\"search-results\">\n            <p id=\"search-results\"></p>\n        </div>\n    </div>\n    <script>\n        let results = [];\n        \n        function interpolationSearch(arr, x) {\n            let lo = 0, hi = arr.length - 1;\n            \n            while (lo <= hi && x >= arr[lo] && x <= arr[hi]) {\n                let i = lo + ((x - arr[lo]) * (hi - lo)) / (arr[hi] - arr[lo]);\n                if (arr[i] === x) return i;\n                if (arr[i] < x) lo = i + 1;\n                else hi = i - 1;\n            }\n            return -1;\n        }\n        \n        function search(arr, x) {\n            let result = interpolationSearch(arr, x);\n            if (result !== -1) {\n                document.getElementById(\"search-results\").innerHTML = \"Result: \" + arr[result] + \" (Index: \" + result + \")\";\n            } else {\n                document.getElementById(\"search-results\").innerHTML = \"No result found.\";\n            }\n        }\n        \n        document.getElementById(\"search-button\").addEventListener(\"click\", function() {\n            let input = document.getElementById(\"search-input\").value;\n            search([1