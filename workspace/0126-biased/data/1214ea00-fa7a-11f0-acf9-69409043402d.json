  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Greedy Algorithms Interactive Demonstration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n    font-family: monospace, monospace;\n    font-size: 1rem;\n  }\n  input[type=\"number\"] {\n    width: 5em;\n  }\n  button {\n    margin: 0 0.3em 0.5em 0;\n  }\n  .section {\n    margin-bottom: 1.5em;\n  }\n  label {\n    user-select:none;\n  }\n  select {\n    font-family: monospace, monospace;\n  }\n  #log {\n    white-space: pre-wrap;\n    max-height: 12em;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 0.5em;\n    font-size: 0.9rem;\n  }\n  table {\n    border-collapse: collapse;\n    margin: 0.5em 0;\n  }\n  td, th {\n    border: 1px solid black;\n    padding: 0.2em 0.5em;\n    text-align: right;\n    font-family: monospace, monospace;\n    font-size: 0.85rem;\n  }\n</style>\n</head>\n<body>\n<h1>Greedy Algorithms Interactive Demonstration</h1>\n<p>\n  This tool allows you to explore greedy algorithms interactively. Choose from multiple problem types, input data, step through algorithms, compare greedy vs non-greedy solutions, and tweak problem parameters. Use controls below to deeply explore greedy algorithms concepts.\n</p>\n\n<div class=\"section\">\n  <label for=\"problem-select\"><b>Select problem:</b></label>\n  <select id=\"problem-select\" aria-label=\"Select Greedy Problem\">\n    <option value=\"coinChange\">Coin Change (Min Coins)</option>\n    <option value=\"activitySelection\">Activity Selection (Interval Scheduling)</option>\n    <option value=\"fractionalKnapsack\">Fractional Knapsack</option>\n    <option value=\"huffmanCoding\">Huffman Coding (Symbol Frequencies)</option>\n  </select>\n  <button id=\"reset-problem\">Reset / Load Problem</button>\n</div>\n\n<div id=\"problem-inputs\" class=\"section\" aria-live=\"polite\" aria-atomic=\"true\">\n  <!-- Dynamic inputs appear here -->\n</div>\n\n<div id=\"algorithm-controls\" class=\"section\" style=\"display:none;\">\n  <button id=\"step-btn\" title=\"Run one step of the greedy algorithm\">Step</button>\n  <button id=\"run-btn\" title=\"Run to completion\">Run to End</button>\n  <button id=\"undo-btn\" title=\"Undo last step\">Undo Step</button>\n  <button id=\"reset-algo-btn\" title=\"Reset algorithm state\">Reset Algorithm</button>\n</div>\n\n<div id=\"output\" class=\"section\" aria-live=\"polite\" aria-atomic=\"true\" style=\"white-space:pre-wrap; max-height: 12em; overflow-y:auto; border: 1px solid black; padding: 0.5em;\"></div>\n\n<div class=\"section\">\n  <h2>Exploration Controls</h2>\n  <button id=\"compare-btn\" title=\"Compare greedy solution vs brute force/exhaustive\">Compare Greedy vs Exhaustive</button>\n  <button id=\"randomize-btn\" title=\"Randomize problem inputs\">Randomize Inputs</button>\n  <button id=\"export-btn\" title=\"Export current problem & solution as JSON\">Export Problem & Solution</button>\n  <button id=\"import-btn\" title=\"Import problem JSON (prompt)\">Import Problem</button>\n</div>\n\n<div class=\"section\">\n  <h2>Log / Algorithm Trace</h2>\n  <div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n</div>\n\n<script>\n//====================\n// Data and state setup\n//====================\n\nconst problems = {\n  // coin change: given coin denominations and amount, find minimum coins (greedy picks largest coins first)\n  coinChange: {\n    description: `Given coin denominations and a target amount, the Greedy strategy picks the largest coin denomination not exceeding the remaining amount until the amount is zero. Works optimally for canonical coin systems (e.g. US coins).`,\n    inputs: [\n      {id:'coins', label:'Coins (comma-separated integers)', default:'1,5,10,25'},\n      {id:'amount', label:'Amount (integer)', default:'63'}\n    ],\n    state: {\n      coins: [],\n      amount: 0,\n      remaining: 0,\n      solution: null,\n      currentStep: 0,\n      chosenCoins: []\n    }\n  },\n\n  // activity selection: select max number of non-overlapping intervals - greedy picks earliest finishing activities\n  activitySelection: {\n    description: `Given a set of activities with start and finish times, Greedy picks activities in order of earliest finish time that do not overlap with already selected ones.`,\n    inputs: [\n      {id:'activities', label:'Activities (start,end) one per line', default:'1,4\\n3,5\\n0,6\\n5,7\\n3,9\\n5,9\\n6,10\\n8,11\\n8,12\\n2,14\\n12,16'}\n    ],\n    state: {\n      activities: [],\n      selected: [],\n      sorted: [],\n      currentStep: 0,\n      lastFinishTime: 0\n    }\n  },\n\n  // fractional knapsack: pick fractions of items with value/weight ratio greedily for max value weight limit\n  fractionalKnapsack: {\n    description: `Given items with weights and values, the greedy picks fractions of items sorted by value/weight ratio to maximize value with total weight limit.`,\n    inputs: [\n      {id:'capacity', label:'Capacity (integer)', default:'50'},\n      {id:'items', label:'Items (value,weight) one per line', default:'60,10\\n100,20\\n120,30'}\n    ],\n    state: {\n      capacity: 0,\n      items: [],\n      chosen: [],\n      currentWeight: 0,\n      totalValue: 0,\n      currentStep: 0,\n      sortedItems: []\n    }\n  },\n\n  // huffman coding: build optimal prefix code via greedy combining lowest freq nodes stepwise\n  huffmanCoding: {\n    description: `Given symbol frequencies, Greedy merges two least frequent trees repeatedly to build a prefix-free code minimizing weighted path length.`,\n    inputs: [\n      {id:'symbols', label:'Symbols and frequencies (symbol,frequency) one per line', default:'a,45\\nb,13\\nc,12\\nd,16\\ne,9\\nf,5'}\n    ],\n    state: {\n      nodes: [],\n      forest: [],\n      steps: [],\n      codes: {},\n      currentStep: 0\n    }\n  }\n};\n\n//==================\n// Global variables\n//==================\n\nlet currentProblemKey = 'coinChange';\nlet currentProblem = problems[currentProblemKey];\nlet currentState = null; // deep clone of problem.state\nlet logElement = null;\nlet outputElement = null;\nlet inputsContainer = null;\nlet algoControls = null;\n\nconst MAX_UNDO_HISTORY = 100;\nlet undoHistory = [];\nfunction cloneDeep(obj) { return JSON.parse(JSON.stringify(obj)); }\n\n//======================\n// Utility parsing helpers\n//======================\n\nfunction parseIntegersCommaSeparated(str) {\n  return str.split(',').map(x=>parseInt(x.trim())).filter(x => !isNaN(x));\n}\n\nfunction parsePairsEachLine(str) {\n  // example: \"1,4\\n3,5\\n0,6\" -> [{start:1,end:4}, ...]\n  return str.trim().split('\\n').map(line => {\n    let parts = line.split(',').map(x => x.trim());\n    if(parts.length>=2){\n      let a = parseInt(parts[0]);\n      let b = parseInt(parts[1]);\n      if(isNaN(a)||isNaN(b)) return null;\n      return {start:a,end:b};\n    }\n    return null;\n  }).filter(x=>x!==null);\n}\n\nfunction parseValueWeightPairs(str) {\n  return str.trim().split('\\n').map(line => {\n    let parts = line.split(',').map(x=>x.trim());\n    if(parts.length>=2){\n      let v = parseFloat(parts[0]);\n      let w = parseFloat(parts[1]);\n      if(isNaN(v)||isNaN(w)||w<=0) return null;\n      return {value:v, weight:w};\n    }\n    return null;\n  }).filter(x => x!==null);\n}\n\nfunction parseSymbolsFreq(str) {\n  return str.trim().split('\\n').map(line => {\n    let parts = line.split(',').map(x=>x.trim());\n    if(parts.length>=2){\n      let sym = parts[0];\n      let freq = parseInt(parts[1]);\n      if(!sym || isNaN(freq) || freq<=0) return null;\n      return {symbol:sym, freq:freq};\n    }\n    return null;\n  }).filter(x=>x!==null);\n}\n\n//================\n// UI Generators\n//================\n\nfunction createInputField(inputCfg){\n  let wrapper = document.createElement('div');\n  let label = document.createElement('label');\n  label.htmlFor = 'input-'+inputCfg.id;\n  label.textContent = inputCfg.label + ': ';\n  let input;\n  if(inputCfg.id==='amount' || inputCfg.id==='capacity'){\n    input = document.createElement('input');\n    input.type = 'number';\n    input.min = '0';\n    input.step = '1';\n    input.value = inputCfg.default || '';\n  } else {\n    let textarea = document.createElement('textarea');\n    textarea.id = 'input-'+inputCfg.id;\n    textarea.value = inputCfg.default || '';\n    input = textarea;\n  }\n  input.id = 'input-'+inputCfg.id;\n  wrapper.appendChild(label);\n  wrapper.appendChild(input);\n  return wrapper;\n}\n\nfunction clearChildren(elem) {\n  while (elem.firstChild) {\n    elem.removeChild(elem.firstChild);\n  }\n}\n\n//=============\n// Logging\n//=============\n\nfunction log(msg) {\n  if(!logElement) return;\n  logElement.textContent += msg + '\\n';\n  logElement.scrollTop = logElement.scrollHeight;\n}\nfunction logClear() {\n  if(!logElement) return;\n  logElement.textContent = '';\n}\n\n//=======================\n// Problem initialization\n//=======================\n\nfunction loadProblemInputs(problemKey){\n  currentProblemKey = problemKey;\n  currentProblem = problems[problemKey];\n  clearChildren(inputsContainer);\n  let descPara = document.createElement('p');\n  descPara.textContent = currentProblem.description;\n  inputsContainer.appendChild(descPara);\n  currentProblem.inputs.forEach(inpCfg => {\n    inputsContainer.appendChild(createInputField(inpCfg));\n  });\n  document.getElementById('algorithm-controls').style.display = 'none';\n  outputElement.textContent = '';\n  logClear();\n  undoHistory = [];\n}\n\nfunction readInputsValidate(){\n  // parse user inputs and update currentState\n  try {\n    let newState = cloneDeep(currentProblem.state);\n    if(currentProblemKey==='coinChange'){\n      let coinsStr = document.getElementById('input-coins').value;\n      let amountStr = document.getElementById('input-amount').value;\n      let coinsArr = parseIntegersCommaSeparated(coinsStr);\n      if(coinsArr.length===0) throw 'Coins input invalid or empty';\n      coinsArr.sort((a,b)=>b-a); // descending order for greedy\n      newState.coins = coinsArr;\n      let amountVal = parseInt(amountStr);\n      if(isNaN(amountVal) || amountVal <= 0) throw 'Amount must be positive integer';\n      newState.amount = amountVal;\n      newState.remaining = amountVal;\n      newState.chosenCoins = [];\n      newState.currentStep=0;\n    } else if(currentProblemKey==='activitySelection'){\n      let actsStr = document.getElementById('input-activities').value;\n      let actsArr = parsePairsEachLine(actsStr);\n      if(actsArr.length===0) throw 'Invalid or empty activities input';\n      newState.activities = actsArr;\n      newState.selected = [];\n      newState.currentStep=0;\n      newState.lastFinishTime=0;\n      // sort activities by finish time ascending once\n      newState.sorted = actsArr.slice().sort((a,b)=>a.end - b.end);\n    } else if(currentProblemKey==='fractionalKnapsack'){\n      let capacityStr = document.getElementById('input-capacity').value;\n      let itemsStr = document.getElementById('input-items').value;\n      let capacityVal = parseInt(capacityStr);\n      if(isNaN(capacityVal) || capacityVal<=0) throw 'Invalid capacity';\n      let itemsArr = parseValueWeightPairs(itemsStr);\n      if(itemsArr.length===0) throw 'Invalid or empty items input';\n      newState.capacity = capacityVal;\n      newState.items = itemsArr;\n      newState.chosen = [];\n      newState.currentWeight = 0;\n      newState.totalValue = 0;\n      newState.currentStep = 0;\n      // sort items descending by value/weight ratio\n      newState.sortedItems = itemsArr.slice().map((item,idx)=>({\n        idx,\n        value: item.value,\n        weight: item.weight,\n        ratio: item.value/item.weight\n      })).sort((a,b)=>b.ratio - a.ratio);\n    } else if(currentProblemKey==='huffmanCoding'){\n      let symStr = document.getElementById('input-symbols').value;\n      let symArr = parseSymbolsFreq(symStr);\n      if(symArr.length===0) throw 'Invalid or empty symbols input';\n      // initialize forest with leaf nodes\n      newState.nodes = symArr.map((s,i) => ({\n        id: i,\n        symbol: s.symbol,\n        freq: s.freq,\n        left: null,\n        right: null\n      }));\n      // forest is a priority list of nodes by freq ascending\n      newState.forest = newState.nodes.slice().sort((a,b)=>a.freq - b.freq);\n      newState.steps = [];\n      newState.codes = {};\n      newState.currentStep = 0;\n    } else {\n      throw 'Unknown problem';\n    }\n    currentState = newState;\n    undoHistory = [cloneDeep(currentState)];\n    document.getElementById('algorithm-controls').style.display = 'inline-block';\n    outputElement.textContent = '';\n    logClear();\n    log(`Problem loaded: ${currentProblemKey}`);\n    renderOutput();\n  } catch(e){\n    alert('Error: ' + e);\n    currentState = null;\n    document.getElementById('algorithm-controls').style.display = 'none';\n    outputElement.textContent = '';\n    logClear();\n  }\n}\n\n//===================\n// Render output area\n//===================\n\nfunction renderOutput(){\n  if(!currentState) return;\n  if(currentProblemKey==='coinChange'){\n    let s = `Coins: ${currentState.coins.join(', ')}\\nTarget amount: ${currentState.amount}\\nRemaining: ${currentState.remaining}\\nChosen coins: ${currentState.chosenCoins.join(', ')}\\nSteps done: ${currentState.currentStep}`;\n    outputElement.textContent = s;\n  } else if(currentProblemKey==='activitySelection'){\n    let s = 'Activities sorted by finish time:\\n';\n    currentState.sorted.forEach((a,i) => {\n      s += ` [${i}] Start: ${a.start}, End: ${a.end}\\n`;\n    });\n    s += '\\nSelected activities:\\n';\n    currentState.selected.forEach((a,i) => {\n      s += ` (${i}) Start: ${a.start}, End: ${a.end}\\n`;\n    });\n    s += `\\nSteps done: ${currentState.currentStep}\\nLast finish time: ${currentState.lastFinishTime}`;\n    outputElement.textContent = s;\n  } else if(currentProblemKey==='fractionalKnapsack'){\n    let s = `Capacity: ${currentState.capacity}\\nTotal value selected: ${currentState.totalValue.toFixed(2)}\\nCurrent weight: ${currentState.currentWeight}\\nChosen fractions:\\n`;\n    currentState.chosen.forEach(c => {\n      s += ` Item #${c.idx} (v=${c.value}, w=${c.weight}), fraction: ${c.fraction.toFixed(3)}\\n`;\n    });\n    s += `\\nSteps done: ${currentState.currentStep}`;\n    outputElement.textContent = s;\n  } else if(currentProblemKey==='huffmanCoding'){\n    let s = 'Forest nodes (freq ascending):\\n';\n    currentState.forest.forEach((n,i) => {\n      if(n.symbol!==null) s += ` [${i}] '${n.symbol}': ${n.freq}\\n`;\n      else s += ` [${i}] internal node freq=${n.freq}\\n`;\n    });\n    s += '\\nSteps done: ' + currentState.currentStep;\n    if(currentState.currentStep === currentState.nodes.length - 1){\n      s += '\\n\\nFinal Huffman Codes:\\n';\n      for(let sym in currentState.codes){\n        s += ` '${sym}': ${currentState.codes[sym]}\\n`;\n      }\n    }\n    outputElement.textContent = s;\n  }\n}\n\n//=============================\n// Greedy step implementations\n//=============================\n\nfunction greedyStep(){\n  if(!currentState) return;\n\n  if(currentProblemKey==='coinChange'){\n    // Pick largest coin <= remaining\n    if(currentState.remaining <= 0){ log('All amount covered'); return false; }\n    // Find largest coin <= remaining\n    let coin = currentState.coins.find(c => c <= currentState.remaining);\n    if(coin === undefined){\n      log('No coin fits remaining amount - no solution possible');\n      return false;\n    }\n    currentState.chosenCoins.push(coin);\n    currentState.remaining -= coin;\n    currentState.currentStep++;\n    log(`Step ${currentState.currentStep}: Picked coin ${coin}, remaining ${currentState.remaining}`);\n    return true;\n  }\n\n  if(currentProblemKey==='activitySelection'){\n    let i = currentState.currentStep;\n    if(i >= currentState.sorted.length){\n      log('All activities considered');\n      return false;\n    }\n    let a = currentState.sorted[i];\n    if(a.start >= currentState.lastFinishTime){\n      // select this activity\n      currentState.selected.push(a);\n      currentState.lastFinishTime = a.end;\n      log(`Step ${i+1}: Selected activity start=${a.start}, end=${a.end}`);\n    } else {\n      log(`Step ${i+1}: Skipped overlapping activity start=${a.start}, end=${a.end}`);\n    }\n    currentState.currentStep++;\n    return true;\n  }\n\n  if(currentProblemKey==='fractionalKnapsack'){\n    let items = currentState.sortedItems;\n    let step = currentState.currentStep;\n    if(step >= items.length){\n      log('All items considered');\n      return false;\n    }\n    let item = items[step];\n    let remainder = currentState.capacity - currentState.currentWeight;\n    if(remainder <= 0){\n      log('Knapsack full');\n      return false;\n    }\n    let fraction = Math.min(1, remainder / item.weight);\n    currentState.chosen.push({\n      idx: item.idx,\n      value: item.value,\n      weight: item.weight,\n      fraction: fraction\n    });\n    currentState.currentWeight += item.weight * fraction;\n    currentState.totalValue += item.value * fraction;\n    currentState.currentStep++;\n    log(`Step ${step+1}: Added ${(fraction*100).toFixed(2)}% of item #${item.idx} (v=${item.value}, w=${item.weight}), total value=${currentState.totalValue.toFixed(2)}, weight=${currentState.currentWeight.toFixed(2)}`);\n    return true;\n  }\n\n  if(currentProblemKey==='huffmanCoding'){\n    // if only one node in forest stop\n    if(currentState.forest.length === 1){\n      log('Huffman tree completed');\n      // At this point build codes from tree and save to currentState.codes\n      const root = currentState.forest[0];\n      function buildCodes(node, prefix) {\n        if(node.symbol !== null) { currentState.codes[node.symbol] = prefix; return; }\n        if(node.left) buildCodes(node.left, prefix + '0');\n        if(node.right) buildCodes(node.right, prefix + '1');\n      }\n      currentState.codes = {};\n      buildCodes(root, '');\n      return false;\n    }\n    // Remove two smallest freq nodes\n    let n1 = currentState.forest.shift();\n    let n2 = currentState.forest.shift();\n    let newNode = {\n      id: 'n' + (currentState.nodes.length + currentState.currentStep),\n      symbol: null,\n      freq: n1.freq + n2.freq,\n      left: n1,\n      right: n2\n    };\n    // Insert newNode back into forest keeping it sorted ascending freq\n    let insertIndex = currentState.forest.findIndex(n => n.freq > newNode.freq);\n    if(insertIndex === -1) currentState.forest.push(newNode);\n    else currentState.forest.splice(insertIndex, 0, newNode);\n\n    currentState.steps.push({n1, n2, newNode});\n    currentState.currentStep++;\n    log(`Step ${currentState.currentStep}: Merged nodes freq=${n1.freq} and freq=${n2.freq} into ${newNode.freq}`);\n    return true;\n  }\n\n  return false;\n}\n\n//===========================\n// Algorithm control handlers\n//===========================\n\nfunction stepBtnHandler(){\n  if(!currentState) return;\n  let success = greedyStep();\n  if(success) {\n    undoHistory.push(cloneDeep(currentState));\n    if(undoHistory.length > MAX_UNDO_HISTORY) undoHistory.shift();\n  }\n  renderOutput();\n}\n\nfunction runToEndHandler(){\n  if(!currentState) return;\n  let steps = 0;\n  while(greedyStep()){\n    steps++;\n    undoHistory.push(cloneDeep(currentState));\n    if(undoHistory.length > MAX_UNDO_HISTORY) undoHistory.shift();\n  }\n  log(`Run to end: executed ${steps} steps`);\n  renderOutput();\n}\n\nfunction undoStepHandler(){\n  if(undoHistory.length < 2){\n    alert('No steps to undo');\n    return;\n  }\n  undoHistory.pop();\n  currentState = cloneDeep(undoHistory[undoHistory.length - 1]);\n  renderOutput();\n  log('Undid one step');\n}\n\n// Reset algorithm to initial problem input state without changing inputs\nfunction resetAlgorithmHandler(){\n  readInputsValidate();\n  log('Algorithm reset');\n}\n\n//===========================\n// Problem selection and init\n//===========================\n\nfunction problemSelectHandler(e){\n  loadProblemInputs(e.target.value);\n}\n\nfunction resetProblemHandler(){\n  loadProblemInputs(currentProblemKey);\n}\n\n//============================\n// Exploration: compare greedy to exhaustive/brute force\n//============================\n\nfunction compareGreedyVsExhaustive(){\n  if(!currentState) {\n    alert('Load a problem first');\n    return;\n  }\n  // Some problems not feasible to brute force here due to complexity\n  if(currentProblemKey==='coinChange'){\n    // We will brute force minimal number of coins via simple DP then display results and difference\n    const coins = currentState.coins;\n    const amount = currentState.amount;\n    // DP array: min coins to form i\n    let dp = new Array(amount+1).fill(Infinity);\n    dp[0] = 0;\n    for(let i=1; i<=amount; i++){\n      for(let c of coins){\n        if(c<=i){\n          dp[i] = Math.min(dp[i], dp[i-c]+1);\n        }\n      }\n    }\n    if(dp[amount] === Infinity){\n      alert('No solution for amount with given coins');\n      return;\n    }\n    let greedyCount = currentState.chosenCoins.length;\n    let bruteCount = dp[amount];\n    let msg = `Greedy solution coin count: ${greedyCount}\\nOptimal solution coin count: ${bruteCount}\\n`;\n    msg += greedyCount===bruteCount ? 'Greedy is optimal here.' : 'Greedy is NOT optimal here.';\n    alert(msg);\n    log(msg);\n  } else if(currentProblemKey==='activitySelection'){\n    // Brute force max compatible subset by checking all combinations (exponential)\n    // Only do for small number of activities <=18 for perf\n    let acts = currentState.activities;\n    if(acts.length > 18){\n      alert('Too many activities for exhaustive search (limit 18).');\n      return;\n    }\n    // We'll generate all subsets\n    let maxCount = 0;\n    let maxSet = [];\n    let n = acts.length;\n    function isCompatible(subset){\n      subset.sort((a,b)=>a.start - b.start);\n      for(let i=1; i<subset.length; i++){\n        if(subset[i].start < subset[i-1].end) return false;\n      }\n      return true;\n    }\n    for(let mask=0; mask<(1<<n); mask++){\n      let subset = [];\n      for(let i=0; i<n; i++){\n        if((mask & (1<<i))!==0) subset.push(acts[i]);\n      }\n      if(isCompatible(subset)){\n        if(subset.length > maxCount){\n          maxCount = subset.length;\n          maxSet = subset;\n        }\n      }\n    }\n    let greedyCount = currentState.selected.length;\n    let bruteCount = maxCount;\n    let msg = `Greedy solution selected activities: ${greedyCount}\\nOptimal selection size: ${bruteCount}\\n`;\n    msg += greedyCount===bruteCount ? 'Greedy is optimal here.' : 'Greedy is NOT optimal here.';\n    alert(msg);\n    log(msg);\n  } else if(currentProblemKey==='fractionalKnapsack'){\n    // fractional knapsack greedy is always optimal\n    let msg = `The fractional knapsack greedy algorithm is always optimal.\\nNo exhaustive search needed.`;\n    alert(msg);\n    log(msg);\n  } else if(currentProblemKey==='huffmanCoding'){\n    let msg = `The Huffman coding greedy algorithm produces an optimal prefix code.\\nExhaustive search not feasible here.`;\n    alert(msg);\n    log(msg);\n  } else {\n    alert('Compare not implemented for this problem.');\n  }\n}\n\n//========================\n// Randomize inputs handler\n//========================\n\nfunction randomizeInputs(){\n  if(!currentProblemKey) return;\n  if(currentProblemKey==='coinChange'){\n    // Random coins - unique, sorted descending, includes 1\n    let numCoins = Math.max(3, Math.min(7, Math.floor(Math.random()*5)+3));\n    let coins = new Set([1]);\n    while(coins.size < numCoins){\n      coins.add(1+Math.floor(Math.random()*50));\n    }\n    let coinsArr = Array.from(coins).sort((a,b)=>b-a);\n    let amount = 1 + Math.floor(Math.random() * 100);\n    document.getElementById('input-coins').value = coinsArr.join(',');\n    document.getElementById('input-amount').value = amount;\n  } else if(currentProblemKey==='activitySelection'){\n    // Random activities - start,end pairs within 0..30 with random lengths 1..10\n    let count = 10 + Math.floor(Math.random()*10);\n    let activities = [];\n    for(let i=0; i<count; i++){\n      let start = Math.floor(Math.random() * 25);\n      let length = 1 + Math.floor(Math.random() * 6);\n      activities.push(`${start},${start+length}`);\n    }\n    document.getElementById('input-activities').value = activities.join('\\n');\n  } else if(currentProblemKey==='fractionalKnapsack'){\n    // Capacity 20..100 and 5..8 items (v:1..100, w:1..30)\n    let capacity = 20 + Math.floor(Math.random()*80);\n    let count = 5 + Math.floor(Math.random()*4);\n    let items = [];\n    for(let i=0; i<count; i++){\n      let v = 1 + Math.floor(Math.random()*100);\n      let w = 1 + Math.floor(Math.random()*30);\n      items.push(`${v},${w}`);\n    }\n    document.getElementById('input-capacity').value = capacity;\n    document.getElementById('input-items').value = items.join('\\n');\n  } else if(currentProblemKey==='huffmanCoding'){\n    // Random frequencies for symbols 'a'...'k' (3..10 symbols)\n    let count = 3 + Math.floor(Math.random()*8);\n    let chars = 'abcdefghijklmnopqrstuvwxyz';\n    let syms = [];\n    for(let i=0; i<count; i++){\n      let freq = 1 + Math.floor(Math.random()*50);\n      syms.push(`${chars[i]},${freq}`);\n    }\n    document.getElementById('input-symbols').value = syms.join('\\n');\n  }\n  readInputsValidate();\n}\n\n//=========================\n// Export/Import JSON handler\n//=========================\n\nfunction exportProblemJSON(){\n  if(!currentState) {\n    alert('No problem loaded');\n    return;\n  }\n  let exportObj = {\n    problemKey: currentProblemKey,\n    inputs: {}\n  };\n  currentProblem.inputs.forEach(inp=>{\n    let el = document.getElementById('input-'+inp.id);\n    exportObj.inputs[inp.id] = el ? el.value : '';\n  });\n  exportObj.state = currentState;\n  let jsonStr = JSON.stringify(exportObj, null, 2);\n  prompt('Copy this JSON text:', jsonStr);\n}\n\nfunction importProblemJSON(){\n  let jsonStr = prompt('Paste JSON problem & solution here');\n  if(!jsonStr) return;\n  try{\n    let importObj = JSON.parse(jsonStr);\n    if(!importObj.problemKey || !problems[importObj.problemKey]){\n      alert('Invalid problem key or unknown problem');\n      return;\n    }\n    currentProblemKey = importObj.problemKey;\n    currentProblem = problems[currentProblemKey];\n    // Set problem selector\n    document.getElementById('problem-select').value = currentProblemKey;\n    loadProblemInputs(currentProblemKey);\n    // Set inputs\n    for(let id in importObj.inputs){\n      let el = document.getElementById('input-'+id);\n      if(el){\n        el.value = importObj.inputs[id];\n      }\n    }\n    // reload state from inputs\n    readInputsValidate();\n    if(importObj.state){\n      currentState = importObj.state;\n      undoHistory = [cloneDeep(currentState)];\n      document.getElementById('algorithm-controls').style.display = 'inline-block';\n      logClear();\n      log('Imported problem and state loaded');\n      renderOutput();\n    }\n  } catch(e){\n    alert('Error importing JSON: ' + e.message);\n  }\n}\n\n//================\n// Event binding\n//================\n\nfunction bindEvents(){\n  const problemSelect = document.getElementById('problem-select');\n  problemSelect.addEventListener('change', (e) => {\n    loadProblemInputs(e.target.value);\n  });\n  document.getElementById('reset-problem').addEventListener('click', resetProblemHandler);\n  document.getElementById('step-btn').addEventListener('click', stepBtnHandler);\n  document.getElementById('run-btn').addEventListener('click', runToEndHandler);\n  document.getElementById('undo-btn').addEventListener('click', undoStepHandler);\n  document.getElementById('reset-algo-btn').addEventListener('click', resetAlgorithmHandler);\n  document.getElementById('compare-btn').addEventListener('click', compareGreedyVsExhaustive);\n  document.getElementById('randomize-btn').addEventListener('click', randomizeInputs);\n  document.getElementById('export-btn').addEventListener('click', exportProblemJSON);\n  document.getElementById('import-btn').addEventListener('click', importProblemJSON);\n\n  // On inputs fields change, validate and reload state\n  inputsContainer.addEventListener('input', debounce(() => {\n    readInputsValidate();\n  }, 400));\n}\n\n//======================\n// Debounce helper\n//======================\n\nfunction debounce(func, timeout = 300){\n  let timer;\n  return (...args) => {\n    clearTimeout(timer);\n    timer = setTimeout(() => { func.apply(this, args); }, timeout);\n  };\n}\n\n//==================\n// Initialization\n//==================\n\nfunction init(){\n  logElement = document.getElementById('log');\n  outputElement = document.getElementById('output');\n  inputsContainer = document.getElementById('problem-inputs');\n  algoControls = document.getElementById('algorithm-controls');\n\n  loadProblemInputs(currentProblemKey);\n  bindEvents();\n}\n\ninit();\n\n</script>\n</body>\n</html>"
