    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Neon Network: Socket Programming Visualized</title>\n    <style>\n        :root {\n            --primary: #6e00ff;\n            --secondary: #ff00c8;\n            --accent: #00f7ff;\n            --dark: #0a0a20;\n            --light: #f0f0ff;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Arial, sans-serif;\n        }\n        \n        body {\n            background-color: var(--dark);\n            color: var(--light);\n            overflow-x: hidden;\n            min-height: 100vh;\n            background-image: \n                radial-gradient(circle at 10% 20%, rgba(110, 0, 255, 0.15) 0%, transparent 20%),\n                radial-gradient(circle at 90% 80%, rgba(255, 0, 200, 0.15) 0%, transparent 20%);\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            position: relative;\n            z-index: 1;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            animation: gradientShift 8s infinite alternate;\n        }\n        \n        @keyframes gradientShift {\n            0% { background-position: 0% 50%; }\n            100% { background-position: 100% 50%; }\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.8;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization {\n            height: 500px;\n            position: relative;\n            background: rgba(10, 10, 32, 0.5);\n            border-radius: 20px;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            box-shadow: 0 0 30px rgba(110, 0, 255, 0.2);\n            backdrop-filter: blur(10px);\n            overflow: hidden;\n            margin-bottom: 3rem;\n        }\n        \n        .node {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            transition: all 0.5s ease;\n            z-index: 2;\n        }\n        \n        .client {\n            background: var(--primary);\n            box-shadow: 0 0 20px var(--primary);\n            left: 15%;\n            top: 50%;\n            transform: translateY(-50%);\n        }\n        \n        .server {\n            background: var(--secondary);\n            box-shadow: 0 0 20px var(--secondary);\n            right: 15%;\n            top: 50%;\n            transform: translateY(-50%);\n        }\n        \n        .connection {\n            position: absolute;\n            height: 4px;\n            background: linear-gradient(90deg, var(--primary), var(--accent), var(--secondary));\n            top: 50%;\n            left: calc(15% + 80px);\n            width: calc(70% - 160px);\n            transform-origin: left center;\n            z-index: 1;\n            animation: pulse 3s infinite;\n        }\n        \n        @keyframes pulse {\n            0%, 100% { opacity: 0.7; }\n            50% { opacity: 1; }\n        }\n        \n        .data-packet {\n            position: absolute;\n            width: 30px;\n            height: 20px;\n            background: var(--accent);\n            border-radius: 4px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 0.7rem;\n            box-shadow: 0 0 10px var(--accent);\n            z-index: 3;\n            opacity: 0;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n        \n        button {\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            border: none;\n            color: white;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-weight: bold;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(110, 0, 255, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(110, 0, 255, 0.4);\n        }\n        \n        button:disabled {\n            opacity: 0.5;\n            transform: none;\n            box-shadow: none;\n            cursor: not-allowed;\n        }\n        \n        .info-panel {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            padding: 1.5rem;\n            margin-top: 2rem;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .info-panel::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 3px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n        }\n        \n        h2 {\n            margin-bottom: 1rem;\n            color: var(--accent);\n        }\n        \n        p {\n            margin-bottom: 1rem;\n            line-height: 1.6;\n        }\n        \n        .code-block {\n            background: rgba(0, 0, 0, 0.3);\n            padding: 1rem;\n            border-radius: 8px;\n            font-family: monospace;\n            margin: 1rem 0;\n            border-left: 3px solid var(--accent);\n            overflow-x: auto;\n        }\n        \n        .glow {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: 0;\n        }\n        \n        .glow::before {\n            content: '';\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            background: radial-gradient(circle, var(--primary), transparent 70%);\n            top: 20%;\n            left: 10%;\n            opacity: 0.3;\n            animation: float 15s infinite ease-in-out;\n        }\n        \n        .glow::after {\n            content: '';\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            background: radial-gradient(circle, var(--secondary), transparent 70%);\n            bottom: 20%;\n            right: 10%;\n            opacity: 0.3;\n            animation: float 15s 5s infinite ease-in-out;\n        }\n        \n        @keyframes float {\n            0%, 100% { transform: translate(0, 0) rotate(0deg); }\n            25% { transform: translate(20px, 20px) rotate(5deg); }\n            50% { transform: translate(-20px, 10px) rotate(-5deg); }\n            75% { transform: translate(10px, -20px) rotate(3deg); }\n        }\n        \n        .tech-labels {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n        }\n        \n        .tech-label {\n            position: absolute;\n            background: rgba(255, 255, 255, 0.1);\n            color: white;\n            padding: 0.3rem 0.6rem;\n            border-radius: 20px;\n            font-size: 0.8rem;\n            animation: fadeInOut 8s infinite;\n        }\n        \n        @keyframes fadeInOut {\n            0%, 100% { opacity: 0; transform: translateY(10px); }\n            20%, 80% { opacity: 1; transform: translateY(0); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"glow\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Socket Programming</h1>\n            <p class=\"subtitle\">A visual exploration of network communication between client and server through sockets</p>\n        </header>\n        \n        <div class=\"controls\">\n            <button id=\"sendRequest\">Send Request</button>\n            <button id=\"resetDemo\" disabled>Reset</button>\n        </div>\n        \n        <div class=\"visualization\">\n            <div class=\"node client\">CLIENT</div>\n            <div class=\"node server\">SERVER</div>\n            <div class=\"connection\"></div>\n            \n            <div class=\"tech-labels\">\n                <div class=\"tech-label\" style=\"top: 30%; left: 20%; animation-delay: 0s;\">TCP/IP</div>\n                <div class=\"tech-label\" style=\"top: 60%; right: 20%; animation-delay: 2s;\">Port Binding</div>\n                <div class=\"tech-label\" style=\"top: 20%; right: 30%; animation-delay: 4s;\">Listen()</div>\n                <div class=\"tech-label\" style=\"bottom: 30%; left: 30%; animation-delay: 6s;\">Accept()</div>\n            </div>\n        </div>\n        \n        <div class=\"info-panel\">\n            <h2>How Socket Communication Works</h2>\n            <p>Sockets provide the fundamental mechanism for process-to-process communication across networks. This visualization demonstrates the key steps:</p>\n            \n            <div class=\"code-block\">\n                // Server setup<br>\n                socket() → bind() → listen() → accept() → read()/write() → close()<br><br>\n                // Client setup<br>\n                socket() → connect() → read()/write() → close()\n            </div>\n            \n            <p>The connection remains open until either side closes it, allowing for continuous bidirectional communication. Sockets can operate over different protocols (TCP/UDP) and handle various data types.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const sendBtn = document.getElementById('sendRequest');\n            const resetBtn = document.getElementById('resetDemo');\n            const client = document.querySelector('.client');\n            const server = document.querySelector('.server');\n            const connection = document.querySelector('.connection');\n            \n            let isAnimating = false;\n            \n            sendBtn.addEventListener('click', function() {\n                if (isAnimating) return;\n                isAnimating = true;\n                sendBtn.disabled = true;\n                \n                // Create request packet\n                const request = createPacket('REQ', client, server);\n                \n                // Animate request\n                setTimeout(() => {\n                    animatePacket(request, () => {\n                        // Request received by server\n                        server.style.transform = 'translateY(-50%) scale(1.1)';\n                        \n                        // Create response packet after delay\n                        setTimeout(() => {\n                            const response = createPacket('RES', server, client);\n                            server.style.transform = 'translateY(-50%) scale(1)';\n                            \n                            // Animate response\n                            setTimeout(() => {\n                                animatePacket(response, () => {\n                                    // Animation complete\n                                    isAnimating = false;\n                                    resetBtn.disabled = false;\n                                });\n                            }, 500);\n                        }, 1000);\n                    });\n                }, 500);\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                // Reset all elements\n                document.querySelectorAll('.data-packet').forEach(p => p.remove());\n                client.style.transform = 'translateY(-50%) scale(1)';\n                server.style.transform = 'translateY(-50%) scale(1)';\n                sendBtn.disabled = false;\n                resetBtn.disabled = true;\n            });\n            \n            function createPacket(content, from, to) {\n                const packet = document.createElement('div');\n                packet.className = 'data-packet';\n                packet.textContent = content;\n                \n                const fromRect = from.getBoundingClientRect();\n                const toRect = to.getBoundingClientRect();\n                \n                packet.style.left = `${fromRect.left + fromRect.width/2 - 15}px`;\n                packet.style.top = `${fromRect.top + fromRect.height/2 - 10}px`;\n                \n                document.body.appendChild(packet);\n                \n                // Calculate angle for movement\n                const angle = Math.atan2(\n                    toRect.top - fromRect.top,\n                    toRect.left - fromRect.left\n                );\n                \n                return { element: packet, angle };\n            }\n            \n            function animatePacket(packet, callback) {\n                const { element, angle } = packet;\n                let pos = 0;\n                const speed = 3;\n                \n                element.style.opacity = '1';\n                \n                function frame() {\n                    pos += speed;\n                    element.style.transform = `translate(${Math.cos(angle) * pos}px, ${Math.sin(angle) * pos}px)`;\n                    \n                    if (pos < 150) {\n                        requestAnimationFrame(frame);\n                    } else {\n                        element.remove();\n                        if (callback) callback();\n                    }\n                }\n                \n                requestAnimationFrame(frame);\n            }\n            \n            // Subtle background animation\n            function animateBackground() {\n                const backgroundPos = performance.now() * 0.01;\n                document.body.style.backgroundPosition = \n                    `${Math.sin(backgroundPos * 0.0005) * 20}px ${Math.cos(backgroundPos * 0.0007) * 20}px, \n                     ${Math.cos(backgroundPos * 0.0006) * 20}px ${Math.sin(backgroundPos * 0.0008) * 20}px`;\n                \n                requestAnimationFrame(animateBackground);\n            }\n            \n            animateBackground();\n        });\n    </script>\n</body>\n</html>"
