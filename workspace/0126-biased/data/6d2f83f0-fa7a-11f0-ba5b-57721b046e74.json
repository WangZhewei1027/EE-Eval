  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Sliding Window Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 800px;\n            margin: 0 auto;\n        }\n        .controls {\n            margin: 20px 0;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        .array-display {\n            font-family: monospace;\n            font-size: 18px;\n            margin: 20px 0;\n            white-space: nowrap;\n            overflow-x: auto;\n        }\n        .window {\n            position: relative;\n            height: 30px;\n            margin: 20px 0;\n        }\n        .window-highlight {\n            position: absolute;\n            background-color: rgba(0,0,0,0.1);\n            height: 30px;\n            border: 1px solid #000;\n        }\n        .result {\n            margin: 20px 0;\n            font-weight: bold;\n        }\n        button, input, select {\n            margin: 5px;\n        }\n        .log {\n            font-family: monospace;\n            height: 200px;\n            overflow-y: scroll;\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Sliding Window Interactive Demo</h1>\n        \n        <div class=\"controls\">\n            <h2>Array Configuration</h2>\n            <div>\n                <label>Array Size: <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"30\" value=\"10\"></label>\n                <span id=\"arraySizeValue\">10</span>\n            </div>\n            <div>\n                <label>Min Value: <input type=\"number\" id=\"minValue\" value=\"1\"></label>\n                <label>Max Value: <input type=\"number\" id=\"maxValue\" value=\"100\"></label>\n            </div>\n            <button id=\"generateArray\">Generate New Array</button>\n            <button id=\"manualEdit\">Edit Array Manually</button>\n            <div id=\"manualEditContainer\" style=\"display: none; margin-top: 10px;\">\n                <input type=\"text\" id=\"manualArrayInput\" placeholder=\"Enter comma-separated numbers\">\n                <button id=\"applyManualArray\">Apply</button>\n            </div>\n        </div>\n        \n        <div class=\"array-display\" id=\"arrayDisplay\"></div>\n        \n        <div class=\"controls\">\n            <h2>Window Configuration</h2>\n            <div>\n                <label>Window Size: <input type=\"range\" id=\"windowSize\" min=\"1\" max=\"10\" value=\"3\"></label>\n                <span id=\"windowSizeValue\">3</span>\n            </div>\n            <div>\n                <label>Operation: \n                    <select id=\"operation\">\n                        <option value=\"max\">Maximum</option>\n                        <option value=\"min\">Minimum</option>\n                        <option value=\"sum\">Sum</option>\n                        <option value=\"average\">Average</option>\n                        <option value=\"custom\">Product</option>\n                    </select>\n                </label>\n            </div>\n            <button id=\"runAlgorithm\">Run Sliding Window</button>\n            <button id=\"stepForward\">Step Forward</button>\n            <button id=\"reset\">Reset</button>\n        </div>\n        \n        <div class=\"window\" id=\"windowContainer\"></div>\n        \n        <div class=\"result\" id=\"resultDisplay\"></div>\n        \n        <div class=\"controls\">\n            <h2>Algorithm State</h2>\n            <div>\n                Current Window: <span id=\"currentWindow\">[]</span>\n            </div>\n            <div>\n                Current Result: <span id=\"currentResult\">-</span>\n            </div>\n            <div>\n                Final Results: <span id=\"finalResults\">[]</span>\n            </div>\n        </div>\n        \n        <div class=\"log\" id=\"executionLog\"></div>\n    </div>\n\n    <script>\n        // State variables\n        let array = [];\n        let windowSize = 3;\n        let currentPosition = 0;\n        let results = [];\n        let isRunning = false;\n        let operation = 'max';\n        \n        // DOM elements\n        const arrayDisplay = document.getElementById('arrayDisplay');\n        const windowContainer = document.getElementById('windowContainer');\n        const resultDisplay = document.getElementById('resultDisplay');\n        const currentWindowDisplay = document.getElementById('currentWindow');\n        const currentResultDisplay = document.getElementById('currentResult');\n        const finalResultsDisplay = document.getElementById('finalResults');\n        const executionLog = document.getElementById('executionLog');\n        \n        // Initialize\n        document.getElementById('arraySize').addEventListener('input', updateArraySize);\n        document.getElementById('windowSize').addEventListener('input', updateWindowSize);\n        document.getElementById('generateArray').addEventListener('click', generateArray);\n        document.getElementById('manualEdit').addEventListener('click', toggleManualEdit);\n        document.getElementById('applyManualArray').addEventListener('click', applyManualArray);\n        document.getElementById('runAlgorithm').addEventListener('click', runAlgorithm);\n        document.getElementById('stepForward').addEventListener('click', stepForward);\n        document.getElementById('reset').addEventListener('click', reset);\n        document.getElementById('operation').addEventListener('change', updateOperation);\n        \n        // Initial setup\n        generateArray();\n        updateWindowSize();\n        \n        function updateArraySize() {\n            const size = document.getElementById('arraySize').value;\n            document.getElementById('arraySizeValue').textContent = size;\n        }\n        \n        function updateWindowSize() {\n            windowSize = parseInt(document.getElementById('windowSize').value);\n            document.getElementById('windowSizeValue').textContent = windowSize;\n            reset();\n        }\n        \n        function updateOperation() {\n            operation = document.getElementById('operation').value;\n            reset();\n        }\n        \n        function generateArray() {\n            const size = parseInt(document.getElementById('arraySize').value);\n            const min = parseInt(document.getElementById('minValue').value);\n            const max = parseInt(document.getElementById('maxValue').value);\n            \n            array = [];\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * (max - min + 1)) + min);\n            }\n            \n            updateArrayDisplay();\n            reset();\n        }\n        \n        function toggleManualEdit() {\n            const container = document.getElementById('manualEditContainer');\n            if (container.style.display === 'none') {\n                container.style.display = 'block';\n                document.getElementById('manualArrayInput').value = array.join(', ');\n            } else {\n                container.style.display = 'none';\n            }\n        }\n        \n        function applyManualArray() {\n            const input = document.getElementById('manualArrayInput').value;\n            try {\n                array = input.split(',').map(num => parseInt(num.trim()));\n                document.getElementById('manualEditContainer').style.display = 'none';\n                updateArrayDisplay();\n                reset();\n            } catch (e) {\n                alert('Invalid input. Please enter comma-separated numbers.');\n            }\n        }\n        \n        function updateArrayDisplay() {\n            arrayDisplay.textContent = array.join(' ');\n        }\n        \n        function runAlgorithm() {\n            reset();\n            isRunning = true;\n            executionLog.innerHTML += 'Algorithm started...<br>';\n            \n            while (currentPosition <= array.length - windowSize) {\n                stepForward();\n            }\n            \n            isRunning = false;\n            executionLog.innerHTML += 'Algorithm completed.<br>';\n        }\n        \n        function stepForward() {\n            if (currentPosition > array.length - windowSize) {\n                executionLog.innerHTML += 'Cannot step forward - reached end of array.<br>';\n                return;\n            }\n            \n            const windowValues = array.slice(currentPosition, currentPosition + windowSize);\n            currentWindowDisplay.textContent = `[${windowValues.join(', ')}]`;\n            \n            let result;\n            switch (operation) {\n                case 'max':\n                    result = Math.max(...windowValues);\n                    break;\n                case 'min':\n                    result = Math.min(...windowValues);\n                    break;\n                case 'sum':\n                    result = windowValues.reduce((a, b) => a + b, 0);\n                    break;\n                case 'average':\n                    result = (windowValues.reduce((a, b) => a + b, 0) / windowSize).toFixed(2);\n                    break;\n                case 'custom':\n                    result = windowValues.reduce((a, b) => a * b, 1);\n                    break;\n            }\n            \n            results.push(result);\n            currentResultDisplay.textContent = result;\n            finalResultsDisplay.textContent = `[${results.join(', ')}]`;\n            \n            // Update window highlight\n            windowContainer.innerHTML = '';\n            const windowHighlight = document.createElement('div');\n            windowHighlight.className = 'window-highlight';\n            const charWidth = 15; // Approximate width of each array element\n            const startPos = currentPosition * charWidth;\n            const width = windowSize * charWidth;\n            \n            windowHighlight.style.left = `${startPos}px`;\n            windowHighlight.style.width = `${width}px`;\n            windowContainer.appendChild(windowHighlight);\n            \n            // Update log\n            executionLog.innerHTML += `Window at position ${currentPosition}: [${windowValues.join(', ')}] → ${result}<br>`;\n            executionLog.scrollTop = executionLog.scrollHeight;\n            \n            currentPosition++;\n        }\n        \n        function reset() {\n            currentPosition = 0;\n            results = [];\n            isRunning = false;\n            \n            currentWindowDisplay.textContent = '[]';\n            currentResultDisplay.textContent = '-';\n            finalResultsDisplay.textContent = '[]';\n            resultDisplay.textContent = '';\n            windowContainer.innerHTML = '';\n            executionLog.innerHTML = '';\n            \n            if (array.length > 0) {\n                const maxPossibleWindowSize = array.length;\n                document.getElementById('windowSize').max = maxPossibleWindowSize;\n                if (windowSize > maxPossibleWindowSize) {\n                    windowSize = maxPossibleWindowSize;\n                    document.getElementById('windowSize').value = windowSize;\n                    document.getElementById('windowSizeValue').textContent = windowSize;\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
