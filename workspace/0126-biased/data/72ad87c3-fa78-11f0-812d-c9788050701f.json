    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Support Vector Machines: A Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #2c3e50;\n            --secondary: #34495e;\n            --accent: #e74c3c;\n            --light: #ecf0f1;\n            --dark: #1a252f;\n            --positive: #2ecc71;\n            --negative: #e74c3c;\n            --neutral: #3498db;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Montserrat', sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            padding: 2rem;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 1rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s ease-out 0.2s forwards;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--light), var(--neutral));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        h2 {\n            font-size: 1.5rem;\n            font-weight: 300;\n            color: rgba(236, 240, 241, 0.7);\n            margin-bottom: 1.5rem;\n        }\n\n        .description {\n            max-width: 700px;\n            line-height: 1.6;\n            text-align: center;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out 0.5s forwards;\n        }\n\n        .visualization-container {\n            position: relative;\n            width: 600px;\n            height: 500px;\n            background-color: rgba(255, 255, 255, 0.05);\n            border-radius: 16px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n            backdrop-filter: blur(8px);\n            -webkit-backdrop-filter: blur(8px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            overflow: hidden;\n            opacity: 0;\n            transform: scale(0.95);\n            animation: fadeIn 0.8s ease-out 0.8s forwards, scaleIn 0.8s ease-out 0.8s forwards;\n            margin-top: 2rem;\n        }\n\n        canvas {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 1rem;\n            opacity: 0;\n            transform: translateY(10px);\n            animation: fadeIn 1s ease-out 1.2s forwards;\n        }\n\n        button {\n            background: rgba(255, 255, 255, 0.1);\n            color: var(--light);\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(5px);\n            -webkit-backdrop-filter: blur(5px);\n            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            background: rgba(255, 255, 255, 0.2);\n            transform: translateY(-2px);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n            transform: translateX(-100%);\n            transition: transform 0.6s ease;\n        }\n\n        button:hover::after {\n            transform: translateX(100%);\n        }\n\n        .legend {\n            display: flex;\n            gap: 2rem;\n            margin-top: 1.5rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n        }\n\n        .support-vector {\n            background-color: var(--accent);\n            box-shadow: 0 0 10px var(--accent);\n        }\n\n        .positive {\n            background-color: var(--positive);\n        }\n\n        .negative {\n            background-color: var(--negative);\n        }\n\n        .decision-boundary {\n            width: 20px;\n            height: 4px;\n            background: var(--light);\n            border-radius: 2px;\n        }\n\n        .margin {\n            width: 20px;\n            height: 4px;\n            background: rgba(236, 240, 241, 0.3);\n            border-radius: 2px;\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes scaleIn {\n            to {\n                transform: scale(1);\n            }\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n        }\n\n        .particle {\n            position: absolute;\n            background-color: rgba(255, 255, 255, 0.1);\n            border-radius: 50%;\n            pointer-events: none;\n        }\n\n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            font-size: 0.9rem;\n            color: rgba(236, 240, 241, 0.5);\n            opacity: 0;\n            animation: fadeIn 1s ease-out 2s forwards;\n        }\n    </style>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    <div class=\"container\">\n        <header>\n            <h1>Support Vector Machines</h1>\n            <h2>The Art of Optimal Separation</h2>\n        </header>\n\n        <p class=\"description\">\n            Support Vector Machines find the optimal hyperplane that maximizes the margin between classes. \n            This elegant visualization demonstrates how SVMs work in a two-dimensional feature space, \n            highlighting the support vectors that define the decision boundary.\n        </p>\n\n        <div class=\"visualization-container\">\n            <canvas id=\"svmCanvas\"></canvas>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"generateData\">Generate New Data</button>\n            <button id=\"toggleMargin\">Toggle Margin</button>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color positive\"></div>\n                <span>Positive Class</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color negative\"></div>\n                <span>Negative Class</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color support-vector\"></div>\n                <span>Support Vectors</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color decision-boundary\"></div>\n                <span>Decision Boundary</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color margin\"></div>\n                <span>Margin</span>\n            </div>\n        </div>\n\n        <footer>\n            <p>A visual exploration of machine learning elegance | SVM Implementation</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create background particles\n            const particlesContainer = document.getElementById('particles');\n            for (let i = 0; i < 50; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 5 + 2;\n                const posX = Math.random() * 100;\n                const posY = Math.random() * 100;\n                const opacity = Math.random() * 0.1 + 0.05;\n                const animationDuration = Math.random() * 20 + 10;\n                const animationDelay = Math.random() * 5;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.top = `${posY}%`;\n                particle.style.opacity = opacity;\n                particle.style.animation = `float ${animationDuration}s ease-in-out ${animationDelay}s infinite alternate`;\n                \n                particlesContainer.appendChild(particle);\n            }\n\n            // Add styles for particle animation\n            const style = document.createElement('style');\n            style.textContent = `\n                @keyframes float {\n                    0%, 100% {\n                        transform: translate(0, 0);\n                    }\n                    25% {\n                        transform: translate(5px, 5px);\n                    }\n                    50% {\n                        transform: translate(-5px, 5px);\n                    }\n                    75% {\n                        transform: translate(-5px, -5px);\n                    }\n                }\n            `;\n            document.head.appendChild(style);\n\n            // SVM Visualization\n            const canvas = document.getElementById('svmCanvas');\n            const ctx = canvas.getContext('2d');\n            \n            // Set canvas dimensions\n            function resizeCanvas() {\n                canvas.width = canvas.offsetWidth;\n                canvas.height = canvas.offsetHeight;\n                draw();\n            }\n            \n            window.addEventListener('resize', resizeCanvas);\n            resizeCanvas();\n\n            // Data and SVM parameters\n            let data = [];\n            let svm = {};\n            let showMargin = true;\n            \n            // Generate random data\n            function generateData() {\n                data = [];\n                const count = 30;\n                const spread = 0.3;\n                \n                // Positive class (y = 1)\n                for (let i = 0; i < count; i++) {\n                    const x = 0.3 + Math.random() * 0.4;\n                    const y = 0.3 + Math.random() * 0.4;\n                    const noiseX = (Math.random() - 0.5) * spread;\n                    const noiseY = (Math.random() - 0.5) * spread;\n                    data.push({ x: x + noiseX, y: y + noiseY, label: 1 });\n                }\n                \n                // Negative class (y = -1)\n                for (let i = 0; i < count; i++) {\n                    const x = 0.6 + Math.random() * 0.3;\n                    const y = 0.6 + Math.random() * 0.3;\n                    const noiseX = (Math.random() - 0.5) * spread;\n                    const noiseY = (Math.random() - 0.5) * spread;\n                    data.push({ x: x + noiseX, y: y + noiseY, label: -1 });\n                }\n                \n                trainSVM();\n            }\n            \n            // Simple linear SVM training\n            function trainSVM() {\n                // Find support vectors (closest points from each class)\n                const positivePoints = data.filter(p => p.label === 1);\n                const negativePoints = data.filter(p => p.label === -1);\n                \n                // Find the closest pair between classes\n                let minDistance = Infinity;\n                let sv1 = null, sv2 = null;\n                \n                for (const pos of positivePoints) {\n                    for (const neg of negativePoints) {\n                        const dx = pos.x - neg.x;\n                        const dy = pos.y - neg.y;\n                        const distance = Math.sqrt(dx * dx + dy * dy);\n                        \n                        if (distance < minDistance) {\n                            minDistance = distance;\n                            sv1 = pos;\n                            sv2 = neg;\n                        }\n                    }\n                }\n                \n                // Calculate decision boundary (perpendicular bisector of sv1 and sv2)\n                const midX = (sv1.x + sv2.x) / 2;\n                const midY = (sv1.y + sv2.y) / 2;\n                \n                // Slope of line connecting sv1 and sv2\n                const slope = (sv2.y - sv1.y) / (sv2.x - sv1.x);\n                \n                // Slope of decision boundary (perpendicular)\n                let dbSlope = -1 / slope;\n                \n                // To avoid extreme slopes for visualization\n                if (Math.abs(dbSlope) > 5) dbSlope = dbSlope > 0 ? 5 : -5;\n                \n                svm = {\n                    slope: dbSlope,\n                    intercept: midY - dbSlope * midX,\n                    supportVectors: [sv1, sv2],\n                    margin: minDistance / 2 * 0.7 // Scale for visualization\n                };\n                \n                draw();\n            }\n            \n            // Draw the visualization\n            function draw() {\n                const width = canvas.width;\n                const height = canvas.height;\n                const padding = 40;\n                \n                ctx.clearRect(0, 0, width, height);\n                \n                // Coordinate transformation\n                function toCanvasX(x) {\n                    return padding + x * (width - 2 * padding);\n                }\n                \n                function toCanvasY(y) {\n                    return padding + (1 - y) * (height - 2 * padding);\n                }\n                \n                // Draw margin area if enabled\n                if (showMargin && svm.margin) {\n                    ctx.fillStyle = 'rgba(236, 240, 241, 0.05)';\n                    ctx.strokeStyle = 'rgba(236, 240, 241, 0.15)';\n                    ctx.lineWidth = 1;\n                    \n                    // Upper margin line\n                    ctx.beginPath();\n                    const marginInterceptUpper = svm.intercept + svm.margin / Math.cos(Math.atan(svm.slope));\n                    const x1 = 0;\n                    const y1 = svm.slope * x1 + marginInterceptUpper;\n                    const x2 = 1;\n                    const y2 = svm.slope * x2 + marginInterceptUpper;\n                    \n                    ctx.moveTo(toCanvasX(x1), toCanvasY(y1));\n                    ctx.lineTo(toCanvasX(x2), toCanvasY(y2));\n                    \n                    // Lower margin line\n                    const marginInterceptLower = svm.intercept - svm.margin / Math.cos(Math.atan(svm.slope));\n                    const y3 = svm.slope * x1 + marginInterceptLower;\n                    const y4 = svm.slope * x2 + marginInterceptLower;\n                    \n                    ctx.lineTo(toCanvasX(x2), toCanvasY(y4));\n                    ctx.lineTo(toCanvasX(x1), toCanvasY(y3));\n                    ctx.closePath();\n                    \n                    ctx.fill();\n                    ctx.stroke();\n                }\n                \n                // Draw decision boundary\n                if (svm.slope !== undefined) {\n                    ctx.strokeStyle = 'rgba(236, 240, 241, 0.8)';\n                    ctx.lineWidth = 3;\n                    ctx.beginPath();\n                    \n                    const x1 = 0;\n                    const y1 = svm.slope * x1 + svm.intercept;\n                    const x2 = 1;\n                    const y2 = svm.slope * x2 + svm.intercept;\n                    \n                    ctx.moveTo(toCanvasX(x1), toCanvasY(y1));\n                    ctx.lineTo(toCanvasX(x2), toCanvasY(y2));\n                    ctx.stroke();\n                    \n                    // Animate the boundary drawing\n                    ctx.save();\n                    ctx.strokeStyle = 'rgba(236, 240, 241, 0.3)';\n                    ctx.lineWidth = 6;\n                    ctx.beginPath();\n                    ctx.moveTo(toCanvasX(x1), toCanvasY(y1));\n                    ctx.lineTo(toCanvasX(x2), toCanvasY(y2));\n                    ctx.stroke();\n                    ctx.restore();\n                }\n                \n                // Draw data points\n                data.forEach(point => {\n                    const isSupportVector = svm.supportVectors && \n                                          (point === svm.supportVectors[0] || point === svm.supportVectors[1]);\n                    \n                    const x = toCanvasX(point.x);\n                    const y = toCanvasY(point.y);\n                    const radius = isSupportVector ? 8 : 6;\n                    \n                    // Draw point\n                    ctx.beginPath();\n                    ctx.arc(x, y, radius, 0, Math.PI * 2);\n                    ctx.fillStyle = point.label === 1 ? \n                        (isSupportVector ? 'rgba(46, 204, 113, 0.8)' : 'rgba(46, 204, 113, 0.6)') : \n                        (isSupportVector ? 'rgba(231, 76, 60, 0.8)' : 'rgba(231, 76, 60, 0.6)');\n                    ctx.fill();\n                    \n                    // Highlight support vectors\n                    if (isSupportVector) {\n                        ctx.beginPath();\n                        ctx.arc(x, y, radius + 6, 0, Math.PI * 2);\n                        ctx.strokeStyle = 'rgba(231, 76, 60, 0.5)';\n                        ctx.lineWidth = 2;\n                        ctx.stroke();\n                        \n                        // Pulsing effect\n                        ctx.beginPath();\n                        ctx.arc(x, y, radius + 10, 0, Math.PI * 2);\n                        ctx.strokeStyle = 'rgba(231, 76, 60, 0.2)';\n                        ctx.lineWidth = 2;\n                        ctx.stroke();\n                    }\n                });\n            }\n            \n            // Event listeners\n            document.getElementById('generateData').addEventListener('click', () => {\n                generateData();\n            });\n            \n            document.getElementById('toggleMargin').addEventListener('click', () => {\n                showMargin = !showMargin;\n                draw();\n            });\n            \n            // Initial generation\n            generateData();\n        });\n    </script>\n</body>\n</html>"
  },
