background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: 2px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: rgba(255, 255, 255, 0.7);\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualizer {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 2rem;\n            perspective: 1000px;\n        }\n\n        .message-container {\n            width: 100%;\n            max-width: 600px;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            border-radius: 15px;\n            padding: 2rem;\n            box-shadow: var(--glow);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: all 0.5s ease;\n            transform-style: preserve-3d;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 0.5s forwards;\n        }\n\n        .message-container:hover {\n            transform: translateY(-5px) rotateX(5deg);\n            box-shadow: 0 10px 30px rgba(110, 69, 226, 0.6);\n        }\n\n        .message-label {\n            font-size: 1rem;\n            color: var(--secondary);\n            margin-bottom: 0.5rem;\n            display: block;\n        }\n\n        .message-display {\n            font-size: 1.2rem;\n            min-height: 80px;\n            padding: 1rem;\n            background: rgba(0, 0, 0, 0.2);\n            border-radius: 8px;\n            border-left: 3px solid var(--primary);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .message-display::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n            transform: translateX(-100%);\n        }\n\n        .message-display.active::after {\n            animation: shine 1.5s infinite;\n        }\n\n        @keyframes shine {\n            100% { transform: translateX(100%); }\n        }\n\n        .encryption-process {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            width: 100%;\n            height: 200px;\n            position: relative;\n            margin: 2rem 0;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1s forwards;\n        }\n\n        .cipher-wheel {\n            width: 180px;\n            height: 180px;\n            border-radius: 50%;\n            background: radial-gradient(circle, var(--dark) 40%, var(--primary) 100%);\n            border: 2px solid rgba(255, 255, 255, 0.1);\n            position: relative;\n            box-shadow: var(--glow);\n            animation: float 5s ease-in-out infinite;\n        }\n\n        .cipher-wheel-inner {\n            position: absolute;\n            width: 80%;\n            height: 80%;\n            border-radius: 50%;\n            background: rgba(0, 0, 0, 0.3);\n            top: 10%;\n            left: 10%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 2rem;\n            color: var(--light);\n        }\n\n        .gear {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background: var(--accent);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            box-shadow: 0 0 15px rgba(255, 126, 95, 0.6);\n            animation: spin 8s linear infinite;\n        }\n\n        .gear-1 {\n            top: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n        }\n\n        .gear-2 {\n            bottom: -25px;\n            right: 15%;\n            animation-direction: reverse;\n        }\n\n        .gear-3 {\n            top: 30%;\n            left: -25px;\n            animation-duration: 6s;\n        }\n\n        .gear-4 {\n            top: 30%;\n            right: -25px;\n            animation-duration: 10s;\n        }\n\n        @keyframes spin {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        .particles {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .particle {\n            position: absolute;\n            width: 3px;\n            height: 3px;\n            background: var(--primary);\n            border-radius: 50%;\n            opacity: 0;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        .btn {\n            padding: 0.8rem 2rem;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            box-shadow: 0 5px 15px rgba(110, 69, 226, 0.4);\n        }\n\n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(110, 69, 226, 0.6);\n        }\n\n        .btn:active {\n            transform: translateY(1px);\n        }\n\n        .btn::after {\n            content: '';\n  