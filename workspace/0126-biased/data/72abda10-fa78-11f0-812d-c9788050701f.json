    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Cosmic Pages</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n            background: #0a0a19;\n            color: #e0e0ff;\n            height: 100vh;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .container {\n            position: relative;\n            width: 100%;\n            max-width: 1200px;\n            height: 600px;\n            perspective: 2000px;\n        }\n\n        .pagination-display {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 80%;\n            height: 60%;\n            transform-style: preserve-3d;\n            transition: transform 1s cubic-bezier(0.65, 0, 0.35, 1);\n        }\n\n        .page {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            backface-visibility: hidden;\n            border-radius: 24px;\n            padding: 30px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            box-shadow: 0 30px 50px rgba(0, 0, 20, 0.3);\n            transition: all 0.8s cubic-bezier(0.65, 0, 0.35, 1);\n            background: linear-gradient(135deg, rgba(20, 20, 60, 0.8), rgba(10, 10, 30, 0.9));\n            backdrop-filter: blur(15px);\n            border: 1px solid rgba(120, 120, 255, 0.1);\n        }\n\n        .page.active {\n            transform: translate3d(0, 0, 0) rotateY(0deg);\n            opacity: 1;\n            z-index: 10;\n        }\n\n        .page.previous {\n            transform: translate3d(-60%, 0, -200px) rotateY(-20deg);\n            opacity: 0.6;\n            z-index: 5;\n        }\n\n        .page.next {\n            transform: translate3d(60%, 0, -200px) rotateY(20deg);\n            opacity: 0.6;\n            z-index: 5;\n        }\n\n        .page h1 {\n            font-size: 3.5rem;\n            margin-bottom: 20px;\n            background: linear-gradient(90deg, #8a2be2, #4169e1);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            text-align: center;\n            font-weight: 800;\n        }\n\n        .page p {\n            font-size: 1.2rem;\n            line-height: 1.8;\n            max-width: 600px;\n            text-align: center;\n            color: rgba(224, 224, 255, 0.8);\n            margin-bottom: 40px;\n        }\n\n        .controls {\n            position: absolute;\n            bottom: 80px;\n            display: flex;\n            gap: 20px;\n            z-index: 100;\n        }\n\n        .btn {\n            padding: 16px 32px;\n            border: none;\n            border-radius: 12px;\n            background: linear-gradient(135deg, #8a2be2, #4169e1);\n            color: white;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 10px 20px rgba(65, 105, 225, 0.2);\n        }\n\n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 15px 30px rgba(65, 105, 225, 0.3);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        .btn:disabled {\n            opacity: 0.5;\n            cursor: not-allowed;\n            transform: none !important;\n        }\n\n        .cosmic-decoration {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .star {\n            position: absolute;\n            background: white;\n            border-radius: 50%;\n            animation: twinkle var(--duration) infinite ease-in-out;\n        }\n\n        @keyframes twinkle {\n            0%, 100% { opacity: 0.2; }\n            50% { opacity: 1; }\n        }\n\n        .galaxy {\n            position: absolute;\n            width: 500px;\n            height: 500px;\n            background: radial-gradient(circle, rgba(138, 43, 226, 0.15) 0%, rgba(0,0,0,0) 70%);\n            animation: rotate var(--galaxy-duration) linear infinite;\n        }\n\n        @keyframes rotate {\n            from { transform: rotate(0deg); }\n            to { transform: rotate(360deg); }\n        }\n\n        .page-number {\n            position: absolute;\n            bottom: 20px;\n            right: 20px;\n            font-size: 0.9rem;\n            color: rgba(224, 224, 255, 0.5);\n        }\n\n        .status-bar {\n            position: absolute;\n            top: 30px;\n            width: 80%;\n            height: 6px;\n            background: rgba(120, 120, 255, 0.1);\n            border-radius: 3px;\n            overflow: hidden;\n        }\n\n        .progress {\n            height: 100%;\n            background: linear-gradient(90deg, #8a2be2, #4169e1);\n            border-radius: 3px;\n            transition: width 0.5s ease;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"cosmic-decoration\" id=\"cosmic\"></div>\n    \n    <div class=\"container\">\n        <div class=\"status-bar\">\n            <div class=\"progress\" id=\"progress\"></div>\n        </div>\n        \n        <div class=\"pagination-display\">\n            <div class=\"page active\">\n                <h1>Celestial Navigation</h1>\n                <p>Discover how cosmic phenomena influence terrestrial navigation and ancient seafaring traditions.</p>\n                <span class=\"page-number\">1</span>\n            </div>\n            <div class=\"page next\">\n                <h1>Stellar Cartography</h1>\n                <p>Explore the mapping of stars and constellations across different cultures and civilizations.</p>\n                <span class=\"page-number\">2</span>\n            </div>\n            <div class=\"page next\">\n                <h1>Quantum Horizons</h1>\n                <p>Delve into the quantum nature of space-time and its implications for our understanding of reality.</p>\n                <span class=\"page-number\">3</span>\n            </div>\n            <div class=\"page next\">\n                <h1>Cosmic Symphony</h1>\n                <p>Witness the harmonic patterns that govern planetary orbits and galactic formations.</p>\n                <span class=\"page-number\">4</span>\n            </div>\n            <div class=\"page next\">\n                <h1>Eternal Return</h1>\n                <p>Contemplate cyclical time and the mythological concept of the unending cosmic cycle.</p>\n                <span class=\"page-number\">5</span>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button class=\"btn\" id=\"prevBtn\" disabled>Previous</button>\n            <button class=\"btn\" id=\"nextBtn\">Next</button>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create cosmic background\n            const cosmic = document.getElementById('cosmic');\n            for (let i = 0; i < 100; i++) {\n                const star = document.createElement('div');\n                star.className = 'star';\n                star.style.width = `${Math.random() * 3 + 1}px`;\n                star.style.height = star.style.width;\n                star.style.left = `${Math.random() * 100}%`;\n                star.style.top = `${Math.random() * 100}%`;\n                star.style.setProperty('--duration', `${Math.random() * 5 + 3}s`);\n                cosmic.appendChild(star);\n            }\n\n            for (let i = 0; i < 3; i++) {\n                const galaxy = document.createElement('div');\n                galaxy.className = 'galaxy';\n                galaxy.style.left = `${Math.random() * 100 - 30}%`;\n                galaxy.style.top = `${Math.random() * 100 - 30}%`;\n                galaxy.style.setProperty('--galaxy-duration', `${Math.random() * 600 + 300}s`);\n                galaxy.style.width = `${Math.random() * 200 + 300}px`;\n                galaxy.style.height = galaxy.style.width;\n                galaxy.style.opacity = Math.random() * 0.1 + 0.05;\n                cosmic.appendChild(galaxy);\n            }\n\n            // Paging functionality\n            const pages = document.querySelectorAll('.page');\n            const prevBtn = document.getElementById('prevBtn');\n            const nextBtn = document.getElementById('nextBtn');\n            const progressBar = document.getElementById('progress');\n            let currentPage = 0;\n\n            function updatePagination() {\n                pages.forEach((page, index) => {\n                    page.classList.remove('active', 'previous', 'next');\n                    \n                    if (index === currentPage) {\n                        page.classList.add('active');\n                    } else if (index === currentPage - 1) {\n                        page.classList.add('previous');\n                    } else if (index === currentPage + 1) {\n                        page.classList.add('next');\n                    }\n                });\n\n                prevBtn.disabled = currentPage === 0;\n                nextBtn.disabled = currentPage === pages.length - 1;\n                \n                // Update progress bar\n                progressBar.style.width = `${(currentPage / (pages.length - 1)) * 100}%`;\n                \n                // Smooth background transition\n                document.body.style.background = \n                    `linear-gradient(135deg, \n                     rgba(${10 + currentPage * 10}, ${10 + currentPage * 5}, ${30 + currentPage * 10}, 1),\n                     rgba(${5 + currentPage * 3}, ${5 + currentPage * 3}, ${15 + currentPage * 5}, 1))`;\n            }\n\n            nextBtn.addEventListener('click', function() {\n                if (currentPage < pages.length - 1) {\n                    currentPage++;\n                    updatePagination();\n                }\n            });\n\n            prevBtn.addEventListener('click', function() {\n                if (currentPage > 0) {\n                    currentPage--;\n                    updatePagination();\n                }\n            });\n\n            // Initialize\n            updatePagination();\n            \n            // Auto-cycle for demo purposes (remove in production)\n            let autoCycle = setInterval(() => {\n                if (currentPage < pages.length - 1) {\n                    currentPage++;\n                } else {\n                    currentPage = 0;\n                }\n                updatePagination();\n            }, 5000);\n            \n            // Stop auto-cycling on user interaction\n            document.addEventListener('click', function() {\n                clearInterval(autoCycle);\n            }, { once: true });\n        });\n    </script>\n</body>\n</html>"
