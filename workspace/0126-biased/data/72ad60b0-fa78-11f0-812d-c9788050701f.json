    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Regression | A Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #4a6fa5;\n            --secondary: #166088;\n            --accent: #4fc3f7;\n            --light: #e8f4f8;\n            --dark: #0a1128;\n            --success: #4caf50;\n            --error: #f44336;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, var(--light) 0%, #ffffff 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            color: var(--secondary);\n            margin-bottom: 0.5rem;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--primary);\n            font-weight: 300;\n            margin-bottom: 2rem;\n        }\n\n        .divider {\n            height: 2px;\n            width: 100px;\n            background: linear-gradient(90deg, transparent 0%, var(--accent) 50%, transparent 100%);\n            margin: 1rem auto;\n        }\n\n        .visualization-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 3rem;\n            margin-top: 4rem;\n        }\n\n        .graph-container {\n            position: relative;\n            width: 800px;\n            height: 500px;\n            background-color: white;\n            border-radius: 12px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);\n            padding: 2rem;\n            overflow: hidden;\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n        }\n\n        .graph-container:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);\n        }\n\n        canvas {\n            width: 100%;\n            height: 100%;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1.5rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            padding: 0.8rem 2rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(74, 111, 165, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(74, 111, 165, 0.4);\n        }\n\n        button::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n            transition: all 0.5s ease;\n        }\n\n        button:hover::before {\n            left: 100%;\n        }\n\n        .explanation {\n            max-width: 700px;\n            margin: 4rem auto;\n            text-align: center;\n            line-height: 1.8;\n            color: var(--dark);\n            opacity: 0;\n            animation: fadeIn 1s ease-out 0.5s forwards;\n        }\n\n        .equation {\n            font-family: 'Courier New', Courier, monospace;\n            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ed 100%);\n            padding: 1.5rem;\n            border-radius: 8px;\n            display: inline-block;\n            margin: 1.5rem 0;\n            font-size: 1.2rem;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n        }\n\n        .footer {\n            text-align: center;\n            margin-top: 5rem;\n            padding-top: 2rem;\n            border-top: 1px solid rgba(0, 0, 0, 0.1);\n            color: var(--primary);\n            font-size: 0.9rem;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n\n        .floating-point {\n            position: absolute;\n            width: 10px;\n            height: 10px;\n            border-radius: 50%;\n            background-color: var(--accent);\n            animation: float 3s ease-in-out infinite;\n            opacity: 0.7;\n        }\n\n        @media (max-width: 900px) {\n            .graph-container {\n                width: 100%;\n                height: 400px;\n            }\n            \n            h1 {\n                font-size: 2.2rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Linear Regression</h1>\n            <div class=\"divider\"></div>\n            <p class=\"subtitle\">A Visual Demonstration of Predictive Modeling</p>\n        </header>\n\n        <div class=\"visualization-container\">\n            <div class=\"graph-container\">\n                <canvas id=\"regressionCanvas\"></canvas>\n                <div class=\"floating-point\" style=\"top: 15%; left: 20%; animation-delay: 0s;\"></div>\n                <div class=\"floating-point\" style=\"top: 25%; left: 70%; animation-delay: 0.5s;\"></div>\n                <div class=\"floating-point\" style=\"top: 60%; left: 40%; animation-delay: 1s;\"></div>\n            </div>\n\n            <div class=\"controls\">\n                <button id=\"generateBtn\">Generate New Data</button>\n                <button id=\"regressBtn\">Calculate Regression</button>\n            </div>\n        </div>\n\n        <div class=\"explanation\">\n            <p>Linear regression is a fundamental statistical approach for modeling the relationship between a dependent variable and one or more independent variables. The goal is to find the linear equation that best predicts the outcome variable from the predictor variables.</p>\n            \n            <div class=\"equation\">\n                y = mx + b\n            </div>\n            \n            <p>Where <strong>y</strong> is the dependent variable, <strong>x</strong> is the independent variable, <strong>m</strong> is the slope of the line, and <strong>b</strong> is the y-intercept. The line is calculated to minimize the sum of squared residuals between the observed and predicted values.</p>\n        </div>\n    </div>\n\n    <footer class=\"footer\">\n        <p>© 2023 Linear Regression Visualization | Designed with Elegance</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const canvas = document.getElementById('regressionCanvas');\n            const ctx = canvas.getContext('2d');\n            \n            // Set canvas dimensions\n            canvas.width = canvas.offsetWidth;\n            canvas.height = canvas.offsetHeight;\n            \n            // Data points\n            let points = [];\n            let regressionLine = null;\n            \n            // Colors\n            const colors = {\n                point: '#4a6fa5',\n                line: '#f06292',\n                background: '#ffffff',\n                axis: '#b0bec5',\n                grid: '#eceff1'\n            };\n            \n            // Initialize\n            generateRandomData();\n            drawGraph();\n            \n            // Event listeners\n            document.getElementById('generateBtn').addEventListener('click', function() {\n                generateRandomData();\n                regressionLine = null;\n                drawGraph();\n            });\n            \n            document.getElementById('regressBtn').addEventListener('click', function() {\n                calculateRegression();\n                drawGraph();\n            });\n            \n            // Functions\n            function generateRandomData() {\n                points = [];\n                const count = 15 + Math.floor(Math.random() * 10);\n                const width = canvas.width - 80;\n                const height = canvas.height - 80;\n                \n                for (let i = 0; i < count; i++) {\n                    const x = 40 + Math.random() * width;\n                    const y = 40 + Math.random() * height;\n                    points.push({ x, y });\n                }\n            }\n            \n            function calculateRegression() {\n                if (points.length < 2) return;\n                \n                // Calculate means\n                let sumX = 0, sumY = 0, sumXY = 0, sumXX = 0;\n                const n = points.length;\n                \n                points.forEach(point => {\n                    sumX += point.x;\n                    sumY += point.y;\n                    sumXY += point.x * point.y;\n                    sumXX += point.x * point.x;\n                });\n                \n                const meanX = sumX / n;\n                const meanY = sumY / n;\n                \n                // Calculate slope (m) and intercept (b)\n                const m = (sumXY - n * meanX * meanY) / (sumXX - n * meanX * meanX);\n                const b = meanY - m * meanX;\n                \n                // Create regression line points\n                const x1 = 40;\n                const y1 = m * x1 + b;\n                const x2 = canvas.width - 40;\n                const y2 = m * x2 + b;\n                \n                regressionLine = { x1, y1, x2, y2, m, b };\n            }\n            \n            function drawGraph() {\n                // Clear canvas\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n                \n                // Draw grid\n                drawGrid();\n                \n                // Draw axes\n                drawAxes();\n                \n                // Draw points\n                drawPoints();\n                \n                // Draw regression line if calculated\n                if (regressionLine) {\n                    drawRegressionLine();\n                }\n            }\n            \n            function drawGrid() {\n                ctx.strokeStyle = colors.grid;\n                ctx.lineWidth = 0.5;\n                \n                // Vertical grid lines\n                for (let x = 40; x < canvas.width; x += 50) {\n                    ctx.beginPath();\n                    ctx.moveTo(x, 40);\n                    ctx.lineTo(x, canvas.height - 40);\n                    ctx.stroke();\n                }\n                \n                // Horizontal grid lines\n                for (let y = 40; y < canvas.height; y += 50) {\n                    ctx.beginPath();\n                    ctx.moveTo(40, y);\n                    ctx.lineTo(canvas.width - 40, y);\n                    ctx.stroke();\n                }\n            }\n            \n            function drawAxes() {\n                ctx.strokeStyle = colors.axis;\n                ctx.lineWidth = 1.5;\n                \n                // X axis\n                ctx.beginPath();\n                ctx.moveTo(40, canvas.height - 40);\n                ctx.lineTo(canvas.width - 40, canvas.height - 40);\n                ctx.stroke();\n                \n                // Y axis\n                ctx.beginPath();\n                ctx.moveTo(40, 40);\n                ctx.lineTo(40, canvas.height - 40);\n                ctx.stroke();\n                \n                // X axis ticks\n                ctx.textAlign = 'center';\n                ctx.textBaseline = 'top';\n                ctx.fillStyle = colors.axis;\n                ctx.font = '12px Arial';\n                \n                for (let x = 100; x < canvas.width - 40; x += 100) {\n                    ctx.beginPath();\n                    ctx.moveTo(x, canvas.height - 40);\n                    ctx.lineTo(x, canvas.height - 35);\n                    ctx.stroke();\n                    \n                    ctx.fillText((x - 40).toString(), x, canvas.height - 30);\n                }\n                \n                // Y axis ticks\n                ctx.textAlign = 'right';\n                ctx.textBaseline = 'middle';\n                \n                for (let y = canvas.height - 100; y > 40; y -= 100) {\n                    ctx.beginPath();\n                    ctx.moveTo(40, y);\n                    ctx.lineTo(45, y);\n                    ctx.stroke();\n                    \n                    ctx.fillText((canvas.height - y - 40).toString(), 35, y);\n                }\n            }\n            \n            function drawPoints() {\n                points.forEach(point => {\n                    ctx.fillStyle = colors.point;\n                    ctx.beginPath();\n                    ctx.arc(point.x, point.y, 6, 0, Math.PI * 2);\n                    ctx.fill();\n                    \n                    // Glow effect\n                    const gradient = ctx.createRadialGradient(\n                        point.x, point.y, 6,\n                        point.x, point.y, 12\n                    );\n                    gradient.addColorStop(0, 'rgba(74, 111, 165, 0.8)');\n                    gradient.addColorStop(1, 'rgba(74, 111, 165, 0)');\n                    \n                    ctx.fillStyle = gradient;\n                    ctx.beginPath();\n                    ctx.arc(point.x, point.y, 12, 0, Math.PI * 2);\n                    ctx.fill();\n                });\n            }\n            \n            function drawRegressionLine() {\n                ctx.strokeStyle = colors.line;\n                ctx.lineWidth = 3;\n                ctx.beginPath();\n                ctx.moveTo(regressionLine.x1, regressionLine.y1);\n                ctx.lineTo(regressionLine.x2, regressionLine.y2);\n                ctx.stroke();\n                \n                // Equation display\n                ctx.textAlign = 'left';\n                ctx.textBaseline = 'top';\n                ctx.fillStyle = colors.line;\n                ctx.font = '16px Arial';\n                \n                const equationText = `y = ${regressionLine.m.toFixed(2)}x + ${regressionLine.b.toFixed(2)}`;\n                ctx.fillText(equationText, 50, 50);\n            }\n            \n            // Handle window resize\n            window.addEventListener('resize', function() {\n                canvas.width = canvas.offsetWidth;\n                canvas.height = canvas.offsetHeight;\n                drawGraph();\n            });\n        });\n    </script>\n</body>\n</html>"
