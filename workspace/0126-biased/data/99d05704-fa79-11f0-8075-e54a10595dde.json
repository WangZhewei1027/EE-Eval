    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive HTTPS Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        button, input, select {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>HTTPS Interactive Demonstration</h1>\n<p>Explore the concept of HTTPS with the following interactive controls:</p>\n\n<h2>1. URL Encryption Simulation</h2>\n<label for=\"urlInput\">Enter URL:</label>\n<input type=\"text\" id=\"urlInput\" placeholder=\"https://example.com\">\n<button id=\"encryptButton\">Encrypt URL</button>\n<p id=\"encryptedResult\"></p>\n\n<h2>2. Simulate Server Response</h2>\n<label for=\"responseSelect\">Select Response Status:</label>\n<select id=\"responseSelect\">\n    <option value=\"200\">200 OK</option>\n    <option value=\"404\">404 Not Found</option>\n    <option value=\"500\">500 Internal Server Error</option>\n</select>\n<button id=\"responseButton\">Simulate Response</button>\n<p id=\"responseResult\"></p>\n\n<h2>3. TLS Version Selection</h2>\n<label for=\"tlsSelect\">Select TLS Version:</label>\n<select id=\"tlsSelect\">\n    <option value=\"TLS 1.0\">TLS 1.0</option>\n    <option value=\"TLS 1.1\">TLS 1.1</option>\n    <option value=\"TLS 1.2\">TLS 1.2</option>\n    <option value=\"TLS 1.3\">TLS 1.3</option>\n</select>\n<button id=\"tlsButton\">Show Selected TLS Version</button>\n<p id=\"tlsResult\"></p>\n\n<h2>4. Random Security Vulnerability</h2>\n<button id=\"vulnerabilityButton\">Check for Random Vulnerability</button>\n<p id=\"vulnerabilityResult\"></p>\n\n<h2>5. Interaction History</h2>\n<button id=\"showHistoryButton\">Show Interaction History</button>\n<ul id=\"interactionHistory\"></ul>\n\n<script>\n    let interactionHistory = [];\n\n    document.getElementById('encryptButton').onclick = function() {\n        const url = document.getElementById('urlInput').value;\n        const encryptedUrl = btoa(url); // Basic simulation of encryption\n        document.getElementById('encryptedResult').innerText = 'Encrypted URL: ' + encryptedUrl;\n        interactionHistory.push('Encrypted URL: ' + encryptedUrl);\n    };\n\n    document.getElementById('responseButton').onclick = function() {\n        const response = document.getElementById('responseSelect').value;\n        let message;\n        switch (response) {\n            case '200':\n                message = 'Server Response: 200 OK';\n                break;\n            case '404':\n                message = 'Server Response: 404 Not Found';\n                break;\n            case '500':\n                message = 'Server Response: 500 Internal Server Error';\n                break;\n        }\n        document.getElementById('responseResult').innerText = message;\n        interactionHistory.push(message);\n    };\n\n    document.getElementById('tlsButton').onclick = function() {\n        const tlsVersion = document.getElementById('tlsSelect').value;\n        document.getElementById('tlsResult').innerText = 'Selected TLS Version: ' + tlsVersion;\n        interactionHistory.push('Selected TLS Version: ' + tlsVersion);\n    };\n\n    document.getElementById('vulnerabilityButton').onclick = function() {\n        const vulnerabilities = ['SSL Stripping', 'Heartbleed', 'POODLE', 'BEAST', 'Logjam'];\n        const randomVulnerability = vulnerabilities[Math.floor(Math.random() * vulnerabilities.length)];\n        document.getElementById('vulnerabilityResult').innerText = 'Random Vulnerability: ' + randomVulnerability;\n        interactionHistory.push('Checked for Vulnerability: ' + randomVulnerability);\n    };\n\n    document.getElementById('showHistoryButton').onclick = function() {\n        const historyList = document.getElementById('interactionHistory');\n        historyList.innerHTML = ''; // Clear previous list\n        interactionHistory.forEach(interaction => {\n            const li = document.createElement('li');\n            li.textContent = interaction;\n            historyList.appendChild(li);\n        });\n    };\n</script>\n\n</body>\n</html>"
