    "role": "assistant",
    "content": "<html>\n<head>\n    <title>TCP/IP Interactive Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .panel { border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; }\n        .hidden { display: none; }\n        button, input, select { margin: 5px; }\n        .packet { border: 1px solid #000; padding: 10px; margin: 5px; }\n        .layer { margin-left: 20px; }\n        table { border-collapse: collapse; width: 100%; }\n        td, th { border: 1px solid #000; padding: 5px; text-align: left; }\n    </style>\n</head>\n<body>\n    <h1>TCP/IP Interactive Explorer</h1>\n    \n    <div class=\"panel\">\n        <h2>Network Configuration</h2>\n        <div>\n            <label>Protocol: </label>\n            <select id=\"protocol\">\n                <option value=\"tcp\">TCP</option>\n                <option value=\"udp\">UDP</option>\n                <option value=\"icmp\">ICMP</option>\n            </select>\n        </div>\n        <div>\n            <label>Source IP: </label>\n            <input type=\"text\" id=\"srcIp\" value=\"192.168.1.1\">\n        </div>\n        <div>\n            <label>Destination IP: </label>\n            <input type=\"text\" id=\"destIp\" value=\"10.0.0.1\">\n        </div>\n        <div>\n            <label>Source Port: </label>\n            <input type=\"number\" id=\"srcPort\" value=\"5000\" min=\"1\" max=\"65535\">\n        </div>\n        <div>\n            <label>Destination Port: </label>\n            <input type=\"number\" id=\"destPort\" value=\"80\" min=\"1\" max=\"65535\">\n        </div>\n        <div>\n            <label>Data: </label>\n            <input type=\"text\" id=\"data\" value=\"Hello, TCP/IP!\">\n        </div>\n        <button onclick=\"sendPacket()\">Send Packet</button>\n    </div>\n\n    <div class=\"panel\">\n        <h2>Packet Construction</h2>\n        <div>\n            <label>Show Layers: </label>\n            <button onclick=\"showLayer('application')\">Application</button>\n            <button onclick=\"showLayer('transport')\">Transport</button>\n            <button onclick=\"showLayer('network')\">Network</button>\n            <button onclick=\"showLayer('link')\">Link</button>\n            <button onclick=\"showLayer('physical')\">Physical</button>\n        </div>\n        <div id=\"packetView\"></div>\n    </div>\n\n    <div class=\"panel\">\n        <h2>Connection Simulation</h2>\n        <div>\n            <button onclick=\"startConnection()\">Start TCP Handshake</button>\n            <button onclick=\"closeConnection()\">Close Connection</button>\n            <button onclick=\"simulatePacketLoss()\">Simulate Packet Loss</button>\n            <button onclick=\"simulateRetransmission()\">Simulate Retransmission</button>\n        </div>\n        <div id=\"connectionStatus\">Status: Not established</div>\n        <div id=\"connectionLog\"></div>\n    </div>\n\n    <div class=\"panel\">\n        <h2>Protocol Analysis</h2>\n        <div>\n            <label>Window Size: </label>\n            <input type=\"range\" id=\"windowSize\" min=\"1\" max=\"20\" value=\"10\" oninput=\"updateWindowSize()\">\n            <span id=\"windowSizeValue\">10</span>\n        </div>\n        <div>\n            <label>MSS (Maximum Segment Size): </label>\n            <input type=\"number\" id=\"mss\" value=\"1460\" min=\"100\" max=\"1500\" onchange=\"updateMSS()\">\n        </div>\n        <div>\n            <label>Timeout: </label>\n            <input type=\"number\" id=\"timeout\" value=\"2000\" min=\"100\" max=\"10000\" step=\"100\" onchange=\"updateTimeout()\"> ms\n        </div>\n        <div id=\"analysisResults\"></div>\n    </div>\n\n    <div class=\"panel\">\n        <h2>Packet Inspector</h2>\n        <div id=\"packetList\"></div>\n        <div id=\"packetDetails\"></div>\n    </div>\n\n    <script>\n        let connectionState = 'closed';\n        let sequenceNumber = 1000;\n        let ackNumber = 0;\n        let packets = [];\n        let windowSize = 10;\n        let mss = 1460;\n        let timeout = 2000;\n\n        function sendPacket() {\n            const protocol = document.getElementById('protocol').value;\n            const srcIp = document.getElementById('srcIp').value;\n            const destIp = document.getElementById('destIp').value;\n            const srcPort = document.getElementById('srcPort').value;\n            const destPort = document.getElementById('destPort').value;\n            const data = document.getElementById('data').value;\n\n            const packet = {\n                id: Date.now(),\n                protocol,\n                srcIp,\n                destIp,\n                srcPort,\n                destPort,\n                data,\n                timestamp: new Date().toLocaleTimeString(),\n                layers: buildLayers(protocol, srcIp, destIp, srcPort, destPort, data)\n            };\n\n            packets.push(packet);\n            updatePacketList();\n            displayPacket(packet);\n            logEvent(`Packet sent from ${srcIp}:${srcPort} to ${destIp}:${destPort} (${protocol})`);\n        }\n\n        function buildLayers(protocol, srcIp, destIp, srcPort, destPort, data) {\n            const layers = {\n                application: {\n                    protocol: protocol.toUpperCase(),\n                    data: data\n                },\n                transport: {\n                    sourcePort: srcPort,\n                    destinationPort: destPort,\n                    sequenceNumber: sequenceNumber,\n                    ackNumber: ackNumber,\n                    windowSize: windowSize,\n                    flags: protocol === 'tcp' ? 'SYN' : ''\n                },\n                network: {\n                    version: 4,\n                    headerLength: 20,\n                    ttl: 64,\n                    protocol: protocol === 'tcp' ? 6 : (protocol === 'udp' ? 17 : 1),\n                    sourceAddress: srcIp,\n                    destinationAddress: destIp\n                },\n                link: {\n                    sourceMAC: '00:1A:2B:3C:4D:5E',\n                    destinationMAC: '00:5E:4D:2B:1A:00',\n                    type: 'IPv4'\n                },\n                physical: {\n                    encoding: 'NRZ',\n                    voltageLevels: '0V (0), +5V (1)',\n                    bitRate: '100 Mbps'\n                }\n            };\n\n            if (protocol === 'tcp') {\n                sequenceNumber += data.length;\n            }\n\n            return layers;\n        }\n\n        function showLayer(layer) {\n            const packet = packets[packets.length - 1];\n            if (!packet) return;\n\n            const layerData = packet.layers[layer];\n            let html = `<h3>${layer.toUpperCase()} Layer</h3><div class=\"layer\"><pre>${JSON.stringify(layerData, null, 2)}</pre></div>`;\n            document.getElementById('packetView').innerHTML = html;\n        }\n\n        function startConnection() {\n            if (connectionState !== 'closed') {\n                logEvent('Connection already established or in progress');\n                return;\n            }\n\n            logEvent('Initiating TCP 3-way handshake...');\n            connectionState = 'syn_sent';\n            \n            // SYN\n            setTimeout(() => {\n                logEvent('SYN sent (sequence number: ' + sequenceNumber + ')');\n                connectionState = 'syn_received';\n                \n                // SYN-ACK\n                setTimeout(() => {\n                    ackNumber = sequenceNumber + 1;\n                    sequenceNumber = 5000; // Server's initial sequence number\n                    logEvent('SYN-ACK received (ack number: ' + ackNumber + ', sequence number: ' + sequenceNumber + ')');\n                    connectionState = 'established';\n                    \n                    // ACK\n                    setTimeout(() => {\n                        ackNumber = sequenceNumber + 1;\n                        logEvent('ACK sent (ack number: ' + ackNumber + ')');\n                        document.getElementById('connectionStatus').textContent = 'Status: Connection established';\n                        logEvent('TCP connection established successfully');\n                    }, 1000);\n                }, 1000);\n            }, 1000);\n        }\n\n        function closeConnection() {\n            if (connectionState !== 'established') {\n                logEvent('No active connection to close');\n                return;\n            }\n\n            logEvent('Initiating TCP connection termination...');\n            connectionState = 'fin_wait_1';\n            \n            // FIN\n            setTimeout(() => {\n                logEvent('FIN sent (sequence number: ' + sequenceNumber + ')');\n                connectionState = 'fin_wait_2';\n                \n                // ACK\n                setTimeout(() => {\n                    ackNumber = sequenceNumber + 1;\n                    logEvent('ACK received (ack number: ' + ackNumber + ')');\n                    \n                    // FIN from other side\n                    setTimeout(() => {\n                        sequenceNumber = ackNumber;\n                        logEvent('FIN received (sequence number: ' + sequenceNumber + ')');\n                        connectionState = 'time_wait';\n                        \n                        // Final ACK\n                        setTimeout(() => {\n                            ackNumber = sequenceNumber + 1;\n                            logEvent('ACK sent (ack number: ' + ackNumber + ')');\n                            connectionState = 'closed';\n                            document.getElementById('connectionStatus').textContent = 'Status: Connection closed';\n                            logEvent('TCP connection closed successfully');\n                        }, 1000);\n                    }, 1000);\n                }, 1000);\n            }, 1000);\n        }\n\n        function simulatePacketLoss() {\n            logEvent('Simulating packet loss...');\n            const lostPacket = {\n                id: 'lost-' + Date.now(),\n                protocol: document.getElementById('protocol').value,\n                srcIp: document.getElementById('srcIp').value,\n                destIp: document.getElementById('destIp').value,\n                srcPort: document.getElementById('srcPort').value,\n                destPort: document.getElementById('destPort').value,\n                data: 'LOST PACKET',\n                timestamp: new Date().toLocaleTimeString(),\n                status: 'LOST'\n            };\n            \n            packets.push(lostPacket);\n            updatePacketList();\n            logEvent('Packet lost in transmission!');\n            \n            if (connectionState === 'established') {\n                setTimeout(() => {\n                    logEvent('Timeout detected, initiating retransmission...');\n                    sendPacket();\n                }, timeout * 1.5);\n            }\n        }\n\n        function simulateRetransmission() {\n            if (packets.length === 0) return;\n            const lastPacket = packets[packets.length - 1];\n            logEvent('Retransmitting last packet...');\n            \n            const retransmittedPacket = {\n                ...lastPacket,\n                id: 'retransmit-' + Date.now(),\n                timestamp: new Date().toLocaleTimeString(),\n                status: 'RETRANSMITTED'\n            };\n            \n            packets.push(retransmittedPacket);\n            updatePacketList();\n            displayPacket(retransmittedPacket);\n            logEvent('Packet retransmitted');\n        }\n\n        function updateWindowSize() {\n            const value = document.getElementById('windowSize').value;\n            document.getElementById('windowSizeValue').textContent = value;\n            windowSize = parseInt(value);\n            document.getElementById('analysisResults').innerHTML = \n                `Window size updated to ${value}. This affects flow control and throughput.`;\n        }\n\n        function updateMSS() {\n            mss = document.getElementById('mss').value;\n            document.getElementById('analysisResults').innerHTML = \n                `MSS updated to ${mss}. This affects how data is segmented for transmission.`;\n        }\n\n        function updateTimeout() {\n            timeout = document.getElementById('timeout').value;\n            document.getElementById('analysisResults').innerHTML = \n                `Timeout updated to ${timeout}ms. This affects how long to wait before retransmitting lost packets.`;\n        }\n\n        function logEvent(message) {\n            const log = document.getElementById('connectionLog');\n            log.innerHTML += `<div>${new Date().toLocaleTimeString()}: ${message}</div>`;\n            log.scrollTop = log.scrollHeight;\n        }\n\n        function updatePacketList() {\n            const list = document.getElementById('packetList');\n            list.innerHTML = '<h3>Captured Packets</h3>';\n            \n            packets.forEach((packet, index) => {\n                const status = packet.status ? ` (${packet.status})` : '';\n                list.innerHTML += `\n                    <div class=\"packet\" onclick=\"displayPacketAtIndex(${index})\">\n                        #${index + 1}: ${packet.protocol} ${packet.srcIp}:${packet.srcPort} → ${packet.destIp}:${packet.destPort} \n                        [${packet.timestamp}]${status}\n                    </div>\n                `;\n            });\n        }\n\n        function displayPacketAtIndex(index) {\n            if (index >= 0 && index < packets.length) {\n                displayPacket(packets[index]);\n            }\n        }\n\n        function displayPacket(packet) {\n            const details = document.getElementById('packetDetails');\n            details.innerHTML = `\n                <h3>Packet Details</h3>\n                <table>\n                    <tr><th>Field</th><th>Value</th></tr>\n                    <tr><td>Protocol</td><td>${packet.protocol.toUpperCase()}</td></tr>\n                    <tr><td>Source</td><td>${packet.srcIp}:${packet.srcPort}</td></tr>\n                    <tr><td>Destination</td><td>${packet.destIp}:${packet.destPort}</td></tr>\n                    <tr><td>Timestamp</td><td>${packet.timestamp}</td></tr>\n                    <tr><td>Status</td><td>${packet.status || 'Normal'}</td></tr>\n                    <trIfExists(packet, 'sequenceNumber')}\n                    <trIfExists(packet, 'ackNumber')}\n                    <tr><td>Data</td><td>${packet.data}</td></tr>\n                </table>\n                <h4>Layers</h4>\n                <button onclick=\"showLayerForPacket('application', ${packets.indexOf(packet)})\">Application</button>\n                <button onclick=\"showLayerForPacket('transport', ${packets.indexOf(packet)})\">Transport</button>\n                <button onclick=\"showLayerForPacket('network', ${packets.indexOf(packet)})\">Network</button>\n                <button onclick=\"showLayerForPacket('link', ${packets.indexOf(packet)})\">Link</button>\n                <button onclick=\"showLayerForPacket('physical', ${packets.indexOf(packet)})\">Physical</button>\n            `;\n        }\n\n        function trIfExists(packet, field) {\n            if (packet[field] !== undefined) {\n                return `<tr><td>${field}</td><td>${packet[field]}</td></tr>`;\n            }\n            return '';\n        }\n\n        function showLayerForPacket(layer, index) {\n            if (index >= 0 && index < packets.length) {\n                const packet = packets[index];\n                const layerData = packet.layers[layer];\n                let html = `<h3>${layer.toUpperCase()} Layer</h3><div class=\"layer\"><pre>${JSON.stringify(layerData, null, 2)}</pre></div>`;\n                document.getElementById('packetDetails').innerHTML += html;\n            }\n        }\n    </script>\n</body>\n</html>"
  },
