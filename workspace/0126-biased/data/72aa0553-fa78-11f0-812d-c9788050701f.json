    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Jump Search Visualizer</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --highlight: #00cec9;\n            --found: #00b894;\n            --current: #fd79a8;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: #f9f9f9;\n            color: var(--dark);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 40px 20px;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n        }\n        \n        .container {\n            max-width: 1000px;\n            width: 100%;\n            margin: 0 auto;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 40px;\n            animation: fadeIn 1s ease-out;\n        }\n        \n        h1 {\n            font-size: 2.8rem;\n            font-weight: 700;\n            margin-bottom: 10px;\n            color: var(--primary);\n            text-shadow: 0 2px 10px rgba(108, 92, 231, 0.2);\n            letter-spacing: -0.5px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualizer {\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);\n            padding: 30px;\n            margin-bottom: 40px;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .visualizer::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: linear-gradient(90deg, var(--primary), var(--highlight));\n        }\n        \n        .array-container {\n            display: flex;\n            justify-content: center;\n            margin: 40px 0;\n            flex-wrap: wrap;\n        }\n        \n        .array-element {\n            width: 60px;\n            height: 60px;\n            margin: 5px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.2rem;\n            font-weight: 600;\n            color: white;\n            background-color: var(--primary);\n            border-radius: 12px;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 12px rgba(108, 92, 231, 0.3);\n            position: relative;\n        }\n        \n        .array-element::after {\n            content: attr(data-index);\n            position: absolute;\n            bottom: -25px;\n            font-size: 0.8rem;\n            color: var(--dark);\n            opacity: 0.7;\n        }\n        \n        .array-element.highlight {\n            background-color: var(--highlight);\n            transform: scale(1.1);\n            z-index: 2;\n            box-shadow: 0 6px 20px rgba(0, 206, 201, 0.4);\n        }\n        \n        .array-element.current {\n            background-color: var(--current);\n            transform: scale(1.1);\n            z-index: 2;\n            box-shadow: 0 6px 20px rgba(253, 121, 168, 0.4);\n        }\n        \n        .array-element.found {\n            background-color: var(--found);\n            transform: scale(1.2);\n            z-index: 3;\n            box-shadow: 0 8px 24px rgba(0, 184, 148, 0.5);\n            animation: pulse 0.5s ease-out 2;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 30px;\n        }\n        \n        button {\n            background-color: var(--primary);\n            color: white;\n            border: none;\n            padding: 12px 28px;\n            font-size: 1rem;\n            font-weight: 600;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 12px rgba(108, 92, 231, 0.3);\n            outline: none;\n            margin: 0 10px;\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 16px rgba(108, 92, 231, 0.3);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);\n            padding: 30px;\n            margin-bottom: 40px;\n        }\n        \n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 20px;\n            font-size: 1.8rem;\n        }\n        \n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 20px;\n            color: #555;\n        }\n        \n        .status {\n            text-align: center;\n            font-size: 1.2rem;\n            margin: 20px 0;\n            min-height: 30px;\n            font-weight: 600;\n            color: var(--primary);\n        }\n        \n        .jump-indicator {\n            position: absolute;\n            top: -30px;\n            left: 50%;\n            transform: translateX(-50%);\n            background-color: var(--current);\n            color: white;\n            padding: 5px 15px;\n            border-radius: 20px;\n            font-size: 0.9rem;\n            font-weight: 600;\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n        \n        .jump-indicator.visible {\n            opacity: 1;\n        }\n        \n        .complexity {\n            display: flex;\n            justify-content: space-around;\n            margin-top: 30px;\n        }\n        \n        .complexity-card {\n            background: white;\n            border-radius: 12px;\n            padding: 20px;\n            width: 30%;\n            text-align: center;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n        }\n        \n        .complexity-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);\n        }\n        \n        .complexity-card h3 {\n            color: var(--primary);\n            margin-bottom: 10px;\n        }\n        \n        .complexity-card p {\n            font-size: 1.5rem;\n            font-weight: 700;\n            color: var(--dark);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.2); }\n            100% { transform: scale(1); }\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 40px;\n            color: #777;\n            font-size: 0.9rem;\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2rem;\n            }\n            \n            .array-element {\n                width: 45px;\n                height: 45px;\n                font-size: 1rem;\n            }\n            \n            .complexity {\n                flex-direction: column;\n            }\n            \n            .complexity-card {\n                width: 100%;\n                margin-bottom: 15px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Jump Search Visualizer</h1>\n            <p class=\"subtitle\">An elegant demonstration of the Jump Search algorithm, which searches for a value in a sorted array by jumping ahead in fixed steps</p>\n        </header>\n        \n        <div class=\"visualizer\">\n            <div class=\"status\" id=\"status\">Ready to search</div>\n            <div class=\"array-container\" id=\"array-container\"></div>\n            <div class=\"controls\">\n                <button id=\"start-btn\">Start Search</button>\n                <button id=\"reset-btn\">Reset</button>\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>How Jump Search Works</h2>\n            <p>Jump Search is a searching algorithm for sorted arrays. The basic idea is to check fewer elements by jumping ahead by fixed steps.</p>\n            <p>1. First, it determines the optimal step size (typically √n)</p>\n            <p>2. Then it jumps through the array in these steps until it finds an interval where the target might be</p>\n            <p>3. Finally, it performs a linear search within that interval</p>\n            <p>Jump Search has a time complexity of O(√n), making it more efficient than linear search but less efficient than binary search.</p>\n            \n            <div class=\"complexity\">\n                <div class=\"complexity-card\">\n                    <h3>Time Complexity</h3>\n                    <p>O(√n)</p>\n                </div>\n                <div class=\"complexity-card\">\n                    <h3>Space Complexity</h3>\n                    <p>O(1)</p>\n                </div>\n                <div class=\"complexity-card\">\n                    <h3>Optimal Step</h3>\n                    <p>√n</p>\n                </div>\n            </div>\n        </div>\n        \n        <footer>\n            <p>Visualization of the Jump Search algorithm | Designed for aesthetic demonstration</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const arrayContainer = document.getElementById('array-container');\n            const startBtn = document.getElementById('start-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            const statusEl = document.getElementById('status');\n            \n            // Generate a sorted array of 20 elements\n            let array = [];\n            const arraySize = 20;\n            const targetValue = 42; // The value we'll search for\n            \n            // Initialize the array with random values (but sorted)\n            function initArray() {\n                array = [];\n                for (let i = 0; i < arraySize; i++) {\n                    array.push(Math.floor(Math.random() * 50) + 10);\n                }\n                array.sort((a, b) => a - b);\n                \n                // Make sure the target exists in the array\n                if (!array.includes(targetValue)) {\n                    const randomIndex = Math.floor(Math.random() * arraySize);\n                    array[randomIndex] = targetValue;\n                    array.sort((a, b) => a - b);\n                }\n                \n                renderArray();\n            }\n            \n            // Render the array visually\n            function renderArray() {\n                arrayContainer.innerHTML = '';\n                array.forEach((value, index) => {\n                    const element = document.createElement('div');\n                    element.className = 'array-element';\n                    element.textContent = value;\n                    element.dataset.index = index;\n                    element.id = `element-${index}`;\n                    arrayContainer.appendChild(element);\n                    \n                    // Add jump indicator\n                    const jumpIndicator = document.createElement('div');\n                    jumpIndicator.className = 'jump-indicator';\n                    jumpIndicator.textContent = 'Jump';\n                    element.appendChild(jumpIndicator);\n                });\n                \n                statusEl.textContent = `Looking for value: ${targetValue}`;\n            }\n            \n            // Perform jump search with visualization\n            async function jumpSearch() {\n                startBtn.disabled = true;\n                resetBtn.disabled = true;\n                \n                const n = array.length;\n                const step = Math.floor(Math.sqrt(n));\n                let prev = 0;\n                let found = false;\n                \n                // Find the block where element is present\n                statusEl.textContent = `Jumping through array in steps of ${step}...`;\n                \n                while (array[Math.min(step, n) - 1] < targetValue) {\n                    // Highlight current element\n                    const currentElement = document.getElementById(`element-${prev}`);\n                    currentElement.classList.add('current');\n                    \n                    // Show jump indicator\n                    const jumpIndicator = currentElement.querySelector('.jump-indicator');\n                    jumpIndicator.classList.add('visible');\n                    \n                    // Wait for animation\n                    await new Promise(resolve => setTimeout(resolve, 800));\n                    \n                    jumpIndicator.classList.remove('visible');\n                    currentElement.classList.remove('current');\n                    \n                    prev = step;\n                    step += Math.floor(Math.sqrt(n));\n                    \n                    if (prev >= n) {\n                        break;\n                    }\n                    \n                    // Highlight next jump position\n                    const nextElement = document.getElementById(`element-${Math.min(prev, n-1)}`);\n                    nextElement.classList.add('highlight');\n                    await new Promise(resolve => setTimeout(resolve, 500));\n                    nextElement.classList.remove('highlight');\n                }\n                \n                // Linear search in the found block\n                statusEl.textContent = `Performing linear search from index ${prev - Math.floor(Math.sqrt(n))} to ${Math.min(prev, n-1)}...`;\n                \n                while (array[prev] < targetValue) {\n                    const currentElement = document.getElementById(`element-${prev}`);\n                    currentElement.classList.add('current');\n                    await new Promise(resolve => setTimeout(resolve, 600));\n                    currentElement.classList.remove('current');\n                    prev++;\n                    \n                    if (prev === Math.min(step, n)) {\n                        break;\n                    }\n                }\n                \n                // If element is found\n                if (array[prev] === targetValue) {\n                    const foundElement = document.getElementById(`element-${prev}`);\n                    foundElement.classList.add('found');\n                    statusEl.textContent = `Found value ${targetValue} at index ${prev}!`;\n                    found = true;\n                } else {\n                    statusEl.textContent = `Value ${targetValue} not found in the array`;\n                }\n                \n                startBtn.disabled = false;\n                resetBtn.disabled = false;\n                return found;\n            }\n            \n            // Event listeners\n            startBtn.addEventListener('click', function() {\n                jumpSearch();\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                initArray();\n            });\n            \n            // Initialize\n            initArray();\n        });\n    </script>\n</body>\n</html>"
