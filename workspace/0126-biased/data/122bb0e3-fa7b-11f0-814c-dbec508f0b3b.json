    "content": "<html>\n<head>\n    <title>Binary Search</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: monospace;\n        }\n        #binary-search-container {\n            width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #binary-search-container h1 {\n            margin-top: 0;\n        }\n        #binary-search-container .controls {\n            margin-bottom: 20px;\n        }\n        #binary-search-container .control {\n            margin-bottom: 10px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #binary-search-container .control:hover {\n            background-color: #ccc;\n        }\n        #binary-search-container .slider {\n            width: 50%;\n            margin-bottom: 20px;\n        }\n        #binary-search-container .slider input[type=\"range\"] {\n            width: 100%;\n        }\n        #binary-search-container .slider input[type=\"range\"]::-webkit-slider-thumb {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 20px;\n            height: 20px;\n            background-color: #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #binary-search-container .slider input[type=\"range\"]::-moz-thumb {\n            width: 20px;\n            height: 20px;\n            background-color: #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #binary-search-container .slider input[type=\"range\"]::-ms-thumb {\n            width: 20px;\n            height: 20px;\n            background-color: #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #binary-search-container .slider input[type=\"range\"]::-ms-thumb-glow {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 20px;\n            height: 20px;\n            background-color: #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #binary-search-container .slider input[type=\"range\"]::-ms-thumb-glow-out {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 20px;\n            height: 20px;\n            background-color: #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"binary-search-container\">\n        <h1>Binary Search</h1>\n        <div class=\"controls\">\n            <button id=\"start-button\">Start</button>\n            <button id=\"reset-button\">Reset</button>\n            <div class=\"slider\">\n                <input type=\"range\" id=\"range-slider\" min=\"1\" max=\"100\" value=\"50\">\n                <label for=\"range-slider\">Range:</label>\n                <input type=\"range\" id=\"step-slider\" min=\"1\" max=\"100\" value=\"5\">\n                <label for=\"step-slider\">Step:</label>\n                <input type=\"range\" id=\"range-step-slider\" min=\"1\" max=\"100\" value=\"10\">\n                <label for=\"range-step-slider\">Range Step:</label>\n            </div>\n        </div>\n        <div class=\"result-container\">\n            <p id=\"result\"></p>\n        </div>\n    </div>\n\n    <script>\n        let range = 50;\n        let step = 5;\n        let result = '';\n\n        document.getElementById('start-button').addEventListener('click', start);\n        document.getElementById('reset-button').addEventListener('click', reset);\n\n        function start() {\n            let startValue = parseInt(document.getElementById('range-slider').value);\n            let endValue = parseInt(document.getElementById('step-slider').value);\n            let startValueStr = startValue.toString();\n            let endValueStr = endValue.toString();\n            let rangeStep = parseInt(document.getElementById('range-step-slider').value);\n            let rangeStepStr = rangeStep.toString();\n\n            let resultStr = '';\n            let stepValue = 0;\n\n            while (startValue >= endValue) {\n                resultStr += 'End of range\\n';\n                startValue -= rangeStep;\n                stepValue++;\n            }\n\n            while (startValue > endValue) {\n                resultStr += 'Start of range\\n';\n                startValue += rangeStep;\n                stepValue++;\n            }\n\n            while (stepValue > 0) {\n                let value = startValue;\n                let valueStr = value.toString();\n                resultStr += 'Step ' + valueStr + '\\n';\n\n                while (value >= endValue) {\n                    resultStr += 'End of range\\n';\n                    value -= rangeStep;\n                    stepValue--;\n                }\n\n                while (value < startValue) {\n                    resultStr += 'Start of range\\n';\n                    value += rangeStep;\n                    stepValue--;\n                }\n\n                startValue = value;\n                stepValue--;\n            }\n\n            document.getElementById('result').innerHTML = resultStr;\n        }\n\n        function reset() {\n            range = 50;\n            step = 5;\n            result = '';\n            document.getElementById('result').innerHTML = '';\n        }\n    </script>\n</body>\n</html>"
