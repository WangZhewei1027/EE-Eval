    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Load Balancing — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Poppins:wght@300;500;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071026;\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.65);\n    --accent-1: #6fffe9;\n    --accent-2: #8ea7ff;\n    --accent-3: #a98bff;\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --success: #7ef3b2;\n    --danger: #ff8aa1;\n    --transition: 500ms cubic-bezier(.2,.9,.3,1);\n  }\n  *{box-sizing:border-box}\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(138, 92, 255, 0.12), transparent 8%),\n                radial-gradient(900px 500px at 90% 90%, rgba(111, 255, 233, 0.05), transparent 6%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #eaf0ff;\n    font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow: hidden;\n    padding:32px;\n  }\n\n  .container{\n    max-width:1200px;\n    margin:0 auto;\n    position:relative;\n    height:calc(100vh - 64px);\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap:28px;\n    align-items:center;\n  }\n\n  /* Sidebar / Info */\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    border-radius:18px;\n    padding:28px;\n    backdrop-filter: blur(8px) saturate(120%);\n    box-shadow: 0 10px 30px rgba(2,8,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  .title{\n    font-family: Poppins, Inter;\n    font-size:28px;\n    margin:0 0 8px 0;\n    letter-spacing: -0.02em;\n    font-weight:700;\n    color: white;\n  }\n  .subtitle{\n    color: var(--muted);\n    margin:0 0 18px 0;\n    font-size:13px;\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:12px;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    cursor:pointer;\n    transition: all var(--transition);\n    display:inline-flex;\n    gap:9px;\n    align-items:center;\n    font-size:13px;\n    box-shadow: 0 6px 18px rgba(12,22,44,0.6);\n  }\n  .btn:active{ transform: translateY(1px) }\n  .btn-primary{\n    background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    color:#021022;\n    padding:12px 16px;\n  }\n  .btn-ghost{\n    background: transparent;\n    color:var(--muted);\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n\n  .desc{\n    color: rgba(255,255,255,0.72);\n    margin-top:16px;\n    font-size:13px;\n    line-height:1.45;\n  }\n\n  .stats{\n    margin-top:20px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:space-between;\n  }\n  .stat{\n    flex:1;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    padding:12px;\n    border-radius:10px;\n    text-align:center;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .stat h4{ margin:0; font-size:12px; color:var(--muted); font-weight:600 }\n  .stat p{ margin:4px 0 0 0; font-size:18px; font-weight:700; color:white }\n\n  /* Visual area */\n  .visual{\n    position:relative;\n    height:100%;\n    border-radius:18px;\n    overflow:visible;\n    padding:30px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .canvas{\n    width:100%;\n    height:100%;\n    border-radius:18px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .ground{\n    position:absolute;\n    inset:28px;\n    border-radius:18px;\n    pointer-events:none;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), transparent 30%);\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Central load balancer */\n  .lb{\n    position:relative;\n    width:160px;\n    height:160px;\n    border-radius:28px;\n    background: radial-gradient(60% 60% at 30% 30%, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.06);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    z-index:40;\n    box-shadow: 0 20px 60px rgba(4,12,28,0.6);\n    transition: transform var(--transition);\n  }\n  .lb .label{\n    font-weight:700;\n    font-size:14px;\n    letter-spacing:0.02em;\n    color:white;\n  }\n  .lb .mini{\n    font-size:12px;\n    color:var(--muted);\n    margin-top:6px;\n  }\n\n  /* decorative rings */\n  .ring{\n    position:absolute;\n    width:340px;\n    height:340px;\n    border-radius:50%;\n    pointer-events:none;\n    z-index:20;\n    filter: blur(12px) saturate(130%);\n    opacity:0.9;\n    transform: rotate(15deg);\n    background:\n      conic-gradient(from 45deg at 50% 50%, rgba(162,142,255,0.12), rgba(111,255,233,0.08), rgba(142,167,255,0.06));\n    mix-blend-mode: screen;\n  }\n\n  /* Servers */\n  .servers{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    z-index:30;\n  }\n  .server{\n    position:absolute;\n    width:120px;\n    height:110px;\n    transform: translate(-50%,-50%);\n    pointer-events:auto;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:12px;\n  }\n  .server .card{\n    width:86px;\n    height:86px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    display:grid;\n    place-items:center;\n    position:relative;\n    box-shadow: 0 12px 30px rgba(2,10,30,0.5);\n  }\n  .cpu{\n    width:66px;\n    height:66px;\n    border-radius:12px;\n    background: conic-gradient(var(--accent) var(--load), rgba(255,255,255,0.04) 0%);\n    display:grid;\n    place-items:center;\n    color:#021026;\n    font-weight:700;\n    font-size:13px;\n    transition: background var(--transition), transform var(--transition);\n  }\n  .server .name{\n    position:absolute;\n    bottom:-12px;\n    left:50%;\n    transform:translateX(-50%);\n    font-size:12px;\n    color:var(--muted);\n    width:100%;\n    text-align:center;\n  }\n\n  /* connections: animated strokes */\n  svg.connect{\n    position:absolute;\n    inset:0;\n    overflow:visible;\n    z-index:10;\n    pointer-events:none;\n  }\n  .conn-path{\n    fill:none;\n    stroke: linear-gradient(90deg, var(--accent-1), var(--accent-2));\n    stroke-linecap:round;\n    stroke-width:2;\n    opacity:0.18;\n  }\n\n  /* moving dots (requests) */\n  .dots{\n    position:absolute;\n    inset:0;\n    z-index:50;\n    pointer-events:none;\n  }\n\n  .dot{\n    position:absolute;\n    left:50%;\n    top:50%;\n    width:8px;\n    height:8px;\n    border-radius:50%;\n    background: radial-gradient(circle at 30% 30%, #fff, rgba(255,255,255,0.92) 10%, rgba(255,255,255,0.14) 35%),\n                linear-gradient(180deg, var(--accent-1), var(--accent-3));\n    box-shadow: 0 6px 20px rgba(110,255,233,0.12), 0 2px 6px rgba(0,0,0,0.6);\n    transform: translate(-50%, -50%) scale(0.9);\n    opacity:0;\n    animation-name: travel;\n    animation-iteration-count: infinite;\n    animation-timing-function: cubic-bezier(.2,.9,.3,1);\n    will-change: transform, opacity;\n  }\n\n  @keyframes travel{\n    0% { transform: translate(-50%,-50%) scale(.75); opacity:0; filter: blur(0px) }\n    8% { opacity:1 }\n    78% { opacity:0.95; filter: blur(0px) }\n    100% { transform: translate(calc(var(--tx)), calc(var(--ty))) scale(0.9); opacity:0 }\n  }\n\n  .legend{\n    margin-top:18px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:flex-start;\n  }\n  .legend .item{\n    display:flex;\n    gap:8px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .swatch{\n    width:12px;\n    height:12px;\n    border-radius:3px;\n    box-shadow: 0 6px 18px rgba(7,9,20,0.6);\n  }\n\n  footer.note{\n    position:absolute;\n    bottom:20px;\n    left:32px;\n    font-size:12px;\n    color:var(--muted);\n    z-index:70;\n  }\n\n  /* subtle hover */\n  .server:hover .card{ transform: translateY(-6px) scale(1.02) }\n  .lb:hover{ transform: translateY(-6px) }\n\n  /* paused state */\n  .paused .dot{ animation-play-state: paused !important; opacity:0.6 }\n\n  /* responsive */\n  @media (max-width:980px){\n    .container{ grid-template-columns: 1fr; height:auto; gap:18px; padding-bottom:40px; }\n    .visual{ order: -1; height:540px }\n    footer.note{ left:16px; bottom:8px }\n  }\n\n  /* reduced motion */\n  @media (prefers-reduced-motion: reduce){\n    .dot{ animation-duration: 2.5s !important; animation-iteration-count: 1; }\n    .lb, .server .card, .cpu{ transition: none; }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"panel\" aria-hidden=\"false\">\n      <h1 class=\"title\">Load Balancing</h1>\n      <p class=\"subtitle\">Evenly distributing traffic across a fleet of servers — quickly, reliably, beautifully.</p>\n\n      <div class=\"controls\" role=\"toolbar\" aria-label=\"controls\">\n        <button id=\"toggle\" class=\"btn btn-primary\" title=\"Play / Pause animation\">\n          <svg id=\"icon-play\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(1px)\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"#021022\"/></svg>\n          <span id=\"toggle-label\">Animate</span>\n        </button>\n        <button id=\"redistribute\" class=\"btn btn-ghost\" title=\"Balance loads\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\"><path d=\"M12 3v3M12 18v3M4.2 6.2l2.1 2.1M17.7 15.7l2.1 2.1M3 12h3M18 12h3M6.2 19.8l2.1-2.1M15.7 6.3l2.1-2.1\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>\n          Redistribute\n        </button>\n      </div>\n\n      <p class=\"desc\">This visual demonstrates how a central load balancer routes requests (bright pulses) to multiple servers. Watch as traffic flows, and press \"Redistribute\" to even the load across the fleet. Minimal controls — mostly an observational experience.</p>\n\n      <div class=\"stats\" aria-hidden=\"true\">\n        <div class=\"stat\">\n          <h4>Active Requests</h4>\n          <p id=\"stat-req\">46</p>\n        </div>\n        <div class=\"stat\">\n          <h4>Servers</h4>\n          <p>5</p>\n        </div>\n        <div class=\"stat\">\n          <h4>Balance</h4>\n          <p id=\"stat-balance\">Uneven</p>\n        </div>\n      </div>\n\n      <div class=\"legend\" aria-hidden=\"true\">\n        <div class=\"item\"><div class=\"swatch\" style=\"background: linear-gradient(90deg,var(--accent-1),var(--accent-2))\"></div> Incoming traffic</div>\n        <div class=\"item\"><div class=\"swatch\" style=\"background: linear-gradient(90deg,var(--accent-3), #6fffe9)\"></div> Server utilization</div>\n      </div>\n\n    </div>\n\n    <div class=\"visual\">\n      <div class=\"canvas\" id=\"canvas\">\n        <div class=\"ground\"></div>\n\n        <div class=\"ring\" style=\"left:unset; right:40px; top:28px; width:480px; height:480px; opacity:0.9;\"></div>\n        <div class=\"ring\" style=\"left:40px; top:80px; width:340px; height:340px; opacity:0.6; filter: blur(18px)\"></div>\n\n        <svg class=\"connect\" id=\"connections\" preserveAspectRatio=\"none\" viewBox=\"0 0 1200 700\" aria-hidden=\"true\">\n          <!-- paths will be injected -->\n        </svg>\n\n        <div class=\"servers\" id=\"servers\">\n          <!-- server nodes will be injected -->\n        </div>\n\n        <div class=\"dots\" id=\"dots\"></div>\n\n        <div class=\"lb\" id=\"lb\" role=\"img\" aria-label=\"Load balancer\">\n          <svg width=\"86\" height=\"86\" viewBox=\"0 0 120 120\" style=\"position:absolute; top:16px; left:20px; opacity:0.14; filter:blur(6px)\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#6fffe9\"/>\n                <stop offset=\"1\" stop-color=\"#8ea7ff\"/>\n              </linearGradient>\n            </defs>\n            <circle cx=\"60\" cy=\"60\" r=\"44\" stroke=\"url(#g1)\" stroke-width=\"6\" fill=\"none\"/>\n            <circle cx=\"60\" cy=\"60\" r=\"32\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"2\" fill=\"none\"/>\n          </svg>\n\n          <div style=\"width:76px;height:76px;border-radius:14px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); display:flex; align-items:center; justify-content:center; flex-direction:column; border:1px solid rgba(255,255,255,0.04);\">\n            <div class=\"label\">Balancer</div>\n            <div class=\"mini\">Round-robin • Health checks</div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n  <footer class=\"note\" aria-hidden=\"true\">Designed for clarity • Smooth animations • Minimal controls</footer>\n\n<script>\n(function(){\n  // Configuration\n  const serverCount = 5;\n  const initialLoads = [18, 6, 28, 12, 8]; // relative request counts\n  const maxDots = 36; // total moving dots cap\n  const dotSize = 8;\n  const canvas = document.getElementById('canvas');\n  const serversContainer = document.getElementById('servers');\n  const connectionsSVG = document.getElementById('connections');\n  const dotsContainer = document.getElementById('dots');\n  const statReq = document.getElementById('stat-req');\n  const statBalance = document.getElementById('stat-balance');\n  const toggleBtn = document.getElementById('toggle');\n  const toggleLabel = document.getElementById('toggle-label');\n  const redistributeBtn = document.getElementById('redistribute');\n  const root = document.documentElement;\n\n  let paused = false;\n  let loads = initialLoads.slice();\n  let dots = [];\n  let totalRequests = loads.reduce((a,b)=>a+b,0);\n\n  // Positioning\n  function placeServers(){\n    serversContainer.innerHTML = '';\n    connectionsSVG.innerHTML = '';\n\n    const rect = canvas.getBoundingClientRect();\n    const cx = rect.width/2;\n    const cy = rect.height/2;\n\n    // arrange servers in an arc\n    const radius = Math.min(rect.width, rect.height)*0.38;\n    const angleStart = -105 * Math.PI/180;\n    const angleEnd = 105 * Math.PI/180;\n\n    const positions = [];\n    for(let i=0;i<serverCount;i++){\n      const t = i/(serverCount-1 || 1);\n      const angle = angleStart + (angleEnd-angleStart)*t;\n      const x = cx + radius * Math.cos(angle);\n      const y = cy + radius * Math.sin(angle) - 12; // slight lift\n      positions.push({x,y,angle});\n    }\n\n    // Create server nodes\n    positions.forEach((pos,i)=>{\n      const el = document.createElement('div');\n      el.className = 'server';\n      el.style.left = pos.x + 'px';\n      el.style.top = pos.y + 'px';\n      el.setAttribute('data-index', i);\n      el.innerHTML = `\n        <div class=\"card\">\n          <div class=\"cpu\" id=\"cpu-${i}\" style=\"--load: 0%\">${Math.round(loads[i])}%</div>\n          <div class=\"name\">srv-${100+i}</div>\n        </div>\n      `;\n      serversContainer.appendChild(el);\n\n      // Create connection path\n      const path = createPath(cx, cy, pos.x, pos.y, i);\n      connectionsSVG.appendChild(path);\n    });\n\n    // update CPU visuals\n    updateCpuVisuals();\n\n    // prepare dots mapping\n    computeDotDistribution();\n  }\n\n  function createPath(x1,y1,x2,y2,index){\n    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n    const dx = x2 - x1;\n    const dy = y2 - y1;\n    const mx = x1 + dx * 0.45;\n    const my = y1 + dy * 0.45 - 30;\n    const qx = x1 + dx * 0.2;\n    const qy = y1 + dy * 0.2 - 10;\n    const d = `M ${x1} ${y1} C ${qx} ${qy}, ${mx} ${my}, ${x2} ${y2}`;\n    path.setAttribute('d', d);\n    path.setAttribute('stroke', 'url(#g'+index+')');\n    path.setAttribute('class','conn-path');\n    path.style.stroke = `rgba(255,255,255,0.06)`;\n    path.style.filter = `drop-shadow(0 6px 18px rgba(20,54,80,0.18))`;\n    return path;\n  }\n\n  // Update CPU ring backgrounds\n  function updateCpuVisuals(transition=true){\n    let total = loads.reduce((a,b)=>a+b,0);\n    totalRequests = total;\n    statReq.textContent = totalRequests;\n    const avg = total / serverCount;\n    let balanced = loads.every(l => Math.abs(l - avg) < 1.2);\n    statBalance.textContent = balanced ? 'Balanced' : 'Uneven';\n\n    for(let i=0;i<serverCount;i++){\n      const cpu = document.getElementById(`cpu-${i}`);\n      if(!cpu) continue;\n      const percent = Math.max(3, Math.round((loads[i] / Math.max(1,total)) * 100));\n      cpu.style.transition = transition ? 'background var(--transition), transform var(--transition)' : 'none';\n      // set conic-gradient percent\n      cpu.style.setProperty('--load', percent + '%');\n      cpu.textContent = percent + '%';\n      // set accent color shift depending on load\n      const hueMix = Math.min(1, loads[i]/(avg*2));\n      const accent = `linear-gradient(180deg, hsl(${180 - hueMix*60} 90% 66%), hsl(${260 - hueMix*40} 80% 70%))`;\n      cpu.style.background = `conic-gradient(${accent} ${percent}%, rgba(255,255,255,0.04) 0%)`;\n    }\n  }\n\n  // Dot management\n  function computeDotDistribution(){\n    // Remove existing dots\n    dotsContainer.innerHTML = '';\n    dots = [];\n\n    const rect = canvas.getBoundingClientRect();\n    const cx = rect.width/2;\n    const cy = rect.height/2;\n\n    let total = Math.max(1, loads.reduce((a,b)=>a+b,0));\n    // Determine dot counts per server proportionally, cap by maxDots\n    let desired = loads.map(l => Math.round((l / total) * maxDots));\n    // ensure at least 1 dot per server for visibility if load > 0\n    desired = desired.map((d,i)=> (loads[i]>0 && d===0) ? 1 : d );\n    // adjust rounding differences\n    let sum = desired.reduce((a,b)=>a+b,0);\n    while(sum > maxDots){\n      // remove from largest\n      let idx = desired.indexOf(Math.max(...desired));\n      if(desired[idx] > 1) desired[idx]--, sum--;\n      else break;\n    }\n    while(sum < Math.min(maxDots, totalRequests)){\n      let idx = desired.indexOf(Math.min(...desired));\n      desired[idx]++, sum++;\n    }\n\n    // get server positions from DOM\n    const serverEls = Array.from(document.querySelectorAll('.server'));\n    for(let i=0;i<serverEls.length;i++){\n      const srv = serverEls[i];\n      const rectSrv = srv.getBoundingClientRect();\n      const tx = rectSrv.left + rectSrv.width/2 - (canvas.getBoundingClientRect().left);\n      const ty = rectSrv.top + rectSrv.height/2 - (canvas.getBoundingClientRect().top);\n      const dx = Math.round(tx - cx);\n      const dy = Math.round(ty - cy);\n      // create dots\n      for(let d=0; d<desired[i]; d++){\n        const dot = document.createElement('div');\n        dot.className = 'dot';\n        // randomized timing to avoid uniform movement\n        const baseDur = 1.2 + Math.random()*1.6;\n        const dur = baseDur + (Math.random()*1.4);\n        const delay = (Math.random()*0.8);\n        dot.style.animationDuration = dur + 's';\n        dot.style.animationDelay = delay + 's';\n        // set translation target via CSS variables (final transform value)\n        // We'll use calc to translate relative to starting left/top set at center\n        dot.style.setProperty('--tx', dx + 'px');\n        dot.style.setProperty('--ty', dy + 'px');\n        // color variations\n        const t = Math.min(1, loads[i]/(total/Math.max(1,serverCount)));\n        const c1 = `rgba(${Math.round(111 + 80*t)}, ${Math.round(255 - 40*t)}, ${Math.round(233 + 6*t)}, 1)`;\n        dot.style.background = `radial-gradient(circle at 30% 30%, #fff, rgba(255,255,255,0.92) 10%, rgba(255,255,255,0.14) 35%), linear-gradient(180deg, ${c1}, rgba(170,140,255,1))`;\n        dot.style.opacity = 0;\n        dotsContainer.appendChild(dot);\n        dots.push({el:dot, toIndex:i});\n      }\n    }\n    // small stagger to avoid simultaneous fadeouts\n    // Pause state handling\n    if(paused){\n      document.body.classList.add('paused');\n    } else {\n      document.body.classList.remove('paused');\n    }\n  }\n\n  // Redistribute to even loads\n  function redistribute(){\n    const total = loads.reduce((a,b)=>a+b,0);\n    const avg = total / serverCount;\n    // smooth transition: scatter loads towards average gradually\n    for(let i=0;i<serverCount;i++){\n      const diff = avg - loads[i];\n      loads[i] = loads[i] + diff * 0.98; // almost instant but slightly smoothed\n    }\n    updateCpuVisuals();\n    computeDotDistribution();\n\n    // subtle center pulse\n    pulseCenter();\n  }\n\n  function pulseCenter(){\n    const lb = document.getElementById('lb');\n    lb.animate([\n      { transform: 'scale(1)' },\n      { transform: 'scale(1.06)' },\n      { transform: 'scale(1)' }\n    ], { duration: 620, easing: 'cubic-bezier(.2,.9,.3,1)' });\n  }\n\n  // Toggle animation\n  function toggle(){\n    paused = !paused;\n    if(paused){\n      document.body.classList.add('paused');\n      toggleBtn.classList.remove('btn-primary');\n      toggleBtn.classList.add('btn-ghost');\n      toggleLabel.textContent = 'Paused';\n    } else {\n      document.body.classList.remove('paused');\n      toggleBtn.classList.remove('btn-ghost');\n      toggleBtn.classList.add('btn-primary');\n      toggleLabel.textContent = 'Animate';\n    }\n  }\n\n  // Initialize dynamic layout\n  function init(){\n    placeServers();\n    // gentle auto-redistribute initially to create motion\n    setTimeout(()=>{ redistribute(); }, 800);\n    // occasional drift: simulate changing loads every few seconds\n    setInterval(()=>{\n      // random small perturbation\n      for(let i=0;i<serverCount;i++){\n        const change = (Math.random()-0.5) * 12;\n        loads[i] = Math.max(1, Math.round(Math.max(1, loads[i] + change)));\n      }\n      updateCpuVisuals(true);\n      computeDotDistribution();\n    }, 5200);\n\n    // minor heartbeat on LB\n    setInterval(()=>{ pulseCenter(); }, 2600);\n  }\n\n  // Event bindings\n  toggleBtn.addEventListener('click', ()=>{ toggle(); });\n  redistributeBtn.addEventListener('click', ()=>{ redistribute(); });\n\n  // Resize handling\n  let resizeTimer;\n  window.addEventListener('resize', ()=>{\n    clearTimeout(resizeTimer);\n    resizeTimer = setTimeout(()=>{\n      placeServers();\n    }, 220);\n  });\n\n  // start\n  init();\n\n})();\n</script>\n</body>\n</html>"
  },
  "messages": [
