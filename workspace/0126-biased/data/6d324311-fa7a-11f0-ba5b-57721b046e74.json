  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Abstract Syntax Tree Explorer</title>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            line-height: 1.5;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #000;\n            padding: 10px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 10px;\n        }\n        button, select, input {\n            padding: 5px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n            font-family: monospace;\n        }\n        .ast-visualization {\n            min-height: 300px;\n            border: 1px solid #000;\n            padding: 10px;\n            white-space: pre;\n            overflow: auto;\n        }\n        .node {\n            cursor: pointer;\n            margin-left: 20px;\n        }\n        .node:hover {\n            text-decoration: underline;\n        }\n        .selected {\n            font-weight: bold;\n        }\n        .properties {\n            margin-top: 10px;\n            padding: 5px;\n            border: 1px dashed #000;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Abstract Syntax Tree Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Code Input</h2>\n            <div class=\"controls\">\n                <select id=\"language-select\">\n                    <option value=\"javascript\">JavaScript</option>\n                    <option value=\"python\">Python</option>\n                    <option value=\"arithmetic\">Arithmetic Expressions</option>\n                </select>\n                <button id=\"parse-btn\">Parse Code</button>\n                <button id=\"random-example-btn\">Random Example</button>\n                <button id=\"clear-btn\">Clear</button>\n            </div>\n            <textarea id=\"code-input\">function add(a, b) {\n    return a + b;\n}</textarea>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>AST Visualization</h2>\n            <div class=\"controls\">\n                <button id=\"expand-all-btn\">Expand All</button>\n                <button id=\"collapse-all-btn\">Collapse All</button>\n                <select id=\"view-mode\">\n                    <option value=\"tree\">Tree View</option>\n                    <option value=\"json\">Raw JSON</option>\n                </select>\n                <label>\n                    Depth Limit: <input type=\"range\" id=\"depth-slider\" min=\"1\" max=\"10\" value=\"5\">\n                    <span id=\"depth-value\">5</span>\n                </label>\n            </div>\n            <div id=\"ast-visualization\" class=\"ast-visualization\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Node Properties</h2>\n            <div id=\"node-properties\" class=\"properties\">Select a node to view its properties</div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>AST Transformations</h2>\n            <div class=\"controls\">\n                <select id=\"transformation-select\">\n                    <option value=\"\">Select Transformation...</option>\n                    <option value=\"rename\">Rename Variable</option>\n                    <option value=\"remove\">Remove Node</option>\n                    <option value=\"insert\">Insert Node</option>\n                    <option value=\"optimize\">Optimize Arithmetic</option>\n                </select>\n                <input type=\"text\" id=\"transformation-param\" placeholder=\"Parameter\" disabled>\n                <button id=\"apply-transformation-btn\" disabled>Apply</button>\n                <button id=\"undo-btn\">Undo</button>\n                <button id=\"redo-btn\">Redo</button>\n            </div>\n            <div id=\"transformation-status\"></div>\n        </div>\n    </div>\n\n    <script>\n        // AST data and state management\n        let ast = null;\n        let astHistory = [];\n        let historyPointer = -1;\n        let selectedNodePath = [];\n        let collapsedNodes = new Set();\n        \n        // Example ASTs for different languages\n        const examples = {\n            javascript: [\n                `function add(a, b) { return a + b; }`,\n                `const x = 5 * (3 + 2); console.log(x);`,\n                `if (x > 10) { alert('Large'); } else { alert('Small'); }`\n            ],\n            python: [\n                `def greet(name):\\n    print(\"Hello\", name)`,\n                `x = [i*2 for i in range(10) if i % 2 == 0]`,\n                `class Point:\\n    def __init__(self, x, y):\\n        self.x = x\\n        self.y = y`\n            ],\n            arithmetic: [\n                `2 + 3 * 4`,\n                `(5 + 3) * (10 - 2)`,\n                `sqrt(9) + pow(2, 3)`\n            ]\n        };\n        \n        // Simple parser for demonstration purposes\n        function parseCode(code, language) {\n            if (language === 'arithmetic') {\n                return parseArithmeticExpression(code);\n            } else {\n                // In a real app, you would use a proper parser like Acorn for JavaScript\n                return mockParse(code, language);\n            }\n        }\n        \n        function mockParse(code, language) {\n            // This is a simplified mock parser for demonstration\n            const ast = {\n                type: 'Program',\n                language: language,\n                body: [],\n                range: [0, code.length],\n                loc: {\n                    start: { line: 1, column: 0 },\n                    end: { line: code.split('\\n').length, column: 0 }\n                }\n            };\n            \n            if (language === 'javascript') {\n                if (code.includes('function')) {\n                    ast.body.push({\n                        type: 'FunctionDeclaration',\n                        id: { type: 'Identifier', name: code.match(/function\\s+(\\w+)/)[1] },\n                        params: code.match(/\\(([^)]*)\\)/)[1].split(',').map(p => ({\n                            type: 'Identifier',\n                            name: p.trim()\n                        })),\n                        body: {\n                            type: 'BlockStatement',\n                            body: [{\n                                type: 'ReturnStatement',\n                                argument: {\n                                    type: 'BinaryExpression',\n                                    operator: '+',\n                                    left: { type: 'Identifier', name: 'a' },\n                                    right: { type: 'Identifier', name: 'b' }\n                                }\n                            }]\n                        }\n                    });\n                } else if (code.includes('if')) {\n                    ast.body.push({\n                        type: 'IfStatement',\n                        test: {\n                            type: 'BinaryExpression',\n                            operator: '>',\n                            left: { type: 'Identifier', name: 'x' },\n                            right: { type: 'Literal', value: 10 }\n                        },\n                        consequent: {\n                            type: 'BlockStatement',\n                            body: [{\n                                type: 'ExpressionStatement',\n                                expression: {\n                                    type: 'CallExpression',\n                                    callee: { type: 'Identifier', name: 'alert' },\n                                    arguments: [{ type: 'Literal', value: 'Large' }]\n                                }\n                            }]\n                        },\n                        alternate: {\n                            type: 'BlockStatement',\n                            body: [{\n                                type: 'ExpressionStatement',\n                                expression: {\n                                    type: 'CallExpression',\n                                    callee: { type: 'Identifier', name: 'alert' },\n                                    arguments: [{ type: 'Literal', value: 'Small' }]\n                                }\n                            }]\n                        }\n                    });\n                }\n            } else if (language === 'python') {\n                if (code.includes('def')) {\n                    ast.body.push({\n                        type: 'FunctionDef',\n                        name: code.match(/def\\s+(\\w+)/)[1],\n                        args: {\n                            type: 'arguments',\n                            args: code.match(/\\(([^)]*)\\)/)[1].split(',').map(p => ({\n                                type: 'arg',\n                                arg: p.trim()\n                            }))\n                        },\n                        body: [{\n                            type: 'Expr',\n                            value: {\n                                type: 'Call',\n                                func: { type: 'Name', id: 'print' },\n                                args: [\n                                    { type: 'Str', s: 'Hello' },\n                                    { type: 'Name', id: 'name' }\n                                ]\n                            }\n                        }]\n                    });\n                }\n            }\n            \n            return ast;\n        }\n        \n        function parseArithmeticExpression(expr) {\n            // Very simple arithmetic expression parser\n            const tokens = tokenize(expr);\n            let index = 0;\n            \n            function parseExpression() {\n                return parseAdditive();\n            }\n            \n            function parseAdditive() {\n                let left = parseMultiplicative();\n                \n                while (index < tokens.length && (tokens[index].type === 'PLUS' || tokens[index].type === 'MINUS')) {\n                    const operator = tokens[index].value;\n                    index++;\n                    const right = parseMultiplicative();\n                    left = {\n                        type: 'BinaryExpression',\n                        operator,\n                        left,\n                        right\n                    };\n                }\n                \n                return left;\n            }\n            \n            function parseMultiplicative() {\n                let left = parsePrimary();\n                \n                while (index < tokens.length && (tokens[index].type === 'MULTIPLY' || tokens[index].type === 'DIVIDE')) {\n                    const operator = tokens[index].value;\n                    index++;\n                    const right = parsePrimary();\n                    left = {\n                        type: 'BinaryExpression',\n                        operator,\n                        left,\n                        right\n                    };\n                }\n                \n                return left;\n            }\n            \n            function parsePrimary() {\n                if (tokens[index].type === 'NUMBER') {\n                    return { type: 'Literal', value: parseFloat(tokens[index++].value) };\n                } else if (tokens[index].type === 'LPAREN') {\n                    index++;\n                    const expr = parseExpression();\n                    if (tokens[index].type !== 'RPAREN') {\n                        throw new Error('Expected )');\n                    }\n                    index++;\n                    return expr;\n                } else if (tokens[index].type === 'IDENTIFIER') {\n                    const name = tokens[index++].value;\n                    if (tokens[index]?.type === 'LPAREN') {\n                        index++;\n                        const args = [];\n                        if (tokens[index].type !== 'RPAREN') {\n                            args.push(parseExpression());\n                            while (tokens[index].type === 'COMMA') {\n                                index++;\n                                args.push(parseExpression());\n                            }\n                        }\n                        if (tokens[index].type !== 'RPAREN') {\n                            throw new Error('Expected )');\n                        }\n                        index++;\n                        return {\n                            type: 'CallExpression',\n                            callee: { type: 'Identifier', name },\n                            arguments: args\n                        };\n                    } else {\n                        return { type: 'Identifier', name };\n                    }\n                } else {\n                    throw new Error('Unexpected token');\n                }\n            }\n            \n            const ast = {\n                type: 'Program',\n                language: 'arithmetic',\n                body: [{\n                    type: 'ExpressionStatement',\n                    expression: parseExpression()\n                }]\n            };\n            \n            return ast;\n        }\n        \n        function tokenize(expr) {\n            const tokens = [];\n            let i = 0;\n            \n            while (i < expr.length) {\n                const c = expr[i];\n                \n                if (c === ' ') {\n                    i++;\n                    continue;\n                }\n                \n                if (c === '+') {\n                    tokens.push({ type: 'PLUS', value: '+' });\n                    i++;\n                } else if (c === '-') {\n                    tokens.push({ type: 'MINUS', value: '-' });\n                    i++;\n                } else if (c === '*') {\n                    tokens.push({ type: 'MULTIPLY', value: '*' });\n                    i++;\n                } else if (c === '/') {\n                    tokens.push({ type: 'DIVIDE', value: '/' });\n                    i++;\n                } else if (c === '(') {\n                    tokens.push({ type: 'LPAREN', value: '(' });\n                    i++;\n                } else if (c === ')') {\n                    tokens.push({ type: 'RPAREN', value: ')' });\n                    i++;\n                } else if (c === ',') {\n                    tokens.push({ type: 'COMMA', value: ',' });\n                    i++;\n                } else if (/c/.test(c)) {\n                    let num = '';\n                    while (/[0-9.]/.test(expr[i])) {\n                        num += expr[i];\n                        i++;\n                    }\n                    tokens.push({ type: 'NUMBER', value: num });\n                } else if (/[a-zA-Z]/.test(c)) {\n                    let ident = '';\n                    while (/[a-zA-Z0-9]/.test(expr[i])) {\n                        ident += expr[i];\n                        i++;\n                    }\n                    tokens.push({ type: 'IDENTIFIER', value: ident });\n                } else {\n                    i++;\n                }\n            }\n            \n            return tokens;\n        }\n        \n        // AST visualization\n        function renderAST() {\n            const visualization = document.getElementById('ast-visualization');\n            const viewMode = document.getElementById('view-mode').value;\n            const depthLimit = parseInt(document.getElementById('depth-slider').value);\n            \n            if (viewMode === 'json') {\n                visualization.textContent = JSON.stringify(ast, null, 2);\n                return;\n            }\n            \n            if (!ast) {\n                visualization.textContent = 'No AST available. Parse some code first.';\n                return;\n            }\n            \n            visualization.innerHTML = '';\n            renderNode(visualization, ast, 0, depthLimit, []);\n        }\n        \n        function renderNode(container, node, depth, depthLimit, path) {\n            if (depth > depthLimit) return;\n            \n            const isCollapsed = collapsedNodes.has(path.join('.'));\n            const nodeElement = document.createElement('div');\n            nodeElement.className = 'node';\n            if (selectedNodePath.join('.') === path.join('.')) {\n                nodeElement.classList.add('selected');\n            }\n            \n            nodeElement.textContent = `${'  '.repeat(depth)}${node.type}`;\n            nodeElement.onclick = (e) => {\n                e.stopPropagation();\n                selectNode(path);\n            };\n            \n            container.appendChild(nodeElement);\n            \n            if (isCollapsed) {\n                const ellipsis = document.createElement('div');\n                ellipsis.textContent = `${'  '.repeat(depth + 1)}...`;\n                ellipsis.style.marginLeft = '20px';\n                container.appendChild(ellipsis);\n                return;\n            }\n            \n            if (typeof node === 'object' && node !== null) {\n                for (const key in node) {\n                    if (key === 'type' || key === 'loc' || key === 'range') continue;\n                    \n                    const value = node[key];\n                    if (Array.isArray(value)) {\n                        value.forEach((item, index) => {\n                            if (typeof item === 'object' && item !== null) {\n                                renderNode(container, item, depth + 1, depthLimit, [...path, key, index]);\n                            }\n                        });\n                    } else if (typeof value === 'object' && value !== null) {\n                        renderNode(container, value, depth + 1, depthLimit, [...path, key]);\n                    }\n                }\n            }\n        }\n        \n        function selectNode(path) {\n            selectedNodePath = path;\n            renderAST();\n            showNodeProperties(getNodeByPath(ast, path));\n        }\n        \n        function getNodeByPath(root, path) {\n            let node = root;\n            for (const key of path) {\n                if (Array.isArray(node)) {\n                    node = node[key];\n                } else {\n                    node = node[key];\n                }\n            }\n            return node;\n        }\n        \n        function showNodeProperties(node) {\n            const propsContainer = document.getElementById('node-properties');\n            \n            if (!node) {\n                propsContainer.textContent = 'No node selected';\n                return;\n            }\n            \n            let html = `<strong>${node.type}</strong><br><br>`;\n            \n            for (const key in node) {\n                if (key === 'type') continue;\n                const value = node[key];\n                html += `<strong>${key}:</strong> ${typeof value === 'object' ? JSON.stringify(value) : value}<br>`;\n            }\n            \n            propsContainer.innerHTML = html;\n        }\n        \n        // AST transformations\n        function applyTransformation() {\n            const transformation = document.getElementById('transformation-select').value;\n            const param = document.getElementById('transformation-param').value;\n            \n            if (!ast || !selectedNodePath.length) {\n                document.getElementById('transformation-status').textContent = 'No node selected for transformation';\n                return;\n            }\n            \n            // Save current state to history\n            saveToHistory();\n            \n            const node = selectedNodePath.reduce((obj, key) => obj[key], ast);\n            \n            try {\n                switch (transformation) {\n                    case 'rename':\n                        if (node.type === 'Identifier' || node.type === 'arg') {\n                            const oldName = node.name || node.arg;\n                            node.name = param;\n                            if (node.arg) node.arg = param;\n                            document.getElementById('transformation-status').textContent = \n                                `Renamed ${oldName} to ${param}`;\n                        } else {\n                            document.getElementById('transformation-status').textContent = \n                                'Can only rename identifier nodes';\n                        }\n                        break;\n                    case 'remove':\n                        const parentPath = selectedNodePath.slice(0, -1);\n                        const parent = parentPath.reduce((obj, key) => obj[key], ast);\n                        const lastKey = selectedNodePath[selectedNodePath.length - 1];\n                        \n                        if (Array.isArray(parent)) {\n                            parent.splice(lastKey, 1);\n                        } else {\n                            delete parent[lastKey];\n                        }\n                        \n                        document.getElementById('transformation-status').textContent = 'Node removed';\n                        selectedNodePath = [];\n                        break;\n                    case 'optimize':\n                        if (node.type === 'BinaryExpression') {\n                            if (node.left.type === 'Literal' && node.right.type === 'Literal') {\n                                const left = node.left.value;\n                                const right = node.right.value;\n                                let result;\n                                \n                                switch (node.operator) {\n                                    case '+': result = left + right; break;\n                                    case '-': result = left - right; break;\n                                    case '*': result = left * right; break;\n                                    case '/': result = left / right; break;\n                                }\n                                \n                                const parentPath = selectedNodePath.slice(0, -1);\n                                const parent = parentPath.reduce((obj, key) => obj[key], ast);\n                                const lastKey = selectedNodePath[selectedNodePath.length - 1];\n                                \n                                parent[lastKey] = { type: 'Literal', value: result };\n                                document.getElementById('transformation-status').textContent = \n                                    `Optimized to ${result}`;\n                            } else {\n                                document.getElementById('transformation-status').textContent = \n                                    'Can only optimize literal expressions';\n                            }\n                        } else {\n                            document.getElementById('transformation-status').textContent = \n                                'Can only optimize binary expressions';\n                        }\n                        break;\n                }\n                \n                renderAST();\n            } catch (e) {\n                document.getElementById('transformation-status').textContent = `Error: ${e.message}`;\n                undo(); // Revert if transformation failed\n            }\n        }\n        \n        // History management\n        function saveToHistory() {\n            // Remove any redo history\n            astHistory = astHistory.slice(0, historyPointer + 1);\n            \n            // Save current state\n            astHistory.push(JSON.parse(JSON.stringify(ast)));\n            historyPointer++;\n            \n            updateUndoRedoButtons();\n        }\n        \n        function undo() {\n            if (historyPointer <= 0) return;\n            \n            historyPointer--;\n            ast = JSON.parse(JSON.stringify(astHistory[historyPointer]));\n            \n            renderAST();\n            updateUndoRedoButtons();\n        }\n        \n        function redo() {\n            if (historyPointer >= astHistory.length - 1) return;\n            \n            historyPointer++;\n            ast = JSON.parse(JSON.stringify(astHistory[historyPointer]));\n            \n            renderAST();\n            updateUndoRedoButtons();\n        }\n        \n        function updateUndoRedoButtons() {\n            document.getElementById('undo-btn').disabled = historyPointer <= 0;\n            document.getElementById('redo-btn').disabled = historyPointer >= astHistory.length - 1;\n        }\n        \n        // Event listeners\n        document.getElementById('parse-btn').addEventListener('click', () => {\n            const code = document.getElementById('code-input').value;\n            const language = document.getElementById('language-select').value;\n            \n            try {\n                ast = parseCode(code, language);\n                saveToHistory();\n                renderAST();\n                document.getElementById('transformation-status').textContent = 'Code parsed successfully';\n            } catch (e) {\n                document.getElementById('transformation-status').textContent = `Parse error: ${e.message}`;\n            }\n        });\n        \n        document.getElementById('random-example-btn').addEventListener('click', () => {\n            const language = document.getElementById('language-select').value;\n            const examplesForLang = examples[language];\n            const randomExample = examplesForLang[Math.floor(Math.random() * examplesForLang.length)];\n            document.getElementById('code-input').value = randomExample;\n        });\n        \n        document.getElementById('clear-btn').addEventListener('click', () => {\n            document.getElementById('code-input').value = '';\n            ast = null;\n            astHistory = [];\n            historyPointer = -1;\n            selectedNodePath = [];\n            collapsedNodes = new Set();\n            renderAST();\n            document.getElementById('node-properties').textContent = 'Select a node to view its properties';\n            document.getElementById('transformation-status').textContent = '';\n        });\n        \n        document.getElementById('expand-all-btn').addEventListener('click', () => {\n            collapsedNodes = new Set();\n            renderAST();\n        });\n        \n        document.getElementById('collapse-all-btn').addEventListener('click', () => {\n            // Collapse all nodes except the root\n            collapsedNodes = new Set();\n            if (ast) {\n                function collectPaths(node, path) {\n                    if (typeof node === 'object' && node !== null) {\n                        for (const key in node) {\n                            if (key === 'type' || key === 'loc' || key === 'range') continue;\n                            \n                            const value = node[key];\n                            if (Array.isArray(value)) {\n                                value.forEach((item, index) => {\n                                    if (typeof item === 'object' && item !== null) {\n                                        collapsedNodes.add([...path, key, index].join('.'));\n                                        collectPaths(item, [...path, key, index]);\n                                    }\n                                });\n                            } else if (typeof value === 'object' && value !== null) {\n                                collapsedNodes.add([...path, key].join('.'));\n                                collectPaths(value, [...path, key]);\n                            }\n                        }\n                    }\n                }\n                \n                collectPaths(ast, []);\n            }\n            renderAST();\n        });\n        \n        document.getElementById('view-mode').addEventListener('change', renderAST);\n        \n        document.getElementById('depth-slider').addEventListener('input', (e) => {\n            document.getElementById('depth-value').textContent = e.target.value;\n            renderAST();\n        });\n        \n        document.getElementById('transformation-select').addEventListener('change', (e) => {\n            const paramInput = document.getElementById('transformation-param');\n            const applyBtn = document.getElementById('apply-transformation-btn');\n            \n            if (e.target.value) {\n                paramInput.disabled = e.target.value !== 'rename';\n                applyBtn.disabled = false;\n            } else {\n                paramInput.disabled = true;\n                applyBtn.disabled = true;\n            }\n        });\n        \n        document.getElementById('apply-transformation-btn').addEventListener('click', applyTransformation);\n        \n        document.getElementById('undo-btn').addEventListener('click', undo);\n        document.getElementById('redo-btn').addEventListener('click', redo);\n        \n        // Initialize\n        renderAST();\n    </script>\n</body>\n</html>"
  },
