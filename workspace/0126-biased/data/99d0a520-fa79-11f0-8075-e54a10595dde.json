    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Version Control Simulator</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #history { margin-top: 20px; }\n        #log { margin-top: 10px; }\n    </style>\n</head>\n<body>\n    <h1>Version Control Simulator</h1>\n    <input type=\"text\" id=\"fileInput\" placeholder=\"Enter file content\">\n    <button id=\"commitBtn\">Commit</button>\n    <button id=\"revertBtn\">Revert Last Commit</button>\n    <button id=\"resetBtn\">Reset to Base Version</button>\n    <button id=\"viewHistoryBtn\">View Commit History</button>\n    \n    <h2>Current Value</h2>\n    <div id=\"currentValue\" style=\"border: 1px solid black; padding: 10px;\">No content</div>\n    \n    <h2 id=\"historyHeader\">Commit History</h2>\n    <div id=\"history\"></div>\n    \n    <div id=\"log\"></div>\n\n    <script>\n        let commits = [];\n        let currentVersion = 0;\n        let baseVersionContent = '';\n\n        document.getElementById('commitBtn').onclick = function() {\n            const fileContent = document.getElementById('fileInput').value;\n            if (fileContent) {\n                commits.push({ version: currentVersion + 1, content: fileContent });\n                currentVersion++;\n                baseVersionContent = fileContent;\n                document.getElementById('currentValue').innerText = fileContent;\n                document.getElementById('log').innerText = 'Committed version ' + (currentVersion);\n                document.getElementById('fileInput').value = '';\n            }\n            else {\n                alert(\"Please enter file content to commit.\");\n            }\n        };\n\n        document.getElementById('revertBtn').onclick = function() {\n            if (commits.length > 0) {\n                commits.pop();\n                currentVersion = commits.length ? commits[commits.length - 1].version : 0;\n                const lastCommit = commits.length > 0 ? commits[commits.length - 1].content : '';\n                document.getElementById('currentValue').innerText = lastCommit || 'No content';\n                document.getElementById('log').innerText = 'Reverted to version ' + (currentVersion);\n            }\n            else {\n                alert(\"No commits to revert.\");\n            }\n        };\n\n        document.getElementById('resetBtn').onclick = function() {\n            commits = [];\n            currentVersion = 0;\n            baseVersionContent = '';\n            document.getElementById('currentValue').innerText = 'No content';\n            document.getElementById('log').innerText = 'Reset to base version';\n        };\n\n        document.getElementById('viewHistoryBtn').onclick = function() {\n            const historyDiv = document.getElementById('history');\n            historyDiv.innerHTML = '';\n            if (commits.length > 0) {\n                commits.forEach(commit => {\n                    const commitEntry = document.createElement('div');\n                    commitEntry.innerText = 'Version ' + commit.version + ': ' + commit.content;\n                    historyDiv.appendChild(commitEntry);\n                });\n            } else {\n                historyDiv.innerText = 'No commits made yet.';\n            }\n        };\n    </script>\n</body>\n</html>"
