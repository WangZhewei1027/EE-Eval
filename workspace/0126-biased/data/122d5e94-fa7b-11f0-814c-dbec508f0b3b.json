    "content": "<html>\n<head>\n    <title>Socket Programming Example</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #fff;\n        }\n        #output {\n            padding: 20px;\n            border: 1px solid #000;\n        }\n    </style>\n</head>\n<body>\n    <h1>Socket Programming Example</h1>\n    <div id=\"output\"></div>\n\n    <button id=\"start-btn\">Start</button>\n    <button id=\"stop-btn\">Stop</button>\n    <button id=\"reset-btn\">Reset</button>\n\n    <input id=\"input-field\" type=\"text\" placeholder=\"Enter message...\">\n    <button id=\"send-btn\">Send</button>\n\n    <div id=\"state-container\"></div>\n\n    <script>\n        let socket = null;\n        let state = \"idle\";\n\n        function start() {\n            if (!socket) {\n                socket = new WebSocket(\"ws://localhost:8080\");\n                socket.onopen = function() {\n                    console.log(\"Connected to server.\");\n                    socket.send(\"Hello, server!\");\n                };\n                socket.onmessage = function(event) {\n                    console.log(\"Received message from server:\", event.data);\n                    updateOutput(event.data);\n                };\n                socket.onclose = function() {\n                    console.log(\"Disconnected from server.\");\n                    socket = null;\n                };\n                socket.onerror = function(event) {\n                    console.log(\"Error occurred:\", event.error);\n                };\n            } else {\n                socket.send(\"Hello, client!\");\n            }\n        }\n\n        function stop() {\n            if (socket) {\n                socket.close();\n                socket = null;\n            }\n        }\n\n        function reset() {\n            state = \"idle\";\n            updateOutput(\"State: idle\");\n        }\n\n        function updateOutput(message) {\n            document.getElementById(\"output\").innerHTML = message;\n            if (state === \"idle\") {\n                document.getElementById(\"state-container\").innerHTML = \"State: idle\";\n            } else if (state === \"running\") {\n                document.getElementById(\"state-container\").innerHTML = \"State: running\";\n            } else if (state === \"stopped\") {\n                document.getElementById(\"state-container\").innerHTML = \"State: stopped\";\n            }\n        }\n\n        document.getElementById(\"start-btn\").addEventListener(\"click\", start);\n        document.getElementById(\"stop-btn\").addEventListener(\"click\", stop);\n        document.getElementById(\"reset-btn\").addEventListener(\"click\", reset);\n\n        function send() {\n            let message = document.getElementById(\"input-field\").value;\n            socket.send(message);\n        }\n    </script>\n</body>\n</html>"
