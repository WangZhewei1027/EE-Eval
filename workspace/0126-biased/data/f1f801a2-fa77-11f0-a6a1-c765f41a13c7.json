    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>OSI Model — Layered Architecture (Visual)</title>\n<style>\n  :root{\n    --bg1: #071029;\n    --bg2: #0d2233;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1: #7be4ff;\n    --accent-2: #9b8cff;\n    --accent-3: #ff9ab3;\n    --muted: rgba(255,255,255,0.65);\n    --glass-2: rgba(255,255,255,0.04);\n    --card-radius: 14px;\n    --shadow-1: 0 8px 30px rgba(4,10,20,0.6);\n    --shadow-2: 0 18px 60px rgba(2,6,12,0.65);\n    --font-sans: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  *{box-sizing:border-box}\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(123,228,255,0.06), transparent 10%),\n                radial-gradient(900px 500px at 90% 85%, rgba(155,140,255,0.04), transparent 10%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e8f3ff;\n    font-family: var(--font-sans);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated nebula background (pure CSS) */\n  .sky {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    opacity:0.9;\n    mix-blend-mode: screen;\n  }\n  .blob {\n    position:absolute;\n    width:520px;height:520px;\n    background: radial-gradient(circle at 30% 30%, rgba(156,139,255,0.18), rgba(123,228,255,0.08), transparent 45%);\n    filter: blur(40px);\n    transform: translate3d(0,0,0);\n    animation: float 18s ease-in-out infinite;\n    border-radius:50%;\n  }\n  .blob.b1{left:-120px;top:10%; animation-duration:22s;}\n  .blob.b2{right:-180px;bottom:5%; animation-duration:26s; transform-origin:center;}\n  .blob.b3{left:40%;top:55%; width:360px;height:360px; animation-duration:20s; background: radial-gradient(circle at 60% 40%, rgba(255,154,179,0.12), rgba(123,228,255,0.06));}\n  @keyframes float {\n    0% { transform: translate3d(0,0,0) scale(1) rotate(0deg);}\n    25%{ transform: translate3d(18px,-18px,0) scale(1.02) rotate(2deg);}\n    50%{ transform: translate3d(0,26px,0) scale(1) rotate(-1deg);}\n    75%{ transform: translate3d(-14px,-12px,0) scale(0.98) rotate(1deg);}\n    100%{ transform: translate3d(0,0,0) scale(1) rotate(0deg);}\n  }\n\n  /* Main stage */\n  .stage {\n    position:relative;\n    z-index:2;\n    width:100%;\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n  }\n\n  .card {\n    width:980px;\n    max-width:calc(100% - 56px);\n    border-radius:20px;\n    padding:36px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow-2);\n    backdrop-filter: blur(8px) saturate(120%);\n    border:1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:visible;\n  }\n\n  /* Title area */\n  .header {\n    display:flex;\n    align-items:flex-start;\n    justify-content:space-between;\n    gap:24px;\n    margin-bottom:18px;\n  }\n  .title {\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .title h1{\n    margin:0;\n    font-weight:700;\n    letter-spacing: -0.02em;\n    font-size:28px;\n    color: #f7fbff;\n  }\n  .title p{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Single control button (only one) */\n  .controls {\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .btn {\n    appearance:none;\n    border:0;\n    background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));\n    color: #f9fcff;\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    letter-spacing:0.02em;\n    cursor:pointer;\n    transition:transform .18s ease, box-shadow .18s ease, background .18s ease;\n    box-shadow: 0 6px 18px rgba(2,8,20,0.45);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    font-size:13px;\n    backdrop-filter: blur(6px);\n  }\n  .btn:active{ transform:translateY(2px); }\n  .btn .dot {\n    width:10px;height:10px;border-radius:50%;\n    background: linear-gradient(180deg,var(--accent-1),var(--accent-2));\n    box-shadow:0 6px 18px rgba(123,228,255,0.14), inset 0 -1px 0 rgba(255,255,255,0.08);\n  }\n\n  /* Visual stack area */\n  .visual {\n    margin-top:10px;\n    padding:28px;\n    display:flex;\n    gap:26px;\n    align-items:center;\n  }\n\n  .stack-wrap {\n    width:560px;\n    min-height:420px;\n    perspective:1400px;\n    position:relative;\n  }\n\n  .stack {\n    position:relative;\n    transform-style:preserve-3d;\n    width:100%;\n    height:100%;\n  }\n\n  .layer {\n    --i: 0;\n    --h: 68px;\n    position:absolute;\n    left:0;\n    right:0;\n    height:var(--h);\n    margin:auto;\n    top:calc(50% - var(--h) / 2);\n    border-radius: 12px;\n    display:flex;\n    align-items:center;\n    gap:18px;\n    padding:14px 18px;\n    color: #072032;\n    font-weight:700;\n    letter-spacing:0.02em;\n    transform-origin:center;\n    transition: transform 900ms cubic-bezier(.22,.9,.28,1), box-shadow 500ms, filter 400ms, opacity 350ms;\n    box-shadow: 0 10px 30px rgba(2,8,20,0.35);\n    backdrop-filter: blur(6px);\n    border:1px solid rgba(255,255,255,0.03);\n    cursor:default;\n  }\n\n  /* Colors and gradients by layer index (7..1) */\n  .layer[data-layer=\"7\"]{ background: linear-gradient(135deg, rgba(255,154,179,0.96), rgba(155,140,255,0.85)); color:white;}\n  .layer[data-layer=\"6\"]{ background: linear-gradient(135deg, rgba(155,140,255,0.92), rgba(123,228,255,0.86)); color:#041b27;}\n  .layer[data-layer=\"5\"]{ background: linear-gradient(135deg, rgba(123,228,255,0.9), rgba(130,220,180,0.85)); color:#042028;}\n  .layer[data-layer=\"4\"]{ background: linear-gradient(135deg, rgba(130,220,180,0.9), rgba(255,216,137,0.85)); color:#082018;}\n  .layer[data-layer=\"3\"]{ background: linear-gradient(135deg, rgba(255,216,137,0.9), rgba(255,154,179,0.85)); color:#231215;}\n  .layer[data-layer=\"2\"]{ background: linear-gradient(135deg, rgba(95,203,255,0.92), rgba(155,140,255,0.9)); color:#021427;}\n  .layer[data-layer=\"1\"]{ background: linear-gradient(135deg, rgba(38,70,255,0.9), rgba(95,203,255,0.86)); color:white;}\n\n  .layer .meta {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    min-width:0;\n  }\n  .num {\n    width:54px;height:54px;border-radius:10px;\n    display:flex;align-items:center;justify-content:center;\n    font-weight:800;\n    font-size:16px;\n    box-shadow: 0 8px 20px rgba(0,0,0,0.18);\n  }\n  .info {\n    display:flex;\n    flex-direction:column;\n    gap:2px;\n    min-width:0;\n  }\n  .name {\n    font-size:15px;\n    line-height:1;\n    white-space:nowrap;\n    overflow:hidden;\n    text-overflow:ellipsis;\n  }\n  .tag {\n    font-size:12px;\n    font-weight:600;\n    opacity:0.92;\n  }\n\n  /* Layout initial stacked offsets (centered stack) */\n  /* We'll use translateZ to create layered depth */\n  .layer[data-layer=\"7\"] { transform: translateY(-210px) translateZ(120px) rotateX(8deg); }\n  .layer[data-layer=\"6\"] { transform: translateY(-140px) translateZ(80px) rotateX(6deg); }\n  .layer[data-layer=\"5\"] { transform: translateY(-70px)  translateZ(40px) rotateX(4deg); }\n  .layer[data-layer=\"4\"] { transform: translateY(0px)    translateZ(0px)   rotateX(0deg); }\n  .layer[data-layer=\"3\"] { transform: translateY(70px)   translateZ(-20px) rotateX(-2deg); }\n  .layer[data-layer=\"2\"] { transform: translateY(140px)  translateZ(-40px) rotateX(-4deg); }\n  .layer[data-layer=\"1\"] { transform: translateY(210px)  translateZ(-60px) rotateX(-6deg); }\n\n  /* Layer content styling */\n  .num { background: rgba(0,0,0,0.08); color:inherit; font-weight:800; }\n  .layer[data-layer=\"7\"] .num,\n  .layer[data-layer=\"1\"] .num { background: rgba(255,255,255,0.08); color:inherit; }\n  .layer svg{ width:44px;height:44px; opacity:0.95; flex-shrink:0; }\n\n  /* Descriptions column */\n  .desc {\n    flex:1;\n    padding-left:18px;\n    color: rgba(255,255,255,0.95);\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n    align-items:flex-start;\n    opacity:0;\n    transform: translateY(6px);\n    transition: opacity 420ms ease, transform 420ms ease;\n    font-size:13px;\n    line-height:1.2;\n    max-width:320px;\n  }\n  .layer .desc .head{ font-weight:800; font-size:12px; text-transform:uppercase; opacity:0.95; letter-spacing:0.12em; color:inherit;}\n  .layer .desc .body{ font-weight:600; color: rgba(0,0,0,0.6); font-size:12px; padding:8px 10px; border-radius:8px; background: rgba(255,255,255,0.12); }\n\n  /* When expanded: fan out layers horizontally a little and show descriptions */\n  .card.expanded .layer[data-layer=\"7\"]{ transform: translateY(-250px) translateX(-60px) translateZ(180px) rotateX(10deg) rotateZ(-3deg) scale(1.02); }\n  .card.expanded .layer[data-layer=\"6\"]{ transform: translateY(-160px) translateX(-40px) translateZ(120px) rotateX(7deg) rotateZ(-2deg); }\n  .card.expanded .layer[data-layer=\"5\"]{ transform: translateY(-80px)  translateX(-20px) translateZ(60px)  rotateX(4deg) rotateZ(-1deg); }\n  .card.expanded .layer[data-layer=\"4\"]{ transform: translateY(0px)     translateX(0px)   translateZ(0px)    rotateX(0deg); filter: none; }\n  .card.expanded .layer[data-layer=\"3\"]{ transform: translateY(80px)    translateX(20px)  translateZ(-20px)  rotateX(-4deg) rotateZ(1deg); }\n  .card.expanded .layer[data-layer=\"2\"]{ transform: translateY(160px)   translateX(40px)  translateZ(-40px)  rotateX(-6deg) rotateZ(2deg); }\n  .card.expanded .layer[data-layer=\"1\"]{ transform: translateY(240px)   translateX(60px)  translateZ(-80px)  rotateX(-8deg) rotateZ(3deg) scale(1.01); }\n\n  .card.expanded .layer .desc{ opacity:1; transform: translateY(0); }\n\n  /* Hover highlight */\n  .layer:hover {\n    transform: translateY(calc(var(--ty,0))) scale(1.02);\n    box-shadow: 0 28px 68px rgba(2,12,30,0.5);\n    filter: saturate(1.06) drop-shadow(0 6px 18px rgba(0,0,0,0.28));\n  }\n\n  /* Connector vertical rail on right */\n  .rail {\n    width:1px;\n    height:420px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    position:relative;\n    border-radius:2px;\n    margin-left:22px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  .rail:before{\n    content:'';\n    position:absolute;\n    width:6px;height:6px;border-radius:50%;\n    background: radial-gradient(circle at 30% 30%, var(--accent-1), var(--accent-2));\n    box-shadow:0 10px 30px rgba(123,228,255,0.14), 0 0 20px rgba(155,140,255,0.06);\n    top:12%;\n    transform:translateY(0);\n    transition:transform 700ms cubic-bezier(.22,.9,.28,1);\n  }\n  /* small ticks corresponding to layers - aesthetic */\n  .tick {\n    position:absolute;\n    width:12px;height:12px;\n    left:50%;\n    transform:translateX(-50%);\n    border-radius:50%;\n    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.02);\n    display:block;\n  }\n  .tick.t7{top:9%;}\n  .tick.t6{top:22%;}\n  .tick.t5{top:36%;}\n  .tick.t4{top:50%;}\n  .tick.t3{top:64%;}\n  .tick.t2{top:78%;}\n  .tick.t1{top:92%;}\n\n  /* Descriptions panel on right for expanded view: decorative */\n  .panel {\n    width:360px;\n    min-height:420px;\n    padding:18px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: var(--shadow-1);\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    opacity:0.98;\n  }\n  .panel h3{ margin:0; font-size:13px; font-weight:700; color:var(--muted); }\n  .panel .note{ font-size:12px; color:rgba(255,255,255,0.85); line-height:1.35; font-weight:600; }\n  .panel .layer-desc {\n    margin-top:6px;\n    display:flex;\n    flex-direction:column;\n    gap:8px;\n    overflow:auto;\n    padding-right:6px;\n  }\n  .panel .row {\n    display:flex;\n    align-items:flex-start;\n    gap:12px;\n    padding:10px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .panel .row .rnum {\n    min-width:40px;height:40px;border-radius:8px;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;font-weight:800;\n    color:inherit;\n  }\n  .panel .row .rtext { font-size:13px; font-weight:700; color:rgba(255,255,255,0.95); }\n  .panel .small { font-size:12px; color:rgba(255,255,255,0.75); }\n\n  /* subtle shimmer overlay for aesthetic */\n  .shimmer {\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    background: linear-gradient(120deg, rgba(255,255,255,0.02), transparent 18%);\n    mix-blend-mode: overlay;\n    opacity:0.5;\n    z-index:3;\n    border-radius:20px;\n    mask-image: linear-gradient(180deg, transparent 0%, black 7%, black 93%, transparent 100%);\n  }\n\n  /* small responsive adjustments */\n  @media (max-width:980px){\n    .visual{flex-direction:column; align-items:center;}\n    .rail{display:none;}\n    .panel{width:100%;}\n    .stack-wrap{width:100%; min-height:520px;}\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"sky\" aria-hidden=\"true\">\n    <div class=\"blob b1\"></div>\n    <div class=\"blob b2\"></div>\n    <div class=\"blob b3\"></div>\n  </div>\n\n  <main class=\"stage\">\n    <section class=\"card\" id=\"card\" aria-labelledby=\"title\">\n      <div class=\"header\">\n        <div class=\"title\">\n          <h1 id=\"title\">OSI Model — Layered Architecture</h1>\n          <p>Elegant, conceptual visualization of the seven-layer Open Systems Interconnection model. Observe how responsibilities separate and stack visually.</p>\n        </div>\n\n        <div class=\"controls\" aria-hidden=\"false\">\n          <!-- Single control button (only one) -->\n          <button id=\"playBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Expand / Collapse visualization\">\n            <span class=\"dot\" aria-hidden=\"true\"></span>\n            <span id=\"btnText\">Explore Layers</span>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"visual\" role=\"img\" aria-label=\"OSI Model visualization\">\n        <div class=\"stack-wrap\" id=\"stackWrap\">\n          <div class=\"stack\" aria-hidden=\"false\">\n            <!-- Layer 7 - Application -->\n            <div class=\"layer\" data-layer=\"7\" style=\"z-index:110\">\n              <div class=\"meta\">\n                <div class=\"num\">7</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <defs></defs>\n                  <path d=\"M12 2v6M6 8v8a6 6 0 0012 0V8\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  <path d=\"M7 12h10\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Application</div>\n                  <div class=\"tag\">Interface for user-facing services</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">User interaction & APIs</div>\n                <div class=\"body\">Hosts applications enabling network-enabled services (HTTP, SMTP, SSH). Responsible for resource access and presentation triggers.</div>\n              </div>\n            </div>\n\n            <!-- Layer 6 - Presentation -->\n            <div class=\"layer\" data-layer=\"6\" style=\"z-index:109\">\n              <div class=\"meta\">\n                <div class=\"num\">6</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M4 7h16M4 12h16M4 17h16\" stroke=\"rgba(2,6,12,0.95)\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Presentation</div>\n                  <div class=\"tag\">Data representation & encoding</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">Translation, encryption</div>\n                <div class=\"body\">Formats, encodes, compresses, encrypts/decrypts data for applications — ensuring semantic interoperability.</div>\n              </div>\n            </div>\n\n            <!-- Layer 5 - Session -->\n            <div class=\"layer\" data-layer=\"5\" style=\"z-index:108\">\n              <div class=\"meta\">\n                <div class=\"num\">5</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M12 3v18M3 12h18\" stroke=\"rgba(2,6,12,0.95)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Session</div>\n                  <div class=\"tag\">Dialog control & synchronization</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">Connections & checkpoints</div>\n                <div class=\"body\">Manages sessions between applications: establishing, maintaining and terminating dialogues, with synchronization points.</div>\n              </div>\n            </div>\n\n            <!-- Layer 4 - Transport -->\n            <div class=\"layer\" data-layer=\"4\" style=\"z-index:107\">\n              <div class=\"meta\">\n                <div class=\"num\">4</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M3 12h18M7 8v8M17 8v8\" stroke=\"rgba(2,6,12,0.95)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Transport</div>\n                  <div class=\"tag\">Reliable transfer & segmentation</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">Flow control & reliability</div>\n                <div class=\"body\">Ensures error-free, ordered delivery (TCP/UDP); handles segmentation, reassembly and flow control between hosts.</div>\n              </div>\n            </div>\n\n            <!-- Layer 3 - Network -->\n            <div class=\"layer\" data-layer=\"3\" style=\"z-index:106\">\n              <div class=\"meta\">\n                <div class=\"num\">3</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M12 2l7 4v6l-7 4-7-4V6l7-4z\" stroke=\"rgba(2,6,12,0.95)\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"rgba(255,255,255,0.02)\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Network</div>\n                  <div class=\"tag\">Routing & addressing</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">Path selection & internetworking</div>\n                <div class=\"body\">Determines how data is transferred between nodes via IP addressing and routing across networks.</div>\n              </div>\n            </div>\n\n            <!-- Layer 2 - Data Link -->\n            <div class=\"layer\" data-layer=\"2\" style=\"z-index:105\">\n              <div class=\"meta\">\n                <div class=\"num\">2</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M3 7h18M3 17h18\" stroke=\"rgba(2,6,12,0.95)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  <path d=\"M12 7v10\" stroke=\"rgba(2,6,12,0.95)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Data Link</div>\n                  <div class=\"tag\">Framing & physical addressing</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">Reliable local transfer</div>\n                <div class=\"body\">Frames packets for local delivery, MAC addressing, error detection and sometimes correction on a single link.</div>\n              </div>\n            </div>\n\n            <!-- Layer 1 - Physical -->\n            <div class=\"layer\" data-layer=\"1\" style=\"z-index:104\">\n              <div class=\"meta\">\n                <div class=\"num\">1</div>\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M2 12h20\" stroke=\"rgba(255,255,255,0.95)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n                  <path d=\"M6 8v8M18 8v8\" stroke=\"rgba(255,255,255,0.95)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n                </svg>\n                <div class=\"info\">\n                  <div class=\"name\">Physical</div>\n                  <div class=\"tag\">Bits on the wire</div>\n                </div>\n              </div>\n              <div class=\"desc\">\n                <div class=\"head\">Electrical & mechanical interface</div>\n                <div class=\"body\">Physical signaling: cables, connectors, voltages, bit-level transmission and media characteristics.</div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n        <div class=\"rail\" aria-hidden=\"true\">\n          <span class=\"tick t7\"></span>\n          <span class=\"tick t6\"></span>\n          <span class=\"tick t5\"></span>\n          <span class=\"tick t4\"></span>\n          <span class=\"tick t3\"></span>\n          <span class=\"tick t2\"></span>\n          <span class=\"tick t1\"></span>\n        </div>\n\n        <aside class=\"panel\" aria-hidden=\"true\">\n          <h3>Layer Summaries</h3>\n          <div class=\"note\">A concise, aesthetic reference — tap 'Explore Layers' to expand the stack and reveal each layer's purpose.</div>\n          <div class=\"layer-desc\" id=\"layerList\" aria-hidden=\"true\">\n            <div class=\"row\"><div class=\"rnum\">7</div><div class=\"rtext\">Application — human-facing services and APIs</div></div>\n            <div class=\"row\"><div class=\"rnum\">6</div><div class=\"rtext\">Presentation — encoding, encryption, compression</div></div>\n            <div class=\"row\"><div class=\"rnum\">5</div><div class=\"rtext\">Session — dialogs, checkpoints, synchronization</div></div>\n            <div class=\"row\"><div class=\"rnum\">4</div><div class=\"rtext\">Transport — reliability, segmentation, flow control</div></div>\n            <div class=\"row\"><div class=\"rnum\">3</div><div class=\"rtext\">Network — routing, addressing, path selection</div></div>\n            <div class=\"row\"><div class=\"rnum\">2</div><div class=\"rtext\">Data Link — frames, MAC, local delivery</div></div>\n            <div class=\"row\"><div class=\"rnum\">1</div><div class=\"rtext\">Physical — wires, signals, media</div></div>\n          </div>\n          <div class=\"small\">Designed for clarity. Minimal interactivity — observe the layered architecture and expand for a refined visual explanation.</div>\n        </aside>\n      </div>\n\n      <div class=\"shimmer\" aria-hidden=\"true\"></div>\n    </section>\n  </main>\n\n<script>\n  (function(){\n    const card = document.getElementById('card');\n    const btn = document.getElementById('playBtn');\n    const btnText = document.getElementById('btnText');\n    let expanded = false;\n\n    // Toggle expand/collapse\n    btn.addEventListener('click', function(){\n      expanded = !expanded;\n      card.classList.toggle('expanded', expanded);\n      btn.setAttribute('aria-pressed', String(expanded));\n      if(expanded){\n        btnText.textContent = 'Collapse';\n        // reveal panel details to screen readers\n        document.querySelector('.panel').setAttribute('aria-hidden','false');\n        document.getElementById('layerList').setAttribute('aria-hidden','false');\n      } else {\n        btnText.textContent = 'Explore Layers';\n        document.querySelector('.panel').setAttribute('aria-hidden','true');\n        document.getElementById('layerList').setAttribute('aria-hidden','true');\n      }\n    });\n\n    // Gentle staggered float animations via JS to set CSS var for hover transform baseline\n    // Keep extremely minimal JS; purely decorative\n    const layers = Array.from(document.querySelectorAll('.layer'));\n    layers.forEach((el, idx) => {\n      // minor variance for motion blur effect by setting --ty property\n      el.style.setProperty('--ty', `${(idx - 3) * 2}px`);\n      // add small entrance fade-in\n      el.style.opacity = 0;\n      setTimeout(() => { el.style.transition += ', opacity 700ms ease'; el.style.opacity = 1; }, 80 + idx * 60);\n    });\n\n    // Keyboard accessibility: Enter/Space toggles button\n    btn.addEventListener('keydown', function(e){\n      if(e.key === 'Enter' || e.key === ' '){\n        e.preventDefault();\n        btn.click();\n      }\n    });\n\n    // On load: small automatic pulse to indicate interactivity, then settle\n    window.addEventListener('load', function(){\n      btn.animate([{ transform: 'scale(1)' }, { transform: 'scale(1.02)' }, { transform: 'scale(1)' }], { duration: 900, easing: 'cubic-bezier(.22,.9,.28,1)' });\n    });\n  })();\n</script>\n</body>\n</html>"
