    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>NP-Completeness — Visual Primer</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071024;\n    --accent-1:#7c5cff;\n    --accent-2:#00d4ff;\n    --glass: rgba(255,255,255,0.04);\n    --muted:#98a0b3;\n    --card:#0b1220;\n    --glass-2: rgba(255,255,255,0.02);\n    --radius:14px;\n    --ease: cubic-bezier(.22,.9,.27,1);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:\"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(900px 500px at 15% 10%, rgba(124,92,255,0.12), transparent 8%),\n                radial-gradient(700px 400px at 90% 90%, rgba(0,212,255,0.06), transparent 10%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2));\n    color:#dfe7f3;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:36px;\n    overflow:hidden;\n  }\n\n  /* Top controls */\n  .controls{\n    position:fixed;\n    right:36px;\n    top:36px;\n    display:flex;\n    gap:12px;\n    z-index:50;\n  }\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.06);\n    color:var(--accent-2);\n    padding:10px 14px;\n    border-radius:999px;\n    font-weight:600;\n    letter-spacing:0.4px;\n    box-shadow: 0 6px 18px rgba(3,8,23,0.6), inset 0 -2px 6px rgba(255,255,255,0.015);\n    cursor:pointer;\n    transition: transform .25s var(--ease), box-shadow .25s var(--ease);\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    font-size:14px;\n  }\n  .btn:active{transform:translateY(1px) scale(.996); box-shadow: 0 4px 12px rgba(3,8,23,0.55)}\n  .btn.secondary{ color: #bfc9d9; border-color: rgba(255,255,255,0.04); background: linear-gradient(180deg, rgba(0,0,0,0.18), rgba(255,255,255,0.01)); }\n\n  /* Layout */\n  .stage{\n    max-width:1200px;\n    margin:54px auto;\n    display:grid;\n    grid-template-columns: 1fr 460px;\n    gap:34px;\n    align-items:start;\n  }\n\n  /* Hero card (left) */\n  .hero{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:var(--radius);\n    padding:34px;\n    position:relative;\n    overflow:visible;\n    min-height:520px;\n    box-shadow: 0 10px 40px rgba(2,6,20,0.6);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .header{\n    display:flex;\n    align-items:center;\n    gap:20px;\n    margin-bottom:22px;\n  }\n  .logo{\n    width:92px;\n    height:92px;\n    border-radius:16px;\n    background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 8px 30px rgba(124,92,255,0.16);\n    transform:translateZ(0);\n    flex-shrink:0;\n  }\n  .logo h1{\n    margin:0;\n    font-family:\"Playfair Display\", serif;\n    font-weight:700;\n    color:white;\n    font-size:34px;\n    letter-spacing:-1px;\n    line-height:1;\n  }\n  .title{\n    flex:1;\n  }\n  .title h2{\n    margin:0;\n    font-size:20px;\n    font-weight:700;\n    color:#f5f8ff;\n    letter-spacing:-0.2px;\n  }\n  .title p{margin:6px 0 0;color:var(--muted);font-size:13px}\n\n  /* Decorative canvas / svg area */\n  .visual{\n    position:relative;\n    width:100%;\n    height:360px;\n    border-radius:12px;\n    margin-top:8px;\n    overflow:visible;\n    background:\n      radial-gradient(600px 200px at 20% 20%, rgba(124,92,255,0.06), transparent 10%),\n      linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0));\n    border: 1px solid rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Venn diagram and nodes */\n  svg.venn{width:84%; height:320px; display:block; filter: drop-shadow(0 18px 50px rgba(2,6,20,0.6));}\n\n  .circle{\n    mix-blend-mode:screen;\n    opacity:.92;\n  }\n\n  .node{\n    fill:transparent;\n    stroke:rgba(255,255,255,0.06);\n    stroke-width:1.5;\n  }\n\n  .label{\n    font-family:\"Inter\";\n    font-weight:600;\n    font-size:14px;\n    fill:#f7fbff;\n  }\n  .sub{\n    font-size:12px;\n    fill:rgba(255,255,255,0.75);\n    font-weight:600;\n  }\n\n  /* floating problem chips */\n  .chips{\n    position:absolute;\n    right:28px;\n    top:70px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    z-index:10;\n  }\n  .chip{\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:12px 14px;\n    width:220px;\n    color:#dfe7f3;\n    font-weight:700;\n    font-size:13px;\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n    transform-origin:right center;\n    transition: transform .6s var(--ease), opacity .5s var(--ease);\n    box-shadow: 0 8px 24px rgba(3,8,23,0.45);\n  }\n  .chip small{font-weight:600;color:var(--muted);font-size:12px}\n  .chip .dot{width:12px;height:12px;border-radius:50%}\n  .chip.sat .dot{background:linear-gradient(90deg,var(--accent-1),#ff8ab3)}\n  .chip.hc .dot{background:linear-gradient(90deg,#00d4ff,#4db6ff)}\n  .chip.kc .dot{background:linear-gradient(90deg,#ffd36b,#ff8a5b)}\n\n  /* side panel (right) */\n  .info{\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    padding:22px;\n    border-radius:var(--radius);\n    border:1px solid rgba(255,255,255,0.03);\n    min-height:520px;\n    box-shadow: 0 10px 40px rgba(2,6,20,0.6);\n  }\n  .info h3{\n    margin:0 0 8px 0;\n    font-weight:800;\n    letter-spacing:-0.4px;\n    font-size:18px;\n  }\n  .info p{color:var(--muted); margin:0 0 18px 0; font-size:13px}\n\n  .legend{\n    display:grid;\n    grid-template-columns:1fr;\n    gap:12px;\n    margin-top:8px;\n  }\n  .card{\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:12px;\n    border-radius:12px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .card h4{margin:0;font-size:14px;font-weight:700}\n  .card p{margin:0;color:var(--muted);font-size:12px}\n\n  /* complexity chart */\n  .chart{\n    margin-top:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:12px;\n    padding:16px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  svg.chart-svg{width:100%; height:120px; display:block; overflow:visible}\n  .axis{stroke:rgba(255,255,255,0.06); stroke-width:1.2}\n  .poly{stroke:rgba(124,92,255,0.92); stroke-width:3; fill:none; stroke-linecap:round}\n  .expo{stroke:rgba(0,212,255,0.92); stroke-width:3; fill:none; stroke-linecap:round; stroke-dasharray:6 6; stroke-linejoin:round}\n  .point{fill:#fff}\n  .curve-label{font-size:12px; fill:rgba(255,255,255,0.9); font-weight:700}\n\n  /* subtle animated particles */\n  .particles{\n    position:absolute;\n    left:12%;\n    top:6%;\n    width:80%;\n    height:88%;\n    pointer-events:none;\n    mix-blend-mode:screen;\n    z-index:0;\n    opacity:0.6;\n    filter:blur(6px);\n  }\n  .particle{fill:rgba(124,92,255,0.06)}\n  .particle.alt{fill:rgba(0,212,255,0.04)}\n\n  /* Reveal explanation panel (toggle) */\n  .explain{\n    margin-top:18px;\n    max-height:0;\n    opacity:0;\n    overflow:hidden;\n    transition: max-height .6s var(--ease), opacity .45s var(--ease) .06s;\n  }\n  body.show-explain .explain{\n    max-height:1000px;\n    opacity:1;\n  }\n  .explain h4{margin:0 0 8px 0;font-size:13px}\n  .explain p{color:var(--muted);font-size:13px;line-height:1.5;margin:0 0 12px 0}\n\n  /* animation control via paused class */\n  body.paused .chip{ transform: translateX(0) scale(1) translateZ(0); opacity:1}\n  .chip{ transform: translateX(12px) scale(.98) translateZ(0); opacity:.96 }\n  body.paused svg.venn .floating{ animation-play-state: paused }\n  body.paused .curve-anim { animation-play-state: paused }\n  body.paused .moving-dot{ animation-play-state: paused }\n\n  /* small responsive */\n  @media (max-width:1080px){\n    .stage{grid-template-columns:1fr; gap:18px}\n    .chips{position:absolute; right:18px; top:40px}\n    .info{min-height:400px}\n  }\n</style>\n</head>\n<body class=\"\">\n  <div class=\"controls\" aria-hidden=\"true\">\n    <button id=\"animateBtn\" class=\"btn\" title=\"Pause or play the animations\">Pause</button>\n    <button id=\"explainBtn\" class=\"btn secondary\" title=\"Reveal concise explanation\">Explain</button>\n  </div>\n\n  <div class=\"stage\" role=\"main\">\n    <section class=\"hero\" aria-labelledby=\"mainTitle\">\n      <div class=\"header\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <h1>NP</h1>\n        </div>\n        <div class=\"title\">\n          <h2 id=\"mainTitle\">NP-Completeness — A Visual Primer</h2>\n          <p>Elegant intuition about P, NP, and why some problems are at the heart of computational difficulty.</p>\n        </div>\n      </div>\n\n      <div class=\"visual\" role=\"img\" aria-label=\"Artistic Venn diagram illustrating P, NP, and NP-Complete\">\n        <svg class=\"venn\" viewBox=\"0 0 920 420\" preserveAspectRatio=\"xMidYMid meet\">\n          <!-- background soft lines -->\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n            </linearGradient>\n            <filter id=\"glow\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"b\"/>\n              <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n            </filter>\n          </defs>\n\n          <!-- Circles: P and NP overlapping -->\n          <g>\n            <ellipse class=\"circle\" cx=\"330\" cy=\"210\" rx=\"240\" ry=\"140\" fill=\"url(#g1)\" opacity=\"0.12\" transform=\"translate(-8,0)\" />\n            <ellipse class=\"circle\" cx=\"580\" cy=\"210\" rx=\"240\" ry=\"140\" fill=\"url(#g1)\" opacity=\"0.08\" transform=\"translate(8,0) rotate(2 580 210)\" />\n          </g>\n\n          <!-- Labels -->\n          <text x=\"210\" y=\"130\" class=\"label\">P</text>\n          <text x=\"610\" y=\"130\" class=\"label\">NP</text>\n          <text x=\"430\" y=\"190\" class=\"label\" opacity=\"0.95\">NP-Complete</text>\n          <text x=\"160\" y=\"165\" class=\"sub\">Efficiently solvable</text>\n          <text x=\"680\" y=\"165\" class=\"sub\">Polynomial-time verifiable</text>\n\n          <!-- Floating nodes representing problems -->\n          <!-- Nodes in P -->\n          <g class=\"floating\" style=\"transform-origin:330px 210px; animation: floatA 6s calc(-0.2s) infinite ease-in-out;\">\n            <circle cx=\"210\" cy=\"250\" r=\"10\" fill=\"#a9b6ff\" opacity=\"0.95\"></circle>\n            <text x=\"232\" y=\"256\" class=\"sub\" fill=\"#bcd0ff\">Sorting</text>\n          </g>\n\n          <g class=\"floating\" style=\"transform-origin:360px 200px; animation: floatA 5.4s calc(-0.5s) infinite ease-in-out;\">\n            <circle cx=\"340\" cy=\"190\" r=\"10\" fill=\"#b6eaff\" opacity=\"0.95\"></circle>\n            <text x=\"360\" y=\"196\" class=\"sub\" fill=\"#dffaff\">GCD</text>\n          </g>\n\n          <!-- Nodes in NP (but not known in P) -->\n          <g class=\"floating\" style=\"transform-origin:620px 210px; animation: floatB 6.4s calc(-0.3s) infinite ease-in-out;\">\n            <circle cx=\"700\" cy=\"250\" r=\"10\" fill=\"#7cffda\" opacity=\"0.95\"></circle>\n            <text x=\"722\" y=\"256\" class=\"sub\" fill=\"#dffef8\">Factorization*</text>\n          </g>\n\n          <!-- NP-Complete nodes in overlap -->\n          <g class=\"floating\" style=\"transform-origin:470px 215px; animation: floatC 5.9s infinite ease-in-out;\">\n            <circle cx=\"470\" cy=\"210\" r=\"14\" fill=\"#ffd36b\" stroke=\"#ffb84d\" stroke-width=\"1.4\"></circle>\n            <text x=\"496\" y=\"215\" class=\"sub\" fill=\"#fff3dd\">SAT</text>\n          </g>\n\n          <g class=\"floating\" style=\"transform-origin:490px 240px; animation: floatC 6.6s infinite ease-in-out;\">\n            <circle cx=\"490\" cy=\"240\" r=\"11\" fill=\"#ff8ab3\" stroke=\"#ff5e92\" stroke-width=\"1.2\"></circle>\n            <text x=\"510\" y=\"246\" class=\"sub\" fill=\"#fff1f6\">Clique</text>\n          </g>\n\n          <g class=\"floating\" style=\"transform-origin:450px 180px; animation: floatC 7s infinite ease-in-out;\">\n            <circle cx=\"450\" cy=\"180\" r=\"11\" fill=\"#8be4ff\" stroke=\"#3fd2ff\" stroke-width=\"1.2\"></circle>\n            <text x=\"470\" y=\"186\" class=\"sub\" fill=\"#f0fdff\">Ham Cycle</text>\n          </g>\n\n          <!-- Animated reduction arrows -->\n          <g opacity=\"0.92\">\n            <defs>\n              <marker id=\"arr\" markerWidth=\"8\" markerHeight=\"8\" refX=\"6\" refY=\"4\" orient=\"auto\">\n                <path d=\"M0,0 L8,4 L0,8 z\" fill=\"#ffffff\"></path>\n              </marker>\n            </defs>\n            <path d=\"M520 240 C 560 260, 620 270, 700 250\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.2\" fill=\"none\" marker-end=\"url(#arr)\" style=\"opacity:.9\"></path>\n            <text x=\"590\" y=\"260\" class=\"sub\" fill=\"rgba(255,255,255,0.6)\">reduction</text>\n            <path d=\"M480 220 C 430 260, 360 270, 300 250\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.2\" fill=\"none\" marker-end=\"url(#arr)\" style=\"opacity:.9\"></path>\n            <text x=\"350\" y=\"265\" class=\"sub\" fill=\"rgba(255,255,255,0.6)\">poly-time mapping</text>\n          </g>\n\n          <!-- subtle connectors -->\n          <g opacity=\"0.06\">\n            <line x1=\"470\" y1=\"210\" x2=\"490\" y2=\"240\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"></line>\n            <line x1=\"470\" y1=\"210\" x2=\"450\" y2=\"180\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"></line>\n          </g>\n\n          <!-- center halo -->\n          <ellipse cx=\"470\" cy=\"210\" rx=\"48\" ry=\"28\" fill=\"rgba(255,255,255,0.02)\"></ellipse>\n\n          <style>\n            @keyframes floatA { 0%{transform:translateY(0)}50%{transform:translateY(-8px)}100%{transform:translateY(0)} }\n            @keyframes floatB { 0%{transform:translateY(0) rotate(0)}50%{transform:translateY(-10px) rotate(1deg)}100%{transform:translateY(0)} }\n            @keyframes floatC { 0%{transform:translateY(0) scale(1)}50%{transform:translateY(-6px) scale(1.02)}100%{transform:translateY(0) scale(1)} }\n            .floating{ animation-timing-function: var(--ease); transform-origin:center; }\n          </style>\n        </svg>\n\n        <!-- chips listing classic NP-complete problems -->\n        <div class=\"chips\" aria-hidden=\"true\">\n          <div class=\"chip sat\">\n            <div style=\"display:flex;align-items:center;gap:10px\">\n              <div class=\"dot\"></div>\n              <div>\n                <div style=\"font-size:13px;font-weight:800\">SAT</div>\n                <small>Boolean satisfiability</small>\n              </div>\n            </div>\n            <div style=\"opacity:.9;color:#fff\">Core</div>\n          </div>\n\n          <div class=\"chip hc\">\n            <div style=\"display:flex;align-items:center;gap:10px\">\n              <div class=\"dot\"></div>\n              <div>\n                <div style=\"font-size:13px;font-weight:800\">Hamiltonian Cycle</div>\n                <small>Graph traversal</small>\n              </div>\n            </div>\n            <div style=\"opacity:.9;color:#fff\">NP-C</div>\n          </div>\n\n          <div class=\"chip kc\">\n            <div style=\"display:flex;align-items:center;gap:10px\">\n              <div class=\"dot\"></div>\n              <div>\n                <div style=\"font-size:13px;font-weight:800\">Clique / Vertex Cover</div>\n                <small>Combinatorial search</small>\n              </div>\n            </div>\n            <div style=\"opacity:.9;color:#fff\">NP-C</div>\n          </div>\n        </div>\n\n        <!-- soft particle field -->\n        <svg class=\"particles\" viewBox=\"0 0 1000 600\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n          <circle class=\"particle\" cx=\"120\" cy=\"80\" r=\"3\"/>\n          <circle class=\"particle alt\" cx=\"220\" cy=\"40\" r=\"4\"/>\n          <circle class=\"particle\" cx=\"420\" cy=\"120\" r=\"2.8\"/>\n          <circle class=\"particle alt\" cx=\"620\" cy=\"60\" r=\"4.2\"/>\n          <circle class=\"particle\" cx=\"820\" cy=\"150\" r=\"3.6\"/>\n          <circle class=\"particle alt\" cx=\"720\" cy=\"320\" r=\"2.9\"/>\n          <circle class=\"particle\" cx=\"520\" cy=\"300\" r=\"3.1\"/>\n          <circle class=\"particle alt\" cx=\"320\" cy=\"280\" r=\"3.8\"/>\n        </svg>\n      </div>\n\n      <!-- Complexity curves -->\n      <div class=\"chart\" aria-hidden=\"true\">\n        <svg class=\"chart-svg\" viewBox=\"0 0 920 130\" preserveAspectRatio=\"xMinYMin meet\">\n          <g transform=\"translate(20,10)\">\n            <line x1=\"0\" y1=\"100\" x2=\"880\" y2=\"100\" class=\"axis\" />\n            <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"100\" class=\"axis\" />\n            <path class=\"poly\" d=\"M0 95 C 80 82, 200 72, 320 62 C 460 52, 640 44, 880 36\" stroke-linejoin=\"round\" />\n            <path class=\"expo\" d=\"M0 95 C 80 85, 160 76, 240 66 C 320 54, 400 42, 480 28 C 560 12, 640 -4, 720 -22 C 800 -46, 880 -78\" transform=\"translate(0,20)\" />\n            <text x=\"720\" y=\"24\" class=\"curve-label\">Exponential</text>\n            <text x=\"500\" y=\"78\" class=\"curve-label\" fill=\"#cfc3ff\">Polynomial</text>\n\n            <!-- animated dots traversing curves -->\n            <circle class=\"point moving-dot\" r=\"6\" fill=\"rgba(124,92,255,0.98)\" cx=\"250\" cy=\"62\">\n              <animateMotion dur=\"9s\" repeatCount=\"indefinite\" path=\"M0 83 C 80 70, 200 60, 320 50 C 460 38, 640 30, 880 22\" />\n            </circle>\n            <circle class=\"point moving-dot\" r=\"5\" fill=\"rgba(0,212,255,0.96)\" cx=\"120\" cy=\"40\">\n              <animateMotion dur=\"9s\" repeatCount=\"indefinite\" path=\"M0 115 C 80 105, 160 96, 240 86 C 320 74, 400 62, 480 48 C 560 32, 640 18, 720 -2 C 800 -26, 880 -58\" />\n            </circle>\n          </g>\n        </svg>\n      </div>\n\n    </section>\n\n    <aside class=\"info\" aria-labelledby=\"sideTitle\">\n      <h3 id=\"sideTitle\">What this visualization conveys</h3>\n      <p>Observe how problems congregate: P problems are efficiently solvable; NP problems are efficiently verifiable. NP-Complete problems sit at the intersection of hardness and verifiability — they are the \"hardest\" in NP.</p>\n\n      <div class=\"legend\" role=\"list\">\n        <div class=\"card\" role=\"listitem\">\n          <div style=\"width:10px;height:40px;border-radius:6px;background:linear-gradient(180deg,var(--accent-1),var(--accent-2));box-shadow:0 6px 18px rgba(124,92,255,0.14)\"></div>\n          <div>\n            <h4>P</h4>\n            <p>Problems solvable in polynomial time (efficient).</p>\n          </div>\n        </div>\n\n        <div class=\"card\" role=\"listitem\">\n          <div style=\"width:10px;height:40px;border-radius:6px;background:linear-gradient(180deg,#00d4ff,#4db6ff);box-shadow:0 6px 18px rgba(0,212,255,0.12)\"></div>\n          <div>\n            <h4>NP</h4>\n            <p>Solutions verifiable in polynomial time given a certificate.</p>\n          </div>\n        </div>\n\n        <div class=\"card\" role=\"listitem\">\n          <div style=\"width:10px;height:40px;border-radius:6px;background:linear-gradient(180deg,#ffd36b,#ff8ab3);box-shadow:0 6px 18px rgba(255,140,123,0.12)\"></div>\n          <div>\n            <h4>NP-Complete</h4>\n            <p>Members of NP to which every problem in NP can be reduced in polynomial time.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"explain\" id=\"explain\" aria-hidden=\"true\">\n        <h4>Concise explanation</h4>\n        <p><strong>P</strong> are problems we can solve quickly (in polynomial time). <strong>NP</strong> are problems for which a proposed solution can be checked quickly.</p>\n        <p><strong>NP-Complete</strong> problems are the \"hard core\" of NP: if any NP-Complete problem has a polynomial-time algorithm, then every problem in NP does (P = NP). The Cook–Levin theorem established the first NP-Complete problem (Boolean satisfiability).</p>\n        <p style=\"margin-top:6px;color:var(--muted)\">Practical note: many real-world tasks reduce to NP-Complete problems, so we often use heuristics or approximation when exact polynomial-time solutions are unknown.</p>\n      </div>\n    </aside>\n  </div>\n\n<script>\n  (function(){\n    const animateBtn = document.getElementById('animateBtn');\n    const explainBtn = document.getElementById('explainBtn');\n    const body = document.body;\n    const explain = document.getElementById('explain');\n\n    // Initial state: animations playing\n    let paused = false;\n    let shown = false;\n\n    animateBtn.addEventListener('click', function(){\n      paused = !paused;\n      body.classList.toggle('paused', paused);\n      animateBtn.textContent = paused ? 'Play' : 'Pause';\n      animateBtn.style.color = paused ? 'var(--accent-1)' : 'var(--accent-2)';\n    });\n\n    explainBtn.addEventListener('click', function(){\n      shown = !shown;\n      body.classList.toggle('show-explain', shown);\n      explainBtn.textContent = shown ? 'Hide' : 'Explain';\n      explainBtn.setAttribute('aria-pressed', shown ? 'true' : 'false');\n    });\n\n    // Gentle entrance animations for chips and cards\n    window.requestAnimationFrame(()=> {\n      const chips = document.querySelectorAll('.chip');\n      chips.forEach((c,i)=> {\n        c.style.transitionDelay = (i*80)+'ms';\n        c.style.transform = 'translateX(0) scale(1)';\n        c.style.opacity = '1';\n      });\n    });\n\n    // Slight, single-run subtle shimmer on title\n    const logo = document.querySelector('.logo');\n    logo.animate([\n      { boxShadow: '0 8px 30px rgba(124,92,255,0.09)', transform:'scale(0.98)'},\n      { boxShadow: '0 18px 40px rgba(124,92,255,0.18)', transform:'scale(1)'}\n    ], { duration:900, easing:'cubic-bezier(.16,.9,.3,1)' });\n\n    // Accessible keyboard: allow toggle with Enter when focused\n    [animateBtn, explainBtn].forEach(b=>{\n      b.tabIndex = 0;\n      b.addEventListener('keyup', (e)=> {\n        if(e.key === 'Enter' || e.key === ' ') b.click();\n      });\n    });\n\n    // Minor performance-friendly stop for users who prefer reduced motion\n    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');\n    if(mq.matches){\n      body.classList.add('paused');\n      animateBtn.textContent = 'Play';\n    }\n  })();\n</script>\n</body>\n</html>"
