    "content": "<html>\n<head>\n    <title>Runtime Environment Simulator</title>\n    <script>\n        // Global state\n        let runtimeState = {\n            executionStack: [],\n            callStack: [],\n            heap: {},\n            eventQueue: [],\n            currentLine: 0,\n            variables: {},\n            breakpoints: [],\n            executionSpeed: 1,\n            isRunning: false,\n            isPaused: false\n        };\n\n        // Sample code\n        const sampleCode = `function factorial(n) {\n    if (n <= 1) return 1;\n    return n * factorial(n - 1);\n}\n\nfunction fibonacci(n) {\n    if (n <= 1) return n;\n    return fibonacci(n - 1) + fibonacci(n - 2);\n}\n\nfunction main() {\n    const num = 5;\n    const fact = factorial(num);\n    const fib = fibonacci(num);\n    console.log(fact, fib);\n}\n\nmain();`;\n\n        // Initialize\n        function init() {\n            document.getElementById('codeArea').value = sampleCode;\n            updateVisualization();\n        }\n\n        // Execution functions\n        function executeStep() {\n            if (runtimeState.currentLine >= runtimeState.executionStack.length) {\n                runtimeState.isRunning = false;\n                return;\n            }\n\n            const line = runtimeState.executionStack[runtimeState.currentLine];\n            processLine(line);\n            runtimeState.currentLine++;\n            updateVisualization();\n        }\n\n        function processLine(line) {\n            // Simplified line processing\n            if (line.includes('=')) {\n                const [varName, value] = line.split('=').map(s => s.trim());\n                runtimeState.variables[varName] = eval(value);\n            } else if (line.includes('function')) {\n                const funcName = line.split('function')[1].split('(')[0].trim();\n                runtimeState.callStack.push(funcName);\n            } else if (line.includes('return')) {\n                runtimeState.callStack.pop();\n            }\n        }\n\n        function runCode() {\n            const code = document.getElementById('codeArea').value;\n            runtimeState.executionStack = code.split('\\n').filter(line => line.trim() !== '');\n            runtimeState.currentLine = 0;\n            runtimeState.variables = {};\n            runtimeState.callStack = [];\n            runtimeState.isRunning = true;\n            runtimeState.isPaused = false;\n            updateVisualization();\n        }\n\n        function pauseExecution() {\n            runtimeState.isPaused = !runtimeState.isPaused;\n            updateVisualization();\n        }\n\n        function stopExecution() {\n            runtimeState.isRunning = false;\n            runtimeState.isPaused = false;\n            updateVisualization();\n        }\n\n        function setBreakpoint() {\n            const lineNum = parseInt(document.getElementById('breakpointLine').value);\n            if (!isNaN(lineNum) && !runtimeState.breakpoints.includes(lineNum)) {\n                runtimeState.breakpoints.push(lineNum);\n                runtimeState.breakpoints.sort((a, b) => a - b);\n                updateVisualization();\n            }\n        }\n\n        function clearBreakpoints() {\n            runtimeState.breakpoints = [];\n            updateVisualization();\n        }\n\n        function changeSpeed() {\n            runtimeState.executionSpeed = parseInt(document.getElementById('speedControl').value);\n        }\n\n        function inspectVariable() {\n            const varName = document.getElementById('inspectVar').value;\n            const value = runtimeState.variables[varName];\n            document.getElementById('inspectionResult').innerText = value !== undefined ? \n                `${varName} = ${value}` : 'Variable not found';\n        }\n\n        function updateVisualization() {\n            // Update call stack display\n            const callStackElement = document.getElementById('callStack');\n            callStackElement.innerHTML = runtimeState.callStack.map(f => `<div>${f}()</div>`).join('');\n\n            // Update variables display\n            const variablesElement = document.getElementById('variables');\n            variablesElement.innerHTML = Object.entries(runtimeState.variables)\n                .map(([k, v]) => `<div>${k} = ${v}</div>`).join('');\n\n            // Update execution status\n            document.getElementById('executionStatus').innerText = \n                runtimeState.isRunning ? \n                    (runtimeState.isPaused ? 'Paused' : 'Running') : \n                    'Stopped';\n\n            // Update current line highlight\n            const codeLines = document.getElementById('codeArea').value.split('\\n');\n            document.getElementById('codePreview').innerHTML = codeLines\n                .map((line, i) => {\n                    let lineClass = '';\n                    if (i === runtimeState.currentLine && runtimeState.isRunning) {\n                        lineClass = 'current-line';\n                    } else if (runtimeState.breakpoints.includes(i)) {\n                        lineClass = 'breakpoint';\n                    }\n                    return `<div class=\"${lineClass}\">${line}</div>`;\n                })\n                .join('');\n        }\n\n        // Auto-execute when running\n        function autoStep() {\n            if (runtimeState.isRunning && !runtimeState.isPaused) {\n                if (runtimeState.breakpoints.includes(runtimeState.currentLine)) {\n                    runtimeState.isPaused = true;\n                } else {\n                    executeStep();\n                }\n            }\n            setTimeout(autoStep, 1000 / runtimeState.executionSpeed);\n        }\n\n        // Start auto-stepping\n        window.onload = function() {\n            init();\n            autoStep();\n        };\n    </script>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            background: white;\n            color: black;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 10px;\n        }\n        .panel {\n            border: 1px solid black;\n            padding: 10px;\n            margin-bottom: 10px;\n        }\n        .controls {\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n        }\n        button, input, select {\n            padding: 5px;\n        }\n        textarea {\n            width: 100%;\n            height: 200px;\n            font-family: monospace;\n        }\n        .current-line {\n            background: #f0f0f0;\n            font-weight: bold;\n        }\n        .breakpoint {\n            background: #f0f0f0;\n            border-left: 3px solid red;\n            padding-left: 3px;\n        }\n        .visualization {\n            display: flex;\n            gap: 20px;\n        }\n        .visualization-panel {\n            flex: 1;\n            min-height: 200px;\n            overflow: auto;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Runtime Environment Simulator</h1>\n        \n        <div class=\"panel\">\n            <h2>Code Editor</h2>\n            <textarea id=\"codeArea\"></textarea>\n            <div id=\"codePreview\" class=\"panel\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Execution Controls</h2>\n            <div class=\"controls\">\n                <button onclick=\"runCode()\">Run</button>\n                <button onclick=\"executeStep()\">Step</button>\n                <button onclick=\"pauseExecution()\">Pause/Resume</button>\n                <button onclick=\"stopExecution()\">Stop</button>\n                <input type=\"range\" id=\"speedControl\" min=\"1\" max=\"10\" value=\"1\" onchange=\"changeSpeed()\">\n                <span>Speed: <span id=\"speedValue\">1</span>x</span>\n            </div>\n            <div>\n                Status: <span id=\"executionStatus\">Stopped</span>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Debugging Tools</h2>\n            <div class=\"controls\">\n                <input type=\"number\" id=\"breakpointLine\" placeholder=\"Line number\">\n                <button onclick=\"setBreakpoint()\">Set Breakpoint</button>\n                <button onclick=\"clearBreakpoints()\">Clear All Breakpoints</button>\n            </div>\n            <div class=\"controls\">\n                <input type=\"text\" id=\"inspectVar\" placeholder=\"Variable name\">\n                <button onclick=\"inspectVariable()\">Inspect</button>\n                <span id=\"inspectionResult\"></span>\n            </div>\n        </div>\n        \n        <div class=\"visualization\">\n            <div class=\"panel visualization-panel\">\n                <h2>Call Stack</h2>\n                <div id=\"callStack\"></div>\n            </div>\n            <div class=\"panel visualization-panel\">\n                <h2>Variables</h2>\n                <div id=\"variables\"></div>\n            </div>\n        </div>\n    </div>\n</body>\n</html>"
