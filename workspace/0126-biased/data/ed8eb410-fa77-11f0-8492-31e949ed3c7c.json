    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deadlock Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(90deg, #1a1a1a, #414141);\n            margin: 0;\n            height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n            color: #e0e0e0;\n            transition: background 0.5s ease-in-out;\n        }\n        .container {\n            text-align: center;\n            border-radius: 16px;\n            padding: 20px;\n            box-shadow: 0 4px 40px rgba(0, 0, 0, 0.5);\n            background: rgba(30, 30, 30, 0.8);\n        }\n        h1 {\n            font-size: 3em;\n            margin-bottom: 20px;\n            color: #ffffff;\n            animation: fadeIn 2s ease-in-out;\n        }\n        p {\n            font-size: 1.5em;\n            margin-bottom: 30px;\n            animation: slideIn 2s ease-in-out;\n        }\n        .button {\n            background: #ff5252;\n            border: none;\n            border-radius: 8px;\n            padding: 12px 24px;\n            font-size: 1.2em;\n            color: white;\n            cursor: pointer;\n            transition: background 0.3s, transform 0.3s;\n        }\n        .button:hover {\n            background: #ff7878;\n            transform: scale(1.05);\n        }\n        canvas {\n            margin-top: 20px;\n            border-radius: 10px;\n            box-shadow: 0 4px 40px rgba(0, 0, 0, 0.5);\n        }\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        @keyframes slideIn {\n            from { transform: translateY(-20px); opacity: 0; }\n            to { transform: translateY(0); opacity: 1; }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Deadlock Visualization</h1>\n        <p>Discover how deadlock occurs in systems through this interactive visualization.</p>\n        <button class=\"button\" id=\"start\">Start Visualization</button>\n        <canvas id=\"canvas\" width=\"400\" height=\"400\"></canvas>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n        let deadlocked = false;\n\n        function draw() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n            ctx.fillStyle = deadlocked ? '#ff5252' : '#4caf50';\n            ctx.beginPath();\n            ctx.arc(canvas.width / 2, canvas.height / 2, 50, 0, Math.PI * 2);\n            ctx.fill();\n            ctx.fillStyle = '#fff';\n            ctx.font = '20px Arial';\n            ctx.fillText(deadlocked ? 'Deadlock' : 'Running', canvas.width / 2 - 40, canvas.height / 2 + 8);\n        }\n\n        document.getElementById('start').addEventListener('click', () => {\n            deadlocked = !deadlocked; // Toggle state\n            draw();\n        });\n        \n        // Initial draw\n        draw();\n    </script>\n</body>\n</html>"
