    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>A* Search — Visual Exploration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071226;\n    --glass: rgba(255,255,255,0.04);\n    --accent: #7dd3fc;\n    --accent-2: #7c3aed;\n    --muted: rgba(255,255,255,0.65);\n    --card-bg: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n  }\n  html,body{height:100%;margin:0;background:radial-gradient(1200px 600px at 10% 10%, rgba(124,58,237,0.12), transparent), radial-gradient(900px 400px at 90% 90%, rgba(125,211,252,0.06), transparent), linear-gradient(180deg,var(--bg1),var(--bg2)); font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color:#e6eef8;}\n  .wrap{\n    display:grid;\n    grid-template-columns: 430px 1fr;\n    gap:32px;\n    align-items:stretch;\n    padding:48px;\n    height:100vh;\n    box-sizing:border-box;\n  }\n\n  .panel{\n    background:var(--card-bg);\n    border-radius:18px;\n    padding:28px;\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  header.title{\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n  }\n  .title h1{\n    margin:0;\n    font-family: \"Playfair Display\", serif;\n    font-size:34px;\n    letter-spacing: -0.6px;\n    color:linear-gradient(#fff,#ddd);\n    text-shadow: 0 6px 30px rgba(124,58,237,0.18);\n  }\n  .title p{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .meta{\n    margin-top:18px;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n  }\n  .meta .desc{\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.35;\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    --b:#ffffff12;\n    appearance:none;\n    border:1px solid rgba(255,255,255,0.06);\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:10px 14px;\n    border-radius:10px;\n    color:#e6eef8;\n    font-weight:600;\n    letter-spacing:0.3px;\n    cursor:pointer;\n    box-shadow: 0 4px 18px rgba(2,6,23,0.45);\n    transition: transform .18s ease, box-shadow .18s ease, opacity .12s ease;\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    font-size:13px;\n  }\n  .btn:hover{ transform: translateY(-3px); box-shadow: 0 10px 30px rgba(2,6,23,0.55); }\n  .btn:active{ transform: translateY(-1px); }\n\n  .btn.secondary{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border: 1px solid rgba(255,255,255,0.035);\n  }\n\n  .legend{\n    margin-top:22px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .chip{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    padding:8px 10px;\n    border-radius:12px;\n    background:rgba(255,255,255,0.016);\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n  .swatch{ width:12px;height:12px;border-radius:4px;box-shadow: 0 6px 12px rgba(0,0,0,0.4) inset; }\n\n  .description{\n    margin-top:18px;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.5;\n  }\n\n  /* RIGHT VISUAL */\n  .visual{\n    position:relative;\n    overflow:hidden;\n    border-radius:18px;\n    background: linear-gradient(180deg, rgba(7,14,30,0.36), rgba(6,9,22,0.55));\n    box-shadow: 0 20px 60px rgba(2,6,23,0.7), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  canvas#scene{\n    width:100%;\n    height:100%;\n    display:block;\n  }\n\n  .overlay{\n    position:absolute;\n    left:34px;\n    top:34px;\n    color:rgba(255,255,255,0.9);\n    font-weight:600;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    z-index:5;\n  }\n  .badge{\n    padding:10px 14px;\n    border-radius:12px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    font-size:13px;\n  }\n\n  .footer{\n    position:absolute;\n    right:28px;\n    bottom:22px;\n    color:rgba(255,255,255,0.7);\n    font-size:12px;\n    display:flex;\n    align-items:center;\n    gap:12px;\n    z-index:6;\n  }\n\n  .credits{\n    opacity:0.9;\n  }\n\n  /* subtle animated glows */\n  .visual::before{\n    content:'';\n    position:absolute;\n    inset:0;\n    background: radial-gradient(600px 300px at 10% 20%, rgba(124,58,237,0.10), transparent),\n                radial-gradient(600px 300px at 90% 80%, rgba(125,211,252,0.06), transparent);\n    pointer-events:none;\n    mix-blend-mode: screen;\n  }\n\n  @media (max-width:1000px){\n    .wrap{ grid-template-columns: 1fr; padding:20px; gap:18px; }\n    .panel{ padding:20px; border-radius:14px;}\n    .overlay{ left:18px; top:18px; }\n  }\n\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <section class=\"panel\">\n    <div class=\"title\">\n      <h1>A* Search</h1>\n      <p>Heuristic pathfinding visualized — watch A* explore and converge to an optimal path.</p>\n    </div>\n\n    <div class=\"meta\">\n      <div class=\"desc\">Elegant demonstration focusing on clarity and motion. Algorithm runs automatically — use controls below to replay or pause the animation.</div>\n      <div class=\"controls\">\n        <button id=\"replay\" class=\"btn\" title=\"Replay visualization\">\n          ⟳ Replay\n        </button>\n        <button id=\"pause\" class=\"btn secondary\" title=\"Pause / resume animation\">⏸ Pause</button>\n      </div>\n    </div>\n\n    <div class=\"legend\">\n      <div class=\"chip\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,#ffd400,#ff7a18);\"></div> Start → Goal</div>\n      <div class=\"chip\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,#60a5fa,#7dd3fc);\"></div> Open set</div>\n      <div class=\"chip\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,#7c3aed,#c084fc);\"></div> Closed set</div>\n      <div class=\"chip\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,#ffb86b,#ff5c7c);\"></div> Final path</div>\n    </div>\n\n    <div class=\"description\">\n      <strong style=\"color:#fff\">How it works —</strong> A* selects the most promising frontier node using cost-so-far plus heuristic (g + h), balancing optimality and speed. Observe the exploration wave and the graceful reveal of the final route, traced by an animated particle.\n    </div>\n  </section>\n\n  <section class=\"visual panel\" aria-hidden=\"false\">\n    <div class=\"overlay\">\n      <div class=\"badge\">A* visual <span style=\"opacity:0.6;font-weight:400;margin-left:8px;font-size:12px;\">Manhattan heuristic</span></div>\n    </div>\n\n    <canvas id=\"scene\"></canvas>\n\n    <div class=\"footer\">\n      <div class=\"credits\">Visualization • Smooth animated aesthetics</div>\n    </div>\n  </section>\n</div>\n\n<script>\n/*\n  A* Visualizer with aesthetic focus.\n  Limited interactivity: Replay and Pause buttons.\n*/\n\nconst canvas = document.getElementById('scene');\nconst ctx = canvas.getContext('2d', { alpha: true });\n\nlet DPR = Math.max(1, window.devicePixelRatio || 1);\n\nfunction resize() {\n  const rect = canvas.getBoundingClientRect();\n  canvas.width = Math.floor(rect.width * DPR);\n  canvas.height = Math.floor(rect.height * DPR);\n  ctx.setTransform(DPR, 0, 0, DPR, 0, 0);\n}\nwindow.addEventListener('resize', resize);\nresize();\n\n/* Grid parameters */\nconst cols = 36; // horizontal\nconst rows = 22; // vertical\nlet CELL, PAD;\nfunction computeLayout(){\n  const w = canvas.width / DPR;\n  const h = canvas.height / DPR;\n  // compute cell size to fit grid nicely\n  const maxW = Math.floor((w - 80) / cols);\n  const maxH = Math.floor((h - 80) / rows);\n  CELL = Math.max(10, Math.min(maxW, maxH));\n  PAD = CELL * 0.16;\n}\ncomputeLayout();\n\n/* Colors & styles */\nconst colors = {\n  bg: '#081223',\n  obstacle: '#091226',\n  start: ['#ffd85a','#ff7a18'],\n  goal: ['#8ef7a9','#08d68f'],\n  openGrad1: '#60a5fa',\n  openGrad2: '#7dd3fc',\n  closed1: '#7c3aed',\n  closed2: '#c084fc',\n  current: '#fff2c8',\n  path1: '#ffb86b',\n  path2: '#ff5c7c',\n  gridLine: 'rgba(255,255,255,0.03)'\n};\n\n/* Node grid */\nlet grid = [];\nlet start = null;\nlet goal = null;\nlet obstacles = new Set();\n\nfunction keyOf(x,y){ return `${x},${y}`; }\n\nfunction makeGrid(){\n  grid = [];\n  obstacles.clear();\n  computeLayout();\n  for(let y=0;y<rows;y++){\n    const row = [];\n    for(let x=0;x<cols;x++){\n      row.push({x,y,walkable:true});\n    }\n    grid.push(row);\n  }\n  // place start & goal with margin\n  start = {x:2, y: Math.floor(rows/2)};\n  goal = {x: cols-3, y: Math.floor(rows/2) + (Math.random()>0.5? -3: 3)};\n\n  // place dynamic obstacles with a soft noise field\n  for(let y=0;y<rows;y++){\n    for(let x=0;x<cols;x++){\n      // keep corridors near start/goal\n      const dx1 = Math.abs(x - start.x);\n      const dx2 = Math.abs(x - goal.x);\n      const corridorBias = (dx1<4 || dx2<4) ? -0.9 : 0;\n      const r = Math.random() + corridorBias;\n      if(r > 0.78 && !(x===start.x && y===start.y) && !(x===goal.x && y===goal.y)){\n        grid[y][x].walkable = false;\n        obstacles.add(keyOf(x,y));\n      }\n    }\n  }\n\n  // ensure connectivity: attempt to find path ignoring obstacles for a guaranteed path corridor\n  carveGuaranteedPath();\n}\n\nfunction carveGuaranteedPath(){\n  // Carve a simple corridor using BFS-like path from start to goal to ensure solvable\n  let sx = start.x, sy = start.y;\n  let gx = goal.x, gy = goal.y;\n  let cx = sx, cy = sy;\n  grid[cy][cx].walkable = true; obstacles.delete(keyOf(cx,cy));\n  while(cx !== gx || cy !== gy){\n    if(Math.random() > 0.4){\n      if(cx < gx) cx++;\n      else if(cx > gx) cx--;\n    } else {\n      if(cy < gy) cy++;\n      else if(cy > gy) cy--;\n    }\n    grid[cy][cx].walkable = true;\n    obstacles.delete(keyOf(cx,cy));\n    // occasionally carve side passages\n    if(Math.random() > 0.76){\n      if(cy+1<rows){ grid[cy+1][cx].walkable = true; obstacles.delete(keyOf(cx,cy+1)); }\n      if(cx+1<cols){ grid[cy][cx+1].walkable = true; obstacles.delete(keyOf(cx+1,cy)); }\n    }\n  }\n}\n\n/* A* Implementation */\nfunction manhattan(a,b){ return Math.abs(a.x-b.x)+Math.abs(a.y-b.y); }\n\nfunction neighbors(node){\n  const n = [];\n  const dirs = [[1,0],[-1,0],[0,1],[0,-1]];\n  for(const d of dirs){\n    const nx = node.x + d[0], ny = node.y + d[1];\n    if(nx>=0 && nx<cols && ny>=0 && ny<rows){\n      if(grid[ny][nx].walkable) n.push(grid[ny][nx]);\n    }\n  }\n  return n;\n}\n\n/* A* state */\nlet openSet, closedSet, cameFrom, gScore, fScore;\nlet foundPath = null;\nlet searchDone = false;\nlet currentNode = null;\nlet stepDelay = 30; // ms between expansions\nlet paused = false;\n\nfunction initSearch(){\n  openSet = new MinHeap((a,b)=> fScore[keyOf(a.x,a.y)] - fScore[keyOf(b.x,b.y)]);\n  closedSet = new Set();\n  cameFrom = new Map();\n  gScore = {};\n  fScore = {};\n  for(let y=0;y<rows;y++){\n    for(let x=0;x<cols;x++){\n      gScore[keyOf(x,y)] = Infinity;\n      fScore[keyOf(x,y)] = Infinity;\n    }\n  }\n  gScore[keyOf(start.x,start.y)] = 0;\n  fScore[keyOf(start.x,start.y)] = manhattan(start, goal);\n  openSet.push(grid[start.y][start.x]);\n  foundPath = null;\n  searchDone = false;\n  currentNode = null;\n}\n\nfunction reconstructPath(node){\n  const path = [];\n  let key = keyOf(node.x,node.y);\n  while(cameFrom.has(key)){\n    path.push(node);\n    node = cameFrom.get(key);\n    key = keyOf(node.x,node.y);\n  }\n  path.push(start);\n  path.reverse();\n  return path;\n}\n\n/* Simple binary heap implementation */\nfunction MinHeap(cmp){\n  this.arr = [];\n  this.cmp = cmp;\n}\nMinHeap.prototype.push = function(v){\n  this.arr.push(v);\n  let i = this.arr.length-1;\n  while(i>0){\n    const p = Math.floor((i-1)/2);\n    if(this.cmp(this.arr[i], this.arr[p]) < 0){\n      [this.arr[i], this.arr[p]] = [this.arr[p], this.arr[i]];\n      i = p;\n    } else break;\n  }\n};\nMinHeap.prototype.pop = function(){\n  if(this.arr.length===0) return null;\n  const top = this.arr[0];\n  const last = this.arr.pop();\n  if(this.arr.length>0){\n    this.arr[0] = last;\n    let i = 0;\n    while(true){\n      let l = i*2+1, r = i*2+2, smallest = i;\n      if(l < this.arr.length && this.cmp(this.arr[l], this.arr[smallest]) < 0) smallest = l;\n      if(r < this.arr.length && this.cmp(this.arr[r], this.arr[smallest]) < 0) smallest = r;\n      if(smallest !== i){\n        [this.arr[i], this.arr[smallest]] = [this.arr[smallest], this.arr[i]];\n        i = smallest;\n      } else break;\n    }\n  }\n  return top;\n};\nMinHeap.prototype.isEmpty = function(){ return this.arr.length===0; };\n\n/* Visualization state */\nlet openSetKeys = new Set();\nlet closedSetKeys = new Set();\nlet exploredOrder = []; // for wave-like timing\n\n/* Animation helpers */\nlet lastStepTime = 0;\nlet lastRender = 0;\nlet frameTicker = 0;\n\n/* Path animation */\nlet pathTween = 0;\nlet particlePos = 0;\n\n/* Initialize & run */\nmakeGrid();\ninitSearch();\nautoStart();\n\nfunction autoStart(){ paused = false; draw(); stepLoop(); }\n\nfunction resetAndRun(){\n  makeGrid();\n  initSearch();\n  pathTween = 0; particlePos = 0;\n  openSetKeys.clear(); closedSetKeys.clear(); exploredOrder = [];\n  paused = false;\n}\n\n/* Main step loop (A* progression) */\nfunction stepLoop(ts){\n  if(paused){ lastStepTime = ts || performance.now(); requestAnimationFrame(stepLoop); return; }\n  const now = ts || performance.now();\n  if(!lastStepTime) lastStepTime = now;\n  if(!searchDone && now - lastStepTime >= stepDelay){\n    // perform one expansion\n    if(openSet.isEmpty()){\n      searchDone = true;\n    } else {\n      const current = openSet.pop();\n      currentNode = current;\n      const cKey = keyOf(current.x,current.y);\n      if(!closedSetKeys.has(cKey)){\n        closedSetKeys.add(cKey);\n        // neighbors\n        for(const nb of neighbors(current)){\n          const nbKey = keyOf(nb.x, nb.y);\n          if(closedSetKeys.has(nbKey)) continue;\n          const tentative_g = gScore[cKey] + 1;\n          if(tentative_g < gScore[nbKey]){\n            cameFrom.set(nbKey, current);\n            gScore[nbKey] = tentative_g;\n            fScore[nbKey] = tentative_g + manhattan(nb, goal);\n            openSet.push(nb);\n            openSetKeys.add(nbKey);\n          }\n        }\n        exploredOrder.push(current);\n      }\n      // goal test\n      if(current.x === goal.x && current.y === goal.y){\n        foundPath = reconstructPath(current);\n        searchDone = true;\n      }\n    }\n    lastStepTime = now;\n  }\n  requestAnimationFrame(stepLoop);\n}\n\n/* Rendering */\nfunction drawGridBackground(){\n  // subtle grid pattern\n  ctx.save();\n  ctx.globalAlpha = 0.9;\n  ctx.fillStyle = 'rgba(8,14,26,0.65)';\n  ctx.fillRect(0,0,canvas.width/DPR, canvas.height/DPR);\n  ctx.restore();\n}\n\nfunction render(){\n  const W = canvas.width / DPR;\n  const H = canvas.height / DPR;\n  ctx.clearRect(0,0,W,H);\n  drawGridBackground();\n\n  // compute starting offset to center grid\n  const gridW = cols * CELL;\n  const gridH = rows * CELL;\n  const offsetX = (W - gridW) * 0.5;\n  const offsetY = (H - gridH) * 0.5;\n\n  // draw obstacles with soft noise & rounded corners\n  ctx.save();\n  for(let y=0;y<rows;y++){\n    for(let x=0;x<cols;x++){\n      const cell = grid[y][x];\n      const px = offsetX + x * CELL;\n      const py = offsetY + y * CELL;\n      // rounded rect with subtle bevel\n      ctx.beginPath();\n      const r = Math.max(3, CELL*0.12);\n      roundRect(ctx, px+PAD/2, py+PAD/2, CELL-PAD, CELL-PAD, r);\n      if(!cell.walkable){\n        // gradient fill for obstacles\n        const g = ctx.createLinearGradient(px,py,px+CELL,py+CELL);\n        g.addColorStop(0, 'rgba(7,10,16,0.9)');\n        g.addColorStop(1, 'rgba(12,15,22,0.78)');\n        ctx.fillStyle = g;\n        ctx.fill();\n        // soft inner shadow\n        ctx.lineWidth = 1;\n        ctx.strokeStyle = 'rgba(255,255,255,0.01)';\n        ctx.stroke();\n      } else {\n        // background tile\n        ctx.fillStyle = 'rgba(255,255,255,0.012)';\n        ctx.fill();\n      }\n    }\n  }\n  ctx.restore();\n\n  // draw exploration: closed set (deeper purple), open set (cyan)\n  ctx.save();\n  ctx.globalCompositeOperation = 'lighter';\n  for(const node of exploredOrder){\n    const key = keyOf(node.x,node.y);\n    if(closedSetKeys.has(key)){\n      const px = offsetX + node.x * CELL + CELL/2;\n      const py = offsetY + node.y * CELL + CELL/2;\n      const maxR = CELL*0.9;\n      const t = Math.min(1, (exploredOrder.indexOf(node)+1) / (exploredOrder.length+1));\n      const g = ctx.createRadialGradient(px,py,0, px,py, maxR);\n      g.addColorStop(0, lerpColor(colors.closed2, colors.closed1, 0.5));\n      g.addColorStop(Math.max(0.12, 0.2*t), 'rgba(124,58,237,0.18)');\n      g.addColorStop(1, 'rgba(0,0,0,0)');\n      ctx.fillStyle = g;\n      ctx.beginPath();\n      ctx.arc(px,py, maxR * (0.6 + 0.6*t), 0, Math.PI*2);\n      ctx.fill();\n    }\n  }\n  for(const key of openSetKeys){\n    const [sx,sy] = key.split(',').map(Number);\n    const node = grid[sy][sx];\n    const px = offsetX + node.x * CELL + CELL/2;\n    const py = offsetY + node.y * CELL + CELL/2;\n    const r = CELL * 0.55;\n    const g = ctx.createRadialGradient(px,py,0, px,py,r);\n    g.addColorStop(0, 'rgba(69, 170, 242, 0.95)');\n    g.addColorStop(0.3, 'rgba(125,211,252,0.24)');\n    g.addColorStop(1, 'rgba(0,0,0,0)');\n    ctx.fillStyle = g;\n    ctx.beginPath();\n    ctx.arc(px,py, r, 0, Math.PI*2);\n    ctx.fill();\n  }\n  ctx.restore();\n\n  // draw grid cell outlines subtly\n  ctx.save();\n  ctx.lineWidth = 1;\n  ctx.strokeStyle = colors.gridLine;\n  for(let y=0;y<rows;y++){\n    for(let x=0;x<cols;x++){\n      const px = offsetX + x * CELL + PAD/2;\n      const py = offsetY + y * CELL + PAD/2;\n      const s = CELL - PAD;\n      roundRect(ctx, px, py, s, s, Math.max(3, s*0.12));\n      ctx.stroke();\n    }\n  }\n  ctx.restore();\n\n  // draw current node with a pulse\n  if(currentNode){\n    const px = offsetX + currentNode.x * CELL + CELL/2;\n    const py = offsetY + currentNode.y * CELL + CELL/2;\n    const pulse = 1 + 0.18*Math.sin(performance.now()/220);\n    ctx.save();\n    const rg = ctx.createRadialGradient(px,py,0,px,py,CELL*0.85*pulse);\n    rg.addColorStop(0, 'rgba(255,242,200,0.95)');\n    rg.addColorStop(0.3, 'rgba(255,210,120,0.12)');\n    rg.addColorStop(1, 'rgba(0,0,0,0)');\n    ctx.fillStyle = rg;\n    ctx.beginPath();\n    ctx.arc(px,py,CELL*0.85*pulse,0,Math.PI*2);\n    ctx.fill();\n    ctx.restore();\n  }\n\n  // draw start and goal with stylish markers\n  drawMarker(start.x, start.y, offsetX, offsetY, colors.start, 'S');\n  drawMarker(goal.x, goal.y, offsetX, offsetY, colors.goal, 'G');\n\n  // overlay the final path if found\n  if(foundPath){\n    // draw path ribbon\n    drawPathRibbon(foundPath, offsetX, offsetY);\n    // animate particle along path\n    particlePos += 0.006 * (paused ? 0 : 1.0);\n    if(particlePos>1) particlePos=1;\n    drawParticleAlong(foundPath, particlePos, offsetX, offsetY);\n  } else if(searchDone && openSet.isEmpty()){\n    // draw subtle \"no path\" notification\n    ctx.save();\n    ctx.fillStyle = 'rgba(255,255,255,0.06)';\n    ctx.font = '700 28px Inter';\n    ctx.textAlign = 'center';\n    ctx.fillText('No path found', W/2, H/2 - 20);\n    ctx.restore();\n  }\n\n  // add foreground glass overlay highlight\n  ctx.save();\n  const gloss = ctx.createLinearGradient(0, offsetY + 10, 0, offsetY + gridH - 10);\n  gloss.addColorStop(0, 'rgba(255,255,255,0.015)');\n  gloss.addColorStop(1, 'rgba(255,255,255,0.002)');\n  ctx.fillStyle = gloss;\n  roundRect(ctx, offsetX + 6, offsetY + 6, gridW - 12, gridH - 12, 18);\n  ctx.fill();\n  ctx.restore();\n}\n\n/* Draw a rounded rectangle helper */\nfunction roundRect(ctx,x,y,w,h,r){\n  ctx.moveTo(x+r, y);\n  ctx.arcTo(x+w, y, x+w, y+h, r);\n  ctx.arcTo(x+w, y+h, x, y+h, r);\n  ctx.arcTo(x, y+h, x, y, r);\n  ctx.arcTo(x, y, x+w, y, r);\n  ctx.closePath();\n}\n\n/* Draw start/goal markers with gradient icon */\nfunction drawMarker(cx, cy, offsetX, offsetY, colorPair, label){\n  const px = offsetX + cx * CELL + CELL/2;\n  const py = offsetY + cy * CELL + CELL/2;\n  const size = CELL * 0.75;\n  // outer glow\n  ctx.save();\n  const rg = ctx.createRadialGradient(px,py,0,px,py,size*1.1);\n  rg.addColorStop(0, colorPair[0]);\n  rg.addColorStop(0.5, colorPair[1]);\n  rg.addColorStop(1, 'rgba(0,0,0,0)');\n  ctx.fillStyle = rg;\n  ctx.beginPath();\n  ctx.arc(px,py,size*0.9,0,Math.PI*2);\n  ctx.fill();\n  // inner badge\n  ctx.beginPath();\n  ctx.fillStyle = '#061018';\n  ctx.strokeStyle = 'rgba(255,255,255,0.06)';\n  ctx.lineWidth = 1;\n  ctx.arc(px,py,size*0.38,0,Math.PI*2);\n  ctx.fill();\n  ctx.stroke();\n  // label\n  ctx.fillStyle = '#fff';\n  ctx.font = `${Math.max(10, size*0.28)}px Inter`;\n  ctx.textAlign = 'center';\n  ctx.textBaseline = 'middle';\n  ctx.fillText(label, px, py);\n  ctx.restore();\n}\n\n/* Draw path ribbon with gradient */\nfunction drawPathRibbon(path, offsetX, offsetY){\n  if(!path || path.length<2) return;\n  ctx.save();\n  ctx.lineCap = 'round';\n  ctx.lineJoin = 'round';\n  // create a smooth polyline (Catmull-Rom to bezier approximation could be used; do simple quadratic smoothing)\n  const pts = path.map(p => ({\n    x: offsetX + p.x * CELL + CELL/2,\n    y: offsetY + p.y * CELL + CELL/2\n  }));\n  // draw glow\n  ctx.beginPath();\n  ctx.moveTo(pts[0].x, pts[0].y);\n  for(let i=1;i<pts.length;i++){\n    const midx = (pts[i-1].x + pts[i].x)/2;\n    const midy = (pts[i-1].y + pts[i].y)/2;\n    ctx.quadraticCurveTo(pts[i-1].x, pts[i-1].y, midx, midy);\n  }\n  ctx.strokeStyle = 'rgba(255,120,100,0.18)';\n  ctx.lineWidth = CELL * 1.0;\n  ctx.stroke();\n\n  // main gradient stroke\n  const grad = ctx.createLinearGradient(pts[0].x, pts[0].y, pts[pts.length-1].x, pts[pts.length-1].y);\n  grad.addColorStop(0, colors.path1);\n  grad.addColorStop(1, colors.path2);\n  ctx.strokeStyle = grad;\n  ctx.lineWidth = Math.max(6, CELL * 0.44);\n  ctx.beginPath();\n  ctx.moveTo(pts[0].x, pts[0].y);\n  for(let i=1;i<pts.length;i++){\n    const midx = (pts[i-1].x + pts[i].x)/2;\n    const midy = (pts[i-1].y + pts[i].y)/2;\n    ctx.quadraticCurveTo(pts[i-1].x, pts[i-1].y, midx, midy);\n  }\n  ctx.stroke();\n  ctx.restore();\n}\n\n/* Draw an animated particle along the path */\nfunction drawParticleAlong(path, t, offsetX, offsetY){\n  if(!path || path.length<2) return;\n  const pts = path.map(p => ({\n    x: offsetX + p.x * CELL + CELL/2,\n    y: offsetY + p.y * CELL + CELL/2\n  }));\n  // compute total segment lengths\n  const seg = [];\n  let total = 0;\n  for(let i=1;i<pts.length;i++){\n    const dx = pts[i].x - pts[i-1].x, dy = pts[i].y - pts[i-1].y;\n    const len = Math.hypot(dx,dy);\n    seg.push({dx,dy,len});\n    total += len;\n  }\n  const target = t * total;\n  let acc = 0;\n  let idx = 0;\n  while(idx < seg.length && acc + seg[idx].len < target){\n    acc += seg[idx].len;\n    idx++;\n  }\n  if(idx >= seg.length) idx = seg.length-1;\n  const ratio = (target - acc) / seg[idx].len;\n  const x = pts[idx].x + seg[idx].dx * ratio;\n  const y = pts[idx].y + seg[idx].dy * ratio;\n\n  // particle with trailing glow\n  ctx.save();\n  const trail = ctx.createRadialGradient(x,y,0,x,y, CELL*0.9);\n  trail.addColorStop(0, 'rgba(255,255,255,0.95)');\n  trail.addColorStop(0.15, 'rgba(255,200,120,0.9)');\n  trail.addColorStop(0.4, 'rgba(255,110,120,0.35)');\n  trail.addColorStop(1, 'rgba(255,110,120,0)');\n  ctx.fillStyle = trail;\n  ctx.beginPath();\n  ctx.arc(x,y, CELL*0.5,0,Math.PI*2);\n  ctx.fill();\n\n  // core\n  ctx.beginPath();\n  ctx.fillStyle = '#fff';\n  ctx.arc(x,y, Math.max(2, CELL*0.18),0,Math.PI*2);\n  ctx.fill();\n  ctx.restore();\n}\n\n/* Render loop */\nfunction draw(now){\n  frameTicker++;\n  render();\n  lastRender = now || performance.now();\n  requestAnimationFrame(draw);\n}\n\n/* Buttons */\nconst btnReplay = document.getElementById('replay');\nconst btnPause = document.getElementById('pause');\nbtnReplay.addEventListener('click', ()=>{\n  resetAndRun();\n});\nbtnPause.addEventListener('click', ()=>{\n  paused = !paused;\n  btnPause.innerText = paused ? '▶ Resume' : '⏸ Pause';\n});\n\n/* Kick things off already */\nrequestAnimationFrame(draw);\n\n/* Ensure path exists (if not, regenerate) — run a quick non-animated A* to validate */\nfunction quickExistsPath(){\n  // Quick A* with obstacles to verify existence\n  const open = [];\n  const closed = new Set();\n  const g = {};\n  for(let y=0;y<rows;y++) for(let x=0;x<cols;x++) g[keyOf(x,y)] = Infinity;\n  g[keyOf(start.x,start.y)] = 0;\n  open.push({node: grid[start.y][start.x], f: manhattan(start,goal)});\n\n  while(open.length){\n    open.sort((a,b)=>a.f-b.f);\n    const cur = open.shift().node;\n    if(cur.x===goal.x && cur.y===goal.y) return true;\n    closed.add(keyOf(cur.x,cur.y));\n    for(const nb of neighbors(cur)){\n      const k = keyOf(nb.x,nb.y);\n      if(closed.has(k)) continue;\n      const tentative = g[keyOf(cur.x,cur.y)] + 1;\n      if(tentative < g[k]){\n        g[k] = tentative;\n        open.push({node: nb, f: tentative + manhattan(nb,goal)});\n      }\n    }\n  }\n  return false;\n}\n\n/* If initial generation yields no path, regenerate until solvable (rare) */\nlet regenAttempts = 0;\n(function ensureSolvable(){\n  if(quickExistsPath()) return;\n  regenAttempts++;\n  if(regenAttempts > 12) {\n    // fallback: clear central corridor\n    for(let x=0;x<cols;x++){\n      for(let y=Math.floor(rows/2)-1;y<=Math.floor(rows/2)+1;y++){\n        if(y>=0 && y<rows) grid[y][x].walkable = true, obstacles.delete(keyOf(x,y));\n      }\n    }\n  } else {\n    makeGrid();\n  }\n  initSearch();\n  setTimeout(ensureSolvable, 8);\n})();\n\n</script>\n</body>\n</html>"
