  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>NoSQL Interactive Demo</title>\n<style>\n  /* Minimal styling: plain black text on white */\n  body {\n    font-family: monospace;\n    margin: 1em;\n    white-space: pre-wrap;\n  }\n  textarea {\n    width: 100%;\n    height: 4em;\n    font-family: monospace;\n  }\n  input, button, select {\n    font-family: monospace;\n    font-size: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n  fieldset {\n    margin-top: 1em;\n  }\n  #output {\n    margin-top: 1em;\n    border: 1px solid #000;\n    padding: 0.5em;\n    height: 8em;\n    overflow: auto;\n  }\n  #dbstate {\n    margin-top: 1em;\n    border: 1px solid #000;\n    padding: 0.5em;\n    height: 14em;\n    overflow: auto;\n    font-size: 0.9em;\n  }\n</style>\n</head>\n<body>\n<h1>NoSQL Interactive Demo</h1>\n<p>\n  This demo simulates an in-memory document-oriented NoSQL database with powerful interactive controls.\n  You can create collections, insert, update, delete, and query documents, define indexes, perform complex queries, and explore NoSQL concepts.\n</p>\n\n<fieldset>\n  <legend>Database Setup</legend>\n  <label>\n    Collection Name:\n    <input type=\"text\" id=\"collectionName\" />\n  </label>\n  <button id=\"createCollectionBtn\">Create Collection</button>\n  <button id=\"deleteCollectionBtn\">Delete Collection</button>\n  <div id=\"collectionsList\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>Document Operations</legend>\n  <label>\n    Selected Collection:\n    <select id=\"collectionSelect\"></select>\n  </label>\n  <label>\n    Insert/Update Document (JSON):\n    <textarea id=\"docInput\" placeholder='e.g. {\"_id\": \"abc123\", \"name\": \"John\", \"age\": 32}'></textarea>\n  </label>\n  <button id=\"insertDocBtn\">Insert Document</button>\n  <button id=\"updateDocBtn\">Update Document by _id</button>\n  <button id=\"deleteDocBtn\">Delete Document by _id</button>\n  <label>\n    Document _id for Update/Delete:\n    <input type=\"text\" id=\"docIdInput\" />\n  </label>\n</fieldset>\n\n<fieldset>\n  <legend>Query Interface</legend>\n  <p>Enter a JSON query object. Supports simple comparison with operators <code>$eq, $ne, $gt, $lt, $gte, $lte, $in, $nin</code> and logical operators <code>$and, $or, $not</code>.</p>\n  <textarea id=\"queryInput\" placeholder='e.g. {\"age\": {\"$gt\": 25}}'></textarea>\n  <label>\n    Limit results:\n    <input type=\"number\" id=\"queryLimit\" min=\"0\" value=\"0\" />\n  </label>\n  <button id=\"runQueryBtn\">Run Query</button>\n</fieldset>\n\n<fieldset>\n  <legend>Indexes</legend>\n  <p>Create indexes on fields to accelerate query simulation. (This demo doesn't execute real index acceleration but showcases management and effect on state.)</p>\n  <label>\n    Index Name:\n    <input type=\"text\" id=\"indexNameInput\" />\n  </label>\n  <label>\n    Collection for Index:\n    <select id=\"indexCollectionSelect\"></select>\n  </label>\n  <label>\n    Field(s) (comma separated):\n    <input type=\"text\" id=\"indexFieldsInput\" placeholder=\"e.g. name,age\" />\n  </label>\n  <button id=\"createIndexBtn\">Create Index</button>\n  <label>\n    Select Index to Delete:\n    <select id=\"indexDeleteSelect\"></select>\n  </label>\n  <button id=\"deleteIndexBtn\">Delete Index</button>\n</fieldset>\n\n<fieldset>\n  <legend>Aggregation Operations</legend>\n  <p>Perform simple aggregation pipeline on selected collection. Supports <code>$match</code>, <code>$group</code>, <code>$sort</code>, <code>$limit</code>.</p>\n  <textarea id=\"aggPipelineInput\" placeholder='Example pipeline JSON:\n[\n  {\"$match\": {\"age\": {\"$gte\": 20}}},\n  {\"$group\": {\"_id\": \"$name\", \"total\": {\"$sum\": 1}}},\n  {\"$sort\": {\"total\": -1}},\n  {\"$limit\": 5}\n]\n'></textarea>\n  <button id=\"runAggBtn\">Run Aggregation</button>\n</fieldset>\n\n<fieldset>\n  <legend>Output</legend>\n  <div id=\"output\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>Database State Snapshot</legend>\n  <small>Current collections, documents, and indexes (expanded view)</small>\n  <div id=\"dbstate\"></div>\n</fieldset>\n\n<script>\n(() => {\n  // Internal DB structure\n  // { collections: { [colName]: { docs: Map(_id -> doc), indexes: { [idxName]: { fields: [fieldStrs] } } } } }\n  const db = { collections: {} };\n\n  // Helpers\n  function safeJSONparse(text) {\n    try {\n      return [JSON.parse(text), null];\n    } catch (e) {\n      return [null, e.message];\n    }\n  }\n  function deepCopy(obj) {\n    return JSON.parse(JSON.stringify(obj));\n  }\n  function isObject(o) {\n    return o !== null && typeof o === 'object' && !Array.isArray(o);\n  }\n  function getValueByPath(obj, path) {\n    // path: \"field.subfield\" or \"$field\"\n    if (typeof path !== 'string') return undefined;\n    if (path[0] === '$') path = path.slice(1);\n    const parts = path.split('.');\n    let val = obj;\n    for (const p of parts) {\n      if (val == null) return undefined;\n      val = val[p];\n    }\n    return val;\n  }\n\n  // Query operators implementation\n  // Returns true if doc matches query\n  function matchesQuery(doc, query) {\n    if (!isObject(query)) return false;\n    // Logical operators\n    if ('$and' in query) {\n      if (!Array.isArray(query['$and'])) return false;\n      return query['$and'].every(q => matchesQuery(doc, q));\n    }\n    if ('$or' in query) {\n      if (!Array.isArray(query['$or'])) return false;\n      return query['$or'].some(q => matchesQuery(doc, q));\n    }\n    if ('$not' in query) {\n      return !matchesQuery(doc, query['$not']);\n    }\n    // Field conditions\n    for (const [field, cond] of Object.entries(query)) {\n      if (field.startsWith('$')) continue; // skip unrecognized operators\n      const val = getValueByPath(doc, field);\n      if (isObject(cond)) {\n        // operator cases\n        for (const [op, opVal] of Object.entries(cond)) {\n          if (!matchesOperator(val, op, opVal)) return false;\n        }\n      } else {\n        // direct equality\n        if (!isEqual(val, cond)) return false;\n      }\n    }\n    return true;\n  }\n\n  function matchesOperator(value, operator, operand) {\n    switch (operator) {\n      case '$eq':\n        return isEqual(value, operand);\n      case '$ne':\n        return !isEqual(value, operand);\n      case '$gt':\n        return compare(value, operand) > 0;\n      case '$lt':\n        return compare(value, operand) < 0;\n      case '$gte':\n        return compare(value, operand) >= 0;\n      case '$lte':\n        return compare(value, operand) <= 0;\n      case '$in':\n        if (!Array.isArray(operand)) return false;\n        return operand.some(o => isEqual(value, o));\n      case '$nin':\n        if (!Array.isArray(operand)) return false;\n        return !operand.some(o => isEqual(value, o));\n      default:\n        return false;\n    }\n  }\n\n  // Compare two values: numbers or strings, else fallback\n  function compare(a, b) {\n    if (typeof a === 'number' && typeof b === 'number') return a - b;\n    if (typeof a === 'string' && typeof b === 'string') return a < b ? -1 : a > b ? 1 : 0;\n    if (a === b) return 0;\n    return 0;\n  }\n  // Deep equality for primitives, arrays, objects\n  function isEqual(a, b) {\n    if (a === b) return true;\n    if (Array.isArray(a) && Array.isArray(b)) {\n      if (a.length !== b.length) return false;\n      for (let i = 0; i < a.length; i++) {\n        if (!isEqual(a[i], b[i])) return false;\n      }\n      return true;\n    }\n    if (isObject(a) && isObject(b)) {\n      const aKeys = Object.keys(a);\n      const bKeys = Object.keys(b);\n      if (aKeys.length !== bKeys.length) return false;\n      for (const k of aKeys) {\n        if (!isEqual(a[k], b[k])) return false;\n      }\n      return true;\n    }\n    return false;\n  }\n\n  // Aggregation pipeline runner (limited implementation)\n  function runAggregationPipeline(collection, pipeline) {\n    // collection: { docs: Map }\n    // pipeline: Array of stages objects\n    let docs = Array.from(collection.docs.values()).map(d => deepCopy(d));\n\n    for (const stage of pipeline) {\n      if (!isObject(stage)) throw 'Pipeline stages must be objects';\n      if ('$match' in stage) {\n        const query = stage['$match'];\n        docs = docs.filter(doc => matchesQuery(doc, query));\n      } else if ('$group' in stage) {\n        const groupSpec = stage['$group']; // {_id: \"...\", accumulations...}\n        if (!isObject(groupSpec)) throw '$group must be an object';\n        const idExpr = groupSpec._id;\n        if (idExpr === undefined) throw '$group must have _id field';\n\n        const groups = new Map();\n        for (const doc of docs) {\n          let groupId;\n          if (typeof idExpr === 'string' && idExpr[0] === '$') {\n            groupId = JSON.stringify(getValueByPath(doc, idExpr));\n          } else {\n            groupId = JSON.stringify(idExpr);\n          }\n          if (!groups.has(groupId)) {\n            groups.set(groupId, { _id: JSON.parse(groupId) });\n            for (const [k, v] of Object.entries(groupSpec)) {\n              if (k !== '_id') groups.get(groupId)[k] = 0;\n            }\n          }\n          const groupObj = groups.get(groupId);\n          for (const [field, expr] of Object.entries(groupSpec)) {\n            if (field === '_id') continue;\n            // Currently only support $sum with number or $sum: 1 for counting\n            if (isObject(expr) && '$sum' in expr) {\n              const sumVal = expr['$sum'];\n              if (typeof sumVal === 'number') {\n                groupObj[field] += sumVal;\n              } else if (sumVal === 1) {\n                groupObj[field] += 1;\n              } else if (typeof sumVal === 'string' && sumVal[0] === '$') {\n                const val = getValueByPath(doc, sumVal);\n                if (typeof val === 'number') groupObj[field] += val;\n              }\n            }\n            // Extend here for $avg, $max, $min if desired\n          }\n        }\n        docs = Array.from(groups.values());\n      } else if ('$sort' in stage) {\n        const sortSpec = stage['$sort'];\n        if (!isObject(sortSpec)) throw '$sort must be an object';\n        docs.sort((a, b) => {\n          for (const [field, dir] of Object.entries(sortSpec)) {\n            const va = getValueByPath(a, field);\n            const vb = getValueByPath(b, field);\n            const c = compare(va, vb);\n            if (c !== 0) return dir > 0 ? c : -c;\n          }\n          return 0;\n        });\n      } else if ('$limit' in stage) {\n        const limitCount = stage['$limit'];\n        if (typeof limitCount !== 'number' || limitCount < 0) throw '$limit must be a nonnegative integer';\n        docs = docs.slice(0, limitCount);\n      } else {\n        throw 'Unsupported pipeline stage: ' + Object.keys(stage)[0];\n      }\n    }\n    return docs;\n  }\n\n\n  // DOM Elements\n  const collectionNameInput = document.getElementById('collectionName');\n  const createCollectionBtn = document.getElementById('createCollectionBtn');\n  const deleteCollectionBtn = document.getElementById('deleteCollectionBtn');\n  const collectionsListDiv = document.getElementById('collectionsList');\n\n  const collectionSelect = document.getElementById('collectionSelect');\n  const docInput = document.getElementById('docInput');\n  const insertDocBtn = document.getElementById('insertDocBtn');\n  const updateDocBtn = document.getElementById('updateDocBtn');\n  const deleteDocBtn = document.getElementById('deleteDocBtn');\n  const docIdInput = document.getElementById('docIdInput');\n\n  const queryInput = document.getElementById('queryInput');\n  const queryLimitInput = document.getElementById('queryLimit');\n  const runQueryBtn = document.getElementById('runQueryBtn');\n\n  const indexNameInput = document.getElementById('indexNameInput');\n  const indexCollectionSelect = document.getElementById('indexCollectionSelect');\n  const indexFieldsInput = document.getElementById('indexFieldsInput');\n  const createIndexBtn = document.getElementById('createIndexBtn');\n  const indexDeleteSelect = document.getElementById('indexDeleteSelect');\n  const deleteIndexBtn = document.getElementById('deleteIndexBtn');\n\n  const aggPipelineInput = document.getElementById('aggPipelineInput');\n  const runAggBtn = document.getElementById('runAggBtn');\n\n  const outputDiv = document.getElementById('output');\n  const dbstateDiv = document.getElementById('dbstate');\n\n  // Update collections list area & selects\n  function refreshCollectionsUI() {\n    // List collections with doc counts and indexes count\n    const names = Object.keys(db.collections);\n    if (names.length === 0) {\n      collectionsListDiv.textContent = 'No collections created yet.';\n    } else {\n      const lines = names.map(name => {\n        const c = db.collections[name];\n        const docCount = c.docs.size;\n        const idxCount = Object.keys(c.indexes).length;\n        return '- ' + name + ' (' + docCount + ' docs, ' + idxCount + ' indexes)';\n      });\n      collectionsListDiv.textContent = lines.join('\\n');\n    }\n    // Populate collectionSelect and indexCollectionSelect dropdowns\n    updateDropdown(collectionSelect, names);\n    updateDropdown(indexCollectionSelect, names);\n    refreshIndexesDeleteUI();\n  }\n\n  function updateDropdown(selectEl, items) {\n    const oldVal = selectEl.value;\n    selectEl.innerHTML = '';\n    for (const item of items) {\n      const opt = document.createElement('option');\n      opt.value = item;\n      opt.textContent = item;\n      selectEl.appendChild(opt);\n    }\n    if (items.includes(oldVal)) selectEl.value = oldVal;\n  }\n\n  // Document operations\n  function insertDocument() {\n    const colName = collectionSelect.value;\n    if (!colName) {\n      setOutput('Select a collection first to insert document.');\n      return;\n    }\n    const [doc, err] = safeJSONparse(docInput.value);\n    if (err) {\n      setOutput('JSON parse error: ' + err);\n      return;\n    }\n    if (!isObject(doc)) {\n      setOutput('Document must be a JSON object.');\n      return;\n    }\n    // Require _id field\n    if (!('_id' in doc)) {\n      setOutput('Document must contain an \"_id\" field.');\n      return;\n    }\n    const c = db.collections[colName];\n    if (c.docs.has(doc._id)) {\n      setOutput('Insert failed: Document with _id=\"' + doc._id + '\" already exists.');\n      return;\n    }\n    c.docs.set(doc._id, deepCopy(doc));\n    setOutput('Inserted document with _id = ' + doc._id + ' into \"' + colName + '\".');\n    refreshDbState();\n  }\n  function updateDocument() {\n    const colName = collectionSelect.value;\n    if (!colName) {\n      setOutput('Select a collection first to update document.');\n      return;\n    }\n    const id = docIdInput.value.trim();\n    if (!id) {\n      setOutput('Provide the _id of the document to update.');\n      return;\n    }\n    const c = db.collections[colName];\n    if (!c.docs.has(id)) {\n      setOutput('No document with _id=\"' + id + '\" found in collection.');\n      return;\n    }\n    const [doc, err] = safeJSONparse(docInput.value);\n    if (err) {\n      setOutput('JSON parse error: ' + err);\n      return;\n    }\n    if (!isObject(doc)) {\n      setOutput('Document must be a JSON object.');\n      return;\n    }\n    if (!('_id' in doc) || doc._id !== id) {\n      setOutput('Document JSON must include the same _id as provided.');\n      return;\n    }\n    c.docs.set(id, deepCopy(doc));\n    setOutput('Updated document with _id = ' + id + ' in \"' + colName + '\".');\n    refreshDbState();\n  }\n  function deleteDocument() {\n    const colName = collectionSelect.value;\n    if (!colName) {\n      setOutput('Select a collection first to delete document.');\n      return;\n    }\n    const id = docIdInput.value.trim();\n    if (!id) {\n      setOutput('Provide the _id of the document to delete.');\n      return;\n    }\n    const c = db.collections[colName];\n    if (!c.docs.has(id)) {\n      setOutput('No document with _id=\"' + id + '\" found in collection.');\n      return;\n    }\n    c.docs.delete(id);\n    setOutput('Deleted document with _id = ' + id + ' from \"' + colName + '\".');\n    refreshDbState();\n  }\n\n  // Create Collection\n  function createCollection() {\n    const name = collectionNameInput.value.trim();\n    if (!name) {\n      setOutput('Collection name cannot be empty.');\n      return;\n    }\n    if (db.collections[name]) {\n      setOutput('Collection \"' + name + '\" already exists.');\n      return;\n    }\n    db.collections[name] = { docs: new Map(), indexes: {} };\n    setOutput('Collection \"' + name + '\" created.');\n    refreshCollectionsUI();\n    refreshDbState();\n  }\n  // Delete Collection\n  function deleteCollection() {\n    const name = collectionNameInput.value.trim();\n    if (!name) {\n      setOutput('Collection name cannot be empty.');\n      return;\n    }\n    if (!db.collections[name]) {\n      setOutput('Collection \"' + name + '\" does not exist.');\n      return;\n    }\n    if (!confirm('Are you sure you want to delete collection \"' + name + '\"? This will remove all documents and indexes.')) return;\n    delete db.collections[name];\n    setOutput('Collection \"' + name + '\" deleted.');\n    refreshCollectionsUI();\n    refreshDbState();\n  }\n\n  // Run Query\n  function runQuery() {\n    const colName = collectionSelect.value;\n    if (!colName) {\n      setOutput('Select a collection before running queries.');\n      return;\n    }\n    const c = db.collections[colName];\n    const [query, err] = safeJSONparse(queryInput.value.trim() || '{}');\n    if (err) {\n      setOutput('Query JSON parse error: ' + err);\n      return;\n    }\n    if (!isObject(query)) {\n      setOutput('Query must be a JSON object');\n      return;\n    }\n    let res = [];\n    try {\n      for (const doc of c.docs.values()) {\n        if (matchesQuery(doc, query)) res.push(deepCopy(doc));\n      }\n    } catch (e) {\n      setOutput('Error running query: ' + e);\n      return;\n    }\n    let limit = parseInt(queryLimitInput.value, 10);\n    if (isNaN(limit) || limit < 0) limit = 0;\n    if (limit > 0) res = res.slice(0, limit);\n    setOutput('Query results (' + res.length + ' documents):\\n' + JSON.stringify(res, null, 2));\n  }\n\n  // Indexes\n  function createIndex() {\n    const idxName = indexNameInput.value.trim();\n    if (!idxName) {\n      setOutput('Index name cannot be empty.');\n      return;\n    }\n    const colName = indexCollectionSelect.value;\n    if (!colName) {\n      setOutput('Select collection to create index on.');\n      return;\n    }\n    const fieldsRaw = indexFieldsInput.value.trim();\n    if (!fieldsRaw) {\n      setOutput('Specify at least one field for the index.');\n      return;\n    }\n    const fields = fieldsRaw.split(',').map(s => s.trim()).filter(s => s.length > 0);\n    if (fields.length === 0) {\n      setOutput('Specify valid fields for the index.');\n      return;\n    }\n    const c = db.collections[colName];\n    if (c.indexes[idxName]) {\n      setOutput('Index with name \"' + idxName + '\" already exists in collection \"' + colName + '\".');\n      return;\n    }\n    c.indexes[idxName] = { fields: fields };\n    setOutput('Created index \"' + idxName + '\" on collection \"' + colName + '\" on fields: ' + fields.join(', '));\n    refreshIndexesDeleteUI();\n    refreshDbState();\n  }\n  function refreshIndexesDeleteUI() {\n    // Show all indexes from all collections as {colName}.{idxName} options\n    const opts = [];\n    for (const [colName, col] of Object.entries(db.collections)) {\n      for (const idxName of Object.keys(col.indexes)) {\n        opts.push(colName + '.' + idxName);\n      }\n    }\n    const oldVal = indexDeleteSelect.value;\n    indexDeleteSelect.innerHTML = '';\n    for (const optStr of opts) {\n      const opt = document.createElement('option');\n      opt.value = optStr;\n      opt.textContent = optStr;\n      indexDeleteSelect.appendChild(opt);\n    }\n    if (opts.includes(oldVal)) {\n      indexDeleteSelect.value = oldVal;\n    }\n  }\n  function deleteIndex() {\n    const val = indexDeleteSelect.value;\n    if (!val) {\n      setOutput('Select an index to delete.');\n      return;\n    }\n    const parts = val.split('.');\n    if (parts.length !== 2) {\n      setOutput('Invalid index selection.');\n      return;\n    }\n    const [colName, idxName] = parts;\n    const c = db.collections[colName];\n    if (!c || !c.indexes[idxName]) {\n      setOutput('Index not found.');\n      return;\n    }\n    delete c.indexes[idxName];\n    setOutput('Deleted index \"' + idxName + '\" from collection \"' + colName + '\".');\n    refreshIndexesDeleteUI();\n    refreshDbState();\n  }\n\n  // Aggregation\n  function runAggregation() {\n    const colName = collectionSelect.value;\n    if (!colName) {\n      setOutput('Select a collection for aggregation.');\n      return;\n    }\n    const c = db.collections[colName];\n    const [pipeline, err] = safeJSONparse(aggPipelineInput.value.trim() || '[]');\n    if (err) {\n      setOutput('Pipeline JSON parse error: ' + err);\n      return;\n    }\n    if (!Array.isArray(pipeline)) {\n      setOutput('Aggregation pipeline must be an array.');\n      return;\n    }\n    let result;\n    try {\n      result = runAggregationPipeline(c, pipeline);\n    } catch (e) {\n      setOutput('Aggregation error: ' + e);\n      return;\n    }\n    setOutput('Aggregation result (' + result.length + ' documents):\\n' + JSON.stringify(result, null, 2));\n  }\n\n  // Display output\n  function setOutput(text) {\n    outputDiv.textContent = text;\n  }\n\n  // Show full DB JSON for exploration\n  function refreshDbState() {\n    const snapshot = {};\n    for (const [colName, col] of Object.entries(db.collections)) {\n      snapshot[colName] = {\n        indexes: deepCopy(col.indexes),\n        documents: {},\n      };\n      for (const [id, doc] of col.docs.entries()) {\n        snapshot[colName].documents[id] = deepCopy(doc);\n      }\n    }\n    dbstateDiv.textContent = JSON.stringify(snapshot, null, 2);\n  }\n\n  // Event listeners\n  createCollectionBtn.addEventListener('click', createCollection);\n  deleteCollectionBtn.addEventListener('click', deleteCollection);\n  insertDocBtn.addEventListener('click', insertDocument);\n  updateDocBtn.addEventListener('click', updateDocument);\n  deleteDocBtn.addEventListener('click', deleteDocument);\n  runQueryBtn.addEventListener('click', runQuery);\n  createIndexBtn.addEventListener('click', createIndex);\n  deleteIndexBtn.addEventListener('click', deleteIndex);\n  runAggBtn.addEventListener('click', runAggregation);\n\n  // Initial UI setup\n  refreshCollectionsUI();\n  refreshDbState();\n})();\n</script>\n</body>\n</html>"
  },
