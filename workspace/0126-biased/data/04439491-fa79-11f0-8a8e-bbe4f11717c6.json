    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #f0f0f0;\n        }\n        \n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        \n        .header h1 {\n            font-size: 24px;\n            font-weight: bold;\n        }\n        \n        .header p {\n            font-size: 18px;\n            color: #666;\n        }\n        \n        .content {\n            padding: 20px;\n            background-color: #f9f9f9;\n        }\n        \n        .content h2 {\n            font-size: 18px;\n            font-weight: bold;\n        }\n        \n        .content p {\n            font-size: 16px;\n            color: #666;\n        }\n        \n        .footer {\n            text-align: center;\n            margin-top: 20px;\n        }\n        \n        .footer p {\n            font-size: 14px;\n            color: #666;\n        }\n        \n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>CPU Scheduling</h1>\n            <p>Learn how CPU scheduling works.</p>\n        </div>\n        <div class=\"content\">\n            <h2>CPU Scheduling Process</h2>\n            <p>The CPU scheduling process is a critical component of computer architecture.</p>\n            <p>Here's a step-by-step explanation:</p>\n            <ol>\n                <li>Preemptive Scheduling</li>\n                <li>Non-Preemptive Scheduling</li>\n            </ol>\n        </div>\n        <div class=\"footer\">\n            <p>&copy; 2023 CPU Scheduling</p>\n        </div>\n    </div>\n    <script>\n        // Define the CPU scheduling process\n        const schedulingProcess = [\n            {\n                name: 'Preemptive Scheduling',\n                description: 'The CPU is preempted by the operating system and given a short burst of time.',\n                steps: [\n                    {\n                        name: 'Scheduling Algorithm',\n                        description: 'A scheduling algorithm is used to determine which process to run next.',\n                    },\n                    {\n                        name: 'Preemptive Interrupt',\n                        description: 'The operating system interrupts the process to take control.',\n                    },\n                ],\n            },\n            {\n                name: 'Non-Preemptive Scheduling',\n                description: 'The CPU continues to run processes without interruption.',\n                steps: [\n                    {\n                        name: 'Process Completion',\n                        description: 'The process completes its execution time.',\n                    },\n                    {\n                        name: 'Process Scheduling',\n                        description: 'The operating system schedules the next process.',\n                    },\n                ],\n            },\n        ];\n\n        // Function to display the CPU scheduling process\n        function displaySchedulingProcess() {\n            const process = schedulingProcess[0];\n            const steps = process.steps;\n            const html = steps.map((step) => {\n                return `\n                    <li>\n                        <h3>${step.name}</h3>\n                        <p>${step.description}</p>\n                    </li>\n                `;\n            }).join('');\n            document.getElementById('scheduling-process').innerHTML = html;\n        }\n\n        // Function to display the CPU scheduling process on hover\n        function displaySchedulingProcessOnHover() {\n            const process = schedulingProcess[0];\n            const steps = process.steps;\n            const html = steps.map((step) => {\n                return `\n                    <li>\n                        <h3>${step.name}</h3>\n                        <p>${step.description}</p>\n                        <p>Hover over to learn more</p>\n                    </li>\n                `;\n            }).join('');\n            document.getElementById('scheduling-process-on-hover').innerHTML = html;\n        }\n\n        // Add event listeners to the buttons\n        document.getElementById('preemptive-scheduling-button').addEventListener('click', displaySchedulingProcess);\n        document.getElementById('non-preemptive-scheduling-button').addEventListener('click', displaySchedulingProcessOnHover);\n\n        // Initialize the scheduling process\n        displaySchedulingProcess();\n    </script>\n</body>\n</html>"
