    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Neural Networks — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071026;\n    --glass: rgba(255,255,255,0.04);\n    --accent-a: #7cf7ff;\n    --accent-b: #9b6cff;\n    --accent-c: #ff7ecb;\n    --muted: rgba(255,255,255,0.65);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(123,83,255,0.12), transparent 8%),\n                radial-gradient(1000px 500px at 90% 80%, rgba(124,247,255,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #ecf3ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated nebula */\n  .nebula{\n    position:fixed;\n    inset: -20% -20% -20% -20%;\n    background:\n      radial-gradient(650px 350px at 10% 10%, rgba(155,108,255,0.08), transparent 8%),\n      radial-gradient(500px 300px at 85% 90%, rgba(255,126,203,0.06), transparent 6%),\n      radial-gradient(700px 350px at 50% 30%, rgba(124,247,255,0.04), transparent 10%);\n    filter: blur(40px) saturate(140%);\n    animation: nebula 20s linear infinite alternate;\n    pointer-events:none;\n    z-index:0;\n  }\n  @keyframes nebula{\n    from{transform: translateY(-20px) scale(1)}\n    to{transform: translateY(20px) scale(1.02)}\n  }\n\n  /* Layout */\n  .stage{\n    position:relative;\n    min-height:100vh;\n    display:grid;\n    align-items:center;\n    justify-items:center;\n    padding:64px;\n    z-index:2;\n  }\n\n  .card{\n    width:min(1200px,94vw);\n    height:min(720px,82vh);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.012));\n    border-radius:20px;\n    box-shadow:\n      0 8px 30px rgba(3,8,20,0.6),\n      0 1px 0 rgba(255,255,255,0.02) inset;\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    overflow:hidden;\n    position:relative;\n    border: 1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(8px) saturate(120%);\n  }\n\n  /* Left panel with title and description */\n  .panel{\n    padding:40px;\n    display:flex;\n    flex-direction:column;\n    gap:20px;\n    position:relative;\n  }\n  .brand{\n    display:flex;\n    gap:14px;\n    align-items:center;\n  }\n  .logo{\n    width:56px;height:56px;border-radius:12px;\n    background: linear-gradient(135deg,var(--accent-b),var(--accent-c));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 6px 18px rgba(155,108,255,0.14), 0 3px 8px rgba(0,0,0,0.4);\n    transform: rotate(-8deg);\n  }\n  .logo svg{filter:drop-shadow(0 8px 20px rgba(99,92,255,0.12));}\n  h1{\n    margin:0;\n    font-size:26px;\n    letter-spacing:-0.02em;\n    color: #fff;\n    font-weight:800;\n  }\n  .subtitle{\n    font-size:13px;\n    color:var(--muted);\n    margin-top:6px;\n    max-width:320px;\n    line-height:1.4;\n  }\n\n  .meta{\n    margin-top:18px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .chip{\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:8px 12px;\n    border-radius:999px;\n    font-size:13px;\n    color:var(--muted);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .dot{\n    width:10px;height:10px;border-radius:50%;\n    background:linear-gradient(180deg,var(--accent-a),var(--accent-b));\n    box-shadow:0 6px 18px rgba(124,247,255,0.06);\n  }\n\n  .description{\n    margin-top:18px;\n    color: rgba(236,243,255,0.9);\n    font-size:15px;\n    line-height:1.6;\n    opacity:0.95;\n  }\n\n  /* Small controls */\n  .controls{\n    margin-top:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    padding:12px 16px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--muted);\n    font-weight:600;\n    cursor:pointer;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition:all .22s cubic-bezier(.2,.9,.25,1);\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .btn:hover{\n    transform:translateY(-3px);\n    box-shadow:0 10px 30px rgba(18,24,40,0.5);\n  }\n  .btn-cta{\n    background: linear-gradient(90deg,var(--accent-a),var(--accent-b));\n    color: #041023;\n    box-shadow: 0 8px 30px rgba(124,247,255,0.06);\n    border: none;\n  }\n\n  .tiny{\n    font-size:12px;color:var(--muted);\n  }\n\n  /* Right: visualization */\n  .viz{\n    position:relative;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:28px;\n  }\n  .canvas-wrap{\n    width:100%;\n    height:100%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n\n  svg.network{\n    width:100%;\n    height:100%;\n    overflow:visible;\n    display:block;\n  }\n\n  /* Node styles */\n  .node{\n    transition:transform .28s cubic-bezier(.2,.9,.25,1);\n    transform-origin:center;\n  }\n  .node .core{\n    fill: url(#g-core);\n    stroke: rgba(255,255,255,0.12);\n    stroke-width:1;\n    filter: url(#softGlow);\n  }\n  .node .halo{\n    fill:none;\n    stroke: url(#g-halo);\n    stroke-width:10;\n    opacity:0.08;\n    filter: blur(8px);\n  }\n  .node.pulse .core{\n    animation: nodePulse 2.2s ease-in-out infinite;\n  }\n  @keyframes nodePulse{\n    0%{ transform: scale(1); filter: drop-shadow(0 0 18px rgba(124,247,255,0.12));}\n    50%{ transform: scale(1.12); filter: drop-shadow(0 0 36px rgba(155,108,255,0.12));}\n    100%{ transform: scale(1); filter: drop-shadow(0 0 18px rgba(124,247,255,0.12));}\n  }\n\n  /* Edge base */\n  .edge{\n    stroke: rgba(255,255,255,0.04);\n    stroke-width:1.6;\n    fill:none;\n    transition:opacity .32s;\n  }\n  /* Highlight moving light */\n  .edge-light{\n    stroke: url(#g-light);\n    stroke-width:3.6;\n    stroke-linecap:round;\n    fill:none;\n    filter: drop-shadow(0 6px 20px rgba(124,247,255,0.12));\n    mix-blend-mode:screen;\n    /* animation is applied inline */\n  }\n\n  /* animation keyframe using CSS var for length */\n  @keyframes dash {\n    from { stroke-dashoffset: 0; }\n    to   { stroke-dashoffset: calc(var(--plen) * -1); }\n  }\n\n  /* Pause all animations elegantly */\n  .paused .edge-light,\n  .paused .node .core {\n    animation-play-state: paused !important;\n  }\n\n  /* Floating micro orbs */\n  .orbs{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    z-index:1;\n  }\n  .orb{\n    position:absolute;\n    width:12px;height:12px;border-radius:50%;\n    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.8), rgba(124,247,255,0.85));\n    opacity:0.09;\n    filter: blur(6px);\n    transform: translateZ(0);\n    animation: floaty 8s linear infinite;\n  }\n  @keyframes floaty{\n    0%{ transform: translateY(0) translateX(0) }\n    50%{ transform: translateY(-26px) translateX(14px) }\n    100%{ transform: translateY(0) translateX(0) }\n  }\n\n  /* small UX: play button center */\n  .floating-controls{\n    position:absolute;\n    right:18px;\n    bottom:18px;\n    z-index:5;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .circle-btn{\n    width:54px;height:54px;border-radius:999px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:inline-grid;\n    place-items:center;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.03);\n    cursor:pointer;\n    box-shadow: 0 8px 26px rgba(3,8,20,0.6);\n    transition: transform .16s, box-shadow .16s;\n  }\n  .circle-btn:hover{ transform: translateY(-4px); box-shadow: 0 14px 40px rgba(3,8,20,0.66); }\n  .circle-btn.play{ background: linear-gradient(90deg,var(--accent-a),var(--accent-b)); color:#041023; }\n  .i-btn{ width:44px;height:44px;border-radius:10px;background:rgba(255,255,255,0.02); display:grid; place-items:center; border:1px solid rgba(255,255,255,0.03); }\n\n  /* Info modal */\n  .modal{\n    position:fixed;\n    inset:0;\n    display:grid;\n    place-items:center;\n    background: linear-gradient(180deg, rgba(2,6,12,0.6), rgba(2,6,12,0.6));\n    z-index:60;\n    opacity:0;\n    pointer-events:none;\n    transition:opacity .28s;\n  }\n  .modal.open{ opacity:1; pointer-events:auto }\n  .modal-card{\n    width:min(760px,94vw);\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:16px;\n    padding:24px;\n    box-shadow: 0 18px 60px rgba(2,8,20,0.7);\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n  }\n  .modal h3{ margin:0 0 10px 0; color:#fff; font-size:18px; }\n  .modal p{ margin:0; line-height:1.6; color:rgba(236,243,255,0.95) }\n\n  /* Responsiveness */\n  @media (max-width:980px){\n    .card{ grid-template-columns: 1fr; height:auto; padding-bottom:28px; }\n    .viz{ order: -1; height:420px; }\n    .panel{ padding:28px; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"nebula\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\">\n    <div class=\"card\" id=\"cardRoot\">\n      <div class=\"panel\">\n        <div class=\"brand\">\n          <div class=\"logo\" aria-hidden=\"true\">\n            <!-- stylized neuron icon -->\n            <svg width=\"34\" height=\"34\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <defs>\n                <linearGradient id=\"lg\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#9B6CFF\"/>\n                  <stop offset=\"1\" stop-color=\"#FF7ECB\"/>\n                </linearGradient>\n              </defs>\n              <path d=\"M12 3c1.1 0 2 .9 2 2v2.2c.9.2 1.7.6 2.4 1.2l1.6-1.6c.8-.8 2.1-.8 2.8 0s.8 2.1 0 2.8l-2 2 2.6 2.6c.7.7.7 2 0 2.8-.7.7-2 .7-2.8 0L18 15l-2-2c-.8.6-1.8 1-2.8 1.2V18c0 1.1-.9 2-2 2s-2-.9-2-2v-2.2c-1-.2-2-.6-2.8-1.2L6.8 17c-.7.7-2 .7-2.8 0-.7-.7-.7-2 0-2.8L6.5 11 4.5 9c-.8-.8-.8-2.1 0-2.8.7-.7 2-.7 2.8 0L8.9 7.6c.8-.6 1.8-1 2.8-1.2V5c0-1.1.9-2 2-2z\" fill=\"url(#lg)\"/>\n            </svg>\n          </div>\n          <div>\n            <h1>Neural Networks</h1>\n            <div class=\"subtitle\">Aesthetic visualization of layered networks — activations, connections, and the flow of information.</div>\n          </div>\n        </div>\n\n        <div class=\"meta\">\n          <div class=\"chip\"><span class=\"dot\"></span> Layered architecture</div>\n          <div class=\"chip\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:.8\"><path d=\"M12 2v2M20 12h2M12 20v2M4 12H2M16.24 7.76l1.42-1.42M6.34 17.66l1.42-1.42M17.66 17.66l1.42 1.42M4.94 4.94l1.42 1.42\" stroke=\"rgba(255,255,255,0.6)\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg> Dynamic links</div>\n        </div>\n\n        <div class=\"description\">\n          Observe a stylized feed-forward neural network where softly glowing nodes and flowing highlights represent activations moving through layers. The visualization balances scientific motifs with modern graphic design — gradients, glows, and smooth motion combine to convey complexity with clarity.\n        </div>\n\n        <div class=\"controls\">\n          <button class=\"btn btn-cta\" id=\"btnExplore\" title=\"Show explanation (minimal interactivity)\">Learn the idea</button>\n          <div style=\"flex:1\"></div>\n          <div class=\"tiny\">Rendering: vector & GPU-friendly</div>\n        </div>\n      </div>\n\n      <div class=\"viz\">\n        <div class=\"canvas-wrap\">\n          <svg class=\"network\" id=\"networkSVG\" viewBox=\"0 0 1200 720\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Stylized neural network visualization\">\n            <defs>\n              <linearGradient id=\"g-core\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#9B6CFF\"/>\n                <stop offset=\"1\" stop-color=\"#7CF7FF\"/>\n              </linearGradient>\n              <linearGradient id=\"g-halo\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7cf7ff\"/>\n                <stop offset=\"1\" stop-color=\"#ff7ecb\"/>\n              </linearGradient>\n              <linearGradient id=\"g-light\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#ffffff\"/>\n                <stop offset=\"0.4\" stop-color=\"#9B6CFF\"/>\n                <stop offset=\"1\" stop-color=\"#7CF7FF\"/>\n              </linearGradient>\n\n              <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"6\" result=\"blur\"/>\n                <feMerge>\n                  <feMergeNode in=\"blur\"/>\n                  <feMergeNode in=\"SourceGraphic\"/>\n                </feMerge>\n              </filter>\n            </defs>\n\n            <!-- Background subtle grid lines -->\n            <g opacity=\"0.03\">\n              <rect x=\"0\" y=\"0\" width=\"1200\" height=\"720\" fill=\"none\" stroke=\"none\"/>\n            </g>\n\n            <!-- Dynamic network will be injected here -->\n            <g id=\"edgesLayer\"></g>\n            <g id=\"nodesLayer\"></g>\n\n            <!-- aesthetic floating accent -->\n            <g transform=\"translate(920 120) rotate(12)\" opacity=\"0.9\">\n              <circle cx=\"0\" cy=\"0\" r=\"62\" fill=\"url(#g-halo)\" opacity=\"0.12\" />\n            </g>\n          </svg>\n\n          <div class=\"orbs\" aria-hidden=\"true\">\n            <div class=\"orb\" style=\"left:12%; top:18%; animation-duration:10s; opacity:0.06;\"></div>\n            <div class=\"orb\" style=\"left:84%; top:30%; width:16px;height:16px; animation-duration:13s; opacity:0.05;\"></div>\n            <div class=\"orb\" style=\"left:42%; top:78%; animation-duration:11s; opacity:0.04;\"></div>\n          </div>\n\n          <div class=\"floating-controls\" title=\"Animation controls\">\n            <div class=\"i-btn\" id=\"infoBtn\" title=\"About\">i</div>\n            <div class=\"circle-btn play\" id=\"playBtn\" title=\"Pause / Play (1 control)\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 3v18h4V3H5zM15 3v18h4V3h-4z\" fill=\"currentColor\"/></svg></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Modal -->\n  <div class=\"modal\" id=\"modal\">\n    <div class=\"modal-card\">\n      <h3>What you’re seeing</h3>\n      <p>\n        This is a stylized feed-forward neural network: nodes are organized into layers and connected by weighted links.\n        The brighter pulses represent information (activations) propagating through the network from left to right.\n        In real neural networks, weights and activations are numeric; here, motion and light communicate flow, depth, and connectivity with visual elegance.\n      </p>\n      <div style=\"display:flex;justify-content:flex-end;margin-top:14px;\">\n        <button class=\"btn\" id=\"modalClose\">Close</button>\n      </div>\n    </div>\n  </div>\n\n<script>\n  (function(){\n    const svg = document.getElementById('networkSVG');\n    const edgesLayer = document.getElementById('edgesLayer');\n    const nodesLayer = document.getElementById('nodesLayer');\n    const playBtn = document.getElementById('playBtn');\n    const infoBtn = document.getElementById('infoBtn');\n    const modal = document.getElementById('modal');\n    const modalClose = document.getElementById('modalClose');\n    const btnExplore = document.getElementById('btnExplore');\n    const cardRoot = document.getElementById('cardRoot');\n\n    // Configuration: a few layers (limited complexity for aesthetics & performance)\n    const layers = [5, 8, 6, 4]; // left -> right\n    const margin = {top:80, bottom:80, left:80, right:80};\n    const viewW = 1200, viewH = 720;\n    const areaW = viewW - margin.left - margin.right;\n    const areaH = viewH - margin.top - margin.bottom;\n    const layerGap = areaW / (layers.length - 1);\n\n    // compute node positions\n    const nodes = [];\n    layers.forEach((count, li) => {\n      const x = margin.left + li * layerGap;\n      const gap = areaH / (count + 1);\n      for (let i=0;i<count;i++){\n        const y = margin.top + (i+1) * gap;\n        nodes.push({id:`n-${li}-${i}`, layer:li, ix:i, x, y});\n      }\n    });\n\n    // map for quick access by layer, index\n    const nodesByLayer = {};\n    nodes.forEach(n=>{\n      nodesByLayer[n.layer] = nodesByLayer[n.layer] || [];\n      nodesByLayer[n.layer].push(n);\n    });\n\n    // create SVG elements: edges then nodes\n    function createPath(x1,y1,x2,y2){\n      const dx = Math.abs(x2-x1);\n      const cpOffset = dx * 0.4;\n      const cp1x = x1 + cpOffset;\n      const cp2x = x2 - cpOffset;\n      const cp1y = y1;\n      const cp2y = y2;\n      return `M ${x1} ${y1} C ${cp1x} ${cp1y} ${cp2x} ${cp2y} ${x2} ${y2}`;\n    }\n\n    // Create edges: connect every node to many in next layer (dense-ish but not full for clarity)\n    const edgeElems = [];\n    for (let li = 0; li < layers.length - 1; li++){\n      const leftNodes = nodesByLayer[li];\n      const rightNodes = nodesByLayer[li+1];\n      leftNodes.forEach(ln => {\n        // connect to a subset for visual balance\n        const targets = rightNodes.filter((_, idx) => Math.random() > 0.18); // sparse random\n        targets.forEach(rn => {\n          const d = createPath(ln.x, ln.y, rn.x, rn.y);\n          const base = document.createElementNS('http://www.w3.org/2000/svg','path');\n          base.setAttribute('d', d);\n          base.setAttribute('class','edge');\n          edgesLayer.appendChild(base);\n\n          const light = document.createElementNS('http://www.w3.org/2000/svg','path');\n          light.setAttribute('d', d);\n          light.setAttribute('class','edge-light');\n          // assign animation properties via CSS variables; compute path length\n          edgesLayer.appendChild(light);\n          edgeElems.push({base, light});\n        });\n      });\n    }\n\n    // Create nodes\n    const nodeElems = [];\n    nodes.forEach(n=>{\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${n.x}, ${n.y})`);\n      g.setAttribute('class', 'node pulse');\n      // halo\n      const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      halo.setAttribute('class','halo');\n      halo.setAttribute('r', 18);\n      halo.setAttribute('cx', 0);\n      halo.setAttribute('cy', 0);\n      // core\n      const core = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      core.setAttribute('class','core');\n      core.setAttribute('r', 8);\n      core.setAttribute('cx', 0);\n      core.setAttribute('cy', 0);\n\n      g.appendChild(halo);\n      g.appendChild(core);\n\n      nodesLayer.appendChild(g);\n      nodeElems.push({g, core, halo, data:n});\n    });\n\n    // Apply per-edge dynamic stroke-dasharray & animation durations\n    edgeElems.forEach((e, idx) => {\n      try{\n        const path = e.light;\n        const len = path.getTotalLength();\n        // dash length relative to path\n        const dash = Math.max(6, Math.min(60, len / (6 + Math.random()*10)));\n        path.style.setProperty('--plen', len);\n        path.style.setProperty('--dash', dash);\n        path.style.strokeDasharray = `${dash} ${len}`;\n        path.style.strokeDashoffset = 0;\n        // animation duration and delay for organic motion\n        const duration = 2.8 + Math.random() * 2.4; // seconds\n        const delay = Math.random() * -duration; // negative so pulses are already moving\n        path.style.animation = `dash ${duration}s linear infinite`;\n        path.style.animationDelay = `${delay}s`;\n        // subtle opacity variation\n        path.style.opacity = 0.9 - Math.random() * 0.6;\n      }catch(err){}\n    });\n\n    // animate nodes with stagger\n    nodeElems.forEach((ne, i)=>{\n      const delay = (i % 7) * 0.08 + (Math.random()*0.2);\n      ne.g.style.transitionDelay = `${delay}s`;\n      // slight random rotation and scale for design\n      const rx = (Math.random()-0.5) * 6;\n      ne.g.style.transform = `translate(${ne.data.x}px, ${ne.data.y}px)`;\n    });\n\n    // play/pause management\n    let isPlaying = true;\n    function setPlaying(playing){\n      isPlaying = playing;\n      if(playing){\n        playBtn.classList.add('play');\n        playBtn.innerHTML = '<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 3v18h4V3H5zM15 3v18h4V3h-4z\" fill=\"currentColor\"/></svg>';\n        cardRoot.classList.remove('paused');\n      } else {\n        playBtn.classList.remove('play');\n        playBtn.innerHTML = '<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 4l14 8-14 8V4z\" fill=\"currentColor\"/></svg>'; // play triangle\n        cardRoot.classList.add('paused');\n      }\n    }\n\n    playBtn.addEventListener('click', ()=>{\n      setPlaying(!isPlaying);\n    });\n\n    // Info modal toggles\n    function openModal(){ modal.classList.add('open'); }\n    function closeModal(){ modal.classList.remove('open'); }\n    infoBtn.addEventListener('click', openModal);\n    modalClose.addEventListener('click', closeModal);\n    btnExplore.addEventListener('click', openModal);\n\n    // Also close modal on background click\n    modal.addEventListener('click', (e)=>{\n      if(e.target === modal) closeModal();\n    });\n\n    // Responsive: adapt svg viewBox on resize (kept simple)\n    function resize(){\n      // nothing heavy; preserve viewBox automatically, elements are placed with fixed coords relative to viewBox\n    }\n    window.addEventListener('resize', resize);\n\n    // gentle subtle motion: animate slight vertical sway of layers via CSS transforms\n    let sway = 0;\n    function animateSway(){\n      sway += 0.006;\n      const yOff = Math.sin(sway) * 4; // small sway\n      nodesLayer.style.transform = `translateY(${yOff}px)`;\n      edgesLayer.style.transform = `translateY(${yOff}px)`;\n      requestAnimationFrame(animateSway);\n    }\n    animateSway();\n\n    // Initial state\n    setPlaying(true);\n\n    // Accessibility: keyboard toggle (space) limited to simple control\n    window.addEventListener('keydown', (e)=>{\n      if(e.code === 'Space'){ e.preventDefault(); setPlaying(!isPlaying); }\n      if(e.key.toLowerCase() === 'i'){ openModal(); }\n    });\n\n    // finally: tiny decorative entrance animation\n    setTimeout(()=>{\n      nodeElems.forEach((n,i)=>{\n        n.g.style.transform = `translate(${n.data.x}px, ${n.data.y}px) scale(1)`;\n        n.g.style.opacity = 1;\n      });\n    }, 240);\n\n  })();\n</script>\n</body>\n</html>"
