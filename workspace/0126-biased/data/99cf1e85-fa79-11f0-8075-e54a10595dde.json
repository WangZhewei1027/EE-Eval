    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Prim's Algorithm Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #controls { margin-bottom: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Prim's Algorithm Interactive Demo</h1>\n\n<div id=\"controls\">\n    <label for=\"numNodes\">Number of Nodes:</label>\n    <input type=\"number\" id=\"numNodes\" value=\"5\" min=\"2\" max=\"20\">\n    <button id=\"generateGraph\">Generate Graph</button>\n    <button id=\"runPrim\">Run Prim's Algorithm</button>\n</div>\n\n<div id=\"graphRepresentation\"></div>\n\n<h2>Graph Edge Weights</h2>\n<pre id=\"edgeWeights\"></pre>\n\n<h2>Minimum Spanning Tree</h2>\n<pre id=\"mstOutput\"></pre>\n\n<script>\n    class Graph {\n        constructor(numNodes) {\n            this.numNodes = numNodes;\n            this.adjacencyMatrix = Array.from({ length: numNodes }, () => Array(numNodes).fill(Infinity));\n            for (let i = 0; i < numNodes; i++) {\n                this.adjacencyMatrix[i][i] = 0;\n            }\n        }\n\n        addEdge(u, v, weight) {\n            this.adjacencyMatrix[u][v] = weight;\n            this.adjacencyMatrix[v][u] = weight;\n        }\n\n        getEdges() {\n            const edges = [];\n            for (let i = 0; i < this.numNodes; i++) {\n                for (let j = i + 1; j < this.numNodes; j++) {\n                    if (this.adjacencyMatrix[i][j] !== Infinity) {\n                        edges.push({ u: i, v: j, weight: this.adjacencyMatrix[i][j] });\n                    }\n                }\n            }\n            return edges;\n        }\n\n        prim() {\n            const visited = Array(this.numNodes).fill(false);\n            const minHeap = [{ weight: 0, node: 0 }];\n            const mst = [];\n            let totalWeight = 0;\n\n            while (minHeap.length) {\n                const { weight, node } = minHeap.pop() || {};\n\n                if (visited[node]) continue;\n                visited[node] = true;\n                totalWeight += weight;\n\n                for (let i = 0; i < this.numNodes; i++) {\n                    if (!visited[i] && this.adjacencyMatrix[node][i] < Infinity) {\n                        minHeap.push({ weight: this.adjacencyMatrix[node][i], node: i });\n                        mst.push({ u: node, v: i, weight: this.adjacencyMatrix[node][i] });\n                    }\n                }\n                minHeap.sort((a, b) => a.weight - b.weight);\n            }\n\n            return { mst, totalWeight };\n        }\n    }\n\n    function displayGraph(graph) {\n        const representation = document.getElementById('graphRepresentation');\n        const edges = graph.getEdges();\n        representation.innerHTML = edges.map(edge => `(${edge.u} -- ${edge.v}) [Weight: ${edge.weight}]`).join('\\n');\n        document.getElementById('edgeWeights').innerText = JSON.stringify(graph.adjacencyMatrix);\n    }\n\n    document.getElementById('generateGraph').addEventListener('click', () => {\n        const numNodes = parseInt(document.getElementById('numNodes').value);\n        const graph = new Graph(numNodes);\n        for (let i = 0; i < numNodes; i++) {\n            for (let j = i + 1; j < numNodes; j++) {\n                const weight = Math.floor(Math.random() * 10) + 1; // Random weights from 1 to 10\n                graph.addEdge(i, j, weight);\n            }\n        }\n        displayGraph(graph);\n        window.currentGraph = graph; // Store current graph in a global variable\n    });\n\n    document.getElementById('runPrim').addEventListener('click', () => {\n        if (!window.currentGraph) {\n            alert(\"Generate a graph first!\");\n            return;\n        }\n        const { mst, totalWeight } = window.currentGraph.prim();\n        document.getElementById('mstOutput').innerText = `MST Edges:\\n${mst.map(edge => `(${edge.u} -- ${edge.v}) [Weight: ${edge.weight}]`).join('\\n')}\\nTotal Weight: ${totalWeight}`;\n    });\n</script>\n\n</body>\n</html>"
