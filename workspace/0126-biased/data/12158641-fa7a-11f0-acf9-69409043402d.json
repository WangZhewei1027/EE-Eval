  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>CPU Scheduling Interactive Simulator</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    white-space: pre-wrap;\n  }\n  button, input, select {\n    font-family: monospace, monospace;\n    font-size: 12px;\n  }\n  textarea {\n    font-family: monospace, monospace;\n    font-size: 12px;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 10px;\n  }\n  td, th {\n    padding: 2px 5px;\n    border: 1px solid black;\n    text-align: center;\n    font-size: 12px;\n  }\n  label {\n    font-weight: bold;\n  }\n  #log {\n    width: 100%;\n    height: 120px;\n  }\n  #ganttChart td {\n    padding: 2px 8px;\n    border: 1px solid black;\n    vertical-align: middle;\n  }\n  #ganttChart td.process {\n    border-left: none;\n    border-right: none;\n  }\n</style>\n</head>\n<body>\n<h1>CPU Scheduling Simulator</h1>\n\n<div>\n<label for=\"strategy\">Select Scheduling Algorithm:</label>\n<select id=\"strategy\" title=\"Choose scheduling algorithm\">\n  <option value=\"fcfs\">First-Come, First-Served (FCFS)</option>\n  <option value=\"sjf\">Shortest Job First (SJF) - Non-preemptive</option>\n  <option value=\"srtf\">Shortest Remaining Time First (SRTF) - Preemptive SJF</option>\n  <option value=\"priority_np\">Priority (Non-preemptive)</option>\n  <option value=\"priority_p\">Priority (Preemptive)</option>\n  <option value=\"roundrobin\">Round Robin (RR)</option>\n</select>\n</div>\n\n<br />\n<div>\n<label>Add Process:</label><br />\n<table>\n<tr>\n  <td><label for=\"pid\">PID: </label></td>\n  <td><input type=\"text\" id=\"pid\" size=\"3\" title=\"Process ID (unique)\"/></td>\n  <td><label for=\"arrival\">Arrival Time:</label></td>\n  <td><input type=\"number\" id=\"arrival\" min=\"0\" size=\"3\" value=\"0\" title=\"Time the process arrives on ready queue\"/></td>\n  <td><label for=\"burst\">CPU Burst Time:</label></td>\n  <td><input type=\"number\" id=\"burst\" min=\"1\" size=\"3\" value=\"1\" title=\"CPU time needed\"/></td>\n  <td><label for=\"priority\">Priority:</label></td>\n  <td><input type=\"number\" id=\"priority\" min=\"0\" size=\"3\" value=\"0\" title=\"Lower number = higher priority\"/></td>\n  <td><button id=\"addProcess\">Add Process</button></td>\n</tr>\n</table>\n<div>\n<span id=\"addProcessError\" style=\"color:red;\"></span>\n</div>\n</div>\n\n<br />\n<div>\n<label>Set Quantum (for Round Robin):</label>\n<input type=\"number\" id=\"quantum\" min=\"1\" value=\"2\" size=\"3\" title=\"Time quantum unit\"/>\n<button id=\"setQuantum\">Set Quantum</button>\n<span id=\"quantumStatus\"></span>\n</div>\n\n<br />\n<div>\n<button id=\"startSim\">Start Simulation</button>\n<button id=\"stepSim\" disabled>Step</button>\n<button id=\"autoSim\" disabled>Auto Run</button>\n<button id=\"pauseSim\" disabled>Pause</button>\n<button id=\"resetSim\">Reset</button>\n</div>\n\n<br />\n<div>\n<label>Processes Table:</label>\n<table id=\"processTable\">\n  <thead><tr><th>PID</th><th>Arrival</th><th>Burst</th><th>Remaining</th><th>Priority</th></tr></thead>\n  <tbody>\n  </tbody>\n</table>\n</div>\n\n<br />\n<div>\n<label>Simulation Time: <span id=\"currentTime\">0</span></label>\n</div>\n\n<div>\n<label>CPU State:</label> <span id=\"cpuState\">Idle</span>\n</div>\n\n<div>\n<label>Ready Queue (by PID):</label> <span id=\"readyQueue\">Empty</span>\n</div>\n\n<div>\n<label>Log:</label><br />\n<textarea id=\"log\" readonly spellcheck=\"false\"></textarea>\n</div>\n\n<div>\n<label>Gantt Chart (Timeline):</label><br />\n<table id=\"ganttChart\">\n  <thead><tr id=\"ganttHeader\"></tr></thead>\n  <tbody><tr id=\"ganttProcess\"></tr></tbody>\n</table>\n</div>\n\n<script>\n(function(){\n  // State and variables\n  let processes = []; // array of {pid, arrival, burst, remaining, priority, startTime, finishTime, waitingTime, turnaroundTime}\n  let readyQueue = [];\n  let currentTime = 0;\n  let cpu = null; // process currently running (pid)\n  let logElem = document.getElementById('log');\n  let strategySelect = document.getElementById('strategy');\n  let quantumInput = document.getElementById('quantum');\n  let quantumValue = parseInt(quantumInput.value, 10) || 2;\n  let autoInterval = null;\n  let isRunning = false;\n  let ganttData = []; // [{pid, start, end}]\n  let rrQueue = []; // for Round Robin queue management\n \n  // Elements references\n  const processTableBody = document.querySelector('#processTable tbody');\n  const currentTimeElem = document.getElementById('currentTime');\n  const cpuStateElem = document.getElementById('cpuState');\n  const readyQueueElem = document.getElementById('readyQueue');\n  const addProcessErrorElem = document.getElementById('addProcessError');\n\n  const startSimButton = document.getElementById('startSim');\n  const stepSimButton = document.getElementById('stepSim');\n  const autoSimButton = document.getElementById('autoSim');\n  const pauseSimButton = document.getElementById('pauseSim');\n  const resetSimButton = document.getElementById('resetSim');\n  const setQuantumButton = document.getElementById('setQuantum');\n  const quantumStatusElem = document.getElementById('quantumStatus');\n\n  // Gantt chart elements\n  const ganttHeader = document.getElementById('ganttHeader');\n  const ganttProcessRow = document.getElementById('ganttProcess');\n\n  // Input fields\n  const pidInput = document.getElementById('pid');\n  const arrivalInput = document.getElementById('arrival');\n  const burstInput = document.getElementById('burst');\n  const priorityInput = document.getElementById('priority');\n\n  // ---------- Utility Functions ----------\n\n  // Logs a message with timestamp\n  function log(message) {\n    logElem.value += `[Time ${currentTime}] ${message}\\n`;\n    logElem.scrollTop = logElem.scrollHeight;\n  }\n\n  // Update all UI elements reflecting current state\n  function updateUI() {\n    // Update process table\n    processTableBody.innerHTML = '';\n    for(let p of processes) {\n      const tr = document.createElement('tr');\n      tr.innerHTML = `<td>${p.pid}</td><td>${p.arrival}</td><td>${p.burst}</td><td>${p.remaining}</td><td>${p.priority}</td>`;\n      processTableBody.appendChild(tr);\n    }\n\n    // Update current time\n    currentTimeElem.textContent = currentTime;\n\n    // Update CPU state\n    cpuStateElem.textContent = cpu ? cpu.pid : 'Idle';\n\n    // Update ready queue display (by PID)\n    if(readyQueue.length === 0) {\n      readyQueueElem.textContent = 'Empty';\n    } else {\n      readyQueueElem.textContent = readyQueue.map(p => p.pid).join(', ');\n    }\n\n    // Update quantum status\n    quantumStatusElem.textContent = `(Quantum = ${quantumValue})`;\n\n    // Update gantt chart\n    updateGanttChart();\n  }\n\n  // Compare function for sorting arrival first, then PID lex order\n  function compareArrival(a,b) {\n    if(a.arrival !== b.arrival) return a.arrival - b.arrival;\n    if(a.pid < b.pid) return -1;\n    if(a.pid > b.pid) return 1;\n    return 0;\n  }\n\n  // Find next processes to add to ready queue at currentTime\n  function addReadyProcesses() {\n    let added = false;\n    for(let p of processes) {\n      if(p.arrival <= currentTime && !readyQueue.includes(p) && p.remaining > 0 && (!cpu || cpu.pid !== p.pid)) {\n        // Add to ready queue according to strategy\n        readyQueue.push(p);\n        added = true;\n      }\n    }\n    if(added) reorderReadyQueue();\n  }\n\n  // Reorder ready queue according to current strategy\n  function reorderReadyQueue() {\n    let strat = strategySelect.value;\n    if(strat === 'fcfs') {\n      // Sort by arrival time, then PID\n      readyQueue.sort((a,b) => {\n        if(a.arrival !== b.arrival) return a.arrival - b.arrival;\n        if(a.pid < b.pid) return -1;\n        if(a.pid > b.pid) return 1;\n        return 0;\n      });\n    } else if(strat === 'sjf') {\n      // Non-preemptive SJF: sort by burst time, then arrival, then PID\n      readyQueue.sort((a,b) => {\n        if(a.burst !== b.burst) return a.burst - b.burst;\n        if(a.arrival !== b.arrival) return a.arrival - b.arrival;\n        if(a.pid < b.pid) return -1;\n        if(a.pid > b.pid) return 1;\n        return 0;\n      });\n    } else if(strat === 'srtf') {\n      // Preemptive SJF: sort by remaining burst time, then arrival, then PID\n      readyQueue.sort((a,b) => {\n        if(a.remaining !== b.remaining) return a.remaining - b.remaining;\n        if(a.arrival !== b.arrival) return a.arrival - b.arrival;\n        if(a.pid < b.pid) return -1;\n        if(a.pid > b.pid) return 1;\n        return 0;\n      });\n    } else if(strat === 'priority_np' || strat === 'priority_p') {\n      // Sort by priority (lower is higher priority), then arrival, then PID\n      readyQueue.sort((a,b) => {\n        if(a.priority !== b.priority) return a.priority - b.priority;\n        if(a.arrival !== b.arrival) return a.arrival - b.arrival;\n        if(a.pid < b.pid) return -1;\n        if(a.pid > b.pid) return 1;\n        return 0;\n      });\n    } else if(strat === 'roundrobin') {\n      // RR uses rrQueue management, so this function does not modify readyQueue order\n      // But ensure readyQueue copy for display is consistent with rrQueue order:\n      readyQueue = rrQueue.slice();\n    }\n  }\n\n  // Get next process to run according to strategy (if CPU idle)\n  function selectNextProcess() {\n    let strat = strategySelect.value;\n    if(strat === 'roundrobin') {\n      // RR: get next process from rrQueue, if CPU idle or quantum expired\n      if(rrQueue.length === 0) return null;\n      return rrQueue[0]; // the front of RR queue\n    }\n    if(readyQueue.length === 0) return null;\n    if(strat === 'fcfs') return readyQueue[0];\n    if(strat === 'sjf') return readyQueue[0];\n    if(strat === 'srtf') return readyQueue[0];\n    if(strat === 'priority_np' || strat === 'priority_p') return readyQueue[0];\n    return null;    \n  }\n\n  // Remove process from readyQueue and rrQueue if present\n  function removeFromQueues(process) {\n    readyQueue = readyQueue.filter(p => p.pid !== process.pid);\n    rrQueue = rrQueue.filter(p => p.pid !== process.pid);\n  }\n\n  // Add to RR queue (if not already present), keeping order\n  function pushToRRQueue(process) {\n    if(!rrQueue.find(p => p.pid === process.pid)) {\n      rrQueue.push(process);\n      reorderReadyQueue(); // keep readyQueue synchronized for display\n    }\n  }\n\n  // Advance the simulation one time unit (step)\n  // Returns true if simulation is still active, false if ended\n  function stepSimulation() {\n    if(!isRunning) return false;\n\n    // Add new arrivals to ready queue\n    addReadyProcesses();\n\n    // For preemptive strategies, always check preemption before running\n    let strat = strategySelect.value;\n    if(cpu) {\n      // Preemptive check\n      if(strat === 'srtf') {\n        reorderReadyQueue();\n        if(readyQueue.length > 0 && readyQueue[0].remaining < cpu.remaining) {\n          // Preempt current process, push CPU to ready queue\n          log(`Preempting process ${cpu.pid} for ${readyQueue[0].pid} (Shorter remaining time found)`);\n          // Save gantt chart segment end time\n          endGanttSegment(currentTime);\n          // Put cpu back in ready queue\n          pushToRRQueue(cpu);\n          cpu = readyQueue.shift();\n          startGanttSegment(cpu.pid, currentTime);\n          removeFromQueues(cpu);\n        }\n      } else if(strat === 'priority_p') {\n        reorderReadyQueue();\n        if(readyQueue.length > 0 && readyQueue[0].priority < cpu.priority) {\n          // Higher priority process arrived - preempt cpu\n          log(`Preempting process ${cpu.pid} for ${readyQueue[0].pid} (Higher priority arrived)`);\n          endGanttSegment(currentTime);\n          pushToRRQueue(cpu);\n          cpu = readyQueue.shift();\n          startGanttSegment(cpu.pid, currentTime);\n          removeFromQueues(cpu);\n        }\n      }\n    }\n\n    // Choose process if none running\n    if(!cpu) {\n      reorderReadyQueue();\n      if(strat === 'roundrobin') {\n        if(rrQueue.length === 0) {\n          cpu = null;\n        } else {\n          cpu = rrQueue.shift();\n          startGanttSegment(cpu.pid, currentTime);\n        }\n      } else {\n        cpu = selectNextProcess();\n        if(cpu) {\n          startGanttSegment(cpu.pid, currentTime);\n          removeFromQueues(cpu);\n        }\n      }\n      if(cpu) log(`Process ${cpu.pid} started/resumed execution`);\n    }\n\n    if(!cpu) {\n      log(`CPU idle at time ${currentTime}`);\n      currentTime++;\n      updateUI();\n      return true;\n    }\n\n    // Run CPU process for one time unit\n    cpu.remaining--;\n    log(`Running process ${cpu.pid}: remaining time is ${cpu.remaining}`);\n\n    // For Round Robin track quantum\n    if(strat === 'roundrobin') {\n      rrQuantumCount++;\n      if(cpu.remaining === 0) {\n        log(`Process ${cpu.pid} finished at time ${currentTime + 1}`);\n        finishProcess(cpu);\n        endGanttSegment(currentTime + 1);\n        cpu = null;\n        rrQuantumCount = 0;\n      } else if(rrQuantumCount >= quantumValue) {\n        // Time slice exhausted - preempt\n        log(`Quantum expired for process ${cpu.pid} at time ${currentTime + 1}`);\n        endGanttSegment(currentTime + 1);\n        pushToRRQueue(cpu);\n        cpu = null;\n        rrQuantumCount = 0;\n      }\n    } else {\n      // Other strategies: check process completion\n      if(cpu.remaining === 0) {\n        log(`Process ${cpu.pid} finished at time ${currentTime + 1}`);\n        finishProcess(cpu);\n        endGanttSegment(currentTime + 1);\n        cpu = null;\n      }\n    }\n\n    currentTime++;\n    addReadyProcesses();\n    updateUI();\n\n    // Check if all finished\n    if(processes.every(p => p.remaining === 0)) {\n      log('All processes completed execution');\n      isRunning = false;\n      stepSimButton.disabled = true;\n      autoSimButton.disabled = true;\n      pauseSimButton.disabled = true;\n      startSimButton.disabled = false;\n      return false;\n    }\n\n    return true;\n  }\n\n  // Finish process: set finish time etc\n  function finishProcess(p) {\n    p.finishTime = currentTime + 1;\n    p.turnaroundTime = p.finishTime - p.arrival;\n    p.waitingTime = p.turnaroundTime - p.burst;\n    removeFromQueues(p);\n  }\n\n  // Reset simulation state\n  function resetSimulation(fullReset = false) {\n    currentTime = 0;\n    cpu = null;\n    readyQueue = [];\n    rrQueue = [];\n    logElem.value = '';\n    ganttData = [];\n    rrQuantumCount = 0;\n    stepSimButton.disabled = true;\n    autoSimButton.disabled = true;\n    pauseSimButton.disabled = true;\n    startSimButton.disabled = false;\n    isRunning = false;\n    if(fullReset) {\n      processes = [];\n      processTableBody.innerHTML = '';\n      readyQueueElem.textContent = 'Empty';\n      cpuStateElem.textContent = 'Idle';\n      currentTimeElem.textContent = '0';\n      ganttHeader.innerHTML = '';\n      ganttProcessRow.innerHTML = '';\n    }\n    updateUI();\n  }\n\n  // Build/update gantt chart DOM from ganttData\n  function updateGanttChart() {\n    // If no segments - clear\n    if(ganttData.length === 0) {\n      ganttHeader.innerHTML = '';\n      ganttProcessRow.innerHTML = '';\n      return;\n    }\n    // Determine total length and timemarks\n    let times = [];\n    for(let s of ganttData) {\n      times.push(s.start,s.end);\n    }\n    let uniqueTimes = [...new Set(times)].sort((a,b)=>a-b);\n    \n    // Clear header and process row\n    ganttHeader.innerHTML = '';\n    ganttProcessRow.innerHTML = '';\n\n    // Header cells: time marks\n    for(let t of uniqueTimes) {\n      let th = document.createElement('th');\n      th.textContent = t;\n      ganttHeader.appendChild(th);\n    }\n\n    // Prepare a map of intervals to PIDs for each time unit\n    let timeline = [];\n    let maxTime = uniqueTimes[uniqueTimes.length - 1];\n    for(let time = 0; time < maxTime; time++) {\n      timeline.push('Idle');\n    }\n    for(let seg of ganttData) {\n      for(let i=seg.start; i < seg.end; i++) {\n        timeline[i] = seg.pid;\n      }\n    }\n\n    // Generate process row cells grouping contiguous blocks of same PID for clarity\n    let cells = [];\n    for(let i = 0; i < timeline.length;) {\n      let currentPid = timeline[i];\n      let start = i;\n      while(i < timeline.length && timeline[i] === currentPid) i++;\n      let cell = document.createElement('td');\n      cell.colSpan = i - start;\n      cell.textContent = currentPid === 'Idle' ? '' : currentPid;\n      cell.className = currentPid === 'Idle' ? '' : 'process';\n      cells.push(cell);\n    }\n    // Append cells\n    for(let c of cells) {\n      ganttProcessRow.appendChild(c);\n    }\n  }\n\n  // Start a new gantt segment (process execution interval)\n  function startGanttSegment(pid, start) {\n    // If last segment is same pid and touching, extend rather than new segment\n    let lastSeg = ganttData.length > 0 ? ganttData[ganttData.length -1] : null;\n    if(lastSeg && lastSeg.pid === pid && lastSeg.end === start) {\n      // continue segment\n      return;\n    }\n    ganttData.push({pid: pid, start: start, end: start});\n  }\n  // End the current gantt segment at time\n  function endGanttSegment(time) {\n    if(ganttData.length === 0) return;\n    let lastSeg = ganttData[ganttData.length -1];\n    if(lastSeg.end < time) {\n      lastSeg.end = time;\n    }\n  }\n\n  // Validate process input:\n  function validateProcessInput(pid, arrival, burst, priority) {\n    if(!pid) return 'PID must not be empty';\n    if(processes.find(p=>p.pid===pid)) return 'PID must be unique';\n    if(arrival === '' || isNaN(arrival) || arrival < 0) return 'Arrival time must be a number >= 0';\n    if(burst === '' || isNaN(burst) || burst < 1) return 'Burst time must be number >= 1';\n    if(priority === '' || isNaN(priority)) return 'Priority must be a number';\n    return null;\n  }\n\n  // ---------- Event Handlers ----------\n\n  // Add process button\n  document.getElementById('addProcess').addEventListener('click', function(){\n    let pid = pidInput.value.trim();\n    let arrival = Number(arrivalInput.value);\n    let burst = Number(burstInput.value);\n    let priority = Number(priorityInput.value);\n    let err = validateProcessInput(pid, arrival, burst, priority);\n    if(err) {\n      addProcessErrorElem.textContent = err;\n      return;\n    }\n    addProcessErrorElem.textContent = '';\n    let newProc = {\n      pid: pid,\n      arrival: arrival,\n      burst: burst,\n      remaining: burst,\n      priority: priority,\n      startTime: null,\n      finishTime: null,\n      waitingTime: null,\n      turnaroundTime: null\n    };\n    processes.push(newProc);\n    processes.sort(compareArrival);\n    updateUI();\n    pidInput.value = '';\n    arrivalInput.value = '0';\n    burstInput.value = '1';\n    priorityInput.value = '0';\n    log(`Added process ${newProc.pid} (Arrival: ${newProc.arrival}, Burst: ${newProc.burst}, Priority: ${newProc.priority})`);\n  });\n\n  // Set quantum button\n  setQuantumButton.addEventListener('click', function(){\n    let q = Number(quantumInput.value);\n    if(isNaN(q) || q < 1) {\n      quantumStatusElem.textContent = 'Invalid quantum value';\n      return;\n    }\n    quantumValue = q;\n    quantumStatusElem.textContent = `(Quantum = ${quantumValue})`;\n    log(`Quantum time set to ${quantumValue}`);\n  });\n\n  // Start simulation\n  startSimButton.addEventListener('click', function(){\n    if(processes.length === 0) {\n      alert('Add at least one process before starting simulation.');\n      return;\n    }\n    // Reset simulation variables for fresh start\n    currentTime = 0;\n    cpu = null;\n    readyQueue = [];\n    rrQueue = [];\n    ganttData = [];\n    rrQuantumCount = 0;\n    isRunning = true;\n\n    // Reset all processes' remaining etc\n    for(let p of processes) {\n      p.remaining = p.burst;\n      p.startTime = null;\n      p.finishTime = null;\n      p.waitingTime = null;\n      p.turnaroundTime = null;\n    }\n    logElem.value = '';\n    log(`Simulation started with ${processes.length} processes.`);\n    stepSimButton.disabled = false;\n    autoSimButton.disabled = false;\n    pauseSimButton.disabled = true;\n    startSimButton.disabled = true;\n\n    // Prepare readyQueue for RR: round robin queue is initially empty, add processes when they arrive\n    if(strategySelect.value === 'roundrobin') {\n      rrQueue = [];\n      readyQueue = [];\n    }\n\n    updateUI();\n  });\n\n  // Step simulation\n  stepSimButton.addEventListener('click', function(){\n    if(!isRunning) return;\n    let active = stepSimulation();\n    if(!active) {\n      stepSimButton.disabled = true;\n      autoSimButton.disabled = true;\n      pauseSimButton.disabled = true;\n      startSimButton.disabled = false;\n    }\n  });\n\n  // Auto run interval variable\n  let autoIntervalId = null;\n  let rrQuantumCount = 0;\n\n  // Auto run simulation\n  autoSimButton.addEventListener('click', function(){\n    if(!isRunning) return;\n    autoSimButton.disabled = true;\n    stepSimButton.disabled = true;\n    pauseSimButton.disabled = false;\n    autoIntervalId = setInterval(function(){\n      let active = stepSimulation();\n      if(!active) {\n        clearInterval(autoIntervalId);\n        pauseSimButton.disabled = true;\n        startSimButton.disabled = false;\n        stepSimButton.disabled = true;\n        autoSimButton.disabled = true;\n      }\n    }, 250);\n  });\n\n  // Pause auto run\n  pauseSimButton.addEventListener('click', function(){\n    clearInterval(autoIntervalId);\n    pauseSimButton.disabled = true;\n    autoSimButton.disabled = false;\n    stepSimButton.disabled = false;\n  });\n\n  // Reset simulation (only state but keep process list)\n  resetSimButton.addEventListener('click', function(){\n    if(isRunning) {\n      if(!confirm('Simulation is running. Reset and stop simulation?')) return;\n    }\n    clearInterval(autoIntervalId);\n    resetSimulation(false);\n  });\n\n  // Strategy change disables simulation controls and resets simulation\n  strategySelect.addEventListener('change', function(){\n    if(isRunning) {\n      if(!confirm('Changing scheduling algorithm resets simulation and stops it. Continue?')) {\n        // revert select to previous\n        strategySelect.value = previousStrategy;\n        return;\n      }\n      clearInterval(autoIntervalId);\n      resetSimulation(false);\n      stepSimButton.disabled = true;\n      autoSimButton.disabled = true;\n      pauseSimButton.disabled = true;\n      startSimButton.disabled = false;\n    }\n    previousStrategy = strategySelect.value;\n    if(strategySelect.value === 'roundrobin') {\n      quantumInput.disabled = false;\n      setQuantumButton.disabled = false;\n    }\n    else {\n      quantumInput.disabled = true;\n      setQuantumButton.disabled = true;\n    }\n  });\n\n  let previousStrategy = strategySelect.value;\n  if(strategySelect.value !== 'roundrobin') {\n    quantumInput.disabled = true;\n    setQuantumButton.disabled = true;\n  }\n\n  // Allow enter key adds process\n  document.getElementById('pid').addEventListener('keydown', function(e){\n    if(e.key==='Enter') document.getElementById('addProcess').click();\n  });\n  document.getElementById('arrival').addEventListener('keydown', function(e){\n    if(e.key==='Enter') document.getElementById('addProcess').click();\n  });\n  document.getElementById('burst').addEventListener('keydown', function(e){\n    if(e.key==='Enter') document.getElementById('addProcess').click();\n  });\n  document.getElementById('priority').addEventListener('keydown', function(e){\n    if(e.key==='Enter') document.getElementById('addProcess').click();\n  });\n\n  // Initial UI update\n  updateUI();\n\n})();\n</script>\n\n</body>\n</html>"
  },
