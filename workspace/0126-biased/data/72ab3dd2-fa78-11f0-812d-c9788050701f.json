    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Time Complexity Visualized</title>\n    <style>\n        :root {\n            --deep-space: #0f0e17;\n            --cosmic-purple: #7f5af0;\n            --nebula-blue: #2cb67d;\n            --stellar-pink: #e53170;\n            --quantum-teal: #00ebc7;\n            --cosmic-text: #fffffe;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Montserrat', sans-serif;\n        }\n\n        body {\n            background-color: var(--deep-space);\n            color: var(--cosmic-text);\n            min-height: 100vh;\n            overflow-x: hidden;\n            background-image: \n                radial-gradient(circle at 10% 20%, rgba(127, 90, 240, 0.1) 0%, transparent 20%),\n                radial-gradient(circle at 90% 30%, rgba(44, 182, 125, 0.1) 0%, transparent 20%),\n                radial-gradient(circle at 50% 80%, rgba(229, 49, 112, 0.1) 0%, transparent 20%);\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            position: relative;\n            z-index: 1;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 4rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            background: linear-gradient(45deg, var(--quantum-teal), var(--nebula-blue));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: -0.05em;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: rgba(255, 255, 254, 0.7);\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .complexity-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            margin-top: 4rem;\n        }\n\n        .complexity-card {\n            background: rgba(15, 14, 23, 0.7);\n            border-radius: 16px;\n            padding: 2rem;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 254, 0.1);\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            opacity: 0;\n            transform: translateY(30px);\n        }\n\n        .complexity-card:nth-child(1) { animation: cardEntry 0.8s 0.3s ease-out forwards; }\n        .complexity-card:nth-child(2) { animation: cardEntry 0.8s 0.5s ease-out forwards; }\n        .complexity-card:nth-child(3) { animation: cardEntry 0.8s 0.7s ease-out forwards; }\n        .complexity-card:nth-child(4) { animation: cardEntry 0.8s 0.9s ease-out forwards; }\n\n        .complexity-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 12px 40px rgba(0, 235, 199, 0.2);\n            border-color: var(--quantum-teal);\n        }\n\n        .card-title {\n            font-size: 1.8rem;\n            margin-bottom: 1rem;\n            color: var(--quantum-teal);\n        }\n\n        .card-description {\n            color: rgba(255, 255, 254, 0.8);\n            margin-bottom: 1.5rem;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            height: 200px;\n            position: relative;\n            margin: 2rem 0;\n            overflow: hidden;\n            border-radius: 8px;\n        }\n\n        .graph-container {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            background: rgba(15, 14, 23, 0.5);\n            border: 1px solid rgba(255, 255, 254, 0.1);\n        }\n\n        .graph-line {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            height: 2px;\n            background: var(--cosmic-purple);\n            transform-origin: left center;\n            transition: all 1.2s ease-out;\n            box-shadow: 0 0 10px var(--cosmic-purple);\n        }\n\n        .graph-point {\n            position: absolute;\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            transform: translate(-50%, 50%);\n            transition: all 1.2s ease-out;\n            box-shadow: 0 0 10px currentColor;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin: 3rem 0;\n            opacity: 0;\n            animation: fadeIn 1s 1.5s ease-out forwards;\n        }\n\n        .control-btn {\n            background: transparent;\n            border: 2px solid var(--quantum-teal);\n            color: var(--quantum-teal);\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            margin: 0 1rem;\n            outline: none;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .control-btn:hover {\n            background: rgba(0, 235, 199, 0.1);\n            transform: translateY(-2px);\n        }\n\n        .control-btn::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(0, 235, 199, 0.2), transparent);\n            transition: all 0.6s ease;\n        }\n\n        .control-btn:hover::after {\n            left: 100%;\n        }\n\n        .big-o-notation {\n            position: absolute;\n            font-size: 1.2rem;\n            font-family: 'Courier New', monospace;\n            font-weight: bold;\n            color: var(--stellar-pink);\n            right: 1rem;\n            top: 1rem;\n            opacity: 0.8;\n        }\n\n        .particles {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        .particle {\n            position: absolute;\n            background: var(--quantum-teal);\n            border-radius: 50%;\n            opacity: 0.3;\n            animation: float 15s infinite linear;\n        }\n\n        @keyframes float {\n            0% {\n                transform: translateY(0) translateX(0) rotate(0deg);\n                opacity: 0.3;\n            }\n            50% {\n                opacity: 0.1;\n            }\n            100% {\n                transform: translateY(-500px) translateX(100px) rotate(360deg);\n                opacity: 0.3;\n            }\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n            }\n        }\n\n        @keyframes cardEntry {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes graphGrow {\n            to {\n                width: 100%;\n            }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            padding: 2rem;\n            color: rgba(255, 255, 254, 0.5);\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1s 2s ease-out forwards;\n        }\n\n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .complexity-grid {\n                grid-template-columns: 1fr;\n            }\n        }\n    </style>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Time Complexity Visualized</h1>\n            <p class=\"subtitle\">Explore the elegance of algorithmic efficiency through these visual representations of common time complexities in computer science.</p>\n        </header>\n\n        <div class=\"controls\">\n            <button class=\"control-btn\" id=\"animateBtn\">Animate</button>\n            <button class=\"control-btn\" id=\"resetBtn\">Reset</button>\n        </div>\n\n        <div class=\"complexity-grid\">\n            <div class=\"complexity-card\">\n                <div class=\"big-o-notation\">O(1)</div>\n                <h2 class=\"card-title\">Constant Time</h2>\n                <p class=\"card-description\">The algorithm takes the same amount of time regardless of input size. Ideal for operations that access a single element.</p>\n                <div class=\"visualization\">\n                    <div class=\"graph-container\" id=\"constantGraph\">\n                        <div class=\"graph-line\" style=\"width: 10%; background: var(--nebula-blue);\"></div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"complexity-card\">\n                <div class=\"big-o-notation\">O(log n)</div>\n                <h2 class=\"card-title\">Logarithmic Time</h2>\n                <p class=\"card-description\">The time grows logarithmically with input size. Common in divide-and-conquer algorithms like binary search.</p>\n                <div class=\"visualization\">\n                    <div class=\"graph-container\" id=\"logGraph\">\n                        <div class=\"graph-line\" style=\"width: 10%; background: var(--cosmic-purple);\"></div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"complexity-card\">\n                <div class=\"big-o-notation\">O(n)</div>\n                <h2 class=\"card-title\">Linear Time</h2>\n                <p class=\"card-description\">Time increases linearly with input size. Found in simple iterations through data structures.</p>\n                <div class=\"visualization\">\n                    <div class=\"graph-container\" id=\"linearGraph\">\n                        <div class=\"graph-line\" style=\"width: 10%; background: var(--stellar-pink);\"></div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"complexity-card\">\n                <div class=\"big-o-notation\">O(n²)</div>\n                <h2 class=\"card-title\">Quadratic Time</h2>\n                <p class=\"card-description\">Time grows quadratically with input size. Often seen in nested loops over the same dataset.</p>\n                <div class=\"visualization\">\n                    <div class=\"graph-container\" id=\"quadraticGraph\">\n                        <div class=\"graph-line\" style=\"width: 10%; background: var(--quantum-teal);\"></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <footer>\n            <p>An aesthetic exploration of time complexity in algorithms | Designed for visual clarity</p>\n        </footer>\n    </div>\n\n    <script>\n        // Create floating particles\n        const particlesContainer = document.getElementById('particles');\n        for (let i = 0; i < 30; i++) {\n            const particle = document.createElement('div');\n            particle.classList.add('particle');\n            \n            // Random properties\n            const size = Math.random() * 5 + 1;\n            const posX = Math.random() * 100;\n            const posY = Math.random() * 100 + 100;\n            const delay = Math.random() * 15;\n            const duration = Math.random() * 10 + 10;\n            \n            particle.style.width = `${size}px`;\n            particle.style.height = `${size}px`;\n            particle.style.left = `${posX}%`;\n            particle.style.top = `${posY}px`;\n            particle.style.animationDelay = `${delay}s`;\n            particle.style.animationDuration = `${duration}s`;\n            \n            // Random color from theme\n            const colors = [\n                'rgba(127, 90, 240, 0.3)',\n                'rgba(44, 182, 125, 0.3)',\n                'rgba(229, 49, 112, 0.3)',\n                'rgba(0, 235, 199, 0.3)'\n            ];\n            particle.style.background = colors[Math.floor(Math.random() * colors.length)];\n            \n            particlesContainer.appendChild(particle);\n        }\n\n        // Animation control\n        const animateBtn = document.getElementById('animateBtn');\n        const resetBtn = document.getElementById('resetBtn');\n        \n        animateBtn.addEventListener('click', () => {\n            animateGraph('constantGraph', 10, 'linear');\n            animateGraph('logGraph', 50, 'ease-in');\n            animateGraph('linearGraph', 100, 'linear');\n            animateGraph('quadraticGraph', 100, 'ease-in');\n        });\n        \n        resetBtn.addEventListener('click', () => {\n            resetAllGraphs();\n        });\n        \n        function animateGraph(graphId, points, easing) {\n            const container = document.getElementById(graphId);\n            container.innerHTML = '';\n            \n            const line = document.createElement('div');\n            line.classList.add('graph-line');\n            container.appendChild(line);\n            \n            // Create data points\n            for (let i = 0; i <= points; i++) {\n                const x = (i / points) * 100;\n                let y;\n                \n                if (graphId === 'constantGraph') {\n                    y = 10;\n                } else if (graphId === 'logGraph') {\n                    y = 100 - (Math.log2(i + 1) / Math.log2(points + 1)) * 100;\n                } else if (graphId === 'linearGraph') {\n                    y = 100 - i;\n                } else if (graphId === 'quadraticGraph') {\n                    y = 100 - (i * i / (points * points)) * 100;\n                }\n                \n                const point = document.createElement('div');\n                point.classList.add('graph-point');\n                point.style.left = `${x}%`;\n                point.style.bottom = `${y}%`;\n                \n                // Color based on graph\n                if (graphId === 'constantGraph') {\n                    point.style.background = 'var(--nebula-blue)';\n                    line.style.background = 'var(--nebula-blue)';\n                } else if (graphId === 'logGraph') {\n                    point.style.background = 'var(--cosmic-purple)';\n                    line.style.background = 'var(--cosmic-purple)';\n                } else if (graphId === 'linearGraph') {\n                    point.style.background = 'var(--stellar-pink)';\n                    line.style.background = 'var(--stellar-pink)';\n                } else {\n                    point.style.background = 'var(--quantum-teal)';\n                    line.style.background = 'var(--quantum-teal)';\n                }\n                \n                container.appendChild(point);\n                \n                // Animate points\n                setTimeout(() => {\n                    point.style.transform = 'translate(-50%, 50%) scale(1.5)';\n                    setTimeout(() => {\n                        point.style.transform = 'translate(-50%, 50%) scale(1)';\n                    }, 300);\n                }, i * (1500 / points));\n            }\n            \n            // Animate line\n            setTimeout(() => {\n                line.style.width = '100%';\n                line.style.transition = `all ${points * 15}ms ${easing}`;\n            }, 100);\n        }\n        \n        function resetAllGraphs() {\n            const graphs = ['constantGraph', 'logGraph', 'linearGraph', 'quadraticGraph'];\n            graphs.forEach(graphId => {\n                const container = document.getElementById(graphId);\n                container.innerHTML = '<div class=\"graph-line\" style=\"width: 10%;\"></div>';\n                \n                // Reset color\n                if (graphId === 'constantGraph') {\n                    container.firstChild.style.background = 'var(--nebula-blue)';\n                } else if (graphId === 'logGraph') {\n                    container.firstChild.style.background = 'var(--cosmic-purple)';\n                } else if (graphId === 'linearGraph') {\n                    container.firstChild.style.background = 'var(--stellar-pink)';\n                } else {\n                    container.firstChild.style.background = 'var(--quantum-teal)';\n                }\n            });\n        }\n    </script>\n</body>\n</html>"
