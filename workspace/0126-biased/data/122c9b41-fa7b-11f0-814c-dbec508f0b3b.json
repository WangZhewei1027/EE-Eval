    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Space Complexity</title>\n    <style>\n        body {\n            background-color: #fff;\n            font-family: Arial, sans-serif;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"text\"], input[type=\"number\"] {\n            width: 50%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ddd;\n        }\n        button {\n            width: 20%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>Space Complexity</h1>\n    <p>Enter the maximum number of elements in a list:</p>\n    <input type=\"number\" id=\"max-elements\" value=\"10\">\n    <button id=\"add-element\">Add Element</button>\n    <button id=\"remove-element\">Remove Element</button>\n    <button id=\"expand\">Expand</button>\n    <button id=\"collapse\">Collapse</button>\n    <button id=\"zoom\">Zoom</button>\n    <button id=\"reset\">Reset</button>\n    <button id=\"clear\">Clear</button>\n    <p id=\"result\"></p>\n\n    <script>\n        let maxElements = 10;\n        let currentElements = 0;\n        let elements = [];\n\n        // Add event listener to add element button\n        document.getElementById(\"add-element\").addEventListener(\"click\", () => {\n            const element = document.getElementById(\"max-elements\").value;\n            if (element > maxElements) {\n                alert(\"Maximum number of elements exceeded!\");\n            } else {\n                elements.push(element);\n                currentElements += element;\n                updateResult();\n            }\n        });\n\n        // Add event listener to remove element button\n        document.getElementById(\"remove-element\").addEventListener(\"click\", () => {\n            const index = elements.indexOf(document.getElementById(\"max-elements\").value);\n            if (index !== -1) {\n                elements.splice(index, 1);\n                currentElements -= elements.length;\n                updateResult();\n            }\n        });\n\n        // Add event listener to expand button\n        document.getElementById(\"expand\").addEventListener(\"click\", () => {\n            if (currentElements > maxElements) {\n                document.getElementById(\"max-elements\").value = currentElements;\n            } else {\n                alert(\"Maximum number of elements exceeded!\");\n            }\n        });\n\n        // Add event listener to collapse button\n        document.getElementById(\"collapse\").addEventListener(\"click\", () => {\n            const currentElement = elements.length - 1;\n            const currentElements = currentElement;\n            document.getElementById(\"max-elements\").value = currentElements;\n            updateResult();\n        });\n\n        // Add event listener to zoom button\n        document.getElementById(\"zoom\").addEventListener(\"click\", () => {\n            const currentElement = elements.length - 1;\n            const currentElements = currentElement;\n            document.getElementById(\"max-elements\").value = currentElements;\n            updateResult();\n        });\n\n        // Add event listener to reset button\n        document.getElementById(\"reset\").addEventListener(\"click\", () => {\n            currentElements = 0;\n            elements = [];\n            updateResult();\n        });\n\n        // Add event listener to clear button\n        document.getElementById(\"clear\").addEventListener(\"click\", () => {\n            elements = [];\n            updateResult();\n        });\n\n        // Add event listener to update result text\n        document.getElementById(\"result\").addEventListener(\"click\", () => {\n            if (currentElements === 0) {\n                document.getElementById(\"result\").innerHTML = \"No elements\";\n            } else {\n                document.getElementById(\"result\").innerHTML = \"You have \" + currentElements + \" elements.\";\n            }\n        });\n\n        function updateResult() {\n            const result = \"You have \" + currentElements + \" elements.\";\n            document.getElementById(\"result\").innerHTML = result;\n        }\n    </script>\n</body>\n</html>"
