  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Refactoring Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; gap: 20px; }\n        .panel { flex: 1; border: 1px solid #ccc; padding: 10px; }\n        .code { font-family: monospace; white-space: pre; background: #f5f5f5; padding: 10px; }\n        button, select, input { margin: 5px; }\n        .hidden { display: none; }\n        .refactor-step { margin-bottom: 15px; padding: 10px; border: 1px solid #eee; }\n    </style>\n</head>\n<body>\n    <h1>Interactive Refactoring Demo</h1>\n    \n    <div class=\"container\">\n        <div class=\"panel\">\n            <h2>Original Code</h2>\n            <select id=\"example-select\">\n                <option value=\"long-method\">Long Method</option>\n                <option value=\"duplicate-code\">Duplicate Code</option>\n                <option value=\"large-class\">Large Class</option>\n                <option value=\"primitive-obsession\">Primitive Obsession</option>\n            </select>\n            \n            <div id=\"original-code\" class=\"code\"></div>\n            \n            <div>\n                <h3>Code Metrics</h3>\n                <div id=\"metrics\">\n                    <p>Lines: <span id=\"lines\">0</span></p>\n                    <p>Complexity: <span id=\"complexity\">0</span></p>\n                    <p>Duplication: <span id=\"duplication\">0%</span></p>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Refactoring Tools</h2>\n            <div id=\"refactoring-controls\">\n                <button id=\"extract-method\">Extract Method</button>\n                <button id=\"rename-variable\">Rename Variable</button>\n                <button id=\"introduce-parameter\">Introduce Parameter</button>\n                <button id=\"replace-conditional\">Replace Conditional</button>\n                <button id=\"extract-class\">Extract Class</button>\n            </div>\n            \n            <div id=\"refactor-options\" class=\"hidden\">\n                <h3>Refactoring Options</h3>\n                <div id=\"options-content\"></div>\n                <button id=\"apply-refactor\">Apply Refactoring</button>\n                <button id=\"cancel-refactor\">Cancel</button>\n            </div>\n            \n            <div id=\"refactor-steps\">\n                <h3>Refactoring Steps</h3>\n                <div id=\"steps-list\"></div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Refactored Code</h2>\n            <div id=\"refactored-code\" class=\"code\"></div>\n            \n            <div>\n                <h3>Refactored Metrics</h3>\n                <div id=\"refactored-metrics\">\n                    <p>Lines: <span id=\"refactored-lines\">0</span></p>\n                    <p>Complexity: <span id=\"refactored-complexity\">0</span></p>\n                    <p>Duplication: <span id=\"refactored-duplication\">0%</span></p>\n                </div>\n            </div>\n            \n            <div>\n                <button id=\"compare\">Compare Before/After</button>\n                <button id=\"reset\">Reset All</button>\n            </div>\n        </div>\n    </div>\n    \n    <div id=\"comparison-view\" class=\"hidden\">\n        <h2>Comparison View</h2>\n        <div class=\"container\">\n            <div class=\"panel\">\n                <h3>Before</h3>\n                <div id=\"before-code\" class=\"code\"></div>\n            </div>\n            <div class=\"panel\">\n                <h3>After</h3>\n                <div id=\"after-code\" class=\"code\"></div>\n            </div>\n        </div>\n        <button id=\"close-comparison\">Close Comparison</button>\n    </div>\n    \n    <script>\n        // Sample code examples\n        const examples = {\n            'long-method': `function processOrder(order) {\n    // Validate order\n    if (!order.items || order.items.length === 0) {\n        throw new Error('No items in order');\n    }\n    \n    // Calculate total\n    let total = 0;\n    for (let item of order.items) {\n        total += item.price * item.quantity;\n    }\n    \n    // Apply discounts\n    if (order.customer.isPremium) {\n        total *= 0.9; // 10% discount\n    } else if (total > 1000) {\n        total *= 0.95; // 5% discount\n    }\n    \n    // Process payment\n    let paymentResult;\n    if (order.paymentMethod === 'credit') {\n        paymentResult = processCreditCard(order.creditCard, total);\n    } else if (order.paymentMethod === 'paypal') {\n        paymentResult = processPayPal(order.paypalEmail, total);\n    } else {\n        throw new Error('Invalid payment method');\n    }\n    \n    // Update inventory\n    for (let item of order.items) {\n        updateInventory(item.productId, item.quantity);\n    }\n    \n    // Send confirmation\n    sendConfirmationEmail(order.customer.email, order, total);\n    \n    return paymentResult;\n}`,\n            'duplicate-code': `function calculateRectangleArea(width, height) {\n    return width * height;\n}\n\nfunction calculateRectanglePerimeter(width, height) {\n    return 2 * (width + height);\n}\n\nfunction calculateCircleArea(radius) {\n    return Math.PI * radius * radius;\n}\n\nfunction calculateCircleCircumference(radius) {\n    return 2 * Math.PI * radius;\n}`,\n            'large-class': `class UserManager {\n    constructor() {\n        this.users = [];\n    }\n    \n    addUser(user) { /* ... */ }\n    removeUser(userId) { /* ... */ }\n    findUserById(userId) { /* ... */ }\n    findUserByEmail(email) { /* ... */ }\n    updateUser(user) { /* ... */ }\n    changePassword(userId, newPassword) { /* ... */ }\n    resetPasswordEmail(userId) { /* ... */ }\n    verifyEmail(userId) { /* ... */ }\n    generateAuthToken(userId) { /* ... */ }\n    revokeToken(token) { /* ... */ }\n    checkPermission(userId, permission) { /* ... */ }\n    addPermission(userId, permission) { /* ... */ }\n    removePermission(userId, permission) { /* ... */ }\n    logLogin(userId) { /* ... */ }\n    logLogout(userId) { /* ... */ }\n    getLoginHistory(userId) { /* ... */ }\n    // ... 15 more methods ...\n}`,\n            'primitive-obsession': `function createUser(firstName, lastName, email, street, city, state, zip, country, phone, dob) {\n    return {\n        firstName,\n        lastName,\n        email,\n        street,\n        city,\n        state,\n        zip,\n        country,\n        phone,\n        dob\n    };\n}\n\nfunction formatAddress(user) {\n    return \\`\\${user.street}, \\${user.city}, \\${user.state} \\${user.zip}, \\${user.country}\\`;\n}\n\nfunction sendWelcomeEmail(user) {\n    const address = formatAddress(user);\n    const message = \\`Welcome \\${user.firstName} \\${user.lastName}! Your address is: \\${address}\\`;\n    sendEmail(user.email, 'Welcome!', message);\n}`\n        };\n\n        // Initialize the app\n        document.addEventListener('DOMContentLoaded', function() {\n            const exampleSelect = document.getElementById('example-select');\n            const originalCode = document.getElementById('original-code');\n            const refactoredCode = document.getElementById('refactored-code');\n            const refactoringControls = document.getElementById('refactoring-controls');\n            const refactorOptions = document.getElementById('refactor-options');\n            const optionsContent = document.getElementById('options-content');\n            const stepsList = document.getElementById('steps-list');\n            const compareButton = document.getElementById('compare');\n            const comparisonView = document.getElementById('comparison-view');\n            const beforeCode = document.getElementById('before-code');\n            const afterCode = document.getElementById('after-code');\n            const closeComparison = document.getElementById('close-comparison');\n            const resetButton = document.getElementById('reset');\n            \n            let currentExample = 'long-method';\n            let originalCodeText = examples[currentExample];\n            let refactoredCodeText = originalCodeText;\n            let refactoringSteps = [];\n            \n            // Metrics calculation\n            function calculateMetrics(code) {\n                const lines = code.split('\\n').length;\n                let complexity = 0;\n                let duplication = 0;\n                \n                // Simple complexity calculation\n                complexity += (code.match(/if\\s*\\(|else\\s*|for\\s*\\(|while\\s*\\(|case\\s*:/g) || []).length;\n                \n                // Simple duplication calculation (for demo)\n                const linesArray = code.split('\\n').filter(l => l.trim().length > 0);\n                const uniqueLines = new Set(linesArray);\n                duplication = Math.round(100 - (uniqueLines.size / linesArray.length * 100));\n                \n                return { lines, complexity, duplication };\n            }\n            \n            // Update code displays\n            function updateCodeDisplays() {\n                originalCode.textContent = originalCodeText;\n                refactoredCode.textContent = refactoredCodeText;\n                \n                const metrics = calculateMetrics(originalCodeText);\n                document.getElementById('lines').textContent = metrics.lines;\n                document.getElementById('complexity').textContent = metrics.complexity;\n                document.getElementById('duplication').textContent = metrics.duplication + '%';\n                \n                const refactoredMetrics = calculateMetrics(refactoredCodeText);\n                document.getElementById('refactored-lines').textContent = refactoredMetrics.lines;\n                document.getElementById('refactored-complexity').textContent = refactoredMetrics.complexity;\n                document.getElementById('refactored-duplication').textContent = refactoredMetrics.duplication + '%';\n            }\n            \n            // Add refactoring step\n            function addRefactoringStep(description) {\n                const step = { description, timestamp: new Date() };\n                refactoringSteps.push(step);\n                \n                const stepElement = document.createElement('div');\n                stepElement.className = 'refactor-step';\n                stepElement.textContent = `${refactoringSteps.length}. ${description}`;\n                stepsList.appendChild(stepElement);\n            }\n            \n            // Example change event\n            exampleSelect.addEventListener('change', function() {\n                currentExample = this.value;\n                originalCodeText = examples[currentExample];\n                refactoredCodeText = originalCodeText;\n                refactoringSteps = [];\n                stepsList.innerHTML = '';\n                updateCodeDisplays();\n            });\n            \n            // Refactoring controls\n            document.getElementById('extract-method').addEventListener('click', function() {\n                refactorOptions.classList.remove('hidden');\n                optionsContent.innerHTML = `\n                    <p>Select code to extract:</p>\n                    <textarea id=\"code-to-extract\" rows=\"5\" cols=\"50\"></textarea>\n                    <p>New method name: <input type=\"text\" id=\"new-method-name\" value=\"newMethod\"></p>\n                    <p>Parameters: <input type=\"text\" id=\"method-parameters\" placeholder=\"param1, param2\"></p>\n                `;\n                \n                document.getElementById('apply-refactor').onclick = function() {\n                    const codeToExtract = document.getElementById('code-to-extract').value;\n                    const methodName = document.getElementById('new-method-name').value;\n                    const parameters = document.getElementById('method-parameters').value;\n                    \n                    if (codeToExtract.trim() && methodName.trim()) {\n                        // Simple extraction (in a real app this would be more sophisticated)\n                        const newMethod = `function ${methodName}(${parameters}) {\\n${codeToExtract}\\n}\\n\\n`;\n                        refactoredCodeText = newMethod + refactoredCodeText.replace(codeToExtract, `${methodName}(${parameters.split(',').map(p => p.trim()).join(', ')});`);\n                        \n                        addRefactoringStep(`Extracted method '${methodName}'`);\n                        updateCodeDisplays();\n                        refactorOptions.classList.add('hidden');\n                    }\n                };\n            });\n            \n            document.getElementById('rename-variable').addEventListener('click', function() {\n                refactorOptions.classList.remove('hidden');\n                optionsContent.innerHTML = `\n                    <p>Variable to rename: <input type=\"text\" id=\"old-name\" placeholder=\"oldVarName\"></p>\n                    <p>New name: <input type=\"text\" id=\"new-name\" placeholder=\"newVarName\"></p>\n                `;\n                \n                document.getElementById('apply-refactor').onclick = function() {\n                    const oldName = document.getElementById('old-name').value;\n                    const newName = document.getElementById('new-name').value;\n                    \n                    if (oldName.trim() && newName.trim()) {\n                        // Simple replace (in a real app this would be more sophisticated)\n                        refactoredCodeText = refactoredCodeText.replace(new RegExp(oldName, 'g'), newName);\n                        \n                        addRefactoringStep(`Renamed variable '${oldName}' to '${newName}'`);\n                        updateCodeDisplays();\n                        refactorOptions.classList.add('hidden');\n                    }\n                };\n            });\n            \n            document.getElementById('introduce-parameter').addEventListener('click', function() {\n                refactorOptions.classList.remove('hidden');\n                optionsContent.innerHTML = `\n                    <p>Select hardcoded value to parameterize:</p>\n                    <input type=\"text\" id=\"hardcoded-value\" placeholder=\"1000 or 'default'\">\n                    <p>New parameter name: <input type=\"text\" id=\"param-name\" value=\"threshold\"></p>\n                `;\n                \n                document.getElementById('apply-refactor').onclick = function() {\n                    const value = document.getElementById('hardcoded-value').value;\n                    const paramName = document.getElementById('param-name').value;\n                    \n                    if (value.trim() && paramName.trim()) {\n                        // Find function definition and add parameter\n                        const functionStart = refactoredCodeText.indexOf('function');\n                        if (functionStart >= 0) {\n                            const functionDefEnd = refactoredCodeText.indexOf(')', functionStart);\n                            const beforeParams = refactoredCodeText.substring(0, functionDefEnd);\n                            const afterParams = refactoredCodeText.substring(functionDefEnd);\n                            \n                            // Add parameter\n                            let newParams = beforeParams;\n                            if (beforeParams.endsWith('()')) {\n                                newParams = beforeParams.replace('()', `(${paramName})`);\n                            } else {\n                                newParams = beforeParams.replace(')', `, ${paramName})`);\n                            }\n                            \n                            // Replace value with parameter\n                            refactoredCodeText = newParams + afterParams.replace(new RegExp(`\\\\b${value}\\\\b`, 'g'), paramName);\n                            \n                            addRefactoringStep(`Introduced parameter '${paramName}' to replace '${value}'`);\n                            updateCodeDisplays();\n                            refactorOptions.classList.add('hidden');\n                        }\n                    }\n                };\n            });\n            \n            document.getElementById('replace-conditional').addEventListener('click', function() {\n                refactorOptions.classList.remove('hidden');\n                optionsContent.innerHTML = `\n                    <p>Select conditional to replace:</p>\n                    <select id=\"conditional-type\">\n                        <option value=\"polymorphism\">Polymorphism</option>\n                        <option value=\"strategy\">Strategy Pattern</option>\n                        <option value=\"null-object\">Null Object Pattern</option>\n                    </select>\n                    <div id=\"conditional-options\"></div>\n                `;\n                \n                document.getElementById('conditional-type').addEventListener('change', function() {\n                    const conditionalOptions = document.getElementById('conditional-options');\n                    if (this.value === 'polymorphism') {\n                        conditionalOptions.innerHTML = `\n                            <p>Type property name: <input type=\"text\" id=\"type-property\" value=\"type\"></p>\n                            <p>Class names (comma separated): <input type=\"text\" id=\"class-names\" value=\"TypeA,TypeB\"></p>\n                        `;\n                    } else if (this.value === 'strategy') {\n                        conditionalOptions.innerHTML = `\n                            <p>Strategy interface name: <input type=\"text\" id=\"interface-name\" value=\"Strategy\"></p>\n                            <p>Strategy implementations (comma separated): <input type=\"text\" id=\"strategy-names\" value=\"StrategyA,StrategyB\"></p>\n                        `;\n                    }\n                });\n                \n                document.getElementById('apply-refactor').onclick = function() {\n                    const refactoringType = document.getElementById('conditional-type').value;\n                    let description = '';\n                    \n                    if (refactoringType === 'polymorphism') {\n                        const typeProperty = document.getElementById('type-property').value;\n                        const classNames = document.getElementById('class-names').value;\n                        description = `Replaced conditional with polymorphism using ${typeProperty} and classes ${classNames}`;\n                    } else if (refactoringType === 'strategy') {\n                        const interfaceName = document.getElementById('interface-name').value;\n                        const strategyNames = document.getElementById('strategy-names').value;\n                        description = `Replaced conditional with strategy pattern (${interfaceName} and ${strategyNames})`;\n                    }\n                    \n                    // In a real app, this would actually transform the code\n                    addRefactoringStep(description);\n                    refactorOptions.classList.add('hidden');\n                };\n            });\n            \n            document.getElementById('extract-class').addEventListener('click', function() {\n                refactorOptions.classList.remove('hidden');\n                optionsContent.innerHTML = `\n                    <p>Class name to extract from: <input type=\"text\" id=\"source-class\" value=\"OrderProcessor\"></p>\n                    <p>New class name: <input type=\"text\" id=\"new-class\" value=\"PaymentProcessor\"></p>\n                    <p>Methods to move (comma separated): <input type=\"text\" id=\"methods-to-move\" value=\"processCreditCard,processPayPal\"></p>\n                `;\n                \n                document.getElementById('apply-refactor').onclick = function() {\n                    const sourceClass = document.getElementById('source-class').value;\n                    const newClass = document.getElementById('new-class').value;\n                    const methods = document.getElementById('methods-to-move').value;\n                    \n                    if (sourceClass && newClass && methods) {\n                        // In a real app, this would actually move the methods\n                        addRefactoringStep(`Extracted class ${newClass} from ${sourceClass} with methods: ${methods}`);\n                        refactorOptions.classList.add('hidden');\n                    }\n                };\n            });\n            \n            document.getElementById('cancel-refactor').addEventListener('click', function() {\n                refactorOptions.classList.add('hidden');\n            });\n            \n            // Comparison view\n            compareButton.addEventListener('click', function() {\n                comparisonView.classList.remove('hidden');\n                beforeCode.textContent = originalCodeText;\n                afterCode.textContent = refactoredCodeText;\n            });\n            \n            closeComparison.addEventListener('click', function() {\n                comparisonView.classList.add('hidden');\n            });\n            \n            // Reset\n            resetButton.addEventListener('click', function() {\n                refactoredCodeText = originalCodeText;\n                refactoringSteps = [];\n                stepsList.innerHTML = '';\n                updateCodeDisplays();\n            });\n            \n            // Initialize\n            updateCodeDisplays();\n        });\n    </script>\n</body>\n</html>"
  },
