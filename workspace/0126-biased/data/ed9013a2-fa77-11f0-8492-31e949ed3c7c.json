{\n            background-color: #2563eb;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <svg id=\"graph\">\n            <text id=\"title\">Linear Regression Visualization</text>\n        </svg>\n        <button id=\"animateBtn\">Animate Prediction</button>\n    </div>\n\n    <script>\n        const svg = document.getElementById('graph');\n        const pointsData = [\n            { x: 50, y: 200 },\n            { x: 100, y: 150 },\n            { x: 150, y: 100 },\n            { x: 200, y: 90 },\n            { x: 250, y: 60 },\n            { x: 300, y: 30 },\n        ];\n\n        const lineData = [\n            { x: 50, y: 190 }, // Start point\n            { x: 300, y: 20 }  // End point\n        ];\n\n        function drawPoints() {\n            pointsData.forEach(point => {\n                const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n                circle.setAttribute('cx', point.x);\n                circle.setAttribute('cy', point.y);\n                circle.setAttribute('r', 5);\n                circle.setAttribute('class', 'point');\n                svg.appendChild(circle);\n            });\n        }\n\n        function drawLine() {\n            const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n            line.setAttribute('x1', lineData[0].x);\n            line.setAttribute('y1', lineData[0].y);\n            line.setAttribute('x2', lineData[1].x);\n            line.setAttribute('y2', lineData[1].y);\n            line.setAttribute('class', 'line');\n            svg.appendChild(line);\n        }\n\n        function animatePrediction() {\n            svg.innerHTML = '';\n            drawPoints();\n            drawLine();\n            const predictedCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n            predictedCircle.setAttribute('cx', 350); // Predicted point\n            predictedCircle.setAttribute('cy', 10);  \n            predictedCircle.setAttribute('r', 6);\n            predictedCircle.setAttribute('class', 'point');\n\n            setTimeout(() => {\n                svg.appendChild(predictedCircle);\n            }, 1000);\n        }\n\n        document.getElementById('animateBtn').addEventListener('click', animatePrediction);\n\n        // Initial Draw\n        drawPoints();\n        drawLine();\n    </script>\n</body>\n</html>"
