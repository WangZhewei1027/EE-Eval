    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>K-Nearest Neighbors — Elegant Visual Demo</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071025;\n    --glass: rgba(255,255,255,0.03);\n    --muted: rgba(255,255,255,0.65);\n    --accent-a: #73f1ff; /* teal */\n    --accent-b: #ff8fb2; /* coral */\n    --accent-c: #9b8bff; /* violet */\n    --card-bg: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    --glass-2: rgba(255,255,255,0.02);\n    --glass-3: rgba(255,255,255,0.035);\n    --glass-border: rgba(255,255,255,0.04);\n    --glass-border-2: rgba(255,255,255,0.02);\n    --glass-glow: 0 6px 30px rgba(0,0,0,0.6);\n    font-synthesis: none;\n  }\n\n  /* Base */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(155,139,255,0.08), transparent),\n                radial-gradient(900px 400px at 90% 90%, rgba(115,241,255,0.04), transparent),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    color: #e6eef8;\n    padding: 48px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    overflow:hidden;\n    letter-spacing: -0.01em;\n  }\n\n  /* Subtle floating shapes */\n  .ambient {\n    position: fixed;\n    inset: 0;\n    pointer-events: none;\n    mix-blend-mode: screen;\n    opacity: 0.9;\n  }\n  .blob {\n    position:absolute;\n    border-radius: 48%;\n    filter: blur(60px);\n    transform: translate3d(0,0,0);\n    opacity: 0.8;\n    animation: drift 18s ease-in-out infinite;\n  }\n  .blob.a{width:420px;height:420px;left:-8%;top:-6%;background:linear-gradient(45deg,var(--accent-c), rgba(155,139,255,0.08)); animation-delay:0s}\n  .blob.b{width:360px;height:360px;right:-6%;bottom:-10%;background:linear-gradient(45deg,var(--accent-a), rgba(115,241,255,0.06)); animation-delay:4s}\n  .blob.c{width:220px;height:220px;left:18%;bottom:2%;background:linear-gradient(45deg,var(--accent-b), rgba(255,143,178,0.06)); animation-delay:8s}\n  @keyframes drift{\n    0%{transform: translateY(0) translateX(0) rotate(0deg) scale(1)}\n    50%{transform: translateY(-20px) translateX(8px) rotate(6deg) scale(1.03)}\n    100%{transform: translateY(0) translateX(0) rotate(0deg) scale(1)}\n  }\n\n  /* Card */\n  .stage {\n    width: min(1100px, 94vw);\n    background: var(--card-bg);\n    border-radius: 18px;\n    display: grid;\n    grid-template-columns: 420px 1fr;\n    gap: 28px;\n    padding: 32px;\n    box-shadow: var(--glass-glow);\n    border: 1px solid rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Left pane */\n  .info {\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    padding: 8px 6px;\n  }\n  .brand {\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .logo {\n    width:64px;height:64px;border-radius:14px;\n    background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border:1px solid var(--glass-border);\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 8px 30px rgba(11,18,30,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n  .logo .mark {\n    width:44px;height:44px;border-radius:10px;\n    background: conic-gradient(from 140deg, var(--accent-a), var(--accent-c), var(--accent-b));\n    filter: drop-shadow(0 6px 18px rgba(155,139,255,0.12));\n  }\n  h1{\n    margin:0;\n    font-size:18px;\n    letter-spacing:0.01em;\n    color: #f3f8ff;\n  }\n  p.lead {\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.5;\n  }\n\n  .desc {\n    padding: 18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.008));\n    border-radius: 12px;\n    border: 1px solid var(--glass-border-2);\n    font-size:13px;\n    color: #cfe8ff;\n    line-height:1.5;\n    box-shadow: 0 6px 24px rgba(4,10,16,0.45);\n  }\n\n  /* Footer controls */\n  .controls {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:auto;\n  }\n  /* Play button */\n  .btn {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid var(--glass-border);\n    color: #e9f7ff;\n    padding: 10px 14px;\n    border-radius: 12px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    cursor:pointer;\n    font-weight:600;\n    font-size:13px;\n    transition: transform .18s ease, box-shadow .18s ease, opacity .18s;\n    box-shadow: 0 8px 22px rgba(11,18,30,0.45);\n    user-select:none;\n  }\n  .btn:active{transform:translateY(1px)}\n  .btn .dot {\n    width:12px;height:12px;border-radius:50%;\n    display:inline-block;\n    background: linear-gradient(180deg,var(--accent-a),var(--accent-c));\n    box-shadow:0 6px 18px rgba(115,241,255,0.08), 0 0 20px rgba(155,139,255,0.06);\n  }\n  .btn.toggle.paused .dot{background: linear-gradient(180deg,var(--accent-b),var(--accent-c))}\n\n  .k-control {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    padding:10px 14px;\n    border-radius:12px;\n    border:1px solid var(--glass-border-2);\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n    font-size:13px;\n    color:var(--muted);\n  }\n  .k-label { min-width:28px; color:#eaf7ff; font-weight:700; font-size:13px; text-align:center }\n  .k-slider {\n    -webkit-appearance:none;\n    appearance:none;\n    height:6px;border-radius:6px;background:transparent;\n    width:120px; outline:none; cursor: pointer;\n  }\n  .k-slider::-webkit-slider-runnable-track {height:6px;border-radius:6px;background:linear-gradient(90deg,var(--accent-a),var(--accent-b));}\n  .k-slider::-moz-range-track {height:6px;border-radius:6px;background:linear-gradient(90deg,var(--accent-a),var(--accent-b));}\n  .k-slider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%; background: #fff;border:3px solid rgba(255,255,255,0.06); box-shadow: 0 6px 18px rgba(11,18,30,0.5); margin-top:-6px}\n  .k-slider::-moz-range-thumb{width:18px;height:18px;border-radius:50%; background: #fff;border:3px solid rgba(255,255,255,0.06); box-shadow: 0 6px 18px rgba(11,18,30,0.5)}\n\n  /* Right pane visualization */\n  .viz {\n    position:relative;\n    min-height:420px;\n    border-radius:12px;\n    padding:18px;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n    align-items:stretch;\n    justify-content:center;\n    background: linear-gradient(180deg, rgba(255,255,255,0.008), rgba(255,255,255,0.002));\n    border:1px solid rgba(255,255,255,0.02);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.01);\n  }\n  .canvas-wrap {\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding: 18px;\n  }\n\n  /* SVG area */\n  svg {\n    width:100%;\n    height:100%;\n    max-height:520px;\n    border-radius:10px;\n    overflow:visible;\n  }\n\n  /* Info overlay badge */\n  .badge {\n    position:absolute;\n    right:22px;\n    top:22px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:10px 14px;\n    border:1px solid var(--glass-border);\n    box-shadow: 0 10px 30px rgba(6,10,20,0.55);\n    display:flex;\n    gap:10px;\n    align-items:center;\n    z-index:6;\n    min-width:220px;\n  }\n  .predict {\n    display:flex;flex-direction:column;\n  }\n  .predict .title { font-size:12px; color:var(--muted); }\n  .predict .value { font-weight:800; font-size:18px; color:#fff; letter-spacing:0.02em; }\n\n  /* Legend */\n  .legend {\n    display:flex;gap:10px;align-items:center; color:var(--muted); font-size:13px;\n  }\n  .legend .item{display:flex;gap:8px;align-items:center}\n  .swatch{width:12px;height:12px;border-radius:4px;box-shadow:0 6px 18px rgba(0,0,0,0.45)}\n  .sw-a{background: linear-gradient(180deg,var(--accent-a), var(--accent-c))}\n  .sw-b{background: linear-gradient(180deg,var(--accent-b), var(--accent-c))}\n\n  /* Small aesthetic extras */\n  .sparkle {\n    position:absolute;\n    right:34px;bottom:18px;\n    font-size:12px;color:var(--muted);opacity:0.9;\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .stage{grid-template-columns:1fr; padding:20px}\n    .canvas-wrap{padding:8px}\n    .brand{gap:10px}\n    .logo{width:56px;height:56px}.logo .mark{width:38px;height:38px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <div class=\"blob a\"></div>\n    <div class=\"blob b\"></div>\n    <div class=\"blob c\"></div>\n  </div>\n\n  <div class=\"stage\" role=\"main\" aria-label=\"K-Nearest Neighbors demonstration\">\n    <div class=\"info\">\n      <div class=\"brand\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <div class=\"mark\"></div>\n        </div>\n        <div>\n          <h1>K-Nearest Neighbors</h1>\n          <p class=\"lead\">Aesthetic, animated visualization of classification by neighbor voting.</p>\n        </div>\n      </div>\n\n      <div class=\"desc\">\n        Watch how a single query point is classified by looking at its K nearest neighbors.\n        Points form subtle clusters and the moving query explores the space. Nearest neighbors pulse,\n        lines draw attention, and the predicted label updates smoothly — a calm and clear demonstration\n        of the KNN principle.\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button class=\"btn toggle\" id=\"playBtn\" title=\"Play/Pause animation\">\n          <span class=\"dot\" aria-hidden=\"true\"></span>\n          <span id=\"playLabel\">Pause</span>\n        </button>\n\n        <div class=\"k-control\" title=\"Choose number of neighbors (K)\">\n          <div style=\"font-size:12px;color:var(--muted);padding-right:6px\">K</div>\n          <div class=\"k-label\" id=\"kValue\">5</div>\n          <input id=\"kSlider\" class=\"k-slider\" type=\"range\" min=\"1\" max=\"15\" step=\"2\" value=\"5\" aria-label=\"K slider\">\n        </div>\n      </div>\n    </div>\n\n    <div class=\"viz\" aria-hidden=\"false\">\n      <div class=\"badge\" role=\"status\" aria-live=\"polite\">\n        <div style=\"width:48px;height:48px;border-radius:10px;background:linear-gradient(120deg,var(--accent-a),var(--accent-b));display:flex;align-items:center;justify-content:center;box-shadow:0 6px 26px rgba(0,0,0,0.45)\">\n          <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M12 2v20\" stroke=\"#0b1220\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n            <path d=\"M5 12h14\" stroke=\"#0b1220\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n          </svg>\n        </div>\n        <div class=\"predict\">\n          <div class=\"title\">Prediction</div>\n          <div class=\"value\" id=\"prediction\">Class A</div>\n        </div>\n      </div>\n\n      <div class=\"canvas-wrap\">\n        <!-- SVG visualization -->\n        <svg id=\"vizSVG\" viewBox=\"0 0 800 520\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"KNN visualization\">\n          <defs>\n            <filter id=\"glow\" x=\"-40%\" y=\"-40%\" width=\"180%\" height=\"180%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n            <linearGradient id=\"lineGrad\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#73f1ff\" stop-opacity=\"0.9\"/>\n              <stop offset=\"1\" stop-color=\"#ff8fb2\" stop-opacity=\"0.9\"/>\n            </linearGradient>\n            <filter id=\"softShadow\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feDropShadow dx=\"0\" dy=\"8\" stdDeviation=\"12\" flood-color=\"#00131b\" flood-opacity=\"0.6\"/>\n            </filter>\n          </defs>\n\n          <!-- subtle grid backdrop -->\n          <g opacity=\"0.06\" transform=\"translate(40,20)\">\n            <rect x=\"0\" y=\"0\" width=\"720\" height=\"460\" rx=\"12\" fill=\"transparent\" stroke=\"rgba(255,255,255,0.02)\"/>\n            <g stroke=\"rgba(255,255,255,0.02)\">\n              <!-- horizontal lines -->\n              <path d=\"M0 0 L720 0\" transform=\"translate(0,460)\"/>\n              <!-- vertical lines -->\n              <path d=\"M0 0 L0 460\"/>\n            </g>\n          </g>\n\n          <!-- dynamic connections -->\n          <g id=\"lines\" stroke=\"url(#lineGrad)\" stroke-width=\"2\" stroke-linecap=\"round\" opacity=\"0.9\"></g>\n\n          <!-- rings for neighbors -->\n          <g id=\"rings\"></g>\n\n          <!-- points group -->\n          <g id=\"points\"></g>\n\n          <!-- query point -->\n          <g id=\"queryGroup\" filter=\"url(#softShadow)\">\n            <circle id=\"queryOuter\" cx=\"0\" cy=\"0\" r=\"18\" fill=\"rgba(255,255,255,0.03)\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.2\"/>\n            <circle id=\"queryFill\" cx=\"0\" cy=\"0\" r=\"9\" fill=\"#fff\"/>\n            <g id=\"queryAura\" opacity=\"0.16\">\n              <circle cx=\"0\" cy=\"0\" r=\"36\" fill=\"url(#lineGrad)\"></circle>\n            </g>\n          </g>\n\n          <!-- subtle cursor trail -->\n          <g id=\"trail\"></g>\n        </svg>\n      </div>\n\n      <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 4px 2px 4px\">\n        <div class=\"legend\">\n          <div class=\"item\"><span class=\"swatch sw-a\"></span><span>Class A</span></div>\n          <div class=\"item\"><span class=\"swatch sw-b\"></span><span>Class B</span></div>\n        </div>\n        <div class=\"sparkle\">Visualization — KNN • Smooth • Minimal controls</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // Config and state\n  const SVG_W = 760, SVG_H = 460; // inside padding 40\n  const OFFSET_X = 40, OFFSET_Y = 20;\n  const POINT_COUNT = 60;\n  const ANIM_DURATION = 14000; // ms for full loop\n  let running = true;\n  let K = 5;\n\n  // Colors for classes\n  const CLASS_COLORS = {\n    A: { fill: '#7ff9ff', stroke: '#4bd6da' }, // teal/cyan\n    B: { fill: '#ffade0', stroke: '#ff7cae' }  // coral/pink\n  };\n\n  // Create deterministic clustered data\n  function seededRandom(seed) {\n    return function() {\n      seed = (seed * 9301 + 49297) % 233280;\n      return seed / 233280;\n    };\n  }\n  const rand = seededRandom(12345);\n  const clusters = [\n    {cx: 0.22, cy: 0.28, r: 0.08, cls: 'A'},\n    {cx: 0.72, cy: 0.32, r: 0.09, cls: 'B'},\n    {cx: 0.38, cy: 0.72, r: 0.10, cls: 'A'},\n    {cx: 0.72, cy: 0.68, r: 0.08, cls: 'B'}\n  ];\n  const points = [];\n  for (let i=0;i<POINT_COUNT;i++){\n    const c = clusters[Math.floor(rand()*clusters.length)];\n    // scatter with gaussian-ish distribution\n    const r = Math.abs((rand()-0.5)*2)*c.r;\n    const angle = rand()*Math.PI*2;\n    const x = Math.min(Math.max(c.cx + Math.cos(angle)*r, 0.05), 0.95);\n    const y = Math.min(Math.max(c.cy + Math.sin(angle)*r, 0.05), 0.95);\n    points.push({\n      id: 'p'+i,\n      x: OFFSET_X + x * SVG_W,\n      y: OFFSET_Y + y * SVG_H,\n      class: c.cls,\n      size: 8 + Math.round(rand()*6)\n    });\n  }\n\n  // Path for query - smooth loop using Bezier points\n  const pathControl = [\n    {x: 0.12, y: 0.18},\n    {x: 0.5, y: 0.08},\n    {x: 0.86, y: 0.22},\n    {x: 0.78, y: 0.5},\n    {x: 0.9, y: 0.78},\n    {x: 0.5, y: 0.86},\n    {x: 0.18, y: 0.74},\n    {x: 0.08, y: 0.44}\n  ];\n\n  function getPathPoint(t){\n    // Catmull-Rom style interpolation through control points\n    const pts = pathControl;\n    const l = pts.length;\n    // map t to segment\n    const scaled = t * l;\n    const i = Math.floor(scaled) % l;\n    const local = scaled - Math.floor(scaled);\n    // indices\n    const p0 = pts[(i-1 + l)%l];\n    const p1 = pts[i];\n    const p2 = pts[(i+1)%l];\n    const p3 = pts[(i+2)%l];\n    // Catmull-Rom to cubic bezier conversion\n    const t2 = local*local, t3 = t2*local;\n    const x = 0.5 * ((2*p1.x) + (-p0.x + p2.x)*local + (2*p0.x -5*p1.x +4*p2.x - p3.x)*t2 + (-p0.x +3*p1.x -3*p2.x + p3.x)*t3);\n    const y = 0.5 * ((2*p1.y) + (-p0.y + p2.y)*local + (2*p0.y -5*p1.y +4*p2.y - p3.y)*t2 + (-p0.y +3*p1.y -3*p2.y + p3.y)*t3);\n    return {x: OFFSET_X + Math.min(Math.max(x,0.02),0.98)*SVG_W, y: OFFSET_Y + Math.min(Math.max(y,0.02),0.98)*SVG_H};\n  }\n\n  // DOM references\n  const svg = document.getElementById('vizSVG');\n  const pointsG = document.getElementById('points');\n  const ringsG = document.getElementById('rings');\n  const linesG = document.getElementById('lines');\n  const queryGroup = document.getElementById('queryGroup');\n  const queryFill = document.getElementById('queryFill');\n  const predictionEl = document.getElementById('prediction');\n  const kValueEl = document.getElementById('kValue');\n  const kSlider = document.getElementById('kSlider');\n  const playBtn = document.getElementById('playBtn');\n  const playLabel = document.getElementById('playLabel');\n\n  // Render static points\n  points.forEach(pt=>{\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('transform', `translate(${pt.x},${pt.y})`);\n    g.setAttribute('id', pt.id);\n    // soft halo\n    const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    halo.setAttribute('r', pt.size*1.8);\n    halo.setAttribute('fill', pt.class === 'A' ? 'rgba(115,241,255,0.06)' : 'rgba(255,143,178,0.06)');\n    halo.setAttribute('filter', 'url(#glow)');\n    // point\n    const circ = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circ.setAttribute('r', pt.size);\n    circ.setAttribute('fill', pt.class === 'A' ? CLASS_COLORS.A.fill : CLASS_COLORS.B.fill);\n    circ.setAttribute('stroke', pt.class === 'A' ? CLASS_COLORS.A.stroke : CLASS_COLORS.B.stroke);\n    circ.setAttribute('stroke-width', '1.5');\n    circ.setAttribute('opacity', '0.98');\n    circ.style.transition = 'transform 240ms cubic-bezier(.2,.9,.3,1), opacity 220ms';\n    g.appendChild(halo);\n    g.appendChild(circ);\n    pointsG.appendChild(g);\n    pt._el = g;\n  });\n\n  // rings and lines placeholder elements\n  function ensureElements() {\n    // nothing here; will create dynamic elements each frame\n  }\n  ensureElements();\n\n  // Compute nearest neighbors\n  function computeNeighbors(qx,qy,k){\n    const arr = points.map(pt=>{\n      const dx = pt.x - qx;\n      const dy = pt.y - qy;\n      return {pt:pt, d2: dx*dx + dy*dy};\n    });\n    arr.sort((a,b) => a.d2 - b.d2);\n    return arr.slice(0,k).map(o => o.pt);\n  }\n\n  // State for animation\n  let startTime = performance.now();\n  let lastT = 0;\n  let trailPoints = [];\n\n  // Animation loop\n  function tick(now){\n    if (!running){ requestAnimationFrame(tick); return; }\n    const elapsed = (now - startTime) % ANIM_DURATION;\n    const t = (elapsed / ANIM_DURATION);\n    // gentle easing for movement\n    const easedT = 0.5 - 0.5 * Math.cos(Math.PI*2*t); // oscillation style map to loop nicely\n    const pos = getPathPoint(easedT);\n    updateQuery(pos.x,pos.y, t);\n    lastT = t;\n    requestAnimationFrame(tick);\n  }\n\n  // Update visuals for query at position x,y\n  function updateQuery(qx,qy, t){\n    // Move query group\n    queryGroup.setAttribute('transform', `translate(${qx},${qy})`);\n    // trail\n    if (trailPoints.length > 18) trailPoints.shift();\n    trailPoints.push({x: qx, y: qy, a: 0.9});\n    drawTrail();\n\n    // Compute neighbors\n    const neighbors =