\n        circ.style.transform = `scale(${scale})`;\n        circ.style.filter = 'saturate(1.2) drop-shadow(0 10px 22px rgba(0,0,0,0.45))';\n      } else {\n        circ.style.transform = 'scale(1)';\n        circ.style.filter = 'none';\n      }\n    });\n\n    // Majority vote\n    const tally = neighbors.reduce((acc, p)=>{\n      acc[p.class] = (acc[p.class]||0) + 1; return acc;\n    }, {});\n    let pred='A', conf=0;\n    if ((tally.B||0) > (tally.A||0)){ pred='B'; conf = tally.B / K; } else { pred='A'; conf = tally.A / K; }\n\n    // Update query fill color and prediction badge\n    queryFill.setAttribute('fill', pred === 'A' ? CLASS_COLORS.A.fill : CLASS_COLORS.B.fill);\n    predictionEl.textContent = `Class ${pred} (${Math.round(conf*100)}%)`;\n    predictionEl.style.color = pred === 'A' ? '#b8ffff' : '#ffd6ea';\n  }\n\n  // Draw trail (soft path behind query)\n  function drawTrail(){\n    const g = document.getElementById('trail');\n    while (g.firstChild) g.removeChild(g.firstChild);\n    for (let i=0;i<trailPoints.length;i++){\n      const tp = trailPoints[i];\n      const c = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      const age = (i / trailPoints.length);\n      const r = 2 + age*8;\n      c.setAttribute('cx', tp.x); c.setAttribute('cy', tp.y);\n      c.setAttribute('r', r);\n      c.setAttribute('fill', `rgba(255,255,255,${0.06 * (1-age)})`);\n      if (i < trailPoints.length-1) c.setAttribute('opacity', 0.85 - i*0.03);\n      g.appendChild(c);\n    }\n  }\n\n  // UI interactions (limited)\n  playBtn.addEventListener('click', ()=>{\n    running = !running;\n    playBtn.classList.toggle('paused', !running);\n    playLabel.textContent = running ? 'Pause' : 'Play';\n    if (running) {\n      // resume tick with adjusted startTime so animation continues smoothly\n      startTime = performance.now() - lastT * ANIM_DURATION;\n    }\n  });\n\n  kSlider.addEventListener('input', (e)=>{\n    K = parseInt(e.target.value,10);\n    kValueEl.textContent = K;\n    // subtle pulse on K change\n    kValueEl.animate([{transform:'scale(0.95)'},{transform:'scale(1.06)'},{transform:'scale(1)'}], {duration:360, easing:'cubic-bezier(.2,.9,.3,1)'});\n  });\n\n  // Initialize UI values\n  kValueEl.textContent = K;\n\n  // Initial render and start\n  // place query at start\n  const initPos = getPathPoint(0);\n  updateQuery(initPos.x, initPos.y, 0);\n  requestAnimationFrame(tick);\n\n  // Accessibility: allow space to toggle play/pause\n  window.addEventListener('keydown', (e)=>{ if (e.code==='Space'){ e.preventDefault(); playBtn.click(); } });\n})();\n</script>\n</body>\n</html>"
