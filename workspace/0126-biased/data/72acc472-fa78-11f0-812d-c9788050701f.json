    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SDLC Visual Journey</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #2a3c6a;\n            --secondary: #4a6fa5;\n            --accent: #ff7e5f;\n            --light: #f8f9fa;\n            --dark: #1a1a2e;\n            --success: #4caf50;\n            --warning: #ff9800;\n            --info: #2196f3;\n            --error: #f44336;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s ease-out forwards;\n        }\n        \n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            letter-spacing: -0.5px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--secondary);\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .sdlc-cycle {\n            position: relative;\n            height: 600px;\n            margin: 4rem 0;\n        }\n        \n        .phase {\n            position: absolute;\n            width: 220px;\n            height: 220px;\n            border-radius: 50%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n            padding: 1.5rem;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            opacity: 0;\n            transform: scale(0.8);\n            cursor: default;\n            z-index: 1;\n        }\n        \n        .phase.active {\n            opacity: 1;\n            transform: scale(1);\n        }\n        \n        .phase:hover {\n            transform: scale(1.05) translateY(-5px);\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);\n            z-index: 2;\n        }\n        \n        .phase-icon {\n            font-size: 3.5rem;\n            margin-bottom: 1rem;\n        }\n        \n        .phase-title {\n            font-family: 'Playfair Display', serif;\n            font-size: 1.3rem;\n            margin-bottom: 0.5rem;\n            font-weight: 700;\n        }\n        \n        .phase-desc {\n            font-size: 0.9rem;\n            line-height: 1.5;\n        }\n        \n        .phase-1 {\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%) scale(0.8);\n            background: linear-gradient(135deg, #ff9966, #ff5e62);\n            color: white;\n        }\n        \n        .phase-2 {\n            top: 20%;\n            left: 30%;\n            background: linear-gradient(135deg, #4facfe, #00f2fe);\n            color: white;\n        }\n        \n        .phase-3 {\n            top: 20%;\n            right: 30%;\n            background: linear-gradient(135deg, #a8ff78, #78ffd6);\n            color: var(--dark);\n        }\n        \n        .phase-4 {\n            bottom: 20%;\n            left: 30%;\n            background: linear-gradient(135deg, #f093fb, #f5576c);\n            color: white;\n        }\n        \n        .phase-5 {\n            bottom: 20%;\n            right: 30%;\n            background: linear-gradient(135deg, #f83600, #f9d423);\n            color: var(--dark);\n        }\n        \n        .phase-6 {\n            top: 50%;\n            right: 10%;\n            background: linear-gradient(135deg, #6a11cb, #2575fc);\n            color: white;\n        }\n        \n        .phase-7 {\n            top: 50%;\n            left: 10%;\n            background: linear-gradient(135deg, #11998e, #38ef7d);\n            color: white;\n        }\n        \n        .connector {\n            position: absolute;\n            background: rgba(42, 60, 106, 0.1);\n            height: 4px;\n            width: 0;\n            transform-origin: left center;\n            z-index: 0;\n            transition: all 1s ease-out 0.5s;\n        }\n        \n        .connector.active {\n            width: 100px;\n        }\n        \n        .connector-1 {\n            top: 50%;\n            left: 27%;\n            transform: rotate(60deg);\n        }\n        \n        .connector-2 {\n            top: 28%;\n            left: 50%;\n            transform: rotate(0deg);\n        }\n        \n        .connector-3 {\n            top: 50%;\n            left: 27%;\n            transform: rotate(-60deg);\n        }\n        \n        .connector-4 {\n            top: 50%;\n            right: 27%;\n            transform: rotate(120deg);\n        }\n        \n        .connector-5 {\n            top: 28%;\n            right: 50%;\n            transform: rotate(180deg);\n        }\n        \n        .connector-6 {\n            top: 50%;\n            right: 27%;\n            transform: rotate(-120deg);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        .btn {\n            padding: 0.8rem 1.8rem;\n            border: none;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            font-size: 0.8rem;\n        }\n        \n        .btn-primary {\n            background: var(--primary);\n            color: white;\n        }\n        \n        .btn-primary:hover {\n            background: var(--secondary);\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n        }\n        \n        .btn-outline {\n            background: transparent;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n        }\n        \n        .btn-outline:hover {\n            background: var(--primary);\n            color: white;\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n        }\n        \n        .info-panel {\n            background: white;\n            border-radius: 12px;\n            padding: 2rem;\n            margin-top: 3rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 0.5s ease-out;\n        }\n        \n        .info-panel.active {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        .info-title {\n            font-family: 'Playfair Display', serif;\n            font-size: 1.8rem;\n            color: var(--primary);\n            margin-bottom: 1rem;\n        }\n        \n        .info-content {\n            line-height: 1.8;\n            color: #555;\n        }\n        \n        .highlight {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0, 0, 0, 0.8);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            z-index: 100;\n            opacity: 0;\n            pointer-events: none;\n            transition: all 0.5s ease;\n        }\n        \n        .highlight.active {\n            opacity: 1;\n            pointer-events: all;\n        }\n        \n        .highlight-content {\n            background: white;\n            border-radius: 12px;\n            padding: 2rem;\n            max-width: 600px;\n            width: 90%;\n            position: relative;\n            transform: scale(0.9);\n            transition: all 0.3s ease;\n        }\n        \n        .highlight.active .highlight-content {\n            transform: scale(1);\n        }\n        \n        .close-btn {\n            position: absolute;\n            top: 1rem;\n            right: 1rem;\n            background: none;\n            border: none;\n            font-size: 1.5rem;\n            cursor: pointer;\n            color: #999;\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem 0;\n            color: var(--secondary);\n            font-size: 0.9rem;\n        }\n        \n        @media (max-width: 768px) {\n            .sdlc-cycle {\n                height: auto;\n                display: flex;\n                flex-direction: column;\n                align-items: center;\n                gap: 2rem;\n            }\n            \n            .phase {\n                position: static;\n                transform: none !important;\n                margin-bottom: 1.5rem;\n            }\n            \n            .connector {\n                display: none;\n            }\n            \n            h1 {\n                font-size: 2.5rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Software Development Life Cycle</h1>\n            <p class=\"subtitle\">A visual journey through the phases that transform ideas into powerful digital solutions</p>\n        </header>\n        \n        <div class=\"sdlc-cycle\">\n            <!-- Phases -->\n            <div class=\"phase phase-1\" data-phase=\"planning\">\n                <div class=\"phase-icon\">📋</div>\n                <h3 class=\"phase-title\">Planning</h3>\n                <p class=\"phase-desc\">Define project scope, goals, timeline and resources</p>\n            </div>\n            \n            <div class=\"phase phase-2\" data-phase=\"analysis\">\n                <div class=\"phase-icon\">🔍</div>\n                <h3 class=\"phase-title\">Analysis</h3>\n                <p class=\"phase-desc\">Gather requirements and understand user needs</p>\n            </div>\n            \n            <div class=\"phase phase-3\" data-phase=\"design\">\n                <div class=\"phase-icon\">🎨</div>\n                <h3 class=\"phase-title\">Design</h3>\n                <p class=\"phase-desc\">Create system architecture and UI/UX designs</p>\n            </div>\n            \n            <div class=\"phase phase-4\" data-phase=\"development\">\n                <div class=\"phase-icon\">💻</div>\n                <h3 class=\"phase-title\">Development</h3>\n                <p class=\"phase-desc\">Write code and build the software product</p>\n            </div>\n            \n            <div class=\"phase phase-5\" data-phase=\"testing\">\n                <div class=\"phase-icon\">🧪</div>\n                <h3 class=\"phase-title\">Testing</h3>\n                <p class=\"phase-desc\">Verify functionality and identify bugs</p>\n            </div>\n            \n            <div class=\"phase phase-6\" data-phase=\"deployment\">\n                <div class=\"phase-icon\">🚀</div>\n                <h3 class=\"phase-title\">Deployment</h3>\n                <p class=\"phase-desc\">Release the product to production environment</p>\n            </div>\n            \n            <div class=\"phase phase-7\" data-phase=\"maintenance\">\n                <div class=\"phase-icon\">🔄</div>\n                <h3 class=\"phase-title\">Maintenance</h3>\n                <p class=\"phase-desc\">Support, updates and improvements</p>\n            </div>\n            \n            <!-- Connectors -->\n            <div class=\"connector connector-1\"></div>\n            <div class=\"connector connector-2\"></div>\n            <div class=\"connector connector-3\"></div>\n            <div class=\"connector connector-4\"></div>\n            <div class=\"connector connector-5\"></div>\n            <div class=\"connector connector-6\"></div>\n        </div>\n        \n        <div class=\"controls\">\n            <button class=\"btn btn-primary\" id=\"animateBtn\">Animate Cycle</button>\n            <button class=\"btn btn-outline\" id=\"learnMoreBtn\">Learn More</button>\n        </div>\n        \n        <div class=\"info-panel\" id=\"infoPanel\">\n            <h3 class=\"info-title\">The SDLC Process</h3>\n            <div class=\"info-content\">\n                <p>The Software Development Life Cycle (SDLC) is a structured process that enables the production of high-quality, low-cost software, in the shortest possible production time.</p>\n                <p>Each phase in the cycle produces deliverables required by the next phase, following a waterfall or iterative approach depending on the project methodology.</p>\n                <p>Modern development often combines these phases in agile methodologies, with continuous integration and deployment creating a more fluid process.</p>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"highlight\" id=\"highlight\">\n        <div class=\"highlight-content\">\n            <button class=\"close-btn\" id=\"closeHighlight\">×</button>\n            <h3 class=\"info-title\">About SDLC</h3>\n            <div class=\"info-content\">\n                <p>The Software Development Life Cycle provides a framework for technical and non-technical activities to deliver quality software that meets or exceeds customer expectations.</p>\n                \n                <h4 style=\"margin-top: 1.5rem; color: var(--primary);\">Key Benefits:</h4>\n                <ul style=\"margin-top: 0.5rem; padding-left: 1.5rem; list-style-type: none;\">\n                    <li style=\"margin-bottom: 0.5rem;\">✔️ Provides structured framework for development</li>\n                    <li style=\"margin-bottom: 0.5rem;\">✔️ Improves visibility for all stakeholders</li>\n                    <li style=\"margin-bottom: 0.5rem;\">✔️ Reduces project risks and costs</li>\n                    <li style=\"margin-bottom: 0.5rem;\">✔️ Ensures quality through testing phases</li>\n                    <li style=\"margin-bottom: 0.5rem;\">✔️ Enables continuous improvement</li>\n                </ul>\n                \n                <p style=\"margin-top: 1.5rem;\">Different methodologies like Waterfall, Agile, Spiral, and DevOps adapt the SDLC to different project needs and environments.</p>\n            </div>\n        </div>\n    </div>\n    \n    <footer>\n        <p>© 2023 SDLC Visual Journey | Created with HTML, CSS & JavaScript</p>\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Animate header\n            setTimeout(() => {\n                document.querySelector('header').style.animation = 'fadeIn 1s ease-out forwards';\n            }, 300);\n            \n            // Get DOM elements\n            const animateBtn = document.getElementById('animateBtn');\n            const learnMoreBtn = document.getElementById('learnMoreBtn');\n            const closeHighlight = document.getElementById('closeHighlight');\n            const highlight = document.getElementById('highlight');\n            const infoPanel = document.getElementById('infoPanel');\n            const phases = document.querySelectorAll('.phase');\n            const connectors = document.querySelectorAll('.connector');\n            \n            // Animate cycle button\n            animateBtn.addEventListener('click', function() {\n                // Reset all phases and connectors\n                phases.forEach(phase => phase.classList.remove('active'));\n                connectors.forEach(connector => connector.classList.remove('active'));\n                \n                // Animate each phase with delay\n                phases.forEach((phase, index) => {\n                    setTimeout(() => {\n                        phase.classList.add('active');\n                    }, index * 300);\n                });\n                \n                // Animate connectors with longer delay\n                setTimeout(() => {\n                    connectors.forEach(connector => {\n                        connector.classList.add('active');\n                    });\n                }, phases.length * 300);\n                \n                // Show info panel\n                setTimeout(() => {\n                    infoPanel.classList.add('active');\n                }, 2500);\n            });\n            \n            // Learn more button\n            learnMoreBtn.addEventListener('click', function() {\n                highlight.classList.add('active');\n            });\n            \n            // Close highlight\n            closeHighlight.addEventListener('click', function() {\n                highlight.classList.remove('active');\n            });\n            \n            // Initial animation after page load\n            setTimeout(() => {\n                animateBtn.click();\n            }, 1000);\n            \n            // Phase hover effects\n            phases.forEach(phase => {\n                phase.addEventListener('mouseenter', function() {\n                    this.style.zIndex = '10';\n                });\n                \n                phase.addEventListener('mouseleave', function() {\n                    this.style.zIndex = '1';\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
