    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Doubly Linked List Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Doubly Linked List Interactive Demo</h1>\n    \n    <h2>Add Node</h2>\n    <input type=\"text\" id=\"newNodeValue\" placeholder=\"Enter node value\" />\n    <button onclick=\"addNodeAtEnd()\">Add Node at End</button>\n    <button onclick=\"addNodeAtStart()\">Add Node at Start</button>\n    \n    <h2>Remove Node</h2>\n    <input type=\"number\" id=\"removeNodeIndex\" placeholder=\"Enter index to remove\" />\n    <button onclick=\"removeNode()\">Remove Node</button>\n\n    <h2>Traversal</h2>\n    <button onclick=\"traverseForward()\">Traverse Forward</button>\n    <button onclick=\"traverseBackward()\">Traverse Backward</button>\n\n    <h2>Search Node</h2>\n    <input type=\"text\" id=\"searchNodeValue\" placeholder=\"Enter value to search\" />\n    <button onclick=\"searchNode()\">Search Node</button>\n\n    <h2>Output</h2>\n    <div id=\"output\"></div>\n\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.next = null;\n                this.prev = null;\n            }\n        }\n\n        class DoublyLinkedList {\n            constructor() {\n                this.head = null;\n                this.tail = null;\n            }\n\n            addToEnd(value) {\n                const newNode = new Node(value);\n                if (this.tail) { \n                    this.tail.next = newNode; \n                    newNode.prev = this.tail;\n                } else { \n                    this.head = newNode; \n                }\n                this.tail = newNode;\n            }\n\n            addToStart(value) {\n                const newNode = new Node(value);\n                if (this.head) {\n                    newNode.next = this.head; \n                    this.head.prev = newNode;\n                } else {\n                    this.tail = newNode; \n                }\n                this.head = newNode;\n            }\n\n            removeAtIndex(index) {\n                if (index < 0) return;\n                let current = this.head;\n                let i = 0;\n                while (current && i < index) {\n                    current = current.next;\n                    i++;\n                }\n                if (!current) return; \n\n                if (current.prev) {\n                    current.prev.next = current.next; \n                } else {\n                    this.head = current.next; \n                }\n                if (current.next) {\n                    current.next.prev = current.prev; \n                } else {\n                    this.tail = current.prev; \n                }\n            }\n\n            forwardTraversal() {\n                let current = this.head;\n                let result = [];\n                while (current) {\n                    result.push(current.value);\n                    current = current.next;\n                }\n                return result.join(' <-> ');\n            }\n\n            backwardTraversal() {\n                let current = this.tail;\n                let result = [];\n                while (current) {\n                    result.push(current.value);\n                    current = current.prev;\n                }\n                return result.join(' <-> ');\n            }\n\n            search(value) {\n                let current = this.head;\n                while (current) {\n                    if (current.value === value) {\n                        return true;\n                    }\n                    current = current.next;\n                }\n                return false;\n            }\n        }\n\n        const list = new DoublyLinkedList();\n\n        function addNodeAtEnd() {\n            const value = document.getElementById('newNodeValue').value;\n            if (value) {\n                list.addToEnd(value);\n                document.getElementById('output').innerText = 'Node added at end. Current List: ' + list.forwardTraversal();\n                document.getElementById('newNodeValue').value = '';\n            }\n        }\n\n        function addNodeAtStart() {\n            const value = document.getElementById('newNodeValue').value;\n            if (value) {\n                list.addToStart(value);\n                document.getElementById('output').innerText = 'Node added at start. Current List: ' + list.forwardTraversal();\n                document.getElementById('newNodeValue').value = '';\n            }\n        }\n\n        function removeNode() {\n            const index = parseInt(document.getElementById('removeNodeIndex').value);\n            list.removeAtIndex(index);\n            document.getElementById('output').innerText = 'Node removed. Current List: ' + list.forwardTraversal();\n        }\n\n        function traverseForward() {\n            document.getElementById('output').innerText = 'Current List (Forward): ' + list.forwardTraversal();\n        }\n\n        function traverseBackward() {\n            document.getElementById('output').innerText = 'Current List (Backward): ' + list.backwardTraversal();\n        }\n\n        function searchNode() {\n            const value = document.getElementById('searchNodeValue').value;\n            const found = list.search(value);\n            if (found) {\n                document.getElementById('output').innerText = 'Node with value \"' + value + '\" found.';\n            } else {\n                document.getElementById('output').innerText = 'Node with value \"' + value + '\" not found.';\n            }\n        }\n    </script>\n</body>\n</html>"
