  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Hash Map Demonstration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    line-height: 1.4;\n    white-space: pre-wrap;\n    margin: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 7em;\n    font-family: monospace, monospace;\n  }\n  input[type=\"number\"], input[type=\"text\"] {\n    font-family: monospace, monospace;\n  }\n  button {\n    margin-right: 0.4em;\n    margin-top: 0.4em;\n  }\n  .section {\n    margin-top: 2em;\n    border-top: 1px solid black;\n    padding-top: 1em;\n  }\n  .inline-group > * {\n    margin-right: 0.5em;\n    margin-bottom: 0.3em;\n  }\n  select {\n    font-family: monospace, monospace;\n  }\n  #log {\n    background-color: #eee;\n    border: 1px solid #ccc;\n    padding: 0.5em;\n    max-height: 12em;\n    overflow-y: auto;\n    margin-top: 0.5em;\n    white-space: pre-wrap;\n  }\n  #hashFunctionDescription {\n    min-height: 3em;\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  #mapDisplay {\n    font-family: monospace, monospace;\n    max-height: 15em;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 0.5em;\n    margin-top: 0.5em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Interactive Hash Map Demonstration</h1>\n\n<p>\nThis demonstration lets you explore the internal workings of a hash map data structure.\nYou can add, delete, update, and find keys. You can experiment with the hash function,\nthe table size, collision resolution strategies, and load factor resizing.\nThis is a fully interactive tool to deepen your understanding of hash maps.\n</p>\n\n<div class=\"section\" id=\"config-section\">\n  <h2>1. Hash Map Configuration</h2>\n  <label>\n    Table Size (number of buckets): <input type=\"number\" id=\"tableSize\" value=\"8\" min=\"1\" max=\"1024\" step=\"1\" />\n  </label>\n  <label>\n    Collision Resolution Strategy:\n    <select id=\"collisionStrategy\">\n      <option value=\"chaining\" selected>Separate Chaining (Linked Lists)</option>\n      <option value=\"linear\">Open Addressing - Linear Probing</option>\n      <option value=\"quadratic\">Open Addressing - Quadratic Probing</option>\n      <option value=\"double\">Open Addressing - Double Hashing</option>\n    </select>\n  </label>\n  <label>\n    Load factor threshold for resize (0.1 - 0.95):\n    <input type=\"number\" id=\"loadFactorThreshold\" value=\"0.75\" min=\"0.1\" max=\"0.95\" step=\"0.01\" />\n  </label>\n\n  <label>\n    Hash Function:\n    <select id=\"hashFunctionChoice\">\n      <option value=\"simpleSum\" selected>Simple sum of char codes mod table size</option>\n      <option value=\"djb2\">DJB2 hash of string mod table size</option>\n      <option value=\"jsHash\">Java String hashCode mod table size</option>\n      <option value=\"custom\">Custom function (edit below)</option>\n    </select>\n  </label>\n  <textarea id=\"customHashFunction\" style=\"display:none;\" spellcheck=\"false\">// Function must be named \"hashFunc\" and return integer ≥ 0\n// Parameter: key (string)\n// Example:\n// function hashFunc(key) {\n//   let h=0; for(let i=0;i<key.length;++i) h+=key.charCodeAt(i);\n//   return h;\n// }\n</textarea>\n\n  <button id=\"createMapBtn\">Create / Reset Hash Map</button>\n  <div id=\"hashFunctionDescription\"></div>\n</div>\n\n<div class=\"section\" id=\"operations-section\" style=\"display:none;\">\n  <h2>2. Hash Map Operations</h2>\n  <div>\n    <label>\n      Key: <input type=\"text\" id=\"opKey\" />\n    </label>\n    <label>\n      Value: <input type=\"text\" id=\"opValue\" />\n    </label>\n  </div>\n  <div class=\"inline-group\">\n    <button id=\"insertBtn\">Insert / Update</button>\n    <button id=\"deleteBtn\">Delete</button>\n    <button id=\"searchBtn\">Search</button>\n    <button id=\"clearBtn\">Clear All</button>\n  </div>\n  <div>\n    <label>\n      Bulk Insert (JSON Array of [key,value] pairs):\n      <textarea id=\"bulkInsertText\">[[\"apple\",\"fruit\"],[\"car\",\"vehicle\"],[\"name\",\"chat\"]]</textarea>\n    </label>\n    <button id=\"bulkInsertBtn\">Bulk Insert from JSON</button>\n  </div>\n</div>\n\n<div class=\"section\" id=\"state-section\" style=\"display:none;\">\n  <h2>3. Hash Map Internal State</h2>\n  <label>\n    Resize Table: <input type=\"number\" id=\"resizeTableSize\" value=\"16\" min=\"1\" max=\"2048\" step=\"1\" />\n    <button id=\"resizeBtn\">Resize Table (rehash)</button>\n  </label>\n  <label>\n    Load Factor: <input type=\"range\" id=\"loadFactorSlider\" min=\"0\" max=\"100\" value=\"75\" />\n    <span id=\"loadFactorDisplay\">0.75</span>\n  </label>\n  <button id=\"toggleAutoResizeBtn\">Toggle Auto-Resize: ON</button>\n  <button id=\"stepRehashBtn\">Step Rehash (demo)</button>\n\n  <h3>Map Buckets</h3>\n  <select id=\"bucketSelect\" size=\"8\" style=\"width:100%; max-width: 600px;\"></select>\n\n  <div id=\"mapDisplay\"></div>\n</div>\n\n<div class=\"section\" id=\"log-section\">\n  <h2>4. Log / Console</h2>\n  <div id=\"log\"></div>\n  <button id=\"clearLogBtn\">Clear Log</button>\n</div>\n\n<script>\n(() => {\n  // Hash map internal representation and behavior\n\n  // ----------- Hash functions -----------\n\n  // All hash functions receive (key:string, tableSize:number) and return int >=0 < tableSize\n\n  function simpleSumHash(key, tableSize) {\n    let sum = 0;\n    for(let i=0; i<key.length; i++) sum += key.charCodeAt(i);\n    return sum % tableSize;\n  }\n\n  function djb2Hash(key, tableSize) {\n    // classic DJB2 hash\n    let hash = 5381;\n    for(let i=0; i<key.length; i++) {\n      hash = ((hash << 5) + hash) + key.charCodeAt(i);\n      hash = hash & 0xFFFFFFFF;\n    }\n    return (hash >>> 0) % tableSize;\n  }\n\n  function javaHashCode(key, tableSize) {\n    // Java String hashCode algorithm\n    let h = 0;\n    for(let i=0; i<key.length; i++) {\n      h = (31 * h + key.charCodeAt(i)) | 0;\n    }\n    return (h >>> 0) % tableSize;\n  }\n\n  // global for custom function\n  let customHashFunc = null;\n\n  // -------------- HashMap Class --------------\n\n  class HashMap {\n    constructor(tableSize = 8, collisionStrategy = \"chaining\", hashFunc = simpleSumHash, loadFactorThreshold = 0.75){\n      this.tableSize = tableSize;\n      this.collisionStrategy = collisionStrategy;\n      this.hashFunc = hashFunc;\n      this.loadFactorThreshold = loadFactorThreshold;\n      this.autoResize = true;\n\n      this.count = 0; // number of entries\n\n      // buckets structure differs:\n      // chaining: array of arrays [ [ {k,v},... ], ...]\n      // open addressing (linear, quadratic, double): array of { key, value, deleted:boolean } or null\n      \n      if(this.collisionStrategy === \"chaining\"){\n        this.buckets = new Array(tableSize);\n        for(let i=0; i<tableSize; i++) this.buckets[i] = [];\n      } else {\n        this.buckets = new Array(tableSize).fill(null);\n      }\n\n      // For open addressing, we must define secondary hash for double hashing\n      if(this.collisionStrategy === \"double\"){\n        // secondary hash function for double hashing (must not be zero)\n        this.secondaryHash = function(key){\n          let h = 0;\n          for(let i=0; i<key.length; i++){\n            h = (h*37 + key.charCodeAt(i)) & 0x7FFFFFFF;\n          }\n          return (h % (this.tableSize -1)) +1;\n        }.bind(this);\n      }\n    }\n\n    _probeSequence(key, i){\n      // Returns bucket index for ith probe for key\n      const h1 = this.hashFunc(key, this.tableSize);\n      if(this.collisionStrategy === \"linear\"){\n        return (h1 + i) % this.tableSize;\n      } else if(this.collisionStrategy === \"quadratic\"){\n        return (h1 + i*i) % this.tableSize;\n      } else if(this.collisionStrategy === \"double\"){\n        const h2 = this.secondaryHash(key);\n        return (h1 + i * h2) % this.tableSize;\n      } else {\n        return h1;\n      }\n    }\n\n    insert(key, value) {\n      if(typeof key !== \"string\") key = String(key);\n      if(this.collisionStrategy === \"chaining\"){\n        const idx = this.hashFunc(key, this.tableSize);\n        let bucket = this.buckets[idx];\n        for(let entry of bucket){\n          if(entry.key === key){\n            entry.value = value;\n            logMessage(`Updated existing key \"${key}\" in bucket ${idx}`);\n            return;\n          }\n        }\n        bucket.push({key,value});\n        this.count++;\n        logMessage(`Inserted key \"${key}\" into bucket ${idx} (chaining)`);\n      } else {\n        // open addressing insert\n        for(let i=0; i<this.tableSize; i++){\n          const idx = this._probeSequence(key, i);\n          const slot = this.buckets[idx];\n          if(slot === null || slot.deleted){\n            this.buckets[idx] = {key,value,deleted:false};\n            this.count++;\n            logMessage(`Inserted key \"${key}\" at bucket ${idx} (open addressing, attempt ${i})`);\n            if(this.autoResize) this._checkResize();\n            return;\n          } else if(slot.key === key && !slot.deleted){\n            this.buckets[idx].value = value;\n            logMessage(`Updated existing key \"${key}\" at bucket ${idx} (open addressing, attempt ${i})`);\n            return;\n          }\n        }\n        // table full\n        logMessage(`ERROR: Table full, cannot insert key \"${key}\"`);\n        throw new Error(\"Hash Map is full.\");\n      }\n\n      if(this.autoResize) this._checkResize();\n    }\n\n    find(key){\n      if(typeof key !== \"string\") key = String(key);\n      if(this.collisionStrategy === \"chaining\"){\n        const idx = this.hashFunc(key, this.tableSize);\n        const bucket = this.buckets[idx];\n        for(let entry of bucket){\n          if(entry.key === key){\n            logMessage(`Found key \"${key}\" in bucket ${idx} (chaining)`);\n            return entry.value;\n          }\n        }\n        logMessage(`Key \"${key}\" not found in bucket ${idx} (chaining)`);\n        return undefined;\n      } else {\n        // open addressing search\n        for(let i=0; i<this.tableSize; i++){\n          const idx = this._probeSequence(key, i);\n          const slot = this.buckets[idx];\n          if(slot === null) {\n            logMessage(`Key \"${key}\" not found - empty slot at bucket ${idx} (open addressing, attempt ${i})`);\n            return undefined; // stop at first never used slot\n          }\n          if(!slot.deleted && slot.key === key){\n            logMessage(`Found key \"${key}\" at bucket ${idx} (open addressing, attempt ${i})`);\n            return slot.value;\n          }\n          // else try next probe\n        }\n        logMessage(`Key \"${key}\" not found in table (open addressing full search)`);\n        return undefined;\n      }\n    }\n\n    delete(key){\n      if(typeof key !== \"string\") key = String(key);\n      if(this.collisionStrategy === \"chaining\"){\n        const idx = this.hashFunc(key, this.tableSize);\n        let bucket = this.buckets[idx];\n        for(let i=0; i<bucket.length; i++){\n          if(bucket[i].key === key){\n            bucket.splice(i,1);\n            this.count--;\n            logMessage(`Deleted key \"${key}\" from bucket ${idx} (chaining)`);\n            return true;\n          }\n        }\n        logMessage(`Key \"${key}\" not found to delete (chaining)`);\n        return false;\n      } else {\n        for(let i=0; i<this.tableSize; i++){\n          const idx = this._probeSequence(key, i);\n          const slot = this.buckets[idx];\n          if(slot === null) {\n            logMessage(`Key \"${key}\" not found for deletion (empty slot at bucket ${idx})`);\n            return false;\n          }\n          if(!slot.deleted && slot.key === key){\n            slot.deleted = true;\n            this.count--;\n            logMessage(`Deleted key \"${key}\" at bucket ${idx} (open addressing)`);\n            return true;\n          }\n        }\n        logMessage(`Key \"${key}\" not found for deletion (full search)`);\n        return false;\n      }\n    }\n\n    clear(){\n      // reset all buckets\n      if(this.collisionStrategy === \"chaining\"){\n        for(let i=0; i<this.tableSize; i++){\n          this.buckets[i] = [];\n        }\n      } else {\n        this.buckets.fill(null);\n      }\n      this.count = 0;\n      logMessage(\"Cleared entire hash map\");\n    }\n\n    loadFactor(){\n      return this.count / this.tableSize;\n    }\n\n    _checkResize(){\n      const lf = this.loadFactor();\n      if(lf > this.loadFactorThreshold){\n        logMessage(`Load factor ${lf.toFixed(3)} exceeded threshold ${this.loadFactorThreshold.toFixed(3)} - resizing...`);\n        this._resize(this.tableSize * 2);\n      }\n    }\n\n    _resize(newTableSize){\n      logMessage(`Resizing from ${this.tableSize} to ${newTableSize} and rehashing all entries...`);\n      // Save old entries\n      let entries = [];\n      if(this.collisionStrategy === \"chaining\"){\n        for(let bucket of this.buckets){\n          for(let e of bucket){\n            entries.push(e);\n          }\n        }\n      } else {\n        for(let slot of this.buckets){\n          if(slot !== null && !slot.deleted) {\n            entries.push({key:slot.key, value:slot.value});\n          }\n        }\n      }\n      // Reinitialize\n      this.tableSize = newTableSize;\n      if(this.collisionStrategy === \"chaining\"){\n        this.buckets = new Array(this.tableSize);\n        for(let i=0; i<this.tableSize; i++) this.buckets[i] = [];\n      } else {\n        this.buckets = new Array(this.tableSize).fill(null);\n      }\n      this.count = 0;\n      // Re-insert entries\n      for(let e of entries){\n        this.insert(e.key, e.value);\n      }\n      logMessage(\"Rehash complete.\");\n      updateBucketList();\n      updateMapDisplay();\n      updateLoadFactorDisplay();\n    }\n\n    resizeManual(newSize){\n      if(newSize < 1) throw new Error(\"Resize size must be positive integer.\");\n      this._resize(newSize);\n    }\n  }\n\n  // ----------------- UI and state -----------------\n\n  // Global variables\n  let hashMap = null;\n\n  // UI elements\n  const tableSizeInput = document.getElementById(\"tableSize\");\n  const collisionStrategySelect = document.getElementById(\"collisionStrategy\");\n  const loadFactorThresholdInput = document.getElementById(\"loadFactorThreshold\");\n  const hashFunctionChoiceSelect = document.getElementById(\"hashFunctionChoice\");\n  const customHashArea = document.getElementById(\"customHashFunction\");\n  const createMapBtn = document.getElementById(\"createMapBtn\");\n\n  const opKeyInput = document.getElementById(\"opKey\");\n  const opValueInput = document.getElementById(\"opValue\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const deleteBtn = document.getElementById(\"deleteBtn\");\n  const searchBtn = document.getElementById(\"searchBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n  const bulkInsertText = document.getElementById(\"bulkInsertText\");\n  const bulkInsertBtn = document.getElementById(\"bulkInsertBtn\");\n\n  const resizeTableSizeInput = document.getElementById(\"resizeTableSize\");\n  const resizeBtn = document.getElementById(\"resizeBtn\");\n  const loadFactorSlider = document.getElementById(\"loadFactorSlider\");\n  const loadFactorDisplay = document.getElementById(\"loadFactorDisplay\");\n  const toggleAutoResizeBtn = document.getElementById(\"toggleAutoResizeBtn\");\n  const stepRehashBtn = document.getElementById(\"stepRehashBtn\");\n\n  const bucketSelect = document.getElementById(\"bucketSelect\");\n  const mapDisplay = document.getElementById(\"mapDisplay\");\n\n  const logBox = document.getElementById(\"log\");\n  const clearLogBtn = document.getElementById(\"clearLogBtn\");\n\n  const operationsSection = document.getElementById(\"operations-section\");\n  const stateSection = document.getElementById(\"state-section\");\n  const hashFunctionDescriptionDiv = document.getElementById(\"hashFunctionDescription\");\n\n  // Helpers\n\n  function logMessage(msg){\n    const now = new Date();\n    const timeStr = now.toLocaleTimeString();\n    logBox.textContent += `[${timeStr}] ${msg}\\n`;\n    logBox.scrollTop = logBox.scrollHeight;\n  }\n\n  function clearLog(){\n    logBox.textContent = \"\";\n  }\n\n  function parseNumberInput(input){\n    let n = Number(input);\n    if(Number.isNaN(n)) return null;\n    return n;\n  }\n\n  function updateHashFunctionDescription(choice){\n    let desc = \"\";\n    if(choice === \"simpleSum\"){\n      desc = \"Hash Function: sum of character codes modulo table size.\\nExample: key='abc' → hash = ('a'+ 'b' + 'c') % tableSize\";\n    } else if(choice === \"djb2\"){\n      desc = \"Hash Function: DJB2 algorithm by Dan Bernstein.\\nUses bit-shifting and addition, then modulo table size.\";\n    } else if(choice === \"jsHash\"){\n      desc = \"Hash Function: Java String hashCode algorithm.\\nPolynomial accumulation with multiplier 31, then modulo table size.\";\n    } else if(choice === \"custom\"){\n      desc = \"Custom hash function provided below.\\nFunction must be named 'hashFunc(key)' and return integer≥0.\";\n    } else {\n      desc = \"\";\n    }\n    hashFunctionDescriptionDiv.textContent = desc;\n  }\n\n  function getHashFunction(){\n    const choice = hashFunctionChoiceSelect.value;\n    if(choice === \"simpleSum\") return simpleSumHash;\n    if(choice === \"djb2\") return djb2Hash;\n    if(choice === \"jsHash\") return javaHashCode;\n    if(choice === \"custom\"){\n      // try to evaluate custom hash func\n      try {\n        const code = customHashArea.value;\n        // eslint-disable-next-line no-new-func\n        const func = new Function(code + \"\\n return hashFunc;\");\n        const fn = func();\n        if(typeof fn !== \"function\") throw new Error(\"No function named 'hashFunc' found.\");\n        // test calling with string\n        const testCall = fn(\"test\");\n        if(!Number.isInteger(testCall) || testCall < 0) throw new Error(\"hashFunc must return a non-negative integer.\");\n        return fn;\n      } catch(e){\n        alert(\"Error in custom hash function:\\n\" + e.message);\n        return null;\n      }\n    }\n    return null;\n  }\n\n  function createNewHashMap(){\n    clearLog();\n    const size = parseNumberInput(tableSizeInput.value);\n    if(!Number.isInteger(size) || size < 1 || size > 1024){\n      alert(\"Invalid table size. Must be integer between 1 and 1024.\");\n      return;\n    }\n    const collisionStrategy = collisionStrategySelect.value;\n    const loadFactorThreshold = parseNumberInput(loadFactorThresholdInput.value);\n    if(typeof loadFactorThreshold !== \"number\" || loadFactorThreshold < 0.1 || loadFactorThreshold > 0.95){\n      alert(\"Load factor threshold must be between 0.1 and 0.95.\");\n      return;\n    }\n    const hf = getHashFunction();\n    if(hf === null){\n      alert(\"Select a valid hash function before creating map.\");\n      return;\n    }\n    hashMap = new HashMap(size, collisionStrategy, hf, loadFactorThreshold);\n    logMessage(`Hash map created: size=${size}, collision=${collisionStrategy}, loadFactorThreshold=${loadFactorThreshold.toFixed(3)}`);\n\n    operationsSection.style.display = \"block\";\n    stateSection.style.display = \"block\";\n    updateBucketList();\n    updateMapDisplay();\n    updateLoadFactorSlider();\n    updateLoadFactorDisplay();\n    updateToggleAutoResizeBtn();\n  }\n\n  function updateBucketList(){\n    if(!hashMap) return;\n    // Show bucket indices with basic summary\n    const n = hashMap.tableSize;\n    bucketSelect.innerHTML = \"\";\n    for(let i=0; i<n; i++){\n      let text = `Bucket ${i}: `;\n      if(hashMap.collisionStrategy === \"chaining\"){\n        let bucket = hashMap.buckets[i];\n        if(bucket.length === 0) text += \"(empty)\";\n        else {\n          text += bucket.map(e=>`[\"${e.key}\":${e.value}]`).join(\", \");\n        }\n      } else {\n        const slot = hashMap.buckets[i];\n        if(slot === null) text += \"(empty)\";\n        else if(slot.deleted) text += '(deleted)';\n        else text += `[\"${slot.key}\":${slot.value}]`;\n      }\n      let option = document.createElement(\"option\");\n      option.value = i;\n      option.textContent = text;\n      bucketSelect.appendChild(option);\n    }\n  }\n  \n  function updateMapDisplay(){\n    if(!hashMap) return;\n    let text = \"\";\n    const n = hashMap.tableSize;\n    if(hashMap.collisionStrategy === \"chaining\"){\n      for(let i=0; i<n; i++){\n        text += `Bucket ${i}:\\n`;\n        let bucket = hashMap.buckets[i];\n        if(bucket.length === 0) {\n          text += \"  (empty)\\n\";\n        } else {\n          for(let e of bucket){\n            text += `  key: \"${e.key}\"  value: \"${e.value}\"\\n`;\n          }\n        }\n      }\n    } else {\n      for(let i=0; i<n; i++){\n        const slot = hashMap.buckets[i];\n        text += `Bucket ${i}: `;\n        if(slot === null) text += \"(empty)\\n\";\n        else if(slot.deleted) text += \"(deleted)\\n\";\n        else text += `key: \"${slot.key}\", value: \"${slot.value}\"\\n`;\n      }\n    }\n    text += `\\nEntries count: ${hashMap.count}\\nTable size: ${hashMap.tableSize}\\nLoad factor: ${hashMap.loadFactor().toFixed(3)}\\n`;\n    mapDisplay.textContent = text;\n  }\n\n  function updateLoadFactorSlider(){\n    const val = Math.round(hashMap.loadFactorThreshold * 100);\n    loadFactorSlider.value = val;\n  }\n\n  function updateLoadFactorDisplay(){\n    if(!hashMap) return;\n    loadFactorDisplay.textContent = hashMap.loadFactorThreshold.toFixed(2);\n  }\n\n  function toggleAutoResize(){\n    if(!hashMap) return;\n    hashMap.autoResize = !hashMap.autoResize;\n    updateToggleAutoResizeBtn();\n    logMessage(\"Auto-resize set to \" + (hashMap.autoResize ? \"ON\" : \"OFF\"));\n  }\n\n  function updateToggleAutoResizeBtn(){\n    if(!hashMap) return;\n    toggleAutoResizeBtn.textContent = \"Toggle Auto-Resize: \" + (hashMap.autoResize ? \"ON\" : \"OFF\");\n  }\n\n  function stepRehashDemo(){\n    // Demonstrate incremental rehashing step (only conceptual; this simple impl does full rehash)\n    // So just run a resize with smaller table increase to visualize process in log\n    if(!hashMap) return;\n    const newSize = hashMap.tableSize + 2;\n    logMessage(`Demo incremental resize to ${newSize}... (conceptual)`);\n    hashMap.resizeManual(newSize);\n  }\n\n  // Event listeners\n\n  createMapBtn.addEventListener(\"click\", () => {\n    createNewHashMap();\n  });\n\n  hashFunctionChoiceSelect.addEventListener(\"change\", () => {\n    updateHashFunctionDescription(hashFunctionChoiceSelect.value);\n    if(hashFunctionChoiceSelect.value === \"custom\"){\n      customHashArea.style.display = \"block\";\n    } else {\n      customHashArea.style.display = \"none\";\n    }\n  });\n\n  insertBtn.addEventListener(\"click\", () => {\n    if(!hashMap) {\n      alert(\"Create hash map first.\");\n      return;\n    }\n    const key = opKeyInput.value;\n    let value = opValueInput.value;\n    if(key === \"\") { alert(\"Key cannot be empty.\"); return; }\n    if(value === \"\") value = null;\n    try {\n      hashMap.insert(key, value);\n      updateBucketList();\n      updateMapDisplay();\n    } catch(e){\n      alert(\"Error: \" + e.message);\n    }\n  });\n\n  deleteBtn.addEventListener(\"click\", () => {\n    if(!hashMap) {\n      alert(\"Create hash map first.\");\n      return;\n    }\n    const key = opKeyInput.value;\n    if(key === \"\") { alert(\"Key cannot be empty.\"); return; }\n    const success = hashMap.delete(key);\n    if(success) logMessage(`Deleted key \"${key}\"`);\n    else logMessage(`Key \"${key}\" not found to delete`);\n    updateBucketList();\n    updateMapDisplay();\n  });\n\n  searchBtn.addEventListener(\"click\", () => {\n    if(!hashMap) {\n      alert(\"Create hash map first.\");\n      return;\n    }\n    const key = opKeyInput.value;\n    if(key === \"\") { alert(\"Key cannot be empty.\"); return; }\n    const value = hashMap.find(key);\n    if(value === undefined) alert(`Key \"${key}\" not found.`);\n    else alert(`Key \"${key}\" found with value: \"${value}\"`);\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    if(!hashMap) {\n      alert(\"Create hash map first.\");\n      return;\n    }\n    if(confirm(\"Are you sure you want to clear entire map?\")){\n      hashMap.clear();\n      updateBucketList();\n      updateMapDisplay();\n    }\n  });\n\n  bulkInsertBtn.addEventListener(\"click\", () => {\n    if(!hashMap) {\n      alert(\"Create hash map first.\");\n      return;\n    }\n    let arr;\n    try{\n      arr = JSON.parse(bulkInsertText.value);\n      if(!Array.isArray(arr)){\n        alert(\"Input must be a JSON array of [key,value] pairs.\");\n        return;\n      }\n      for(let pair of arr){\n        if(!Array.isArray(pair) || pair.length !== 2){\n          alert(\"Each entry must be an array with exactly two elements: [key, value]\");\n          return;\n        }\n      }\n    }catch(e){\n      alert(\"Invalid JSON input: \" + e.message);\n      return;\n    }\n    for(let [k,v] of arr){\n      try {\n        hashMap.insert(String(k), String(v));\n      } catch(e){\n        alert(\"Insert error: \" + e.message);\n        break;\n      }\n    }\n    updateBucketList();\n    updateMapDisplay();\n    logMessage(`Bulk inserted ${arr.length} entries.`);\n  });\n\n  resizeBtn.addEventListener(\"click\", () => {\n    if(!hashMap) return;\n    const n = parseNumberInput(resizeTableSizeInput.value);\n    if(!Number.isInteger(n) || n < 1 || n > 2048){\n      alert(\"Resize table size must be integer between 1 and 2048\");\n      return;\n    }\n    try {\n      hashMap.resizeManual(n);\n      updateBucketList();\n      updateMapDisplay();\n      updateLoadFactorDisplay();\n    } catch(e) {\n      alert(\"Resize error: \" + e.message);\n    }\n  });\n\n  loadFactorThresholdInput.addEventListener(\"change\", () => {\n    if(!hashMap) return;\n    let v = parseFloat(loadFactorThresholdInput.value);\n    if(v < 0.1) v = 0.1;\n    if(v > 0.95) v = 0.95;\n    hashMap.loadFactorThreshold = v;\n    loadFactorDisplay.textContent = v.toFixed(2);\n  });\n\n  loadFactorSlider.addEventListener(\"input\", () => {\n    if(!hashMap) return;\n    let v = loadFactorSlider.value/100;\n    hashMap.loadFactorThreshold = v;\n    loadFactorThresholdInput.value = v.toFixed(2);\n    loadFactorDisplay.textContent = v.toFixed(2);\n  });\n\n  toggleAutoResizeBtn.addEventListener(\"click\", () => {\n    if(!hashMap) return;\n    toggleAutoResize();\n  });\n\n  stepRehashBtn.addEventListener(\"click\", () => {\n    if(!hashMap) return;\n    stepRehashDemo();\n  });\n\n  clearLogBtn.addEventListener(\"click\", () => {\n    clearLog();\n  });\n\n  // Initialize descriptions and default hash function display\n  updateHashFunctionDescription(hashFunctionChoiceSelect.value);\n\n  // Accessibility notes:\n  // tab order is natural, labels connected with inputs, minimal complexity but full keyboard support\n\n})();\n</script>\n\n</body>\n</html>"
