    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Design Patterns — Visual Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');\n\n  /* Reset & base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1e2a78, #0a1a40);\n    color: #e0e6f3;\n    font-family: 'Montserrat', sans-serif;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 2rem 6rem;\n  }\n\n  /* Heading */\n  header {\n    max-width: 900px;\n    text-align: center;\n    margin-bottom: 3rem;\n  }\n  header h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.6rem;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #f0f5ff;\n    margin-bottom: 0.4rem;\n    text-shadow:\n      0 0 10px rgba(255 255 255 / 0.3),\n      0 0 20px rgba(20 25 120 / 0.8);\n    user-select: none;\n  }\n  header p {\n    font-size: 1.3rem;\n    color: #a3abbf;\n    user-select: none;\n    font-weight: 600;\n    letter-spacing: 0.04em;\n  }\n\n  /* Container & layout */\n  main {\n    max-width: 1000px;\n    width: 100%;\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n    gap: 2.8rem;\n  }\n\n  /* Pattern Card */\n  .pattern-card {\n    background: radial-gradient(circle at top left, #2a3575 0%, #151c3d 85%);\n    border-radius: 1.2rem;\n    box-shadow:\n      0 14px 40px rgba(17, 28, 69, 0.6),\n      inset 0 0 12px rgba(230, 240, 255, 0.03);\n    padding: 2.4rem 2rem 3.6rem;\n    color: #e0eafc;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    overflow: hidden;\n    position: relative;\n    user-select: none;\n    transition:\n      background 0.6s ease,\n      box-shadow 0.6s ease;\n  }\n  .pattern-card::before {\n    content: '';\n    position: absolute;\n    top: -40%;\n    left: -30%;\n    width: 160%;\n    height: 180%;\n    background:\n      radial-gradient(circle at center, #1f296b 7%, transparent 70%);\n    opacity: 0.3;\n    mix-blend-mode: screen;\n    transform: rotate(-45deg);\n    pointer-events: none;\n  }\n  .pattern-card:hover {\n    background: radial-gradient(circle at top left, #31418f, #1c2e66);\n    box-shadow:\n      0 20px 56px rgba(38, 56, 139, 0.8),\n      inset 0 2px 16px rgba(255 255 255 / 0.07);\n  }\n\n  .pattern-title {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 1.9rem;\n    color: #c6d7ff;\n    margin: 0 0 0.3rem 0;\n    letter-spacing: 0.06em;\n    text-shadow: 0 0 6px rgba(190 210 255 / 0.6);\n  }\n\n  .pattern-type {\n    font-weight: 600;\n    font-size: 1.05rem;\n    color: #879dffcc;\n    margin-bottom: 1.4rem;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  .pattern-description {\n    font-weight: 400;\n    font-size: 1.07rem;\n    line-height: 1.55;\n    color: #bbc9f6ee;\n    flex-grow: 1;\n  }\n\n  /* Visual Symbol */\n  .pattern-symbol {\n    margin-top: 2rem;\n    display: block;\n    width: 100%;\n    height: 140px;\n    border-radius: 1rem;\n    background: #121d48;\n    box-shadow:\n      inset 0 0 28px #4f67e9cc,\n      0 12px 30px #3f50b8aa;\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Specific pattern illustrations */\n  /* Using SVG inside for neatness */\n\n  /* For animation: subtle shape movement */\n\n  .pattern-symbol svg {\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n  }\n\n  /* Animations for shapes */\n\n  .shape {\n    transform-origin: center;\n    animation-timing-function: ease-in-out;\n    animation-iteration-count: infinite;\n  }\n  .rotate-slow {\n    animation-name: rotate-slow;\n    animation-duration: 15s;\n  }\n  .pulse {\n    animation-name: pulse;\n    animation-duration: 4.5s;\n  }\n  .move-up-down {\n    animation-name: move-up-down;\n    animation-duration: 6s;\n  }\n\n  @keyframes rotate-slow {\n    0% { transform: rotate(0deg);}\n    50% { transform: rotate(20deg);}\n    100% { transform: rotate(0deg);}\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 0.8; transform: scale(1);}\n    50% { opacity: 1; transform: scale(1.07);}\n  }\n  @keyframes move-up-down {\n    0%,100% { transform: translateY(0);}\n    50% { transform: translateY(-6px);}\n  }\n\n  /* Footer with button */\n  footer {\n    margin-top: 5rem;\n    text-align: center;\n    max-width: 900px;\n    width: 100%;\n  }\n  .btn-toggle {\n    background: transparent;\n    border: 2.4px solid #6276eb;\n    color: #aec4ff;\n    font-weight: 600;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1rem;\n    letter-spacing: 0.12em;\n    padding: 0.9rem 2.6rem;\n    border-radius: 2rem;\n    cursor: pointer;\n    transition:\n      color 0.3s ease,\n      border-color 0.3s ease,\n      background-color 0.4s ease;\n    user-select: none;\n  }\n  .btn-toggle:hover {\n    color: #d3daff;\n    border-color: #8e9eff;\n    background-color: rgba(138,152,251,0.12);\n  }\n  .btn-toggle:active {\n    background-color: #6e86ff55;\n  }\n  /* Subtle fade effect on color theme switching */\n  body.light {\n    background: #f9fbfe;\n    color: #2a343d;\n    transition: background-color 0.7s ease, color 0.7s ease;\n  }\n  body.light header h1 {\n    color: #1e2631;\n    text-shadow: none;\n  }\n  body.light header p {\n    color: #4c5365;\n  }\n  body.light .pattern-card {\n    background: #ffffffcc;\n    color: #2a2a3c;\n    box-shadow:\n      0 10px 30px rgba(34, 48, 63, 0.12);\n  }\n  body.light .pattern-card::before {\n    background: radial-gradient(circle at center, #d2daf7 8%, transparent 62%);\n    opacity: .2;\n  }\n  body.light .pattern-card:hover {\n    background: #f0f4ff;\n    box-shadow:\n      0 14px 48px rgba(97, 117, 200, 0.3);\n  }\n  body.light .pattern-title {\n    color: #3c4a7a;\n    text-shadow: none;\n  }\n  body.light .pattern-type {\n    color: #6f7da3cc;\n  }\n  body.light .pattern-description {\n    color: #5a637fdd;\n  }\n  body.light .pattern-symbol {\n    background: #dbe1ff;\n    box-shadow:\n      inset 0 0 30px #889fd8cc,\n      0 10px 24px #7685ddcc;\n  }\n  body.light .btn-toggle {\n    border-color: #4a5ad6;\n    color: #3c4a7a;\n  }\n  body.light .btn-toggle:hover {\n    color: #192847;\n    border-color: #3462fc;\n    background-color: rgba(75, 90, 214, 0.15);\n  }\n  body.light .btn-toggle:active {\n    background-color: #2b44c6aa;\n  }\n\n  /* Scrollfade intro animation */\n  main {\n    opacity: 0;\n    transform: translateY(15px);\n    animation: fadeSlideUp 1.2s ease forwards;\n    animation-delay: 0.4s;\n  }\n  @keyframes fadeSlideUp {\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  /* Scrollbar styling */\n  ::-webkit-scrollbar {\n    width: 9px;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #6276ebaa;\n    border-radius: 9px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #152249bb;\n  }\n\n</style>\n</head>\n<body>\n<header role=\"banner\" aria-label=\"Page title and description\">\n  <h1>DESIGN PATTERNS</h1>\n  <p>An Elegant Visual Exploration of Object-Oriented Best Practices</p>\n</header>\n<main role=\"main\" aria-label=\"Design patterns overview\">\n\n  <article class=\"pattern-card\" tabindex=\"0\" aria-describedby=\"desc-1\" aria-labelledby=\"title-1\">\n    <h2 class=\"pattern-title\" id=\"title-1\">Singleton</h2>\n    <div class=\"pattern-type\">Creational</div>\n    <p class=\"pattern-description\" id=\"desc-1\">\n      Ensures a class has only one instance and provides a global point of access to it. Ideal for managing shared resources.\n    </p>\n    <div class=\"pattern-symbol\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 200 140\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <circle class=\"shape rotate-slow\" cx=\"100\" cy=\"70\" r=\"50\" stroke=\"#6276eb\" stroke-width=\"6\" fill=\"none\" />\n        <circle class=\"shape pulse\" cx=\"100\" cy=\"70\" r=\"25\" fill=\"#879dff88\" />\n        <rect x=\"98\" y=\"45\" width=\"4\" height=\"50\" fill=\"#a2b3ffcc\" rx=\"2\" ry=\"2\" />\n      </svg>\n    </div>\n  </article>\n\n  <article class=\"pattern-card\" tabindex=\"0\" aria-describedby=\"desc-2\" aria-labelledby=\"title-2\">\n    <h2 class=\"pattern-title\" id=\"title-2\">Observer</h2>\n    <div class=\"pattern-type\">Behavioral</div>\n    <p class=\"pattern-description\" id=\"desc-2\">\n      Defines a dependency between objects so that when one changes state, all dependents are notified and updated automatically.\n    </p>\n    <div class=\"pattern-symbol\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 200 140\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <circle class=\"shape pulse\" cx=\"100\" cy=\"70\" r=\"40\" fill=\"#5f75ff88\" />\n        <circle class=\"shape move-up-down\" cx=\"50\" cy=\"35\" r=\"13\" fill=\"#859affcc\" />\n        <circle class=\"shape move-up-down\" style=\"animation-delay: 1s\" cx=\"150\" cy=\"100\" r=\"15\" fill=\"#7193ffcc\" />\n        <line x1=\"50\" y1=\"35\" x2=\"100\" y2=\"70\" stroke=\"#a2b3ffcc\" stroke-width=\"3\" stroke-linecap=\"round\" />\n        <line x1=\"150\" y1=\"100\" x2=\"100\" y2=\"70\" stroke=\"#a2b3ffcc\" stroke-width=\"3\" stroke-linecap=\"round\" />\n      </svg>\n    </div>\n  </article>\n\n  <article class=\"pattern-card\" tabindex=\"0\" aria-describedby=\"desc-3\" aria-labelledby=\"title-3\">\n    <h2 class=\"pattern-title\" id=\"title-3\">Factory Method</h2>\n    <div class=\"pattern-type\">Creational</div>\n    <p class=\"pattern-description\" id=\"desc-3\">\n      Defines an interface for creating objects, but lets subclasses decide which class to instantiate. Promotes loose coupling.\n    </p>\n    <div class=\"pattern-symbol\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 200 140\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <polygon class=\"shape rotate-slow\" points=\"50,120 100,30 150,120\" stroke=\"#7387ff\" stroke-width=\"5\" fill=\"none\" />\n        <circle class=\"shape pulse\" cx=\"100\" cy=\"75\" r=\"27\" fill=\"#6178ffcc\" />\n        <rect x=\"95\" y=\"70\" width=\"10\" height=\"20\" fill=\"#8aa1ffcc\" rx=\"3\" ry=\"3\" />\n      </svg>\n    </div>\n  </article>\n\n  <article class=\"pattern-card\" tabindex=\"0\" aria-describedby=\"desc-4\" aria-labelledby=\"title-4\">\n    <h2 class=\"pattern-title\" id=\"title-4\">Decorator</h2>\n    <div class=\"pattern-type\">Structural</div>\n    <p class=\"pattern-description\" id=\"desc-4\">\n      Dynamically adds responsibilities to objects without modifying their structure. Allows flexible and reusable code enhancements.\n    </p>\n    <div class=\"pattern-symbol\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 200 140\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <rect class=\"shape move-up-down\" x=\"60\" y=\"40\" width=\"80\" height=\"60\" fill=\"#6275ffcc\" rx=\"14\" ry=\"14\" />\n        <rect class=\"shape pulse\" x=\"40\" y=\"30\" width=\"120\" height=\"80\" stroke=\"#859cff\" stroke-width=\"6\" fill=\"none\" rx=\"18\" ry=\"18\" />\n        <circle cx=\"100\" cy=\"70\" r=\"12\" fill=\"#aac2f9cc\" />\n      </svg>\n    </div>\n  </article>\n\n  <article class=\"pattern-card\" tabindex=\"0\" aria-describedby=\"desc-5\" aria-labelledby=\"title-5\">\n    <h2 class=\"pattern-title\" id=\"title-5\">Strategy</h2>\n    <div class=\"pattern-type\">Behavioral</div>\n    <p class=\"pattern-description\" id=\"desc-5\">\n      Defines a family of algorithms, encapsulates each one, and makes them interchangeable to vary behavior independently.\n    </p>\n    <div class=\"pattern-symbol\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 200 140\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <ellipse class=\"shape rotate-slow\" cx=\"100\" cy=\"70\" rx=\"70\" ry=\"38\" stroke=\"#6587ff\" stroke-width=\"6\" fill=\"none\" />\n        <circle class=\"shape pulse\" cx=\"60\" cy=\"70\" r=\"18\" fill=\"#799cffcc\" />\n        <circle class=\"shape pulse\" style=\"animation-delay: 1.2s\" cx=\"140\" cy=\"70\" r=\"18\" fill=\"#4f6effcc\" />\n        <line x1=\"60\" y1=\"70\" x2=\"140\" y2=\"70\" stroke=\"#aac8ffcc\" stroke-width=\"5\" stroke-linecap=\"round\" />\n      </svg>\n    </div>\n  </article>\n\n</main>\n\n<footer>\n  <button class=\"btn-toggle\" aria-pressed=\"false\" type=\"button\" id=\"themeToggle\" aria-label=\"Toggle light and dark color theme\">Toggle Theme</button>\n</footer>\n\n<script>\n  (() => {\n    const btn = document.getElementById('themeToggle');\n    const body = document.body;\n\n    btn.addEventListener('click', () => {\n      const isLight = body.classList.toggle('light');\n      btn.setAttribute('aria-pressed', isLight);\n    });\n  })();\n</script>\n</body>\n</html>"
