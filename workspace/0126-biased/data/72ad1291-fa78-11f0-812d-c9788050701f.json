    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linguistic Interpreter | Design Pattern</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .container {\n            width: 90%;\n            max-width: 1200px;\n            background: rgba(255, 255, 255, 0.95);\n            border-radius: 20px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);\n            overflow: hidden;\n            position: relative;\n            transform-style: preserve-3d;\n            perspective: 1000px;\n        }\n\n        .header {\n            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);\n            color: white;\n            padding: 2rem;\n            text-align: center;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .header h1 {\n            font-size: 2.5rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            position: relative;\n            z-index: 2;\n            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);\n        }\n\n        .header p {\n            font-size: 1.1rem;\n            opacity: 0.9;\n            max-width: 600px;\n            margin: 0 auto;\n            position: relative;\n            z-index: 2;\n        }\n\n        .header::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);\n            animation: rotate 20s linear infinite;\n            z-index: 1;\n        }\n\n        @keyframes rotate {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        .content {\n            display: flex;\n            padding: 2rem;\n            gap: 2rem;\n        }\n\n        .visualization {\n            flex: 1;\n            min-height: 400px;\n            background: white;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            transition: all 0.3s ease;\n        }\n\n        .visualization:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n        }\n\n        .explanation {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            gap: 1.5rem;\n        }\n\n        .card {\n            background: white;\n            border-radius: 15px;\n            padding: 1.5rem;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n        }\n\n        .card:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);\n        }\n\n        .card h2 {\n            color: var(--primary);\n            margin-bottom: 0.8rem;\n            font-size: 1.3rem;\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .card p {\n            line-height: 1.6;\n            color: #555;\n        }\n\n        .interpreter-display {\n            position: relative;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .language-node {\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            background: var(--primary);\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: bold;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n            position: relative;\n            z-index: 2;\n            transition: all 0.3s ease;\n        }\n\n        .language-node:hover {\n            transform: scale(1.1);\n            box-shadow: 0 8px 25px rgba(108, 92, 231, 0.6);\n        }\n\n        .parse-tree {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            z-index: 1;\n        }\n\n        .branch {\n            position: absolute;\n            background: var(--secondary);\n            transform-origin: top left;\n            opacity: 0.7;\n        }\n\n        .terminal {\n            position: absolute;\n            background: var(--accent);\n            width: 40px;\n            height: 40px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-size: 0.8rem;\n            box-shadow: 0 3px 10px rgba(253, 121, 168, 0.4);\n            transition: all 0.3s ease;\n        }\n\n        .terminal:hover {\n            transform: scale(1.1);\n            box-shadow: 0 5px 20px rgba(253, 121, 168, 0.6);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        .btn {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);\n            color: white;\n            font-weight: 600;\n            cursor: pointer;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n            transition: all 0.3s ease;\n            outline: none;\n        }\n\n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(108, 92, 231, 0.6);\n        }\n\n        .btn:active {\n            transform: translateY(1px);\n        }\n\n        .btn-secondary {\n            background: white;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n            box-shadow: none;\n        }\n\n        .btn-secondary:hover {\n            background: var(--primary);\n            color: white;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n        }\n\n        .result-display {\n            margin-top: 2rem;\n            padding: 1.5rem;\n            background: rgba(108, 92, 231, 0.1);\n            border-radius: 10px;\n            border-left: 4px solid var(--primary);\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 0.5s ease;\n        }\n\n        .result-display.show {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .result-display p {\n            font-size: 1.1rem;\n            color: var(--dark);\n        }\n\n        .result-display .output {\n            font-weight: bold;\n            color: var(--primary);\n            margin-top: 0.5rem;\n            font-size: 1.3rem;\n        }\n\n        .floating-shapes {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            overflow: hidden;\n            z-index: 0;\n        }\n\n        .shape {\n            position: absolute;\n            border-radius: 50%;\n            opacity: 0.1;\n            filter: blur(30px);\n        }\n\n        .shape-1 {\n            width: 300px;\n            height: 300px;\n            background: var(--primary);\n            top: -100px;\n            right: -100px;\n        }\n\n        .shape-2 {\n            width: 200px;\n            height: 200px;\n            background: var(--accent);\n            bottom: -50px;\n            left: -50px;\n        }\n\n        footer {\n            text-align: center;\n            padding: 1.5rem;\n            background: rgba(0, 0, 0, 0.02);\n            color: #666;\n            font-size: 0.9rem;\n        }\n\n        @media (max-width: 900px) {\n            .content {\n                flex-direction: column;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"floating-shapes\">\n            <div class=\"shape shape-1\"></div>\n            <div class=\"shape shape-2\"></div>\n        </div>\n        \n        <div class=\"header\">\n            <h1>Linguistic Interpreter Pattern</h1>\n            <p>A beautiful visualization of how language expressions are parsed and interpreted</p>\n        </div>\n        \n        <div class=\"content\">\n            <div class=\"visualization\">\n                <div class=\"interpreter-display\">\n                    <div class=\"parse-tree\" id=\"parseTree\"></div>\n                    <div class=\"language-node\" id=\"rootNode\">EXP</div>\n                    <div class=\"result-display\" id=\"resultDisplay\">\n                        <p>Interpreted Result:</p>\n                        <div class=\"output\" id=\"outputText\">\"Hello World\" in Spanish</div>\n                    </div>\n                </div>\n                \n                <div class=\"controls\">\n                    <button class=\"btn\" id=\"interpretBtn\">Interpret Expression</button>\n                    <button class=\"btn btn-secondary\" id=\"resetBtn\">Reset</button>\n                </div>\n            </div>\n            \n            <div class=\"explanation\">\n                <div class=\"card\">\n                    <h2>✨ The Interpreter Pattern</h2>\n                    <p>The interpreter pattern defines a representation for a language grammar along with an interpreter that uses the representation to interpret sentences in the language.</p>\n                </div>\n                \n                <div class=\"card\">\n                    <h2>🌐 How It Works</h2>\n                    <p>1. Define a grammar for the language<br>\n                       2. Represent grammar rules as class hierarchies<br>\n                       3. Parse input expressions into syntax trees<br>\n                       4. Interpret the tree by walking through nodes</p>\n                </div>\n                \n                <div class=\"card\">\n                    <h2>🎨 This Visualization</h2>\n                    <p>This demonstrates a simple language interpreter that translates between English and Spanish. The parse tree shows how the expression is broken down and interpreted through the pattern's structure.</p>\n                </div>\n            </div>\n        </div>\n        \n        <footer>\n            <p>Design Pattern Visualization | Created with HTML, CSS & JavaScript</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const interpretBtn = document.getElementById('interpretBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const parseTree = document.getElementById('parseTree');\n            const rootNode = document.getElementById('rootNode');\n            const resultDisplay = document.getElementById('resultDisplay');\n            const outputText = document.getElementById('outputText');\n            \n            // Sample expressions and translations\n            const expressions = [\n                { input: \"Hello World\", output: \"Hola Mundo\" },\n                { input: \"Good morning\", output: \"Buenos días\" },\n                { input: \"How are you?\", output: \"¿Cómo estás?\" },\n                { input: \"Thank you\", output: \"Gracias\" },\n                { input: \"Goodbye\", output: \"Adiós\" }\n            ];\n            \n            let currentExpression = 0;\n            \n            // Create parse tree visualization\n            function createParseTree() {\n                parseTree.innerHTML = '';\n                \n                // Create branches\n                const branch1 = document.createElement('div');\n                branch1.className = 'branch';\n                branch1.style.width = '100px';\n                branch1.style.height = '4px';\n                branch1.style.left = 'calc(50% - 50px)';\n                branch1.style.top = '60px';\n                branch1.style.transform = 'rotate(-30deg)';\n                \n                const branch2 = document.createElement('div');\n                branch2.className = 'branch';\n                branch2.style.width = '100px';\n                branch2.style.height = '4px';\n                branch2.style.left = 'calc(50% - 50px)';\n                branch2.style.top = '60px';\n                branch2.style.transform = 'rotate(30deg)';\n                \n                parseTree.appendChild(branch1);\n                parseTree.appendChild(branch2);\n                \n                // Create terminal nodes\n                const terminal1 = document.createElement('div');\n                terminal1.className = 'terminal';\n                terminal1.textContent = 'ENG';\n                terminal1.style.left = 'calc(50% - 130px)';\n                terminal1.style.top = '140px';\n                \n                const terminal2 = document.createElement('div');\n                terminal2.className = 'terminal';\n                terminal2.textContent = 'ESP';\n                terminal2.style.left = 'calc(50% + 70px)';\n                terminal2.style.top = '140px';\n                \n                parseTree.appendChild(terminal1);\n                parseTree.appendChild(terminal2);\n                \n                // Animate the tree\n                setTimeout(() => {\n                    branch1.style.width = '100px';\n                    branch2.style.width = '100px';\n                }, 100);\n            }\n            \n            // Interpret the expression\n            function interpretExpression() {\n                // Show processing animation\n                rootNode.textContent = '...';\n                rootNode.style.backgroundColor = '#fdcb6e';\n                \n                setTimeout(() => {\n                    // Update with current expression\n                    const expr = expressions[currentExpression];\n                    outputText.textContent = `\"${expr.input}\" → \"${expr.output}\"`;\n                    \n                    // Reset node appearance\n                    rootNode.textContent = 'EXP';\n                    rootNode.style.backgroundColor = 'var(--primary)';\n                    \n                    // Show result\n                    resultDisplay.classList.add('show');\n                    \n                    // Move to next expression\n                    currentExpression = (currentExpression + 1) % expressions.length;\n                }, 1000);\n            }\n            \n            // Reset the visualization\n            function resetVisualization() {\n                rootNode.textContent = 'EXP';\n                rootNode.style.backgroundColor = 'var(--primary)';\n                resultDisplay.classList.remove('show');\n            }\n            \n            // Initialize\n            createParseTree();\n            \n            // Event listeners\n            interpretBtn.addEventListener('click', interpretExpression);\n            resetBtn.addEventListener('click', resetVisualization);\n            \n            // Animate the root node on hover\n            rootNode.addEventListener('mouseenter', function() {\n                this.style.transform = 'scale(1.1) rotate(5deg)';\n            });\n            \n            rootNode.addEventListener('mouseleave', function() {\n                this.style.transform = 'scale(1) rotate(0deg)';\n            });\n        });\n    </script>\n</body>\n</html>"
