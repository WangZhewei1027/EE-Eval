    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Nearest Neighbors | Visual Elegance</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Montserrat', 'Helvetica Neue', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);\n            color: #2c3e50;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            overflow-x: hidden;\n        }\n\n        header {\n            background: rgba(255, 255, 255, 0.9);\n            backdrop-filter: blur(10px);\n            padding: 2rem;\n            text-align: center;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);\n            z-index: 100;\n        }\n\n        h1 {\n            font-weight: 300;\n            font-size: 2.5rem;\n            letter-spacing: 1px;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(135deg, #3498db, #9b59b6);\n            -webkit-background-clip: text;\n            background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .subtitle {\n            font-weight: 300;\n            color: #7f8c8d;\n            font-size: 1.1rem;\n        }\n\n        .container {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            position: relative;\n        }\n\n        .visualization {\n            width: 600px;\n            height: 600px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            position: relative;\n            overflow: hidden;\n            margin: 2rem 0;\n        }\n\n        .point {\n            position: absolute;\n            width: 16px;\n            height: 16px;\n            border-radius: 50%;\n            transform: translate(-50%, -50%);\n            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n            z-index: 10;\n        }\n\n        .point.class1 {\n            background: #3498db;\n        }\n\n        .point.class2 {\n            background: #e74c3c;\n        }\n\n        .point.new {\n            background: #2ecc71;\n            width: 20px;\n            height: 20px;\n            box-shadow: 0 0 0 8px rgba(46, 204, 113, 0.2);\n            animation: pulse 2s infinite;\n        }\n\n        .point.neighbor {\n            transform: translate(-50%, -50%) scale(1.3);\n            box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.8);\n        }\n\n        .connection {\n            position: absolute;\n            background: rgba(149, 165, 166, 0.3);\n            height: 2px;\n            transform-origin: 0 0;\n            z-index: 5;\n            transition: all 0.5s ease-out;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n\n        button {\n            background: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 500;\n            color: #3498db;\n            cursor: pointer;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 5px;\n            height: 5px;\n            background: rgba(255, 255, 255, 0.5);\n            opacity: 0;\n            border-radius: 100%;\n            transform: scale(1, 1) translate(-50%, -50%);\n            transform-origin: 50% 50%;\n        }\n\n        button:focus:not(:active)::after {\n            animation: ripple 0.6s ease-out;\n        }\n\n        .legend {\n            display: flex;\n            gap: 2rem;\n            margin-top: 1rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n        }\n\n        .legend-color.class1 {\n            background: #3498db;\n        }\n\n        .legend-color.class2 {\n            background: #e74c3c;\n        }\n\n        .legend-color.new {\n            background: #2ecc71;\n        }\n\n        .info-panel {\n            position: absolute;\n            top: 2rem;\n            right: 2rem;\n            background: white;\n            padding: 1.5rem;\n            border-radius: 12px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n            max-width: 300px;\n            opacity: 0;\n            transform: translateY(10px);\n            transition: all 0.4s ease;\n        }\n\n        .info-panel.visible {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .info-panel h3 {\n            font-weight: 500;\n            margin-bottom: 0.5rem;\n            color: #3498db;\n        }\n\n        .info-panel p {\n            font-size: 0.9rem;\n            color: #7f8c8d;\n            line-height: 1.5;\n        }\n\n        @keyframes pulse {\n            0% {\n                box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.4);\n            }\n            70% {\n                box-shadow: 0 0 0 12px rgba(46, 204, 113, 0);\n            }\n            100% {\n                box-shadow: 0 0 0 0 rgba(46, 204, 113, 0);\n            }\n        }\n\n        @keyframes ripple {\n            0% {\n                transform: scale(0, 0);\n                opacity: 0.5;\n            }\n            100% {\n                transform: scale(20, 20);\n                opacity: 0;\n            }\n        }\n\n        .bg-elements {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .bg-circle {\n            position: absolute;\n            border-radius: 50%;\n            background: linear-gradient(135deg, rgba(52, 152, 219, 0.05) 0%, rgba(155, 89, 182, 0.05) 100%);\n        }\n\n        footer {\n            text-align: center;\n            padding: 1.5rem;\n            color: #7f8c8d;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>K-Nearest Neighbors</h1>\n        <div class=\"subtitle\">A visual exploration of the KNN algorithm</div>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"bg-elements\" id=\"bgElements\"></div>\n\n        <div class=\"controls\">\n            <button id=\"newPointBtn\">Add Random Point</button>\n            <button id=\"infoBtn\">About KNN</button>\n        </div>\n\n        <div class=\"visualization\" id=\"visualization\">\n            <!-- Points will be added here -->\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color class1\"></div>\n                <span>Class 1</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color class2\"></div>\n                <span>Class 2</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color new\"></div>\n                <span>New Point</span>\n            </div>\n        </div>\n\n        <div class=\"info-panel\" id=\"infoPanel\">\n            <h3>K-Nearest Neighbors</h3>\n            <p>The KNN algorithm is a simple, intuitive machine learning method that classifies new data points based on the majority class among their K closest neighbors in the feature space.</p>\n            <p>In this visualization, blue and red points represent two different classes. When you add a new green point, the algorithm finds its 3 nearest neighbors (connected by lines) and classifies it based on their majority.</p>\n        </div>\n    </div>\n\n    <footer>\n        Visual demonstration of the KNN algorithm | Designed for aesthetic appreciation\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Background elements\n            const bgElements = document.getElementById('bgElements');\n            for (let i = 0; i < 10; i++) {\n                const circle = document.createElement('div');\n                circle.classList.add('bg-circle');\n                const size = Math.random() * 300 + 100;\n                circle.style.width = `${size}px`;\n                circle.style.height = `${size}px`;\n                circle.style.left = `${Math.random() * 100}%`;\n                circle.style.top = `${Math.random() * 100}%`;\n                circle.style.opacity = 0.3;\n                bgElements.appendChild(circle);\n            }\n\n            // Visualization setup\n            const visualization = document.getElementById('visualization');\n            const width = visualization.offsetWidth;\n            const height = visualization.offsetHeight;\n            \n            // Create initial points\n            const points = [];\n            const pointCount = 30;\n            const k = 3; // Number of neighbors to consider\n            \n            for (let i = 0; i < pointCount; i++) {\n                const point = document.createElement('div');\n                point.classList.add('point');\n                point.classList.add(Math.random() > 0.5 ? 'class1' : 'class2');\n                \n                const x = Math.random() * (width - 40) + 20;\n                const y = Math.random() * (height - 40) + 20;\n                \n                point.style.left = `${x}px`;\n                point.style.top = `${y}px`;\n                \n                visualization.appendChild(point);\n                points.push({\n                    element: point,\n                    x: x,\n                    y: y,\n                    className: point.classList.contains('class1') ? 'class1' : 'class2'\n                });\n            }\n            \n            // Add new point button\n            const newPointBtn = document.getElementById('newPointBtn');\n            newPointBtn.addEventListener('click', addNewPoint);\n            \n            // Info panel toggle\n            const infoBtn = document.getElementById('infoBtn');\n            const infoPanel = document.getElementById('infoPanel');\n            infoBtn.addEventListener('click', function() {\n                infoPanel.classList.toggle('visible');\n            });\n            \n            function addNewPoint() {\n                // Remove any existing new points and connections\n                const existingNewPoints = document.querySelectorAll('.point.new');\n                const existingConnections = document.querySelectorAll('.connection');\n                \n                existingNewPoints.forEach(point => point.remove());\n                existingConnections.forEach(conn => conn.remove());\n                \n                // Create new point\n                const newPoint = document.createElement('div');\n                newPoint.classList.add('point', 'new');\n                \n                const x = Math.random() * (width - 40) + 20;\n                const y = Math.random() * (height - 40) + 20;\n                \n                newPoint.style.left = `${x}px`;\n                newPoint.style.top = `${y}px`;\n                \n                visualization.appendChild(newPoint);\n                \n                // Find k nearest neighbors\n                const neighbors = findNearestNeighbors({x, y}, k);\n                \n                // Draw connections to neighbors\n                neighbors.forEach(neighbor => {\n                    const connection = document.createElement('div');\n                    connection.classList.add('connection');\n                    \n                    const dx = neighbor.x - x;\n                    const dy = neighbor.y - y;\n                    const length = Math.sqrt(dx * dx + dy * dy);\n                    const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n                    \n                    connection.style.width = `${length}px`;\n                    connection.style.left = `${x}px`;\n                    connection.style.top = `${y}px`;\n                    connection.style.transform = `rotate(${angle}deg)`;\n                    \n                    visualization.insertBefore(connection, visualization.firstChild);\n                    \n                    // Highlight neighbors\n                    neighbor.element.classList.add('neighbor');\n                });\n                \n                // Classify the new point based on neighbors\n                setTimeout(() => {\n                    const classCounts = { class1: 0, class2: 0 };\n                    neighbors.forEach(n => classCounts[n.className]++);\n                    \n                    const predictedClass = classCounts.class1 > classCounts.class2 ? 'class1' : 'class2';\n                    newPoint.style.background = predictedClass === 'class1' ? '#3498db' : '#e74c3c';\n                }, 1000);\n            }\n            \n            function findNearestNeighbors(point, k) {\n                // Calculate distances to all points\n                points.forEach(p => {\n                    const dx = p.x - point.x;\n                    const dy = p.y - point.y;\n                    p.distance = Math.sqrt(dx * dx + dy * dy);\n                });\n                \n                // Sort by distance and take first k\n                const sorted = [...points].sort((a, b) => a.distance - b.distance);\n                return sorted.slice(0, k);\n            }\n        });\n    </script>\n</body>\n</html>"
