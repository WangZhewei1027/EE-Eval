    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive SDLC Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .phase { border: 1px solid #000; padding: 10px; margin: 10px 0; }\n        .hidden { display: none; }\n        button, select, input { margin: 5px; }\n        .artifact { border-left: 2px solid #000; padding-left: 10px; margin: 5px 0; }\n        #workflow { height: 300px; overflow-y: scroll; border: 1px solid #000; padding: 10px; }\n    </style>\n</head>\n<body>\n    <h1>Software Development Life Cycle Interactive Explorer</h1>\n    \n    <div>\n        <h2>Select Methodology:</h2>\n        <select id=\"methodology\">\n            <option value=\"waterfall\">Waterfall</option>\n            <option value=\"agile\">Agile</option>\n            <option value=\"spiral\">Spiral</option>\n            <option value=\"vmodel\">V-Model</option>\n        </select>\n        <button onclick=\"initSDLC()\">Initialize SDLC</button>\n    </div>\n    \n    <div id=\"sdlcContainer\" class=\"hidden\">\n        <h2>Current Phase: <span id=\"currentPhase\"></span></h2>\n        <div id=\"phaseControls\">\n            <button onclick=\"previousPhase()\">Previous Phase</button>\n            <button onclick=\"nextPhase()\">Next Phase</button>\n            <button onclick=\"showAllPhases()\">Show All Phases</button>\n            <button onclick=\"customizePhase()\">Customize Current Phase</button>\n        </div>\n        \n        <div id=\"phases\"></div>\n        \n        <div>\n            <h3>Workflow Simulation</h3>\n            <div id=\"workflow\"></div>\n            <button onclick=\"simulateWork()\">Simulate Work</button>\n            <button onclick=\"introduceBug()\">Introduce Bug</button>\n            <button onclick=\"resolveBug()\">Resolve Bug</button>\n            <input type=\"range\" id=\"teamSize\" min=\"1\" max=\"10\" value=\"3\" onchange=\"updateTeamSize()\">\n            <span>Team Size: <span id=\"teamSizeValue\">3</span></span>\n        </div>\n        \n        <div>\n            <h3>Artifact Generator</h3>\n            <select id=\"artifactType\">\n                <option value=\"document\">Document</option>\n                <option value=\"diagram\">Diagram</option>\n                <option value=\"code\">Code</option>\n                <option value=\"test\">Test Case</option>\n            </select>\n            <button onclick=\"generateArtifact()\">Generate Artifact</button>\n            <div id=\"artifacts\"></div>\n        </div>\n        \n        <div>\n            <h3>Metrics Dashboard</h3>\n            <div>\n                Progress: <progress id=\"progress\" value=\"0\" max=\"100\"></progress> <span id=\"progressValue\">0%</span>\n            </div>\n            <div>\n                Bugs Found: <span id=\"bugCount\">0</span>\n            </div>\n            <div>\n                Artifacts Created: <span id=\"artifactCount\">0</span>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        const methodologies = {\n            waterfall: ['Requirements', 'Design', 'Implementation', 'Verification', 'Maintenance'],\n            agile: ['Sprint Planning', 'Development', 'Testing', 'Review', 'Retrospective'],\n            spiral: ['Planning', 'Risk Analysis', 'Engineering', 'Evaluation'],\n            vmodel: ['Requirements', 'HL Design', 'LL Design', 'Unit Testing', 'Integration Testing', 'System Testing', 'Acceptance Testing']\n        };\n        \n        let currentMethodology = 'waterfall';\n        let currentPhaseIndex = 0;\n        let bugs = 0;\n        let artifacts = 0;\n        let progress = 0;\n        let teamSize = 3;\n        let phaseCustomizations = {};\n        \n        function initSDLC() {\n            currentMethodology = document.getElementById('methodology').value;\n            currentPhaseIndex = 0;\n            bugs = 0;\n            artifacts = 0;\n            progress = 0;\n            updateMetrics();\n            \n            document.getElementById('sdlcContainer').classList.remove('hidden');\n            renderPhases();\n            updateCurrentPhase();\n            logWorkflow(`Initialized ${currentMethodology} SDLC`);\n        }\n        \n        function renderPhases() {\n            const phasesContainer = document.getElementById('phases');\n            phasesContainer.innerHTML = '';\n            \n            methodologies[currentMethodology].forEach((phase, index) => {\n                const phaseDiv = document.createElement('div');\n                phaseDiv.className = 'phase hidden';\n                phaseDiv.id = `phase-${index}`;\n                \n                const phaseTitle = document.createElement('h3');\n                phaseTitle.textContent = phase;\n                phaseDiv.appendChild(phaseTitle);\n                \n                const phaseDesc = document.createElement('p');\n                phaseDesc.textContent = getPhaseDescription(phase);\n                phaseDiv.appendChild(phaseDesc);\n                \n                const phaseTasks = document.createElement('div');\n                phaseTasks.innerHTML = `<p>Tasks: ${getPhaseTasks(phase)}</p>`;\n                phaseDiv.appendChild(phaseTasks);\n                \n                if (phaseCustomizations[phase]) {\n                    const customNote = document.createElement('p');\n                    customNote.textContent = `Custom: ${phaseCustomizations[phase]}`;\n                    phaseDiv.appendChild(customNote);\n                }\n                \n                phasesContainer.appendChild(phaseDiv);\n            });\n        }\n        \n        function getPhaseDescription(phase) {\n            const descriptions = {\n                'Requirements': 'Gather and document system requirements from stakeholders.',\n                'Design': 'Create architectural and detailed design specifications.',\n                'Implementation': 'Write code according to design specifications.',\n                'Verification': 'Test the system against requirements.',\n                'Maintenance': 'Fix issues and implement changes post-deployment.',\n                'Sprint Planning': 'Plan work for the upcoming sprint with user stories.',\n                'Development': 'Implement user stories and features.',\n                'Testing': 'Verify functionality through automated and manual tests.',\n                'Review': 'Demonstrate completed work to stakeholders.',\n                'Retrospective': 'Reflect on the sprint and identify improvements.',\n                'Planning': 'Define objectives, alternatives, and constraints.',\n                'Risk Analysis': 'Identify and resolve potential risks.',\n                'Engineering': 'Develop and test the product.',\n                'Evaluation': 'Assess results and plan next iteration.',\n                'HL Design': 'Create high-level system architecture.',\n                'LL Design': 'Create detailed component designs.',\n                'Unit Testing': 'Test individual components.',\n                'Integration Testing': 'Test component interactions.',\n                'System Testing': 'Test the complete system.',\n                'Acceptance Testing': 'Validate system with end users.'\n            };\n            return descriptions[phase] || 'Phase description not available.';\n        }\n        \n        function getPhaseTasks(phase) {\n            const tasks = {\n                'Requirements': 'Interviews, Use Cases, SRS',\n                'Design': 'Architecture Diagrams, Database Schema',\n                'Implementation': 'Coding, Code Reviews',\n                'Verification': 'Test Cases, Bug Reports',\n                'Maintenance': 'Patches, Updates',\n                'Sprint Planning': 'Backlog Grooming, Story Points',\n                'Development': 'Pair Programming, CI/CD',\n                'Testing': 'Unit Tests, Regression Tests',\n                'Review': 'Demo, Feedback Collection',\n                'Retrospective': 'Action Items, Process Improvements',\n                'Planning': 'Feasibility Study, Cost Estimation',\n                'Risk Analysis': 'Risk Matrix, Mitigation Plans',\n                'Engineering': 'Prototyping, Coding',\n                'Evaluation': 'Customer Feedback, Metrics Analysis',\n                'HL Design': 'System Architecture, Interfaces',\n                'LL Design': 'Class Diagrams, Algorithm Design',\n                'Unit Testing': 'White-box Testing, Code Coverage',\n                'Integration Testing': 'API Testing, Interface Testing',\n                'System Testing': 'End-to-end Testing, Performance Testing',\n                'Acceptance Testing': 'UAT, Sign-off'\n            };\n            return tasks[phase] || 'Various development tasks';\n        }\n        \n        function updateCurrentPhase() {\n            const phases = methodologies[currentMethodology];\n            document.getElementById('currentPhase').textContent = phases[currentPhaseIndex];\n            \n            // Hide all phases\n            document.querySelectorAll('.phase').forEach(el => {\n                el.classList.add('hidden');\n            });\n            \n            // Show current phase\n            document.getElementById(`phase-${currentPhaseIndex}`).classList.remove('hidden');\n            \n            updateProgress();\n        }\n        \n        function nextPhase() {\n            const phases = methodologies[currentMethodology];\n            if (currentPhaseIndex < phases.length - 1) {\n                currentPhaseIndex++;\n                updateCurrentPhase();\n                logWorkflow(`Moved to ${phases[currentPhaseIndex]} phase`);\n            } else {\n                logWorkflow('Project completed!');\n            }\n        }\n        \n        function previousPhase() {\n            if (currentPhaseIndex > 0) {\n                currentPhaseIndex--;\n                updateCurrentPhase();\n                logWorkflow(`Returned to ${methodologies[currentMethodology][currentPhaseIndex]} phase`);\n            }\n        }\n        \n        function showAllPhases() {\n            document.querySelectorAll('.phase').forEach(el => {\n                el.classList.remove('hidden');\n            });\n            logWorkflow('Showing all phases simultaneously');\n        }\n        \n        function customizePhase() {\n            const currentPhase = methodologies[currentMethodology][currentPhaseIndex];\n            const customization = prompt(`Customize ${currentPhase} phase:`);\n            if (customization) {\n                phaseCustomizations[currentPhase] = customization;\n                renderPhases();\n                updateCurrentPhase();\n                logWorkflow(`Customized ${currentPhase}: ${customization}`);\n            }\n        }\n        \n        function simulateWork() {\n            const currentPhase = methodologies[currentMethodology][currentPhaseIndex];\n            const workItems = [\n                `Working on ${getRandomTask(currentPhase)}`,\n                `Reviewing ${getRandomArtifact(currentPhase)}`,\n                `Collaborating with team on ${currentPhase}`,\n                `Documenting ${currentPhase} progress`,\n                `Refining ${currentPhase} deliverables`\n            ];\n            \n            const work = workItems[Math.floor(Math.random() * workItems.length)];\n            logWorkflow(work);\n            \n            // Increase progress based on team size\n            progress += (5 * teamSize);\n            if (progress > 100) progress = 100;\n            updateMetrics();\n        }\n        \n        function getRandomTask(phase) {\n            const tasks = getPhaseTasks(phase).split(', ');\n            return tasks[Math.floor(Math.random() * tasks.length)] || 'task';\n        }\n        \n        function getRandomArtifact(phase) {\n            const artifacts = {\n                'Requirements': ['SRS', 'Use Cases', 'User Stories'],\n                'Design': ['Architecture Diagram', 'Database Schema', 'UI Mockups'],\n                'Implementation': ['Source Code', 'API Documentation', 'Build Scripts'],\n                'Verification': ['Test Cases', 'Bug Reports', 'Test Plans'],\n                'Maintenance': ['Patch Notes', 'Change Requests', 'Hotfixes'],\n                'Sprint Planning': ['Backlog', 'Sprint Goals', 'Task Board'],\n                'Development': ['Feature Branch', 'Pull Request', 'CI Pipeline'],\n                'Testing': ['Automated Tests', 'Test Results', 'Bug Tickets'],\n                'Review': ['Demo', 'Feedback Notes', 'Acceptance Criteria'],\n                'Retrospective': ['Action Items', 'Process Improvements', 'Team Feedback'],\n                'Planning': ['Project Charter', 'Feasibility Study', 'Cost Estimate'],\n                'Risk Analysis': ['Risk Matrix', 'Mitigation Plan', 'Contingency Plan'],\n                'Engineering': ['Prototype', 'Technical Spec', 'Code Review'],\n                'Evaluation': ['Customer Feedback', 'Metrics Report', 'Lessons Learned'],\n                'HL Design': ['System Architecture', 'Component Diagram', 'Interface Spec'],\n                'LL Design': ['Class Diagram', 'Algorithm Spec', 'Database Design'],\n                'Unit Testing': ['Unit Tests', 'Code Coverage', 'Test Stubs'],\n                'Integration Testing': ['Integration Tests', 'API Contracts', 'Interface Tests'],\n                'System Testing': ['E2E Tests', 'Performance Tests', 'Security Tests'],\n                'Acceptance Testing': ['UAT Plan', 'Sign-off Document', 'User Manual']\n            };\n            \n            const phaseArtifacts = artifacts[phase] || ['artifact'];\n            return phaseArtifacts[Math.floor(Math.random() * phaseArtifacts.length)];\n        }\n        \n        function introduceBug() {\n            bugs++;\n            updateMetrics();\n            logWorkflow(`Bug introduced! Total bugs: ${bugs}`);\n        }\n        \n        function resolveBug() {\n            if (bugs > 0) {\n                bugs--;\n                updateMetrics();\n                logWorkflow(`Bug resolved! Remaining bugs: ${bugs}`);\n            }\n        }\n        \n        function updateTeamSize() {\n            teamSize = parseInt(document.getElementById('teamSize').value);\n            document.getElementById('teamSizeValue').textContent = teamSize;\n            logWorkflow(`Team size changed to ${teamSize}`);\n        }\n        \n        function generateArtifact() {\n            const type = document.getElementById('artifactType').value;\n            const currentPhase = methodologies[currentMethodology][currentPhaseIndex];\n            let artifact = '';\n            \n            switch(type) {\n                case 'document':\n                    artifact = `${currentPhase} Document v${Math.floor(Math.random() * 5) + 1}.0`;\n                    break;\n                case 'diagram':\n                    artifact = `${currentPhaseTasks(currentPhase).split(', ')[0]} Diagram`;\n                    break;\n                case 'code':\n                    artifact = `${currentPhase.replace(/ /g, '')}Module.java`;\n                    break;\n                case 'test':\n                    artifact = `Test Case for ${getRandomTask(currentPhase)}`;\n                    break;\n            }\n            \n            artifacts++;\n            updateMetrics();\n            \n            const artifactDiv = document.createElement('div');\n            artifactDiv.className = 'artifact';\n            artifactDiv.textContent = artifact;\n            document.getElementById('artifacts').appendChild(artifactDiv);\n            \n            logWorkflow(`Created artifact: ${artifact}`);\n        }\n        \n        function updateMetrics() {\n            document.getElementById('bugCount').textContent = bugs;\n            document.getElementById('artifactCount').textContent = artifacts;\n            \n            document.getElementById('progress').value = progress;\n            document.getElementById('progressValue').textContent = `${progress}%`;\n        }\n        \n        function updateProgress() {\n            const phaseCount = methodologies[currentMethodology].length;\n            progress = Math.floor((currentPhaseIndex / phaseCount) * 100);\n            updateMetrics();\n        }\n        \n        function logWorkflow(message) {\n            const workflow = document.getElementById('workflow');\n            const entry = document.createElement('div');\n            entry.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;\n            workflow.appendChild(entry);\n            workflow.scrollTop = workflow.scrollHeight;\n        }\n    </script>\n</body>\n</html>"
  },
