    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>ACID Properties — Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display&family=Poppins:wght@300;600&display=swap');\n\n  /* Root and base styles */\n  :root {\n    --color-bg: #0f1123;\n    --color-primary: #7f5af0;\n    --color-primary-alt: #a78bfa;\n    --color-accent: #f0f0f7;\n    --color-accent-alt: #e0dfff;\n    --color-shadow: rgba(127, 90, 240, 0.5);\n    --color-surface: #1a1f44;\n    --transition: 0.8s cubic-bezier(0.77,0,0.175,1);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: var(--color-bg);\n    color: var(--color-accent);\n    font-family: 'Poppins', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 3rem 2rem 6rem;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.8rem;\n    margin-bottom: 0.4rem;\n    letter-spacing: 0.05em;\n    background: linear-gradient(135deg, #7f5af0, #a78bfa);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n  h2 {\n    font-weight: 600;\n    font-size: 1.3rem;\n    letter-spacing: 0.15em;\n    color: #b2aefa88;\n    text-transform: uppercase;\n    margin-bottom: 5rem;\n    font-family: monospace;\n  }\n\n  /* Container for the properties and diagram */\n  .container {\n    max-width: 980px;\n    width: 100%;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 4rem;\n  }\n\n  /* ACID properties list */\n  .acid-list {\n    color: var(--color-accent-alt);\n    display: flex;\n    flex-direction: column;\n    gap: 3.5rem;\n    font-size: 1.32rem;\n    font-weight: 300;\n    line-height: 1.6;\n  }\n  .acid-item {\n    position: relative;\n    padding-left: 4.4rem;\n    cursor: default;\n    transition: color var(--transition);\n    user-select: none;\n  }\n  .acid-item::before {\n    content: attr(data-letter);\n    position: absolute;\n    left: 0;\n    top: 50%;\n    transform: translateY(-50%);\n    font-weight: 700;\n    font-size: 3.5rem;\n    color: var(--color-primary);\n    font-family: 'Playfair Display', serif;\n    user-select: none;\n    filter: drop-shadow(0 0 3px var(--color-shadow));\n    transition: color var(--transition);\n  }\n  .acid-item strong {\n    color: var(--color-primary-alt);\n    font-weight: 600;\n  }\n  .acid-item p {\n    margin-top: 0.35rem;\n    color: #d8d8eecc;\n    max-width: 420px;\n  }\n\n  /* Diagram container */\n  .diagram {\n    perspective: 1500px;\n    position: relative;\n    width: 420px;\n    height: 420px;\n    user-select: none;\n  }\n\n  /* Circular \"molecule\" ring with nodes */\n  .molecule {\n    width: 100%;\n    height: 100%;\n    position: relative;\n    transform-style: preserve-3d;\n    animation: flow-rotate 30s linear infinite;\n  }\n\n  @keyframes flow-rotate {\n    from { transform: rotateY(0deg) rotateX(15deg) translateZ(0); }\n    to { transform: rotateY(360deg) rotateX(15deg) translateZ(0); }\n  }\n\n  /* Central nucleus circle */\n  .nucleus {\n    position: absolute;\n    top: 50%; left: 50%;\n    width: 140px; height: 140px;\n    background: linear-gradient(135deg, #7f5af0cc, #a78bfacc);\n    border-radius: 50%;\n    box-shadow:\n      0 0 30px 10px var(--color-primary-alt),\n      inset 0 0 20px 3px #d6cfffcc;\n    transform: translate(-50%, -50%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Playfair Display', serif;\n    font-size: 2.4rem;\n    font-weight: 700;\n    color: #fff;\n    text-shadow: 0 0 4px #d2c8ff;\n    user-select: none;\n  }\n  .nucleus small {\n    font-size: 1rem;\n    position: absolute;\n    bottom: 12px;\n    right: 14px;\n    color: #d0c9ffbb;\n    font-weight: 400;\n    font-family: 'Poppins', sans-serif;\n    user-select: none;\n  }\n\n  /* Nodes ring */\n  .node {\n    position: absolute;\n    width: 110px;\n    height: 110px;\n    border-radius: 50%;\n    background: linear-gradient(145deg, #1a1f44, #222850);\n    box-shadow:\n      0 0 15px 2px #5c4fcf88,\n      inset 0 0 10px 1px #746cf1,\n      inset 0 0 20px 3px #7f5af0cc;\n    color: var(--color-primary-alt);\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    padding: 1rem 1.3rem 1.2rem;\n    cursor: default;\n    user-select: none;\n    backdrop-filter: saturate(180%) blur(10px);\n    transition: box-shadow 0.6s ease;\n    box-sizing: border-box;\n  }\n  .node strong {\n    font-size: 2.5rem;\n    line-height: 1.1;\n    color: #c5b8ffcc;\n    text-shadow: 0 0 2px #5c4fcfaa;\n  }\n  .node span {\n    margin-top: 0.3rem;\n    font-weight: 600;\n    font-size: 1.08rem;\n    letter-spacing: 0.06em;\n    color: #a28befcc;\n    text-transform: uppercase;\n  }\n  .node p {\n    margin-top: 6px;\n    font-weight: 300;\n    font-size: 0.85rem;\n    color: #9088c2bb;\n    font-family: 'Poppins', sans-serif;\n    line-height: 1.22;\n    font-weight: 400;\n  }\n\n  /* Positions for 4 nodes in a balanced circular layout with 3D depth */\n  .node-1 { /* Atomicity Top-Left */\n    top: 15%;\n    left: 50%;\n    transform: translate(-50%, -50%) translateZ(90px) rotateY(50deg);\n    box-shadow:\n      0 0 20px 5px #8a6dffbb,\n      inset 0 0 12px 2px #a88affcc;\n  }\n  .node-2 { /* Consistency Bottom-Left */\n    top: 70%;\n    left: 15%;\n    transform: translate(-50%, -50%) translateZ(50px) rotateY(20deg);\n  }\n  .node-3 { /* Isolation Bottom-Right */\n    top: 70%;\n    left: 85%;\n    transform: translate(-50%, -50%) translateZ(50px) rotateY(-20deg);\n  }\n  .node-4 { /* Durability Top-Right */\n    top: 15%;\n    left: 50%;\n    transform: translate(-50%, -50%) translateZ(90px) rotateY(-50deg);\n    box-shadow:\n      0 0 20px 5px #8a6dffbb,\n      inset 0 0 12px 2px #a88affcc;\n  }\n  /* Adjust node-1 slightly left, node-4 slightly right for dynamic effect */\n  .node-1 {\n    left: 30%;\n  }\n  .node-4 {\n    left: 70%;\n  }\n\n  /* Glow lines connecting nucleus to nodes with smooth animation */\n  .connection {\n    position: absolute;\n    width: 140px;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, var(--color-primary-alt), transparent);\n    opacity: 0.8;\n    border-radius: 1px;\n    filter: drop-shadow(0 0 5px var(--color-shadow));\n    transform-origin: left center;\n    pointer-events: none;\n    animation: pulse-line 3s ease-in-out infinite alternate;\n  }\n\n  .conn-1 {\n    top: 18.5%;\n    left: 43%;\n    width: 120px;\n    transform: rotate(45deg);\n    animation-delay: 0s;\n  }\n  .conn-2 {\n    top: 59%;\n    left: 40%;\n    width: 110px;\n    transform: rotate(130deg);\n    animation-delay: 0.6s;\n  }\n  .conn-3 {\n    top: 59%;\n    left: 70%;\n    width: 110px;\n    transform: rotate(50deg);\n    animation-delay: 1.2s;\n  }\n  .conn-4 {\n    top: 18.5%;\n    left: 58%;\n    width: 120px;\n    transform: rotate(-45deg);\n    animation-delay: 1.8s;\n  }\n\n  @keyframes pulse-line {\n    0%, 100% {\n      opacity: 0.7;\n      filter: drop-shadow(0 0 6px var(--color-shadow));\n    }\n    50% {\n      opacity: 1;\n      filter: drop-shadow(0 0 16px var(--color-primary-alt));\n    }\n  }\n\n  /* Bottom controls panel */\n  .controls {\n    margin-top: 5rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.6rem;\n  }\n\n  button {\n    border: none;\n    background: linear-gradient(135deg, #7f5af0, #a78bfa);\n    color: #fff;\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.85rem 2rem;\n    border-radius: 28px;\n    box-shadow:\n      0 7px 15px -3px rgba(127, 90, 240, 0.65),\n      0 4px 6px -4px rgba(127, 90, 240, 0.35);\n    cursor: pointer;\n    transition: background 0.5s ease, box-shadow 0.5s ease;\n    user-select: none;\n    outline-offset: 3px;\n  }\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, #a78bfa, #cdb4ff);\n    box-shadow:\n      0 10px 25px -5px rgba(167, 139, 250, 0.8),\n      0 6px 10px -5px rgba(167, 139, 250, 0.55);\n  }\n  button:active {\n    transform: scale(0.97);\n    box-shadow:\n      0 5px 15px -5px rgba(127, 90, 240, 0.7);\n  }\n\n  /* Tooltip style for button feedback */\n  .tooltip {\n    position: fixed;\n    bottom: 38px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: var(--color-primary-alt);\n    color: #fff;\n    padding: 0.6rem 1.5rem;\n    border-radius: 24px;\n    font-size: 1rem;\n    font-weight: 600;\n    pointer-events: none;\n    opacity: 0;\n    user-select: none;\n    transition: opacity 0.4s ease;\n    z-index: 10;\n    box-shadow: 0 0 10px var(--color-primary-alt);\n  }\n  .tooltip.show {\n    opacity: 1;\n  }\n\n  /* Responsive Adjustments */\n  @media (max-width: 900px) {\n    .container {\n      grid-template-columns: 1fr;\n      gap: 5rem;\n      align-items: center;\n    }\n    .acid-list {\n      align-items: center;\n      text-align: center;\n    }\n    .acid-item p {\n      max-width: 100%;\n    }\n    .diagram {\n      margin: 0 auto;\n      width: 320px;\n      height: 320px;\n    }\n  }\n  @media (max-width: 480px) {\n    h1 {\n      font-size: 2.8rem;\n    }\n    h2 {\n      margin-bottom: 3rem;\n    }\n    .diagram {\n      width: 280px;\n      height: 280px;\n    }\n    .node {\n      width: 90px;\n      height: 90px;\n      font-size: 0.9rem;\n    }\n    .node strong {\n      font-size: 2rem;\n    }\n  }\n\n</style>\n</head>\n<body>\n  <h1>ACID Properties</h1>\n  <h2>Database Transaction Guarantees</h2>\n\n  <div class=\"container\" aria-label=\"ACID Properties visualization and description\">\n    <section class=\"acid-list\" aria-labelledby=\"properties-title\">\n      <h3 id=\"properties-title\" style=\"position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;\">ACID Properties List</h3>\n      <article class=\"acid-item\" data-letter=\"A\" tabindex=\"-1\" aria-describedby=\"A-desc\">\n        <strong>Atomicity</strong>\n        <p id=\"A-desc\">Each transaction is treated as a single, indivisible unit – either all operations complete successfully or none do.</p>\n      </article>\n      <article class=\"acid-item\" data-letter=\"C\" tabindex=\"-1\" aria-describedby=\"C-desc\">\n        <strong>Consistency</strong>\n        <p id=\"C-desc\">Transactions bring the database from one valid state to another, maintaining database rules and constraints.</p>\n      </article>\n      <article class=\"acid-item\" data-letter=\"I\" tabindex=\"-1\" aria-describedby=\"I-desc\">\n        <strong>Isolation</strong>\n        <p id=\"I-desc\">Concurrent transactions do not interfere with each other, ensuring isolated execution results.</p>\n      </article>\n      <article class=\"acid-item\" data-letter=\"D\" tabindex=\"-1\" aria-describedby=\"D-desc\">\n        <strong>Durability</strong>\n        <p id=\"D-desc\">Once a transaction is committed, its results are permanent even in case of system failure.</p>\n      </article>\n    </section>\n\n    <section class=\"diagram\" aria-label=\"Visual representation of ACID properties\">\n      <div class=\"molecule\" aria-hidden=\"true\">\n        <div class=\"nucleus\" title=\"ACID Core Concept\">ACID <small>Properties</small></div>\n        <div class=\"node node-1\" title=\"Atomicity\">\n          <strong>A</strong>\n          <span>Atomicity</span>\n          <p>All or nothing</p>\n        </div>\n        <div class=\"node node-2\" title=\"Consistency\">\n          <strong>C</strong>\n          <span>Consistency</span>\n          <p>Valid state transitions</p>\n        </div>\n        <div class=\"node node-3\" title=\"Isolation\">\n          <strong>I</strong>\n          <span>Isolation</span>\n          <p>Independent transactions</p>\n        </div>\n        <div class=\"node node-4\" title=\"Durability\">\n          <strong>D</strong>\n          <span>Durability</span>\n          <p>Permanent changes</p>\n        </div>\n\n        <div class=\"connection conn-1\"></div>\n        <div class=\"connection conn-2\"></div>\n        <div class=\"connection conn-3\"></div>\n        <div class=\"connection conn-4\"></div>\n      </div>\n    </section>\n  </div>\n\n  <nav class=\"controls\" aria-label=\"Controls to toggle color themes and animations\">\n    <button id=\"toggleAnimationBtn\" aria-pressed=\"true\" aria-label=\"Toggle animation\">Pause Rotation</button>\n    <button id=\"toggleThemeBtn\" aria-label=\"Toggle color theme\">Dark Theme</button>\n  </nav>\n\n  <div role=\"alert\" aria-live=\"polite\" class=\"tooltip\" id=\"tooltip\"></div>\n\n  <script>\n    (() => {\n      const molecule = document.querySelector('.molecule');\n      const animationBtn = document.getElementById('toggleAnimationBtn');\n      const themeBtn = document.getElementById('toggleThemeBtn');\n      const tooltip = document.getElementById('tooltip');\n\n      let animationRunning = true;\n      let darkTheme = true;\n\n      // Animation toggle handler\n      animationBtn.addEventListener('click', () => {\n        animationRunning = !animationRunning;\n        if(animationRunning) {\n          molecule.style.animationPlayState = 'running';\n          animationBtn.textContent = 'Pause Rotation';\n          animationBtn.setAttribute('aria-pressed', 'true');\n          showTooltip('Animation resumed');\n        } else {\n          molecule.style.animationPlayState = 'paused';\n          animationBtn.textContent = 'Play Rotation';\n          animationBtn.setAttribute('aria-pressed', 'false');\n          showTooltip('Animation paused');\n        }\n      });\n\n      // Theme toggle handler\n      themeBtn.addEventListener('click', () => {\n        darkTheme = !darkTheme;\n        if(darkTheme) {\n          document.documentElement.style.setProperty('--color-bg', '#0f1123');\n          document.documentElement.style.setProperty('--color-primary', '#7f5af0');\n          document.documentElement.style.setProperty('--color-primary-alt', '#a78bfa');\n          document.documentElement.style.setProperty('--color-accent', '#f0f0f7');\n          document.documentElement.style.setProperty('--color-accent-alt', '#e0dfff');\n          document.documentElement.style.setProperty('--color-shadow', 'rgba(127, 90, 240, 0.5)');\n          document.documentElement.style.setProperty('--color-surface', '#1a1f44');\n          themeBtn.textContent = 'Dark Theme';\n          showTooltip('Switched to Dark Theme');\n        } else {\n          document.documentElement.style.setProperty('--color-bg', '#f7f8fe');\n          document.documentElement.style.setProperty('--color-primary', '#6b21a8');\n          document.documentElement.style.setProperty('--color-primary-alt', '#9333ea');\n          document.documentElement.style.setProperty('--color-accent', '#3c1361');\n          document.documentElement.style.setProperty('--color-accent-alt', '#522775');\n          document.documentElement.style.setProperty('--color-shadow', 'rgba(105, 40, 143, 0.35)');\n          document.documentElement.style.setProperty('--color-surface', '#e4d7fa');\n          themeBtn.textContent = 'Light Theme';\n          showTooltip('Switched to Light Theme');\n        }\n      });\n\n      // Show tooltip with fade\n      let tooltipTimeout;\n      function showTooltip(message) {\n        clearTimeout(tooltipTimeout);\n        tooltip.textContent = message;\n        tooltip.classList.add('show');\n        tooltipTimeout = setTimeout(() => {\n          tooltip.classList.remove('show');\n        }, 2000);\n      }\n\n      // Initialize\n      molecule.style.animationPlayState = 'running';\n    })();\n  </script>\n</body>\n</html>"
