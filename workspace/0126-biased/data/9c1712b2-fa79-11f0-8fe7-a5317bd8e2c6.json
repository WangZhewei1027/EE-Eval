  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Symmetric Cryptography Interactive Playground</title>\n<style>\n/* Extremely minimal styling - plain black text on white background */\nbody { font-family: Arial, sans-serif; color: #000; background: #fff; margin: 12px; }\nsection { margin-bottom: 18px; padding: 6px; border: 1px solid #000; }\nlabel { display: block; margin-top: 8px; }\ninput[type=\"text\"], input[type=\"number\"], textarea, select { width: 100%; box-sizing: border-box; margin-top: 4px; }\ntextarea { height: 90px; }\nbutton { margin-top: 6px; display: inline-block; }\n.small { width: auto; display: inline-block; }\n.log { height: 160px; overflow: auto; white-space: pre-wrap; background: #fff; border: 1px solid #000; padding: 6px; }\n.inline { display: inline-block; vertical-align: top; margin-right: 8px; }\nfieldset { margin-top: 8px; padding: 6px; }\n</style>\n</head>\n<body>\n<h1>Symmetric Cryptography Interactive Playground</h1>\n\n<section id=\"stateSection\">\n  <strong>State</strong>\n  <div id=\"stateDisplay\">idle</div>\n  <div>\n    <button id=\"resetBtn\">Reset All</button>\n    <button id=\"clearLogBtn\">Clear Log</button>\n  </div>\n</section>\n\n<section>\n  <strong>Algorithm & Key Management</strong>\n  <label>Algorithm:\n    <select id=\"algoSelect\">\n      <option value=\"AES\">AES</option>\n      <option value=\"XOR\">XOR (educational)</option>\n      <option value=\"AES-GCM\">AES-GCM (explicit)</option>\n      <option value=\"AES-CBC\">AES-CBC (explicit)</option>\n      <option value=\"AES-CTR\">AES-CTR</option>\n    </select>\n  </label>\n\n  <label id=\"modeLabel\">AES Key Size (bits):\n    <input id=\"keySize\" type=\"range\" min=\"128\" max=\"256\" step=\"64\" value=\"256\">\n    <span id=\"keySizeVal\">256</span>\n  </label>\n\n  <label>Key input (text or hex). Prefix hex with 0x or enter base64 and click Import:\n    <input id=\"keyInput\" type=\"text\" placeholder=\"raw text, 0x...hex, or base64\">\n  </label>\n\n  <div>\n    <button id=\"importKeyBtn\">Import Key</button>\n    <button id=\"genKeyBtn\">Generate Random Key</button>\n    <button id=\"exportKeyBtn\">Export Key (hex)</button>\n    <button id=\"showKeyBtn\">Show Key Representations</button>\n  </div>\n\n  <fieldset>\n    <legend>Derive from password (PBKDF2)</legend>\n    <label>Password:\n      <input id=\"pwInput\" type=\"text\" placeholder=\"password\">\n    </label>\n    <label>Salt (hex or text):\n      <input id=\"saltInput\" type=\"text\" placeholder=\"salt\">\n    </label>\n    <label>Iterations:\n      <input id=\"pwIters\" type=\"number\" min=\"1\" value=\"100000\">\n    </label>\n    <label>Hash:\n      <select id=\"pwHash\">\n        <option>SHA-256</option>\n        <option>SHA-1</option>\n        <option>SHA-384</option>\n      </select>\n    </label>\n    <button id=\"deriveBtn\">Derive Key</button>\n  </fieldset>\n\n  <div id=\"keyInfo\" style=\"margin-top:8px;\"></div>\n</section>\n\n<section>\n  <strong>IV / Nonce / Counter Controls</strong>\n  <label>\n    Auto-generate IV/nonce on encrypt:\n    <input id=\"autoIv\" type=\"checkbox\" checked>\n  </label>\n\n  <label>\n    IV / Nonce (hex). If empty and auto-generate is ON, a random IV will be used.\n    <input id=\"ivInput\" type=\"text\" placeholder=\"hex iv (e.g. 0x...)\">\n  </label>\n\n  <label>\n    IV length (bytes) (applies for auto-generation):\n    <input id=\"ivLen\" type=\"number\" min=\"1\" value=\"12\">\n  </label>\n\n  <div>\n    <button id=\"genIvBtn\">Generate IV Now</button>\n    <button id=\"mutateIvBtn\">Flip bit in IV</button>\n  </div>\n  <div id=\"ivInfo\"></div>\n</section>\n\n<section>\n  <strong>Encryption / Decryption</strong>\n\n  <label>Plaintext input (text):\n    <textarea id=\"plaintext\">Hello world</textarea>\n  </label>\n\n  <label>Input encoding for export:\n    <select id=\"plainEncoding\">\n      <option value=\"utf8\">UTF-8 text</option>\n      <option value=\"hex\">Hex</option>\n      <option value=\"base64\">Base64</option>\n    </select>\n  </label>\n\n  <label>Ciphertext output encoding:\n    <select id=\"ctEncoding\">\n      <option value=\"base64\">Base64</option>\n      <option value=\"hex\">Hex</option>\n      <option value=\"utf8\">UTF-8 (may be binary)</option>\n    </select>\n  </label>\n\n  <div>\n    <button id=\"encryptBtn\">Encrypt</button>\n    <button id=\"decryptBtn\">Decrypt</button>\n    <button id=\"tamperBtn\">Flip bit in ciphertext</button>\n    <button id=\"showCtBtn\">Show Stored Ciphertext</button>\n    <button id=\"downloadBtn\">Download Ciphertext as file</button>\n  </div>\n\n  <label>Ciphertext area (editable). You can paste ciphertext here to decrypt:\n    <textarea id=\"ciphertext\"></textarea>\n  </label>\n\n  <div id=\"decryptResult\"></div>\n</section>\n\n<section>\n  <strong>Advanced / Exploration</strong>\n\n  <fieldset>\n    <legend>Brute-forcing (demonstration only) - works for XOR small key sizes</legend>\n    <label>Target ciphertext (hex or base64 or paste above):\n      <input id=\"bfInput\" type=\"text\" placeholder=\"ciphertext to try decrypting\">\n    </label>\n    <label>Key size to brute-force (bytes):\n      <input id=\"bfKeySize\" type=\"number\" min=\"1\" max=\"4\" value=\"1\">\n    </label>\n    <label>Max attempts limit:\n      <input id=\"bfLimit\" type=\"number\" min=\"1\" value=\"10000\">\n    </label>\n    <label>Filter for readable plaintext (ASCII printable):\n      <input id=\"bfFilter\" type=\"checkbox\" checked>\n    </label>\n    <div>\n      <button id=\"bfStart\">Start Brute-force</button>\n      <button id=\"bfStop\">Stop</button>\n    </div>\n    <div id=\"bfResults\"></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Benchmarking</legend>\n    <label>Iterations:\n      <input id=\"benchIters\" type=\"number\" min=\"1\" value=\"100\">\n    </label>\n    <label>Data size per op (bytes):\n      <input id=\"benchSize\" type=\"number\" min=\"1\" value=\"1024\">\n    </label>\n    <div>\n      <button id=\"benchBtn\">Run Benchmark (encrypt)</button>\n    </div>\n    <div id=\"benchResult\"></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Logs and detailed trace</legend>\n    <div class=\"log\" id=\"log\"></div>\n    <div>\n      <button id=\"dumpStateBtn\">Dump Internal State</button>\n    </div>\n  </fieldset>\n</section>\n\n<script>\n/*\n  Symmetric Cryptography Interactive Playground\n  - Uses WebCrypto for AES operations\n  - Provides XOR implementation for educational brute-force demos\n  - Supports key import/export, PBKDF2 derivation\n  - Numerous interactive controls and state transitions\n*/\n\n(function(){\n  // Utility conversions\n  function str2ab(str) {\n    return new TextEncoder().encode(str).buffer;\n  }\n  function ab2str(ab) {\n    try { return new TextDecoder().decode(ab); }\n    catch(e) { return ''; }\n  }\n  function ab2hex(buf) {\n    const a = new Uint8Array(buf);\n    return Array.from(a).map(b => ('0'+b.toString(16)).slice(-2)).join('');\n  }\n  function hex2ab(hex) {\n    if (hex.startsWith('0x')) hex = hex.slice(2);\n    if (hex.length % 2) hex = '0' + hex;\n    const len = hex.length/2;\n    const out = new Uint8Array(len);\n    for (let i=0;i<len;i++) out[i]=parseInt(hex.substr(i*2,2),16);\n    return out.buffer;\n  }\n  function ab2b64(buf) {\n    let binary = '';\n    const bytes = new Uint8Array(buf);\n    for (let i=0;i<bytes.length;i++) binary += String.fromCharCode(bytes[i]);\n    return btoa(binary);\n  }\n  function b642ab(b64) {\n    try {\n      const bin = atob(b64);\n      const out = new Uint8Array(bin.length);\n      for (let i=0;i<bin.length;i++) out[i]=bin.charCodeAt(i);\n      return out.buffer;\n    } catch(e) { return null; }\n  }\n  function tryParseInputAsArrayBuffer(input) {\n    input = input.trim();\n    if (!input) return null;\n    // try hex\n    if (/^(0x)?[0-9a-fA-F\\s]+$/.test(input.replace(/\\s+/g,''))) {\n      try { return hex2ab(input.replace(/\\s+/g,'')); } catch(e){}\n    }\n    // try base64\n    try {\n      const a = b642ab(input);\n      if (a) return a;\n    } catch(e){}\n    // fallback to utf8 string\n    return str2ab(input);\n  }\n\n  // DOM\n  const stateDisplay = document.getElementById('stateDisplay');\n  const resetBtn = document.getElementById('resetBtn');\n  const clearLogBtn = document.getElementById('clearLogBtn');\n\n  const algoSelect = document.getElementById('algoSelect');\n  const keySize = document.getElementById('keySize');\n  const keySizeVal = document.getElementById('keySizeVal');\n  const keyInput = document.getElementById('keyInput');\n  const importKeyBtn = document.getElementById('importKeyBtn');\n  const genKeyBtn = document.getElementById('genKeyBtn');\n  const exportKeyBtn = document.getElementById('exportKeyBtn');\n  const showKeyBtn = document.getElementById('showKeyBtn');\n  const keyInfo = document.getElementById('keyInfo');\n\n  const deriveBtn = document.getElementById('deriveBtn');\n  const pwInput = document.getElementById('pwInput');\n  const saltInput = document.getElementById('saltInput');\n  const pwIters = document.getElementById('pwIters');\n  const pwHash = document.getElementById('pwHash');\n\n  const autoIv = document.getElementById('autoIv');\n  const ivInput = document.getElementById('ivInput');\n  const genIvBtn = document.getElementById('genIvBtn');\n  const ivLen = document.getElementById('ivLen');\n  const ivInfo = document.getElementById('ivInfo');\n  const mutateIvBtn = document.getElementById('mutateIvBtn');\n\n  const plaintext = document.getElementById('plaintext');\n  const plainEncoding = document.getElementById('plainEncoding');\n  const ctEncoding = document.getElementById('ctEncoding');\n  const encryptBtn = document.getElementById('encryptBtn');\n  const decryptBtn = document.getElementById('decryptBtn');\n  const tamperBtn = document.getElementById('tamperBtn');\n  const showCtBtn = document.getElementById('showCtBtn');\n  const downloadBtn = document.getElementById('downloadBtn');\n  const ciphertextArea = document.getElementById('ciphertext');\n  const decryptResult = document.getElementById('decryptResult');\n\n  const bfStart = document.getElementById('bfStart');\n  const bfStop = document.getElementById('bfStop');\n  const bfInput = document.getElementById('bfInput');\n  const bfKeySize = document.getElementById('bfKeySize');\n  const bfLimit = document.getElementById('bfLimit');\n  const bfFilter = document.getElementById('bfFilter');\n  const bfResults = document.getElementById('bfResults');\n\n  const benchBtn = document.getElementById('benchBtn');\n  const benchIters = document.getElementById('benchIters');\n  const benchSize = document.getElementById('benchSize');\n  const benchResult = document.getElementById('benchResult');\n\n  const logBox = document.getElementById('log');\n  const dumpStateBtn = document.getElementById('dumpStateBtn');\n\n  // Internal state\n  const app = {\n    phase: 'idle',\n    key: null,               // CryptoKey for AES or Uint8Array for XOR\n    keyRaw: null,            // ArrayBuffer of raw key bytes\n    algo: 'AES',\n    iv: null,                // ArrayBuffer\n    ciphertext: null,        // ArrayBuffer\n    lastPlain: null,         // ArrayBuffer\n    lastCiphertextEncoding: 'base64',\n    bruteForceRunning: false\n  };\n\n  function log(...args) {\n    const s = args.map(a => (typeof a === 'string' ? a : JSON.stringify(a))).join(' ');\n    const ts = (new Date()).toISOString();\n    logBox.textContent = ts + '  ' + s + '\\n' + logBox.textContent;\n  }\n\n  function setPhase(phase) {\n    app.phase = phase;\n    stateDisplay.textContent = phase;\n    log('Phase ->', phase);\n  }\n\n  function updateKeySizeDisplay() {\n    keySizeVal.textContent = keySize.value;\n  }\n\n  // Key helpers\n  async function importKeyFromText(text) {\n    const ab = tryParseInputAsArrayBuffer(text);\n    if (!ab) throw new Error('Could not parse input as key bytes');\n    app.keyRaw = ab.slice(0); // copy\n    if (app.algo === 'XOR') {\n      app.key = new Uint8Array(app.keyRaw);\n      setPhase('keyImported');\n    } else {\n      // import as AES raw key\n      const lenBits = (new Uint8Array(app.keyRaw)).length * 8;\n      // accept if matches requested or derive/truncate\n      const requested = parseInt(keySize.value,10);\n      let raw = new Uint8Array(app.keyRaw);\n      if (raw.length * 8 !== requested) {\n        // truncate or pad with zeros\n        const needed = requested/8;\n        const out = new Uint8Array(needed);\n        out.set(raw.subarray(0, needed));\n        raw = out;\n        app.keyRaw = raw.buffer;\n      }\n      app.key = await window.crypto.subtle.importKey('raw', app.keyRaw, {name:'AES-GCM'}, false, ['encrypt','decrypt']);\n      setPhase('keyImported');\n    }\n    refreshKeyInfo();\n    log('Imported key length bytes:', (new Uint8Array(app.keyRaw)).length);\n  }\n\n  async function generateRandomKey() {\n    if (app.algo === 'XOR') {\n      const size = Math.max(1, parseInt(prompt('How many bytes for XOR key?', '8') || '8',10));\n      const arr = new Uint8Array(size);\n      window.crypto.getRandomValues(arr);\n      app.keyRaw = arr.buffer;\n      app.key = arr;\n      setPhase('keyGenerated');\n      refreshKeyInfo();\n      return;\n    }\n    const bits = parseInt(keySize.value,10);\n    const key = await window.crypto.subtle.generateKey({name:'AES-GCM', length: bits}, true, ['encrypt','decrypt']);\n    const exported = await window.crypto.subtle.exportKey('raw', key);\n    app.keyRaw = exported;\n    app.key = key;\n    setPhase('keyGenerated');\n    refreshKeyInfo();\n    log('Generated AES key', bits, 'bits');\n  }\n\n  async function exportKeyHex() {\n    if (!app.keyRaw) { alert('No key available'); return; }\n    const hex = ab2hex(app.keyRaw);\n    prompt('Key hex (copy):', hex);\n  }\n\n  function refreshKeyInfo() {\n    if (!app.keyRaw) { keyInfo.textContent = 'No key loaded'; return; }\n    const hex = ab2hex(app.keyRaw);\n    const b64 = ab2b64(app.keyRaw);\n    const len = (new Uint8Array(app.keyRaw)).length;\n    keyInfo.textContent = 'Key: ' + len + ' bytes. Hex preview: ' + hex.slice(0,64) + (hex.length>64? '...':'') + '  Base64 preview: ' + b64.slice(0,64);\n    ivInfo.textContent = app.iv ? ('IV: ' + ab2hex(app.iv).slice(0,64)) : 'IV: <none>';\n  }\n\n  // IV helpers\n  function generateIv(lenBytes) {\n    const arr = new Uint8Array(lenBytes);\n    window.crypto.getRandomValues(arr);\n    app.iv = arr.buffer;\n    ivInput.value = '0x' + ab2hex(app.iv);\n    ivInfo.textContent = 'IV: 0x' + ab2hex(app.iv);\n    setPhase('ivGenerated');\n    log('IV generated length', lenBytes);\n  }\n\n  function parseIvInput() {\n    const v = ivInput.value.trim();\n    if (!v) return null;\n    try {\n      const ab = tryParseInputAsArrayBuffer(v);\n      return ab;\n    } catch(e) { return null; }\n  }\n\n  function mutateIv() {\n    if (!app.iv) {\n      alert('No IV to mutate. Generate one first.');\n      return;\n    }\n    const u = new Uint8Array(app.iv.slice(0));\n    u[0] = u[0] ^ 1;\n    app.iv = u.buffer;\n    ivInput.value = '0x' + ab2hex(app.iv);\n    ivInfo.textContent = 'IV: 0x' + ab2hex(app.iv);\n    setPhase('ivMutated');\n    log('IV mutated (flipped bit 0)');\n  }\n\n  // AES encrypt/decrypt wrappers\n  async function importKeyForAes(raw) {\n    const key = await window.crypto.subtle.importKey('raw', raw, {name:'AES-GCM'}, false, ['encrypt','decrypt']);\n    return key;\n  }\n\n  function pkcs7Pad(buf) {\n    const block = 16;\n    const u = new Uint8Array(buf);\n    const padLen = block - (u.length % block) || block;\n    const out = new Uint8Array(u.length + padLen);\n    out.set(u,0);\n    out.fill(padLen, u.length);\n    return out.buffer;\n  }\n  function pkcs7Unpad(buf) {\n    const u = new Uint8Array(buf);\n    if (u.length === 0) throw new Error('Invalid padding');\n    const pad = u[u.length-1];\n    if (pad <= 0 || pad > 16) throw new Error('Invalid padding value');\n    for (let i=1;i<=pad;i++) if (u[u.length-i] !== pad) throw new Error('Invalid padding bytes');\n    return u.subarray(0, u.length - pad).buffer;\n  }\n\n  async function encryptOperation() {\n    // prepare input\n    const plainMode = plainEncoding.value;\n    let plainAB;\n    if (plainMode === 'utf8') plainAB = str2ab(plaintext.value);\n    else if (plainMode === 'hex') plainAB = hex2ab(plaintext.value);\n    else if (plainMode === 'base64') plainAB = b642ab(plaintext.value);\n\n    app.lastPlain = plainAB;\n\n    // ensure key exists\n    if (!app.key) { alert('No key. Generate or import one.'); return; }\n    app.algo = algoSelect.value;\n\n    // prepare IV\n    let ivToUse = null;\n    if (autoIv.checked || !ivInput.value.trim()) {\n      const len = Math.max(1, parseInt(ivLen.value,10) || 12);\n      ivToUse = new Uint8Array(len);\n      window.crypto.getRandomValues(ivToUse);\n      app.iv = ivToUse.buffer;\n    } else {\n      const parsed = parseIvInput();\n      if (!parsed) { alert('Invalid IV input'); return; }\n      app.iv = parsed;\n    }\n\n    // perform encrypt based on algorithm\n    if (app.algo === 'XOR') {\n      // XOR: repeat key bytes\n      if (!(app.key instanceof Uint8Array)) { alert('XOR key is not loaded'); return; }\n      const keyBytes = app.key;\n      const data = new Uint8Array(plainAB);\n      const out = new Uint8Array(data.length);\n      for (let i=0;i<data.length;i++) out[i] = data[i] ^ keyBytes[i % keyBytes.length];\n      app.ciphertext = out.buffer;\n      app.lastCiphertextEncoding = ctEncoding.value;\n      const displayed = encodeOutput(app.ciphertext, ctEncoding.value);\n      ciphertextArea.value = displayed;\n      setPhase('encrypted');\n      log('XOR encryption done. ciphertext length', out.length);\n      return;\n    }\n\n    // AES modes - use WebCrypto\n    const algorithmMode = algoSelect.value === 'AES' ? 'AES-GCM' : algoSelect.value;\n    const key = app.key;\n    let algoParams;\n    if (algorithmMode === 'AES-GCM') {\n      algoParams = { name: 'AES-GCM', iv: new Uint8Array(app.iv) };\n      try {\n        const ct = await window.crypto.subtle.encrypt(algoParams, key, plainAB);\n        app.ciphertext = ct;\n        app.lastCiphertextEncoding = ctEncoding.value;\n        ciphertextArea.value = encodeOutput(ct, ctEncoding.value);\n        setPhase('encrypted');\n        log('AES-GCM encrypt success, ciphertext bytes', (new Uint8Array(ct)).length);\n      } catch(e) {\n        log('Encrypt error', e.message);\n        alert('Encryption failed: ' + e.message);\n      }\n      return;\n    } else if (algorithmMode === 'AES-CBC') {\n      // pad then encrypt\n      const padded = pkcs7Pad(plainAB);\n      algoParams = { name: 'AES-CBC', iv: new Uint8Array(app.iv) };\n      try {\n        const ct = await window.crypto.subtle.encrypt(algoParams, key, padded);\n        app.ciphertext = ct;\n        app.lastCiphertextEncoding = ctEncoding.value;\n        ciphertextArea.value = encodeOutput(ct, ctEncoding.value);\n        setPhase('encrypted');\n        log('AES-CBC encrypt success, ciphertext bytes', (new Uint8Array(ct)).length);\n      } catch(e) { log('Encrypt CBC error', e.message); alert('Encryption failed: '+ e.message); }\n      return;\n    } else if (algorithmMode === 'AES-CTR') {\n      // CTR needs counter 16 bytes\n      const counter = new Uint8Array(16);\n      const ivBytes = new Uint8Array(app.iv);\n      counter.set(ivBytes.slice(0,16));\n      algoParams = { name:'AES-CTR', counter: counter, length: 64 };\n      try {\n        const ct = await window.crypto.subtle.encrypt(algoParams, key, plainAB);\n        app.ciphertext = ct;\n        app.lastCiphertextEncoding = ctEncoding.value;\n        ciphertextArea.value = encodeOutput(ct, ctEncoding.value);\n        setPhase('encrypted');\n        log('AES-CTR encrypt success');\n      } catch(e) { log('Encrypt CTR error', e.message); alert('Encryption failed: '+ e.message); }\n      return;\n    } else {\n      alert('Unsupported algorithm: ' + algorithmMode);\n    }\n  }\n\n  async function decryptOperation() {\n    // find ciphertext from area or stored\n    let ctInput = ciphertextArea.value.trim();\n    let ctAB = null;\n    if (!ctInput && app.ciphertext) ctAB = app.ciphertext;\n    else ctAB = tryParseInputAsArrayBuffer(ctInput);\n\n    if (!ctAB) { alert('No ciphertext found to decrypt'); return; }\n    if (!app.key) { alert('No key available'); return; }\n\n    if (app.algo === 'XOR') {\n      if (!(app.key instanceof Uint8Array)) { alert('XOR key is not a Uint8Array'); return; }\n      const data = new Uint8Array(ctAB);\n      const out = new Uint8Array(data.length);\n      for (let i=0;i<data.length;i++) out[i] = data[i] ^ app.key[i % app.key.length];\n      decryptResult.textContent = 'Decrypted (UTF-8):\\n' + ab2str(out.buffer) + '\\n\\nHex:\\n' + ab2hex(out.buffer);\n      setPhase('decrypted');\n      return;\n    }\n\n    const algorithmMode = algoSelect.value === 'AES' ? 'AES-GCM' : algoSelect.value;\n    const key = app.key;\n\n    // ensure iv parsed\n    const ivParsed = parseIvInput();\n    if (ivParsed) app.iv = ivParsed;\n    if (!app.iv && algorithmMode !== 'AES-CTR') { alert('IV not set. For AES-GCM/CBC you must set IV or enable auto-generate before encrypt to store the IV.'); return; }\n\n    try {\n      if (algorithmMode === 'AES-GCM') {\n        const params = { name:'AES-GCM', iv: new Uint8Array(app.iv) };\n        const plain = await window.crypto.subtle.decrypt(params, key, ctAB);\n        decryptResult.textContent = 'Decrypted (UTF-8):\\n' + ab2str(plain);\n        setPhase('decrypted');\n        log('AES-GCM decrypt OK');\n      } else if (algorithmMode === 'AES-CBC') {\n        const params = { name:'AES-CBC', iv: new Uint8Array(app.iv) };\n        const dec = await window.crypto.subtle.decrypt(params, key, ctAB);\n        try {\n          const unp = pkcs7Unpad(dec);\n          decryptResult.textContent = 'Decrypted (UTF-8):\\n' + ab2str(unp);\n        } catch(e) {\n          decryptResult.textContent = 'Decrypted but padding invalid or error: ' + e.message;\n        }\n        setPhase('decrypted');\n        log('AES-CBC decrypt completed');\n      } else if (algorithmMode === 'AES-CTR') {\n        // CTR uses counter 16 bytes\n        const counter = new Uint8Array(16);\n        counter.set(new Uint8Array(app.iv).slice(0,16));\n        const params = { name:'AES-CTR', counter: counter, length:64 };\n        const dec = await window.crypto.subtle.decrypt(params, key, ctAB);\n        decryptResult.textContent = 'Decrypted (UTF-8):\\n' + ab2str(dec);\n        setPhase('decrypted');\n      } else {\n        alert('Unsupported decrypt algorithm: ' + algorithmMode);\n      }\n    } catch(e) {\n      log('Decrypt error', e.message);\n      decryptResult.textContent = 'Decryption failed: ' + e.message;\n      setPhase('decryptFailed');\n    }\n  }\n\n  function encodeOutput(ab, encoding) {\n    if (!ab) return '';\n    if (encoding === 'hex') return ab2hex(ab);\n    if (encoding === 'base64') return ab2b64(ab);\n    if (encoding === 'utf8') return ab2str(ab);\n    return ab2b64(ab);\n  }\n\n  function flipBitInCiphertext() {\n    let ctAB = app.ciphertext;\n    if (!ctAB) {\n      const txt = ciphertextArea.value.trim();\n      if (!txt) { alert('No ciphertext available to tamper'); return; }\n      ctAB = tryParseInputAsArrayBuffer(txt);\n    }\n    const u = new Uint8Array(ctAB.slice(0));\n    if (u.length === 0) { alert('Ciphertext empty'); return; }\n    u[0] = u[0] ^ 1;\n    app.ciphertext = u.buffer;\n    ciphertextArea.value = encodeOutput(app.ciphertext, app.lastCiphertextEncoding || 'base64');\n    setPhase('ciphertextTampered');\n    log('Ciphertext bit flipped at byte 0');\n  }\n\n  // Brute force XOR small key\n  let bfAbort = false;\n  async function bruteForceXor() {\n    bfResults.textContent = '';\n    bfAbort = false;\n    const ctText = bfInput.value.trim() || ciphertextArea.value.trim();\n    if (!ctText) { alert('No ciphertext specified'); return; }\n    const ctAB = tryParseInputAsArrayBuffer(ctText);\n    if (!ctAB) { alert('Failed to parse ciphertext'); return; }\n    const data = new Uint8Array(ctAB);\n    const keySizeBytes = parseInt(bfKeySize.value,10) || 1;\n    const limit = parseInt(bfLimit.value,10) || 10000;\n    const filterPrintable = bfFilter.checked;\n    const maxKeyspace = Math.pow(256, keySizeBytes);\n    const attempts = Math.min(limit, maxKeyspace);\n    setPhase('bruteforce_running');\n    log('Starting brute-force XOR. Key bytes:', keySizeBytes, 'attempts:', attempts);\n    let tries = 0, found = 0;\n    // iterate lexicographically small to large; for keyspace > limit will iterate attempts only\n    function keyFromIndex(i) {\n      const out = new Uint8Array(keySizeBytes);\n      for (let j=0;j<keySizeBytes;j++) {\n        out[j] = (i >> (8*j)) & 0xff;\n      }\n      return out;\n    }\n    for (let i=0;i<attempts;i++) {\n      if (bfAbort) { log('Brute-force aborted by user'); bfResults.textContent += '\\nAborted\\n'; break; }\n      const key = keyFromIndex(i);\n      // decrypt\n      const dec = new Uint8Array(data.length);\n      for (let k=0;k<data.length;k++) dec[k] = data[k] ^ key[k % key.length];\n      const text = ab2str(dec.buffer);\n      const isPrintable = /^[\\x09\\x0A\\x0D\\x20-\\x7E]*$/.test(text);\n      if (!filterPrintable || isPrintable) {\n        found++;\n        bfResults.textContent += 'KEY hex:' + ab2hex(key.buffer) + ' -> ' + text.slice(0,200) + '\\n';\n      }\n      tries++;\n      if (tries % 1000 === 0) {\n        await new Promise(r => setTimeout(r,0));\n      }\n    }\n    setPhase('bruteforce_done');\n    log('Brute-force finished. tried', tries, 'found', found);\n  }\n\n  // Benchmark\n  async function runBenchmark() {\n    if (!app.key) { alert('Load or generate a key first'); return; }\n    const iterations = parseInt(benchIters.value,10) || 1;\n    const size = parseInt(benchSize.value,10) || 1024;\n    const algo = (algoSelect.value === 'AES' ? 'AES-GCM' : algoSelect.value);\n    const data = new Uint8Array(size);\n    window.crypto.getRandomValues(data);\n    const start = performance.now();\n    for (let i=0;i<iterations;i++) {\n      // use auto IV for each iteration\n      const iv = new Uint8Array(Math.max(12, Math.min(16, parseInt(ivLen.value,10) || 12)));\n      window.crypto.getRandomValues(iv);\n      if (algo === 'AES-GCM') {\n        await window.crypto.subtle.encrypt({name:'AES-GCM', iv:iv}, app.key, data);\n      } else if (algo === 'AES-CBC') {\n        const padded = pkcs7Pad(data.buffer);\n        await window.crypto.subtle.encrypt({name:'AES-CBC', iv:iv}, app.key, padded);\n      } else if (algo === 'AES-CTR') {\n        const counter = new Uint8Array(16);\n        counter.set(iv.slice(0,16));\n        await window.crypto.subtle.encrypt({name:'AES-CTR', counter: counter, length: 64}, app.key, data);\n      } else if (algoSelect.value === 'XOR') {\n        // simple XOR speed\n        const keyBytes = app.key;\n        const out = new Uint8Array(data.length);\n        for (let k=0;k<data.length;k++) out[k] = data[k] ^ keyBytes[k % keyBytes.length];\n      }\n    }\n    const end = performance.now();\n    const elapsed = end - start;\n    benchResult.textContent = 'Elapsed: ' + elapsed.toFixed(2) + ' ms. Ops: ' + iterations + '. Ops/s: ' + ((iterations/(elapsed/1000))|0);\n    log('Benchmark complete', benchResult.textContent);\n  }\n\n  // Event wiring\n  keySize.addEventListener('input', updateKeySizeDisplay);\n  updateKeySizeDisplay();\n\n  algoSelect.addEventListener('change', ()=> {\n    app.algo = algoSelect.value;\n    log('Algorithm changed to', app.algo);\n    // adjust features for XOR\n    if (app.algo === 'XOR') {\n      keySize.disabled = true;\n      keySizeVal.textContent = 'variable';\n    } else {\n      keySize.disabled = false;\n      keySizeVal.textContent = keySize.value;\n    }\n  });\n\n  importKeyBtn.addEventListener('click', async ()=> {\n    try {\n      await importKeyFromText(keyInput.value || '');\n    } catch(e) {\n      alert('Import failed: ' + e.message);\n      log('Import error', e.message);\n    }\n  });\n\n  genKeyBtn.addEventListener('click', async ()=> {\n    try { await generateRandomKey(); } catch(e){ alert('Generate key failed: '+e.message); log('genKey error', e.message); }\n  });\n\n  exportKeyBtn.addEventListener('click', exportKeyHex);\n  showKeyBtn.addEventListener('click', refreshKeyInfo);\n\n  deriveBtn.addEventListener('click', async ()=> {\n    const pw = pwInput.value || '';\n    if (!pw) { alert('Enter password'); return; }\n    const saltAB = tryParseInputAsArrayBuffer(saltInput.value || '') || str2ab('salt');\n    const iters = parseInt(pwIters.value,10) || 100000;\n    const hash = pwHash.value;\n    // derive raw key bytes of desired length\n    const bits = (app.algo === 'XOR') ? 64 : parseInt(keySize.value,10);\n    const lengthBytes = bits/8;\n    try {\n      const baseKey = await window.crypto.subtle.importKey('raw', str2ab(pw), {name:'PBKDF2'}, false, ['deriveBits','deriveKey']);\n      const derived = await window.crypto.subtle.deriveBits({name:'PBKDF2', salt: saltAB, iterations: iters, hash: hash}, baseKey, bits);\n      app.keyRaw = derived;\n      if (app.algo === 'XOR') {\n        app.key = new Uint8Array(derived);\n      } else {\n        app.key = await importKeyForAes(derived);\n      }\n      refreshKeyInfo();\n      setPhase('keyDerived');\n      log('Derived key via PBKDF2', bits, 'bits');\n    } catch(e) {\n      alert('Derive failed: ' + e.message);\n      log('derive error', e.message);\n    }\n  });\n\n  genIvBtn.addEventListener('click', ()=> generateIv(Math.max(1, parseInt(ivLen.value,10))));\n  mutateIvBtn.addEventListener('click', mutateIv);\n\n  encryptBtn.addEventListener('click', async ()=> {\n    try { await encryptOperation(); } catch(e) { alert('Encrypt op failed: ' + e.message); log('encrypt error', e.message); }\n  });\n\n  decryptBtn.addEventListener('click', async ()=> {\n    try { await decryptOperation(); } catch(e) { alert('Decrypt op failed: ' + e.message); log('decrypt error', e.message); }\n  });\n\n  tamperBtn.addEventListener('click', flipBitInCiphertext);\n  showCtBtn.addEventListener('click', ()=> {\n    if (!app.ciphertext) return alert('No stored ciphertext');\n    const enc = app.lastCiphertextEncoding || 'base64';\n    alert('Stored ciphertext ('+enc+'): \\n' + encodeOutput(app.ciphertext, enc));\n  });\n\n  downloadBtn.addEventListener('click', ()=> {\n    if (!app.ciphertext) { alert('Nothing to download'); return; }\n    const blob = new Blob([new Uint8Array(app.ciphertext)], {type:'application/octet-stream'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a'); a.href = url; a.download = 'cipher.bin'; document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n    log('Ciphertext downloaded as cipher.bin');\n  });\n\n  bfStart.addEventListener('click', ()=> {\n    if (algoSelect.value !== 'XOR') {\n      if (!confirm('Brute-force DEMO is designed for XOR. Continue anyway?')) return;\n    }\n    app.bruteForceRunning = true;\n    bruteForceXor();\n  });\n  bfStop.addEventListener('click', ()=> {\n    bfAbort = true;\n    app.bruteForceRunning = false;\n    setPhase('bruteforce_aborted');\n  });\n\n  benchBtn.addEventListener('click', runBenchmark);\n\n  resetBtn.addEventListener('click', ()=> {\n    if (!confirm('Reset all internal state?')) return;\n    app.key = null; app.keyRaw = null; app.iv = null; app.ciphertext = null; app.lastPlain = null;\n    keyInput.value = ''; ivInput.value = ''; ciphertextArea.value = ''; plaintext.value = 'Hello world';\n    setPhase('idle');\n    refreshKeyInfo();\n    log('State reset by user');\n  });\n\n  clearLogBtn.addEventListener('click', ()=> { logBox.textContent=''; });\n\n  dumpStateBtn.addEventListener('click', ()=> {\n    try {\n      const dump = {\n        phase: app.phase,\n        algo: app.algo,\n        keyBytes: app.keyRaw ? (new Uint8Array(app.keyRaw)).length : null,\n        ivHex: app.iv ? ab2hex(app.iv) : null,\n        ciphertextBytes: app.ciphertext ? (new Uint8Array(app.ciphertext)).length : null\n      };\n      alert(JSON.stringify(dump, null, 2));\n    } catch(e) { alert('Dump failed: ' + e.message); }\n  });\n\n  // initialize\n  setPhase('idle');\n  refreshKeyInfo();\n  log('Interactive symmetric cryptography playground ready. Use controls to explore.');\n})();\n</script>\n\n</body>\n</html>"
