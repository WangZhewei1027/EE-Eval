    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Compiler Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 10px;\n        }\n        .output-area, .input-area {\n            border: 1px solid black;\n            padding: 10px;\n            margin-top: 10px;\n            min-height: 50px;\n        }\n        button {\n            margin: 5px 0;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Interactive Compiler Demo</h1>\n\n<div>\n    <label for=\"source-code\">Source Code:</label><br>\n    <textarea id=\"source-code\" rows=\"5\" cols=\"50\"></textarea><br>\n    <button id=\"compile-button\">Compile</button>\n    <button id=\"reset-button\">Reset</button>\n</div>\n\n<div>\n    <label for=\"options\">Select Optimization Level:</label><br>\n    <select id=\"options\">\n        <option value=\"none\">None</option>\n        <option value=\"basic\">Basic</option>\n        <option value=\"advanced\">Advanced</option>\n    </select>\n</div>\n\n<div>\n    <label for=\"output\">Output:</label><br>\n    <div id=\"output\" class=\"output-area\"></div>\n</div>\n\n<div>\n    <label for=\"error-log\">Error Log:</label><br>\n    <div id=\"error-log\" class=\"output-area\"></div>\n</div>\n\n<div>\n    <label for=\"memory-usage\">Memory Usage:</label>\n    <input type=\"range\" id=\"memory-usage\" min=\"0\" max=\"100\" value=\"0\">\n    <span id=\"memory-value\">0</span>%\n</div>\n\n<div>\n    <button id=\"increase-memory\">Increase Memory</button>\n    <button id=\"decrease-memory\">Decrease Memory</button>\n</div>\n\n<script>\n    let memoryUsage = 0;\n\n    document.getElementById('compile-button').onclick = function() {\n        const sourceCode = document.getElementById('source-code').value;\n        const optimization = document.getElementById('options').value;\n        let output = \"\";\n        let errors = \"\";\n\n        if (sourceCode.trim() === \"\") {\n            errors = \"Error: Source code is empty.\";\n        } else {\n            output = `Compiled Code:\\n${sourceCode}\\nOptimization Level: ${optimization}`;\n        }\n\n        document.getElementById('output').innerText = output;\n        document.getElementById('error-log').innerText = errors;\n    };\n\n    document.getElementById('reset-button').onclick = function() {\n        document.getElementById('source-code').value = \"\";\n        document.getElementById('output').innerText = \"\";\n        document.getElementById('error-log').innerText = \"\";\n        document.getElementById('options').selectedIndex = 0;\n    };\n\n    document.getElementById('memory-usage').oninput = function() {\n        memoryUsage = this.value;\n        document.getElementById('memory-value').innerText = memoryUsage;\n    };\n\n    document.getElementById('increase-memory').onclick = function() {\n        if (memoryUsage < 100) {\n            memoryUsage++;\n            document.getElementById('memory-usage').value = memoryUsage;\n            document.getElementById('memory-value').innerText = memoryUsage;\n        }\n    };\n\n    document.getElementById('decrease-memory').onclick = function() {\n        if (memoryUsage > 0) {\n            memoryUsage--;\n            document.getElementById('memory-usage').value = memoryUsage;\n            document.getElementById('memory-value').innerText = memoryUsage;\n        }\n    };\n</script>\n\n</body>\n</html>"
