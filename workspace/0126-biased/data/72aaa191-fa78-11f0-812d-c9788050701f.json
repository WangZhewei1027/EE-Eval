    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Topological Sort | Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #6C63FF;\n            --secondary: #FF6584;\n            --dark: #2D3748;\n            --light: #F7FAFC;\n            --accent: #4FD1C5;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 1200px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 3rem;\n        }\n\n        .graph-container {\n            position: relative;\n            width: 800px;\n            height: 500px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            overflow: hidden;\n            opacity: 0;\n            transform: translateY(30px);\n            animation: slideUp 1s ease-out 0.5s forwards;\n        }\n\n        .graph {\n            width: 100%;\n            height: 100%;\n            position: relative;\n        }\n\n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            z-index: 10;\n            background: var(--primary);\n        }\n\n        .edge {\n            position: absolute;\n            height: 4px;\n            background: rgba(108, 99, 255, 0.3);\n            transform-origin: left center;\n            z-index: 1;\n            transition: all 0.8s ease-out;\n        }\n\n        .edge::after {\n            content: '';\n            position: absolute;\n            right: 0;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 12px;\n            height: 12px;\n            background: var(--primary);\n            border-radius: 50%;\n        }\n\n        .result-container {\n            width: 800px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            opacity: 0;\n            transform: translateY(30px);\n            animation: slideUp 1s ease-out 1s forwards;\n        }\n\n        .result-title {\n            font-size: 1.5rem;\n            margin-bottom: 1.5rem;\n            color: var(--dark);\n            font-weight: 400;\n        }\n\n        .result-sequence {\n            display: flex;\n            gap: 1rem;\n            opacity: 0;\n            transform: translateX(-20px);\n            transition: all 0.5s ease-out;\n        }\n\n        .result-node {\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: bold;\n            background: var(--primary);\n            box-shadow: 0 8px 15px rgba(108, 99, 255, 0.3);\n            transform: scale(0);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .result-node.highlight {\n            background: var(--secondary);\n            transform: scale(1.1);\n        }\n\n        .controls {\n            margin-top: 2rem;\n            display: flex;\n            gap: 1rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: var(--primary);\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 99, 255, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 99, 255, 0.4);\n        }\n\n        button:active {\n            transform: translateY(-1px);\n        }\n\n        button.secondary {\n            background: var(--secondary);\n            box-shadow: 0 5px 15px rgba(255, 101, 132, 0.3);\n        }\n\n        button.secondary:hover {\n            box-shadow: 0 8px 20px rgba(255, 101, 132, 0.4);\n        }\n\n        .legend {\n            display: flex;\n            gap: 2rem;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 2s forwards;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n            color: var(--dark);\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .legend-color.primary {\n            background: var(--primary);\n        }\n\n        .legend-color.secondary {\n            background: var(--secondary);\n        }\n\n        .legend-color.accent {\n            background: var(--accent);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(30px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        .floating-shapes {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            z-index: -1;\n        }\n\n        .shape {\n            position: absolute;\n            border-radius: 50%;\n            background: rgba(108, 99, 255, 0.05);\n            filter: blur(40px);\n        }\n\n        .shape-1 {\n            width: 300px;\n            height: 300px;\n            top: -100px;\n            right: -100px;\n            background: rgba(255, 101, 132, 0.05);\n        }\n\n        .shape-2 {\n            width: 400px;\n            height: 400px;\n            bottom: -150px;\n            left: -100px;\n            background: rgba(79, 209, 197, 0.05);\n        }\n\n        .explanation {\n            margin-top: 3rem;\n            max-width: 800px;\n            text-align: center;\n            line-height: 1.6;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 2.5s forwards;\n        }\n\n        .explanation p {\n            margin-bottom: 1rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"floating-shapes\">\n        <div class=\"shape shape-1\"></div>\n        <div class=\"shape shape-2\"></div>\n    </div>\n\n    <div class=\"container\">\n        <header>\n            <h1>Topological Sort</h1>\n            <p class=\"subtitle\">A linear ordering of vertices in a directed acyclic graph</p>\n        </header>\n\n        <div class=\"graph-container\">\n            <div class=\"graph\" id=\"graph\">\n                <!-- Nodes and edges will be added here via JavaScript -->\n            </div>\n        </div>\n\n        <div class=\"result-container\">\n            <h2 class=\"result-title\">Topological Order</h2>\n            <div class=\"result-sequence\" id=\"result-sequence\">\n                <!-- Result nodes will be added here via JavaScript -->\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"sort-btn\">Sort Graph</button>\n            <button class=\"secondary\" id=\"reset-btn\">Reset</button>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color primary\"></div>\n                <span>Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color secondary\"></div>\n                <span>Selected Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color accent\"></div>\n                <span>Completed Node</span>\n            </div>\n        </div>\n\n        <div class=\"explanation\">\n            <p>Topological sort is an algorithm that orders the vertices of a directed acyclic graph (DAG) such that for every directed edge (u → v), vertex u comes before v in the ordering.</p>\n            <p>This ordering is useful in many applications such as task scheduling, dependency resolution, and determining the order of compilation tasks.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Sample DAG\n            const graph = {\n                'A': ['D'],\n                'B': ['D'],\n                'C': ['A', 'B'],\n                'D': ['E', 'H'],\n                'E': ['F'],\n                'F': [],\n                'G': ['A', 'B', 'C'],\n                'H': []\n            };\n\n            const nodePositions = {\n                'A': { x: 150, y: 150 },\n                'B': { x: 350, y: 150 },\n                'C': { x: 550, y: 150 },\n                'D': { x: 250, y: 250 },\n                'E': { x: 250, y: 350 },\n                'F': { x: 150, y: 450 },\n                'G': { x: 650, y: 50 },\n                'H': { x: 450, y: 350 }\n            };\n\n            const graphElement = document.getElementById('graph');\n            const resultSequence = document.getElementById('result-sequence');\n            const sortBtn = document.getElementById('sort-btn');\n            const resetBtn = document.getElementById('reset-btn');\n\n            // Create nodes and edges\n            function renderGraph() {\n                graphElement.innerHTML = '';\n                resultSequence.innerHTML = '';\n\n                // Create edges first (so they appear behind nodes)\n                for (const [src, dests] of Object.entries(graph)) {\n                    const srcPos = nodePositions[src];\n                    for (const dest of dests) {\n                        const destPos = nodePositions[dest];\n                        createEdge(srcPos, destPos, src, dest);\n                    }\n                }\n\n                // Create nodes\n                for (const [node, pos] of Object.entries(nodePositions)) {\n                    createNode(node, pos.x, pos.y);\n                }\n            }\n\n            function createNode(node, x, y) {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                nodeElement.id = `node-${node}`;\n                nodeElement.textContent = node;\n                nodeElement.style.left = `${x}px`;\n                nodeElement.style.top = `${y}px`;\n                graphElement.appendChild(nodeElement);\n            }\n\n            function createEdge(srcPos, destPos, src, dest) {\n                const edgeElement = document.createElement('div');\n                edgeElement.className = 'edge';\n                edgeElement.id = `edge-${src}-${dest}`;\n\n                // Calculate edge properties\n                const dx = destPos.x - srcPos.x;\n                const dy = destPos.y - srcPos.y;\n                const length = Math.sqrt(dx * dx + dy * dy);\n                const angle = Math.atan2(dy, dx);\n\n                edgeElement.style.width = `${length}px`;\n                edgeElement.style.left = `${srcPos.x + 30}px`;\n                edgeElement.style.top = `${srcPos.y + 30}px`;\n                edgeElement.style.transform = `rotate(${angle}rad)`;\n\n                graphElement.appendChild(edgeElement);\n            }\n\n            function createResultNode(node) {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'result-node';\n                nodeElement.textContent = node;\n                return nodeElement;\n            }\n\n            // Topological sort using Kahn's algorithm\n            function topologicalSort() {\n                sortBtn.disabled = true;\n                resetBtn.disabled = true;\n\n                // Initialize in-degree count\n                const inDegree = {};\n                for (const node in graph) {\n                    inDegree[node] = 0;\n                }\n\n                // Calculate in-degree for each node\n                for (const src in graph) {\n                    for (const dest of graph[src]) {\n                        inDegree[dest]++;\n                    }\n                }\n\n                // Queue for nodes with no incoming edges\n                const queue = [];\n                for (const node in inDegree) {\n                    if (inDegree[node] === 0) {\n                        queue.push(node);\n                    }\n                }\n\n                const result = [];\n                let processedCount = 0;\n                const totalNodes = Object.keys(graph).length;\n\n                // Process nodes one by one\n                function processNext() {\n                    if (queue.length === 0) {\n                        if (processedCount !== totalNodes) {\n                            console.log(\"Graph has a cycle!\");\n                        }\n                        resetBtn.disabled = false;\n                        return;\n                    }\n\n                    const node = queue.shift();\n                    result.push(node);\n                    processedCount++;\n\n                    // Highlight the current node\n                    const nodeElement = document.getElementById(`node-${node}`);\n                    nodeElement.style.background = 'var(--secondary)';\n                    nodeElement.style.transform = 'scale(1.2)';\n\n                    // Add to result sequence with animation\n                    setTimeout(() => {\n                        const resultNode = createResultNode(node);\n                        resultSequence.appendChild(resultNode);\n                        \n                        // Animate the result node\n                        setTimeout(() => {\n                            resultNode.style.opacity = '1';\n                            resultNode.style.transform = 'scale(1) translateX(0)';\n                            resultNode.classList.add('highlight');\n                            \n                            setTimeout(() => {\n                                resultNode.classList.remove('highlight');\n                                resultNode.style.background = 'var(--accent)';\n                                \n                                // Process outgoing edges\n                                const edges = graph[node] || [];\n                                edges.forEach(dest => {\n                                    const edge = document.getElementById(`edge-${node}-${dest}`);\n                                    edge.style.background = 'var(--accent)';\n                                    \n                                    inDegree[dest]--;\n                                    if (inDegree[dest] === 0) {\n                                        queue.push(dest);\n                                        \n                                        // Highlight next available nodes\n                                        const nextNode = document.getElementById(`node-${dest}`);\n                                        nextNode.style.boxShadow = '0 0 0 5px rgba(79, 209, 197, 0.5)';\n                                    }\n                                });\n\n                                // Mark current node as completed\n                                nodeElement.style.background = 'var(--accent)';\n                                nodeElement.style.transform = 'scale(1)';\n\n                                // Process next node\n                                setTimeout(processNext, 800);\n                            }, 300);\n                        }, 50);\n                    }, 500);\n                }\n\n                // Start animation sequence\n                setTimeout(() => {\n                    resultSequence.style.opacity = '1';\n                    resultSequence.style.transform = 'translateX(0)';\n                    processNext();\n                }, 300);\n            }\n\n            // Event listeners\n            sortBtn.addEventListener('click', topologicalSort);\n            resetBtn.addEventListener('click', () => {\n                renderGraph();\n                sortBtn.disabled = false;\n                resetBtn.disabled = false;\n            });\n\n            // Initial render\n            renderGraph();\n\n            // Animate the subtitle\n            setTimeout(() => {\n                document.querySelector('.subtitle').style.transform = 'translateY(0)';\n                document.querySelector('.subtitle').style.opacity = '1';\n            }, 700);\n        });\n    </script>\n</body>\n</html>"
