    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Overfitting: A Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n            --warning: #fdcb6e;\n            --danger: #e17055;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background-color: var(--light);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n            line-height: 1.6;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            background: linear-gradient(135deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .visualization-container {\n            display: flex;\n            flex-direction: column;\n            gap: 3rem;\n            margin-top: 4rem;\n        }\n\n        .chart-section {\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);\n            padding: 2rem;\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .chart-section:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n        }\n\n        .section-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 1.5rem;\n        }\n\n        .section-title {\n            font-size: 1.8rem;\n            font-weight: 500;\n            color: var(--primary);\n        }\n\n        .section-description {\n            color: #666;\n            margin-bottom: 2rem;\n            line-height: 1.7;\n        }\n\n        .chart {\n            height: 400px;\n            position: relative;\n            margin: 0 auto;\n        }\n\n        .chart-svg {\n            width: 100%;\n            height: 100%;\n        }\n\n        .data-point {\n            fill: var(--primary);\n            stroke: white;\n            stroke-width: 2;\n            transition: all 0.3s ease;\n        }\n\n        .data-point:hover {\n            fill: var(--accent);\n            transform: scale(1.2);\n        }\n\n        .line {\n            stroke: var(--primary);\n            stroke-width: 3;\n            fill: none;\n            stroke-linecap: round;\n        }\n\n        .overfit-line {\n            stroke: var(--accent);\n            stroke-width: 3;\n            fill: none;\n            stroke-linecap: round;\n            stroke-dasharray: 1000;\n            stroke-dashoffset: 1000;\n            animation: dash 2s ease-out forwards;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        .btn {\n            padding: 0.8rem 1.8rem;\n            border-radius: 50px;\n            border: none;\n            font-size: 1rem;\n            font-weight: 500;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        .btn-primary {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n        }\n\n        .btn-outline {\n            background: transparent;\n            border: 2px solid var(--primary);\n            color: var(--primary);\n        }\n\n        .btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        .explanation {\n            margin-top: 4rem;\n            background: white;\n            border-radius: 16px;\n            padding: 2rem;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1.5rem;\n            font-size: 2rem;\n            font-weight: 500;\n        }\n\n        .explanation p {\n            margin-bottom: 1.5rem;\n            line-height: 1.7;\n        }\n\n        .highlight {\n            background: linear-gradient(120deg, rgba(108, 92, 231, 0.2), rgba(108, 92, 231, 0));\n            padding: 0.2rem 0.5rem;\n            border-radius: 4px;\n            font-weight: 500;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem;\n            color: #666;\n            font-size: 0.9rem;\n        }\n\n        /* Animations */\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes dash {\n            to {\n                stroke-dashoffset: 0;\n            }\n        }\n\n        .ripple {\n            position: absolute;\n            border-radius: 50%;\n            background: rgba(108, 92, 231, 0.3);\n            transform: scale(0);\n            animation: ripple 1.5s ease-out;\n            pointer-events: none;\n        }\n\n        @keyframes ripple {\n            to {\n                transform: scale(4);\n                opacity: 0;\n            }\n        }\n\n        /* Responsive */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .chart {\n                height: 300px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>The Art of Overfitting</h1>\n            <p class=\"subtitle\">A visual exploration of how models can become too complex, capturing noise instead of signal</p>\n        </header>\n\n        <div class=\"visualization-container\">\n            <div class=\"chart-section\">\n                <div class=\"section-header\">\n                    <h2 class=\"section-title\">Ideal Fit</h2>\n                </div>\n                <p class=\"section-description\">\n                    A well-generalized model that captures the underlying pattern without being distracted by noise.\n                </p>\n                <div class=\"chart\" id=\"ideal-chart\">\n                    <svg class=\"chart-svg\" viewBox=\"0 0 800 400\" preserveAspectRatio=\"xMidYMid meet\">\n                        <!-- Background grid -->\n                        <defs>\n                            <pattern id=\"grid\" width=\"100\" height=\"100\" patternUnits=\"userSpaceOnUse\">\n                                <path d=\"M 100 0 L 0 0 0 100\" fill=\"none\" stroke=\"#eee\" stroke-width=\"1\" />\n                            </pattern>\n                        </defs>\n                        <rect width=\"100%\" height=\"100%\" fill=\"url(#grid)\" />\n                        \n                        <!-- Data points -->\n                        <circle class=\"data-point\" cx=\"100\" cy=\"350\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"150\" cy=\"320\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"200\" cy=\"280\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"250\" cy=\"250\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"300\" cy=\"220\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"350\" cy=\"200\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"400\" cy=\"180\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"450\" cy=\"160\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"500\" cy=\"150\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"550\" cy=\"160\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"600\" cy=\"180\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"650\" cy=\"200\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"700\" cy=\"230\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"750\" cy=\"270\" r=\"6\" />\n                        \n                        <!-- Ideal fit line -->\n                        <path class=\"line\" d=\"M 50 370 Q 250 250, 450 150 Q 650 200, 750 250\" />\n                    </svg>\n                </div>\n            </div>\n\n            <div class=\"chart-section\">\n                <div class=\"section-header\">\n                    <h2 class=\"section-title\">Overfit Model</h2>\n                </div>\n                <p class=\"section-description\">\n                    A model that has memorized the training data perfectly, including all the noise and outliers.\n                </p>\n                <div class=\"chart\" id=\"overfit-chart\">\n                    <svg class=\"chart-svg\" viewBox=\"0 0 800 400\" preserveAspectRatio=\"xMidYMid meet\">\n                        <!-- Background grid -->\n                        <rect width=\"100%\" height=\"100%\" fill=\"url(#grid)\" />\n                        \n                        <!-- Same data points -->\n                        <circle class=\"data-point\" cx=\"100\" cy=\"350\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"150\" cy=\"320\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"200\" cy=\"280\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"250\" cy=\"250\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"300\" cy=\"220\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"350\" cy=\"200\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"400\" cy=\"180\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"450\" cy=\"160\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"500\" cy=\"150\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"550\" cy=\"160\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"600\" cy=\"180\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"650\" cy=\"200\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"700\" cy=\"230\" r=\"6\" />\n                        <circle class=\"data-point\" cx=\"750\" cy=\"270\" r=\"6\" />\n                        \n                        <!-- Overfit line -->\n                        <path class=\"overfit-line\" d=\"M 50 370 \n                            Q 100 350, 150 320 \n                            Q 200 280, 250 250 \n                            Q 300 220, 350 200 \n                            Q 400 180, 450 160 \n                            Q 500 150, 550 160 \n                            Q 600 180, 650 200 \n                            Q 700 230, 750 270\" />\n                    </svg>\n                </div>\n            </div>\n\n            <div class=\"controls\">\n                <button class=\"btn btn-primary\" id=\"animate-btn\">Animate Comparison</button>\n                <button class=\"btn btn-outline\" id=\"reset-btn\">Reset</button>\n            </div>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>Understanding Overfitting</h2>\n            <p>\n                <span class=\"highlight\">Overfitting</span> occurs when a machine learning model learns the training data too well, including its noise and outliers, \n                resulting in poor performance on new, unseen data. It's like memorizing answers instead of understanding concepts.\n            </p>\n            <p>\n                The overfit model above perfectly passes through every training point, but its complex, wiggly shape suggests it's capturing random \n                fluctuations rather than the true underlying pattern. In contrast, the well-generalized model captures the essential trend while \n                remaining smooth and simple.\n            </p>\n            <p>\n                Techniques to prevent overfitting include using more training data, applying regularization, simplifying the model architecture, \n                and employing cross-validation. The goal is to find the sweet spot between underfitting and overfitting.\n            </p>\n        </div>\n    </div>\n\n    <footer>\n        <p>A visual demonstration of overfitting in machine learning | Designed for aesthetic appreciation</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const animateBtn = document.getElementById('animate-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            const overfitLine = document.querySelector('.overfit-line');\n            \n            // Create ripple effect on button click\n            function createRipple(event) {\n                const btn = event.currentTarget;\n                const rect = btn.getBoundingClientRect();\n                const x = event.clientX - rect.left;\n                const y = event.clientY - rect.top;\n                \n                const ripple = document.createElement('span');\n                ripple.classList.add('ripple');\n                ripple.style.left = `${x}px`;\n                ripple.style.top = `${y}px`;\n                \n                btn.appendChild(ripple);\n                \n                setTimeout(() => {\n                    ripple.remove();\n                }, 1500);\n            }\n            \n            animateBtn.addEventListener('click', function(e) {\n                createRipple(e);\n                \n                // Reset animation\n                overfitLine.style.strokeDasharray = '1000';\n                overfitLine.style.strokeDashoffset = '1000';\n                \n                // Trigger reflow\n                void overfitLine.offsetWidth;\n                \n                // Animate\n                overfitLine.style.animation = 'dash 2s ease-out forwards';\n                \n                // Highlight data points\n                const dataPoints = document.querySelectorAll('.data-point');\n                dataPoints.forEach((point, index) => {\n                    setTimeout(() => {\n                        point.style.fill = 'var(--accent)';\n                        point.style.transform = 'scale(1.3)';\n                        \n                        setTimeout(() => {\n                            point.style.fill = 'var(--primary)';\n                            point.style.transform = 'scale(1)';\n                        }, 500);\n                    }, index * 100);\n                });\n            });\n            \n            resetBtn.addEventListener('click', function(e) {\n                createRipple(e);\n                \n                // Reset animation\n                overfitLine.style.animation = 'none';\n                overfitLine.style.strokeDasharray = '1000';\n                overfitLine.style.strokeDashoffset = '1000';\n                \n                // Reset data points\n                const dataPoints = document.querySelectorAll('.data-point');\n                dataPoints.forEach(point => {\n                    point.style.fill = 'var(--primary)';\n                    point.style.transform = 'scale(1)';\n                });\n            });\n            \n            // Add hover effect to data points\n            const dataPoints = document.querySelectorAll('.data-point');\n            dataPoints.forEach(point => {\n                point.addEventListener('mouseenter', function() {\n                    this.style.fill = 'var(--accent)';\n                    this.style.transform = 'scale(1.3)';\n                });\n                \n                point.addEventListener('mouseleave', function() {\n                    this.style.fill = 'var(--primary)';\n                    this.style.transform = 'scale(1)';\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
