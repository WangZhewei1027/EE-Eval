    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Time Complexity</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n        }\n        \n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        \n        .header h1 {\n            font-size: 24px;\n            font-weight: bold;\n            margin-bottom: 10px;\n        }\n        \n        .controls {\n            margin-top: 20px;\n        }\n        \n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n            margin-bottom: 10px;\n        }\n        \n        .slider {\n            width: 100%;\n            height: 10px;\n            margin-bottom: 10px;\n        }\n        \n        .input-field {\n            width: 100%;\n            height: 10px;\n            margin-bottom: 10px;\n            padding: 5px;\n        }\n        \n        .button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Time Complexity</h1>\n        </div>\n        <div class=\"controls\">\n            <div class=\"button\">\n                <button id=\"start-button\">Start</button>\n            </div>\n            <div class=\"button\">\n                <button id=\"stop-button\">Stop</button>\n            </div>\n            <div class=\"button\">\n                <button id=\"reset-button\">Reset</button>\n            </div>\n            <div class=\"slider\">\n                <input type=\"range\" id=\"duration-slider\" min=\"1\" max=\"100\" value=\"10\">\n                <label for=\"duration-slider\">Duration (s)</label>\n            </div>\n            <div class=\"input-field\">\n                <input type=\"text\" id=\"time-input\" placeholder=\"Enter time in seconds\">\n            </div>\n            <div class=\"button\">\n                <button id=\"calculate-button\">Calculate</button>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        let startButton = document.getElementById('start-button');\n        let stopButton = document.getElementById('stop-button');\n        let resetButton = document.getElementById('reset-button');\n        let durationSlider = document.getElementById('duration-slider');\n        let timeInput = document.getElementById('time-input');\n        let calculateButton = document.getElementById('calculate-button');\n        \n        let duration = 10;\n        let time = 0;\n        \n        startButton.addEventListener('click', start);\n        stopButton.addEventListener('click', stop);\n        resetButton.addEventListener('click', reset);\n        \n        function start() {\n            startButton.disabled = true;\n            stopButton.disabled = false;\n            calculateButton.disabled = false;\n            durationSlider.disabled = false;\n            timeInput.disabled = false;\n            calculateButton.style.backgroundColor = 'green';\n        }\n        \n        function stop() {\n            startButton.disabled = false;\n            stopButton.disabled = true;\n            calculateButton.disabled = true;\n            durationSlider.disabled = true;\n            timeInput.disabled = true;\n            calculateButton.style.backgroundColor = 'red';\n        }\n        \n        function reset() {\n            startButton.disabled = true;\n            stopButton.disabled = false;\n            calculateButton.disabled = false;\n            durationSlider.disabled = false;\n            timeInput.disabled = false;\n            calculateButton.style.backgroundColor = 'green';\n            duration = 10;\n            time = 0;\n            startButton.disabled = false;\n            stopButton.disabled = true;\n            calculateButton.disabled = true;\n        }\n        \n        function calculate() {\n            time = duration * time;\n            timeInput.value = time;\n            calculateButton.style.backgroundColor = 'green';\n        }\n        \n        durationSlider.addEventListener('input', calculate);\n        timeInput.addEventListener('input', calculate);\n    </script>\n</body>\n</html>"
