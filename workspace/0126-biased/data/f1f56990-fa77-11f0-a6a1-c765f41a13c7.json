    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Suffix Tree — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071126;\n      --glass: rgba(255,255,255,0.06);\n      --muted: rgba(255,255,255,0.65);\n      --accent-1: #7c5cff;\n      --accent-2: #00d4ff;\n      --accent-3: #ff7ac6;\n      --glass-2: rgba(255,255,255,0.03);\n      --card-border: rgba(255,255,255,0.06);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;\n      background: radial-gradient(1200px 700px at 10% 10%, rgba(124,92,255,0.12), transparent 8%),\n                  radial-gradient(900px 500px at 90% 90%, rgba(0,212,255,0.06), transparent 10%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color: #e8f0ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Decorative animated aurora */\n    .aurora{\n      position:fixed;\n      inset: -10% -10% auto auto;\n      width:70vmax;\n      height:70vmax;\n      filter: blur(60px) saturate(120%);\n      opacity:0.14;\n      transform: rotate(-20deg);\n      pointer-events:none;\n      background: conic-gradient(from 180deg at 50% 50%, rgba(124,92,255,0.16), rgba(0,212,255,0.12), rgba(255,122,198,0.08), rgba(124,92,255,0.16));\n      mix-blend-mode:screen;\n      animation: float 12s ease-in-out infinite;\n    }\n    @keyframes float{\n      0%{transform:rotate(-18deg) translateY(0)}\n      50%{transform:rotate(-22deg) translateY(-18px)}\n      100%{transform:rotate(-18deg) translateY(0)}\n    }\n\n    .wrap{\n      display:grid;\n      grid-template-columns: 480px 1fr;\n      gap:28px;\n      align-items:center;\n      height:100vh;\n      padding:48px;\n      max-width:1250px;\n      margin:0 auto;\n    }\n\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));\n      border: 1px solid var(--card-border);\n      border-radius:18px;\n      padding:28px;\n      box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(8px) saturate(120%);\n      min-height:420px;\n      display:flex;\n      flex-direction:column;\n      justify-content:space-between;\n      position:relative;\n    }\n\n    /* Left panel */\n    .title{\n      display:flex;\n      gap:18px;\n      align-items:center;\n      margin-bottom:6px;\n    }\n    .logo{\n      width:66px;\n      height:66px;\n      border-radius:12px;\n      background: linear-gradient(135deg,var(--accent-1),var(--accent-2));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color:white;\n      font-weight:800;\n      font-family:\"JetBrains Mono\", monospace;\n      font-size:20px;\n      box-shadow: 0 6px 20px rgba(124,92,255,0.18), 0 1px 0 rgba(255,255,255,0.04) inset;\n    }\n    h1{\n      margin:0;\n      font-size:20px;\n      line-height:1;\n      letter-spacing:-0.2px;\n      font-weight:800;\n    }\n    p.lead{\n      margin:10px 0 0 0;\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n      max-width:420px;\n    }\n\n    .meta{\n      display:flex;\n      gap:12px;\n      margin-top:18px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    .chip{\n      padding:8px 12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border-radius:999px;\n      border:1px solid rgba(255,255,255,0.03);\n      font-weight:600;\n      font-size:13px;\n      color: #fff;\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n    }\n    .chip .mono{\n      font-family:\"JetBrains Mono\", monospace;\n      font-weight:600;\n      background: linear-gradient(90deg,var(--accent-2),var(--accent-1));\n      -webkit-background-clip:text;\n      background-clip:text;\n      color:transparent;\n      font-size:13px;\n    }\n\n    .desc{\n      margin-top:18px;\n      font-size:13px;\n      color:var(--muted);\n      line-height:1.6;\n    }\n\n    .controls{\n      margin-top:22px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      padding:10px 16px;\n      border-radius:10px;\n      border:0;\n      cursor:pointer;\n      font-weight:700;\n      color:white;\n      background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\n      box-shadow: 0 8px 30px rgba(124,92,255,0.18);\n      transition:transform .22s cubic-bezier(.2,.9,.2,1), box-shadow .22s;\n    }\n    .btn:active{transform:translateY(1px)}\n    .btn.secondary{\n      background:transparent;\n      color:var(--muted);\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow:none;\n      font-weight:600;\n    }\n\n    .legend{\n      margin-top:18px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    /* Right panel: dazzling SVG area */\n    .visual{\n      position:relative;\n      min-height:420px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:28px;\n    }\n    .canvas{\n      width:100%;\n      height:100%;\n      border-radius:16px;\n      overflow:visible;\n      position:relative;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    /* Subtitle overlay */\n    .aside{\n      position:absolute;\n      right:34px;\n      top:32px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:10px;\n      padding:10px 14px;\n      backdrop-filter: blur(6px);\n      border:1px solid rgba(255,255,255,0.03);\n      color:var(--muted);\n      font-size:13px;\n      display:flex;\n      gap:10px;\n      align-items:center;\n      box-shadow: 0 6px 26px rgba(2,6,23,0.5);\n    }\n\n    /* SVG styling */\n    svg{width:100%; height:100%}\n    .node{\n      transform-origin:center;\n      transition:transform .6s cubic-bezier(.2,.9,.2,1), opacity .4s;\n    }\n    .node.core{\n      fill: url(#nodeGradient);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1;\n      filter: drop-shadow(0 8px 24px rgba(2,6,23,0.6));\n    }\n    .node.leaf{\n      fill: linear-gradient(90deg,#ffffff, #ffffff);\n    }\n\n    .edge{\n      fill:none;\n      stroke:rgba(255,255,255,0.15);\n      stroke-width:2.2;\n      stroke-linecap:round;\n      stroke-linejoin:round;\n      transition: stroke-dashoffset .9s cubic-bezier(.2,.9,.2,1), opacity .6s;\n      opacity:0.9;\n    }\n    .edge.dim{\n      stroke:rgba(255,255,255,0.06);\n      opacity:0.5;\n    }\n    .edge.revealed{\n      stroke: url(#edgeGradient);\n      stroke-width:3.6;\n      opacity:1;\n    }\n\n    .label{\n      font-family:\"JetBrains Mono\", monospace;\n      font-size:12px;\n      fill:#021225;\n      font-weight:600;\n      pointer-events:none;\n      opacity:0;\n      transition:opacity .5s ease .05s, transform .6s cubic-bezier(.2,.9,.2,1);\n      transform:translateY(8px) scale(.98);\n    }\n    .label.bg{\n      fill: rgba(255,255,255,0.95);\n    }\n\n    .chip-label{\n      font-family:Inter,system-ui;\n      font-size:12px;\n      fill:#fff;\n      font-weight:700;\n      letter-spacing:-0.2px;\n      opacity:0;\n      transition:opacity .36s ease .05s, transform .6s cubic-bezier(.2,.9,.2,1);\n      transform:translateY(6px) scale(.98);\n    }\n\n    .leaf-chip{\n      fill: rgba(255,255,255,0.96);\n      rx:8;\n      filter: drop-shadow(0 6px 18px rgba(2,6,23,0.5));\n      opacity:0;\n      transform-origin:center;\n      transition:opacity .38s ease .05s, transform .6s cubic-bezier(.2,.9,.2,1);\n      transform:translateY(6px) scale(.98);\n    }\n\n    /* When played - reveal classes will animate */\n    .reveal .edge{ opacity:0.12 }\n    .reveal .edge.show-1.revealed,\n    .reveal .edge.show-2.revealed,\n    .reveal .edge.show-3.revealed,\n    .reveal .edge.show-4.revealed,\n    .reveal .edge.show-5.revealed,\n    .reveal .edge.show-6.revealed,\n    .reveal .edge.show-7.revealed,\n    .reveal .edge.show-8.revealed{\n      opacity:1;\n    }\n    .reveal .label.show{ opacity:1; transform:translateY(0) scale(1) }\n    .reveal .chip-label.show{ opacity:1; transform:translateY(0) scale(1) }\n    .reveal .leaf-chip.show{ opacity:1; transform:translateY(0) scale(1) }\n    .reveal .node.core.show{ transform:scale(1); opacity:1 }\n    .node.core{ transform:scale(.88); opacity:0.92 }\n\n    /* footer small */\n    .credits{\n      font-size:12px;\n      color:var(--muted);\n      margin-top:20px;\n    }\n\n    /* responsiveness */\n    @media (max-width:1060px){\n      .wrap{grid-template-columns: 1fr; padding:28px; gap:18px}\n      .aside{right:20px; top:16px}\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"aurora\" aria-hidden=\"true\"></div>\n  <div class=\"wrap\" role=\"main\" aria-labelledby=\"main-title\">\n    <div class=\"card\" aria-hidden=\"false\">\n      <div>\n        <div class=\"title\">\n          <div class=\"logo\">ST</div>\n          <div>\n            <h1 id=\"main-title\">Suffix Tree — Visual Concept</h1>\n            <p class=\"lead\">A compact structure representing all suffixes of a string. This elegant visualization presents the suffix tree for <span class=\"mono\">\"banana$\"</span> with labeled edges and leaves.</p>\n          </div>\n        </div>\n\n        <div class=\"meta\" aria-hidden=\"true\">\n          <div class=\"chip\">\n            Example string\n            <span class=\"mono\">banana$</span>\n          </div>\n          <div class=\"chip\">\n            Leaves\n            <span style=\"opacity:0.85; font-weight:600; font-family:JetBrains Mono, monospace; background:linear-gradient(90deg,var(--accent-2),var(--accent-1)); -webkit-background-clip:text; color:transparent\">7</span>\n          </div>\n        </div>\n\n        <div class=\"desc\">\n          - The root branches into edges beginning with distinct first characters: b, a, n and the terminal $.<br>\n          - Paths are compressed: edge labels show substrings. Leaves correspond to suffixes: <span class=\"mono\">banana$, anana$, nana$, ana$, na$, a$, $</span>.<br>\n          - Press \"Animate\" to reveal the tree step-by-step; observe how common prefixes are shared.\n        </div>\n\n        <div class=\"controls\" style=\"margin-top:18px;\">\n          <button id=\"playBtn\" class=\"btn\" aria-pressed=\"false\">Animate</button>\n          <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset view\">Reset</button>\n        </div>\n\n        <div class=\"legend\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"flex:0 0 auto\">\n            <defs><linearGradient id=\"mini\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7c5cff\"/><stop offset=\"1\" stop-color=\"#00d4ff\"/></linearGradient></defs>\n            <path d=\"M2 12s4-8 10-8 10 8 10 8-4 8-10 8S2 12 2 12z\" fill=\"url(#mini)\"></path>\n          </svg>\n          <div style=\"color:var(--muted);\">Edges labeled with substrings • Leaves show full suffix</div>\n        </div>\n      </div>\n\n      <div style=\"display:flex; align-items:center; justify-content:space-between;\">\n        <div class=\"credits\">Aesthetic algorithmic visualization — minimal controls. Built for clarity and elegance.</div>\n        <div style=\"color:var(--muted); font-size:12px;\">Suffix tree for \"banana$\"</div>\n      </div>\n    </div>\n\n    <div class=\"visual\">\n      <div class=\"canvas\" role=\"img\" aria-label=\"Visual representation of a suffix tree for 'banana$'\">\n        <svg viewBox=\"0 0 900 520\" preserveAspectRatio=\"xMidYMid meet\" id=\"svgRoot\">\n          <defs>\n            <linearGradient id=\"edgeGradient\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n            </linearGradient>\n            <linearGradient id=\"nodeGradient\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n            </linearGradient>\n\n            <filter id=\"soft\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"blur\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"blur\" mode=\"normal\"/>\n            </filter>\n          </defs>\n\n          <!-- Subtle grid lines -->\n          <g opacity=\"0.03\" transform=\"translate(0,0)\">\n            <path d=\"M140 0 L140 520\" stroke=\"#fff\" stroke-width=\"1\" />\n            <path d=\"M420 0 L420 520\" stroke=\"#fff\" stroke-width=\"1\" />\n            <path d=\"M700 0 L700 520\" stroke=\"#fff\" stroke-width=\"1\" />\n          </g>\n\n          <!-- Root -->\n          <g id=\"root\" transform=\"translate(120,260)\" class=\"node core\" aria-hidden=\"true\">\n            <circle cx=\"0\" cy=\"0\" r=\"18\" />\n            <text x=\"0\" y=\"6\" text-anchor=\"middle\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\" font-size=\"12\" fill=\"rgba(255,255,255,0.98)\">R</text>\n          </g>\n\n          <!-- Internal nodes -->\n          <g id=\"nodeA\" transform=\"translate(420,190)\" class=\"node core\">\n            <circle cx=\"0\" cy=\"0\" r=\"14\" />\n            <text x=\"0\" y=\"5\" text-anchor=\"middle\" font-family=\"JetBrains Mono,monospace\" font-size=\"11\" fill=\"rgba(255,255,255,0.98)\">•</text>\n          </g>\n\n          <g id=\"nodeB\" transform=\"translate(420,320)\" class=\"node core\">\n            <circle cx=\"0\" cy=\"0\" r=\"14\" />\n            <text x=\"0\" y=\"5\" text-anchor=\"middle\" font-family=\"JetBrains Mono,monospace\" font-size=\"11\" fill=\"rgba(255,255,255,0.98)\">•</text>\n          </g>\n\n          <!-- Leaves -->\n          <g id=\"leafB\" transform=\"translate(420,80)\" class=\"node leaf\" aria-hidden=\"true\">\n            <rect x=\"-46\" y=\"-14\" width=\"92\" height=\"28\" rx=\"8\" class=\"leaf-chip\"/>\n            <text class=\"chip-label\" x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"#021225\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\">#1 banana$</text>\n          </g>\n\n          <g id=\"leafDollarRoot\" transform=\"translate(420,440)\" class=\"node leaf\" aria-hidden=\"true\">\n            <rect x=\"-28\" y=\"-12\" width=\"56\" height=\"24\" rx=\"8\" class=\"leaf-chip\"/>\n            <text class=\"chip-label\" x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"#021225\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\">#7 $</text>\n          </g>\n\n          <g id=\"leafA1\" transform=\"translate(680,300)\" class=\"node leaf\">\n            <rect x=\"-52\" y=\"-14\" width=\"104\" height=\"28\" rx=\"8\" class=\"leaf-chip\"/>\n            <text class=\"chip-label\" x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"#021225\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\">#2 anana$</text>\n          </g>\n\n          <g id=\"leafA2\" transform=\"translate(680,360)\" class=\"node leaf\">\n            <rect x=\"-36\" y=\"-12\" width=\"72\" height=\"24\" rx=\"8\" class=\"leaf-chip\"/>\n            <text class=\"chip-label\" x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"#021225\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\">#6 a$</text>\n          </g>\n\n          <g id=\"leafN1\" transform=\"translate(680,150)\" class=\"node leaf\">\n            <rect x=\"-56\" y=\"-14\" width=\"112\" height=\"28\" rx=\"8\" class=\"leaf-chip\"/>\n            <text class=\"chip-label\" x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"#021225\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\">#3 nana$</text>\n          </g>\n\n          <g id=\"leafN2\" transform=\"translate(680,210)\" class=\"node leaf\">\n            <rect x=\"-36\" y=\"-12\" width=\"72\" height=\"24\" rx=\"8\" class=\"leaf-chip\"/>\n            <text class=\"chip-label\" x=\"0\" y=\"6\" text-anchor=\"middle\" fill=\"#021225\" font-family=\"JetBrains Mono,monospace\" font-weight=\"700\">#5 na$</text>\n          </g>\n\n          <!-- Edges from root -->\n          <g id=\"edges\">\n            <!-- root -> leaf b (banana$) edge 1 -->\n            <path id=\"e1\" class=\"edge show-1\" d=\"M138 260 C210 190 360 140 420 80\" />\n\n            <!-- root -> nodeA (na) edge 2 -->\n            <path id=\"e2\" class=\"edge show-2\" d=\"M138 260 C210 210 360 200 420 190\" />\n\n            <!-- root -> nodeB (a) edge 3 -->\n            <path id=\"e3\" class=\"edge show-3\" d=\"M138 260 C210 330 360 320 420 320\" />\n\n            <!-- root -> $ leaf edge 4 -->\n            <path id=\"e4\" class=\"edge show-4\" d=\"M138 260 C210 360 360 420 420 440\" />\n\n            <!-- nodeA -> leafN1 (na$) edge 5 -->\n            <path id=\"e5\" class=\"edge show-5\" d=\"M420 190 C520 160 600 155 680 150\" />\n\n            <!-- nodeA -> leafN2 ($) edge 6 -->\n            <path id=\"e6\" class=\"edge show-6\" d=\"M420 190 C520 200 600 210 680 210\" />\n\n            <!-- nodeB -> leafA1 (na$) edge 7 -->\n            <path id=\"e7\" class=\"edge show-7\" d=\"M420 320 C520 300 600 300 680 300\" />\n\n            <!-- nodeB -> leafA2 ($) edge 8 -->\n            <path id=\"e8\" class=\"edge show-8\" d=\"M420 320 C520 360 600 360 680 360\" />\n          </g>\n\n          <!-- Edge labels (placed manually near midpoints) -->\n          <g id=\"labels\">\n            <g transform=\"translate(330,140)\">\n              <rect x=\"-52\" y=\"-18\" width=\"104\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\" style=\"filter: drop-shadow(0 6px 16px rgba(2,6,23,0.6));\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">banana$</text>\n            </g>\n\n            <g transform=\"translate(300,210)\">\n              <rect x=\"-34\" y=\"-14\" width=\"68\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">na</text>\n            </g>\n\n            <g transform=\"translate(300,320)\">\n              <rect x=\"-18\" y=\"-14\" width=\"36\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">a</text>\n            </g>\n\n            <g transform=\"translate(340,420)\">\n              <rect x=\"-10\" y=\"-12\" width=\"20\" height=\"24\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">$</text>\n            </g>\n\n            <g transform=\"translate(560,150)\">\n              <rect x=\"-36\" y=\"-14\" width=\"72\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">na$</text>\n            </g>\n\n            <g transform=\"translate(560,210)\">\n              <rect x=\"-18\" y=\"-14\" width=\"36\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">$</text>\n            </g>\n\n            <g transform=\"translate(560,300)\">\n              <rect x=\"-36\" y=\"-14\" width=\"72\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">na$</text>\n            </g>\n\n            <g transform=\"translate(560,360)\">\n              <rect x=\"-18\" y=\"-14\" width=\"36\" height=\"28\" rx=\"8\" fill=\"#fff\" opacity=\"0.96\" class=\"label-bg\"></rect>\n              <text class=\"label\" x=\"0\" y=\"6\" text-anchor=\"middle\">$</text>\n            </g>\n\n          </g>\n        </svg>\n\n        <div class=\"aside\" aria-hidden=\"true\">\n          <div style=\"width:10px; height:10px; border-radius:3px; background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\"></div>\n          <div style=\"font-weight:700\">Compressed edges</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const svgRoot = document.getElementById('svgRoot');\n      const paths = Array.from(svgRoot.querySelectorAll('.edge'));\n      const labels = Array.from(svgRoot.querySelectorAll('.label'));\n      const chips = Array.from(svgRoot.querySelectorAll('.chip-label'));\n      const leafChips = Array.from(svgRoot.querySelectorAll('.leaf-chip'));\n      const nodes = Array.from(svgRoot.querySelectorAll('.node.core'));\n\n      // Prepare path stroke-dasharray using lengths\n      paths.forEach(p => {\n        const len = p.getTotalLength();\n        p.style.strokeDasharray = len;\n        p.style.strokeDashoffset = len;\n        p.style.opacity = 0.6;\n      });\n\n      // initial state: hide labels and chip text and leaf chips and nodes scaled\n      labels.forEach(l => { l.style.opacity = 0; l.style.transform = 'translateY(8px) scale(.98)'; });\n      chips.forEach(c => { c.style.opacity = 0; c.style.transform = 'translateY(6px) scale(.98)'; });\n      leafChips.forEach(c => { c.style.opacity = 0; c.style.transform = 'translateY(6px) scale(.98)'; });\n      nodes.forEach(n => { n.classList.remove('show'); n.style.transform = 'scale(.88)'; });\n\n      let playing = false;\n      let timers = [];\n\n      function clearTimers(){\n        timers.forEach(t => clearTimeout(t));\n        timers = [];\n      }\n\n      function animate(){\n        if(playing) return;\n        playing = true;\n        playBtn.setAttribute('aria-pressed','true');\n        playBtn.textContent = 'Animating…';\n        svgRoot.classList.add('reveal');\n\n        // Sequence: reveal edges 1..8 with delays\n        const seq = [\n          {pathId:'e1', labelIndex:0, nodeIds: ['leafB']},\n          {pathId:'e2', labelIndex:1, nodeIds: ['nodeA']},\n          {pathId:'e5', labelIndex:4, nodeIds: ['leafN1']},\n          {pathId:'e6', labelIndex:5, nodeIds: ['leafN2']},\n          {pathId:'e3', labelIndex:2, nodeIds: ['nodeB']},\n          {pathId:'e7', labelIndex:6, nodeIds: ['leafA1']},\n          {pathId:'e8', labelIndex:7, nodeIds: ['leafA2']},\n          {pathId:'e4', labelIndex:3, nodeIds: ['leafDollarRoot']},\n        ];\n\n        let t = 0;\n        const base = 520; // base duration for stroke animation in ms per edge\n\n        seq.forEach((s, i) => {\n          const delay = t;\n          const el = svgRoot.getElementById ? svgRoot.getElementById(s.pathId) : document.getElementById(s.pathId);\n          const label = labels[s.labelIndex];\n          const nodesToShow = s.nodeIds.map(id => svgRoot.getElementById(id) || document.getElementById(id));\n          timers.push(setTimeout(()=> {\n            // animate stroke\n            el.classList.add('revealed');\n            el.style.transition = 'stroke-dashoffset .9s cubic-bezier(.2,.9,.2,1), opacity .5s';\n            el.style.strokeDashoffset = 0;\n            // show label\n            if(label){\n              label.classList.add('show');\n              label.style.opacity = 1;\n              label.style.transform = 'translateY(0) scale(1)';\n            }\n            // reveal nodes\n            nodesToShow.forEach(nid => {\n              if(!nid) return;\n              // reveal rectangle and text separately\n              const chipRect = nid.querySelector('.leaf-chip');\n              const chipText = nid.querySelector('.chip-label');\n              if(chipRect) {\n                chipRect.classList.add('show');\n                chipRect.style.opacity = 1;\n                chipRect.style.transform = 'translateY(0) scale(1)';\n              }\n              if(chipText){\n                chipText.classList.add('show');\n                chipText.style.opacity = 1;\n                chipText.style.transform = 'translateY(0) scale(1)';\n              }\n            });\n\n            // also anim root->internal node appearance\n            if(s.pathId === 'e2' || s.pathId === 'e3'){\n              // show the internal node\n              const nodeId = s.pathId === 'e2' ? 'nodeA' : 'nodeB';\n              const nodeEl = svgRoot.getElementById(nodeId);\n              if(nodeEl){\n                nodeEl.classList.add('show');\n                nodeEl.style.transform = 'scale(1)';\n                nodeEl.style.opacity = 1;\n              }\n            } else {\n              // small pulse on root for connectivity\n              const root = svgRoot.getElementById('root');\n              if(root){\n                root.style.transform = 'scale(1.02)';\n                setTimeout(()=> root.style.transform = 'scale(1)', 420);\n              }\n            }\n\n          }, delay));\n          t += 450; // spacing between reveals\n        });\n\n        // finalize\n        timers.push(setTimeout(()=> {\n          playBtn.textContent = 'Replay';\n          playing = false;\n          playBtn.setAttribute('aria-pressed','false');\n        }, t + 800));\n      }\n\n      function reset(){\n        clearTimers();\n        playing = false;\n        playBtn.textContent = 'Animate';\n        playBtn.setAttribute('aria-pressed','false');\n        svgRoot.classList.remove('reveal');\n\n        paths.forEach(p => {\n          const len = p.getTotalLength();\n          p.style.transition = 'none';\n          p.style.strokeDashoffset = len;\n          p.classList.remove('revealed');\n          p.style.opacity = 0.9;\n        });\n        labels.forEach(l => {\n          l.style.transition = 'none';\n          l.style.opacity = 0;\n          l.classList.remove('show');\n          l.style.transform = 'translateY(8px) scale(.98)';\n        });\n        chips.forEach(c => {\n          c.style.transition = 'none';\n          c.style.opacity = 0;\n          c.classList.remove('show');\n          c.style.transform = 'translateY(6px) scale(.98)';\n        });\n        leafChips.forEach(c => {\n          c.style.transition = 'none';\n          c.style.opacity = 0;\n          c.classList.remove('show');\n          c.style.transform = 'translateY(6px) scale(.98)';\n        });\n        nodes.forEach(n => {\n          n.style.transition = 'none';\n          n.classList.remove('show');\n          n.style.transform = 'scale(.88)';\n          n.style.opacity = 0.92;\n        });\n        // small timeout to re-enable transitions smoothly\n        setTimeout(() => {\n          paths.forEach(p => p.style.transition = '');\n          labels.forEach(l => l.style.transition = '');\n          chips.forEach(c => c.style.transition = '');\n          leafChips.forEach(c => c.style.transition = '');\n          nodes.forEach(n => n.style.transition = '');\n        }, 40);\n      }\n\n      playBtn.addEventListener('click', animate);\n      resetBtn.addEventListener('click', reset);\n\n      // On load, apply a gentle entrance\n      window.addEventListener('load', ()=>{\n        // slight staggered fade-in of UI elements\n        document.querySelectorAll('.card, .visual').forEach((el,i)=>{\n          el.style.opacity = 0;\n          el.style.transform = 'translateY(6px) scale(.996)';\n          setTimeout(()=> {\n            el.style.transition = 'all .9s cubic-bezier(.2,.9,.2,1)';\n            el.style.opacity = 1;\n            el.style.transform = 'translateY(0) scale(1)';\n          }, 220 + i*120);\n        });\n      });\n\n      // Ensure accessible SVG getElementById works across browsers\n      if(!svgRoot.getElementById){\n        SVGElement.prototype.getElementById = function(id){ return document.getElementById(id); };\n      }\n\n    })();\n  </script>\n</body>\n</html>"
  },
