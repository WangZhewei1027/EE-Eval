    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Cosmic Web Graph</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap');\n        \n        :root {\n            --space: #0b0d17;\n            --nebula: #641f91;\n            --star: #f3e5ff;\n            --planet: #c792ea;\n            --comet: #4fc1ff;\n            --aurora: #0dc5dd;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n            background-color: var(--space);\n            font-family: 'Orbitron', sans-serif;\n            color: var(--star);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            height: 100vh;\n        }\n        \n        header {\n            padding: 2rem;\n            text-align: center;\n            z-index: 10;\n        }\n        \n        h1 {\n            font-size: 2.5rem;\n            margin: 0;\n            background: linear-gradient(45deg, var(--comet), var(--aurora));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 0 15px rgba(79, 193, 255, 0.3);\n        }\n        \n        .subtitle {\n            font-size: 0.9rem;\n            margin-top: 0.5rem;\n            opacity: 0.8;\n            letter-spacing: 2px;\n        }\n        \n        .graph-container {\n            position: relative;\n            width: 90%;\n            height: 70%;\n            margin: auto;\n        }\n        \n        canvas {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n        }\n        \n        .controls {\n            position: absolute;\n            bottom: 2rem;\n            display: flex;\n            gap: 1rem;\n            z-index: 10;\n        }\n        \n        button {\n            background: rgba(100, 31, 145, 0.3);\n            border: 1px solid var(--nebula);\n            color: var(--star);\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-family: 'Orbitron', sans-serif;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 0 15px rgba(100, 31, 145, 0.5);\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            font-size: 0.7rem;\n        }\n        \n        button:hover {\n            background: rgba(100, 31, 145, 0.6);\n            box-shadow: 0 0 25px rgba(100, 31, 145, 0.8);\n        }\n        \n        .node-info {\n            position: absolute;\n            bottom: 5rem;\n            background: rgba(15, 15, 30, 0.8);\n            border-radius: 10px;\n            padding: 1rem;\n            max-width: 300px;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 0.5s ease;\n            backdrop-filter: blur(5px);\n            border: 1px solid var(--comet);\n        }\n        \n        .node-info.show {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        .particles {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            z-index: -1;\n        }\n        \n        .particle {\n            position: absolute;\n            background-color: var(--star);\n            border-radius: 50%;\n            opacity: 0.5;\n            animation: float linear infinite;\n        }\n        \n        @keyframes float {\n            0% { transform: translateY(0) rotate(0deg); }\n            100% { transform: translateY(-1000px) rotate(720deg); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <header>\n        <h1>GALACTIC GRAPH</h1>\n        <div class=\"subtitle\">UNDIRECTED NEBULA NETWORK</div>\n    </header>\n    \n    <div class=\"graph-container\">\n        <canvas id=\"graph\"></canvas>\n        <div class=\"node-info\" id=\"nodeInfo\">\n            <h3>NODE DATA</h3>\n            <p id=\"infoText\">Select a node to view information</p>\n        </div>\n    </div>\n    \n    <div class=\"controls\">\n        <button id=\"recenter\">Recenter Map</button>\n        <button id=\"pulse\">Pulse Network</button>\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Create star particles\n            const particlesContainer = document.getElementById('particles');\n            const particleCount = 50;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 5;\n                const posX = Math.random() * window.innerWidth;\n                const duration = Math.random() * 30 + 20;\n                const delay = Math.random() * 30;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}px`;\n                particle.style.bottom = `-${size}px`;\n                particle.style.animationDuration = `${duration}s`;\n                particle.style.animationDelay = `${delay}s`;\n                \n                particlesContainer.appendChild(particle);\n            }\n            \n            // Graph setup\n            const canvas = document.getElementById('graph');\n            const ctx = canvas.getContext('2d');\n            \n            canvas.width = canvas.offsetWidth;\n            canvas.height = canvas.offsetHeight;\n            \n            const centerX = canvas.width / 2;\n            const centerY = canvas.height / 2;\n            \n            const nodes = [];\n            const edges = [];\n            \n            // Create cosmic nodes\n            const nodeCount = 8;\n            const radius = 20;\n            const distance = Math.min(canvas.width, canvas.height) * 0.35;\n            \n            for (let i = 0; i < nodeCount; i++) {\n                const angle = (i / nodeCount) * Math.PI * 2;\n                const dx = Math.cos(angle) * distance;\n                const dy = Math.sin(angle) * distance;\n                \n                nodes.push({\n                    x: centerX + dx,\n                    y: centerY + dy,\n                    radius: radius,\n                    color: getRandomColor(),\n                    label: `NEBULA-${i+1}`,\n                    connections: getRandomConnections(nodes.length, nodeCount)\n                });\n            }\n            \n            // Create connections between nodes\n            nodes.forEach((node, i) => {\n                node.connections.forEach(connIndex => {\n                    if (!edges.some(edge => \n                        (edge.from === i && edge.to === connIndex) || \n                        (edge.from === connIndex && edge.to === i))) {\n                        edges.push({\n                            from: i,\n                            to: connIndex\n                        });\n                    }\n                });\n            });\n            \n            // Animation variables\n            let hoveredNode = null;\n            let pulseActive = false;\n            let pulseTime = 0;\n            let rotationAngle = 0;\n            \n            // Main animation loop\n            function animate() {\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n                \n                // Draw connections with glow effect\n                edges.forEach(edge => {\n                    const fromNode = nodes[edge.from];\n                    const toNode = nodes[edge.to];\n                    \n                    if (pulseActive) {\n                        const pulseIntensity = Math.sin(pulseTime * 5) * 0.5 + 0.5;\n                        \n                        // Inner glow\n                        ctx.beginPath();\n                        ctx.moveTo(fromNode.x, fromNode.y);\n                        ctx.lineTo(toNode.x, toNode.y);\n                        ctx.strokeStyle = `rgba(79, 193, 255, ${0.3 * pulseIntensity})`;\n                        ctx.lineWidth = 10;\n                        ctx.stroke();\n                        \n                        // Outer glow\n                        ctx.beginPath();\n                        ctx.moveTo(fromNode.x, fromNode.y);\n                        ctx.lineTo(toNode.x, toNode.y);\n                        ctx.strokeStyle = `rgba(13, 197, 221, ${0.2 * pulseIntensity})`;\n                        ctx.lineWidth = 30;\n                        ctx.stroke();\n                    }\n                    \n                    // Main connection line\n                    drawConnectionLine(fromNode, toNode);\n                });\n                \n                // Draw floating nodes\n                nodes.forEach(node => {\n                    drawNode(node);\n                });\n                \n                // Rotate everything slowly\n                nodes.forEach(node => {\n                    const x = node.x - centerX;\n                    const y = node.y - centerY;\n                    const rotatedX = x * Math.cos(rotationAngle) - y * Math.sin(rotationAngle);\n                    const rotatedY = x * Math.sin(rotationAngle) + y * Math.cos(rotationAngle);\n                    node.x = centerX + rotatedX;\n                    node.y = centerY + rotatedY;\n                });\n                \n                rotationAngle += 0.0005;\n                \n                if (pulseActive) {\n                    pulseTime += 0.05;\n                    if (pulseTime >= Math.PI) {\n                        pulseActive = false;\n                    }\n                }\n                \n                requestAnimationFrame(animate);\n            }\n            \n            function drawNode(node) {\n                // Node glow\n                const gradient = ctx.createRadialGradient(\n                    node.x, node.y, 0,\n                    node.x, node.y, node.radius * 2\n                );\n                \n                gradient.addColorStop(0, node.color);\n                gradient.addColorStop(0.7, 'rgba(199, 146, 234, 0.5)');\n                gradient.addColorStop(1, 'rgba(100, 31, 145, 0)');\n                \n                ctx.beginPath();\n                ctx.arc(node.x, node.y, node.radius * 2, 0, Math.PI * 2);\n                ctx.fillStyle = gradient;\n                ctx.fill();\n                \n                // Node core\n                ctx.beginPath();\n                ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);\n                ctx.fillStyle = node.color;\n                ctx.fill();\n                \n                // Label\n                if (node === hoveredNode) {\n                    ctx.font = 'bold 12px Orbitron';\n                    ctx.fillStyle = node.color;\n                    ctx.textAlign = 'center';\n                    ctx.fillText(node.label, node.x, node.y + node.radius + 20);\n                }\n            }\n            \n            function drawConnectionLine(fromNode, toNode) {\n                ctx.beginPath();\n                ctx.moveTo(fromNode.x, fromNode.y);\n                ctx.lineTo(toNode.x, toNode.y);\n                ctx.strokeStyle = 'rgba(79, 193, 255, 0.5)';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n            }\n            \n            function getRandomColor() {\n                const colors = ['#c792ea', '#4fc1ff', '#0dc5dd', '#f78c6c', '#ffcb6b'];\n                return colors[Math.floor(Math.random() * colors.length)];\n            }\n            \n            function getRandomConnections(currentIndex, totalNodes) {\n                const connCount = Math.floor(Math.random() * 3) + 1;\n                const connections = new Set();\n                \n                while (connections.size < connCount) {\n                    const randomNode = Math.floor(Math.random() * totalNodes);\n                    if (randomNode !== currentIndex) {\n                        connections.add(randomNode);\n                    }\n                }\n                \n                return Array.from(connections);\n            }\n            \n            // Handle mouse events\n            canvas.addEventListener('mousemove', (e) => {\n                const rect = canvas.getBoundingClientRect();\n                const mouseX = e.clientX - rect.left;\n                const mouseY = e.clientY - rect.top;\n                \n                hoveredNode = null;\n                \n                nodes.forEach(node => {\n                    const dx = mouseX - node.x;\n                    const dy = mouseY - node.y;\n                    const distance = Math.sqrt(dx * dx + dy * dy);\n                    \n                    if (distance < node.radius * 2) {\n                        hoveredNode = node;\n                        \n                        // Show node info\n                        const nodeInfo = document.getElementById('nodeInfo');\n                        const infoText = document.getElementById('infoText');\n                        \n                        nodeInfo.classList.add('show');\n                        infoText.innerHTML = `\n                            <span style=\"color: ${node.color}\">●</span> ${node.label}<br>\n                            Connections: ${node.connections.length}<br>\n                            Sector: ${Math.floor(Math.random() * 1000) + 1000}\n                        `;\n                    }\n                });\n                \n                if (!hoveredNode) {\n                    document.getElementById('nodeInfo').classList.remove('show');\n                }\n            });\n            \n            // Button controls\n            document.getElementById('recenter').addEventListener('click', () => {\n                rotationAngle = 0;\n            });\n            \n            document.getElementById('pulse').addEventListener('click', () => {\n                pulseActive = true;\n                pulseTime = 0;\n            });\n            \n            // Start animation\n            animate();\n            \n            // Handle resize\n            window.addEventListener('resize', () => {\n                canvas.width = canvas.offsetWidth;\n                canvas.height = canvas.offsetHeight;\n                \n                const newCenterX = canvas.width / 2;\n                const newCenterY = canvas.height / 2;\n                \n                nodes.forEach(node => {\n                    node.x = newCenterX + (node.x - centerX);\n                    node.y = newCenterY + (node.y - centerY);\n                });\n                \n                centerX = newCenterX;\n                centerY = newCenterY;\n            });\n        });\n    </script>\n</body>\n</html>"
  },
