  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bellman-Ford Algorithm Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    padding: 10px;\n    white-space: pre-wrap;\n  }\n  input[type=number] {\n    width: 4em;\n  }\n  button, input, select, label {\n    margin: 2px 4px 2px 0;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    margin-top: 6px;\n    font-family: monospace;\n  }\n  #graph-area, #output, #step-info {\n    border: 1px solid black;\n    height: 150px;\n    overflow: auto;\n    white-space: pre;\n    margin-top: 6px;\n  }\n  #control-panel > div {\n    margin-bottom: 6px;\n  }\n  #distance-table {\n    border-collapse: collapse;\n    width: 100%;\n  }\n  #distance-table td, #distance-table th {\n    border: 1px solid black;\n    padding: 2px 5px;\n    text-align: center;\n    font-family: monospace;\n  }\n</style>\n</head>\n<body>\n\n<h2>Bellman-Ford Algorithm Interactive Demo</h2>\n\n<div id=\"instruction\" style=\"max-width:600px;\">\nThe Bellman-Ford Algorithm finds shortest paths from a source vertex to all other vertices in a weighted graph.\nIt can detect negative weight cycles reachable from the source.\n\nThis demo allows you to:\n- Build your own directed weighted graph (with negative weights allowed)\n- Input the source vertex\n- Step through the algorithm iteration by iteration or run it fully\n- See the distance table updates and edge relaxation details\n- Detect negative cycles interactively\n- Reset, clear, or import/export graph + settings\n\nUse the controls below to interact.\n</div>\n\n<hr/>\n\n<div id=\"control-panel\">\n\n  <div>\n    <label for=\"vertex-count\">Number of vertices (max 20): </label>\n    <input type=\"number\" id=\"vertex-count\" min=\"1\" max=\"20\" value=\"5\" />\n    <button id=\"set-vertex-count\">Set Vertices</button>\n  </div>\n\n  <div>\n    <label for=\"edge-from\">Add edge: from</label>\n    <input type=\"number\" id=\"edge-from\" min=\"0\" max=\"19\" value=\"0\" />\n    <label for=\"edge-to\">to</label>\n    <input type=\"number\" id=\"edge-to\" min=\"0\" max=\"19\" value=\"1\" />\n    <label for=\"edge-weight\">weight</label>\n    <input type=\"number\" id=\"edge-weight\" value=\"1\" step=\"any\" />\n    <button id=\"add-edge\">Add Edge</button>\n    <button id=\"remove-edge\">Remove Edge</button>\n  </div>\n\n  <div>\n    <label for=\"source-vertex\">Source vertex: </label>\n    <input type=\"number\" id=\"source-vertex\" min=\"0\" max=\"19\" value=\"0\" />\n    <button id=\"set-source\">Set Source</button>\n  </div>\n\n  <div>\n    <button id=\"reset-algorithm\">Reset Algorithm</button>\n    <button id=\"step-forward\" disabled>Step Forward</button>\n    <button id=\"step-backward\" disabled>Step Backward</button>\n    <button id=\"run-to-end\" disabled>Run To End</button>\n  </div>\n\n  <div>\n    <label for=\"import-export-area\">Import/Export Graph + Source (JSON format):</label><br/>\n    <textarea id=\"import-export-area\" placeholder='{\"vertexCount\":5,\"edges\":[{\"from\":0,\"to\":1,\"weight\":2},...],\"source\":0}'></textarea><br/>\n    <button id=\"import-graph\">Import</button>\n    <button id=\"export-graph\">Export</button>\n    <button id=\"clear-graph\">Clear Graph</button>\n  </div>\n\n</div>\n\n<hr/>\n\n<div>\n  <b>Current Graph Edges (directed):</b>\n  <div id=\"graph-area\"></div>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <b>Algorithm Step Info:</b>\n  <div id=\"step-info\"></div>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <b>Distance Table (vertex : distance from source):</b>\n  <div id=\"distance-table-container\" style=\"overflow:auto; max-height:150px;\"></div>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <b>Algorithm Output / Messages:</b>\n  <div id=\"output\" aria-live=\"polite\"></div>\n</div>\n\n<script>\n(() => {\n  \"use strict\";\n\n  // Data structures\n  let vertexCount = 5;\n  let edges = []; // {from:number, to:number, weight:number}\n  let sourceVertex = 0;\n\n  // Bellman-Ford algorithm state for stepping\n  let distances = [];\n  let predecessors = [];\n  let stepIndex = 0; // Current relaxation step (0-based)\n  /*\n   Relaxation steps numbering:\n   Each iteration has |V|-1 relaxation rounds.\n   Each round relaxes all edges in order.\n   Total steps = (vertexCount - 1) * edges.length\n  */\n  let totalSteps = 0;\n\n  // For storing history of distance arrays for stepping backward (deep exploration)\n  let distanceHistory = [];\n  let predecessorHistory = [];\n\n  // For user messages\n  const messages = {\n    invalidVertexCount: \"Invalid vertex count. Min=1, Max=20.\",\n    invalidEdgeVertex: \"Edge vertices must be between 0 and vertexCount-1.\",\n    invalidWeight: \"Edge weight must be a valid number.\",\n    invalidSource: \"Source vertex must be between 0 and vertexCount-1.\",\n    noVertices: \"Graph must have at least one vertex.\",\n  };\n\n  // Elements references\n  const vertexCountInput = document.getElementById(\"vertex-count\");\n  const setVertexCountBtn = document.getElementById(\"set-vertex-count\");\n  const edgeFromInput = document.getElementById(\"edge-from\");\n  const edgeToInput = document.getElementById(\"edge-to\");\n  const edgeWeightInput = document.getElementById(\"edge-weight\");\n  const addEdgeBtn = document.getElementById(\"add-edge\");\n  const removeEdgeBtn = document.getElementById(\"remove-edge\");\n  const sourceVertexInput = document.getElementById(\"source-vertex\");\n  const setSourceBtn = document.getElementById(\"set-source\");\n  const resetAlgorithmBtn = document.getElementById(\"reset-algorithm\");\n  const stepForwardBtn = document.getElementById(\"step-forward\");\n  const stepBackwardBtn = document.getElementById(\"step-backward\");\n  const runToEndBtn = document.getElementById(\"run-to-end\");\n  const importExportArea = document.getElementById(\"import-export-area\");\n  const importGraphBtn = document.getElementById(\"import-graph\");\n  const exportGraphBtn = document.getElementById(\"export-graph\");\n  const clearGraphBtn = document.getElementById(\"clear-graph\");\n  const graphArea = document.getElementById(\"graph-area\");\n  const stepInfoArea = document.getElementById(\"step-info\");\n  const outputArea = document.getElementById(\"output\");\n  const distanceTableContainer = document.getElementById(\"distance-table-container\");\n\n  // Utility cloning function\n  function cloneArray(arr) {\n    if (Array.isArray(arr)) return arr.map(x => (Array.isArray(x) ? cloneArray(x) : x));\n    return arr;\n  }\n\n  // Validate inputs\n\n  function validateVertexCount(n) {\n    if (typeof n !== \"number\") return false;\n    if (!Number.isInteger(n)) return false;\n    if (n < 1 || n > 20) return false;\n    return true;\n  }\n\n  function validateVertex(v) {\n    if (typeof v !== \"number\") return false;\n    if (!Number.isInteger(v)) return false;\n    if (v < 0 || v >= vertexCount) return false;\n    return true;\n  }\n\n  function validateWeight(w) {\n    if (typeof w !== \"number\") return false;\n    if (isNaN(w) || !isFinite(w)) return false;\n    return true;\n  }\n\n  // Display Graph edges text\n  function renderGraph() {\n    if (vertexCount === 0) {\n      graphArea.textContent = \"(No vertices)\";\n      return;\n    }\n    if (edges.length === 0) {\n      graphArea.textContent = \"(No edges)\";\n      return;\n    }\n    // Sort edges by from then to for stable display\n    const sortedEdges = edges.slice().sort((a,b) => a.from - b.from || a.to - b.to);\n    let s = \"\";\n    for (let e of sortedEdges) {\n      s += `${e.from} -> ${e.to} (w=${e.weight})\\n`;\n    }\n    graphArea.textContent = s;\n  }\n\n  // Render distances table\n  function renderDistances() {\n    if (vertexCount === 0) {\n      distanceTableContainer.innerHTML = \"(No vertices)\";\n      return;\n    }\n    const createCell = (content) => `<td>${content}</td>`;\n    const rows = [];\n    rows.push(\"<tr><th>Vertex</th><th>Distance</th><th>Predecessor</th></tr>\");\n    for (let v = 0; v < vertexCount; v++) {\n      let dist = distances[v];\n      let distDisplay = dist === Infinity ? \"∞\" : dist.toFixed(4).replace(/\\.?0+$/,\"\");\n      let pred = predecessors[v];\n      let predDisplay = (typeof pred === \"number\") ? pred : \"\";\n      rows.push(`<tr>${createCell(v)}${createCell(distDisplay)}${createCell(predDisplay)}</tr>`);\n    }\n    distanceTableContainer.innerHTML = \"<table id='distance-table'>\" + rows.join(\"\") + \"</table>\";\n  }\n\n  // Initialize the graph data\n  function initializeGraph(n) {\n    vertexCount = n;\n    edges = [];\n    sourceVertex = 0;\n    // Reset inputs\n    vertexCountInput.value = vertexCount;\n    edgeFromInput.max = vertexCount - 1;\n    edgeToInput.max = vertexCount - 1;\n    sourceVertexInput.max = vertexCount - 1;\n    edgeFromInput.value = 0;\n    edgeToInput.value = 1 <= vertexCount - 1 ? 1 : 0;\n    sourceVertexInput.value = 0;\n    // Reset dist & pred and history\n    resetAlgorithmState();\n    updateAllDisplays();\n  }\n\n  // Resets algorithm state to initial with current graph and source\n  function resetAlgorithmState() {\n    distances = new Array(vertexCount).fill(Infinity);\n    predecessors = new Array(vertexCount).fill(null);\n    if (validateVertex(sourceVertex)) {\n      distances[sourceVertex] = 0;\n    }\n    stepIndex = 0;\n    distanceHistory = [];\n    predecessorHistory = [];\n\n    // Calculate total relaxation steps:\n    totalSteps = (vertexCount - 1) * edges.length;\n    enableSteppingControls(totalSteps > 0 && validateVertex(sourceVertex));\n  }\n\n  // Enable/Disable stepping controls\n  function enableSteppingControls(enabled) {\n    stepForwardBtn.disabled = !enabled;\n    runToEndBtn.disabled = !enabled;\n    stepBackwardBtn.disabled = true; // Initially backward disabled because no step done\n  }\n\n  // Add edge\n  function addEdge(f,t,w) {\n    if (!validateVertex(f) || !validateVertex(t)) {\n      showMessage(messages.invalidEdgeVertex, true);\n      return false;\n    }\n    if (!validateWeight(w)) {\n      showMessage(messages.invalidWeight, true);\n      return false;\n    }\n    // Check if edge exists - if yes, replace weight\n    let idx = edges.findIndex(e => e.from === f && e.to === t);\n    if (idx !== -1) {\n      edges[idx].weight = w;\n    } else {\n      edges.push({from:f, to:t, weight:w});\n    }\n    resetAlgorithmState();\n    updateAllDisplays();\n    showMessage(\"Edge added or updated.\");\n    return true;\n  }\n\n  // Remove edge\n  function removeEdge(f,t) {\n    if (!validateVertex(f) || !validateVertex(t)) {\n      showMessage(messages.invalidEdgeVertex, true);\n      return false;\n    }\n    let countBefore = edges.length;\n    edges = edges.filter(e => !(e.from === f && e.to === t));\n    if (edges.length < countBefore) {\n      resetAlgorithmState();\n      updateAllDisplays();\n      showMessage(\"Edge removed.\");\n      return true;\n    }\n    showMessage(\"Edge to remove not found.\", true);\n    return false;\n  }\n\n  // Set source vertex\n  function setSource(s) {\n    if (!validateVertex(s)) {\n      showMessage(messages.invalidSource, true);\n      return false;\n    }\n    sourceVertex = s;\n    resetAlgorithmState();\n    updateAllDisplays();\n    showMessage(\"Source vertex set.\");\n    return true;\n  }\n\n  // Show message (with error flag)\n  function showMessage(msg, isError = false) {\n    outputArea.textContent = msg;\n    // No special styling so just plain text\n  }\n\n  // Update all displays: graph, dist table, step info\n  function updateAllDisplays() {\n    renderGraph();\n    renderDistances();\n    renderStepInfo();\n  }\n\n  // Render step info:\n  // Step index meaning:\n  // We do (vertexCount -1) iterations over all edges.\n  // Each step relaxes one edge.\n\n  function renderStepInfo() {\n    if (vertexCount === 0) {\n      stepInfoArea.textContent = \"(No graph)\";\n      return;\n    }\n    if (!validateVertex(sourceVertex)) {\n      stepInfoArea.textContent = \"Source vertex not set or invalid.\";\n      return;\n    }\n    if (edges.length === 0) {\n      stepInfoArea.textContent = \"No edges to relax.\";\n      return;\n    }\n    if (stepIndex === 0) {\n      stepInfoArea.textContent = \"Before any relaxations, distances initialized.\\n\" +\n        `Source vertex: ${sourceVertex}\\n` +\n        `Distances: ${distances.map((d,i)=>`${i}:${d===Infinity?\"∞\":d}`).join(\", \")}`;\n      stepBackwardBtn.disabled = true;\n      return;\n    }\n    if (stepIndex > totalSteps) {\n      stepInfoArea.textContent = \"Algorithm finished all relaxation steps.\";\n      stepForwardBtn.disabled = true;\n      stepBackwardBtn.disabled = false;\n      return;\n    }\n\n    // Decode stepIndex into iteration and which edge relaxing\n    // steps count from 1 to totalSteps included\n    // stepIndex=1 means iteration=1 edge=0; stepIndex=totalSteps means iteration=vertexCount-1 edge=edges.length-1\n\n    const iteration = Math.floor((stepIndex-1)/edges.length) + 1; // iteration 1-based\n    const edgeId = (stepIndex-1) % edges.length;\n    const e = edges[edgeId];\n    const u = e.from;\n    const v = e.to;\n    const w = e.weight;\n\n    let info = `Iteration ${iteration} / ${vertexCount-1}\\n`;\n    info += `Relaxing edge ${u} -> ${v} (weight=${w})\\n`;\n    info += `Current distance to ${u}: ${distances[u] === Infinity ? \"∞\" : distances[u]}\\n`;\n    info += `Current distance to ${v}: ${distances[v] === Infinity ? \"∞\" : distances[v]}\\n`;\n\n    if (distances[u] !== Infinity && distances[u] + w < distances[v]) {\n      info += `Edge can be relaxed.\\nNew distance for vertex ${v}: ${distances[u] + w}`;\n    } else {\n      info += `No relaxation performed on this edge.`;\n    }\n\n    stepInfoArea.textContent = info;\n  }\n\n  // Perform one relaxation step (step forward)\n  function stepForward() {\n    if (stepIndex >= totalSteps) {\n      showMessage(\"Algorithm already finished.\");\n      stepForwardBtn.disabled = true;\n      return;\n    }\n    // Save current state before relaxation for backward stepping\n    distanceHistory.push(distances.slice());\n    predecessorHistory.push(predecessors.slice());\n\n    stepIndex++;\n    // Identify edge to relax\n    const currEdgeId = (stepIndex - 1) % edges.length;\n    const u = edges[currEdgeId].from;\n    const v = edges[currEdgeId].to;\n    const w = edges[currEdgeId].weight;\n\n    // Relax edge\n    if (distances[u] !== Infinity && distances[u] + w < distances[v]) {\n      distances[v] = distances[u] + w;\n      predecessors[v] = u;\n    }\n\n    updateAllDisplays();\n\n    stepBackwardBtn.disabled = false;\n    if (stepIndex === totalSteps) {\n      stepForwardBtn.disabled = true;\n      detectNegativeCycle();\n    }\n  }\n\n  // Step backward (undo last relaxation)\n  function stepBackward() {\n    if (stepIndex === 0) {\n      showMessage(\"At initial state, cannot step backward.\");\n      stepBackwardBtn.disabled = true;\n      return;\n    }\n    stepIndex--;\n    distances = distanceHistory.pop();\n    predecessors = predecessorHistory.pop();\n\n    updateAllDisplays();\n\n    stepForwardBtn.disabled = false;\n    if (stepIndex === 0) {\n      stepBackwardBtn.disabled = true;\n    }\n  }\n\n  // Run algorithm to end in one go (non-animated)\n  function runToEnd() {\n    if (stepIndex >= totalSteps) {\n      showMessage(\"Algorithm already finished.\");\n      stepForwardBtn.disabled = true;\n      runToEndBtn.disabled = true;\n      return;\n    }\n    // Save current state before running for backward capability\n    // We'll save each step in history so user can step back through full run\n    for(; stepIndex < totalSteps; stepIndex++) {\n      distanceHistory.push(distances.slice());\n      predecessorHistory.push(predecessors.slice());\n\n      const currEdgeId = (stepIndex) % edges.length;\n      const u = edges[currEdgeId].from;\n      const v = edges[currEdgeId].to;\n      const w = edges[currEdgeId].weight;\n\n      if (distances[u] !== Infinity && distances[u] + w < distances[v]) {\n        distances[v] = distances[u] + w;\n        predecessors[v] = u;\n      }\n    }\n    updateAllDisplays();\n    stepForwardBtn.disabled = true;\n    runToEndBtn.disabled = true;\n    stepBackwardBtn.disabled = (stepIndex === 0);\n\n    detectNegativeCycle();\n  }\n\n  // Check for negative weight cycles reachable from source\n  function detectNegativeCycle() {\n    // After |V|-1 iterations, relax edges one more time:\n    // if any edge can still relax, negative cycle reachable from source exists\n    for (const e of edges) {\n      if (distances[e.from] !== Infinity && distances[e.from] + e.weight < distances[e.to]) {\n        showMessage(\"Warning: Negative weight cycle detected reachable from source vertex.\");\n        return;\n      }\n    }\n    showMessage(\"Algorithm completed without detecting negative weight cycles.\");\n  }\n\n  // Clear graph completely\n  function clearGraph() {\n    vertexCount = 0;\n    edges = [];\n    sourceVertex = 0;\n    distances = [];\n    predecessors = [];\n    stepIndex = 0;\n    distanceHistory = [];\n    predecessorHistory = [];\n    totalSteps = 0;\n    vertexCountInput.value = \"\";\n    edgeFromInput.value = \"\";\n    edgeToInput.value = \"\";\n    edgeWeightInput.value = \"\";\n    sourceVertexInput.value = \"\";\n    importExportArea.value = \"\";\n    enableSteppingControls(false);\n    updateAllDisplays();\n    showMessage(\"Graph cleared.\");\n  }\n\n  // Import graph from JSON\n  function importGraph() {\n    let data;\n    try {\n      data = JSON.parse(importExportArea.value);\n    } catch(e) {\n      showMessage(\"Import failed: invalid JSON.\", true);\n      return;\n    }\n    // Should have vertexCount (int), edges (array), source (int)\n    if (!validateVertexCount(data.vertexCount)) {\n      showMessage(\"Import failed: invalid or missing vertexCount.\", true);\n      return;\n    }\n    if (!Array.isArray(data.edges)) {\n      showMessage(\"Import failed: edges should be an array.\", true);\n      return;\n    }\n    if (!validateVertex(data.source)) {\n      showMessage(\"Import failed: invalid or missing source vertex.\", true);\n      return;\n    }\n    let importedEdges = [];\n    for(const edge of data.edges) {\n      if (typeof edge !== \"object\" || edge === null) {\n        showMessage(\"Import failed: edges array contains invalid entry.\", true);\n        return;\n      }\n      const {from, to, weight} = edge;\n      if (!validateVertex(from) || !validateVertex(to)) {\n        showMessage(\"Import failed: edge vertices out of range.\", true);\n        return;\n      }\n      if (!validateWeight(weight)) {\n        showMessage(\"Import failed: invalid edge weight.\", true);\n        return;\n      }\n      importedEdges.push({from, to, weight});\n    }\n    // Set the graph\n    vertexCount = data.vertexCount;\n    edges = importedEdges;\n    sourceVertex = data.source;\n\n    // Update inputs controls and states\n    vertexCountInput.value = vertexCount;\n    edgeFromInput.max = vertexCount - 1;\n    edgeToInput.max = vertexCount - 1;\n    sourceVertexInput.max = vertexCount -1;\n    edgeFromInput.value = 0;\n    edgeToInput.value = 1 <= vertexCount - 1 ? 1 : 0;\n    sourceVertexInput.value = sourceVertex;\n\n    resetAlgorithmState();\n    updateAllDisplays();\n    showMessage(\"Graph imported successfully.\");\n  }\n\n  // Export graph as JSON\n  function exportGraph() {\n    const exportData = {\n      vertexCount,\n      edges,\n      source: sourceVertex,\n    };\n    importExportArea.value = JSON.stringify(exportData, null, 2);\n    showMessage(\"Graph exported to JSON.\");\n  }\n\n  // --- Event bindings ---\n  setVertexCountBtn.addEventListener(\"click\", () => {\n    const n = Number(vertexCountInput.value);\n    if (!validateVertexCount(n)) {\n      showMessage(messages.invalidVertexCount, true);\n      return;\n    }\n    initializeGraph(n);\n    showMessage(`Number of vertices set to ${n}.`);\n  });\n\n  addEdgeBtn.addEventListener(\"click\", () => {\n    const f = Number(edgeFromInput.value);\n    const t = Number(edgeToInput.value);\n    const w = Number(edgeWeightInput.value);\n    addEdge(f,t,w);\n  });\n\n  removeEdgeBtn.addEventListener(\"click\", () => {\n    const f = Number(edgeFromInput.value);\n    const t = Number(edgeToInput.value);\n    removeEdge(f,t);\n  });\n\n  setSourceBtn.addEventListener(\"click\", () => {\n    const s = Number(sourceVertexInput.value);\n    setSource(s);\n  });\n\n  resetAlgorithmBtn.addEventListener(\"click\", () => {\n    if (vertexCount === 0) {\n      showMessage(messages.noVertices, true);\n      return;\n    }\n    if (!validateVertex(sourceVertex)) {\n      showMessage(messages.invalidSource, true);\n      return;\n    }\n    resetAlgorithmState();\n    updateAllDisplays();\n    showMessage(\"Algorithm reset to initial state.\");\n  });\n\n  stepForwardBtn.addEventListener(\"click\", () => {\n    stepForward();\n  });\n\n  stepBackwardBtn.addEventListener(\"click\", () => {\n    stepBackward();\n  });\n\n  runToEndBtn.addEventListener(\"click\", () => {\n    runToEnd();\n  });\n\n  importGraphBtn.addEventListener(\"click\", () => {\n    importGraph();\n  });\n\n  exportGraphBtn.addEventListener(\"click\", () => {\n    exportGraph();\n  });\n\n  clearGraphBtn.addEventListener(\"click\", () => {\n    clearGraph();\n  });\n\n  // Initial setup\n  initializeGraph(vertexCount);\n\n  // Accessibility: add keyboard shortcuts hints in console\n  /*\n  Controls keyboard shortcuts (not implemented due to minimal UI):\n  - Set Vertices: click button\n  - Add Edge: click Add Edge\n  - Remove Edge: click Remove Edge\n  - Set Source: click Set Source\n  - Reset Algorithm: click Reset Algorithm\n  - Step Forward: click Step Forward\n  - Step Backward: click Step Backward\n  - Run To End: click Run To End\n  - Import: Paste JSON in textarea then Import\n  - Export: Export JSON to textarea\n  - Clear Graph: click Clear Graph\n  */\n\n})();\n</script>\n\n</body>\n</html>"
  },
