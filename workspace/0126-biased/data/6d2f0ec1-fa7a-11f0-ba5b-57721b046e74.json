    "role": "assistant",
    "content": "<html>\n<head>\n    <title>A* Search Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        #grid {\n            display: grid;\n            gap: 1px;\n            margin: 20px 0;\n            background-color: #ddd;\n        }\n        .cell {\n            background-color: white;\n            border: 1px solid #999;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            user-select: none;\n        }\n        .start { background-color: #4CAF50; }\n        .end { background-color: #F44336; }\n        .wall { background-color: #333; }\n        .path { background-color: #2196F3; }\n        .visited { background-color: #90CAF9; }\n        .controls {\n            margin-bottom: 20px;\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n            gap: 10px;\n        }\n        .control-group {\n            margin-bottom: 10px;\n        }\n        label {\n            display: block;\n            margin-bottom: 5px;\n        }\n        button {\n            padding: 5px 10px;\n            margin-right: 5px;\n            margin-bottom: 5px;\n        }\n        select, input {\n            padding: 5px;\n            width: 100%;\n        }\n        .info {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ddd;\n        }\n    </style>\n</head>\n<body>\n    <h1>A* Search Algorithm</h1>\n    \n    <div class=\"controls\">\n        <div class=\"control-group\">\n            <label for=\"gridSize\">Grid Size:</label>\n            <input type=\"range\" id=\"gridSize\" min=\"5\" max=\"30\" value=\"15\">\n            <span id=\"gridSizeValue\">15x15</span>\n        </div>\n        \n        <div class=\"control-group\">\n            <label for=\"cellType\">Cell Type:</label>\n            <select id=\"cellType\">\n                <option value=\"start\">Start</option>\n                <option value=\"end\">End</option>\n                <option value=\"wall\">Wall</option>\n                <option value=\"empty\">Empty</option>\n            </select>\n        </div>\n        \n        <div class=\"control-group\">\n            <label for=\"heuristic\">Heuristic:</label>\n            <select id=\"heuristic\">\n                <option value=\"manhattan\">Manhattan</option>\n                <option value=\"euclidean\">Euclidean</option>\n                <option value=\"diagonal\">Diagonal</option>\n            </select>\n        </div>\n        \n        <div class=\"control-group\">\n            <label for=\"diagonal\">Allow Diagonal:</label>\n            <select id=\"diagonal\">\n                <option value=\"true\">Yes</option>\n                <option value=\"false\">No</option>\n            </select>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Actions:</label>\n            <button id=\"run\">Run A*</button>\n            <button id=\"step\">Step</button>\n            <button id=\"reset\">Reset</button>\n            <button id=\"clearWalls\">Clear Walls</button>\n            <button id=\"randomWalls\">Random Walls</button>\n        </div>\n    </div>\n    \n    <div id=\"grid\"></div>\n    \n    <div class=\"info\">\n        <h3>Instructions:</h3>\n        <p>1. Select cell type and click on grid to place start/end/walls</p>\n        <p>2. Adjust grid size and algorithm parameters</p>\n        <p>3. Click \"Run A*\" to find path or \"Step\" to see each step</p>\n        <p>4. Use \"Reset\" to clear path or \"Clear Walls\" to remove all walls</p>\n        \n        <h3>Algorithm Info:</h3>\n        <p>Current State: <span id=\"state\">Ready</span></p>\n        <p>Path Length: <span id=\"pathLength\">-</span></p>\n        <p>Nodes Visited: <span id=\"nodesVisited\">0</span></p>\n        <p>Time Taken: <span id=\"timeTaken\">0</span> ms</p>\n    </div>\n\n    <script>\n        // Grid {\n            let gridSize = 15;\n            let grid = [];\n            let startCell = {x: 0, y: 0};\n            let endCell = {x: gridSize-1, y: gridSize-1};\n            let selectedCellType = 'start';\n            let heuristicType = 'manhattan';\n            let allowDiagonal = false;\n            let isRunning = false;\n            let isPaused = false;\n            let openSet = [];\n            let closedSet = [];\n            let path = [];\n            let nodesVisited = 0;\n            let animationSpeed = 50;\n            let animationInterval;\n            \n            // Initialize grid\n            function initGrid() {\n                grid = [];\n                for (let y = 0; y < gridSize; y++) {\n                    grid[y] = [];\n                    for (let x = 0; x < gridSize; x++) {\n                        grid[y][x] = {\n                            x: x,\n                            y: y,\n                            isWall: false,\n                            g: Infinity,\n                            h: 0,\n                            f: Infinity,\n                            parent: null\n                        };\n                    }\n                }\n                grid[startCell.y][startCell.x].isStart = true;\n                grid[endCell.y][endCell.x].isEnd = true;\n                renderGrid();\n            }\n            \n            // Render grid to DOM\n            function renderGrid() {\n                const gridElement = document.getElementById('grid');\n                gridElement.innerHTML = '';\n                gridElement.style.gridTemplateColumns = `repeat(${gridSize}, 30px)`;\n                \n                for (let y = 0; y < gridSize; y++) {\n                    for (let x = 0; x < gridSize; x++) {\n                        const cell = grid[y][x];\n                        const cellElement = document.createElement('div');\n                        cellElement.className = 'cell';\n                        cellElement.dataset.x = x;\n                        cellElement.dataset.y = y;\n                        \n                        if (cell.isStart) cellElement.classList.add('start');\n                        else if (cell.isEnd) cellElement.classList.add('end');\n                        else if (cell.isWall) cellElement.classList.add('wall');\n                        else if (path.some(p => p.x === x && p.y === y)) cellElement.classList.add('path');\n                        else if (closedSet.some(c => c.x === x && c.y === y)) cellElement.classList.add('visited');\n                        \n                        cellElement.addEventListener('click', () => handleCellClick(x, y));\n                        gridElement.appendChild(cellElement);\n                    }\n                }\n            }\n            \n            // Handle cell click\n            function handleCellClick(x, y) {\n                if (isRunning) return;\n                \n                const cell = grid[y][x];\n                \n                switch(selectedCellType) {\n                    case 'start':\n                        if (!cell.isWall && !cell.isEnd) {\n                            grid[startCell.y][startCell.x].isStart = false;\n                            startCell = {x, y};\n                            cell.isStart = true;\n                        }\n                        break;\n                    case 'end':\n                        if (!cell.isWall && !cell.isStart) {\n                            grid[endCell.y][endCell.x].isEnd = false;\n                            endCell = {x, y};\n                            cell.isEnd = true;\n                        }\n                        break;\n                    case 'wall':\n                        if (!cell.isStart && !cell.isEnd) {\n                            cell.isWall = !cell.isWall;\n                        }\n                        break;\n                    case 'empty':\n                        cell.isWall = false;\n                        if (cell.isStart) {\n                            grid[startCell.y][startCell.x].isStart = false;\n                            startCell = null;\n                        }\n                        if (cell.isEnd) {\n                            grid[endCell.y][endCell.x].isEnd = false;\n                            endCell = null;\n                        }\n                        break;\n                }\n                \n                renderGrid();\n            }\n        // }\n        \n        // A* Implementation {\n            // Heuristic functions\n            function manhattan(a, b) {\n                return Math.abs(a.x - b.x) + Math.abs(a.y - b.y);\n            }\n            \n            function euclidean(a, b) {\n                return Math.sqrt(Math.pow(a.x - b.x, 2) + Math.pow(a.y - b.y, 2));\n            }\n            \n            function diagonal(a, b) {\n                const dx = Math.abs(a.x - b.x);\n                const dy = Math.abs(a.y - b.y);\n                return Math.max(dx, dy);\n            }\n            \n            function getHeuristic(a, b) {\n                switch(heuristicType) {\n                    case 'manhattan': return manhattan(a, b);\n                    case 'euclidean': return euclidean(a, b);\n                    case 'diagonal': return diagonal(a, b);\n                    default: return manhattan(a, b);\n                }\n            }\n            \n            // Get neighbors\n            function getNeighbors(cell) {\n                const neighbors = [];\n                const {x, y} = cell;\n                \n                // Cardinal directions\n                const directions = [\n                    {x: 0, y: -1}, {x: 1, y: 0},\n                    {x: 0, y: 1}, {x: -1, y: 0}\n                ];\n                \n                // Diagonal directions\n                if (allowDiagonal) {\n                    directions.push(\n                        {x: 1, y: -1}, {x: 1, y: 1},\n                        {x: -1, y: 1}, {x: -1, y: -1}\n                    );\n                }\n                \n                for (const dir of directions) {\n                    const nx = x + dir.x;\n                    const ny = y + dir.y;\n                    \n                    if (nx >= 0 && nx < gridSize && ny >= 0 && ny < gridSize && !grid[ny][nx].isWall) {\n                        neighbors.push(grid[ny][nx]);\n                    }\n                }\n                \n                return neighbors;\n            }\n            \n            // Reconstruct path\n            function reconstructPath(current) {\n                path = [];\n                let temp = current;\n                while (temp) {\n                    path.unshift(temp);\n                    temp = temp.parent;\n                }\n                return path;\n            }\n            \n            // A* Algorithm\n            function aStarStep() {\n                if (openSet.length === 0) {\n                    document.getElementById('state').textContent = 'No path found';\n                    isRunning = false;\n                    isPaused = false;\n                    clearInterval(animationInterval);\n                    return false;\n                }\n                \n                // Get node with lowest f score\n                openSet.sort((a, b) => a.f - b.f);\n                const current = openSet.shift();\n                nodesVisited++;\n                \n                // Check if we reached the end\n                if (current.x === endCell.x && current.y === endCell.y) {\n                    path = reconstructPath(current);\n                    document.getElementById('state').textContent = 'Path found';\n                    document.getElementById('pathLength').textContent = path.length - 1;\n                    isRunning = false;\n                    isPaused = false;\n                    clearInterval(animationInterval);\n                    renderGrid();\n                    return true;\n                }\n                \n                closedSet.push(current);\n                \n                // Explore neighbors\n                const neighbors = getNeighbors(current);\n                for (const neighbor of neighbors) {\n                    if (closedSet.includes(neighbor)) continue;\n                    \n                    // Calculate tentative g score\n                    const tentativeG = current.g + \n                        (Math.abs(neighbor.x - current.x) === 1 && Math.abs(neighbor.y - current.y) === 1 ? \n                        1.414 : 1); // Diagonal cost is sqrt(2)\n                    \n                    if (!openSet.includes(neighbor)) {\n                        openSet.push(neighbor);\n                    } else if (tentativeG >= neighbor.g) {\n                        continue;\n                    }\n                    \n                    neighbor.parent = current;\n                    neighbor.g = tentativeG;\n                    neighbor.h = getHeuristic(neighbor, endCell);\n                    neighbor.f = neighbor.g + neighbor.h;\n                }\n                \n                renderGrid();\n                document.getElementById('nodesVisited').textContent = nodesVisited;\n                return true;\n            }\n            \n            // Run A* algorithm\n            function runAStar() {\n                if (isRunning || !startCell || !endCell) return;\n                \n                resetSearch();\n                isRunning = true;\n                isPaused = false;\n                document.getElementById('state').textContent = 'Running...';\n                \n                const startTime = performance.now();\n                \n                // Initialize open set with start node\n                grid[startCell.y][startCell.x].g = 0;\n                grid[startCell.y][startCell.x].h = getHeuristic(startCell, endCell);\n                grid[startCell.y][startCell.x].f = grid[startCell.y][startCell.x].h;\n                openSet = [grid[startCell.y][startCell.x]];\n                \n                animationInterval = setInterval(() => {\n                    if (!aStarStep()) {\n                        const endTime = performance.now();\n                        document.getElementById('timeTaken').textContent = (endTime - startTime).toFixed(2);\n                    }\n                }, animationSpeed);\n            }\n            \n            // Reset search (keep walls)\n            function resetSearch() {\n                openSet = [];\n                closedSet = [];\n                path = [];\n                nodesVisited = 0;\n                for (let y = 0; y < gridSize; y++) {\n                    for (let x = 0; x < gridSize; x++) {\n                        grid[y][x].g = Infinity;\n                        grid[y][x].h = 0;\n                        grid[y][x].f = Infinity;\n                        grid[y][x].parent = null;\n                    }\n                }\n                document.getElementById('state').textContent = 'Ready';\n                document.getElementById('pathLength').textContent = '-';\n                document.getElementById('nodesVisited').textContent = '0';\n                document.getElementById('timeTaken').textContent = '0';\n                renderGrid();\n            }\n            \n            // Clear walls\n            function clearWalls() {\n                if (isRunning) return;\n                for (let y = 0; y < gridSize; y++) {\n                    for (let x = 0; x < gridSize; x++) {\n                        if (!grid[y][x].isStart && !grid[y][x].isEnd) {\n                            grid[y][x].isWall = false;\n                        }\n                    }\n                }\n                renderGrid();\n            }\n            \n            // Random walls\n            function randomWalls() {\n                if (isRunning) return;\n                clearWalls();\n                for (let y = 0; y < gridSize; y++) {\n                    for (let x = 0; x < gridSize; x++) {\n                        if (!grid[y][x].isStart && !grid[y][x].isEnd && Math.random() < 0.3) {\n                            grid[y][x].isWall = true;\n                        }\n                    }\n                }\n                renderGrid();\n            }\n        // }\n        \n        // Event Listeners {\n            document.getElementById('gridSize').addEventListener('input', function() {\n                gridSize = parseInt(this.value);\n                document.getElementById('gridSizeValue').textContent = `${gridSize}x${gridSize}`;\n                startCell = {x: 0, y: 0};\n                endCell = {x: gridSize-1, y: gridSize-1};\n                initGrid();\n            });\n            \n            document.getElementById('cellType').addEventListener('change', function() {\n                selectedCellType = this.value;\n            });\n            \n            document.getElementById('heuristic').addEventListener('change', function() {\n                heuristicType = this.value;\n            });\n            \n            document.getElementById('diagonal').addEventListener('change', function() {\n                allowDiagonal = this.value === 'true';\n            });\n            \n            document.getElementById('run').addEventListener('click', runAStar);\n            \n            document.getElementById('step').addEventListener('click', function() {\n                if (isRunning && isPaused) {\n                    aStarStep();\n                } else if (!isRunning) {\n                    resetSearch();\n                    isRunning = true;\n                    isPaused = true;\n                    document.getElementById('state').textContent = 'Stepping...';\n                    \n                    grid[startCell.y][startCell.x].g = 0;\n                    grid[startCell.y][startCell.x].h = getHeuristic(startCell, endCell);\n                    grid[startCell.y][startCell.x].f = grid[startCell.y][startCell.x].h;\n                    openSet = [grid[startCell.y][startCell.x]];\n                }\n            });\n            \n            document.getElementById('reset').addEventListener('click', resetSearch);\n            document.getElementById('clearWalls').addEventListener('click', clearWalls);\n            document.getElementById('randomWalls').addEventListener('click', randomWalls);\n        // }\n        \n        // Initialize\n        initGrid();\n    </script>\n</body>\n</html>"
  },
