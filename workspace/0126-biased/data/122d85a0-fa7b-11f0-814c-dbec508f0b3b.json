    "content": "<html>\n<head>\n    <title>REST API Demo</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n        .input-field {\n            padding: 10px;\n            font-size: 16px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        .input-field input[type=\"text\"] {\n            width: 100%;\n        }\n        .button-group {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>REST API Demo</h1>\n        <button class=\"button\" onclick=\"createUser()\">Create User</button>\n        <button class=\"button\" onclick=\"getUser()\">Get User</button>\n        <button class=\"button\" onclick=\"updateUser()\">Update User</button>\n        <button class=\"button\" onclick=\"deleteUser()\">Delete User</button>\n        <button class=\"button\" onclick=\"createProduct()\">Create Product</button>\n        <button class=\"button\" onclick=\"getProduct()\">Get Product</button>\n        <button class=\"button\" onclick=\"updateProduct()\">Update Product</button>\n        <button class=\"button\" onclick=\"deleteProduct()\">Delete Product</button>\n        <h2>Product</h2>\n        <input type=\"text\" class=\"input-field\" id=\"productName\" placeholder=\"Product Name\">\n        <button class=\"button\" onclick=\"saveProduct()\">Save Product</button>\n        <button class=\"button\" onclick=\"loadProduct()\">Load Product</button>\n        <h2>Product</h2>\n        <table id=\"productTable\">\n            <tr>\n                <th>Product ID</th>\n                <th>Product Name</th>\n                <th>Product Price</th>\n                <th>Actions</th>\n            </tr>\n        </table>\n    </div>\n\n    <script>\n        let users = [\n            { id: 1, name: 'John Doe' },\n            { id: 2, name: 'Jane Doe' },\n        ];\n        let products = [\n            { id: 1, name: 'Product 1', price: 10.99 },\n            { id: 2, name: 'Product 2', price: 9.99 },\n        ];\n\n        function createUser() {\n            const productName = document.getElementById('productName').value;\n            if (productName !== '') {\n                const user = { id: users.length + 1, name: productName };\n                users.push(user);\n                alert('User created successfully!');\n                updateProductTable();\n            } else {\n                alert('Please enter a product name!');\n            }\n        }\n\n        function getUser() {\n            const id = document.getElementById('productID').value;\n            if (id !== '') {\n                const user = users.find((user) => user.id === parseInt(id));\n                if (user) {\n                    alert('User retrieved successfully!');\n                    updateProductTable();\n                } else {\n                    alert('User not found!');\n                }\n            } else {\n                alert('Please enter a product ID!');\n            }\n        }\n\n        function updateUser() {\n            const id = document.getElementById('productID').value;\n            const name = document.getElementById('productName').value;\n            if (id !== '' && name !== '') {\n                const user = users.find((user) => user.id === parseInt(id));\n                if (user) {\n                    user.name = name;\n                    alert('User updated successfully!');\n                    updateProductTable();\n                } else {\n                    alert('User not found!');\n                }\n            } else {\n                alert('Please enter a product ID and a new name!');\n            }\n        }\n\n        function deleteUser() {\n            const id = document.getElementById('productID').value;\n            if (id !== '') {\n                const user = users.find((user) => user.id === parseInt(id));\n                if (user) {\n                    users.splice(user.id, 1);\n                    alert('User deleted successfully!');\n                    updateProductTable();\n                } else {\n                    alert('User not found!');\n                }\n            } else {\n                alert('Please enter a product ID!');\n            }\n        }\n\n        function createProduct() {\n            const productName = document.getElementById('productName').value;\n            if (productName !== '') {\n                const product = { id: products.length + 1, name: productName, price: 9.99 };\n                products.push(product);\n                alert('Product created successfully!');\n                updateProductTable();\n            } else {\n                alert('Please enter a product name!');\n            }\n        }\n\n        function getProduct() {\n            const id = document.getElementById('productID').value;\n            if (id !== '') {\n                const product = products.find((product) => product.id === parseInt(id));\n                if (product) {\n                    alert('Product retrieved successfully!');\n                    updateProductTable();\n                } else {\n                    alert('Product not found!');\n                }\n            } else {\n                alert('Please enter a product ID!');\n            }\n        }\n\n        function updateProduct() {\n            const id = document.getElementById('productID').value;\n            const name = document.getElementById('productName').value;\n            const price = document.getElementById('productPrice').value;\n            if (id !== '' && name !== '' && price !== '') {\n                const product = products.find((product) => product.id === parseInt(id));\n                if (product) {\n                    product.name = name;\n                    product.price = parseFloat(price);\n                    alert('Product updated successfully!');\n                    updateProductTable();\n                } else {\n                    alert('Product not found!');\n                }\n            } else {\n                alert('Please enter a product ID, a new name, and a price!');\n            }\n        }\n\n        function deleteProduct() {\n            const id = document.getElementById('productID').value;\n            if (id !== '') {\n                const product = products.find((product) => product.id === parseInt(id));\n                if (product) {\n                    products.splice(product.id, 1);\n                    alert('Product deleted successfully!');\n                    updateProductTable();\n                } else {\n                    alert('Product not found!');\n                }\n            } else {\n                alert('Please enter a product ID!');\n            }\n        }\n\n        function updateProductTable() {\n            const table = document.getElementById('productTable');\n            table.innerHTML = '';\n            users.forEach((user) => {\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${user.id}</td>\n                    <td>${user.name}</td>\n                    <td>${user.price}</td>\n                    <td>\n                        <button class=\"button\" onclick=\"deleteProduct(${user.id})\">Delete</button>\n                        <button class=\"button\" onclick=\"updateProduct(${user.id})\">Update</button>\n                    </td>\n                `;\n                table.appendChild(row);\n            });\n        }\n\n        function saveProduct() {\n            const productName = document.getElementById('productName').value;\n            if (productName !== '') {\n                const product = { id: products.length + 1, name: productName, price: 9.99 };\n                products.push(product);\n                alert('Product saved successfully!');\n                updateProductTable();\n            } else {\n                alert('Please enter a product name!');\n            }\n        }\n\n        function loadProduct() {\n            const id = document.getElementById('productID').value;\n            if (id !== '') {\n                const product = products.find((product) => product.id === parseInt(id));\n                if (product) {\n                    alert('Product loaded successfully!');\n                    updateProductTable();\n                } else {\n                    alert('Product not found!');\n                }\n            } else {\n                alert('Please enter a product ID!');\n            }\n        }\n    </script>\n</body>\n</html>"
