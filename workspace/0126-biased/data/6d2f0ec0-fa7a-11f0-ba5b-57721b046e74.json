  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Topological Sort Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .control-panel {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .graph-container {\n            display: flex;\n            gap: 50px;\n        }\n        .graph-display {\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 300px;\n            min-width: 300px;\n        }\n        .result-display {\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 300px;\n            min-width: 200px;\n        }\n        .node {\n            cursor: pointer;\n            margin: 5px;\n            padding: 5px;\n            border: 1px solid #000;\n            display: inline-block;\n        }\n        .edge {\n            margin-left: 10px;\n            color: #555;\n        }\n        .step {\n            margin: 5px 0;\n            padding: 5px;\n            border-bottom: 1px solid #eee;\n        }\n        button {\n            padding: 5px 10px;\n        }\n        input {\n            padding: 5px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Topological Sort Interactive Demo</h1>\n        \n        <div class=\"control-panel\">\n            <div>\n                <h3>Graph Input</h3>\n                <textarea id=\"graphInput\">A: b,c\nB: c,d\nC: e\nD: \nE: d</textarea>\n                <button id=\"parseGraph\">Parse Graph</button>\n            </div>\n            \n            <div>\n                <h3>Manual Node Control</h3>\n                <input type=\"text\" id=\"newNode\" placeholder=\"Node name\">\n                <button id=\"addNode\">Add Node</button>\n                <div>\n                    <input type=\"text\" id=\"edgeFrom\" placeholder=\"From\" size=\"5\">\n                    →\n                    <input type=\"text\" id=\"edgeTo\" placeholder=\"To\" size=\"5\">\n                    <button id=\"addEdge\">Add Edge</button>\n                </div>\n                <button id=\"removeSelected\">Remove Selected</button>\n            </div>\n            \n            <div>\n                <h3>Algorithm Control</h3>\n                <button id=\"startSort\">Start Sort</button>\n                <button id=\"nextStep\">Next Step</button>\n                <button id=\"autoStep\">Auto Step</button>\n                <button id=\"reset\">Reset</button>\n                <div>\n                    Speed: \n                    <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\">\n                </div>\n            </div>\n            \n            <div>\n                <h3>Preset Graphs</h3>\n                <button id=\"presetDAG\">DAG Example</button>\n                <button id=\"presetCycle\">Cycle Example</button>\n                <button id=\"presetLarge\">Large Example</button>\n            </div>\n        </div>\n        \n        <div class=\"graph-container\">\n            <div class=\"graph-display\" id=\"graphDisplay\">\n                <h3>Graph Visualization</h3>\n                <div id=\"nodesContainer\"></div>\n            </div>\n            \n            <div class=\"result-display\">\n                <h3>Topological Order</h3>\n                <div id=\"sortedNodes\"></div>\n                <h3>Algorithm Steps</h3>\n                <div id=\"algorithmSteps\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Graph data structure\n        let graph = {\n            nodes: new Set(),\n            edges: new Map()\n        };\n        \n        // Algorithm state\n        let algorithmState = {\n            inProgress: false,\n            currentStep: 0,\n            steps: [],\n            visited: new Set(),\n            tempVisited: new Set(),\n            sorted: [],\n            processing: null,\n            autoInterval: null,\n            speed: 500\n        };\n        \n        // DOM elements\n        const graphInput = document.getElementById('graphInput');\n        const parseGraph = document.getElementById('parseGraph');\n        const newNode = document.getElementById('newNode');\n        const addNode = document.getElementById('addNode');\n        const edgeFrom = document.getElementById('edgeFrom');\n        const edgeTo = document.getElementById('edgeTo');\n        const addEdge = document.getElementById('addEdge');\n        const removeSelected = document.getElementById('removeSelected');\n        const startSort = document.getElementById('startSort');\n        const nextStep = document.getElementById('nextStep');\n        const autoStep = document.getElementById('autoStep');\n        const reset = document.getElementById('reset');\n        const speed = document.getElementById('speed');\n        const presetDAG = document.getElementById('presetDAG');\n        const presetCycle = document.getElementById('presetCycle');\n        const presetLarge = document.getElementById('presetLarge');\n        const nodesContainer = document.getElementById('nodesContainer');\n        const sortedNodes = document.getElementById('sortedNodes');\n        const algorithmSteps = document.getElementById('algorithmSteps');\n        \n        // Initialize\n        init();\n        \n        function init() {\n            parseGraph.addEventListener('click', parseGraphInput);\n            addNode.addEventListener('click', addNewNode);\n            addEdge.addEventListener('click', addNewEdge);\n            removeSelected.addEventListener('click', removeSelectedNodes);\n            startSort.addEventListener('click', startTopologicalSort);\n            nextStep.addEventListener('click', performNextStep);\n            autoStep.addEventListener('click', toggleAutoStep);\n            reset.addEventListener('click', resetAlgorithm);\n            speed.addEventListener('input', updateSpeed);\n            presetDAG.addEventListener('click', () => loadPreset('dag'));\n            presetCycle.addEventListener('click', () => loadPreset('cycle'));\n            presetLarge.addEventListener('click', () => loadPreset('large'));\n            \n            renderGraph();\n        }\n        \n        function parseGraphInput() {\n            const input = graphInput.value.trim();\n            const lines = input.split('\\n');\n            \n            graph.nodes.clear();\n            graph.edges.clear();\n            \n            lines.forEach(line => {\n                const parts = line.split(':');\n                if (parts.length < 1) return;\n                \n                const node = parts[0].trim();\n                if (!node) return;\n                \n                graph.nodes.add(node);\n                \n                if (parts.length > 1) {\n                    const edges = parts[1].split(',').map(e => e.trim()).filter(e => e);\n                    graph.edges.set(node, new Set(edges));\n                } else {\n                    graph.edges.set(node, new Set());\n                }\n            });\n            \n            renderGraph();\n        }\n        \n        function addNewNode() {\n            const node = newNode.value.trim();\n            if (!node) return;\n            \n            graph.nodes.add(node);\n            if (!graph.edges.has(node)) {\n                graph.edges.set(node, new Set());\n            }\n            \n            newNode.value = '';\n            renderGraph();\n        }\n        \n        function addNewEdge() {\n            const from = edgeFrom.value.trim();\n            const to = edgeTo.value.trim();\n            \n            if (!from || !to || !graph.nodes.has(from) || !graph.nodes.has(to)) {\n                alert('Invalid edge. Both nodes must exist.');\n                return;\n            }\n            \n            if (!graph.edges.has(from)) {\n                graph.edges.set(from, new Set());\n            }\n            \n            graph.edges.get(from).add(to);\n            \n            edgeFrom.value = '';\n            edgeTo.value = '';\n            renderGraph();\n        }\n        \n        function removeSelectedNodes() {\n            const selected = document.querySelectorAll('.node.selected');\n            selected.forEach(nodeEl => {\n                const node = nodeEl.getAttribute('data-node');\n                graph.nodes.delete(node);\n                graph.edges.delete(node);\n                \n                // Remove any edges pointing to this node\n                for (const [from, edges] of graph.edges) {\n                    if (edges.has(node)) {\n                        edges.delete(node);\n                    }\n                }\n            });\n            \n            renderGraph();\n        }\n        \n        function renderGraph() {\n            nodesContainer.innerHTML = '';\n            \n            graph.nodes.forEach(node => {\n                const nodeEl = document.createElement('div');\n                nodeEl.className = 'node';\n                nodeEl.setAttribute('data-node', node);\n                nodeEl.textContent = node;\n                \n                nodeEl.addEventListener('click', () => {\n                    nodeEl.classList.toggle('selected');\n                });\n                \n                nodesContainer.appendChild(nodeEl);\n                \n                const edges\n                const edges = graph.edges.get(node) || new Set();\n                if (edges.size > 0) {\n                    const edgeList = document.createElement('div');\n                    edgeList.className = 'edge';\n                    edgeList.textContent = `→ ${Array.from(edges).join(', ')}`;\n                    nodeEl.appendChild(edgeList);\n                }\n            });\n        }\n        \n        function startTopologicalSort() {\n            if (algorithmState.inProgress) return;\n            \n            algorithmState.inProgress = true;\n            algorithmState.currentStep = 0;\n            algorithmState.steps = [];\n            algorithmState.visited = new Set();\n            algorithmState.tempVisited = new Set();\n            algorithmState.sorted = [];\n            algorithmState.processing = null;\n            \n            // Perform the sort\n            let hasCycle = false;\n            \n            for (const node of graph.nodes) {\n                if (!algorithmState.visited.has(node)) {\n                    if (!visit(node)) {\n                        hasCycle = true;\n                        break;\n                    }\n                }\n            }\n            \n            if (hasCycle) {\n                algorithmState.steps.push({\n                    action: 'cycle',\n                    message: 'Cycle detected! Graph is not a DAG.'\n                });\n            } else {\n                algorithmState.steps.push({\n                    action: 'complete',\n                    message: 'Topological sort completed successfully!'\n                });\n            }\n            \n            updateAlgorithmDisplay();\n            startSort.disabled = true;\n            nextStep.disabled = false;\n        }\n        \n        function visit(node) {\n            if (algorithmState.tempVisited.has(node)) {\n                return false; // Cycle detected\n            }\n            \n            if (algorithmState.visited.has(node)) {\n                return true;\n            }\n            \n            algorithmState.tempVisited.add(node);\n            algorithmState.steps.push({\n                action: 'visit',\n                node: node,\n                message: `Visiting node ${node}`\n            });\n            \n            algorithmState.processing = node;\n            \n            const edges = graph.edges.get(node) || new Set();\n            for (const neighbor of edges) {\n                algorithmState.steps.push({\n                    action: 'check-edge',\n                    from: node,\n                    to: neighbor,\n                    message: `Checking edge ${node} → ${neighbor}`\n                });\n                \n                if (!visit(neighbor)) {\n                    return false;\n                }\n            }\n            \n            algorithmState.tempVisited.delete(node);\n            algorithmState.visited.add(node);\n            algorithmState.sorted.unshift(node);\n            \n            algorithmState.steps.push({\n                action: 'add-to-sorted',\n                node: node,\n                message: `Added ${node} to sorted list`\n            });\n            \n            algorithmState.processing = null;\n            return true;\n        }\n        \n        function performNextStep() {\n            if (!algorithmState.inProgress || algorithmState.currentStep >= algorithmState.steps.length) {\n                return;\n            }\n            \n            const step = algorithmState.steps[algorithmState.currentStep];\n            algorithmState.currentStep++;\n            \n            updateAlgorithmDisplay(step);\n            \n            if (algorithmState.currentStep >= algorithmState.steps.length) {\n                nextStep.disabled = true;\n            }\n        }\n        \n        function toggleAutoStep() {\n            if (algorithmState.autoInterval) {\n                clearInterval(algorithmState.autoInterval);\n                algorithmState.autoInterval = null;\n                autoStep.textContent = 'Auto Step';\n                nextStep.disabled = false;\n            } else {\n                if (!algorithmState.inProgress) {\n                    startTopologicalSort();\n                }\n                \n                autoStep.textContent = 'Stop Auto';\n                nextStep.disabled = true;\n                algorithmState.autoInterval = setInterval(() => {\n                    if (algorithmState.currentStep >= algorithmState.steps.length) {\n                        clearInterval(algorithmState.autoInterval);\n                        algorithmState.autoInterval = null;\n                        autoStep.textContent = 'Auto Step';\n                        nextStep.disabled = false;\n                        return;\n                    }\n                    performNextStep();\n                }, algorithmState.speed);\n            }\n        }\n        \n        function updateAlgorithmDisplay(step) {\n            // Update sorted nodes display\n            sortedNodes.innerHTML = '';\n            algorithmState.sorted.forEach(node => {\n                const nodeEl = document.createElement('div');\n                nodeEl.className = 'step';\n                nodeEl.textContent = node;\n                sortedNodes.appendChild(nodeEl);\n            });\n            \n            // Update algorithm steps\n            algorithmSteps.innerHTML = '';\n            for (let i = 0; i < algorithmState.currentStep; i++) {\n                const s = algorithmState.steps[i];\n                const stepEl = document.createElement('div');\n                stepEl.className = 'step';\n                \n                if (s.action === 'cycle') {\n                    stepEl.textContent = '✗ ' + s.message;\n                    stepEl.style.color = 'red';\n                } else if (s.action === 'complete') {\n                    stepEl.textContent = '✓ ' + s.message;\n                    stepEl.style.color = 'green';\n                } else {\n                    stepEl.textContent = s.message;\n                }\n                \n                algorithmSteps.appendChild(stepEl);\n            }\n            \n            // Highlight current processing node\n            document.querySelectorAll('.node').forEach(nodeEl => {\n                nodeEl.classList.remove('processing');\n                const node = nodeEl.getAttribute('data-node');\n                \n                if (step && step.node === node) {\n                    if (step.action === 'visit') {\n                        nodeEl.classList.add('processing');\n                    }\n                }\n            });\n        }\n        \n        function resetAlgorithm() {\n            if (algorithmState.autoInterval) {\n                clearInterval(algorithmState.autoInterval);\n                algorithmState.autoInterval = null;\n                autoStep.textContent = 'Auto Step';\n            }\n            \n            algorithmState.inProgress = false;\n            algorithmState.currentStep = 0;\n            algorithmState.steps = [];\n            algorithmState.visited = new Set();\n            algorithmState.tempVisited = new Set();\n            algorithmState.sorted = [];\n            algorithmState.processing = null;\n            \n            sortedNodes.innerHTML = '';\n            algorithmSteps.innerHTML = '';\n            \n            document.querySelectorAll('.node').forEach(nodeEl => {\n                nodeEl.classList.remove('processing');\n            });\n            \n            startSort.disabled = false;\n            nextStep.disabled = false;\n        }\n        \n        function updateSpeed() {\n            algorithmState.speed = 2100 - speed.value; // Invert so higher value = faster\n            \n            if (algorithmState.autoInterval) {\n                clearInterval(algorithmState.autoInterval);\n                algorithmState.autoInterval = setInterval(() => {\n                    if (algorithmState.currentStep >= algorithmState.steps.length) {\n                        clearInterval(algorithmState.autoInterval);\n                        algorithmState.autoInterval = null;\n                        autoStep.textContent = 'Auto Step';\n                        nextStep.disabled = false;\n                        return;\n                    }\n                    performNextStep();\n                }, algorithmState.speed);\n            }\n        }\n        \n        function loadPreset(type) {\n            let preset = '';\n            \n            switch (type) {\n                case 'dag':\n                    preset = `A: b,c\nB: c,d\nC: e\nD: \nE: d`;\n                    break;\n                case 'cycle':\n                    preset = `A: b\nB: c\nC: a`;\n                    break;\n                case 'large':\n                    preset = `Task1: Task2,Task3\nTask2: Task4,Task5\nTask3: Task5,Task6\nTask4: Task7\nTask5: Task7,Task8\nTask6: Task8\nTask7: Task9\nTask8: Task9\nTask9: `;\n                    break;\n            }\n            \n            graphInput.value = preset;\n            parseGraphInput();\n        }\n    </script>\n</body>\n</html>"
