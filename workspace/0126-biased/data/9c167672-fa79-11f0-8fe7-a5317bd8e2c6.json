    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Type System Playground</title>\n<style>\n  /* Extremely minimal visual design: default fonts, black text on white */\n  body { font-family: Arial, sans-serif; margin: 12px; color: black; background: white; }\n  h1 { font-size: 18px; margin: 6px 0 12px 0; }\n  .row { display: flex; gap: 12px; margin-bottom: 12px; }\n  .col { display: flex; flex-direction: column; gap: 8px; }\n  label { font-size: 12px; }\n  input, select, textarea, button { font-size: 12px; }\n  textarea { width: 100%; height: 120px; }\n  .small { width: 160px; }\n  .wide { width: 420px; }\n  .list { width: 260px; height: 160px; }\n  .log { width: 640px; height: 240px; white-space: pre-wrap; overflow: auto; border: 1px solid #000; padding: 6px; }\n  .controls { display: flex; gap: 8px; flex-wrap: wrap; }\n  /* Keep everything plain - minimal lines only */\n</style>\n</head>\n<body>\n<h1>Type System Playground</h1>\n\n<div class=\"row\">\n  <div class=\"col\">\n    <label>1) New Type / Alias</label>\n    <div class=\"controls\">\n      <input id=\"newTypeName\" class=\"small\" placeholder=\"Name (e.g. Pair)\"/>\n      <input id=\"newTypeExpr\" class=\"wide\" placeholder=\"Type expression (e.g. (Int,String) -> Bool or {x:Int, y:String} or List<T>)\"/>\n      <button id=\"addTypeBtn\">Add Type</button>\n      <button id=\"aliasTypeBtn\">Add Alias (store as named alias)</button>\n    </div>\n\n    <label>2) Types (environment)</label>\n    <select id=\"typesList\" class=\"list\" size=\"8\"></select>\n    <div class=\"controls\">\n      <button id=\"viewTypeBtn\">View</button>\n      <button id=\"editTypeBtn\">Edit</button>\n      <button id=\"deleteTypeBtn\">Delete</button>\n      <button id=\"applySubstEnvBtn\">Apply last substitution to environment</button>\n    </div>\n\n    <label>3) Variables</label>\n    <div class=\"controls\">\n      <input id=\"newVarName\" class=\"small\" placeholder=\"var name\"/>\n      <select id=\"varTypeSelect\" class=\"small\"></select>\n      <button id=\"addVarBtn\">Add Var</button>\n    </div>\n    <select id=\"varsList\" class=\"list\" size=\"6\"></select>\n    <div class=\"controls\">\n      <button id=\"viewVarBtn\">View Var</button>\n      <button id=\"deleteVarBtn\">Delete Var</button>\n    </div>\n  </div>\n\n  <div class=\"col\">\n    <label>4) Operation</label>\n    <select id=\"operationSelect\" class=\"wide\">\n      <option value=\"unify\">Unify two types</option>\n      <option value=\"subtype\">Check A <: B (subtyping)</option>\n      <option value=\"instantiate\">Instantiate generic (List<T> -> List<Int>)</option>\n      <option value=\"apply\">Apply substitution to a type</option>\n      <option value=\"simplify\">Simplify / normalize a type</option>\n      <option value=\"infer_simple\">Infer simple expression (call/use var)</option>\n    </select>\n\n    <div id=\"opControls\" class=\"col\">\n      <!-- dynamic controls inserted here -->\n    </div>\n\n    <div class=\"controls\">\n      <label><input type=\"checkbox\" id=\"nominalMode\"/> Nominal mode (named types distinct)</label>\n      <label><input type=\"checkbox\" id=\"allowWild\"/> Allow wildcard type vars (a = _)</label>\n      <label>Recursion depth <input id=\"recDepth\" type=\"range\" min=\"1\" max=\"8\" value=\"6\"/></label>\n      <span id=\"recDepthVal\">6</span>\n    </div>\n\n    <div class=\"controls\">\n      <button id=\"runOpBtn\">Run</button>\n      <button id=\"stepPrevBtn\">Step &lt;</button>\n      <input id=\"traceSlider\" type=\"range\" min=\"0\" max=\"0\" value=\"0\"/>\n      <button id=\"stepNextBtn\">Step &gt;</button>\n      <button id=\"clearLogBtn\">Clear Log</button>\n      <button id=\"resetEnvBtn\">Reset Env</button>\n    </div>\n\n    <label>5) Scenarios</label>\n    <div class=\"controls\">\n      <select id=\"scenarioSelect\" class=\"small\">\n        <option value=\"simple\">Simple primitives</option>\n        <option value=\"functions\">Function types & variance</option>\n        <option value=\"generics\">Generics & unification</option>\n        <option value=\"objects\">Object structural subtyping</option>\n        <option value=\"nominal\">Nominal vs Structural</option>\n        <option value=\"unions\">Union & Intersection</option>\n      </select>\n      <button id=\"loadScenarioBtn\">Load Scenario</button>\n    </div>\n\n    <label>6) Save / Load Environment (JSON)</label>\n    <textarea id=\"envJson\"></textarea>\n    <div class=\"controls\">\n      <button id=\"saveEnvBtn\">Export Environment JSON</button>\n      <button id=\"loadEnvBtn\">Import JSON</button>\n    </div>\n  </div>\n</div>\n\n<label>7) Trace & Output</label>\n<div class=\"log\" id=\"logArea\"></div>\n<div class=\"controls\" style=\"margin-top:8px;\">\n  <label>Current Substitution:</label>\n  <input id=\"currentSubst\" class=\"wide\" readonly/>\n</div>\n\n<script>\n/*\n Type System Playground\n - Minimal visual design\n - Rich interaction: define types, variables, unify, subtype check, instantiate generics\n - Step-by-step traces for unification and subtyping\n*/\n\n/* ---------- Basic Type AST ---------- */\n\nfunction Type(kind, details) {\n  this.kind = kind; // 'prim', 'var', 'name', 'func', 'obj', 'union', 'inter', 'app'\n  Object.assign(this, details || {});\n}\n\nfunction tPrim(name) { return new Type('prim', { name }); }\nfunction tVar(name) { return new Type('var', { name }); }\nfunction tName(name, params) { return new Type('name', { name, params: params || [] }); } // named alias or generic declaration\nfunction tFunc(params, ret) { return new Type('func', { params, ret }); }\nfunction tObj(fields) { return new Type('obj', { fields }); } // fields: {k:Type}\nfunction tUnion(types) { return new Type('union', { types }); }\nfunction tInter(types) { return new Type('inter', { types }); }\nfunction tApp(name, args) { return new Type('app', { name, args }); } // application of generic: name + args\n\nfunction cloneType(ty) {\n  // deep clone\n  if (!ty) return ty;\n  switch (ty.kind) {\n    case 'prim': return tPrim(ty.name);\n    case 'var': return tVar(ty.name);\n    case 'name': return tName(ty.name, (ty.params || []).map(cloneType));\n    case 'app': return tApp(ty.name, (ty.args || []).map(cloneType));\n    case 'func': return tFunc((ty.params || []).map(cloneType), cloneType(ty.ret));\n    case 'obj': {\n      const f = {};\n      for (const k in ty.fields) f[k] = cloneType(ty.fields[k]);\n      return tObj(f);\n    }\n    case 'union': return tUnion(ty.types.map(cloneType));\n    case 'inter': return tInter(ty.types.map(cloneType));\n  }\n}\n\n/* ---------- Pretty printer ---------- */\n\nfunction typeToString(ty) {\n  if (!ty) return 'null';\n  switch (ty.kind) {\n    case 'prim': return ty.name;\n    case 'var': return ty.name;\n    case 'name': {\n      if (ty.params && ty.params.length) {\n        return ty.name + \"<\" + ty.params.map(typeToString).join(\",\") + \">\";\n      }\n      return ty.name;\n    }\n    case 'app': {\n      return ty.name + \"<\" + ty.args.map(typeToString).join(\",\") + \">\";\n    }\n    case 'func': {\n      const ps = ty.params.map(typeToString).join(\", \");\n      return \"(\" + ps + \") -> \" + typeToString(ty.ret);\n    }\n    case 'obj': {\n      const f = Object.keys(ty.fields).map(k => k + \":\" + typeToString(ty.fields[k])).join(\", \");\n      return \"{\" + f + \"}\";\n    }\n    case 'union': return ty.types.map(typeToString).join(\" | \");\n    case 'inter': return ty.types.map(typeToString).join(\" & \");\n    default: return JSON.stringify(ty);\n  }\n}\n\n/* ---------- Parser (simple) ---------- */\n/* Grammar:\n Type := Union\n Union := Inter ('|' Inter)*\n Inter := Arrow ('&' Arrow)*\n Arrow := Primary ('->' Arrow)?\n Primary := IDENT [ '<' TypeList '>' ] | VAR | '(' Type ')' | '{' FieldList '}' \n TypeList := Type (',' Type)*\n FieldList := name ':' Type (',' name ':' Type)*\n IDENT: [A-Za-z_][A-Za-z0-9_]*\n VAR: [a-z] (single lowercase letter) denotes type variable\n*/\n\nfunction tokenize(s) {\n  const tokens = [];\n  const re = /\\s*([A-Za-z_][A-Za-z0-9_]*|[a-z]|->|<=|>=|==|!=|[{}(),:<>|&])\\s*/g;\n  let m;\n  while ((m = re.exec(s)) !== null) {\n    tokens.push(m[1]);\n  }\n  return tokens;\n}\n\nfunction parseType(s) {\n  const tokens = tokenize(s);\n  let i = 0;\n  function peek() { return tokens[i]; }\n  function next() { return tokens[i++]; }\n  function expect(tok) {\n    if (peek() !== tok) throw new Error(\"Expected '\" + tok + \"' but got '\" + peek() + \"'\");\n    next();\n  }\n  function parsePrimary() {\n    const tk = peek();\n    if (!tk) throw new Error(\"Unexpected end in primary\");\n    if (tk === '(') {\n      next();\n      const t = parseUnion();\n      expect(')');\n      return t;\n    }\n    if (tk === '{') {\n      next();\n      const fields = {};\n      if (peek() !== '}') {\n        while (true) {\n          const name = next();\n          if (!/^[_A-Za-z][_A-Za-z0-9]*$/.test(name)) throw new Error(\"Bad field name: \" + name);\n          expect(':');\n          const ft = parseUnion();\n          fields[name] = ft;\n          if (peek() === ',') { next(); continue; }\n          break;\n        }\n      }\n      expect('}');\n      return tObj(fields);\n    }\n    // identifier or var\n    if (/^[A-Za-z_][A-Za-z0-9_]*$/.test(tk)) {\n      const id = next();\n      // generic application?\n      if (peek() === '<') {\n        next();\n        const args = [];\n        while (true) {\n          args.push(parseUnion());\n          if (peek() === ',') { next(); continue; }\n          break;\n        }\n        expect('>');\n        return tApp(id, args);\n      } else {\n        return tName(id);\n      }\n    }\n    if (/^[a-z]$/.test(tk)) {\n      // single lowercase letter as type variable\n      const v = next();\n      return tVar(v);\n    }\n    throw new Error(\"Unexpected token in primary: \" + tk);\n  }\n\n  function parseArrow() {\n    let left = parsePrimary();\n    if (peek() === '->') {\n      next();\n      const right = parseArrow();\n      // If left is tuple like (a,b) we should treat as params\n      if (left.kind === 'app' && left.name === 'Tuple') {\n        // Not used; keep simple: if left is tApp named 'Tuple' treat as params\n      }\n      // If left is a function param list inside parentheses, the parser will have built separate structure; to handle simple syntax (A,B) -> R, provide helper:\n      if (left.kind === 'name' && left.name === ',' ) {\n        // not used\n      }\n      // If left is an obj or other, wrap single param\n      const params = (left.kind === 'union' || left.kind === 'inter' || left.kind === 'func') ? [left] : [left];\n      return tFunc(params, right);\n    }\n    return left;\n  }\n\n  function parseInter() {\n    let t = parseArrow();\n    while (peek() === '&') {\n      next();\n      const r = parseArrow();\n      if (t.kind === 'inter') t.types.push(r); else t = tInter([t, r]);\n    }\n    return t;\n  }\n\n  function parseUnion() {\n    let t = parseInter();\n    while (peek() === '|') {\n      next();\n      const r = parseInter();\n      if (t.kind === 'union') t.types.push(r); else t = tUnion([t, r]);\n    }\n    return t;\n  }\n\n  const res = parseUnion();\n  if (i < tokens.length) throw new Error(\"Extra tokens: \" + tokens.slice(i).join(\" \"));\n  return res;\n}\n\n/* ---------- Environment ---------- */\n\nconst env = {\n  types: {}, // name -> { type: Type, alias: boolean }\n  vars: {},  // name -> Type\n  lastSubst: {}, // substitution map varName -> Type\n  trace: [], // steps for last operation\n  traceIndex: 0\n};\n\nfunction resetEnv() {\n  env.types = {};\n  env.vars = {};\n  env.lastSubst = {};\n  env.trace = [];\n  env.traceIndex = 0;\n  log(\"Environment reset.\");\n  refreshUI();\n}\n\n/* ---------- Utilities ---------- */\n\nfunction log(s) {\n  const a = document.getElementById('logArea');\n  a.textContent += s + \"\\n\";\n  a.scrollTop = a.scrollHeight;\n}\n\nfunction setSubstDisplay(subst) {\n  const el = document.getElementById('currentSubst');\n  const keys = Object.keys(subst || {});\n  el.value = keys.map(k => k + \" ↦ \" + typeToString(subst[k])).join(\", \");\n}\n\n/* ---------- Unification with trace ---------- */\n/* Unify type a and b. Type variables are lowercase single letters. Returns substitution or throws error */\nfunction unify(a, b, opts) {\n  opts = opts || {};\n  const nominal = !!opts.nominal;\n  const allowWild = !!opts.allowWild;\n  env.trace = [];\n  env.traceIndex = 0;\n  const subst = {}; // varName -> Type\n\n  function occursCheck(v, t) {\n    if (!t) return false;\n    if (t.kind === 'var') return t.name === v;\n    if (t.kind === 'func') return t.params.some(p => occursCheck(v, p)) || occursCheck(v, t.ret);\n    if (t.kind === 'obj') return Object.values(t.fields).some(f => occursCheck(v, f));\n    if (t.kind === 'union' || t.kind === 'inter') return t.types.some(x => occursCheck(v, x));\n    if (t.kind === 'app') return t.args.some(a => occursCheck(v, a));\n    return false;\n  }\n\n  function applySubst(t) {\n    if (!t) return t;\n    if (t.kind === 'var') {\n      if (subst[t.name]) return applySubst(subst[t.name]);\n      return t;\n    }\n    if (t.kind === 'func') return tFunc(t.params.map(applySubst), applySubst(t.ret));\n    if (t.kind === 'obj') {\n      const f = {};\n      for (const k in t.fields) f[k] = applySubst(t.fields[k]);\n      return tObj(f);\n    }\n    if (t.kind === 'union') return tUnion(t.types.map(applySubst));\n    if (t.kind === 'inter') return tInter(t.types.map(applySubst));\n    if (t.kind === 'app') return tApp(t.name, t.args.map(applySubst));\n    return t;\n  }\n\n  function recordStep(a,b,action) {\n    env.trace.push({a: cloneType(a), b: cloneType(b), subst: JSON.parse(JSON.stringify(subst)), action});\n  }\n\n  function unifyInternal(x, y) {\n    x = applySubst(x);\n    y = applySubst(y);\n    recordStep(x,y,\"attempt-unify\");\n    // identical\n    if (typeEquals(x, y)) {\n      recordStep(x,y,\"identical\");\n      return;\n    }\n    // var cases\n    if (x.kind === 'var') {\n      if (allowWild && x.name === '_') {\n        recordStep(x,y,\"wildcard-left\");\n        return;\n      }\n      if (occursCheck(x.name, y)) {\n        throw new Error(\"Occurs check failed: \" + x.name + \" in \" + typeToString(y));\n      }\n      subst[x.name] = y;\n      recordStep(x,y,\"bind-left \"+x.name+\" -> \"+typeToString(y));\n      return;\n    }\n    if (y.kind === 'var') {\n      if (allowWild && y.name === '_') {\n        recordStep(x,y,\"wildcard-right\");\n        return;\n      }\n      if (occursCheck(y.name, x)) {\n        throw new Error(\"Occurs check failed: \" + y.name + \" in \" + typeToString(x));\n      }\n      subst[y.name] = x;\n      recordStep(x,y,\"bind-right \"+y.name+\" -> \"+typeToString(x));\n      return;\n    }\n    // same kind primitives / names\n    if (x.kind === 'prim' && y.kind === 'prim') {\n      if (x.name !== y.name) throw new Error(\"Cannot unify primitives \" + x.name + \" and \" + y.name);\n      return;\n    }\n    // name or app: if nominal mode, names must match; if structural, try to unfold alias\n    if (x.kind === 'name' && y.kind === 'name') {\n      if (x.name === y.name && x.params.length === y.params.length) {\n        for (let i=0;i<x.params.length;i++) unifyInternal(x.params[i], y.params[i]);\n        return;\n      }\n      // try if both defined in env and can be unified structurally by aliasing:\n      if (!nominal) {\n        const ax = env.types[x.name] && env.types[x.name].type;\n        const ay = env.types[y.name] && env.types[y.name].type;\n        if (ax && ay) {\n          unifyInternal(ax, ay);\n          return;\n        }\n      }\n      throw new Error(\"Cannot unify named types \" + x.name + \" and \" + y.name);\n    }\n    if (x.kind === 'app' && y.kind === 'app') {\n      if (x.name !== y.name || x.args.length !== y.args.length) throw new Error(\"Cannot unify type applications \" + typeToString(x) + \" and \" + typeToString(y));\n      for (let i=0;i<x.args.length;i++) unifyInternal(x.args[i], y.args[i]);\n      return;\n    }\n    // function types\n    if (x.kind === 'func' && y.kind === 'func') {\n      // unify parameter-wise and return type\n      if (x.params.length !== y.params.length) throw new Error(\"Function arity mismatch\");\n      for (let i=0;i<x.params.length;i++) unifyInternal(x.params[i], y.params[i]);\n      unifyInternal(x.ret, y.ret);\n      return;\n    }\n    // objects: match fields\n    if (x.kind === 'obj' && y.kind === 'obj') {\n      const keysX = Object.keys(x.fields);\n      const keysY = Object.keys(y.fields);\n      const common = keysX.filter(k => keysY.includes(k));\n      if (common.length !== keysX.length || common.length !== keysY.length) {\n        // allow partial match? for unification require same keys\n        throw new Error(\"Object fields differ: \" + JSON.stringify(keysX) + \" vs \" + JSON.stringify(keysY));\n      }\n      for (const k of common) unifyInternal(x.fields[k], y.fields[k]);\n      return;\n    }\n    // unions and intersections - naive approach: require same structure\n    if (x.kind === 'union' && y.kind === 'union') {\n      if (x.types.length !== y.types.length) throw new Error(\"Union length mismatch\");\n      for (let i=0;i<x.types.length;i++) unifyInternal(x.types[i], y.types[i]);\n      return;\n    }\n    if (x.kind === 'inter' && y.kind === 'inter') {\n      if (x.types.length !== y.types.length) throw new Error(\"Intersection length mismatch\");\n      for (let i=0;i<x.types.length;i++) unifyInternal(x.types[i], y.types[i]);\n      return;\n    }\n    // cross-kind cases: try structural unfold of named types if allowed\n    if (!nominal) {\n      if (x.kind === 'name') {\n        const a = env.types[x.name] && env.types[x.name].type;\n        if (a) { unifyInternal(a, y); return; }\n      }\n      if (y.kind === 'name') {\n        const a = env.types[y.name] && env.types[y.name].type;\n        if (a) { unifyInternal(x, a); return; }\n      }\n    }\n\n    throw new Error(\"Cannot unify types: \" + typeToString(x) + \" and \" + typeToString(y));\n  }\n\n  try {\n    unifyInternal(a,b);\n  } catch (e) {\n    recordStep(a,b,\"error: \"+e.message);\n    env.lastSubst = subst;\n    throw e;\n  }\n  env.lastSubst = subst;\n  recordStep(a,b,\"success\");\n  return subst;\n}\n\n/* ---------- Type equality ---------- */\n\nfunction typeEquals(a,b) {\n  if (a === b) return true;\n  if (!a || !b) return false;\n  if (a.kind !== b.kind) return false;\n  switch (a.kind) {\n    case 'prim': return a.name === b.name;\n    case 'var': return a.name === b.name;\n    case 'name': {\n      if (a.name !== b.name) return false;\n      if ((a.params||[]).length !== (b.params||[]).length) return false;\n      for (let i=0;i<a.params.length;i++) if (!typeEquals(a.params[i], b.params[i])) return false;\n      return true;\n    }\n    case 'app': {\n      if (a.name !== b.name) return false;\n      if (a.args.length !== b.args.length) return false;\n      for (let i=0;i<a.args.length;i++) if (!typeEquals(a.args[i], b.args[i])) return false;\n      return true;\n    }\n    case 'func': {\n      if (a.params.length !== b.params.length) return false;\n      for (let i=0;i<a.params.length;i++) if (!typeEquals(a.params[i], b.params[i])) return false;\n      return typeEquals(a.ret, b.ret);\n    }\n    case 'obj': {\n      const ka = Object.keys(a.fields).sort();\n      const kb = Object.keys(b.fields).sort();\n      if (ka.length !== kb.length) return false;\n      for (let i=0;i<ka.length;i++) if (ka[i] !== kb[i]) return false;\n      for (const k of ka) if (!typeEquals(a.fields[k], b.fields[k])) return false;\n      return true;\n    }\n    case 'union':\n    case 'inter': {\n      if (a.types.length !== b.types.length) return false;\n      for (let i=0;i<a.types.length;i++) if (!typeEquals(a.types[i], b.types[i])) return false;\n      return true;\n    }\n  }\n  return false;\n}\n\n/* ---------- Subtyping (structural) with trace ---------- */\n\nfunction isSubtype(a,b, opts) {\n  opts = opts || {};\n  const nominal = !!opts.nominal;\n  const allowWild = !!opts.allowWild;\n  env.trace = [];\n  env.traceIndex = 0;\n\n  function recordStep(a,b,action) {\n    env.trace.push({a: cloneType(a), b: cloneType(b), action});\n  }\n\n  function applySubstType(t) { return t; } // no substitution here\n  function subtype(x,y) {\n    recordStep(x,y,\"check\");\n    if (typeEquals(x,y)) { recordStep(x,y,\"equal\"); return true; }\n    // var on either side: be permissive: treat var as wildcard or unknown\n    if (x.kind === 'var' || y.kind === 'var') {\n      if (allowWild) { recordStep(x,y,\"wildcard-true\"); return true; }\n      recordStep(x,y,\"var-unknown-false\");\n      return false;\n    }\n    // union: A <: B if each component of A is <: B\n    if (x.kind === 'union') {\n      for (const xt of x.types) {\n        if (!subtype(xt, y)) return false;\n      }\n      return true;\n    }\n    // intersection: A <: B if any component of A is <: B\n    if (x.kind === 'inter') {\n      for (const xt of x.types) {\n        if (subtype(xt, y)) return true;\n      }\n      return false;\n    }\n    // B is union: A <: (B1|B2) if A <: B1 or A <: B2\n    if (y.kind === 'union') {\n      for (const yt of y.types) {\n        if (subtype(x, yt)) return true;\n      }\n      return false;\n    }\n    // B is intersection: A <: (B1 & B2) if A <: B1 and A <: B2\n    if (y.kind === 'inter') {\n      for (const yt of y.types) {\n        if (!subtype(x, yt)) return false;\n      }\n      return true;\n    }\n    // primitives\n    if (x.kind === 'prim' && y.kind === 'prim') return x.name === y.name;\n    // functions: contravariant parameters, covariant return\n    if (x.kind === 'func' && y.kind === 'func') {\n      if (x.params.length !== y.params.length) { recordStep(x,y,\"func-arity-mismatch\"); return false; }\n      // contravariant: y.param <: x.param\n      for (let i=0;i<x.params.length;i++) {\n        if (!subtype(y.params[i], x.params[i])) { recordStep(x,y,\"param-contravariant-fail\"); return false; }\n      }\n      if (!subtype(x.ret, y.ret)) { recordStep(x,y,\"ret-covariant-fail\"); return false; }\n      return true;\n    }\n    // objects: structural: x <: y if x has at least y's fields with compatible types\n    if (x.kind === 'obj' && y.kind === 'obj') {\n      for (const k in y.fields) {\n        if (!(k in x.fields)) { recordStep(x,y,\"missing-field \"+k); return false; }\n        if (!subtype(x.fields[k], y.fields[k])) { recordStep(x,y,\"field-type-fail \"+k); return false; }\n      }\n      return true;\n    }\n    // names: if nominal and names equal then true, else unfold if structural\n    if (x.kind === 'name' && y.kind === 'name') {\n      if (nominal) return x.name === y.name;\n      // structural: try to resolve both if defined\n      const ax = env.types[x.name] && env.types[x.name].type;\n      const ay = env.types[y.name] && env.types[y.name].type;\n      if (ax && ay) return subtype(ax, ay);\n      return false;\n    }\n    // name vs other\n    if (!nominal) {\n      if (x.kind === 'name') {\n        const ax = env.types[x.name] && env.types[x.name].type;\n        if (ax) return subtype(ax, y);\n      }\n      if (y.kind === 'name') {\n        const ay = env.types[y.name] && env.types[y.name].type;\n        if (ay) return subtype(x, ay);\n      }\n    }\n\n    // app vs app: require same base and arg-wise equality/subtyping depending on variance (simplify: require equality)\n    if (x.kind === 'app' && y.kind === 'app' && x.name === y.name && x.args.length === y.args.length) {\n      for (let i=0;i<x.args.length;i++) {\n        if (!subtype(x.args[i], y.args[i])) return false;\n      }\n      return true;\n    }\n\n    recordStep(x,y,\"no-rule\");\n    return false;\n  }\n\n  const res = subtype(a,b);\n  env.lastSubst = {}; // no substitution here\n  return res;\n}\n\n/* ---------- Type application / instantiate ---------- */\n\nfunction instantiate(name, args) {\n  // find type definition for name\n  const tpl = env.types[name];\n  if (!tpl) throw new Error(\"Type \" + name + \" not found\");\n  const decl = tpl.type;\n  // If decl has params stored in name.params (for tName), we try basic substitution: if decl is a named alias with its own params, we do naive textual replacement\n  // For simplicity, if type was defined as tApp or uses type variables inside, we do a naive replacement based on lowercase vars a,b,...\n  // We'll adopt convention: use type variables named 'T','U','V' or single-letter lowercase 'a' etc -> map by number when applying\n  // If decl includes type variables of form 'a','b', we'll substitute by provided args in order.\n  const mapping = {};\n  // gather declaration type variables by scanning decl for tVar occurrences in order\n  const seen = [];\n  function collectVars(t) {\n    if (!t) return;\n    if (t.kind === 'var') {\n      if (!seen.includes(t.name)) seen.push(t.name);\n    } else if (t.kind === 'func') {\n      t.params.forEach(collectVars); collectVars(t.ret);\n    } else if (t.kind === 'obj') {\n      Object.values(t.fields).forEach(collectVars);\n    } else if (t.kind === 'union' || t.kind === 'inter') {\n      t.types.forEach(collectVars);\n    } else if (t.kind === 'app') {\n      t.args.forEach(collectVars);\n    } else if (t.kind === 'name') {\n      if (t.params) t.params.forEach(collectVars);\n    }\n  }\n  collectVars(decl);\n  for (let i=0;i<seen.length;i++) {\n    mapping[seen[i]] = args[i] || tVar(\"_\");\n  }\n  function subst(t) {\n    if (!t) return t;\n    if (t.kind === 'var') {\n      if (mapping[t.name]) return mapping[t.name];\n      return t;\n    }\n    if (t.kind === 'func') return tFunc(t.params.map(subst), subst(t.ret));\n    if (t.kind === 'obj') {\n      const f = {};\n      for (const k in t.fields) f[k] = subst(t.fields[k]);\n      return tObj(f);\n    }\n    if (t.kind === 'union') return tUnion(t.types.map(subst));\n    if (t.kind === 'inter') return tInter(t.types.map(subst));\n    if (t.kind === 'app') return tApp(t.name, t.args.map(subst));\n    if (t.kind === 'name') return tName(t.name, (t.params||[]).map(subst));\n    return t;\n  }\n  return subst(decl);\n}\n\n/* ---------- UI glue ---------- */\n\nfunction refreshTypeList() {\n  const sel = document.getElementById('typesList');\n  sel.innerHTML = '';\n  for (const name of Object.keys(env.types)) {\n    const opt = document.createElement('option');\n    opt.value = name;\n    opt.textContent = name + \" = \" + typeToString(env.types[name].type) + (env.types[name].alias ? \" (alias)\" : \"\");\n    sel.appendChild(opt);\n  }\n  refreshTypeOptions();\n}\n\nfunction refreshTypeOptions() {\n  const sel = document.getElementById('varTypeSelect');\n  sel.innerHTML = '';\n  const sel2 = document.getElementById('opTypeA') || null;\n  const sel3 = document.getElementById('opTypeB') || null;\n  const all = Object.keys(env.types);\n  for (const name of all) {\n    const o = document.createElement('option'); o.value = name; o.textContent = name;\n    sel.appendChild(o);\n  }\n  // also primitives quick add\n  ['Int','String','Bool','Float'].forEach(p => {\n    const o = document.createElement('option'); o.value = p; o.textContent = p; sel.appendChild(o);\n  });\n  // update operation selects if present\n  if (sel2) { sel2.innerHTML = ''; all.forEach(n => { const o = document.createElement('option'); o.value=n; o.textContent = n; sel2.appendChild(o); }); ['Int','String','Bool','Float'].forEach(p=>{const o=document.createElement('option');o.value=p;o.textContent=p;sel2.appendChild(o);}) }\n  if (sel3) { sel3.innerHTML = ''; all.forEach(n => { const o = document.createElement('option'); o.value=n; o.textContent = n; sel3.appendChild(o); }); ['Int','String','Bool','Float'].forEach(p=>{const o=document.createElement('option');o.value=p;o.textContent=p;sel3.appendChild(o);}) }\n}\n\nfunction refreshVarList() {\n  const sel = document.getElementById('varsList');\n  sel.innerHTML = '';\n  for (const v of Object.keys(env.vars)) {\n    const opt = document.createElement('option');\n    opt.value = v;\n    opt.textContent = v + \" : \" + typeToString(env.vars[v]);\n    sel.appendChild(opt);\n  }\n}\n\nfunction refreshUI() {\n  refreshTypeList();\n  refreshVarList();\n  setSubstDisplay(env.lastSubst || {});\n  updateTraceControls();\n}\n\n/* ---------- Operations UI ---------- */\n\nfunction buildOpControls() {\n  const container = document.getElementById('opControls');\n  container.innerHTML = '';\n  const op = document.getElementById('operationSelect').value;\n  // create generic selects for type A and B\n  function mkSelect(id) {\n    const s = document.createElement('select'); s.id = id; s.className = 'small';\n    // options will be filled by refreshTypeOptions\n    return s;\n  }\n\n  if (op === 'unify' || op === 'subtype') {\n    const a = mkSelect('opTypeA'); const b = mkSelect('opTypeB');\n    container.appendChild(document.createTextNode(\"Type A: \"));\n    container.appendChild(a);\n    container.appendChild(document.createTextNode(\" Type B: \"));\n    container.appendChild(b);\n    refreshTypeOptions();\n  } else if (op === 'instantiate') {\n    const sel = mkSelect('opTypeA');\n    container.appendChild(document.createTextNode(\"Generic Type Name: \"));\n    container.appendChild(sel);\n    refreshTypeOptions();\n    container.appendChild(document.createTextNode(\" Type args (comma separated expressions): \"));\n    const inpe = document.createElement('input'); inpe.id='instantiateArgs'; inpe.className='wide';\n    inpe.placeholder = \"e.g. Int,String or T,U\";\n    container.appendChild(inpe);\n  } else if (op === 'apply') {\n    const sel = mkSelect('opTypeA');\n    container.appendChild(document.createTextNode(\"Type to apply substitution to: \"));\n    container.appendChild(sel);\n    refreshTypeOptions();\n  } else if (op === 'simplify') {\n    const inp = document.createElement('input'); inp.id='simplifyExpr'; inp.className='wide';\n    inp.placeholder = \"Type expression to simplify\";\n    container.appendChild(inp);\n  } else if (op === 'infer_simple') {\n    const vsel = document.createElement('select'); vsel.id='inferVar'; vsel.className='small';\n    for (const n in env.vars) { const o=document.createElement('option'); o.value=n; o.textContent=n; vsel.appendChild(o); }\n    const callName = document.createElement('input'); callName.id='inferCall'; callName.className='small'; callName.placeholder='call with var name (optional)';\n    container.appendChild(document.createTextNode(\"Use variable: \"));\n    container.appendChild(vsel);\n    container.appendChild(document.createTextNode(\" Call with argument var (optional): \"));\n    container.appendChild(callName);\n  }\n}\n\n/* ---------- Execution ---------- */\n\ndocument.getElementById('operationSelect').addEventListener('change', buildOpControls);\n\n/* Add type buttons */\n\ndocument.getElementById('addTypeBtn').addEventListener('click', () => {\n  const n = document.getElementById('newTypeName').value.trim();\n  const expr = document.getElementById('newTypeExpr').value.trim();\n  if (!n || !expr) { alert(\"Provide name and type expression\"); return; }\n  try {\n    const t = parseType(expr);\n    env.types[n] = { type: t, alias: false };\n    log(\"Added type \" + n + \" = \" + typeToString(t));\n    refreshUI();\n  } catch (e) {\n    alert(\"Parse error: \" + e.message);\n  }\n});\n\ndocument.getElementById('aliasTypeBtn').addEventListener('click', () => {\n  const n = document.getElementById('newTypeName').value.trim();\n  const expr = document.getElementById('newTypeExpr').value.trim();\n  if (!n || !expr) { alert(\"Provide name and type expression\"); return; }\n  try {\n    const t = parseType(expr);\n    env.types[n] = { type: t, alias: true };\n    log(\"Added alias \" + n + \" = \" + typeToString(t));\n    refreshUI();\n  } catch (e) {\n    alert(\"Parse error: \" + e.message);\n  }\n});\n\n/* View/Edit/Delete type */\n\ndocument.getElementById('viewTypeBtn').addEventListener('click', () => {\n  const sel = document.getElementById('typesList');\n  const name = sel.value;\n  if (!name) { alert(\"Select a type\"); return; }\n  const obj = env.types[name];\n  alert(name + \" = \" + typeToString(obj.type) + (obj.alias ? \" (alias)\" : \"\"));\n});\n\ndocument.getElementById('editTypeBtn').addEventListener('click', () => {\n  const sel = document.getElementById('typesList');\n  const name = sel.value;\n  if (!name) { alert(\"Select a type\"); return; }\n  const newExpr = prompt(\"Edit type expression for \" + name, typeToString(env.types[name].type));\n  if (newExpr === null) return;\n  try {\n    const t = parseType(newExpr);\n    env.types[name].type = t;\n    log(\"Edited type \" + name + \" => \" + typeToString(t));\n    refreshUI();\n  } catch (e) {\n    alert(\"Parse error: \" + e.message);\n  }\n});\n\ndocument.getElementById('deleteTypeBtn').addEventListener('click', () => {\n  const sel = document.getElementById('typesList');\n  const name = sel.value;\n  if (!name) { alert(\"Select a type\"); return; }\n  if (!confirm(\"Delete type \" + name + \"?\")) return;\n  delete env.types[name];\n  log(\"Deleted type \" + name);\n  refreshUI();\n});\n\n/* Variables */\n\ndocument.getElementById('addVarBtn').addEventListener('click', () => {\n  const name = document.getElementById('newVarName').value.trim();\n  if (!name) { alert(\"Provide variable name\"); return; }\n  const typeName = document.getElementById('varTypeSelect').value;\n  if (!typeName) { alert(\"Select a type\"); return; }\n  // if typeName is a primitive (like Int) create that primitive type, else use env type\n  let ty;\n  if (env.types[typeName]) ty = cloneType(env.types[typeName].type);\n  else ty = tPrim(typeName);\n  env.vars[name] = ty;\n  log(\"Added variable \" + name + \" : \" + typeToString(ty));\n  refreshUI();\n});\n\ndocument.getElementById('viewVarBtn').addEventListener('click', () => {\n  const sel = document.getElementById('varsList');\n  const name = sel.value;\n  if (!name) { alert(\"Select a variable\"); return; }\n  alert(name + \" : \" + typeToString(env.vars[name]));\n});\n\ndocument.getElementById('deleteVarBtn').addEventListener('click', () => {\n  const sel = document.getElementById('varsList');\n  const name = sel.value;\n  if (!name) { alert(\"Select a variable\"); return; }\n  delete env.vars[name];\n  log(\"Deleted variable \" + name);\n  refreshUI();\n});\n\n/* Run operation */\n\ndocument.getElementById('runOpBtn').addEventListener('click', () => {\n  const op = document.getElementById('operationSelect').value;\n  const nominal = document.getElementById('nominalMode').checked;\n  const allowWild = document.getElementById('allowWild').checked;\n  const recDepth = parseInt(document.getElementById('recDepth').value,10) || 6;\n  document.getElementById('recDepthVal').textContent = recDepth;\n  try {\n    if (op === 'unify') {\n      const aName = document.getElementById('opTypeA').value;\n      const bName = document.getElementById('opTypeB').value;\n      if (!aName || !bName) { alert(\"Select two types\"); return; }\n      const a = env.types[aName] ? cloneType(env.types[aName].type) : parseType(aName);\n      const b = env.types[bName] ? cloneType(env.types[bName].type) : parseType(bName);\n      log(\"Unifying \" + typeToString(a) + \"  and  \" + typeToString(b) + \"  (nominal=\" + nominal + \")\");\n      const subst = unify(a,b,{nominal,allowWild});\n      setSubstDisplay(subst);\n      log(\"Unification success. Substitution: \" + Object.keys(subst).map(k => k+\"->\"+typeToString(subst[k])).join(\", \"));\n    } else if (op === 'subtype') {\n      const aName = document.getElementById('opTypeA').value;\n      const bName = document.getElementById('opTypeB').value;\n      if (!aName || !bName) { alert(\"Select two types\"); return; }\n      const a = env.types[aName] ? cloneType(env.types[aName].type) : parseType(aName);\n      const b = env.types[bName] ? cloneType(env.types[bName].type) : parseType(bName);\n      log(\"Checking subtyping \" + typeToString(a) + \" <: \" + typeToString(b) + \" (nominal=\" + nominal + \")\");\n      const res = isSubtype(a,b,{nominal,allowWild});\n      log(\"Result: \" + res);\n      setSubstDisplay({});\n    } else if (op === 'instantiate') {\n      const base = document.getElementById('opTypeA').value;\n      if (!base) { alert(\"Select a generic type name\"); return; }\n      const argsExpr = document.getElementById('instantiateArgs').value.trim();\n      const argList = argsExpr ? argsExpr.split(',').map(s => s.trim()) : [];\n      const args = argList.map(s => {\n        try { return parseType(s); } catch (e) { if (env.types[s]) return cloneType(env.types[s].type); throw e; }\n      });\n      const inst = instantiate(base, args);\n      log(\"Instantiated \" + base + \"<\" + argList.join(\",\") + \"> => \" + typeToString(inst));\n      setSubstDisplay({});\n    } else if (op === 'apply') {\n      const aName = document.getElementById('opTypeA').value;\n      if (!aName) { alert(\"Select a type\"); return; }\n      const ty = env.types[aName] ? cloneType(env.types[aName].type) : parseType(aName);\n      // apply lastSubst\n      const s = env.lastSubst || {};\n      function apply(t) {\n        if (!t) return t;\n        if (t.kind === 'var' && s[t.name]) return apply(s[t.name]);\n        if (t.kind === 'func') return tFunc(t.params.map(apply), apply(t.ret));\n        if (t.kind === 'obj') { const f={}; for (const k in t.fields) f[k]=apply(t.fields[k]); return tObj(f); }\n        if (t.kind === 'union') return tUnion(t.types.map(apply));\n        if (t.kind === 'inter') return tInter(t.types.map(apply));\n        if (t.kind === 'app') return tApp(t.name, t.args.map(apply));\n        return t;\n      }\n      const newt = apply(ty);\n      log(\"Applied substitution to \" + typeToString(ty) + \" => \" + typeToString(newt));\n      setSubstDisplay(env.lastSubst || {});\n    } else if (op === 'simplify') {\n      const expr = document.getElementById('simplifyExpr').value.trim();\n      if (!expr) { alert(\"Provide expression\"); return; }\n      const ty = parseType(expr);\n      // very simple normalization: resolve named aliases in structural mode\n      function norm(t) {\n        if (!t) return t;\n        if (t.kind === 'name' && env.types[t.name]) return norm(env.types[t.name].type);\n        if (t.kind === 'func') return tFunc(t.params.map(norm), norm(t.ret));\n        if (t.kind === 'obj') { const f={}; for (const k in t.fields) f[k]=norm(t.fields[k]); return tObj(f); }\n        if (t.kind === 'union') return tUnion(t.types.map(norm));\n        if (t.kind === 'inter') return tInter(t.types.map(norm));\n        if (t.kind === 'app') return tApp(t.name, t.args.map(norm));\n        return t;\n      }\n      const n = norm(ty);\n      log(\"Simplified \" + typeToString(ty) + \" => \" + typeToString(n));\n    } else if (op === 'infer_simple') {\n      const v = document.getElementById('inferVar').value;\n      if (!v) { alert(\"Select a variable\"); return; }\n      const callArg = document.getElementById('inferCall').value.trim();\n      const ty = env.vars[v];\n      if (!ty) { alert(\"Variable not found\"); return; }\n      if (!callArg) {\n        log(\"Inference: variable \" + v + \" has type \" + typeToString(ty));\n      } else {\n        const argTy = env.vars[callArg];\n        if (!argTy) { alert(\"Argument variable not found\"); return; }\n        // if ty is a function type, check arg compatibility and report result\n        if (ty.kind !== 'func') { log(\"Variable \" + v + \" is not a function\"); return; }\n        if (ty.params.length !== 1) { log(\"Only single param functions supported for this simple infer\"); return; }\n        // check subtype argTy <: param\n        const ok = isSubtype(argTy, ty.params[0], {nominal: document.getElementById('nominalMode').checked, allowWild: document.getElementById('allowWild').checked});\n        log(\"Call \" + v + \"(\" + callArg + \") : arg type \" + typeToString(argTy) + (ok ? \" is compatible \" : \" is NOT compatible \") + \"with param \" + typeToString(ty.params[0]) + \". Result type: \" + typeToString(ty.ret));\n      }\n    }\n  } catch (e) {\n    log(\"Error: \" + e.message);\n  }\n  updateTraceControls();\n});\n\n/* Trace navigation */\n\nfunction updateTraceControls() {\n  const s = env.trace || [];\n  const slider = document.getElementById('traceSlider');\n  if (!s || s.length === 0) {\n    slider.max = 0; slider.value = 0;\n  } else {\n    slider.max = Math.max(0, s.length-1);\n    slider.value = Math.min(slider.value || 0, slider.max);\n  }\n  showTraceAt(parseInt(slider.value || 0, 10));\n}\n\ndocument.getElementById('traceSlider').addEventListener('input', (e) => {\n  showTraceAt(parseInt(e.target.value,10));\n});\n\ndocument.getElementById('stepPrevBtn').addEventListener('click', () => {\n  const slider = document.getElementById('traceSlider');\n  slider.value = Math.max(0, parseInt(slider.value,10)-1);\n  showTraceAt(parseInt(slider.value,10));\n});\n\ndocument.getElementById('stepNextBtn').addEventListener('click', () => {\n  const slider = document.getElementById('traceSlider');\n  slider.value = Math.min(slider.max, parseInt(slider.value,10)+1);\n  showTraceAt(parseInt(slider.value,10));\n});\n\nfunction showTraceAt(idx) {\n  const t = env.trace || [];\n  const out = document.getElementById('logArea');\n  const line = t[idx];\n  if (!line) {\n    // nothing\n    return;\n  }\n  const a = typeToString(line.a || tPrim(\"null\"));\n  const b = typeToString(line.b || tPrim(\"null\"));\n  const action = line.action || \"\";\n  // show a summary appended to log (do not clear previous logs)\n  log(\"Trace[\" + idx + \"]: \" + action + \"  |  A=\" + a + \"  B=\" + b + \"  Subst=\" + JSON.stringify(line.subst || {}));\n  setSubstDisplay(line.subst || {});\n}\n\n/* Clear log and reset env controls */\n\ndocument.getElementById('clearLogBtn').addEventListener('click', () => {\n  document.getElementById('logArea').textContent = \"\";\n});\n\ndocument.getElementById('resetEnvBtn').addEventListener('click', () => {\n  if (!confirm(\"Reset environment and clear types/vars?\")) return;\n  resetEnv();\n});\n\n/* Scenarios */\n\nconst scenarios = {\n  simple: function() {\n    env.types = {};\n    env.vars = {};\n    env.types['Int'] = { type: tPrim('Int'), alias: false };\n    env.types['String'] = { type: tPrim('String'), alias: false };\n    env.types['Bool'] = { type: tPrim('Bool'), alias: false };\n    env.types['Pair'] = { type: parseType(\"{fst:Int, snd:Int}\"), alias: false };\n    env.vars['x'] = parseType('Int');\n    env.vars['s'] = parseType('String');\n    log(\"Loaded simple primitives scenario.\");\n    refreshUI();\n  },\n  functions: function() {\n    env.types = {};\n    env.vars = {};\n    env.types['Int'] = { type: tPrim('Int') };\n    env.types['String'] = { type: tPrim('String') };\n    env.types['Adder'] = { type: parseType(\"(Int) -> Int\") };\n    env.types['ToString'] = { type: parseType(\"(Int) -> String\") };\n    env.vars['f'] = parseType(\"(Int) -> Int\");\n    env.vars['g'] = parseType(\"(String) -> Int\");\n    log(\"Loaded functions scenario (try subtyping and contravariant parameter checks).\");\n    refreshUI();\n  },\n  generics: function() {\n    env.types = {};\n    env.vars = {};\n    // define generic List<T> as {head:T, tail:List<T>} recursive (we store as name alias)\n    env.types['List'] = { type: parseType(\"{head:a, tail:List<a>}\"), alias: false };\n    env.types['Int'] = { type: tPrim('Int') };\n    env.types['Pair'] = { type: parseType(\"{fst:a, snd:b}\") };\n    log(\"Loaded generics scenario. 'List' uses type variable 'a' inside its alias.\");\n    refreshUI();\n  },\n  objects: function() {\n    env.types = {};\n    env.vars = {};\n    env.types['Point2D'] = { type: parseType(\"{x:Float, y:Float}\") };\n    env.types['Point3D'] = { type: parseType(\"{x:Float, y:Float, z:Float}\") };\n    env.types['HasX'] = { type: parseType(\"{x:Float}\") };\n    env.vars['p2'] = parseType('Point2D');\n    env.vars['p3'] = parseType('Point3D');\n    log(\"Loaded object subtyping scenario. Try checking Point3D <: Point2D, etc.\");\n    refreshUI();\n  },\n  nominal: function() {\n    env.types = {};\n    env.vars = {};\n    env.types['Meter'] = { type: parseType('Float'), alias: true };\n    env.types['Second'] = { type: parseType('Float'), alias: true };\n    env.vars['t'] = parseType('Meter');\n    env.vars['s'] = parseType('Second');\n    log(\"Loaded nominal scenario where Meter and Second are aliases but in nominal mode they are distinct.\");\n    refreshUI();\n  },\n  unions: function() {\n    env.types = {};\n    env.vars = {};\n    env.types['A'] = { type: parseType(\"{x:Int}\") };\n    env.types['B'] = { type: parseType(\"{y:Int}\") };\n    env.types['AorB'] = { type: parseType(\"{x:Int} | {y:Int}\") };\n    env.vars['a'] = parseType('A');\n    env.vars['b'] = parseType('B');\n    log(\"Loaded unions/intersections scenario.\");\n    refreshUI();\n  }\n};\n\ndocument.getElementById('loadScenarioBtn').addEventListener('click', () => {\n  const name = document.getElementById('scenarioSelect').value;\n  if (!scenarios[name]) { alert(\"Scenario not found\"); return; }\n  scenarios[name]();\n});\n\n/* Save / Load environment JSON */\n\ndocument.getElementById('saveEnvBtn').addEventListener('click', () => {\n  // export env.types and env.vars in textual form for ease\n  const exportObj = { types: {}, vars: {} };\n  for (const n in env.types) exportObj.types[n] = typeToString(env.types[n].type);\n  for (const v in env.vars) exportObj.vars[v] = typeToString(env.vars[v]);\n  document.getElementById('envJson').value = JSON.stringify(exportObj, null, 2);\n});\n\ndocument.getElementById('loadEnvBtn').addEventListener('click', () => {\n  let j;\n  try { j = JSON.parse(document.getElementById('envJson').value); } catch (e) { alert(\"Bad JSON\"); return; }\n  env.types = {};\n  env.vars = {};\n  for (const n in j.types) {\n    try { env.types[n] = { type: parseType(j.types[n]), alias: false }; } catch (e) { alert(\"Error parsing type \" + n + \": \" + e.message); return; }\n  }\n  for (const v in j.vars) {\n    try { env.vars[v] = parseType(j.vars[v]); } catch (e) { alert(\"Error parsing var \" + v + \": \" + e.message); return; }\n  }\n  log(\"Imported environment from JSON.\");\n  refreshUI();\n});\n\n/* Misc initial setup */\n\nresetEnv();\nbuildOpControls();\nupdateTraceControls();\n\n/* populate simple default scenario */\nscenarios.simple();\n\n</script>\n</body>\n</html>"
  },
