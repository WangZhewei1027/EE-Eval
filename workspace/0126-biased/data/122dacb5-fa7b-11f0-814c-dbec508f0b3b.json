    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interpreter</title>\n    <style>\n        body {\n            font-family: monospace;\n            text-align: center;\n            margin: 0;\n            padding: 0;\n        }\n        #input {\n            padding: 10px;\n            border: 1px solid black;\n            width: 50%;\n        }\n        #output {\n            padding: 10px;\n            border: 1px solid black;\n            width: 50%;\n            height: 100px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"input\">\n        <input type=\"text\" id=\"input1\" placeholder=\"Enter a string\">\n        <button id=\"submit\">Submit</button>\n    </div>\n    <div id=\"output\">\n        <pre id=\"output1\"></pre>\n    </div>\n\n    <script>\n        let input1 = document.getElementById('input1');\n        let submitButton = document.getElementById('submit');\n        let output1 = document.getElementById('output1');\n\n        function handleInput() {\n            let inputStr = input1.value;\n            if (inputStr.length > 100) {\n                output1.innerText = \"Input too long. Please enter a string less than 100 characters.\";\n                return;\n            }\n            output1.innerText = \"\";\n            submitButton.disabled = false;\n            submitButton.textContent = \"Submit\";\n            let time = 0;\n            let intervalId = setInterval(() => {\n                time++;\n                if (time > 100) {\n                    clearInterval(intervalId);\n                    output1.innerText = \"You have submitted the input for 100 iterations. Please try again.\";\n                    submitButton.disabled = true;\n                    submitButton.textContent = \"Submit\";\n                }\n            }, 1000);\n        }\n\n        submitButton.addEventListener('click', handleInput);\n    </script>\n</body>\n</html>"
