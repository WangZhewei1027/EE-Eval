    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Suffix Tree Interactive Demo</title>\n    <script>\n        class SuffixTreeNode {\n            constructor() {\n                this.children = {};\n                this.isEndOfString = false;\n        }\n        }\n\n        class SuffixTree {\n            constructor() {\n                this.root = new SuffixTreeNode();\n            }\n\n            insert(text) {\n                for (let i = 0; i < text.length; i++) {\n                    let currentNode = this.root;\n                    for (let j = i; j < text.length; j++) {\n                        const char = text[j];\n                        if (!currentNode.children[char]) {\n                            currentNode.children[char] = new SuffixTreeNode();\n                        }\n                        currentNode = currentNode.children[char];\n                    }\n                    currentNode.isEndOfString = true;\n                }\n            }\n\n            search(pattern) {\n                let currentNode = this.root;\n                for (const char of pattern) {\n                    if (!currentNode.children[char]) {\n                        return false;\n                    }\n                    currentNode = currentNode.children[char];\n                }\n                return currentNode.isEndOfString;\n            }\n\n            getSuffixes() {\n                const suffixes = [];\n                const collectSuffixes = (node, path) => {\n                    if (node.isEndOfString) {\n                        suffixes.push(path);\n                    }\n                    for (const char in node.children) {\n                        collectSuffixes(node.children[char], path + char);\n                    }\n                };\n                collectSuffixes(this.root, \"\");\n                return suffixes;\n            }\n        }\n\n        let suffixTree = new SuffixTree();\n\n        function insertText() {\n            const input = document.getElementById(\"insertInput\").value;\n            if (input) {\n                suffixTree.insert(input);\n                document.getElementById(\"insertInput\").value = \"\";\n                updateSuffixes();\n            }\n        }\n\n        function searchPattern() {\n            const pattern = document.getElementById(\"searchInput\").value;\n            const result = suffixTree.search(pattern);\n            alert(result ? \"Pattern found!\" : \"Pattern not found!\");\n            document.getElementById(\"searchInput\").value = \"\";\n        }\n\n        function updateSuffixes() {\n            const suffixes = suffixTree.getSuffixes();\n            const suffixList = document.getElementById(\"suffixes\");\n            suffixList.innerHTML = \"\"; // Clear existing list\n            suffixes.forEach(suffix => {\n                const listItem = document.createElement(\"li\");\n                listItem.textContent = suffix;\n                suffixList.appendChild(listItem);\n            });\n        }\n    </script>\n</head>\n<body>\n    <h1>Suffix Tree Interactive Demo</h1>\n    \n    <div>\n        <label for=\"insertInput\">Insert Text:</label>\n        <input type=\"text\" id=\"insertInput\">\n        <button onclick=\"insertText()\">Insert</button>\n    </div>\n\n    <div>\n        <label for=\"searchInput\">Search Pattern:</label>\n        <input type=\"text\" id=\"searchInput\">\n        <button onclick=\"searchPattern()\">Search</button>\n    </div>\n\n    <h2>Generated Suffixes:</h2>\n    <ul id=\"suffixes\"></ul>\n</body>\n</html>"
