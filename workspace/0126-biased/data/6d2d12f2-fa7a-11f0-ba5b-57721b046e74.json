  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>AVL Tree Interactive Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        canvas {\n            border: 1px solid #000;\n            margin-top: 20px;\n        }\n        input, button, select {\n            margin: 5px;\n        }\n        .tree-info {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>AVL Tree Interactive Visualization</h1>\n    <div class=\"container\">\n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Node Operations</h3>\n                <input type=\"number\" id=\"nodeValue\" placeholder=\"Enter value\">\n                <button onclick=\"insertNode()\">Insert</button>\n                <button onclick=\"deleteNode()\">Delete</button>\n                <button onclick=\"findNode()\">Find</button>\n                <button onclick=\"clearTree()\">Clear Tree</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Tree Generation</h3>\n                <input type=\"number\" id=\"randomCount\" placeholder=\"Node count\" min=\"1\" max=\"50\" value=\"10\">\n                <button onclick=\"generateRandomTree()\">Generate Random Tree</button>\n                <button onclick=\"generateBalancedTree()\">Generate Balanced Tree</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Traversal</h3>\n                <button onclick=\"traverse('inorder')\">Inorder</button>\n                <button onclick=\"traverse('preorder')\">Preorder</button>\n                <button onclick=\"traverse('postorder')\">Postorder</button>\n                <button onclick=\"traverse('levelorder')\">Level Order</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Visualization</h3>\n                <label>Node Size: <input type=\"range\" id=\"nodeSize\" min=\"20\" max=\"100\" value=\"40\" onchange=\"updateVisualization()\"></label>\n                <label>Spacing: <input type=\"range\" id=\"treeSpacing\" min=\"50\" max=\"300\" value=\"150\" onchange=\"updateVisualization()\"></label>\n                <label>Speed: <input type=\"range\" id=\"animationSpeed\" min=\"100\" max=\"2000\" value=\"500\"></label>\n                <button onclick=\"toggleDetails()\">Toggle Details</button>\n            </div>\n        </div>\n        \n        <canvas id=\"treeCanvas\" width=\"1200\" height=\"600\"></canvas>\n        \n        <div class=\"tree-info\">\n            <h3>Tree Information</h3>\n            <div id=\"treeStats\">Nodes: 0 | Height: 0 | Balanced: Yes</div>\n            <div id=\"operationLog\">No operations yet</div>\n            <div id=\"traversalResult\"></div>\n        </div>\n    </div>\n\n    <script>\n        // AVL Tree implementation\n        class AVLNode {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n                this.height = 1;\n                this.balanceFactor = 0;\n            }\n        }\n\n        class AVLTree {\n            constructor() {\n                this.root = null;\n                this.operations = [];\n                this.highlightedNode = null;\n            }\n\n            getHeight(node) {\n                return node ? node.height : 0;\n            }\n\n            updateHeight(node) {\n                node.height = Math.max(this.getHeight(node.left), this.getHeight(node.right)) + 1;\n                node.balanceFactor = this.getHeight(node.left) - this.getHeight(node.right);\n            }\n\n            rotateRight(y) {\n                const x = y.left;\n                const T2 = x.right;\n\n                x.right = y;\n                y.left = T2;\n\n                this.updateHeight(y);\n                this.updateHeight(x);\n\n                this.operations(`Rotate right at ${y.value}`);\n                return x;\n            }\n\n            rotateLeft(x) {\n                const y = x.right;\n                const T2 = y.left;\n\n                y.left = x;\n                x.right = T2;\n\n                this.updateHeight(x);\n                this.updateHeight(y);\n\n                this.operations(`Rotate left at ${x.value}`);\n                return y;\n            }\n\n            balance(node) {\n                if (!node) return node;\n\n                this.updateHeight(node);\n\n                // Left heavy\n                if (node.balanceFactor > 1) {\n                    if (node.left.balanceFactor < 0) {\n                        node.left = this.rotateLeft(node.left);\n                    }\n                    return this.rotateRight(node);\n                }\n\n                // Right heavy\n                if (node.balanceFactor < -1) {\n                    if (node.right.balanceFactor > 0) {\n                        node.right = this.rotateRight(node.right);\n                    }\n                    return this.rotateLeft(node);\n                }\n\n                return node;\n            }\n\n            insert(value) {\n                this.root = this._insert(this.root, value);\n                this.operations(`Inserted ${value}`);\n            }\n\n            _insert(node, value) {\n                if (!node) return new AVLNode(value);\n\n                if (value < node.value) {\n                    node.left = this._insert(node.left, value);\n                } else if (value > node.value) {\n                    node.right = this._insert(node.right, value);\n                } else {\n                    return node; // No duplicates\n                }\n\n                return this.balance(node);\n            }\n\n            delete(value) {\n                this.root = this._delete(this.root, value);\n                this.operations(`Deleted ${value}`);\n            }\n\n            _delete(node, value) {\n                if (!node) return null;\n\n                if (value < node.value) {\n                    node.left = this._delete(node.left, value);\n                } else if (value > node.value) {\n                    node.right = this._delete(node.right, value);\n                } else {\n                    if (!node.left || !node.right) {\n                        node = node.left || node.right;\n                    } else {\n                        const minRight = this.findMin(node.right);\n                        node.value = minRight.value;\n                        node.right = this._delete(node.right, minRight.value);\n                    }\n                }\n\n                if (!node) return null;\n                return this.balance(node);\n            }\n\n            findMin(node) {\n                while (node && node.left) {\n                    node = node.left;\n                }\n                return node;\n            }\n\n            find(value) {\n                return this._find(this.root, value);\n            }\n\n            _find(node, value) {\n                if (!node) return null;\n                if (value === node.value) return node;\n                if (value < node.value) return this._find(node.left, value);\n                return this._find(node.right, value);\n            }\n\n            isBalanced() {\n                return this._isBalanced(this.root);\n            }\n\n            _isBalanced(node) {\n                if (!node) return true;\n                const balance = Math.abs(this.getHeight(node.left) - this.getHeight(node.right)) <= 1;\n                return balance && this._isBalanced(node.left) && this._isBalanced(node.right);\n            }\n\n            getNodeCount() {\n                return this._getNodeCount(this.root);\n            }\n\n            _getNodeCount(node) {\n                if (!node) return 0;\n                return 1 + this._getNodeCount(node.left) + this._getNodeCount(node.right);\n            }\n\n            operations(message) {\n                this.operations.push(message);\n                updateOperationLog();\n            }\n\n            clear() {\n                this.root = null;\n                this.operations = [];\n                this.highlightedNode = null;\n                this.operations(\"Tree cleared\");\n            }\n        }\n\n        // Visualization\n        const tree = new AVLTree();\n        const canvas = document.getElementById('treeCanvas');\n        const ctx = canvas.getContext('2d');\n        let showDetails = true;\n        let animationQueue = [];\n        let isAnimating = false;\n\n        function drawTree() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            if (tree.root) {\n                const nodeSize = parseInt(document.getElementById('nodeSize').value);\n                const spacing = parseInt(document.getElementById('treeSpacing').value);\n                drawNode(tree.root, canvas.width / 2, 50, spacing, nodeSize);\n            }\n        }\n\n        function drawNode(node, x, y, spacing, nodeSize) {\n            if (!node) return;\n\n            // Draw left child\n            if (node.left) {\n                const leftX = x - spacing;\n                const leftY = y + 80;\n                ctx.beginPath();\n                ctx.moveTo(x, y + nodeSize / 2);\n                ctx.lineTo(leftX, leftY - nodeSize / 2);\n                ctx.stroke();\n                drawNode(node.left, leftX, leftY, spacing / 1.8, nodeSize);\n            }\n\n            // Draw right child\n            if (node.right) {\n                const rightX = x + spacing;\n                const rightY = y + 80;\n                ctx.beginPath();\n                ctx.moveTo(x, y + nodeSize / 2);\n                ctx.lineTo(rightX, rightY - nodeSize / 2);\n                ctx.stroke();\n                drawNode(node.right, rightX, rightY, spacing / 1.8, nodeSize);\n            }\n\n            // Draw node\n            ctx.beginPath();\n            ctx.arc(x, y, nodeSize / 2, 0, Math.PI * 2);\n            // Highlight if this is the current node\n            if (tree.highlightedNode === node) {\n                ctx.fillStyle = 'rgba(200, 200, 0, 0.3)';\n                ctx.fill();\n            }\n            ctx.stroke();\n\n            // Draw value\n            ctx.fillStyle = '#000';\n            ctx.textAlign = 'center';\n            ctx.textBaseline = 'middle';\n            ctx.font = `${Math.max(12, nodeSize / 3)}px Arial`;\n            ctx.fillText(node.value, x, y);\n\n            // Draw details if enabled\n            if (showDetails) {\n                ctx.font = `${Math.max(10, nodeSize / 4)}px Arial`;\n                ctx.fillText(`h:${node.height}`, x, y + nodeSize / 2 + 15);\n                ctx.fillText(`b:${node.balanceFactor}`, x, y + nodeSize / 2 + 30);\n            }\n        }\n\n        function updateTreeStats() {\n            const stats = document.getElementById('treeStats');\n            const nodeCount = tree.getNodeCount();\n            const height = tree.root ? tree.root.height : 0;\n            const balanced = tree.isBalanced() ? \"Yes\" : \"No\";\n            stats.textContent = `Nodes: ${nodeCount} | Height: ${height} | Balanced: ${balanced}`;\n        }\n\n        function updateOperationLog() {\n            const log = document.getElementById('operationLog');\n            log.textContent = tree.operations.slice(-5).join(\" | \");\n        }\n\n        function updateVisualization() {\n            drawTree();\n        }\n\n        function toggleDetails() {\n            showDetails = !showDetails;\n            drawTree();\n        }\n\n        // Tree operations\n        function insertNode() {\n            const value = parseInt(document.getElementById('nodeValue').value);\n            if (isNaN(value)) return;\n            \n            tree.insert(value);\n            updateTreeOperation(() => {\n                updateTreeStats();\n                drawTree();\n            });\n        }\n\n        function deleteNode() {\n            const value = parseInt(document.getElementById('nodeValue').value);\n            if (isNaN(value)) return;\n            \n            tree.delete(value);\n            updateTreeOperation(() => {\n                updateTreeStats();\n                drawTree();\n            });\n        }\n\n        function findNode() {\n            const value = parseInt(document.getElementById('nodeValue').value);\n            if (isNaN(value)) return;\n            \n            const node = tree.find(value);\n            if (node) {\n                tree.highlightedNode = node;\n                drawTree();\n                setTimeout(() => {\n                    tree.highlightedNode = null;\n                    drawTree();\n                }, 1000);\n            }\n        }\n\n        function clearTree() {\n            tree.clear();\n            updateTreeStats();\n            drawTree();\n        }\n\n        function generateRandomTree() {\n            const count = parseInt(document.getElementById('randomCount').value);\n            if (isNaN(count) || count < 1 || count > 50) return;\n            \n            tree.clear();\n            const values = new Set();\n            while (values.size < count) {\n                values.add(Math.floor(Math.random() * 100) + 1);\n            }\n            \n            Array.from(values).forEach(value => tree.insert(value));\n            \n            updateTreeOperation(() => {\n                updateTreeStats();\n                drawTree();\n            });\n        }\n\n        function generateBalancedTree() {\n            const count = parseInt(document.getElementById('randomCount').value);\n            if (isNaN(count) || count < 1 || count > 50) return;\n            \n            tree.clear();\n            const sortedValues = Array.from({length: count}, (_, i) => i + 1);\n            buildBalancedTree(sortedValues, 0, sortedValues.length - 1);\n            \n            updateTreeOperation(() => {\n                updateTreeStats();\n                drawTree();\n            });\n        }\n\n        function buildBalancedTree(sortedValues, start, end) {\n            if (start > end) return;\n            \n            const mid = Math.floor((start + end) / 2);\n            tree.insert(sortedValues[mid]);\n            \n            buildBalancedTree(sortedValues, start, mid - 1);\n            buildBalancedTree(sortedValues, mid + 1, end);\n        }\n\n        // Traversal functions\n        function traverse(type) {\n            const resultDiv = document.getElementById('traversalResult');\n            resultDiv.textContent = `${type.toUpperCase()} Traversal: `;\n            \n            const values = [];\n            const speed = parseInt(document.getElementById('animationSpeed').value);\n            \n            switch (type) {\n                case 'inorder':\n                    inorderTraversal(tree.root, values);\n                    break;\n                case 'preorder':\n                    preorderTraversal(tree.root, values);\n                    break;\n                case 'postorder':\n                    postorderTraversal(tree.root, values);\n                    break;\n                case 'levelorder':\n                    levelOrderTraversal(tree.root, values);\n                    break;\n            }\n            \n            // Clear previous highlights\n            tree.highlightedNode = null;\n            drawTree();\n            \n            // Animate traversal\n            animateTraversal(values, speed, resultDiv);\n        }\n\n        function inorderTraversal(node, values) {\n            if (!node) return;\n            inorderTraversal(node.left, values);\n            values.push(node);\n            inorderTraversal(node.right, values);\n        }\n\n        function preorderTraversal(node, values) {\n            if (!node) return;\n            values.push(node);\n            preorderTraversal(node.left, values);\n            preorderTraversal(node.right, values);\n        }\n\n        function postorderTraversal(node, values) {\n            if (!node) return;\n            postorderTraversal(node.left, values);\n            postorderTraversal(node.right, values);\n            values.push(node);\n        }\n\n        function levelOrderTraversal(node, values) {\n            if (!node) return;\n            const queue = [node];\n            while (queue.length > 0) {\n                const current = queue.shift();\n                values.push(current);\n                if (current.left) queue.push(current.left);\n                if (current.right) queue.push(current.right);\n            }\n        }\n\n        function animateTraversal(nodes, speed, resultDiv) {\n            let i = 0;\n            const interval = setInterval(() => {\n                if (i >= nodes.length) {\n                    clearInterval(interval);\n                    tree.highlightedNode = null;\n                    drawTree();\n                    return;\n                }\n                \n                tree.highlightedNode = nodes[i];\n                drawTree();\n                resultDiv.textContent += nodes[i].value + (i < nodes.length - 1 ? \", \" : \"\");\n                i++;\n            }, speed);\n        }\n\n        function updateTreeOperation(callback) {\n            if (isAnimating) {\n                animationQueue.push(callback);\n                return;\n            }\n            \n            isAnimating = true;\n            const speed = parseInt(document.getElementById('animationSpeed').value);\n            \n            setTimeout(() => {\n                callback();\n                isAnimating = false;\n                \n                if (animationQueue.length > 0) {\n                    const nextCallback = animationQueue.shift();\n                    updateTreeOperation(nextCallback);\n                }\n            }, speed);\n        }\n\n        // Initialize\n        drawTree();\n        updateTreeStats();\n    </script>\n</body>\n</html>"
