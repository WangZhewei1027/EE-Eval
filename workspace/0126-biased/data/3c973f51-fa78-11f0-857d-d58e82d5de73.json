    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Visualization — Exquisite Design</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&family=Roboto+Slab&display=swap');\n\n  /* Root and Reset */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    color: #e0e6f1;\n    font-family: 'Roboto Slab', serif;\n    height: 100vh;\n    overflow: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 3.25rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    margin: 0 0 1rem;\n    color: #a3cef1;\n    text-shadow:\n      0 0 8px #78a7d0aa,\n      0 0 12px #5f8eb8cc;\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.1rem;\n    color: #a3a9b8cc;\n    margin: 0 0 3.5rem 0;\n    letter-spacing: 0.04em;\n  }\n\n  /* Container for search & array */\n  #container {\n    position: relative;\n    width: 90vw;\n    max-width: 1000px;\n    min-height: 380px;\n    background: rgba(32, 53, 67, 0.6);\n    border-radius: 1.8rem;\n    box-shadow:\n      inset 0 0 40px 6px #224858aa,\n      0 10px 40px 0 #183445cc;\n    padding: 3rem 3.5rem 4rem 3.5rem;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* Binary array row */\n  #array-row {\n    display: flex;\n    justify-content: center;\n    gap: 0.85rem;\n    margin-bottom: 3rem;\n    perspective: 1100px;\n  }\n\n  .array-element {\n    background: #1e3c5b;\n    box-shadow:\n      inset 0 0 3px #a3cef1dd,\n      0 0 22px 2px #69a9d833;\n    width: 54px;\n    height: 72px;\n    border-radius: 0.75rem;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.9rem;\n    line-height: 72px;\n    color: #bdd7f7;\n    text-shadow:\n      0 0 6px #83bff588;\n    user-select: none;\n    position: relative;\n    transition:\n      background-color 0.7s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.7s cubic-bezier(0.4, 0, 0.2, 1),\n      transform 0.9s ease;\n    cursor: default;\n    transform-style: preserve-3d;\n  }\n\n  .array-element.low {\n    background: #2f6ca3;\n    box-shadow:\n      0 0 10px 3px #4ea6ecaa;\n    color: #c0d6f9;\n    transform: translateY(8px) scale(1.05) translateZ(12px);\n  }\n\n  .array-element.high {\n    background: #2f6ca3;\n    box-shadow:\n      0 0 14px 4px #4ea6eccc;\n    color: #c0d6f9;\n    transform: translateY(8px) scale(1.05) translateZ(11px);\n  }\n\n  .array-element.mid {\n    background: #e1a44d;\n    box-shadow:\n      0 0 22px 8px #f2c24fee,\n      0 0 60px 20px #f2c24fbb;\n    color: #3f2d00;\n    text-shadow:\n      0 0 14px #f2c24fff;\n    transform: translateY(-6px) scale(1.2) translateZ(20px);\n    z-index: 22;\n  }\n\n  .array-element.found {\n    background: #4cc552;\n    box-shadow:\n      0 0 26px 10px #95de95ee,\n      0 0 70px 27px #95de95aa;\n    color: #1f2f16;\n    text-shadow:\n      0 0 22px #5ed665cc;\n    transform: translateY(-8px) scale(1.25) translateZ(24px) rotateY(15deg);\n    z-index: 28;\n  }\n\n  /* Search Instructions */\n  #info {\n    font-family: 'Montserrat', sans-serif;\n    letter-spacing: 0.04em;\n    font-weight: 600;\n    font-size: 1.22rem;\n    text-align: center;\n    margin-bottom: 2.2rem;\n    color: #80a6d6dd;\n    user-select: none;\n    min-height: 39px;\n    transition: color 0.5s ease;\n  }\n\n  /* Buttons container */\n  #controls {\n    width: 100%;\n    display: flex;\n    justify-content: center;\n    gap: 1.8rem;\n    pointer-events: auto;\n  }\n\n  button {\n    background: linear-gradient(145deg, #214264, #2a5980);\n    border: none;\n    border-radius: 0.95rem;\n    padding: 0.85rem 2.3rem;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    font-size: 1.1rem;\n    color: #b9d5ff;\n    box-shadow:\n      0 4px 15px #4885cfaa,\n      inset 0 2px 4px #6ba0dbbb;\n    cursor: pointer;\n    transition:\n      box-shadow 0.35s ease,\n      background 0.4s ease,\n      color 0.3s ease;\n    user-select: none;\n    text-transform: uppercase;\n    filter: drop-shadow(0 0 1px #6794dbcc);\n  }\n  button:hover {\n    background: linear-gradient(145deg, #2a5980, #4b8ee3);\n    box-shadow:\n      0 5px 25px #6ca6ffdd,\n      inset 0 2px 6px #9cc4f9ff;\n    color: #e7f1ff;\n  }\n  button:active {\n    filter: none;\n    box-shadow:\n      inset 0 2px 5px #265078;\n    background: linear-gradient(145deg, #1c3757, #214e79);\n    color: #bbe1ff;\n  }\n\n  /* Footer with author */\n  #footer {\n    position: fixed;\n    bottom: 14px;\n    font-family: 'Roboto Slab', serif;\n    font-size: 0.88rem;\n    color: #4b648baa;\n    user-select: none;\n    font-style: italic;\n    letter-spacing: 0.08em;\n  }\n\n  /* SVG animation elements */\n  svg#decorative-svg {\n    position: absolute;\n    top: 0;\n    left: 0;\n    pointer-events: none;\n    user-select: none;\n    width: 100%;\n    height: 100%;\n  }\n\n  /* Glow Layer */\n  #glowLayer circle {\n    filter: url(#glow);\n    transition: fill 0.5s ease;\n  }\n\n</style>\n</head>\n<body>\n\n<h1>Binary Search</h1>\n<h2>An elegant visual demonstration</h2>\n\n<div id=\"container\" role=\"main\" aria-label=\"Binary search visualization container\">\n\n  <div id=\"array-row\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n    <!-- Array elements inserted by JS -->\n  </div>\n\n  <div id=\"info\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"text\">\n    Click <strong>Start Search</strong> to see the binary search in action.\n  </div>\n\n  <div id=\"controls\">\n    <button id=\"startBtn\" aria-label=\"Start binary search animation\">Start Search</button>\n    <button id=\"resetBtn\" aria-label=\"Reset the visualization\" disabled>Reset</button>\n  </div>\n\n  <!-- Decorative SVG for subtle glowing arcs -->\n  <svg id=\"decorative-svg\" aria-hidden=\"true\" focusable=\"false\" viewBox=\"0 0 1000 380\" preserveAspectRatio=\"xMidYMid meet\" >\n    <defs>\n      <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\" color-interpolation-filters=\"sRGB\">\n        <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"6\" flood-color=\"#87cefa\" flood-opacity=\"0.3\"/>\n        <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"11\" flood-color=\"#5b9ad2\" flood-opacity=\"0.2\"/>\n      </filter>\n    </defs>\n\n    <circle cx=\"500\" cy=\"190\" r=\"160\" stroke=\"#3a5770\" stroke-width=\"1.2\" fill=\"none\" />\n    <circle cx=\"500\" cy=\"190\" r=\"135\" stroke=\"#3570a9\" stroke-width=\"1\" fill=\"none\" />\n    <circle cx=\"500\" cy=\"190\" r=\"110\" stroke=\"#4295e1\" stroke-width=\"0.7\" fill=\"none\" />\n    <circle id=\"glowCircle\" cx=\"500\" cy=\"190\" r=\"90\" fill=\"none\" stroke=\"#67b2ff\" stroke-width=\"1.8\" filter=\"url(#glow)\" opacity=\"0\" />\n  </svg>\n\n</div>\n\n<div id=\"footer\">Crafted with ♥ by AI Design</div>\n\n<script>\n  // Variables and constants\n  const arr = [3, 7, 12, 19, 23, 27, 31, 37, 42, 48, 54, 59, 63, 68, 73];\n  const target = 42;\n  const animationDelay = 1600;\n\n  const arrayRow = document.getElementById('array-row');\n  const info = document.getElementById('info');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const glowCircle = document.getElementById('glowCircle');\n\n  let timeoutIds = [];\n\n  // Create visual array elements\n  function createArrayElements() {\n    arrayRow.innerHTML = '';\n    for(let i = 0; i < arr.length; i++) {\n      const el = document.createElement('div');\n      el.classList.add('array-element');\n      el.textContent = arr[i];\n      el.dataset.index = i;\n      arrayRow.appendChild(el);\n    }\n  }\n\n  // Reset all styles and state\n  function resetVisualization() {\n    timeoutIds.forEach(clearTimeout);\n    timeoutIds.length = 0;\n    glowCircle.style.opacity = '0';\n    info.style.color = '#80a6d6dd';\n    info.innerHTML = 'Click <strong>Start Search</strong> to see the binary search in action.';\n    createArrayElements();\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Animate the binary search process\n  function binarySearchVisual(arr, target) {\n    let low = 0;\n    let high = arr.length - 1;\n    let step = 0;\n    const elements = arrayRow.children;\n\n    function markRange(low, high) {\n      for(let i = 0; i < elements.length; i++) {\n        elements[i].classList.remove('low','high','mid','found');\n        if(i < low || i > high) {\n          elements[i].style.opacity = '0.25';\n          elements[i].style.transform = 'scale(0.8) translateZ(0)';\n          elements[i].style.filter = 'grayscale(0.7) brightness(0.65)';\n        } else {\n          elements[i].style.opacity = '1';\n          elements[i].style.filter = 'none';\n          elements[i].style.transform = 'scale(1) translateZ(0)';\n        }\n      }\n      if(low <= high) {\n        elements[low].classList.add('low');\n        elements[high].classList.add('high');\n      }\n    }\n\n    function highlightMid(mid) {\n      for(let i = 0; i < elements.length; i++) {\n        elements[i].classList.remove('mid');\n      }\n      elements[mid].classList.add('mid');\n    }\n\n    function highlightFound(idx) {\n      elements[idx].classList.remove('mid');\n      elements[idx].classList.add('found');\n    }\n\n    // Glow circle animation on found element\n    function glowAtElement(idx) {\n      const el = elements[idx];\n      const rect = el.getBoundingClientRect();\n      const containerRect = arrayRow.getBoundingClientRect();\n\n      // Coordinates relative to SVG container\n      const cx = rect.left + rect.width/2 - containerRect.left;\n      const cy = rect.top + rect.height/2 - containerRect.top;\n\n      glowCircle.setAttribute('cx', cx);\n      glowCircle.setAttribute('cy', cy);\n      glowCircle.style.opacity = '1';\n      glowCircle.style.transition = 'opacity 0.7s ease-in-out';\n    }\n\n    // Stepwise animation loop\n    function stepSearch() {\n      if(low > high) {\n        info.style.color = '#de6868cc';\n        info.innerHTML = `<strong>Target <em>${target}</em> not found in the array.</strong>`;\n        startBtn.disabled = false;\n        resetBtn.disabled = false;\n        glowCircle.style.opacity = '0';\n        return;\n      }\n      markRange(low, high);\n\n      const mid = Math.floor((low + high)/2);\n      highlightMid(mid);\n\n      info.style.color = '#a9cdf4';\n      info.innerHTML = `Step ${step+1}: Checking middle index <strong>${mid}</strong>, value <strong>${arr[mid]}</strong>...`;\n\n      timeoutIds.push(setTimeout(() => {\n        if(arr[mid] === target) {\n          highlightFound(mid);\n          info.style.color = '#94d78e';\n          info.innerHTML = `<strong>Target <em>${target}</em> found at index <em>${mid}</em>!</strong>`;\n\n          glowAtElement(mid);\n\n          startBtn.disabled = false;\n          resetBtn.disabled = false;\n        } else if(arr[mid] < target) {\n          low = mid + 1;\n          step++;\n          stepSearch();\n        } else {\n          high = mid - 1;\n          step++;\n          stepSearch();\n        }\n      }, animationDelay));\n    }\n\n    stepSearch();\n  }\n\n  // Initialization\n  createArrayElements();\n\n  // Button handlers\n  startBtn.addEventListener('click', () => {\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    binarySearchVisual(arr, target);\n  });\n\n  resetBtn.addEventListener('click', resetVisualization);\n\n</script>\n\n</body>\n</html>"
