    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Heap Sort Visualization</title>\n    <style>\n        :root {\n            --primary-color: #3a0ca3;\n            --secondary-color: #7209b7;\n            --accent-color: #f72585;\n            --background-color: #1a1a2e;\n            --text-color: #e2e2e2;\n            --highlight-color: #4cc9f0;\n            --node-color: #4361ee;\n            --node-sorted: #4ad66d;\n            --node-compare: #ff9e00;\n            --node-parent: #f72585;\n            --node-active: #4cc9f0;\n        }\n\n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--background-color);\n            color: var(--text-color);\n            margin: 0;\n            padding: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .header {\n            text-align: center;\n            padding: 2rem;\n            width: 100%;\n            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);\n            margin-bottom: 2rem;\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            font-weight: 700;\n            margin: 0;\n            background: linear-gradient(to right, white, var(--highlight-color));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);\n        }\n\n        .subtitle {\n            font-size: 1.1rem;\n            opacity: 0.9;\n            margin-top: 0.5rem;\n            font-weight: 300;\n        }\n\n        .container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            width: 90%;\n            max-width: 1200px;\n            margin-bottom: 3rem;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            width: 100%;\n        }\n\n        button {\n            background: linear-gradient(135deg, var(--secondary-color), var(--accent-color));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            font-size: 1rem;\n            font-weight: 600;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);\n            background: linear-gradient(135deg, var(--accent-color), var(--secondary-color));\n        }\n\n        button:disabled {\n            opacity: 0.6;\n            transform: none;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n            cursor: not-allowed;\n        }\n\n        .visualization {\n            position: relative;\n            width: 100%;\n            min-height: 500px;\n            background: rgba(255, 255, 255, 0.03);\n            border-radius: 20px;\n            padding: 2rem;\n            box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.1), 0 10px 30px rgba(0, 0, 0, 0.3);\n            backdrop-filter: blur(5px);\n            overflow: hidden;\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 250px;\n            margin-bottom: 2rem;\n            position: relative;\n        }\n\n        .array-bar {\n            width: 40px;\n            margin: 0 3px;\n            transition: all 0.3s ease;\n            position: relative;\n            background-color: var(--node-color);\n            border-radius: 5px 5px 0 0;\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);\n        }\n\n        .array-bar.sorted {\n            background-color: var(--node-sorted);\n        }\n\n        .array-bar.comparing {\n            background-color: var(--node-compare);\n        }\n\n        .array-bar.parent {\n            background-color: var(--node-parent);\n        }\n\n        .array-bar.active {\n            background-color: var(--node-active);\n        }\n\n        .array-bar::after {\n            content: attr(data-value);\n            position: absolute;\n            top: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 0.9rem;\n            font-weight: 600;\n        }\n\n        .tree-container {\n            height: 300px;\n            width: 100%;\n            position: relative;\n            margin-top: 2rem;\n        }\n\n        .node {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background-color: var(--node-color);\n            color: white;\n            font-weight: bold;\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);\n            transition: all 0.5s ease;\n            z-index: 2;\n        }\n\n        .node.sorted {\n            background-color: var(--node-sorted);\n        }\n\n        .node.comparing {\n            background-color: var(--node-compare);\n        }\n\n        .node.parent {\n            background-color: var(--node-parent);\n        }\n\n        .edge {\n            position: absolute;\n            height: 2px;\n            background-color: rgba(255, 255, 255, 0.3);\n            transform-origin: 0 0;\n            z-index: 1;\n            transition: all 0.5s ease;\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 1.5rem;\n            margin-top: 2rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .status {\n            margin-top: 1.5rem;\n            font-size: 1.1rem;\n            font-weight: 500;\n            height: 1.5rem;\n            text-align: center;\n            color: var(--highlight-color);\n            text-shadow: 0 0 10px rgba(76, 201, 240, 0.3);\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 1s infinite;\n        }\n\n        @media (max-width: 768px) {\n            .array-bar {\n                width: 25px;\n            }\n\n            h1 {\n                font-size: 2rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Heap Sort Visualization</h1>\n        <p class=\"subtitle\">A beautiful demonstration of the heap sort algorithm</p>\n    </div>\n\n    <div class=\"container\">\n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Visualization</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n\n        <div class=\"visualization\">\n            <div class=\"array-container\" id=\"arrayContainer\"></div>\n            <div class=\"status\" id=\"status\">Ready to begin heap sort</div>\n            <div class=\"tree-container\" id=\"treeContainer\"></div>\n\n            <div class=\"legend\">\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--node-color);\"></div>\n                    <span>Normal Node</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--node-parent);\"></div>\n                    <span>Parent Node</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--node-compare);\"></div>\n                    <span>Comparing Nodes</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--node-active);\"></div>\n                    <span>Active Node</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background-color: var(--node-sorted);\"></div>\n                    <span>Sorted Position</span>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Configuration\n            const arraySize = 15;\n            const minValue = 10;\n            const maxValue = 100;\n            const animationSpeed = 800;\n            \n            // DOM Elements\n            const arrayContainer = document.getElementById('arrayContainer');\n            const treeContainer = document.getElementById('treeContainer');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const statusElement = document.getElementById('status');\n            \n            // State\n            let array = [];\n            let isSorting = false;\n            let animationQueue = [];\n            let heapSize = 0;\n            let edges = [];\n            \n            // Initialize\n            function init() {\n                resetArray();\n                renderArray();\n                renderTree();\n                updateStatus(\"Ready to begin heap sort\");\n            }\n            \n            // Generate random array\n            function resetArray() {\n                array = Array.from({length: arraySize}, () => \n                    Math.floor(Math.random() * (maxValue - minValue + 1)) + minValue\n                );\n                heapSize = array.length;\n                clearAnimations();\n                renderArray();\n                renderTree();\n            }\n            \n            // Render array as bars\n            function renderArray() {\n                arrayContainer.innerHTML = '';\n                array.forEach((value, index) => {\n                    const bar = document.createElement('div');\n                    bar.className = 'array-bar';\n                    bar.style.height = `${value * 2}px`;\n                    bar.setAttribute('data-value', value);\n                    arrayContainer.appendChild(bar);\n                });\n            }\n            \n            // Render heap as tree\n            function renderTree() {\n                treeContainer.innerHTML = '';\n                edges = [];\n                \n                // Calculate positions for nodes\n                const levelHeight = 80;\n                const maxLevel = Math.floor(Math.log2(array.length)) + 1;\n                const containerWidth = treeContainer.offsetWidth;\n                \n                // Create nodes\n                array.forEach((value, index) => {\n                    if (index >= heapSize) return;\n                    \n                    const level = Math.floor(Math.log2(index + 1));\n                    const nodesInLevel = Math.pow(2, level);\n                    const posInLevel = index + 1 - Math.pow(2, level);\n                    \n                    const node = document.createElement('div');\n                    node.className = 'node';\n                    node.textContent = value;\n                    node.id = `node-${index}`;\n                    \n                    // Position calculation\n                    const x = (containerWidth / (nodesInLevel + 1)) * (posInLevel + 1);\n                    const y = 50 + level * levelHeight;\n                    \n                    node.style.left = `${x - 25}px`;\n                    node.style.top = `${y}px`;\n                    \n                    treeContainer.appendChild(node);\n                    \n                    // Create edges to children\n                    const leftChild = 2 * index + 1;\n                    const rightChild = 2 * index + 2;\n                    \n                    if (leftChild < heapSize) {\n                        createEdge(index, leftChild, x, y);\n                    }\n                    if (rightChild < heapSize) {\n                        createEdge(index, rightChild, x, y);\n                    }\n                });\n                \n                // Render edges after all nodes are positioned\n                edges.forEach(edgeData => {\n                    const edge = document.createElement('div');\n                    edge.className = 'edge';\n                    edge.style.width = `${edgeData.width}px`;\n                    edge.style.left = `${edgeData.fromX}px`;\n                    edge.style.top = `${edgeData.fromY}px`;\n                    edge.style.transform = `rotate(${edgeData.angle}rad)`;\n                    treeContainer.appendChild(edge);\n                });\n            }\n            \n            function createEdge(parentIndex, childIndex, parentX, parentY) {\n                const level = Math.floor(Math.log2(childIndex + 1));\n                const nodesInLevel = Math.pow(2, level);\n                const posInLevel = childIndex + 1 - Math.pow(2, level);\n                \n                const childX = (treeContainer.offsetWidth / (nodesInLevel + 1)) * (posInLevel + 1);\n                const childY = 50 + level * 80;\n                \n                const dx = childX - parentX;\n                const dy = childY - parentY;\n                const length = Math.sqrt(dx * dx + dy * dy);\n                const angle = Math.atan2(dy, dx);\n                \n                edges.push({\n                    width: length,\n                    fromX: parentX,\n                    fromY: parentY + 25,\n                    angle: angle\n                });\n            }\n            \n            // Highlight elements being compared\n            function highlightElements(indices, className) {\n                return new Promise(resolve => {\n                    // Highlight array bars\n                    indices.forEach(i => {\n                        const bar = arrayContainer.children[i];\n                        bar.classList.add(className);\n                    });\n                    \n                    // Highlight tree nodes\n                    indices.forEach(i => {\n                        if (i < heapSize) {\n                            const node = document.getElementById(`node-${i}`);\n                            if (node) node.classList.add(className);\n                        }\n                    });\n                    \n                    setTimeout(() => {\n                        indices.forEach(i => {\n                            const bar = arrayContainer.children[i];\n                            bar.classList.remove(className);\n                            \n                            if (i < heapSize) {\n                                const node = document.getElementById(`node-${i}`);\n                                if (node) node.classList.remove(className);\n                            }\n                        });\n                        resolve();\n                    }, animationSpeed);\n                });\n            }\n            \n            // Move element in array and tree\n            function moveElement(fromIndex, toIndex) {\n                return new Promise(resolve => {\n                    // Swap array values\n                    [array[fromIndex], array[toIndex]] = [array[toIndex], array[fromIndex]];\n                    \n                    // Animate array bars\n                    const fromBar = arrayContainer.children[fromIndex];\n                    const toBar = arrayContainer.children[toIndex];\n                    \n                    fromBar.style.transform = `translateX(${(toIndex - fromIndex) * 46}px)`;\n                    toBar.style.transform = `translateX(${(fromIndex - toIndex) * 46}px)`;\n                    \n                    setTimeout(() => {\n                        // Update array bars\n                        fromBar.style.height = `${array[fromIndex] * 2}px`;\n                        fromBar.setAttribute('data-value', array[fromIndex]);\n                        toBar.style.height = `${array[toIndex] * 2}px`;\n                        toBar.setAttribute('data-value', array[toIndex]);\n                        \n                        // Reset transforms\n                        fromBar.style.transform = '';\n                        toBar.style.transform = '';\n                        \n                        // Re-render tree to update positions and values\n                        renderTree();\n                        \n                        resolve();\n                    }, animationSpeed);\n                });\n            }\n            \n            // Mark element as sorted\n            function markSorted(index) {\n                const bar = arrayContainer.children[index];\n                bar.classList.add('sorted');\n                \n                if (index < heapSize) {\n                    const node = document.getElementById(`node-${index}`);\n                    if (node) node.classList.add('sorted');\n                }\n            }\n            \n            // Heap sort algorithm\n            async function heapSort() {\n                if (isSorting) return;\n                isSorting = true;\n                startBtn.disabled = true;\n                \n                // Build max heap\n                await updateStatus(\"Building max heap...\");\n                await buildMaxHeap();\n                \n                // Extract elements from heap\n                await updateStatus(\"Sorting by extracting elements...\");\n                for (let i = array.length - 1; i > 0; i--) {\n                    // Move current root to end\n                    await highlightElements([0, i], 'comparing');\n                    await moveElement(0, i);\n                    markSorted(i);\n                    \n                    // Reduce heap size\n                    heapSize--;\n                    await updateStatus(`Extracted max element (${array[i]}), reduced heap size to ${heapSize}`);\n                    \n                    // Heapify root element\n                    await heapify(0);\n                    renderTree();\n                }\n                \n                // Mark first element as sorted\n                markSorted(0);\n                \n                await updateStatus(\"Sorting complete!\", 2000);\n                isSorting = false;\n                startBtn.disabled = false;\n            }\n            \n            // Build max heap\n            async function buildMaxHeap() {\n                // Start from last non-leaf node\n                const startIdx = Math.floor(array.length / 2) - 1;\n                \n                for (let i = startIdx; i >= 0; i--) {\n                    await updateStatus(`Heapifying subtree rooted at index ${i}`);\n                    await heapify(i);\n                    renderTree();\n                }\n            }\n            \n            // Heapify subtree rooted at index i\n            async function heapify(i) {\n                let largest = i;\n                const left = 2 * i + 1;\n                const right = 2 * i + 2;\n                \n                // Highlight parent and children being considered\n                await highlightElements([i], 'parent');\n                \n                // Compare with left child\n                if (left < heapSize) {\n                    await highlightElements([largest, left], 'comparing');\n                    \n                    if (array[left] > array[largest]) {\n                        largest = left;\n                    }\n                }\n                \n                // Compare with right child\n                if (right < heapSize) {\n                    await highlightElements([largest, right], 'comparing');\n                    \n                    if (array[right] > array[largest]) {\n                        largest = right;\n                    }\n                }\n                \n                // If largest is not root\n                if (largest !== i) {\n                    await highlightElements([i, largest], 'active');\n                    await moveElement(i, largest);\n                    \n                    // Recursively heapify the affected sub-tree\n                    await heapify(largest);\n                }\n            }\n            \n            // Clear all animations and highlights\n            function clearAnimations() {\n                const bars = arrayContainer.querySelectorAll('.array-bar');\n                bars.forEach(bar => {\n                    bar.className = 'array-bar';\n                    bar.style.transform = '';\n                });\n                \n                treeContainer.innerHTML = '';\n            }\n            \n            // Update status message\n            async function updateStatus(message, duration = 1000) {\n                statusElement.textContent = message;\n                statusElement.classList.add('pulse');\n                \n                if (duration > 0) {\n                    await new Promise(resolve => setTimeout(resolve, duration));\n                    statusElement.classList.remove('pulse');\n                }\n            }\n            \n            // Event listeners\n            startBtn.addEventListener('click', heapSort);\n            resetBtn.addEventListener('click', init);\n            \n            // Initialize the visualization\n            init();\n        });\n    </script>\n</body>\n</html>"
