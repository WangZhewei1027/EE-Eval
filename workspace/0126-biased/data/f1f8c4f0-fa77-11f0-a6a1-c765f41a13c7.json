  "question": "Design Patterns",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Design Patterns — Visual Showcase</title>\n<style>\n  :root{\n    --bg:#0b1020;\n    --panel: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --accent1: #8be9fd;\n    --accent2: #c792ea;\n    --accent3: #ffb86b;\n    --glass-blur: 10px;\n    --card-shadow: 0 10px 30px rgba(2,6,23,0.6);\n    --glass-border: rgba(255,255,255,0.06);\n  }\n\n  [data-theme=\"light\"]{\n    --bg:linear-gradient(180deg,#f6f8fb 0%, #eef3fb 100%);\n    --panel: rgba(255,255,255,0.7);\n    --glass: rgba(255,255,255,0.85);\n    --muted: rgba(20,28,40,0.6);\n    --accent1: #0066ff;\n    --accent2: #7b4cfb;\n    --accent3: #ff7a59;\n    --glass-blur: 8px;\n    --card-shadow: 0 20px 40px rgba(13,30,59,0.08);\n    --glass-border: rgba(13,30,59,0.06);\n  }\n\n  /* Reset & basics */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(139,233,253,0.06), transparent 6%),\n                radial-gradient(1000px 500px at 90% 90%, rgba(199,146,234,0.05), transparent 6%),\n                var(--bg);\n    color: #eaf2ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    transition: background 0.7s ease, color 0.6s ease;\n    overflow-x:hidden;\n    padding:48px;\n  }\n\n  /* Subtle animated gradient overlay */\n  .ambient{\n    pointer-events:none;\n    position:fixed;\n    inset:0;\n    z-index:0;\n    mix-blend-mode:screen;\n    opacity:0.45;\n    transition:opacity .6s;\n  }\n  svg.ambient-svg{width:100%;height:100%}\n  .wave{\n    animation: float 14s ease-in-out infinite;\n    transform-origin:center;\n    opacity:0.9;\n  }\n  .wave2{animation-duration:18s; animation-direction:reverse; opacity:0.85}\n  @keyframes float{\n    0%{transform:translateY(0) rotate(-2deg)}\n    50%{transform:translateY(-24px) rotate(2deg)}\n    100%{transform:translateY(0) rotate(-2deg)}\n  }\n\n  /* Header */\n  .header{\n    position:relative;\n    z-index:2;\n    display:flex;\n    align-items:center;\n    gap:20px;\n    margin-bottom:28px;\n  }\n  .logo{\n    width:84px;\n    height:84px;\n    border-radius:18px;\n    display:grid;\n    place-items:center;\n    background:linear-gradient(135deg,var(--accent1), var(--accent2));\n    box-shadow: 0 6px 20px rgba(11,16,32,0.55), inset 0 -6px 18px rgba(0,0,0,0.12);\n    color:white;\n    font-weight:700;\n    letter-spacing:0.6px;\n    font-size:20px;\n    transform:translateZ(0);\n  }\n  .title-block{\n    display:flex;\n    flex-direction:column;\n    gap:4px;\n  }\n  h1{\n    margin:0;\n    font-size:28px;\n    letter-spacing: -0.4px;\n    color:var(--muted);\n    font-weight:700;\n    text-shadow: 0 6px 30px rgba(2,6,23,0.35);\n  }\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    opacity:0.9;\n    font-size:13px;\n    max-width:54ch;\n  }\n\n  /* Layout */\n  .stage{\n    position:relative;\n    z-index:2;\n    margin-top:22px;\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:28px;\n    align-items:start;\n  }\n\n  /* Showcase panel */\n  .showcase{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent 40%);\n    border-radius:18px;\n    padding:28px;\n    backdrop-filter: blur(var(--glass-blur));\n    border: 1px solid var(--glass-border);\n    box-shadow: var(--card-shadow);\n    overflow:visible;\n  }\n\n  .pattern-hub{\n    display:grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap:20px;\n  }\n\n  .pattern-card{\n    position:relative;\n    min-height:160px;\n    border-radius:12px;\n    padding:18px;\n    overflow:hidden;\n    background:linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    transition: transform .6s cubic-bezier(.2,.9,.2,1), box-shadow .4s;\n    transform-style:preserve-3d;\n    perspective:1000px;\n  }\n  .pattern-card:hover{\n    transform: translateY(-8px) rotateX(3deg);\n    box-shadow: 0 34px 70px rgba(2,6,23,0.6);\n  }\n\n  .pattern-icon{\n    width:64px;height:64px;border-radius:12px;\n    display:flex;align-items:center;justify-content:center;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45) inset;\n    margin-bottom:12px;\n  }\n  .pattern-title{\n    font-size:15px;\n    font-weight:700;\n    color:var(--muted);\n    margin-bottom:6px;\n  }\n  .pattern-desc{\n    font-size:13px;color:var(--muted);opacity:0.9;\n    line-height:1.35;\n    margin-bottom:12px;\n  }\n  .pattern-list{\n    display:flex;gap:8px;flex-wrap:wrap;\n  }\n  .chip{\n    padding:6px 10px;border-radius:999px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    font-size:12px;\n  }\n\n  /* Right panel: visual diagram */\n  .visual{\n    position:relative;\n    border-radius:18px;\n    padding:20px;\n    backdrop-filter: blur(var(--glass-blur));\n    border:1px solid var(--glass-border);\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    box-shadow: var(--card-shadow);\n    height:100%;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    justify-content:center;\n    align-items:center;\n  }\n\n  .diagram{\n    width:100%;\n    max-width:360px;\n    height:360px;\n    position:relative;\n    display:grid;\n    place-items:center;\n  }\n\n  /* Orbs and connectors */\n  .orb{\n    position:absolute;\n    width:120px;height:120px;border-radius:999px;\n    display:grid;place-items:center;\n    color:white;font-weight:700;\n    text-align:center;\n    padding:10px;\n    transform:translate3d(0,0,0);\n    transition:transform .8s cubic-bezier(.2,.9,.2,1);\n  }\n\n  .orb .label{font-size:13px;letter-spacing:0.4px}\n  .orb .sub{font-size:11px;opacity:0.9;margin-top:6px;font-weight:600}\n\n  .orb.creational{\n    left:8%; top:18%;\n    background: radial-gradient(circle at 30% 20%, rgba(139,233,253,0.14), rgba(199,146,234,0.06)),\n                linear-gradient(135deg, var(--accent1), rgba(120,120,230,0.9));\n    box-shadow: 0 18px 40px rgba(11,26,40,0.55);\n    border:1px solid rgba(255,255,255,0.045);\n  }\n  .orb.structural{\n    right:6%; top:24%;\n    background: radial-gradient(circle at 70% 20%, rgba(199,146,234,0.12), rgba(255,184,107,0.06)),\n                linear-gradient(135deg, var(--accent2), rgba(255,184,107,0.92));\n    box-shadow: 0 18px 40px rgba(40,18,50,0.5);\n    border:1px solid rgba(255,255,255,0.035);\n  }\n  .orb.behavioral{\n    left:22%; bottom:6%;\n    background: radial-gradient(circle at 30% 70%, rgba(255,184,107,0.12), rgba(139,233,253,0.04)),\n                linear-gradient(135deg, var(--accent3), rgba(139,233,253,0.9));\n    box-shadow: 0 18px 40px rgba(50,30,10,0.45);\n    border:1px solid rgba(255,255,255,0.03);\n  }\n\n  /* animated small nodes */\n  .node{\n    position:absolute;\n    width:10px;height:10px;border-radius:999px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.95), rgba(255,255,255,0.6));\n    box-shadow:0 8px 20px rgba(0,0,0,0.45);\n    opacity:0.95;\n    transform:translateZ(0);\n    animation: drift 6s linear infinite;\n  }\n  .node.n1{left:50%; top:8%; animation-duration:8s;}\n  .node.n2{right:14%; top:48%; animation-duration:6.6s;}\n  .node.n3{left:12%; top:46%; animation-duration:7.6s;}\n  .node.n4{left:68%; top:72%; animation-duration:9s;}\n  .node.n5{right:6%; bottom:16%;animation-duration:11s;}\n\n  @keyframes drift{\n    0%{transform:translateY(0) translateX(0)}\n    50%{transform:translateY(-18px) translateX(12px)}\n    100%{transform:translateY(0) translateX(0)}\n  }\n\n  /* connectors (svg) */\n  .connectors{position:absolute;inset:0;pointer-events:none}\n\n  /* caption */\n  .explain{\n    color:var(--muted);\n    font-size:13px;\n    text-align:center;\n    opacity:0.95;\n    line-height:1.4;\n    padding:0 8px;\n  }\n\n  /* Footer small credits */\n  .meta{\n    margin-top:22px;\n    color:var(--muted);\n    font-size:12px;\n    opacity:0.9;\n  }\n\n  /* theme toggle button */\n  .controls{\n    position:fixed;\n    right:28px;\n    top:28px;\n    z-index:10;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    width:54px;height:54px;border-radius:14px;border:0;\n    display:grid;place-items:center;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 8px 24px rgba(2,6,23,0.5);\n    color:var(--muted);\n    cursor:pointer;\n    transition: transform .25s, box-shadow .25s, background .25s;\n    border:1px solid rgba(255,255,255,0.04);\n    backdrop-filter: blur(var(--glass-blur));\n  }\n  .btn:active{transform:scale(.96)}\n  .btn .ico{width:22px;height:22px;display:block;opacity:0.95}\n\n  /* responsive */\n  @media (max-width:980px){\n    .stage{grid-template-columns:1fr; padding-bottom:40px}\n    .visual{order: -1}\n    body{padding:20px}\n    .logo{width:68px;height:68px}\n  }\n\n  /* small reveal animation on load */\n  .pattern-card{opacity:0; transform:translateY(20px)}\n  .pattern-card.visible{opacity:1; transform:translateY(0)}\n  .orb{opacity:0; transform: translateY(12px) scale(.96)}\n  .orb.visible{opacity:1; transform: translateY(0) scale(1)}\n</style>\n</head>\n<body data-theme=\"dark\">\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <svg class=\"ambient-svg\" viewBox=\"0 0 1600 900\" preserveAspectRatio=\"none\">\n      <defs>\n        <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#8be9fd\" stop-opacity=\"0.12\"/>\n          <stop offset=\"1\" stop-color=\"#c792ea\" stop-opacity=\"0.06\"/>\n        </linearGradient>\n        <linearGradient id=\"g2\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#ffb86b\" stop-opacity=\"0.08\"/>\n          <stop offset=\"1\" stop-color=\"#c792ea\" stop-opacity=\"0.04\"/>\n        </linearGradient>\n      </defs>\n      <g class=\"wave\">\n        <path d=\"M0 260 C250 320 350 160 700 240 C1050 320 1200 120 1600 200 L1600 0 L0 0 Z\" fill=\"url(#g1)\"/>\n      </g>\n      <g class=\"wave2\">\n        <path d=\"M0 700 C350 620 500 840 900 720 C1200 620 1350 840 1600 720 L1600 900 L0 900 Z\" fill=\"url(#g2)\"/>\n      </g>\n    </svg>\n  </div>\n\n  <div class=\"controls\" role=\"toolbar\" aria-label=\"Theme controls\">\n    <button class=\"btn\" id=\"themeToggle\" title=\"Toggle theme\" aria-pressed=\"false\">\n      <svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <circle cx=\"12\" cy=\"12\" r=\"5\" stroke=\"currentColor\" stroke-width=\"1.6\"/>\n        <g stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\">\n          <path d=\"M12 1v2.5\"/>\n          <path d=\"M12 20.5V23\"/>\n          <path d=\"M4.22 4.22l1.76 1.76\"/>\n          <path d=\"M17.98 17.98l1.76 1.76\"/>\n          <path d=\"M1 12h2.5\"/>\n          <path d=\"M20.5 12H23\"/>\n          <path d=\"M4.22 19.78l1.76-1.76\"/>\n          <path d=\"M17.98 6.02l1.76-1.76\"/>\n        </g>\n      </svg>\n    </button>\n  </div>\n\n  <header class=\"header\" role=\"banner\">\n    <div class=\"logo\" aria-hidden=\"true\">DP</div>\n    <div class=\"title-block\">\n      <h1>Design Patterns — An Aesthetic Overview</h1>\n      <p class=\"lead\">A curated, visual introduction to common design pattern families. Elegant shapes, soft motion and clear grouping help reveal structure without heavy interaction.</p>\n    </div>\n  </header>\n\n  <main class=\"stage\" role=\"main\">\n    <section class=\"showcase\" aria-labelledby=\"patterns-heading\">\n      <h2 id=\"patterns-heading\" style=\"position:absolute;left:-9999px;top:auto;height:1px;width:1px;overflow:hidden\">Patterns</h2>\n\n      <div class=\"pattern-hub\" aria-hidden=\"false\">\n        <article class=\"pattern-card\" data-delay=\"0.08\">\n          <div class=\"pattern-icon\" aria-hidden=\"true\">\n            <svg width=\"44\" height=\"44\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M3 12h18\" stroke=\"white\" stroke-opacity=\"0.9\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><path d=\"M12 3v18\" stroke=\"white\" stroke-opacity=\"0.9\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n          </div>\n          <div class=\"pattern-title\">Creational Patterns</div>\n          <div class=\"pattern-desc\">Focus on object creation mechanisms: control instantiation, abstract construction, and unify creation logic for flexibility and reuse.</div>\n          <div class=\"pattern-list\">\n            <span class=\"chip\">Factory</span>\n            <span class=\"chip\">Singleton</span>\n            <span class=\"chip\">Builder</span>\n          </div>\n        </article>\n\n        <article class=\"pattern-card\" data-delay=\"0.16\">\n          <div class=\"pattern-icon\" aria-hidden=\"true\">\n            <svg width=\"44\" height=\"44\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 7h6v6H4zM14 11h6v6h-6zM10 3h4v4h-4z\" stroke=\"white\" stroke-opacity=\"0.95\" stroke-width=\"1.4\" stroke-linejoin=\"round\"/></svg>\n          </div>\n          <div class=\"pattern-title\">Structural Patterns</div>\n          <div class=\"pattern-desc\">Compose classes and objects to form larger structures while keeping flexibility and efficient collaboration.</div>\n          <div class=\"pattern-list\">\n            <span class=\"chip\">Adapter</span>\n            <span class=\"chip\">Composite</span>\n            <span class=\"chip\">Facade</span>\n          </div>\n        </article>\n\n        <article class=\"pattern-card\" data-delay=\"0.24\">\n          <div class=\"pattern-icon\" aria-hidden=\"true\">\n            <svg width=\"44\" height=\"44\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 3c2.5 0 6 2 6 6s-3.5 6-6 8c-2.5-2-6-4.5-6-8s3.5-6 6-6z\" stroke=\"white\" stroke-opacity=\"0.95\" stroke-width=\"1.4\"/></svg>\n          </div>\n          <div class=\"pattern-title\">Behavioral Patterns</div>\n          <div class=\"pattern-desc\">Define communication and control flow between objects — how they collaborate to perform tasks and evolve.</div>\n          <div class=\"pattern-list\">\n            <span class=\"chip\">Observer</span>\n            <span class=\"chip\">Strategy</span>\n            <span class=\"chip\">Chain of Resp.</span>\n          </div>\n        </article>\n      </div>\n\n      <p class=\"meta\">Design patterns group solutions by intent: creation, composition, and interaction. Visual grouping clarifies their relationships at a glance.</p>\n    </section>\n\n    <aside class=\"visual\" aria-label=\"Visual diagram\">\n      <div class=\"diagram\" role=\"img\" aria-label=\"Diagram showing relationships between pattern families\">\n        <svg class=\"connectors\" viewBox=\"0 0 360 360\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"c1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#8be9fd\"/><stop offset=\"1\" stop-color=\"#c792ea\"/></linearGradient>\n            <linearGradient id=\"c2\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#c792ea\"/><stop offset=\"1\" stop-color=\"#ffb86b\"/></linearGradient>\n            <filter id=\"glow\"><feGaussianBlur stdDeviation=\"6\" result=\"b\"/><feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n          </defs>\n\n          <!-- connectors -->\n          <path d=\"M60 140 C130 80 230 80 300 140\" stroke=\"url(#c1)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" style=\"filter:url(#glow);stroke-opacity:0.95\"/>\n          <path d=\"M80 220 C150 280 210 280 280 220\" stroke=\"url(#c2)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" style=\"filter:url(#glow);stroke-opacity:0.9\"/>\n          <path d=\"M120 60 C160 140 200 220 240 120\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.8\" fill=\"none\" stroke-linecap=\"round\"/>\n\n          <!-- orbiting dots along paths -->\n          <circle r=\"4\" fill=\"#fff\" cx=\"60\" cy=\"140\">\n            <animateMotion dur=\"8s\" repeatCount=\"indefinite\" rotate=\"auto\">\n              <mpath xlink:href=\"#p1\" />\n            </animateMotion>\n          </circle>\n\n          <!-- actual paths used for motion -->\n          <path id=\"p1\" d=\"M60 140 C130 80 230 80 300 140\" fill=\"none\" stroke=\"none\"/>\n          <path id=\"p2\" d=\"M80 220 C150 280 210 280 280 220\" fill=\"none\" stroke=\"none\"/>\n        </svg>\n\n        <!-- Orbs -->\n        <div class=\"orb creational\" id=\"orbC\">\n          <div style=\"text-align:center\">\n            <div class=\"label\">Creational</div>\n            <div class=\"sub\">Make & Manage</div>\n          </div>\n        </div>\n\n        <div class=\"orb structural\" id=\"orbS\">\n          <div style=\"text-align:center\">\n            <div class=\"label\">Structural</div>\n            <div class=\"sub\">Compose & Connect</div>\n          </div>\n        </div>\n\n        <div class=\"orb behavioral\" id=\"orbB\">\n          <div style=\"text-align:center\">\n            <div class=\"label\">Behavioral</div>\n            <div class=\"sub\">Communicate</div>\n          </div>\n        </div>\n\n        <!-- floating nodes -->\n        <div class=\"node n1\" aria-hidden=\"true\"></div>\n        <div class=\"node n2\" aria-hidden=\"true\"></div>\n        <div class=\"node n3\" aria-hidden=\"true\"></div>\n        <div class=\"node n4\" aria-hidden=\"true\"></div>\n        <div class=\"node n5\" aria-hidden=\"true\"></div>\n      </div>\n\n      <p class=\"explain\">A soft network of forms reveals families of design patterns: creation at the top-left, composition to the top-right, and interaction flowing below — connected by intent.</p>\n    </aside>\n  </main>\n\n<script>\n  (function(){\n    // Minimal JS: theme toggle + staged reveal on load\n    const root = document.documentElement;\n    const btn = document.getElementById('themeToggle');\n    const userPref = localStorage.getItem('dp-theme') || 'dark';\n    const applyTheme = (t) => {\n      root.setAttribute('data-theme', t);\n      btn.setAttribute('aria-pressed', t === 'light' ? 'true' : 'false');\n      localStorage.setItem('dp-theme', t);\n      // update icon (simple)\n      btn.innerHTML = t === 'light' ? sunIcon() : moonIcon();\n    };\n\n    function moonIcon(){\n      return '<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\\\"M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"/></svg>';\n    }\n    function sunIcon(){\n      return '<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><circle cx=\\\"12\\\" cy=\\\"12\\\" r=\\\"4\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\"/><path d=\\\"M12 1v2\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M12 21v2\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M4.2 4.2l1.4 1.4\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M18.4 18.4l1.4 1.4\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M1 12h2\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M21 12h2\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M4.2 19.8l1.4-1.4\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M18.4 5.6l1.4-1.4\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"1.4\\\" stroke-linecap=\\\"round\\\"/></svg>';\n    }\n\n    applyTheme(userPref === 'light' ? 'light' : 'dark');\n\n    btn.addEventListener('click', () => {\n      const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';\n      applyTheme(next);\n    });\n\n    // Staggered reveal for visual polish\n    window.addEventListener('load', () => {\n      const cards = document.querySelectorAll('.pattern-card');\n      const orbs = document.querySelectorAll('.orb');\n      cards.forEach((c,i) => {\n        setTimeout(()=> c.classList.add('visible'), i*120 + 200);\n      });\n      orbs.forEach((o,i) => {\n        setTimeout(()=> o.classList.add('visible'), i*180 + 360);\n      });\n\n      // Gentle orbital motion for orbs (subtle)\n      const orbC = document.getElementById('orbC');\n      const orbS = document.getElementById('orbS');\n      const orbB = document.getElementById('orbB');\n\n      // compute positions based on container size\n      function positionOrbs(){\n        const d = document.querySelector('.diagram');\n        const rect = d.getBoundingClientRect();\n        // Creational: left-top\n        orbC.style.left = (rect.width * 0.08) + 'px';\n        orbC.style.top = (rect.height * 0.12) + 'px';\n        // Structural: right-top\n        orbS.style.left = (rect.width * 0.72) + 'px';\n        orbS.style.top = (rect.height * 0.12) + 'px';\n        // Behavioral: left-bottom\n        orbB.style.left = (rect.width * 0.18) + 'px';\n        orbB.style.top = (rect.height * 0.62) + 'px';\n      }\n      positionOrbs();\n      window.addEventListener('resize', positionOrbs);\n\n      // subtle breathing animation via JS transform for a tiny extra life\n      let t = 0;\n      function breathe(){\n        t += 0.02;\n        const s = 1 + Math.sin(t) * 0.008;\n        orbC.style.transform = 'translate3d(0,0,0) scale(' + s + ')';\n        orbS.style.transform = 'translate3d(0,0,0) scale(' + (1 + Math.cos(t*1.1)*0.006) + ')';\n        orbB.style.transform = 'translate3d(0,0,0) scale(' + (1 + Math.sin(t*0.9)*0.007) + ')';\n        requestAnimationFrame(breathe);\n      }\n      requestAnimationFrame(breathe);\n    });\n  })();\n</script>\n</body>\n</html>"
  },
