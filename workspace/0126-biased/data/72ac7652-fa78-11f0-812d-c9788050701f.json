    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Cosmic Routing</title>\n    <style>\n        :root {\n            --primary: #6a11cb;\n            --secondary: #2575fc;\n            --accent: #ff2d75;\n            --text: #f8f9fa;\n            --bg-dark: #121212;\n            --bg-darker: #0a0a0a;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Montserrat', 'Segoe UI', sans-serif;\n            background: linear-gradient(135deg, var(--bg-darker), var(--bg-dark));\n            color: var(--text);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        @font-face {\n            font-family: 'Montserrat';\n            font-weight: 400;\n            src: url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            position: relative;\n            z-index: 1;\n        }\n\n        header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 4rem;\n            animation: fadeInDown 1s ease-out;\n        }\n\n        .logo {\n            font-size: 1.8rem;\n            font-weight: 700;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            position: relative;\n        }\n\n        .logo::after {\n            content: '';\n            position: absolute;\n            bottom: -5px;\n            left: 0;\n            width: 100%;\n            height: 2px;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            transform: scaleX(0);\n            transform-origin: right;\n            transition: transform 0.3s ease;\n        }\n\n        .logo:hover::after {\n            transform: scaleX(1);\n            transform-origin: left;\n        }\n\n        nav {\n            display: flex;\n            gap: 2rem;\n        }\n\n        .nav-link {\n            color: var(--text);\n            text-decoration: none;\n            font-weight: 500;\n            position: relative;\n            opacity: 0.8;\n            transition: all 0.3s ease;\n        }\n\n        .nav-link:hover {\n            opacity: 1;\n            color: var(--accent);\n        }\n\n        .nav-link::after {\n            content: '';\n            position: absolute;\n            bottom: -5px;\n            left: 0;\n            width: 0;\n            height: 2px;\n            background: var(--accent);\n            transition: width 0.3s ease;\n        }\n\n        .nav-link:hover::after {\n            width: 100%;\n        }\n\n        .main-content {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            text-align: center;\n            margin-top: 3rem;\n        }\n\n        h1 {\n            font-size: 4rem;\n            margin-bottom: 1.5rem;\n            background: linear-gradient(45deg, var(--primary), var(--secondary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            animation: gradientPulse 8s infinite alternate;\n        }\n\n        .subtitle {\n            font-size: 1.5rem;\n            margin-bottom: 3rem;\n            max-width: 700px;\n            line-height: 1.6;\n            opacity: 0.9;\n        }\n\n        .route-display {\n            width: 100%;\n            height: 500px;\n            position: relative;\n            margin-top: 4rem;\n            perspective: 1000px;\n        }\n\n        .route {\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            border-radius: 50%;\n            background: radial-gradient(circle, rgba(106,17,203,0.2) 0%, rgba(37,117,252,0.1) 70%, transparent 100%);\n            box-shadow: 0 0 50px rgba(106,17,203,0.3), \n                        0 0 100px rgba(37,117,252,0.1);\n            transition: all 1s ease-in-out;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            opacity: 0;\n            transform: translateY(50px) rotateY(180deg);\n        }\n\n        .route.active {\n            opacity: 1;\n            transform: translateY(0) rotateY(0);\n        }\n\n        .route-1 {\n            left: 50%;\n            top: 50%;\n            transform: translate(-50%, -50%) rotateY(180deg);\n        }\n\n        .route-1.active {\n            transform: translate(-50%, -50%) rotateY(0);\n        }\n\n        .route-2 {\n            left: 30%;\n            top: 30%;\n        }\n\n        .route-3 {\n            left: 70%;\n            top: 30%;\n        }\n\n        .route-4 {\n            left: 20%;\n            top: 70%;\n        }\n\n        .route-5 {\n            left: 80%;\n            top: 70%;\n        }\n\n        .route-icon {\n            font-size: 3rem;\n            margin-bottom: 1rem;\n            color: var(--accent);\n        }\n\n        .route-title {\n            font-size: 1.5rem;\n            font-weight: 600;\n            margin-bottom: 0.5rem;\n        }\n\n        .route-desc {\n            font-size: 0.9rem;\n            opacity: 0.8;\n            max-width: 80%;\n        }\n\n        .connection-line {\n            position: absolute;\n            background: transparent;\n            height: 2px;\n            transform-origin: 0 0;\n            z-index: -1;\n            transition: all 1s ease;\n            opacity: 0;\n        }\n\n        .connection-line.active {\n            opacity: 0.6;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            box-shadow: 0 0 10px var(--primary), 0 0 20px var(--secondary);\n        }\n\n        .controls {\n            margin-top: 3rem;\n            display: flex;\n            gap: 1rem;\n        }\n\n        .btn {\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            border: none;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(106,17,203,0.4);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .btn::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);\n            transition: transform 0.5s ease;\n        }\n\n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(106,17,203,0.6);\n        }\n\n        .btn:hover::before {\n            transform: translateX(100%);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        .btn-outline {\n            background: transparent;\n            border: 2px solid var(--primary);\n            color: var(--primary);\n            box-shadow: none;\n        }\n\n        .btn-outline:hover {\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            border-color: transparent;\n            box-shadow: 0 5px 15px rgba(106,17,203,0.4);\n        }\n\n        .particles {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 0;\n            pointer-events: none;\n        }\n\n        .particle {\n            position: absolute;\n            border-radius: 50%;\n            background: var(--accent);\n            opacity: 0.3;\n            animation: float 15s infinite linear;\n        }\n\n        @keyframes float {\n            0% {\n                transform: translateY(0) rotate(0deg);\n            }\n            100% {\n                transform: translateY(-100vh) rotate(360deg);\n            }\n        }\n\n        @keyframes fadeInDown {\n            from {\n                opacity: 0;\n                transform: translateY(-20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes gradientPulse {\n            0% {\n                filter: hue-rotate(0deg);\n            }\n            100% {\n                filter: hue-rotate(360deg);\n            }\n        }\n\n        footer {\n            margin-top: 6rem;\n            text-align: center;\n            padding: 2rem;\n            font-size: 0.9rem;\n            opacity: 0.6;\n            animation: fadeInUp 1s ease-out;\n        }\n\n        @keyframes fadeInUp {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to {\n                opacity: 0.6;\n                transform: translateY(0);\n            }\n        }\n\n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .subtitle {\n                font-size: 1.2rem;\n            }\n            \n            .route-display {\n                height: 400px;\n            }\n            \n            .route {\n                width: 200px;\n                height: 200px;\n            }\n            \n            .route-title {\n                font-size: 1.2rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    <div class=\"container\">\n        <header>\n            <div class=\"logo\">Cosmic Router</div>\n            <nav>\n                <a href=\"#\" class=\"nav-link\" data-route=\"home\">Home</a>\n                <a href=\"#\" class=\"nav-link\" data-route=\"about\">About</a>\n                <a href=\"#\" class=\"nav-link\" data-route=\"services\">Services</a>\n                <a href=\"#\" class=\"nav-link\" data-route=\"contact\">Contact</a>\n            </nav>\n        </header>\n\n        <div class=\"main-content\">\n            <h1>Cosmic Routing</h1>\n            <p class=\"subtitle\">A visual exploration of elegant pathfinding through your digital universe. Watch as data traverses the celestial pathways.</p>\n            \n            <div class=\"route-display\">\n                <div class=\"route route-1\" id=\"route-center\">\n                    <div class=\"route-icon\">🌌</div>\n                    <div class=\"route-title\">Central Hub</div>\n                    <div class=\"route-desc\">All routes originate from this nexus point</div>\n                </div>\n                \n                <div class=\"route route-2\" id=\"route-about\">\n                    <div class=\"route-icon\">🪐</div>\n                    <div class=\"route-title\">About</div>\n                    <div class=\"route-desc\">Learn about our cosmic journey</div>\n                </div>\n                \n                <div class=\"route route-3\" id=\"route-services\">\n                    <div class=\"route-icon\">🚀</div>\n                    <div class=\"route-title\">Services</div>\n                    <div class=\"route-desc\">Explore our stellar offerings</div>\n                </div>\n                \n                <div class=\"route route-4\" id=\"route-contact\">\n                    <div class=\"route-icon\">📡</div>\n                    <div class=\"route-title\">Contact</div>\n                    <div class=\"route-desc\">Transmit your message through the void</div>\n                </div>\n                \n                <div class=\"route route-5\" id=\"route-dashboard\">\n                    <div class=\"route-icon\">🛰️</div>\n                    <div class=\"route-title\">Dashboard</div>\n                    <div class=\"route-desc\">Monitor the cosmic network</div>\n                </div>\n                \n                <div class=\"connection-line\" id=\"line1\"></div>\n                <div class=\"connection-line\" id=\"line2\"></div>\n                <div class=\"connection-line\" id=\"line3\"></div>\n                <div class=\"connection-line\" id=\"line4\"></div>\n            </div>\n            \n            <div class=\"controls\">\n                <button class=\"btn\" id=\"animateBtn\">Animate Routes</button>\n                <button class=\"btn btn-outline\" id=\"resetBtn\">Reset</button>\n            </div>\n        </div>\n        \n        <footer>\n            <p>Cosmic Routing Visualization | Journey through the digital cosmos</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create floating particles\n            const particlesEl = document.getElementById('particles');\n            for (let i = 0; i < 50; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 5 + 1;\n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                \n                particle.style.left = `${Math.random() * 100}vw`;\n                particle.style.top = `${Math.random() * 100}vh`;\n                \n                const delay = Math.random() * 15;\n                particle.style.animationDelay = `${delay}s`;\n                \n                particlesEl.appendChild(particle);\n            }\n            \n            // Routes animation\n            const routes = document.querySelectorAll('.route');\n            const lines = document.querySelectorAll('.connection-line');\n            const animateBtn = document.getElementById('animateBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const navLinks = document.querySelectorAll('.nav-link');\n            \n            // Set up connection lines between routes\n            const routeCenter = document.getElementById('route-center');\n            const routeAbout = document.getElementById('route-about');\n            const routeServices = document.getElementById('route-services');\n            const routeContact = document.getElementById('route-contact');\n            const routeDashboard = document.getElementById('route-dashboard');\n            \n            function updateConnectionLines() {\n                // Get position of elements\n                const centerRect = routeCenter.getBoundingClientRect();\n                const aboutRect = routeAbout.getBoundingClientRect();\n                const servicesRect = routeServices.getBoundingClientRect();\n                const contactRect = routeContact.getBoundingClientRect();\n                const dashboardRect = routeDashboard.getBoundingClientRect();\n                \n                // Line 1 - Center to About\n                setLinePosition(\n                    'line1',\n                    centerRect.left + centerRect.width/2,\n                    centerRect.top + centerRect.height/2,\n                    aboutRect.left + aboutRect.width/2,\n                    aboutRect.top + aboutRect.height/2\n                );\n                \n                // Line 2 - Center to Services\n                setLinePosition(\n                    'line2',\n                    centerRect.left + centerRect.width/2,\n                    centerRect.top + centerRect.height/2,\n                    servicesRect.left + servicesRect.width/2,\n                    servicesRect.top + servicesRect.height/2\n                );\n                \n                // Line 3 - Center to Contact\n                setLinePosition(\n                    'line3',\n                    centerRect.left + centerRect.width/2,\n                    centerRect.top + centerRect.height/2,\n                    contactRect.left + contactRect.width/2,\n                    contactRect.top + contactRect.height/2\n                );\n                \n                // Line 4 - Center to Dashboard\n                setLinePosition(\n                    'line4',\n                    centerRect.left + centerRect.width/2,\n                    centerRect.top + centerRect.height/2,\n                    dashboardRect.left + dashboardRect.width/2,\n                    dashboardRect.top + dashboardRect.height/2\n                );\n            }\n            \n            function setLinePosition(lineId, x1, y1, x2, y2) {\n                const line = document.getElementById(lineId);\n                const length = Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2));\n                const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;\n                \n                line.style.width = `${length}px`;\n                line.style.left = `${x1}px`;\n                line.style.top = `${y1}px`;\n                line.style.transform = `rotate(${angle}deg)`;\n            }\n            \n            // Initialize lines\n            setTimeout(() => {\n                updateConnectionLines();\n            }, 100);\n            \n            // Handle window resize\n            window.addEventListener('resize', updateConnectionLines);\n            \n            // Animation controller\n            function animateRoutes(routeName) {\n                // Reset all routes first\n                routes.forEach(route => {\n                    route.classList.remove('active');\n                });\n                \n                lines.forEach(line => {\n                    line.classList.remove('active');\n                });\n                \n                // Activate the central route\n                setTimeout(() => {\n                    routeCenter.classList.add('active');\n                }, 200);\n                \n                // Activate specific route if provided\n                if (routeName) {\n                    setTimeout(() => {\n                        document.getElementById(`route-${routeName}`).classList.add('active');\n                        \n                        // Activate the corresponding connection line\n                        let lineId;\n                        switch (routeName) {\n                            case 'about': lineId = 'line1'; break;\n                            case 'services': lineId = 'line2'; break;\n                            case 'contact': lineId = 'line3'; break;\n                            case 'dashboard': lineId = 'line4'; break;\n                        }\n                        \n                        setTimeout(() => {\n                            document.getElementById(lineId).classList.add('active');\n                        }, 800);\n                    }, 400);\n                } else {\n                    // Activate all routes and lines\n                    setTimeout(() => {\n                        routes.forEach(route => {\n                            route.classList.add('active');\n                        });\n                        \n                        setTimeout(() => {\n                            lines.forEach(line => {\n                                line.classList.add('active');\n                            });\n                        }, 500);\n                    }, 400);\n                }\n            }\n            \n            // Button controls\n            animateBtn.addEventListener('click', () => {\n                animateRoutes();\n            });\n            \n            resetBtn.addEventListener('click', () => {\n                routes.forEach(route => {\n                    route.classList.remove('active');\n                });\n                \n                lines.forEach(line => {\n                    line.classList.remove('active');\n                });\n            });\n            \n            // Nav link controls\n            navLinks.forEach(link => {\n                link.addEventListener('click', (e) => {\n                    e.preventDefault();\n                    const routeName = link.dataset.route;\n                    animateRoutes(routeName);\n                });\n            });\n            \n            // Initial animation\n            setTimeout(() => {\n                animateRoutes();\n            }, 1000);\n        });\n    </script>\n</body>\n</html>"
