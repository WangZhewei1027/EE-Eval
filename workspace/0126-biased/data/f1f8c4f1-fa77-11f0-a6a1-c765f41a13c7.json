    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Refactoring — Visual Demo</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071026;\n    --glass-1: rgba(255,255,255,0.06);\n    --accent: #7dd3fc;\n    --accent-2: #a78bfa;\n    --muted: rgba(255,255,255,0.45);\n    --glass-border: rgba(255,255,255,0.06);\n    --glass-glow: rgba(124,58,237,0.12);\n    --success: #36d399;\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  /* Page */\n  html,body{height:100%; margin:0; background:linear-gradient(180deg,var(--bg-1),var(--bg-2)); color:#e6eef8; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;}\n  .stage{\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Background dynamic shapes */\n  .blob {\n    position:absolute;\n    filter: blur(40px) contrast(120%);\n    opacity:0.8;\n    mix-blend-mode: screen;\n    transform-origin: center;\n    will-change: transform, opacity;\n    pointer-events:none;\n  }\n  .blob.b1{ width:560px; height:560px; background: radial-gradient(circle at 30% 20%, #7dd3fc 0%, #67e8f9 15%, transparent 40%); left:-10%; top:5%; animation: drift1 12s ease-in-out infinite; }\n  .blob.b2{ width:420px; height:420px; background: radial-gradient(circle at 70% 80%, #a78bfa 0%, #7c3aed 20%, transparent 50%); right:-8%; bottom:-6%; animation: drift2 14s ease-in-out infinite; }\n  .blob.b3{ width:220px; height:220px; background: radial-gradient(circle at 40% 60%, #60a5fa 0%, #38bdf8 30%, transparent 60%); left:50%; top:10%; transform:translateX(-50%); animation: drift3 10s linear infinite; opacity:0.5; }\n\n  @keyframes drift1 { 0%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-20px) rotate(6deg)} 100%{transform:translateY(0) rotate(0deg)} }\n  @keyframes drift2 { 0%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(18px) rotate(-4deg)} 100%{transform:translateY(0) rotate(0deg)} }\n  @keyframes drift3 { 0%{transform:translateY(0)} 50%{transform:translateY(-8px)} 100%{transform:translateY(0)} }\n\n  /* Central card */\n  .panel {\n    width:1100px;\n    max-width:96vw;\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:20px;\n    padding:32px;\n    box-shadow: var(--shadow);\n    border:1px solid var(--glass-border);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:hidden;\n    z-index:2;\n  }\n\n  /* Header */\n  .head {\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:20px;\n    margin-bottom:24px;\n  }\n  .title {\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .logo {\n    width:56px; height:56px; border-radius:12px;\n    background: linear-gradient(135deg,var(--accent),var(--accent-2));\n    display:flex; align-items:center; justify-content:center;\n    box-shadow: 0 6px 20px rgba(122,77,255,0.18), inset 0 -6px 18px rgba(255,255,255,0.06);\n    transform:translateZ(0);\n  }\n  .logo svg{ width:34px; height:34px; }\n  .heading {\n    line-height:1;\n  }\n  .heading h1 { font-size:20px; margin:0; letter-spacing:-0.2px; color: #fff; }\n  .heading p { margin:2px 0 0 0; font-size:13px; color:var(--muted); }\n\n  .controls {\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .kb {\n    font-size:12px;\n    color:var(--muted);\n    padding:8px 10px;\n    border-radius:10px;\n    background:rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 6px 16px rgba(2,6,23,0.45);\n  }\n  .btn {\n    -webkit-appearance:none; appearance:none; border:0; cursor:pointer;\n    padding:10px 16px; background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)); color: #fff;\n    border-radius:12px; font-weight:600; font-size:14px; letter-spacing:0.2px;\n    display:inline-flex; align-items:center; gap:10px;\n    transition: transform .18s cubic-bezier(.2,.9,.2,1), box-shadow .18s;\n    box-shadow: 0 6px 18px rgba(5,10,30,.45);\n  }\n  .btn:active{ transform: translateY(1px) scale(.998); }\n  .btn .dot {\n    width:10px; height:10px; border-radius:50%;\n    background:linear-gradient(135deg,var(--accent),var(--accent-2));\n    box-shadow: 0 6px 20px rgba(124,58,237,0.18);\n  }\n\n  /* Workbench area */\n  .workbench {\n    display:grid;\n    grid-template-columns: 1fr 140px 1fr;\n    gap:18px;\n    align-items:center;\n  }\n  .pane {\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    min-height:320px;\n    position:relative;\n    overflow:hidden;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .label {\n    position:absolute;\n    top:12px; left:14px;\n    font-size:12px; color:var(--muted);\n    display:flex; gap:8px; align-items:center;\n  }\n  .label .chip {\n    width:8px; height:8px; border-radius:50%;\n    background:rgba(255,255,255,0.06); box-shadow: inset 0 0 6px rgba(0,0,0,0.2);\n  }\n\n  /* center glyph */\n  .center {\n    display:flex; align-items:center; justify-content:center; flex-direction:column;\n    gap:12px; user-select:none;\n  }\n  .glyph {\n    width:120px; height:120px; border-radius:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.012));\n    display:flex; align-items:center; justify-content:center; box-shadow: 0 8px 30px rgba(10,15,30,0.45);\n    border:1px solid rgba(255,255,255,0.03);\n    position:relative;\n    transition: transform .7s cubic-bezier(.2,.9,.2,1);\n  }\n  .glyph .arrow {\n    width:72px; height:72px;\n    display:block;\n    transition: transform .9s cubic-bezier(.2,.9,.2,1), opacity .5s;\n    filter: drop-shadow(0 8px 22px rgba(44,199,255,0.06));\n  }\n  .glyph .badge{\n    position:absolute; right:12px; bottom:10px;\n    background: linear-gradient(90deg,#0ea5d9,#7c3aed);\n    padding:6px 8px; color:#fff; font-weight:700; font-size:11px;\n    border-radius:8px; box-shadow: 0 6px 20px rgba(124,58,237,0.12);\n  }\n\n  /* Code layout */\n  .code {\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n    font-size:13px;\n    color:#dbeafe;\n    line-height:1.5;\n    margin-top:22px;\n    position:relative;\n  }\n  .line {\n    white-space:pre;\n    display:block;\n    transform-origin:left center;\n    will-change: transform, opacity;\n    opacity:1;\n  }\n  .muted { color: #92a6c8; }\n  .kw { color:#60a5fa; font-weight:600; }\n  .fn { color:#a78bfa; font-weight:700; }\n  .str { color:#34d399; }\n  .num { color:#fbbf24; }\n  .comment { color:#94a3b8; font-style:italic; font-weight:500; }\n\n  /* before pane specifics */\n  .pane.before .code { padding-left:6px; }\n  .pane.after .code { padding-left:6px; }\n\n  /* animation: lines move and morph */\n  .run .glyph { transform: rotate(-6deg) scale(1.02); }\n  .run .arrow { transform: translateX(8px) rotate(8deg); opacity:0.95; }\n\n  /* animate individual lines in the before pane as they transform */\n  .pane.before .line { transition: transform .9s cubic-bezier(.2,.9,.2,1), opacity .6s, filter .6s; }\n  .pane.after .line { transition: opacity .6s ease .4s, transform .9s cubic-bezier(.2,.9,.2,1) .4s; opacity:0; transform: translateY(18px) scale(.98); }\n\n  /* when running, animate lines with stagger via style attribute set by JS */\n  .run .pane.before .line.animate {\n    transform: translateX(-28px) rotate(-2deg) scale(.96);\n    opacity:0;\n    filter: blur(1px) saturate(.95);\n  }\n  .run .pane.after .line.animate {\n    opacity:1;\n    transform: translateY(0) scale(1);\n    filter: none;\n  }\n\n  /* subtle rulers and decorations */\n  .ruler {\n    position:absolute; inset:12px; pointer-events:none; opacity:0.06;\n    background: repeating-linear-gradient(180deg, rgba(255,255,255,0.02) 0 1px, transparent 1px 28px);\n    border-radius:12px;\n  }\n\n  /* Footer micro info */\n  .meta {\n    margin-top:18px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* small responsive */\n  @media (max-width:880px){\n    .workbench { grid-template-columns: 1fr; }\n    .center { order:3; margin:8px 0 0; }\n    .pane { min-height:220px; }\n  }\n\n  /* tiny flourish */\n  .sparkle {\n    position:absolute; width:8px; height:8px; border-radius:50%;\n    box-shadow: 0 8px 30px rgba(124,58,237,0.22);\n    background: radial-gradient(circle, #fff 0%, #7c3aed 40%, #7dd3fc 100%);\n    opacity:0; transform:scale(.6);\n    animation: twinkle 6s linear infinite;\n  }\n  .sparkle.s1{ left:20%; top:18%; animation-delay: -1s; }\n  .sparkle.s2{ right:18%; bottom:24%; animation-delay: -2.2s; }\n  .sparkle.s3{ left:52%; top:64%; animation-delay: -4.5s; }\n\n  @keyframes twinkle {\n    0%{ opacity:0; transform:scale(.6) translateY(0); }\n    10%{ opacity:1; transform:scale(1) translateY(-6px); }\n    50%{ opacity:0.3; transform:scale(.9) translateY(3px) }\n    100%{ opacity:0; transform:scale(.6) translateY(0); }\n  }\n\n  /* small accessibility focus */\n  .btn:focus{ outline:2px solid rgba(125,211,252,0.12); outline-offset:3px; }\n\n</style>\n</head>\n<body>\n<div class=\"stage\">\n  <!-- Background blobs -->\n  <div class=\"blob b1\"></div>\n  <div class=\"blob b2\"></div>\n  <div class=\"blob b3\"></div>\n\n  <div class=\"panel\" id=\"panel\" role=\"region\" aria-label=\"Refactoring visual demonstration\">\n    <div class=\"head\">\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"g\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7dd3fc\"/>\n                <stop offset=\"1\" stop-color=\"#a78bfa\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"10\" fill=\"url(#g)\"/>\n            <path d=\"M20 38 L28 26 L36 34 L44 22\" stroke=\"#0b1220\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\" opacity=\".9\"/>\n          </svg>\n        </div>\n        <div class=\"heading\">\n          <h1>Refactoring</h1>\n          <p>Sculpting code into clarity — before → after</p>\n        </div>\n      </div>\n\n      <div class=\"controls\">\n        <div class=\"kb\">Design-first demo</div>\n        <button id=\"actionBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Run the refactor animation\">\n          <span class=\"dot\" aria-hidden=\"true\"></span>\n          <span id=\"btnText\">Run Refactor</span>\n        </button>\n      </div>\n    </div>\n\n    <div class=\"workbench\" aria-hidden=\"false\">\n      <div class=\"pane before\" id=\"beforePane\" aria-label=\"Before refactor\">\n        <div class=\"label\"><span class=\"chip\"></span><strong style=\"margin-left:8px\">Before</strong></div>\n        <div class=\"ruler\" aria-hidden=\"true\"></div>\n        <div class=\"code\" id=\"beforeCode\" aria-hidden=\"false\">\n          <!-- Lines will be populated by JS for animation control -->\n        </div>\n      </div>\n\n      <div class=\"center\" aria-hidden=\"true\">\n        <div class=\"glyph\" id=\"glyph\">\n          <svg class=\"arrow\" viewBox=\"0 0 120 120\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"ag\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#60a5fa\"/>\n                <stop offset=\"1\" stop-color=\"#a78bfa\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"6\" width=\"108\" height=\"108\" rx=\"16\" fill=\"url(#ag)\" opacity=\"0.08\"></rect>\n            <g transform=\"translate(20,20)\" stroke=\"url(#ag)\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\">\n              <path d=\"M6 36 H60\" opacity=\"0.75\"></path>\n              <path d=\"M42 12 L66 36 L42 60\" opacity=\"0.95\"></path>\n            </g>\n          </svg>\n          <div class=\"badge\">refactor</div>\n        </div>\n        <div style=\"font-size:13px; color:var(--muted)\">Transformation</div>\n      </div>\n\n      <div class=\"pane after\" id=\"afterPane\" aria-label=\"After refactor\">\n        <div class=\"label\"><span class=\"chip\"></span><strong style=\"margin-left:8px\">After</strong></div>\n        <div class=\"ruler\" aria-hidden=\"true\"></div>\n        <div class=\"code\" id=\"afterCode\" aria-hidden=\"true\">\n          <!-- After lines populated by JS -->\n        </div>\n      </div>\n    </div>\n\n    <div class=\"meta\">\n      <div style=\"display:flex;gap:8px;align-items:center\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:.9\">\n          <circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.7\"></circle>\n          <path d=\"M7 12h10M12 7v10\" stroke=\"rgba(255,255,255,0.16)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n        </svg>\n        <div style=\"font-size:13px;color:var(--muted)\">One-click animation. Observe how complexity becomes composable.</div>\n      </div>\n    </div>\n\n    <div class=\"sparkle s1\"></div>\n    <div class=\"sparkle s2\"></div>\n    <div class=\"sparkle s3\"></div>\n  </div>\n</div>\n\n<script>\n  // Content for before and after\n  const beforeLines = [\n    { html: '<span class=\"comment\">// utility to fetch and compute user stats</span>' },\n    { html: '<span class=\"kw\">async</span> <span class=\"fn\">processUser</span>(user){' },\n    { html: '    let data = await fetch(\"/api/users/\"+user.id).then(r=>r.json());' },\n    { html: '    // merge, compute, filter, sort — all inline' },\n    { html: '    data = data.items.filter(i=>i.active).map(i=>({x:i.score*yOffset(i), name:i.name}));' },\n    { html: '    let total=0; for(let i=0;i<data.length;i++){ total+=data[i].x; }' },\n    { html: '    let avg = total/data.length; console.log(\"avg\",avg);' },\n    { html: '    // side-effects sprinkled everywhere' },\n    { html: '    sendTelemetry(user.id, avg); updateUI(avg); return avg;' },\n    { html: '}' }\n  ];\n\n  const afterLines = [\n    { html: '<span class=\"comment\">// refactored: small single-purpose functions</span>' },\n    { html: '<span class=\"kw\">async</span> <span class=\"fn\">processUser</span>(user){' },\n    { html: '    const data = await <span class=\"fn\">loadUserData</span>(user.id);' },\n    { html: '    const stats = <span class=\"fn\">computeStats</span>(data);' },\n    { html: '    <span class=\"fn\">present</span>(stats);' },\n    { html: '    <span class=\"fn\">track</span>(user.id, stats.avg);' },\n    { html: '    return stats.avg;' },\n    { html: '}' },\n    { html: '' },\n    { html: '<span class=\"kw\">async</span> <span class=\"fn\">loadUserData</span>(id){ /* fetch + safe-json */ }' },\n    { html: '<span class=\"kw\">function</span> <span class=\"fn\">computeStats</span>(data){ /* filter, map, sum */ }' }\n  ];\n\n  const beforeContainer = document.getElementById('beforeCode');\n  const afterContainer = document.getElementById('afterCode');\n  const panel = document.getElementById('panel');\n  const actionBtn = document.getElementById('actionBtn');\n  const btnText = document.getElementById('btnText');\n\n  // Create line elements with stagger data attributes\n  function renderLines(container, lines, prefix){\n    container.innerHTML = '';\n    lines.forEach((ln, i) => {\n      const line = document.createElement('div');\n      line.className = 'line';\n      line.dataset.index = i;\n      // slight variation to look organic\n      line.style.opacity = '1';\n      line.style.transform = 'translateY(0) scale(1)';\n      line.innerHTML = ln.html;\n      container.appendChild(line);\n    });\n  }\n\n  renderLines(beforeContainer, beforeLines, 'b');\n  renderLines(afterContainer, afterLines, 'a');\n\n  // Animation orchestration\n  let state = 'idle'; // idle | running | done\n  let timeouts = [];\n\n  function clearTimers(){\n    timeouts.forEach(t => clearTimeout(t));\n    timeouts = [];\n  }\n\n  function runRefactor(){\n    if(state === 'running') return;\n    clearTimers();\n    state = 'running';\n    panel.classList.add('run');\n    actionBtn.setAttribute('aria-pressed','true');\n    btnText.textContent = 'Refactoring…';\n\n    // animate before lines out with stagger\n    const beforeLinesEls = Array.from(beforeContainer.querySelectorAll('.line'));\n    const afterLinesEls = Array.from(afterContainer.querySelectorAll('.line'));\n\n    // add animate class with stagger\n    beforeLinesEls.forEach((el, idx) => {\n      const delay = idx * 120;\n      timeouts.push(setTimeout(() => {\n        el.classList.add('animate');\n      }, delay));\n    });\n\n    // reveal center glyph flourish\n    timeouts.push(setTimeout(() => {\n      // slide in after pane lines\n      afterLinesEls.forEach((el, idx) => {\n        const d2 = idx * 80 + 300;\n        timeouts.push(setTimeout(() => {\n          el.classList.add('animate');\n        }, d2));\n      });\n    }, 420));\n\n    // finally mark done and update button\n    timeouts.push(setTimeout(() => {\n      state = 'done';\n      panel.classList.remove('run');\n      // visually settle: ensure before lines faded and after visible\n      beforeLinesEls.forEach(el => { el.style.opacity = '0'; });\n      afterContainer.parentElement.setAttribute('aria-hidden','false');\n      beforeContainer.parentElement.setAttribute('aria-hidden','true');\n      actionBtn.setAttribute('aria-pressed','false');\n      btnText.textContent = 'Reset';\n    }, 1600 + beforeLinesEls.length * 120));\n  }\n\n  function reset(){\n    clearTimers();\n    state = 'idle';\n    panel.classList.remove('run');\n    actionBtn.setAttribute('aria-pressed','false');\n    btnText.textContent = 'Run Refactor';\n    // reset DOM lines\n    renderLines(beforeContainer, beforeLines);\n    renderLines(afterContainer, afterLines);\n    // ensure visibility states\n    const beforeLinesEls = Array.from(beforeContainer.querySelectorAll('.line'));\n    const afterLinesEls = Array.from(afterContainer.querySelectorAll('.line'));\n    beforeLinesEls.forEach(el => { el.style.opacity = '1'; el.classList.remove('animate'); });\n    afterLinesEls.forEach(el => { el.style.opacity = '0'; el.classList.remove('animate'); el.style.transform = 'translateY(18px) scale(.98)'; });\n    afterContainer.parentElement.setAttribute('aria-hidden','true');\n    beforeContainer.parentElement.setAttribute('aria-hidden','false');\n  }\n\n  // Initial state: after hidden\n  reset();\n\n  actionBtn.addEventListener('click', () => {\n    if(state === 'idle') runRefactor();\n    else reset();\n  });\n\n  // small accessibility: allow space/enter to trigger\n  actionBtn.addEventListener('keydown', (e) => {\n    if(e.key === 'Enter' || e.key === ' ') { e.preventDefault(); actionBtn.click(); }\n  });\n\n  // decorative gentle animation on load\n  window.addEventListener('load', () => {\n    const glyph = document.getElementById('glyph');\n    glyph.animate([\n      { transform: 'translateY(4px) rotate(0deg)' },\n      { transform: 'translateY(-2px) rotate(-1deg)' },\n      { transform: 'translateY(0px) rotate(0deg)' }\n    ], { duration: 2600, iterations: Infinity, easing: 'ease-in-out' });\n  });\n\n  // small helper (not interactive) to compute yOffset placeholder in comment\n  function yOffset(i){ return 1 + (i%3)/10; }\n</script>\n</body>\n</html>"
  },
