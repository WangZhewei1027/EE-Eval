n        <button id=\"remove-branch\">Remove Branch</button>\n        <input id=\"input-text\" type=\"text\" placeholder=\"Enter node value\">\n        <button id=\"add-node\">Add Node</button>\n        <button id=\"remove-node\">Remove Node</button>\n        <button id=\"clear-branch\">Clear Branch</button>\n        <button id=\"clear-node\">Clear Node</button>\n        <button id=\"search-node\">Search Node</button>\n        <button id=\"insert-node\">Insert Node</button>\n        <button id=\"delete-node\">Delete Node</button>\n        <button id=\"print-bst\">Print BST</button>\n        <button id=\"reset-bst\">Reset BST</button>\n        <button id=\"display-bst\">Display BST</button>\n    </div>\n\n    <script>\n        let bst = new BinarySearchTree();\n        let inputText = document.getElementById('input-text');\n        let addBranchButton = document.getElementById('add-branch');\n        let removeBranchButton = document.getElementById('remove-branch');\n        let addNodeButton = document.getElementById('add-node');\n        let removeNodeButton = document.getElementById('remove-node');\n        let clearBranchButton = document.getElementById('clear-branch');\n        let clearNodeButton = document.getElementById('clear-node');\n        let searchNodeButton = document.getElementById('search-node');\n        let insertNodeButton = document.getElementById('insert-node');\n        let deleteNodeButton = document.getElementById('delete-node');\n        let printBstButton = document.getElementById('print-bst');\n        let resetBstButton = document.getElementById('reset-bst');\n        let displayBstButton = document.getElementById('display-bst');\n\n        addBranchButton.addEventListener('click', addBranch);\n        removeBranchButton.addEventListener('click', removeBranch);\n        addNodeButton.addEventListener('click', addNode);\n        removeNodeButton.addEventListener('click', removeNode);\n        clearBranchButton.addEventListener('click', clearBranch);\n        clearNodeButton.addEventListener('click', clearNode);\n        searchNodeButton.addEventListener('click', searchNode);\n        insertNodeButton.addEventListener('click', insertNode);\n        deleteNodeButton.addEventListener('click', deleteNode);\n        printBstButton.addEventListener('click', printBst);\n        resetBstButton.addEventListener('click', resetBst);\n        displayBstButton.addEventListener('click', displayBst);\n\n        function addBranch() {\n            let value = inputText.value.trim();\n            if (value) {\n                bst.add(value);\n                inputText.value = '';\n            }\n        }\n\n        function removeBranch() {\n            bst.remove();\n            inputText.value = '';\n        }\n\n        function addNode() {\n            let value = inputText.value.trim();\n            if (value) {\n                bst.addNode(value);\n                inputText.value = '';\n            }\n        }\n\n        function removeNode() {\n            bst.removeNode(inputText.value.trim());\n            inputText.value = '';\n        }\n\n        function searchNode() {\n            let value = inputText.value.trim();\n            if (value) {\n                bst.search(value);\n                inputText.value = '';\n            }\n        }\n\n        function insertNode() {\n            let value = inputText.value.trim();\n            if (value) {\n                bst.insert(value);\n                inputText.value = '';\n            }\n        }\n\n        function deleteNode() {\n            bst.delete(inputText.value.trim());\n            inputText.value = '';\n        }\n\n        function printBst() {\n            bst.print();\n        }\n\n        function resetBst() {\n            bst.reset();\n        }\n\n        function displayBst() {\n            bst.display();\n        }\n\n        function print() {\n            let output = '';\n            bst.print().forEach(node => output += `${node