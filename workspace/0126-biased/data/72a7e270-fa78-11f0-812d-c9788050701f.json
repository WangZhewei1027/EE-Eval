    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>The Beauty of Arrays</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n\n        @keyframes glow {\n            0%, 100% { box-shadow: 0 0 10px rgba(100, 108, 255, 0.3); }\n            50% { box-shadow: 0 0 20px rgba(100, 108, 255, 0.6); }\n        }\n\n        body {\n            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);\n            color: #fff;\n            min-height: 100vh;\n            overflow-x: hidden;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            position: relative;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, #a6c1ee, #fbc2eb);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-align: center;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            text-align: center;\n            margin-bottom: 3rem;\n            color: rgba(255, 255, 255, 0.7);\n            font-weight: 300;\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            margin: 4rem 0;\n            perspective: 1000px;\n        }\n\n        .array-element {\n            width: 100px;\n            height: 100px;\n            background: linear-gradient(45deg, #4facfe, #00f2fe);\n            margin: 0 10px;\n            border-radius: 12px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.5rem;\n            font-weight: 700;\n            color: white;\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n            animation: float 4s ease-in-out infinite;\n        }\n\n        .array-element::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: linear-gradient(\n                rgba(255, 255, 255, 0.1),\n                rgba(255, 255, 255, 0)\n            );\n            transform: rotate(45deg);\n        }\n\n        .array-element:nth-child(1) { animation-delay: 0.2s; background: linear-gradient(45deg, #4facfe, #00f2fe); }\n        .array-element:nth-child(2) { animation-delay: 0.4s; background: linear-gradient(45deg, #f093fb, #f5576c); }\n        .array-element:nth-child(3) { animation-delay: 0.6s; background: linear-gradient(45deg, #43e97b, #38f9d7); }\n        .array-element:nth-child(4) { animation-delay: 0.8s; background: linear-gradient(45deg, #ff9a9e, #fad0c4); }\n        .array-element:nth-child(5) { animation-delay: 1.0s; background: linear-gradient(45deg, #a18cd1, #fbc2eb); }\n\n        .array-index {\n            position: absolute;\n            top: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 0.9rem;\n            color: rgba(255, 255, 255, 0.7);\n            font-weight: 400;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 3rem;\n            gap: 1rem;\n        }\n\n        button {\n            padding: 0.8rem 2rem;\n            background: rgba(255, 255, 255, 0.1);\n            border: 1px solid rgba(255, 255, 255, 0.2);\n            color: white;\n            font-size: 1rem;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(10px);\n        }\n\n        button:hover {\n            background: rgba(255, 255, 255, 0.2);\n            transform: translateY(-3px);\n            animation: glow 2s infinite;\n        }\n\n        .info-panel {\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 20px;\n            padding: 2rem;\n            margin-top: 4rem;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: all 0.5s ease;\n        }\n\n        .info-panel:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);\n        }\n\n        h2 {\n            font-size: 1.8rem;\n            margin-bottom: 1rem;\n            color: white;\n            font-weight: 600;\n        }\n\n        p {\n            color: rgba(255, 255, 255, 0.7);\n            line-height: 1.6;\n            margin-bottom: 1rem;\n        }\n\n        .code {\n            font-family: 'Menlo', monospace;\n            background: rgba(0, 0, 0, 0.3);\n            padding: 0.2rem 0.4rem;\n            border-radius: 4px;\n            color: #a6e3e9;\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .particle {\n            position: absolute;\n            background: rgba(255, 255, 255, 0.3);\n            border-radius: 50%;\n            animation: float 10s infinite linear;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <h1>The Elegance of Arrays</h1>\n        <p class=\"subtitle\">A visual symphony of ordered data structures</p>\n        \n        <div class=\"array-container\">\n            <div class=\"array-element\">\n                <span class=\"array-index\">[0]</span>\n                42\n            </div>\n            <div class=\"array-element\">\n                <span class=\"array-index\">[1]</span>\n                π\n            </div>\n            <div class=\"array-element\">\n                <span class=\"array-index\">[2]</span>\n                ∞\n            </div>\n            <div class=\"array-element\">\n                <span class=\"array-index\">[3]</span>\n                ∅\n            </div>\n            <div class=\"array-element\">\n                <span class=\"array-index\">[4]</span>\n                Ω\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"animateBtn\">Animate Array</button>\n            <button id=\"randomizeBtn\">Randomize Values</button>\n        </div>\n        \n        <div class=\"info-panel\">\n            <h2>Array Fundamentals</h2>\n            <p>\n                An array is a systematic arrangement of similar objects, typically in rows and columns. \n                In computer science, arrays are among the oldest and most important data structures.\n            </p>\n            <p>\n                Each element in an array can be accessed by its numerical <span class=\"code\">index</span>. \n                The illustration above shows a simple array with five elements, each containing a unique value.\n            </p>\n            <p>\n                Arrays are <span class=\"code\">zero-indexed</span> in most programming languages, meaning the \n                first element is at position <span class=\"code\">0</span>, not <span class=\"code\">1</span>.\n            </p>\n        </div>\n    </div>\n\n    <script>\n        // Create background particles\n        function createParticles() {\n            const particlesContainer = document.getElementById('particles');\n            const particleCount = window.innerWidth < 768 ? 20 : 50;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                // Random properties\n                const size = Math.random() * 5 + 2;\n                const posX = Math.random() * 100;\n                const posY = Math.random() * 100;\n                const duration = Math.random() * 20 + 10;\n                const delay = Math.random() * 10;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.top = `${posY}%`;\n                particle.style.opacity = Math.random() * 0.5 + 0.1;\n                particle.style.animationDuration = `${duration}s`;\n                particle.style.animationDelay = `${delay}s`;\n                \n                particlesContainer.appendChild(particle);\n            }\n        }\n        \n        // Animate array elements\n        function animateArray() {\n            const elements = document.querySelectorAll('.array-element');\n            elements.forEach((el, index) => {\n                setTimeout(() => {\n                    el.style.transform = 'rotateY(360deg) scale(1.2)';\n                    setTimeout(() => {\n                        el.style.transform = 'rotateY(0) scale(1)';\n                    }, 1000);\n                }, index * 200);\n            });\n        }\n        \n        // Randomize array values\n        function randomizeValues() {\n            const elements = document.querySelectorAll('.array-element');\n            const symbols = ['α', 'β', 'γ', 'δ', 'ε', 'ζ', 'θ', 'λ', 'μ', 'σ', 'φ', 'ψ', 'ω'];\n            \n            elements.forEach(el => {\n                const randomValue = Math.random() < 0.5 \n                    ? Math.floor(Math.random() * 100)\n                    : symbols[Math.floor(Math.random() * symbols.length)];\n                el.textContent = randomValue;\n                el.innerHTML = `<span class=\"array-index\">${el.querySelector('.array-index').textContent}</span> ${randomValue}`;\n            });\n        }\n        \n        // Initialize\n        document.addEventListener('DOMContentLoaded', () => {\n            createParticles();\n            \n            document.getElementById('animateBtn').addEventListener('click', animateArray);\n            document.getElementById('randomizeBtn').addEventListener('click', randomizeValues);\n        });\n    </script>\n</body>\n</html>"
