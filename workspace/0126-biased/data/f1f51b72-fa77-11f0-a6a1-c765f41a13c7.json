    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Min Heap — Visual Concept</title>\n\n  <!-- Aesthetic fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg1: #0f1724; /* deep navy */\n      --bg2: #061025; /* darker teal */\n      --accent: #7DE0E0; /* soft aqua */\n      --accent2: #FFD580; /* warm gold */\n      --muted: rgba(255,255,255,0.06);\n      --glass: rgba(255,255,255,0.04);\n      --card: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      --radius: 18px;\n    }\n\n    * { box-sizing: border-box; }\n    html,body { height:100%; margin:0; font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; -webkit-font-smoothing:antialiased; color: #EAF6F6; background: radial-gradient(1200px 700px at 10% 20%, rgba(125,224,224,0.06), transparent), radial-gradient(900px 600px at 90% 80%, rgba(255,213,128,0.03), transparent), linear-gradient(180deg, var(--bg1), var(--bg2)); }\n\n    /* subtle animated aurora */\n    .aurora {\n      position: fixed;\n      inset: 0;\n      pointer-events: none;\n      z-index:0;\n      overflow:hidden;\n      mix-blend-mode: screen;\n    }\n    .aurora::before, .aurora::after{\n      content:\"\";\n      position:absolute;\n      border-radius:50%;\n      filter: blur(60px);\n      transform: translateZ(0);\n      opacity:0.6;\n      animation: drift 12s infinite alternate ease-in-out;\n    }\n    .aurora::before{\n      width:700px; height:700px;\n      left:-10%; top:-20%;\n      background: radial-gradient(circle at 30% 30%, rgba(125,224,224,0.14), transparent 30%), conic-gradient(from 120deg, rgba(255,213,128,0.06), rgba(125,224,224,0.06));\n      animation-duration: 16s;\n    }\n    .aurora::after{\n      width:900px; height:900px;\n      right:-10%; bottom:-10%;\n      background: radial-gradient(circle at 70% 70%, rgba(255,213,128,0.10), transparent 28%), linear-gradient(120deg, rgba(125,224,224,0.03), transparent);\n      animation-duration: 20s;\n    }\n    @keyframes drift {\n      from { transform: translateY(-20px) translateX(0) scale(1); }\n      to { transform: translateY(20px) translateX(30px) scale(1.02); }\n    }\n\n    /* Center stage */\n    .stage {\n      min-height:100vh;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n      position:relative;\n      z-index:1;\n    }\n\n    .card {\n      width:1100px;\n      max-width:96%;\n      border-radius:var(--radius);\n      padding:28px;\n      background: var(--card);\n      box-shadow: 0 8px 40px rgba(3,8,18,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(8px) saturate(120%);\n      position:relative;\n      overflow:hidden;\n      border: 1px solid rgba(255,255,255,0.04);\n    }\n\n    .header {\n      display:flex;\n      align-items:center;\n      gap:20px;\n    }\n\n    .logo {\n      width:84px;\n      height:84px;\n      border-radius:16px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      background: linear-gradient(135deg, rgba(125,224,224,0.16), rgba(255,213,128,0.06));\n      box-shadow: 0 6px 30px rgba(9,20,27,0.6), inset 0 -6px 24px rgba(255,255,255,0.02);\n      border: 1px solid rgba(255,255,255,0.04);\n    }\n\n    .logo svg { filter: drop-shadow(0 6px 18px rgba(0,0,0,0.6)); }\n\n    h1 {\n      font-family: \"Playfair Display\", serif;\n      margin:0;\n      font-size:28px;\n      letter-spacing:-0.02em;\n      color:#F6FDFF;\n    }\n    .subtitle {\n      margin:6px 0 0 0;\n      color: rgba(234,246,246,0.75);\n      font-size:13px;\n    }\n\n    .controls {\n      margin-left:auto;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n\n    .btn {\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.06);\n      color:#EAF6F6;\n      padding:10px 14px;\n      border-radius:12px;\n      font-weight:600;\n      font-size:13px;\n      cursor:pointer;\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n      transition: transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n      box-shadow: 0 6px 18px rgba(3,8,18,0.45);\n      backdrop-filter: blur(6px);\n    }\n    .btn:active { transform: translateY(1px) scale(0.997); }\n    .btn:disabled { opacity:0.5; cursor:default; transform:none; }\n\n    .btn.primary {\n      background: linear-gradient(90deg, rgba(125,224,224,0.14), rgba(255,213,128,0.08));\n      color: #05222A;\n      border: 1px solid rgba(125,224,224,0.16);\n      box-shadow: 0 10px 30px rgba(125,224,224,0.06);\n    }\n\n    .layout {\n      display:flex;\n      gap:28px;\n      margin-top:22px;\n      align-items:stretch;\n    }\n\n    .left {\n      flex:1.2;\n      min-height:360px;\n      position:relative;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border-radius:14px;\n      padding:18px;\n      border: 1px solid rgba(255,255,255,0.02);\n      overflow:hidden;\n    }\n\n    .right {\n      width:320px;\n      min-height:360px;\n      padding:18px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.02);\n    }\n\n    /* Canvas where nodes will live */\n    .canvas {\n      position:relative;\n      width:100%;\n      height:420px;\n    }\n\n    svg.connect {\n      width:100%;\n      height:100%;\n      position:absolute;\n      left:0;\n      top:0;\n      pointer-events:none;\n      overflow:visible;\n    }\n\n    .node {\n      position:absolute;\n      width:68px;\n      height:68px;\n      border-radius:50%;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:700;\n      font-size:18px;\n      color: #022428;\n      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.85), rgba(255,255,255,0.78) 20%, rgba(255,255,255,0.12) 55%), linear-gradient(180deg, rgba(125,224,224,0.9), rgba(255,213,128,0.9));\n      box-shadow: 0 10px 30px rgba(2,36,40,0.12), inset 0 2px 10px rgba(255,255,255,0.35);\n      transform: translate(-50%,-50%) scale(1);\n      transition: transform 520ms cubic-bezier(.2,.9,.2,1), left 520ms cubic-bezier(.2,.9,.2,1), top 520ms cubic-bezier(.2,.9,.2,1), box-shadow 240ms ease;\n      z-index:2;\n      user-select:none;\n      pointer-events:none;\n    }\n    .node.small { width:56px;height:56px;font-size:15px; }\n    .node .label {\n      display:block;\n      text-align:center;\n      transform: translateY(-1px);\n    }\n    .node.pulse {\n      animation: pulse 1.6s infinite ease-in-out;\n    }\n    @keyframes pulse {\n      0% { transform: translate(-50%,-50%) scale(1); filter: drop-shadow(0 8px 30px rgba(125,224,224,0.04)); }\n      50% { transform: translate(-50%,-50%) scale(1.03); filter: drop-shadow(0 18px 60px rgba(125,224,224,0.06)); }\n      100%{ transform: translate(-50%,-50%) scale(1); }\n    }\n\n    .node.compare {\n      box-shadow: 0 18px 40px rgba(255,205,120,0.12), inset 0 6px 20px rgba(255,255,255,0.35);\n      transform: translate(-50%,-50%) scale(1.06);\n    }\n\n    .node.swap {\n      box-shadow: 0 22px 60px rgba(255,170,60,0.14), inset 0 8px 30px rgba(255,255,255,0.4);\n      transform: translate(-50%,-50%) scale(1.08);\n    }\n\n    .arrayRow {\n      position:absolute;\n      left:12px;\n      right:12px;\n      top:8px;\n      display:flex;\n      gap:10px;\n      justify-content:center;\n      pointer-events:none;\n    }\n    .pill{\n      min-width:44px;\n      height:30px;\n      border-radius:18px;\n      display:inline-flex;\n      align-items:center;\n      justify-content:center;\n      padding:6px 12px;\n      font-weight:600;\n      font-size:13px;\n      color:#05222A;\n      background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.90));\n      box-shadow: 0 6px 18px rgba(2,36,40,0.09);\n      border: 1px solid rgba(255,255,255,0.6);\n    }\n\n    .meta {\n      margin-top:6px;\n      color: rgba(234,246,246,0.66);\n      font-size:13px;\n    }\n\n    .right h3 {\n      margin:0 0 8px 0;\n      font-size:15px;\n      color:#EAF6F6;\n      font-weight:700;\n      letter-spacing:-0.01em;\n      font-family:Inter;\n    }\n\n    .info {\n      font-size:13px;\n      color: rgba(234,246,246,0.75);\n      line-height:1.6;\n    }\n\n    .legend {\n      margin-top:12px;\n      display:flex;\n      gap:8px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    .legend .key {\n      display:flex;\n      gap:8px;\n      align-items:center;\n      padding:8px 10px;\n      border-radius:12px;\n      background: rgba(255,255,255,0.02);\n      color: rgba(234,246,246,0.9);\n      font-weight:600;\n      font-size:13px;\n    }\n    .dot {\n      width:12px;height:12px;border-radius:50%;\n      box-shadow: 0 6px 10px rgba(0,0,0,0.35);\n    }\n    .dot.min { background: linear-gradient(180deg,#FFD580,#FFB347); }\n    .dot.comp { background: linear-gradient(90deg,#7DE0E0,#6FE3C8); }\n\n    /* footer small */\n    .footerSmall {\n      margin-top:16px;\n      font-size:12px;\n      color: rgba(234,246,246,0.52);\n    }\n\n    /* responsive tweaks */\n    @media (max-width:960px){\n      .layout { flex-direction:column; }\n      .right { width:100%; }\n      .controls { display:flex; gap:8px; }\n      .logo { width:70px; height:70px; }\n      .card { padding:18px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"aurora\" aria-hidden=\"true\"></div>\n  <div class=\"stage\">\n    <div class=\"card\" role=\"region\" aria-label=\"Min Heap visualization\">\n      <div class=\"header\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <!-- stylized heap icon -->\n          <svg width=\"56\" height=\"56\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7DE0E0\"/>\n                <stop offset=\"1\" stop-color=\"#FFD580\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"12\" fill=\"url(#g1)\" opacity=\"0.9\"/>\n            <g transform=\"translate(8,8)\" fill=\"#05222A\" opacity=\"0.9\">\n              <circle cx=\"26\" cy=\"8\" r=\"6\"/>\n              <circle cx=\"10\" cy=\"26\" r=\"6\"/>\n              <circle cx=\"42\" cy=\"26\" r=\"6\"/>\n              <path d=\"M26 14 L10 22\" stroke=\"#05222A\" stroke-width=\"2\" stroke-linecap=\"round\" />\n              <path d=\"M26 14 L42 22\" stroke=\"#05222A\" stroke-width=\"2\" stroke-linecap=\"round\" />\n            </g>\n          </svg>\n        </div>\n\n        <div>\n          <h1>Min Heap — Visual Concept</h1>\n          <div class=\"subtitle\">A refined, minimal interaction visualization explaining the min-heap structure and build process.</div>\n        </div>\n\n        <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n          <button id=\"regenBtn\" class=\"btn\" title=\"Generate a new random heap\">\n            <!-- icon -->\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\"><path d=\"M20 7v6h-6\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path><path d=\"M4 17V9h6\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path><path d=\"M20 7a9 9 0 1 0 0 10\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n            Generate New Heap\n          </button>\n\n          <button id=\"playBtn\" class=\"btn primary\" title=\"Animate building the min-heap\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.95\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path></svg>\n            Play Build Animation\n          </button>\n        </div>\n      </div>\n\n      <div class=\"layout\">\n        <div class=\"left\">\n          <div class=\"canvas\" id=\"canvas\" aria-hidden=\"true\">\n            <div class=\"arrayRow\" id=\"arrayRow\" aria-hidden=\"true\"></div>\n\n            <svg class=\"connect\" id=\"svgLayer\" aria-hidden=\"true\"></svg>\n            <!-- nodes will be injected here -->\n          </div>\n\n          <div class=\"meta\">Observe the nodes as they move into a tree layout and the heapify process enforces the min-heap property. Minimal controls — mostly watch the animation.</div>\n        </div>\n\n        <div class=\"right\" aria-hidden=\"true\">\n          <h3>About Min-Heap</h3>\n          <div class=\"info\">\n            - A min-heap is a binary tree where each parent node is less than or equal to its children.<br>\n            - Commonly implemented as an array: parent at i, children at 2i+1 and 2i+2.<br>\n            - The \"build\" process runs sift-down from the last parent to the root, establishing the heap property.\n          </div>\n\n          <div class=\"legend\">\n            <div class=\"key\"><span class=\"dot min\"></span> Current minimum</div>\n            <div class=\"key\"><span class=\"dot comp\"></span> Comparing nodes</div>\n          </div>\n\n          <div class=\"footerSmall\">Tip: Use \"Generate New Heap\" for fresh examples. The animation will show comparisons and swaps softly.</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    /* Min Heap Visualization Script\n       - Minimal controls: Generate New Heap, Play Build Animation\n       - Smooth animations, aesthetic styling\n    */\n\n    // Utilities for animation timing\n    const ms = t => new Promise(r => setTimeout(r, t));\n\n    // DOM Elements\n    const canvas = document.getElementById('canvas');\n    const svgLayer = document.getElementById('svgLayer');\n    const arrayRow = document.getElementById('arrayRow');\n    const playBtn = document.getElementById('playBtn');\n    const regenBtn = document.getElementById('regenBtn');\n\n    let nodes = [];   // {val, el, idx}\n    let values = [];\n    let positions = {}; // idx -> {x,y}\n    let animating = false;\n\n    // Initial generate\n    function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }\n\n    function generateValues(count){\n      const vals = [];\n      const pool = [];\n      for(let i=1;i<=60;i++) pool.push(i);\n      // shuffle pool slightly and pick\n      for(let i=pool.length-1;i>0;i--){\n        const j = Math.floor(Math.random()*(i+1)); [pool[i],pool[j]]=[pool[j],pool[i]];\n      }\n      for(let i=0;i<count;i++) vals.push(pool[i]);\n      return vals;\n    }\n\n    function clearCanvas(){\n      nodes = [];\n      positions = {};\n      svgLayer.innerHTML = '';\n      arrayRow.innerHTML = '';\n      // remove existing node elements\n      const existing = canvas.querySelectorAll('.node');\n      existing.forEach(n=>n.remove());\n    }\n\n    function placeArrayRow(vals){\n      arrayRow.innerHTML = '';\n      vals.forEach((v,i)=>{\n        const pill = document.createElement('div');\n        pill.className = 'pill';\n        pill.textContent = v;\n        arrayRow.appendChild(pill);\n      });\n    }\n\n    function createNodes(vals){\n      clearCanvas();\n      values = vals.slice();\n\n      // array row pills\n      placeArrayRow(vals);\n\n      // Create node elements placed initially in a row above then animate to tree\n      const rect = canvas.getBoundingClientRect();\n      const topY = 52; // start Y for array row placed nodes\n      const spacing = Math.min(88, Math.max(52, (rect.width-40)/ (vals.length+1)));\n      const startX = (rect.width - ((vals.length-1)*spacing)) / 2;\n\n      vals.forEach((v,i)=>{\n        const el = document.createElement('div');\n        el.className = 'node';\n        el.setAttribute('data-idx', i);\n        el.innerHTML = `<span class=\"label\">${v}</span>`;\n        canvas.appendChild(el);\n        nodes.push({val:v, el, idx:i});\n        // initial position arranged horizontally\n        const left = startX + i*spacing;\n        const top = topY;\n        el.style.left = left + 'px';\n        el.style.top = top + 'px';\n        el.style.transition = 'transform 520ms cubic-bezier(.2,.9,.2,1), left 520ms cubic-bezier(.2,.9,.2,1), top 520ms cubic-bezier(.2,.9,.2,1), box-shadow 240ms ease';\n      });\n\n      // compute final tree positions\n      computeTreePositions(vals.length);\n      // draw initial connecting lines (empty)\n      drawConnections();\n    }\n\n    function computeTreePositions(n){\n      const rect = canvas.getBoundingClientRect();\n      const width = rect.width;\n      const margin = 20;\n      const levelHeight = 84;\n      const topOffset = 140;\n      let level = 0;\n      let i = 0;\n      while(i < n){\n        const count = Math.min(2**level, n - (2**level -1));\n        const y = topOffset + level*levelHeight;\n        const spacing = width / (count + 1);\n        for(let k=0;k<count && i<n;k++, i++){\n          const x = spacing*(k+1);\n          positions[i] = {x, y};\n        }\n        level++;\n        if (level > 8) break;\n      }\n    }\n\n    function drawConnections(){\n      // clear svg\n      svgLayer.innerHTML = '';\n      for(let i=0;i<nodes.length;i++){\n        const p = positions[i];\n        if(!p) continue;\n        const left = p.x, top = p.y;\n        const leftChild = 2*i+1, rightChild = 2*i+2;\n        [leftChild,rightChild].forEach(childIdx=>{\n          if(childIdx < nodes.length){\n            const cp = positions[childIdx];\n            if(!cp) return;\n            const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n            const stroke = 'rgba(125,224,224,0.12)';\n            const d = `M ${left} ${top+30} Q ${ (left+cp.x)/2 } ${ (top+cp.y)/2 } ${cp.x} ${cp.y-30}`;\n            path.setAttribute('d', d);\n            path.setAttribute('stroke', stroke);\n            path.setAttribute('stroke-width', '2.2');\n            path.setAttribute('fill','none');\n            path.setAttribute('stroke-linecap','round');\n            path.setAttribute('stroke-linejoin','round');\n            path.style.transition = 'd 520ms cubic-bezier(.2,.9,.2,1), stroke 240ms ease';\n            svgLayer.appendChild(path);\n          }\n        });\n      }\n    }\n\n    // Smoothly move node to target index position\n    function moveNodeToIndex(node, newIndex, instant=false){\n      return new Promise(resolve=>{\n        const p = positions[newIndex];\n        if(!p){ resolve(); return; }\n        node.idx = newIndex;\n        node.el.setAttribute('data-idx', newIndex);\n        if(instant){\n          node.el.style.transition = 'none';\n          node.el.style.left = p.x + 'px';\n          node.el.style.top = p.y + 'px';\n          // force reflow then restore\n          void node.el.offsetHeight;\n          node.el.style.transition = 'transform 520ms cubic-bezier(.2,.9,.2,1), left 520ms cubic-bezier(.2,.9,.2,1), top 520ms cubic-bezier(.2,.9,.2,1), box-shadow 240ms ease';\n          resolve();\n        } else {\n          // Listen for a single transition end\n          let done = false;\n          const onEnd = (e)=>{\n            if(e.propertyName === 'left' || e.propertyName === 'top'){\n              if(done) return;\n              done = true;\n              node.el.removeEventListener('transitionend', onEnd);\n              resolve();\n            }\n          };\n          node.el.addEventListener('transitionend', onEnd);\n          // trigger move\n          node.el.style.left = p.x + 'px';\n          node.el.style.top = p.y + 'px';\n        }\n      });\n    }\n\n    async function animateToTree(){\n      // move all nodes from array placement to tree positions concurrently with stagger\n      const promises = [];\n      for(let i=0;i<nodes.length;i++){\n        const n = nodes[i];\n        // add slight stagger\n        await ms(28);\n        n.el.classList.add('pulse');\n        promises.push(moveNodeToIndex(n, i, false));\n      }\n      // when done, remove pulse\n      await Promise.all(promises);\n      nodes.forEach(n=>n.el.classList.remove('pulse'));\n      drawConnections();\n      await ms(120);\n    }\n\n    // helper: highlight nodes for comparison\n    function highlight(idxList, cls='compare'){\n      idxList.forEach(i=>{\n        const n = nodes.find(nn=>nn.idx===i);\n        if(n) n.el.classList.add(cls);\n      });\n    }\n    function unhighlight(idxList, cls='compare'){\n      idxList.forEach(i=>{\n        const n = nodes.find(nn=>nn.idx===i);\n        if(n) n.el.classList.remove(cls);\n      });\n    }\n\n    // swap nodes in our nodes array by indices (idx positions)\n    async function swapByIdx(i,j){\n      const ni = nodes.find(n=>n.idx===i);\n      const nj = nodes.find(n=>n.idx===j);\n      if(!ni || !nj) return;\n      // animate swap: both get swap class\n      ni.el.classList.add('swap');\n      nj.el.classList.add('swap');\n      // swap their idxs visually\n      const pI = positions[i];\n      const pJ = positions[j];\n      // set z-index to ensure clearer swap layering\n      ni.el.style.zIndex = 5;\n      nj.el.style.zIndex = 6;\n      // Move simultaneously\n      const p1 = moveNodeToIndex(ni, j);\n      const p2 = moveNodeToIndex(nj, i);\n      drawConnections();\n      await Promise.all([p1,p2]);\n      // reflect in nodes structure: swap their idx values (already updated), but maintain nodes array order variable\n      ni.el.classList.remove('swap');\n      nj.el.classList.remove('swap');\n      ni.el.style.zIndex = 2;\n      nj.el.style.zIndex = 2;\n      // update nodes array ordering to reflect positions (not strictly necessary)\n      await ms(40);\n    }\n\n    // Build heap using sift-down with animations\n    async function buildHeapAnimated(){\n      if(animating) return;\n      animating = true;\n      playBtn.disabled = true;\n      regenBtn.disabled = true;\n      // move nodes to tree first if not already\n      await animateToTree();\n\n      // We'll operate on a lightweight array of values but track nodes by their idx\n      const n = nodes.length;\n      // Helper to get value at idx\n      function valAt(i){\n        const nd = nodes.find(nn=>nn.idx===i);\n        return nd ? nd.val : undefined;\n      }\n\n      // SiftDown with visualizations\n      async function siftDown(start, end){\n        let root = start;\n        while(true){\n          const left = 2*root + 1;\n          const right = 2*root + 2;\n          if(left > end) break;\n          // highlight comparison\n          highlight([root,left]);\n          await ms(360);\n          let swapIdx = root;\n          if(valAt(swapIdx) > valAt(left)) swapIdx = left;\n          if(right <= end){\n            highlight([right]);\n            await ms(280);\n            if(valAt(swapIdx) > valAt(right)) swapIdx = right;\n          }\n          // small delay\n          await ms(240);\n          unhighlight([root,left,right]);\n          if(swapIdx === root) break;\n          // swap in values & animate nodes swapping positions\n          await swapByIdx(root, swapIdx);\n          // after swap, update val references in nodes to keep values correct\n          const a = nodes.find(n=>n.idx===root);\n          const b = nodes.find(n=>n.idx===swapIdx);\n          // Actually the node.elem positions changed; we need to swap their val labels so valAt works\n          // Find the DOM node elements and swap their displayed values and internal val mapping.\n          // But since we swapped their idxs via moveNodeToIndex, their .val fields remain with the original numbers - to keep valAt mapping coherent we must swap .val fields\n          // Find nodes by their element positions (el has data-idx updated), but earlier we swapped idx's. So adjust:\n          const nodeA = nodes.find(n=>n.el.getAttribute('data-idx')==root);\n          const nodeB = nodes.find(n=>n.el.getAttribute('data-idx')==swapIdx);\n          // However, simpler approach: swap the .val fields between the elements at root and swapIdx in our nodes array representation.\n          // We'll find elements by matching previous idx via their left/top positions. To avoid complexity, swap values in the DOM labels according to tree positions.\n          // Find node objects by searching where their idx equals swapIdx and root (after move they updated). We need to swap .val properties of DOM nodes that now sit at those idxs.\n          const nRoot = nodes.find(n=>n.idx===root);\n          const nSwap = nodes.find(n=>n.idx===swapIdx);\n          // swap val properties\n          const tmp = nRoot.val;\n          nRoot.val = nSwap.val;\n          nSwap.val = tmp;\n          // update labels\n          nRoot.el.querySelector('.label').textContent = nRoot.val;\n          nSwap.el.querySelector('.label').textContent = nSwap.val;\n\n          // continue sifting at the swapped child position\n          root = swapIdx;\n          await ms(160);\n        }\n      }\n\n      // Build heap: from last parent down to 0\n      const lastParent = Math.floor((nodes.length - 2)/2);\n      for(let i = lastParent; i >= 0; i--){\n        // brief highlight on current root candidate\n        highlight([i], 'compare');\n        await ms(220);\n        unhighlight([i], 'compare');\n        await siftDown(i, nodes.length - 1);\n        await ms(100);\n      }\n\n      // Final subtle glow to indicate completion: highlight root as min\n      const rootNode = nodes.find(n=>n.idx===0);\n      if(rootNode){\n        rootNode.el.classList.add('pulse');\n        await ms(900);\n        rootNode.el.classList.remove('pulse');\n      }\n\n      drawConnections(); // final\n      animating = false;\n      playBtn.disabled = false;\n      regenBtn.disabled = false;\n    }\n\n    // Initial render\n    function initRandom(){\n      if(animating) return;\n      const count = randInt(7,13);\n      const vals = generateValues(count);\n      createNodes(vals);\n      // position nodes to tree immediately (without animation) for clean starting view\n      nodes.forEach(n=>{\n        // set final positions instantly\n        const p = positions[n.idx];\n        if(p){\n          n.el.style.transition = 'none';\n          n.el.style.left = p.x + 'px';\n          n.el.style.top = p.y + 'px';\n          // small reflow and restore transitions\n          void n.el.offsetHeight;\n          n.el.style.transition = 'transform 520ms cubic-bezier(.2,.9,.2,1), left 520ms cubic-bezier(.2,.9,.2,1), top 520ms cubic-bezier(.2,.9,.2,1), box-shadow 240ms ease';\n        }\n      });\n      drawConnections();\n    }\n\n    // Generate but place nodes in the array row first (so animation will move them)\n    function initRandomForAnimation(){\n      if(animating) return;\n      const count = randInt(8,14);\n      const vals = generateValues(count);\n      createNodes(vals);\n      // Keep nodes in array row positions (done by createNodes)\n      drawConnections();\n    }\n\n    // Event listeners\n    regenBtn.addEventListener('click', ()=> {\n      // generate new dataset; default to array-row start positions for visual interest\n      initRandomForAnimation();\n    });\n\n    playBtn.addEventListener('click', async ()=>{\n      if(animating) return;\n      buildHeapAnimated();\n    });\n\n    // initial load: create a static pleasing heap\n    (function startup(){\n      // produce an elegant default sequence that isn't sorted (so animation is interesting)\n      const initial = [18, 34, 7, 49, 26, 11, 3];\n      createNodes(initial);\n      // place no