    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Typing Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Dynamic Typing Demonstration</h1>\n\n<div>\n    <label for=\"textInput\">Input a value:</label>\n    <input type=\"text\" id=\"textInput\" oninput=\"updateOutput()\" placeholder=\"Type here...\">\n</div>\n\n<div>\n    <label for=\"numberInput\">Input a number:</label>\n    <input type=\"number\" id=\"numberInput\" oninput=\"updateOutput()\">\n</div>\n\n<div>\n    <label for=\"boolInput\">Select a boolean:</label>\n    <select id=\"boolInput\" onchange=\"updateOutput()\">\n        <option value=\"true\">True</option>\n        <option value=\"false\">False</option>\n    </select>\n</div>\n\n<div>\n    <label for=\"stringButton\">Click to input predefined string:</label>\n    <button id=\"stringButton\" onclick=\"setString()\">Set String \"Hello World\"</button>\n</div>\n\n<div>\n    <label for=\"arrayButton\">Click to input array:</label>\n    <button id=\"arrayButton\" onclick=\"setArray()\">Set Array [1, 2, 3]</button>\n</div>\n\n<div>\n    <label for=\"objectButton\">Click to input object:</label>\n    <button id=\"objectButton\" onclick=\"setObject()\">Set Object { name: 'John', age: 30 }</button>\n</div>\n\n<div>\n    <label for=\"dateButton\">Click to input current date:</label>\n    <button id=\"dateButton\" onclick=\"setDate()\">Set Date</button>\n</div>\n\n<div>\n    <label for=\"customObjectButton\">Click to input custom object:</label>\n    <button id=\"customObjectButton\" onclick=\"setCustomObject()\">Set Custom Object</button>\n</div>\n\n<div id=\"output\">\n    <h3>Output:</h3>\n    <pre id=\"outputDisplay\"></pre>\n</div>\n\n<script>\n    let currentOutput = \"\";\n\n    function updateOutput() {\n        const textInput = document.getElementById('textInput').value;\n        const numberInput = document.getElementById('numberInput').value;\n        const boolInput = document.getElementById('boolInput').value;\n\n        currentOutput = {\n            string: textInput,\n            number: numberInput ? Number(numberInput) : null,\n            boolean: boolInput === \"true\",\n        };\n\n        updateDisplay();\n    }\n\n    function setString() {\n        document.getElementById('textInput').value = \"Hello World\";\n        updateOutput();\n    }\n\n    function setArray() {\n        currentOutput = [1, 2, 3];\n        updateDisplay();\n    }\n\n    function setObject() {\n        currentOutput = { name: 'John', age: 30 };\n        updateDisplay();\n    }\n\n    function setDate() {\n        currentOutput = new Date().toString();\n        updateDisplay();\n    }\n\n    function setCustomObject() {\n        currentOutput = { info: \"This is a custom object\", timestamp: new Date() };\n        updateDisplay();\n    }\n\n    function updateDisplay() {\n        document.getElementById('outputDisplay').textContent = JSON.stringify(currentOutput, null, 2);\n    }\n</script>\n\n</body>\n</html>"
