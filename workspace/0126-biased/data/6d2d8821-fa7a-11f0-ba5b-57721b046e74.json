  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Directed Graph</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            background: white;\n            color: black;\n        }\n        #graph-container {\n            border: 1px solid black;\n            width: 800px;\n            height: 500px;\n            position: relative;\n            margin-bottom: 20px;\n        }\n        .node {\n            position: absolute;\n            width: 30px;\n            height: 30px;\n            border: 1px solid black;\n            border-radius: 15px;\n            text-align: center;\n            line-height: 30px;\n            cursor: move;\n            background: white;\n        }\n        .edge {\n            position: absolute;\n            pointer-events: none;\n        }\n        .arrow {\n            position: absolute;\n            width: 0;\n            height: 0;\n            border-style: solid;\n            pointer-events: none;\n        }\n        .control-panel {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid black;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        textarea {\n            width: 300px;\n            height: 100px;\n        }\n        input, button {\n            margin: 5px;\n        }\n        #node-properties, #edge-properties {\n            display: none;\n            position: absolute;\n            background: white;\n            border: 1px solid black;\n            padding: 10px;\n            z-index: 100;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interactive Directed Graph</h1>\n    \n    <div class=\"control-panel\">\n        <div class=\"control-group\">\n            <h3>Graph Construction</h3>\n            <button id=\"add-node\">Add Node</button>\n            <button id=\"add-edge\">Add Edge</button>\n            <button id=\"delete-mode\">Delete Mode</button>\n            <button id=\"clear-graph\">Clear Graph</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Layout</h3>\n            <button id=\"random-layout\">Random Layout</button>\n            <button id=\"circle-layout\">Circle Layout</button>\n            <button id=\"force-layout\">Force Layout</button>\n            <div>\n                <label>Force Layout Parameters:</label>\n                <div>\n                    <label>Charge: <input type=\"range\" id=\"charge\" min=\"-1000\" max=\"-10\" value=\"-300\"></label>\n                </div>\n                <div>\n                    <label>Link Distance: <input type=\"range\" id=\"link-distance\" min=\"10\" max=\"200\" value=\"50\"></label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Graph Operations</h3>\n            <button id=\"find-path\">Find Path</button>\n            <button id=\"find-cycles\">Find Cycles</button>\n            <button id=\"topological-sort\">Topological Sort</button>\n            <div>\n                <label>Start Node: <input type=\"text\" id=\"start-node\" size=\"3\"></label>\n                <label>End Node: <input type=\"text\" id=\"end-node\" size=\"3\"></label>\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Import/Export</h3>\n            <textarea id=\"graph-json\" placeholder=\"Graph JSON will appear here\"></textarea>\n            <button id=\"import-graph\">Import Graph</button>\n            <button id=\"export-graph\">Export Graph</button>\n        </div>\n    </div>\n    \n    <div id=\"graph-container\"></div>\n    \n    <div id=\"node-properties\">\n        <h3>Node Properties</h3>\n        <label>ID: <input type=\"text\" id=\"node-id\" readonly></label>\n        <label>Label: <input type=\"text\" id=\"node-label\"></label>\n        <button id=\"update-node\">Update</button>\n        <button id=\"close-node-props\">Close</button>\n    </div>\n    \n    <div id=\"edge-properties\">\n        <h3>Edge Properties</h3>\n        <label>From: <input type=\"text\" id=\"edge-from\" readonly></label>\n        <label>To: <input type=\"text\" id=\"edge-to\" readonly></label>\n        <label>Weight: <input type=\"number\" id=\"edge-weight\" min=\"0\" step=\"0.1\" value=\"1\"></label>\n        <button id=\"update-edge\">Update</button>\n        <button id=\"close-edge-props\">Close</button>\n    </div>\n    \n    <div id=\"status-message\"></div>\n    \n    <script>\n        // Graph data structure\n        let graph = {\n            nodes: [],\n            edges: []\n        };\n        \n        // UI state\n        let selectedNode = null;\n        let edgeStartNode = null;\n        let deleteMode = false;\n        let forceLayoutActive = false;\n        let animationId = null;\n        \n        // DOM elements\n        const graphContainer = document.getElementById('graph-container');\n        const nodeProperties = document.getElementById('node-properties');\n        const edgeProperties = document.getElementById('edge-properties');\n        const statusMessage = document.getElementById('status-message');\n        \n        // Initialize the application\n        function init() {\n            // Add sample graph\n            addNode(100, 100, 'A');\n            addNode(200, 200, 'B');\n            addNode(300, 100, 'C');\n            addEdge('A', 'B');\n            addEdge('B', 'C');\n            addEdge('C', 'A');\n            \n            // Event listeners\n            document.getElementById('add-node').addEventListener('click', () => {\n                const x = Math.random() * (graphContainer.clientWidth - 40) + 20;\n                const y = Math.random() * (graphContainer.clientHeight - 40) + 20;\n                addNode(x, y, String.fromCharCode(65 + graph.nodes.length));\n            });\n            \n            document.getElementById('add-edge').addEventListener('click', () => {\n                if (edgeStartNode) {\n                    edgeStartNode = null;\n                    statusMessage.textContent = 'Edge creation canceled';\n                } else {\n                    statusMessage.textContent = 'Click on source node for new edge';\n                }\n            });\n            \n            document.getElementById('delete-mode').addEventListener('click', () => {\n                deleteMode = !deleteMode;\n                statusMessage.textContent = deleteMode ? 'Delete mode active - click nodes/edges to delete' : 'Delete mode deactivated';\n            });\n            \n            document.getElementById('clear-graph').addEventListener('click', () => {\n                graph = { nodes: [], edges: [] };\n                renderGraph();\n                statusMessage.textContent = 'Graph cleared';\n            });\n            \n            document.getElementById('random-layout').addEventListener('click', randomLayout);\n            document.getElementById('circle-layout').addEventListener('click', circleLayout);\n            document.getElementById('force-layout').addEventListener('click', toggleForceLayout);\n            \n            document.getElementById('charge').addEventListener('input', updateForceLayout);\n            document.getElementById('link-distance').addEventListener('input', updateForceLayout);\n            \n            document.getElementById('find-path').addEventListener('click', findPath);\n            document.getElementById('find-cycles').addEventListener('click', findCycles);\n            document.getElementById('topological-sort').addEventListener('click', topologicalSort);\n            \n            document.getElementById('import-graph').addEventListener('click', importGraph);\n            document.getElementById('export-graph').addEventListener('click', exportGraph);\n            \n            document.getElementById('update-node').addEventListener('click', updateNodeProperties);\n            document.getElementById('close-node-props').addEventListener('click', () => nodeProperties.style.display = 'none');\n            \n            document.getElementById('update-edge').addEventListener('click', updateEdgeProperties);\n            document.getElementById('close-edge-props').addEventListener('click', () => edgeProperties.style.display = 'none');\n            \n            // Initial render\n            renderGraph();\n        }\n        \n        // Graph manipulation functions\n        function addNode(x, y, label) {\n            const id = label || `N${graph.nodes.length + 1}`;\n            graph.nodes.push({ id, x, y, label: id });\n            renderGraph();\n            return id;\n        }\n        \n        function addEdge(from, to, weight = 1) {\n            if (from === to) return; // No self-loops\n            \n            // Check if edge already exists\n            const exists = graph.edges.some(e => e.from === from && e.to === to);\n            if (exists) return;\n            \n            graph.edges.push({ from, to, weight });\n            renderGraph();\n        }\n        \n        function removeNode(nodeId) {\n            graph.nodes = graph.nodes.filter(n => n.id !== nodeId);\n            graph.edges = graph.edges.filter(e => e.from !== nodeId && e.to !== nodeId);\n            renderGraph();\n        }\n        \n        function removeEdge(from, to) {\n            graph.edges = graph.edges.filter(e => !(e.from === from && e.to === to));\n            renderGraph();\n        }\n        \n        // Layout functions\n        function randomLayout() {\n            stopForceLayout();\n            graph.nodes.forEach(node => {\n                node.x = Math.random() * (graphContainer.clientWidth - 40) + 20;\n                node.y = Math.random() * (graphContainer.clientHeight - 40) + 20;\n            });\n            renderGraph();\n        }\n        \n        function circleLayout() {\n            stopForceLayout();\n            const centerX = graphContainer.clientWidth / 2;\n            const centerY = graphContainer.clientHeight / 2;\n            const radius = Math.min(centerX, centerY) - 50;\n            \n            graph.nodes.forEach((node, i) => {\n                const angle = (i * 2 * Math.PI) / graph.nodes.length;\n                node.x = centerX + radius * Math.cos(angle);\n                node.y = centerY + radius * Math.sin(angle);\n            });\n            renderGraph();\n        }\n        \n        function toggleForceLayout() {\n            if (forceLayoutActive) {\n                stopForceLayout();\n            } else {\n                startForceLayout();\n            }\n        }\n        \n        function startForceLayout() {\n            forceLayoutActive = true;\n            document.getElementById('force-layout').textContent = 'Stop Force Layout';\n            updateForceLayout();\n        }\n        \n        function stopForceLayout() {\n            forceLayoutActive = false;\n            if (animationId) {\n                cancelAnimationFrame(animationId);\n                animationId = null;\n            }\n            document.getElementById('force-layout').textContent = 'Force Layout';\n        }\n        \n        function updateForceLayout() {\n            if (!forceLayoutActive) return;\n            \n            const charge = parseInt(document.getElementById('charge').value);\n            const linkDistance = parseInt(document.getElementById('link-distance').value);\n            \n            // Simple force-directed layout simulation\n            const nodes = graph.nodes;\n            const edges = graph.edges;\n            \n            // Initialize velocities\n            nodes.forEach(node => {\n                if (!node.vx) node.vx = 0;\n                if (!node.vy) node.vy = 0;\n            });\n            \n            // Apply forces\n            const repulsion = (n1, n2) => {\n                const dx = n1.x - n2.x;\n                const dy = n1.y - n2.y;\n                const distance = Math.sqrt(dx * dx + dy * dy) || 0.1;\n                const force = charge / (distance * distance);\n                \n                n1.vx += (dx / distance) * force;\n                n1.vy += (dy / distance) * force;\n                n2.vx -= (dx / distance) * force;\n                n2.vy -= (dy / distance) * force;\n            };\n            \n            const attraction = (n1, n2) => {\n                const dx = n1.x - n2.x;\n                const dy = n1.y - n2.y;\n                const distance = Math.sqrt(dx * dx + dy * dy) || 0.1;\n                const force = (distance - linkDistance) * 0.1;\n                \n                n1.vx -= (dx / distance) * force;\n                n1.vy -= (dy / distance) * force;\n                n2.vx += (dx / distance) * force;\n                n2.vy += (dy / distance) * force;\n            };\n            \n            // Apply repulsion between all nodes\n            for (let i = 0; i < nodes.length; i++) {\n                for (let j = i + 1; j < nodes.length; j++) {\n                    repulsion(nodes[i], nodes[j]);\n                }\n            }\n            \n            // Apply attraction between connected nodes\n            edges.forEach(edge => {\n                const fromNode = nodes.find(n => n.id === edge.from);\n                const toNode = nodes.find(n => n.id === edge.to);\n                if (fromNode && toNode) {\n                    attraction(fromNode, toNode);\n                }\n            });\n            \n            // Update positions with damping\n            nodes.forEach(node => {\n                node.vx *= 0.9;\n                node.vy *= 0.9;\n                node.x += node.vx;\n                node.y += node.vy;\n                \n                // Boundary constraints\n                const padding = 20;\n                node.x = Math.max(padding, Math.min(graphContainer.clientWidth - padding, node.x));\n                node.y = Math.max(padding, Math.min(graphContainer.clientHeight - padding, node.y));\n            });\n            \n            renderGraph();\n            \n            if (forceLayoutActive) {\n                animationId = requestAnimationFrame(updateForceLayout);\n            }\n        }\n        \n        // Graph algorithms\n        function findPath() {\n            const from = document.getElementById('start-node').value;\n            const to = document.getElementById('end-node').value;\n            \n            if (!from || !to) {\n                statusMessage.textContent = 'Please specify both start and end nodes';\n                return;\n            }\n            \n            if (from === to) {\n                statusMessage.textContent = 'Start and end nodes are the same';\n                return;\n            }\n            \n            // Simple BFS path finding\n            const visited = new Set();\n            const queue = [[from, [from]]];\n            \n            while (queue.length > 0) {\n                const [current, path] = queue.shift();\n                \n                if (current === to) {\n                    highlightPath(path);\n                    statusMessage.textContent = `Path found: ${path.join(' → ')}`;\n                    return;\n                }\n                \n                if (!visited.has(current)) {\n                    visited.add(current);\n                    \n                    const neighbors = graph.edges\n                        .filter(e => e.from === current)\n                        .map(e => e.to);\n                    \n                    for (const neighbor of neighbors) {\n                        if (!visited.has(neighbor)) {\n                            queue.push([neighbor, [...path, neighbor]]);\n                        }\n                    }\n                }\n            }\n            \n            statusMessage.textContent = 'No path found between the specified nodes';\n        }\n        \n        function findCycles() {\n            // Simple cycle detection using DFS\n            const visited = new Set();\n            const recursionStack = new Set();\n            const cycles = [];\n            \n            function dfs(node, path) {\n                if (recursionStack.has(node)) {\n                    // Found a cycle\n                    const cycleStart = path.indexOf(node);\n                    if (cycleStart !== -1) {\n                        const cycle = path.slice(cycleStart);\n                        cycles.push([...cycle, node]);\n                    }\n                    return;\n                }\n                \n                if (visited.has(node)) return;\n                \n                visited.add(node);\n                recursionStack.add(node);\n                \n                const neighbors = graph.edges\n                    .filter(e => e.from === node)\n                    .map(e => e.to);\n                \n                for (const neighbor of neighbors) {\n                    dfs(neighbor, [...path, node]);\n                }\n                \n                recursionStack.delete(node);\n            }\n            \n            graph.nodes.forEach(node => {\n                if (!visited.has(node.id)) {\n                    dfs(node.id, []);\n                }\n            });\n            \n            if (cycles.length > 0) {\n                // Highlight the first cycle found\n                highlightPath(cycles[0]);\n                statusMessage.textContent = `Found ${cycles.length} cycle(s). First cycle: ${cycles[0].join(' → ')}`;\n            } else {\n                statusMessage.textContent = 'No cycles found in the graph';\n            }\n        }\n        \n        function topologicalSort() {\n            // Kahn's algorithm for topological sort\n            const inDegree = {};\n            const queue = [];\n            const result = [];\n            \n            // Initialize in-degree\n            graph.nodes.forEach(node => inDegree[node.id] = 0);\n            graph.edges.forEach(edge => inDegree[edge.to]++);\n            \n            // Find nodes with zero in-degree\n            for (const nodeId in inDegree) {\n                if (inDegree[nodeId] === 0) {\n                    queue.push(nodeId);\n                }\n            }\n            \n            let count = 0;\n            \n            while (queue.length > 0) {\n                const u = queue.shift();\n                result.push(u);\n                \n                // Decrease in-degree for all neighbors\n                graph.edges\n                    .filter(e => e.from === u)\n                    .forEach(e => {\n                        inDegree[e.to]--;\n                        if (inDegree[e.to] === 0) {\n                            queue.push(e.to);\n                        }\n                    });\n                \n                count++;\n            }\n            \n            if (count !== graph.nodes.length) {\n                statusMessage.textContent = 'Graph has at least one cycle - topological sort not possible';\n            } else {\n                statusMessage.textContent = `Topological order: ${result.join(' → ')}`;\n            }\n        }\n        \n        function highlightPath(nodeIds) {\n            // Reset all highlights\n            document.querySelectorAll('.node').forEach(el => {\n                el.style.border = '1px solid black';\n            });\n            \n            document.querySelectorAll('.edge').forEach(el => {\n                el.style.stroke = 'black';\n            });\n            \n            // Highlight nodes in path\n            nodeIds.forEach(id => {\n                const nodeEl = document.querySelector(`.node[data-id=\"${id}\"]`);\n                if (nodeEl) nodeEl.style.border = '2px solid red';\n            });\n            \n            // Highlight edges in path\n            for (let i = 0; i < nodeIds.length - 1; i++) {\n                const from = nodeIds[i];\n                const to = nodeIds[i + 1];\n                \n                const edgeEl = document.querySelector(`.edge[data-from=\"${from}\"][data-to=\"${to}\"]`);\n                if (edgeEl) edgeEl.style.stroke = 'red';\n            }\n        }\n        \n        // Import/export\n        function exportGraph() {\n            document.getElementById('graph-json').value = JSON.stringify(graph, null, 2);\n            statusMessage.textContent = 'Graph exported to JSON';\n        }\n        \n        function importGraph() {\n            try {\n                const json = document.getElementById('graph-json').value;\n                const newGraph = JSON.parse(json);\n                \n                if (!newGraph.nodes || !newGraph.edges) {\n                    throw new Error('Invalid graph format');\n                }\n                \n                graph = newGraph;\n                renderGraph();\n                statusMessage.textContent = 'Graph imported successfully';\n            } catch (e) {\n                statusMessage.textContent = 'Error importing graph: ' + e.message;\n            }\n        }\n        \n        // Node/edge properties\n        function showNodeProperties(node) {\n            document.getElementById('node-id').value = node.id;\n            document.getElementById('node-label').value = node.label || node.id;\n            nodeProperties.style.display = 'block';\n            nodeProperties.style.left = `${node.x + 40}px`;\n            nodeProperties.style.top = `${node.y}px`;\n        }\n        \n        function updateNodeProperties() {\n            const id = document.getElementById('node-id').value;\n            const label = document.getElementById('node-label').value;\n            \n            const node = graph.nodes.find(n => n.id === id);\n            if (node) {\n                node.label = label;\n                renderGraph();\n            }\n            \n            nodeProperties.style.display = 'none';\n        }\n        \n        function showEdgeProperties(edge) {\n            document.getElementById('edge-from').value = edge.from;\n            document.getElementById('edge-to').value = edge.to;\n            document.getElementById('edge-weight').value = edge.weight || 1;\n            \n            const fromNode = graph.nodes.find(n => n.id === edge.from);\n            const toNode = graph.nodes.find(n => n.id === edge.to);\n            \n            if (fromNode && toNode) {\n                const x = (fromNode.x + toNode.x) / 2;\n                const y = (fromNode.y + toNode.y) / 2;\n                edgeProperties.style.display = 'block';\n                edgeProperties.style.left = `${x}px`;\n                edgeProperties.style.top = `${y}px`;\n            }\n        }\n        \n        function updateEdgeProperties() {\n            const from = document.getElementById('edge-from').value;\n            const to = document.getElementById('edge-to').value;\n            const weight = parseFloat(document.getElementById('edge-weight').value);\n            \n            const edge = graph.edges.find(e => e.from === from && e.to === to);\n            if (edge) {\n                edge.weight = weight;\n                renderGraph();\n            }\n            \n            edgeProperties.style.display = 'none';\n        }\n        \n        // Rendering\n        function renderGraph() {\n            // Clear container\n            graphContainer.innerHTML = '';\n            \n            // Draw edges first (under nodes)\n            graph.edges.forEach(edge => {\n                const fromNode = graph.nodes.find(n => n.id === edge.from);\n                const toNode = graph.nodes.find(n => n.id === edge.to);\n                \n                if (fromNode && toNode) {\n                    // Calculate edge path\n                    const dx = toNode.x - fromNode.x;\n                    const dy = toNode.y - fromNode.y;\n                    const angle = Math.atan2(dy, dx);\n                    const dist = Math.sqrt(dx * dx + dy * dy);\n                    \n                    // Adjust start/end points to node boundaries\n                    const startX = fromNode.x + 15 * Math.cos(angle);\n                    const startY = fromNode.y + 15 * Math.sin(angle);\n                    const endX = toNode.x - 15 * Math.cos(angle);\n                    const endY = toNode.y - 15 * Math.sin(angle);\n                    \n                    // Create edge line\n                    const edgeEl = document.createElement('div');\n                    edgeEl.className = 'edge';\n                    edgeEl.setAttribute('data-from', edge.from);\n                    edgeEl.setAttribute('data-to', edge.to);\n                    \n                    // Position and style the edge\n                    edgeEl.style.left = `${startX}px`;\n                    edgeEl.style.top = `${startY}px`;\n                    edgeEl.style.width = `${dist - 30}px`;\n                    edgeEl.style.height = '1px';\n                    edgeEl.style.transformOrigin = '0 0';\n                    edgeEl.style.transform = `rotate(${angle}rad)`;\n                    edgeEl.style.borderTop = '1px solid black';\n                    \n                    // Create arrowhead\n                    const arrowEl = document.createElement('div');\n                    arrowEl.className = 'arrow';\n                    arrowEl.style.left = `${endX}px`;\n                    arrowEl.style.top = `${endY}px`;\n                    arrowEl.style.borderWidth = '0 5px 10px 5px';\n                    arrowEl.style.borderColor = `transparent transparent black transparent`;\n                    arrowEl.style.transform = `rotate(${angle + Math.PI/2}rad)`;\n                    \n                    // Add weight label if not 1\n                    if (edge.weight !== 1) {\n                        const labelEl = document.createElement('div');\n                        labelEl.textContent = edge.weight;\n                        labelEl.style.position = 'absolute';\n                        labelEl.style.left = `${(startX + endX) / 2}px`;\n                        labelEl.style.top = `${(startY + endY) / 2}px`;\n                        labelEl.style.transform = 'translate(-50%, -50%)';\n                        graphContainer.appendChild(labelEl);\n                    }\n                    \n                    graphContainer.appendChild(edgeEl);\n                    graphContainer.appendChild(arrowEl);\n                    \n                    // Add click handler for edge\n                    edgeEl.addEventListener('click', (e) => {\n                        e.stopPropagation();\n                        if (deleteMode) {\n                            removeEdge(edge.from, edge.to);\n                        } else {\n                            showEdgeProperties(edge);\n                        }\n                    });\n                }\n            });\n            \n            // Draw nodes\n            graph.nodes.forEach(node => {\n                const nodeEl = document.createElement('div');\n                nodeEl.className = 'node';\n                nodeEl.setAttribute('data-id', node.id);\n                nodeEl.textContent = node.label || node.id;\n                nodeEl.style.left = `${node.x - 15}px`;\n                nodeEl.style.top = `${node.y - 15}px`;\n                \n                // Make nodes draggable\n                let isDragging = false;\n                let offsetX, offsetY;\n                \n                nodeEl.addEventListener('mousedown', (e) => {\n                    if (deleteMode) {\n                        removeNode(node.id);\n                        return;\n                    }\n                    \n                    if (edgeStartNode === null) {\n                        // Start dragging\n                        isDragging = true;\n                        offsetX = e.clientX - node.x;\n                        offsetY = e.clientY - node.y;\n                        e.preventDefault(); // Prevent text selection\n                    } else if (edgeStartNode !== node.id) {\n                        // Complete edge creation\n                        addEdge(edgeStartNode, node.id);\n                        edgeStartNode = null;\n                    }\n                });\n                \n                document.addEventListener('mousemove', (e) => {\n                    if (isDragging) {\n                        node.x = e.clientX - offsetX;\n                        node.y = e.clientY - offsetY;\n                        renderGraph();\n                    }\n                });\n                \n                document.addEventListener('mouseup', () => {\n                    isDragging = false;\n                });\n                \n                nodeEl.addEventListener('click', (e) => {\n                    if (deleteMode) return;\n                    \n                    if (edgeStartNode === null) {\n                        // Show node properties\n                        showNodeProperties(node);\n                    } else if (edgeStartNode === node.id) {\n                        // Cancel edge creation\n                        edgeStartNode = null;\n                        statusMessage.textContent = 'Edge creation canceled';\n                    } else {\n                        // Start edge creation\n                        edgeStartNode = node.id;\n                        statusMessage.textContent = `Creating edge from ${node.id} - click target node`;\n                    }\n                });\n                \n                graphContainer.appendChild(nodeEl);\n            });\n        }\n        \n        // Initialize the application\n        init();\n    </script>\n</body>\n</html>"
  },
