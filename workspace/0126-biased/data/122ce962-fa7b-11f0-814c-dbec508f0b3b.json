    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Virtual Memory</title>\n    <style>\n        body {\n            background-color: #000;\n        }\n        #container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #000;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.2);\n        }\n        #controls {\n            margin-bottom: 20px;\n        }\n        #controls button, #controls input {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #000;\n            color: #fff;\n            cursor: pointer;\n        }\n        #controls input[type=\"text\"] {\n            padding: 10px 20px;\n            border: 1px solid #000;\n            border-radius: 5px;\n            width: 50%;\n        }\n        #controls button:hover, #controls input[type=\"text\"]:hover {\n            background-color: #000;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <h1>Virtual Memory</h1>\n        <div id=\"controls\">\n            <button id=\"clear-btn\">Clear</button>\n            <input id=\"input-field\" type=\"text\" placeholder=\"Enter text to clear\">\n            <button id=\"write-btn\">Write</button>\n            <input id=\"write-input\" type=\"text\" placeholder=\"Enter text to write\">\n            <button id=\"read-btn\">Read</button>\n            <input id=\"read-input\" type=\"text\" placeholder=\"Enter text to read\">\n            <button id=\"delete-btn\">Delete</button>\n        </div>\n        <div id=\"output\"></div>\n    </div>\n\n    <script>\n        let inputField = document.getElementById('input-field');\n        let outputDiv = document.getElementById('output');\n        let clearBtn = document.getElementById('clear-btn');\n        let writeBtn = document.getElementById('write-btn');\n        let readBtn = document.getElementById('read-btn');\n        let deleteBtn = document.getElementById('delete-btn');\n        let writeInput = document.getElementById('write-input');\n        let readInput = document.getElementById('read-input');\n\n        let clear = function() {\n            outputDiv.innerText = '';\n        }\n\n        let write = function() {\n            let text = writeInput.value;\n            outputDiv.innerText = text;\n        }\n\n        let read = function() {\n            let text = readInput.value;\n            outputDiv.innerText = text;\n        }\n\n        let delete = function() {\n            outputDiv.innerText = '';\n        }\n\n        clearBtn.addEventListener('click', clear);\n        writeBtn.addEventListener('click', write);\n        readBtn.addEventListener('click', read);\n        deleteBtn.addEventListener('click', delete);\n\n        inputField.addEventListener('input', function() {\n            writeInput.value = inputField.value;\n        });\n\n        writeInput.addEventListener('input', function() {\n            write();\n        });\n\n        readInput.addEventListener('input', function() {\n            read();\n        });\n\n        writeBtn.addEventListener('click', function() {\n            write();\n        });\n\n        readBtn.addEventListener('click', function() {\n            read();\n        });\n\n        deleteBtn.addEventListener('click', function() {\n            clear();\n        });\n    </script>\n</body>\n</html>"
