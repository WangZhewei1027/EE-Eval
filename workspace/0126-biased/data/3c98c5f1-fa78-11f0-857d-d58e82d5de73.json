    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Time Complexity — A Visual Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;600&display=swap');\n\n  /* Root colors for a professional dark palette */\n  :root {\n    --color-bg: #0f172a;\n    --color-primary: #38bdf8; /* sky blue */\n    --color-secondary: #818cf8; /* indigo */\n    --color-accent: #facc15; /* amber */\n    --color-text-primary: #e0e7ff;\n    --color-text-secondary: #a5b4fc;\n    --color-shadow: rgba(24, 71, 146, 0.25);\n    --font-sans: 'Inter', sans-serif;\n  }\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n    margin: 0;\n    padding: 0;\n  }\n  html, body {\n    height: 100%;\n    background: var(--color-bg);\n    color: var(--color-text-primary);\n    font-family: var(--font-sans);\n    overflow-x: hidden;\n  }\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 3rem 1rem 5rem;\n    min-height: 100vh;\n  }\n\n  /* Header */\n  header {\n    text-align: center;\n    margin-bottom: 3rem;\n  }\n  header h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    color: var(--color-primary);\n    letter-spacing: 0.05em;\n    line-height: 1.1;\n    text-shadow:\n      0 0 8px #38bdf8cc,\n      0 0 20px #38bdf8bb;\n    user-select: none;\n  }\n  header p {\n    margin-top: 0.6rem;\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: var(--color-text-secondary);\n    letter-spacing: 0.03em;\n  }\n\n  /* Container for main content */\n  main {\n    width: 100%;\n    max-width: 900px;\n    background: linear-gradient(180deg, #1e293bdd 0%, #0f172aee 100%);\n    border-radius: 2rem;\n    box-shadow:\n      0 0 30px var(--color-primary),\n      inset 0 0 15px #081029;\n    backdrop-filter: blur(18px);\n    padding: 3rem 4rem 5rem;\n    position: relative;\n    overflow: visible;\n  }\n\n  /* TIME COMPLEXITY GRAPH */\n  .graph-container {\n    position: relative;\n    height: 380px;\n    margin-top: 1rem;\n  }\n\n  /* Axis lines */\n  .axis {\n    position: absolute;\n    background: var(--color-text-secondary);\n    opacity: 0.2;\n    filter: drop-shadow(1px 1px 1px #0005);\n    user-select: none;\n  }\n  .axis-x {\n    bottom: 48px;\n    left: 48px;\n    right: 48px;\n    height: 2px;\n    border-radius: 1px;\n  }\n  .axis-y {\n    top: 48px;\n    bottom: 80px;\n    left: 48px;\n    width: 2px;\n    border-radius: 1px;\n  }\n\n  /* Axis labels */\n  .labels-x, .labels-y {\n    position: absolute;\n    font-weight: 600;\n    font-size: 0.9rem;\n    letter-spacing: 0.05em;\n    color: var(--color-text-secondary);\n    user-select: none;\n  }\n  .labels-x {\n    bottom: 18px;\n    left: 48px;\n    right: 48px;\n    display: flex;\n    justify-content: space-between;\n    padding: 0 2px;\n  }\n  .labels-y {\n    top: 48px;\n    bottom: 80px;\n    left: 6px;\n    writing-mode: vertical-rl;\n    text-orientation: mixed;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    gap: 3rem;\n  }\n  .labels-y span {\n    transform: translateX(2px);\n    opacity: 0.8;\n  }\n\n  /* Curves container */\n  .curves {\n    position: absolute;\n    top: 48px;\n    left: 48px;\n    right: 48px;\n    bottom: 80px;\n    pointer-events: none;\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n  }\n\n  /* Curve styles */\n  .curve-path {\n    fill: none;\n    stroke-width: 3.5;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    transition: stroke-dashoffset 1.3s cubic-bezier(0.23, 1, 0.32, 1);\n  }\n  .curve-constant {\n    stroke: var(--color-secondary);\n    stroke-dasharray: 720;\n    stroke-dashoffset: 720;\n    filter: drop-shadow(0 0 10px #818cf8cc);\n  }\n  .curve-log {\n    stroke: var(--color-primary);\n    stroke-dasharray: 720;\n    stroke-dashoffset: 720;\n    filter: drop-shadow(0 0 12px #38bdf8cc);\n  }\n  .curve-linear {\n    stroke: var(--color-accent);\n    stroke-dasharray: 720;\n    stroke-dashoffset: 720;\n    filter: drop-shadow(0 0 14px #facc1588);\n  }\n  .curve-nlogn {\n    stroke: #f97316; /* orange-500 */\n    stroke-dasharray: 720;\n    stroke-dashoffset: 720;\n    filter: drop-shadow(0 0 14px #f9731688);\n  }\n  .curve-quadratic {\n    stroke: #ef4444; /* red-500 */\n    stroke-dasharray: 720;\n    stroke-dashoffset: 720;\n    filter: drop-shadow(0 0 14px #ef444488);\n  }\n  .curve-exponential {\n    stroke: #db2777; /* pink-600 */\n    stroke-dasharray: 720;\n    stroke-dashoffset: 720;\n    filter: drop-shadow(0 0 18px #db277788);\n  }\n\n  /* Labels for curves */\n  .legend {\n    margin-top: 3rem;\n    display: grid;\n    grid-template-columns: repeat(auto-fit,minmax(140px,1fr));\n    gap: 0.8rem 2rem;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 0.6rem;\n    user-select: none;\n    color: var(--color-text-secondary);\n    font-weight: 600;\n    font-size: 1rem;\n    opacity: 0.9;\n    transition: color 0.3s ease;\n  }\n  .legend-color {\n    width: 24px;\n    height: 10px;\n    border-radius: 4px;\n    box-shadow: 0 0 8px;\n  }\n  .legend-constant {\n    background: var(--color-secondary);\n    box-shadow: 0 0 10px #818cf8cc;\n  }\n  .legend-log {\n    background: var(--color-primary);\n    box-shadow: 0 0 12px #38bdf8cc;\n  }\n  .legend-linear {\n    background: var(--color-accent);\n    box-shadow: 0 0 14px #facc1588;\n  }\n  .legend-nlogn {\n    background: #f97316;\n    box-shadow: 0 0 14px #f9731688;\n  }\n  .legend-quadratic {\n    background: #ef4444;\n    box-shadow: 0 0 14px #ef444488;\n  }\n  .legend-exponential {\n    background: #db2777;\n    box-shadow: 0 0 18px #db277788;\n  }\n\n  /* Button container */\n  .controls {\n    margin-top: 3rem;\n    text-align: center;\n  }\n  button {\n    background: var(--color-primary);\n    border: none;\n    outline: none;\n    cursor: pointer;\n    color: var(--color-bg);\n    font-weight: 600;\n    font-size: 1.1rem;\n    padding: 0.65rem 2rem;\n    border-radius: 1.2rem;\n    box-shadow:\n      0 0 12px var(--color-primary);\n    transition:\n      background-color 0.3s ease,\n      box-shadow 0.3s ease,\n      transform 0.2s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: var(--color-accent);\n    box-shadow:\n      0 0 20px var(--color-accent);\n    transform: scale(1.05);\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 4rem;\n    font-size: 0.85rem;\n    color: var(--color-text-secondary);\n    user-select: none;\n    font-style: italic;\n  }\n\n  /* Subtle background animation behind main */\n  body::before {\n    content: \"\";\n    position: fixed;\n    top: -50vh;\n    left: -50vw;\n    width: 200vw;\n    height: 200vh;\n    background:\n      radial-gradient(circle at 30% 40%, #38bdf8aa, transparent 60%),\n      radial-gradient(circle at 70% 70%, #facc15aa, transparent 50%),\n      radial-gradient(circle at 50% 35%, #818cf8aa, transparent 70%);\n    animation: bgFloat 30s ease-in-out infinite alternate;\n    z-index: -1;\n    filter: blur(70px);\n  }\n  @keyframes bgFloat {\n    0% {\n      transform: translate(0, 0) scale(1);\n      opacity: 0.6;\n    }\n    100% {\n      transform: translate(40px, -45px) scale(1.1);\n      opacity: 0.85;\n    }\n  }\n\n  /* Responsive typography */\n  @media (max-width: 600px){\n    header h1 {\n      font-size: 2.25rem;\n    }\n    main {\n      padding: 2rem 2rem 4rem;\n    }\n    .legend {\n      gap: 0.4rem 1rem;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Time Complexity</h1>\n  <p>Visualizing the landscape of algorithmic growth</p>\n</header>\n<main>\n  <div class=\"graph-container\" role=\"img\" aria-label=\"Graph showing different time complexity curves\">\n    <div class=\"axis axis-x\"></div>\n    <div class=\"axis axis-y\"></div>\n    <div class=\"labels-y\" aria-hidden=\"true\">\n      <span>1000</span>\n      <span>100</span>\n      <span>10</span>\n      <span>1</span>\n    </div>\n    <div class=\"labels-x\" aria-hidden=\"true\">\n      <span>1</span>\n      <span>10</span>\n      <span>20</span>\n      <span>30</span>\n      <span>40</span>\n      <span>50</span>\n      <span>60</span>\n      <span>70</span>\n      <span>80</span>\n      <span>90</span>\n      <span>100</span>\n    </div>\n    <div class=\"curves\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 110 110\" preserveAspectRatio=\"none\" aria-hidden=\"true\" >\n        <!-- Constant O(1) -->\n        <path class=\"curve-path curve-constant\" d=\"M5 100 L105 100\" />\n        <!-- Logarithmic O(log n) -->\n        <path class=\"curve-path curve-log\" d=\"M5 98 Q30 95 55 90 Q80 85 105 80\" />\n        <!-- Linear O(n) -->\n        <path class=\"curve-path curve-linear\" d=\"M5 95 L105 15\" />\n        <!-- Linearithmic O(n log n) -->\n        <path class=\"curve-path curve-nlogn\" d=\"M5 92 Q45 60 85 35 L105 28\" />\n        <!-- Quadratic O(n²) -->\n        <path class=\"curve-path curve-quadratic\" d=\"M5 95 C40 80 75 50 105 5\" />\n        <!-- Exponential O(2ⁿ) -->\n        <path class=\"curve-path curve-exponential\" d=\"M5 95 C40 30 70 10 105 1\" />\n      </svg>\n    </div>\n  </div>\n  <section class=\"legend\" aria-label=\"Legend describing time complexity curves\">\n    <div class=\"legend-item\"><div class=\"legend-color legend-constant\"></div>Constant O(1)</div>\n    <div class=\"legend-item\"><div class=\"legend-color legend-log\"></div>Logarithmic O(log n)</div>\n    <div class=\"legend-item\"><div class=\"legend-color legend-linear\"></div>Linear O(n)</div>\n    <div class=\"legend-item\"><div class=\"legend-color legend-nlogn\"></div>Linearithmic O(n log n)</div>\n    <div class=\"legend-item\"><div class=\"legend-color legend-quadratic\"></div>Quadratic O(n²)</div>\n    <div class=\"legend-item\"><div class=\"legend-color legend-exponential\"></div>Exponential O(2ⁿ)</div>\n  </section>\n  <div class=\"controls\" aria-label=\"Controls for animating the time complexity curves\">\n    <button id=\"animateBtn\" aria-pressed=\"false\" aria-label=\"Animate Time Complexity Curves\">Animate Curves</button>\n  </div>\n</main>\n<footer>\n  &mdash; The Beauty of Algorithms &mdash;\n</footer>\n<script>\n  (() => {\n    const btn = document.getElementById('animateBtn');\n    const curves = document.querySelectorAll('.curve-path');\n    let animated = false;\n    let animationTimeout;\n\n    // Reset all curves to hidden offset\n    function resetCurves() {\n      curves.forEach(curve => {\n        curve.style.transition = 'none';\n        curve.style.strokeDashoffset = getComputedStyle(curve).strokeDasharray;\n      });\n      // Force reflow to apply styles immediately without transition\n      void btn.offsetWidth;\n      curves.forEach(curve => {\n        curve.style.transition = 'stroke-dashoffset 1.3s cubic-bezier(0.23, 1, 0.32, 1)';\n      });\n    }\n\n    // Animate curves drawing in a staggered manner\n    function animateCurves() {\n      curves.forEach((curve, i) => {\n        setTimeout(() => {\n          curve.style.strokeDashoffset = '0';\n        }, i * 180);\n      });\n    }\n\n    btn.addEventListener('click', () => {\n      if (animated) {\n        // Reverse animation (hide curves)\n        curves.forEach((curve, i) => {\n          setTimeout(() => {\n            curve.style.strokeDashoffset = getComputedStyle(curve).strokeDasharray;\n          }, i * 140);\n        });\n        btn.textContent = \"Animate Curves\";\n        btn.setAttribute('aria-pressed', 'false');\n      } else {\n        animateCurves();\n        btn.textContent = \"Reset Animation\";\n        btn.setAttribute('aria-pressed', 'true');\n      }\n      animated = !animated;\n      clearTimeout(animationTimeout);\n      animationTimeout = setTimeout(() => {\n        animated = false;\n        btn.textContent = \"Animate Curves\";\n        btn.setAttribute('aria-pressed', 'false');\n        resetCurves();\n      }, 12000);\n    });\n\n    // On page load, reset curves to hidden state\n    window.addEventListener('load', () => {\n      resetCurves();\n    });\n  })();\n</script>\n</body>\n</html>"
