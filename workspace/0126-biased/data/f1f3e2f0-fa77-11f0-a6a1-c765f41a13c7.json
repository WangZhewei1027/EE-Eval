    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Array — A Visual Exploration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Space+Grotesk:wght@400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #081229;\n      --bg-2: #071226;\n      --glass: rgba(255,255,255,0.06);\n      --accent: #7C5CFF;\n      --accent-2: #00E0C6;\n      --muted: rgba(255,255,255,0.12);\n      --glass-2: rgba(255,255,255,0.03);\n      --card-radius: 18px;\n      --cell-size: 110px;\n      --shadow: 0 10px 30px rgba(2,6,23,0.6);\n      --neon: 0 0 30px rgba(124,92,255,0.22);\n    }\n\n    *{box-sizing:border-box}\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.08), transparent 10%),\n                  radial-gradient(700px 500px at 90% 90%, rgba(0,224,198,0.04), transparent 10%),\n                  linear-gradient(180deg, var(--bg-1), var(--bg-2));\n      color: #EAF0FF;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Decorative floating blobs */\n    .blobs{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n      mix-blend-mode:screen;\n    }\n    .blob{\n      position:absolute;\n      filter: blur(40px) saturate(120%);\n      opacity:0.9;\n      transform: translate3d(0,0,0);\n      will-change: transform, opacity;\n      animation: float 8s ease-in-out infinite;\n    }\n    .blob.b1{width:520px;height:520px;left:-120px;top:-80px;background:linear-gradient(135deg,#7C5CFF,#5A8BFF); animation-duration:10s;}\n    .blob.b2{width:420px;height:420px;right:-100px;bottom:-100px;background:linear-gradient(135deg,#00E0C6,#7C5CFF); animation-duration:12s; animation-delay:2s;}\n    .blob.b3{width:260px;height:260px;left:20%;bottom:10%;background:linear-gradient(135deg,#5A8BFF,#00E0C6); animation-duration:9s; animation-delay:1.5s; opacity:0.18;}\n\n    @keyframes float{\n      0%{transform:translateY(0px) rotate(0deg)}\n      50%{transform:translateY(18px) rotate(6deg)}\n      100%{transform:translateY(0px) rotate(0deg)}\n    }\n\n    /* Main layout */\n    .wrap{\n      position:relative;\n      z-index:2;\n      min-height:100vh;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n    }\n\n    .panel{\n      width:1100px;\n      max-width:calc(100% - 96px);\n      border-radius:24px;\n      padding:40px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: var(--shadow);\n      backdrop-filter: blur(10px) saturate(120%);\n      border: 1px solid rgba(255,255,255,0.03);\n      position:relative;\n      overflow:visible;\n    }\n\n    .heading{\n      display:flex;\n      align-items:baseline;\n      gap:20px;\n      margin-bottom:22px;\n    }\n\n    .title{\n      font-family: 'Space Grotesk', sans-serif;\n      font-size:44px;\n      font-weight:600;\n      letter-spacing:-1px;\n      color: #FFF;\n      margin:0;\n      line-height:1;\n      text-shadow: 0 6px 30px rgba(124,92,255,0.12);\n    }\n\n    .sub{\n      color:var(--muted);\n      font-size:14px;\n      padding:6px 10px;\n      border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.02);\n      margin-left:auto;\n      display:inline-flex;\n    }\n\n    .desc{\n      color: rgba(234,240,255,0.85);\n      margin:0 0 28px 0;\n      font-size:15px;\n      max-width:780px;\n      line-height:1.6;\n      opacity:0.95;\n    }\n\n    /* Array visualization */\n    .array-scene{\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      gap:32px;\n      padding:28px;\n      border-radius:16px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border: 1px solid rgba(255,255,255,0.02);\n      box-shadow: 0 6px 22px rgba(3,8,25,0.45);\n    }\n\n    .memory-rail{\n      position:relative;\n      padding:28px 28px 40px 28px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.005));\n      display:flex;\n      gap:18px;\n      align-items:center;\n      justify-content:center;\n      flex-wrap:nowrap;\n      overflow:visible;\n    }\n\n    .cell{\n      width:var(--cell-size);\n      height:var(--cell-size);\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      flex-direction:column;\n      color:#fff;\n      position:relative;\n      transform-style:preserve-3d;\n      transition: transform 420ms cubic-bezier(.2,.9,.25,1), box-shadow 320ms, opacity 300ms;\n      box-shadow: 0 10px 20px rgba(3,8,25,0.55);\n      border: 1px solid rgba(255,255,255,0.03);\n      cursor:default;\n      overflow:visible;\n      will-change: transform, box-shadow;\n    }\n\n    .cell::before{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      border-radius:inherit;\n      background: linear-gradient(135deg, rgba(124,92,255,0.06), rgba(0,224,198,0.03));\n      opacity:0;\n      transition:opacity 300ms;\n      pointer-events:none;\n    }\n\n    .cell .value{\n      font-weight:700;\n      font-size:22px;\n      letter-spacing:0.6px;\n      text-shadow: 0 6px 20px rgba(0,0,0,0.6);\n      transform: translateZ(20px);\n    }\n\n    .cell .index{\n      font-size:12px;\n      color: rgba(255,255,255,0.65);\n      margin-top:8px;\n      transform: translateZ(18px);\n    }\n\n    .cell.highlight{\n      transform: translateY(-16px) scale(1.06);\n      box-shadow: 0 28px 60px rgba(124,92,255,0.12);\n    }\n    .cell.highlight::before{ opacity:1; }\n\n    .cell.dim{\n      opacity:0.35;\n      transform: scale(0.98);\n      box-shadow: none;\n    }\n\n    /* pointer / accessor */\n    .pointer{\n      position:absolute;\n      top:-48px;\n      width:54px;\n      height:54px;\n      border-radius:50%;\n      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.18), rgba(255,255,255,0.04));\n      border: 2px solid rgba(255,255,255,0.06);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color:var(--accent);\n      font-weight:700;\n      font-size:13px;\n      transform: translate3d(0,0,0);\n      transition: transform 420ms cubic-bezier(.2,.9,.25,1), opacity 260ms;\n      box-shadow: var(--neon);\n      backdrop-filter: blur(6px);\n      z-index:6;\n      pointer-events:none;\n      opacity:0;\n    }\n\n    .pointer .stem{\n      position:absolute;\n      bottom:-14px;\n      left:50%;\n      transform:translateX(-50%);\n      width:2px;\n      height:14px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.15), rgba(255,255,255,0.02));\n      border-radius:2px;\n      box-shadow: 0 6px 20px rgba(0,0,0,0.6);\n    }\n\n    .pointer.visible{opacity:1}\n\n    /* index rail below with addresses */\n    .index-rail{\n      display:flex;\n      gap:18px;\n      justify-content:center;\n      margin-top:18px;\n      pointer-events:none;\n    }\n    .addr{\n      width:var(--cell-size);\n      height:44px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-size:12px;\n      color:rgba(255,255,255,0.55);\n      border-radius:12px;\n      border:1px dashed rgba(255,255,255,0.03);\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      transition: background 260ms, color 260ms;\n    }\n    .addr.active{ color:var(--accent); border-style:solid; background:linear-gradient(180deg, rgba(124,92,255,0.06), rgba(124,92,255,0.02)); }\n\n    /* info card */\n    .info{\n      margin-left:32px;\n      width:320px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:18px;\n      border-radius:14px;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 10px 30px rgba(2,6,23,0.55);\n    }\n    .info h4{\n      margin:0 0 8px 0;\n      font-size:16px;\n      color:#FFF;\n      font-weight:600;\n    }\n    .info p{\n      margin:0;\n      font-size:13px;\n      color:rgba(255,255,255,0.78);\n      line-height:1.6;\n    }\n    .stat{\n      display:flex;\n      gap:12px;\n      margin-top:14px;\n    }\n    .stat .k{\n      flex:1;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border-radius:12px;\n      padding:10px;\n      text-align:center;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .stat .k .v{font-weight:700; font-size:18px; color:#FFF}\n    .stat .k .t{font-size:12px; color:rgba(255,255,255,0.68)}\n\n    /* Controls */\n    .controls{\n      display:flex;\n      gap:12px;\n      margin-top:20px;\n      justify-content:flex-end;\n      align-items:center;\n    }\n    .btn{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:#FFF;\n      border:1px solid rgba(255,255,255,0.04);\n      padding:10px 14px;\n      border-radius:12px;\n      font-weight:600;\n      cursor:pointer;\n      transition: transform 180ms, box-shadow 180ms, opacity 200ms;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      font-size:13px;\n      backdrop-filter: blur(6px);\n    }\n    .btn:hover{ transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.45); }\n    .btn:active{ transform: translateY(-2px); }\n\n    .btn.primary{\n      background: linear-gradient(90deg, rgba(124,92,255,0.16), rgba(0,224,198,0.06));\n      border: 1px solid rgba(124,92,255,0.28);\n      box-shadow: 0 8px 30px rgba(124,92,255,0.08);\n    }\n\n    .small{\n      font-size:12px;\n      opacity:0.9;\n      color:rgba(255,255,255,0.92);\n    }\n\n    /* subtle hover sparkles on cells */\n    .cell:hover{ transform: translateY(-6px) scale(1.02); box-shadow: 0 26px 60px rgba(3,8,25,0.55); }\n\n    /* responsive */\n    @media (max-width:900px){\n      .panel{ padding:26px; }\n      .heading{ flex-direction:column; align-items:flex-start; gap:8px; }\n      .title{ font-size:28px }\n      .array-scene{ flex-direction:column; gap:18px; }\n      .info{ margin-left:0; width:100%;}\n    }\n\n    /* subtle animated underline flourish */\n    .title:after{\n      content:\"\";\n      display:block;\n      height:6px;\n      width:60px;\n      border-radius:6px;\n      margin-top:12px;\n      background: linear-gradient(90deg, rgba(124,92,255,0.9), rgba(0,224,198,0.7));\n      transform: translateX(-10px);\n      opacity:0.95;\n      box-shadow: 0 10px 30px rgba(124,92,255,0.12);\n    }\n\n    /* tiny tooltip */\n    .tip{\n      position:absolute;\n      top:-40px;\n      left:50%;\n      transform:translateX(-50%);\n      padding:8px 12px;\n      background: rgba(0,0,0,0.6);\n      border-radius:999px;\n      font-size:12px;\n      color:#fff;\n      pointer-events:none;\n      opacity:0;\n      transition:opacity 260ms, transform 260ms;\n      backdrop-filter: blur(4px);\n      z-index:10;\n    }\n    .tip.show{ opacity:1; transform:translateX(-50%) translateY(-6px); }\n\n    /* heart beat indicator for access count */\n    .pulse{\n      display:inline-block;\n      width:10px;\n      height:10px;\n      border-radius:999px;\n      background:linear-gradient(90deg,#00E0C6,#7C5CFF);\n      box-shadow: 0 6px 30px rgba(124,92,255,0.12);\n      margin-right:8px;\n      animation: pulse 1400ms infinite;\n    }\n    @keyframes pulse{\n      0%{ transform:scale(1); opacity:1 }\n      50%{ transform:scale(1.6); opacity:0.8 }\n      100%{ transform:scale(1); opacity:1 }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"blobs\" aria-hidden=\"true\">\n    <div class=\"blob b1\"></div>\n    <div class=\"blob b2\"></div>\n    <div class=\"blob b3\"></div>\n  </div>\n\n  <div class=\"wrap\">\n    <div class=\"panel\" role=\"main\" aria-label=\"Array visualization panel\">\n      <div class=\"heading\">\n        <h1 class=\"title\">Array</h1>\n        <div class=\"sub\">Ordered • Contiguous • Indexed</div>\n      </div>\n\n      <p class=\"desc\">\n        An array is a linear, fixed-size collection of elements stored contiguously in memory.\n        Each element is accessible by its index — a number representing its offset from the start.\n        Below is a stylized representation that highlights sequential access and indexed addressing.\n      </p>\n\n      <div style=\"display:flex;gap:28px;align-items:flex-start;flex-wrap:wrap;\">\n        <div style=\"flex:1;min-width:320px;\">\n          <div class=\"array-scene\" aria-hidden=\"false\">\n            <div class=\"memory-rail\" id=\"rail\">\n              <div class=\"pointer\" id=\"pointer\" aria-hidden=\"true\">\n                i\n                <div class=\"stem\"></div>\n              </div>\n\n              <!-- Cells inserted by JS for ease of demonstration -->\n              <div id=\"cellsHolder\" style=\"display:flex;align-items:center;gap:18px;position:relative;z-index:3;\"></div>\n\n            </div>\n\n            <!-- Right side info card -->\n            <div class=\"info\" aria-hidden=\"false\">\n              <h4>Conceptual Notes</h4>\n              <p>Elements are stored next to each other. Indexing calculates an element's location: address_of_first + index * size_of_element.\n                 Traversal visits each element, and random access directly targets an index.</p>\n\n              <div class=\"stat\" aria-hidden=\"true\">\n                <div class=\"k\">\n                  <div class=\"v\" id=\"lenValue\">8</div>\n                  <div class=\"t\">Length</div>\n                </div>\n                <div class=\"k\">\n                  <div class=\"v\" id=\"accessValue\">0</div>\n                  <div class=\"t\">Accesses</div>\n                </div>\n              </div>\n\n              <div style=\"display:flex;align-items:center;justify-content:space-between;margin-top:14px;\">\n                <div style=\"display:flex;flex-direction:column;\">\n                  <div class=\"small\" style=\"color:rgba(255,255,255,0.75);\">Base Address</div>\n                  <div style=\"font-weight:700;color:#D8E7FF;margin-top:6px;\">0x7ff4a2c0</div>\n                </div>\n                <div style=\"display:flex;flex-direction:column;align-items:flex-end;\">\n                  <div class=\"small\" style=\"color:rgba(255,255,255,0.75);\">Element Size</div>\n                  <div style=\"font-weight:700;color:#D8E7FF;margin-top:6px;\">4 bytes</div>\n                </div>\n              </div>\n\n            </div>\n          </div>\n\n          <div class=\"index-rail\" id=\"indexRail\" style=\"margin-top:14px;\"></div>\n\n          <div class=\"controls\" style=\"margin-top:20px;\">\n            <button class=\"btn primary\" id=\"traverseBtn\" title=\"Animate a sequential traversal\">▶ Traverse</button>\n            <button class=\"btn\" id=\"shuffleBtn\" title=\"Shuffle the values (visual only)\">Shuffle</button>\n          </div>\n\n        </div>\n      </div>\n\n      <div style=\"position:absolute;right:22px;bottom:18px;color:rgba(255,255,255,0.06);font-weight:700;font-size:80px;transform:translateZ(0);pointer-events:none;\">[]</div>\n\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      // Configuration\n      const initialValues = [12, 7, 34, 2, 19, 88, 3, 45];\n      const elementSizeBytes = 4; // for display\n      const baseAddress = 0x7ff4a2c0;\n\n      // DOM refs\n      const cellsHolder = document.getElementById('cellsHolder');\n      const indexRail = document.getElementById('indexRail');\n      const pointer = document.getElementById('pointer');\n      const traverseBtn = document.getElementById('traverseBtn');\n      const shuffleBtn = document.getElementById('shuffleBtn');\n      const lenValue = document.getElementById('lenValue');\n      const accessValue = document.getElementById('accessValue');\n\n      let values = initialValues.slice();\n      let cells = [];\n      let addrEls = [];\n      let traversalActive = false;\n      let accessCount = 0;\n\n      // Utilities\n      const fmtHex = (n) => '0x' + n.toString(16).padStart(8,'0');\n\n      // Build cells\n      function renderArray(){\n        cellsHolder.innerHTML = '';\n        indexRail.innerHTML = '';\n        cells = [];\n        addrEls = [];\n\n        values.forEach((val, i) => {\n          const cell = document.createElement('div');\n          cell.className = 'cell';\n          cell.dataset.index = i;\n          cell.setAttribute('role','group');\n          cell.innerHTML = `\n            <div class=\"value\">${val}</div>\n            <div class=\"index\">[${i}]</div>\n          `;\n          // add subtle entrance animation\n          cell.style.opacity = '0';\n          cell.style.transform = 'translateY(18px) scale(0.98)';\n          cellsHolder.appendChild(cell);\n          cells.push(cell);\n\n          const addr = document.createElement('div');\n          addr.className = 'addr';\n          addr.innerText = fmtHex(baseAddress + i * elementSizeBytes);\n          indexRail.appendChild(addr);\n          addrEls.push(addr);\n\n          // small delay for appearance\n          requestAnimationFrame(() => {\n            setTimeout(() => {\n              cell.style.opacity = '1';\n              cell.style.transform = '';\n            }, i * 40);\n          });\n        });\n\n        lenValue.innerText = values.length;\n        accessValue.innerText = accessCount;\n\n        // initial pointer position\n        positionPointer(-1);\n      }\n\n      // Position pointer above a cell index (-1 hides it)\n      function positionPointer(index){\n        const railRect = cellsHolder.getBoundingClientRect();\n        if(index < 0 || index >= cells.length){\n          pointer.classList.remove('visible');\n          pointer.style.transform = `translate3d(0,0,0)`;\n          return;\n        }\n        const target = cells[index];\n        const tRect = target.getBoundingClientRect();\n        const parentRect = railRect;\n        // compute center relative to rail container\n        const x = (tRect.left + tRect.right) / 2 - parentRect.left - pointer.offsetWidth / 2;\n        const y = -pointer.offsetHeight - 12; // above\n        pointer.classList.add('visible');\n        pointer.style.transform = `translate3d(${x}px, ${y}px, 0)`;\n      }\n\n      // Highlight a cell at index\n      function highlight(index, opts = {}){\n        cells.forEach((c, idx) => {\n          c.classList.toggle('highlight', idx === index);\n          c.classList.toggle('dim', idx !== index && opts.dimOthers);\n        });\n        addrEls.forEach((a, idx) => {\n          a.classList.toggle('active', idx === index);\n        });\n        positionPointer(index);\n      }\n\n      // Traverse animation: sequentially highlight each element\n      async function traverse(){\n        if(traversalActive) return;\n        traversalActive = true;\n        traverseBtn.disabled = true;\n        shuffleBtn.disabled = true;\n        traverseBtn.innerText = '⏳ Traversing...';\n\n        for(let i=0;i<cells.length;i++){\n          highlight(i, {dimOthers:true});\n          accessCount++;\n          accessValue.innerText = accessCount;\n          // small tooltip effect: show index in pointer briefly\n          pointer.innerHTML = `<span style=\"font-weight:800;color:var(--accent);font-size:13px;\">${i}</span><div class=\"stem\"></div>`;\n          // gentle pulse: slightly enlarge currently accessed value\n          const valEl = cells[i].querySelector('.value');\n          valEl.style.transition = 'transform 200ms';\n          valEl.style.transform = 'translateZ(22px) scale(1.08)';\n          await sleep(520);\n          valEl.style.transform = '';\n        }\n\n        // finish\n        highlight(-1);\n        pointer.innerHTML = 'i<div class=\"stem\"></div>';\n        traverseBtn.disabled = false;\n        shuffleBtn.disabled = false;\n        traverseBtn.innerText = '▶ Traverse';\n        traversalActive = false;\n      }\n\n      // Shuffle values (purely visual)\n      function shuffleValues(){\n        if(traversalActive) return;\n        // gently animate flip of each cell while assigning new random values\n        const newVals = values.slice().sort(() => Math.random()-0.5);\n        values = newVals;\n        accessCount = 0;\n        accessValue.innerText = accessCount;\n        values.forEach((v, i) => {\n          const c = cells[i];\n          // flip animation\n          c.style.transition = 'transform 420ms cubic-bezier(.2,.9,.25,1), box-shadow 320ms';\n          c.style.transform = 'rotateX(90deg)';\n          c.style.opacity = '0.4';\n          setTimeout(() => {\n            c.querySelector('.value').innerText = v;\n            c.style.transform = '';\n            c.style.opacity = '1';\n          }, 220 + i*40);\n        });\n      }\n\n      // small helper\n      function sleep(ms){ return new Promise(res => setTimeout(res, ms)); }\n\n      // Attach event handlers\n      traverseBtn.addEventListener('click', traverse);\n      shuffleBtn.addEventListener('click', shuffleValues);\n\n      // initial render\n      renderArray();\n\n      // Reposition pointer on resize\n      let resizeTimer;\n      window.addEventListener('resize', ()=> {\n        clearTimeout(resizeTimer);\n        resizeTimer = setTimeout(()=> positionPointer(-1), 120);\n      });\n\n      // Accessibility: keyboard trigger (space/enter) on traverse button\n      traverseBtn.addEventListener('keyup', (e)=>{\n        if(e.key === 'Enter' || e.key === ' ') traverse();\n      });\n\n      // Subtle ambient animation: slowly nudge cells horizontally (parallax)\n      (function ambientNudge(){\n        let t = 0;\n        function step(){\n          t += 0.008;\n          cells.forEach((c,i) => {\n            const dx = Math.sin(t + i*0.6) * (i%2 ? 4 : -3);\n            c.style.transform = c.classList.contains('highlight') ? '' : `translateX(${dx}px)`;\n          });\n          requestAnimationFrame(step);\n        }\n        requestAnimationFrame(step);\n      })();\n\n      // On click on a cell, briefly highlight (non-intrusive)\n      cellsHolder.addEventListener('click', (e)=>{\n        if(traversalActive) return;\n        const cell = e.target.closest('.cell');\n        if(!cell) return;\n        const idx = Number(cell.dataset.index);\n        highlight(idx, {dimOthers:true});\n        setTimeout(()=> highlight(-1), 700);\n      });\n\n      // Small entrance flourish: pointer fades in above first cell briefly\n      setTimeout(()=> {\n        positionPointer(0);\n        pointer.classList.add('visible');\n        setTimeout(()=> {\n          pointer.classList.remove('visible');\n          positionPointer(-1);\n        }, 900);\n      }, 900);\n\n      // Expose for debugging (no-op)\n      window._visualArray = {renderArray, traverse, shuffleValues};\n\n    })();\n  </script>\n</body>\n</html>"
  },
