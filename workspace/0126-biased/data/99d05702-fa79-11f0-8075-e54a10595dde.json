    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>TCP/IP Simulation</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .control { margin: 5px; }\n        #output { margin-top: 15px; border: 1px solid #000; padding: 5px; }\n    </style>\n</head>\n<body>\n\n<h1>TCP/IP Simulation</h1>\n<div class=\"control\">\n    <label for=\"ipAddress\">Enter IP Address:</label>\n    <input type=\"text\" id=\"ipAddress\" placeholder=\"e.g. 192.168.1.1\">\n</div>\n<div class=\"control\">\n    <label for=\"port\">Enter Port:</label>\n    <input type=\"number\" id=\"port\" value=\"80\" min=\"1\" max=\"65535\">\n</div>\n<div class=\"control\">\n    <button id=\"connectBtn\">Connect</button>\n</div>\n<div class=\"control\">\n    <label for=\"dataToSend\">Data to Send:</label>\n    <input type=\"text\" id=\"dataToSend\" placeholder=\"Enter data here...\">\n    <button id=\"sendDataBtn\">Send Data</button>\n</div>\n<div class=\"control\">\n    <button id=\"disconnectBtn\">Disconnect</button>\n</div>\n<div class=\"control\">\n    <input type=\"checkbox\" id=\"verboseLogging\">\n    <label for=\"verboseLogging\">Enable Verbose Logging</label>\n</div>\n<div class=\"control\">\n    <button id=\"resetBtn\">Reset Simulation</button>\n</div>\n\n<div id=\"output\"></div>\n\n<script>\n    let connectionState = \"disconnected\";\n    let logOutput = \"\";\n    \n    document.getElementById('connectBtn').addEventListener('click', function() {\n        const ip = document.getElementById('ipAddress').value;\n        const port = document.getElementById('port').value;\n        if (ip && port) {\n            connectionState = \"connected\";\n            logOutput += `Connected to ${ip}:${port}\\n`;\n            updateOutput();\n        } else {\n            alert(\"Please enter a valid IP address and port.\");\n        }\n    });\n\n    document.getElementById('sendDataBtn').addEventListener('click', function() {\n        if (connectionState === \"connected\") {\n            const data = document.getElementById('dataToSend').value;\n            logOutput += `Sent data: ${data}\\n`;\n            updateOutput();\n        } else {\n            alert(\"You must be connected to send data.\");\n        }\n    });\n\n    document.getElementById('disconnectBtn').addEventListener('click', function() {\n        if (connectionState === \"connected\") {\n            connectionState = \"disconnected\";\n            logOutput += `Disconnected.\\n`;\n            updateOutput();\n        } else {\n            alert(\"You are not connected.\");\n        }\n    });\n\n    document.getElementById('resetBtn').addEventListener('click', function() {\n        connectionState = \"disconnected\";\n        logOutput = \"Simulation reset.\\n\";\n        updateOutput();\n    });\n\n    function updateOutput() {\n        document.getElementById('output').textContent = logOutput;\n        if (document.getElementById('verboseLogging').checked) {\n            logOutput += `[Verbose Mode On] - Current State: ${connectionState}\\n`;\n            document.getElementById('output').textContent = logOutput;\n        }\n    }\n</script>\n\n</body>\n</html>"
