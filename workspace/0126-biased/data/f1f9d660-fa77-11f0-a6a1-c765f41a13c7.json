    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Authentication — Visual Concept</title>\n\n  <!-- Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,500&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #081028;\n      --accent-1: #6ee7b7;\n      --accent-2: #60a5fa;\n      --accent-3: #c084fc;\n      --muted: rgba(255,255,255,0.08);\n      --glass: rgba(255,255,255,0.06);\n      --glass-2: rgba(255,255,255,0.03);\n      --maxw: 980px;\n      color-scheme: dark;\n    }\n\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 20%, rgba(99,102,241,0.12), transparent 8%),\n                  radial-gradient(900px 500px at 85% 80%, rgba(96,165,250,0.06), transparent 6%),\n                  linear-gradient(180deg,var(--bg-1), var(--bg-2) 60%);\n      min-height:100vh;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      overflow:hidden;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n    }\n\n    /* Subtle animated particles / aurora */\n    .sky {\n      position: absolute;\n      inset: 0;\n      pointer-events: none;\n      overflow: hidden;\n      z-index:0;\n    }\n    .blob {\n      position:absolute;\n      width:520px;\n      height:520px;\n      background: radial-gradient(circle at 30% 30%, rgba(192,132,252,0.15), rgba(96,165,250,0.08) 30%, transparent 40%);\n      filter: blur(80px) saturate(120%);\n      transform: translate3d(0,0,0);\n      animation: float 12s infinite linear;\n      will-change: transform;\n      mix-blend-mode: screen;\n      opacity:0.9;\n    }\n    .blob.b1{ left:-12%; top:-10%; animation-duration:14s; transform-origin:center; }\n    .blob.b2{ right:-10%; bottom:-6%; width:460px;height:460px; animation-duration:18s; animation-direction:reverse; }\n\n    @keyframes float {\n      0%{ transform: translate3d(0,0,0) rotate(0deg) scale(1); }\n      25%{ transform: translate3d(18px,-24px,0) rotate(6deg) scale(1.03); }\n      50%{ transform: translate3d(0,30px,0) rotate(0deg) scale(0.97); }\n      75%{ transform: translate3d(-18px,-10px,0) rotate(-4deg) scale(1.02); }\n      100%{ transform: translate3d(0,0,0) rotate(0deg) scale(1); }\n    }\n\n    /* Grid / lines overlay */\n    .grid {\n      position:absolute;\n      inset:0;\n      background-image:\n        linear-gradient(transparent 95%, rgba(255,255,255,0.012) 0),\n        linear-gradient(90deg, transparent 95%, rgba(255,255,255,0.012) 0);\n      background-size: 48px 48px, 48px 48px;\n      opacity:0.9;\n      transform: translateZ(0);\n      mix-blend-mode: overlay;\n      pointer-events:none;\n      z-index:1;\n      mask-image: linear-gradient(180deg, rgba(0,0,0,0.7), transparent 30%);\n    }\n\n    /* Centered card */\n    .stage {\n      position:relative;\n      z-index:2;\n      width: min(92vw, var(--maxw));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding: clamp(24px, 6vw, 40px);\n    }\n\n    .auth-card {\n      position:relative;\n      width: 920px;\n      max-width:100%;\n      border-radius:20px;\n      padding:40px;\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap:28px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.04);\n      box-shadow:\n         0 10px 30px rgba(3,7,18,0.6),\n         0 2px 8px rgba(96,165,250,0.05) inset;\n      backdrop-filter: blur(10px) saturate(120%);\n      overflow:hidden;\n    }\n\n    /* Left: graphical hero */\n    .visual {\n      position:relative;\n      padding:28px;\n      border-radius:12px;\n      background: linear-gradient(135deg, rgba(8,16,40,0.28), rgba(10,18,36,0.2));\n      border: 1px solid rgba(255,255,255,0.02);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      justify-content:center;\n      align-items:flex-start;\n      overflow:visible;\n    }\n\n    .brand {\n      display:flex;\n      gap:14px;\n      align-items:center;\n    }\n\n    .logo {\n      width:56px;height:56px;\n      background: conic-gradient(from 180deg at 50% 50%, rgba(96,165,250,0.18), rgba(192,132,252,0.14), rgba(110,231,183,0.15));\n      border-radius:12px;\n      display:grid;\n      place-items:center;\n      box-shadow: 0 6px 24px rgba(3,7,18,0.48), inset 0 -6px 18px rgba(255,255,255,0.02);\n      position:relative;\n    }\n    .logo svg{ filter: drop-shadow(0 6px 16px rgba(0,0,0,0.45)); }\n\n    .title {\n      color: #e6eefb;\n      font-weight:700;\n      letter-spacing: -0.02em;\n      font-size:20px;\n    }\n    .tag {\n      color: rgba(255,255,255,0.55);\n      font-size:13px;\n      margin-top:-2px;\n    }\n\n    .hero-illustration {\n      margin-top:6px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      width:100%;\n      justify-content:space-between;\n    }\n\n    .card-chip {\n      width: calc(100% - 74px);\n      height: 160px;\n      border-radius:14px;\n      background: linear-gradient(120deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border: 1px solid rgba(255,255,255,0.03);\n      display:flex;\n      align-items:center;\n      gap:18px;\n      padding:18px;\n      position:relative;\n      overflow:visible;\n    }\n\n    .chip-left {\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n      color:rgba(255,255,255,0.88);\n      font-weight:600;\n    }\n    .chip-left .name {\n      font-size:18px;\n      letter-spacing:0.2px;\n      color:#fff;\n    }\n    .chip-left .meta {\n      font-size:12px;\n      color:rgba(255,255,255,0.6);\n      font-weight:500;\n    }\n\n    .token-visual {\n      width:120px;height:120px;\n      border-radius:14px;\n      display:grid;\n      place-items:center;\n      background: linear-gradient(135deg, rgba(96,165,250,0.18), rgba(198,120,255,0.12));\n      box-shadow: 0 10px 36px rgba(96,165,250,0.06);\n      transform: rotate(-8deg);\n      transition: transform 600ms cubic-bezier(.2,.9,.2,1);\n    }\n\n    .auth-card:hover .token-visual{ transform: rotate(0deg) translateY(-6px); }\n\n    /* Right: form mockup */\n    .panel {\n      padding:28px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-items:stretch;\n      justify-content:center;\n    }\n\n    .panel .hdr {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n    .panel h3{\n      margin:0;\n      color:#f7fbff;\n      font-size:18px;\n      font-weight:700;\n      letter-spacing:-0.02em;\n      font-family: 'Playfair Display', serif;\n    }\n    .panel p {\n      margin:0;\n      color: rgba(255,255,255,0.55);\n      font-size:13px;\n    }\n\n    .fields {\n      margin-top:4px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n\n    .field {\n      height:56px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      display:flex;\n      align-items:center;\n      gap:12px;\n      padding:12px;\n      color:rgba(255,255,255,0.85);\n      font-weight:600;\n      letter-spacing:0.06em;\n      box-shadow: 0 6px 18px rgba(0,0,0,0.45) inset;\n      opacity:0.98;\n      transition: transform 360ms cubic-bezier(.2,.9,.2,1), box-shadow 360ms;\n      user-select:none;\n    }\n    .field .icon {\n      width:36px;height:36px;border-radius:8px;\n      display:grid;place-items:center;\n      background:rgba(255,255,255,0.02);\n      color: rgba(255,255,255,0.7);\n      font-size:16px;\n    }\n    .field .value {\n      font-size:14px;\n      color:rgba(255,255,255,0.9);\n      opacity:0.95;\n    }\n\n    /* Action area */\n    .actions {\n      display:flex;\n      align-items:center;\n      gap:12px;\n      margin-top:8px;\n    }\n\n    .btn {\n      appearance:none;\n      -webkit-appearance:none;\n      border:0;\n      color: #051023;\n      background: linear-gradient(90deg, var(--accent-1), var(--accent-2));\n      padding:12px 20px;\n      border-radius:12px;\n      font-weight:700;\n      cursor:pointer;\n      font-size:14px;\n      box-shadow: 0 10px 30px rgba(96,165,250,0.12), 0 2px 6px rgba(3,7,18,0.3);\n      transition: transform 220ms cubic-bezier(.2,.9,.2,1), box-shadow 220ms;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n    }\n    .btn:active{ transform: translateY(1px) scale(.998); }\n    .btn.secondary{\n      background: transparent;\n      color: rgba(255,255,255,0.82);\n      border: 1px solid rgba(255,255,255,0.04);\n      box-shadow: none;\n    }\n\n    .btn .pulse {\n      width:10px;height:10px;border-radius:4px;background:rgba(255,255,255,0.85);\n      box-shadow: 0 6px 18px rgba(110,231,183,0.14), 0 0 22px rgba(96,165,250,0.08);\n      transform-origin:center;\n      animation: pulse 1.8s infinite;\n    }\n    @keyframes pulse{\n      0%{ transform:scale(1); opacity:1; }\n      50%{ transform:scale(1.6); opacity:0.5; }\n      100%{ transform:scale(1); opacity:1; }\n    }\n\n    /* Status overlay (progress -> success) */\n    .status {\n      position:absolute;\n      inset:0;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      background: linear-gradient(180deg, rgba(7,12,24,0.6), rgba(5,8,18,0.6));\n      opacity:0;\n      pointer-events:none;\n      transition: opacity 360ms ease;\n      z-index:6;\n      backdrop-filter: blur(6px);\n    }\n    .status.visible{ opacity:1; pointer-events:auto; }\n\n    .status-card {\n      width: 360px;\n      height:160px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border: 1px solid rgba(255,255,255,0.04);\n      display:flex;\n      align-items:center;\n      gap:18px;\n      padding:20px;\n      justify-content:center;\n      flex-direction:column;\n      color:#ffffff;\n      box-shadow: 0 20px 60px rgba(2,6,23,0.66);\n    }\n\n    .spinner {\n      width:64px;height:64px;\n      display:grid;place-items:center;\n    }\n    .ring {\n      width:56px;height:56px;border-radius:50%;\n      border:4px solid rgba(255,255,255,0.06);\n      border-top-color: rgba(110,231,183,0.98);\n      animation: spin 1s linear infinite;\n      box-shadow: 0 6px 24px rgba(96,165,250,0.08), inset 0 2px 8px rgba(255,255,255,0.03);\n    }\n    @keyframes spin{ to{ transform:rotate(1turn); } }\n\n    /* success check */\n    .success {\n      width:72px;height:72px;\n      display:grid;place-items:center;\n      border-radius:50%;\n      background: conic-gradient(from 200deg, rgba(110,231,183,0.14), rgba(96,165,250,0.12));\n      box-shadow: 0 12px 36px rgba(110,231,183,0.06), 0 2px 6px rgba(3,7,18,0.45);\n      transform: scale(.95);\n      opacity:0;\n      transition: opacity 480ms cubic-bezier(.2,.9,.2,1), transform 480ms;\n    }\n    .status.success .spinner{ display:none; }\n    .status.success .success{ opacity:1; transform:scale(1); }\n\n    /* check mark draw */\n    .check {\n      width:42px;height:42px;\n    }\n    .check svg { width:100%; height:100%; stroke: rgba(10,45,28,0.98); stroke-width:4; fill:none; stroke-linecap:round; stroke-linejoin:round; }\n    .path {\n      stroke-dasharray: 60;\n      stroke-dashoffset: 60;\n      animation: draw 560ms forwards 320ms cubic-bezier(.2,.9,.2,1);\n    }\n    @keyframes draw {\n      to{ stroke-dashoffset: 0; }\n    }\n\n    .status .message {\n      font-weight:700;\n      letter-spacing:-0.01em;\n      color:#e9fbf6;\n      font-size:15px;\n      margin-top:8px;\n    }\n    .status .sub {\n      margin:0;\n      font-size:12px;\n      color: rgba(255,255,255,0.6);\n    }\n\n    /* Token reveal */\n    .token {\n      margin-top:10px;\n      padding:8px 12px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:10px;\n      border: 1px solid rgba(255,255,255,0.04);\n      color: rgba(255,255,255,0.92);\n      font-weight:700;\n      font-family: monospace;\n      letter-spacing:0.08em;\n      font-size:12px;\n      opacity:0;\n      transform: translateY(6px);\n      transition: opacity 420ms 220ms, transform 420ms 220ms;\n    }\n    .status.success .token{ opacity:1; transform:none; }\n\n    /* small reset button */\n    .reset {\n      position:absolute;\n      top:14px;\n      right:14px;\n      z-index:8;\n      padding:8px 10px;\n      border-radius:10px;\n      background: rgba(255,255,255,0.02);\n      border:1px solid rgba(255,255,255,0.03);\n      color: rgba(255,255,255,0.78);\n      font-weight:700;\n      cursor:pointer;\n      display:none;\n    }\n    .reset.visible{ display:inline-flex; gap:8px; align-items:center; }\n\n    /* responsive */\n    @media (max-width:900px){\n      .auth-card{ grid-template-columns:1fr; padding:24px; gap:18px; }\n      .visual{ order:2 }\n      .panel{ order:1 }\n      .token-visual{ display:none }\n      .brand .title{ font-size:18px }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"sky\" aria-hidden=\"true\">\n    <div class=\"blob b1\"></div>\n    <div class=\"blob b2\"></div>\n  </div>\n  <div class=\"grid\" aria-hidden=\"true\"></div>\n\n  <main class=\"stage\" role=\"main\" aria-label=\"Authentication concept demo\">\n    <section class=\"auth-card\" aria-hidden=\"false\">\n      <!-- Reset small control -->\n      <button class=\"reset\" id=\"resetBtn\" aria-hidden=\"true\" title=\"Reset demo\">\n        ⟲ Reset\n      </button>\n\n      <!-- Visual / left side -->\n      <div class=\"visual\" aria-hidden=\"false\">\n        <div class=\"brand\">\n          <div class=\"logo\" aria-hidden=\"true\">\n            <!-- lock glyph -->\n            <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <defs>\n                <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#6ee7b7\" />\n                  <stop offset=\"1\" stop-color=\"#60a5fa\" />\n                </linearGradient>\n              </defs>\n              <rect x=\"3\" y=\"10\" width=\"18\" height=\"11\" rx=\"2\" stroke=\"url(#g1)\" stroke-width=\"1.6\" />\n              <path d=\"M7 10V8a5 5 0 0 1 10 0v2\" stroke=\"url(#g1)\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n            </svg>\n          </div>\n          <div>\n            <div class=\"title\">Authentication</div>\n            <div class=\"tag\">Secure access • Elegant visualization</div>\n          </div>\n        </div>\n\n        <div class=\"hero-illustration\" aria-hidden=\"true\">\n          <div class=\"card-chip\">\n            <div class=\"chip-left\">\n              <div class=\"name\">User • Demo</div>\n              <div class=\"meta\">Access: Tokenized • 2FA-ready</div>\n              <div style=\"height:6px\"></div>\n              <div style=\"width:140px;height:10px;border-radius:6px;background:linear-gradient(90deg,#ffffff22,#ffffff09)\"></div>\n            </div>\n            <div class=\"token-visual\" aria-hidden=\"true\">\n              <!-- stylized token hex -->\n              <svg viewBox=\"0 0 120 120\" width=\"86\" height=\"86\" aria-hidden=\"true\">\n                <defs>\n                  <linearGradient id=\"tg\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#6ee7b7\" stop-opacity=\"0.95\"/>\n                    <stop offset=\"1\" stop-color=\"#c084fc\" stop-opacity=\"0.95\"/>\n                  </linearGradient>\n                  <filter id=\"shadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                    <feDropShadow dx=\"0\" dy=\"8\" stdDeviation=\"12\" flood-color=\"#00000055\"/>\n                  </filter>\n                </defs>\n                <g filter=\"url(#shadow)\">\n                  <polygon points=\"60,8 100,30 100,78 60,100 20,78 20,30\" fill=\"url(#tg)\"></polygon>\n                  <circle cx=\"60\" cy=\"54\" r=\"24\" fill=\"#ffffff0c\"></circle>\n                  <g transform=\"translate(60,54)\">\n                    <path d=\"M-8 0 L0 10 L12 -10\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\" opacity=\"0.95\" transform=\"rotate(0)\"></path>\n                  </g>\n                </g>\n              </svg>\n            </div>\n          </div>\n\n          <!-- decorative small elements -->\n          <svg width=\"74\" height=\"160\" viewBox=\"0 0 74 160\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"g2\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#60a5fa\" stop-opacity=\"0.08\"/>\n                <stop offset=\"1\" stop-color=\"#c084fc\" stop-opacity=\"0.06\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"6\" width=\"62\" height=\"148\" rx=\"10\" fill=\"url(#g2)\" stroke=\"rgba(255,255,255,0.02)\" />\n            <g fill=\"none\" stroke=\"#ffffff11\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.6\">\n              <path d=\"M14 26h46\"/>\n              <path d=\"M14 56h46\"/>\n              <path d=\"M14 86h46\"/>\n              <path d=\"M14 116h46\"/>\n            </g>\n          </svg>\n        </div>\n\n        <p style=\"color:rgba(255,255,255,0.6);margin:6px 0 0;font-size:13px;max-width:82%;\">A refined visual exploration of modern authentication. Minimal controls — maximal confidence. Observe the handshake, tokenization, and bloom of access confirmation.</p>\n      </div>\n\n      <!-- Panel / right side (mockup) -->\n      <div class=\"panel\" aria-hidden=\"false\">\n        <div class=\"hdr\">\n          <div>\n            <h3>Secure Sign-In</h3>\n            <p>Demonstration of an authentication sequence</p>\n          </div>\n          <div style=\"text-align:right;color:rgba(255,255,255,0.55);font-weight:700\">Demo v1.0</div>\n        </div>\n\n        <div class=\"fields\" aria-hidden=\"true\">\n          <div class=\"field\" title=\"Email\">\n            <div class=\"icon\" aria-hidden=\"true\">✉</div>\n            <div class=\"value\">alice@example.com</div>\n          </div>\n\n          <div class=\"field\" title=\"Password\">\n            <div class=\"icon\" aria-hidden=\"true\">🔒</div>\n            <div class=\"value\">•••••••••</div>\n          </div>\n        </div>\n\n        <div class=\"actions\" aria-hidden=\"false\">\n          <button class=\"btn\" id=\"authBtn\" aria-live=\"polite\" aria-pressed=\"false\">\n            <span class=\"pulse\" aria-hidden=\"true\"></span>\n            Authenticate\n          </button>\n\n          <button class=\"btn secondary\" id=\"helpBtn\" aria-hidden=\"true\" title=\"Informational\">\n            Details\n          </button>\n        </div>\n\n        <p style=\"margin-top:6px;color:rgba(255,255,255,0.5);font-size:12px;\">Note: This is a visual concept. The \"Authenticate\" button triggers a simulated secure exchange — no real credentials are used.</p>\n      </div>\n\n      <!-- Status overlay -->\n      <div class=\"status\" id=\"status\" aria-hidden=\"true\">\n        <div class=\"status-card\" role=\"status\">\n          <div class=\"spinner\" id=\"spinner\">\n            <div class=\"ring\" aria-hidden=\"true\"></div>\n          </div>\n\n          <div class=\"success\" id=\"success\">\n            <div class=\"check\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 24 24\">\n                <path class=\"path\" d=\"M4 12.5l4.2-4.2 4.6 4.9 7.2-8.8\"></path>\n              </svg>\n            </div>\n          </div>\n\n          <div class=\"message\" id=\"msg\">Authenticating…</div>\n          <div class=\"sub\" id=\"sub\">Establishing secure channel</div>\n          <div class=\"token\" id=\"token\" aria-hidden=\"true\">Token • a1b2-9f3c-7d88</div>\n        </div>\n      </div>\n\n    </section>\n  </main>\n\n  <script>\n    (function(){\n      const authBtn = document.getElementById('authBtn');\n      const status = document.getElementById('status');\n      const spinner = document.getElementById('spinner');\n      const success = document.getElementById('success');\n      const msg = document.getElementById('msg');\n      const sub = document.getElementById('sub');\n      const tokenEl = document.getElementById('token');\n      const resetBtn = document.getElementById('resetBtn');\n      const helpBtn = document.getElementById('helpBtn');\n\n      let timer1, timer2;\n\n      function startAuth(){\n        authBtn.setAttribute('aria-pressed','true');\n        status.classList.add('visible');\n        status.classList.remove('success');\n        msg.textContent = 'Authenticating…';\n        sub.textContent = 'Establishing secure channel';\n        tokenEl.style.opacity = 0;\n        tokenEl.setAttribute('aria-hidden','true');\n        resetBtn.classList.remove('visible');\n        helpBtn.setAttribute('aria-hidden','true');\n\n        // Simulate ephemeral steps\n        clearTimeout(timer1);\n        clearTimeout(timer2);\n\n        // after 1.6s, update substatus\n        timer1 = setTimeout(()=>{\n          sub.textContent = 'Exchanging keys • validating factors';\n        }, 1400);\n\n        // after ~2.4s, show success\n        timer2 = setTimeout(()=>{\n          status.classList.add('success');\n          msg.textContent = 'Access Granted';\n          sub.textContent = 'Token issued • Valid for 15m';\n          tokenEl.setAttribute('aria-hidden','false');\n          resetBtn.classList.add('visible');\n          helpBtn.setAttribute('aria-hidden','true');\n        }, 2400);\n      }\n\n      function reset(){\n        clearTimeout(timer1);\n        clearTimeout(timer2);\n        status.classList.remove('visible','success');\n        authBtn.setAttribute('aria-pressed','false');\n        msg.textContent = 'Authenticating…';\n        sub.textContent = 'Establishing secure channel';\n        tokenEl.setAttribute('aria-hidden','true');\n        resetBtn.classList.remove('visible');\n        helpBtn.setAttribute('aria-hidden','true');\n      }\n\n      authBtn.addEventListener('click', startAuth);\n      resetBtn.addEventListener('click', reset);\n\n      // Accessibility: keyboard trigger on Enter\n      authBtn.addEventListener('keyup', (e)=>{ if(e.key === 'Enter') startAuth(); });\n      resetBtn.addEventListener('keyup', (e)=>{ if(e.key === 'Enter') reset(); });\n\n      // Small visual: after page load, briefly show the status sequence automatically (observational)\n      window.addEventListener('load', ()=>{\n        // auto-run once after small delay for demo viewing\n        setTimeout(()=> {\n          startAuth();\n        }, 700);\n      });\n\n    })();\n  </script>\n</body>\n</html>"
  },
