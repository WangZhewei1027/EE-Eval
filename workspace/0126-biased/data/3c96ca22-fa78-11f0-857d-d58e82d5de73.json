    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Insertion Sort Visualization — Aesthetic Demo</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n  :root {\n    --clr-bg: #0f2027;\n    --clr-bg-gradient: linear-gradient(135deg, #2c5364 0%, #203a43 50%, #0f2027 100%);\n    --clr-primary: #ffb347;\n    --clr-primary-dark: #ff8c00;\n    --clr-secondary: #00d2ff;\n    --clr-accent: #a8edea;\n    --clr-text-light: #f0f6f8;\n    --clr-text-muted: #7a8a99;\n    --clr-bar: #668cff;\n    --clr-bar-sorted: #7ee8fa;\n    --clr-bar-highlight: #ffb347;\n    --transition-speed: 0.5s;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: var(--clr-bg-gradient);\n    font-family: 'Montserrat', sans-serif;\n    color: var(--clr-text-light);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    overflow-x: hidden;\n    padding: 2rem 1rem 4rem;\n  }\n\n  h1 {\n    font-weight: 700;\n    font-size: 2.8rem;\n    letter-spacing: 5px;\n    text-transform: uppercase;\n    margin-bottom: 0.6rem;\n    user-select: none;\n    text-shadow:\n      0 0 8px var(--clr-primary),\n      0 0 20px var(--clr-primary-dark);\n  }\n\n  h2 {\n    font-weight: 500;\n    font-size: 1.1rem;\n    color: var(--clr-text-muted);\n    margin-top: 0;\n    margin-bottom: 3rem;\n    font-style: italic;\n    letter-spacing: 1.5px;\n    user-select: none;\n  }\n\n  #container {\n    position: relative;\n    width: 100%;\n    max-width: 900px;\n    height: 330px;\n    background: rgba(34, 49, 63, 0.6);\n    border-radius: 1.25rem;\n    box-shadow:\n      inset 0 0 24px 1px rgba(255 179 71 / 0.3),\n      0 0 36px 6px rgba(255 179 71 / 0.2);\n    padding: 2rem 2rem 3rem;\n    user-select: none;\n    overflow: visible;\n  }\n\n  #bars {\n    display: flex;\n    align-items: flex-end;\n    height: 100%;\n    gap: 9px;\n    perspective: 600px;\n    margin-bottom: 0;\n  }\n\n  .bar {\n    position: relative;\n    background: linear-gradient(180deg, var(--clr-bar-sorted) 0%, var(--clr-bar) 100%);\n    border-radius: 0.625rem 0.625rem 0 0;\n    transform-style: preserve-3d;\n    flex: 1 1 auto;\n    cursor: default;\n    transition: background var(--transition-speed) ease, transform var(--transition-speed) ease;\n\n    will-change: transform, background-color;\n    box-shadow:\n      0 3px 10px rgba(35, 102, 255, 0.4),\n      inset 0 -4px 12px rgba(255 255 255 / 0.2);\n  }\n\n  .bar.highlight {\n    background: linear-gradient(180deg, var(--clr-bar-highlight) 0%, #e39600 100%);\n    box-shadow:\n      0 0 20px 3px #ffb347c4,\n      inset 0 -6px 18px #ffb347c9;\n    transform: scale(1.1) translateZ(20px);\n    z-index: 2;\n  }\n\n  .bar.sorted {\n    background: linear-gradient(180deg, var(--clr-bar-sorted) 0%, #81e7fa 100%);\n    box-shadow:\n      0 0 24px 3px #69dae9cc,\n      inset 0 -6px 18px #4cdff0ba;\n  }\n\n  #controls {\n    margin-top: 1.25rem;\n    user-select: none;\n    display: flex;\n    gap: 1rem;\n    justify-content: center;\n  }\n\n  button {\n    background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));\n    border: none;\n    border-radius: 9999px;\n    padding: 0.78rem 2.2rem;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1.08rem;\n    color: #0f2027;\n    cursor: pointer;\n    box-shadow:\n      0 4px 15px rgba(255 179 71 / 0.7);\n    transition: background 0.4s ease, transform 0.25s ease;\n    user-select: none;\n    text-transform: uppercase;\n    letter-spacing: 2px;\n    outline-offset: 4px;\n  }\n\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, #ffc75f, #ff9300);\n    outline: 2px solid #ffb347;\n    outline-offset: 6px;\n    transform: scale(1.08);\n  }\n\n  /* Tooltip style */\n  #tooltip {\n    position: absolute;\n    bottom: 100%;\n    padding: 0.25rem 0.6rem;\n    background: rgba(0, 0, 0, 0.75);\n    color: var(--clr-primary);\n    font-size: 0.78rem;\n    border-radius: 0.38rem;\n    pointer-events: none;\n    user-select: none;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    letter-spacing: 0.6px;\n    font-weight: 600;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  /* Subtle shimmering background highlight inside container */\n  #container::before {\n    content: \"\";\n    position: absolute;\n    pointer-events: none;\n    top: -20%;\n    left: -40%;\n    width: 180%;\n    height: 140%;\n    z-index: 0;\n    background:\n      radial-gradient(ellipse 80px 80px at 25% 30%, #ffb34730, transparent 70%),\n      radial-gradient(ellipse 80px 80px at 77% 45%, #00d2ff3b, transparent 70%),\n      radial-gradient(ellipse 100px 130px at 50% 70%, #a8edea40, transparent 60%);\n    filter: blur(40px);\n    animation: shimmer 12s linear infinite;\n    border-radius: 1.25rem;\n  }\n\n  @keyframes shimmer {\n    0% {\n      background-position: 0% 0%, 0% 0%, 0% 0%;\n    }\n    100% {\n      background-position: 180% 90%, 180% 90%, 180% 90%;\n    }\n  }\n\n  /* Info panel */\n  #info {\n    margin-top: 2rem;\n    max-width: 700px;\n    font-weight: 400;\n    font-size: 1rem;\n    color: var(--clr-text-muted);\n    line-height: 1.42;\n    text-align: center;\n    font-style: italic;\n    user-select: none;\n  }\n\n  /* Responsive */\n  @media (max-width: 600px) {\n    #container {\n      height: 250px;\n      padding: 1.5rem 1.5rem 2.5rem;\n    }\n\n    h1 {\n      font-size: 2.2rem;\n    }\n\n    h2 {\n      font-size: 1rem;\n      margin-bottom: 2rem;\n    }\n\n    button {\n      padding: 0.65rem 1.6rem;\n      font-size: 0.9rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>Insertion Sort</h1>\n  <h2>Visualizing the elegance of \"inserting\" numbers in order</h2>\n\n  <div id=\"container\" aria-label=\"Insertion sort visualization\" role=\"img\">\n    <div id=\"bars\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n  </div>\n\n  <div id=\"controls\" aria-label=\"Controls\">\n    <button id=\"startBtn\" type=\"button\" aria-pressed=\"false\" aria-label=\"Start sorting animation\">Start</button>\n    <button id=\"resetBtn\" type=\"button\" aria-label=\"Reset array\">Reset</button>\n  </div>\n\n  <p id=\"info\">Watch how the algorithm picks each element and inserts it into the sorted part step by step. The golden bar shows the element currently being considered. Smooth transitions reveal the subtle beauty behind sorting.</p>\n\n<script>\n(() => {\n  'use strict';\n\n  // Parameters\n  const NUM_BARS = 22;\n  const MIN_VAL = 12;\n  const MAX_VAL = 280;\n\n  const container = document.getElementById('bars');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  let bars = [];\n  let values = [];\n  let sorting = false;\n  let sortGenerator = null;\n\n  // Generate random array with unique-ish values for elegant aesthetics\n  function generateArray() {\n    const arr = [];\n    const step = Math.floor((MAX_VAL - MIN_VAL) / NUM_BARS);\n    for(let i=0; i<NUM_BARS; i++) {\n      // Spread values with jitter for aesthetics\n      arr.push(MIN_VAL + i*step + Math.floor((Math.random()-0.5)*(step*0.7)));\n    }\n    // Shuffle a bit to disorder the array\n    for(let i=0; i < arr.length*3; i++) {\n      const idx1 = Math.floor(Math.random()*NUM_BARS);\n      const idx2 = Math.floor(Math.random()*NUM_BARS);\n      [arr[idx1], arr[idx2]] = [arr[idx2], arr[idx1]];\n    }\n    return arr;\n  }\n\n  function createBars(array) {\n    container.innerHTML = '';\n    bars = [];\n    for(let val of array) {\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      bar.style.height = `${val}px`;\n      bars.push(bar);\n      container.appendChild(bar);\n    }\n  }\n\n  // Animate swapping of bars by adjusting heights, with smooth CSS transition\n  // We won't swap DOM nodes, just change heights and colors\n  // This keeps the layout stable and visually elegant\n\n  // Insertion sort generator for stepwise iteration\n  function* insertionSortGen(array) {\n    let arr = array.slice();\n    let n = arr.length;\n    yield {type: 'init', array: arr.slice(), current: null, sorted: []};\n\n    for(let i = 1; i < n; i++) {\n      let key = arr[i];\n      let j = i - 1;\n      yield {type: 'select', index: i, key: key, sorted: arr.slice(0,i)};\n\n      while(j >= 0 && arr[j] > key) {\n        arr[j+1] = arr[j];\n        yield {type: 'shift', from: j, to: j+1, key: key, sorted: arr.slice(0,i)};\n        j = j - 1;\n      }\n      arr[j+1] = key;\n      yield {type: 'insert', index: j+1, key: key, array: arr.slice(), sorted: arr.slice(0,i+1)};\n    }\n    yield {type: 'done', array: arr.slice(), sorted: arr.slice()};\n  }\n\n  // Update bars heights and colors\n  // Highlights array indices: highlightIndex is the \"key\" bar being inserted\n  // sortedIndices - array of sorted elements indices\n  // shiftFrom and shiftTo for highlighting shifts\n  function updateBars(state) {\n    const arr = state.array || values;\n    for(let i=0; i < bars.length; i++) {\n      bars[i].style.height = arr[i] + 'px';\n      bars[i].classList.remove('highlight','sorted');\n    }\n\n    if(state.type === 'init') {\n      // No highlights, no sorted bars\n    } else if(state.type === 'select') {\n      // Highlight \"key\" bar\n      const i = state.index;\n      if (bars[i]) bars[i].classList.add('highlight');\n      // Mark sorted bars\n      for(let s=0; s < i; s++) bars[s].classList.add('sorted');\n    } else if(state.type === 'shift') {\n      // The bar at shiftFrom is being moved to shiftTo by shifting height visually\n      // Highlight the shifted bar at shiftTo\n      const to = state.to;\n      if (bars[to]) bars[to].classList.add('highlight');\n      // Mark sorted bars before i, we don't have i here exactly but approximate it\n      const sortedCount = state.sorted.length;\n      for(let s=0; s < sortedCount; s++) bars[s].classList.add('sorted');\n    } else if(state.type === 'insert') {\n      // After insertion - mark sorted bars and highlight the inserted\n      const idx = state.index;\n      if (bars[idx]) bars[idx].classList.add('highlight');\n      for(let s=0; s < state.sorted.length; s++) bars[s].classList.add('sorted');\n    } else if(state.type === 'done') {\n      for(let i=0; i < bars.length; i++) {\n        bars[i].classList.add('sorted');\n      }\n    }\n  }\n\n  // Delay helper for animation pacing\n  function delay(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Run insertion sort with animations and generator\n  async function runSort() {\n    sorting = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    startBtn.setAttribute('aria-pressed', 'true');\n\n    sortGenerator = insertionSortGen(values);\n    let next = sortGenerator.next();\n\n    while(!next.done && sorting) {\n      updateBars(next.value);\n\n      // Tune delay depending on step type\n      if(next.value.type === 'shift') {\n        await delay(140);\n      } else if(next.value.type === 'select' || next.value.type === 'insert') {\n        await delay(350);\n      } else {\n        await delay(270);\n      }\n\n      next = sortGenerator.next();\n    }\n\n    if (!sorting) {\n      // If ended early by reset, do nothing\n      updateBars({type:'init', array: values});\n    } else {\n      updateBars({type:'done', array: values});\n    }\n\n    sorting = false;\n    startBtn.disabled = false;\n    resetBtn.disabled = false;\n    startBtn.setAttribute('aria-pressed', 'false');\n  }\n\n  function reset() {\n    sorting = false;\n    if(sortGenerator && typeof sortGenerator.return === 'function') {\n      sortGenerator.return();\n    }\n    values = generateArray();\n    createBars(values);\n    updateBars({type:'init', array: values});\n  }\n\n  // Initialize\n  reset();\n\n  startBtn.addEventListener('click', () => {\n    if(!sorting) runSort();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    if(!sorting) reset();\n  });\n\n})();\n</script>\n</body>\n</html>"
