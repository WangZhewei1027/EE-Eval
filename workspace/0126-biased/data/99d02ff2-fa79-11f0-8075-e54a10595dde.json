    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Index Demo</title>\n    <style>\n        body { font-family: monospace; }\n    </style>\n</head>\n<body>\n    <h1>B-Tree Index Demo</h1>\n    <div>\n        <label for=\"order\">B-Tree Order (Max Children): </label>\n        <input type=\"number\" id=\"order\" value=\"3\" min=\"2\">\n        <button id=\"createTree\">Create B-Tree</button>\n    </div>\n    <div>\n        <h2>Tree Structure</h2>\n        <pre id=\"treeStructure\"></pre>\n    </div>\n    <div>\n        <h2>Insert Value</h2>\n        <input type=\"number\" id=\"insertValue\">\n        <button id=\"insertBtn\">Insert</button>\n    </div>\n    <div>\n        <h2>Search Value</h2>\n        <input type=\"number\" id=\"searchValue\">\n        <button id=\"searchBtn\">Search</button>\n        <p id=\"searchResult\"></p>\n    </div>\n    <div>\n        <h2>Delete Value</h2>\n        <input type=\"number\" id=\"deleteValue\">\n        <button id=\"deleteBtn\">Delete</button>\n    </div>\n    \n    <script>\n        class BTreeNode {\n            constructor(order, leaf = true) {\n                this.order = order;\n                this.leaf = leaf;\n                this.keys = [];\n                this.children = [];\n            }\n    \n            insertNonFull(key) {\n                let i = this.keys.length - 1;\n                if (this.leaf) {\n                    while (i >= 0 && key < this.keys[i]) {\n                        i--;\n                    }\n                    this.keys.splice(i + 1, 0, key);\n                } else {\n                    while (i >= 0 && key < this.keys[i]) {\n                        i--;\n                    }\n                    i++;\n                    if (this.children[i].keys.length === this.order - 1) {\n                        this.splitChild(i);\n                        if (key > this.keys[i]) {\n                            i++;\n                        }\n                    }\n                    this.children[i].insertNonFull(key);\n                }\n            }\n    \n            splitChild(i) {\n                const newNode = new BTreeNode(this.order, this.children[i].leaf);\n                const midKey = this.children[i].keys[this.order / 2 - 1];\n                newNode.keys = this.children[i].keys.slice(this.order / 2);\n                this.children[i].keys = this.children[i].keys.slice(0, this.order / 2 - 1);\n                if (!this.children[i].leaf) {\n                    newNode.children = this.children[i].children.slice(this.order / 2);\n                    this.children[i].children = this.children[i].children.slice(0, this.order / 2);\n                }\n                this.keys.splice(i, 0, midKey);\n                this.children.splice(i + 1, 0, newNode);\n            }\n        }\n    \n        class BTree {\n            constructor(order) {\n                this.root = new BTreeNode(order);\n                this.order = order;\n            }\n    \n            insert(key) {\n                if (this.root.keys.length === this.order - 1) {\n                    const newRoot = new BTreeNode(this.order, false);\n                    newRoot.children.push(this.root);\n                    newRoot.splitChild(0);\n                    newRoot.insertNonFull(key);\n                    this.root = newRoot;\n                } else {\n                    this.root.insertNonFull(key);\n                }\n            }\n    \n            search(key, node = this.root) {\n                let i = 0;\n                while (i < node.keys.length && key > node.keys[i]) {\n                    i++;\n                }\n                if (i < node.keys.length && key === node.keys[i]) {\n                    return true;\n                }\n                if (node.leaf) {\n                    return false;\n                }\n                return this.search(key, node.children[i]);\n            }\n    \n            delete(key) {\n                // Deletion is complex; can be implemented if required.\n                // Here, we retain keys but do not delete for simplicity.\n            }\n    \n            toString(node = this.root) {\n                let result = \"\";\n                for (let i = 0; i < node.keys.length; i++) {\n                    if (!node.leaf) {\n                        result += this.toString(node.children[i]);\n                    }\n                    result += node.keys[i] + \" \";\n                }\n                if (!node.leaf) {\n                    result += this.toString(node.children[node.keys.length]);\n                }\n                return result;\n            }\n        }\n    \n        let btree;\n    \n        document.getElementById('createTree').onclick = function() {\n            const order = parseInt(document.getElementById('order').value);\n            btree = new BTree(order);\n            document.getElementById('treeStructure').textContent = \"B-Tree Created with Order: \" + order;\n        };\n    \n        document.getElementById('insertBtn').onclick = function() {\n            const key = parseInt(document.getElementById('insertValue').value);\n            btree.insert(key);\n            document.getElementById('treeStructure').textContent = btree.toString();\n            document.getElementById('insertValue').value = '';\n        };\n    \n        document.getElementById('searchBtn').onclick = function() {\n            const key = parseInt(document.getElementById('searchValue').value);\n            const found = btree.search(key);\n            document.getElementById('searchResult').textContent = found ? \"Value Found\" : \"Value Not Found\";\n            document.getElementById('searchValue').value = '';\n        };\n    \n        document.getElementById('deleteBtn').onclick = function() {\n            const key = parseInt(document.getElementById('deleteValue').value);\n            btree.delete(key);\n            document.getElementById('treeStructure').textContent = btree.toString();\n            document.getElementById('deleteValue').value = '';\n        };\n    </script>\n</body>\n</html>"
