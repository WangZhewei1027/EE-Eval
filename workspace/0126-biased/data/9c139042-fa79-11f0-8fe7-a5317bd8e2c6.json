    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Heap (Max) - Interactive Demo</title>\n</head>\n<body>\n  <h1>Heap (Max) - Interactive Demo</h1>\n\n  <div>\n    <h3>Array Input / Random Generation</h3>\n    <div>\n      Enter array (comma or space separated): <input id=\"arrayInput\" size=\"60\" value=\"16,14,10,8,7,9,3,2,4,1\">\n      <button id=\"loadArrayBtn\">Load Array</button>\n    </div>\n    <div>\n      Random size: <input id=\"randSize\" type=\"number\" value=\"10\" min=\"0\" style=\"width:60px\">\n      Min value: <input id=\"randMin\" type=\"number\" value=\"0\" style=\"width:80px\">\n      Max value: <input id=\"randMax\" type=\"number\" value=\"99\" style=\"width:80px\">\n      <button id=\"genRandomBtn\">Generate Random Array</button>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Primary Heap Operations</h3>\n    <div>\n      <button id=\"buildHeapBtn\">Build Heap (Heapify bottom-up)</button>\n      <button id=\"autoBuildBtn\">Auto-Build (play steps)</button>\n      Speed: <input id=\"playSpeed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\"> <span id=\"speedLabel\">400ms</span>\n    </div>\n\n    <div>\n      Insert value: <input id=\"insertVal\" type=\"number\" value=\"42\" style=\"width:80px\">\n      <button id=\"insertBtn\">Insert</button>\n      <button id=\"autoInsertBtn\">Insert (step-by-step playback)</button>\n      Extract max: <button id=\"extractBtn\">Extract-Max</button>\n      <button id=\"autoExtractBtn\">Extract (step-by-step playback)</button>\n      Replace root with: <input id=\"replaceVal\" type=\"number\" value=\"5\" style=\"width:80px\">\n      <button id=\"replaceBtn\">Replace Max</button>\n      Peek: <button id=\"peekBtn\">Peek</button>\n    </div>\n\n    <div>\n      Bulk insert (CSV): <input id=\"bulkInsert\" size=\"40\" value=\"11,22,33\"> <button id=\"bulkInsertBtn\">Bulk Insert</button>\n    </div>\n\n    <div>\n      Build stats: <span id=\"statComparisons\">0</span> comparisons, <span id=\"statSwaps\">0</span> swaps\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Manual and Exploratory Controls</h3>\n    <div>\n      Select node index: <input id=\"selectedIndex\" type=\"number\" value=\"0\" style=\"width:80px\">\n      <button id=\"selectBtn\">Select</button>\n      <button id=\"siftDownBtn\">Sift-Down (one step)</button>\n      <button id=\"siftUpBtn\">Sift-Up (one step)</button>\n      <button id=\"siftDownFullBtn\">Sift-Down (complete)</button>\n      <button id=\"siftUpFullBtn\">Sift-Up (complete)</button>\n      Swap selected with index: <input id=\"swapWithIndex\" type=\"number\" style=\"width:80px\">\n      <button id=\"manualSwapBtn\">Manual Swap</button>\n      <button id=\"autoFixBtn\">Auto-Fix Entire Heap (verify and fix every node)</button>\n    </div>\n    <div>\n      Click two array items to swap manually: <button id=\"clearSelectionBtn\">Clear Click Selection</button>\n      <span id=\"clickSelection\">none</span>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Playback / Step Controls</h3>\n    <div>\n      <button id=\"stepBackBtn\">Step Back</button>\n      <button id=\"stepForwardBtn\">Step Forward</button>\n      <button id=\"playBtn\">Play</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"resetPlaybackBtn\">Reset Playback</button>\n      <div>Current step: <span id=\"currentStep\">0</span> / <span id=\"totalSteps\">0</span></div>\n      <div>Mode: <span id=\"playMode\">Idle</span></div>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Undo / Redo</h3>\n    <div>\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n      <button id=\"snapshotBtn\">Save Snapshot (manual)</button>\n      <button id=\"restoreSnapshotBtn\">Restore Last Snapshot</button>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Scripted Sequence Runner</h3>\n    <div>\n      Enter commands (one per line). Commands:\n      build, insert X, extract, replace X, peek, wait N (ms), swap i j, siftDown i, siftUp i, load a,b,c\n    </div>\n    <div>\n      <textarea id=\"scriptArea\" rows=\"6\" cols=\"80\">insert 99\nbuild\nextract\ninsert 15\nreplace 50\n</textarea>\n    </div>\n    <div>\n      <button id=\"runScriptBtn\">Run Script</button>\n      <button id=\"stopScriptBtn\">Stop Script</button>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Views</h3>\n    <div>\n      Array view (click element to select): <span id=\"arrayView\"></span>\n    </div>\n    <div>\n      Tree view (levels): <pre id=\"treeView\"></pre>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <h3>Logs & History</h3>\n    <div>\n      <textarea id=\"logArea\" rows=\"10\" cols=\"120\" readonly></textarea>\n    </div>\n    <div>\n      History snapshots: <select id=\"historySelect\"></select>\n      <button id=\"goToHistoryBtn\">Go To</button>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // Core data\n  let heap = []; // max-heap stored as array (0-based)\n  let comparisons = 0;\n  let swaps = 0;\n\n  // Playback and stepping\n  let playbackSteps = []; // array of {arr:[], info: string}\n  let currentStepIndex = -1;\n  let playTimer = null;\n  let playSpeed = 400;\n  let playMode = 'Idle';\n\n  // Undo/redo stack\n  let undoStack = [];\n  let redoStack = [];\n\n  // Click selection for manual swap\n  let clickSel = [];\n\n  // History snapshots\n  let history = [];\n\n  // Script runner\n  let scriptRunner = {running:false, commands:[], index:0};\n\n  // DOM elements\n  const arrayInput = document.getElementById('arrayInput');\n  const loadArrayBtn = document.getElementById('loadArrayBtn');\n  const randSize = document.getElementById('randSize');\n  const randMin = document.getElementById('randMin');\n  const randMax = document.getElementById('randMax');\n  const genRandomBtn = document.getElementById('genRandomBtn');\n\n  const buildHeapBtn = document.getElementById('buildHeapBtn');\n  const autoBuildBtn = document.getElementById('autoBuildBtn');\n  const playSpeedInput = document.getElementById('playSpeed');\n  const speedLabel = document.getElementById('speedLabel');\n\n  const insertVal = document.getElementById('insertVal');\n  const insertBtn = document.getElementById('insertBtn');\n  const autoInsertBtn = document.getElementById('autoInsertBtn');\n  const extractBtn = document.getElementById('extractBtn');\n  const autoExtractBtn = document.getElementById('autoExtractBtn');\n  const replaceVal = document.getElementById('replaceVal');\n  const replaceBtn = document.getElementById('replaceBtn');\n  const peekBtn = document.getElementById('peekBtn');\n  const bulkInsert = document.getElementById('bulkInsert');\n  const bulkInsertBtn = document.getElementById('bulkInsertBtn');\n\n  const statComparisons = document.getElementById('statComparisons');\n  const statSwaps = document.getElementById('statSwaps');\n\n  const selectedIndex = document.getElementById('selectedIndex');\n  const selectBtn = document.getElementById('selectBtn');\n  const siftDownBtn = document.getElementById('siftDownBtn');\n  const siftUpBtn = document.getElementById('siftUpBtn');\n  const siftDownFullBtn = document.getElementById('siftDownFullBtn');\n  const siftUpFullBtn = document.getElementById('siftUpFullBtn');\n  const swapWithIndex = document.getElementById('swapWithIndex');\n  const manualSwapBtn = document.getElementById('manualSwapBtn');\n  const autoFixBtn = document.getElementById('autoFixBtn');\n  const clearSelectionBtn = document.getElementById('clearSelectionBtn');\n  const clickSelectionSpan = document.getElementById('clickSelection');\n\n  const stepBackBtn = document.getElementById('stepBackBtn');\n  const stepForwardBtn = document.getElementById('stepForwardBtn');\n  const playBtn = document.getElementById('playBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const resetPlaybackBtn = document.getElementById('resetPlaybackBtn');\n  const currentStepSpan = document.getElementById('currentStep');\n  const totalStepsSpan = document.getElementById('totalSteps');\n  const playModeSpan = document.getElementById('playMode');\n\n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n  const snapshotBtn = document.getElementById('snapshotBtn');\n  const restoreSnapshotBtn = document.getElementById('restoreSnapshotBtn');\n\n  const scriptArea = document.getElementById('scriptArea');\n  const runScriptBtn = document.getElementById('runScriptBtn');\n  const stopScriptBtn = document.getElementById('stopScriptBtn');\n\n  const arrayView = document.getElementById('arrayView');\n  const treeView = document.getElementById('treeView');\n\n  const logArea = document.getElementById('logArea');\n  const historySelect = document.getElementById('historySelect');\n  const goToHistoryBtn = document.getElementById('goToHistoryBtn');\n\n  // Utility\n  function log(text){\n    const t = new Date().toISOString().split('T')[1].slice(0,12) + ' ' + text;\n    logArea.value = t + \"\\\\n\" + logArea.value;\n  }\n\n  function saveHistory(label){\n    const snap = {arr: heap.slice(), label: label || ('snapshot ' + (history.length+1)), comps: comparisons, swaps: swaps};\n    history.push(snap);\n    const opt = document.createElement('option');\n    opt.value = history.length-1;\n    opt.text = snap.label + ' (' + snap.arr.join(',') + ')';\n    historySelect.add(opt);\n    log('Saved snapshot: ' + opt.text);\n  }\n\n  function loadHistory(idx){\n    if (idx < 0 || idx >= history.length) return;\n    const snap = history[idx];\n    pushUndo(); // save current state for undo\n    heap = snap.arr.slice();\n    comparisons = snap.comps;\n    swaps = snap.swaps;\n    clearPlayback();\n    pushPlaybackSnapshot('Loaded history: ' + snap.label);\n    renderAll();\n    log('Loaded history: ' + snap.label);\n  }\n\n  function pushUndo(){\n    undoStack.push({arr: heap.slice(), comps: comparisons, swaps: swaps});\n    if (undoStack.length > 100) undoStack.shift();\n    redoStack = []; // clear redo on new action\n  }\n\n  function popUndo(){\n    if (undoStack.length === 0) return;\n    const st = undoStack.pop();\n    redoStack.push({arr: heap.slice(), comps: comparisons, swaps: swaps});\n    heap = st.arr.slice();\n    comparisons = st.comps;\n    swaps = st.swaps;\n    clearPlayback();\n    pushPlaybackSnapshot('Undo');\n    renderAll();\n    log('Undo performed');\n  }\n\n  function popRedo(){\n    if (redoStack.length === 0) return;\n    const st = redoStack.pop();\n    undoStack.push({arr: heap.slice(), comps: comparisons, swaps: swaps});\n    heap = st.arr.slice();\n    comparisons = st.comps;\n    swaps = st.swaps;\n    clearPlayback();\n    pushPlaybackSnapshot('Redo');\n    renderAll();\n    log('Redo performed');\n  }\n\n  function pushPlaybackSnapshot(info){\n    playbackSteps.push({arr: heap.slice(), info: info});\n    totalStepsSpan.textContent = playbackSteps.length;\n  }\n\n  function clearPlayback(){\n    playbackSteps = [];\n    currentStepIndex = -1;\n    updatePlaybackUI();\n  }\n\n  function updatePlaybackUI(){\n    currentStepSpan.textContent = Math.max(0, currentStepIndex+1);\n    totalStepsSpan.textContent = playbackSteps.length;\n    playModeSpan.textContent = playMode;\n  }\n\n  function renderArrayView(){\n    arrayView.innerHTML = '';\n    heap.forEach((v,i)=>{\n      const btn = document.createElement('button');\n      btn.textContent = '['+i+'] '+v;\n      btn.onclick = ()=>{\n        handleArrayClick(i);\n      };\n      arrayView.appendChild(btn);\n      arrayView.appendChild(document.createTextNode(' '));\n    });\n  }\n\n  function renderTreeView(){\n    // Simple level rows\n    let lines = [];\n    for (let i=0;i<heap.length;i++){\n      const level = Math.floor(Math.log2(i+1));\n      if (!lines[level]) lines[level] = [];\n      lines[level].push('['+i+']:'+heap[i]);\n    }\n    treeView.textContent = lines.map((row,idx)=>('level '+idx+': '+row.join(' '))).join('\\\\n');\n  }\n\n  function renderAll(){\n    statComparisons.textContent = comparisons;\n    statSwaps.textContent = swaps;\n    renderArrayView();\n    renderTreeView();\n    updatePlaybackUI();\n  }\n\n  function parseArrayInput(text){\n    if (!text || text.trim().length===0) return [];\n    const tokens = text.split(/[,\\\\s]+/).filter(s=>s.length>0);\n    return tokens.map(s=>Number(s));\n  }\n\n  // Heap operations with step recording (we will record snapshots after each swap or assignment)\n  function heapifyBottomUp(recordSteps){\n    // Build heap in-place: start from last parent down to 0\n    if (recordSteps) pushUndo();\n    let N = heap.length;\n    for (let i = Math.floor((N-2)/2); i>=0; i--){\n      siftDown(i, N, recordSteps);\n    }\n    if (recordSteps) {\n      pushPlaybackSnapshot('Heapify complete');\n      saveHistory('heapify');\n      log('Heap built with bottom-up heapify');\n    }\n  }\n\n  function siftDown(i, N, recordSteps){\n    // Sift-down starting at index i, stop at N (length)\n    while (true){\n      let left = 2*i+1, right = 2*i+2;\n      let largest = i;\n      if (left < N){ comparisons++; if (heap[left] > heap[largest]) largest = left; if (recordSteps) pushPlaybackSnapshot('compare '+left+' > '+largest); }\n      if (right < N){ comparisons++; if (heap[right] > heap[largest]) largest = right; if (recordSteps) pushPlaybackSnapshot('compare '+right+' > '+largest); }\n      if (largest !== i){\n        swaps++;\n        [heap[i], heap[largest]] = [heap[largest], heap[i]];\n        if (recordSteps) pushPlaybackSnapshot('swap '+i+' <-> '+largest);\n        i = largest;\n      } else break;\n    }\n  }\n\n  function siftUp(i, recordSteps){\n    while (i > 0){\n      let parent = Math.floor((i-1)/2);\n      comparisons++;\n      if (heap[i] > heap[parent]){\n        swaps++;\n        [heap[i], heap[parent]] = [heap[parent], heap[i]];\n        if (recordSteps) pushPlaybackSnapshot('swap '+i+' <-> '+parent);\n        i = parent;\n      } else {\n        if (recordSteps) pushPlaybackSnapshot('compare stop at '+i);\n        break;\n      }\n    }\n  }\n\n  function insertValue(val, recordSteps){\n    if (recordSteps) pushUndo();\n    heap.push(val);\n    if (recordSteps) pushPlaybackSnapshot('insert '+val+' at index '+(heap.length-1));\n    siftUp(heap.length-1, recordSteps);\n    if (recordSteps) {\n      pushPlaybackSnapshot('insert complete');\n      saveHistory('insert '+val);\n      log('Inserted ' + val);\n    }\n  }\n\n  function extractMaxOp(recordSteps){\n    if (heap.length === 0) { log('extract on empty heap'); return null; }\n    if (recordSteps) pushUndo();\n    const max = heap[0];\n    swaps++;\n    [heap[0], heap[heap.length-1]] = [heap[heap.length-1], heap[0]];\n    if (recordSteps) pushPlaybackSnapshot('swap root with last');\n    heap.pop();\n    if (recordSteps) pushPlaybackSnapshot('pop last, now sift down root');\n    siftDown(0, heap.length, recordSteps);\n    if (recordSteps) {\n      pushPlaybackSnapshot('extract complete: '+max);\n      saveHistory('extract '+max);\n      log('Extracted max ' + max);\n    }\n    return max;\n  }\n\n  function replaceRoot(val, recordSteps){\n    if (heap.length === 0){\n      insertValue(val, recordSteps);\n      return;\n    }\n    if (recordSteps) pushUndo();\n    heap[0] = val;\n    if (recordSteps) pushPlaybackSnapshot('replace root with '+val);\n    siftDown(0, heap.length, recordSteps);\n    if (recordSteps) {\n      pushPlaybackSnapshot('replace complete');\n      saveHistory('replace '+val);\n      log('Replaced root with ' + val);\n    }\n  }\n\n  // Manual algorithms for single-step control\n  function manualSiftDownOne(useSelected){\n    let i = useSelected ? Number(selectedIndex.value) : 0;\n    if (i < 0 || i >= heap.length) { log('siftDown: invalid index'); return; }\n    pushUndo();\n    let left = 2*i+1, right = 2*i+2;\n    let largest = i;\n    if (left < heap.length) { comparisons++; if (heap[left] > heap[largest]) largest = left; }\n    if (right < heap.length) { comparisons++; if (heap[right] > heap[largest]) largest = right; }\n    if (largest !== i){\n      swaps++;\n      [heap[i], heap[largest]] = [heap[largest], heap[i]];\n      pushPlaybackSnapshot('manual swap '+i+' <-> '+largest);\n      log('Manual siftDown: swapped '+i+' and '+largest);\n    } else {\n      pushPlaybackSnapshot('manual siftDown: no swap at '+i);\n      log('Manual siftDown: no swap needed at '+i);\n    }\n    renderAll();\n  }\n\n  function manualSiftUpOne(useSelected){\n    let i = useSelected ? Number(selectedIndex.value) : heap.length-1;\n    if (i < 0 || i >= heap.length) { log('siftUp: invalid index'); return; }\n    pushUndo();\n    if (i === 0) { pushPlaybackSnapshot('manual siftUp: at root'); return; }\n    let parent = Math.floor((i-1)/2);\n    comparisons++;\n    if (heap[i] > heap[parent]){\n      swaps++;\n      [heap[i], heap[parent]] = [heap[parent], heap[i]];\n      pushPlaybackSnapshot('manual swap '+i+' <-> '+parent);\n      log('Manual siftUp: swapped '+i+' and '+parent);\n    } else {\n      pushPlaybackSnapshot('manual siftUp: compare stop at '+i);\n      log('Manual siftUp: no swap needed at '+i);\n    }\n    renderAll();\n  }\n\n  function manualSwap(i,j){\n    if (i<0 || j<0 || i>=heap.length || j>=heap.length) { log('manual swap invalid indices'); return; }\n    pushUndo();\n    swaps++;\n    [heap[i], heap[j]] = [heap[j], heap[i]];\n    pushPlaybackSnapshot('manual swap '+i+' <-> '+j);\n    renderAll();\n    log('Manually swapped '+i+' and '+j);\n  }\n\n  function autoFixEntireHeap(){\n    pushUndo();\n    // naive approach: repeatedly ensure each parent is >= children by sifting down each parent from last to first\n    for (let i = Math.floor((heap.length-2)/2); i>=0; i--){\n      siftDown(i, heap.length, true);\n    }\n    pushPlaybackSnapshot('Auto fix entire heap');\n    saveHistory('autoFix');\n    renderAll();\n    log('Auto-fixed entire heap');\n  }\n\n  // Playback control\n  function goToStep(idx){\n    if (idx < 0) idx = 0;\n    if (idx >= playbackSteps.length) idx = playbackSteps.length-1;\n    if (playbackSteps.length === 0) return;\n    currentStepIndex = idx;\n    const snap = playbackSteps[currentStepIndex];\n    heap = snap.arr.slice();\n    updatePlaybackUI();\n    renderAll();\n    log('Playback step '+(currentStepIndex+1)+': '+snap.info);\n  }\n\n  function stepForward(){\n    if (currentStepIndex+1 < playbackSteps.length){\n      goToStep(currentStepIndex+1);\n    } else {\n      log('Already at last playback step');\n    }\n  }\n\n  function stepBack(){\n    if (currentStepIndex-1 >= 0){\n      goToStep(currentStepIndex-1);\n    } else {\n      log('Already at first playback step');\n    }\n  }\n\n  function play(){\n    if (playTimer) clearInterval(playTimer);\n    playMode = 'Playing';\n    updatePlaybackUI();\n    playTimer = setInterval(()=>{\n      if (currentStepIndex+1 < playbackSteps.length){\n        stepForward();\n      } else {\n        pause();\n      }\n    }, playSpeed);\n  }\n\n  function pause(){\n    if (playTimer) clearInterval(playTimer);\n    playTimer = null;\n    playMode = 'Idle';\n    updatePlaybackUI();\n  }\n\n  // Higher-level UX wrappers that build playbackSteps\n  function recordHeapifyAndStartPlayback(){\n    // Build playbackSteps by performing heapify on a copy and recording states\n    playbackSteps = [];\n    const arrCopy = heap.slice();\n    const compsBefore = comparisons;\n    const swapsBefore = swaps;\n    // We'll operate on the actual heap but record snapshots, then restore final state\n    // Save current state for undo\n    pushUndo();\n    // Perform heapify with recordSteps true\n    heapifyBottomUp(true);\n    // playbackSteps contain intermediate states; set current step to 0\n    currentStepIndex = -1;\n    updatePlaybackUI();\n    renderAll();\n    log('Recorded heapify steps: ' + playbackSteps.length);\n  }\n\n  function recordInsertAndStartPlayback(val){\n    playbackSteps = [];\n    pushUndo();\n    insertValue(val, true);\n    currentStepIndex = -1;\n    updatePlaybackUI();\n    renderAll();\n    log('Recorded insert steps: ' + playbackSteps.length);\n  }\n\n  function recordExtractAndStartPlayback(){\n    playbackSteps = [];\n    pushUndo();\n    extractMaxOp(true);\n    currentStepIndex = -1;\n    updatePlaybackUI();\n    renderAll();\n    log('Recorded extract steps: ' + playbackSteps.length);\n  }\n\n  // Script runner\n  function parseAndRunScript(text){\n    if (scriptRunner.running) { log('Script already running'); return; }\n    const lines = text.split('\\\\n').map(l=>l.trim()).filter(l=>l.length>0);\n    scriptRunner.commands = lines;\n    scriptRunner.index = 0;\n    scriptRunner.running = true;\n    log('Script started ('+lines.length+' commands)');\n    runNextScriptCommand();\n  }\n\n  function runNextScriptCommand(){\n    if (!scriptRunner.running) return;\n    if (scriptRunner.index >= scriptRunner.commands.length){\n      scriptRunner.running = false;\n      log('Script finished');\n      return;\n    }\n    const line = scriptRunner.commands[scriptRunner.index++];\n    log('Script command: '+line);\n    const parts = line.split(/\\\\s+/);\n    const cmd = parts[0].toLowerCase();\n    if (cmd === 'build'){\n      recordHeapifyAndStartPlayback();\n      // Play the recording automatically\n      play();\n      // Wait until playback done then continue\n      waitUntilPlaybackDone(runNextScriptCommand);\n    } else if (cmd === 'insert'){\n      const v = Number(parts[1]);\n      recordInsertAndStartPlayback(v);\n      play();\n      waitUntilPlaybackDone(runNextScriptCommand);\n    } else if (cmd === 'extract'){\n      recordExtractAndStartPlayback();\n      play();\n      waitUntilPlaybackDone(runNextScriptCommand);\n    } else if (cmd === 'replace'){\n      const v = Number(parts[1]);\n      pushUndo();\n      replaceRoot(v, false);\n      pushPlaybackSnapshot('script replace '+v);\n      renderAll();\n      runNextScriptCommand();\n    } else if (cmd === 'peek'){\n      log('Peek: ' + (heap.length>0 ? heap[0] : 'empty'));\n      runNextScriptCommand();\n    } else if (cmd === 'wait'){\n      const ms = Number(parts[1]) || 500;\n      setTimeout(runNextScriptCommand, ms);\n    } else if (cmd === 'swap'){\n      const i = Number(parts[1]), j = Number(parts[2]);\n      manualSwap(i,j);\n      runNextScriptCommand();\n    } else if (cmd === 'siftdown'){\n      const i = Number(parts[1]);\n      pushUndo();\n      siftDown(i, heap.length, true);\n      runNextScriptCommand();\n    } else if (cmd === 'siftup'){\n      const i = Number(parts[1]);\n      pushUndo();\n      siftUp(i, true);\n      runNextScriptCommand();\n    } else if (cmd === 'load'){\n      const arr = parseArrayInput(parts.slice(1).join(' '));\n      pushUndo();\n      heap = arr.slice();\n      clearPlayback();\n      pushPlaybackSnapshot('script load array');\n      renderAll();\n      runNextScriptCommand();\n    } else {\n      log('Unknown script command: '+cmd);\n      runNextScriptCommand();\n    }\n  }\n\n  function waitUntilPlaybackDone(cb){\n    // Poll until playbackSteps exhausted or playback idle\n    const check = ()=>{\n      if (!scriptRunner.running) return; // if stopped manually\n      if (!playTimer && currentStepIndex >= playbackSteps.length-1){\n        // done\n        cb();\n      } else {\n        setTimeout(check, 100);\n      }\n    };\n    check();\n  }\n\n  function stopScript(){\n    scriptRunner.running = false;\n    log('Script stopped');\n  }\n\n  // Click handlers\n  function handleArrayClick(i){\n    // toggle selection\n    const idx = clickSel.indexOf(i);\n    if (idx === -1) clickSel.push(i); else clickSel.splice(idx,1);\n    clickSelectionSpan.textContent = clickSel.length>0 ? clickSel.join(',') : 'none';\n    if (clickSel.length === 2){\n      // auto swap if two selected\n      manualSwap(clickSel[0], clickSel[1]);\n      clickSel = [];\n      clickSelectionSpan.textContent = 'none';\n    }\n  }\n\n  //