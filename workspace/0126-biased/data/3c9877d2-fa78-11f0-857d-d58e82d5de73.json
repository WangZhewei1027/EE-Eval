    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Sliding Window Concept - Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n\n  /* Root and Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0; background: linear-gradient(135deg, #1f2937, #3b82f6);\n    color: #e0e7ff;\n    font-family: 'Poppins', sans-serif;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  .container {\n    max-width: 860px;\n    margin: 3rem auto 4rem;\n    padding: 0 1.5rem;\n    text-align: center;\n    filter: drop-shadow(0 0 10px rgba(59, 130, 246, 0.5));\n  }\n\n  /* Title */\n  h1 {\n    font-weight: 600;\n    font-size: 3rem;\n    line-height: 1.15;\n    letter-spacing: -0.03em;\n    margin-bottom: 0.25em;\n    color: #bbdefb;\n    text-shadow:\n      0 0 5px #60a5fa,\n      0 0 15px #93c5fd,\n      0 0 25px #3b82f6;\n  }\n\n  /* Subtitle */\n  .subtitle {\n    font-weight: 400;\n    font-size: 1.1rem;\n    color: #a5b4fc;\n    margin-bottom: 3rem;\n    letter-spacing: 0.03em;\n  }\n\n  /* The window frame */\n  .array-and-window {\n    position: relative;\n    display: flex;\n    justify-content: center;\n    gap: 1.25rem;\n    perspective: 1200px;\n  }\n\n  /* Array slots */\n  .slot {\n    flex: 0 0 60px;\n    height: 85px;\n    border-radius: 0.75rem;\n    background: linear-gradient(145deg, #415a77, #1f2937);\n    box-shadow: inset 0 0 8px #94a3b8;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 1.85rem;\n    font-weight: 600;\n    color: #cbd5e1;\n    user-select: none;\n    position: relative;\n    transition:\n      background-color 0.45s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1),\n      transform 0.65s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .slot::before {\n    content: attr(data-index);\n    position: absolute;\n    top: 6px;\n    right: 8px;\n    font-size: 0.65rem;\n    color: #7c8db5;\n    font-weight: 600;\n    font-feature-settings: \"tnum\";\n    user-select: none;\n    letter-spacing: 0.03em;\n  }\n\n  /* Highlighted window slots */\n  .slot.in-window {\n    background: linear-gradient(135deg, #60a5fa, #2563eb);\n    box-shadow:\n      0 0 8px 2px #3b82f6,\n      inset 0 2px 5px #93c5fd,\n      0 10px 15px rgba(59, 130, 246, 0.4);\n    color: #ecfeff;\n    transform: scale(1.1) translateZ(40px);\n    z-index: 2;\n  }\n\n  /* Window overlay */\n  .window-overlay {\n    position: absolute;\n    top: -24px;\n    height: 130px;\n    left: 0;\n    border-radius: 1.25rem;\n    border: 3.8px solid #60a5fa;\n    box-shadow:\n      0 0 25px #3b82f6aa,\n      0 0 50px #93c5fdbb;\n    pointer-events: none;\n    transition:\n      left 1s cubic-bezier(0.4, 0, 0.2, 1),\n      width 1s cubic-bezier(0.4, 0, 0.2, 1);\n    will-change: left, width;\n    user-select: none;\n  }\n\n  /* Controls */\n  .controls {\n    margin-top: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n\n  button {\n    background: #1e40af;\n    color: #dbeafe;\n    font-weight: 600;\n    font-size: 1.1rem;\n    border: none;\n    border-radius: 0.75rem;\n    padding: 0.55rem 2.1rem;\n    cursor: pointer;\n    box-shadow:\n      0 3px 10px #1e40af88,\n      0 0 10px #3b82f622;\n    transition:\n      background-color 0.55s ease,\n      box-shadow 0.5s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: #3b82f6;\n    box-shadow:\n      0 6px 20px #3b82f6aa,\n      0 0 18px #60a5fa;\n    outline: none;\n    transform: translateY(-3px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow:\n      0 2px 7px #2563ebbb,\n      0 0 10px #3b82f6cc;\n  }\n\n  /* Info Box */\n  .info-box {\n    margin-top: 3.5rem;\n    font-size: 1.15rem;\n    background: rgba(15, 23, 42, 0.72);\n    padding: 1.5rem 2rem;\n    border-radius: 1rem;\n    box-shadow:\n      inset 0 0 25px #2563eb66,\n      0 0 30px #3b82f6aa;\n    max-width: 620px;\n    margin-left: auto;\n    margin-right: auto;\n    line-height: 1.5;\n    color: #cbd5e1;\n    user-select: none;\n  }\n  .info-box strong {\n    color: #93c5fd;\n  }\n\n  /* Subtle floating glow on background behind slots */\n  .floating-glow {\n    position: absolute;\n    top: -60px; left: 50%;\n    width: 480px; height: 160px;\n    background:\n      radial-gradient(ellipse 120px 60px at 50% 50%, #3b82f6bb, transparent 80%);\n    transform: translateX(-50%);\n    filter: blur(38px);\n    pointer-events: none;\n    user-select: none;\n  }\n\n  /* Footer with subtle branding */\n  footer {\n    text-align: center;\n    font-size: 0.9rem;\n    color: #94a3b8;\n    margin-top: 6rem;\n    letter-spacing: 0.04em;\n  }\n\n</style>\n</head>\n<body>\n  <main class=\"container\" aria-label=\"Sliding Window Visualization Concept\">\n    <h1>Sliding Window</h1>\n    <p class=\"subtitle\">Visualizing the Sliding Window technique with smooth, elegant animation</p>\n\n    <div class=\"array-and-window\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"all\" aria-label=\"Array with sliding window highlight\">\n      <!-- array slots generated by JS -->\n      <div class=\"window-overlay\"></div>\n      <div class=\"floating-glow\" aria-hidden=\"true\"></div>\n    </div>\n\n    <div class=\"controls\" aria-label=\"Sliding window controls\">\n      <button id=\"prevBtn\" aria-label=\"Move window to previous position\" type=\"button\" disabled>← Previous</button>\n      <button id=\"nextBtn\" aria-label=\"Move window to next position\" type=\"button\">Next →</button>\n    </div>\n\n    <section class=\"info-box\" aria-live=\"polite\" aria-atomic=\"true\" aria-label=\"Explanation of the sliding window step\">\n      The <strong>sliding window</strong> is a technique often used to traverse or analyze a subset (window)\n      of elements in a larger data structure (like an array). Here, the window moves smoothly over the array,\n      highlighting a fixed-size range of elements each step.\n    </section>\n  </main>\n\n<script>\n  (() => {\n    const container = document.querySelector('.array-and-window');\n    const windowOverlay = container.querySelector('.window-overlay');\n    const prevBtn = document.getElementById('prevBtn');\n    const nextBtn = document.getElementById('nextBtn');\n    const infoBox = document.querySelector('.info-box');\n\n    // Define the array and window size\n    const arrayValues = [7, 2, 9, 4, 5, 8, 3, 6, 1, 0, 11, 13];\n    const windowSize = 4;\n    let position = 0;\n\n    // Create slots\n    const slots = [];\n    for (let i = 0; i < arrayValues.length; i++) {\n      const slot = document.createElement('div');\n      slot.classList.add('slot');\n      slot.textContent = arrayValues[i];\n      slot.dataset.index = i;\n      container.appendChild(slot);\n      slots.push(slot);\n    }\n\n    // Compute slot left offset relative to container\n    function getSlotPositions() {\n      return slots.map(s => s.getBoundingClientRect().left);\n    }\n    // We use positioning relative to container:\n    // container left offset + slots offsets\n\n    // Update window highlight and overlay\n    function updateWindow(pos) {\n      // Clamp pos\n      position = Math.min(Math.max(pos, 0), arrayValues.length - windowSize);\n\n      // Highlight slots inside window\n      slots.forEach((slot, i) => {\n        if (i >= position && i < position + windowSize) {\n          slot.classList.add('in-window');\n        } else {\n          slot.classList.remove('in-window');\n        }\n      });\n\n      // Calculate overlay position & width relative to container\n      const firstSlot = slots[position];\n      const lastSlot = slots[position + windowSize - 1];\n\n      const containerRect = container.getBoundingClientRect();\n      const firstRect = firstSlot.getBoundingClientRect();\n      const lastRect = lastSlot.getBoundingClientRect();\n\n      const leftPx = firstRect.left - containerRect.left - 6; // 6px padding inside overlay\n      const rightPx = lastRect.right - containerRect.left + 6;\n\n      const widthPx = rightPx - leftPx;\n\n      windowOverlay.style.left = `${leftPx}px`;\n      windowOverlay.style.width = `${widthPx}px`;\n\n      // Update buttons enabled state\n      prevBtn.disabled = position === 0;\n      nextBtn.disabled = position === arrayValues.length - windowSize;\n\n      // Update info text with subtle fade\n      infoBox.style.opacity = '0';\n      setTimeout(() => {\n        infoBox.textContent = `Window covering indices [${position} ... ${position + windowSize - 1}]: [${arrayValues.slice(position, position + windowSize).join(', ')}]`;\n        infoBox.style.opacity = '1';\n      }, 420);\n    }\n\n    // Initialize overlay invisibly for smoother first update\n    windowOverlay.style.opacity = '0';\n\n    window.addEventListener('load', () => {\n      updateWindow(position);\n      // Fade in overlay after first position set\n      setTimeout(() => {\n        windowOverlay.style.opacity = '1';\n      }, 400);\n    });\n\n    // Button interactions\n    prevBtn.addEventListener('click', () => {\n      if (position > 0) {\n        updateWindow(position - 1);\n      }\n    });\n    nextBtn.addEventListener('click', () => {\n      if (position < arrayValues.length - windowSize) {\n        updateWindow(position + 1);\n      }\n    });\n\n    // Keyboard accessibility for buttons (Enter / Space triggers click)\n    [prevBtn, nextBtn].forEach(btn => {\n      btn.addEventListener('keyup', (e) => {\n        if (e.key === 'Enter' || e.key === ' ') {\n          e.preventDefault();\n          btn.click();\n        }\n      });\n    });\n  })();\n</script>\n</body>\n</html>"
