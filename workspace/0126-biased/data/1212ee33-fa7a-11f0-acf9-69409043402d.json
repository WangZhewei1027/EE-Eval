  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Tree Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre;\n    margin: 0.5em;\n  }\n  input[type=number] {\n    width: 5em;\n  }\n  button, input, select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  #treeDisplay {\n    line-height: 1.2em;\n    font-size: 1em;\n    margin-top: 1em;\n  }\n  #controls {\n    max-width: 80ch;\n  }\n  #pathDisplay {\n    margin-top: 1em;\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n\n<h1>Binary Tree Interactive Demo</h1>\n\n<div id=\"controls\">\n  <fieldset>\n    <legend>Create / Reset Tree</legend>\n    <label>Root Value: <input type=\"number\" id=\"rootValue\" value=\"10\" /></label>\n    <button id=\"createTreeBtn\">Create Root Node</button>\n    <button id=\"clearTreeBtn\">Clear Tree</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Insert Node</legend>\n    <label>Value: <input type=\"number\" id=\"insertValue\" /></label>\n    <label>Insert Path: <input type=\"text\" id=\"insertPath\" placeholder=\"L or R sequence, e.g. LR\" /></label>\n    <button id=\"insertBtn\">Insert Node at Path</button>\n    <div><small>Path is sequence of L or R from root to target parent. Inserted as child at last step (replace if exists).</small></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Delete Node</legend>\n    <label>Delete Path: <input type=\"text\" id=\"deletePath\" placeholder=\"L or R, e.g. RL\" /></label>\n    <button id=\"deleteBtn\">Delete Node at Path</button>\n    <div><small>Deleting a node removes entire subtree at that node.</small></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Find Node</legend>\n    <label>Search Value: <input type=\"number\" id=\"searchValue\" /></label>\n    <button id=\"searchBtn\">Search Value</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Traversal Controls</legend>\n    <label>Traversal Type: \n      <select id=\"traversalType\">\n        <option value=\"inorder\">Inorder</option>\n        <option value=\"preorder\">Preorder</option>\n        <option value=\"postorder\">Postorder</option>\n        <option value=\"levelorder\">Level-order</option>\n      </select>\n    </label>\n    <button id=\"traverseBtn\">Traverse Tree</button>\n    <label>Traversal Step: <input type=\"range\" id=\"traversalStep\" min=\"0\" max=\"0\" value=\"0\" /></label>\n    <button id=\"prevStepBtn\">&lt; Prev</button>\n    <button id=\"nextStepBtn\">Next &gt;</button>\n    <div>Current Node: <span id=\"currentNodeDisplay\">N/A</span></div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Tree Height & Balance</legend>\n    <button id=\"heightBtn\">Compute Height</button>\n    <span id=\"heightDisplay\"></span>\n    <button id=\"balanceCheckBtn\">Check if Balanced</button>\n    <span id=\"balanceDisplay\"></span>\n  </fieldset>\n\n  <fieldset>\n    <legend>Path Exploration</legend>\n    <label>Explore Path (L/R): <input type=\"text\" id=\"explorePath\" placeholder=\"e.g. LRRL\" /></label>\n    <button id=\"exploreBtn\">Show Node Details</button>\n    <div id=\"pathDisplay\"></div>\n  </fieldset>\n\n</div>\n\n<pre id=\"treeDisplay\"></pre>\n\n<script>\n(function(){\n  // Node constructor\n  function TreeNode(value) {\n    this.value = value;\n    this.left = null;\n    this.right = null;\n  }\n\n  // Binary Tree object\n  var binaryTree = {\n    root: null\n  };\n\n  // Utility: Validate path string (only L,R upper or lower)\n  function validatePath(path) {\n    return /^[LRlr]*$/.test(path);\n  }\n\n  // Traverse to node by path, optionally create missing intermediate nodes if specified\n  function getNodeByPath(root, path, createMissing, newValue) {\n    if (!root) return null;\n    var node = root;\n    for (var i=0; i<path.length; i++) {\n      var c = path[i].toUpperCase();\n      if (c === 'L') {\n        if (!node.left) {\n          if (createMissing) node.left = (i === path.length - 1 && newValue !== undefined) ? new TreeNode(newValue) : new TreeNode(null);\n          else return null;\n        }\n        node = node.left;\n      } else if (c === 'R') {\n        if (!node.right) {\n          if (createMissing) node.right = (i === path.length - 1 && newValue !== undefined) ? new TreeNode(newValue) : new TreeNode(null);\n          else return null;\n        }\n        node = node.right;\n      } else {\n        return null;\n      }\n    }\n    return node;\n  }\n\n  // Insert node at path relative to root\n  // The path is to the parent: the last character indicates left or right child to place new node\n  // If path empty, replace root\n  function insertAtPath(tree, path, value) {\n    if (path === '') {\n      tree.root = new TreeNode(value);\n      return true;\n    }\n    var parentPath = path.slice(0,-1);\n    var direction = path[path.length - 1].toUpperCase();\n    if (!validatePath(parentPath)) return false;\n    var parent = getNodeByPath(tree.root, parentPath, false);\n    if (!parent) return false;\n    if (direction === 'L') {\n      parent.left = new TreeNode(value);\n    } else if (direction === 'R') {\n      parent.right = new TreeNode(value);\n    } else {\n      return false;\n    }\n    return true;\n  }\n\n  // Delete node (and subtree) at given path\n  // If empty path delete root\n  function deleteAtPath(tree, path) {\n    if (path === '') {\n      tree.root = null;\n      return true;\n    }\n    var parentPath = path.slice(0,-1);\n    var direction = path[path.length-1].toUpperCase();\n    if (!validatePath(parentPath)) return false;\n    var parent = getNodeByPath(tree.root, parentPath, false);\n    if (!parent) return false;\n    if (direction === 'L') {\n      parent.left = null;\n    } else if (direction === 'R') {\n      parent.right = null;\n    } else {\n      return false;\n    }\n    return true;\n  }\n\n  // Search value in tree, returning array of paths where found (multiple possible)\n  function searchValue(root, value) {\n    var results = [];\n    function dfs(node, path) {\n      if (!node) return;\n      if (node.value === value) results.push(path);\n      dfs(node.left, path + 'L');\n      dfs(node.right, path + 'R');\n    }\n    dfs(root, '');\n    return results;\n  }\n\n  // Traversals returning array of node and path in order\n  // Node info: {node, path}\n  function traverse(root, type) {\n    var result = [];\n    if (!root) return result;\n\n    if (type === 'inorder') {\n      function inorder(n, p) {\n        if (!n) return;\n        inorder(n.left, p+'L');\n        result.push({node: n, path: p});\n        inorder(n.right, p+'R');\n      }\n      inorder(root,'');\n    } else if (type === 'preorder') {\n      function preorder(n, p) {\n        if (!n) return;\n        result.push({node: n, path: p});\n        preorder(n.left, p+'L');\n        preorder(n.right, p+'R');\n      }\n      preorder(root,'');\n    } else if (type === 'postorder') {\n      function postorder(n, p) {\n        if (!n) return;\n        postorder(n.left, p+'L');\n        postorder(n.right, p+'R');\n        result.push({node: n, path: p});\n      }\n      postorder(root,'');\n    } else if (type === 'levelorder') {\n      var queue = [{node: root, path: ''}];\n      while(queue.length) {\n        var cur = queue.shift();\n        result.push(cur);\n        if (cur.node.left) queue.push({node: cur.node.left, path: cur.path + 'L'});\n        if (cur.node.right) queue.push({node: cur.node.right, path: cur.path + 'R'});\n      }\n    }\n    return result;\n  }\n\n  // Compute height of tree (null = 0, leaf = 1)\n  function height(node) {\n    if (!node) return 0;\n    return 1 + Math.max(height(node.left), height(node.right));\n  }\n\n  // Check if height balanced (difference left-right height <= 1 for all nodes)\n  // Return {balanced:bool, reason:string|null}\n  function checkBalanced(node) {\n    var balanced = true;\n    var reason = null;\n    function helper(n) {\n      if (!n) return 0;\n      var hl = helper(n.left);\n      var hr = helper(n.right);\n      if (Math.abs(hl - hr) > 1) {\n        balanced = false;\n        reason = 'Imbalance at node with value ' + n.value + ', left height = '+hl+', right height = '+hr;\n      }\n      return 1 + Math.max(hl, hr);\n    }\n    helper(node);\n    return {balanced: balanced, reason: reason};\n  }\n\n  // Pretty-print the tree as text, rotated -90 deg:\n  // Display rotated tree with root on left, right subtree on top, left subtree on bottom\n  // Widely used method printing right subtree first with indentation\n  function printTreeText(node) {\n    var lines = [];\n    function buildLines(n, prefix, isLeft) {\n      if (n === null) {\n        lines.push(prefix + (isLeft ? \"└── \" : \"┌── \") + \"[null]\");\n        return;\n      }\n      if (!n.left && !n.right) {\n        lines.push(prefix + (isLeft ? \"└── \" : \"┌── \") + String(n.value));\n        return;\n      }\n      if (n.right) {\n        buildLines(n.right, prefix + (isLeft ? \"    \" : \"│   \"), false);\n      } else {\n        lines.push(prefix + (isLeft ? \"    \" : \"│   \") + \"┌── [null]\");\n      }\n      lines.push(prefix + (isLeft ? \"└── \" : \"┌── \") + String(n.value));\n      if (n.left) {\n        buildLines(n.left, prefix + (isLeft ? \"    \" : \"│   \"), true);\n      } else {\n        lines.push(prefix + (isLeft ? \"    \" : \"│   \") + \"└── [null]\");\n      }\n    }\n    if (!node) return \"[empty tree]\";\n    buildLines(node, \"\", true);\n    return lines.join(\"\\n\");\n  }\n\n  // Display details about a single node (value, left,right existence)\n  function nodeDetails(node, path) {\n    if (!node) return \"No node found at path: \" + path;\n    var details = [];\n    details.push(\"Node at path: \" + (path === '' ? 'Root' : path));\n    details.push(\"Value: \" + node.value);\n    details.push(\"Has Left child: \" + (node.left ? \"Yes\" : \"No\"));\n    details.push(\"Has Right child: \" + (node.right ? \"Yes\" : \"No\"));\n    return details.join(\"\\n\");\n  }\n\n  // DOM elements\n  var rootValueInput = document.getElementById('rootValue');\n  var createTreeBtn = document.getElementById('createTreeBtn');\n  var clearTreeBtn = document.getElementById('clearTreeBtn');\n  var insertValueInput = document.getElementById('insertValue');\n  var insertPathInput = document.getElementById('insertPath');\n  var insertBtn = document.getElementById('insertBtn');\n  var deletePathInput = document.getElementById('deletePath');\n  var deleteBtn = document.getElementById('deleteBtn');\n  var searchValueInput = document.getElementById('searchValue');\n  var searchBtn = document.getElementById('searchBtn');\n  var traversalTypeSelect = document.getElementById('traversalType');\n  var traverseBtn = document.getElementById('traverseBtn');\n  var traversalStepRange = document.getElementById('traversalStep');\n  var prevStepBtn = document.getElementById('prevStepBtn');\n  var nextStepBtn = document.getElementById('nextStepBtn');\n  var currentNodeDisplay = document.getElementById('currentNodeDisplay');\n  var heightBtn = document.getElementById('heightBtn');\n  var heightDisplay = document.getElementById('heightDisplay');\n  var balanceCheckBtn = document.getElementById('balanceCheckBtn');\n  var balanceDisplay = document.getElementById('balanceDisplay');\n  var explorePathInput = document.getElementById('explorePath');\n  var exploreBtn = document.getElementById('exploreBtn');\n  var pathDisplay = document.getElementById('pathDisplay');\n  var treeDisplay = document.getElementById('treeDisplay');\n\n  // Current traversal state\n  var currentTraversal = [];\n  var currentStepIndex = -1;\n\n  // Update tree display\n  function updateTreeDisplay() {\n    treeDisplay.textContent = printTreeText(binaryTree.root);\n  }\n\n\n  // Clear all status/social spans\n  function clearStatus() {\n    heightDisplay.textContent = '';\n    balanceDisplay.textContent = '';\n    currentNodeDisplay.textContent = 'N/A';\n    pathDisplay.textContent = '';\n  }\n\n  // Event Handlers\n\n  createTreeBtn.onclick = function(){\n    var v = Number(rootValueInput.value);\n    if (isNaN(v)) {\n      alert(\"Root value must be a number.\");\n      return;\n    }\n    binaryTree.root = new TreeNode(v);\n    updateTreeDisplay();\n    clearStatus();\n    currentTraversal = [];\n    currentStepIndex = -1;\n    traversalStepRange.value = 0;\n    traversalStepRange.max = 0;\n  };\n\n  clearTreeBtn.onclick = function(){\n    binaryTree.root = null;\n    updateTreeDisplay();\n    clearStatus();\n    currentTraversal = [];\n    currentStepIndex = -1;\n    traversalStepRange.value = 0;\n    traversalStepRange.max = 0;\n  };\n\n  insertBtn.onclick = function(){\n    var val = Number(insertValueInput.value);\n    var path = insertPathInput.value.toUpperCase().trim();\n    if (isNaN(val)) {\n      alert(\"Insert value must be a number.\");\n      return;\n    }\n    if (!validatePath(path.slice(0, -1)) && path.length > 0) {\n      alert(\"Invalid path format. Use sequence of L and R only.\");\n      return;\n    }\n    if (path === '') {\n      // replace root\n      binaryTree.root = new TreeNode(val);\n      updateTreeDisplay();\n      clearStatus();\n      return;\n    }\n    if (!['L','R'].includes(path[path.length-1])) {\n      alert(\"Last character of path must be L or R (to specify left or right child).\");\n      return;\n    }\n    if (!binaryTree.root) {\n      alert(\"Tree is empty. Create root first.\");\n      return;\n    }\n    var success = insertAtPath(binaryTree, path, val);\n    if (!success) {\n      alert(\"Failed to insert: invalid path or no parent at path.\");\n      return;\n    }\n    updateTreeDisplay();\n    clearStatus();\n  };\n\n  deleteBtn.onclick = function(){\n    var path = deletePathInput.value.toUpperCase().trim();\n    if (path !== '' && !validatePath(path)) {\n      alert(\"Invalid path format. Use sequence of L and R only.\");\n      return;\n    }\n    if (!binaryTree.root) {\n      alert(\"Tree is empty.\");\n      return;\n    }\n    var success = deleteAtPath(binaryTree, path);\n    if (!success) {\n      alert(\"Failed to delete: invalid path or no parent at path.\");\n      return;\n    }\n    updateTreeDisplay();\n    clearStatus();\n  };\n\n  searchBtn.onclick = function(){\n    var val = Number(searchValueInput.value);\n    if (isNaN(val)) {\n      alert(\"Search value must be a number.\");\n      return;\n    }\n    if (!binaryTree.root) {\n      alert(\"Tree is empty.\");\n      return;\n    }\n    var foundPaths = searchValue(binaryTree.root, val);\n    if (foundPaths.length === 0) {\n      alert(\"Value not found in tree.\");\n      return;\n    }\n    alert(\"Value found at paths:\\n\" + foundPaths.map(p => p === '' ? 'Root' : p).join('\\n'));\n  };\n\n  traverseBtn.onclick = function(){\n    if (!binaryTree.root) {\n      alert(\"Tree is empty.\");\n      currentTraversal = [];\n      currentStepIndex = -1;\n      traversalStepRange.value = 0;\n      traversalStepRange.max = 0;\n      currentNodeDisplay.textContent = 'N/A';\n      return;\n    }\n    var type = traversalTypeSelect.value;\n    currentTraversal = traverse(binaryTree.root, type);\n    if (currentTraversal.length === 0) {\n      alert(\"Traversal yielded no nodes.\");\n      currentStepIndex = -1;\n      traversalStepRange.value = 0;\n      traversalStepRange.max = 0;\n      currentNodeDisplay.textContent = \"N/A\";\n      return;\n    }\n    currentStepIndex = 0;\n    traversalStepRange.max = currentTraversal.length - 1;\n    traversalStepRange.value = 0;\n    updateCurrentTraversalNode();\n  };\n\n  function updateCurrentTraversalNode() {\n    if (currentTraversal.length === 0 || currentStepIndex < 0 || currentStepIndex >= currentTraversal.length) {\n      currentNodeDisplay.textContent = \"N/A\";\n      traversalStepRange.value = 0;\n      return;\n    }\n    var entry = currentTraversal[currentStepIndex];\n    currentNodeDisplay.textContent = \"Value: \" + entry.node.value + \", Path: \" + (entry.path === '' ? 'Root' : entry.path);\n    traversalStepRange.value = currentStepIndex;\n  }\n\n  traversalStepRange.oninput = function() {\n    var step = Number(traversalStepRange.value);\n    if (step >= 0 && step < currentTraversal.length) {\n      currentStepIndex = step;\n      updateCurrentTraversalNode();\n    }\n  };\n\n  prevStepBtn.onclick = function(){\n    if (currentStepIndex > 0) {\n      currentStepIndex--;\n      updateCurrentTraversalNode();\n    }\n  };\n\n  nextStepBtn.onclick = function(){\n    if (currentStepIndex < currentTraversal.length - 1) {\n      currentStepIndex++;\n      updateCurrentTraversalNode();\n    }\n  };\n\n  heightBtn.onclick = function(){\n    if (!binaryTree.root) {\n      heightDisplay.textContent = \"Tree is empty.\";\n      return;\n    }\n    var h = height(binaryTree.root);\n    heightDisplay.textContent = \"Height: \" + h;\n  };\n\n  balanceCheckBtn.onclick = function(){\n    if (!binaryTree.root) {\n      balanceDisplay.textContent = \"Tree is empty.\";\n      return;\n    }\n    var res = checkBalanced(binaryTree.root);\n    if (res.balanced) {\n      balanceDisplay.textContent = \"Balanced: Yes\";\n    } else {\n      balanceDisplay.textContent = \"Balanced: No. \" + res.reason;\n    }\n  };\n\n  exploreBtn.onclick = function(){\n    var path = explorePathInput.value.toUpperCase().trim();\n    if (!validatePath(path)) {\n      alert(\"Invalid path format. Use sequence of L and R only or leave empty for root.\");\n      return;\n    }\n    if (!binaryTree.root) {\n      pathDisplay.textContent = \"Tree is empty.\";\n      return;\n    }\n    var node = getNodeByPath(binaryTree.root, path, false);\n    pathDisplay.textContent = nodeDetails(node, path);\n  };\n\n  // Init display empty\n  updateTreeDisplay();\n\n})();\n</script>\n\n</body>\n</html>"
  },
