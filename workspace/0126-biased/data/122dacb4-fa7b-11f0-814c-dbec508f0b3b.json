put\">\n    </div>\n    <script>\n        let inputs = document.querySelectorAll('input[type=\"text\"], input[type=\"number\"], select');\n        let outputs = document.querySelectorAll('input[type=\"text\"]');\n        let startButton = document.getElementById('compiler-start');\n        let stopButton = document.getElementById('compiler-stop');\n        let runButton = document.getElementById('compiler-run');\n        let quitButton = document.getElementById('compiler-quit');\n        let input1 = document.getElementById('input1');\n        let input2 = document.getElementById('input2');\n        let input3 = document.getElementById('input3');\n        let output1 = document.getElementById('output1');\n        let output2 = document.getElementById('output2');\n\n        function startCompiler() {\n            startButton.disabled = true;\n            stopButton.disabled = false;\n            runButton.disabled = false;\n            runButton.textContent = 'Stop Compiler';\n            runButton.style.backgroundColor = '#000';\n            runButton.style.color = '#fff';\n            runButton.style.cursor = 'pointer';\n            runButton.addEventListener('click', () => {\n                runButton.textContent = 'Run Compiler';\n                runButton.style.backgroundColor = '#fff';\n                runButton.style.color = '#000';\n                runButton.style.cursor = 'pointer';\n                inputs.forEach(input => input.disabled = true);\n                outputs.forEach(output => output.disabled = true);\n                inputs.forEach(input => input.value = '');\n                outputs.forEach(output => output.value = '');\n            });\n        }\n\n        function stopCompiler() {\n            stopButton.disabled = true;\n            startButton.disabled = false;\n            runButton.disabled = false;\n            runButton.textContent = 'Stop Compiler';\n            runButton.style.backgroundColor = '#000';\n            runButton.style.color = '#fff';\n            runButton.style.cursor = 'pointer';\n            runButton.addEventListener('click', () => {\n                stopButton.textContent = 'Start Compiler';\n                stopButton.style.backgroundColor = '#fff';\n                stopButton.style.color = '#000';\n                stopButton.style.cursor = 'pointer';\n                runButton.disabled = true;\n                startButton.disabled = false;\n                inputs.forEach(input => input.disabled = false);\n                outputs.forEach(output => output.disabled = false);\n                inputs.forEach(input => input.value = '');\n                outputs.forEach(output => output.value = '');\n            });\n        }\n\n        function runCompiler() {\n            startCompiler();\n        }\n\n        function quitCompiler() {\n            stopCompiler();\n        }\n\n        startButton.addEventListener('click', runCompiler);\n        stopButton.addEventListener('click', quitCompiler);\n        runButton.addEventListener('click', runCompiler);\n    </script>\n</body>\n</html>"
