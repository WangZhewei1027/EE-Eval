  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Directed Graph Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: #fff;\n    color: #000;\n  }\n  hr {\n    margin: 1em 0;\n  }\n  label {\n    display: inline-block;\n    margin-right: 0.5em;\n  }\n  input[type=\"number\"] {\n    width: 4em;\n  }\n  .section {\n    margin-bottom: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n  }\n  select {\n    width: 6em;\n  }\n  button {\n    margin-right: 0.5em;\n  }\n  #graphOutput {\n    white-space: pre;\n    font-family: monospace;\n    border: 1px solid #000;\n    padding: 0.5em;\n    height: 10em;\n    overflow: auto;\n  }\n  #pathResult {\n    white-space: pre;\n    font-family: monospace;\n    border: 1px solid #000;\n    padding: 0.5em;\n    max-height: 10em;\n    overflow: auto;\n  }\n</style>\n</head>\n<body>\n\n<h1>Directed Graph Interactive Explorer</h1>\n\n<div class=\"section\">\n  <h2>1. Graph Node and Edge Management</h2>\n\n  <div>\n    <label for=\"nodeInput\">Add Node Label:</label>\n    <input type=\"text\" id=\"nodeInput\" maxlength=\"20\" />\n    <button id=\"addNodeBtn\">Add Node</button>\n  </div>\n  <div>\n    <label for=\"nodeRemoveSelect\">Remove Node:</label>\n    <select id=\"nodeRemoveSelect\">\n      <option value=\"\">--No nodes--</option>\n    </select>\n    <button id=\"removeNodeBtn\">Remove Node</button>\n  </div>\n  <hr />\n  <div>\n    <label for=\"edgeFromSelect\">Add Edge From:</label>\n    <select id=\"edgeFromSelect\">\n      <option value=\"\">--Select--</option>\n    </select>\n    <label for=\"edgeToSelect\">To:</label>\n    <select id=\"edgeToSelect\">\n      <option value=\"\">--Select--</option>\n    </select>\n    <label for=\"edgeWeightInput\">Weight:</label>\n    <input type=\"number\" id=\"edgeWeightInput\" value=\"1\" step=\"1\" min=\"1\" max=\"999\" />\n    <button id=\"addEdgeBtn\">Add Edge</button>\n  </div>\n  <div>\n    <label for=\"edgeRemoveFromSelect\">Remove Edge From:</label>\n    <select id=\"edgeRemoveFromSelect\">\n      <option value=\"\">--Select--</option>\n    </select>\n    <label for=\"edgeRemoveToSelect\">To:</label>\n    <select id=\"edgeRemoveToSelect\">\n      <option value=\"\">--Select--</option>\n    </select>\n    <button id=\"removeEdgeBtn\">Remove Edge</button>\n  </div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <h2>2. Graph State and Visualization</h2>\n  <div>\n    <button id=\"showAdjListBtn\">Show Adjacency List</button>\n    <button id=\"showAdjMatrixBtn\">Show Adjacency Matrix</button>\n    <button id=\"showEdgesBtn\">Show Edge List</button>\n  </div>\n  <pre id=\"graphOutput\"></pre>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <h2>3. Graph Algorithms and Exploration</h2>\n\n  <div>\n    <label for=\"algorithmSelect\">Select Algorithm:</label>\n    <select id=\"algorithmSelect\">\n      <option value=\"bfs\">BFS (Breadth-First Search)</option>\n      <option value=\"dfs\">DFS (Depth-First Search)</option>\n      <option value=\"topo\">Topological Sort (if DAG)</option>\n      <option value=\"shortest\">Shortest Path (Dijkstra)</option>\n      <option value=\"detectCycle\">Cycle Detection</option>\n      <option value=\"allPaths\">All Paths (Between Two Nodes)</option>\n    </select>\n  </div>\n\n  <div id=\"algoNodeInputSection\" style=\"margin-top: 0.5em;\">\n    <label for=\"startNodeInput\">Start Node:</label>\n    <select id=\"startNodeInput\"></select>\n    <label for=\"endNodeInput\" style=\"margin-left: 1em; display:none;\">End Node:</label>\n    <select id=\"endNodeInput\" style=\"display:none;\"></select>\n  </div>\n\n  <div style=\"margin-top:0.5em;\">\n    <button id=\"runAlgorithmBtn\">Run Algorithm</button>\n    <button id=\"clearOutputBtn\">Clear Output</button>\n  </div>\n\n  <pre id=\"pathResult\"></pre>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <h2>4. Import / Export Graph</h2>\n  <div>\n    <label for=\"importArea\">Import Graph Data (JSON adjacency list):</label><br />\n    <textarea id=\"importArea\" placeholder='e.g. {\"A\":{\"B\":1,\"C\":2},\"B\":{\"C\":3},\"C\":{}}'></textarea><br />\n    <button id=\"importGraphBtn\">Import Graph</button>\n  </div>\n  <div style=\"margin-top: 0.5em;\">\n    <button id=\"exportGraphBtn\">Export Graph as JSON</button>\n  </div>\n  <pre id=\"exportArea\"></pre>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <h2>5. Graph Metrics</h2>\n  <button id=\"computeMetricsBtn\">Compute Metrics</button>\n  <pre id=\"metricsOutput\"></pre>\n</div>\n\n\n<script>\n(() => {\n  // Directed graph: adjacency list structure\n  // graph = { nodeLabel1: { neighborLabel1: weight, neighborLabel2: weight, ... }, ... }\n  let graph = {};\n\n  // Utility HTML elements references\n  const nodeInput = document.getElementById('nodeInput');\n  const addNodeBtn = document.getElementById('addNodeBtn');\n  const nodeRemoveSelect = document.getElementById('nodeRemoveSelect');\n  const removeNodeBtn = document.getElementById('removeNodeBtn');\n  const edgeFromSelect = document.getElementById('edgeFromSelect');\n  const edgeToSelect = document.getElementById('edgeToSelect');\n  const edgeWeightInput = document.getElementById('edgeWeightInput');\n  const addEdgeBtn = document.getElementById('addEdgeBtn');\n  const edgeRemoveFromSelect = document.getElementById('edgeRemoveFromSelect');\n  const edgeRemoveToSelect = document.getElementById('edgeRemoveToSelect');\n  const removeEdgeBtn = document.getElementById('removeEdgeBtn');\n\n  const showAdjListBtn = document.getElementById('showAdjListBtn');\n  const showAdjMatrixBtn = document.getElementById('showAdjMatrixBtn');\n  const showEdgesBtn = document.getElementById('showEdgesBtn');\n  const graphOutput = document.getElementById('graphOutput');\n\n  const algorithmSelect = document.getElementById('algorithmSelect');\n  const startNodeInput = document.getElementById('startNodeInput');\n  const endNodeInput = document.getElementById('endNodeInput');\n  const runAlgorithmBtn = document.getElementById('runAlgorithmBtn');\n  const pathResult = document.getElementById('pathResult');\n  const clearOutputBtn = document.getElementById('clearOutputBtn');\n\n  const importArea = document.getElementById('importArea');\n  const importGraphBtn = document.getElementById('importGraphBtn');\n  const exportGraphBtn = document.getElementById('exportGraphBtn');\n  const exportArea = document.getElementById('exportArea');\n\n  const computeMetricsBtn = document.getElementById('computeMetricsBtn');\n  const metricsOutput = document.getElementById('metricsOutput');\n\n  // === Graph manipulation functions ===\n\n  function updateNodeSelectors() {\n    const nodes = Object.keys(graph).sort();\n    // Helper to fill a <select> with options\n    function fillSelect(select, nodesList, includeEmpty=true) {\n      select.innerHTML = '';\n      if(includeEmpty) {\n        const opt = document.createElement('option');\n        opt.value = '';\n        opt.textContent = '--Select--';\n        select.appendChild(opt);\n      }\n      for (const n of nodesList) {\n        const opt = document.createElement('option');\n        opt.value = n;\n        opt.textContent = n;\n        select.appendChild(opt);\n      }\n    }\n    // Remove node select\n    if (nodes.length === 0) {\n      nodeRemoveSelect.innerHTML = '';\n      const opt = document.createElement('option');\n      opt.value = '';\n      opt.textContent = '--No nodes--';\n      nodeRemoveSelect.appendChild(opt);\n    } else {\n      fillSelect(nodeRemoveSelect, nodes, false);\n    }\n    // Edge add selects\n    fillSelect(edgeFromSelect, nodes);\n    fillSelect(edgeToSelect, nodes);\n    // Edge remove selects\n    fillSelect(edgeRemoveFromSelect, nodes);\n    // update edgeRemoveToSelect depending on edgeRemoveFromSelect value\n    updateEdgeRemoveToSelect();\n    // Algorithm start/end selects\n    fillSelect(startNodeInput, nodes);\n    fillSelect(endNodeInput, nodes);\n\n    // Show/hide endNodeInput based on algorithm selected\n    adjustAlgoNodeInputs();\n  }\n\n  function updateEdgeRemoveToSelect() {\n    const fromNode = edgeRemoveFromSelect.value;\n    edgeRemoveToSelect.innerHTML = '';\n    if (!fromNode || !(fromNode in graph)) {\n      const opt = document.createElement('option');\n      opt.value = '';\n      opt.textContent = '--Select--';\n      edgeRemoveToSelect.appendChild(opt);\n      return;\n    }\n    const neighbors = Object.keys(graph[fromNode]).sort();\n    if (neighbors.length === 0) {\n      const opt = document.createElement('option');\n      opt.value = '';\n      opt.textContent = '--No edges--';\n      edgeRemoveToSelect.appendChild(opt);\n    } else {\n      const optEmpty = document.createElement('option');\n      optEmpty.value = '';\n      optEmpty.textContent = '--Select--';\n      edgeRemoveToSelect.appendChild(optEmpty);\n      for (const n of neighbors) {\n        const opt = document.createElement('option');\n        opt.value = n;\n        opt.textContent = n;\n        edgeRemoveToSelect.appendChild(opt);\n      }\n    }\n  }\n\n  function addNode(label) {\n    label = label.trim();\n    if (!label) return {error: 'Node label cannot be empty'};\n    if (label.length > 20) return {error: 'Node label max length is 20'};\n    if (label in graph) return {error: 'Node label already exists'};\n    graph[label] = {};\n    updateNodeSelectors();\n    return {success: true};\n  }\n\n  function removeNode(label) {\n    if (!(label in graph)) return {error: 'Node does not exist'};\n    delete graph[label];\n    // Remove edges pointing to this node:\n    for (const node in graph) {\n      if (label in graph[node]) {\n        delete graph[node][label];\n      }\n    }\n    updateNodeSelectors();\n    return {success: true};\n  }\n\n  function addEdge(from, to, weight) {\n    if (!(from in graph)) return {error: `Node \"${from}\" does not exist`};\n    if (!(to in graph)) return {error: `Node \"${to}\" does not exist`};\n    if (from === to) {\n      // allow loops but user should be warned? Accept for general use.\n    }\n    if (typeof weight !== 'number' || weight < 1 || !Number.isFinite(weight)) {\n      return {error: 'Weight must be a positive number'};\n    }\n    graph[from][to] = weight;\n    updateEdgeRemoveToSelect();\n    return {success: true};\n  }\n\n  function removeEdge(from, to) {\n    if (!(from in graph)) return {error: `Node \"${from}\" does not exist`};\n    if (!(to in graph[from])) return {error: `Edge from \"${from}\" to \"${to}\" does not exist`};\n    delete graph[from][to];\n    updateEdgeRemoveToSelect();\n    return {success: true};\n  }\n\n  // === Graph visualization ===\n\n  function visualizeAdjacencyList() {\n    if (Object.keys(graph).length === 0) {\n      graphOutput.textContent = '(Graph is empty)';\n      return;\n    }\n    const lines = [];\n    for (const node of Object.keys(graph).sort()) {\n      const edges = graph[node];\n      const edgeStrings = [];\n      for (const [nbr, w] of Object.entries(edges)) {\n        edgeStrings.push(`${nbr}(${w})`);\n      }\n      lines.push(`${node} -> ${edgeStrings.length > 0 ? edgeStrings.join(', ') : '[No edges]'}`);\n    }\n    graphOutput.textContent = lines.join('\\n');\n  }\n\n  function visualizeEdgesList() {\n    if (Object.keys(graph).length === 0) {\n      graphOutput.textContent = '(Graph is empty)';\n      return;\n    }\n    const edges = [];\n    for (const from of Object.keys(graph).sort()) {\n      for (const to in graph[from]) {\n        edges.push(`${from} -> ${to} (weight: ${graph[from][to]})`);\n      }\n    }\n    if (edges.length === 0) {\n      graphOutput.textContent = '(No edges in graph)';\n      return;\n    }\n    graphOutput.textContent = edges.join('\\n');\n  }\n\n  // adjacency matrix with node order = sorted nodes\n  function visualizeAdjacencyMatrix() {\n    const nodes = Object.keys(graph).sort();\n    if (nodes.length === 0) {\n      graphOutput.textContent = '(Graph is empty)';\n      return;\n    }\n    // header row\n    const rows = [];\n    const header = [' '].concat(nodes);\n    rows.push(header.join('\\t'));\n    for (const rNode of nodes) {\n      const row = [rNode];\n      for (const cNode of nodes) {\n        let val = graph[rNode][cNode];\n        if (val == null) val = 0;\n        row.push(val);\n      }\n      rows.push(row.join('\\t'));\n    }\n    graphOutput.textContent = rows.join('\\n');\n  }\n\n  // === Algorithm helpers & implementations ===\n\n  // BFS traversal from start node: lists reachable nodes and order of discovery\n  function bfs(start) {\n    if (!(start in graph)) return {error: 'Start node not in graph'};\n    const visited = new Set();\n    const queue = [start];\n    const order = [];\n    while (queue.length > 0) {\n      const node = queue.shift();\n      if (visited.has(node)) continue;\n      visited.add(node);\n      order.push(node);\n      for (const neighbor in graph[node]) {\n        if (!visited.has(neighbor)) queue.push(neighbor);\n      }\n    }\n    return order;\n  }\n\n  // DFS traversal from start node: lists nodes in preorder\n  function dfs(start) {\n    if (!(start in graph)) return {error: 'Start node not in graph'};\n    const visited = new Set();\n    const order = [];\n    function visit(node) {\n      if (visited.has(node)) return;\n      visited.add(node);\n      order.push(node);\n      for (const neighbor in graph[node]) {\n        visit(neighbor);\n      }\n    }\n    visit(start);\n    return order;\n  }\n\n  // Topological sort of the whole graph - if acyclic - returns order or error\n  function topologicalSort() {\n    // Kahn's algorithm\n    const inDegree = {};\n    for (const node of Object.keys(graph)) {\n      inDegree[node] = 0;\n    }\n    for (const node in graph) {\n      for (const nbr in graph[node]) {\n        inDegree[nbr] = (inDegree[nbr] || 0) + 1;\n      }\n    }\n    const zeroInDegree = [];\n    for (const node in inDegree) {\n      if (inDegree[node] === 0) zeroInDegree.push(node);\n    }\n    const topoOrder = [];\n    while (zeroInDegree.length > 0) {\n      const node = zeroInDegree.shift();\n      topoOrder.push(node);\n      for (const nbr in graph[node]) {\n        inDegree[nbr]--;\n        if (inDegree[nbr] === 0) zeroInDegree.push(nbr);\n      }\n    }\n    if (topoOrder.length !== Object.keys(graph).length) {\n      return {error: 'Graph contains cycles; topological sort not possible'};\n    }\n    return topoOrder;\n  }\n\n  // Dijkstra for shortest path from start to end - returns dist and path or error\n  function dijkstra(start, end) {\n    if (!(start in graph)) return {error: 'Start node not in graph'};\n    if (!(end in graph)) return {error: 'End node not in graph'};\n    const dist = {};\n    const prev = {};\n    const nodes = new Set(Object.keys(graph));\n    for (const n of nodes) {\n      dist[n] = Infinity;\n      prev[n] = null;\n    }\n    dist[start] = 0;\n\n    while (nodes.size > 0) {\n      // find node with min dist\n      let minNode = null;\n      let minDist = Infinity;\n      for (const n of nodes) {\n        if (dist[n] < minDist) {\n          minDist = dist[n];\n          minNode = n;\n        }\n      }\n      if (minNode === null || minDist === Infinity) break;\n      if (minNode === end) break;\n      nodes.delete(minNode);\n      for (const nbr in graph[minNode]) {\n        if (!nodes.has(nbr)) continue;\n        const alt = dist[minNode] + graph[minNode][nbr];\n        if (alt < dist[nbr]) {\n          dist[nbr] = alt;\n          prev[nbr] = minNode;\n        }\n      }\n    }\n    // build path\n    if (dist[end] === Infinity) {\n      return {error: `No path from \"${start}\" to \"${end}\"`};\n    }\n    const path = [];\n    let cur = end;\n    while (cur !== null) {\n      path.unshift(cur);\n      cur = prev[cur];\n    }\n    return {distance: dist[end], path};\n  }\n\n  // Cycle detection: detect if graph has a cycle\n  // Use DFS with recursion stack method\n  function hasCycle() {\n    const visited = new Set();\n    const recStack = new Set();\n\n    function dfsCycle(node) {\n      if (!visited.has(node)) {\n        visited.add(node);\n        recStack.add(node);\n        for (const nbr in graph[node]) {\n          if (!visited.has(nbr) && dfsCycle(nbr)) {\n            return true;\n          } else if (recStack.has(nbr)) {\n            return true;\n          }\n        }\n      }\n      recStack.delete(node);\n      return false;\n    }\n    for (const node in graph) {\n      if (dfsCycle(node)) return true;\n    }\n    return false;\n  }\n\n  // Find all paths between two nodes - careful of cycles - limit max paths\n  function allPaths(start, end, maxPaths=1000) {\n    if (!(start in graph)) return {error: 'Start node not in graph'};\n    if (!(end in graph)) return {error: 'End node not in graph'};\n    const paths = [];\n    const path = [];\n    const visited = new Set();\n\n    function backtrack(curr) {\n      if (paths.length >= maxPaths) return;\n      path.push(curr);\n      if (curr === end) {\n        paths.push([...path]);\n        path.pop();\n        return;\n      }\n      // To allow paths in cyclic graphs w/o infinite loops, avoid revisiting nodes on current path\n      for (const nbr in graph[curr]) {\n        if (!path.includes(nbr)) {\n          backtrack(nbr);\n        }\n      }\n      path.pop();\n    }\n    backtrack(start);\n    return paths;\n  }\n\n  // === UI interactivity and event handlers ===\n\n  addNodeBtn.addEventListener('click', () => {\n    const label = nodeInput.value.trim();\n    if (!label) {\n      alert('Please enter a node label');\n      return;\n    }\n    const res = addNode(label);\n    if (res.error) alert(res.error);\n    else nodeInput.value = '';\n  });\n\n  removeNodeBtn.addEventListener('click', () => {\n    const label = nodeRemoveSelect.value;\n    if (!label) {\n      alert('Select a node to remove');\n      return;\n    }\n    if (!confirm(`Remove node \"${label}\" and all edges connected to it?`)) return;\n    const res = removeNode(label);\n    if (res.error) alert(res.error);\n  });\n\n  addEdgeBtn.addEventListener('click', () => {\n    const from = edgeFromSelect.value;\n    const to = edgeToSelect.value;\n    const weightStr = edgeWeightInput.value;\n    if (!from || !to) {\n      alert('Select both \"from\" and \"to\" nodes for the edge');\n      return;\n    }\n    const weight = Number(weightStr);\n    if (!weight || weight < 1) {\n      alert('Enter a valid edge weight (positive number)');\n      return;\n    }\n    const res = addEdge(from, to, weight);\n    if (res.error) alert(res.error);\n  });\n\n  removeEdgeBtn.addEventListener('click', () => {\n    const from = edgeRemoveFromSelect.value;\n    const to = edgeRemoveToSelect.value;\n    if (!from || !to) {\n      alert('Select both \"from\" and \"to\" nodes of the edge to remove');\n      return;\n    }\n    if (!confirm(`Remove edge from \"${from}\" to \"${to}\"?`)) return;\n    const res = removeEdge(from, to);\n    if (res.error) alert(res.error);\n  });\n\n  edgeRemoveFromSelect.addEventListener('change', () => {\n    updateEdgeRemoveToSelect();\n  });\n\n  // Visualization buttons\n  showAdjListBtn.addEventListener('click', () => {\n    visualizeAdjacencyList();\n  });\n  showEdgesBtn.addEventListener('click', () => {\n    visualizeEdgesList();\n  });\n  showAdjMatrixBtn.addEventListener('click', () => {\n    visualizeAdjacencyMatrix();\n  });\n\n  // Algorithm selection changes\n  algorithmSelect.addEventListener('change', adjustAlgoNodeInputs);\n\n  function adjustAlgoNodeInputs() {\n    const sel = algorithmSelect.value;\n    if (sel === 'shortest' || sel === 'allPaths') {\n      endNodeInput.style.display = '';\n      endNodeInput.previousElementSibling.style.display = '';\n    } else {\n      endNodeInput.style.display = 'none';\n      endNodeInput.previousElementSibling.style.display = 'none';\n    }\n    // Refresh selections to contain current nodes\n    updateNodeSelectors();\n  }\n\n  runAlgorithmBtn.addEventListener('click', () => {\n    pathResult.textContent = '';\n    const alg = algorithmSelect.value;\n    const start = startNodeInput.value;\n    const end = endNodeInput.value;\n\n    if (!start) {\n      alert('Select a start node');\n      return;\n    }\n    if ((alg === 'shortest' || alg === 'allPaths') && !end) {\n      alert('Select an end node');\n      return;\n    }\n    if ((alg === 'shortest' || alg === 'allPaths') && start === end) {\n      alert('Start and end node must be different');\n      return;\n    }\n\n    let result;\n    switch (alg) {\n      case 'bfs':\n        result = bfs(start);\n        if (result.error) alert(result.error);\n        else pathResult.textContent = 'BFS order:\\n' + result.join(' -> ');\n        break;\n\n      case 'dfs':\n        result = dfs(start);\n        if (result.error) alert(result.error);\n        else pathResult.textContent = 'DFS order:\\n' + result.join(' -> ');\n        break;\n\n      case 'topo':\n        result = topologicalSort();\n        if (result.error) alert(result.error);\n        else pathResult.textContent = 'Topological order:\\n' + result.join(' -> ');\n        break;\n\n      case 'shortest':\n        result = dijkstra(start, end);\n        if (result.error) alert(result.error);\n        else {\n          pathResult.textContent = `Shortest path from \"${start}\" to \"${end}\":\\n` +\n            result.path.join(' -> ') +\n            `\\nTotal cost: ${result.distance}`;\n        }\n        break;\n\n      case 'detectCycle':\n        result = hasCycle();\n        pathResult.textContent = result ? 'Graph contains at least one cycle.' : 'Graph is acyclic.';\n        break;\n\n      case 'allPaths':\n        result = allPaths(start, end);\n        if (result.error) alert(result.error);\n        else if (result.length === 0) {\n          pathResult.textContent = `No paths from \"${start}\" to \"${end}\".`;\n        } else {\n          let outputLines = [`All paths from \"${start}\" to \"${end}\" (max 1000):`];\n          for (let i = 0; i < result.length; i++) {\n            outputLines.push(`${i + 1}. ${result[i].join(' -> ')}`);\n          }\n          pathResult.textContent = outputLines.join('\\n');\n        }\n        break;\n    }\n  });\n\n  clearOutputBtn.addEventListener('click', () => {\n    pathResult.textContent = '';\n  });\n\n  // Import graph\n  importGraphBtn.addEventListener('click', () => {\n    const text = importArea.value.trim();\n    if (!text) {\n      alert('Enter JSON graph data to import');\n      return;\n    }\n    try {\n      const imported = JSON.parse(text);\n      if (typeof imported !== 'object' || imported === null) {\n        alert('Invalid JSON format: must be an object');\n        return;\n      }\n      // Validate structure: keys are strings (nodes), values are adjacency objs with node: weight\n      for (const node in imported) {\n        if (typeof node !== 'string') {\n          alert('Invalid JSON format: node labels must be strings');\n          return;\n        }\n        if (typeof imported[node] !== 'object' || imported[node] === null) {\n          alert(`Invalid adjacency list for node \"${node}\"`);\n          return;\n        }\n        for (const nbr in imported[node]) {\n          if (typeof imported[node][nbr] !== 'number' || imported[node][nbr] < 1) {\n            alert(`Invalid edge weight from \"${node}\" to \"${nbr}\". Must be positive number`);\n            return;\n          }\n        }\n      }\n      // Replace graph\n      graph = imported;\n      updateNodeSelectors();\n      graphOutput.textContent = '';\n      pathResult.textContent = '';\n      metricsOutput.textContent = '';\n      exportArea.textContent = '';\n      alert('Graph successfully imported');\n    } catch (e) {\n      alert('Invalid JSON: ' + e.message);\n    }\n  });\n\n  // Export graph\n  exportGraphBtn.addEventListener('click', () => {\n    if (Object.keys(graph).length === 0) {\n      alert('Graph is empty');\n      return;\n    }\n    const jsonStr = JSON.stringify(graph, null, 2);\n    exportArea.textContent = jsonStr;\n  });\n\n  // Compute graph metrics\n  computeMetricsBtn.addEventListener('click', () => {\n    if (Object.keys(graph).length === 0) {\n      metricsOutput.textContent = '(Graph is empty)';\n      return;\n    }\n    // Metrics:\n    // Nodes count, edges count, average out degree, average in degree, max out degree, max in degree\n    // Number of strongly connected components (SCC) (Tarjan)\n    // Check acyclic\n    // Diameter (longest shortest path) approximate for large graphs (but we keep small graphs for now)\n\n    const nodes = Object.keys(graph);\n    const nCount = nodes.length;\n    let eCount = 0;\n    const outDegrees = nodes.map(n => Object.keys(graph[n]).length);\n    for (const edges of Object.values(graph)) {\n      eCount += Object.keys(edges).length;\n    }\n    const inDegreeMap = {};\n    for (const n of nodes) inDegreeMap[n] = 0;\n    for (const from of nodes) {\n      for (const to in graph[from]) {\n        inDegreeMap[to]++;\n      }\n    }\n    const inDegrees = nodes.map(n => inDegreeMap[n]);\n    const avgOut = (eCount / nCount).toFixed(2);\n    const avgIn = (eCount / nCount).toFixed(2);\n    const maxOut = Math.max(...outDegrees);\n    const maxIn = Math.max(...inDegrees);\n\n    // Tarjan's SCC algorithm\n    let index = 0;\n    const indices = {};\n    const lowlink = {};\n    const stack = [];\n    const onStack = new Set();\n    const sccs = [];\n\n    function strongConnect(v) {\n      indices[v] = index;\n      lowlink[v] = index;\n      index++;\n      stack.push(v);\n      onStack.add(v);\n\n      for (const w in graph[v]) {\n        if (!(w in indices)) {\n          strongConnect(w);\n          lowlink[v] = Math.min(lowlink[v], lowlink[w]);\n        } else if (onStack.has(w)) {\n          lowlink[v] = Math.min(lowlink[v], indices[w]);\n        }\n      }\n\n      if (lowlink[v] === indices[v]) {\n        const scc = [];\n        let w;\n        do {\n          w = stack.pop();\n          onStack.delete(w);\n          scc.push(w);\n        } while (w !== v);\n        sccs.push(scc);\n      }\n    }\n    for (const v of nodes) {\n      if (!(v in indices)) {\n        strongConnect(v);\n      }\n    }\n\n    // Acyclic check\n    const cycle = hasCycle();\n\n    // Diameter calculation (longest shortest path)\n    // For each node run Dijkstra for shortest paths and track max distance\n    // Warning: O(n*(e log n)) can be big, but we restrict to small graphs for demo (< 50 nodes)\n    let diameter = 0;\n    let disconnectedPairs = 0;\n    if (nCount <= 50) {\n      for (const s of nodes) {\n        const dists = dijkstraAll(s);\n        for (const dist of Object.values(dists)) {\n          if (dist !== Infinity && dist > diameter) diameter = dist;\n          if (dist === Infinity) disconnectedPairs++;\n        }\n      }\n    } else {\n      diameter = '(not computed for graphs > 50 nodes)';\n    }\n\n\n    function dijkstraAll(start) {\n      const dist = {};\n      const nodesSet = new Set(nodes);\n      for (const n of nodes) dist[n] = Infinity;\n      dist[start] = 0;\n      while (nodesSet.size > 0) {\n        let minNode = null;\n        let minDist = Infinity;\n        for (const n of nodesSet) {\n          if (dist[n] < minDist) {\n            minDist = dist[n];\n            minNode = n;\n          }\n        }\n        if (minNode === null) break;\n        nodesSet.delete(minNode);\n        for (const nbr in graph[minNode]) {\n          if (!nodesSet.has(nbr)) continue;\n          const alt = dist[minNode] + graph[minNode][nbr];\n          if (alt < dist[nbr]) dist[nbr] = alt;\n        }\n      }\n      return dist;\n    }\n\n    let metricsText = '';\n    metricsText += `Nodes count: ${nCount}\\n`;\n    metricsText += `Edges count: ${eCount}\\n`;\n    metricsText += `Average out-degree: ${avgOut}\\n`;\n    metricsText += `Average in-degree: ${avgIn}\\n`;\n    metricsText += `Maximum out-degree: ${maxOut}\\n`;\n    metricsText += `Maximum in-degree: ${maxIn}\\n`;\n    metricsText += `Strongly connected components: ${sccs.length} (sizes: ${sccs.map(scc => scc.length).sort((a,b)=>b-a).join(', ')})\\n`;\n    metricsText += `Graph is ${cycle ? 'cyclic' : 'acyclic'}\\n`;\n    if (typeof diameter === 'number') {\n      metricsText += `Diameter (longest shortest path): ${diameter}\\n`;\n      if (disconnectedPairs > 0) {\n        metricsText += `There are ${disconnectedPairs} unreachable pairs\\n`;\n      }\n    } else {\n      metricsText += `Diameter: ${diameter}\\n`;\n    }\n\n    metricsOutput.textContent = metricsText;\n  });\n\n  // Initialize selectors on load\n  function initialSetup() {\n    updateNodeSelectors();\n    adjustAlgoNodeInputs();\n  }\n  initialSetup();\n\n})();\n</script>\n\n</body>\n</html>"
