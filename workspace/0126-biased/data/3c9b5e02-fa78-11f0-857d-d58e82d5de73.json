    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Static Typing — A Visual Journey</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Code&family=Inter:wght@400;700&display=swap');\n\n  /* Reset */\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  html, body {\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Inter', sans-serif;\n    color: #e5e5e5;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 3rem;\n    min-height: 100vh;\n    position: relative;\n  }\n\n  h1 {\n    font-family: 'Fira Code', monospace;\n    font-weight: 700;\n    font-size: clamp(2.5rem, 5vw, 4rem);\n    color: #7fffd4;\n    text-align: center;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    margin-bottom: 1rem;\n    user-select: none;\n    filter: drop-shadow(0 0 8px #7fffd4aa);\n  }\n\n  h2 {\n    font-family: 'Inter', sans-serif;\n    font-weight: 500;\n    font-size: clamp(1rem, 1.8vw, 1.6rem);\n    color: #a0e7e5;\n    text-align: center;\n    margin-bottom: 3.5rem;\n    font-style: italic;\n    user-select: none;\n  }\n\n  main {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 6rem;\n    flex-wrap: wrap;\n    max-width: 1200px;\n  }\n\n  /* Code panel */\n  .code-panel {\n    position: relative;\n    background: linear-gradient(145deg, #15202b, #192734);\n    border-radius: 24px;\n    box-shadow:\n      0 0 30px #20e3b2cc,\n      inset 0 0 15px #0fffd414;\n    padding: 3rem 2.5rem 3rem 3.5rem;\n    width: 420px;\n    min-height: 360px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    user-select: text;\n    transition: box-shadow 0.6s ease;\n  }\n\n  .code-panel:hover {\n    box-shadow:\n      0 0 50px #32f7d4cc,\n      inset 0 0 20px #2affdf44;\n  }\n\n  .code-header {\n    font-family: 'Fira Code', monospace;\n    font-size: 1.3rem;\n    letter-spacing: 0.08em;\n    color: #67fff7;\n    margin-bottom: 1rem;\n    user-select: none;\n  }\n\n  pre.code-content {\n    font-family: 'Fira Code', monospace;\n    font-size: 1.05rem;\n    line-height: 1.6;\n    background: transparent;\n    overflow-x: auto;\n    color: #c9f7f0;\n    user-select: text;\n  }\n\n  /* Syntax Highlight */\n  .token.keyword {\n    color: #81e6d9;\n    font-weight: 700;\n  }\n  .token.type {\n    color: #94bbe9;\n  }\n  .token.variable {\n    color: #f3f99d;\n  }\n  .token.number {\n    color: #ff85a2;\n  }\n  .token.string {\n    color: #a6f0c6;\n  }\n  .token.function {\n    color: #ffd782;\n  }\n  .token.comment {\n    color: #52796f;\n    font-style: italic;\n  }\n\n  /* Info Panel */\n  .info-panel {\n    max-width: 470px;\n    background: linear-gradient(135deg, #1c2833, #2a4150);\n    border-radius: 32px;\n    box-shadow:\n      0 0 40px #0fffd4cc,\n      inset 0 0 25px #1affe044;\n    padding: 3.2rem 3rem;\n    font-family: 'Inter', sans-serif;\n    font-weight: 500;\n    font-size: 1.1rem;\n    line-height: 1.5;\n    color: #b2fef7;\n    user-select: none;\n    position: relative;\n  }\n\n  .info-panel strong {\n    color: #7fffd4;\n  }\n\n  /* Abstract Geometry Visual */\n\n  .visualizer {\n    position: absolute;\n    top: 6vh;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 160vw;\n    max-width: none;\n    height: 160vh;\n    pointer-events: none;\n    overflow: visible;\n    z-index: 0;\n  }\n\n  /* Geometric Shape Styles */\n  .shape {\n    position: absolute;\n    border-radius: 50%;\n    filter: drop-shadow(0 0 3px #22ffdeb8);\n    animation-timing-function: ease-in-out;\n    animation-iteration-count: infinite;\n    animation-direction: alternate;\n    opacity: 0.3;\n  }\n\n  .shape.circle1 {\n    width: 170px;\n    height: 170px;\n    background: radial-gradient(circle at center, #45e1de99 40%, transparent 90%);\n    top: 15vh;\n    left: 20vw;\n    animation-name: pulse1;\n    animation-duration: 6.8s;\n  }\n  .shape.circle2 {\n    width: 120px;\n    height: 120px;\n    border: 2px solid #40e0d0aa;\n    top: 48vh;\n    left: 80vw;\n    animation-name: pulse2;\n    animation-duration: 4.5s;\n  }\n  .shape.circle3 {\n    width: 100px;\n    height: 100px;\n    background: linear-gradient(135deg, #00c6ff55, #0072ffbb);\n    filter: drop-shadow(0 0 9px #00bbffcc);\n    top: 73vh;\n    left: 42vw;\n    animation-name: pulse3;\n    animation-duration: 5.9s;\n  }\n  .shape.ring1 {\n    width: 220px;\n    height: 220px;\n    border: 4px solid #7fffd4bb;\n    top: 35vh;\n    left: 50vw;\n    animation-name: rotateRing;\n    animation-duration: 25s;\n    animation-timing-function: linear;\n    animation-iteration-count: infinite;\n    animation-direction: normal;\n    opacity: 0.15;\n  }\n  .shape.dots {\n    width: 12px;\n    height: 12px;\n    background: #3afffaee;\n    box-shadow:\n      40px 15px #2efff9cc,\n      75px 70px #4efff912,\n      120px 20px #6affff44,\n      160px 80px #38fff4aa,\n      195px 15px #6effee22;\n    top: 50vh;\n    left: 15vw;\n    animation-name: pulseDot;\n    animation-duration: 3.8s;\n  }\n\n  /* Animations */\n\n  @keyframes pulse1 {\n    0%, 100% { transform: scale(1) translateY(0); opacity: 0.35; }\n    50% { transform: scale(1.1) translateY(-12px); opacity: 0.5; }\n  }\n\n  @keyframes pulse2 {\n    0%,100% { transform: scale(1) translateX(0) translateY(0); opacity: 0.3; }\n    50% { transform: scale(0.9) translateX(-8px) translateY(6px); opacity: 0.45; }\n  }\n\n  @keyframes pulse3 {\n    0%,100% { transform: scale(1) translateY(0); opacity: 0.4;}\n    50% { transform: scale(1.08) translateY(9px); opacity: 0.55;}\n  }\n\n  @keyframes rotateRing {\n    0% { transform: rotate(0deg);}\n    100% { transform: rotate(360deg);}\n  }\n\n  @keyframes pulseDot {\n    0%,100% { opacity: 0.3; transform: translateY(0) scale(1);}\n    50% { opacity: 0.6; transform: translateY(-6px) scale(1.2);}\n  }\n\n  /* Buttons */\n\n  .btn-container {\n    margin-top: 3.5rem;\n    display: flex;\n    gap: 2rem;\n  }\n\n  button {\n    padding: 0.65rem 2.3rem;\n    font-family: 'Fira Code', monospace;\n    font-size: 1.1rem;\n    font-weight: 700;\n    border: none;\n    cursor: pointer;\n    border-radius: 40px;\n    color: #081b24;\n    background: linear-gradient(135deg, #7fffd4, #00b8a9);\n    box-shadow:\n      0 4px 15px #22ffd99d;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.3s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, #0ff9c9, #13d9ad);\n    box-shadow:\n      0 0 20px #0ff9c9aa,\n      0 10px 30px #12d994c9;\n    transform: scale(1.05);\n    outline-offset: 2px;\n  }\n\n  button:active {\n    transform: scale(0.98);\n  }\n\n\n  /* Tooltip for typecast */\n  .tooltip {\n    position: relative;\n    cursor: help;\n    border-bottom: 1px dotted #67fff7c9;\n  }\n\n  .tooltip::after {\n    content: attr(data-tooltip);\n    position: absolute;\n    bottom: 125%;\n    left: 50%;\n    transform: translateX(-50%) translateY(-6px);\n    background: #12d9adcc;\n    color: #023b34;\n    padding: 6px 12px;\n    border-radius: 14px;\n    font-size: 0.8rem;\n    white-space: nowrap;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.25s ease, transform 0.25s ease;\n    user-select: none;\n  }\n\n  .tooltip:hover::after,\n  .tooltip:focus::after {\n    opacity: 1;\n    pointer-events: auto;\n    transform: translateX(-50%) translateY(-12px);\n  }\n\n  /* Scrollbar for code panel */\n  pre.code-content::-webkit-scrollbar {\n    height: 6px;\n  }\n  pre.code-content::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  pre.code-content::-webkit-scrollbar-thumb {\n    background: #00b8a9bb;\n    border-radius: 3px;\n  }\n\n  /* Responsive */\n  @media (max-width: 900px) {\n    main {\n      flex-direction: column;\n      align-items: center;\n      gap: 3.5rem;\n    }\n    .code-panel, .info-panel {\n      width: 90vw;\n      min-height: auto;\n    }\n  }\n\n</style>\n</head>\n<body>\n  <h1>STATIC TYPING</h1>\n  <h2>The art of catching errors before runtime</h2>\n\n  <main>\n    <section class=\"code-panel\" aria-label=\"Example code demonstrating static typing\">\n      <div class=\"code-header\">&lt;TypeScript Example&gt;</div>\n      <pre class=\"code-content\" aria-live=\"polite\" aria-atomic=\"true\">\n<span class=\"token.keyword\">function</span> <span class=\"token.function\">sum</span>(<span class=\"token.variable\">a</span>: <span class=\"token.type tooltip\" data-tooltip=\"A whole number value\">number</span>, <span class=\"token.variable\">b</span>: <span class=\"token.type tooltip\" data-tooltip=\"A whole number value\">number</span>): <span class=\"token.type tooltip\" data-tooltip=\"Returns a number\">number</span> {\n  <span class=\"token.keyword\">return</span> <span class=\"token.variable\">a</span> + <span class=\"token.variable\">b</span>;\n}\n\n<span class=\"token.keyword\">let</span> <span class=\"token.variable\">total</span>: <span class=\"token.type\">number</span> = <span class=\"token.function\">sum</span>(<span class=\"token.number\">10</span>, <span class=\"token.number\">20</span>);\n\n<span class=\"token.comment\">// The following line would cause a compile-time error</span>\n<span class=\"token.comment\">// let wrong: number = sum('10', 20);</span>\n      </pre>\n      <div class=\"btn-container\" role=\"group\" aria-label=\"Code display controls\">\n        <button type=\"button\" id=\"toggleTheme\" aria-pressed=\"false\" aria-label=\"Toggle code panel theme\">Dark Theme</button>\n      </div>\n    </section>\n\n    <aside class=\"info-panel\" aria-label=\"Explanation of static typing\">\n      <p><strong>Static Typing</strong> is a <em>programming paradigm</em> where variable types are known <strong>at compile-time</strong>, not at runtime.</p>\n      <p>This means:</p>\n      <ul>\n        <li>Every variable and function parameter has a <strong>fixed type</strong>.</li>\n        <li>Errors such as type mismatches are caught <u>before</u> running the program.</li>\n        <li>Improves <strong>code reliability</strong>, <em>readability</em>, and <strong>developer confidence</strong>.</li>\n      </ul>\n      <p><em>Languages like TypeScript, Rust, and Swift embrace static typing.</em></p>\n    </aside>\n  </main>\n\n  <div class=\"visualizer\" aria-hidden=\"true\" aria-label=\"Background abstract geometry animation\">\n    <div class=\"shape circle1\"></div>\n    <div class=\"shape circle2\"></div>\n    <div class=\"shape circle3\"></div>\n    <div class=\"shape ring1\"></div>\n    <div class=\"shape dots\"></div>\n  </div>\n\n<script>\n  (() => {\n    const codePanel = document.querySelector('.code-panel');\n    const toggleBtn = document.getElementById('toggleTheme');\n    let darkTheme = true;\n\n    // Dark and Light theme styles stored for toggle\n    const darkStyles = {\n      background: 'linear-gradient(145deg, #15202b, #192734)',\n      boxShadow: '0 0 30px #20e3b2cc, inset 0 0 15px #0fffd414',\n      color: '#c9f7f0'\n    };\n\n    const lightStyles = {\n      background: 'linear-gradient(145deg, #edf2f7, #d1dae6)',\n      boxShadow: '0 0 40px #09bc8a88, inset 0 0 15px #0fffd414',\n      color: '#191f24'\n    };\n\n    toggleBtn.addEventListener('click', () => {\n      darkTheme = !darkTheme;\n      if(darkTheme) {\n        codePanel.style.background = darkStyles.background;\n        codePanel.style.boxShadow = darkStyles.boxShadow;\n        codePanel.querySelector('pre').style.color = darkStyles.color;\n        toggleBtn.textContent = 'Dark Theme';\n        toggleBtn.setAttribute('aria-pressed', 'false');\n      } else {\n        codePanel.style.background = lightStyles.background;\n        codePanel.style.boxShadow = lightStyles.boxShadow;\n        codePanel.querySelector('pre').style.color = lightStyles.color;\n        toggleBtn.textContent = 'Light Theme';\n        toggleBtn.setAttribute('aria-pressed', 'true');\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
