    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Red-Black Tree Explorer - Minimal Interface</title>\n  <style>\n    /* Extremely minimal styling: plain black text on white background, monospace for readability */\n    body { font-family: monospace; margin: 10px; color: black; background: white; }\n    button,input,select,textarea { font-family: monospace; margin: 2px; }\n    .panel { display:block; margin:6px 0; }\n    .columns { display:flex; gap:12px; align-items:flex-start; }\n    .col { min-width:300px; }\n    pre { border:1px solid #000; padding:8px; white-space:pre-wrap; word-break:break-word; }\n    table { border-collapse: collapse; }\n    td,th { padding:4px; border:1px solid #000; }\n    .small { font-size:12px; }\n  </style>\n</head>\n<body>\n  <h2>Red-Black Tree Explorer (Minimal UI)</h2>\n  <div class=\"panel\">\n    This tool demonstrates a red-black tree. Use the many controls below to insert, delete, step through automatic fix-ups, perform manual rotations/recolors, export/import, save snapshots, run randomized sequences, and inspect invariants and black-heights. Visuals are intentionally plain.\n  </div>\n\n  <div class=\"columns\">\n    <div class=\"col\">\n      <div class=\"panel\">\n        <label>Key (integer):</label>\n        <input id=\"keyInput\" type=\"number\" value=\"10\">\n        <button id=\"insertBtn\">Insert</button>\n        <button id=\"deleteBtn\">Delete</button>\n        <button id=\"searchBtn\">Search</button>\n        <button id=\"selectBtn\">Select</button>\n        <button id=\"clearSelectBtn\">Clear Select</button>\n      </div>\n\n      <div class=\"panel\">\n        <label>Bulk insert (comma-separated integers):</label><br>\n        <input id=\"bulkInput\" style=\"width:100%;\" placeholder=\"e.g. 10,5,15,1,7\">\n        <button id=\"bulkInsertBtn\">Bulk Insert (step-by-step)</button>\n        <button id=\"bulkFastBtn\">Bulk Insert (fast, no steps)</button>\n      </div>\n\n      <div class=\"panel\">\n        <label>Randomized operations:</label><br>\n        <label>Seed:</label><input id=\"seedInput\" type=\"text\" value=\"42\" style=\"width:70px\">\n        <label>Count:</label><input id=\"randCount\" type=\"number\" value=\"8\" style=\"width:60px\">\n        <button id=\"randInsertBtn\">Random Insert (step)</button>\n        <button id=\"randInsertFastBtn\">Random Insert (fast)</button>\n        <button id=\"randOpsBtn\">Random Mix (insert/delete)</button>\n      </div>\n\n      <div class=\"panel\">\n        <label>Control auto-balance:</label><br>\n        <label><input id=\"autoBalanceToggle\" type=\"checkbox\" checked> Enable RB fix-up on insert/delete</label>\n        <label><input id=\"showNILs\" type=\"checkbox\"> Show NIL sentinel nodes</label>\n        <label><input id=\"showParents\" type=\"checkbox\"> Show parent pointers</label>\n        <label><input id=\"showBlackHeight\" type=\"checkbox\"> Show black-height</label>\n      </div>\n\n      <div class=\"panel\">\n        <label>Manual actions on selected node:</label><br>\n        <button id=\"rotateLeftBtn\">Rotate Left (selected)</button>\n        <button id=\"rotateRightBtn\">Rotate Right (selected)</button>\n        <button id=\"recolorRedBtn\">Recolor Red (selected)</button>\n        <button id=\"recolorBlackBtn\">Recolor Black (selected)</button>\n        <button id=\"deleteSelectedBtn\">Delete Selected</button>\n        <button id=\"transplantBtn\">Transplant Selected => Key:</button>\n        <input id=\"transplantKey\" type=\"number\" style=\"width:70px\">\n      </div>\n\n      <div class=\"panel\">\n        <label>Operation stepping / history:</label><br>\n        <button id=\"stepBackBtn\">Step Back</button>\n        <button id=\"stepForwardBtn\">Step Forward</button>\n        <button id=\"autoPlayBtn\">Auto-play Steps</button>\n        <label>Speed (ms):</label><input id=\"speedSlider\" type=\"range\" min=\"100\" max=\"2000\" value=\"600\">\n        <span id=\"speedDisplay\">600</span>ms\n        <div>\n          <button id=\"undoBtn\">Undo</button>\n          <button id=\"redoBtn\">Redo</button>\n          <button id=\"clearHistoryBtn\">Clear History</button>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <label>Export / Import / Snapshots:</label><br>\n        <button id=\"exportBtn\">Export Tree JSON</button>\n        <button id=\"importBtn\">Import Tree JSON</button>\n        <input id=\"importArea\" placeholder=\"Paste JSON here\" style=\"width:100%;\">\n        <div>\n          <input id=\"snapshotName\" placeholder=\"Snapshot name\" style=\"width:60%;\">\n          <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n          <select id=\"snapshotList\"></select>\n          <button id=\"loadSnapshotBtn\">Load Snapshot</button>\n          <button id=\"deleteSnapshotBtn\">Delete Snapshot</button>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"col\">\n      <div class=\"panel\">\n        <strong>Tree view (textual)</strong>\n        <pre id=\"treeView\" style=\"min-height:220px;\"></pre>\n      </div>\n\n      <div class=\"panel\">\n        <strong>Operation log / Steps</strong><br>\n        <div style=\"display:flex; gap:6px; align-items:center;\">\n          <button id=\"clearStepsBtn\">Clear Steps</button>\n          <label>Auto-capture steps:</label><input id=\"autoCapture\" type=\"checkbox\" checked>\n        </div>\n        <select id=\"stepsList\" style=\"width:100%; height:120px;\"></select>\n        <div>\n          <button id=\"loadStepBtn\">Load Selected Step</button>\n          <button id=\"appendCurrentAsStepBtn\">Append Current State as Step</button>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <strong>Traversal / Queries</strong><br>\n        <button id=\"inorderBtn\">In-order</button>\n        <button id=\"preorderBtn\">Pre-order</button>\n        <button id=\"postorderBtn\">Post-order</button>\n        <button id=\"levelorderBtn\">Level-order</button>\n        <div>\n          <label>Range query (lo,hi):</label><input id=\"loKey\" type=\"number\" style=\"width:60px\">, <input id=\"hiKey\" type=\"number\" style=\"width:60px\">\n          <button id=\"rangeQueryBtn\">Run</button>\n        </div>\n        <div>\n          <label>Find min/max:</label>\n          <button id=\"findMinBtn\">Min</button>\n          <button id=\"findMaxBtn\">Max</button>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <strong>Diagnostics & Stats</strong><br>\n        <div>\n          <button id=\"checkInvariantsBtn\">Check Invariants</button>\n          <button id=\"fixViolationsBtn\">Auto-Fix Violations (reinsert rebuild)</button>\n        </div>\n        <div>\n          <span>Rotations: <span id=\"rotCount\">0</span></span> |\n          <span>Recolors: <span id=\"recolorCount\">0</span></span> |\n          <span>Node count: <span id=\"nodeCount\">0</span></span>\n        </div>\n        <pre id=\"diagnostics\" class=\"small\" style=\"min-height:80px;\"></pre>\n      </div>\n\n      <div class=\"panel\">\n        <strong>Preloaded examples</strong><br>\n        <button id=\"example1Btn\">Example 1: sequential 1..10</button>\n        <button id=\"example2Btn\">Example 2: classic insert demo</button>\n        <button id=\"clearTreeBtn\">Clear Tree</button>\n      </div>\n\n    </div>\n  </div>\n\n<script>\n/*\n  Red-Black Tree Explorer\n  - Minimal plain UI, rich interactivity and steps\n  - All functionality implemented in this single file.\n*/\n\n/* Utility: simple seeded RNG for reproducibility */\nfunction RNG(seed) {\n  let s = 0;\n  for (let i = 0; i < seed.length; i++) s = (s * 31 + seed.charCodeAt(i)) >>> 0;\n  return function() {\n    s = (s ^ (s << 13)) >>> 0;\n    s = (s ^ (s >>> 17)) >>> 0;\n    s = (s ^ (s << 5)) >>> 0;\n    return (s >>> 0) / 4294967295;\n  };\n}\n\n/* Node and Tree implementation using sentinel NIL */\nfunction RBTree() {\n  const NIL = { key: null, color: 'B', left: null, right: null, parent: null, isNil: true };\n  NIL.left = NIL.right = NIL.parent = NIL;\n  this.NIL = NIL;\n  this.root = NIL;\n  this.rotations = 0;\n  this.recolors = 0;\n}\n\n/* Helper: deep clone by serializing to JSON-friendly object then revive with NIL sentinel */\nRBTree.prototype.toJSON = function() {\n  const NIL = this.NIL;\n  function copyNode(n) {\n    if (!n || n.isNil) return { isNil: true };\n    return {\n      isNil: false,\n      key: n.key,\n      color: n.color,\n      left: copyNode(n.left),\n      right: copyNode(n.right)\n    };\n  }\n  return JSON.stringify(copyNode(this.root));\n};\n\nRBTree.prototype.fromJSON = function(json) {\n  const raw = JSON.parse(json);\n  const NIL = this.NIL;\n  function revive(obj, parent) {\n    if (!obj || obj.isNil) return NIL;\n    const n = { key: obj.key, color: obj.color, left: NIL, right: NIL, parent: parent, isNil: false };\n    n.left = revive(obj.left, n);\n    n.right = revive(obj.right, n);\n    return n;\n  }\n  this.root = revive(raw, NIL);\n  fixParents(this.root, NIL);\n  this.rotations = 0;\n  this.recolors = 0;\n};\n\n/* Utility to ensure parent pointers correct */\nfunction fixParents(node, NIL) {\n  if (!node || node.isNil) return;\n  if (node.left && !node.left.isNil) node.left.parent = node;\n  if (node.right && !node.right.isNil) node.right.parent = node;\n  fixParents(node.left, NIL);\n  fixParents(node.right, NIL);\n}\n\n/* Search */\nRBTree.prototype.search = function(key) {\n  let x = this.root;\n  const NIL = this.NIL;\n  while (!x.isNil && key !== x.key) {\n    x = (key < x.key) ? x.left : x.right;\n  }\n  return x;\n};\n\n/* Minimum / Maximum */\nRBTree.prototype.minimum = function(x) {\n  const NIL = this.NIL;\n  while (!x.isNil && !x.left.isNil) x = x.left;\n  return x;\n};\nRBTree.prototype.maximum = function(x) {\n  const NIL = this.NIL;\n  while (!x.isNil && !x.right.isNil) x = x.right;\n  return x;\n};\n\n/* Left rotate */\nRBTree.prototype.leftRotate = function(x) {\n  const NIL = this.NIL;\n  const y = x.right;\n  if (!y || y.isNil) return;\n  x.right = y.left;\n  if (!y.left.isNil) y.left.parent = x;\n  y.parent = x.parent;\n  if (x.parent.isNil) {\n    this.root = y;\n  } else if (x === x.parent.left) {\n    x.parent.left = y;\n  } else {\n    x.parent.right = y;\n  }\n  y.left = x;\n  x.parent = y;\n  this.rotations++;\n};\n\n/* Right rotate */\nRBTree.prototype.rightRotate = function(y) {\n  const NIL = this.NIL;\n  const x = y.left;\n  if (!x || x.isNil) return;\n  y.left = x.right;\n  if (!x.right.isNil) x.right.parent = y;\n  x.parent = y.parent;\n  if (y.parent.isNil) {\n    this.root = x;\n  } else if (y === y.parent.right) {\n    y.parent.right = x;\n  } else {\n    y.parent.left = x;\n  }\n  x.right = y;\n  y.parent = x;\n  this.rotations++;\n};\n\n/* Transplant helper for delete */\nRBTree.prototype.transplant = function(u, v) {\n  if (u.parent.isNil) {\n    this.root = v;\n  } else if (u === u.parent.left) {\n    u.parent.left = v;\n  } else {\n    u.parent.right = v;\n  }\n  v.parent = u.parent;\n};\n\n/* Insert (with option to capture fix-up steps) */\nRBTree.prototype.bstInsertNode = function(z) {\n  const NIL = this.NIL;\n  let y = NIL;\n  let x = this.root;\n  while (!x.isNil) {\n    y = x;\n    if (z.key < x.key) x = x.left; else x = x.right;\n  }\n  z.parent = y;\n  if (y.isNil) this.root = z;\n  else if (z.key < y.key) y.left = z; else y.right = z;\n  z.left = NIL; z.right = NIL; z.color = 'R';\n};\n\nRBTree.prototype.insert = function(key, stepRecorder) {\n  const NIL = this.NIL;\n  if (this.search(key) && !this.search(key).isNil) {\n    if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Insert aborted: duplicate key \" + key);\n    return;\n  }\n  const z = { key: key, left: NIL, right: NIL, parent: NIL, color: 'R', isNil:false };\n  if (stepRecorder && stepRecorder.record) stepRecorder.record(\"BST insert key \" + key);\n  this.bstInsertNode(z);\n  if (!(stepRecorder && stepRecorder.record) && !document.getElementById('autoBalanceToggle').checked) {\n    // If no step recording and auto-balance turned off, leave red nodes as inserted\n    return;\n  }\n  if (!document.getElementById('autoBalanceToggle').checked) {\n    if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Auto-balance disabled: skipping fixup\");\n    return;\n  }\n  // Insert fix-up with detailed steps\n  while (z.parent && z.parent.color === 'R') {\n    const gp = z.parent.parent;\n    if (z.parent === gp.left) {\n      const y = gp.right;\n      if (!y.isNil && y.color === 'R') {\n        // case 1\n        if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"insert-case1: recolor parent and uncle to black, grandparent to red\");\n        z.parent.color = 'B'; this.recolors++;\n        y.color = 'B'; this.recolors++;\n        gp.color = 'R'; this.recolors++;\n        z = gp;\n      } else {\n        if (z === z.parent.right) {\n          // case 2\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"insert-case2: left-rotate parent\");\n          z = z.parent;\n          this.leftRotate(z);\n        }\n        // case 3\n        if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"insert-case3: right-rotate grandparent and recolor\");\n        z.parent.color = 'B'; this.recolors++;\n        gp.color = 'R'; this.recolors++;\n        this.rightRotate(gp);\n      }\n    } else {\n      // mirror\n      const y = gp.left;\n      if (!y.isNil && y.color === 'R') {\n        // case 1\n        if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"insert-case1 (mirror): recolor parent and uncle to black, grandparent to red\");\n        z.parent.color = 'B'; this.recolors++;\n        y.color = 'B'; this.recolors++;\n        gp.color = 'R'; this.recolors++;\n        z = gp;\n      } else {\n        if (z === z.parent.left) {\n          // case 2\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"insert-case2 (mirror): right-rotate parent\");\n          z = z.parent;\n          this.rightRotate(z);\n        }\n        // case 3\n        if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"insert-case3 (mirror): left-rotate grandparent and recolor\");\n        z.parent.color = 'B'; this.recolors++;\n        gp.color = 'R'; this.recolors++;\n        this.leftRotate(gp);\n      }\n    }\n  }\n  if (this.root.color !== 'B') { this.root.color = 'B'; this.recolors++; if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"recolor root black\"); }\n  if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Insert complete\");\n};\n\n/* Delete operation with fix-up logging */\nRBTree.prototype.delete = function(key, stepRecorder) {\n  const z = this.search(key);\n  const NIL = this.NIL;\n  if (!z || z.isNil) {\n    if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Delete aborted: key \" + key + \" not found\");\n    return;\n  }\n  if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Deleting key \" + key);\n  let y = z;\n  let yOriginalColor = y.color;\n  let x;\n  if (z.left.isNil) {\n    x = z.right;\n    this.transplant(z, z.right);\n  } else if (z.right.isNil) {\n    x = z.left;\n    this.transplant(z, z.left);\n  } else {\n    y = this.minimum(z.right);\n    yOriginalColor = y.color;\n    x = y.right;\n    if (y.parent === z) {\n      x.parent = y;\n    } else {\n      this.transplant(y, y.right);\n      y.right = z.right;\n      y.right.parent = y;\n    }\n    this.transplant(z, y);\n    y.left = z.left;\n    y.left.parent = y;\n    y.color = z.color;\n  }\n  if (!document.getElementById('autoBalanceToggle').checked) {\n    if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Auto-balance disabled: skipping delete fixup\");\n    return;\n  }\n  if (yOriginalColor === 'B') {\n    // fixup x\n    while (!x.parent.isNil && x.color === 'B') {\n      if (x === x.parent.left) {\n        let w = x.parent.right;\n        if (w.color === 'R') {\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case1: sibling red -> recolor and left-rotate parent\");\n          w.color = 'B'; this.recolors++;\n          x.parent.color = 'R'; this.recolors++;\n          this.leftRotate(x.parent);\n          w = x.parent.right;\n        }\n        if (w.left.color === 'B' && w.right.color === 'B') {\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case2: sibling's children both black -> recolor sibling red\");\n          w.color = 'R'; this.recolors++;\n          x = x.parent;\n        } else {\n          if (w.right.color === 'B') {\n            if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case3: sibling's right black -> recolor and right-rotate sibling\");\n            w.left.color = 'B'; this.recolors++;\n            w.color = 'R'; this.recolors++;\n            this.rightRotate(w);\n            w = x.parent.right;\n          }\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case4: recolor and left-rotate parent\");\n          w.color = x.parent.color; // no recolor count for copying but we'll count as recolor for clarity\n          this.recolors++;\n          x.parent.color = 'B';\n          w.right.color = 'B';\n          this.recolors += 2;\n          this.leftRotate(x.parent);\n          x = this.root;\n        }\n      } else {\n        // mirror\n        let w = x.parent.left;\n        if (w.color === 'R') {\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case1 (mirror): sibling red -> recolor and right-rotate parent\");\n          w.color = 'B'; this.recolors++;\n          x.parent.color = 'R'; this.recolors++;\n          this.rightRotate(x.parent);\n          w = x.parent.left;\n        }\n        if (w.right.color === 'B' && w.left.color === 'B') {\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case2 (mirror): sibling's children both black -> recolor sibling red\");\n          w.color = 'R'; this.recolors++;\n          x = x.parent;\n        } else {\n          if (w.left.color === 'B') {\n            if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case3 (mirror): sibling's left black -> recolor and left-rotate sibling\");\n            w.right.color = 'B'; this.recolors++;\n            w.color = 'R'; this.recolors++;\n            this.leftRotate(w);\n            w = x.parent.left;\n          }\n          if (stepRecorder && stepRecorder.snapshot) stepRecorder.snapshot(\"delete-case4 (mirror): recolor and right-rotate parent\");\n          w.color = x.parent.color;\n          this.recolors++;\n          x.parent.color = 'B';\n          w.left.color = 'B';\n          this.recolors += 2;\n          this.rightRotate(x.parent);\n          x = this.root;\n        }\n      }\n    }\n    x.color = 'B';\n    this.recolors++;\n  }\n  if (stepRecorder && stepRecorder.record) stepRecorder.record(\"Delete complete\");\n};\n\n/* Utility: collect statistics and checks */\nRBTree.prototype.countNodes = function() {\n  const NIL = this.NIL;\n  function count(n) {\n    if (!n || n.isNil) return 0;\n    return 1 + count(n.left) + count(n.right);\n  }\n  return count(this.root);\n};\n\nRBTree.prototype.allPathsBlackHeight = function() {\n  const NIL = this.NIL;\n  const heights = [];\n  function dfs(n, blackCount) {\n    if (n.isNil) { heights.push(blackCount); return; }\n    if (n.color === 'B') blackCount++;\n    dfs(n.left, blackCount);\n    dfs(n.right, blackCount);\n  }\n  dfs(this.root, 0);\n  return heights;\n};\n\nRBTree.prototype.checkInvariants = function() {\n  const res = { rootBlack: true, noConsecutiveRed: true, equalBlackHeight: true, messages: [] };\n  if (this.root.isNil) {\n    res.messages.push(\"Tree empty\");\n    return res;\n  }\n  if (this.root.color !== 'B') { res.rootBlack = false; res.messages.push(\"Root is not black\"); }\n  // check no red parent-child\n  function checkNoRed(n) {\n    if (n.isNil) return true;\n    if (n.color === 'R') {\n      if (!n.left.isNil && n.left.color === 'R') { res.noConsecutiveRed = false; res.messages.push(\"Red node with red left child at key \" + n.key); }\n      if (!n.right.isNil && n.right.color === 'R') { res.noConsecutiveRed = false; res.messages.push(\"Red node with red right child at key \" + n.key); }\n    }\n    checkNoRed(n.left); checkNoRed(n.right);\n  }\n  checkNoRed(this.root);\n  // check black height\n  const heights = this.allPathsBlackHeight();\n  const uniq = Array.from(new Set(heights));\n  if (uniq.length > 1) { res.equalBlackHeight = false; res.messages.push(\"Black-height differs across root-to-leaf paths: \" + uniq.join(\", \")); }\n  if (res.rootBlack && res.noConsecutiveRed && res.equalBlackHeight) res.messages.push(\"All invariants satisfied\");\n  return res;\n};\n\n/* Pretty textual rendering */\nfunction renderTreeText(tree, options) {\n  const out = [];\n  if (tree.root.isNil) return \"(empty)\";\n  function recurse(node, prefix, isLeft) {\n    if (node.isNil) {\n      if (options.showNILs) out.push(prefix + (isLeft ? \"├── \" : \"└── \") + \"NIL(B)\");\n      return;\n    }\n    const color = node.color;\n    let s = node.key + \"(\" + color + \")\";\n    if (options.showBlackHeight) s += \"[BH=\" + computeBlackHeight(node, tree.NIL) + \"]\";\n    if (options.showParents && !node.parent.isNil) s += \"{p:\" + node.parent.key + \"}\";\n    if (options.selectedKey !== null && node.key === options.selectedKey) s = \">\" + s;\n    out.push(prefix + (isLeft ? \"├── \" : \"└── \") + s);\n    const childPrefix = prefix + (isLeft ? \"│   \" : \"    \");\n    recurse(node.left, childPrefix, true);\n    recurse(node.right, childPrefix, false);\n  }\n  // root\n  let rootLine = tree.root.key + \"(\" + tree.root.color + \")\";\n  if (options.showBlackHeight) rootLine += \"[BH=\" + computeBlackHeight(tree.root, tree.NIL) + \"]\";\n  if (options.selectedKey !== null && tree.root.key === options.selectedKey) rootLine = \">\" + rootLine;\n  out.push(rootLine);\n  recurse(tree.root.left, \"\", true);\n  recurse(tree.root.right, \"\", false);\n  return out.join(\"\\n\");\n}\n\n/* Compute black-height from node to leaves (count blacks on the way including NIL) */\nfunction computeBlackHeight(node, NIL) {\n  function bh(n) {\n    if (n.isNil) return 0;\n    let left = bh(n.left);\n    let add = (n.color === 'B') ? 1 : 0;\n    return Math.max(left, bh(n.right)) + add;\n  }\n  return bh(node);\n}\n\n/* Serialize the current tree into a descriptive snapshot (JSON string) */\nfunction snapshotOf(tree, desc) {\n  return {\n    desc: desc || \"\",\n    json: tree.toJSON(),\n    rotations: tree.rotations,\n    recolors: tree.recolors,\n    nodeCount: tree.countNodes()\n  };\n}\n\n/* Global app state */\nconst App = {\n  tree: new RBTree(),\n  steps: [], // array of snapshots\n  stepIndex: -1,\n  history: [], // for undo/redo: store json states\n  historyIndex: -1,\n  selectedKey: null,\n  autoPlayTimer: null,\n  rng: Math.random\n};\n\n/* DOM helpers */\nconst dom = {\n  keyInput: document.getElementById('keyInput'),\n  insertBtn: document.getElementById('insertBtn'),\n  deleteBtn: document.getElementById('deleteBtn'),\n  searchBtn: document.getElementById('searchBtn'),\n  selectBtn: document.getElementById('selectBtn'),\n  clearSelectBtn: document.getElementById('clearSelectBtn'),\n  bulkInput: document.getElementById('bulkInput'),\n  bulkInsertBtn: document.getElementById('bulkInsertBtn'),\n  bulkFastBtn: document.getElementById('bulkFastBtn'),\n  seedInput: document.getElementById('seedInput'),\n  randCount: document.getElementById('randCount'),\n  randInsertBtn: document.getElementById('randInsertBtn'),\n  randInsertFastBtn: document.getElementById('randInsertFastBtn'),\n  randOpsBtn: document.getElementById('randOpsBtn'),\n  autoBalanceToggle: document.getElementById('autoBalanceToggle'),\n  showNILs: document.getElementById('showNILs'),\n  showParents: document.getElementById('showParents'),\n  showBlackHeight: document.getElementById('showBlackHeight'),\n  rotateLeftBtn: document.getElementById('rotateLeftBtn'),\n  rotateRightBtn: document.getElementById('rotateRightBtn'),\n  recolorRedBtn: document.getElementById('recolorRedBtn'),\n  recolorBlackBtn: document.getElementById('recolorBlackBtn'),\n  deleteSelectedBtn: document.getElementById('deleteSelectedBtn'),\n  transplantBtn: document.getElementById('transplantBtn'),\n  transplantKey: document.getElementById('transplantKey'),\n  stepBackBtn: document.getElementById('stepBackBtn'),\n  stepForwardBtn: document.getElementById('stepForwardBtn'),\n  autoPlayBtn: document.getElementById('autoPlayBtn'),\n  speedSlider: document.getElementById('speedSlider'),\n  speedDisplay: document.getElementById('speedDisplay'),\n  undoBtn: document.getElementById('undoBtn'),\n  redoBtn: document.getElementById('redoBtn'),\n  clearHistoryBtn: document.getElementById('clearHistoryBtn'),\n  exportBtn: document.getElementById('exportBtn'),\n  importBtn: document.getElementById('importBtn'),\n  importArea: document.getElementById('importArea'),\n  snapshotName: document.getElementById('snapshotName'),\n  saveSnapshotBtn: document.getElementById('saveSnapshotBtn'),\n  snapshotList: document.getElementById('snapshotList'),\n  loadSnapshotBtn: document.getElementById('loadSnapshotBtn'),\n  deleteSnapshotBtn: document.getElementById('deleteSnapshotBtn'),\n  treeView: document.getElementById('treeView'),\n  clearStepsBtn: document.getElementById('clearStepsBtn'),\n  autoCapture: document.getElementById('autoCapture'),\n  stepsList: document.getElementById('stepsList'),\n  loadStepBtn: document.getElementById('loadStepBtn'),\n  appendCurrentAsStepBtn: document.getElementById('appendCurrentAsStepBtn'),\n  inorderBtn: document.getElementById('inorderBtn'),\n  preorderBtn: document.getElementById('preorderBtn'),\n  postorderBtn: document.getElementById('postorderBtn'),\n  levelorderBtn: document.getElementById('levelorderBtn'),\n  loKey: document.getElementById('loKey'),\n  hiKey: document.getElementById('hiKey'),\n  rangeQueryBtn: document.getElementById('rangeQueryBtn'),\n  findMinBtn: document.getElementById('findMinBtn'),\n  findMaxBtn: document.getElementById('findMaxBtn'),\n  checkInvariantsBtn: document.getElementById('checkInvariantsBtn'),\n  fixViolationsBtn: document.getElementById('fixViolationsBtn'),\n  rotCount: document.getElementById('rotCount'),\n  recolorCount: document.getElementById('recolorCount'),\n  nodeCount: document.getElementById('nodeCount'),\n  diagnostics: document.getElementById('diagnostics'),\n  example1Btn: document.getElementById('example1Btn'),\n  example2Btn: document.getElementById('example2Btn'),\n  clearTreeBtn: document.getElementById('clearTreeBtn'),\n  searchRes: null\n};\n\n/* Rendering update */\nfunction refreshUI() {\n  const options = {\n    showNILs: dom.showNILs.checked,\n    showParents: dom.showParents.checked,\n    showBlackHeight: dom.showBlackHeight.checked,\n    selectedKey: App.selectedKey\n  };\n  dom.treeView.textContent = renderTreeText(App.tree, options);\n  dom.rotCount.textContent = App.tree.rotations;\n  dom.recolorCount.textContent = App.tree.recolors;\n  dom.nodeCount.textContent = App.tree.countNodes();\n}\n\n/* History management */\nfunction pushHistory(desc) {\n  const json = App.tree.toJSON();\n  // discard forward history\n  App.history = App.history.slice(0, App.historyIndex + 1);\n  App.history.push({ json: json, desc: desc });\n  App.historyIndex = App.history.length - 1;\n}\n\nfunction undo() {\n  if (App.historyIndex <= 0) return;\n  App.historyIndex--;\n  App.tree.fromJSON(App.history[App.historyIndex].json);\n  refreshUI();\n}\n\nfunction redo() {\n  if (App.historyIndex >= App.history.length - 1) return;\n  App.historyIndex++;\n  App.tree.fromJSON(App.history[App.historyIndex].json);\n  refreshUI();\n}\n\n/* Steps management */\nfunction clearSteps() {\n  App.steps = [];\n  App.stepIndex = -1;\n  renderStepsList();\n}\n\nfunction appendStep(desc) {\n  const snap = snapshotOf(App.tree, desc);\n  App.steps.push(snap);\n  App.stepIndex = App.steps.length - 1;\n  renderStepsList();\n}\n\nfunction appendStepCustom(snap) {\n  App.steps.push(snap);\n  App.stepIndex = App.steps.length - 1;\n  renderStepsList();\n}\n\nfunction loadStepAt(i) {\n  if (i < 0 || i >= App.steps.length) return;\n  try {\n    App.tree.fromJSON(App.steps[i].json);\n    App.stepIndex = i;\n    pushHistory(\"loaded step \" + i + \" \" + (App.steps[i].desc || \"\"));\n    refreshUI();\n  } catch (e) {\n    alert(\"Failed to load step: \" + e);\n  }\n}\n\nfunction renderStepsList() {\n  dom.stepsList.innerHTML = \"\";\n  App.steps.forEach((s, i) => {\n    const opt = document.createElement('option');\n    opt.value = i;\n    opt.text = i + \": \" + (s.desc || \"\").slice(0,80) + \" (nodes:\" + s.nodeCount + \")\";\n    dom.stepsList.appendChild(opt);\n  });\n}\n\n/* Button handlers and interactions */\ndom.insertBtn.addEventListener('click', () => {\n  const key = parseInt(dom.keyInput.value, 10);\n  if (isNaN(key)) return alert(\"Enter integer key\");\n  const recorder = {\n    record: (msg) => { if (dom.autoCapture.checked) appendStep(msg); },\n    snapshot: (msg) => { if (dom.autoCapture.checked) appendStep(msg); }\n  };\n  App.tree.insert(key, recorder);\n  pushHistory(\"insert \" + key);\n  refreshUI();\n});\n\ndom.deleteBtn.addEventListener('click', () => {\n  const key = parseInt(dom.keyInput.value, 10);\n  if (isNaN(key)) return alert(\"Enter integer key\");\n  const recorder = {\n    record: (msg) => { if (dom.autoCapture.checked) appendStep(msg); },\n    snapshot: (msg) => { if (dom.autoCapture.checked) appendStep(msg); }\n  };\n  App.tree.delete(key, recorder);\n  pushHistory(\"delete \" + key);\n  refreshUI();\n});\n\ndom.searchBtn.addEventListener('click', () => {\n  const key = parseInt(dom.keyInput.value, 10);\n  const node = App.tree.search(key);\n  if (!node || node.isNil) {\n    dom.diagnostics.textContent = \"Search: key \" + key + \" not found\";\n    App.selectedKey = null;\n  } else {\n    dom.diagnostics.textContent = \"Search: found key \" + key + \" color \" + node.color;\n    App.selectedKey = key;\n  }\n  refreshUI();\n});\n\ndom.selectBtn.addEventListener('click', () => {\n  const key = parseInt(dom.keyInput.value, 10);\n  const node = App.tree.search(key);\n  if (!node || node.isNil) {\n    App.selectedKey = null;\n    dom.diagnostics.textContent = \"Select: key not found\";\n  } else {\n    App.selectedKey = key;\n    dom.diagnostics.textContent = \"Selected key \" + key;\n  }\n  refreshUI();\n});\n\ndom.clearSelectBtn.addEventListener('click', () => {\n  App.selectedKey = null;\n  refreshUI();\n});\n\ndom.bulkInsertBtn.addEventListener('click', () => {\n  const list = dom.bulkInput.value.split(',').map(s => s.trim()).filter(Boolean).map(Number);\n  if (!list.length) return alert(\"No keys specified\");\n  (async () => {\n    for (let k of list) {\n      const recorder = { record: (msg) => appendStep(\"Insert \" + k + \": \" + msg), snapshot: (msg) => appendStep(\"Insert \" + k + \": \" + msg) };\n      App.tree.insert(k, recorder);\n      pushHistory(\"insert \" + k);\n      refreshUI();\n      await sleep(150);\n    }\n  })();\n});\n\ndom.bulkFastBtn.addEventListener('click', () => {\n  const list = dom.bulkInput.value.split(',').map(s => s.trim()).filter(Boolean).map(Number);\n  if (!list.length) return alert(\"No keys specified\");\n  list.forEach(k => App.tree.insert(k, null));\n  pushHistory(\"bulk insert fast\");\n  refreshUI();\n});\n\ndom.randInsertBtn.addEventListener('click', () => {\n  const seed = dom.seedInput.value || \"\";\n  App.rng = RNG(seed);\n  const count = parseInt(dom.randCount.value, 10) || 5;\n  (async () => {\n    for (let i = 0; i < count; i++) {\n      const val = Math.floor(App.rng() * 100);\n      const recorder = { record: (msg) => appendStep(\"Rand insert \" + val + \": \" + msg), snapshot: (msg) => appendStep(\"Rand insert \" + val + \": \" + msg) };\n      App.tree.insert(val, recorder);\n      pushHistory(\"rand insert \" + val);\n      refreshUI();\n      await sleep(120);\n    }\n  })();\n});\n\ndom.randInsertFastBtn.addEventListener('click', () => {\n  const seed = dom.seedInput.value || \"\";\n  const rng = RNG(seed);\n  const count = parseInt(dom.randCount.value, 10) || 5;\n  for (let i = 0; i < count; i++) {\n    const val = Math.floor(rng() * 100);\n    App.tree.insert(val, null);\n  }\n  pushHistory(\"rand insert fast\");\n  refreshUI();\n});\n\ndom.randOpsBtn.addEventListener('click', () => {\n  const seed = dom.seedInput.value || \"\";\n  App.rng = RNG(seed);\n  const count = parseInt(dom.randCount.value, 10) || 10;\n  (async () => {\n    for (let i = 0; i < count; i++) {\n      const op = App.rng() < 0.6 ? 'i' : 'd';\n      const val = Math.floor(App.rng() * 100);\n      if (op === 'i') {\n        const recorder = { record: (msg) => appendStep(\"Rand insert \" + val + \": \" + msg), snapshot: (msg) => appendStep(\"Rand insert \" + val + \": \" + msg) };\n        App.tree.insert(val, recorder);\n        pushHistory(\"rand insert \" + val);\n      } else {\n        const recorder = { record: (msg) => appendStep(\"Rand delete \" + val + \": \" + msg), snapshot: (msg) => appendStep(\"Rand delete \" + val + \": \" + msg) };\n        App.tree.delete(val, recorder);\n        pushHistory(\"rand delete \" + val);\n      }\n      refreshUI();\n      await sleep(200);\n    }\n  })();\n});\n\ndom.rotateLeftBtn.addEventListener('click', () => {\n  if (App.selectedKey === null) return alert(\"Select a node first\");\n  const node = App.tree.search(App.selectedKey);\n  if (node.isNil) return alert(\"Selected node not found\");\n  App.tree.leftRotate(node);\n  pushHistory(\"manual left-rotate at \" + App.selectedKey);\n  appendStep(\"manual left-rotate at \" + App.selectedKey);\n  refreshUI();\n});\n\ndom.rotateRightBtn.addEventListener('click', () => {\n  if (App.selectedKey === null) return alert(\"Select a node first\");\n  const node = App.tree.search(App.selectedKey);\n  if (node.isNil) return alert(\"Selected node not found\");\n  App.tree.rightRotate(node);\n  pushHistory(\"manual right-rotate at \" + App.selectedKey);\n  appendStep(\"manual right-rotate at \" + App.selectedKey);\n  refreshUI();\n});\n\ndom.recolorRedBtn.addEventListener('click', () => {\n  if (App.selectedKey === null) return alert(\"Select a node first\");\n  const node = App.tree.search(App.selectedKey);\n  if (node.isNil) return alert(\"Selected node not found\");\n  node.color = 'R';\n  App.tree.recolors++;\n  pushHistory(\"recolor \" + App.selectedKey + \" to R\");\n  appendStep(\"manual recolor \" + App.selectedKey + \" -> R\");\n  refreshUI();\n});\n\ndom.recolorBlackBtn.addEventListener('click', () => {\n  if (App.selectedKey === null) return alert(\"Select a node first\");\n  const node = App.tree.search(App.selectedKey);\n  if (node.isNil) return alert(\"Selected node not found\");\n  node.color = 'B';\n  App.tree.recolors++;\n  pushHistory(\"recolor \" + App.selectedKey + \" to B\");\n  appendStep(\"manual recolor \" + App.selectedKey + \" -> B\");\n  refreshUI();\n});\n\ndom.deleteSelectedBtn.addEventListener('click', () => {\n  if (App.selectedKey === null) return alert(\"Select a node first\");\n  const recorder = { record: (msg) => appendStep(\"Manual delete \" + App.selectedKey + \": \" + msg), snapshot: (msg) => appendStep(\"Manual delete \" + App.selectedKey + \": \" + msg) };\n  App.tree.delete(App.selectedKey, recorder);\n  pushHistory(\"delete \" + App.selectedKey);\n  App.selectedKey = null;\n  refreshUI();\n});\n\ndom.transplantBtn.addEventListener('click', () => {\n  const key = parseInt(dom.transplantKey.value, 10);\n  if (isNaN(key)) return alert(\"Enter target key for transplant\");\n  if (App.selectedKey === null) return alert(\"Select a node first\");\n  const u = App.tree.search(App.selectedKey);\n  const v = App.tree.search(key);\n  if (u.isNil) return alert(\"Selected node not found\");\n  if (v.isNil) {\n    // create new node to transplant\n    const n = { key: key, left: App.tree.NIL, right: App.tree.NIL, parent: App.tree.NIL, color: 'R', isNil:false };\n    App.tree.transplant(u, n);\n  } else {\n    App.tree.transplant(u, v);\n  }\n  pushHistory(\"transplant \" + App.selectedKey + \" -> \" + key);\n  appendStep(\"transplant \" + App.selectedKey + \" -> \" + key);\n  refreshUI();\n});\n\n/* Step navigation */\ndom.stepBackBtn.addEventListener('click', () => {\n  if (App.stepIndex <= 0) return;\n  App.stepIndex--;\n  loadStepAt(App.stepIndex);\n});\n\ndom.stepForwardBtn.addEventListener('click', () => {\n  if (App.stepIndex >= App.steps.length - 1) return;\n  App.stepIndex++;\n  loadStepAt(App.stepIndex);\n});\n\ndom.autoPlayBtn.addEventListener('click', () => {\n  if (App.autoPlayTimer) {\n    clearInterval(App.autoPlayTimer); App.autoPlayTimer = null; dom.autoPlayBtn.textContent = \"Auto-play Steps\";\n    return;\n  }\n  if (App.steps.length === 0) return alert(\"No steps to play\");\n  dom.autoPlayBtn.textContent = \"Stop Auto-play\";\n  const speed = parseInt(dom.speedSlider.value, 10);\n  let i = 0;\n  App.autoPlayTimer = setInterval(() => {\n    loadStepAt(i);\n    i++;\n    if (i >= App.steps.length) { clearInterval(App.autoPlayTimer); App.autoPlayTimer = null; dom.autoPlayBtn.textContent = \"Auto-play Steps\"; }\n  }, speed);\n});\n\ndom.speedSlider.addEventListener('input', () => { dom.speedDisplay.textContent = dom.speedSlider.value; });\n\ndom.undoBtn.addEventListener('click', undo);\ndom.redoBtn.addEventListener('click', redo);\ndom.clearHistoryBtn.addEventListener('click', () => { App.history = []; App.historyIndex = -1; });\n\n/* Export / Import / Snapshots */\ndom.exportBtn.addEventListener('click', () => {\n  const s = App.tree.toJSON();\n  dom.importArea.value = s;\n  alert(\"Tree JSON exported to import area (you can copy).\");\n});\n\ndom.importBtn.addEventListener('click', () => {\n  const json = dom.importArea.value.trim();\n  if (!json) return alert(\"Paste JSON into import area\");\n  try {\n    App.tree.fromJSON(json);\n    pushHistory(\"import\");\n    refreshUI();\n    alert(\"Import successful\");\n  } catch (e) {\n    alert(\"Import failed: \" + e);\n  }\n});\n\ndom.saveSnapshotBtn.addEventListener('click', () => {\n  const name = dom.snapshotName.value || (\"snap\" + new Date().toISOString());\n  const sList = JSON.parse(localStorage.getItem('rb_snapshots') || \"[]\");\n  sList.push({ name: name, json: App.tree.toJSON(), date: new Date().toISOString() });\n  localStorage.setItem('rb_snapshots', JSON.stringify(sList));\n  refreshSnapshotList();\n});\n\nfunction refreshSnapshotList() {\n  dom.snapshotList.innerHTML = \"\";\n  const sList = JSON.parse(localStorage.getItem('rb_snapshots') || \"[]\");\n  sList.forEach((s, i) => {\n    const opt = document.createElement('option');\n    opt.value = i;\n    opt.text = i + \": \" + s.name + \" (\" + s.date + \")\";\n    dom.snapshotList.appendChild(opt);\n  });\n}\n\ndom.loadSnapshotBtn.addEventListener('click', () => {\n  const idx = parseInt(dom.snapshotList.value, 10);\n  const sList = JSON.parse(localStorage.getItem('rb_snapshots') || \"[]\");\n  if (!sList[idx]) return alert(\"Select a snapshot\");\n  App.tree.fromJSON(sList[idx].json);\n  pushHistory(\"load snapshot \" + sList[idx].name);\n  refreshUI();\n});\n\ndom.deleteSnapshotBtn.addEventListener('click', () => {\n  const idx = parseInt(dom.snapshotList.value, 10);\n  const sList = JSON.parse(localStorage.getItem('rb_snapshots') || \"[]\");\n  if (!sList[idx]) return alert(\"Select a snapshot\");\n  sList.splice(idx, 1);\n  localStorage.setItem('rb_snapshots', JSON.stringify(sList));\n  refreshSnapshotList();\n});\n\n/* Steps list actions */\ndom.clearStepsBtn.addEventListener('click', clearSteps);\ndom.loadStepBtn.addEventListener('click', () => {\n  const idx = parseInt(dom.stepsList.value, 10);\n  loadStepAt(idx);\n});\ndom.appendCurrentAsStepBtn.addEventListener('click', () => {\n  appendStepCustom(snapshotOf(App.tree, \"manual snapshot\"));\n});\n\n/* Traversals and queries */\nfunction inorder(n, res) { if (n.isNil) return; inorder(n.left,res); res.push(n.key); inorder(n.right,res); }\nfunction preorder(n,res) { if (n.isNil) return; res.push(n.key); preorder(n.left,res); preorder(n.right,res); }\nfunction postorder(n,res) { if (n.isNil) return; postorder(n.left,res); postorder(n.right,res); res.push(n.key); }\nfunction levelorder(root,res) {\n  const NIL = App.tree.NIL;\n  if (root.isNil) return;\n  const q = [root];\n  while (q.length) {\n    const n = q.shift();\n    res.push(n.key);\n    if (!n.left.isNil) q.push(n.left);\n    if (!n.right.isNil) q.push(n.right);\n  }\n}\n\ndom.inorderBtn.addEventListener('click', () => {\n  const r = []; inorder(App.tree.root, r); dom.diagnostics.textContent = \"In-order: \" + r.join(\", \");\n});\ndom.preorderBtn.addEventListener('click', () => {\n  const r = []; preorder(App.tree.root, r); dom.diagnostics.textContent = \"Pre-order: \" + r.join(\", \");\n});\ndom.postorderBtn.addEventListener('click', () => {\n  const r = []; postorder(App.tree.root, r); dom.diagnostics.textContent = \"Post-order: \" + r.join(\", \");\n});\ndom.levelorderBtn.addEventListener('click', () => {\n  const r = []; levelorder(App.tree.root, r); dom.diagnostics.textContent = \"Level-order: \" + r.join(\", \");\n});\ndom.rangeQueryBtn.addEventListener('click', () => {\n  const lo = parseInt(dom.loKey.value,10); const hi = parseInt(dom.hiKey.value,10);\n  if (isNaN(lo) || isNaN(hi)) return alert(\"Enter both lo and hi\");\n  const res = [];\n  function dfs(n) {\n    if (n.isNil) return;\n    if (n.key >= lo && n.key <= hi) res.push(n.key);\n    if (n.left && !n.left.isNil) dfs(n.left);\n    if (n.right && !n.right.isNil) dfs(n.right);\n  }\n  dfs(App.tree.root);\n  dom.diagnostics.textContent = \"Range [\"+lo+\",\"+hi+\"]: \" + res.sort((a,b)=>a-b).join(\", \");\n});\ndom.findMinBtn.addEventListener('click', () => {\n  if (App.tree.root.isNil) return dom.diagnostics.textContent = \"Empty\";\n  const m = App.tree.minimum(App.tree.root);\n  dom.diagnostics.textContent = \"Min: \" + m.key;\n});\ndom.findMaxBtn.addEventListener('click', () => {\n  if (App.tree.root.isNil) return dom.diagnostics.textContent = \"Empty\";\n  const m = App.tree.maximum(App.tree.root);\n  dom.diagnostics.textContent = \"Max: \" + m.key;\n});\n\n/* Diagnostics */\ndom.checkInvariantsBtn.addEventListener('click', () => {\n  const res = App.tree.checkInvariants();\n  dom.diagnostics.textContent = res.messages.join(\"\\n\");\n});\ndom.fixViolationsBtn.addEventListener('click', () => {\n  // simplistic auto-fix: rebuild by reinserting nodes as proper RB tree from sorted unique keys\n  const keys = [];\n  inorder(App.tree.root, keys);\n  const uniq = Array.from(new Set(keys));\n  const newTree = new RBTree();\n  App.tree = newTree;\n  for (let k of uniq) newTree.insert(k, null);\n  pushHistory(\"rebuild to fix violations\");\n  appendStep(\"rebuild tree from sorted unique keys\");\n  refreshUI();\n});\n\n/* Examples */\ndom.example1Btn.addEventListener('click', () => {\n  App.tree = new RBTree();\n  for (let i=1;i<=10;i++) App.tree.insert(i, null);\n  pushHistory(\"example sequential 1..10\");\n  refreshUI();\n});\ndom.example2Btn.addEventListener('click', () => {\n  App.tree = new RBTree();\n  const seq = [10,85,15,70,20,60,30,50,65,80,90,40,5,2,1,3,4,6,7,8,9];\n  for (let k of seq) App.tree.insert(k, null);\n  pushHistory(\"example classic\");\n  refreshUI();\n});\ndom.clearTreeBtn.addEventListener('click', () => {\n  App.tree = new RBTree();\n  pushHistory(\"clear\");\n  refreshUI();\n});\n\n/* Steps list select load */\ndom.stepsList.addEventListener('dblclick', () => {\n  const idx = parseInt(dom.stepsList.value, 10);\n  loadStepAt(idx);\n});\n\n/* Steps loading via select change reflects index */\ndom.stepsList.addEventListener('change', () => {\n  // no-op\n});\n\n/* Misc helpers */\nfunction sleep(ms) { return new Promise(r => setTimeout(r, ms)); }\n\n/* Initialize */\n(function init(){\n  refreshSnapshotList();\n  refreshUI();\n  // initial history\n  pushHistory(\"initial empty\");\n  // sample initial steps\n  appendStepCustom(snapshotOf(App.tree, \"initial\"));\n  renderStepsList();\n})();\n</script>\n</body>\n</html>"
  },
