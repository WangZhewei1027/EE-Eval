    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Quick Sort</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .section {\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            margin-bottom: 20px;\n        }\n        .section h2 {\n            margin-top: 0;\n        }\n        .section p {\n            margin-bottom: 10px;\n        }\n        .sort-container {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        .sort-button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .sort-button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"section\">\n            <h2>Quick Sort</h2>\n            <p>Sort an array of numbers using the Quick Sort algorithm.</p>\n            <button class=\"sort-button\" id=\"sort-button\">Sort</button>\n            <button class=\"sort-button\" id=\"reverse-button\">Reverse</button>\n        </div>\n        <div class=\"section\">\n            <h2>Example Data:</h2>\n            <p>Array of numbers:</p>\n            <ul>\n                <li>1</li>\n                <li>3</li>\n                <li>5</li>\n                <li>7</li>\n                <li>9</li>\n            </ul>\n            <p>Original array:</p>\n            <pre>1 3 5 7 9</pre>\n        </div>\n    </div>\n\n    <script>\n        function quickSort(arr, low, high) {\n            if (low < high) {\n                const pivotIndex = partition(arr, low, high);\n                quickSort(arr, low, pivotIndex - 1);\n                quickSort(arr, pivotIndex + 1, high);\n            }\n        }\n\n        function partition(arr, low, high) {\n            const pivot = arr[high];\n            let i = low - 1;\n            for (let j = low; j < high; j++) {\n                if (arr[j] < pivot) {\n                    i++;\n                    [arr[i], arr[j]] = [arr[j], arr[i]];\n                }\n            }\n            [arr[i + 1], arr[high]] = [arr[high], arr[i + 1]];\n            return i + 1;\n        }\n\n        const arr = [1, 3, 5, 7, 9];\n        quickSort(arr, 0, arr.length - 1);\n        console.log(\"Sorted array:\", arr);\n\n        const reverseButton = document.getElementById(\"reverse-button\");\n        reverseButton.addEventListener(\"click\", () => {\n            arr = arr.slice().reverse();\n            console.log(\"Array after reversing:\", arr);\n        });\n    </script>\n</body>\n</html>"
