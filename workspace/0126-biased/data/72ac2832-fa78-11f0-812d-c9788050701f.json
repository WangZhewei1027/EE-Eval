    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Transaction Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n            --warning: #fdcb6e;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1s ease-out;\n        }\n        \n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n        \n        .transaction-visualization {\n            position: relative;\n            height: 500px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px rgba(0,0,0,0.1);\n            overflow: hidden;\n            padding: 2rem;\n            margin-bottom: 3rem;\n            animation: slideUp 1s ease-out;\n        }\n        \n        .transaction-path {\n            position: relative;\n            height: 100%;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        \n        .node {\n            position: relative;\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: 600;\n            z-index: 2;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n            transition: all 0.5s ease;\n            cursor: default;\n        }\n        \n        .node:hover {\n            transform: scale(1.1);\n            box-shadow: 0 15px 40px rgba(0,0,0,0.3);\n        }\n        \n        .node-icon {\n            font-size: 2rem;\n            margin-bottom: 0.5rem;\n        }\n        \n        .node-label {\n            font-size: 0.9rem;\n            font-weight: 400;\n        }\n        \n        .sender {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n        }\n        \n        .network {\n            background: linear-gradient(135deg, #0984e3, #74b9ff);\n        }\n        \n        .blockchain {\n            background: linear-gradient(135deg, #00b894, #55efc4);\n        }\n        \n        .receiver {\n            background: linear-gradient(135deg, var(--accent), #ff7675);\n        }\n        \n        .connection-line {\n            position: absolute;\n            height: 8px;\n            background: linear-gradient(to right, var(--secondary), #74b9ff, #55efc4, var(--accent));\n            top: 50%;\n            left: 120px;\n            right: 120px;\n            transform: translateY(-50%);\n            border-radius: 10px;\n            z-index: 1;\n            animation: pulse 3s infinite;\n        }\n        \n        .transaction-details {\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0,0,0,0.1);\n            padding: 2rem;\n            margin-bottom: 3rem;\n            animation: slideUp 1.2s ease-out;\n        }\n        \n        .details-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 1.5rem;\n            padding-bottom: 1rem;\n            border-bottom: 1px solid rgba(0,0,0,0.1);\n        }\n        \n        .details-title {\n            font-size: 1.5rem;\n            font-weight: 600;\n            color: var(--primary);\n        }\n        \n        .status-badge {\n            padding: 0.5rem 1rem;\n            border-radius: 50px;\n            font-size: 0.9rem;\n            font-weight: 600;\n            background: var(--success);\n            color: white;\n        }\n        \n        .detail-row {\n            display: flex;\n            margin-bottom: 1rem;\n        }\n        \n        .detail-label {\n            width: 150px;\n            font-weight: 600;\n            color: rgba(0,0,0,0.7);\n        }\n        \n        .detail-value {\n            flex: 1;\n            font-family: monospace;\n        }\n        \n        .visualization-controls {\n            text-align: center;\n            margin-top: 2rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n        \n        .btn {\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            border: none;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0,0,0,0.1);\n        }\n        \n        .btn-primary {\n            background: var(--primary);\n            color: white;\n        }\n        \n        .btn-primary:hover {\n            background: #5a4bd1;\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.3);\n        }\n        \n        .btn-outline {\n            background: transparent;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n            margin-left: 1rem;\n        }\n        \n        .btn-outline:hover {\n            background: rgba(108, 92, 231, 0.1);\n            transform: translateY(-2px);\n        }\n        \n        .transaction-animation {\n            position: absolute;\n            width: 20px;\n            height: 20px;\n            background: white;\n            border-radius: 50%;\n            box-shadow: 0 0 20px rgba(255,255,255,0.8);\n            z-index: 3;\n            opacity: 0;\n        }\n        \n        .confetti {\n            position: fixed;\n            width: 10px;\n            height: 10px;\n            background: var(--accent);\n            opacity: 0;\n            z-index: 100;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulse {\n            0% { opacity: 0.7; }\n            50% { opacity: 1; }\n            100% { opacity: 0.7; }\n        }\n        \n        @keyframes moveCoin {\n            0% { left: 120px; opacity: 1; }\n            100% { left: calc(100% - 140px); opacity: 1; }\n        }\n        \n        @keyframes confettiFall {\n            0% { \n                transform: translateY(-100px) rotate(0deg); \n                opacity: 1;\n            }\n            100% { \n                transform: translateY(100vh) rotate(360deg); \n                opacity: 0;\n            }\n        }\n        \n        @media (max-width: 768px) {\n            .transaction-path {\n                flex-direction: column;\n                height: auto;\n                padding: 2rem 0;\n            }\n            \n            .node {\n                margin: 1rem 0;\n            }\n            \n            .connection-line {\n                width: 8px;\n                height: 100%;\n                left: 50%;\n                top: 0;\n                transform: translateX(-50%);\n                background: linear-gradient(to bottom, var(--secondary), #74b9ff, #55efc4, var(--accent));\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Transaction Flow</h1>\n            <p class=\"subtitle\">Visualizing the journey of a blockchain transaction</p>\n        </header>\n        \n        <div class=\"transaction-visualization\">\n            <div class=\"connection-line\"></div>\n            <div class=\"transaction-path\">\n                <div class=\"node sender\" id=\"sender\">\n                    <div class=\"node-icon\">👤</div>\n                    <div class=\"node-label\">Sender</div>\n                </div>\n                \n                <div class=\"node network\" id=\"network\">\n                    <div class=\"node-icon\">🌐</div>\n                    <div class=\"node-label\">Network</div>\n                </div>\n                \n                <div class=\"node blockchain\" id=\"blockchain\">\n                    <div class=\"node-icon\">⛓️</div>\n                    <div class=\"node-label\">Blockchain</div>\n                </div>\n                \n                <div class=\"node receiver\" id=\"receiver\">\n                    <div class=\"node-icon\">👤</div>\n                    <div class=\"node-label\">Receiver</div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"transaction-details\">\n            <div class=\"details-header\">\n                <div class=\"details-title\">Transaction Details</div>\n                <div class=\"status-badge\" id=\"statusBadge\">Pending</div>\n            </div>\n            \n            <div class=\"detail-row\">\n                <div class=\"detail-label\">Transaction ID:</div>\n                <div class=\"detail-value\">0x8a3f...c72d</div>\n            </div>\n            \n            <div class=\"detail-row\">\n                <div class=\"detail-label\">Amount:</div>\n                <div class=\"detail-value\">1.5 ETH</div>\n            </div>\n            \n            <div class=\"detail-row\">\n                <div class=\"detail-label\">From:</div>\n                <div class=\"detail-value\">0x4b3a...f9e2</div>\n            </div>\n            \n            <div class=\"detail-row\">\n                <div class=\"detail-label\">To:</div>\n                <div class=\"detail-value\">0x7d1f...a4c6</div>\n            </div>\n            \n            <div class=\"detail-row\">\n                <div class=\"detail-label\">Gas Fee:</div>\n                <div class=\"detail-value\">0.0021 ETH</div>\n            </div>\n            \n            <div class=\"detail-row\">\n                <div class=\"detail-label\">Timestamp:</div>\n                <div class=\"detail-value\">2023-06-15 14:32:45 UTC</div>\n            </div>\n        </div>\n        \n        <div class=\"visualization-controls\">\n            <button class=\"btn btn-primary\" id=\"startBtn\">Start Transaction</button>\n            <button class=\"btn btn-outline\" id=\"resetBtn\">Reset</button>\n        </div>\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const statusBadge = document.getElementById('statusBadge');\n            const transactionVisualization = document.querySelector('.transaction-visualization');\n            \n            let animationInProgress = false;\n            \n            startBtn.addEventListener('click', function() {\n                if (animationInProgress) return;\n                animationInProgress = true;\n                \n                // Reset previous animations\n                document.querySelectorAll('.transaction-animation').forEach(el => el.remove());\n                \n                // Create coin animation\n                const coin = document.createElement('div');\n                coin.className = 'transaction-animation';\n                coin.style.top = '50%';\n                coin.style.left = '120px';\n                coin.style.transform = 'translateY(-50%)';\n                transactionVisualization.appendChild(coin);\n                \n                // Update status\n                statusBadge.textContent = 'Processing';\n                statusBadge.style.background = 'var(--warning)';\n                \n                // Animate coin through the path\n                setTimeout(() => {\n                    coin.style.animation = 'moveCoin 2s forwards';\n                    \n                    // When coin reaches network node\n                    setTimeout(() => {\n                        document.getElementById('network').style.transform = 'scale(1.1)';\n                    }, 500);\n                    \n                    // When coin reaches blockchain node\n                    setTimeout(() => {\n                        document.getElementById('blockchain').style.transform = 'scale(1.1)';\n                    }, 1500);\n                    \n                    // When coin reaches receiver\n                    setTimeout(() => {\n                        document.getElementById('receiver').style.transform = 'scale(1.1)';\n                        statusBadge.textContent = 'Completed';\n                        statusBadge.style.background = 'var(--success)';\n                        \n                        // Create confetti celebration\n                        createConfetti();\n                        animationInProgress = false;\n                    }, 2000);\n                }, 100);\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                // Reset all animations and states\n                document.querySelectorAll('.transaction-animation, .confetti').forEach(el => el.remove());\n                document.querySelectorAll('.node').forEach(node => {\n                    node.style.transform = 'scale(1)';\n                });\n                \n                statusBadge.textContent = 'Pending';\n                statusBadge.style.background = 'var(--warning)';\n                animationInProgress = false;\n            });\n            \n            function createConfetti() {\n                const colors = ['var(--primary)', 'var(--secondary)', 'var(--accent)', 'var(--success)', 'var(--warning)'];\n                \n                for (let i = 0; i < 50; i++) {\n                    const confetti = document.createElement('div');\n                    confetti.className = 'confetti';\n                    confetti.style.background = colors[Math.floor(Math.random() * colors.length)];\n                    confetti.style.left = Math.random() * 100 + 'vw';\n                    confetti.style.width = (Math.random() * 10 + 5) + 'px';\n                    confetti.style.height = (Math.random() * 10 + 5) + 'px';\n                    confetti.style.animation = `confettiFall ${Math.random() * 3 + 2}s linear forwards`;\n                    document.body.appendChild(confetti);\n                    \n                    // Remove confetti after animation\n                    setTimeout(() => {\n                        confetti.remove();\n                    }, 5000);\n                }\n            }\n        });\n    </script>\n</body>\n</html>"
