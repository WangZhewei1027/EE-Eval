    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Selection Sort — Visual Elegance</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1:#0f1724;\n      --bg-2:#081021;\n      --glass: rgba(255,255,255,0.04);\n      --muted: rgba(255,255,255,0.55);\n      --accent: linear-gradient(135deg,#7c5cff 0%,#5ee7df 100%);\n      --accent-solid: #7c5cff;\n      --accent-2: #5ee7df;\n      --card-shadow: 0 10px 40px rgba(2,6,23,0.65);\n      --glass-border: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      --neon: rgba(124,92,255,0.12);\n      --success: #2ee6a7;\n      --danger: #ff6b6b;\n      --glass-2: rgba(255,255,255,0.02);\n    }\n\n    *{box-sizing:border-box}\n    html,body{\n      height:100%;\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 20%, rgba(94,231,223,0.06), transparent 8%),\n                  radial-gradient(900px 500px at 90% 80%, rgba(124,92,255,0.045), transparent 10%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color:#e9eef8;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:32px;\n    }\n\n    /* Subtle animated background orbs */\n    .orbs{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n      overflow:hidden;\n    }\n    .orb{\n      position:absolute;\n      width:420px;\n      height:420px;\n      border-radius:50%;\n      filter:blur(60px) saturate(120%);\n      opacity:0.16;\n      transform:translate3d(0,0,0);\n      mix-blend-mode:screen;\n      animation: float 12s ease-in-out infinite;\n    }\n    .orb.a{left:-10%; top:5%; background:linear-gradient(135deg,#7c5cff,#5ee7df); animation-delay:-2s;}\n    .orb.b{right:-12%; bottom:-4%; width:520px;height:520px;background:linear-gradient(135deg,#ff8ab2,#7c5cff); animation-delay:-6s;opacity:0.12;}\n    @keyframes float{\n      0%{transform:translateY(0px) rotate(0deg)}\n      50%{transform:translateY(-24px) rotate(12deg)}\n      100%{transform:translateY(0px) rotate(0deg)}\n    }\n\n    /* Card */\n    .stage{\n      position:relative;\n      z-index:3;\n      width:min(1100px,98%);\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n      border-radius:20px;\n      padding:28px;\n      box-shadow:var(--card-shadow);\n      border: 1px solid rgba(255,255,255,0.03);\n      display:grid;\n      grid-template-columns: 1fr 380px;\n      gap:24px;\n      overflow:hidden;\n      backdrop-filter: blur(8px) saturate(120%);\n    }\n\n    /* Header */\n    .header{\n      grid-column:1/-1;\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:20px;\n    }\n    .title{\n      display:flex;\n      gap:18px;\n      align-items:center;\n    }\n    .logo{\n      width:62px;\n      height:62px;\n      border-radius:12px;\n      background: linear-gradient(135deg,#7c5cff,#5ee7df);\n      box-shadow: 0 6px 30px rgba(124,92,255,0.18), inset 0 -6px 18px rgba(255,255,255,0.08);\n      display:grid;\n      place-items:center;\n      color:white;\n      font-weight:800;\n      font-size:20px;\n      letter-spacing:0.6px;\n    }\n    .meta{\n      line-height:1;\n    }\n    .meta h1{\n      margin:0;\n      font-size:18px;\n      letter-spacing:-0.2px;\n      font-weight:700;\n    }\n    .meta p{\n      margin:0;\n      margin-top:4px;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      appearance:none;\n      border:0;\n      padding:10px 14px;\n      border-radius:12px;\n      min-width:96px;\n      cursor:pointer;\n      font-weight:600;\n      font-size:14px;\n      color:white;\n      background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n      border:1px solid rgba(255,255,255,0.04);\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      justify-content:center;\n      transition:transform .18s ease, box-shadow .18s ease, opacity .12s;\n    }\n    .btn:active{transform:translateY(1px) scale(.998)}\n    .btn.play{\n      background: var(--accent);\n      box-shadow: 0 8px 28px rgba(124,92,255,0.18), 0 2px 18px rgba(94,231,223,0.06);\n      border: none;\n      color: white;\n    }\n    .btn.ghost{\n      background: transparent;\n      border: 1px solid rgba(255,255,255,0.06);\n      color:var(--muted);\n      min-width:44px;\n      padding:10px;\n    }\n    .hint{\n      font-size:12px;\n      color:var(--muted);\n      padding-left:8px;\n    }\n\n    /* Main visual */\n    .visual{\n      padding:24px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.01));\n      border-radius:14px;\n      border: 1px solid rgba(255,255,255,0.02);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      min-height:420px;\n      position:relative;\n      overflow:hidden;\n    }\n\n    .legend{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      color:var(--muted);\n      font-size:13px;\n      margin-left:6px;\n    }\n    .legend .dot{\n      width:12px;height:12px;border-radius:4px;\n      background:var(--glass-2);\n      box-shadow: inset 0 -3px 6px rgba(0,0,0,0.3);\n      display:inline-block;\n      margin-right:8px;\n    }\n    .legend .dot.current{ background: linear-gradient(90deg,#ffd57a,#ff8ab2);}\n    .legend .dot.min{ background: linear-gradient(90deg,#7c5cff,#5ee7df);}\n    .legend .dot.sorted{ background: linear-gradient(90deg,#65e9b2,#29d1a1);}\n\n    .bar-area{\n      --gap:18px;\n      flex:1;\n      display:flex;\n      align-items:end;\n      justify-content:center;\n      gap:var(--gap);\n      padding:18px;\n      position:relative;\n      perspective:900px;\n      user-select:none;\n    }\n\n    /* Bar styles */\n    .bar{\n      width:48px;\n      height:160px;\n      display:flex;\n      align-items:flex-end;\n      justify-content:center;\n      border-radius:12px;\n      position:relative;\n      transform-origin:center bottom;\n      transition: box-shadow .22s ease, transform .32s cubic-bezier(.2,.9,.24,1), opacity .18s;\n      will-change:transform, opacity;\n      cursor:default;\n    }\n    .bar .unit{\n      width:100%;\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      border-radius:10px;\n      display:flex;\n      align-items:flex-end;\n      justify-content:center;\n      position:relative;\n      overflow:visible;\n      box-shadow: 0 6px 22px rgba(2,6,23,0.6), inset 0 -8px 22px rgba(0,0,0,0.18);\n      border: 1px solid rgba(255,255,255,0.02);\n      padding-bottom:12px;\n      transition: transform .32s cubic-bezier(.2,.9,.24,1);\n    }\n    .bar .label{\n      position:absolute;\n      bottom:8px;\n      font-weight:600;\n      font-size:13px;\n      color:white;\n      text-shadow: 0 6px 18px rgba(0,0,0,0.45);\n    }\n    .bar.small .label{ font-size:12px; }\n    .bar.current{ transform: translateY(-10px) scale(1.03); box-shadow: 0 18px 40px rgba(255,172,102,0.08); }\n    .bar.compare{ transform: translateY(-10px) scale(1.04); }\n    .bar.min{ box-shadow: 0 18px 40px rgba(94,231,223,0.06); transform: translateY(-6px) scale(1.02); }\n    .bar.sorted{ opacity:1; transform: translateY(-2px) scale(.998); box-shadow: 0 12px 30px rgba(46,230,167,0.06); }\n\n    /* Colors for bar inner gradient via data-index for variety */\n    .bar .unit::before{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      border-radius:9px;\n      opacity:0.94;\n      transition: opacity .18s, transform .18s;\n      z-index:0;\n    }\n    .bar .unit .label{\n      z-index:3;\n      position:relative;\n    }\n\n    /* different accent fills */\n    .bar[data-color=\"0\"] .unit::before{ background: linear-gradient(180deg,#7c5cff 0%, #4a42f5 100%); box-shadow: 0 12px 30px rgba(76,58,238,0.12) inset; }\n    .bar[data-color=\"1\"] .unit::before{ background: linear-gradient(180deg,#5ee7df 0%, #49c8bf 100%); box-shadow: 0 12px 30px rgba(93,230,220,0.08) inset; }\n    .bar[data-color=\"2\"] .unit::before{ background: linear-gradient(180deg,#ff8ab2 0%, #ff6b8a 100%); box-shadow: 0 12px 30px rgba(255,139,155,0.08) inset; }\n    .bar[data-color=\"3\"] .unit::before{ background: linear-gradient(180deg,#ffd57a 0%, #ffb86b 100%); box-shadow: 0 12px 30px rgba(255,200,120,0.06) inset; }\n    .bar[data-color=\"4\"] .unit::before{ background: linear-gradient(180deg,#a8ff78 0%, #78ffd6 100%); box-shadow: 0 12px 30px rgba(130,230,160,0.06) inset; }\n\n    .bar .halo{\n      position:absolute;\n      inset:auto -14px auto -14px;\n      height:10px;\n      top:-18px;\n      border-radius:10px;\n      filter:blur(18px);\n      opacity:0;\n      transition:opacity .2s;\n      z-index:1;\n      mix-blend-mode:screen;\n    }\n    .bar.current .halo{ opacity:1; background: linear-gradient(90deg, rgba(255,183,87,0.28), rgba(255,138,178,0.28)); }\n    .bar.min .halo{ opacity:1; background: linear-gradient(90deg, rgba(124,92,255,0.18), rgba(94,231,223,0.18)); }\n    .bar.sorted .halo{ opacity:1; background: linear-gradient(90deg, rgba(46,230,167,0.12), rgba(46,230,167,0.06)); }\n\n    /* Right panel */\n    .panel{\n      padding:22px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.01));\n      border-radius:12px;\n      border:1px solid rgba(255,255,255,0.02);\n      display:flex;\n      flex-direction:column;\n      gap:16px;\n      min-height:420px;\n    }\n    .panel h3{\n      margin:0;\n      font-size:15px;\n      font-weight:700;\n    }\n    .code{\n      background: linear-gradient(180deg, rgba(8,10,20,0.6), rgba(20,22,30,0.45));\n      border-radius:10px;\n      padding:14px;\n      color:#e9eef8;\n      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Courier New\", monospace;\n      font-size:13px;\n      line-height:1.6;\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .code .line{\n      padding:6px 8px;\n      border-radius:8px;\n      display:flex;\n      gap:8px;\n      align-items:flex-start;\n      transition: background .18s ease, color .18s ease;\n    }\n    .code .line .num{ color:rgba(255,255,255,0.28); min-width:28px; text-align:right; padding-right:6px; font-weight:600; }\n    .code .line .txt{ white-space:pre-wrap; flex:1; color:rgba(255,255,255,0.82); }\n    .code .line.current{ background: linear-gradient(90deg, rgba(124,92,255,0.08), rgba(94,231,223,0.04)); box-shadow: 0 6px 26px rgba(124,92,255,0.06) inset; }\n\n    .stats{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:auto;\n    }\n    .stat{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:10px 14px;\n      border-radius:10px;\n      border:1px solid rgba(255,255,255,0.02);\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n      min-width:110px;\n      text-align:center;\n    }\n    .stat .n{ font-weight:700; font-size:18px; }\n    .stat .t{ font-size:12px; color:var(--muted); }\n\n    .footer-note{\n      font-size:12px;\n      color:var(--muted);\n      margin-top:6px;\n    }\n\n    /* small screens */\n    @media (max-width:980px){\n      .stage{ grid-template-columns:1fr; padding:18px; gap:14px;}\n      .panel{order:2}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"orbs\" aria-hidden=\"true\">\n    <div class=\"orb a\"></div>\n    <div class=\"orb b\"></div>\n  </div>\n\n  <div class=\"stage\" role=\"application\" aria-label=\"Selection Sort visualization\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">SS</div>\n        <div class=\"meta\">\n          <h1>Selection Sort</h1>\n          <p>Classic in-place comparison sort — visualized with poetry.</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n        <button id=\"playBtn\" class=\"btn play\" aria-pressed=\"false\" title=\"Play / Pause\">\n          ▶ Play\n        </button>\n        <button id=\"shuffleBtn\" class=\"btn ghost\" title=\"Shuffle array\">\n          Shuffle\n        </button>\n        <div class=\"hint\" aria-hidden=\"true\">Minimal controls • Observe the algorithm</div>\n      </div>\n    </div>\n\n    <section class=\"visual\" aria-live=\"polite\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n        <div class=\"legend\">\n          <span class=\"dot current\"></span><span style=\"margin-right:10px\">Current i</span>\n          <span class=\"dot min\"></span><span style=\"margin-right:10px\">Current min</span>\n          <span class=\"dot sorted\"></span><span>Sorted</span>\n        </div>\n        <div style=\"color:var(--muted); font-size:13px;\">Steps: <span id=\"stepCount\">0</span></div>\n      </div>\n\n      <div id=\"barArea\" class=\"bar-area\" aria-hidden=\"false\">\n        <!-- Bars will be injected here -->\n      </div>\n\n      <div style=\"display:flex;gap:12px;align-items:center;justify-content:space-between;\">\n        <div style=\"color:var(--muted);font-size:13px;\">\n          <strong id=\"statusTitle\" style=\"color:var(--muted)\"></strong>\n        </div>\n        <div style=\"display:flex;gap:12px;align-items:center;\">\n          <div style=\"width:220px;height:10px;border-radius:999px;background:rgba(255,255,255,0.03);overflow:hidden;\">\n            <div id=\"progress\" style=\"height:100%;width:0%;background:linear-gradient(90deg,#7c5cff,#5ee7df);transition:width .6s cubic-bezier(.2,.9,.24,1);box-shadow:0 6px 26px rgba(124,92,255,0.08)\"></div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <aside class=\"panel\">\n      <h3>Pseudocode</h3>\n      <div class=\"code\" aria-hidden=\"false\" id=\"pseudocode\">\n        <div class=\"line\" data-line=\"1\"><div class=\"num\">1</div><div class=\"txt\">for i from 0 to n-2</div></div>\n        <div class=\"line\" data-line=\"2\"><div class=\"num\">2</div><div class=\"txt\">  minIndex = i</div></div>\n        <div class=\"line\" data-line=\"3\"><div class=\"num\">3</div><div class=\"txt\">  for j from i+1 to n-1</div></div>\n        <div class=\"line\" data-line=\"4\"><div class=\"num\">4</div><div class=\"txt\">    if array[j] &lt; array[minIndex]</div></div>\n        <div class=\"line\" data-line=\"5\"><div class=\"num\">5</div><div class=\"txt\">      minIndex = j</div></div>\n        <div class=\"line\" data-line=\"6\"><div class=\"num\">6</div><div class=\"txt\">  swap array[i] and array[minIndex]</div></div>\n      </div>\n\n      <div style=\"display:flex;flex-direction:column;gap:6px;margin-top:4px;\">\n        <div style=\"font-weight:700;\">Snapshot</div>\n        <div style=\"color:var(--muted);font-size:13px;\">Observe comparisons, min updates, and swaps — the algorithm steadily builds the sorted prefix on the left.</div>\n      </div>\n\n      <div class=\"stats\" role=\"status\" aria-live=\"polite\">\n        <div class=\"stat\">\n          <div class=\"n\" id=\"compCount\">0</div>\n          <div class=\"t\">Comparisons</div>\n        </div>\n        <div class=\"stat\">\n          <div class=\"n\" id=\"swapCount\">0</div>\n          <div class=\"t\">Swaps</div>\n        </div>\n        <div class=\"stat\">\n          <div class=\"n\" id=\"nVal\">10</div>\n          <div class=\"t\">Elements</div>\n        </div>\n      </div>\n\n      <div class=\"footer-note\">Selection sort is simple and performs O(n²) comparisons. This elegant walkthrough prioritizes clarity and beauty.</div>\n    </aside>\n  </div>\n\n  <script>\n    // Elegant Selection Sort Visual (Minimal Controls)\n    const barArea = document.getElementById('barArea');\n    const playBtn = document.getElementById('playBtn');\n    const shuffleBtn = document.getElementById('shuffleBtn');\n    const stepCountEl = document.getElementById('stepCount');\n    const compCountEl = document.getElementById('compCount');\n    const swapCountEl = document.getElementById('swapCount');\n    const nValEl = document.getElementById('nVal');\n    const progressEl = document.getElementById('progress');\n    const statusTitle = document.getElementById('statusTitle');\n    const pseudocode = document.getElementById('pseudocode');\n\n    let arr = [];\n    let bars = [];\n    let playing = false;\n    let controller = { stop:false };\n    let steps = 0, comps=0, swaps=0;\n\n    const COLORS = [\"0\",\"1\",\"2\",\"3\",\"4\"];\n\n    function createArray(n=10){\n      const a = [];\n      for(let i=0;i<n;i++){\n        a.push(Math.floor(Math.random()*90)+10);\n      }\n      return a;\n    }\n\n    function renderArray(a){\n      barArea.innerHTML='';\n      bars = [];\n      const n = a.length;\n      nValEl.textContent = n;\n      a.forEach((v,i) => {\n        const el = document.createElement('div');\n        el.className = 'bar';\n        el.dataset.index = i;\n        el.dataset.color = COLORS[i % COLORS.length];\n        el.style.width = '48px';\n        el.style.height = 'auto';\n\n        // scale height dynamically\n        const height = 40 + (v/100)*220; // px\n        el.style.setProperty('--h', height+'px');\n\n        el.innerHTML = `\n          <div class=\"halo\"></div>\n          <div class=\"unit\" style=\"height:${height}px\">\n            <div class=\"label\">${v}</div>\n          </div>\n        `;\n        barArea.appendChild(el);\n        bars.push(el);\n      });\n\n      // set initial positions (required for FLIP)\n      layoutBars();\n    }\n\n    function layoutBars(){\n      // place items inline with gap using flex; we only need bounding rects for animation swaps\n      // ensure labels centered (handled by CSS)\n    }\n\n    // Helper: sleep\n    function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }\n\n    function setPseudocodeLine(n){\n      const lines = pseudocode.querySelectorAll('.line');\n      lines.forEach(l => l.classList.toggle('current', Number(l.dataset.line)===n));\n    }\n\n    // FLIP animation for swapping two DOM nodes\n    async function animateSwap(i,j){\n      const elA = bars[i];\n      const elB = bars[j];\n\n      if(!elA || !elB || elA === elB) return;\n\n      // get starting rects\n      const rectA = elA.getBoundingClientRect();\n      const rectB = elB.getBoundingClientRect();\n\n      // change DOM order: swap positions in barArea\n      // We will replace nodes to new positions\n      const placeholder = document.createElement('div');\n      barArea.insertBefore(placeholder, elA);\n      barArea.insertBefore(elA, elB);\n      barArea.insertBefore(elB, placeholder);\n      placeholder.remove();\n\n      // update bars array to reflect new order\n      const newBars = Array.from(barArea.children);\n      // compute deltas and apply inverse transforms\n      newBars.forEach((el,idx) => {\n        const old = bars.find(b => b.isSameNode(el));\n        const nowRect = el.getBoundingClientRect();\n        let dx = 0, dy = 0;\n        if(old){\n          const oldRect = old.getBoundingClientRect();\n          dx = oldRect.left - nowRect.left;\n          dy = oldRect.top - nowRect.top;\n        } else {\n          // fallback\n        }\n        el.style.transition = 'none';\n        el.style.transform = `translate(${dx}px, ${dy}px)`;\n      });\n\n      // force reflow\n      await Promise.resolve();\n      await new Promise(r => requestAnimationFrame(r));\n\n      // animate to identity\n      newBars.forEach((el,idx) => {\n        el.style.transition = 'transform 520ms cubic-bezier(.2,.9,.24,1)';\n        el.style.transform = 'translate(0px,0px)';\n      });\n\n      // wait for animation finish\n      await sleep(560);\n\n      // clear transforms/styles\n      newBars.forEach(el => {\n        el.style.transition = '';\n        el.style.transform = '';\n      });\n\n      // update bars reference\n      bars = newBars;\n    }\n\n    // Visual helpers\n    function resetVisuals(){\n      bars.forEach(b => {\n        b.classList.remove('current','min','compare','sorted');\n      });\n      statusTitle.textContent = '';\n      progressEl.style.width = '0%';\n    }\n\n    // Main selection sort visual with pacing\n    async function visualizeSelectionSort(a, ctrl){\n      steps = 0; comps = 0; swaps = 0;\n      stepCountEl.textContent = steps;\n      compCountEl.textContent = comps;\n      swapCountEl.textContent = swaps;\n      statusTitle.textContent = 'Starting…';\n      const n = a.length;\n      setPseudocodeLine(1);\n      for(let i=0;i<n-1;i++){\n        if(ctrl.stop) break;\n        // mark current i\n        bars.forEach(b => b.classList.remove('current','min','compare'));\n        bars[i].classList.add('current');\n        setPseudocodeLine(1);\n        statusTitle.textContent = `Selecting position ${i}`;\n        await sleep(420);\n        let minIndex = i;\n        bars[minIndex].classList.add('min');\n        setPseudocodeLine(2);\n        await sleep(320);\n\n        for(let j=i+1;j<n;j++){\n          if(ctrl.stop) break;\n          // compare j with minIndex\n          setPseudocodeLine(3);\n          bars[j].classList.add('compare');\n          bars[minIndex].classList.add('min');\n          statusTitle.textContent = `Comparing index ${j} (value ${a[j]}) with current min at ${minIndex} (value ${a[minIndex]})`;\n          await sleep(380);\n\n          comps++;\n          compCountEl.textContent = comps;\n          steps++;\n          stepCountEl.textContent = steps;\n\n          setPseudocodeLine(4);\n          await sleep(260);\n\n          if(a[j] < a[minIndex]){\n            // update min\n            bars[minIndex].classList.remove('min');\n            minIndex = j;\n            bars[minIndex].classList.add('min');\n            setPseudocodeLine(5);\n            statusTitle.textContent = `New min found at ${minIndex} (value ${a[minIndex]})`;\n            // subtle emphasis animation\n            bars[minIndex].classList.add('current');\n            await sleep(360);\n            bars[minIndex].classList.remove('current');\n          }\n          bars[j].classList.remove('compare');\n          await sleep(80);\n        }\n\n        // swap i and minIndex\n        setPseudocodeLine(6);\n        if(ctrl.stop) break;\n        statusTitle.textContent = `Swapping index ${i} and ${minIndex}`;\n        if(minIndex !== i){\n          // animate FLIP swap\n          await animateSwap(i, minIndex);\n\n          // swap array and bars references\n          const temp = a[i]; a[i] = a[minIndex]; a[minIndex] = temp;\n          swaps++;\n          swapCountEl.textContent = swaps;\n          steps++;\n          stepCountEl.textContent = steps;\n          await sleep(260);\n        } else {\n          // nothing to swap, a small pulse\n          bars[i].classList.add('current');\n          await sleep(220);\n          bars[i].classList.remove('current');\n        }\n\n        // mark sorted prefix\n        bars.forEach((b,k) => {\n          if(k <= i) b.classList.add('sorted'); // left part sorted\n          b.classList.remove('min');\n        });\n\n        // update progress\n        const prog = Math.round(((i+1)/(n-1))*100);\n        progressEl.style.width = prog + '%';\n        statusTitle.textContent = `Position ${i} locked`;\n        await sleep(240);\n      }\n\n      // finalize\n      bars.forEach(b => b.classList.add('sorted'));\n      progressEl.style.width = '100%';\n      setPseudocodeLine(0);\n      statusTitle.textContent = 'Sorted — finished';\n      return {steps, comps, swaps};\n    }\n\n    // Controls and flow\n    async function startVisual(){\n      playBtn.disabled = true;\n      shuffleBtn.disabled = true;\n      controller.stop = false;\n      playBtn.textContent = '❚❚ Pause';\n      playBtn.setAttribute('aria-pressed','true');\n      playing = true;\n\n      // clone current array\n      const a = arr.slice();\n      await visualizeSelectionSort(a, controller);\n\n      playBtn.textContent = '▶ Play';\n      playBtn.setAttribute('aria-pressed','false');\n      playing = false;\n      playBtn.disabled = false;\n      shuffleBtn.disabled = false;\n    }\n\n    function stopVisual(){\n      controller.stop = true;\n      playBtn.textContent = '▶ Play';\n      playBtn.setAttribute('aria-pressed','false');\n      playing = false;\n      playBtn.disabled = false;\n      shuffleBtn.disabled = false;\n    }\n\n    // Initialize with a default array\n    function init(n=10){\n      arr = createArray(n);\n      renderArray(arr);\n      resetVisuals();\n      stepCountEl.textContent = '0';\n      compCountEl.textContent = '0';\n      swapCountEl.textContent = '0';\n      progressEl.style.width = '0%';\n      statusTitle.textContent = 'Ready';\n    }\n\n    playBtn.addEventListener('click', async () => {\n      if(playing){\n        stopVisual();\n      } else {\n        controller = { stop:false };\n        startVisual();\n      }\n    });\n\n    shuffleBtn.addEventListener('click', () => {\n      if(playing) return;\n      init(10);\n    });\n\n    // Initial render\n    init(10);\n\n    // Accessibility: keyboard shortcut (P) to play/pause — minimal interaction\n    window.addEventListener('keydown',(e) => {\n      if(e.key.toLowerCase() === 'p'){\n        e.preventDefault();\n        playBtn.click();\n      }\n    });\n\n    // Polishing touches: small entrance animation\n    document.querySelectorAll('.bar').forEach((b,i) => {\n      b.style.transform = 'translateY(30px) scale(.98)';\n      b.style.opacity = '0';\n      setTimeout(() => {\n        b.style.transition = 'transform 720ms cubic-bezier(.2,.9,.24,1), opacity 520ms ease';\n        b.style.transform = 'translateY(0px) scale(1)';\n        b.style.opacity = '1';\n      }, 60*i);\n    });\n\n  </script>\n</body>\n</html>"
