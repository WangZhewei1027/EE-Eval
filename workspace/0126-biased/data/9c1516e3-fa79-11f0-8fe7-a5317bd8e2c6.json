  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Amortized Analysis Simulator</title>\n<style>\n  /* Extremely minimal visual styling: plain black on white, basic layout */\n  html,body { background: white; color: black; font-family: sans-serif; margin: 8px; }\n  .row { display: flex; gap: 8px; align-items: flex-start; }\n  .col { display: flex; flex-direction: column; gap: 8px; }\n  fieldset { padding: 8px; }\n  label { display: block; font-size: 13px; margin-bottom: 2px; }\n  input[type=\"text\"], input[type=\"number\"], select, textarea { font-size: 13px; padding: 4px; }\n  button { font-size: 13px; padding: 6px; }\n  .small { font-size: 12px; }\n  .log { white-space: pre; font-family: monospace; font-size: 12px; border: 1px solid black; padding: 6px; height: 160px; overflow: auto; }\n  canvas { border: 1px solid black; background: white; }\n  .ops-list { font-family: monospace; font-size: 12px; border: 1px solid black; padding: 6px; height: 160px; overflow: auto; }\n  .state-box { font-family: monospace; font-size: 13px; border: 1px solid black; padding: 6px; min-width: 220px; white-space: pre; }\n  .controls-grid { display: grid; grid-template-columns: repeat(2, auto); gap: 6px; align-items: center; }\n  .flex-space { flex: 1; }\n</style>\n</head>\n<body>\n<h2>Amortized Analysis Simulator</h2>\n\n<div class=\"row\">\n  <div class=\"col\" style=\"flex:1; min-width:420px;\">\n    <fieldset>\n      <legend>Sequence / Workload</legend>\n      <div class=\"row\">\n        <div style=\"flex:1;\">\n          <label>Manual Operations</label>\n          <div class=\"row\">\n            <button id=\"btnPush\">Push</button>\n            <button id=\"btnPop\">Pop</button>\n            <input id=\"pushValue\" type=\"text\" placeholder=\"value (optional)\" style=\"width:120px;\">\n            <button id=\"btnAppendOp\">Append Op to Sequence</button>\n          </div>\n        </div>\n        <div style=\"width:260px;\">\n          <label>Generate Random Sequence</label>\n          <div class=\"controls-grid\">\n            <label class=\"small\">Length</label><input id=\"randLen\" type=\"number\" value=\"30\" min=\"1\" style=\"width:70px;\">\n            <label class=\"small\">Push Prob (0-1)</label><input id=\"randProb\" type=\"number\" step=\"0.05\" min=\"0\" max=\"1\" value=\"0.7\" style=\"width:70px;\">\n            <label class=\"small\">Seed (optional)</label><input id=\"randSeed\" type=\"text\" placeholder=\"seed\" style=\"width:70px;\">\n            <div></div>\n            <button id=\"btnGenRand\">Generate</button>\n            <button id=\"btnClearSeq\">Clear</button>\n          </div>\n        </div>\n      </div>\n\n      <label>Sequence (editable text: one op per line: push or pop)</label>\n      <textarea id=\"sequenceText\" rows=\"6\" style=\"width:100%; font-family: monospace;\">push\npush\npush\npop\npush</textarea>\n\n      <div class=\"row\">\n        <button id=\"btnLoadSeq\">Load Sequence</button>\n        <button id=\"btnSaveSeq\">Export Sequence</button>\n        <input id=\"exportOut\" type=\"text\" readonly style=\"flex:1;\">\n      </div>\n\n      <label>Ops list (click an op to edit/remove)</label>\n      <div id=\"opsList\" class=\"ops-list\"></div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Snapshots & Branching</legend>\n      <div class=\"row\">\n        <div style=\"flex:1;\">\n          <label>Snapshots</label>\n          <div id=\"snapshotsList\" class=\"ops-list\"></div>\n          <div class=\"row\">\n            <button id=\"btnSaveSnapshot\">Save Snapshot</button>\n            <button id=\"btnRestoreSnapshot\">Restore Selected</button>\n            <button id=\"btnDeleteSnapshot\">Delete Selected</button>\n          </div>\n        </div>\n        <div style=\"width:260px;\">\n          <label>Forks (compare up to 3 strategies)</label>\n          <div class=\"row\">\n            <button id=\"btnAddStrategy\">Add Strategy</button>\n            <button id=\"btnRemoveStrategy\">Remove Strategy</button>\n          </div>\n          <div class=\"small\">Tip: Save snapshot, change parameters, fork and run different policies from same state.</div>\n        </div>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Simulation Controls</legend>\n      <div class=\"row\">\n        <button id=\"btnStep\">Step</button>\n        <button id=\"btnBack\">Back</button>\n        <button id=\"btnRun\">Run</button>\n        <button id=\"btnPause\">Pause</button>\n        <button id=\"btnReset\">Reset</button>\n        <label class=\"small\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"10\" max=\"1000\" value=\"200\">\n      </div>\n\n      <label>Mode</label>\n      <div class=\"row\">\n        <select id=\"modeSelect\">\n          <option value=\"auto\">Auto-simulate sequence</option>\n          <option value=\"manual\">Manual only</option>\n        </select>\n        <div class=\"flex-space\"></div>\n        <label class=\"small\">Show methods</label>\n        <input type=\"checkbox\" id=\"showAggregate\" checked>Aggregate\n        <input type=\"checkbox\" id=\"showAccounting\" checked>Accounting\n        <input type=\"checkbox\" id=\"showPotential\" checked>Potential\n      </div>\n    </fieldset>\n  </div>\n\n  <div class=\"col\" style=\"width:820px;\">\n    <fieldset>\n      <legend>Strategies (up to 3) — click strategy header to configure</legend>\n      <div id=\"strategiesContainer\" class=\"row\"></div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Visualizations / Logs</legend>\n      <canvas id=\"costCanvas\" width=\"800\" height=\"160\"></canvas>\n      <div class=\"row\">\n        <div style=\"flex:1;\">\n          <label>Per-operation log (selected strategy)</label>\n          <div id=\"log\" class=\"log\"></div>\n        </div>\n        <div style=\"width:320px;\">\n          <label>Selected strategy state</label>\n          <div id=\"stateBox\" class=\"state-box\"></div>\n        </div>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Help / Notes</legend>\n      <div style=\"font-size:13px;\">\n        This simulator demonstrates amortized analysis for dynamic arrays (push/pop) under different resizing policies.\n        You can run sequences, step through operations, save snapshots, fork strategies, and compare costs.\n        Methods shown:\n        - Aggregate: total cost / operations.\n        - Accounting: assign charges per op, track saved credits.\n        - Potential: use a potential function phi; amortized = actual + phi_after - phi_before.\n        Configure parameters per strategy and watch costs, potentials, and credits change.\n      </div>\n    </fieldset>\n  </div>\n</div>\n\n<script>\n/* Amortized Analysis Simulator\n   Extremely minimal UI, many interactive controls and branching.\n   Keep logic clear and allow multiple strategies running in parallel.\n*/\n\n// Utility functions\nfunction clamp(v,a,b){return Math.max(a,Math.min(b,v));}\nfunction copy(obj){return JSON.parse(JSON.stringify(obj));}\nfunction seededRandom(seed) {\n  // simple LCG\n  let s = 0;\n  for (let i=0;i<seed.length;i++) s = (s*31 + seed.charCodeAt(i))|0;\n  return function() {\n    s = (s * 1664525 + 1013904223) >>> 0;\n    return s / 4294967296;\n  }\n}\n\n// Core strategy class\nclass Strategy {\n  constructor(id, config) {\n    this.id = id;\n    this.name = config.name || (\"Strategy \"+id);\n    // Parameters\n    this.growthMode = config.growthMode || 'factor'; // 'factor'|'increment'|'custom'\n    this.growthFactor = config.growthFactor || 2.0;\n    this.increment = config.increment || 1;\n    this.customRule = config.customRule || ''; // JS expression newCap = ...\n    this.shrinkEnabled = config.shrinkEnabled || false;\n    this.shrinkFactor = config.shrinkFactor || 0.25;\n    this.copyCost = config.copyCost || 1; // cost per element copy\n    this.baseOpCost = config.baseOpCost || 1; // cost for regular push/pop\n    this.allocCost = config.allocCost || 0; // fixed cost to allocate new array\n    this.freeCost = config.freeCost || 0;\n    // Accounting method parameter\n    this.chargePush = config.chargePush || 3;\n    this.chargePop = config.chargePop || 1;\n    // Potential method parameter\n    this.potentialType = config.potentialType || 'cap_minus_size'; // 'cap_minus_size'|'size'|'custom'\n    this.potentialCoeff = config.potentialCoeff || 1.0;\n    this.customPotential = config.customPotential || ''; // JS expression phi(state)\n    // Simulation state\n    this.reset();\n  }\n\n  reset() {\n    this.size = 0;\n    this.capacity = 1;\n    this.array = new Array(this.capacity);\n    this.opIndex = 0;\n    this.totalCost = 0;\n    this.history = []; // per op: {op, actualCost, amortizedAggregate, accountBalance, potentialBefore, potentialAfter, amortizedPotential, details}\n    this.accountBalance = 0;\n    this.savedStates = [];\n    this.lastAction = null;\n  }\n\n  // decide next capacity based on rule\n  computeNewCapacity(requiredSize) {\n    const cap = this.capacity;\n    if (this.growthMode === 'factor') {\n      let g = Math.max(1.0001, this.growthFactor);\n      let newCap = cap;\n      while (newCap < requiredSize) newCap = Math.floor(Math.max(1, Math.floor(newCap * g)));\n      if (newCap < requiredSize) newCap = requiredSize;\n      return newCap;\n    } else if (this.growthMode === 'increment') {\n      const inc = Math.max(1, Math.floor(this.increment));\n      let newCap = cap;\n      while (newCap < requiredSize) newCap += inc;\n      return newCap;\n    } else {\n      // customRule: user supplies JS that sets newCap based on capacity, required, size\n      try {\n        const fn = new Function('capacity','size','required','Math','Number','parseInt','parseFloat', this.customRule + '; return newCap;');\n        const result = fn(cap, this.size, requiredSize, Math, Number, parseInt, parseFloat);\n        let parsed = Number(result);\n        if (!isFinite(parsed) || parsed < requiredSize) parsed = requiredSize;\n        return Math.max(1, Math.floor(parsed));\n      } catch (e) {\n        return requiredSize;\n      }\n    }\n  }\n\n  potentialValue() {\n    // phi(state)\n    const state = {capacity:this.capacity, size:this.size};\n    if (this.potentialType === 'cap_minus_size') {\n      return this.potentialCoeff * Math.max(0, this.capacity - this.size);\n    } else if (this.potentialType === 'size') {\n      return this.potentialCoeff * this.size;\n    } else {\n      // custom JS expression using state, Math\n      try {\n        const fn = new Function('state','Math', this.customPotential + '; return phi;');\n        const val = fn(state, Math);\n        if (!isFinite(val)) return 0;\n        return val;\n      } catch (e) {\n        return 0;\n      }\n    }\n  }\n\n  performOp(op) {\n    // op: {type:'push'|'pop', value: any}\n    let actualCost = 0;\n    let details = '';\n    const potentialBefore = this.potentialValue();\n    if (op.type === 'push') {\n      // default cost to place element\n      actualCost += this.baseOpCost;\n      // if capacity insufficient -> resize\n      if (this.size + 1 > this.capacity) {\n        const newCap = this.computeNewCapacity(this.size + 1);\n        // cost to copy existing elements\n        const copyCost = this.copyCost * this.size;\n        actualCost += copyCost + this.allocCost;\n        details += `resize ${this.capacity}→${newCap} copyCost=${copyCost} alloc=${this.allocCost}; `;\n        // perform resize\n        const newArray = new Array(newCap);\n        for (let i=0;i<this.size;i++) newArray[i] = this.array[i];\n        this.array = newArray;\n        this.capacity = newCap;\n      }\n      // push element\n      this.array[this.size] = op.value;\n      this.size += 1;\n    } else if (op.type === 'pop') {\n      if (this.size === 0) {\n        // popping empty - define as no op cost 0\n        details += 'pop empty -> no-op; ';\n      } else {\n        actualCost += this.baseOpCost;\n        this.size -= 1;\n        this.array[this.size] = undefined;\n        // possibly shrink\n        if (this.shrinkEnabled && this.size <= Math.floor(this.capacity * this.shrinkFactor)) {\n          // shrink to max(size,1) or compute new capacity\n          const newCap = Math.max(1, Math.floor(Math.max(this.size, this.capacity * this.shrinkFactor)));\n          // don't shrink below size\n          if (newCap < this.capacity) {\n            const copyCost = this.copyCost * this.size;\n            actualCost += copyCost + this.freeCost;\n            const newArray = new Array(newCap);\n            for (let i=0;i<this.size;i++) newArray[i] = this.array[i];\n            this.array = newArray;\n            details += `shrink ${this.capacity}→${newCap} copyCost=${copyCost} free=${this.freeCost}; `;\n            this.capacity = newCap;\n          }\n        }\n      }\n    }\n    const potentialAfter = this.potentialValue();\n    // Accounting charges\n    if (op.type === 'push') {\n      this.accountBalance += this.chargePush;\n    } else {\n      this.accountBalance += this.chargePop;\n    }\n    // update totals\n    this.totalCost += actualCost;\n    this.history.push({\n      op: op,\n      actualCost: actualCost,\n      cumulativeCost: this.totalCost,\n      potentialBefore: potentialBefore,\n      potentialAfter: potentialAfter,\n      amortizedPotential: actualCost + potentialAfter - potentialBefore,\n      accountBalance: this.accountBalance,\n      details: details\n    });\n    this.lastAction = {op:op, actualCost: actualCost};\n    this.opIndex += 1;\n    return this.history[this.history.length-1];\n  }\n\n  // revert last op (for stepping back)\n  undoLast() {\n    if (this.history.length === 0) return false;\n    // naive undo: reconstruct from scratch by replaying history up to length-1\n    const hist = this.history.slice(0, this.history.length-1);\n    const savedConfig = this.extractConfig();\n    this.reset();\n    this.applyConfig(savedConfig);\n    // replay hist\n    for (let h of hist) {\n      // we need to re-run performOp with same op (but performOp mutates history too)\n      // to avoid double-pushing history we temporarily store and restore\n      this.performOp(h.op);\n      // override actualCost & details to match old (actualCost should match)\n    }\n    // restore accountBalance as from last item or from history\n    if (this.history.length > 0) {\n      this.accountBalance = this.history[this.history.length-1].accountBalance;\n      this.totalCost = this.history[this.history.length-1].cumulativeCost;\n    } else {\n      this.accountBalance = 0;\n      this.totalCost = 0;\n    }\n    return true;\n  }\n\n  extractConfig() {\n    return {\n      name:this.name,\n      growthMode:this.growthMode, growthFactor:this.growthFactor, increment:this.increment, customRule:this.customRule,\n      shrinkEnabled:this.shrinkEnabled, shrinkFactor:this.shrinkFactor,\n      copyCost:this.copyCost, baseOpCost:this.baseOpCost, allocCost:this.allocCost, freeCost:this.freeCost,\n      chargePush:this.chargePush, chargePop:this.chargePop,\n      potentialType:this.potentialType, potentialCoeff:this.potentialCoeff, customPotential:this.customPotential\n    };\n  }\n\n  applyConfig(cfg) {\n    this.name = cfg.name || this.name;\n    this.growthMode = cfg.growthMode || this.growthMode;\n    this.growthFactor = cfg.growthFactor || this.growthFactor;\n    this.increment = cfg.increment || this.increment;\n    this.customRule = cfg.customRule || this.customRule;\n    this.shrinkEnabled = cfg.shrinkEnabled || this.shrinkEnabled;\n    this.shrinkFactor = cfg.shrinkFactor || this.shrinkFactor;\n    this.copyCost = cfg.copyCost || this.copyCost;\n    this.baseOpCost = cfg.baseOpCost || this.baseOpCost;\n    this.allocCost = cfg.allocCost || this.allocCost;\n    this.freeCost = cfg.freeCost || this.freeCost;\n    this.chargePush = cfg.chargePush || this.chargePush;\n    this.chargePop = cfg.chargePop || this.chargePop;\n    this.potentialType = cfg.potentialType || this.potentialType;\n    this.potentialCoeff = cfg.potentialCoeff || this.potentialCoeff;\n    this.customPotential = cfg.customPotential || this.customPotential;\n  }\n\n  clone() {\n    const cfg = this.extractConfig();\n    return new Strategy(this.id, cfg);\n  }\n\n  snapshotState() {\n    return {\n      name:this.name, size:this.size, capacity:this.capacity, array:copy(this.array),\n      totalCost:this.totalCost, history: copy(this.history), accountBalance:this.accountBalance, opIndex:this.opIndex\n    };\n  }\n\n  restoreState(snap) {\n    this.name = snap.name;\n    this.size = snap.size;\n    this.capacity = snap.capacity;\n    this.array = snap.array.slice();\n    this.totalCost = snap.totalCost;\n    this.history = copy(snap.history);\n    this.accountBalance = snap.accountBalance;\n    this.opIndex = snap.opIndex;\n  }\n}\n\n// Simulation manager handling multiple strategies and sequence\nclass SimulationManager {\n  constructor() {\n    this.strategies = [];\n    this.maxStrategies = 3;\n    this.sequence = []; // array of ops {type:'push'|'pop', value}\n    this.index = 0;\n    this.isRunning = false;\n    this.timer = null;\n  }\n\n  addStrategy(config) {\n    if (this.strategies.length >= this.maxStrategies) return null;\n    const id = this.strategies.length+1;\n    const s = new Strategy(id, config || {});\n    this.strategies.push(s);\n    return s;\n  }\n\n  removeLastStrategy() {\n    if (this.strategies.length === 0) return;\n    this.strategies.pop();\n  }\n\n  resetAll() {\n    for (let s of this.strategies) s.reset();\n    this.index = 0;\n    this.isRunning = false;\n    if (this.timer) { clearInterval(this.timer); this.timer = null; }\n  }\n\n  stepAll() {\n    if (this.index >= this.sequence.length) return false;\n    const op = this.sequence[this.index];\n    for (let s of this.strategies) {\n      s.performOp(op);\n    }\n    this.index += 1;\n    return true;\n  }\n\n  backAll() {\n    if (this.index === 0) return false;\n    // undo each strategy last op\n    for (let s of this.strategies) {\n      s.undoLast();\n    }\n    this.index -= 1;\n    return true;\n  }\n\n  run(speedMs, onTick) {\n    if (this.isRunning) return;\n    this.isRunning = true;\n    this.timer = setInterval(() => {\n      if (!this.stepAll()) {\n        this.pause();\n        if (onTick) onTick();\n        return;\n      }\n      if (onTick) onTick();\n    }, speedMs);\n  }\n\n  pause() {\n    this.isRunning = false;\n    if (this.timer) { clearInterval(this.timer); this.timer = null; }\n  }\n\n  importSequenceFromText(text) {\n    const lines = text.split(/\\r?\\n/).map(s=>s.trim()).filter(s=>s.length>0);\n    this.sequence = [];\n    for (let ln of lines) {\n      const parts = ln.split(/\\s+/);\n      const op = parts[0].toLowerCase();\n      if (op === 'push' || op === 'p') {\n        const val = parts.length>1 ? parts.slice(1).join(' ') : null;\n        this.sequence.push({type:'push', value:val});\n      } else if (op === 'pop') {\n        this.sequence.push({type:'pop', value:null});\n      } else {\n        // try JSON?\n        if (ln.toLowerCase().startsWith('push')) {\n          this.sequence.push({type:'push', value:ln.substring(4).trim() || null});\n        } else {\n          // unknown -> ignore\n        }\n      }\n    }\n  }\n\n  exportSequenceAsText() {\n    return this.sequence.map(o => o.type + (o.value ? (' ' + String(o.value)) : '')).join('\\n');\n  }\n}\n\n// Initialize manager and default strategies\nconst manager = new SimulationManager();\nmanager.addStrategy({\n  name:'Doubling (factor=2)',\n  growthMode:'factor',\n  growthFactor:2.0,\n  copyCost:1,\n  chargePush:3,\n  potentialType:'cap_minus_size',\n  potentialCoeff:1\n});\nmanager.addStrategy({\n  name:'Incremental (+1)',\n  growthMode:'increment',\n  increment:1,\n  copyCost:1,\n  chargePush:2,\n  potentialType:'size',\n  potentialCoeff:0.5\n});\n// third default - 1.5x\nmanager.addStrategy({\n  name:'Factor 1.5',\n  growthMode:'factor',\n  growthFactor:1.5,\n  copyCost:1,\n  chargePush:2,\n  potentialType:'cap_minus_size',\n  potentialCoeff:1\n});\n\n// UI wiring\nconst opsListEl = document.getElementById('opsList');\nconst sequenceTextEl = document.getElementById('sequenceText');\nconst btnLoadSeq = document.getElementById('btnLoadSeq');\nconst btnSaveSeq = document.getElementById('btnSaveSeq');\nconst exportOut = document.getElementById('exportOut');\nconst btnGenRand = document.getElementById('btnGenRand');\nconst randLen = document.getElementById('randLen');\nconst randProb = document.getElementById('randProb');\nconst randSeed = document.getElementById('randSeed');\nconst btnClearSeq = document.getElementById('btnClearSeq');\nconst btnPush = document.getElementById('btnPush');\nconst btnPop = document.getElementById('btnPop');\nconst pushValue = document.getElementById('pushValue');\nconst btnAppendOp = document.getElementById('btnAppendOp');\n\nconst btnStep = document.getElementById('btnStep');\nconst btnBack = document.getElementById('btnBack');\nconst btnRun = document.getElementById('btnRun');\nconst btnPause = document.getElementById('btnPause');\nconst btnReset = document.getElementById('btnReset');\nconst speedEl = document.getElementById('speed');\nconst modeSelect = document.getElementById('modeSelect');\nconst showAggregate = document.getElementById('showAggregate');\nconst showAccounting = document.getElementById('showAccounting');\nconst showPotential = document.getElementById('showPotential');\n\nconst strategiesContainer = document.getElementById('strategiesContainer');\nconst btnAddStrategy = document.getElementById('btnAddStrategy');\nconst btnRemoveStrategy = document.getElementById('btnRemoveStrategy');\n\nconst costCanvas = document.getElementById('costCanvas');\nconst logEl = document.getElementById('log');\nconst stateBox = document.getElementById('stateBox');\n\nconst snapshotsList = document.getElementById('snapshotsList');\nconst btnSaveSnapshot = document.getElementById('btnSaveSnapshot');\nconst btnRestoreSnapshot = document.getElementById('btnRestoreSnapshot');\nconst btnDeleteSnapshot = document.getElementById('btnDeleteSnapshot');\n\nlet selectedStrategyIndex = 0;\nlet snapshots = [];\n\n// Render operations list\nfunction renderOpsList() {\n  opsListEl.innerHTML = '';\n  manager.sequence.forEach((op, i) => {\n    const div = document.createElement('div');\n    div.textContent = `${i}: ${op.type}` + (op.value ? (' ' + op.value) : '');\n    div.style.cursor = 'pointer';\n    div.onclick = () => {\n      const newVal = prompt('Edit operation (push <value> or pop). Leave blank to delete.', op.type + (op.value ? (' ' + op.value) : ''));\n      if (newVal === null) return;\n      const trimmed = newVal.trim();\n      if (trimmed === '') {\n        manager.sequence.splice(i,1);\n      } else {\n        const parts = trimmed.split(/\\s+/);\n        const t = parts[0].toLowerCase();\n        if (t === 'push') {\n          const val = parts.length>1 ? parts.slice(1).join(' ') : null;\n          manager.sequence[i] = {type:'push', value:val};\n        } else if (t === 'pop') {\n          manager.sequence[i] = {type:'pop', value:null};\n        } else {\n          alert('Invalid op. Use \"push <value>\" or \"pop\".');\n        }\n      }\n      sequenceTextEl.value = manager.exportSequenceAsText();\n      renderOpsList();\n    };\n    opsListEl.appendChild(div);\n  });\n}\n\n// Render strategies UI\nfunction renderStrategies() {\n  strategiesContainer.innerHTML = '';\n  manager.strategies.forEach((s, idx) => {\n    const box = document.createElement('div');\n    box.style.border = '1px solid black';\n    box.style.padding = '6px';\n    box.style.minWidth = '240px';\n    box.style.display = 'flex';\n    box.style.flexDirection = 'column';\n\n    const header = document.createElement('div');\n    header.textContent = `${idx+1}. ${s.name}`;\n    header.style.cursor = 'pointer';\n    header.onclick = () => { editStrategyConfig(idx); };\n    box.appendChild(header);\n\n    const stateDiv = document.createElement('div');\n    stateDiv.style.fontFamily = 'monospace';\n    stateDiv.style.fontSize = '12px';\n    stateDiv.style.marginTop = '6px';\n    stateDiv.textContent = `size=${s.size} cap=${s.capacity} ops=${s.history.length}\\ncost=${s.totalCost.toFixed(2)} bal=${s.accountBalance}`;\n    box.appendChild(stateDiv);\n\n    const miniLog = document.createElement('div');\n    miniLog.style.fontFamily = 'monospace';\n    miniLog.style.fontSize = '12px';\n    miniLog.style.marginTop = '6px';\n    miniLog.style.height = '70px';\n    miniLog.style.overflow = 'auto';\n    miniLog.textContent = s.history.slice(-6).map((h, i) => {\n      return `${s.history.length-6+i+1||''}: ${h.op.type} c=${h.actualCost} aPot=${h.amortizedPotential.toFixed(2)}`;\n    }).join('\\n');\n    box.appendChild(miniLog);\n\n    box.onclick = () => { selectedStrategyIndex = idx; updateDetails(); };\n\n    strategiesContainer.appendChild(box);\n  });\n}\n\n// Edit a strategy's parameters\nfunction editStrategyConfig(idx) {\n  const s = manager.strategies[idx];\n  const cfg = s.extractConfig();\n  // build a simple prompt-driven editor (plain UI)\n  let msg = 'Edit strategy parameters, one per line as key=value. Available keys:\\n' +\n            'name,growthMode(factor|increment|custom),growthFactor,increment,customRule,shrinkEnabled,shrinkFactor,copyCost,baseOpCost,allocCost,freeCost,chargePush,chargePop,potentialType(cap_minus_size|size|custom),potentialCoeff,customPotential\\n';\n  msg += 'Current config:\\n';\n  for (let k in cfg) msg += `${k}=${cfg[k]}\\n`;\n  const res = prompt(msg, Object.keys(cfg).map(k=>`${k}=${cfg[k]}`).join('\\n'));\n  if (res === null) return;\n  // parse lines\n  const lines = res.split(/\\r?\\n/).map(l=>l.trim()).filter(l=>l.length>0);\n  for (let line of lines) {\n    const idxEq = line.indexOf('=');\n    if (idxEq < 0) continue;\n    const key = line.substring(0,idxEq).trim();\n    const val = line.substring(idxEq+1).trim();\n    if (!(key in cfg)) continue;\n    // convert types\n    if (['growthFactor','increment','shrinkFactor','copyCost','baseOpCost','allocCost','freeCost','chargePush','chargePop','potentialCoeff'].includes(key)) {\n      cfg[key] = Number(val);\n    } else if (['shrinkEnabled'].includes(key)) {\n      cfg[key] = (val.toLowerCase() === 'true');\n    } else {\n      cfg[key] = val;\n    }\n  }\n  s.applyConfig(cfg);\n  renderStrategies();\n  updateDetails();\n}\n\n// update details and logs for selected strategy\nfunction updateDetails() {\n  renderStrategies();\n  // update canvas and logs\n  drawCanvas();\n  const s = manager.strategies[selectedStrategyIndex];\n  if (!s) {\n    logEl.textContent = '';\n    stateBox.textContent = '';\n    return;\n  }\n  // show full history\n  logEl.textContent = s.history.map((h,i)=> {\n    return `${i}: ${h.op.type}${h.op.value ? ' '+h.op.value : ''} | actual=${h.actualCost} | cum=${h.cumulativeCost} | potΔ=${(h.potentialAfter-h.potentialBefore).toFixed(2)} | amortizedPot=${h.amortizedPotential.toFixed(2)} | accBal=${h.accountBalance} | ${h.details}`;\n  }).join('\\n');\n  stateBox.textContent = `Strategy: ${s.name}\\nsize=${s.size}\\ncapacity=${s.capacity}\\narrayIndices=${s.array.slice(0,s.size).map((v,i)=> i+':'+(v===undefined?'_':v)).join(' ')}\\nopsRun=${s.history.length}\\ntotalCost=${s.totalCost}\\naccountBalance=${s.accountBalance.toFixed(2)}\\npotential=${s.potentialValue().toFixed(2)}`;\n}\n\n// draw simple plot of cumulative cost per operation for each strategy\nfunction drawCanvas() {\n  const ctx = costCanvas.getContext('2d');\n  ctx.clearRect(0,0,costCanvas.width,costCanvas.height);\n  // find max ops across strategies\n  let maxOps = 1;\n  for (let s of manager.strategies) maxOps = Math.max(maxOps, s.history.length);\n  // find max cost\n  let maxCost = 1;\n  for (let s of manager.strategies) {\n    for (let h of s.history) maxCost = Math.max(maxCost, h.cumulativeCost);\n  }\n  // draw simple axes\n  ctx.fillStyle = 'black';\n  ctx.font = '11px monospace';\n  ctx.fillText('Cumulative cost vs op index', 6, 12);\n  // draw grid lines\n  const padding = 36;\n  const w = costCanvas.width - padding - 6;\n  const h = costCanvas.height - 36;\n  // draw each strategy as a polyline with different dash offsets (no colors)\n  manager.strategies.forEach((s, idx) => {\n    const hist = s.history;\n    if (hist.length === 0) return;\n    ctx.beginPath();\n    for (let i=0;i<hist.length;i++) {\n      const x = padding + (i / Math.max(1, maxOps-1)) * w;\n      const y = 20 + (1 - (hist[i].cumulativeCost / maxCost)) * h;\n      if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n    }\n    ctx.strokeStyle = 'black';\n    // emulate different style by line width + dash pattern variations (still black)\n    ctx.lineWidth = 1 + idx*0.5;\n    ctx.setLineDash(idx===0 ? [] : (idx===1 ? [4,4] : [2,6]));\n    ctx.stroke();\n    ctx.setLineDash([]);\n    // label final point\n    const last = hist[hist.length-1];\n    const x = padding + ((hist.length-1) / Math.max(1, maxOps-1)) * w;\n    const y = 20 + (1 - (last.cumulativeCost / maxCost)) * h;\n    ctx.fillText(`${idx+1}:${s.name.split(' ')[0]}(${last.cumulativeCost})`, x+4, y+4);\n  });\n  // reset\n  ctx.lineWidth = 1;\n  ctx.setLineDash([]);\n}\n\n// Sequence editing handlers\nbtnLoadSeq.onclick = () => {\n  manager.importSequenceFromText(sequenceTextEl.value);\n  renderOpsList();\n};\n\nbtnSaveSeq.onclick = () => {\n  const t = manager.exportSequenceAsText();\n  exportOut.value = t;\n  alert('Sequence exported to the box on the right. You can copy it.');\n};\n\nbtnGenRand.onclick = () => {\n  const n = Math.max(1, Number(randLen.value)||1);\n  const p = clamp(Number(randProb.value)||0.5, 0, 1);\n  const seed = randSeed.value || '';\n  const rnd = seed ? seededRandom(seed) : Math.random;\n  manager.sequence = [];\n  for (let i=0;i<n;i++) {\n    if (rnd() < p) {\n      manager.sequence.push({type:'push', value:Math.floor(rnd()*1000)});\n    } else {\n      manager.sequence.push({type:'pop', value:null});\n    }\n  }\n  sequenceTextEl.value = manager.exportSequenceAsText();\n  renderOpsList();\n};\n\nbtnClearSeq.onclick = () => {\n  manager.sequence = [];\n  sequenceTextEl.value = '';\n  renderOpsList();\n};\n\nbtnAppendOp.onclick = () => {\n  const val = pushValue.value.trim();\n  manager.sequence.push({type:'push', value: val || null});\n  sequenceTextEl.value = manager.exportSequenceAsText();\n  renderOpsList();\n};\n\nbtnPush.onclick = () => {\n  if (modeSelect.value === 'manual') {\n    // perform push on all strategies directly (no sequence)\n    const val = pushValue.value.trim() || null;\n    for (let s of manager.strategies) s.performOp({type:'push', value:val});\n    updateDetails();\n  } else {\n    // append to sequence and step\n    manager.sequence.push({type:'push', value:pushValue.value.trim() || null});\n    sequenceTextEl.value = manager.exportSequenceAsText();\n    renderOpsList();\n    // optionally step immediately\n    if (!manager.isRunning) {\n      // auto-step just this op\n      manager.stepAll();\n      updateDetails();\n    }\n  }\n};\n\nbtnPop.onclick = () => {\n  if (modeSelect.value === 'manual') {\n    for (let s of manager.strategies) s.performOp({type:'pop', value:null});\n    updateDetails();\n  } else {\n    manager.sequence.push({type:'pop', value:null});\n    sequenceTextEl.value = manager.exportSequenceAsText();\n    renderOpsList();\n    if (!manager.isRunning) {\n      manager.stepAll();\n      updateDetails();\n    }\n  }\n};\n\n// Simulation controls\nbtnStep.onclick = () => {\n  manager.stepAll();\n  updateDetails();\n};\n\nbtnBack.onclick = () => {\n  manager.backAll();\n  updateDetails();\n};\n\nbtnRun.onclick = () => {\n  const ms = clamp(Number(speedEl.value)||200, 10, 10000);\n  manager.run(ms, updateDetails);\n};\n\nbtnPause.onclick = () => {\n  manager.pause();\n  updateDetails();\n};\n\nbtnReset.onclick = () => {\n  manager.resetAll();\n  updateDetails();\n};\n\n// Strategy add/remove\nbtnAddStrategy.onclick = () => {\n  if (manager.strategies.length >= manager.maxStrategies) { alert('Max strategies reached.'); return; }\n  // clone selected strategy if exists\n  const base = manager.strategies[selectedStrategyIndex] || manager.strategies[0];\n  const cfg = base ? base.extractConfig() : {name:'New'};\n  cfg.name = cfg.name + ' (clone)';\n  const s = manager.addStrategy(cfg);\n  renderStrategies();\n  updateDetails();\n};\n\nbtnRemoveStrategy.onclick = () => {\n  if (manager.strategies.length <= 1) { alert('At least one strategy required.'); return; }\n  manager.removeLastStrategy();\n  selectedStrategyIndex = Math.max(0, selectedStrategyIndex-1);\n  renderStrategies();\n  updateDetails();\n};\n\n// Snapshots\nbtnSaveSnapshot.onclick = () => {\n  const snap = {\n    index: manager.index,\n    seq: copy(manager.sequence),\n    strategies: manager.strategies.map(s => ({cfg:s.extractConfig(), state:s.snapshotState()})),\n    ts: new Date().toISOString()\n  };\n  snapshots.push(snap);\n  renderSnapshots();\n};\n\nfunction renderSnapshots() {\n  snapshotsList.innerHTML = '';\n  snapshots.forEach((snap, i) => {\n    const d = document.createElement('div');\n    d.textContent = `${i}: ${snap.ts} (opIndex=${snap.index} seq=${snap.seq.length} ops)`;\n    d.style.cursor = 'pointer';\n    d.onclick = () => {\n      Array.from(snapshotsList.children).forEach(c=>c.style.background='white');\n      d.style.background='#eee';\n      d.dataset.selected = '1';\n    };\n    snapshotsList.appendChild(d);\n  });\n}\n\nbtnRestoreSnapshot.onclick = () => {\n  const sel = Array.from(snapshotsList.children).findIndex(c=>c.dataset.selected==='1');\n  if (sel < 0) { alert('Select a snapshot first.'); return; }\n  const snap = snapshots[sel];\n  manager.sequence = copy(snap.seq);\n  manager.index = snap.index;\n  // restore strategies configs and states\n  manager.strategies = [];\n  for (let i=0;i<snap.strategies.length;i++) {\n    const st = snap.strategies[i];\n    const s = manager.addStrategy(st.cfg);\n    s.restoreState(st.state);\n  }\n  renderOpsList();\n  renderStrategies();\n  updateDetails();\n};\n\nbtnDeleteSnapshot.onclick = () => {\n  const sel = Array.from(snapshotsList.children).findIndex(c=>c.dataset.selected==='1');\n  if (sel < 0) { alert('Select a snapshot first.'); return; }\n  snapshots.splice(sel,1);\n  renderSnapshots();\n};\n\n// initialize UI\nrenderOpsList();\nrenderStrategies();\nupdateDetails();\n\n// keyboard shortcuts for convenience\ndocument.addEventListener('keydown', (e) => {\n  if (e.key === ' ') { // space toggles run/pause\n    if (manager.isRunning) { manager.pause(); } else { manager.run(Number(speedEl.value)); }\n    e.preventDefault();\n    updateDetails();\n  }\n});\n\n// Simple autosave of sequence textarea on change\nsequenceTextEl.addEventListener('change', () => {\n  // no auto-parse; leave to user to click Load Sequence\n});\n\n// Basic export/import of full simulation\ndocument.getElementById('btnSaveSeq').addEventListener('click', () => {\n  // also allow full export of strategies and state\n  const exportAll = {\n    sequence: manager.sequence,\n    strategies: manager.strategies.map(s => ({cfg:s.extractConfig(), state:s.snapshotState()})),\n    index: manager.index\n  };\n  exportOut.value = JSON.stringify(exportAll, null, 2);\n});\n\n// allow loading a full export by pasting JSON into sequence textbox then clicking Load Sequence\n// simple detection: if sequenceTextEl contains JSON object with 'sequence' property\nbtnLoadSeq.addEventListener('click', () => {\n  const text = sequenceTextEl.value.trim();\n  if (text.startsWith('{') && text.includes('\"sequence\"')) {\n    try {\n      const obj = JSON.parse(text);\n      if (obj.sequence) {\n        manager.sequence = obj.sequence;\n        sequenceTextEl.value = manager.exportSequenceAsText();\n        // if contains strategies\n        if (obj.strategies) {\n          manager.strategies = [];\n          for (let st of obj.strategies) {\n            const s = manager.addStrategy(st.cfg);\n            s.restoreState(st.state);\n          }\n        }\n        renderOpsList();\n        renderStrategies();\n        updateDetails();\n        return;\n      }\n    } catch(e){}\n  }\n  // otherwise treat as plain sequence text\n  manager.importSequenceFromText(text);\n  renderOpsList();\n});\n\n// initial quick tip\nconsole.log('Amortized Analysis Simulator ready. Use the UI to configure strategies, generate sequences, step/run, and save snapshots.');\n\n</script>\n</body>\n</html>"
