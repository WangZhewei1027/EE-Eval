    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Refactoring — Elegance in Code Evolution</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=JetBrains+Mono&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #141214 0%, #1f1f27 40%, #2e2d39 75%, #45455b 100%);\n    color: #e6e6e9;\n    font-family: 'Space Grotesk', sans-serif;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* Container wrapper */\n  .container {\n    max-width: 960px;\n    width: 90vw;\n    padding: 2rem 0 6rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Title */\n  h1 {\n    font-weight: 700;\n    font-size: 3.8rem;\n    line-height: 1.1;\n    letter-spacing: 0.015em;\n    color: #8fd3f4;\n    text-shadow:\n      0 0 8px #08f,\n      0 0 20px #0cf,\n      0 0 36px #09f,\n      0 0 48px #0ff,\n      0 0 68px #0ff,\n      0 0 80px #0ff;\n    margin-bottom: 0.3em;\n    transition: color 0.6s ease;\n  }\n  h1 span.highlight {\n    color: #e2fffa;\n    filter: drop-shadow(0 0 6px #3ce5d7);\n  }\n\n  /* Subtitle */\n  .subtitle {\n    font-size: 1.25rem;\n    font-weight: 400;\n    color: #bbd7ea;\n    margin-bottom: 3.2rem;\n    letter-spacing: 0.02em;\n    max-width: 28rem;\n    line-height: 1.55;\n  }\n\n  /* Abstract visualization frame */\n  .visualization {\n    position: relative;\n    width: 100%;\n    max-width: 600px;\n    aspect-ratio: 1 / 1;\n    background:\n      radial-gradient(circle at top left, #03a9f4aa, transparent 40%),\n      radial-gradient(circle at bottom right, #00bcd499, transparent 50%),\n      linear-gradient(135deg, #1e2433 0%, #12151e 100%);\n    border-radius: 2rem;\n    box-shadow:\n      0 0 40px rgba(3, 169, 244, 0.3),\n      inset 0 0 40px #0091ea66,\n      0 4px 24px rgba(0,0,0,0.7);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    overflow: visible;\n  }\n\n  /* Code block stylized */\n  .codeblock {\n    width: 75%;\n    height: 75%;\n    background: #11131a;\n    border-radius: 1.5rem;\n    box-shadow: inset 0 0 18px #0ff7ffc7;\n    color: #a1eafd;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 1.02rem;\n    line-height: 1.5;\n    letter-spacing: 0.04em;\n    padding: 2rem 2.4rem;\n    overflow-y: auto;\n    position: relative;\n    user-select: text;\n    white-space: pre-wrap;\n    transition:\n      box-shadow 0.6s ease,\n      transform 0.6s ease;\n  }\n\n  /* Puff glow animation around code block */\n  @keyframes pulseGlow {\n    0% {\n      box-shadow:\n        inset 0 0 18px #0ff7ffc7,\n        0 0 40px #00ffffcc;\n      transform: scale(1);\n    }\n    50% {\n      box-shadow:\n        inset 0 0 26px #00fff0e0,\n        0 0 54px #0ff;\n      transform: scale(1.02);\n    }\n    100% {\n      box-shadow:\n        inset 0 0 18px #0ff7ffc7,\n        0 0 40px #00ffffcc;\n      transform: scale(1);\n    }\n  }\n  .codeblock.pulse {\n    animation: pulseGlow 3.2s infinite ease-in-out;\n  }\n\n  /* Interactive buttons container */\n  .controls {\n    margin-top: 3.8rem;\n    display: flex;\n    gap: 1.6rem;\n  }\n  button {\n    background: transparent;\n    border: 2.4px solid #0ff;\n    border-radius: 0.8rem;\n    color: #0ff;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.68rem 2.4rem;\n    cursor: pointer;\n    transition:\n      background-color 0.3s ease,\n      color 0.3s ease,\n      box-shadow 0.35s ease;\n    user-select: none;\n    position: relative;\n    overflow: hidden;\n  }\n  button::before {\n    content: \"\";\n    position: absolute;\n    top: 110%;\n    left: 50%;\n    transform: translateX(-50%) rotate(45deg);\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(120deg, #00ffffcc 0%, transparent 80%);\n    transition: top 0.35s ease;\n    filter: blur(15px);\n    border-radius: 50%;\n    z-index: 0;\n  }\n  button:hover::before {\n    top: -30%;\n  }\n  button:hover {\n    background-color: #0ff3;\n    color: #e0f7ff;\n    box-shadow: 0 0 12px 3px #00fffccc;\n  }\n  button:active {\n    background-color: #08e8ffbb;\n    box-shadow: 0 0 18px 5px #00ffffdd;\n  }\n  button:focus {\n    outline: none;\n    box-shadow: 0 0 14px 3px #00ffffdd;\n  }\n\n  /* Code line highlights */\n  .highlight-line {\n    background: linear-gradient(90deg, #127bdc44 0%, #0ffaff44 100%);\n    border-radius: 4px;\n    transition: background-color 0.45s ease;\n  }\n\n  /* Animated morphing shapes behind code block - signifying transformation */\n  .shape-glow {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 850px;\n    height: 850px;\n    transform: translate(-50%, -50%);\n    pointer-events: none;\n    filter: drop-shadow(0 0 10px #00ffffaa);\n    z-index: 0;\n  }\n  svg.morph-shape {\n    width: 100%;\n    height: 100%;\n    stroke-width: 1.2;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    fill: none;\n    stroke: #00fffccc;\n    filter: drop-shadow(0 0 20px #0ff);\n  }\n\n  /* Footer text */\n  footer {\n    position: fixed;\n    bottom: 1.8rem;\n    width: 100%;\n    text-align: center;\n    font-size: 0.9rem;\n    font-weight: 400;\n    letter-spacing: 0.05em;\n    color: #33ffffaa;\n    user-select: none;\n    font-family: 'Space Grotesk', sans-serif;\n    text-transform: uppercase;\n  }\n\n  /* Scrollbar styling for code block */\n  .codeblock::-webkit-scrollbar {\n    width: 8px;\n  }\n  .codeblock::-webkit-scrollbar-thumb {\n    background: #0ff4;\n    border-radius: 4px;\n  }\n  .codeblock::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  /* Responsive typography */\n  @media (max-width: 480px) {\n    h1 {\n      font-size: 2.8rem;\n    }\n    .subtitle {\n      font-size: 1rem;\n      max-width: 90vw;\n    }\n    .codeblock {\n      font-size: 0.9rem;\n      padding: 1.6rem 1.8rem;\n    }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"container\" role=\"main\" aria-label=\"Refactoring demonstration\">\n  <h1>Refactoring<br /><span class=\"highlight\">Elegance in Code Evolution</span></h1>\n  <p class=\"subtitle\">Transforming tangled codebases into fluid, elegant structures — the art and science of sustainable development.</p>\n\n  <div class=\"visualization\" aria-hidden=\"true\">\n    <svg class=\"shape-glow\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"true\" >\n      <path id=\"morphPath\" stroke-opacity=\"0.65\" />\n    </svg>\n    <pre class=\"codeblock pulse\" id=\"codeblock\" aria-label=\"Before and after sample code snippet\" tabindex=\"0\"></pre>\n  </div>\n\n  <div class=\"controls\" aria-label=\"Code view controls\">\n    <button id=\"beforeBtn\" aria-pressed=\"true\">Before Refactor</button>\n    <button id=\"afterBtn\" aria-pressed=\"false\">After Refactor</button>\n  </div>\n</div>\n\n<footer>Visualized by refined UI &amp; subtle motion</footer>\n\n<script>\n  (() => {\n    // Code samples demonstrating refactoring (basic JS example)\n    const beforeRefactor = `\n// Original tangled code\n\nfunction processData(data){\n  let result = [];\n  for(let i=0; i<data.length; i++){\n    if(data[i].active){\n      let filtered = [];\n      for(let j=0; j<data[i].items.length; j++){\n        if(data[i].items[j].valid){\n          filtered.push(data[i].items[j]);\n        }\n      }\n      if(filtered.length > 0){\n        result.push({\n          id: data[i].id,\n          items: filtered,\n          timestamp: new Date().toISOString()\n        });\n      }\n    }\n  }\n  return result;\n}\n  `.trim();\n\n    const afterRefactor = `\n// Refactored for clarity, performance & maintainability\n\nfunction processData(data) {\n  const filterValidItems = items => items.filter(item => item.valid);\n\n  return data\n    .filter(entry => entry.active)\n    .map(entry => ({\n      id: entry.id,\n      items: filterValidItems(entry.items),\n      timestamp: new Date().toISOString()\n    }))\n    .filter(entry => entry.items.length > 0);\n}\n    `.trim();\n\n    // Elements\n    const codeblock = document.getElementById('codeblock');\n    const beforeBtn = document.getElementById('beforeBtn');\n    const afterBtn = document.getElementById('afterBtn');\n\n    // Initial state\n    let showingBefore = true;\n    codeblock.textContent = beforeRefactor;\n\n    // Highlight lines for emphasis (simulate complexity -> clarity)\n    const highlightLinesBefore = [3,4,5,6,7,8,9,12,13,14];\n    const highlightLinesAfter = [5,8];\n\n    function highlightCode(text, linesToHighlight) {\n      const lines = text.split('\\n');\n      return lines.map((line, i) => {\n        const n = i + 1;\n        if (linesToHighlight.includes(n)) {\n          return `<span class=\"highlight-line\">${line}</span>`;\n        }\n        return line;\n      }).join('\\n');\n    }\n\n    // Set code content with highlights wrapped in spans\n    function setCode(isBefore) {\n      codeblock.innerHTML = highlightCode(isBefore ? beforeRefactor : afterRefactor, isBefore ? highlightLinesBefore : highlightLinesAfter);\n    }\n\n    beforeBtn.addEventListener('click', () => {\n      if (!showingBefore) {\n        showingBefore = true;\n        setCode(true);\n        beforeBtn.setAttribute('aria-pressed', 'true');\n        afterBtn.setAttribute('aria-pressed', 'false');\n        codeblock.classList.add('pulse');\n      }\n    });\n    afterBtn.addEventListener('click', () => {\n      if (showingBefore) {\n        showingBefore = false;\n        setCode(false);\n        afterBtn.setAttribute('aria-pressed', 'true');\n        beforeBtn.setAttribute('aria-pressed', 'false');\n        codeblock.classList.remove('pulse');\n      }\n    });\n\n    // Initialize code with highlights\n    setCode(true);\n\n    // Animated morphing path for background shape (symbolizing transformation)\n    const morphPath = document.getElementById('morphPath');\n\n    // Morph shapes - 3 organic blobs\n    const blobs = [\n      \"M445,300Q436,350 409.5,372.5Q383,395 345,390.5Q307,386 278,378.5Q249,371 236,338.5Q223,306 215,270Q207,234 243,210Q279,186 311,177Q343,168 380,190Q417,212 445,300Z\",\n      \"M439,302Q433,354 403,379.5Q373,405 331.5,400.5Q290,396 273,372Q256,348 230.5,335Q205,322 222,276Q239,230 275,198.5Q311,167 361.5,182Q412,197 445.5,254Q479,311 439,302Z\",\n      \"M451,303.5Q469,355 437.5,399Q406,443 360,440.5Q314,438 260,433Q206,428 206,381.5Q206,335 214,296Q222,257 260,236.5Q298,216 358,209Q418,202 438,254Q458,306 451,303.5Z\"\n    ];\n\n    let morphIndex = 0;\n    let morphDirection = 1;\n\n    function animateMorph(t = 0) {\n      const duration = 8000;\n      let progress = (t % duration) / duration;\n      if (morphDirection === -1) progress = 1 - progress;\n\n      // cubic interpolation between blobs[morphIndex] to blobs[nextIndex]\n      const nextIndex = (morphIndex + 1) % blobs.length;\n\n      try {\n        const pathA = blobs[morphIndex];\n        const pathB = blobs[nextIndex];\n\n        // Simple morph function: interpolate by points - approximated by SVG path strings\n        // Because paths differ structurally this is a rough approximation using opacity fade:\n\n        morphPath.setAttribute('d', progress < 0.5 ? pathA : pathB);\n        morphPath.style.opacity = 0.75 + 0.25 * Math.cos(progress * Math.PI * 2);\n\n      } catch {\n        morphPath.setAttribute('d', blobs[0]);\n      }\n\n      if (t >= duration) {\n        morphIndex = nextIndex;\n        morphDirection = 1;\n      }\n      requestAnimationFrame(animateMorph);\n    }\n    requestAnimationFrame(animateMorph);\n\n  })();\n</script>\n\n</body>\n</html>"
