  "question": "Depth-First Search (DFS)",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Depth-First Search (DFS) Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { display: flex; flex-direction: column; gap: 10px; }\n        .control-panel { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; }\n        .panel { border: 1px solid black; padding: 10px; margin-bottom: 10px; }\n        button, select, input { padding: 5px; }\n        #graph-container { position: relative; height: 400px; border: 1px solid black; }\n        .node { position: absolute; width: 30px; height: 30px; border: 1px solid black; \n                border-radius: 15px; display: flex; justify-content: center; \n                align-items: center; cursor: pointer; }\n        .edge { position: absolute; height: 2px; background: black; transform-origin: 0 0; }\n        .visited { background-color: #ccc; }\n        .current { background-color: #888; }\n        .stack-display { border: 1px solid black; padding: 5px; min-height: 100px; }\n        .log { border: 1px solid black; padding: 5px; height: 150px; overflow-y: scroll; }\n    </style>\n</head>\n<body>\n    <h1>Depth-First Search (DFS) Interactive Demo</h1>\n    \n    <div class=\"container\">\n        <div class=\"control-panel\">\n            <div class=\"panel\">\n                <h3>Graph Construction</h3>\n                <button id=\"add-node\">Add Node</button>\n                <button id=\"add-edge\">Add Edge (select 2 nodes)</button>\n                <button id=\"clear-graph\">Clear Graph</button>\n                <div>\n                    <label>Edge Direction: </label>\n                    <select id=\"edge-direction\">\n                        <option value=\"directed\">Directed</option>\n                        <option value=\"undirected\">Undirected</option>\n                    </select>\n                </div>\n            </div>\n            \n            <div class=\"panel\">\n                <h3>DFS Controls</h3>\n                <button id=\"start-dfs\">Start DFS</button>\n                <button id=\"step-dfs\">Step</button>\n                <button id=\"reset-dfs\">Reset</button>\n                <div>\n                    <label>Start Node: </label>\n                    <select id=\"start-node\"></select>\n                </div>\n                <div>\n                    <label>Speed: </label>\n                    <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\">\n                </div>\n            </div>\n            \n            <div class=\"panel\">\n                <h3>Graph Type</h3>\n                <button id=\"load-tree\">Load Binary Tree</button>\n                <button id=\"load-dag\">Load DAG</button>\n                <button id=\"load-cyclic\">Load Cyclic Graph</button>\n            </div>\n        </div>\n        \n        <div id=\"graph-container\"></div>\n        \n        <div class=\"panel\">\n            <h3>DFS Stack</h3>\n            <div id=\"stack-display\" class=\"stack-display\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h3>Algorithm Log</h3>\n            <div id=\"log\" class=\"log\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h3>DFS Details</h3>\n            <div>\n                <label><input type=\"checkbox\" id=\"show-visit-order\"> Show Visit Order</label>\n                <label><input type=\"checkbox\" id=\"show-parents\"> Show Parent Relationships</label>\n            </div>\n            <div id=\"visit-order\"></div>\n            <div id=\"parent-relationships\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Graph data structure\n        let graph = {\n            nodes: [],\n            edges: [],\n            adjacencyList: {}\n        };\n        \n        // DFS state\n        let dfsState = {\n            running: false,\n            visited: new Set(),\n            stack: [],\n            visitOrder: [],\n            parents: {},\n            timer: null,\n            currentStep: 0,\n            speed: 500\n        };\n        \n        // DOM elements\n        const graphContainer = document.getElementById('graph-container');\n        const addNodeBtn = document.getElementById('add-node');\n        const addEdgeBtn = document.getElementById('add-edge');\n        const clearGraphBtn = document.getElementById('clear-graph');\n        const startDfsBtn = document.getElementById('start-dfs');\n        const stepDfsBtn = document.getElementById('step-dfs');\n        const resetDfsBtn = document.getElementById('reset-dfs');\n        const startNodeSelect = document.getElementById('start-node');\n        const speedSlider = document.getElementById('speed');\n        const stackDisplay = document.getElementById('stack-display');\n        const logElement = document.getElementById('log');\n        const visitOrderDisplay = document.getElementById('visit-order');\n        const parentRelationshipsDisplay = document.getElementById('parent-relationships');\n        const showVisitOrderCheckbox = document.getElementById('show-visit-order');\n        const showParentsCheckbox = document.getElementById('show-parents');\n        const loadTreeBtn = document.getElementById('load-tree');\n        const loadDagBtn = document.getElementById('load-dag');\n        const loadCyclicBtn = document.getElementById('load-cyclic');\n        \n        // Node tracking for edge creation\n        let selectedNodes = [];\n        \n        // Initialize\n        init();\n        \n        function init() {\n            addEventListeners();\n            updateStartNodeSelect();\n        }\n        \n        function addEventListeners() {\n            addNodeBtn.addEventListener('click', addRandomNode);\n            addEdgeBtn.addEventListener('click', () => {\n                if (selectedNodes.length === 2) {\n                    addEdge(selectedNodes[0], selectedNodes[1]);\n                    selectedNodes = [];\n                    updateNodeSelection();\n                }\n            });\n            clearGraphBtn.addEventListener('click', clearGraph);\n            startDfsBtn.addEventListener('click', startDFS);\n            stepDfsBtn.addEventListener('click', stepDFS);\n            resetDfsBtn.addEventListener('click', resetDFS);\n            speedSlider.addEventListener('input', updateSpeed);\n            showVisitOrderCheckbox.addEventListener('change', updateVisitOrderDisplay);\n            showParentsCheckbox.addEventListener('change', updateParentRelationships);\n            loadTreeBtn.addEventListener('click', loadBinaryTree);\n            loadDagBtn.addEventListener('click', loadDAG);\n            loadCyclicBtn.addEventListener('click', loadCyclicGraph);\n        }\n        \n        function addRandomNode() {\n            const nodeId = `N${graph.nodes.length + 1}`;\n            const x = Math.floor(Math.random() * (graphContainer.clientWidth - 40)) + 20;\n            const y = Math.floor(Math.random() * (graphContainer.clientHeight - 40)) + 20;\n            \n            graph.nodes.push({ id: nodeId, x, y });\n            graph.adjacencyList[nodeId] = [];\n            \n            renderGraph();\n            updateStartNodeSelect();\n            log(`Added node ${nodeId}`);\n        }\n        \n        function addEdge(nodeId1, nodeId2) {\n            const edgeExists = document.getElementById('edge-direction').value === 'directed' \n                ? graph.edges.some(e => e.from === nodeId1 && e.to === nodeId2)\n                : graph.edges.some(e => \n                    (e.from === nodeId1 && e.to === nodeId2) || \n                    (e.from === nodeId2 && e.to === nodeId1));\n            \n            if (nodeId1 === nodeId2) {\n                log(\"Cannot create edge to the same node\");\n                return;\n            }\n            \n            if (edgeExists) {\n                log(\"Edge already exists\");\n                return;\n            }\n            \n            graph.edges.push({ from: nodeId1, to: nodeId2 });\n            graph.adjacencyList[nodeId1].push(nodeId2);\n            \n            if (document.getElementById('edge-direction').value === 'undirected') {\n                graph.adjacencyList[nodeId2].push(nodeId1);\n            }\n            \n            renderGraph();\n            log(`Added edge from ${nodeId1} to ${nodeId2}`);\n        }\n        \n        function clearGraph() {\n            graph = {\n                nodes: [],\n                edges: [],\n                adjacencyList: {}\n            };\n            resetDFS();\n            renderGraph();\n            updateStartNodeSelect();\n            log(\"Graph cleared\");\n        }\n        \n        function renderGraph() {\n            graphContainer.innerHTML = '';\n            \n            // Render edges first (so they appear behind nodes)\n            graph.edges.forEach(edge => {\n                const fromNode = graph.nodes.find(n => n.id === edge.from);\n                const toNode = graph.nodes.find(n => n.id === edge.to);\n                \n                if (fromNode && toNode) {\n                    const edgeElement = document.createElement('div');\n                    edgeElement.className = 'edge';\n                    \n                    const dx = toNode.x - fromNode.x;\n                    const dy = toNode.y - fromNode.y;\n                    const length = Math.sqrt(dx * dx + dy * dy);\n                    const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n                    \n                    edgeElement.style.width = `${length}px`;\n                    edgeElement.style.left = `${fromNode.x}px`;\n                    edgeElement.style.top = `${fromNode.y}px`;\n                    edgeElement.style.transform = `rotate(${angle}deg)`;\n                    \n                    graphContainer.appendChild(edgeElement);\n                }\n            });\n            \n            // Render nodes\n            graph.nodes.forEach(node => {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                nodeElement.id = `node-${node.id}`;\n                nodeElement.textContent = node.id;\n                nodeElement.style.left = `${node.x - 15}px`;\n                nodeElement.style.top = `${node.y - 15}px`;\n                \n                if (dfsState.visited.has(node.id)) {\n                    nodeElement.classList.add('visited');\n                }\n                \n                if (dfsState.stack.includes(node.id)) {\n                    nodeElement.classList.add('current');\n                }\n                \n                nodeElement.addEventListener('click', () => {\n                    if (!dfsState.running) {\n                        if (document.getElementById('add-edge').classList.contains('active')) {\n                            selectedNodes.push(node.id);\n                            if (selectedNodes.length > 2) {\n                                selectedNodes.shift();\n                            }\n                            updateNodeSelection();\n                        } else {\n                            // Select as start node\n                            startNodeSelect.value = node.id;\n                        }\n                    }\n                });\n                \n                graphContainer.appendChild(nodeElement);\n            });\n        }\n        \n        function updateNodeSelection() {\n            // Clear previous selection\n            document.querySelectorAll('.node').forEach(node => {\n                node.style.border = '1px solid black';\n            });\n            \n            // Highlight selected nodes\n            selectedNodes.forEach(nodeId => {\n                const node = document.getElementById(`node-${nodeId}`);\n                if (node) {\n                    node.style.border = '2px solid red';\n                }\n            });\n        }\n        \n        function updateStartNodeSelect() {\n            startNodeSelect.innerHTML = '';\n            graph.nodes.forEach(node => {\n                const option = document.createElement('option');\n                option.value = node.id;\n                option.textContent = node.id;\n                startNodeSelect.appendChild(option);\n            });\n        }\n        \n        function startDFS() {\n            if (dfsState.running) return;\n            if (graph.nodes.length === 0) {\n                log(\"No nodes in graph\");\n                return;\n            }\n            \n            const startNode = startNodeSelect.value || graph.nodes[0].id;\n            \n            resetDFS();\n            dfsState.running = true;\n            dfsState.stack.push(startNode);\n            dfsState.visited.add(startNode);\n            dfsState.visitOrder.push(startNode);\n            dfsState.parents[startNode] = null;\n            \n            updateStackDisplay();\n            renderGraph();\n            log(`DFS started from node ${startNode}`);\n            \n            dfsState.timer = setInterval(() => {\n                if (dfsState.stack.length === 0) {\n                    clearInterval(dfsState.timer);\n                    dfsState.running = false;\n                    log(\"DFS completed\");\n                    return;\n                }\n                stepDFS();\n            }, dfsState.speed);\n        }\n        \n        function stepDFS() {\n            if (dfsState.stack.length === 0) {\n                log(\"DFS completed\");\n                dfsState.running = false;\n                if (dfsState.timer) clearInterval(dfsState.timer);\n                return;\n            }\n            \n            const currentNode = dfsState.stack.pop();\n            dfsState.currentStep++;\n            \n            // Highlight current node\n            document.querySelectorAll('.node').forEach(node => {\n                node.classList.remove('current');\n            });\n            const currentNodeElement = document.getElementById(`node-${currentNode}`);\n            if (currentNodeElement) {\n                currentNodeElement.classList.add('current');\n            }\n            \n            log(`Processing node ${currentNode}`);\n            \n            // Process neighbors\n            const neighbors = graph.adjacencyList[currentNode] || [];\n            neighbors.forEach(neighbor => {\n                if (!dfsState.visited.has(neighbor)) {\n                    dfsState.visited.add(neighbor);\n                    dfsState.stack.push(neighbor);\n                    dfsState.visitOrder.push(neighbor);\n                    dfsState.parents[neighbor] = currentNode;\n                    log(`Discovered node ${neighbor} from ${currentNode}`);\n                }\n            });\n            \n            updateStackDisplay();\n            renderGraph();\n            updateVisitOrderDisplay();\n            updateParentRelationships();\n        }\n        \n        function resetDFS() {\n            clearInterval(dfsState.timer);\n            dfsState = {\n                running: false,\n                visited: new Set(),\n                stack: [],\n                visitOrder: [],\n                parents: {},\n                timer: null,\n                currentStep: 0,\n                speed: parseInt(speedSlider.value)\n            };\n            stackDisplay.innerHTML = '';\n            logElement.innerHTML = '';\n            visitOrderDisplay.innerHTML = '';\n            parentRelationshipsDisplay.innerHTML = '';\n            renderGraph();\n            log(\"DFS reset\");\n        }\n        \n        function updateSpeed() {\n            dfsState.speed = parseInt(speedSlider.value);\n            if (dfsState.running) {\n                clearInterval(dfsState.timer);\n                dfsState.timer = setInterval(() => {\n                    if (dfsState.stack.length === 0) {\n                        clearInterval(dfsState.timer);\n                        dfsState.running = false;\n                        log(\"DFS completed\");\n                        return;\n                    }\n                    stepDFS();\n                }, dfsState.speed);\n            }\n        }\n        \n        function updateStackDisplay() {\n            stackDisplay.innerHTML = '<strong>DFS Stack:</strong><br>' + \n                dfsState.stack.map(node => \n                    `<div>${dfsState.stack[dfsState.stack.length-1] === node ? 'font-weight:bold;' : ''}> ${node}</div>`\n                ).join('');\n        }\n        \n        function updateVisitOrderDisplay() {\n            if (showVisitOrderCheckbox.checked) {\n                visitOrderDisplay.innerHTML = '<strong>Visit Order:</strong> ' + \n                    dfsState.visitOrder.join(' → ');\n            } else {\n                visitOrderDisplay.innerHTML = '';\n            }\n        }\n        \n        function updateParentRelationships() {\n            if (showParentsCheckbox.checked) {\n                let html = '<strong>Parent Relationships:</strong><br>';\n                for (const [child, parent] of Object.entries(dfsState.parents)) {\n                    html += `${child} → ${parent || 'null'}<br>`;\n                }\n                parentRelationshipsDisplay.innerHTML = html;\n            } else {\n                parentRelationshipsDisplay.innerHTML = '';\n            }\n        }\n        \n        function log(message) {\n            const logEntry = document.createElement('div');\n            logEntry.textContent = `Step ${dfsState.currentStep}: ${message}`;\n            logElement.appendChild(logEntry);\n            logElement.scrollTop = logElement.scrollHeight;\n        }\n        \n        function loadBinaryTree() {\n            clearGraph();\n            \n            // Create a simple binary tree\n            const nodes = ['A', 'B', 'C', 'D', 'E', 'F', 'G'];\n            const edges = [\n                ['A', 'B'], ['A', 'C'],\n                ['B', 'D'], ['B', 'E'],\n                ['C', 'F'], ['C', 'G']\n            ];\n            \n            // Position nodes in a tree layout\n            const positions = {\n                'A': { x: 200, y: 50 },\n                'B': { x: 100, y: 150 },\n                'C': { x: 300, y: 150 },\n                'D': { x: 50, y: 250 },\n                'E': { x: 150, y: 250 },\n                'F': { x: 250, y: 250 },\n                'G': { x: 350, y: 250 }\n            };\n            \n            nodes.forEach(node => {\n                graph.nodes.push({ id: node, x: positions[node].x, y: positions[node].y });\n                graph.adjacencyList[node] = [];\n            });\n            \n            edges.forEach(([from, to]) => {\n                graph.edges.push({ from, to });\n                graph.adjacencyList[from].push(to);\n            });\n            \n            renderGraph();\n            updateStartNodeSelect();\n            log(\"Loaded binary tree graph\");\n        }\n        \n        function loadDAG() {\n            clearGraph();\n            \n            // Create a Directed Acyclic Graph (DAG)\n            const nodes = ['A', 'B', 'C', 'D', 'E', 'F'];\n            const edges = [\n                ['A', 'B'], ['A', 'C'],\n                ['B', 'D'], ['B', 'E'],\n                ['C', 'D'], ['D', 'F'], ['E', 'F']\n            ];\n            \n            // Position nodes\n            const positions = {\n                'A': { x: 100, y: 50 },\n                'B': { x: 50, y: 150 },\n                'C': { x: 150, y: 150 },\n                'D': { x: 50, y: 250 },\n                'E': { x: 150, y: 250 },\n                'F': { x: 100, y: 350 }\n            };\n            \n            nodes.forEach(node => {\n                graph.nodes.push({ id: node, x: positions[node].x, y: positions[node].y });\n                graph.adjacencyList[node] = [];\n            });\n            \n            edges.forEach(([from, to]) => {\n                graph.edges.push({ from, to });\n                graph.adjacencyList[from].push(to);\n            });\n            \n            renderGraph();\n            updateStartNodeSelect();\n            log(\"Loaded Directed Acyclic Graph (DAG)\");\n        }\n        \n        function loadCyclicGraph() {\n            clearGraph();\n            \n            // Create a cyclic graph\n            const nodes = ['A', 'B', 'C', 'D', 'E'];\n            const edges = [\n                ['A', 'B'], ['B', 'C'],\n                ['C', 'D'], ['D', 'E'],\n                ['E', 'A'], ['B', 'D']\n            ];\n            \n            // Position nodes in a circle\n            const centerX = 200, centerY = 200, radius = 150;\n            nodes.forEach((node, i) => {\n                const angle = (i * 2 * Math.PI / nodes.length) - Math.PI/2;\n                graph.nodes.push({\n                    id: node,\n                    x: centerX + radius * Math.cos(angle),\n                    y: centerY + radius * Math.sin(angle)\n                });\n                graph.adjacencyList[node] = [];\n            });\n            \n            edges.forEach(([from, to]) => {\n                graph.edges.push({ from, to });\n                graph.adjacencyList[from].push(to);\n            });\n            \n            renderGraph();\n            updateStartNodeSelect();\n            log(\"Loaded cyclic graph\");\n        }\n    </script>\n</body>\n</html>"
  },
