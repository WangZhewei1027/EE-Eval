    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>B-Tree Index — Visual Concept</title>\n\n  <!-- Elegant fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Poppins:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #081124;\n      --bg-2: #0b2238;\n      --glass: rgba(255,255,255,0.06);\n      --accent: #7BE4FF;\n      --accent-2: #7DF5C3;\n      --muted: #9db0c0;\n      --card: rgba(255,255,255,0.03);\n      --glow: 0 10px 30px rgba(26,197,255,0.06);\n      --node-fill: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    }\n    *{box-sizing:border-box}\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1000px 600px at 10% 10%, rgba(34,139,230,0.08), transparent 8%),\n                  radial-gradient(800px 500px at 90% 90%, rgba(123,229,255,0.04), transparent 12%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color:#e8f6ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:auto;\n    }\n\n    /* Decorative animated blobs */\n    .bg-blob{\n      position:fixed;\n      width:650px;\n      height:650px;\n      top:-8%;\n      left:-10%;\n      background: radial-gradient(circle at 30% 30%, rgba(123,229,255,0.18), rgba(123,229,255,0.08) 20%, transparent 30%),\n                  conic-gradient(from 120deg at 70% 70%, rgba(125,245,195,0.06), transparent 40%);\n      filter: blur(40px) saturate(140%);\n      transform: rotate(12deg);\n      pointer-events:none;\n      z-index:0;\n      animation: floatA 18s ease-in-out infinite;\n      opacity:0.9;\n      border-radius:40%;\n    }\n    .bg-blob.b2{\n      top:55%;\n      left:60%;\n      width:520px;\n      height:520px;\n      background: radial-gradient(circle at 60% 60%, rgba(125,245,195,0.12), transparent 20%),\n                  conic-gradient(from 200deg at 30% 30%, rgba(123,229,255,0.04), transparent 40%);\n      filter:blur(50px);\n      animation: floatB 20s ease-in-out infinite;\n      border-radius:48%;\n    }\n    @keyframes floatA{\n      0%{transform:translateY(0) rotate(12deg) scale(1)}\n      50%{transform:translateY(-18px) rotate(8deg) scale(1.02)}\n      100%{transform:translateY(0) rotate(12deg) scale(1)}\n    }\n    @keyframes floatB{\n      0%{transform:translateY(0) rotate(-6deg) scale(1)}\n      50%{transform:translateY(22px) rotate(-12deg) scale(1.03)}\n      100%{transform:translateY(0) rotate(-6deg) scale(1)}\n    }\n\n    /* Layout */\n    .wrap{\n      position:relative;\n      z-index:2;\n      max-width:1100px;\n      margin:48px auto;\n      padding:36px;\n    }\n    .panel{\n      display:grid;\n      grid-template-columns: 420px 1fr;\n      gap:28px;\n      align-items:start;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      padding:28px;\n      box-shadow: 0 10px 40px rgba(2,10,20,0.6);\n      border: 1px solid rgba(255,255,255,0.04);\n      backdrop-filter: blur(6px) saturate(120%);\n    }\n\n    /* Left column: title and controls */\n    .info{\n      padding:26px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      box-shadow: var(--glow);\n      min-height:420px;\n    }\n\n    h1{\n      font-family:Poppins, Inter, sans-serif;\n      font-size:28px;\n      margin:0 0 8px 0;\n      letter-spacing:-0.4px;\n      color:linear-gradient(90deg,var(--accent),var(--accent-2));\n    }\n    .eyebrow{\n      display:inline-block;\n      padding:6px 10px;\n      font-size:12px;\n      border-radius:999px;\n      color:rgba(8,17,36,0.9);\n      background:linear-gradient(90deg,var(--accent),var(--accent-2));\n      font-weight:700;\n      margin-bottom:14px;\n      box-shadow: 0 6px 22px rgba(123,229,255,0.06);\n    }\n    p.lead{\n      margin-top:8px;\n      font-size:14px;\n      color:var(--muted);\n      line-height:1.5;\n    }\n\n    .controls{\n      margin-top:20px;\n      display:flex;\n      gap:12px;\n    }\n    .btn{\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n      border:0;\n      cursor:pointer;\n      padding:12px 16px;\n      border-radius:12px;\n      font-weight:600;\n      color:var(--bg-1);\n      background: linear-gradient(90deg,var(--accent),#94f1b9);\n      box-shadow: 0 6px 18px rgba(125,245,195,0.12), 0 2px 8px rgba(123,229,255,0.06);\n      transition:transform .22s cubic-bezier(.2,.9,.3,1), box-shadow .2s;\n      transform:translateZ(0);\n    }\n    .btn.secondary{\n      background:transparent;\n      color:var(--accent);\n      border:1px solid rgba(123,229,255,0.12);\n      box-shadow:none;\n    }\n    .btn:active{ transform:translateY(1px) scale(.997) }\n    .btn[disabled]{\n      opacity:0.4;\n      cursor:not-allowed;\n      transform:none;\n      box-shadow:none;\n    }\n\n    .meta{\n      margin-top:22px;\n      display:flex;\n      gap:12px;\n      color:var(--muted);\n      font-size:13px;\n      align-items:center;\n    }\n    .meta .pill{\n      background:rgba(255,255,255,0.02);\n      padding:8px 10px;\n      border-radius:9px;\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n    }\n\n    /* Right column: visualization */\n    .stage{\n      padding:20px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      min-height:420px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n      overflow:hidden;\n    }\n\n    /* SVG styling */\n    svg{\n      width:100%;\n      height:100%;\n      max-height:440px;\n    }\n    .tree-group{ transform-origin:center top; transition:transform .6s cubic-bezier(.2,.9,.3,1); }\n    .edge{\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:2.5;\n      fill:none;\n      transition:stroke .32s ease, stroke-width .32s;\n      stroke-linecap:round;\n    }\n    .edge.drawn{\n      stroke: linear-gradient(90deg,var(--accent),var(--accent-2));\n      stroke:rgba(123,229,255,0.62);\n      stroke-width:3.2;\n      filter: drop-shadow(0 6px 18px rgba(123,229,255,0.08));\n    }\n\n    .node{\n      cursor:default;\n      transform-origin:center;\n      transition:transform .28s cubic-bezier(.2,.9,.3,1), filter .28s, box-shadow .28s;\n      filter: drop-shadow(0 8px 22px rgba(2,8,14,0.55));\n    }\n    .node .frame{\n      rx:12;\n      ry:12;\n      fill: rgba(255,255,255,0.02);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1.2px;\n      transition:fill .22s, stroke .22s, transform .22s;\n    }\n    .node .chips{\n      font-family: Inter, sans-serif;\n      font-size:13px;\n      fill:rgba(255,255,255,0.95);\n      font-weight:600;\n    }\n    .node .chip{\n      fill: rgba(255,255,255,0.03);\n      stroke: rgba(255,255,255,0.05);\n      rx:8; ry:8;\n      transition:fill .28s, transform .28s;\n    }\n\n    /* Idle subtle float for nodes */\n    .node.float{ animation: softFloat 6s ease-in-out infinite; }\n    @keyframes softFloat{\n      0%{ transform:translateY(0) }\n      50%{ transform:translateY(-6px) }\n      100%{ transform:translateY(0) }\n    }\n\n    /* highlight states used in traversal */\n    .node.highlight{\n      transform:scale(1.06);\n    }\n    .node.searching .frame{\n      fill: linear-gradient(180deg, rgba(123,229,255,0.08), rgba(125,245,195,0.03));\n      stroke: rgba(123,229,255,0.88);\n      filter: drop-shadow(0 14px 40px rgba(123,229,255,0.08));\n    }\n    .node.searching .chip{\n      fill: rgba(255,255,255,0.06);\n      stroke: rgba(255,255,255,0.06);\n    }\n\n    .node.found .frame{\n      fill: linear-gradient(180deg, rgba(125,245,195,0.12), rgba(123,229,255,0.03));\n      stroke: rgba(125,245,195,0.94);\n      filter: drop-shadow(0 18px 50px rgba(125,245,195,0.12));\n    }\n    .node.found .chip{\n      fill: rgba(255,255,255,0.06);\n      stroke: rgba(255,255,255,0.06);\n      transform:translateY(-3px);\n    }\n\n    /* small legend */\n    .legend{\n      margin-top:22px;\n      font-size:13px;\n      color:var(--muted);\n      display:flex;\n      gap:12px;\n      flex-wrap:wrap;\n    }\n    .legend .item{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      background:rgba(255,255,255,0.02);\n      padding:8px 10px;\n      border-radius:10px;\n    }\n    .legend .dot{ width:12px;height:12px;border-radius:50% }\n\n    /* info footer inside stage */\n    .stage-note{\n      position:absolute;\n      bottom:18px;\n      left:24px;\n      font-size:13px;\n      color:var(--muted);\n      background: rgba(255,255,255,0.02);\n      padding:10px 12px;\n      border-radius:10px;\n      backdrop-filter: blur(6px);\n      border:1px solid rgba(255,255,255,0.02);\n    }\n\n    /* responsiveness */\n    @media (max-width:980px){\n      .panel{ grid-template-columns:1fr; padding:18px; gap:18px; }\n      .stage{ min-height:360px }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"bg-blob\"></div>\n  <div class=\"bg-blob b2\"></div>\n\n  <div class=\"wrap\">\n    <div class=\"panel\" role=\"region\" aria-label=\"B-Tree Index visualization\">\n      <div class=\"info\">\n        <span class=\"eyebrow\">INDEX STRUCTURE</span>\n        <h1 style=\"margin-top:12px\">B-Tree Index — Visual Concept</h1>\n        <p class=\"lead\">A B-Tree stores sorted keys in balanced nodes to allow fast searches, inserts and deletes. Each internal node routes queries downward by comparing keys; leaves hold actual records or pointers. This animated illustration highlights a simple traversal searching for key <strong>50</strong>.</p>\n\n        <div class=\"controls\" aria-hidden=\"false\">\n          <button id=\"playBtn\" class=\"btn\" title=\"Animate a traversal of the B-Tree\">Animate Traversal ▶</button>\n          <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset the animation\">Reset ⟲</button>\n        </div>\n\n        <div class=\"meta\">\n          <div class=\"pill\"><strong>Order:</strong>&nbsp;M = 3 (example)</div>\n          <div class=\"pill\"><strong>Height:</strong>&nbsp;3</div>\n        </div>\n\n        <div class=\"legend\" style=\"margin-top:18px\">\n          <div class=\"item\"><span class=\"dot\" style=\"background:rgba(123,229,255,0.95)\"></span> Internal node</div>\n          <div class=\"item\"><span class=\"dot\" style=\"background:rgba(125,245,195,0.95)\"></span> Found / Leaf</div>\n          <div class=\"item\"><span class=\"dot\" style=\"background:rgba(255,255,255,0.06)\"></span> Keys</div>\n        </div>\n\n        <p style=\"margin-top:18px; color:var(--muted); font-size:13px; line-height:1.45\">\n          Observation: B-Trees keep nodes partially filled and balanced; search complexity is O(log n) with a small constant because each node contains multiple keys (high fanout), reducing disk or memory accesses.\n        </p>\n      </div>\n\n      <div class=\"stage\">\n        <svg id=\"btreeSvg\" viewBox=\"0 0 900 440\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"true\">\n          <!-- edges -->\n          <g id=\"edges\" stroke-linejoin=\"round\">\n            <path id=\"e-root-left\" class=\"edge\" d=\"M450 88 C 420 140, 270 195, 250 270\" stroke-dasharray=\"600\" stroke-dashoffset=\"600\" />\n            <path id=\"e-root-right\" class=\"edge\" d=\"M450 88 C 480 140, 630 195, 650 270\" stroke-dasharray=\"600\" stroke-dashoffset=\"600\" />\n            <path id=\"e-left-left\" class=\"edge\" d=\"M250 270 C 240 320, 180 360, 140 400\" stroke-dasharray=\"300\" stroke-dashoffset=\"300\" />\n            <path id=\"e-left-right\" class=\"edge\" d=\"M250 270 C 260 320, 320 360, 360 400\" stroke-dasharray=\"300\" stroke-dashoffset=\"300\" />\n            <path id=\"e-right-left\" class=\"edge\" d=\"M650 270 C 640 320, 580 360, 540 400\" stroke-dasharray=\"300\" stroke-dashoffset=\"300\" />\n            <path id=\"e-right-right\" class=\"edge\" d=\"M650 270 C 660 320, 720 360, 760 400\" stroke-dasharray=\"300\" stroke-dashoffset=\"300\" />\n          </g>\n\n          <!-- nodes: root -->\n          <g id=\"root\" class=\"tree-group node float\" transform=\"translate(260,28)\">\n            <g class=\"frameWrap\" transform=\"translate(190,20)\">\n              <!-- frame -->\n              <rect class=\"frame\" x=\"-110\" y=\"0\" width=\"260\" height=\"64\" rx=\"12\" ry=\"12\"></rect>\n\n              <!-- chips (keys) -->\n              <g class=\"chips\" transform=\"translate(-90,34)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\">\n                  <rect class=\"chip\" x=\"0\" y=\"0\" width=\"84\" height=\"28\" rx=\"8\" ry=\"8\"></rect>\n                  <text x=\"12\" y=\"19\" style=\"font-size:14px; fill:rgba(8,17,36,0.95); font-weight:700\">30</text>\n                </g>\n              </g>\n            </g>\n          </g>\n\n          <!-- left internal node -->\n          <g id=\"leftInt\" class=\"tree-group node float\" transform=\"translate(80,170)\">\n            <g class=\"frameWrap\" transform=\"translate(0,0)\">\n              <rect class=\"frame\" x=\"0\" y=\"0\" width=\"220\" height=\"54\" rx=\"12\" ry=\"12\"></rect>\n              <g class=\"chips\" transform=\"translate(10,33)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\">\n                  <rect class=\"chip\" x=\"0\" y=\"0\" width=\"60\" height=\"26\" rx=\"8\" ry=\"8\"></rect>\n                  <text x=\"12\" y=\"18\" style=\"font-size:13px\">10</text>\n                </g>\n                <g class=\"chipWrap\" transform=\"translate(70,0)\">\n                  <rect class=\"chip\" x=\"0\" y=\"0\" width=\"60\" height=\"26\" rx=\"8\" ry=\"8\"></rect>\n                  <text x=\"12\" y=\"18\" style=\"font-size:13px\">20</text>\n                </g>\n              </g>\n            </g>\n          </g>\n\n          <!-- right internal node -->\n          <g id=\"rightInt\" class=\"tree-group node float\" transform=\"translate(520,170)\">\n            <g class=\"frameWrap\" transform=\"translate(0,0)\">\n              <rect class=\"frame\" x=\"0\" y=\"0\" width=\"260\" height=\"54\" rx=\"12\" ry=\"12\"></rect>\n              <g class=\"chips\" transform=\"translate(12,33)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\">\n                  <rect class=\"chip\" x=\"0\" y=\"0\" width=\"60\" height=\"26\" rx=\"8\" ry=\"8\"></rect>\n                  <text x=\"12\" y=\"18\" style=\"font-size:13px\">40</text>\n                </g>\n                <g class=\"chipWrap\" transform=\"translate(70,0)\">\n                  <rect class=\"chip\" x=\"0\" y=\"0\" width=\"60\" height=\"26\" rx=\"8\" ry=\"8\"></rect>\n                  <text x=\"12\" y=\"18\" style=\"font-size:13px\">50</text>\n                </g>\n                <g class=\"chipWrap\" transform=\"translate(140,0)\">\n                  <rect class=\"chip\" x=\"0\" y=\"0\" width=\"60\" height=\"26\" rx=\"8\" ry=\"8\"></rect>\n                  <text x=\"12\" y=\"18\" style=\"font-size:13px\">60</text>\n                </g>\n              </g>\n            </g>\n          </g>\n\n          <!-- left-left leaf -->\n          <g id=\"leftLeafLL\" class=\"tree-group node float\" transform=\"translate(20,320)\">\n            <g class=\"frameWrap\" transform=\"translate(0,0)\">\n              <rect class=\"frame\" x=\"0\" y=\"0\" width=\"220\" height=\"54\" rx=\"12\" ry=\"12\"></rect>\n              <g class=\"chips\" transform=\"translate(10,33)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"48\" height=\"26\" rx=\"8\"></rect><text x=\"10\" y=\"18\" style=\"font-size:13px\">1</text></g>\n                <g class=\"chipWrap\" transform=\"translate(58,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"48\" height=\"26\" rx=\"8\"></rect><text x=\"10\" y=\"18\" style=\"font-size:13px\">8</text></g>\n                <g class=\"chipWrap\" transform=\"translate(116,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"48\" height=\"26\" rx=\"8\"></rect><text x=\"10\" y=\"18\" style=\"font-size:13px\">9</text></g>\n              </g>\n            </g>\n          </g>\n\n          <!-- left-right leaf -->\n          <g id=\"leftLeafLR\" class=\"tree-group node float\" transform=\"translate(360,320)\">\n            <g class=\"frameWrap\" transform=\"translate(0,0)\">\n              <rect class=\"frame\" x=\"0\" y=\"0\" width=\"220\" height=\"54\" rx=\"12\" ry=\"12\"></rect>\n              <g class=\"chips\" transform=\"translate(10,33)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"56\" height=\"26\" rx=\"8\"></rect><text x=\"12\" y=\"18\" style=\"font-size:13px\">12</text></g>\n                <g class=\"chipWrap\" transform=\"translate(68,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"56\" height=\"26\" rx=\"8\"></rect><text x=\"12\" y=\"18\" style=\"font-size:13px\">20</text></g>\n                <g class=\"chipWrap\" transform=\"translate(136,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"56\" height=\"26\" rx=\"8\"></rect><text x=\"12\" y=\"18\" style=\"font-size:13px\">25</text></g>\n              </g>\n            </g>\n          </g>\n\n          <!-- right-left leaf -->\n          <g id=\"rightLeafRL\" class=\"tree-group node float\" transform=\"translate(500,320)\">\n            <g class=\"frameWrap\" transform=\"translate(0,0)\">\n              <rect class=\"frame\" x=\"0\" y=\"0\" width=\"220\" height=\"54\" rx=\"12\" ry=\"12\"></rect>\n              <g class=\"chips\" transform=\"translate(10,33)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"60\" height=\"26\" rx=\"8\"></rect><text x=\"12\" y=\"18\" style=\"font-size:13px\">32</text></g>\n                <g class=\"chipWrap\" transform=\"translate(68,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"56\" height=\"26\" rx=\"8\"></rect><text x=\"12\" y=\"18\" style=\"font-size:13px\">40</text></g>\n                <g class=\"chipWrap\" transform=\"translate(132,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"48\" height=\"26\" rx=\"8\"></rect><text x=\"10\" y=\"18\" style=\"font-size:13px\">45</text></g>\n              </g>\n            </g>\n          </g>\n\n          <!-- right-right leaf (contains 50) -->\n          <g id=\"rightLeafRR\" class=\"tree-group node float\" transform=\"translate(740,320)\">\n            <g class=\"frameWrap\" transform=\"translate(-20,0)\">\n              <rect class=\"frame\" x=\"0\" y=\"0\" width=\"220\" height=\"54\" rx=\"12\" ry=\"12\"></rect>\n              <g class=\"chips\" transform=\"translate(10,33)\">\n                <g class=\"chipWrap\" transform=\"translate(0,-24)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"56\" height=\"26\" rx=\"8\"></rect><text x=\"12\" y=\"18\" style=\"font-size:13px\">50</text></g>\n                <g class=\"chipWrap\" transform=\"translate(68,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"58\" height=\"26\" rx=\"8\"></rect><text x=\"14\" y=\"18\" style=\"font-size:13px\">51</text></g>\n                <g class=\"chipWrap\" transform=\"translate(136,0)\"><rect class=\"chip\" x=\"0\" y=\"0\" width=\"48\" height=\"26\" rx=\"8\"></rect><text x=\"10\" y=\"18\" style=\"font-size:13px\">60</text></g>\n              </g>\n            </g>\n          </g>\n\n        </svg>\n\n        <div class=\"stage-note\">Target key: <strong style=\"color:var(--accent)\">50</strong> — watch the traversal highlight path</div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Very limited interactivity: animate a traversal and reset.\n    (function(){\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n\n      // Node order of the traversal for searching 50:\n      // root -> rightInt -> rightLeafRR (leaf containing 50)\n      const traversal = [\n        { nodeId: 'root', edgeId: null, delay: 0 },\n        { nodeId: 'rightInt', edgeId: 'e-root-right', delay: 700 },\n        { nodeId: 'rightLeafRR', edgeId: 'e-right-right', delay: 700 }\n      ];\n\n      const edgesToDraw = ['e-root-right','e-right-right'];\n\n      // helper to add class\n      function addClass(el, cls){ if(!el) return; if(!el.classList.contains(cls)) el.classList.add(cls); }\n      function removeClass(el, cls){ if(!el) return; el.classList.remove(cls); }\n      function clearAllStates(){\n        // clear nodes states\n        const nodes = document.querySelectorAll('.node');\n        nodes.forEach(n => { removeClass(n,'searching'); removeClass(n,'found'); removeClass(n,'highlight') });\n        // reset edges\n        const edges = document.querySelectorAll('.edge');\n        edges.forEach(e => {\n          e.classList.remove('drawn');\n          // reset dashoffset\n          const len = e.getTotalLength ? e.getTotalLength() : 600;\n          e.style.transition = 'none';\n          e.style.strokeDashoffset = len;\n          // force reflow\n          void e.offsetWidth;\n          e.style.transition = '';\n        });\n      }\n\n      // initialize dashoffsets for edges\n      document.querySelectorAll('.edge').forEach(e => {\n        try{\n          const len = e.getTotalLength();\n          e.style.strokeDasharray = len;\n          e.style.strokeDashoffset = len;\n        }catch(err){}\n      });\n\n      let animating = false;\n      playBtn.addEventListener('click', async function(){\n        if(animating) return;\n        animating = true;\n        playBtn.disabled = true;\n        resetBtn.disabled = true;\n        clearAllStates();\n\n        // tiny entrance shimmer\n        const root = document.getElementById('root');\n        addClass(root,'highlight');\n        await pause(420);\n        removeClass(root,'highlight');\n\n        // Run traversal sequence\n        for(let i=0;i<traversal.length;i++){\n          const step = traversal[i];\n          const node = document.getElementById(step.nodeId);\n          const edge = step.edgeId ? document.getElementById(step.edgeId) : null;\n\n          // animate edge drawing if present\n          if(edge){\n            drawEdge(edge);\n            await pause(240);\n          }\n\n          // mark searching\n          addClass(node,'searching');\n          addClass(node,'highlight');\n\n          // subtle pulse\n          await pulse(node, step.delay || 700);\n\n          // if final node, mark found\n          if(i === traversal.length - 1){\n            removeClass(node,'searching');\n            removeClass(node,'highlight');\n            addClass(node,'found');\n            // slight celebratory glow animation\n            await sparkle(node);\n          } else {\n            removeClass(node,'searching');\n            removeClass(node,'highlight');\n            // keep it slightly emphasized\n            addClass(node,'highlight');\n            await pause(220);\n          }\n        }\n\n        // keep final state for a moment\n        await pause(800);\n        resetBtn.disabled = false;\n        animating = false;\n      });\n\n      resetBtn.addEventListener('click', function(){\n        if(animating) return;\n        clearAllStates();\n      });\n\n      // helpers\n      function pause(ms){ return new Promise(res => setTimeout(res, ms)); }\n\n      function drawEdge(edge){\n        // animate stroke dashoffset to 0 and add 'drawn'\n        try{\n          const len = edge.getTotalLength();\n          edge.style.transition = 'stroke-dashoffset 520ms cubic-bezier(.2,.9,.3,1), stroke 380ms';\n          edge.style.strokeDashoffset = 0;\n          setTimeout(()=> edge.classList.add('drawn'), 260);\n        }catch(e){}\n      }\n\n      function pulse(node, duration){\n        // slight scale in/out using class toggles\n        return new Promise(res => {\n          addClass(node,'highlight');\n          setTimeout(()=> {\n            removeClass(node,'highlight');\n            setTimeout(res, Math.max(160, duration-160));\n          }, Math.max(160, duration-300));\n        });\n      }\n\n      function sparkle(node){\n        return new Promise(res => {\n          // quick scale and glow pulses\n          node.animate([\n            { transform: 'scale(1)' },\n            { transform: 'scale(1.06)' },\n            { transform: 'scale(1)' }\n          ], {\n            duration: 900,\n            easing: 'cubic-bezier(.2,.9,.3,1)'\n          });\n          // also pulse sibling chips\n          const chips = node.querySelectorAll('.chip');\n          chips.forEach((c, idx) => {\n            c.animate([\n              { transform: 'translateY(0)'},\n              { transform: 'translateY(-4px)'},\n              { transform: 'translateY(0)'}\n            ], { duration: 700 + idx*80, easing: 'ease-out' });\n          });\n          setTimeout(res, 920);\n        });\n      }\n\n      // initialize: subtle entrance reveal for nodes (staggered)\n      window.addEventListener('load', function(){\n        const nodes = Array.from(document.querySelectorAll('.tree-group'));\n        nodes.forEach((n,i) => {\n          n.style.opacity = 0;\n          n.style.transform += ' translateY(8px)';\n          setTimeout(()=> {\n            n.style.transition = 'opacity 680ms ease, transform 680ms cubic-bezier(.2,.9,.3,1)';\n            n.style.opacity = 1;\n            n.style.transform = (n.style.transform || '').replace(' translateY(8px)','');\n          }, 120 + i*90);\n        });\n\n        // soft glow on header button\n        setTimeout(()=> {\n          playBtn.animate([\n            { boxShadow: '0 6px 18px rgba(125,245,195,0.12)', transform: 'translateY(0)' },\n            { boxShadow: '0 12px 36px rgba(123,229,255,0.12)', transform: 'translateY(-3px)' },\n            { boxShadow: '0 6px 18px rgba(125,245,195,0.12)', transform: 'translateY(0)' }\n          ], { duration: 2400, iterations: Infinity, easing: 'ease-in-out' });\n        }, 1200);\n      });\n    })();\n  </script>\n</body>\n</html>"
