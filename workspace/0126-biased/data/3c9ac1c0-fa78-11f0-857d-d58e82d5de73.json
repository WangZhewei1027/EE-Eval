    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Version Control — Visual Journey</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&display=swap');\n\n  /* Root and reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1f2937 0%, #0f172a 100%);\n    color: #f8fafc;\n    font-family: 'Montserrat', sans-serif;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 1rem 4rem;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.6rem;\n    letter-spacing: 0.12em;\n    color: #38bdf8;\n    margin: 0 0 0.4em;\n    text-transform: uppercase;\n    text-align: center;\n    user-select: none;\n    text-shadow:\n      0 0 8px #38bdf8aa,\n      0 0 12px #0ea5e9ee,\n      0 0 24px #0ea5e9cc;\n  }\n\n  h2 {\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: #94a3b8;\n    letter-spacing: 0.06em;\n    margin: 0 0 3rem 0;\n    text-align: center;\n    user-select: none;\n  }\n\n  .container {\n    max-width: 880px;\n    width: 100%;\n    position: relative;\n  }\n\n  /* Timeline & Branch Graph */\n  .version-control-graph {\n    position: relative;\n    padding-left: 160px;\n    min-height: 520px;\n    overflow: visible;\n  }\n\n  /* Main vertical line */\n  .main-line {\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    left: 80px;\n    width: 6px;\n    background: linear-gradient(180deg, #38bdf8 0%, #0ea5e9 100%);\n    border-radius: 3px;\n    box-shadow:\n      0 0 12px #38bdf8cc,\n      inset 0 0 15px #3b82f6cc;\n    transition: background 0.6s ease;\n  }\n\n  /* Branch container */\n  .branch {\n    position: absolute;\n    top: 0;\n    left: 0;\n    height: 100%;\n    width: 100%;\n    pointer-events: none;\n  }\n\n  /* Branch lines (curves) */\n  .branch-line {\n    position: absolute;\n    height: 140px;\n    width: 140px;\n    border-radius: 50% / 100%;\n    border: 4px solid transparent;\n    border-left-color: #60a5fa;\n    border-top-color: #3b82f6;\n    box-shadow:\n      0 0 8px #2563ebcc;\n    filter: drop-shadow(0 0 2px #3b82f650);\n    transition: border-color 0.5s ease;\n  }\n\n  .branch-line-right {\n    left: 80px;\n    top: 60px;\n    transform: rotate(-45deg);\n  }\n\n  .branch-line-left {\n    left: 80px;\n    top: 220px;\n    transform: rotate(45deg);\n  }\n\n  /* Commits */\n  .commit {\n    position: absolute;\n    left: 80px;\n    width: 40px;\n    height: 40px;\n    background: linear-gradient(145deg, #0284c7, #0ea5e9);\n    border-radius: 50%;\n    box-shadow:\n      0 0 6px #0ea5e9cc,\n      inset 0 0 8px #0284c799;\n    border: 2.5px solid #e0f2fe;\n    cursor: default;\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.3s ease;\n  }\n\n  .commit:hover {\n    background: linear-gradient(145deg, #3b82f6, #38bdf8);\n    box-shadow:\n      0 0 18px #38bdf8ff,\n      inset 0 0 16px #7dd3fccc;\n    transform: scale(1.18);\n    z-index: 10;\n  }\n\n  /* Commit labels */\n  .commit-label {\n    position: absolute;\n    left: 140px;\n    font-weight: 600;\n    font-size: 1rem;\n    color: #bae6fd;\n    user-select: none;\n    pointer-events: none;\n    width: 300px;\n  }\n\n  .commit-desc {\n    font-weight: 300;\n    font-size: 0.875rem;\n    color: #94a3b8;\n    margin-top: 0.1em;\n    font-style: italic;\n  }\n\n  /* Vertical positions for commits */\n  /* Main master commits */\n  .commit-master-1 { top: 0px; }\n  .commit-master-2 { top: 80px; }\n  .commit-master-3 { top: 160px; }\n  .commit-master-4 { top: 240px; }\n  .commit-master-5 { top: 320px; }\n\n  /* Branch \"feature\" commits offset with horizontal -20 */\n  .commit-feature-1 {\n    top: 80px;\n    left: 15px;\n    background: linear-gradient(145deg, #f97316, #fb923c);\n    box-shadow:\n      0 0 8px #fb923cff,\n      inset 0 0 10px #fca311cc;\n    border: 2.5px solid #fed7aa;\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.3s ease;\n  }\n  .commit-feature-1:hover {\n    background: linear-gradient(145deg, #fb923c, #f97316);\n    box-shadow:\n      0 0 20px #fb923cff,\n      inset 0 0 12px #fca311ee;\n    transform: scale(1.2);\n    z-index: 10;\n  }\n  .commit-feature-2 {\n    top: 160px;\n    left: 15px;\n    background: linear-gradient(145deg, #f97316, #fb923c);\n    box-shadow:\n      0 0 8px #fb923cff,\n      inset 0 0 10px #fca311cc;\n    border: 2.5px solid #fed7aa;\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.3s ease;\n  }\n  .commit-feature-2:hover {\n    background: linear-gradient(145deg, #fb923c, #f97316);\n    box-shadow:\n      0 0 20px #fb923cff,\n      inset 0 0 12px #fca311ee;\n    transform: scale(1.2);\n    z-index: 10;\n  }\n\n  /* Branch \"hotfix\" commit - right side */\n  .commit-hotfix-1 {\n    top: 240px;\n    left: 145px;\n    background: linear-gradient(145deg, #dc2626, #ef4444);\n    box-shadow:\n      0 0 8px #ef4444cc,\n      inset 0 0 10px #f87171cc;\n    border: 2.5px solid #fecaca;\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.3s ease;\n  }\n  .commit-hotfix-1:hover {\n    background: linear-gradient(145deg, #ef4444, #dc2626);\n    box-shadow:\n      0 0 20px #ef4444ff,\n      inset 0 0 12px #f87171ee;\n    transform: scale(1.2);\n    z-index: 10;\n  }\n\n  /* Commit label top alignment relative to commits */\n  .commit-label-master-1 { top: -6px; left: 140px; }\n  .commit-label-master-2 { top: 74px; left: 140px; }\n  .commit-label-master-3 { top: 154px; left: 140px; }\n  .commit-label-master-4 { top: 234px; left: 140px; }\n  .commit-label-master-5 { top: 314px; left: 140px; }\n\n  .commit-label-feature-1 { top: 74px; left: 85px; text-align: right; }\n  .commit-label-feature-2 { top: 154px; left: 85px; text-align: right; }\n\n  .commit-label-hotfix-1 { top: 234px; left: 205px; }\n\n  /* Branch names stylized */\n  .branch-name {\n    position: absolute;\n    font-weight: 700;\n    font-size: 1rem;\n    color: #a5f3fc;\n    text-shadow: 0 0 12px #22d3eecc;\n    font-variant: small-caps;\n    user-select: none;\n    padding: 0.25em 0.75em;\n    border-radius: 18px;\n    letter-spacing: 0.1em;\n    background: linear-gradient(135deg, #0ea5e9bb 0%, #0284c7aa 100%);\n    box-shadow:\n      0 0 8px #0ea5e9aa;\n    transition: background-color 0.4s ease;\n  }\n  .branch-master-name {\n    top: -2rem;\n    left: 60px;\n  }\n  .branch-feature-name {\n    top: 60px;\n    left: 8px;\n    background: linear-gradient(135deg, #fb923cbb 0%, #f9731699 100%);\n    box-shadow:\n      0 0 8px #fb923cff;\n  }\n  .branch-hotfix-name {\n    top: 240px;\n    left: 185px;\n    background: linear-gradient(135deg, #ef4444bb 0%, #dc262699 100%);\n    box-shadow:\n      0 0 10px #ef4444ee;\n  }\n\n  /* Tooltip for descriptive text on commits (appear on hover) */\n  .tooltip {\n    position: absolute;\n    padding: 12px 18px;\n    background: rgba(0, 0, 0, 0.8);\n    border-radius: 14px;\n    color: #d1d5db;\n    font-size: 0.9rem;\n    max-width: 260px;\n    line-height: 1.3;\n    pointer-events: none;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    box-shadow:\n      0 0 18px #0284c7cc;\n    user-select: none;\n    backdrop-filter: blur(6px);\n    transform-origin: bottom center;\n  }\n\n  /* Show tooltip */\n  .commit:hover + .tooltip,\n  .commit:focus + .tooltip {\n    opacity: 1;\n  }\n\n  /* Interactive button controls container */\n  .controls {\n    margin: 2rem 0 0;\n    user-select: none;\n    text-align: center;\n  }\n\n  button {\n    background: #0284c7;\n    color: #f8fafc;\n    border: none;\n    padding: 0.7rem 1.8rem;\n    font-size: 1rem;\n    font-weight: 600;\n    border-radius: 36px;\n    cursor: pointer;\n    box-shadow:\n      0 0 12px #075985cc;\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button:hover, button:focus {\n    background: #0ea5e9;\n    box-shadow:\n      0 0 20px #38bdf8ff;\n    outline: none;\n  }\n  button:active {\n    transform: scale(0.92);\n  }\n\n  /* Subtle fade effect on toggled state */\n  .fade-out {\n    opacity: 0.18 !important;\n    pointer-events: none !important;\n    transform: scale(0.92) !important;\n    transition: opacity 0.7s ease, transform 0.7s ease;\n  }\n\n  /* Footer attribution (very subtle) */\n  footer {\n    margin-top: 4rem;\n    font-size: 0.75rem;\n    color: #64748b;\n    font-weight: 300;\n  }\n\n  /* Responsive scaling */\n  @media (max-width: 600px) {\n    h1 {\n      font-size: 2.6rem;\n    }\n    .commit-label {\n      font-size: 0.9rem;\n      width: 180px;\n    }\n    .version-control-graph {\n      padding-left: 110px;\n      min-height: 460px;\n    }\n    .main-line {\n      left: 55px;\n      width: 4.5px;\n    }\n    .branch-line {\n      width: 110px;\n      height: 110px;\n      border-width: 3px;\n    }\n    /* Commit positions */\n    .commit {\n      left: 55px;\n      width: 30px;\n      height: 30px;\n      border-width: 1.8px;\n    }\n    .commit-feature-1, .commit-feature-2 {\n      left: 0px;\n      width: 30px;\n      height: 30px;\n      border-width: 1.8px;\n    }\n    .commit-hotfix-1 {\n      left: 110px;\n      width: 30px;\n      height: 30px;\n      border-width: 1.8px;\n    }\n    /* Labels changes */\n    .commit-label {\n      left: 95px;\n      width: 220px;\n    }\n    .commit-label-feature-1, .commit-label-feature-2 {\n      left: -10px;\n      text-align: right;\n    }\n    .commit-label-hotfix-1 {\n      left: 160px;\n    }\n    .branch-name {\n      font-size: 0.9rem;\n      padding: 0.2em 0.65em;\n      border-radius: 14px;\n    }\n    .branch-master-name {\n      left: 35px;\n      top: -1.7rem;\n    }\n    .branch-feature-name {\n      left: 2px;\n      top: 55px;\n    }\n    .branch-hotfix-name {\n      left: 155px;\n      top: 235px;\n    }\n  }\n</style>\n</head>\n<body>\n  <header>\n    <h1>VERSION CONTROL</h1>\n    <h2>A Visual Journey Through Branches & Commits</h2>\n  </header>\n\n  <main class=\"container\" aria-label=\"Version control Graph visualization\">\n    <section class=\"version-control-graph\" role=\"img\" aria-describedby=\"description\">\n      <div class=\"main-line\" aria-hidden=\"true\"></div>\n\n      <!-- Branch labels -->\n      <div class=\"branch-name branch-master-name\" aria-hidden=\"true\">MASTER</div>\n      <div class=\"branch-name branch-feature-name\" aria-hidden=\"true\">FEATURE</div>\n      <div class=\"branch-name branch-hotfix-name\" aria-hidden=\"true\">HOTFIX</div>\n\n      <!-- Branch curved lines -->\n      <div class=\"branch-line branch-line-right\" aria-hidden=\"true\"></div>\n      <div class=\"branch-line branch-line-left\" aria-hidden=\"true\"></div>\n\n      <!-- Master branch commits -->\n      <div class=\"commit commit-master-1\" tabindex=\"0\" aria-describedby=\"commitH1\" role=\"button\" aria-label=\"Commit Initial setup\"></div>\n      <div id=\"commitH1\" class=\"tooltip\" style=\"top: -10px; left: 130px;\" role=\"tooltip\">\n        Initial project setup with basic scaffolding.\n      </div>\n      <div class=\"commit-label commit-label-master-1\" aria-hidden=\"true\"><strong>Initial Setup</strong><div class=\"commit-desc\">Basic scaffold & config</div></div>\n\n      <div class=\"commit commit-master-2\" tabindex=\"0\" aria-describedby=\"commitH2\" role=\"button\" aria-label=\"Commit Add core features\"></div>\n      <div id=\"commitH2\" class=\"tooltip\" style=\"top: 68px; left: 130px;\" role=\"tooltip\">\n        Added core logic for user authentication and routing.\n      </div>\n      <div class=\"commit-label commit-label-master-2\" aria-hidden=\"true\"><strong>Core Features</strong><div class=\"commit-desc\">Auth & routing</div></div>\n\n      <div class=\"commit commit-master-3\" tabindex=\"0\" aria-describedby=\"commitH3\" role=\"button\" aria-label=\"Commit Database Integration\"></div>\n      <div id=\"commitH3\" class=\"tooltip\" style=\"top: 148px; left: 130px;\" role=\"tooltip\">\n        Integrated database layer with schema migrations.\n      </div>\n      <div class=\"commit-label commit-label-master-3\" aria-hidden=\"true\"><strong>DB Integration</strong><div class=\"commit-desc\">Schema & migrations</div></div>\n\n      <div class=\"commit commit-master-4\" tabindex=\"0\" aria-describedby=\"commitH4\" role=\"button\" aria-label=\"Commit UI Improvements\"></div>\n      <div id=\"commitH4\" class=\"tooltip\" style=\"top: 228px; left: 130px;\" role=\"tooltip\">\n        Refined user interface with accessibility improvements.\n      </div>\n      <div class=\"commit-label commit-label-master-4\" aria-hidden=\"true\"><strong>UI Improvements</strong><div class=\"commit-desc\">Accessibility focus</div></div>\n\n      <div class=\"commit commit-master-5\" tabindex=\"0\" aria-describedby=\"commitH5\" role=\"button\" aria-label=\"Commit Release v1.0\"></div>\n      <div id=\"commitH5\" class=\"tooltip\" style=\"top: 308px; left: 130px;\" role=\"tooltip\">\n        Official release version 1.0 with stable features.\n      </div>\n      <div class=\"commit-label commit-label-master-5\" aria-hidden=\"true\"><strong>Release v1.0</strong><div class=\"commit-desc\">Stable release</div></div>\n\n      <!-- Feature Branch commits -->\n      <div class=\"commit commit-feature-1\" tabindex=\"0\" aria-describedby=\"commitF1\" role=\"button\" aria-label=\"Commit Feature: Add Chat\"></div>\n      <div id=\"commitF1\" class=\"tooltip\" style=\"top: 68px; left: 15px;\" role=\"tooltip\">\n        Developed chat feature enabling real-time messaging.\n      </div>\n      <div class=\"commit-label commit-label-feature-1\" aria-hidden=\"true\"><strong>Add Chat</strong><div class=\"commit-desc\">Real-time messages</div></div>\n\n      <div class=\"commit commit-feature-2\" tabindex=\"0\" aria-describedby=\"commitF2\" role=\"button\" aria-label=\"Commit Feature: Chat UI\"></div>\n      <div id=\"commitF2\" class=\"tooltip\" style=\"top: 148px; left: 15px;\" role=\"tooltip\">\n        Implemented chat user interface with animations.\n      </div>\n      <div class=\"commit-label commit-label-feature-2\" aria-hidden=\"true\"><strong>Chat UI</strong><div class=\"commit-desc\">Smooth animations</div></div>\n\n      <!-- Hotfix Branch commit -->\n      <div class=\"commit commit-hotfix-1\" tabindex=\"0\" aria-describedby=\"commitHf1\" role=\"button\" aria-label=\"Commit Hotfix: Login Bug\"></div>\n      <div id=\"commitHf1\" class=\"tooltip\" style=\"top: 228px; left: 195px;\" role=\"tooltip\">\n        Hotfix for login failure under special conditions.\n      </div>\n      <div class=\"commit-label commit-label-hotfix-1\" aria-hidden=\"true\"><strong>Login Bugfix</strong><div class=\"commit-desc\">Patch release</div></div>\n    </section>\n\n    <div class=\"controls\" aria-label=\"Toggle visibility of feature branch\">\n      <button id=\"toggleFeatureBtn\" aria-pressed=\"true\">Toggle Feature Branch</button>\n    </div>\n  </main>\n\n  <footer aria-hidden=\"true\">\n    &copy; 2024 Version Control Visualizer &mdash; Crafted with care and code.\n  </footer>\n\n<script>\n  // Basic toggle of feature branch commits and arcs\n  const toggleBtn = document.getElementById('toggleFeatureBtn');\n  const featureCommits = document.querySelectorAll('.commit-feature-1, .commit-feature-2');\n  const featureLabels = document.querySelectorAll('.commit-label-feature-1, .commit-label-feature-2');\n  const branchFeatureName = document.querySelector('.branch-feature-name');\n  const branchLineRight = document.querySelector('.branch-line-right');\n\n  let featureVisible = true;\n\n  toggleBtn.addEventListener('click', () => {\n    featureVisible = !featureVisible;\n\n    featureCommits.forEach(el => {\n      if (featureVisible) {\n        el.classList.remove('fade-out');\n      } else {\n        el.classList.add('fade-out');\n      }\n    });\n    featureLabels.forEach(el => {\n      if (featureVisible) {\n        el.classList.remove('fade-out');\n      } else {\n        el.classList.add('fade-out');\n      }\n    });\n\n    if(featureVisible) {\n      branchFeatureName.classList.remove('fade-out');\n      branchLineRight.classList.remove('fade-out');\n      toggleBtn.setAttribute('aria-pressed', 'true');\n    } else {\n      branchFeatureName.classList.add('fade-out');\n      branchLineRight.classList.add('fade-out');\n      toggleBtn.setAttribute('aria-pressed', 'false');\n    }\n  });\n</script>\n</body>\n</html>"
