    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ternary Search</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        input[type=\"text\"] {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n        }\n        button {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n        #ternary-search-container {\n            width: 80%;\n            height: 500px;\n            padding: 20px;\n            border: 1px solid black;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);\n        }\n        #ternary-search-container input[type=\"number\"] {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n        }\n        #ternary-search-container input[type=\"text\"] {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n        }\n        #ternary-search-container button {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n        }\n        #ternary-search-container button:hover {\n            background-color: #ccc;\n        }\n        #ternary-search-container .search-button {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #ternary-search-container .search-button:hover {\n            background-color: #ccc;\n        }\n        #ternary-search-container .search-button:active {\n            background-color: #aaa;\n        }\n        #ternary-search-container .search-input {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n        }\n        #ternary-search-container .search-input input[type=\"text\"] {\n            width: 100%;\n            height: 20px;\n            padding: 0;\n            margin-bottom: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"ternary-search-container\">\n        <input type=\"number\" id=\"ternary-search-input\" placeholder=\"Search...\">\n        <button id=\"ternary-search-button\">Search</button>\n        <button id=\"ternary-search-clear\">Clear</button>\n        <div id=\"ternary-search-results\"></div>\n    </div>\n\n    <script>\n        let ternarySearchResults = [];\n        const ternarySearchInput = document.getElementById('ternary-search-input');\n        const ternarySearchButton = document.getElementById('ternary-search-button');\n        const ternarySearchClearButton = document.getElementById('ternary-search-clear');\n        const ternarySearchResultsDiv = document.getElementById('ternary-search-results');\n\n        ternarySearchButton.addEventListener('click', searchTernary);\n        ternarySearchClearButton.addEventListener('click', clearTernarySearch);\n\n        function searchTernary() {\n            const searchValue = ternarySearchInput.value.trim();\n            if (searchValue === '') {\n                return;\n            }\n            ternarySearchResults = [];\n            for (let i = 0; i < 10; i++) {\n                for (let j = 0; j < 10; j++) {\n                    for (let k = 0; k < 10; k++) {\n                        ternarySearchResults.push({\n                            i,\n                            j,\n                            k,\n                            value: searchValue\n                        });\n                    }\n                }\n            }\n            ternarySearchResults.sort((a, b) => a.value.localeCompare(b.value));\n            displayTernarySearchResults();\n        }\n\n        function displayTernarySearchResults() {\n            ternarySearchResultsDiv.innerHTML = '';\n            for (let i = 0; i < ternarySearchResults.length; i++) {\n                const result = ternarySearchResults[i];\n                const row = document.createElement('div');\n                row.className = 'ternary-search-result';\n                row.innerHTML = `${result.i} ${result.j} ${result.k} ${result.value}`;\n                ternarySearchResultsDiv.appendChild(row);\n            }\n        }\n\n        function clearTernarySearch() {\n            ternarySearchResults = [];\n            displayTernarySearchResults();\n        }\n    </script>\n</body>\n</html>"
