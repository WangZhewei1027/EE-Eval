    "content": "<html>\n<head>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #fff;\n            font-size: 14px;\n            margin: 0;\n            padding: 0;\n        }\n        \n        input[type=\"text\"] {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        \n        button {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        \n        button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <h1>NP-Completeness Demo</h1>\n    <p>Explore the complexity of NP-Completeness with multiple interactive controls and user-driven workflows.</p>\n    \n    <button id=\"start-button\">Start Experiment</button>\n    <button id=\"reset-button\">Reset Experiment</button>\n    <button id=\"help-button\">View Help</button>\n    \n    <div id=\"output\"></div>\n    \n    <script>\n        let state = 'normal';\n        let maxIterations = 1000;\n        let currentIteration = 0;\n        let maxTime = 10;\n        let timer = null;\n        let inputFields = [];\n        let buttons = [];\n        let output = document.getElementById('output');\n        \n        function updateOutput() {\n            output.innerHTML = `State: ${state}, Iteration: ${currentIteration}, Time: ${Math.floor((currentIteration / maxTime) * maxTime)}ms`;\n        }\n        \n        function startExperiment() {\n            state = 'running';\n            timer = setInterval(() => {\n                if (currentIteration < maxIterations) {\n                    inputFields.forEach(field => field.value = '');\n                    buttons.forEach(button => button.textContent = '');\n                    currentIteration++;\n                    updateOutput();\n                } else {\n                    clearInterval(timer);\n                    state = 'finished';\n                    output.innerHTML = `Time: ${Math.floor((currentIteration / maxTime) * maxTime)}ms`;\n                }\n            }, 100);\n        }\n        \n        function resetExperiment() {\n            state = 'normal';\n            clearInterval(timer);\n            inputFields = [];\n            buttons = [];\n            currentIteration = 0;\n            updateOutput();\n        }\n        \n        function addInputField(field) {\n            inputFields.push(field);\n            buttons.push(document.createElement('button'));\n            buttons[buttons.length - 1].textContent = 'Submit';\n            buttons[buttons.length - 1].addEventListener('click', () => {\n                field.value = inputFields[0].value;\n                inputFields.shift();\n                buttons[buttons.length - 1].textContent = 'Submit';\n            });\n            inputFields[0].addEventListener('input', () => {\n                field.value = inputFields[0].value;\n                inputFields[0].focus();\n            });\n        }\n        \n        function addButton(button) {\n            buttons.push(button);\n            buttons[buttons.length - 1].addEventListener('click', () => {\n                button.textContent = 'Reset';\n                button.textContent = 'Help';\n                buttons[buttons.length - 1].textContent = 'Reset';\n            });\n        }\n        \n        startExperiment();\n        \n        document.getElementById('start-button').addEventListener('click', startExperiment);\n        document.getElementById('reset-button').addEventListener('click', resetExperiment);\n        document.getElementById('help-button').addEventListener('click', () => {\n            alert('NP-Completeness Demo');\n        });\n        \n        function updateButtons() {\n            buttons.forEach(button => button.disabled = false);\n            buttons[buttons.length - 1].disabled = true;\n        }\n        \n        function updateInputFields() {\n            inputFields.forEach(field => field.disabled = false);\n            inputFields[0].disabled = true;\n        }\n        \n        document.getElementById('start-button').addEventListener('click', updateInputFields);\n        document.getElementById('reset-button').addEventListener('click', updateInputFields);\n        document.getElementById('help-button').addEventListener('click', updateInputFields);\n        \n        function updateOutputButtons() {\n            buttons.forEach(button => button.disabled = true);\n            buttons[buttons.length - 1].disabled = false;\n            output.innerHTML = '';\n        }\n        \n        document.getElementById('start-button').addEventListener('click', updateOutputButtons);\n        document.getElementById('reset-button').addEventListener('click', updateOutputButtons);\n        document.getElementById('help-button').addEventListener('click', updateOutputButtons);\n        \n        updateButtons();\n        updateInputFields();\n    </script>\n</body>\n</html>"
