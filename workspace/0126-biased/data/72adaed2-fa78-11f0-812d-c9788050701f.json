    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Neural Networks | A Visual Exploration</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;500;700&display=swap');\n        \n        :root {\n            --primary: #3a0ca3;\n            --secondary: #4361ee;\n            --accent: #f72585;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --gradient: linear-gradient(135deg, #3a0ca3 0%, #4361ee 50%, #4cc9f0 100%);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--light);\n            color: var(--dark);\n            overflow-x: hidden;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n        }\n        \n        header {\n            background: var(--gradient);\n            color: white;\n            padding: 3rem 2rem;\n            text-align: center;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        header::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.1) 0%, transparent 70%);\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            position: relative;\n            text-shadow: 0 2px 10px rgba(0,0,0,0.2);\n        }\n        \n        h2 {\n            font-weight: 300;\n            font-size: 1.5rem;\n            max-width: 800px;\n            margin: 0 auto;\n            position: relative;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            flex: 1;\n        }\n        \n        .intro {\n            text-align: center;\n            margin-bottom: 4rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out forwards;\n        }\n        \n        .intro p {\n            font-size: 1.2rem;\n            line-height: 1.8;\n            margin: 1.5rem auto;\n            max-width: 700px;\n        }\n        \n        .neural-viz {\n            position: relative;\n            height: 500px;\n            margin: 3rem auto;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 20px 40px rgba(0,0,0,0.1);\n            overflow: hidden;\n            opacity: 0;\n            transform: scale(0.95);\n            animation: fadeInScale 1s 0.3s ease-out forwards;\n        }\n        \n        .network {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n        }\n        \n        .layer {\n            position: absolute;\n            top: 50%;\n            transform: translateY(-50%);\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            gap: 30px;\n        }\n        \n        .neuron {\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            background: var(--secondary);\n            position: relative;\n            box-shadow: 0 5px 15px rgba(67, 97, 238, 0.4);\n            transition: all 0.3s ease;\n        }\n        \n        .neuron::after {\n            content: '';\n            position: absolute;\n            top: -5px;\n            left: -5px;\n            right: -5px;\n            bottom: -5px;\n            border-radius: 50%;\n            border: 2px solid var(--accent);\n            opacity: 0;\n            animation: pulse 2s infinite;\n        }\n        \n        .neuron.active {\n            transform: scale(1.2);\n            background: var(--accent);\n            box-shadow: 0 5px 20px rgba(247, 37, 133, 0.6);\n        }\n        \n        .neuron.active::after {\n            opacity: 1;\n        }\n        \n        .connection {\n            position: absolute;\n            background: linear-gradient(to right, rgba(67, 97, 238, 0.3), rgba(67, 97, 238, 0.1));\n            transform-origin: left center;\n            height: 2px;\n            z-index: -1;\n            transition: all 0.3s ease;\n        }\n        \n        .connection.active {\n            background: linear-gradient(to right, rgba(247, 37, 133, 0.6), rgba(247, 37, 133, 0.3));\n            height: 3px;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            background: var(--gradient);\n            color: white;\n            border: none;\n            padding: 0.8rem 2rem;\n            font-size: 1rem;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(58, 12, 163, 0.3);\n            font-weight: 600;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(rgba(255,255,255,0.2), transparent);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(58, 12, 163, 0.4);\n        }\n        \n        button:hover::after {\n            opacity: 1;\n        }\n        \n        button:active {\n            transform: translateY(1px);\n        }\n        \n        footer {\n            text-align: center;\n            padding: 2rem;\n            background: var(--dark);\n            color: white;\n            font-size: 0.9rem;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes fadeInScale {\n            from { opacity: 0; transform: scale(0.95); }\n            to { opacity: 1; transform: scale(1); }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); opacity: 0.7; }\n            70% { transform: scale(1.3); opacity: 0; }\n            100% { transform: scale(1.3); opacity: 0; }\n        }\n        \n        .info-cards {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            margin: 4rem 0;\n        }\n        \n        .card {\n            background: white;\n            border-radius: 12px;\n            padding: 2rem;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.05);\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n            opacity: 0;\n            transform: translateY(20px);\n        }\n        \n        .card:nth-child(1) { animation: fadeIn 0.8s 0.4s ease-out forwards; }\n        .card:nth-child(2) { animation: fadeIn 0.8s 0.6s ease-out forwards; }\n        .card:nth-child(3) { animation: fadeIn 0.8s 0.8s ease-out forwards; }\n        \n        .card:hover {\n            transform: translateY(-10px);\n            box-shadow: 0 15px 40px rgba(0,0,0,0.1);\n        }\n        \n        .card h3 {\n            font-family: 'Playfair Display', serif;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.5rem;\n        }\n        \n        .card p {\n            line-height: 1.7;\n            color: #555;\n        }\n        \n        .card-icon {\n            font-size: 2.5rem;\n            margin-bottom: 1.5rem;\n            color: var(--secondary);\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Neural Networks</h1>\n        <h2>A Visual Exploration of Artificial Intelligence</h2>\n    </header>\n    \n    <div class=\"container\">\n        <div class=\"intro\">\n            <p>Neural networks are computing systems inspired by biological neural networks. They learn to perform tasks by considering examples, generally without being programmed with task-specific rules.</p>\n        </div>\n        \n        <div class=\"neural-viz\">\n            <div class=\"network\" id=\"network\"></div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"activateBtn\">Activate Network</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n        \n        <div class=\"info-cards\">\n            <div class=\"card\">\n                <div class=\"card-icon\">🧠</div>\n                <h3>Biological Inspiration</h3>\n                <p>Neural networks are loosely modeled after the human brain, with interconnected nodes (neurons) that process information in layers, similar to how biological neurons transmit signals.</p>\n            </div>\n            <div class=\"card\">\n                <div class=\"card-icon\">🔢</div>\n                <h3>Learning Process</h3>\n                <p>Through backpropagation and gradient descent, neural networks adjust their weights to minimize error, improving their performance on tasks like image recognition and language processing.</p>\n            </div>\n            <div class=\"card\">\n                <div class=\"card-icon\">🌐</div>\n                <h3>Modern Applications</h3>\n                <p>From voice assistants to medical diagnosis, neural networks power many of today's AI breakthroughs, enabling machines to recognize patterns and make decisions with human-like ability.</p>\n            </div>\n        </div>\n    </div>\n    \n    <footer>\n        <p>Aesthetic Visualization of Neural Network Concepts | Designed for Visual Impact</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const networkEl = document.getElementById('network');\n            const activateBtn = document.getElementById('activateBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            // Network configuration\n            const layers = [4, 6, 5, 3]; // Number of neurons in each layer\n            const neurons = [];\n            const connections = [];\n            \n            // Create network\n            function createNetwork() {\n                networkEl.innerHTML = '';\n                neurons.length = 0;\n                connections.length = 0;\n                \n                const width = networkEl.offsetWidth;\n                const height = networkEl.offsetHeight;\n                const layerCount = layers.length;\n                const layerGap = width / (layerCount + 1);\n                \n                // Create layers and neurons\n                for (let l = 0; l < layerCount; l++) {\n                    const layerEl = document.createElement('div');\n                    layerEl.className = 'layer';\n                    layerEl.style.left = `${(l + 1) * layerGap - 15}px`;\n                    networkEl.appendChild(layerEl);\n                    \n                    const neuronCount = layers[l];\n                    const neuronGap = height / (neuronCount + 1);\n                    \n                    // Create neurons in this layer\n                    for (let n = 0; n < neuronCount; n++) {\n                        const neuronEl = document.createElement('div');\n                        neuronEl.className = 'neuron';\n                        neuronEl.style.top = `${(n + 1) * neuronGap - 15}px`;\n                        neuronEl.dataset.layer = l;\n                        neuronEl.dataset.index = n;\n                        layerEl.appendChild(neuronEl);\n                        neurons.push(neuronEl);\n                    }\n                }\n                \n                // Create connections between neurons\n                for (let i = 0; i < neurons.length; i++) {\n                    const currentNeuron = neurons[i];\n                    const currentLayer = parseInt(currentNeuron.dataset.layer);\n                    \n                    // Connect to next layer\n                    if (currentLayer < layerCount - 1) {\n                        const nextLayerNeurons = neurons.filter(n => \n                            parseInt(n.dataset.layer) === currentLayer + 1\n                        );\n                        \n                        for (let j = 0; j < nextLayerNeurons.length; j++) {\n                            const nextNeuron = nextLayerNeurons[j];\n                            createConnection(currentNeuron, nextNeuron);\n                        }\n                    }\n                }\n            }\n            \n            // Create a connection between two neurons\n            function createConnection(fromNeuron, toNeuron) {\n                const fromRect = fromNeuron.getBoundingClientRect();\n                const toRect = toNeuron.getBoundingClientRect();\n                const networkRect = networkEl.getBoundingClientRect();\n                \n                const x1 = fromRect.left + fromRect.width/2 - networkRect.left;\n                const y1 = fromRect.top + fromRect.height/2 - networkRect.top;\n                const x2 = toRect.left + toRect.width/2 - networkRect.left;\n                const y2 = toRect.top + toRect.height/2 - networkRect.top;\n                \n                const length = Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2));\n                const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;\n                \n                const connectionEl = document.createElement('div');\n                connectionEl.className = 'connection';\n                connectionEl.style.width = `${length}px`;\n                connectionEl.style.left = `${x1}px`;\n                connectionEl.style.top = `${y1}px`;\n                connectionEl.style.transform = `rotate(${angle}deg)`;\n                \n                networkEl.appendChild(connectionEl);\n                connections.push({\n                    el: connectionEl,\n                    from: fromNeuron,\n                    to: toNeuron\n                });\n            }\n            \n            // Activate random path through network\n            function activateNetwork() {\n                // Reset all\n                neurons.forEach(n => n.classList.remove('active'));\n                connections.forEach(c => c.el.classList.remove('active'));\n                \n                // Start with first layer\n                const startLayer = 0;\n                let currentNeurons = neurons.filter(n => \n                    parseInt(n.dataset.layer) === startLayer\n                );\n                \n                // Randomly select one neuron to start\n                let currentNeuron = currentNeurons[Math.floor(Math.random() * currentNeurons.length)];\n                currentNeuron.classList.add('active');\n                \n                // Animate through layers\n                const totalLayers = layers.length;\n                let layer = startLayer;\n                \n                const interval = setInterval(() => {\n                    layer++;\n                    if (layer >= totalLayers) {\n                        clearInterval(interval);\n                        return;\n                    }\n                    \n                    // Find connected neurons in next layer\n                    const nextConnections = connections.filter(c => \n                        c.from === currentNeuron && \n                        parseInt(c.to.dataset.layer) === layer\n                    );\n                    \n                    if (nextConnections.length === 0) return;\n                    \n                    // Randomly select one connection to follow\n                    const nextConnection = nextConnections[Math.floor(Math.random() * nextConnections.length)];\n                    const nextNeuron = nextConnection.to;\n                    \n                    // Highlight connection and next neuron\n                    nextConnection.el.classList.add('active');\n                    nextNeuron.classList.add('active');\n                    \n                    currentNeuron = nextNeuron;\n                }, 300);\n            }\n            \n            // Initialize network\n            createNetwork();\n            \n            // Handle window resize\n            window.addEventListener('resize', function() {\n                createNetwork();\n            });\n            \n            // Button events\n            activateBtn.addEventListener('click', function() {\n                activateNetwork();\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                neurons.forEach(n => n.classList.remove('active'));\n                connections.forEach(c => c.el.classList.remove('active'));\n            });\n        });\n    </script>\n</body>\n</html>"
