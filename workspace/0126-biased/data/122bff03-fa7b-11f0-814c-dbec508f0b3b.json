    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kruskal's Algorithm</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        #input-container {\n            display: inline-block;\n            margin: 10px 0;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #input-container input[type=\"number\"] {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: 1px solid #ccc;\n        }\n        #kruskal-button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #kruskal-button:hover {\n            background-color: #3e8e41;\n        }\n        #kruskal-output {\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Kruskal's Algorithm</h1>\n    <div id=\"input-container\">\n        <input type=\"number\" id=\"m\" value=\"3\">\n        <label for=\"m\">Maximum edges:</label>\n        <br>\n        <input type=\"number\" id=\"e\" value=\"0\">\n        <label for=\"e\">Minimum edges:</label>\n        <br>\n        <input type=\"number\" id=\"k\" value=\"4\">\n        <label for=\"k\">Number of edges:</label>\n        <br>\n        <button id=\"kruskal-button\">Kruskal's Algorithm</button>\n        <br>\n        <button id=\"run-button\">Run</button>\n    </div>\n    <div id=\"kruskal-output\"></div>\n\n    <script>\n        const m = parseInt(document.getElementById('m').value);\n        const e = parseInt(document.getElementById('e').value);\n        const k = parseInt(document.getElementById('k').value);\n\n        const edges = [];\n\n        function addEdge(u, v) {\n            edges.push([u, v]);\n        }\n\n        function kruskal() {\n            edges.sort((a, b) => a[1] - b[1]);\n            let result = [];\n            let i = 0;\n            let j = 0;\n\n            while (i < edges.length && j < edges.length) {\n                if (edges[i][0] < edges[j][0]) {\n                    result.push(edges[i]);\n                    i++;\n                } else if (edges[i][0] > edges[j][0]) {\n                    result.push(edges[j]);\n                    j++;\n                } else {\n                    i++;\n                    j++;\n                }\n            }\n\n            return result;\n        }\n\n        function run() {\n            const result = kruskal();\n            const output = result.map((edge, i) => {\n                return `<${i+1}> ${edge[0]} - ${edge[1]} (${edge[1] - edge[0]})`;\n            }).join('\\n');\n\n            document.getElementById('kruskal-output').innerHTML = output;\n        }\n\n        document.getElementById('run-button').addEventListener('click', run);\n\n        document.getElementById('kruskal-button').addEventListener('click', () => {\n            run();\n        });\n    </script>\n</body>\n</html>"
