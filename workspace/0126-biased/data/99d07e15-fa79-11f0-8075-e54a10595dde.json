    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>REST API Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .control { margin-bottom: 10px; }\n    </style>\n</head>\n<body>\n\n<h1>REST API Interactive Demo</h1>\n\n<div class=\"control\">\n    <input type=\"text\" id=\"apiEndpoint\" placeholder=\"Enter API Endpoint\" />\n    <button id=\"fetchData\">Fetch Data</button>\n</div>\n\n<div class=\"control\">\n    <input type=\"text\" id=\"postData\" placeholder='Enter JSON for POST (e.g. {\"name\": \"John\"})' />\n    <button id=\"postDataButton\">Post Data</button>\n</div>\n\n<div class=\"control\">\n    <input type=\"text\" id=\"updateDataId\" placeholder=\"Enter ID to Update\" />\n    <input type=\"text\" id=\"updateData\" placeholder='Enter JSON for Update (e.g. {\"name\": \"Doe\"})' />\n    <button id=\"updateDataButton\">Update Data</button>\n</div>\n\n<div class=\"control\">\n    <input type=\"text\" id=\"deleteDataId\" placeholder=\"Enter ID to Delete\" />\n    <button id=\"deleteDataButton\">Delete Data</button>\n</div>\n\n<div class=\"control\">\n    <label for=\"timeout\">Request Timeout (ms): </label>\n    <input type=\"number\" id=\"timeout\" value=\"5000\" />\n</div>\n\n<h2>Response:</h2>\n<pre id=\"responseOutput\"></pre>\n\n<script>\n    document.getElementById('fetchData').onclick = function() {\n        const endpoint = document.getElementById('apiEndpoint').value;\n        const timeout = document.getElementById('timeout').value;\n\n        fetch(endpoint, { method: 'GET', timeout: timeout })\n            .then(response => response.json())\n            .then(data => {\n                document.getElementById('responseOutput').textContent = JSON.stringify(data, null, 2);\n            })\n            .catch(error => {\n                document.getElementById('responseOutput').textContent = 'Error: ' + error;\n            });\n    };\n\n    document.getElementById('postDataButton').onclick = function() {\n        const endpoint = document.getElementById('apiEndpoint').value;\n        const postData = document.getElementById('postData').value;\n        const timeout = document.getElementById('timeout').value;\n\n        fetch(endpoint, {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            body: postData,\n            timeout: timeout\n        })\n        .then(response => response.json())\n        .then(data => {\n            document.getElementById('responseOutput').textContent = JSON.stringify(data, null, 2);\n        })\n        .catch(error => {\n            document.getElementById('responseOutput').textContent = 'Error: ' + error;\n        });\n    };\n\n    document.getElementById('updateDataButton').onclick = function() {\n        const endpoint = document.getElementById('apiEndpoint').value + '/' + document.getElementById('updateDataId').value;\n        const updateData = document.getElementById('updateData').value;\n        const timeout = document.getElementById('timeout').value;\n\n        fetch(endpoint, {\n            method: 'PUT',\n            headers: { 'Content-Type': 'application/json' },\n            body: updateData,\n            timeout: timeout\n        })\n        .then(response => response.json())\n        .then(data => {\n            document.getElementById('responseOutput').textContent = JSON.stringify(data, null, 2);\n        })\n        .catch(error => {\n            document.getElementById('responseOutput').textContent = 'Error: ' + error;\n        });\n    };\n\n    document.getElementById('deleteDataButton').onclick = function() {\n        const endpoint = document.getElementById('apiEndpoint').value + '/' + document.getElementById('deleteDataId').value;\n        const timeout = document.getElementById('timeout').value;\n\n        fetch(endpoint, {\n            method: 'DELETE',\n            timeout: timeout\n        })\n        .then(response => response.json())\n        .then(data => {\n            document.getElementById('responseOutput').textContent = JSON.stringify(data, null, 2);\n        })\n        .catch(error => {\n            document.getElementById('responseOutput').textContent = 'Error: ' + error;\n        });\n    };\n</script>\n\n</body>\n</html>"
