  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>TCP/IP Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  button, input[type=text], input[type=number], select {\n    font: inherit;\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  label {\n    margin-right: 0.3em;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n    font-family: monospace, monospace;\n  }\n  fieldset {\n    margin-bottom: 1em;\n    padding: 0.4em;\n  }\n  legend {\n    font-weight: bold;\n  }\n  hr {\n    margin: 1em 0;\n  }\n  .small {\n    font-size: 0.9em;\n  }\n</style>\n</head>\n<body>\n\n<h1>TCP/IP Protocol Suite Interactive Explorer</h1>\n<p>Explore TCP/IP through layered protocol interaction, packet crafting, connection simulation, and routing. Use controls below to build packets, simulate transmissions and understand protocol behavior step-by-step.</p>\n\n<hr />\n\n<fieldset>\n  <legend>1. Select Layer & Protocol</legend>\n  <label><input type=\"radio\" name=\"layer\" value=\"link\" checked /> Link Layer (Ethernet)</label>\n  <label><input type=\"radio\" name=\"layer\" value=\"internet\" /> Internet Layer (IP)</label>\n  <label><input type=\"radio\" name=\"layer\" value=\"transport\" /> Transport Layer (TCP/UDP)</label>\n  <label><input type=\"radio\" name=\"layer\" value=\"application\" /> Application Layer (HTTP/DNS/Custom)</label>\n</fieldset>\n\n<fieldset id=\"protocol-section\">\n  <legend>2. Protocol Options</legend>\n  <div id=\"protocol-controls\">\n    <!-- Dynamic controls for protocols will appear here -->\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>3. Packet Builder</legend>\n  <div id=\"packet-builder\">\n    <!-- Fields vary by layer and protocol -->\n  </div>\n  <button id=\"build-packet\">Build Packet</button>\n  <button id=\"reset-builder\">Reset Fields</button>\n</fieldset>\n\n<fieldset>\n  <legend>4. Packet Preview & Edit</legend>\n  <textarea id=\"packet-preview\" readonly></textarea><br/>\n  <button id=\"edit-packet\">Edit Packet JSON</button>\n  <button id=\"save-packet\" disabled>Save Edited Packet</button>\n  <button id=\"clear-packet\">Clear</button>\n</fieldset>\n\n<hr />\n\n<fieldset>\n  <legend>5. Transmission Simulation</legend>\n  <label for=\"simulate-path\">Choose Transmission Path:</label>\n  <select id=\"simulate-path\">\n    <option value=\"local\">Local Ethernet Segment</option>\n    <option value=\"internet\">Internet (IP Routing)</option>\n    <option value=\"loopback\">Loopback Interface</option>\n  </select>\n  <button id=\"start-sim\">Start Simulation</button>\n  <button id=\"step-sim\" disabled>Step Simulation</button>\n  <button id=\"reset-sim\" disabled>Reset Simulation</button>\n  <button id=\"auto-run\" disabled>Auto Run (5 steps)</button>\n  <div id=\"sim-log\" style=\"white-space: pre-wrap; border: 1px solid black; margin-top:0.5em; height: 12em; overflow-y: scroll; background:#fff;\"></div>\n</fieldset>\n\n<hr />\n\n<fieldset>\n  <legend>6. TCP Connection Simulator</legend>\n  <div>\n    <button id=\"start-conn\">Start TCP 3-Way Handshake</button>\n    <button id=\"close-conn\" disabled>Close TCP Connection</button>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <label for=\"tcp-send-data\">Send Data (string):</label>\n    <input type=\"text\" id=\"tcp-send-data\" />\n    <button id=\"tcp-send\" disabled>Send</button>\n  </div>\n  <div id=\"tcp-status\" style=\"white-space: pre-wrap; border: 1px solid black; margin-top:0.5em; height: 10em; overflow-y: scroll; background:#fff;\"></div>\n</fieldset>\n\n<hr />\n\n<fieldset>\n  <legend>7. Routing & IP Address Exploration</legend>\n  <div>\n    <label for=\"my-ip\">My IP:</label>\n    <input type=\"text\" id=\"my-ip\" value=\"192.168.1.2\" size=\"15\" />\n    <label for=\"dest-ip\">Destination IP:</label>\n    <input type=\"text\" id=\"dest-ip\" value=\"8.8.8.8\" size=\"15\" />\n    <button id=\"calc-route\">Calculate Routing Path</button>\n  </div>\n  <pre id=\"routing-output\" style=\"border:1px solid black; margin-top:0.5em; height: 8em; overflow-y: auto;\"></pre>\n  <button id=\"reset-routing\">Reset</button>\n</fieldset>\n\n<hr />\n\n<fieldset>\n  <legend>8. Custom User Packet JSON Input</legend>\n  <textarea id=\"custom-json\" placeholder='Paste custom packet JSON here'></textarea><br/>\n  <button id=\"load-custom-json\">Load & Validate</button>\n  <div id=\"json-valid-msg\" class=\"small\"></div>\n</fieldset>\n\n<script>\n(() => {\n  // Data structures & templates\n\n  // Protocols available by layer\n  const PROTOCOLS = {\n    link: ['Ethernet'],\n    internet: ['IPv4', 'IPv6', 'ICMP'],\n    transport: ['TCP', 'UDP'],\n    application: ['HTTP', 'DNS', 'Custom']\n  };\n\n  // Packet templates by protocol - for packet builder defaults and fields\n  const PACKET_TEMPLATES = {\n    Ethernet: {\n      description: \"Classic Ethernet II frame\",\n      fields: {\n        destMAC: {label: \"Destination MAC (e.g. AA:BB:CC:DD:EE:FF)\", type: \"text\", default: \"ff:ff:ff:ff:ff:ff\"},\n        srcMAC: {label: \"Source MAC\", type: \"text\", default: \"00:11:22:33:44:55\"},\n        ethType: {label: \"Ethertype (hex, e.g. 0800 for IPv4)\", type: \"text\", default: \"0800\"},\n        payload: {label: \"Payload (hex string)\", type: \"text\", default: \"\"}\n      }\n    },\n    IPv4: {\n      description: \"Internet Protocol version 4 packet\",\n      fields: {\n        version: {label: \"Version (fixed 4)\", type: \"number\", default: 4, readonly: true},\n        ihl: {label: \"IHL (header length in 32-bit words)\", type: \"number\", default: 5, min: 5, max: 15},\n        tos: {label: \"Type of Service (decimal)\", type: \"number\", default: 0, min: 0, max: 255},\n        totalLength: {label: \"Total Length (bytes)\", type: \"number\", default: 20, min: 20, max: 65535},\n        identification: {label: \"Identification\", type: \"number\", default: 0, min: 0, max: 65535},\n        flags: {label: \"Flags (3 bits decimal)\", type: \"number\", default: 2, min: 0, max: 7},\n        fragmentOffset: {label: \"Fragment Offset\", type: \"number\", default: 0, min:0, max: 8191},\n        ttl: {label: \"Time to Live\", type: \"number\", default: 64, min: 1, max: 255},\n        protocol: {label: \"Protocol (decimal, e.g. 6=TCP, 17=UDP, 1=ICMP)\", type: \"number\", default: 6, min: 0, max: 255},\n        headerChecksum: {label: \"Header Checksum (hex, auto-calc ignored)\", type: \"text\", default: \"0000\"},\n        srcIP: {label: \"Source IP (dotted decimal)\", type: \"text\", default: \"192.168.1.2\"},\n        destIP: {label: \"Destination IP\", type: \"text\", default: \"192.168.1.1\"},\n        payload: {label: \"Payload (hex string)\", type: \"text\", default: \"\"}\n      }\n    },\n    IPv6: {\n      description: \"Internet Protocol version 6 packet\",\n      fields: {\n        version: {label: \"Version (fixed 6)\", type: \"number\", default: 6, readonly: true},\n        trafficClass: {label: \"Traffic Class\", type: \"number\", default: 0, min: 0, max: 255},\n        flowLabel: {label: \"Flow Label\", type: \"number\", default: 0, min: 0, max: 1048575},\n        payloadLength: {label: \"Payload Length\", type: \"number\", default: 0, min:0, max:65535},\n        nextHeader: {label: \"Next Header (decimal, e.g. 6=TCP)\", type: \"number\", default: 6, min: 0, max: 255},\n        hopLimit: {label: \"Hop Limit\", type: \"number\", default: 64, min: 1, max: 255},\n        srcIP: {label: \"Source IPv6 (hex notation)\", type: \"text\", default: \"::1\"},\n        destIP: {label: \"Destination IPv6\", type: \"text\", default: \"::1\"},\n        payload: {label: \"Payload (hex string)\", type: \"text\", default: \"\"}\n      }\n    },\n    ICMP: {\n      description: \"Internet Control Message Protocol\",\n      fields: {\n        type: {label: \"Type\", type: \"number\", default: 8, min: 0, max: 255},\n        code: {label: \"Code\", type: \"number\", default: 0, min: 0, max: 255},\n        checksum: {label: \"Checksum (hex string)\", type: \"text\", default: \"0000\"},\n        identifier: {label: \"Identifier\", type: \"number\", default: 0, min: 0, max: 65535},\n        sequenceNumber: {label: \"Sequence Number\", type: \"number\", default: 0, min: 0, max: 65535},\n        data: {label: \"Data (hex string)\", type: \"text\", default: \"\"}\n      }\n    },\n    TCP: {\n      description: \"Transmission Control Protocol segment\",\n      fields: {\n        srcPort: {label: \"Source Port\", type: \"number\", default: 12345, min: 0, max: 65535},\n        destPort: {label: \"Destination Port\", type: \"number\", default: 80, min: 0, max: 65535},\n        seqNum: {label: \"Sequence Number\", type: \"number\", default: 0, min: 0, max: 4294967295},\n        ackNum: {label: \"Acknowledgment Number\", type: \"number\", default: 0, min: 0, max: 4294967295},\n        dataOffset: {label: \"Data Offset (header length)\", type: \"number\", default: 5, min: 5, max: 15},\n        reserved: {label: \"Reserved (3 bits)\", type: \"number\", default: 0, min: 0, max: 7},\n        flags: {label: \"Flags (decimal bitmask)\", type: \"number\", default: 2, min: 0, max: 511}, // Typically 9 bits, e.g., SYN=2, ACK=16,...\n        windowSize: {label: \"Window Size\", type: \"number\", default: 65535, min: 0, max: 65535},\n        checksum: {label: \"Checksum (hex string)\", type: \"text\", default: \"0000\"},\n        urgentPointer: {label: \"Urgent Pointer\", type: \"number\", default: 0, min: 0, max: 65535},\n        options: {label: \"Options (hex string)\", type: \"text\", default: \"\"},\n        payload: {label: \"Payload (ASCII string)\", type: \"text\", default: \"\"}\n      }\n    },\n    UDP: {\n      description: \"User Datagram Protocol datagram\",\n      fields: {\n        srcPort: {label: \"Source Port\", type: \"number\", default: 12345, min: 0, max: 65535},\n        destPort: {label: \"Destination Port\", type: \"number\", default: 53, min: 0, max: 65535},\n        length: {label: \"Length (bytes)\", type: \"number\", default: 8, min: 8, max: 65535},\n        checksum: {label: \"Checksum (hex string)\", type: \"text\", default: \"0000\"},\n        payload: {label: \"Payload (ASCII string)\", type: \"text\", default: \"\"}\n      }\n    },\n    HTTP: {\n      description: \"HTTP protocol - request or response builder\",\n      fields: {\n        method: {label: \"Method (GET/POST/PUT/DELETE)\", type: \"text\", default: \"GET\"},\n        url: {label: \"URL\", type: \"text\", default: \"/\"},\n        httpVersion: {label: \"HTTP Version\", type: \"text\", default: \"HTTP/1.1\"},\n        headers: {label: \"Headers (JSON object string)\", type: \"text\", default: \"{\\\"Host\\\":\\\"example.com\\\"}\"},\n        body: {label: \"Body (string)\", type: \"text\", default: \"\"}\n      }\n    },\n    DNS: {\n      description: \"DNS query packet builder\",\n      fields: {\n        transactionID: {label: \"Transaction ID (hex 4 digits)\", type: \"text\", default: \"1234\"},\n        flags: {label: \"Flags (hex 4 digits)\", type: \"text\", default: \"0100\"},\n        questions: {label: \"Number of Questions\", type: \"number\", default: 1, min: 0, max: 65535},\n        answerRRs: {label: \"Answer RRs\", type: \"number\", default: 0, min: 0, max: 65535},\n        authorityRRs: {label: \"Authority RRs\", type: \"number\", default: 0, min: 0, max: 65535},\n        additionalRRs: {label: \"Additional RRs\", type: \"number\", default: 0, min: 0, max: 65535},\n        queryName: {label: \"Query Name (domain)\", type: \"text\", default: \"example.com\"},\n        queryType: {label: \"Query Type (A/AAAA/CNAME/etc)\", type: \"text\", default: \"A\"},\n        queryClass: {label: \"Query Class (default 1)\", type: \"number\", default: 1, min: 0, max: 65535}\n      }\n    },\n    Custom: {\n      description: \"Custom Application Payload\",\n      fields: {\n        data: {label: \"Custom Raw Payload (ASCII or hex, specify)\", type: \"text\", default: \"\"}\n      }\n    }\n  };\n\n  // Protocol selection & controls cache\n  let currentLayer = 'link';\n  let currentProtocol = PROTOCOLS.link[0]; // defaults\n  let packetState = null; // last built packet object\n  let editingPacket = false;  // is user editing custom json\n\n  // DOM refs\n  const protocolSection = document.getElementById('protocol-controls');\n  const packetBuilderDiv = document.getElementById('packet-builder');\n  const packetPreview = document.getElementById('packet-preview');\n  const buildPacketBtn = document.getElementById('build-packet');\n  const resetBuilderBtn = document.getElementById('reset-builder');\n  const editPacketBtn = document.getElementById('edit-packet');\n  const savePacketBtn = document.getElementById('save-packet');\n  const clearPacketBtn = document.getElementById('clear-packet');\n  const simLogDiv = document.getElementById('sim-log');\n\n  const startSimBtn = document.getElementById('start-sim');\n  const stepSimBtn = document.getElementById('step-sim');\n  const resetSimBtn = document.getElementById('reset-sim');\n  const autoRunBtn = document.getElementById('auto-run');\n  const simulatePathSelect = document.getElementById('simulate-path');\n\n  const startConnBtn = document.getElementById('start-conn');\n  const closeConnBtn = document.getElementById('close-conn');\n  const tcpSendDataInput = document.getElementById('tcp-send-data');\n  const tcpSendBtn = document.getElementById('tcp-send');\n  const tcpStatusDiv = document.getElementById('tcp-status');\n\n  const myIpInput = document.getElementById('my-ip');\n  const destIpInput = document.getElementById('dest-ip');\n  const calcRouteBtn = document.getElementById('calc-route');\n  const routingOutput = document.getElementById('routing-output');\n  const resetRoutingBtn = document.getElementById('reset-routing');\n\n  const customJsonArea = document.getElementById('custom-json');\n  const loadCustomJsonBtn = document.getElementById('load-custom-json');\n  const jsonValidMsg = document.getElementById('json-valid-msg');\n\n  // Utility functions\n\n  function clearChildren(elem) {\n    while(elem.firstChild) elem.removeChild(elem.firstChild);\n  }\n\n  function createInputField(key, config, value) {\n    const container = document.createElement('div');\n    const label = document.createElement('label');\n    label.textContent = config.label + \": \";\n    label.htmlFor = \"field-\" + key;\n    const input = document.createElement(config.type === \"number\" ? \"input\" : \"input\");\n    input.type = config.type;\n    input.id = \"field-\" + key;\n    input.name = key;\n    if(config.readonly) input.readOnly = true;\n    if(config.min !== undefined) input.min = config.min;\n    if(config.max !== undefined) input.max = config.max;\n    if(config.size) input.size = config.size;\n    input.value = value !== undefined ? value : (config.default !== undefined ? config.default : '');\n    container.appendChild(label);\n    container.appendChild(input);\n    return container;\n  }\n\n  function loadProtocolOptions(layer) {\n    const protocols = PROTOCOLS[layer];\n    clearChildren(protocolSection);\n    // Add dropdown to select protocol within layer if multiple\n    if(protocols.length > 1) {\n      const label = document.createElement('label');\n      label.textContent = \"Protocol: \";\n      const select = document.createElement('select');\n      select.id = 'protocol-select';\n\n      protocols.forEach(proto => {\n        const option = document.createElement('option');\n        option.value = proto;\n        option.textContent = proto;\n        select.appendChild(option);\n      });\n\n      protocolSection.appendChild(label);\n      protocolSection.appendChild(select);\n\n      select.value = currentProtocol;\n      select.addEventListener('change', e => {\n        currentProtocol = e.target.value;\n        loadPacketBuilderFields(currentProtocol);\n        clearPacketPreview();\n      });\n\n    } else {\n      // Single protocol - just show its name and description\n      const p = document.createElement('p');\n      currentProtocol = protocols[0];\n      p.textContent = \"Protocol: \" + currentProtocol + \" - \" + (PACKET_TEMPLATES[currentProtocol]?.description || \"\");\n      protocolSection.appendChild(p);\n    }\n    loadPacketBuilderFields(currentProtocol);\n  }\n\n  function loadPacketBuilderFields(protocol) {\n    clearChildren(packetBuilderDiv);\n    const template = PACKET_TEMPLATES[protocol];\n    if(!template) {\n      packetBuilderDiv.textContent = \"No template available.\";\n      return;\n    }\n    // Provide inputs for all fields\n    for(const key in template.fields) {\n      const config = template.fields[key];\n      const fieldNode = createInputField(key, config);\n      packetBuilderDiv.appendChild(fieldNode);\n    }\n  }\n\n  // Get packet builder data as object, casting values\n  function readPacketBuilderData(protocol) {\n    const template = PACKET_TEMPLATES[protocol];\n    if(!template) return null;\n    const obj = {protocol};\n    for(const key in template.fields) {\n      const config = template.fields[key];\n      const input = document.getElementById(\"field-\" + key);\n      if(!input) continue;\n      let val = input.value;\n      if(config.type === \"number\") {\n        val = val === '' ? NaN : Number(val);\n        if(isNaN(val)) return null;\n        // Optional: validate ranges - skipping here for brevity\n      }\n      obj[key] = val;\n    }\n    return obj;\n  }\n\n  function updatePacketPreview(packet) {\n    if(!packet) {\n      packetPreview.value = '';\n      return;\n    }\n    packetPreview.value = JSON.stringify(packet, null, 2);\n  }\n\n  function clearPacketPreview() {\n    packetPreview.value = '';\n    packetState = null;\n    editingPacket = false;\n    savePacketBtn.disabled = true;\n  }\n\n  function toggleEditing(enable) {\n    if(enable) {\n      packetPreview.readOnly = false;\n      savePacketBtn.disabled = false;\n      editingPacket = true;\n    } else {\n      packetPreview.readOnly = true;\n      savePacketBtn.disabled = true;\n      editingPacket = false;\n    }\n  }\n\n  // Validate MAC address format (simple)\n  function validMAC(mac) {\n    return /^([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}$/.test(mac);\n  }\n\n  // Validate IPv4 address (simplified)\n  function validIPv4(ip) {\n    const parts = ip.split('.');\n    if(parts.length !== 4) return false;\n    return parts.every(p => {\n      const n = Number(p);\n      return n>=0 && n<=255 && String(n) === p;\n    });\n  }\n\n  // Validate IPv6 address (very basic)\n  function validIPv6(ip) {\n    // just check if contains colon for this demo\n    return ip.includes(':');\n  }\n\n  // Validation of packet fields sanity (simple)\n  function validatePacket(packet) {\n    if(!packet) return false;\n    switch(packet.protocol) {\n      case 'Ethernet':\n        if(!validMAC(packet.destMAC)) return false;\n        if(!validMAC(packet.srcMAC)) return false;\n        if(!/^[0-9a-fA-F]{4}$/.test(packet.ethType)) return false;\n        // payload can be empty or hex string\n        if(packet.payload && !/^[0-9a-fA-F]*$/.test(packet.payload)) return false;\n        return true;\n      case 'IPv4':\n        if(packet.version != 4) return false;\n        if(!validIPv4(packet.srcIP)) return false;\n        if(!validIPv4(packet.destIP)) return false;\n        if(isNaN(packet.ihl) || packet.ihl < 5 || packet.ihl > 15) return false;\n        if(isNaN(packet.tos) || packet.tos < 0 || packet.tos > 255) return false;\n        if(isNaN(packet.ttl) || packet.ttl < 1 || packet.ttl > 255) return false;\n        if(isNaN(packet.protocol) || packet.protocol < 0 || packet.protocol > 255) return false;\n        if(packet.payload && !/^[0-9a-fA-F]*$/.test(packet.payload)) return false;\n        return true;\n      case 'IPv6':\n        if(packet.version != 6) return false;\n        if(!validIPv6(packet.srcIP)) return false;\n        if(!validIPv6(packet.destIP)) return false;\n        if(isNaN(packet.trafficClass) || packet.trafficClass<0 || packet.trafficClass>255) return false;\n        if(isNaN(packet.nextHeader) || packet.nextHeader<0 || packet.nextHeader>255) return false;\n        if(isNaN(packet.hopLimit) || packet.hopLimit < 1 || packet.hopLimit > 255) return false;\n        if(packet.payload && !/^[0-9a-fA-F]*$/.test(packet.payload)) return false;\n        return true;\n      case 'ICMP':\n        if(isNaN(packet.type) || packet.type<0 || packet.type>255) return false;\n        if(isNaN(packet.code) || packet.code<0 || packet.code>255) return false;\n        if(!/^[0-9a-fA-F]{4}$/.test(packet.checksum)) return false;\n        if(isNaN(packet.identifier) || packet.identifier<0 || packet.identifier>65535) return false;\n        if(isNaN(packet.sequenceNumber) || packet.sequenceNumber<0 || packet.sequenceNumber>65535) return false;\n        if(packet.data && !/^[0-9a-fA-F]*$/.test(packet.data)) return false;\n        return true;\n      case 'TCP':\n        for(const key of ['srcPort','destPort','seqNum','ackNum','dataOffset','reserved','flags','windowSize','urgentPointer']) {\n          if(isNaN(packet[key])) return false;\n        }\n        if(!/^[0-9a-fA-F]*$/.test(packet.checksum)) return false;\n        if(packet.options && !/^[0-9a-fA-F]*$/.test(packet.options)) return false;\n        // payload is ASCII string, accept any\n        return true;\n      case 'UDP':\n        for(const key of ['srcPort','destPort','length']) {\n          if(isNaN(packet[key])) return false;\n        }\n        if(!/^[0-9a-fA-F]*$/.test(packet.checksum)) return false;\n        // payload ASCII string, accept any\n        return true;\n      case 'HTTP':\n        if(typeof packet.method !== 'string') return false;\n        if(typeof packet.url !== 'string') return false;\n        if(typeof packet.httpVersion !== 'string') return false;\n        try {\n          JSON.parse(packet.headers);\n        } catch {\n          return false;\n        }\n        return true;\n      case 'DNS':\n        if(!/^[0-9a-fA-F]{4}$/.test(packet.transactionID)) return false;\n        if(!/^[0-9a-fA-F]{4}$/.test(packet.flags)) return false;\n        for(const key of ['questions','answerRRs','authorityRRs','additionalRRs','queryClass']) {\n          if(isNaN(packet[key]) || packet[key] < 0) return false;\n        }\n        if(typeof packet.queryName !== 'string') return false;\n        if(typeof packet.queryType !== 'string') return false;\n        return true;\n      case 'Custom':\n        return typeof packet.data === 'string';\n      default:\n        return false;\n    }\n  }\n\n  // Text helpers for simulation logs\n  function logSim(text) {\n    simLogDiv.textContent += text + \"\\n\";\n    simLogDiv.scrollTop = simLogDiv.scrollHeight;\n  }\n\n  // ----------------------------------\n  // INTERACTIVE FUNCTIONALITY STARTS\n  // ----------------------------------\n\n  // Initial setup\n  function init() {\n    // Load initial layer protocols & packet builder\n    const radios = document.querySelectorAll('input[name=layer]');\n    radios.forEach(radio => {\n      radio.addEventListener('change', e => {\n        currentLayer = e.target.value;\n        const protocols = PROTOCOLS[currentLayer];\n        currentProtocol = protocols[0];\n        loadProtocolOptions(currentLayer);\n        clearPacketPreview();\n      });\n    });\n    loadProtocolOptions(currentLayer);\n\n    buildPacketBtn.addEventListener('click', () => {\n      if(editingPacket) {\n        alert(\"You are editing packet JSON. Save or cancel editing first.\");\n        return;\n      }\n      const packet = readPacketBuilderData(currentProtocol);\n      if(!packet) {\n        alert(\"Invalid or incomplete input values.\");\n        return;\n      }\n      if(!validatePacket(packet)) {\n        alert(\"Validation failed: Check field formats and ranges.\");\n        return;\n      }\n      packetState = packet;\n      updatePacketPreview(packet);\n      alert(\"Packet built successfully.\");\n    });\n\n    resetBuilderBtn.addEventListener('click', () => {\n      loadPacketBuilderFields(currentProtocol);\n      clearPacketPreview();\n    });\n\n    editPacketBtn.addEventListener('click', () => {\n      if(!packetState) {\n        alert(\"No packet to edit. Build one first.\");\n        return;\n      }\n      toggleEditing(true);\n    });\n\n    savePacketBtn.addEventListener('click', () => {\n      try {\n        const parsed = JSON.parse(packetPreview.value);\n        if(!validatePacket(parsed)) {\n          alert(\"Validation failed: Edited JSON does not match protocol fields or has invalid values.\");\n          return;\n        }\n        packetState = parsed;\n        toggleEditing(false);\n        alert(\"Packet JSON saved successfully.\");\n      } catch(e) {\n        alert(\"Invalid JSON format: \" + e.message);\n      }\n    });\n\n    clearPacketBtn.addEventListener('click', () => {\n      packetState = null;\n      clearPacketPreview();\n      toggleEditing(false);\n      loadPacketBuilderFields(currentProtocol);\n    });\n\n    // Simulation controls\n    startSimBtn.addEventListener('click', () => {\n      if(!packetState) {\n        alert(\"Build or load a packet first before starting simulation.\");\n        return;\n      }\n      simLogDiv.textContent = \"\";\n      simulation.reset(packetState, simulatePathSelect.value);\n      logSim(\"Simulation started on path: \" + simulatePathSelect.value);\n      stepSimBtn.disabled = false;\n      resetSimBtn.disabled = false;\n      autoRunBtn.disabled = false;\n      startSimBtn.disabled = true;\n    });\n\n    stepSimBtn.addEventListener('click', () => {\n      const done = simulation.step();\n      if(done) {\n        logSim(\"Simulation ended.\");\n        stepSimBtn.disabled = true;\n        autoRunBtn.disabled = true;\n        startSimBtn.disabled = false;\n      }\n    });\n\n    resetSimBtn.addEventListener('click', () => {\n      simulation.reset(null, null);\n      simLogDiv.textContent = \"\";\n      stepSimBtn.disabled = true;\n      resetSimBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      startSimBtn.disabled = false;\n    });\n\n    autoRunBtn.addEventListener('click', () => {\n      autoRunBtn.disabled = true;\n      stepSimBtn.disabled = true;\n      startSimBtn.disabled = true;\n      resetSimBtn.disabled = true;\n\n      let steps = 5;\n      function doStep() {\n        if(steps <= 0) {\n          logSim(\"Auto-run finished.\");\n          stepSimBtn.disabled = true;\n          startSimBtn.disabled = false;\n          resetSimBtn.disabled = false;\n          return;\n        }\n        const done = simulation.step();\n        if(done) {\n          logSim(\"Simulation ended.\");\n          stepSimBtn.disabled = true;\n          startSimBtn.disabled = false;\n          resetSimBtn.disabled = false;\n          return;\n        }\n        steps--;\n        setTimeout(doStep, 700);\n      }\n      doStep();\n    });\n\n    // TCP connection simulator\n    startConnBtn.addEventListener('click', () => {\n      tcpConnection.startHandshake();\n      tcpSendBtn.disabled = false;\n      closeConnBtn.disabled = false;\n      startConnBtn.disabled = true;\n      tcpSendDataInput.value = \"\";\n      tcpStatusDiv.textContent = \"\";\n    });\n\n    closeConnBtn.addEventListener('click', () => {\n      tcpConnection.closeConnection();\n      closeConnBtn.disabled = true;\n      tcpSendBtn.disabled = true;\n      startConnBtn.disabled = false;\n      tcpSendDataInput.value = \"\";\n    });\n\n    tcpSendBtn.addEventListener('click', () => {\n      const text = tcpSendDataInput.value.trim();\n      if(text === \"\") {\n        alert(\"Type data to send.\");\n        return;\n      }\n      tcpConnection.sendData(text);\n      tcpSendDataInput.value = \"\";\n    });\n\n    // Routing & IP exploration\n    calcRouteBtn.addEventListener('click', () => {\n      const src = myIpInput.value.trim();\n      const dst = destIpInput.value.trim();\n      routingOutput.textContent = \"\";\n      if(!validIPv4(src)) {\n        alert(\"My IP is not valid IPv4 address.\");\n        return;\n      }\n      if(!validIPv4(dst)) {\n        alert(\"Destination IP is not valid IPv4 address.\");\n        return;\n      }\n      try {\n        const routeSteps = routingCalculator.calculateRouting(src, dst);\n        routingOutput.textContent = \"Routing Path:\\n\" + routeSteps.map((s,i) => (i+1) + \". \" + s).join(\"\\n\");\n      } catch (e) {\n        routingOutput.textContent = \"Error calculating route: \" + e.message;\n      }\n    });\n\n    resetRoutingBtn.addEventListener('click', () => {\n      routingOutput.textContent = \"\";\n      myIpInput.value = \"192.168.1.2\";\n      destIpInput.value = \"8.8.8.8\";\n    });\n\n    // Custom JSON input\n    loadCustomJsonBtn.addEventListener('click', () => {\n      const raw = customJsonArea.value.trim();\n      jsonValidMsg.textContent = \"\";\n      if(!raw) return;\n      try {\n        const parsed = JSON.parse(raw);\n        if(typeof parsed !== 'object' || parsed === null) {\n          jsonValidMsg.textContent = \"JSON is not an object\";\n          return;\n        }\n        if(!parsed.protocol) {\n          jsonValidMsg.textContent = \"Missing 'protocol' field.\";\n          return;\n        }\n        if(!validatePacket(parsed)) {\n          jsonValidMsg.textContent = \"Validation failed according to protocol.\";\n          return;\n        }\n        packetState = parsed;\n        updatePacketPreview(parsed);\n        loadPacketBuilderFields(parsed.protocol);\n        // fill inputs\n        const template = PACKET_TEMPLATES[parsed.protocol];\n        for(const key in template.fields) {\n          const input = document.getElementById(\"field-\"+key);\n          if(input && (parsed[key] !== undefined)) input.value = parsed[key];\n        }\n        jsonValidMsg.textContent = \"Packet loaded successfully.\";\n      } catch(e) {\n        jsonValidMsg.textContent = \"Invalid JSON: \" + e.message;\n      }\n    });\n  }\n\n  // ------------------\n  // Simulation engine\n  // ------------------\n\n  // Simulation states & step logic\n  const simulation = (() => {\n    let currentPacket = null;\n    let path = null;\n    let stepCount = 0;\n    let maxSteps = 20;\n\n    function reset(packet, selectedPath) {\n      currentPacket = packet;\n      path = selectedPath || null;\n      stepCount = 0;\n    }\n\n    function step() {\n      if(!currentPacket || !path) {\n        logSim(\"No active simulation.\");\n        return true; // no simulation\n      }\n      stepCount++;\n      switch(path) {\n        case 'local':\n          if(stepCount === 1) {\n            logSim(\"[Ethernet] Frame created with dest MAC: \" + currentPacket.destMAC);\n            return false;\n          }\n          if(stepCount === 2) {\n            logSim(\"[Ethernet] Frame is checked for CRC and sent on local LAN.\");\n            return false;\n          }\n          if(stepCount === 3) {\n            logSim(\"[Ethernet] Frame received by destination device.\");\n            return false;\n          }\n          if(stepCount === 4) {\n            if(currentPacket.ethType === '0800') {\n              logSim(\"[Ethernet] Detected IPv4 packet inside Ethernet. Passing to IP layer.\");\n              return false;\n            } else {\n              logSim(\"[Ethernet] Payload processed at Link Layer.\");\n              return true;\n            }\n          }\n          return true;\n\n        case 'internet':\n          if(stepCount === 1) {\n            logSim(\"[Link] Frame created (Ethernet) encapsulating IP packet.\");\n            return false;\n          }\n          if(stepCount === 2) {\n            logSim(\"[IP] IP header checksum verified; TTL decremented.\");\n            return false;\n          }\n          if(stepCount === 3) {\n            logSim(\"[IP] Routing table checked for destination address.\");\n            return false;\n          }\n          if(stepCount === 4) {\n            logSim(\"[IP] Packet forwarded to next hop router.\");\n            return false;\n          }\n          if(stepCount === 5) {\n            if(currentPacket.protocol === 6) {\n              logSim(\"[Transport] TCP segment processed, state machine updated.\");\n              return false;\n            } else if(currentPacket.protocol === 17) {\n              logSim(\"[Transport] UDP datagram processed.\");\n              return false;\n            } else {\n              logSim(\"[Transport] Other Transport protocol.\");\n              return false;\n            }\n          }\n          if(stepCount === 6) {\n            logSim(\"[Application] Data delivered to application layer.\");\n            return true;\n          }\n          return true;\n\n        case 'loopback':\n          if(stepCount === 1) {\n            logSim(\"[Loopback] Packet sent to loopback interface.\");\n            return false;\n          }\n          if(stepCount === 2) {\n            logSim(\"[Loopback] Packet received by same host.\");\n            return false;\n          }\n          if(stepCount === 3) {\n            logSim(\"[Loopback] Packet passed up protocol stack internally.\");\n            return true;\n          }\n          return true;\n\n        default:\n          logSim(\"Unknown simulation path.\");\n          return true;\n      }\n    }\n\n    return {reset, step};\n  })();\n\n  // -----------------------\n  // TCP Connection Simulator\n  // -----------------------\n\n  const tcpConnection = (() => {\n    // TCP states\n    // CLOSED -> SYN-SENT -> ESTABLISHED\n    // ESTABLISHED -> FIN-WAIT -> CLOSED\n    // We'll simulate simplified 3-way handshake + data send + FIN close\n    let state = 'CLOSED';\n    let seqNum = 0;\n    let ackNum = 0;\n\n    function logStatus(msg) {\n      tcpStatusDiv.textContent += msg + \"\\n\";\n      tcpStatusDiv.scrollTop = tcpStatusDiv.scrollHeight;\n    }\n\n    function startHandshake() {\n      state = 'CLOSED';\n      seqNum = Math.floor(Math.random()*100000);\n      ackNum = 0;\n      tcpStatusDiv.textContent = \"\";\n      logStatus(\"Starting TCP 3-way handshake...\");\n      logStatus(\"[Client] State: CLOSED\");\n      setTimeout(() => {\n        sendSYN();\n      }, 500);\n    }\n\n    function sendSYN() {\n      if(state !== 'CLOSED') return;\n      state = 'SYN-SENT';\n      logStatus(\"[Client] Sending SYN (Seq=\"+seqNum+\")\");\n      setTimeout(() => {\n        receiveSYNACK();\n      }, 1000);\n    }\n\n    function receiveSYNACK() {\n      if(state !== 'SYN-SENT') return;\n      ackNum = seqNum + 1;\n      seqNum = Math.floor(Math.random()*100000);\n      logStatus(\"[Server] Received SYN\");\n      logStatus(\"[Server] Sending SYN+ACK (Seq=\"+seqNum+\", Ack=\"+ackNum+\")\");\n      setTimeout(() => {\n        sendACK();\n      }, 1000);\n    }\n\n    function sendACK() {\n      if(state !== 'SYN-SENT') return;\n      state = 'ESTABLISHED';\n      ackNum = seqNum + 1;\n      logStatus(\"[Client] Received SYN+ACK\");\n      logStatus(\"[Client] Sending ACK (Seq=\"+ackNum+\", Ack=\"+ackNum+\")\");\n      logStatus(\"[Client] State: ESTABLISHED\");\n      logStatus(\"TCP connection established.\");\n    }\n\n    function sendData(data) {\n      if(state !== 'ESTABLISHED') {\n        alert(\"TCP connection not established.\");\n        return;\n      }\n      logStatus(\"[Client] Sending data: \\\"\" + data + \"\\\"\");\n      seqNum += data.length;\n      setTimeout(() => {\n        receiveDataAck(seqNum);\n      }, 800);\n    }\n\n    function receiveDataAck(newAck) {\n      logStatus(\"[Server] Received data, sending ACK (Ack=\"+newAck+\")\");\n      ackNum = newAck;\n    }\n\n    // Closing sequence (4-step simplified)\n    function closeConnection() {\n      if(state !== 'ESTABLISHED') {\n        alert(\"TCP connection not established.\");\n        return;\n      }\n      logStatus(\"[Client] Sending FIN\");\n      state = 'FIN-WAIT';\n      setTimeout(() => {\n        receiveFINACK();\n      }, 800);\n    }\n\n    function receiveFINACK() {\n      logStatus(\"[Server] Received FIN\");\n      logStatus(\"[Server] Sending ACK\");\n      setTimeout(() => {\n        sendFIN();\n      }, 800);\n    }\n\n    function sendFIN() {\n      logStatus(\"[Client] Received ACK, sending FIN\");\n      setTimeout(() => {\n        receiveFINACK2();\n      }, 800);\n    }\n\n    function receiveFINACK2() {\n      logStatus(\"[Server] Received FIN\");\n      logStatus(\"[Server] Sending ACK\");\n      setTimeout(() => {\n        state = 'CLOSED';\n        logStatus(\"TCP connection closed. State: CLOSED\");\n        closeConnBtn.disabled = true;\n        tcpSendBtn.disabled = true;\n        startConnBtn.disabled = false;\n      }, 500);\n    }\n\n    return {\n      startHandshake,\n      sendData,\n      closeConnection\n    };\n  })();\n\n  // ----------------------\n  // Routing Calculator\n  // ----------------------\n\n  const routingCalculator = (() => {\n    // Simulate simple IPv4 routing table:\n    // 192.168.1.0/24 => local LAN\n    // 10.0.0.0/8 => VPN\n    // 0.0.0.0/0 via default gateway 192.168.1.1\n\n    // for demo: if destination is in same subnet => direct\n    // else => gateway\n\n    function ipToInt(ip) {\n      const parts = ip.split('.');\n      return parts.reduce((acc,v) => (acc<<8) + Number(v), 0) >>> 0;\n    }\n\n    function inSubnet(ip, subnet, maskBits) {\n      const ipInt = ipToInt(ip);\n      const subnetInt = ipToInt(subnet);\n      const mask = ~(0xFFFFFFFF >>> maskBits) >>> 0;\n      return (ipInt & mask) === (subnetInt & mask);\n    }\n\n    function calculateRouting(srcIP, destIP) {\n      const steps = [];\n      steps.push(\"Host src IP: \"+srcIP);\n      if(inSubnet(destIP, \"192.168.1.0\", 24)) {\n        steps.push(\"Destination IP is in the same subnet 192.168.1.0/24\");\n        steps.push(\"Send directly via Ethernet\");\n      } else if(inSubnet(destIP, \"10.0.0.0\", 8)) {\n        steps.push(\"Destination IP is in VPN subnet 10.0.0.0/8\");\n        steps.push(\"Send packet via VPN tunnel interface\");\n      } else {\n        steps.push(\"Destination IP is external\");\n        steps.push(\"Send packet to default gateway 192.168.1.1\");\n        steps.push(\"Router forwards packet to destination via next hop\");\n      }\n      return steps;\n    }\n\n    return {calculateRouting};\n  })();\n\n  // Initialize everything\n  init();\n\n})();\n</script>\n\n</body>\n</html>"
