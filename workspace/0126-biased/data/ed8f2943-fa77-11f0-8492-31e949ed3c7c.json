r: #c0392b;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>OSI Model</h1>\n        <div class=\"layer\" onclick=\"showAlert('Layer 7: Application Layer')\">\n            <div class=\"label\">Application</div>\n            <div class=\"description\">This layer is responsible for network services to applications.</div>\n        </div>\n        <div class=\"layer\" onclick=\"showAlert('Layer 6: Presentation Layer')\">\n            <div class=\"label\">Presentation</div>\n            <div class=\"description\">This layer translates data between a networking service and an application.</div>\n        </div>\n        <div class=\"layer\" onclick=\"showAlert('Layer 5: Session Layer')\">\n            <div class=\"label\">Session</div>\n            <div class=\"description\">This layer manages sessions between applications.</div>\n        </div>\n        <div class=\"layer\" onclick=\"showAlert('Layer 4: Transport Layer')\">\n            <div class=\"label\">Transport</div>\n            <div class=\"description\">This layer provides end-to-end communication services for applications.</div>\n        </div>\n        <div class=\"layer\" onclick=\"showAlert('Layer 3: Network Layer')\">\n            <div class=\"label\">Network</div>\n            <div class=\"description\">This layer handles the routing of data.</div>\n        </div>\n        <div class=\"layer\" onclick=\"showAlert('Layer 2: Data Link Layer')\">\n            <div class=\"label\">Data Link</div>\n            <div class=\"description\">This layer provides node-to-node data transfer and error correction.</div>\n        </div>\n        <div class=\"layer\" onclick=\"showAlert('Layer 1: Physical Layer')\">\n            <div class=\"label\">Physical</div>\n            <div class=\"description\">This layer transmits raw bit streams over a physical medium.</div>\n        </d