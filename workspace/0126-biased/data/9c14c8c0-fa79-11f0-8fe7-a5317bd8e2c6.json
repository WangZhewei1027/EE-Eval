  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Dynamic Programming Interactive Playground</title>\n<style>\n/* Intentionally minimal: keep plain black text on white background, minimal spacing */\nbody { margin: 10px; font-family: Arial, Helvetica, sans-serif; color: black; background: white; }\nsection { margin-bottom: 12px; }\nlabel { margin-right: 6px; }\ninput[type=\"text\"], textarea { width: 100%; box-sizing: border-box; }\ntextarea { height: 80px; }\nbutton { margin-right: 6px; margin-top: 6px; }\n.small { width: 60px; display: inline-block; }\n.code { font-family: monospace; white-space: pre-wrap; background: #fff; border: 1px solid #ddd; padding: 6px; }\n.table-wrap { overflow:auto; max-height:300px; border: 1px solid #ddd; padding: 6px; }\n.log { max-height: 150px; overflow:auto; border: 1px solid #ddd; padding: 6px; background: #fff; }\n.stack { max-height: 150px; overflow:auto; border: 1px solid #ddd; padding: 6px; background: #fff; }\n.controls { margin-bottom:8px; }\n.small-input { width: 140px; display:inline-block; }\n.inline { display:inline-block; vertical-align: middle; margin-right:8px; }\n.candidate-btn { margin-right:4px; margin-top:4px; display:inline-block; }\n.notice { font-size: 0.9em; color: black; }\n</style>\n</head>\n<body>\n\n<h2>Dynamic Programming Interactive Playground</h2>\n\n<section>\n  <div class=\"controls\">\n    <label for=\"algo\">Algorithm:</label>\n    <select id=\"algo\">\n      <option value=\"knapsack\">0/1 Knapsack (bottom-up)</option>\n      <option value=\"edit\">Edit Distance (bottom-up)</option>\n      <option value=\"lis\">Longest Increasing Subsequence (O(n^2) bottom-up)</option>\n      <option value=\"coin\">Coin Change (min coins, bottom-up)</option>\n      <option value=\"fib\">Fibonacci (top-down memoized)</option>\n    </select>\n\n    <label for=\"mode\">Mode:</label>\n    <select id=\"mode\">\n      <option value=\"bottom-up\">bottom-up</option>\n      <option value=\"top-down\">top-down (where available)</option>\n    </select>\n\n    <label for=\"manualChoice\">Manual choices:</label>\n    <input type=\"checkbox\" id=\"manualChoice\" checked>\n\n    <label for=\"showRec\">Show recursion tree:</label>\n    <input type=\"checkbox\" id=\"showRec\">\n\n    <label for=\"autoBack\">Auto backtrack after fill:</label>\n    <input type=\"checkbox\" id=\"autoBack\">\n  </div>\n\n  <div id=\"inputArea\">\n    <!-- dynamic inputs per algorithm -->\n  </div>\n\n  <div style=\"margin-top:6px;\">\n    <button id=\"initBtn\">Initialize</button>\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"runBtn\">Run</button>\n    <button id=\"pauseBtn\" disabled>Pause</button>\n    <button id=\"resetBtn\">Reset</button>\n    <button id=\"randomBtn\">Randomize</button>\n    <label>Speed(ms):</label>\n    <input type=\"range\" id=\"speed\" min=\"50\" max=\"2000\" value=\"400\">\n    <span id=\"speedVal\">400</span>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <button id=\"saveBtn\">Export State</button>\n    <button id=\"loadBtn\">Load State</button>\n    <button id=\"exportJSON\">Export Snapshot JSON</button>\n  </div>\n\n</section>\n\n<section>\n  <div>\n    <strong>Problem / Input</strong>\n    <div id=\"problemDisplay\" class=\"code\"></div>\n  </div>\n</section>\n\n<section>\n  <div style=\"display:flex; gap:12px; align-items:flex-start;\">\n    <div style=\"flex:1;\">\n      <strong>DP Table / Memo</strong>\n      <div id=\"tablePane\" class=\"table-wrap\"></div>\n    </div>\n\n    <div style=\"width:320px;\">\n      <div><strong>Recursion Stack</strong></div>\n      <div id=\"stackPane\" class=\"stack\"></div>\n\n      <div style=\"margin-top:8px;\"><strong>Memoization Map / Aux</strong></div>\n      <div id=\"memoPane\" class=\"table-wrap\" style=\"max-height:150px;\"></div>\n\n      <div style=\"margin-top:8px;\"><strong>Backtracking Controls</strong></div>\n      <div>\n        <button id=\"startBackBtn\">Start Backtracking</button>\n        <button id=\"backStepBtn\">Backtrack Step</button>\n        <button id=\"endBackBtn\">End Backtracking</button>\n        <div id=\"backInfo\" class=\"notice\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Operation / Explanation</strong>\n    <div id=\"opInfo\" class=\"code\"></div>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <strong>Candidates (when a choice is possible)</strong>\n    <div id=\"candidates\"></div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Logs (click to jump to snapshot)</strong>\n    <div id=\"logPane\" class=\"log\"></div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Complexity / Analysis</strong>\n    <div id=\"analysis\" class=\"code\"></div>\n  </div>\n</section>\n\n<section>\n  <div>\n    <strong>Save/Load Text</strong>\n    <textarea id=\"saveLoadArea\" placeholder=\"Saved JSON will appear here or paste JSON to load\"></textarea>\n  </div>\n</section>\n\n<script>\n(function(){\n  // Minimal styling used, heavy interactivity below.\n  // State and utilities\n  const state = {\n    algorithm: 'knapsack',\n    mode: 'bottom-up',\n    manualChoice: true,\n    showRecursion: false,\n    autoBack: true,\n    input: {},\n    dp: null,\n    dpMeta: null, // metadata for visualization depending on algo\n    memo: {},\n    stack: [],\n    operations: [], // queue for bottom-up or list to step through\n    opIndex: 0,\n    running: false,\n    runInterval: null,\n    speed: 400,\n    history: [], // snapshots\n    historyIndex: -1,\n    logs: [],\n    backtrack: {active:false, path:[], pos:null}\n  };\n\n  // DOM\n  const algoEl = document.getElementById('algo');\n  const modeEl = document.getElementById('mode');\n  const manualChoiceEl = document.getElementById('manualChoice');\n  const showRecEl = document.getElementById('showRec');\n  const autoBackEl = document.getElementById('autoBack');\n  const inputArea = document.getElementById('inputArea');\n  const initBtn = document.getElementById('initBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const runBtn = document.getElementById('runBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const randomBtn = document.getElementById('randomBtn');\n  const speedEl = document.getElementById('speed');\n  const speedVal = document.getElementById('speedVal');\n  const tablePane = document.getElementById('tablePane');\n  const memoPane = document.getElementById('memoPane');\n  const stackPane = document.getElementById('stackPane');\n  const opInfo = document.getElementById('opInfo');\n  const candidatesPane = document.getElementById('candidates');\n  const logPane = document.getElementById('logPane');\n  const problemDisplay = document.getElementById('problemDisplay');\n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n  const saveBtn = document.getElementById('saveBtn');\n  const loadBtn = document.getElementById('loadBtn');\n  const saveLoadArea = document.getElementById('saveLoadArea');\n  const exportJSON = document.getElementById('exportJSON');\n  const backStartBtn = document.getElementById('startBackBtn');\n  const backStepBtn = document.getElementById('backStepBtn');\n  const backEndBtn = document.getElementById('endBackBtn');\n  const backInfo = document.getElementById('backInfo');\n  const analysis = document.getElementById('analysis');\n\n  // Dynamic input elements\n  function renderInputArea() {\n    const algo = algoEl.value;\n    inputArea.innerHTML = '';\n    let html = '';\n    if (algo === 'knapsack') {\n      html = `\n        <div>\n          <label>Weights (comma separated):</label>\n          <input id=\"weights\" type=\"text\" value=\"2,3,4,5\">\n          <label>Values (comma separated):</label>\n          <input id=\"values\" type=\"text\" value=\"3,4,5,6\">\n          <label>Capacity:</label>\n          <input id=\"capacity\" type=\"number\" value=\"8\" class=\"small-input\">\n        </div>\n      `;\n    } else if (algo === 'edit') {\n      html = `\n        <div>\n          <label>String A:</label>\n          <input id=\"s1\" type=\"text\" value=\"kitten\">\n          <label>String B:</label>\n          <input id=\"s2\" type=\"text\" value=\"sitting\">\n        </div>\n      `;\n    } else if (algo === 'lis') {\n      html = `\n        <div>\n          <label>Sequence (comma separated):</label>\n          <input id=\"seq\" type=\"text\" value=\"3,10,2,1,20\">\n        </div>\n      `;\n    } else if (algo === 'coin') {\n      html = `\n        <div>\n          <label>Coins (comma separated):</label>\n          <input id=\"coins\" type=\"text\" value=\"1,3,4\">\n          <label>Target:</label>\n          <input id=\"target\" type=\"number\" value=\"6\" class=\"small-input\">\n        </div>\n      `;\n    } else if (algo === 'fib') {\n      html = `\n        <div>\n          <label>n (integer):</label>\n          <input id=\"nval\" type=\"number\" value=\"10\" class=\"small-input\">\n        </div>\n      `;\n    }\n    inputArea.innerHTML = html;\n    // Adjust mode availability (some algorithms only bottom-up or top-down)\n    if (algo === 'fib') {\n      modeEl.value = 'top-down';\n      modeEl.querySelector('option[value=\"bottom-up\"]') && (modeEl.querySelector('option[value=\"bottom-up\"]').disabled = true);\n      modeEl.querySelector('option[value=\"top-down\"]').disabled = false;\n    } else {\n      modeEl.querySelector('option[value=\"bottom-up\"]') && (modeEl.querySelector('option[value=\"bottom-up\"]').disabled = false);\n      modeEl.querySelector('option[value=\"top-down\"]') && (modeEl.querySelector('option[value=\"top-down\"]').disabled = false);\n    }\n    updateAnalysis();\n  }\n\n  function updateAnalysis() {\n    const algo = algoEl.value;\n    let text = '';\n    if (algo === 'knapsack') {\n      const weights = (document.getElementById('weights') && document.getElementById('weights').value) || '';\n      const vals = (document.getElementById('values') && document.getElementById('values').value) || '';\n      const cap = (document.getElementById('capacity') && +document.getElementById('capacity').value) || 0;\n      const n = weights ? weights.split(',').filter(s=>s.trim()!=='').length : '?';\n      text = `0/1 Knapsack - bottom-up DP with table size (n+1) x (W+1). Typical time O(n * W), space O(n * W).\\nn = ${n}, W = ${cap}\\nEstimated operations: ~${n} * ${cap}`;\n    } else if (algo === 'edit') {\n      const s1 = document.getElementById('s1') && document.getElementById('s1').value || '';\n      const s2 = document.getElementById('s2') && document.getElementById('s2').value || '';\n      const m = s1.length, n = s2.length;\n      text = `Edit Distance - bottom-up DP filling (m+1) x (n+1) table. Time O(m * n), space O(m * n).\\nm = ${m}, n = ${n}\\nEstimated operations: ~${m * n}`;\n    } else if (algo === 'lis') {\n      const seq = document.getElementById('seq') && document.getElementById('seq').value || '';\n      const n = seq ? seq.split(',').filter(s=>s.trim()!=='').length : '?';\n      text = `Longest Increasing Subsequence (O(n^2) DP) - dp[i] = 1 + max(dp[j]) over j<i. Time O(n^2), space O(n).\\nn = ${n}\\nEstimated operations: ~n^2`;\n    } else if (algo === 'coin') {\n      const coins = document.getElementById('coins') && document.getElementById('coins').value || '';\n      const target = document.getElementById('target') && +document.getElementById('target').value || '?';\n      text = `Coin Change (min coins) - bottom-up dp over amounts 0..target. Time O(target * numCoins), space O(target).\\nTarget = ${target}, coins = ${coins}\\nEstimated operations: ~${target} * numCoins`;\n    } else if (algo === 'fib') {\n      const n = document.getElementById('nval') && +document.getElementById('nval').value || '?';\n      text = `Fibonacci - top-down memoized. Without memo would be exponential, with memo O(n) time and O(n) space.\\nn = ${n}\\nEstimated operations: ~n (with memo)`;\n    }\n    analysis.textContent = text;\n  }\n\n  algoEl.addEventListener('change', ()=>{ renderInputArea(); saveSnapshot('algorithm change'); });\n  modeEl.addEventListener('change', ()=>{ state.mode = modeEl.value; saveSnapshot('mode change'); });\n  manualChoiceEl.addEventListener('change', ()=>{ state.manualChoice = manualChoiceEl.checked; saveSnapshot('manualChoice change'); });\n  showRecEl.addEventListener('change', ()=>{ state.showRecursion = showRecEl.checked; renderStack(); });\n  autoBackEl.addEventListener('change', ()=>{ state.autoBack = autoBackEl.checked; saveSnapshot('autoBack change'); });\n  speedEl.addEventListener('input', ()=>{ state.speed = +speedEl.value; speedVal.textContent = speedEl.value; });\n  inputArea.addEventListener('input', updateAnalysis);\n  // Initialize defaults\n  renderInputArea();\n\n  // Utility: deep copy state for snapshots\n  function clone(obj) {\n    return JSON.parse(JSON.stringify(obj));\n  }\n\n  function pushOp(op) {\n    state.operations.push(op);\n  }\n\n  // Snapshotting and history\n  function snapshot(label) {\n    const s = {\n      label: label || ('step ' + state.opIndex),\n      state: {\n        algorithm: state.algorithm,\n        mode: state.mode,\n        input: clone(state.input),\n        dp: clone(state.dp),\n        dpMeta: clone(state.dpMeta),\n        memo: clone(state.memo),\n        stack: clone(state.stack),\n        operations: clone(state.operations),\n        opIndex: state.opIndex,\n        backtrack: clone(state.backtrack)\n      }\n    };\n    return s;\n  }\n\n  function saveSnapshot(reason) {\n    // Trim redo history\n    if (state.historyIndex < state.history.length - 1) {\n      state.history = state.history.slice(0, state.historyIndex + 1);\n    }\n    const s = snapshot(reason);\n    state.history.push(s);\n    state.historyIndex = state.history.length - 1;\n    addLog(reason || 'snapshot');\n    renderLogs();\n  }\n\n  function restoreSnapshot(index) {\n    if (index < 0 || index >= state.history.length) return;\n    const s = state.history[index].state;\n    state.algorithm = s.algorithm;\n    state.mode = s.mode;\n    state.input = clone(s.input);\n    state.dp = clone(s.dp);\n    state.dpMeta = clone(s.dpMeta);\n    state.memo = clone(s.memo);\n    state.stack = clone(s.stack);\n    state.operations = clone(s.operations);\n    state.opIndex = s.opIndex;\n    state.backtrack = clone(s.backtrack);\n    state.historyIndex = index;\n    renderAll();\n  }\n\n  function addLog(msg) {\n    const idx = state.historyIndex;\n    const stamp = new Date().toLocaleTimeString();\n    const label = `${stamp} - ${msg} (snapshot ${idx})`;\n    state.logs.push({msg: label, idx});\n    if (state.logs.length > 500) state.logs.shift();\n  }\n\n  function renderLogs() {\n    logPane.innerHTML = '';\n    state.logs.slice().reverse().forEach(l => {\n      const btn = document.createElement('div');\n      btn.textContent = l.msg;\n      btn.style.cursor = 'pointer';\n      btn.addEventListener('click', ()=>{ restoreSnapshot(l.idx); });\n      logPane.appendChild(btn);\n    });\n  }\n\n  // Renderers\n  function renderProblemDisplay() {\n    const algo = state.algorithm;\n    let txt = '';\n    if (algo === 'knapsack') {\n      txt = `Knapsack\\nWeights: ${state.input.weights}\\nValues: ${state.input.values}\\nCapacity: ${state.input.capacity}`;\n    } else if (algo === 'edit') {\n      txt = `Edit Distance\\nA: \"${state.input.s1}\"\\nB: \"${state.input.s2}\"`;\n    } else if (algo === 'lis') {\n      txt = `LIS\\nSequence: [${state.input.seq}]`;\n    } else if (algo === 'coin') {\n      txt = `Coin Change\\nCoins: [${state.input.coins}]\\nTarget: ${state.input.target}`;\n    } else if (algo === 'fib') {\n      txt = `Fibonacci\\nn = ${state.input.n}`;\n    }\n    problemDisplay.textContent = txt;\n  }\n\n  function renderTable() {\n    tablePane.innerHTML = '';\n    if (!state.dp) return;\n    const algo = state.algorithm;\n    if (algo === 'knapsack' || algo === 'edit') {\n      // 2D table\n      const rows = state.dp.length, cols = state.dp[0].length;\n      const table = document.createElement('table');\n      table.border = 1;\n      table.cellPadding = 6;\n      for (let i=0;i<rows;i++) {\n        const tr = document.createElement('tr');\n        for (let j=0;j<cols;j++) {\n          const td = document.createElement('td');\n          td.textContent = state.dp[i][j] === null ? '' : state.dp[i][j];\n          td.style.cursor = 'pointer';\n          td.addEventListener('click', ()=>{ editCell(i,j); });\n          // highlight current op target\n          const currentOp = state.operations[state.opIndex];\n          if (currentOp && currentOp.type === 'computeCell' && currentOp.i === i && currentOp.j === j) {\n            td.style.fontWeight = 'bold';\n          }\n          tr.appendChild(td);\n        }\n        table.appendChild(tr);\n      }\n      tablePane.appendChild(table);\n    } else if (algo === 'lis' || algo === 'coin') {\n      // 1D dp shown as table of cells\n      const table = document.createElement('table');\n      table.border = 1;\n      table.cellPadding = 6;\n      const tr = document.createElement('tr');\n      if (algo === 'coin') {\n        for (let a=0;a<state.dp.length;a++) {\n          const td = document.createElement('td');\n          td.textContent = state.dp[a] === null ? '∞' : state.dp[a];\n          td.style.cursor = 'pointer';\n          td.addEventListener('click', ()=>{ editCell(a, null); });\n          const currentOp = state.operations[state.opIndex];\n          if (currentOp && currentOp.type === 'computeCell' && currentOp.i === a) td.style.fontWeight='bold';\n          tr.appendChild(td);\n        }\n      } else { // lis\n        for (let i=0;i<state.dp.length;i++) {\n          const td = document.createElement('td');\n          td.textContent = state.dp[i] === null ? '' : state.dp[i];\n          td.style.cursor = 'pointer';\n          td.addEventListener('click', ()=>{ editCell(i, null); });\n          const currentOp = state.operations[state.opIndex];\n          if (currentOp && currentOp.type === 'computeCell' && currentOp.i === i) td.style.fontWeight='bold';\n          tr.appendChild(td);\n        }\n      }\n      table.appendChild(tr);\n      tablePane.appendChild(table);\n      // For lis show original sequence below\n      const meta = document.createElement('div');\n      meta.textContent = 'Sequence: [' + state.dpMeta.seq.join(', ') + ']';\n      tablePane.appendChild(meta);\n    } else if (algo === 'fib') {\n      // show memo map only\n      const pre = document.createElement('pre');\n      pre.textContent = JSON.stringify(state.memo, null, 2);\n      tablePane.appendChild(pre);\n    }\n  }\n\n  function renderMemo() {\n    memoPane.innerHTML = '';\n    if (!state.memo || Object.keys(state.memo).length === 0) {\n      memoPane.textContent = '(empty)';\n    } else {\n      const pre = document.createElement('pre');\n      pre.textContent = JSON.stringify(state.memo, null, 2);\n      memoPane.appendChild(pre);\n    }\n  }\n\n  function renderStack() {\n    stackPane.innerHTML = '';\n    if (state.showRecursion && state.stack && state.stack.length>0) {\n      state.stack.slice().reverse().forEach((frame, idx) => {\n        const div = document.createElement('div');\n        div.textContent = JSON.stringify(frame);\n        stackPane.appendChild(div);\n      });\n    } else {\n      stackPane.textContent = '(not shown)';\n    }\n  }\n\n  function renderOpInfo(op) {\n    if (!op) { opInfo.textContent = '(no current operation)'; return; }\n    let s = 'Operation: ' + op.type + '\\n';\n    if (op.type === 'computeCell') {\n      s += `Computing cell: ${opLabel(op)}\\n`;\n      if (op.candidates) {\n        s += `Candidates:\\n` + op.candidates.map(c=>` - ${c.label}: ${c.value}`).join('\\n');\n      }\n    } else if (op.type === 'call') {\n      s += `Function call: ${op.func}(${op.args.join(',')})\\n`;\n      s += `Stack depth: ${state.stack.length}\\n`;\n    } else if (op.type === 'memoHit') {\n      s += `Memo hit for key ${op.key}: value=${op.value}\\n`;\n    } else if (op.type === 'memoStore') {\n      s += `Memo store ${op.key} = ${op.value}\\n`;\n    }\n    opInfo.textContent = s;\n  }\n\n  function opLabel(op) {\n    const algo = state.algorithm;\n    if (algo === 'knapsack' || algo === 'edit') return `(${op.i}, ${op.j})`;\n    if (algo === 'lis') return `(${op.i})`;\n    if (algo === 'coin') return `(amount ${op.i})`;\n    return JSON.stringify(op);\n  }\n\n  // Edit cell manually\n  function editCell(i, j) {\n    const algo = state.algorithm;\n    const promptVal = prompt('Enter new value (use blank for null/∞):', (j===null ? state.dp[i] : state.dp[i][j]));\n    if (promptVal === null) return;\n    let val = promptVal.trim();\n    if (val === '') {\n      if (j===null) state.dp[i] = null; else state.dp[i][j] = null;\n    } else {\n      const num = Number(val);\n      if (!isNaN(num)) {\n        if (j===null) state.dp[i] = num; else state.dp[i][j] = num;\n      } else {\n        // keep as string\n        if (j===null) state.dp[i] = val; else state.dp[i][j] = val;\n      }\n    }\n    saveSnapshot('manual edit cell');\n    renderAll();\n  }\n\n  // Core: initialize operations based on algorithm and inputs\n  function initEngine() {\n    state.algorithm = algoEl.value;\n    state.mode = modeEl.value;\n    state.manualChoice = manualChoiceEl.checked;\n    state.showRecursion = showRecEl.checked;\n    state.autoBack = autoBackEl.checked;\n\n    // parse inputs per algorithm\n    if (state.algorithm === 'knapsack') {\n      const wRaw = document.getElementById('weights').value;\n      const vRaw = document.getElementById('values').value;\n      const cap = +document.getElementById('capacity').value;\n      const weights = wRaw.split(',').map(s=>+s.trim()).filter(n=>!isNaN(n));\n      const values = vRaw.split(',').map(s=>+s.trim()).filter(n=>!isNaN(n));\n      state.input = {weights, values, capacity: cap};\n      // dp (n+1) x (W+1) initialized 0\n      const n = weights.length;\n      state.dp = Array.from({length:n+1}, ()=>Array.from({length:cap+1}, ()=>0));\n      state.dpMeta = {n, W: cap};\n      state.memo = {};\n      state.stack = [];\n      state.operations = [];\n      // bottom-up operations: compute cells for i=1..n, w=0..W\n      for (let i=1;i<=n;i++) {\n        for (let w=0;w<=cap;w++) {\n          state.operations.push({type:'computeCell', i:i, j:w});\n        }\n      }\n    } else if (state.algorithm === 'edit') {\n      const s1 = document.getElementById('s1').value || '';\n      const s2 = document.getElementById('s2').value || '';\n      state.input = {s1, s2};\n      const m = s1.length, n = s2.length;\n      state.dp = Array.from({length:m+1}, ()=>Array.from({length:n+1}, ()=>null));\n      // base cases will be set by operations: dp[i][0] = i and dp[0][j] = j\n      state.dpMeta = {m, n};\n      state.memo = {};\n      state.stack = [];\n      state.operations = [];\n      // push base row and col first\n      for (let i=0;i<=m;i++) state.operations.push({type:'computeCell', i:i, j:0});\n      for (let j=1;j<=n;j++) state.operations.push({type:'computeCell', i:0, j:j});\n      for (let i=1;i<=m;i++) {\n        for (let j=1;j<=n;j++) state.operations.push({type:'computeCell', i:i, j:j});\n      }\n    } else if (state.algorithm === 'lis') {\n      const seq = (document.getElementById('seq').value || '').split(',').map(s=>+s.trim()).filter(n=>!isNaN(n));\n      state.input = {seq};\n      state.dp = Array.from({length:seq.length}, ()=>null);\n      state.dpMeta = {seq};\n      state.memo = {};\n      state.stack = [];\n      state.operations = [];\n      // dp[0]..dp[n-1]\n      for (let i=0;i<seq.length;i++) {\n        state.operations.push({type:'computeCell', i:i});\n      }\n    } else if (state.algorithm === 'coin') {\n      const coins = (document.getElementById('coins').value || '').split(',').map(s=>+s.trim()).filter(n=>!isNaN(n));\n      const target = +document.getElementById('target').value;\n      state.input = {coins, target};\n      state.dp = Array.from({length: target+1}, ()=>null);\n      state.dp[0] = 0;\n      state.dpMeta = {coins, target};\n      state.memo = {};\n      state.stack = [];\n      state.operations = [];\n      for (let a=1;a<=target;a++) state.operations.push({type:'computeCell', i:a});\n    } else if (state.algorithm === 'fib') {\n      const n = +document.getElementById('nval').value;\n      state.input = {n};\n      state.memo = {};\n      state.stack = [];\n      state.operations = [];\n      state.dp = null;\n      state.dpMeta = {};\n      // top-down: initial call\n      state.operations.push({type:'call', func:'fib', args:[n], id:uniqueId()});\n    }\n\n    state.opIndex = 0;\n    state.running = false;\n    clearInterval(state.runInterval);\n    pauseBtn.disabled = true;\n    runBtn.disabled = false;\n    // push initial snapshot\n    saveSnapshot('initialize');\n    renderAll();\n  }\n\n  // Step processing\n  function step() {\n    if (state.opIndex >= state.operations.length) {\n      // finished\n      state.running = false;\n      clearInterval(state.runInterval);\n      pauseBtn.disabled = true;\n      runBtn.disabled = false;\n      renderOpInfo(null);\n      if (state.autoBack) {\n        startBacktrackingIfApplicable();\n      }\n      return;\n    }\n    const op = state.operations[state.opIndex];\n    // Handle op types\n    if (op.type === 'computeCell') {\n      handleComputeCell(op);\n    } else if (op.type === 'call') {\n      handleCall(op);\n    } else if (op.type === 'memoHit' || op.type === 'memoStore') {\n      // immediate effect\n      handleSimpleOp(op);\n    } else {\n      // unknown\n    }\n    // After processing, advance unless paused by manualChoice\n    renderAll();\n  }\n\n  function handleSimpleOp(op) {\n    if (op.type === 'memoStore') {\n      state.memo[op.key] = op.value;\n      addLog(`memo store ${op.key}=${op.value}`);\n    } else if (op.type === 'memoHit') {\n      // nothing to do\n    }\n    state.opIndex++;\n    saveSnapshot(op.type);\n  }\n\n  function handleCall(op) {\n    // top-down fibonacci supported\n    if (state.algorithm === 'fib') {\n      const n = op.args[0];\n      // if memo\n      if (n in state.memo) {\n        // memo hit\n        addLog(`memo hit fib(${n})=${state.memo[n]}`);\n        state.operations.splice(state.opIndex, 1, {type:'memoHit', key:n, value:state.memo[n]});\n        // next step will process memoHit\n        return;\n      }\n      // push frame to stack\n      state.stack.push({func:'fib', n, status:'entered'});\n      renderStack();\n      if (n <= 1) {\n        // return directly; store memo and produce memoStore op\n        state.operations.splice(state.opIndex, 1, {type:'memoStore', key:n, value:n});\n        return;\n      } else {\n        // replace current call by a sequence: call(n-1), call(n-2), store result (we will compute after children)\n        const storeId = uniqueId();\n        const newOps = [\n          {type:'call', func:'fib', args:[n-1], id:storeId},\n          {type:'call', func:'fib', args:[n-2], id:storeId},\n          {type:'computeFibStore', n:n, id:storeId} // will sum children and store in memo\n        ];\n        state.operations.splice(state.opIndex, 1, ...newOps);\n        return;\n      }\n    } else {\n      // unsupported call, skip\n      state.opIndex++;\n    }\n  }\n\n  function handleComputeCell(op) {\n    const algo = state.algorithm;\n    if (algo === 'knapsack') {\n      const i = op.i, w = op.j;\n      const weights = state.input.weights, values = state.input.values, cap = state.input.capacity;\n      // compute candidates from current dp\n      const exclude = state.dp[i-1][w];\n      const candidates = [{label:'exclude', value:exclude, meta:{from:'i-1,w'}}];\n      if (weights[i-1] <= w) {\n        const include = state.dp[i-1][w-weights[i-1]] + values[i-1];\n        candidates.push({label:`include item ${i-1}`, value: include, meta:{from:'i-1,w-wi'}})\n      }\n      op.candidates = candidates;\n      // if manualChoice: present choices and wait for user to pick\n      if (state.manualChoice) {\n        renderCandidates(op);\n        renderOpInfo(op);\n        // do not advance opIndex until user chooses\n        return;\n      } else {\n        // auto choose max\n        let best = candidates[0];\n        candidates.forEach(c=>{ if (c.value > best.value) best = c; });\n        state.dp[i][w] = best.value;\n        addLog(`computed dp[${i}][${w}] = ${best.value}`);\n        state.opIndex++;\n        saveSnapshot('computeCell auto');\n        return;\n      }\n    } else if (algo === 'edit') {\n      const i = op.i, j = op.j;\n      const s1 = state.input.s1, s2 = state.input.s2;\n      if (i === 0) {\n        state.dp[0][j] = j;\n        state.opIndex++;\n        saveSnapshot('base row');\n        return;\n      }\n      if (j === 0) {\n        state.dp[i][0] = i;\n        state.opIndex++;\n        saveSnapshot('base col');\n        return;\n      }\n      // candidates: if s1[i-1] === s2[j-1] -> dp[i-1][j-1], else min(replace, insert, delete)+1\n      const candidates = [];\n      if (s1[i-1] === s2[j-1]) {\n        candidates.push({label:'match', value: state.dp[i-1][j-1], meta:{type:'match'}});\n      } else {\n        // ensure neighbors exist (they should by ordering)\n        const replace = state.dp[i-1][j-1] + 1;\n        const insert = state.dp[i][j-1] + 1;\n        const remove = state.dp[i-1][j] + 1;\n        candidates.push({label:'replace', value: replace});\n        candidates.push({label:'insert', value: insert});\n        candidates.push({label:'delete', value: remove});\n      }\n      op.candidates = candidates;\n      if (state.manualChoice) {\n        renderCandidates(op);\n        renderOpInfo(op);\n        return;\n      } else {\n        // auto choose min\n        let best = candidates[0];\n        candidates.forEach(c=>{ if (c.value < best.value) best = c; });\n        state.dp[i][j] = best.value;\n        addLog(`dp[${i}][${j}] = ${best.value}`);\n        state.opIndex++;\n        saveSnapshot('compute edit auto');\n        return;\n      }\n    } else if (algo === 'lis') {\n      const i = op.i;\n      const seq = state.dpMeta.seq;\n      if (i === 0) {\n        state.dp[0] = 1;\n        state.opIndex++;\n        saveSnapshot('lis base');\n        return;\n      }\n      const candidates = [];\n      // default candidate: 1\n      let bestVal = 1;\n      candidates.push({label:'start', value:1});\n      for (let j=0;j<i;j++) {\n        if (seq[j] < seq[i]) {\n          const val = (state.dp[j] || 0) + 1;\n          candidates.push({label:`extend from ${j}`, value: val, meta:{from:j}});\n        }\n      }\n      op.candidates = candidates;\n      if (state.manualChoice) {\n        renderCandidates(op);\n        renderOpInfo(op);\n        return;\n      } else {\n        let best = candidates[0];\n        candidates.forEach(c=>{ if (c.value > best.value) best = c; });\n        state.dp[i] = best.value;\n        addLog(`dp[${i}] = ${best.value}`);\n        state.opIndex++;\n        saveSnapshot('lis auto');\n        return;\n      }\n    } else if (algo === 'coin') {\n      const a = op.i;\n      const coins = state.input.coins;\n      const candidates = [];\n      coins.forEach(c => {\n        if (a - c >= 0 && state.dp[a-c] != null) {\n          candidates.push({label:`use coin ${c}`, value: state.dp[a-c] + 1});\n        }\n      });\n      if (candidates.length === 0) {\n        state.dp[a] = null; // unreachable\n        state.opIndex++;\n        saveSnapshot('coin no candidates');\n        return;\n      }\n      op.candidates = candidates;\n      if (state.manualChoice) {\n        renderCandidates(op);\n        renderOpInfo(op);\n        return;\n      } else {\n        // auto choose min\n        let best = candidates[0];\n        candidates.forEach(c=>{ if (c.value < best.value) best = c; });\n        state.dp[a] = best.value;\n        addLog(`dp[${a}] = ${best.value}`);\n        state.opIndex++;\n        saveSnapshot('coin auto');\n        return;\n      }\n    } else {\n      state.opIndex++;\n    }\n  }\n\n  function renderCandidates(op) {\n    candidatesPane.innerHTML = '';\n    const algo = state.algorithm;\n    if (!op || !op.candidates) return;\n    op.candidates.forEach((c, idx) => {\n      const btn = document.createElement('button');\n      btn.textContent = `${c.label} => ${c.value}`;\n      btn.className = 'candidate-btn';\n      btn.addEventListener('click', ()=>{\n        applyCandidate(op, idx);\n      });\n      candidatesPane.appendChild(btn);\n    });\n    // also allow auto-select best\n    const autoBtn = document.createElement('button');\n    autoBtn.textContent = 'Auto-select best';\n    autoBtn.addEventListener('click', ()=>{ autoSelect(op); });\n    candidatesPane.appendChild(autoBtn);\n  }\n\n  function autoSelect(op) {\n    const algo = state.algorithm;\n    let bestIdx = 0;\n    if (algo === 'knapsack' || algo === 'lis') {\n      // maximize\n      for (let i=1;i<op.candidates.length;i++){\n        if (op.candidates[i].value > op.candidates[bestIdx].value) bestIdx = i;\n      }\n    } else {\n      // minimize (edit, coin)\n      for (let i=1;i<op.candidates.length;i++){\n        if (op.candidates[i].value < op.candidates[bestIdx].value) bestIdx = i;\n      }\n    }\n    applyCandidate(op, bestIdx);\n  }\n\n  function applyCandidate(op, idx) {\n    const c = op.candidates[idx];\n    const algo = state.algorithm;\n    if (algo === 'knapsack') {\n      state.dp[op.i][op.j] = c.value;\n    } else if (algo === 'edit') {\n      state.dp[op.i][op.j] = c.value;\n    } else if (algo === 'lis') {\n      state.dp[op.i] = c.value;\n    } else if (algo === 'coin') {\n      state.dp[op.i] = c.value;\n    }\n    addLog(`choice applied at ${opLabel(op)} => ${c.label} (${c.value})`);\n    state.opIndex++;\n    saveSnapshot('user choice');\n    candidatesPane.innerHTML = '';\n    // after applying, if the table is fully filled and autoBack enabled, start backtracking\n    if (state.opIndex >= state.operations.length) {\n      if (state.autoBack) startBacktrackingIfApplicable();\n    }\n    renderAll();\n  }\n\n  // Top-down fib compute store op handler\n  function handleComputeFibStore(op) {\n    const n = op.n;\n    // find the two memo values from previous calls (should be stored by memoStore)\n    const a = state.memo[n-1];\n    const b = state.memo[n-2];\n    if (typeof a === 'undefined' || typeof b === 'undefined') {\n      // not ready? This situation shouldn't happen with our op sequencing, but we'll handle by re-queueing\n      state.operations.push({type:'call', func:'fib', args:[n-1], id:op.id});\n      state.operations.push({type:'call', func:'fib', args:[n-2], id:op.id});\n      return;\n    }\n    const val = a + b;\n    // store in memo\n    state.memo[n] = val;\n    addLog(`fib(${n}) computed = ${val}`);\n    // remove the corresponding frames from stack if present\n    state.stack = state.stack.filter(f => !(f.func==='fib' && f.n===n && f.status==='entered'));\n    state.opIndex++;\n    saveSnapshot('fib store');\n  }\n\n  // Since computeFibStore is a custom type, integrate into step dispatcher\n  function dispatchStep() {\n    if (state.opIndex >= state.operations.length) {\n      // finished\n      state.running = false;\n      clearInterval(state.runInterval);\n      pauseBtn.disabled = true;\n      runBtn.disabled = false;\n      renderOpInfo(null);\n      if (state.autoBack) startBacktrackingIfApplicable();\n      return;\n    }\n    const op = state.operations[state.opIndex];\n    if (!op) return;\n    if (op.type === 'computeCell') {\n      handleComputeCell(op);\n    } else if (op.type === 'call') {\n      handleCall(op);\n    } else if (op.type === 'memoStore' || op.type === 'memoHit') {\n      handleSimpleOp(op);\n    } else if (op.type === 'computeFibStore') {\n      handleComputeFibStore(op);\n    } else {\n      // unknown\n      state.opIndex++;\n    }\n    renderAll();\n  }\n\n  // Exposed step function connected to button\n  stepBtn.addEventListener('click', ()=>{ dispatchStep(); });\n\n  // Run / Pause\n  runBtn.addEventListener('click', ()=>{ \n    state.running = true;\n    runBtn.disabled = true;\n    pauseBtn.disabled = false;\n    state.runInterval = setInterval(()=> {\n      if (!state.running) return;\n      dispatchStep();\n      if (state.opIndex >= state.operations.length) { clearInterval(state.runInterval); state.running=false; runBtn.disabled=false; pauseBtn.disabled=true; }\n    }, state.speed);\n  });\n\n  pauseBtn.addEventListener('click', ()=>{ \n    state.running = false;\n    clearInterval(state.runInterval);\n    runBtn.disabled = false;\n    pauseBtn.disabled = true;\n  });\n\n  // Initialize button\n  initBtn.addEventListener('click', ()=>{ initEngine(); });\n\n  // Reset\n  resetBtn.addEventListener('click', ()=>{ \n    // clear everything\n    state.dp = null;\n    state.operations = [];\n    state.opIndex = 0;\n    state.memo = {};\n    state.stack = [];\n    state.running = false;\n    clearInterval(state.runInterval);\n    saveSnapshot('reset');\n    renderAll();\n  });\n\n  // Randomize\n  randomBtn.addEventListener('click', ()=>{ randomizeInput(); });\n\n  function randomizeInput() {\n    const algo = algoEl.value;\n    if (algo === 'knapsack') {\n      const n = Math.floor(Math.random()*6)+3;\n      const weights = Array.from({length:n}, ()=>Math.floor(Math.random()*8)+1);\n      const values = Array.from({length:n}, ()=>Math.floor(Math.random()*10)+1);\n      const cap = Math.max(5, Math.floor(weights.reduce((a,b)=>a+b,0)/2));\n      document.getElementById('weights').value = weights.join(',');\n      document.getElementById('values').value = values.join(',');\n      document.getElementById('capacity').value = cap;\n    } else if (algo === 'edit') {\n      const presets = [['kitten','sitting'], ['intention','execution'], ['horse','ros']];\n      const p = presets[Math.floor(Math.random()*presets.length)];\n      document.getElementById('s1').value = p[0];\n      document.getElementById('s2').value = p[1];\n    } else if (algo === 'lis') {\n      const n = Math.floor(Math.random()*8)+5;\n      const seq = Array.from({length:n}, ()=>Math.floor(Math.random()*20));\n      document.getElementById('seq').value = seq.join(',');\n    } else if (algo === 'coin') {\n      const coins = [1,3,4];\n      document.getElementById('coins').value = coins.join(',');\n      document.getElementById('target').value = Math.floor(Math.random()*10)+5;\n    } else if (algo === 'fib') {\n      document.getElementById('nval').value = Math.floor(Math.random()*16)+2;\n    }\n    updateAnalysis();\n    saveSnapshot('randomize input');\n  }\n\n  // Undo / Redo\n  undoBtn.addEventListener('click', ()=>{ if (state.historyIndex > 0) restoreSnapshot(state.historyIndex-1); });\n  redoBtn.addEventListener('click', ()=>{ if (state.historyIndex < state.history.length - 1) restoreSnapshot(state.historyIndex+1); });\n\n  // Save / Load\n  saveBtn.addEventListener('click', ()=>{ \n    const s = state.history[state.historyIndex];\n    if (!s) { alert('No snapshot to export'); return; }\n    saveLoadArea.value = JSON.stringify(s);\n  });\n\n  loadBtn.addEventListener('click', ()=>{ \n    try {\n      const s = JSON.parse(saveLoadArea.value);\n      if (s && s.state) {\n        // push loaded as new snapshot\n        state.history.push(s);\n        state.historyIndex = state.history.length - 1;\n        restoreSnapshot(state.historyIndex);\n        addLog('loaded snapshot from text');\n        renderLogs();\n      } else {\n        alert('Invalid format (expected snapshot object with state)'). \n        toString();\n      }\n    } catch (e) {\n      alert('Failed to parse JSON: ' + e.message);\n    }\n  });\n\n  exportJSON.addEventListener('click', ()=> {\n    const s = state.history[state.historyIndex];\n    if (!s) { alert('No snapshot'); return; }\n    const data = JSON.stringify(s.state);\n    const blob = new Blob([data], {type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a');\n    a.href = url; a.download = 'dp_snapshot.json'; document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n  });\n\n  // Backtracking\n  backStartBtn.addEventListener('click', ()=>{ startBacktrackingIfApplicable(true); });\n  backStepBtn.addEventListener('click', ()=>{ backtrackStep(); });\n  backEndBtn.addEventListener('click', ()=>{ endBacktracking(); });\n\n  function startBacktrackingIfApplicable(force) {\n    // create backtracking path depending on algorithm\n    if (state.backtrack.active && !force) return;\n    const algo = state.algorithm;\n    state.backtrack = {active:true, path:[], pos:0};\n    if (algo === 'knapsack') {\n      const n = state.dpMeta.n, W = state.dpMeta.W;\n      let i = n, w = W;\n      const path = [];\n      while (i>0) {\n        const val = state.dp[i][w];\n        if (val === state.dp[i-1][w]) {\n          path.push({i, w, take:false});\n          i = i-1;\n        } else {\n          path.push({i, w, take:true});\n          w = w - state.input.weights[i-1];\n          i = i-1;\n        }\n      }\n      state.backtrack.path = path;\n      state.backtrack.pos = 0;\n      backInfo.textContent = `Backtracking prepared: ${path.length} steps.`;\n      renderAll();\n    } else if (algo === 'edit') {\n      // reconstruct one possible alignment by walking from bottom-right\n      const m = state.dpMeta.m, n = state.dpMeta.n;\n      let i = m, j = n;\n      const path = [];\n      while (i>0 || j>0) {\n        if (i>0 && j>0 && state.input.s1[i-1] === state.input.s2[j-1]) {\n          path.push({i,j,action:'match'});\n          i--; j--;\n        } else {\n          // choose minimal neighbor\n          const options = [];\n          if (i>0 && j>0) options.push({act:'replace', val:state.dp[i-1][j-1]});\n          if (j>0) options.push({act:'insert', val:state.dp[i][j-1]});\n          if (i>0) options.push({act:'delete', val:state.dp[i-1][j]});\n          options.sort((a,b)=>a.val - b.val);\n          const choice = options[0].act;\n          path.push({i,j,action:choice});\n          if (choice === 'replace') { i--; j--; }\n          else if (choice === 'insert') { j--; }\n          else { i--; }\n        }\n      }\n      state.backtrack.path = path;\n      state.backtrack.pos = 0;\n      backInfo.textContent = `Backtracking prepared: ${path.length} steps.`;\n    } else if (algo === 'lis') {\n      // find index of max dp\n      let bestIdx = 0, bestVal = -Infinity;\n      for (let i=0;i<state.dp.length;i++) {\n        if ((state.dp[i] || 0) > bestVal) { bestVal = state.dp[i] || 0; bestIdx = i; }\n      }\n      const seq = state.dpMeta.seq;\n      // naive backtracking: find j<i with dp[j] = dp[i]-1 and seq[j] < seq[i]\n      const path = [];\n      let i = bestIdx;\n      let curVal = state.dp[i];\n      while (i >= 0 && curVal > 0) {\n        path.push({i, val:curVal});\n        // find previous\n        let found = false;\n        for (let j = i-1; j>=0; j--) {\n          if ((state.dp[j] || 0) === curVal - 1 && seq[j] < seq[i]) {\n            i = j; curVal = state.dp[j]; found = true; break;\n          }\n        }\n        if (!found) break;\n      }\n      state.backtrack.path = path;\n      state.backtrack.pos = 0;\n      backInfo.textContent = `Backtracking prepared: ${path.length} steps.`;\n    } else if (algo === 'coin') {\n      // reconstruct coins used for target\n      let a = state.input.target;\n      const path = [];\n      while (a > 0) {\n        let found = false;\n        for (let c of state.input.coins) {\n          if (a-c >= 0 && state.dp[a-c] != null && state.dp[a] === state.dp[a-c] + 1) {\n            path.push({amount:a, coin:c});\n            a = a-c;\n            found = true;\n            break;\n          }\n        }\n        if (!found) break;\n      }\n      state.backtrack.path = path;\n      state.backtrack.pos = 0;\n      backInfo.textContent = `Backtracking prepared: ${path.length} steps.`;\n    } else if (algo === 'fib') {\n      backInfo.textContent = `Fibonacci memo keys: ${Object.keys(state.memo).join(', ')}`;\n      state.backtrack = {active:true, path: Object.keys(state.memo).map(k=>({k, v: state.memo[k]})), pos:0};\n    } else {\n      backInfo.textContent = 'Backtracking not available for this algorithm.';\n      state.backtrack.active = false;\n    }\n    renderAll();\n  }\n\n  function backtrackStep() {\n    if (!state.backtrack.active || !state.backtrack.path) { backInfo.textContent = 'No backtracking prepared.'; return; }\n    const pos = state.backtrack.pos;\n    if (pos >= state.backtrack.path.length) { backInfo.textContent = 'Backtracking complete.'; return; }\n    const step = state.backtrack.path[pos];\n    // show highlight in opInfo and log\n    addLog('backtrack step: ' + JSON.stringify(step));\n    state.backtrack.pos++;\n    backInfo.textContent = `Backtracking step ${state.backtrack.pos}/${state.backtrack.path.length}`;\n    saveSnapshot('backtrack step');\n    renderAll();\n  }\n\n  function endBacktracking() {\n    state.backtrack = {active:false, path:[], pos:0};\n    backInfo.textContent = '';\n    saveSnapshot('end backtrack');\n    renderAll();\n  }\n\n  // Helpers\n  function uniqueId() { return Math.random().toString(36).slice(2,10); }\n\n  // Render everything\n  function renderAll() {\n    // update controls to reflect state\n    algoEl.value = state.algorithm;\n    modeEl.value = state.mode;\n    manualChoiceEl.checked = state.manualChoice;\n    showRecEl.checked = state.showRecursion;\n    autoBackEl.checked = state.autoBack;\n    speedEl.value = state.speed;\n    speedVal.textContent = state.speed;\n    renderProblemDisplay();\n    renderTable();\n    renderMemo();\n    renderStack();\n    renderOpInfo(state.operations[state.opIndex]);\n    renderLogs();\n  }\n\n  // Start by initializing default engine\n  initEngine();\n\n  // Hook into some internal op types for dispatch\n  // We will intercept op types in the main dispatcher; ensure computeFibStore is handled\n  // For clarity, modify dispatchStep to call handleComputeFibStore for that type; already coded\n\n  // Expose some global functions for debugging (not necessary)\n  window.__dp_state = state;\n  window.__renderAll = renderAll;\n\n  // Extra: allow clicking table logs to restore snapshots already handled\n  // Finalize initial render\n  renderAll();\n\n  // Integrate special handling for computeFibStore in dispatchStep by injecting into operations array\n  // Modify operations to include computeFibStore type when created inside handleCall\n  // All set.\n\n})();\n</script>\n\n</body>\n</html>"
