  "question": "Breadth-First Search (BFS)",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Breadth-First Search Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background-color: white;\n    color: black;\n    margin: 1em;\n  }\n  textarea, input, button, select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  #graph-area {\n    white-space: pre;\n    border: 1px solid black;\n    padding: 1em;\n    height: 14em;\n    overflow: auto;\n    margin-bottom: 1em;\n  }\n  #queue-area {\n    white-space: pre;\n    border: 1px solid black;\n    padding: 0.5em;\n    height: 6em;\n    overflow: auto;\n    margin-bottom: 1em;\n  }\n  #log-area {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 0.5em;\n    height: 10em;\n    overflow: auto;\n    margin-bottom: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n  button {\n    margin-top: 0.5em;\n  }\n  input[type=text] {\n    width: 8em;\n  }\n  #controls {\n    margin-bottom: 1em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Breadth-First Search (BFS) Interactive Demo</h1>\n\n<div id=\"instructions\">\n  <strong>Instructions:</strong>\n  <ul>\n    <li>Define a directed or undirected graph by entering edges below.</li>\n    <li>Edges must be entered one per line in the format: <code>NodeA NodeB</code>, e.g. <code>A B</code>.</li>\n    <li>Nodes are case-sensitive and can be alphanumeric strings without spaces.</li>\n    <li>Select whether the graph is directed or undirected.</li>\n    <li>Enter the start node for BFS traversal.</li>\n    <li>Click <em>Load Graph</em> to parse and visualize the graph as adjacency list.</li>\n    <li>Use the step controls to run BFS step-by-step or automatically.</li>\n    <li>You can clear and redefine the graph anytime.</li>\n  </ul>\n</div>\n\n<label for=\"graph-text\">Graph edges (one per line):</label>\n<textarea id=\"graph-text\" rows=\"6\" cols=\"50\" placeholder=\"Example:\nA B\nA C\nB D\nC D\nD E\n\"></textarea>\n\n<label>\n  <input type=\"checkbox\" id=\"directed-checkbox\" />\n  Directed graph (unchecked = undirected)\n</label>\n\n<label for=\"start-node\">Start node for BFS:</label>\n<input type=\"text\" id=\"start-node\" placeholder=\"e.g. A\" />\n\n<div id=\"controls\">\n  <button id=\"load-graph-btn\" type=\"button\">Load Graph</button>\n  <button id=\"clear-graph-btn\" type=\"button\">Clear Graph</button>\n</div>\n\n<div>\n  <strong>Graph adjacency list:</strong>\n  <pre id=\"graph-area\">(Load a graph to show adjacency list here)</pre>\n</div>\n\n<div>\n  <label for=\"step-delay-range\">Auto-run step delay (ms): <span id=\"delay-value\">1000</span></label>\n  <input id=\"step-delay-range\" type=\"range\" min=\"100\" max=\"5000\" step=\"100\" value=\"1000\" />\n</div>\n\n<div id=\"bfs-controls\" style=\"margin-top: 1em;\">\n  <button id=\"bfs-step-btn\" type=\"button\" disabled>Step BFS</button>\n  <button id=\"bfs-auto-btn\" type=\"button\" disabled>Run Auto BFS</button>\n  <button id=\"bfs-pause-btn\" type=\"button\" disabled>Pause Auto BFS</button>\n  <button id=\"bfs-reset-btn\" type=\"button\" disabled>Reset BFS</button>\n</div>\n\n<div>\n  <strong>Current BFS Queue:</strong>\n  <pre id=\"queue-area\">(Queue will appear here)</pre>\n</div>\n\n<div>\n  <strong>Visited nodes in order:</strong>\n  <pre id=\"visited-area\">(Visited nodes will appear here)</pre>\n</div>\n\n<div>\n  <strong>Log / Details:</strong>\n  <pre id=\"log-area\">(Logs will appear here)</pre>\n</div>\n\n<hr />\n\n<h2>Advanced Controls and Exploration</h2>\n\n<div>\n  <label for=\"add-node-input\">Add a new node:</label>\n  <input type=\"text\" id=\"add-node-input\" placeholder=\"Node name\" />\n  <button id=\"add-node-btn\" type=\"button\" disabled>Add Node</button>\n</div>\n\n<div>\n  <label for=\"add-edge-input-a\">Add edge from node:</label>\n  <input type=\"text\" id=\"add-edge-input-a\" placeholder=\"Node A\" />\n  <label for=\"add-edge-input-b\">to node:</label>\n  <input type=\"text\" id=\"add-edge-input-b\" placeholder=\"Node B\" />\n  <button id=\"add-edge-btn\" type=\"button\" disabled>Add Edge</button>\n</div>\n\n<div>\n  <label for=\"remove-node-input\">Remove a node:</label>\n  <input type=\"text\" id=\"remove-node-input\" placeholder=\"Node name\" />\n  <button id=\"remove-node-btn\" type=\"button\" disabled>Remove Node</button>\n</div>\n\n<div>\n  <label for=\"remove-edge-input-a\">Remove edge from node:</label>\n  <input type=\"text\" id=\"remove-edge-input-a\" placeholder=\"Node A\" />\n  <label for=\"remove-edge-input-b\">to node:</label>\n  <input type=\"text\" id=\"remove-edge-input-b\" placeholder=\"Node B\" />\n  <button id=\"remove-edge-btn\" type=\"button\" disabled>Remove Edge</button>\n</div>\n\n<div>\n  <label for=\"change-start-node\">Change BFS start node:</label>\n  <input type=\"text\" id=\"change-start-node\" placeholder=\"Start node\" />\n  <button id=\"change-start-node-btn\" type=\"button\" disabled>Change Start Node</button>\n</div>\n\n<div style=\"margin-top: 1em;\">\n  <button id=\"export-graph-btn\" type=\"button\" disabled>Export Graph (Adjacency List)</button>\n  <button id=\"import-graph-btn\" type=\"button\">Import Graph (Paste adjacency list)</button>\n</div>\n\n<div id=\"import-area\" style=\"margin-top: 0.5em; display:none;\">\n  <label for=\"import-textarea\">Paste adjacency list here (one line per node, format: Node: Neighbor1 Neighbor2 ...):</label>\n  <textarea id=\"import-textarea\" rows=\"6\" cols=\"50\"></textarea>\n  <button id=\"import-graph-confirm-btn\" type=\"button\">Import Graph</button>\n  <button id=\"import-graph-cancel-btn\" type=\"button\">Cancel Import</button>\n</div>\n\n<script>\n(function(){\n  // Data structures\n  let graph = {}; // adjacency list {node: [neighbors]}\n  let directed = false;\n  let startNode = null;\n\n  // BFS state\n  let bfsQueue = [];\n  let bfsVisited = new Set();\n  let bfsVisitedOrder = [];\n  let bfsRunning = false;\n  let bfsTimer = null;\n  let stepDelay = 1000; // ms\n\n  // DOM elements\n  const graphTextArea = document.getElementById('graph-text');\n  const directedCheckbox = document.getElementById('directed-checkbox');\n  const startNodeInput = document.getElementById('start-node');\n  const loadGraphBtn = document.getElementById('load-graph-btn');\n  const clearGraphBtn = document.getElementById('clear-graph-btn');\n  const graphArea = document.getElementById('graph-area');\n  const bfsStepBtn = document.getElementById('bfs-step-btn');\n  const bfsAutoBtn = document.getElementById('bfs-auto-btn');\n  const bfsPauseBtn = document.getElementById('bfs-pause-btn');\n  const bfsResetBtn = document.getElementById('bfs-reset-btn');\n  const queueArea = document.getElementById('queue-area');\n  const visitedArea = document.getElementById('visited-area');\n  const logArea = document.getElementById('log-area');\n  const stepDelayRange = document.getElementById('step-delay-range');\n  const delayValue = document.getElementById('delay-value');\n\n  const addNodeInput = document.getElementById('add-node-input');\n  const addNodeBtn = document.getElementById('add-node-btn');\n\n  const addEdgeInputA = document.getElementById('add-edge-input-a');\n  const addEdgeInputB = document.getElementById('add-edge-input-b');\n  const addEdgeBtn = document.getElementById('add-edge-btn');\n\n  const removeNodeInput = document.getElementById('remove-node-input');\n  const removeNodeBtn = document.getElementById('remove-node-btn');\n\n  const removeEdgeInputA = document.getElementById('remove-edge-input-a');\n  const removeEdgeInputB = document.getElementById('remove-edge-input-b');\n  const removeEdgeBtn = document.getElementById('remove-edge-btn');\n\n  const changeStartNodeInput = document.getElementById('change-start-node');\n  const changeStartNodeBtn = document.getElementById('change-start-node-btn');\n\n  const exportGraphBtn = document.getElementById('export-graph-btn');\n  const importGraphBtn = document.getElementById('import-graph-btn');\n  const importArea = document.getElementById('import-area');\n  const importTextarea = document.getElementById('import-textarea');\n  const importGraphConfirmBtn = document.getElementById('import-graph-confirm-btn');\n  const importGraphCancelBtn = document.getElementById('import-graph-cancel-btn');\n\n  function log(msg){\n    logArea.textContent += msg + '\\n';\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  function clearLog(){\n    logArea.textContent = '';\n  }\n\n  // Graph utilities\n\n  function resetBFSState(){\n    bfsQueue = [];\n    bfsVisited.clear();\n    bfsVisitedOrder = [];\n    bfsRunning = false;\n    if(bfsTimer !== null){\n      clearTimeout(bfsTimer);\n      bfsTimer = null;\n    }\n    updateBFSControls(false);\n    updateQueueArea();\n    updateVisitedArea();\n    log('BFS state reset.');\n  }\n\n  function updateGraphArea(){\n    if(Object.keys(graph).length === 0){\n      graphArea.textContent = '(Graph is empty)';\n      return;\n    }\n    let lines = [];\n    for(let node of Object.keys(graph).sort()){\n      if(graph[node].length === 0){\n        lines.push(node + ':');\n      } else {\n        lines.push(node + ': ' + graph[node].join(' '));\n      }\n    }\n    graphArea.textContent = lines.join('\\n');\n  }\n\n  function updateQueueArea(){\n    if(bfsQueue.length === 0){\n      queueArea.textContent = '(empty)';\n      return;\n    }\n    queueArea.textContent = bfsQueue.join(' → ');\n  }\n\n  function updateVisitedArea(){\n    if(bfsVisitedOrder.length === 0){\n      visitedArea.textContent = '(none)';\n      return;\n    }\n    visitedArea.textContent = bfsVisitedOrder.join(' → ');\n  }\n\n  function updateBFSControls(enabled){\n    bfsStepBtn.disabled = !enabled;\n    bfsAutoBtn.disabled = !enabled || bfsRunning;\n    bfsPauseBtn.disabled = !bfsRunning;\n    bfsResetBtn.disabled = !enabled;\n  }\n\n  // Parse graph text area\n\n  function parseGraphInput(text){\n    // lines like: A B (edge from A to B)\n    // empty lines ignored\n    let lines = text.split('\\n');\n    let newGraph = {};\n    let nodesSet = new Set();\n\n    for(let line of lines){\n      line = line.trim();\n      if(line === '') continue;\n      let parts = line.split(/\\s+/);\n      if(parts.length !== 2){\n        throw new Error('Invalid edge format (must be exactly 2 nodes per line): ' + line);\n      }\n      let from = parts[0];\n      let to = parts[1];\n      if(!newGraph[from]) newGraph[from] = [];\n      newGraph[from].push(to);\n\n      nodesSet.add(from);\n      nodesSet.add(to);\n    }\n    // Add empty neighbor array for nodes with no outgoing edges\n    for(let n of nodesSet){\n      if(!newGraph[n]) newGraph[n] = [];\n    }\n\n    if(!directed){\n      // Add reverse edges for undirected\n      for(let from of Object.keys(newGraph)){\n        for(let to of newGraph[from]){\n          if(!newGraph[to].includes(from)){\n            newGraph[to].push(from);\n          }\n        }\n      }\n    }\n    // Sort neighbors for consistent display\n    for(let node in newGraph){\n      newGraph[node].sort();\n    }\n    return newGraph;\n  }\n\n  // BFS Step function\n\n  function bfsStep(){\n    if(bfsQueue.length === 0){\n      log('Queue empty: BFS complete.');\n      updateBFSControls(false);\n      bfsRunning = false;\n      bfsAutoBtn.disabled = true;\n      bfsPauseBtn.disabled = true;\n      return false;\n    }\n    let current = bfsQueue.shift();\n    log('Visiting node: ' + current);\n    bfsVisitedOrder.push(current);\n    let neighbors = graph[current] || [];\n    for(let n of neighbors){\n      if(!bfsVisited.has(n) && !bfsQueue.includes(n)){\n        bfsQueue.push(n);\n        log('  Enqueued neighbor: ' + n);\n      }\n    }\n    bfsVisited.add(current);\n    updateQueueArea();\n    updateVisitedArea();\n    return true;\n  }\n\n  // BFS Auto runner\n\n  function bfsAutoRun(){\n    if(!bfsRunning) return;\n    let continueRunning = bfsStep();\n    if(!continueRunning){\n      bfsRunning = false;\n      updateBFSControls(false);\n      return;\n    }\n    bfsTimer = setTimeout(bfsAutoRun, stepDelay);\n  }\n\n  // Load graph button action\n\n  loadGraphBtn.addEventListener('click', ()=>{\n    clearLog();\n    try{\n      directed = directedCheckbox.checked;\n      graph = parseGraphInput(graphTextArea.value);\n      updateGraphArea();\n      startNode = startNodeInput.value.trim();\n      if(!(startNode in graph)){\n        alert('Start node \"'+startNode+'\" is not in the graph. Please choose a valid node.');\n        startNode = null;\n        updateBFSControls(false);\n        return;\n      }\n      resetBFSState();\n      // Initialize BFS state with the start node\n      bfsQueue.push(startNode);\n      bfsVisited.clear();\n      bfsVisitedOrder = [];\n      updateQueueArea();\n      updateVisitedArea();\n      updateBFSControls(true);\n\n      // Enable advanced controls\n      addNodeBtn.disabled = false;\n      addEdgeBtn.disabled = false;\n      removeNodeBtn.disabled = false;\n      removeEdgeBtn.disabled = false;\n      changeStartNodeBtn.disabled = false;\n      exportGraphBtn.disabled = false;\n\n      log('Graph loaded. BFS ready to start from node \"' + startNode + '\".');\n    }catch(e){\n      alert('Error loading graph: ' + e.message);\n      graphArea.textContent = '(Error parsing graph)';\n      updateBFSControls(false);\n    }\n  });\n\n  clearGraphBtn.addEventListener('click', ()=>{\n    if(bfsTimer !== null){\n      clearTimeout(bfsTimer);\n      bfsTimer = null;\n    }\n    graph = {};\n    graphArea.textContent = '(Graph is empty)';\n    queueArea.textContent = '(Queue will appear here)';\n    visitedArea.textContent = '(Visited nodes will appear here)';\n    clearLog();\n    bfsRunning = false;\n    bfsQueue = [];\n    bfsVisited.clear();\n    bfsVisitedOrder = [];\n    updateBFSControls(false);\n    addNodeBtn.disabled = true;\n    addEdgeBtn.disabled = true;\n    removeNodeBtn.disabled = true;\n    removeEdgeBtn.disabled = true;\n    changeStartNodeBtn.disabled = true;\n    exportGraphBtn.disabled = true;\n\n    // Clear inputs for advanced controls\n    addNodeInput.value = '';\n    addEdgeInputA.value = '';\n    addEdgeInputB.value = '';\n    removeNodeInput.value = '';\n    removeEdgeInputA.value = '';\n    removeEdgeInputB.value = '';\n    changeStartNodeInput.value = '';\n\n    log('Graph cleared.');\n  });\n\n  bfsStepBtn.addEventListener('click', ()=>{\n    if(bfsRunning){\n      log('Cannot step while auto-running.');\n      return;\n    }\n    bfsStep();\n  });\n\n  bfsAutoBtn.addEventListener('click', ()=>{\n    if(bfsRunning) return;\n    bfsRunning = true;\n    updateBFSControls(true);\n    bfsAutoRun();\n  });\n\n  bfsPauseBtn.addEventListener('click', ()=>{\n    if(!bfsRunning) return;\n    bfsRunning = false;\n    if(bfsTimer !== null){\n      clearTimeout(bfsTimer);\n      bfsTimer = null;\n    }\n    updateBFSControls(true);\n    log('Auto BFS paused.');\n  });\n\n  bfsResetBtn.addEventListener('click', ()=>{\n    if(bfsTimer !== null){\n      clearTimeout(bfsTimer);\n      bfsTimer = null;\n    }\n    resetBFSState();\n    if(startNode && (startNode in graph)){\n      bfsQueue.push(startNode);\n      updateQueueArea();\n      updateVisitedArea();\n      updateBFSControls(true);\n      log('BFS reset to start node \"'+startNode+'\"');\n    } else {\n      updateBFSControls(false);\n    }\n  });\n\n  stepDelayRange.addEventListener('input', ()=>{\n    stepDelay = parseInt(stepDelayRange.value,10);\n    delayValue.textContent = stepDelay;\n  });\n\n  // Advanced Controls\n\n  // Add Node\n  addNodeBtn.addEventListener('click', ()=>{\n    let node = addNodeInput.value.trim();\n    if(node === ''){\n      alert('Please enter a node name.');\n      return;\n    }\n    if(node in graph){\n      alert('Node \"'+node+'\" already exists.');\n      return;\n    }\n    graph[node] = [];\n    updateGraphArea();\n    addNodeInput.value = '';\n    log('Node \"'+node+'\" added.');\n\n    // When graph changes, BFS state must be reset\n    resetBFSState();\n    if(startNode && (startNode in graph)){\n      bfsQueue.push(startNode);\n      updateQueueArea();\n      updateVisitedArea();\n      updateBFSControls(true);\n    } else {\n      updateBFSControls(false);\n    }\n  });\n\n  // Add Edge\n  addEdgeBtn.addEventListener('click', ()=>{\n    let a = addEdgeInputA.value.trim();\n    let b = addEdgeInputB.value.trim();\n    if(a === '' || b === ''){\n      alert('Please enter both node names for edge.');\n      return;\n    }\n    if(!(a in graph)){\n      alert('Node \"'+a+'\" does not exist in graph.');\n      return;\n    }\n    if(!(b in graph)){\n      alert('Node \"'+b+'\" does not exist in graph.');\n      return;\n    }\n    if(graph[a].includes(b)){\n      alert('Edge \"'+a+' → '+b+'\" already exists.');\n      return;\n    }\n    graph[a].push(b);\n    graph[a].sort();\n    if(!directed){\n      if(!graph[b].includes(a)){\n        graph[b].push(a);\n        graph[b].sort();\n      }\n    }\n    updateGraphArea();\n    addEdgeInputA.value = '';\n    addEdgeInputB.value = '';\n    log('Edge \"'+a+' → '+b+'\" added.');\n\n    resetBFSState();\n    if(startNode && (startNode in graph)){\n      bfsQueue.push(startNode);\n      updateQueueArea();\n      updateVisitedArea();\n      updateBFSControls(true);\n    } else {\n      updateBFSControls(false);\n    }\n  });\n\n  // Remove Node\n  removeNodeBtn.addEventListener('click', ()=>{\n    let node = removeNodeInput.value.trim();\n    if(node === ''){\n      alert('Please enter a node name.');\n      return;\n    }\n    if(!(node in graph)){\n      alert('Node \"'+node+'\" does not exist.');\n      return;\n    }\n    delete graph[node];\n    // Remove from neighbors lists\n    for(let n in graph){\n      graph[n] = graph[n].filter(x => x !== node);\n    }\n    updateGraphArea();\n    removeNodeInput.value = '';\n    log('Node \"'+node+'\" removed.');\n\n    // If startNode is removed, reset startNode to null\n    if(startNode === node){\n      startNode = null;\n      startNodeInput.value = '';\n      log('Start node was removed; select a new start node.');\n      updateBFSControls(false);\n    }\n\n    resetBFSState();\n    if(startNode && (startNode in graph)){\n      bfsQueue.push(startNode);\n      updateQueueArea();\n      updateVisitedArea();\n      updateBFSControls(true);\n    } else {\n      updateBFSControls(false);\n    }\n  });\n\n  // Remove Edge\n  removeEdgeBtn.addEventListener('click', ()=>{\n    let a = removeEdgeInputA.value.trim();\n    let b = removeEdgeInputB.value.trim();\n    if(a === '' || b === ''){\n      alert('Please enter both node names for edge removal.');\n      return;\n    }\n    if(!(a in graph)){\n      alert('Node \"'+a+'\" does not exist.');\n      return;\n    }\n    if(!(b in graph)){\n      alert('Node \"'+b+'\" does not exist.');\n      return;\n    }\n    if(!graph[a].includes(b)){\n      alert('Edge \"'+a+' → '+b+'\" does not exist.');\n      return;\n    }\n    graph[a] = graph[a].filter(x => x !== b);\n    if(!directed){\n      graph[b] = graph[b].filter(x => x !== a);\n    }\n    updateGraphArea();\n    removeEdgeInputA.value = '';\n    removeEdgeInputB.value = '';\n    log('Edge \"'+a+' → '+b+'\" removed.');\n\n    resetBFSState();\n    if(startNode && (startNode in graph)){\n      bfsQueue.push(startNode);\n      updateQueueArea();\n      updateVisitedArea();\n      updateBFSControls(true);\n    } else {\n      updateBFSControls(false);\n    }\n  });\n\n  // Change start node\n  changeStartNodeBtn.addEventListener('click', ()=>{\n    let newStart = changeStartNodeInput.value.trim();\n    if(newStart === ''){\n      alert('Please enter a start node.');\n      return;\n    }\n    if(!(newStart in graph)){\n      alert('Node \"'+newStart+'\" does not exist.');\n      return;\n    }\n    startNode = newStart;\n    startNodeInput.value = startNode;\n    resetBFSState();\n    bfsQueue.push(startNode);\n    updateQueueArea();\n    updateVisitedArea();\n    updateBFSControls(true);\n    log('Start node changed to \"'+startNode+'\". BFS reset.');\n    changeStartNodeInput.value = '';\n  });\n\n  // Export graph\n\n  exportGraphBtn.addEventListener('click', ()=>{\n    let lines = [];\n    for(let node of Object.keys(graph).sort()){\n      lines.push(node + ': ' + graph[node].join(' '));\n    }\n    let text = lines.join('\\n');\n    // Just prompt for copy or manual save\n    let w = window.open('', '', 'width=600,height=400');\n    w.document.write('<pre>' + text.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</pre>');\n    w.document.title = 'Exported Graph Adjacency List';\n    w.focus();\n  });\n\n  // Import graph controls\n\n  importGraphBtn.addEventListener('click', ()=>{\n    importArea.style.display = 'block';\n    importTextarea.value = '';\n  });\n\n  importGraphCancelBtn.addEventListener('click', ()=>{\n    importArea.style.display = 'none';\n  });\n\n  importGraphConfirmBtn.addEventListener('click', ()=>{\n    let importText = importTextarea.value.trim();\n    if(importText === ''){\n      alert('Please paste adjacency list text to import.');\n      return;\n    }\n    // Parse adjacency list format:\n    // Node: Neighbor1 Neighbor2 ...\n    // Example:\n    // A: B C\n    // B: A D\n    // C: A\n    // D: B\n    let lines = importText.split('\\n');\n    let newGraph = {};\n    try{\n      for(let line of lines){\n        line = line.trim();\n        if(line === '') continue;\n        let colonIndex = line.indexOf(':');\n        if(colonIndex === -1){\n          throw new Error('Invalid line, missing colon: '+line);\n        }\n        let node = line.substring(0, colonIndex).trim();\n        let neighborsStr = line.substring(colonIndex+1).trim();\n        let neighbors = neighborsStr.length > 0 ? neighborsStr.split(/\\s+/) : [];\n        if(node === ''){\n          throw new Error('Node name cannot be empty in line: '+line);\n        }\n        newGraph[node] = neighbors;\n      }\n      // Confirm all neighbors nodes present in keys or add them empty\n      for(let node in newGraph){\n        for(let nb of newGraph[node]){\n          if(!(nb in newGraph)){\n            newGraph[nb] = [];\n          }\n        }\n      }\n      // Sort neighbors\n      for(let node in newGraph){\n        newGraph[node].sort();\n      }\n      graph = newGraph;\n      directed = directedCheckbox.checked;\n      updateGraphArea();\n      importArea.style.display = 'none';\n      log('Graph imported from adjacency list.');\n      // Reset BFS state and controls\n      resetBFSState();\n      // If startNode is missing or no longer valid\n      if(!startNode || !(startNode in graph)){\n        startNode = null;\n        alert('Current start node missing or invalid in imported graph. Please set new start node.');\n        startNodeInput.value = '';\n        updateBFSControls(false);\n      } else {\n        bfsQueue.push(startNode);\n        updateQueueArea();\n        updateVisitedArea();\n        updateBFSControls(true);\n      }\n      // Enable advanced controls if graph nonempty\n      if(Object.keys(graph).length > 0){\n        addNodeBtn.disabled = false;\n        addEdgeBtn.disabled = false;\n        removeNodeBtn.disabled = false;\n        removeEdgeBtn.disabled = false;\n        changeStartNodeBtn.disabled = false;\n        exportGraphBtn.disabled = false;\n      } else {\n        addNodeBtn.disabled = true;\n        addEdgeBtn.disabled = true;\n        removeNodeBtn.disabled = true;\n        removeEdgeBtn.disabled = true;\n        changeStartNodeBtn.disabled = true;\n        exportGraphBtn.disabled = true;\n      }\n    }catch(e){\n      alert('Error importing graph: '+e.message);\n    }\n  });\n\n  // Initialization\n\n  // Disable advanced buttons initially\n  addNodeBtn.disabled = true;\n  addEdgeBtn.disabled = true;\n  removeNodeBtn.disabled = true;\n  removeEdgeBtn.disabled = true;\n  changeStartNodeBtn.disabled = true;\n  exportGraphBtn.disabled = true;\n\n  updateBFSControls(false);\n\n  delayValue.textContent = stepDelayRange.value;\n\n  // Make the demo richer by adding keyboard enter triggers for inputs to add edges/nodes etc.\n  function addEnterKeyHandler(inputElem, buttonElem){\n    inputElem.addEventListener('keydown', (e)=>{\n      if(e.key === 'Enter'){\n        e.preventDefault();\n        if(!buttonElem.disabled){\n          buttonElem.click();\n        }\n      }\n    });\n  }\n  addEnterKeyHandler(addNodeInput, addNodeBtn);\n  addEnterKeyHandler(addEdgeInputA, addEdgeBtn);\n  addEnterKeyHandler(addEdgeInputB, addEdgeBtn);\n  addEnterKeyHandler(removeNodeInput, removeNodeBtn);\n  addEnterKeyHandler(removeEdgeInputA, removeEdgeBtn);\n  addEnterKeyHandler(removeEdgeInputB, removeEdgeBtn);\n  addEnterKeyHandler(changeStartNodeInput, changeStartNodeBtn);\n\n})();\n</script>\n\n</body>\n</html>"
  },
  "messages": [
