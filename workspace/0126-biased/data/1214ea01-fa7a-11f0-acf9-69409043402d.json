  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Backtracking Interactive Demo</title>\n<style>\n  /* Minimal styling to ensure plain appearance */\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 7em;\n    font-family: monospace;\n    font-size: 14px;\n  }\n  input[type=number] {\n    width: 4em;\n  }\n  button {\n    margin: 0.2em 0.5em 0.5em 0;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n  label {\n    white-space: nowrap;\n  }\n  #log {\n    height: 10em;\n    overflow-y: scroll;\n    border: 1px solid black;\n    background: white;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  #solutionOutput {\n    font-family: monospace;\n    white-space: pre;\n    margin-top: 0.5em;\n    border: 1px solid black;\n    padding: 0.3em;\n    min-height: 5em;\n  }\n</style>\n</head>\n<body>\n<h1>Backtracking Interactive Demo</h1>\n\n<p>This tool lets you explore backtracking algorithms interactively with multiple examples and controls. Modify inputs, run step-by-step backtracking, explore solution branches, and control the process fully.</p>\n\n<fieldset>\n  <legend>Choose Backtracking Problem</legend>\n  <select id=\"problemSelect\" aria-label=\"Select backtracking problem\">\n    <option value=\"subsetSum\">Subset Sum (find subsets that sum to target)</option>\n    <option value=\"nQueens\">N Queens (place N queens on N×N board)</option>\n    <option value=\"permute\">Permutations (all permutations of given list)</option>\n  </select>\n</fieldset>\n\n<fieldset id=\"configSubsetSum\">\n  <legend>Subset Sum Problem Configuration</legend>\n  <label for=\"subsetSumSetInput\">Set (comma-separated integers):</label><br />\n  <textarea id=\"subsetSumSetInput\">3,7,1,8,4,5</textarea><br />\n  <label for=\"subsetSumTargetInput\">Target sum:</label>\n  <input type=\"number\" id=\"subsetSumTargetInput\" value=\"15\" min=\"0\" step=\"1\" /><br />\n</fieldset>\n\n<fieldset id=\"configNQueens\" hidden>\n  <legend>N Queens Problem Configuration</legend>\n  <label for=\"nQueensNInput\">Board size (N):</label>\n  <input type=\"number\" id=\"nQueensNInput\" value=\"4\" min=\"1\" max=\"15\" step=\"1\" /><br />\n</fieldset>\n\n<fieldset id=\"configPermutations\" hidden>\n  <legend>Permutations Problem Configuration</legend>\n  <label for=\"permuteInput\">Elements (comma-separated):</label><br />\n  <textarea id=\"permuteInput\">a,b,c</textarea><br />\n</fieldset>\n\n<fieldset>\n  <legend>Controls</legend>\n  <button id=\"initBtn\" aria-label=\"Initialize the backtracking algorithm\">Initialize</button>\n  <button id=\"stepForwardBtn\" disabled aria-label=\"Perform next backtracking step\">Step Forward</button>\n  <button id=\"stepBackBtn\" disabled aria-label=\"Step backward in path\">Step Backward</button>\n  <button id=\"autoRunBtn\" disabled aria-label=\"Run continuously with interval\">Auto Run</button>\n  <button id=\"pauseBtn\" disabled aria-label=\"Pause auto run\">Pause</button>\n  <button id=\"resetBtn\" disabled aria-label=\"Reset all\">Reset</button>\n  <br />\n  <label for=\"speedRange\">Auto Run speed (ms/step):</label>\n  <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"2000\" value=\"500\" step=\"50\" />\n  <span id=\"speedDisplay\">500</span>\n</fieldset>\n\n<fieldset>\n  <legend>Current State and Exploration</legend>\n  <div><strong>Current Depth:</strong> <span id=\"currentDepth\">0</span></div>\n  <div><strong>Current Partial Solution:</strong></div>\n  <pre id=\"currentPartial\"></pre>\n  <div>\n    <strong>Available Next Choices:</strong>\n    <ul id=\"choicesList\"></ul>\n  </div>\n  <div>\n    <strong>Action Log:</strong>\n    <div id=\"log\" aria-live=\"polite\" aria-relevant=\"additions\"></div>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Found Solutions</legend>\n  <button id=\"exportSolutionsBtn\" disabled aria-label=\"Export all found solutions as JSON\">Export Solutions</button><br />\n  <textarea id=\"solutionOutput\" readonly aria-label=\"Solutions output\"></textarea>\n</fieldset>\n\n<script>\n(function() {\n  // State Variables\n  let problem = 'subsetSum';\n\n  // Backtracking engine state\n  let backtrackingState = null; // object containing current state, stack, solutions, etc.\n  let autoRunInterval = null;\n\n  // Cached DOM elements\n  const problemSelect = document.getElementById('problemSelect');\n  const configSubsetSum = document.getElementById('configSubsetSum');\n  const subsetSumSetInput = document.getElementById('subsetSumSetInput');\n  const subsetSumTargetInput = document.getElementById('subsetSumTargetInput');\n  const configNQueens = document.getElementById('configNQueens');\n  const nQueensNInput = document.getElementById('nQueensNInput');\n  const configPermutations = document.getElementById('configPermutations');\n  const permuteInput = document.getElementById('permuteInput');\n\n  const initBtn = document.getElementById('initBtn');\n  const stepForwardBtn = document.getElementById('stepForwardBtn');\n  const stepBackBtn = document.getElementById('stepBackBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const speedRange = document.getElementById('speedRange');\n  const speedDisplay = document.getElementById('speedDisplay');\n\n  const currentDepth = document.getElementById('currentDepth');\n  const currentPartial = document.getElementById('currentPartial');\n  const choicesList = document.getElementById('choicesList');\n  const log = document.getElementById('log');\n\n  const solutionOutput = document.getElementById('solutionOutput');\n  const exportSolutionsBtn = document.getElementById('exportSolutionsBtn');\n\n  // Utility: log messages to action log\n  function logMessage(msg) {\n    log.textContent += msg + '\\n';\n    log.scrollTop = log.scrollHeight;\n  }\n\n  // Clear logs and outputs\n  function clearLogs() {\n    log.textContent = '';\n    solutionOutput.value = '';\n  }\n\n  // Enable/disable controls depending on state\n  function updateControlState() {\n    const initialized = backtrackingState !== null;\n    stepForwardBtn.disabled = !initialized;\n    stepBackBtn.disabled = !initialized || backtrackingState.steps.length <= 1;\n    autoRunBtn.disabled = !initialized || (autoRunInterval !== null);\n    pauseBtn.disabled = (autoRunInterval === null);\n    resetBtn.disabled = !initialized;\n    exportSolutionsBtn.disabled = !(initialized && backtrackingState.solutions.length > 0);\n  }\n\n  // Problem configurations switching\n  function updateProblemConfigs() {\n    const val = problemSelect.value;\n    problem = val;\n    configSubsetSum.hidden = val !== 'subsetSum';\n    configNQueens.hidden = val !== 'nQueens';\n    configPermutations.hidden = val !== 'permute';\n  }\n\n  // ****************\n  // BACKTRACKING ENGINES FOR PROBLEMS\n  // ****************\n  /*\n    Each engine must implement:\n    - initialize(): returns initial state object\n    - step(state, direction): perform next step in given direction ('forward' or 'backward')\n    - getChoices(state): return array of possible next choices from current state\n    - formatPartial(state): return string describing current partial solution\n    - foundSolution(state): returns boolean if current partial is a solution\n    - exportSolution(state): return solution in a JSON-serializable form\n  */\n\n  // ---------- Subset Sum Backtracking -----------\n  function subsetSumInitialize() {\n    let rawSet = subsetSumSetInput.value.trim();\n    if (!rawSet) throw new Error('Set is empty');\n    let set = rawSet.split(',').map(s => parseInt(s.trim(),10));\n    if (set.some(isNaN)) throw new Error('Set contains invalid numbers');\n    let target = parseInt(subsetSumTargetInput.value, 10);\n    if (isNaN(target)) throw new Error('Invalid target sum');\n    // state shape:\n    // {\n    //   set: array of numbers,\n    //   target: target sum,\n    //   stack: array of frames,\n    //   solutions: array of arrays (each solution is list of values),\n    //   currentPartial: current chosen elements (array),\n    //   steps: array snapshots for backward stepping\n    // }\n    // A frame = { index: number, included: boolean|null } - null means not yet decided\n    return {\n      set,\n      target,\n      stack: [{index: 0, included: null}],\n      currentPartial: [],\n      solutions: [],\n      steps: [] // will store deep copies of stack and partial for stepping back\n    };\n  }\n  // Helper: clone stack and partial to save state snapshot\n  function cloneSubsetState(state) {\n    return {\n      stack: JSON.parse(JSON.stringify(state.stack)),\n      currentPartial: state.currentPartial.slice()\n    };\n  }\n  function subsetSumGetChoices(state) {\n    let frame = state.stack[state.stack.length-1];\n    if (!frame) return [];\n    if (frame.included === null) {\n      // two choices: include or not include the current index element\n      return [true,false];\n    } else {\n      return [];\n    }\n  }\n  function subsetSumFormatPartial(state) {\n    if(state.currentPartial.length === 0)\n      return '(empty)';\n    return state.currentPartial.join(', ');\n  }\n  function subsetSumCheckSolution(state) {\n    let sum = state.currentPartial.reduce((a,b)=>a+b,0);\n    return sum === state.target &&\n      state.stack[state.stack.length-1].index === state.set.length;\n  }\n  function subsetSumStep(state, direction) {\n    // direction: 'forward' or 'backward'\n    // For forward step:\n    // - If current frame.included is null,\n    //   set included to first unexplored choice (true, then false)\n    // - If included is true, add element to partial, if false do nothing\n    // - Then if possible, push new frame for next index\n    // - If at leaf, check solution, record if found, then backtrack (pop stack)\n    // For backward step:\n    // - revert to previous step state\n    if(direction === 'backward'){\n      if(state.steps.length <= 1) return; // cannot step back\n      state.steps.pop();\n      let snapshot = state.steps[state.steps.length-1];\n      state.stack = JSON.parse(JSON.stringify(snapshot.stack));\n      state.currentPartial = snapshot.currentPartial.slice();\n      return;\n    }\n    // forward step\n    let stack = state.stack;\n    if(stack.length === 0) return;\n\n    let frame = stack[stack.length - 1];\n\n    // Save snapshot before changing\n    state.steps.push(cloneSubsetState(state)); \n\n    // If included is null => try true first, otherwise false\n    if(frame.included === null) {\n      frame.included = true;\n      state.currentPartial.push(state.set[frame.index]);\n    } else if(frame.included === true) {\n      // try false now\n      frame.included = false;\n      state.currentPartial.pop();\n    } else {\n      // included false already => pop current frame (backtrack)\n      stack.pop();\n      if(stack.length === 0){\n        // done\n        return;\n      }\n      // move to next choice of previous frame\n      let prevFrame = stack[stack.length - 1];\n      if(prevFrame.included === null){\n        // no choice made yet, will pick true next step\n        return;\n      } else if (prevFrame.included === true){\n        // will pick false next step\n        return;\n      } else {\n        // prevFrame was false, pop prev frame? This will be done next step\n        return;\n      }\n    }\n\n    // After deciding to include or exclude:\n    // If included true or false just decided, check if we can push next frame\n    if(frame.index + 1 < state.set.length) {\n      // push next frame\n      stack.push({index: frame.index + 1, included: null});\n    } else {\n      // Leaf node reached, check solution\n      if(subsetSumCheckSolution(state)) {\n        // Save solution (copy)\n        state.solutions.push(state.currentPartial.slice());\n        logMessage(\"Found solution: [\"+state.currentPartial.join(', ')+\"]\");\n      }\n      // Next forward step will backtrack\n    }\n  }\n  function subsetSumExportSolution(sol) {\n    return sol;\n  }\n\n  // ------------ N Queens Backtracking -------------\n  /*\n  State shape:\n  {\n    N: board size,\n    board: array of length N: board[row] = col index of queen (or -1 if no queen),\n    row: next row to place queen,\n    solutions: array of board arrays,\n    steps: array snapshots for back steps\n  }\n  */\n  function nQueensInitialize() {\n    let N = parseInt(nQueensNInput.value,10);\n    if(isNaN(N) || N < 1 || N > 15) throw new Error(\"N must be between 1 and 15\");\n    return {\n      N,\n      board: new Array(N).fill(-1),\n      row: 0,\n      solutions: [],\n      steps: []\n    };\n  }\n  function nQueensIsSafe(board, row, col) {\n    for(let r=0; r<row; r++) {\n      let c = board[r];\n      if(c === col) return false;\n      if(Math.abs(row-r) === Math.abs(col-c)) return false;\n    }\n    return true;\n  }\n  function nQueensGetChoices(state) {\n    let choices = [];\n    if(state.row >= state.N) return choices;\n    for(let c=0;c<state.N;c++) {\n      if(nQueensIsSafe(state.board, state.row, c)){\n        choices.push(c);\n      }\n    }\n    return choices;\n  }\n  function nQueensFormatPartial(state) {\n    // Show board rows up to current row, with Q and .\n    let lines = [];\n    for(let r=0;r<state.N;r++) {\n      if(r < state.row) {\n        let line = '';\n        for(let c=0;c<state.N;c++){\n          line += (state.board[r] === c) ? 'Q' : '.';\n        }\n        lines.push(line);\n      } else {\n        lines.push('(row '+r+': not placed)');\n      }\n    }\n    return lines.join('\\n');\n  }\n  function nQueensCheckSolution(state) {\n    return state.row === state.N;\n  }\n  function nQueensStep(state, direction) {\n    if(direction === 'backward'){\n      if(state.steps.length <= 1) return;\n      state.steps.pop();\n      let snapshot = state.steps[state.steps.length-1];\n      state.board = snapshot.board.slice();\n      state.row = snapshot.row;\n      return;\n    }\n    // forward step\n    if(state.row === state.N) return; // done\n\n    state.steps.push({\n      board: state.board.slice(),\n      row: state.row\n    });\n\n    let choices = nQueensGetChoices(state);\n    if(choices.length === 0){\n      // dead end, backtrack\n      if(state.row > 0){\n        state.row--;\n        // Remove queen from that row\n        state.board[state.row] = -1;\n      }\n      return;\n    }\n\n    // We need to carefully explore choices one by one for each row\n    // To support stepping through multiple branches at one row,\n    // state needs to remember which columns have been tried per row\n    // We'll extend state with an array triedCols: length N, entries hold integer index of tried choice (-1 = none tried)\n    if(!state.triedCols) {\n      state.triedCols = new Array(state.N).fill(-1);\n    }\n    let tried = state.triedCols[state.row] || -1;\n    let nextChoiceIdx = tried + 1;\n\n    if(nextChoiceIdx >= choices.length){\n      // No more choices in this row - backtrack\n      state.triedCols[state.row] = -1;\n      state.board[state.row] = -1;\n      state.row--;\n      if(state.row < 0) return; // finished all\n      // This will try next choice in previous row next time step is called\n    } else {\n      // Try next choice at this row\n      state.board[state.row] = choices[nextChoiceIdx];\n      state.triedCols[state.row] = nextChoiceIdx;\n      state.row++;\n    }\n\n    // If we reached last row, check solution and record\n    if(state.row === state.N){\n      if(nQueensCheckSolution(state)){\n        state.solutions.push(state.board.slice());\n        logMessage('Found solution at row '+state.N);\n      }\n      // Backtrack next step\n      if(state.row > 0){\n        state.row--;\n        state.board[state.row] = -1;\n        state.triedCols[state.row] = -1;\n      }\n    }\n  }\n  function nQueensExportSolution(solution) {\n    return solution;\n  }\n\n  // ----------- Permutations Backtracking ------------\n  /*\n  State shape:\n  {\n    elements: original array,\n    chosen: current prefix array,\n    used: boolean array to mark used elements,\n    solutions: array of arrays,\n    steps: array snapshots,\n    nextChoiceIndex: for tracking which unused elements tried next\n  }\n  */\n  function permuteInitialize() {\n    let raw = permuteInput.value.trim();\n    if(!raw) throw new Error('Elements input empty');\n    let elements = raw.split(',').map(s=>s.trim()).filter(s=>s.length>0);\n    let used = new Array(elements.length).fill(false);\n    return {\n      elements,\n      chosen: [],\n      used,\n      solutions: [],\n      steps: [],\n      nextChoiceIndexStack: [] // will store index of next unused element to try per recursion level\n    };\n  }\n  function permuteGetChoices(state) {\n    let choices = [];\n    for(let i=0;i<state.elements.length;i++){\n      if(!state.used[i]) choices.push(i);\n    }\n    return choices;\n  }\n  function permuteFormatPartial(state) {\n    if(state.chosen.length === 0) return '(empty)';\n    let res = state.chosen.map(i=>state.elements[i]).join(', ');\n    return res;\n  }\n  function permuteCheckSolution(state) {\n    return state.chosen.length === state.elements.length;\n  }\n  function permuteStep(state, direction) {\n    if(direction === 'backward'){\n      if(state.steps.length <= 1) return;\n      state.steps.pop();\n      let snapshot = state.steps[state.steps.length-1];\n      state.chosen = snapshot.chosen.slice();\n      state.used = snapshot.used.slice();\n      state.nextChoiceIndexStack = snapshot.nextChoiceIndexStack.slice();\n      return;\n    }\n    // forward step\n    state.steps.push({\n      chosen: state.chosen.slice(),\n      used: state.used.slice(),\n      nextChoiceIndexStack: state.nextChoiceIndexStack.slice()\n    });\n    if(permuteCheckSolution(state)){\n      // already a solution => no forward step\n      return;\n    }\n    // Current recursion depth is chosen.length\n    let depth = state.chosen.length;\n    if(state.nextChoiceIndexStack.length < depth+1){\n      state.nextChoiceIndexStack.push(-1);\n    }\n    // Try next unused element index\n    let nextIndex = state.nextChoiceIndexStack[depth] + 1;\n    let choices = permuteGetChoices(state);\n    if(nextIndex >= choices.length){\n      // exhausted all at this depth, backtrack\n      state.nextChoiceIndexStack.pop();\n      if(state.chosen.length === 0){\n        // done\n        return;\n      }\n      let lastChosen = state.chosen.pop();\n      state.used[lastChosen] = false;\n      // next forward call will try next choice in previous depth\n    } else {\n      // try next unused choice for this depth\n      state.nextChoiceIndexStack[depth] = nextIndex;\n      let elIndex = choices[nextIndex];\n      state.chosen.push(elIndex);\n      state.used[elIndex] = true;\n\n      if(permuteCheckSolution(state)){\n        // found solution\n        let sol = state.chosen.map(i=>state.elements[i]);\n        state.solutions.push(sol);\n        logMessage('Found permutation: [' + sol.join(', ') + ']');\n        // next forward step will backtrack from this leaf\n      }\n      // next forward step will go deeper or backtrack if no unused choice at next level\n    }\n  }\n  function permuteExportSolution(sol) {\n    return sol;\n  }\n\n  // -------------\n  // Master hook to get engine by problem\n  // -------------\n  function getEngine() {\n    if(problem === 'subsetSum'){\n      return {\n        initialize: subsetSumInitialize,\n        step: subsetSumStep,\n        getChoices: subsetSumGetChoices,\n        formatPartial: subsetSumFormatPartial,\n        foundSolution: subsetSumCheckSolution,\n        exportSolution: subsetSumExportSolution\n      };\n    }\n    if(problem === 'nQueens'){\n      return {\n        initialize: nQueensInitialize,\n        step: nQueensStep,\n        getChoices: nQueensGetChoices,\n        formatPartial: nQueensFormatPartial,\n        foundSolution: nQueensCheckSolution,\n        exportSolution: nQueensExportSolution\n      };\n    }\n    if(problem === 'permute'){\n      return {\n        initialize: permuteInitialize,\n        step: permuteStep,\n        getChoices: permuteGetChoices,\n        formatPartial: permuteFormatPartial,\n        foundSolution: permuteCheckSolution,\n        exportSolution: permuteExportSolution\n      };\n    }\n  }\n\n  // -------------\n  // UI update function to reflect current state\n  // -------------\n  function updateUI() {\n    if(!backtrackingState) {\n      currentDepth.textContent = '0';\n      currentPartial.textContent = '';\n      choicesList.innerHTML = '';\n      solutionOutput.value = '';\n      updateControlState();\n      return;\n    }\n    let engine = getEngine();\n    // Depth = length of stack or recursion level\n    let depth = 0;\n    if(problem === 'subsetSum') depth = backtrackingState.stack.length;\n    else if(problem === 'nQueens') depth = backtrackingState.row;\n    else if(problem === 'permute') depth = backtrackingState.chosen.length;\n    currentDepth.textContent = depth;\n\n    currentPartial.textContent = engine.formatPartial(backtrackingState);\n\n    // Show choices available at this step (if any)\n    let choices = engine.getChoices(backtrackingState);\n    choicesList.innerHTML = '';\n    if(choices.length === 0) {\n      let li = document.createElement('li');\n      li.textContent = '(no choices)';\n      choicesList.appendChild(li);\n    } else {\n      if(problem === 'subsetSum'){\n        choices.forEach(c => {\n          let li = document.createElement('li');\n          li.textContent = (c ? 'Include next element' : 'Exclude next element');\n          choicesList.appendChild(li);\n        });\n      } else if(problem === 'nQueens') {\n        choices.forEach(c => {\n          let li = document.createElement('li');\n          li.textContent = 'Place queen in column ' + c;\n          choicesList.appendChild(li);\n        });\n      } else if(problem === 'permute') {\n        choices.forEach(i => {\n          let li = document.createElement('li');\n          li.textContent = 'Choose element \"' + backtrackingState.elements[i] + '\"';\n          choicesList.appendChild(li);\n        });\n      }\n    }\n\n    // Update solutions display\n    if(backtrackingState.solutions.length === 0){\n      solutionOutput.value = '(No solutions found yet)';\n    } else {\n      let sols = backtrackingState.solutions.map(engine.exportSolution);\n      solutionOutput.value = JSON.stringify(sols,null,2);\n    }\n    updateControlState();\n  }\n\n  // -------------\n  // Button event handlers\n  // -------------\n\n  initBtn.addEventListener('click', ()=> {\n    clearLogs();\n    try {\n      let engine = getEngine();\n      backtrackingState = engine.initialize();\n      // Save initial step snapshot\n      if(problem === 'subsetSum'){\n        backtrackingState.steps = [cloneSubsetState(backtrackingState)];\n      } else if(problem === 'nQueens'){\n        backtrackingState.steps = [{board: backtrackingState.board.slice(), row: backtrackingState.row}];\n      } else if(problem === 'permute'){\n        backtrackingState.steps = [{\n          chosen: backtrackingState.chosen.slice(),\n          used: backtrackingState.used.slice(),\n          nextChoiceIndexStack: backtrackingState.nextChoiceIndexStack ? backtrackingState.nextChoiceIndexStack.slice() : []\n        }];\n      }\n      updateUI();\n    } catch(e) {\n      alert('Init failed: ' + e.message);\n    }\n  });\n\n  stepForwardBtn.addEventListener('click', () => {\n    if(!backtrackingState) return;\n    let engine = getEngine();\n    engine.step(backtrackingState, 'forward');\n    updateUI();\n  });\n\n  stepBackBtn.addEventListener('click', () => {\n    if(!backtrackingState) return;\n    let engine = getEngine();\n    engine.step(backtrackingState, 'backward');\n    updateUI();\n  });\n\n  autoRunBtn.addEventListener('click', () => {\n    if(autoRunInterval !== null) return;\n    if(!backtrackingState) return;\n    let engine = getEngine();\n\n    function autoStep() {\n      engine.step(backtrackingState, 'forward');\n      updateUI();\n      let depth = 0;\n      if(problem === 'subsetSum') depth = backtrackingState.stack.length;\n      else if(problem === 'nQueens') depth = backtrackingState.row;\n      else if(problem === 'permute') depth = backtrackingState.chosen.length;\n      // Try stop if no more forward steps possible:\n      // For subsetSum, stack empty means finished\n      if((problem === 'subsetSum' && depth === 0) ||\n         (problem === 'nQueens' && depth === 0 && backtrackingState.board.every(x => x === -1)) ||\n         (problem === 'permute' && depth === 0 && backtrackingState.chosen.length === 0)) {\n        clearInterval(autoRunInterval);\n        autoRunInterval = null;\n        updateControlState();\n        logMessage('Auto run finished');\n      }\n    }\n    autoStep();\n    autoRunInterval = setInterval(autoStep, parseInt(speedRange.value,10));\n    updateControlState();\n  });\n\n  pauseBtn.addEventListener('click', () => {\n    if(autoRunInterval !== null) {\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n    }\n    updateControlState();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    backtrackingState = null;\n    autoRunInterval && clearInterval(autoRunInterval);\n    autoRunInterval = null;\n    clearLogs();\n    updateUI();\n  });\n\n  speedRange.addEventListener('input', () => {\n    speedDisplay.textContent = speedRange.value;\n    if(autoRunInterval !== null) {\n      clearInterval(autoRunInterval);\n      let engine = getEngine();\n      autoRunInterval = setInterval(() => {\n        engine.step(backtrackingState, 'forward');\n        updateUI();\n      }, parseInt(speedRange.value,10));\n    }\n  });\n\n  exportSolutionsBtn.addEventListener('click', () => {\n    if(!backtrackingState || backtrackingState.solutions.length === 0) return;\n    let text = solutionOutput.value;\n    // Create a downloadable blob text file for convenience (trigger download)\n    let blob = new Blob([text], {type: 'application/json'});\n    let url = URL.createObjectURL(blob);\n    let a = document.createElement('a');\n    a.href = url;\n    a.download = problem + '_solutions.json';\n    document.body.appendChild(a);\n    a.click();\n    document.body.removeChild(a);\n    URL.revokeObjectURL(url);\n  });\n\n  problemSelect.addEventListener('change', () => {\n    updateProblemConfigs();\n    backtrackingState = null;\n    clearLogs();\n    updateUI();\n  });\n\n  // Initial setup\n  updateProblemConfigs();\n  updateControlState();\n\n})();\n</script>\n</body>\n</html>"
  },
  "messages": [
