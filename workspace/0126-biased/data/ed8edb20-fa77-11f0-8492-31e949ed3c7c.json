    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Stunning Monitor Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            overflow: hidden;\n            background-color: #1a1a2e;\n            color: #fff;\n        }\n        .container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            perspective: 1000px;\n        }\n        .monitor {\n            width: 80vw;\n            height: 50vh;\n            border-radius: 15px;\n            background: linear-gradient(145deg, #0e1a30, #1d2a4d);\n            box-shadow: 15px 15px 30px #1a1a2e, -15px -15px 30px #0b0c1c;\n            overflow: hidden;\n            position: relative;\n            transition: transform 0.5s ease;\n        }\n        .screen {\n            width: 100%;\n            height: 100%;\n            background: url('https://via.placeholder.com/800x500/5D5C61/FFFFFF/?text=Interactive+Monitor+Screen') center/cover no-repeat;\n            border-radius: 15px;\n            position: relative;\n            transform: translateZ(20px);\n            transition: transform 0.5s ease;\n        }\n        .button {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            padding: 10px 20px;\n            background-color: #e94560;\n            border: none;\n            border-radius: 5px;\n            color: white;\n            font-size: 16px;\n            cursor: pointer;\n            box-shadow: 2px 2px 8px rgba(0,0,0,0.3);\n            transition: background-color 0.3s ease;\n        }\n        .button:hover {\n            background-color: #d13450;\n        }\n        .button:focus {\n            outline: none;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <div class=\"monitor\">\n        <div class=\"screen\"></div>\n        <button class=\"button\" onclick=\"toggleAnimation()\">Toggle Animation</button>\n    </div>\n</div>\n\n<script>\n    let animated = false;\n\n    function toggleAnimation() {\n        const monitor = document.querySelector('.monitor');\n        animated = !animated;\n        monitor.style.transform = animated ? 'rotateY(-20deg)' : 'rotateY(0deg)';\n    }\n</script>\n\n</body>\n</html>"
