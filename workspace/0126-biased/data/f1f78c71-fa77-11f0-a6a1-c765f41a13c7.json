    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Semaphore — Elegant Visualization</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071028;\n    --accent: #7de3ff;\n    --accent-2: #8b62ff;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.7);\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.04);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    font-synthesis: none;\n  }\n\n  /* Base layout */\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(123,58,255,0.12), transparent 8%),\n                radial-gradient(900px 700px at 95% 90%, rgba(125,227,255,0.06), transparent 12%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2));\n    color: white;\n    overflow:hidden;\n  }\n\n  /* Subtle animated stars / particles */\n  .sky {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    background-image:\n      radial-gradient(1px 1px at 10% 30%, rgba(255,255,255,0.08), transparent 40%),\n      radial-gradient(1px 1px at 25% 10%, rgba(255,255,255,0.06), transparent 40%),\n      radial-gradient(1px 1px at 60% 25%, rgba(255,255,255,0.05), transparent 40%),\n      radial-gradient(1px 1px at 80% 70%, rgba(255,255,255,0.04), transparent 40%);\n    mix-blend-mode:screen;\n    animation: drift 12s linear infinite;\n    opacity:0.8;\n    filter:blur(0.4px) saturate(1.1);\n  }\n\n  @keyframes drift {\n    0% { transform: translateY(0) translateX(0) rotate(0deg); }\n    50% { transform: translateY(-6px) translateX(4px) rotate(0.2deg); }\n    100% { transform: translateY(0) translateX(0) rotate(0deg); }\n  }\n\n  /* Center stage */\n  .stage {\n    position:relative;\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    z-index:1;\n    gap:28px;\n  }\n\n  .card {\n    width:980px;\n    max-width:calc(100% - 96px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:18px;\n    box-shadow: var(--shadow);\n    padding:30px;\n    display:flex;\n    gap:28px;\n    align-items:center;\n    backdrop-filter: blur(10px) saturate(140%);\n  }\n\n  /* Left panel: Title & Info */\n  .info {\n    width:360px;\n    min-width:260px;\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n  }\n\n  .logo {\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n\n  .badge {\n    width:56px;\n    height:56px;\n    border-radius:14px;\n    background: linear-gradient(135deg,var(--accent),var(--accent-2));\n    box-shadow: 0 8px 20px rgba(139,98,255,0.18), inset 0 -6px 18px rgba(0,0,0,0.18);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    font-size:18px;\n    color: #041026;\n    letter-spacing:0.6px;\n    transform:translateZ(0);\n  }\n\n  h1 {\n    margin:0;\n    font-size:20px;\n    letter-spacing:0.2px;\n    font-weight:700;\n    color: white;\n  }\n\n  p.lead {\n    margin:0;\n    color: var(--muted);\n    font-size:13px;\n    line-height:1.5;\n  }\n\n  .meta {\n    margin-top:6px;\n    font-size:13px;\n    color: #cfefff;\n    opacity:0.85;\n  }\n\n  .controls {\n    display:flex;\n    gap:12px;\n    margin-top:18px;\n  }\n\n  .btn {\n    -webkit-tap-highlight-color: transparent;\n    border:0;\n    padding:10px 16px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    color: #dff8ff;\n    font-weight:600;\n    cursor:pointer;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n    transition: transform .18s cubic-bezier(.2,.9,.2,1), box-shadow .18s;\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    font-size:13px;\n    backdrop-filter: blur(6px);\n  }\n\n  .btn:active { transform: translateY(2px) scale(.995); }\n  .btn.primary {\n    background: linear-gradient(90deg,var(--accent), var(--accent-2));\n    color:#021225;\n    box-shadow: 0 14px 30px rgba(124,92,255,0.14), 0 6px 18px rgba(0,0,0,0.35);\n  }\n\n  .note {\n    margin-top:8px;\n    color: var(--muted);\n    font-size:12px;\n  }\n\n  /* Right panel: Visualizer */\n  .visual {\n    flex:1;\n    min-height:360px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n\n  .visor {\n    width:560px;\n    max-width:100%;\n    height:380px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:visible;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 16px 40px rgba(3,8,23,0.6);\n    padding:18px;\n  }\n\n  /* Soft radial spotlight behind the mast */\n  .halo {\n    position:absolute;\n    width:560px;\n    height:380px;\n    left:0;\n    top:0;\n    background: radial-gradient(ellipse at center, rgba(125,227,255,0.07) 0%, transparent 35%),\n                radial-gradient(ellipse at 30% 70%, rgba(139,98,255,0.03) 0%, transparent 25%);\n    border-radius:14px;\n    pointer-events:none;\n    mix-blend-mode:screen;\n  }\n\n  /* Decoded text display */\n  .decoded {\n    position:absolute;\n    bottom:18px;\n    left:50%;\n    transform:translateX(-50%);\n    font-size:18px;\n    letter-spacing:4px;\n    color: rgba(255,255,255,0.92);\n    font-weight:700;\n    text-shadow: 0 4px 22px rgba(0,0,0,0.6);\n    opacity:0;\n    transition: opacity .6s cubic-bezier(.2,.9,.2,1), transform .6s;\n    pointer-events:none;\n  }\n\n  .decoded.active {\n    opacity:1;\n    transform:translateX(-50%) translateY(0);\n  }\n\n  /* Overlay message card for reveal */\n  .overlay {\n    position:fixed;\n    inset:0;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n  }\n  .message {\n    pointer-events:auto;\n    min-width:320px;\n    border-radius:14px;\n    padding:22px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 30px 60px rgba(4,10,24,0.6);\n    color:white;\n    transform:translateY(16px) scale(.98);\n    opacity:0;\n    transition: all .38s cubic-bezier(.2,.9,.2,1);\n    text-align:center;\n  }\n\n  .message.show {\n    opacity:1;\n    transform:translateY(0) scale(1);\n  }\n\n  .message h2 {\n    margin:0 0 8px 0;\n    font-size:18px;\n    letter-spacing:1px;\n  }\n  .message p {\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.5;\n  }\n\n  /* Footer tiny credits */\n  .foot {\n    position:fixed;\n    left:18px;\n    bottom:18px;\n    color:rgba(255,255,255,0.5);\n    font-size:12px;\n    backdrop-filter: blur(4px);\n  }\n\n  /* Responsive */\n  @media (max-width:880px){\n    .card { flex-direction:column; padding:20px; gap:18px; align-items:stretch; }\n    .info { width:100%; order:2; }\n    .visual { order:1; }\n    .decoded { font-size:16px; bottom:12px; }\n  }\n\n  /* tiny flourish animation for mast */\n  .mast-group { transform-origin:center bottom; animation: sway 5.6s ease-in-out infinite; }\n  @keyframes sway {\n    0%,100% { transform: translateY(0) rotate(-0.2deg); }\n    50% { transform: translateY(-2px) rotate(0.6deg); }\n  }\n\n  /* glow on flag when moving */\n  .flag .flag-shape { transition: filter .36s, transform .36s; }\n  .flag.moving .flag-shape { filter: drop-shadow(0 8px 24px rgba(125,227,255,0.14)); transform: scale(1.01); }\n\n  /* subtle pulse of decoded text */\n  .decoded .pill {\n    display:inline-block;\n    padding:6px 12px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    box-shadow: inset 0 -4px 12px rgba(0,0,0,0.35);\n    backdrop-filter: blur(6px);\n    font-weight:700;\n    letter-spacing:3px;\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"sky\" aria-hidden=\"true\"></div>\n\n  <main class=\"stage\" role=\"main\">\n    <section class=\"card\" aria-labelledby=\"title\">\n      <div class=\"info\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <div class=\"badge\">S</div>\n          <div>\n            <h1 id=\"title\">Semaphore</h1>\n            <div class=\"meta\">Visual signaling & coordination — classic maritime communication translated to motion and light.</div>\n          </div>\n        </div>\n\n        <p class=\"lead\">Observe elegant, slow-motion flag positions communicating a short encoded message. The animation demonstrates how two arms coordinate to convey letters — readable when decoded.</p>\n\n        <div class=\"controls\" role=\"group\" aria-label=\"controls\">\n          <button id=\"toggle\" class=\"btn primary\" aria-pressed=\"false\" title=\"Play or pause the semaphore animation\">Play</button>\n          <button id=\"reveal\" class=\"btn\" title=\"Reveal the decoded message\" aria-pressed=\"false\">Reveal</button>\n        </div>\n\n        <div class=\"note\">Minimal interactivity: play/pause the demonstration and reveal the decoded text.</div>\n      </div>\n\n      <div class=\"visual\" aria-hidden=\"false\">\n        <div class=\"visor\" role=\"img\" aria-label=\"Semaphore visual representation\">\n          <div class=\"halo\" aria-hidden=\"true\"></div>\n\n          <!-- SVG semaphore -->\n          <svg id=\"sema\" viewBox=\"0 0 560 360\" width=\"540\" height=\"340\" xmlns=\"http://www.w3.org/2000/svg\" role=\"presentation\">\n            <defs>\n              <linearGradient id=\"poleGrad\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#dfe6f3\" stop-opacity=\"0.06\"/>\n                <stop offset=\"1\" stop-color=\"#000\" stop-opacity=\"0.12\"/>\n              </linearGradient>\n              <linearGradient id=\"flagGradA\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7de3ff\"/>\n                <stop offset=\"1\" stop-color=\"#8b62ff\"/>\n              </linearGradient>\n              <linearGradient id=\"flagGradB\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#ffd37a\"/>\n                <stop offset=\"1\" stop-color=\"#ff6f6f\"/>\n              </linearGradient>\n              <filter id=\"softShadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"8\" result=\"b\"/>\n                <feOffset in=\"b\" dx=\"0\" dy=\"10\" result=\"o\"/>\n                <feBlend in=\"SourceGraphic\" in2=\"o\"/>\n              </filter>\n              <filter id=\"grain\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n                <feTurbulence baseFrequency=\"0.8\" numOctaves=\"1\" stitchTiles=\"stitch\" seed=\"3\" result=\"t\"/>\n                <feColorMatrix in=\"t\" type=\"saturate\" values=\"0\"/>\n                <feBlend in=\"SourceGraphic\" in2=\"t\" mode=\"overlay\" />\n              </filter>\n            </defs>\n\n            <!-- Subtle floor reflection -->\n            <g transform=\"translate(280,220)\">\n              <ellipse cx=\"0\" cy=\"92\" rx=\"140\" ry=\"32\" fill=\"rgba(3,8,23,0.36)\" />\n            </g>\n\n            <!-- Mast group -->\n            <g class=\"mast-group\" id=\"mast\" transform=\"translate(280,110)\">\n              <!-- pole -->\n              <rect x=\"-6\" y=\"-120\" width=\"12\" height=\"260\" rx=\"6\" fill=\"url(#poleGrad)\" />\n              <!-- pulley -->\n              <circle cx=\"0\" cy=\"-120\" r=\"8\" fill=\"#071428\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"2\"></circle>\n\n              <!-- left arm group (pivot at -8, -94 relative to group translate) -->\n              <g id=\"leftArm\" transform=\"rotate(-60 -40 -12)\">\n                <!-- arm shaft -->\n                <rect x=\"-120\" y=\"-12\" width=\"120\" height=\"8\" rx=\"4\" fill=\"#0a2233\" />\n                <!-- flag pivot ring -->\n                <circle cx=\"-120\" cy=\"-8\" r=\"8\" fill=\"#031427\"></circle>\n                <!-- flag -->\n                <g class=\"flag\" transform=\"translate(-120,-8)\">\n                  <rect class=\"flag-shape\" x=\"-2\" y=\"-18\" width=\"92\" height=\"36\" rx=\"8\" fill=\"url(#flagGradA)\"></rect>\n                  <rect x=\"60\" y=\"-18\" width=\"26\" height=\"36\" rx=\"6\" fill=\"rgba(255,255,255,0.06)\"></rect>\n                  <circle cx=\"18\" cy=\"0\" r=\"28\" fill=\"rgba(0,0,0,0.03)\"></circle>\n                </g>\n              </g>\n\n              <!-- right arm group (pivot at 8, -94 relative) -->\n              <g id=\"rightArm\" transform=\"rotate(60 40 -12)\">\n                <rect x=\"0\" y=\"-12\" width=\"120\" height=\"8\" rx=\"4\" fill=\"#071a28\" />\n                <circle cx=\"0\" cy=\"-8\" r=\"8\" fill=\"#031427\"></circle>\n                <g class=\"flag\" transform=\"translate(0,-8)\">\n                  <rect class=\"flag-shape\" x=\"-2\" y=\"-18\" width=\"92\" height=\"36\" rx=\"8\" fill=\"url(#flagGradB)\"></rect>\n                  <rect x=\"-86\" y=\"-18\" width=\"26\" height=\"36\" rx=\"6\" fill=\"rgba(255,255,255,0.06)\"></rect>\n                  <circle cx=\"-18\" cy=\"0\" r=\"28\" fill=\"rgba(0,0,0,0.03)\"></circle>\n                </g>\n              </g>\n\n              <!-- base ornament -->\n              <g transform=\"translate(0,120)\">\n                <rect x=\"-46\" y=\"0\" width=\"92\" height=\"20\" rx=\"8\" fill=\"rgba(255,255,255,0.02)\"></rect>\n              </g>\n            </g>\n\n            <!-- small static annotations -->\n            <text x=\"280\" y=\"330\" font-size=\"11\" text-anchor=\"middle\" fill=\"rgba(255,255,255,0.12)\">Two-arm semaphore — animated positions</text>\n          </svg>\n\n          <div class=\"decoded\" id=\"decoded\" aria-live=\"polite\">\n            <span class=\"pill\" id=\"decodedText\">— — —</span>\n          </div>\n\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <div class=\"overlay\" aria-hidden=\"true\">\n    <div class=\"message\" id=\"message\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Decoded message\">\n      <h2>Decoded Message</h2>\n      <p id=\"messageText\"> </p>\n    </div>\n  </div>\n\n  <div class=\"foot\">Designed as an elegant demonstration — minimal controls, maximum aesthetic.</div>\n\n<script>\n  // Semaphore animation controller (minimal interactivity)\n  (function(){\n    // Sequence: letters and target angles for left and right arms (degrees)\n    // Transform uses SVG rotate(angle, cx, cy) where 0 = pointing to the right.\n    // The arms initial layout in the SVG was roughly rotated; these values were tuned visually.\n    const sequence = [\n      { letter:'S', left:-110, right:30 },\n      { letter:'E', left:-100, right:50 },\n      { letter:'M', left:-120, right:70 },\n      { letter:'A', left:-140, right:82 },\n      { letter:'P', left:-60, right:140 },\n      { letter:'H', left:-30, right:140 },\n      { letter:'O', left:0, right:140 },\n      { letter:'R', left:40, right:120 },\n      { letter:'E', left:60, right:100 }\n    ];\n\n    const leftGroup = document.getElementById('leftArm');\n    const rightGroup = document.getElementById('rightArm');\n    const toggle = document.getElementById('toggle');\n    const reveal = document.getElementById('reveal');\n    const decoded = document.getElementById('decoded');\n    const decodedText = document.getElementById('decodedText');\n    const message = document.getElementById('message');\n    const messageText = document.getElementById('messageText');\n    const overlay = document.querySelector('.overlay');\n\n    // Animation state\n    let playing = false;\n    let idx = 0;\n    let rafId = null;\n    let startTime = null;\n    let currentLeft = -60;   // initial rough angle\n    let currentRight = 60;\n    let targetLeft = currentLeft;\n    let targetRight = currentRight;\n    let dur = 1000;\n    let pauseBetween = 500;\n    let movingClassLeft = leftGroup.querySelector('.flag');\n    let movingClassRight = rightGroup.querySelector('.flag');\n\n    // pivot coordinates relative to mast group translation (same as in SVG)\n    const leftPivot = { x: -120, y: -8 };\n    const rightPivot = { x: 0, y: -8 };\n\n    // Easing\n    function easeOutCubic(t){ return 1 - Math.pow(1 - t, 3); }\n\n    // Apply rotation transforms\n    function applyTransforms(l, r){\n      leftGroup.setAttribute('transform', `rotate(${l} ${leftPivot.x} ${leftPivot.y})`);\n      rightGroup.setAttribute('transform', `rotate(${r} ${rightPivot.x} ${rightPivot.y})`);\n    }\n\n    // Tweening loop\n    function step(ts){\n      if (!startTime) startTime = ts;\n      const elapsed = ts - startTime;\n      const t = Math.min(1, elapsed / dur);\n      const eased = easeOutCubic(t);\n      const l = currentLeft + (targetLeft - currentLeft) * eased;\n      const r = currentRight + (targetRight - currentRight) * eased;\n      applyTransforms(l, r);\n\n      // add gentle glow when motion is happening\n      if (t < 1) {\n        movingClassLeft.classList.add('moving');\n        movingClassRight.classList.add('moving');\n      } else {\n        movingClassLeft.classList.remove('moving');\n        movingClassRight.classList.remove('moving');\n      }\n\n      if (t < 1) {\n        rafId = requestAnimationFrame(step);\n      } else {\n        // landed; update current values\n        currentLeft = targetLeft;\n        currentRight = targetRight;\n        startTime = null;\n        // show letter briefly in decoded area\n        decoded.classList.add('active');\n        decodedText.textContent = sequence[idx].letter;\n        // schedule next after pause\n        setTimeout(()=>{\n          decoded.classList.remove('active');\n          idx = (idx + 1) % sequence.length;\n          scheduleNext();\n        }, pauseBetween + 200);\n      }\n    }\n\n    function scheduleNext(){\n      if (!playing) return;\n      targetLeft = sequence[idx].left;\n      targetRight = sequence[idx].right;\n      startTime = null;\n      // start the tween\n      rafId = requestAnimationFrame(step);\n    }\n\n    // Controls\n    toggle.addEventListener('click', ()=>{\n      playing = !playing;\n      toggle.setAttribute('aria-pressed', String(playing));\n      toggle.textContent = playing ? 'Pause' : 'Play';\n      toggle.classList.toggle('primary', playing);\n      // if starting, ensure a proper start\n      if (playing){\n        // if nothing scheduled, set next target\n        // idx already points to next\n        scheduleNext();\n      } else {\n        // stop animation gracefully\n        if (rafId) cancelAnimationFrame(rafId);\n        rafId = null;\n        // remove moving glows\n        movingClassLeft.classList.remove('moving');\n        movingClassRight.classList.remove('moving');\n      }\n    });\n\n    // Reveal toggles overlay and shows complete decoded word\n    let revealed = false;\n    reveal.addEventListener('click', ()=>{\n      revealed = !revealed;\n      reveal.setAttribute('aria-pressed', String(revealed));\n      overlay.setAttribute('aria-hidden', String(!revealed));\n      if (revealed){\n        // build decoded message from sequence letters\n        const msg = sequence.map(s => s.letter).join('');\n        messageText.textContent = msg;\n        message.classList.add('show');\n      } else {\n        message.classList.remove('show');\n      }\n    });\n\n    // Initialize positions\n    applyTransforms(currentLeft, currentRight);\n    decodedText.textContent = '— — —';\n\n    // Start in a slow idle animation: gently cycle arms to a neutral cross to give life\n    (function idlePulse(){\n      let t = 0;\n      function loop(ts){\n        t += 0.002;\n        const wobble = Math.sin(t * Math.PI * 2) * 3;\n        applyTransforms(currentLeft + wobble, currentRight - wobble);\n        requestAnimationFrame(loop);\n      }\n      requestAnimationFrame(loop);\n    })();\n\n    // Accessibility: pause on reduced-motion preference\n    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');\n    function handleReduceMotion(e){\n      if (e.matches) {\n        // stop animations and ensure static neutral pose\n        if (rafId) cancelAnimationFrame(rafId);\n        playing = false;\n        toggle.textContent = 'Play';\n        toggle.setAttribute('aria-pressed', 'false');\n        applyTransforms(sequence[0].left, sequence[0].right);\n      }\n    }\n    mq.addEventListener ? mq.addEventListener('change', handleReduceMotion) : mq.addListener(handleReduceMotion);\n    handleReduceMotion(mq);\n\n    // Small touch: clicking the mast will briefly highlight a frame (non-invasive)\n    const mast = document.getElementById('mast');\n    mast.style.cursor = 'default';\n    mast.addEventListener('click', ()=> {\n      // brief pulse: show current letter\n      decoded.classList.add('active');\n      decodedText.textContent = sequence[(idx+sequence.length-1)%sequence.length].letter;\n      setTimeout(()=> decoded.classList.remove('active'), 800);\n    });\n\n  })();\n</script>\n</body>\n</html>"
  },
