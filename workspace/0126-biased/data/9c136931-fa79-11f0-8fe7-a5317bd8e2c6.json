  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Binary Search Tree (BST) Interactive Demo</title>\n  <style>\n    /* Extremely minimal styling: keep default fonts and layout, only small resets for SVG space */\n    html, body { margin: 8px; padding: 0; font-family: sans-serif; color: black; background: white; }\n    button, input, select, textarea { margin: 2px; }\n    #main { display: block; }\n    #svgArea { border: 1px solid black; width: 100%; height: 420px; box-sizing: border-box; }\n    .controls { margin-bottom: 6px; }\n    .panel { margin-bottom: 8px; }\n    pre { white-space: pre-wrap; word-wrap: break-word; max-height: 180px; overflow: auto; border: 1px solid black; padding: 4px; }\n  </style>\n</head>\n<body>\n  <h2>Binary Search Tree (BST) Interactive Demo</h2>\n\n  <div id=\"main\">\n\n    <div class=\"panel controls\">\n      <label>Value:\n        <input id=\"valueInput\" type=\"text\" size=\"6\" placeholder=\"e.g. 42\">\n      </label>\n      <button id=\"insertBtn\">Insert</button>\n      <button id=\"deleteBtn\">Delete</button>\n      <button id=\"searchBtn\">Search</button>\n\n      <label>Duplicates:\n        <select id=\"dupMode\">\n          <option value=\"no\">Disallow</option>\n          <option value=\"left\">Allow - go left</option>\n          <option value=\"right\">Allow - go right</option>\n        </select>\n      </label>\n\n      <label>Step speed:\n        <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\">\n      </label>\n\n      <label>Node radius:\n        <input id=\"radius\" type=\"range\" min=\"8\" max=\"28\" value=\"14\">\n      </label>\n\n      <label>Show heights:\n        <input id=\"showHeight\" type=\"checkbox\">\n      </label>\n\n      <label>Show balance:\n        <input id=\"showBalance\" type=\"checkbox\">\n      </label>\n    </div>\n\n    <div class=\"panel controls\">\n      <button id=\"stepInsertBtn\">Step Insert (interactive)</button>\n      <button id=\"stepDeleteBtn\">Step Delete (interactive)</button>\n      <button id=\"stepSearchBtn\">Step Search (interactive)</button>\n\n      <button id=\"playStepsBtn\">Play Steps</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"stepForwardBtn\">Step Forward</button>\n      <button id=\"stepBackBtn\">Step Back</button>\n      <button id=\"clearStepsBtn\">Clear Steps</button>\n\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n    </div>\n\n    <div class=\"panel controls\">\n      <label>Bulk CSV:\n        <input id=\"bulkInput\" type=\"text\" size=\"40\" placeholder=\"e.g. 5,3,8,2,6\">\n      </label>\n      <button id=\"bulkInsertBtn\">Bulk Insert</button>\n\n      <label>Random count:\n        <input id=\"randCount\" type=\"number\" value=\"7\" min=\"1\" max=\"200\" style=\"width:60px\">\n      </label>\n      <label>min:\n        <input id=\"randMin\" type=\"number\" value=\"1\" style=\"width:60px\">\n      </label>\n      <label>max:\n        <input id=\"randMax\" type=\"number\" value=\"100\" style=\"width:60px\">\n      </label>\n      <button id=\"randBtn\">Generate Random</button>\n\n      <button id=\"clearBtn\">Clear</button>\n      <button id=\"mirrorBtn\">Mirror (invert)</button>\n      <button id=\"balanceBtn\">Rebuild Balanced</button>\n      <button id=\"avlRebalanceBtn\">AVL Rebalance</button>\n    </div>\n\n    <div class=\"panel controls\">\n      <label>Select node by clicking on it. Selected id: <span id=\"selectedInfo\">none</span></label>\n      <button id=\"deleteSelectedBtn\">Delete Selected</button>\n      <button id=\"rotateLeftBtn\">Rotate Left</button>\n      <button id=\"rotateRightBtn\">Rotate Right</button>\n      <button id=\"showSubtreeBtn\">Show Subtree (selected)</button>\n      <button id=\"kthBtn\">Find k-th Smallest</button>\n      <input id=\"kInput\" type=\"number\" style=\"width:60px\" value=\"1\" min=\"1\">\n    </div>\n\n    <div class=\"panel controls\">\n      <button id=\"inorderBtn\">In-order</button>\n      <button id=\"preorderBtn\">Pre-order</button>\n      <button id=\"postorderBtn\">Post-order</button>\n      <button id=\"levelorderBtn\">Level-order</button>\n      <button id=\"clearLogBtn\">Clear Log</button>\n    </div>\n\n    <div class=\"panel\">\n      <div id=\"svgAreaContainer\">\n        <svg id=\"svgArea\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Traversal / Info / Logs</strong>\n      <div>\n        <pre id=\"infoArea\">Tree is empty.</pre>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Save / Load</strong>\n      <button id=\"exportBtn\">Export JSON (copy)</button>\n      <button id=\"importBtn\">Import JSON (paste)</button>\n      <button id=\"clearStorageBtn\">Clear saved</button>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Internal Step Log (click an entry to jump to that state)</strong>\n      <pre id=\"stepLog\"></pre>\n    </div>\n\n  </div>\n\n  <script>\n    // Minimal BST interactive demo with rich controls. No visual flair.\n    (function(){\n      // Utility\n      function idGen() {\n        let i = 1;\n        return function(){ return i++; };\n      }\n      const nextId = idGen();\n      function clamp(v,min,max){return Math.max(min,Math.min(max,v));}\n\n      // Node class\n      class Node {\n        constructor(value){\n          this.id = nextId();\n          this.value = value;\n          this.left = null;\n          this.right = null;\n          this.parent = null;\n          this.height = 0;\n          this.size = 1;\n        }\n      }\n\n      // BST state\n      let root = null;\n      let selected = null;\n      let history = [];\n      let future = [];\n      let steps = []; // step frames for play/step\n      let currentStepIndex = -1;\n      let playing = false;\n      let playTimer = null;\n\n      // Settings\n      const settings = {\n        dupMode: 'no',\n        speed: 400,\n        radius: 14,\n        showHeight: false,\n        showBalance: false\n      };\n\n      // DOM handles\n      const svg = document.getElementById('svgArea');\n      const valueInput = document.getElementById('valueInput');\n      const insertBtn = document.getElementById('insertBtn');\n      const deleteBtn = document.getElementById('deleteBtn');\n      const searchBtn = document.getElementById('searchBtn');\n      const dupMode = document.getElementById('dupMode');\n      const speedRange = document.getElementById('speed');\n      const radiusRange = document.getElementById('radius');\n      const showHeightCb = document.getElementById('showHeight');\n      const showBalanceCb = document.getElementById('showBalance');\n\n      const stepInsertBtn = document.getElementById('stepInsertBtn');\n      const stepDeleteBtn = document.getElementById('stepDeleteBtn');\n      const stepSearchBtn = document.getElementById('stepSearchBtn');\n      const playStepsBtn = document.getElementById('playStepsBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const stepForwardBtn = document.getElementById('stepForwardBtn');\n      const stepBackBtn = document.getElementById('stepBackBtn');\n      const clearStepsBtn = document.getElementById('clearStepsBtn');\n\n      const undoBtn = document.getElementById('undoBtn');\n      const redoBtn = document.getElementById('redoBtn');\n\n      const bulkInput = document.getElementById('bulkInput');\n      const bulkInsertBtn = document.getElementById('bulkInsertBtn');\n      const randCount = document.getElementById('randCount');\n      const randMin = document.getElementById('randMin');\n      const randMax = document.getElementById('randMax');\n      const randBtn = document.getElementById('randBtn');\n      const clearBtn = document.getElementById('clearBtn');\n      const mirrorBtn = document.getElementById('mirrorBtn');\n      const balanceBtn = document.getElementById('balanceBtn');\n      const avlRebalanceBtn = document.getElementById('avlRebalanceBtn');\n\n      const selectedInfo = document.getElementById('selectedInfo');\n      const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');\n      const rotateLeftBtn = document.getElementById('rotateLeftBtn');\n      const rotateRightBtn = document.getElementById('rotateRightBtn');\n      const showSubtreeBtn = document.getElementById('showSubtreeBtn');\n      const kthBtn = document.getElementById('kthBtn');\n      const kInput = document.getElementById('kInput');\n\n      const inorderBtn = document.getElementById('inorderBtn');\n      const preorderBtn = document.getElementById('preorderBtn');\n      const postorderBtn = document.getElementById('postorderBtn');\n      const levelorderBtn = document.getElementById('levelorderBtn');\n      const clearLogBtn = document.getElementById('clearLogBtn');\n\n      const infoArea = document.getElementById('infoArea');\n      const exportBtn = document.getElementById('exportBtn');\n      const importBtn = document.getElementById('importBtn');\n      const clearStorageBtn = document.getElementById('clearStorageBtn');\n\n      const stepLog = document.getElementById('stepLog');\n\n      // Helpers to compute heights and sizes\n      function recompute(node){\n        if(!node) return -1;\n        const lh = node.left ? recompute(node.left) : -1;\n        const rh = node.right ? recompute(node.right) : -1;\n        node.height = 1 + Math.max(lh, rh);\n        node.size = 1 + (node.left ? node.left.size : 0) + (node.right ? node.right.size : 0);\n        return node.height;\n      }\n\n      function computeBalance(node){\n        if(!node) return 0;\n        const lh = node.left ? node.left.height + 1 : 0;\n        const rh = node.right ? node.right.height + 1 : 0;\n        return lh - rh;\n      }\n\n      // Save and restore state for undo/redo and stepping\n      function snapshotState(){\n        return JSON.stringify(serialize(root));\n      }\n      function pushHistory(){\n        history.push(snapshotState());\n        if(history.length > 200) history.shift();\n        future = [];\n        updateInfo();\n      }\n      function undo(){\n        if(history.length === 0) return;\n        const state = history.pop();\n        future.push(snapshotState());\n        root = deserialize(JSON.parse(state));\n        recompute(root);\n        selected = null;\n        pushLog(\"Undo: restored previous state\");\n        render();\n      }\n      function redo(){\n        if(future.length === 0) return;\n        const state = future.pop();\n        history.push(snapshotState());\n        root = deserialize(JSON.parse(state));\n        recompute(root);\n        selected = null;\n        pushLog(\"Redo: restored next state\");\n        render();\n      }\n\n      // Serialization\n      function serialize(node){\n        if(!node) return null;\n        return {\n          id: node.id,\n          value: node.value,\n          left: serialize(node.left),\n          right: serialize(node.right)\n        };\n      }\n      function deserialize(obj){\n        if(!obj) return null;\n        const n = new Node(obj.value);\n        n.id = obj.id || nextId();\n        n.left = deserialize(obj.left);\n        n.right = deserialize(obj.right);\n        if(n.left) n.left.parent = n;\n        if(n.right) n.right.parent = n;\n        return n;\n      }\n\n      // Insert (non-stepping)\n      function bstInsert(val){\n        if(root === null){\n          root = new Node(val);\n          pushLog(\"Inserted root: \" + val);\n          recompute(root);\n          pushHistory();\n          render();\n          return root;\n        }\n        let cur = root;\n        while(true){\n          if(val === cur.value){\n            if(settings.dupMode === 'no'){\n              pushLog(\"Duplicate not allowed: \" + val);\n              return null;\n            } else if(settings.dupMode === 'left'){\n              if(cur.left === null){\n                const n = new Node(val);\n                cur.left = n; n.parent = cur;\n                recompute(root);\n                pushHistory();\n                render();\n                pushLog(\"Inserted \" + val + \" as left duplicate of \" + cur.value);\n                return n;\n              } else cur = cur.left;\n            } else {\n              if(cur.right === null){\n                const n = new Node(val);\n                cur.right = n; n.parent = cur;\n                recompute(root);\n                pushHistory();\n                render();\n                pushLog(\"Inserted \" + val + \" as right duplicate of \" + cur.value);\n                return n;\n              } else cur = cur.right;\n            }\n          } else if(val < cur.value){\n            if(cur.left === null){\n              const n = new Node(val);\n              cur.left = n; n.parent = cur;\n              recompute(root);\n              pushHistory();\n              render();\n              pushLog(\"Inserted \" + val + \" to left of \" + cur.value);\n              return n;\n            } else cur = cur.left;\n          } else {\n            if(cur.right === null){\n              const n = new Node(val);\n              cur.right = n; n.parent = cur;\n              recompute(root);\n              pushHistory();\n              render();\n              pushLog(\"Inserted \" + val + \" to right of \" + cur.value);\n              return n;\n            } else cur = cur.right;\n          }\n        }\n      }\n\n      // Search (non-stepping)\n      function bstSearch(val){\n        let cur = root;\n        let path = [];\n        while(cur){\n          path.push(cur);\n          if(val === cur.value) return {node: cur, path: path};\n          if(val < cur.value) cur = cur.left;\n          else cur = cur.right;\n        }\n        return {node: null, path: path};\n      }\n\n      // Delete (non-stepping)\n      function bstDelete(val){\n        const res = bstSearch(val);\n        const node = res.node;\n        if(!node){\n          pushLog(\"Delete: value not found: \" + val);\n          return null;\n        }\n        const deletedNode = deleteNode(node);\n        recompute(root);\n        pushHistory();\n        render();\n        pushLog(\"Deleted node: \" + val);\n        return deletedNode;\n      }\n\n      function deleteNode(node){\n        if(!node.left && !node.right){\n          // leaf\n          replaceNodeInParent(node, null);\n        } else if(node.left && !node.right){\n          replaceNodeInParent(node, node.left);\n        } else if(!node.left && node.right){\n          replaceNodeInParent(node, node.right);\n        } else {\n          // two children: find successor (min of right)\n          const succ = minNode(node.right);\n          const succVal = succ.value;\n          node.value = succVal;\n          // delete successor\n          deleteNode(succ);\n        }\n        // if root got replaced, update root variable\n      }\n\n      function replaceNodeInParent(node, replacement){\n        if(node.parent){\n          if(node.parent.left === node) node.parent.left = replacement;\n          else node.parent.right = replacement;\n        } else {\n          root = replacement;\n        }\n        if(replacement) replacement.parent = node.parent;\n      }\n\n      function minNode(node){\n        let cur = node;\n        while(cur.left) cur = cur.left;\n        return cur;\n      }\n\n      function maxNode(node){\n        let cur = node;\n        while(cur.right) cur = cur.right;\n        return cur;\n      }\n\n      // Rotations (local)\n      function rotateLeft(x){\n        if(!x || !x.right) { pushLog(\"Rotate left not possible\"); return; }\n        const y = x.right;\n        x.right = y.left;\n        if(y.left) y.left.parent = x;\n        y.parent = x.parent;\n        if(!x.parent) root = y;\n        else if(x === x.parent.left) x.parent.left = y;\n        else x.parent.right = y;\n        y.left = x;\n        x.parent = y;\n        recompute(root);\n        pushHistory();\n        render();\n        pushLog(\"Rotated left at node \" + x.value);\n      }\n      function rotateRight(x){\n        if(!x || !x.left) { pushLog(\"Rotate right not possible\"); return; }\n        const y = x.left;\n        x.left = y.right;\n        if(y.right) y.right.parent = x;\n        y.parent = x.parent;\n        if(!x.parent) root = y;\n        else if(x === x.parent.left) x.parent.left = y;\n        else x.parent.right = y;\n        y.right = x;\n        x.parent = y;\n        recompute(root);\n        pushHistory();\n        render();\n        pushLog(\"Rotated right at node \" + x.value);\n      }\n\n      // Rebuild balanced from sorted array\n      function buildBalancedFromSorted(arr, l=0, r=arr.length-1){\n        if(l>r) return null;\n        const m = Math.floor((l+r)/2);\n        const n = new Node(arr[m]);\n        n.left = buildBalancedFromSorted(arr, l, m-1);\n        if(n.left) n.left.parent = n;\n        n.right = buildBalancedFromSorted(arr, m+1, r);\n        if(n.right) n.right.parent = n;\n        return n;\n      }\n      function rebuildBalanced(){\n        const arr = inorderValues();\n        root = buildBalancedFromSorted(arr);\n        recompute(root);\n        pushHistory();\n        render();\n        pushLog(\"Rebuilt balanced tree from in-order sequence.\");\n      }\n\n      // AVL rebalance: naive approach - perform rotations bottom-up\n      function avlRebalance(){\n        recompute(root);\n        if(!root) return;\n        // collect nodes in post-order and attempt balancing\n        const nodes = [];\n        (function post(node){\n          if(!node) return;\n          post(node.left); post(node.right);\n          nodes.push(node);\n        })(root);\n        for(let node of nodes){\n          recompute(root);\n          const bal = computeBalance(node);\n          if(bal > 1){\n            // left heavy\n            if(computeBalance(node.left) < 0){\n              rotateLeft(node.left);\n            }\n            rotateRight(node);\n          } else if(bal < -1){\n            if(computeBalance(node.right) > 0){\n              rotateRight(node.right);\n            }\n            rotateLeft(node);\n          }\n        }\n        recompute(root);\n        pushHistory();\n        render();\n        pushLog(\"Attempted AVL rebalancing (local rotations).\");\n      }\n\n      // Utility traversals\n      function inorderValues(){\n        const res = [];\n        (function dfs(n){ if(!n) return; dfs(n.left); res.push(n.value); dfs(n.right); })(root);\n        return res;\n      }\n      function inorderNodesArray(){\n        const res = [];\n        (function dfs(n){ if(!n) return; dfs(n.left); res.push(n); dfs(n.right); })(root);\n        return res;\n      }\n      function preorderValues(){\n        const res = [];\n        (function dfs(n){ if(!n) return; res.push(n.value); dfs(n.left); dfs(n.right); })(root);\n        return res;\n      }\n      function postorderValues(){\n        const res = [];\n        (function dfs(n){ if(!n) return; dfs(n.left); dfs(n.right); res.push(n.value); })(root);\n        return res;\n      }\n      function levelorderValues(){\n        const res = [];\n        if(!root) return res;\n        const q = [root];\n        while(q.length){\n          const n = q.shift();\n          res.push(n.value);\n          if(n.left) q.push(n.left);\n          if(n.right) q.push(n.right);\n        }\n        return res;\n      }\n\n      // Subtree info for selected\n      function subtreeValues(node){\n        const res = [];\n        (function dfs(n){ if(!n) return; res.push(n.value); dfs(n.left); dfs(n.right); })(node);\n        return res;\n      }\n      function subtreeSize(node){ return node ? node.size : 0; }\n      function nodeDepth(node){\n        let d = 0; let cur = node;\n        while(cur && cur.parent){ d++; cur = cur.parent; }\n        return d;\n      }\n\n      // Render SVG tree\n      function render(){\n        // clear svg contents\n        while(svg.firstChild) svg.removeChild(svg.firstChild);\n        recompute(root);\n\n        const nodes = [];\n        const positions = {};\n        // compute x by inorder index\n        const arr = inorderNodesArray();\n        for(let i=0;i<arr.length;i++){\n          nodes.push(arr[i]);\n        }\n        const width = svg.clientWidth || 800;\n        const height = svg.clientHeight || 300;\n        const marginX = 10;\n        const marginY = 20;\n        const levels = (root ? root.height + 1 : 1);\n        const levelHeight = Math.max(24, Math.floor((height - 40)/levels));\n        // compute x positions based on inorder index mapping\n        const indexMap = new Map();\n        for(let i=0;i<nodes.length;i++){\n          indexMap.set(nodes[i].id, i);\n        }\n        // BFS to assign positions\n        (function assign(node, depth){\n          if(!node) return;\n          const idx = indexMap.get(node.id) || 0;\n          const x = marginX + (idx+1) * ((width-2*marginX) / (nodes.length+1));\n          const y = marginY + depth * levelHeight;\n          positions[node.id] = {x, y};\n          assign(node.left, depth+1);\n          assign(node.right, depth+1);\n        })(root, 0);\n\n        // draw edges first\n        (function drawEdges(node){\n          if(!node) return;\n          if(node.left){\n            const pa = positions[node.id];\n            const pb = positions[node.left.id];\n            const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n            line.setAttribute(\"x1\", pa.x);\n            line.setAttribute(\"y1\", pa.y);\n            line.setAttribute(\"x2\", pb.x);\n            line.setAttribute(\"y2\", pb.y);\n            line.setAttribute(\"stroke\", \"black\");\n            line.setAttribute(\"stroke-width\", 1);\n            svg.appendChild(line);\n          }\n          if(node.right){\n            const pa = positions[node.id];\n            const pb = positions[node.right.id];\n            const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n            line.setAttribute(\"x1\", pa.x);\n            line.setAttribute(\"y1\", pa.y);\n            line.setAttribute(\"x2\", pb.x);\n            line.setAttribute(\"y2\", pb.y);\n            line.setAttribute(\"stroke\", \"black\");\n            line.setAttribute(\"stroke-width\", 1);\n            svg.appendChild(line);\n          }\n          drawEdges(node.left);\n          drawEdges(node.right);\n        })(root);\n\n        // draw nodes\n        (function drawNodes(node){\n          if(!node) return;\n          const pos = positions[node.id];\n          if(!pos) return;\n          const g = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n          g.setAttribute(\"data-id\", node.id);\n          const circle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n          circle.setAttribute(\"cx\", pos.x);\n          circle.setAttribute(\"cy\", pos.y);\n          circle.setAttribute(\"r\", settings.radius);\n          circle.setAttribute(\"fill\", \"white\");\n          circle.setAttribute(\"stroke\", \"black\");\n          circle.setAttribute(\"stroke-width\", selected === node ? 3 : 1);\n          g.appendChild(circle);\n\n          const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n          text.setAttribute(\"x\", pos.x);\n          text.setAttribute(\"y\", pos.y + 4);\n          text.setAttribute(\"text-anchor\", \"middle\");\n          text.setAttribute(\"font-size\", Math.max(10, settings.radius));\n          text.textContent = String(node.value);\n          g.appendChild(text);\n\n          if(settings.showHeight){\n            const ht = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n            ht.setAttribute(\"x\", pos.x);\n            ht.setAttribute(\"y\", pos.y - settings.radius - 2);\n            ht.setAttribute(\"text-anchor\", \"middle\");\n            ht.setAttribute(\"font-size\", Math.max(8, settings.radius - 6));\n            ht.textContent = \"h:\" + node.height;\n            g.appendChild(ht);\n          }\n\n          if(settings.showBalance){\n            const bf = computeBalance(node);\n            const bfText = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n            bfText.setAttribute(\"x\", pos.x + settings.radius + 8);\n            bfText.setAttribute(\"y\", pos.y - settings.radius - 2);\n            bfText.setAttribute(\"font-size\", Math.max(8, settings.radius - 6));\n            bfText.textContent = \"b:\" + bf;\n            g.appendChild(bfText);\n          }\n\n          // click handler to select\n          g.addEventListener(\"click\", function(evt){\n            evt.stopPropagation();\n            selected = node;\n            updateSelectedInfo();\n            render();\n          });\n\n          svg.appendChild(g);\n          drawNodes(node.left);\n          drawNodes(node.right);\n        })(root);\n\n        updateInfo();\n      }\n\n      function updateInfo(){\n        let s = \"\";\n        s += \"Size: \" + (root ? root.size : 0) + (root ? \"    Height: \" + root.height : \"\") + \"\\n\";\n        s += \"In-order: \" + inorderValues().join(\", \") + \"\\n\";\n        s += \"Pre-order: \" + preorderValues().join(\", \") + \"\\n\";\n        s += \"Post-order: \" + postorderValues().join(\", \") + \"\\n\";\n        s += \"Level-order: \" + levelorderValues().join(\", \") + \"\\n\";\n        if(selected){\n          s += \"\\nSelected node:\\n\";\n          s += \"Value: \" + selected.value + \"  id:\" + selected.id + \"\\n\";\n          s += \"Depth: \" + nodeDepth(selected) + \"\\n\";\n          s += \"Parent: \" + (selected.parent ? selected.parent.value : \"none\") + \"\\n\";\n          s += \"Subtree size: \" + subtreeSize(selected) + \"\\n\";\n          s += \"Subtree values: \" + subtreeValues(selected).join(\", \") + \"\\n\";\n        }\n        infoArea.textContent = s;\n      }\n\n      function updateSelectedInfo(){\n        selectedInfo.textContent = selected ? (selected.value + \" (id:\" + selected.id + \")\") : \"none\";\n      }\n\n      function pushLog(msg){\n        const time = new Date().toLocaleTimeString();\n        const line = \"[\"+time+\"] \" + msg + \"\\n\" + (stepStringFromRoot());\n        stepLog.textContent = line + \"\\n\\n\" + stepLog.textContent;\n      }\n\n      function stepStringFromRoot(){\n        return \"state: size=\" + (root ? root.size : 0) + \"  in-order=[\" + inorderValues().join(\",\") + \"]\";\n      }\n\n      // Stepping / frames. Each frame: {type:'compare'|'move'|'insert'|'delete'|'select', nodeId?, value?, message?}\n      function createInsertionFrames(val){\n        const frames = [];\n        if(!root){\n          frames.push({type:'insert', value: val, message: \"Insert as root\"});\n          return frames;\n        }\n        let cur = root;\n        while(cur){\n          frames.push({type:'select', node: cur.id, message: \"Compare with node \" + cur.value});\n          if(val === cur.value){\n            if(settings.dupMode === 'no'){\n              frames.push({type:'noop', message: \"Duplicate, abort insert\"});\n              return frames;\n            } else if(settings.dupMode === 'left'){\n              frames.push({type:'move', dir:'left', node:cur.id, message: \"Going left for duplicate\"});\n              if(!cur.left){\n                frames.push({type:'insertChild', parent:cur.id, side:'left', value:val, message:\"Insert left duplicate\"});\n                return frames;\n              } else cur = cur.left;\n            } else {\n              frames.push({type:'move', dir:'right', node:cur.id, message: \"Going right for duplicate\"});\n              if(!cur.right){\n                frames.push({type:'insertChild', parent:cur.id, side:'right', value:val, message:\"Insert right duplicate\"});\n                return frames;\n              } else cur = cur.right;\n            }\n          } else if(val < cur.value){\n            frames.push({type:'move', dir:'left', node: cur.id, message: \"Go left\"});\n            if(!cur.left){\n              frames.push({type:'insertChild', parent:cur.id, side:'left', value:val, message:\"Insert as left child\"});\n              return frames;\n            } else cur = cur.left;\n          } else {\n            frames.push({type:'move', dir:'right', node: cur.id, message: \"Go right\"});\n            if(!cur.right){\n              frames.push({type:'insertChild', parent:cur.id, side:'right', value:val, message:\"Insert as right child\"});\n              return frames;\n            } else cur = cur.right;\n          }\n        }\n        return frames;\n      }\n\n      function createSearchFrames(val){\n        const frames = [];\n        let cur = root;\n        while(cur){\n          frames.push({type:'select', node: cur.id, message: \"Compare with node \" + cur.value});\n          if(val === cur.value){\n            frames.push({type:'found', node: cur.id, message: \"Found value\"});\n            return frames;\n          } else if(val < cur.value){\n            frames.push({type:'move', dir:'left', node:cur.id, message: \"Go left\"});\n            cur = cur.left;\n          } else {\n            frames.push({type:'move', dir:'right', node:cur.id, message: \"Go right\"});\n            cur = cur.right;\n          }\n        }\n        frames.push({type:'notfound', message: \"Value not found\"});\n        return frames;\n      }\n\n      function findNodeById(id){\n        if(!id || !root) return null;\n        let found = null;\n        (function dfs(n){\n          if(!n) return;\n          if(n.id === id){ found = n; return; }\n          dfs(n.left); dfs(n.right);\n        })(root);\n        return found;\n      }\n\n      // Execute frame (mutating)\n      function executeFrame(frame){\n        switch(frame.type){\n          case 'select':\n            selected = findNodeById(frame.node) || null;\n            updateSelectedInfo();\n            pushLog(frame.message || (\"Select node \" + frame.node));\n            break;\n          case 'move':\n            selected = findNodeById(frame.node) || null;\n            updateSelectedInfo();\n            pushLog(frame.message || (\"Move from \" + frame.node));\n            break;\n          case 'insert':\n            // as root\n            root = new Node(frame.value);\n            pushLog(frame.message || (\"Inserted root \" + frame.value));\n            break;\n          case 'insertChild':\n            {\n              const parent = findNodeById(frame.parent);\n              if(!parent){ pushLog(\"Parent not found for insertChild\"); break; }\n              const n = new Node(frame.value);\n              if(frame.side === 'left') parent.left = n;\n              else parent.right = n;\n              n.parent = parent;\n              pushLog(frame.message || (\"Inserted child \" + frame.value));\n            }\n            break;\n          case 'found':\n            selected = findNodeById(frame.node) || null;\n            updateSelectedInfo();\n            pushLog(frame.message || \"Found node\");\n            break;\n          case 'notfound':\n            selected = null;\n            updateSelectedInfo();\n            pushLog(frame.message || \"Not found\");\n            break;\n          case 'noop':\n            pushLog(frame.message || \"No operation\");\n            break;\n        }\n        recompute(root);\n        render();\n      }\n\n      // Step queue handling\n      function setSteps(newSteps){\n        steps = newSteps.slice();\n        currentStepIndex = -1;\n        updateStepLogDisplay();\n      }\n      function playSteps(){\n        if(playing) return;\n        playing = true;\n        function stepPlay(){\n          if(!playing) return;\n          if(currentStepIndex+1 >= steps.length){\n            playing = false;\n            pushLog(\"Finished stepping sequence.\");\n            return;\n          }\n          currentStepIndex++;\n          const f = steps[currentStepIndex];\n          executeFrame(f);\n          updateStepLogDisplay();\n          playTimer = setTimeout(stepPlay, settings.speed);\n        }\n        stepPlay();\n      }\n      function pauseSteps(){\n        playing = false;\n        if(playTimer) clearTimeout(playTimer);\n        playTimer = null;\n      }\n      function stepForward(){\n        if(currentStepIndex+1 >= steps.length) return;\n        currentStepIndex++;\n        executeFrame(steps[currentStepIndex]);\n        updateStepLogDisplay();\n      }\n      function stepBack(){\n        // restore from history snapshot before steps started if possible\n        if(history.length === 0) return;\n        // roll back to the state before first step, and then replay up to currentStepIndex-1\n        // For simplicity, when stepping begins, we push a snapshot. We'll assume it's first in history.\n        // Implementation: can't partially revert frames easily; instead, we saved initial snapshot at step creation.\n        if(stepBaseSnapshot){\n          root = deserialize(JSON.parse(stepBaseSnapshot));\n          recompute(root);\n          selected = null;\n          pushHistory();\n          // replay frames up to currentStepIndex-1\n          const target = Math.max(-1, currentStepIndex-1);\n          currentStepIndex = -1;\n          for(let i=0;i<=target;i++){\n            currentStepIndex++;\n            executeFrame(steps[currentStepIndex]);\n          }\n          updateStepLogDisplay();\n        }\n      }\n      function clearSteps(){\n        steps = [];\n        currentStepIndex = -1;\n        stepBaseSnapshot = null;\n        updateStepLogDisplay();\n      }\n\n      let stepBaseSnapshot = null;\n\n      function updateStepLogDisplay(){\n        const arr = steps.map((s,i) => ((i === currentStepIndex) ? \"-> \" : \"   \") + i + \": \" + (s.message || s.type));\n        stepLog.textContent = arr.join(\"\\n\") + \"\\n\\n\" + stepLog.textContent;\n      }\n\n      // Event wiring\n      insertBtn.addEventListener('click', function(){\n        const v = parseValue(valueInput.value);\n        if(v === null) { pushLog(\"Invalid value for insert\"); return; }\n        bstInsert(v);\n      });\n\n      deleteBtn.addEventListener('click', function(){\n        const v = parseValue(valueInput.value);\n        if(v === null) { pushLog(\"Invalid value for delete\"); return; }\n        bstDelete(v);\n      });\n\n      searchBtn.addEventListener('click', function(){\n        const v = parseValue(valueInput.value);\n        if(v === null) { pushLog(\"Invalid value for search\"); return; }\n        const res = bstSearch(v);\n        if(res.node){\n          selected = res.node;\n          updateSelectedInfo();\n          pushLog(\"Search found: \" + v);\n        } else {\n          selected = null;\n          updateSelectedInfo();\n          pushLog(\"Search not found: \" + v);\n        }\n        render();\n      });\n\n      dupMode.addEventListener('change', function(){\n        settings.dupMode = dupMode.value;\n      });\n      speedRange.addEventListener('input', function(){\n        settings.speed = parseInt(speedRange.value, 10);\n      });\n      radiusRange.addEventListener('input', function(){\n        settings.radius = parseInt(radiusRange.value, 10);\n        render();\n      });\n      showHeightCb.addEventListener('change', function(){\n        settings.showHeight = showHeightCb.checked;\n        render();\n      });\n      showBalanceCb.addEventListener('change', function(){\n        settings.showBalance = showBalanceCb.checked;\n        render();\n      });\n\n      stepInsertBtn.addEventListener('click', function(){\n        const v = parseValue(valueInput.value);\n        if(v === null) { pushLog(\"Invalid value for step insert\"); return; }\n        stepBaseSnapshot = snapshotState();\n        setSteps(createInsertionFrames(v));\n        pushLog(\"Prepared step insertion frames for \" + v);\n      });\n\n      stepSearchBtn.addEventListener('click', function(){\n        const v = parseValue(valueInput.value);\n        if(v === null) { pushLog(\"Invalid value for step search\"); return; }\n        stepBaseSnapshot = snapshotState();\n        setSteps(createSearchFrames(v));\n        pushLog(\"Prepared step search frames for \" + v);\n      });\n\n      stepDeleteBtn.addEventListener('click', function(){\n        const v = parseValue(valueInput.value);\n        if(v === null) { pushLog(\"Invalid value for step delete\"); return; }\n        // create frames: search, then delete\n        const searchFrames = createSearchFrames(v);\n        const final = [];\n        final.push(...searchFrames);\n        final.push({type:'noop', message: \"Manual delete will be performed now\"});\n        stepBaseSnapshot = snapshotState();\n        setSteps(final);\n        pushLog(\"Prepared step delete frames for \" + v);\n      });\n\n      playStepsBtn.addEventListener('click', function(){\n        if(steps.length === 0){ pushLog(\"No steps to play\"); return; }\n        playSteps();\n        pushLog(\"Playing steps...\");\n      });\n\n      pauseBtn.addEventListener('click', function(){\n        pauseSteps();\n        pushLog(\"Paused steps.\");\n      });\n\n      stepForwardBtn.addEventListener('click', function(){ stepForward(); });\n      stepBackBtn.addEventListener('click', function(){ stepBack(); });\n      clearStepsBtn.addEventListener('click', function(){ clearSteps(); pushLog(\"Cleared steps.\"); });\n\n      undoBtn.addEventListener('click', function(){ undo(); });\n      redoBtn.addEventListener('click', function(){ redo(); });\n\n      bulkInsertBtn.addEventListener('click', function(){\n        const txt = bulkInput.value.trim();\n        if(!txt) { pushLog(\"Bulk input empty\"); return; }\n        const arr = txt.split(/[\\s,;]+/).map(x => parseValue(x)).filter(x => x!==null);\n        if(arr.length === 0) { pushLog(\"No valid numbers in bulk input\"); return; }\n        for(let v of arr) bstInsert(v);\n        pushLog(\"Bulk inserted \" + arr.length + \" items.\");\n      });\n\n      randBtn.addEventListener('click', function(){\n        const count = clamp(parseInt(randCount.value||0,10),1,200);\n        const lo = parseInt(randMin.value||0,10);\n        const hi = parseInt(randMax.value||0,10);\n        const arr = [];\n        for(let i=0;i<count;i++){\n          const r = Math.floor(Math.random()*(hi-lo+1)) + lo;\n          arr.push(r);\n          bstInsert(r);\n        }\n        pushLog(\"Generated and inserted random \" + count + \" values.\");\n      });\n\n      clearBtn.addEventListener('click', function(){\n        root = null;\n        selected = null;\n        history = [];\n        future = [];\n        steps = [];\n        currentStepIndex = -1;\n        stepBaseSnapshot = null;\n        pushLog(\"Cleared tree and history.\");\n        render();\n      });\n\n      mirrorBtn.addEventListener('click', function(){\n        (function mirror(n){\n          if(!n) return;\n          const t = n.left; n.left = n.right; n.right = t;\n          mirror(n.left); mirror(n.right);\n        })(root);\n        recompute(root);\n        pushHistory();\n        render();\n        pushLog(\"Mirrored (inverted) tree.\");\n      });\n\n      balanceBtn.addEventListener('click', function(){\n        rebuildBalanced();\n      });\n\n      avlRebalanceBtn.addEventListener('click', function(){\n        avlRebalance();\n      });\n\n      deleteSelectedBtn.addEventListener('click', function(){\n        if(!selected){ pushLog(\"No selected node to delete\"); return; }\n        deleteNode(selected);\n        recompute(root);\n        pushHistory();\n        selected = null;\n        render();\n        pushLog(\"Deleted selected node.\");\n      });\n\n      rotateLeftBtn.addEventListener('click', function(){\n        if(!selected){ pushLog(\"No selected node to rotate\"); return; }\n        rotateLeft(selected);\n      });\n      rotateRightBtn.addEventListener('click', function(){\n        if(!selected){ pushLog(\"No selected node to rotate\"); return; }\n        rotateRight(selected);\n      });\n\n      showSubtreeBtn.addEventListener('click', function(){\n        if(!selected){ pushLog(\"No selected node to show subtree\"); return; }\n        pushLog(\"Subtree values: \" + subtreeValues(selected).join(\", \"));\n      });\n\n      kthBtn.addEventListener('click', function(){\n        const k = parseInt(kInput.value||1,10);\n        if(!root){ pushLog(\"Tree empty\"); return; }\n        if(k < 1 || k > root.size){ pushLog(\"k out of range\"); return; }\n        let cur = root;\n        while(cur){\n          const leftSize = cur.left ? cur.left.size : 0;\n          if(k === leftSize + 1){\n            selected = cur;\n            updateSelectedInfo();\n            render();\n            pushLog(k + \"-th smallest = \" + cur.value);\n            return;\n          } else if(k <= leftSize){\n            cur = cur.left;\n          } else {\n            k = k - leftSize - 1;\n            cur = cur.right;\n          }\n        }\n      });\n\n      inorderBtn.addEventListener('click', function(){ pushLog(\"In-order: \" + inorderValues().join(\", \")); });\n      preorderBtn.addEventListener('click', function(){ pushLog(\"Pre-order: \" + preorderValues().join(\", \")); });\n      postorderBtn.addEventListener('click', function(){ pushLog(\"Post-order: \" + postorderValues().join(\", \")); });\n      levelorderBtn.addEventListener('click', function(){ pushLog(\"Level-order: \" + levelorderValues().join(\", \")); });\n      clearLogBtn.addEventListener('click', function(){ stepLog.textContent = \"\"; pushLog(\"Cleared log\"); });\n\n      exportBtn.addEventListener('click', function(){\n        const txt = snapshotState();\n        prompt(\"Copy tree JSON:\", txt);\n      });\n      importBtn.addEventListener('click', function(){\n        const txt = prompt(\"Paste tree JSON:\");\n        if(!txt) return;\n        try{\n          const obj = JSON.parse(txt);\n          root = deserialize(obj);\n          recompute(root);\n          pushHistory();\n          render();\n          pushLog(\"Imported tree from JSON.\");\n        }catch(e){\n          pushLog(\"Import failed: invalid JSON\");\n        }\n      });\n      clearStorageBtn.addEventListener('click', function(){\n        history = []; future = [];\n        pushLog(\"Cleared saved history (only in-memory).\");\n      });\n\n      clearLogBtn.addEventListener('click', function(){\n        stepLog.textContent = \"\";\n      });\n\n      // helper parse value: try integer or raw string if not numeric\n      function parseValue(raw){\n        if(raw === null || raw === undefined) return null;\n        const s = raw.trim();\n        if(s === \"\") return null;\n        // try numeric\n        if(/^[-+]?\\d+$/.test(s)){\n          return parseInt(s,10);\n        }\n        // allow floats\n        if(/^[-+]?\\d*\\.\\d+$/.test(s)){\n          return parseFloat(s);\n        }\n        // otherwise use string\n        return s;\n      }\n\n      // Initialize\n      function init(){\n        settings.dupMode = dupMode.value;\n        settings.speed = parseInt(speedRange.value,10);\n        settings.radius = parseInt(radiusRange.value,10);\n        settings.showHeight = showHeightCb.checked;\n        settings.showBalance = showBalanceCb.checked;\n        render();\n        pushHistory(); // initial state\n        pushLog(\"Initialized BST demo.\");\n        // click background clears selection\n        svg.addEventListener('click', function(){ selected = null; updateSelectedInfo(); render(); });\n      }\n\n      init();\n\n      // expose some functions for debugging\n      window._bst = {\n        rootGetter: () => root,\n        serialize: () => serialize(root),\n        deserialize: (obj) => { root = deserialize(obj); recompute(root); render(); },\n        insert: bstInsert,\n        delete: bstDelete,\n        search: bstSearch,\n        rotateLeft,\n        rotateRight,\n        rebalance: avlRebalance\n      };\n\n    })();\n  </script>\n</body>\n</html>"
