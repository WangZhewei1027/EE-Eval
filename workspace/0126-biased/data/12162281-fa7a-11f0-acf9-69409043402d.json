  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Query Optimization Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 10px;\n  }\n  textarea, input, select, button {\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin: 4px 0;\n    display: block;\n    width: 100%;\n    box-sizing: border-box;\n  }\n  label {\n    margin-top: 10px;\n    display: block;\n  }\n  #output {\n    white-space: pre-wrap;\n    border: 1px solid #000;\n    padding: 4px;\n    margin-top: 10px;\n    height: 250px;\n    overflow-y: scroll;\n  }\n  #planDisplay {\n    font-family: monospace;\n    white-space: pre;\n    border: 1px solid #000;\n    padding: 4px;\n    margin-top: 10px;\n    height: 160px;\n    overflow-y: scroll;\n  }\n  #controls > * {\n    width: auto;\n    display: inline-block;\n    margin-right: 6px;\n  }\n</style>\n</head>\n<body>\n<h1>Query Optimization Interactive Demo</h1>\n<p>\nThis demo lets you explore query optimization concepts interactively with multiple ways to enter queries, manipulate query plans, and simulate optimization steps.\n</p>\n\n<label for=\"queryInput\">Enter SQL SELECT Query (simple tables, JOINs, WHERE, ORDER BY, LIMIT):</label>\n<textarea id=\"queryInput\" rows=\"4\" placeholder=\"SELECT * FROM A JOIN B ON A.id = B.a_id WHERE B.value &gt; 100 ORDER BY A.date LIMIT 10;\"></textarea>\n\n<label for=\"tableSchemas\">Define Table Schemas (one per line, format: TableName(ColumnName:Type,...)):</label>\n<textarea id=\"tableSchemas\" rows=\"6\" placeholder=\"A(id:int,date:text,category:text)\\nB(a_id:int,value:int)\"></textarea>\n\n<div id=\"controls\">\n  <button id=\"parseQueryBtn\">Parse Query</button>\n  <button id=\"generateInitialPlanBtn\" disabled>Generate Initial Plan</button>\n  <button id=\"applyHeuristicBtn\" disabled>Apply Heuristic Optimization</button>\n  <button id=\"applyCostModelBtn\" disabled>Apply Cost-Based Optimization</button>\n  <button id=\"resetDemoBtn\">Reset Demo</button>\n</div>\n\n<label for=\"heuristicLevel\">Heuristic Optimization Level (1-3):</label>\n<input id=\"heuristicLevel\" type=\"range\" min=\"1\" max=\"3\" value=\"1\" disabled />\n\n<label for=\"costModelStrategy\">Cost Model Strategy:</label>\n<select id=\"costModelStrategy\" disabled>\n  <option value=\"simple\">Simple Row Estimation</option>\n  <option value=\"complex\">Complex Cost Heuristic</option>\n</select>\n\n<label for=\"manualTransform\">Manually Pick a Transformation Step (SQL Operator Swap, Predicate Pushdown, Join Reorder, Index Use):</label>\n<select id=\"manualTransform\" disabled>\n  <option value=\"\">--Select one--</option>\n  <option value=\"swap\">Operator Swap (Reorder Joins)</option>\n  <option value=\"pushdown\">Predicate Pushdown (Filters before Joins)</option>\n  <option value=\"joinReorder\">Join Reorder (Enumerate Orders)</option>\n  <option value=\"indexUse\">Index Usage (Simulate Indexes)</option>\n</select>\n<button id=\"applyManualTransform\" disabled>Apply Selected Transformation</button>\n\n<label for=\"explanationText\">Explanation/Notes (editable):</label>\n<textarea id=\"explanationText\" rows=\"4\" placeholder=\"Write your notes or explanation here...\"></textarea>\n\n<h2>Current Query Plan</h2>\n<div id=\"planDisplay\">No plan generated yet.</div>\n\n<h2>Console / Log Output</h2>\n<div id=\"output\">Awaiting user input...</div>\n\n<script>\n(() => {\n  /*\n  High-level flow:\n  1) User inputs SQL and table schemas.\n  2) Parse input SQL into a naive parse tree (very simplified).\n  3) Generate initial logical query plan from parse.\n  4) Allow user to apply heuristic optimizations:\n      - Levels control complexity of heuristic.\n  5) Allow user to apply cost model optimization with chosen strategy.\n  6) Allow manual transformations with detailed feedback/log.\n  7) User can add/edit explanatory text at any time.\n  8) Logging of all steps in the console area.\n\n  Internal representation:\n  We model queries as a simple tree of relational algebra operators:\n  - Scan(table)\n  - Filter(condition)\n  - Join(left, right, condition)\n  - Project(columns)\n  - Sort(order)\n  - Limit(n)\n\n  We'll implement transformation functions:\n  - predicate pushdown\n  - join reorder heuristics\n  - operator swap\n  - index use simulation\n\n  We keep the plan as a JSON-like structure and print it in a readable way.\n  */\n\n  const output = document.getElementById(\"output\");\n  const planDisplay = document.getElementById(\"planDisplay\");\n  const queryInput = document.getElementById(\"queryInput\");\n  const tableSchemasInput = document.getElementById(\"tableSchemas\");\n  const parseQueryBtn = document.getElementById(\"parseQueryBtn\");\n  const generateInitialPlanBtn = document.getElementById(\"generateInitialPlanBtn\");\n  const applyHeuristicBtn = document.getElementById(\"applyHeuristicBtn\");\n  const applyCostModelBtn = document.getElementById(\"applyCostModelBtn\");\n  const resetDemoBtn = document.getElementById(\"resetDemoBtn\");\n  const heuristicLevelInput = document.getElementById(\"heuristicLevel\");\n  const costModelStrategySelect = document.getElementById(\"costModelStrategy\");\n  const manualTransformSelect = document.getElementById(\"manualTransform\");\n  const applyManualTransformBtn = document.getElementById(\"applyManualTransform\");\n  const explanationText = document.getElementById(\"explanationText\");\n\n  let state = {\n    tables: {}, // tableName -> {columns: {colName: type}, indexes: []}\n    parsedQuery: null, // representation of simple parse\n    currentPlan: null, // relational algebra tree\n    heuristicLevel: 1,\n    costModelStrategy: \"simple\",\n    explanation: \"\",\n  };\n\n  // Utility: Log messages to output with timestamp\n  function log(msg) {\n    const now = new Date().toLocaleTimeString();\n    output.textContent += `[${now}] ${msg}\\n`;\n    output.scrollTop = output.scrollHeight;\n  }\n\n  // Simple SQL parser (very limited and fragile) for SELECT queries to parse:\n  // SELECT ... FROM table [JOIN table ON cond]* [WHERE cond] [ORDER BY ...] [LIMIT n]\n  // This is for demonstration only, not full SQL!\n  function simpleSQLParse(sql) {\n    // Remove line breaks and unify spaces\n    let q = sql.replace(/\\s+/g, \" \").trim();\n\n    // We parse out components in order:\n    // 1) Extract SELECT ... FROM ...\n    // 2) Extract JOINs and ON conditions\n    // 3) Extract WHERE\n    // 4) Extract ORDER BY\n    // 5) Extract LIMIT\n\n    let result = {\n      select: null,\n      from: null,\n      joins: [],\n      where: null,\n      orderBy: null,\n      limit: null,\n    };\n\n    // Capitalize keywords for easy regex\n    q = q.replace(/select /i, \"SELECT \")\n      .replace(/ from /i, \" FROM \")\n      .replace(/ join /ig, \" JOIN \")\n      .replace(/ on /ig, \" ON \")\n      .replace(/ where /i, \" WHERE \")\n      .replace(/ order by /i, \" ORDER BY \")\n      .replace(/ limit /i, \" LIMIT \");\n\n    // Extract SELECT part\n    const selectMatch = q.match(/^SELECT (.+?) FROM /);\n    if (!selectMatch) throw Error(\"Can't parse SELECT clause.\");\n    result.select = selectMatch[1].trim();\n\n    // Remove SELECT ... FROM from q\n    q = q.slice(selectMatch[0].length - 5).trim(); // -5 because \" FROM \" included\n\n    // From now parse FROM tableName\n    // Then 0+ JOIN table ON condition\n    // Then optional WHERE condition\n    // Then optional ORDER BY ...\n    // Then optional LIMIT n\n\n    // FROM tableName (tableName is a simple word)\n    let fromMatch = q.match(/^([a-zA-Z0-9_]+)(.*)/);\n    if (!fromMatch) throw Error(\"Can't parse FROM clause.\");\n    result.from = fromMatch[1];\n    q = fromMatch[2].trim();\n\n    // Parse JOINs (zero or more)\n    while (true) {\n      const joinMatch = q.match(/^JOIN ([a-zA-Z0-9_]+) ON ([^ ]+ [=<>!]+ [^ ]+)(.*)/);\n      if (!joinMatch) break;\n      result.joins.push({table: joinMatch[1], condition: joinMatch[2]});\n      q = joinMatch[3].trim();\n    }\n\n    // Parse WHERE, ORDER BY, LIMIT\n    // We'll support them only in this order if present\n\n    if (q.startsWith(\"WHERE \")) {\n      q = q.slice(6).trim();\n      // WHERE ends at ORDER BY or LIMIT or end\n      let whereEnd = q.length;\n      const orderIndex = q.indexOf(\"ORDER BY \");\n      if (orderIndex !== -1 && orderIndex < whereEnd) whereEnd = orderIndex;\n      const limitIndex = q.indexOf(\"LIMIT \");\n      if (limitIndex !== -1 && limitIndex < whereEnd) whereEnd = limitIndex;\n      result.where = q.slice(0, whereEnd).trim();\n      q = q.slice(whereEnd).trim();\n    }\n\n    if (q.startsWith(\"ORDER BY \")) {\n      q = q.slice(9).trim();\n      // ORDER BY ends at LIMIT or end\n      let orderEnd = q.length;\n      const limitIndex = q.indexOf(\"LIMIT \");\n      if (limitIndex !== -1 && limitIndex < orderEnd) orderEnd = limitIndex;\n      result.orderBy = q.slice(0, orderEnd).trim();\n      q = q.slice(orderEnd).trim();\n    }\n\n    if (q.startsWith(\"LIMIT \")) {\n      q = q.slice(6).trim();\n      // LIMIT is last part\n      const spaceIndex = q.indexOf(\" \");\n      if(spaceIndex === -1){\n        result.limit = q;\n        q = \"\";\n      } else {\n        result.limit = q.slice(0, spaceIndex);\n        q = q.slice(spaceIndex).trim();\n      }\n    }\n\n    if (q.length > 0) throw Error(\"Unparsed trailing text in query: \" + q);\n\n    return result;\n  }\n\n  // Parse the table schemas input lines:\n  // e.g. A(id:int,date:text), B(a_id:int,value:int)\n  // Return object: {tableName: {columns: {colName: type}, indexes: []}}\n  function parseSchemas(schemasText) {\n    const lines = schemasText.split(\"\\n\");\n    let tables = {};\n    for (let line of lines) {\n      line = line.trim();\n      if (!line) continue;\n      // Parse TableName(col:type,...)\n      const m = line.match(/^([a-zA-Z0-9_]+)\\((.+)\\)$/);\n      if (!m) throw Error(\"Invalid schema line: \" + line);\n      const tableName = m[1];\n      const colsPart = m[2];\n      let columns = {};\n      const colsItems = colsPart.split(\",\");\n      for (let colItem of colsItems) {\n        const cm = colItem.match(/^([a-zA-Z0-9_]+):([a-zA-Z]+)$/);\n        if (!cm) throw Error(\"Invalid column definition: \" + colItem);\n        columns[cm[1]] = cm[2];\n      }\n      tables[tableName] = {columns: columns, indexes: []};\n    }\n    return tables;\n  }\n\n  // Build initial logical query plan (relational algebra tree) from parsedQuery and schema.\n  // Very naive:\n  // Scan each table -> join them sequentially as per input order -> apply Filters (WHERE and JOIN ON) -> Project(select) -> OrderBy -> Limit\n  //\n  // We parse JOIN and WHERE conditions as strings only (no full condition parsing),\n  // but split out conjuncts for predicate pushdown simulation.\n\n  // Representation of plan nodes:\n  // {type: \"Scan\", table: \"A\"}\n  // {type: \"Filter\", condition: \"...\", input: {...}}\n  // {type: \"Join\", left: {...}, right: {...}, condition: \"...\"}\n  // {type: \"Project\", columns: [...], input: {...}}\n  // {type: \"Sort\", orderBy: \"...\", input: {...}}\n  // {type: \"Limit\", count: N, input: {...}}\n\n  // Utility: splits WHERE or ON condition by AND (simple split by \"AND\" ignoring case)\n  function splitConjuncts(cond) {\n    if (!cond) return [];\n    return cond.split(/ AND /i).map(c => c.trim()).filter(c => c.length > 0);\n  }\n\n  // Create initial plan (no optimization)\n  function createInitialPlan(parsedQuery, tables) {\n    // Scans for FROM and all joined tables\n    // Join conditions are combined later\n\n    let scans = {};\n    try {\n      scans[parsedQuery.from] = {type: \"Scan\", table: parsedQuery.from};\n      for (let join of parsedQuery.joins) {\n        scans[join.table] = {type: \"Scan\", table: join.table};\n      }\n    } catch {\n      throw new Error(\"Error creating Scans.\");\n    }\n\n    // Create JOIN tree - naive left deep join order: from FROM then join tables in order\n\n    // Parse join conditions into array for easier management\n    let joinConds = parsedQuery.joins.map(j => j.condition);\n\n    // Combine all join conditions using AND (for initial plan, put all at top Join)\n    let combinedJoinCondition = joinConds.length > 0 ? joinConds.join(\" AND \") : null;\n\n    // Build join tree left deep (FROM joined with each join.table sequentially)\n\n    let joinTree = scans[parsedQuery.from];\n    for (let join of parsedQuery.joins) {\n      joinTree = {\n        type: \"Join\",\n        left: joinTree,\n        right: scans[join.table],\n        condition: join.condition\n      };\n    }\n\n    // Then apply Filter for WHERE if exists\n    let plan = joinTree;\n    if (parsedQuery.where) {\n      plan = {type: \"Filter\", condition: parsedQuery.where, input: plan};\n    }\n\n    // Then Project\n    // Select list can be \"*\" or list of columns\n    // For our purpose, split select by commas unless \"*\"\n    let selectCols = null;\n    if (parsedQuery.select === \"*\") {\n      selectCols = [\"*\"];\n    } else {\n      selectCols = parsedQuery.select.split(\",\").map(s => s.trim());\n    }\n    plan = {type: \"Project\", columns: selectCols, input: plan};\n\n    // Order By (optional)\n    if (parsedQuery.orderBy) {\n      plan = {type: \"Sort\", orderBy: parsedQuery.orderBy, input: plan};\n    }\n\n    // Limit (optional)\n    if (parsedQuery.limit) {\n      const n = parseInt(parsedQuery.limit, 10);\n      if (isNaN(n) || n < 0) throw new Error(\"Invalid LIMIT operand\");\n      plan = {type: \"Limit\", count: n, input: plan};\n    }\n\n    return plan;\n  }\n\n  // Pretty print plan tree with indentation\n  function printPlan(plan, indent = 0) {\n    const space = \"  \".repeat(indent);\n    if (!plan) return space + \"EMPTY\";\n    let s = \"\";\n    switch (plan.type) {\n      case \"Scan\":\n        s += space + `Scan(${plan.table})`;\n        break;\n      case \"Filter\":\n        s += space + `Filter(condition: ${plan.condition})\\n`;\n        s += printPlan(plan.input, indent + 1);\n        break;\n      case \"Join\":\n        s += space + `Join(condition: ${plan.condition})\\n`;\n        s += printPlan(plan.left, indent + 1) + \"\\n\";\n        s += printPlan(plan.right, indent + 1);\n        break;\n      case \"Project\":\n        s += space + `Project(columns: ${plan.columns.join(\", \")})\\n`;\n        s += printPlan(plan.input, indent + 1);\n        break;\n      case \"Sort\":\n        s += space + `Sort(orderBy: ${plan.orderBy})\\n`;\n        s += printPlan(plan.input, indent + 1);\n        break;\n      case \"Limit\":\n        s += space + `Limit(count: ${plan.count})\\n`;\n        s += printPlan(plan.input, indent + 1);\n        break;\n      default:\n        s += space + `UNKNOWN NODE`;\n    }\n    return s;\n  }\n\n  // Apply Heuristic Optimizations\n  // Levels:\n  // 1: Predicate Pushdown only\n  // 2: Join Reordering heuristic (swap join children if estimated smaller left side)\n  // 3: Combine predicate pushdown + join reorder + simplistic index usage\n  //\n  // Predicate Pushdown: move Filters down closer to Scan if conditions relate only to one table\n  // Join Reordering: reorder join inputs by heuristic (smallest table left)\n\n  // Helper: Determine which tables a condition references (by simple parsing)\n  // We scan for table aliases or table.column patterns.\n  function getTablesInCondition(cond) {\n    if (!cond) return [];\n    let tokens = cond.match(/[a-zA-Z0-9_]+\\.[a-zA-Z0-9_]+/g);\n    if (!tokens) return [];\n    let tables = new Set();\n    for (let t of tokens) {\n      let parts = t.split(\".\");\n      if (parts.length === 2) tables.add(parts[0]);\n    }\n    return Array.from(tables);\n  }\n\n  // Predicate Pushdown implementation:\n  // For each filter condition, if references only one table, push filter down to that table scan subtree\n  function pushdownPredicates(plan, allPredicates) {\n    // allPredicates is array of conditions (from WHERE and JOIN ON conjuncts)\n    // When pushing down, we attach Filters below joins where possible\n\n    // We recursively descend the plan and try to attach predicates near scans of their tables\n\n    // We'll split predicates into:\n    // single-table predicates => push down to that scan\n    // multi-table predicates => remain above joins\n\n    let remainingPreds = [];\n\n    for (let p of allPredicates) {\n      let tables = getTablesInCondition(p);\n      if (tables.length === 1) {\n        // Push down this predicate\n        plan = pushPredicateDown(plan, tables[0], p);\n        log(`Predicate pushdown: pushed condition \"${p}\" towards table \"${tables[0]}\"`);\n      } else {\n        remainingPreds.push(p);\n      }\n    }\n\n    // Remaining predicates are applied as Filter(s) on top\n    if (remainingPreds.length > 0) {\n      plan = {type: \"Filter\", condition: remainingPreds.join(\" AND \"), input: plan};\n    }\n    return plan;\n  }\n\n  // Recursive function to push predicate down to subtree scans for the given tableName\n  function pushPredicateDown(plan, tableName, predicate) {\n    if (!plan) return plan;\n    switch (plan.type) {\n      case \"Scan\":\n        if (plan.table === tableName) {\n          // Insert Filter above Scan if not already filtered by this predicate\n          return {type: \"Filter\", condition: predicate, input: plan};\n        }\n        return plan;\n      case \"Filter\":\n        // descend inside Filter input (do not duplicate predicates)\n        if (plan.condition === predicate) return plan;\n        return {...plan, input: pushPredicateDown(plan.input, tableName, predicate)};\n      case \"Join\":\n        // Push predicate down to left or right branch if table belongs\n        // If table appears on left side, push there else right side else no push\n        // To determine presence, check Scan nodes in subtree\n        if (subtreeHasTable(plan.left, tableName)) {\n          return {...plan, left: pushPredicateDown(plan.left, tableName, predicate)};\n        } else if (subtreeHasTable(plan.right, tableName)) {\n          return {...plan, right: pushPredicateDown(plan.right, tableName, predicate)};\n        } else {\n          // table not found in either side - cannot push down here\n          return plan;\n        }\n      case \"Project\":\n      case \"Sort\":\n      case \"Limit\":\n        return {...plan, input: pushPredicateDown(plan.input, tableName, predicate)};\n      default:\n        return plan;\n    }\n  }\n\n  // Check if subtree contains Scan node for given table name\n  function subtreeHasTable(plan, tableName) {\n    if (!plan) return false;\n    switch (plan.type) {\n      case \"Scan\":\n        return plan.table === tableName;\n      case \"Filter\":\n      case \"Project\":\n      case \"Sort\":\n      case \"Limit\":\n        return subtreeHasTable(plan.input, tableName);\n      case \"Join\":\n        return subtreeHasTable(plan.left, tableName) || subtreeHasTable(plan.right, tableName);\n      default:\n        return false;\n    }\n  }\n\n  // Join reorder heuristic:\n  // Reorder join inputs to put smaller estimated tables left\n  // Estimate sizes: use table row counts = 1000 default, or smaller if filtered heavily\n  // This is a simplistic cost heuristic.\n\n  // To simulate table sizes, we estimate base scans sizes,\n  // Filtering reduces size by factor 10 if predicates applied on table\n  // Joins multiply sizes naively\n\n  // Returns estimated cost of plan subtree (rows)\n  function estimatePlanRows(plan, tables) {\n    if (!plan) return 1;\n    switch (plan.type) {\n      case \"Scan\":\n        return tables[plan.table].rowCount || 1000; // default 1000 rows\n      case \"Filter\":\n        // Apply 10x reduction per predicate approx.\n        let n = estimatePlanRows(plan.input, tables);\n        let preds = splitConjuncts(plan.condition).length;\n        return Math.max(1, Math.floor(n / (10 * preds)));\n      case \"Join\":\n        let leftN = estimatePlanRows(plan.left, tables);\n        let rightN = estimatePlanRows(plan.right, tables);\n        // Join results - simpler heuristic: product * 0.1 of rows\n        return Math.max(1, Math.floor(leftN * rightN * 0.1));\n      case \"Project\":\n      case \"Sort\":\n      case \"Limit\":\n        return estimatePlanRows(plan.input, tables);\n      default:\n        return 1000;\n    }\n  }\n\n  // Reorder joins in plan if possible (left-deep only)\n  // For demo: swap Join.left and Join.right if right subtree has smaller estimated rows.\n  function reorderJoins(plan, tables) {\n    if (!plan) return plan;\n    switch (plan.type) {\n      case \"Join\":\n        let leftRows = estimatePlanRows(plan.left, tables);\n        let rightRows = estimatePlanRows(plan.right, tables);\n        let changed = false;\n        if (rightRows < leftRows) {\n          // Swap children\n          log(`Join reorder: swapping join children to put smaller side left (rows left=${leftRows}, right=${rightRows})`);\n          [plan.left, plan.right] = [plan.right, plan.left];\n          changed = true;\n        }\n        plan.left = reorderJoins(plan.left, tables);\n        plan.right = reorderJoins(plan.right, tables);\n        return plan;\n      case \"Filter\":\n      case \"Project\":\n      case \"Sort\":\n      case \"Limit\":\n        plan.input = reorderJoins(plan.input, tables);\n        return plan;\n      default:\n        return plan;\n    }\n  }\n\n  // Simulate index usage:\n  // For each Scan, if table has indexes on columns used in filter conditions, reduce estimated rows by 10x\n  // We add a property plan.indexUsed = true for indication\n\n  function applyIndexUsage(plan, tables) {\n    if (!plan) return plan;\n    switch (plan.type) {\n      case \"Scan\":\n        // Check if any index could help based on filter applied above this Scan\n        // We'll use a simplistic approach: if a Filter above Scan uses indexed column predicates, mark indexUsed\n        return plan;\n      case \"Filter\":\n        // Check if Filter is directly above Scan and applies predicate on indexed column\n        if (plan.input && plan.input.type === \"Scan\") {\n          let scan = plan.input;\n          let table = tables[scan.table];\n          let indexes = table.indexes;\n          if (!indexes || indexes.length===0) return plan;\n          let preds = splitConjuncts(plan.condition);\n          // For each predicate check if indexed column is involved: search for table.column in predicate\n          for (let pred of preds) {\n            for (let idxCol of indexes) {\n              // Simple check: pred contains table.column or column name\n              if (pred.includes(scan.table + \".\" + idxCol) || pred.includes(idxCol)) {\n                plan.indexUsed = true;\n                log(`Index usage: Using index on ${scan.table}.${idxCol} for predicate \"${pred}\"`);\n                // Mark scan as index used\n                scan.indexUsed = true;\n              }\n            }\n          }\n          // Continue inside input\n          plan.input = applyIndexUsage(plan.input, tables);\n          return plan;\n        } else {\n          plan.input = applyIndexUsage(plan.input, tables);\n          return plan;\n        }\n      case \"Join\":\n        plan.left = applyIndexUsage(plan.left, tables);\n        plan.right = applyIndexUsage(plan.right, tables);\n        return plan;\n      case \"Project\":\n      case \"Sort\":\n      case \"Limit\":\n        plan.input = applyIndexUsage(plan.input, tables);\n        return plan;\n      default:\n        return plan;\n    }\n  }\n\n\n  // Initialize tables with default row counts and no indexes\n  function initializeTables(tables) {\n    for (let tbl in tables) {\n      if (!('rowCount' in tables[tbl])) {\n        tables[tbl].rowCount = 1000;\n      }\n      if (!('indexes' in tables[tbl])) {\n        tables[tbl].indexes = [];\n      }\n    }\n  }\n\n  // Expose functions for UI buttons\n\n  function resetState() {\n    state = {\n      tables: {},\n      parsedQuery: null,\n      currentPlan: null,\n      heuristicLevel: 1,\n      costModelStrategy: \"simple\",\n      explanation: \"\",\n    };\n    output.textContent = \"Demo reset. Enter SQL and table schema to start.\\n\";\n    planDisplay.textContent = \"No plan generated yet.\";\n    generateInitialPlanBtn.disabled = true;\n    applyHeuristicBtn.disabled = true;\n    applyCostModelBtn.disabled = true;\n    heuristicLevelInput.disabled = true;\n    costModelStrategySelect.disabled = true;\n    manualTransformSelect.disabled = true;\n    applyManualTransformBtn.disabled = true;\n    explanationText.value = \"\";\n  }\n\n  // Button: Parse Query\n  parseQueryBtn.addEventListener(\"click\", () => {\n    output.textContent = \"\";\n    try {\n      let schemasText = tableSchemasInput.value.trim();\n      if (!schemasText) {\n        alert(\"Please provide table schemas.\");\n        return;\n      }\n      let parsedSchemas = parseSchemas(schemasText);\n      initializeTables(parsedSchemas);\n      state.tables = parsedSchemas;\n      log(\"Parsed table schemas:\");\n      for (let t in parsedSchemas) {\n        log(` - ${t} (${Object.keys(parsedSchemas[t].columns).join(\", \")})`);\n      }\n      let sql = queryInput.value.trim();\n      if (!sql) {\n        alert(\"Please enter an SQL query.\");\n        return;\n      }\n      let parsed = simpleSQLParse(sql);\n      state.parsedQuery = parsed;\n      log(\"Parsed Query:\");\n      log(JSON.stringify(parsed, null, 2));\n      generateInitialPlanBtn.disabled = false;\n      heuristicLevelInput.disabled = true;\n      applyHeuristicBtn.disabled = true;\n      costModelStrategySelect.disabled = true;\n      applyCostModelBtn.disabled = true;\n      manualTransformSelect.disabled = true;\n      applyManualTransformBtn.disabled = true;\n      planDisplay.textContent = \"Query parsed. Click 'Generate Initial Plan' to continue.\";\n    } catch (e) {\n      alert(\"Error parsing input: \" + e.message);\n      log(\"Error parsing input: \" + e.message);\n    }\n  });\n\n  // Button: Generate Initial Plan\n  generateInitialPlanBtn.addEventListener(\"click\", () => {\n    try {\n      let plan = createInitialPlan(state.parsedQuery, state.tables);\n      state.currentPlan = plan;\n      planDisplay.textContent = printPlan(plan);\n      log(\"Initial query plan generated.\");\n      applyHeuristicBtn.disabled = false;\n      heuristicLevelInput.disabled = false;\n      applyCostModelBtn.disabled = false;\n      costModelStrategySelect.disabled = false;\n      manualTransformSelect.disabled = false;\n      applyManualTransformBtn.disabled = false;\n    } catch (e) {\n      alert(\"Error generating initial plan: \" + e.message);\n      log(\"Error generating initial plan: \" + e.message);\n    }\n  });\n\n  // Button: Apply Heuristic Optimization\n  applyHeuristicBtn.addEventListener(\"click\", () => {\n    if (!state.currentPlan) {\n      alert(\"No plan to optimize. Generate initial plan first.\");\n      return;\n    }\n    let level = parseInt(heuristicLevelInput.value, 10);\n    state.heuristicLevel = level;\n    log(`Applying heuristic optimizations (level ${level})...`);\n\n    let allPreds = [];\n    let pq = state.parsedQuery;\n\n    // Extract all predicates from WHERE and JOIN ON\n    if(pq.where) allPreds.push(pq.where);\n    pq.joins.forEach(j => allPreds.push(j.condition));\n\n    let newPlan = JSON.parse(JSON.stringify(state.currentPlan)); // Deep clone by stringify parse (okay for this demo)\n\n    if(level >= 1){\n      // Predicate pushdown\n      newPlan = pushdownPredicates(newPlan, allPreds);\n      log(\"Predicate pushdown applied.\");\n    }\n    if(level >= 2){\n      // Join reorder\n      newPlan = reorderJoins(newPlan, state.tables);\n      log(\"Join reorder heuristic applied.\");\n    }\n    if(level >= 3){\n      // Index usage simulation: simulate indexes on all primary keys (id columns ending with '_id' or named 'id')\n      for(let t in state.tables){\n        const cols = state.tables[t].columns;\n        let idxCols = [];\n        for(let c in cols){\n          if (c === \"id\" || c.endsWith(\"_id\")){\n            idxCols.push(c);\n          }\n        }\n        state.tables[t].indexes = idxCols;\n        if(idxCols.length > 0){\n          log(`Simulated indexes on table ${t}: ${idxCols.join(\", \")}`);\n        }\n      }\n      newPlan = applyIndexUsage(newPlan, state.tables);\n      log(\"Index usage simulation applied.\");\n    }\n\n    state.currentPlan = newPlan;\n    planDisplay.textContent = printPlan(newPlan);\n    log(\"Heuristic optimization complete.\");\n  });\n\n  // Button: Apply Cost-Based Optimization\n  applyCostModelBtn.addEventListener(\"click\", () => {\n    if (!state.currentPlan) {\n      alert(\"No plan to optimize. Generate initial plan first.\");\n      return;\n    }\n    let strategy = costModelStrategySelect.value;\n    state.costModelStrategy = strategy;\n    log(`Applying cost based optimization with strategy: ${strategy}`);\n\n    // For demo, cost model optimization tries a few join orders and picks lowest cost\n\n    // Extract all join tables and conditions\n    let joins = state.parsedQuery.joins || [];\n    let baseTable = state.parsedQuery.from;\n    let allTables = [baseTable].concat(joins.map(j => j.table));\n\n    // We try all possible join orders (factorial) but limit to max 5 tables (or 3 join steps) for UI responsiveness\n\n    if(allTables.length > 5){\n      log(\"Too many tables for exhaustive join reorder (limit 5). Skipping cost-based reordering.\");\n      return;\n    }\n\n    function buildJoinPlanFromOrder(order) {\n      // Build joins left deep, join conditions combined from parsedQuery for involved tables\n      let plan = {type: \"Scan\", table: order[0]};\n      for(let i=1;i<order.length;++i){\n        // Find join condition between plan subtree tables and order[i]\n        // We pick condition matching order[i]'s join, or fallback to \"TRUE\"\n        let joinCond = null;\n        for(let jjoin of joins){\n          if((jjoin.table === order[i] && order.slice(0,i).includes(state.parsedQuery.from) && order.slice(0,i).includes(jjoin.table) === false) ||\n             (jjoin.table === order[i])){\n            joinCond = jjoin.condition;\n            break;\n          }\n        }\n        if(!joinCond) joinCond = \"TRUE\";\n        plan = {type: \"Join\", left: plan, right: {type: \"Scan\", table: order[i]}, condition: joinCond};\n      }\n      // Add WHERE filter if present\n      if(state.parsedQuery.where){\n        plan = {type:\"Filter\", condition: state.parsedQuery.where, input: plan};\n      }\n      // Project, OrderBy, Limit as before\n      plan = {type:\"Project\", columns: state.parsedQuery.select===\"*\" ? [\"*\"] : state.parsedQuery.select.split(\",\").map(s=>s.trim()), input: plan};\n      if(state.parsedQuery.orderBy) plan = {type:\"Sort\", orderBy: state.parsedQuery.orderBy, input: plan};\n      if(state.parsedQuery.limit) plan = {type:\"Limit\", count:parseInt(state.parsedQuery.limit,10), input: plan};\n      return plan;\n    }\n\n    // Join order permutations (factorial)\n    function permutations(arr) {\n      if(arr.length===0) return [[]];\n      let res = [];\n      for(let i=0;i<arr.length;++i){\n        let rest = [...arr.slice(0,i),...arr.slice(i+1)];\n        for(let p of permutations(rest)) res.push([arr[i]].concat(p));\n      }\n      return res;\n    }\n\n    // Estimate plan cost using estimatePlanRows (approximate cost = estimated rows)\n    let orders = permutations(allTables);\n    let bestPlan = null;\n    let bestCost = Number.MAX_SAFE_INTEGER;\n    for(let order of orders){\n      // For performance, skip obviously bad orders: those that don't start with baseTable?\n      if(order[0] !== baseTable) continue;\n      let pl = buildJoinPlanFromOrder(order);\n      // Heuristic optimization: applies predicate pushdown for cost model\n      pl = pushdownPredicates(pl, splitConjuncts(state.parsedQuery.where || \"\").concat(state.parsedQuery.joins.map(j => j.condition)));\n      let cost = estimatePlanRows(pl, state.tables);\n      if(cost < bestCost){\n        bestCost = cost;\n        bestPlan = pl;\n      }\n    }\n\n    if(bestPlan){\n      state.currentPlan = bestPlan;\n      planDisplay.textContent = printPlan(bestPlan);\n      log(`Cost-based optimization complete. Selected plan cost estimate: ${bestCost}`);\n    } else {\n      log(\"Cost-based optimization did not find better plan.\");\n    }\n  });\n\n  // Button: Apply Manual Transformation\n  applyManualTransformBtn.addEventListener(\"click\", () => {\n    if (!state.currentPlan) {\n      alert(\"No plan to transform. Generate initial plan first.\");\n      return;\n    }\n    let transform = manualTransformSelect.value;\n    if (!transform) {\n      alert(\"Please select a transformation.\");\n      return;\n    }\n    log(`Applying manual transformation: ${transform}`);\n\n    switch(transform){\n      case \"swap\":\n        // Swap top-level Join children if the top node is Join\n        if(state.currentPlan.type===\"Join\"){\n          [state.currentPlan.left, state.currentPlan.right] = [state.currentPlan.right, state.currentPlan.left];\n          log(\"Operator Swap: Top-level join inputs swapped.\");\n        } else {\n          log(\"Operator Swap: Current plan top node is not a Join, cannot swap.\");\n        }\n        break;\n      case \"pushdown\":\n        // Apply one step of predicate pushdown\n        // We'll re-extract predicates and apply pushdown again\n        {\n          let allPreds = [];\n          if(state.parsedQuery.where) allPreds.push(state.parsedQuery.where);\n          state.parsedQuery.joins.forEach(j => allPreds.push(j.condition));\n          state.currentPlan = pushdownPredicates(state.currentPlan, allPreds);\n          log(\"Predicate Pushdown: applied manual pushdown.\");\n        }\n        break;\n      case \"joinReorder\":\n        // Swap joins lower down if possible (try all joins to swap children if beneficial)\n        {\n          function swapIfBetter(node){\n            if(!node) return node;\n            if(node.type===\"Join\"){\n              let leftRows = estimatePlanRows(node.left,state.tables);\n              let rightRows = estimatePlanRows(node.right,state.tables);\n              if(rightRows < leftRows){\n                [node.left,node.right] = [node.right,node.left];\n                log(\"Join Reorder: swapped join children of a join subtree.\");\n              }\n              node.left = swapIfBetter(node.left);\n              node.right = swapIfBetter(node.right);\n            } else if(node.input){\n              node.input = swapIfBetter(node.input);\n            }\n            return node;\n          }\n          state.currentPlan = swapIfBetter(state.currentPlan);\n        }\n        break;\n      case \"indexUse\":\n        // User triggers index usage simulation explicitly\n        for(let t in state.tables){\n          const cols = state.tables[t].columns;\n          let idxCols = [];\n          for(let c in cols){\n            if(c === \"id\" || c.endsWith(\"_id\")){\n              idxCols.push(c);\n            }\n          }\n          state.tables[t].indexes = idxCols;\n          if(idxCols.length>0){\n            log(`Index Usage: Simulated indexes on table ${t}: ${idxCols.join(\", \")}`);\n          }\n        }\n        state.currentPlan = applyIndexUsage(state.currentPlan,state.tables);\n        break;\n      default:\n        log(`Unknown transformation \"${transform}\"`);\n    }\n\n    planDisplay.textContent = printPlan(state.currentPlan);\n  });\n\n  // User edits explanation text\n  explanationText.addEventListener(\"input\", () => {\n    state.explanation = explanationText.value;\n  });\n\n  // Reset Button\n  resetDemoBtn.addEventListener(\"click\", () => {\n    if(confirm(\"Are you sure you want to reset the demo? All current progress will be lost.\")){\n      resetState();\n    }\n  });\n\n  // Initialize\n  resetState();\n\n  // Provide some sample data for user convenience\n  queryInput.value =\n`SELECT A.id, B.value FROM A JOIN B ON A.id = B.a_id WHERE B.value > 100 ORDER BY A.date LIMIT 10;`;\n  tableSchemasInput.value = \n`A(id:int,date:text,category:text)\nB(a_id:int,value:int)`;\n\n})();\n</script>\n</body>\n</html>"
