  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>AVL Tree Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre;\n    line-height: 1.2em;\n  }\n  #output {\n    border: 1px solid black;\n    height: 300px;\n    overflow: auto;\n    font-family: monospace;\n    margin-top: 10px;\n  }\n  #controls > * {\n    margin: 4px 4px 4px 0;\n  }\n  input[type=number] {\n    width: 60px;\n  }\n</style>\n</head>\n<body>\n<h1>AVL Tree Interactive Demo</h1>\n\n<div id=\"controls\">\n  <fieldset>\n    <legend>Insert / Remove / Search</legend>\n    <label for=\"valInput\">Key: </label><input type=\"number\" id=\"valInput\" />\n    <button id=\"insertBtn\">Insert</button>\n    <button id=\"removeBtn\">Remove</button>\n    <button id=\"searchBtn\">Search</button>\n    <button id=\"clearBtn\">Clear Tree</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Traversal / Display</legend>\n    <select id=\"traversalSelect\" aria-label=\"Select Traversal\">\n      <option value=\"inorder\">In-order</option>\n      <option value=\"preorder\">Pre-order</option>\n      <option value=\"postorder\">Post-order</option>\n      <option value=\"levelorder\">Level-order</option>\n    </select>\n    <button id=\"showTraversalBtn\">Show Traversal</button>\n    <button id=\"showTreeBtn\">Show Tree Structure</button>\n    <button id=\"showBalanceBtn\">Show Node Balances</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Bulk Insertion</legend>\n    <label for=\"bulkInput\" title=\"Comma or space separated integers\">Values: </label>\n    <input type=\"text\" id=\"bulkInput\" placeholder=\"e.g. 5,3,7,2\" size=\"30\" />\n    <button id=\"bulkInsertBtn\">Insert All</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Controls</legend>\n    <label for=\"delayRange\" title=\"Animation delay for insert/remove (ms)\">Delay: </label>\n    <input type=\"range\" id=\"delayRange\" min=\"0\" max=\"2000\" step=\"100\" value=\"0\" />\n    <span id=\"delayVal\">0 ms</span>\n    <button id=\"stepBtn\" title=\"Perform one queued step\">Step</button>\n    <button id=\"autoRunBtn\">Auto Run</button>\n    <button id=\"pauseBtn\" disabled>Pause</button>\n    <label>\n      <input type=\"checkbox\" id=\"showStepsCheckbox\" />\n      Show Steps Output\n    </label>\n  </fieldset>\n\n  <fieldset>\n    <legend>Find Min / Max / Height / Size</legend>\n    <button id=\"minBtn\">Find Min</button>\n    <button id=\"maxBtn\">Find Max</button>\n    <button id=\"heightBtn\">Get Height</button>\n    <button id=\"sizeBtn\">Get Size</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Tree Rotations Demo</legend>\n    <button id=\"demoLL\">Demo LL (Right Rotation)</button>\n    <button id=\"demoRR\">Demo RR (Left Rotation)</button>\n    <button id=\"demoLR\">Demo LR (Left-Right Rotation)</button>\n    <button id=\"demoRL\">Demo RL (Right-Left Rotation)</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Node Probe</legend>\n    <label for=\"probeInput\">Key: </label>\n    <input type=\"number\" id=\"probeInput\" />\n    <button id=\"probeBtn\">Show Node Details</button>\n  </fieldset>\n\n</div>\n\n<div id=\"output\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n(function(){\n  'use strict';\n\n  // AVL Node definition\n  class AVLNode {\n    constructor(key) {\n      this.key = key;\n      this.left = null;\n      this.right = null;\n      this.height = 1;\n    }\n  }\n\n  class AVLTree {\n    constructor() {\n      this.root = null;\n    }\n\n    getHeight(node) {\n      return node ? node.height : 0;\n    }\n\n    getBalance(node) {\n      if (!node) return 0;\n      return this.getHeight(node.left) - this.getHeight(node.right);\n    }\n\n    rightRotate(y) {\n      const x = y.left;\n      const T2 = x.right;\n\n      // Perform rotation\n      x.right = y;\n      y.left = T2;\n\n      // Update heights\n      y.height = Math.max(this.getHeight(y.left), this.getHeight(y.right)) + 1;\n      x.height = Math.max(this.getHeight(x.left), this.getHeight(x.right)) + 1;\n\n      return x;\n    }\n\n    leftRotate(x) {\n      const y = x.right;\n      const T2 = y.left;\n\n      // Perform rotation\n      y.left = x;\n      x.right = T2;\n\n      // Update heights\n      x.height = Math.max(this.getHeight(x.left), this.getHeight(x.right)) + 1;\n      y.height = Math.max(this.getHeight(y.left), this.getHeight(y.right)) + 1;\n\n      return y;\n    }\n\n    insert(node, key, steps) {\n      if (!node) {\n        steps.push(`Insert key ${key}: New node created.`);\n        return new AVLNode(key);\n      }\n\n      if (key === node.key) {\n        steps.push(`Insert key ${key}: Key already exists; no insertion.`);\n        return node; // no duplicates allowed\n      } else if (key < node.key) {\n        steps.push(`Insert key ${key}: Descend left from node with key ${node.key}.`);\n        node.left = this.insert(node.left, key, steps);\n      } else {\n        steps.push(`Insert key ${key}: Descend right from node with key ${node.key}.`);\n        node.right = this.insert(node.right, key, steps);\n      }\n\n      // update height\n      node.height = 1 + Math.max(this.getHeight(node.left), this.getHeight(node.right));\n\n      const balance = this.getBalance(node);\n      steps.push(`Check balance at node ${node.key}: ${balance}.`);\n\n      // cases\n      // Left Left\n      if (balance > 1 && key < node.left.key) {\n        steps.push(`Imbalance detected: Left Left case at node ${node.key}. Perform right rotation.`);\n        return this.rightRotate(node);\n      }\n      // Right Right\n      if (balance < -1 && key > node.right.key) {\n        steps.push(`Imbalance detected: Right Right case at node ${node.key}. Perform left rotation.`);\n        return this.leftRotate(node);\n      }\n      // Left Right\n      if (balance > 1 && key > node.left.key) {\n        steps.push(`Imbalance detected: Left Right case at node ${node.key}. Perform left rotation at left child, then right rotation at current node.`);\n        node.left = this.leftRotate(node.left);\n        return this.rightRotate(node);\n      }\n      // Right Left\n      if (balance < -1 && key < node.right.key) {\n        steps.push(`Imbalance detected: Right Left case at node ${node.key}. Perform right rotation at right child, then left rotation at current node.`);\n        node.right = this.rightRotate(node.right);\n        return this.leftRotate(node);\n      }\n\n      return node;\n    }\n\n    minValueNode(node) {\n      let current = node;\n      while (current.left !== null) current = current.left;\n      return current;\n    }\n\n    maxValueNode(node) {\n      let current = node;\n      while (current.right !== null) current = current.right;\n      return current;\n    }\n\n    remove(node, key, steps) {\n      if (!node) {\n        steps.push(`Remove key ${key}: Key not found.`);\n        return node;\n      }\n\n      if (key < node.key) {\n        steps.push(`Remove key ${key}: Descend left from node ${node.key}.`);\n        node.left = this.remove(node.left, key, steps);\n      } else if (key > node.key) {\n        steps.push(`Remove key ${key}: Descend right from node ${node.key}.`);\n        node.right = this.remove(node.right, key, steps);\n      } else {\n        steps.push(`Remove key ${key}: Node found.`);\n\n        // node with one or no child\n        if (!node.left || !node.right) {\n          const temp = node.left ? node.left : node.right;\n          if (!temp) {\n            steps.push(`Node ${node.key} is a leaf; removing it.`);\n            node = null;\n          } else {\n            steps.push(`Node ${node.key} has one child; replacing with the child.`);\n            node = temp;\n          }\n        } else {\n          // node with two children\n          steps.push(`Node ${node.key} has two children; finding inorder successor.`);\n          const temp = this.minValueNode(node.right);\n          steps.push(`Inorder successor is ${temp.key}. Replacing node ${node.key} key with ${temp.key}.`);\n          node.key = temp.key;\n          node.right = this.remove(node.right, temp.key, steps);\n        }\n      }\n\n      // if tree had only one node then return\n      if (!node) return node;\n\n      // update height\n      node.height = 1 + Math.max(this.getHeight(node.left), this.getHeight(node.right));\n\n      const balance = this.getBalance(node);\n      steps.push(`Check balance at node ${node.key} after removal: ${balance}.`);\n\n      // Balancing the node\n      // Left Left\n      if (balance > 1 && this.getBalance(node.left) >= 0) {\n        steps.push(`Imbalance detected: Left Left case at node ${node.key}. Perform right rotation.`);\n        return this.rightRotate(node);\n      }\n      // Left Right\n      if (balance > 1 && this.getBalance(node.left) < 0) {\n        steps.push(`Imbalance detected: Left Right case at node ${node.key}. Perform left rotation at left child, then right rotation.`);\n        node.left = this.leftRotate(node.left);\n        return this.rightRotate(node);\n      }\n      // Right Right\n      if (balance < -1 && this.getBalance(node.right) <= 0) {\n        steps.push(`Imbalance detected: Right Right case at node ${node.key}. Perform left rotation.`);\n        return this.leftRotate(node);\n      }\n      // Right Left\n      if (balance < -1 && this.getBalance(node.right) > 0) {\n        steps.push(`Imbalance detected: Right Left case at node ${node.key}. Perform right rotation at right child, then left rotation.`);\n        node.right = this.rightRotate(node.right);\n        return this.leftRotate(node);\n      }\n\n      return node;\n    }\n\n    search(node, key, path) {\n      if (!node) {\n        path.push(`Key ${key} not found.`);\n        return null;\n      }\n      path.push(`Visiting node ${node.key}.`);\n      if (key === node.key) {\n        path.push(`Found key ${key}.`);\n        return node;\n      }\n      if (key < node.key) {\n        path.push(`Going left.`);\n        return this.search(node.left, key, path);\n      } else {\n        path.push(`Going right.`);\n        return this.search(node.right, key, path);\n      }\n    }\n\n    inorder(node, arr) {\n      if (node) {\n        this.inorder(node.left, arr);\n        arr.push(node.key);\n        this.inorder(node.right, arr);\n      }\n    }\n    preorder(node, arr) {\n      if (node) {\n        arr.push(node.key);\n        this.preorder(node.left, arr);\n        this.preorder(node.right, arr);\n      }\n    }\n    postorder(node, arr) {\n      if (node) {\n        this.postorder(node.left, arr);\n        this.postorder(node.right, arr);\n        arr.push(node.key);\n      }\n    }\n    levelOrder(node, arr) {\n      if (!node) return;\n      let queue = [node];\n      while(queue.length > 0){\n        let size = queue.length;\n        let level = [];\n        for(let i=0;i<size;i++){\n          let n = queue.shift();\n          level.push(n.key);\n          if(n.left) queue.push(n.left);\n          if(n.right) queue.push(n.right);\n        }\n        arr.push(level);\n      }\n    }\n\n    size(node) {\n      if (!node) return 0;\n      return 1 + this.size(node.left) + this.size(node.right);\n    }\n\n    height(node) {\n      return node ? node.height : 0;\n    }\n\n    // Produce a textual structured view of the tree\n    treeString(node, prefix=\"\", isLeft=true) {\n      if (!node) return prefix + (isLeft ? \"└── (null)\\n\" : \"┌── (null)\\n\");\n      let str = \"\";\n      if (node.right) {\n        str += this.treeString(node.right, prefix + (isLeft ? \"│   \" : \"    \"), false);\n      } else {\n        str += prefix + (isLeft ? \"│   \" : \"    \") + \"┌── (null)\\n\";\n      }\n      str += prefix + (isLeft ? \"└── \" : \"┌── \") + node.key + \"\\n\";\n      if (node.left) {\n        str += this.treeString(node.left, prefix + (isLeft ? \"    \" : \"│   \"), true);\n      } else {\n        str += prefix + (isLeft ? \"    \" : \"│   \") + \"└── (null)\\n\";\n      }\n      return str;\n    }\n\n    // Produce a textual view of node keys and their balance factors\n    balanceString(node, prefix = \"\", isLeft = true) {\n      if (!node) return prefix + (isLeft ? \"└── (null)\\n\" : \"┌── (null)\\n\");\n      let str = \"\";\n      if (node.right) {\n        str += this.balanceString(node.right, prefix + (isLeft ? \"│   \" : \"    \"), false);\n      } else {\n        str += prefix + (isLeft ? \"│   \" : \"    \") + \"┌── (null)\\n\";\n      }\n      let bal = this.getBalance(node);\n      str += prefix + (isLeft ? \"└── \" : \"┌── \") + node.key + \" (B: \" + bal + \")\\n\";\n      if (node.left) {\n        str += this.balanceString(node.left, prefix + (isLeft ? \"    \" : \"│   \"), true);\n      } else {\n        str += prefix + (isLeft ? \"    \" : \"│   \") + \"└── (null)\\n\";\n      }\n      return str;\n    }\n  }\n\n  // Utility parse text for bulk insertion\n  function parseBulkInput(text) {\n    let values = text.split(/[\\s,]+/).filter((v)=>v.trim()!=='' );\n    let nums = [];\n    for(let v of values){\n      let n = Number(v);\n      if (!Number.isInteger(n)) return null;\n      nums.push(n);\n    }\n    return nums;\n  }\n\n  // DOM Elements\n  const valInput = document.getElementById('valInput');\n  const insertBtn = document.getElementById('insertBtn');\n  const removeBtn = document.getElementById('removeBtn');\n  const searchBtn = document.getElementById('searchBtn');\n  const clearBtn = document.getElementById('clearBtn');\n\n  const traversalSelect = document.getElementById('traversalSelect');\n  const showTraversalBtn = document.getElementById('showTraversalBtn');\n  const showTreeBtn = document.getElementById('showTreeBtn');\n  const showBalanceBtn = document.getElementById('showBalanceBtn');\n\n  const bulkInput = document.getElementById('bulkInput');\n  const bulkInsertBtn = document.getElementById('bulkInsertBtn');\n\n  const delayRange = document.getElementById('delayRange');\n  const delayVal = document.getElementById('delayVal');\n  const stepBtn = document.getElementById('stepBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const showStepsCheckbox = document.getElementById('showStepsCheckbox');\n\n  const minBtn = document.getElementById('minBtn');\n  const maxBtn = document.getElementById('maxBtn');\n  const heightBtn = document.getElementById('heightBtn');\n  const sizeBtn = document.getElementById('sizeBtn');\n\n  const demoLL = document.getElementById('demoLL');\n  const demoRR = document.getElementById('demoRR');\n  const demoLR = document.getElementById('demoLR');\n  const demoRL = document.getElementById('demoRL');\n\n  const probeInput = document.getElementById('probeInput');\n  const probeBtn = document.getElementById('probeBtn');\n\n  const output = document.getElementById('output');\n\n  // AVL Tree instance\n  const tree = new AVLTree();\n\n  // Step queue for animation and stepping\n  let stepQueue = [];\n  let autoRunInterval = null;\n\n  function outputAppend(text) {\n    if (showStepsCheckbox.checked) {\n      output.textContent += text + \"\\n\";\n      output.scrollTop = output.scrollHeight;\n    }\n  }\n\n  function outputSet(text) {\n    output.textContent = text;\n  }\n\n  // Insert wrapper with steps & optional animation delay\n  function insertKey(key) {\n    stepQueue.push({\n      type: \"insert\",\n      key: key,\n      steps: []\n    });\n    processStepQueue();\n  }\n\n  // Remove wrapper\n  function removeKey(key) {\n    stepQueue.push({\n      type: \"remove\",\n      key: key,\n      steps: []\n    });\n    processStepQueue();\n  }\n\n  // Process one step in the queue, returns true if something processed\n  function processStep() {\n    if (stepQueue.length === 0) return false;\n    let current = stepQueue[0];\n    if (!current.processed) {\n      if (current.type === \"insert\") {\n        current.steps.length = 0;\n        tree.root = tree.insert(tree.root, current.key, current.steps);\n        current.processed = true;\n        outputAppend(`=== Insertion of ${current.key} ===`);\n        current.stepIndex = 0;\n      } else if (current.type === \"remove\") {\n        current.steps.length = 0;\n        tree.root = tree.remove(tree.root, current.key, current.steps);\n        current.processed = true;\n        outputAppend(`=== Removal of ${current.key} ===`);\n        current.stepIndex = 0;\n      }\n    }\n    if (current.stepIndex < current.steps.length) {\n      outputAppend(current.steps[current.stepIndex]);\n      current.stepIndex++;\n      return true;\n    } else {\n      stepQueue.shift();\n      return processStep(); // immediately run next if any steps remain\n    }\n  }\n\n  // Process full queue at once with no delay\n  function processAllSteps() {\n    while(stepQueue.length > 0){\n      let current = stepQueue.shift();\n      if (current.type === \"insert\") {\n        current.steps.length = 0;\n        tree.root = tree.insert(tree.root, current.key, current.steps);\n        outputAppend(`=== Insertion of ${current.key} ===`);\n      } else if (current.type === \"remove\") {\n        current.steps.length = 0;\n        tree.root = tree.remove(tree.root, current.key, current.steps);\n        outputAppend(`=== Removal of ${current.key} ===`);\n      }\n      for(let s of current.steps){\n        outputAppend(s);\n      }\n    }\n  }\n\n  // Process Step Queue with delay given by slider\n  function processStepQueue() {\n    if (autoRunInterval) return;\n\n    let delay = +delayRange.value;\n    if (delay === 0) {\n      processAllSteps();\n    } else {\n      stepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      pauseBtn.disabled = false;\n      // Run automatically with delay\n      autoRunInterval = setInterval(()=>{\n        let somethingDone = false;\n        if (stepQueue.length > 0){\n          let current = stepQueue[0];\n          if (!current.processed) {\n            current.steps.length = 0;\n            if (current.type === \"insert\") {\n              tree.root = tree.insert(tree.root, current.key, current.steps);\n            } else if (current.type === \"remove\") {\n              tree.root = tree.remove(tree.root, current.key, current.steps);\n            }\n            outputAppend(`=== ${current.type === \"insert\" ? 'Insertion' : 'Removal'} of ${current.key} ===`);\n            current.processed = true;\n            current.stepIndex=0;\n          }\n          if(current.stepIndex < current.steps.length) {\n            outputAppend(current.steps[current.stepIndex]);\n            current.stepIndex++;\n            somethingDone = true;\n          } else {\n            stepQueue.shift();\n            somethingDone = true;\n          }\n        } else {\n          clearInterval(autoRunInterval);\n          autoRunInterval = null;\n          outputAppend('All steps complete.');\n          stepBtn.disabled = false;\n          autoRunBtn.disabled = false;\n          pauseBtn.disabled = true;\n        }\n      }, delay);\n    }\n  }\n\n  // Single step function for manual stepping\n  function stepOnce() {\n    if (autoRunInterval) {\n      // Do nothing if auto running\n      return;\n    }\n    if (stepQueue.length === 0) {\n      outputAppend(\"No actions in queue.\");\n      return;\n    }\n    const current = stepQueue[0];\n    if (!current.processed) {\n      current.steps.length = 0;\n      if (current.type === \"insert\") {\n        tree.root = tree.insert(tree.root, current.key, current.steps);\n      } else if (current.type === \"remove\") {\n        tree.root = tree.remove(tree.root, current.key, current.steps);\n      }\n      outputAppend(`=== ${current.type === \"insert\" ? 'Insertion' : 'Removal'} of ${current.key} ===`);\n      current.processed = true;\n      current.stepIndex=0;\n    }\n    if (current.stepIndex < current.steps.length) {\n      outputAppend(current.steps[current.stepIndex]);\n      current.stepIndex++;\n    } else {\n      stepQueue.shift();\n      if (stepQueue.length === 0) {\n        outputAppend(\"All steps processed.\");\n      }\n    }\n  }\n\n  // Auto run button press\n  function autoRun() {\n    if (autoRunInterval) return; // already running\n    processStepQueue();\n  }\n\n  // Pause button press\n  function pause() {\n    if(autoRunInterval){\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n      outputAppend(\"Auto run paused.\");\n      stepBtn.disabled = false;\n      autoRunBtn.disabled = false;\n      pauseBtn.disabled = true;\n    }\n  }\n\n  // Show traversal outputs\n  function showTraversal() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    let arr = [];\n    let t = traversalSelect.value;\n    if (t === \"inorder\") {\n      tree.inorder(tree.root, arr);\n      outputSet(\"Inorder traversal:\\n\" + arr.join(\" \"));\n    } else if (t === \"preorder\") {\n      tree.preorder(tree.root, arr);\n      outputSet(\"Preorder traversal:\\n\" + arr.join(\" \"));\n    } else if (t === \"postorder\") {\n      tree.postorder(tree.root, arr);\n      outputSet(\"Postorder traversal:\\n\" + arr.join(\" \"));\n    } else if (t === \"levelorder\") {\n      tree.levelOrder(tree.root, arr);\n      let lines = arr.map(level => level.join(\" \"));\n      outputSet(\"Level-order traversal:\\n\" + lines.join(\"\\n\"));\n    }\n  }\n\n  // Show tree structure in textual form\n  function showTreeStructure() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    let str = \"Tree structure (rotated - root center):\\n\";\n    str += tree.treeString(tree.root);\n    outputSet(str);\n  }\n\n  // Show node balances along with tree structure\n  function showBalances() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    let str = \"Tree structure with balance factors (B):\\n\";\n    str += tree.balanceString(tree.root);\n    outputSet(str);\n  }\n\n  // Find min key\n  function showMin() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    let node = tree.minValueNode(tree.root);\n    outputSet(\"Minimum key: \" + node.key);\n  }\n\n  // Find max key\n  function showMax() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    let node = tree.maxValueNode(tree.root);\n    outputSet(\"Maximum key: \" + node.key);\n  }\n\n  // Show height (root height = height of tree)\n  function showHeight() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    outputSet(\"Tree height: \" + tree.height(tree.root));\n  }\n\n  // Show size (number of nodes)\n  function showSize() {\n    if (!tree.root) {\n      outputSet(\"Tree is empty.\");\n      return;\n    }\n    outputSet(\"Tree size (number of nodes): \" + tree.size(tree.root));\n  }\n\n  // Show node details by key probe\n  function probeNode() {\n    const key = parseInt(probeInput.value, 10);\n    if (Number.isNaN(key)) {\n      outputSet(\"Input is not a valid integer.\");\n      return;\n    }\n    let path = [];\n    let node = tree.search(tree.root, key, path);\n    outputSet(\"Node probe path:\\n\" + path.join(\"\\n\") + \"\\n\\n\" +\n      (node ? `Node details:\\nKey: ${node.key}\\nHeight: ${node.height}\\nBalance factor: ${tree.getBalance(node)}\\nLeft child: ${node.left ? node.left.key : 'null'}\\nRight child: ${node.right ? node.right.key : 'null'}` : \"Node not found in tree.\"));\n  }\n\n  // Demo insertions for rotations\n  function demoLLRotation() {\n    // Clear tree, then insert to produce LL imbalance => right rotation\n    tree.root = null;\n    stepQueue.length = 0;\n    outputSet(\"Demo LL rotation:\\nInserting 30, 20, 10 to trigger LL imbalance.\");\n    stepQueue.push({type:\"insert\", key:30, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:20, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:10, steps:[], processed:false});\n    processStepQueue();\n  }\n\n  function demoRRRotation() {\n    tree.root = null;\n    stepQueue.length = 0;\n    outputSet(\"Demo RR rotation:\\nInserting 10, 20, 30 to trigger RR imbalance.\");\n    stepQueue.push({type:\"insert\", key:10, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:20, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:30, steps:[], processed:false});\n    processStepQueue();\n  }\n\n  function demoLRRotation() {\n    tree.root = null;\n    stepQueue.length = 0;\n    outputSet(\"Demo LR rotation:\\nInserting 30, 10, 20 to trigger LR imbalance.\");\n    stepQueue.push({type:\"insert\", key:30, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:10, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:20, steps:[], processed:false});\n    processStepQueue();\n  }\n\n  function demoRLRotation() {\n    tree.root = null;\n    stepQueue.length = 0;\n    outputSet(\"Demo RL rotation:\\nInserting 10, 30, 20 to trigger RL imbalance.\");\n    stepQueue.push({type:\"insert\", key:10, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:30, steps:[], processed:false});\n    stepQueue.push({type:\"insert\", key:20, steps:[], processed:false});\n    processStepQueue();\n  }\n\n  // Event listeners\n\n  insertBtn.addEventListener('click', () => {\n    const key = parseInt(valInput.value, 10);\n    if (Number.isNaN(key)) {\n      outputSet(\"Insert: Please input a valid integer.\");\n      return;\n    }\n    insertKey(key);\n    valInput.value = \"\";\n  });\n\n  removeBtn.addEventListener('click', () => {\n    const key = parseInt(valInput.value, 10);\n    if (Number.isNaN(key)) {\n      outputSet(\"Remove: Please input a valid integer.\");\n      return;\n    }\n    removeKey(key);\n    valInput.value = \"\";\n  });\n\n  searchBtn.addEventListener('click', () => {\n    const key = parseInt(valInput.value, 10);\n    if (Number.isNaN(key)) {\n      outputSet(\"Search: Please input a valid integer.\");\n      return;\n    }\n    let path = [];\n    let node = tree.search(tree.root, key, path);\n    outputSet(\"Search path:\\n\" + path.join(\"\\n\") + \"\\n\\n\" +\n      (node ? `Key ${key} found in tree.` : `Key ${key} not found.`));\n    valInput.value = \"\";\n  });\n\n  clearBtn.addEventListener('click', () => {\n    tree.root = null;\n    stepQueue.length = 0;\n    outputSet(\"Tree has been cleared.\");\n  });\n\n  showTraversalBtn.addEventListener('click', () => {\n    showTraversal();\n  });\n\n  showTreeBtn.addEventListener('click', () => {\n    showTreeStructure();\n  });\n\n  showBalanceBtn.addEventListener('click', () => {\n    showBalances();\n  });\n\n  bulkInsertBtn.addEventListener('click', () => {\n    let nums = parseBulkInput(bulkInput.value);\n    if (!nums) {\n      outputSet(\"Bulk Insert: Input must be space or comma separated integers only.\");\n      return;\n    }\n    for(let n of nums){\n      stepQueue.push({type:\"insert\", key: n, steps: [], processed:false});\n    }\n    bulkInput.value = \"\";\n    processStepQueue();\n  });\n\n  delayRange.addEventListener('input', () => {\n    delayVal.textContent = delayRange.value + \" ms\";\n  });\n\n  stepBtn.addEventListener('click', () => {\n    stepOnce();\n  });\n\n  autoRunBtn.addEventListener('click', () => {\n    autoRun();\n  });\n\n  pauseBtn.addEventListener('click', () => {\n    pause();\n  });\n\n  minBtn.addEventListener('click', () => {\n    showMin();\n  });\n\n  maxBtn.addEventListener('click', () => {\n    showMax();\n  });\n\n  heightBtn.addEventListener('click', () => {\n    showHeight();\n  });\n\n  sizeBtn.addEventListener('click', () => {\n    showSize();\n  });\n\n  demoLL.addEventListener('click', () => {\n    demoLLRotation();\n  });\n\n  demoRR.addEventListener('click', () => {\n    demoRRRotation();\n  });\n\n  demoLR.addEventListener('click', () => {\n    demoLRRotation();\n  });\n\n  demoRL.addEventListener('click', () => {\n    demoRLRotation();\n  });\n\n  probeBtn.addEventListener('click', () => {\n    probeNode();\n  });\n\n  // Initialize UI display for delay\n  delayVal.textContent = delayRange.value + \" ms\";\n})();\n</script>\n\n</body>\n</html>"
