  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Integration Testing Playground</title>\n  <style>\n    /* Minimal plain layout. No colors, no animations. */\n    html,body { height:100%; margin:0; font-family: Arial, sans-serif; font-size:13px; color:black; background:white; }\n    .app { display:flex; height:100vh; gap:8px; padding:8px; box-sizing:border-box; }\n    .pane { border:1px solid #ccc; padding:8px; box-sizing:border-box; overflow:auto; }\n    .left { width:260px; flex-shrink:0; }\n    .center { flex:1 1 520px; }\n    .right { width:420px; flex-shrink:0; }\n    h1 { font-size:16px; margin:0 0 8px 0; }\n    label { display:block; margin-top:6px; }\n    input[type=\"text\"], input[type=\"number\"], select, textarea { width:100%; box-sizing:border-box; padding:4px; margin-top:4px; }\n    textarea { height:120px; resize:vertical; font-family:monospace; }\n    .steps { margin-top:8px; }\n    .step { border-top:1px dashed #ddd; padding:6px 0; }\n    .controls { margin-top:8px; display:flex; gap:6px; flex-wrap:wrap; align-items:center; }\n    button { padding:6px 10px; }\n    .small { padding:4px 8px; font-size:12px; }\n    .muted { font-size:12px; color:#666; }\n    pre.log { height:240px; overflow:auto; background:transparent; border:1px solid #ddd; padding:6px; white-space:pre-wrap; font-family:monospace; }\n    .kv { font-family:monospace; background:transparent; border:1px solid #ddd; padding:6px; min-height:120px; white-space:pre-wrap; }\n    .row { display:flex; gap:6px; align-items:center; }\n    .row > * { margin:0; }\n    .split { display:flex; gap:6px; }\n    .flexcol { display:flex; flex-direction:column; gap:6px; }\n    .step-actions { display:flex; gap:4px; margin-top:6px; }\n    .checkbox-inline { display:inline-flex; align-items:center; gap:6px; margin-left:6px; }\n    .inline { display:inline-block; }\n    .wide { width:100%; }\n  </style>\n</head>\n<body>\n  <div class=\"app\" role=\"application\" aria-label=\"Integration Testing Playground\">\n    <div class=\"pane left\" aria-label=\"Suite and Test Manager\">\n      <h1>Integration Testing</h1>\n      <div>\n        <label>Suites\n          <select id=\"suiteSelect\"></select>\n        </label>\n        <div class=\"controls\">\n          <button id=\"newSuiteBtn\">New Suite</button>\n          <button id=\"deleteSuiteBtn\" class=\"small\">Delete</button>\n        </div>\n        <label>Tests\n          <select id=\"testSelect\"></select>\n        </label>\n        <div class=\"controls\">\n          <button id=\"newTestBtn\">New Test</button>\n          <button id=\"deleteTestBtn\" class=\"small\">Delete</button>\n        </div>\n        <label>Quick Actions</label>\n        <div class=\"controls\">\n          <button id=\"importBtn\">Import JSON</button>\n          <button id=\"exportBtn\">Export JSON</button>\n          <button id=\"loadSampleBtn\">Load Sample</button>\n        </div>\n        <label>Fuzzer / Randomizer</label>\n        <div class=\"controls\">\n          <label class=\"inline\">Seed <input id=\"seedInput\" type=\"number\" value=\"1\" style=\"width:90px\"></label>\n          <label class=\"inline\">Paths <input id=\"fuzzPaths\" type=\"number\" value=\"10\" style=\"width:80px\"></label>\n          <button id=\"runFuzzerBtn\">Run Fuzzer</button>\n        </div>\n      </div>\n      <div style=\"margin-top:10px;\">\n        <label>Parallel Runs\n          <input id=\"parallelRuns\" type=\"number\" min=\"1\" value=\"1\" />\n        </label>\n        <label>Worker Speed (ms)\n          <input id=\"workerSpeed\" type=\"number\" min=\"0\" value=\"200\" />\n        </label>\n        <label>Auto-reset state before run\n          <input id=\"autoReset\" type=\"checkbox\" checked />\n        </label>\n      </div>\n      <div style=\"margin-top:10px;\">\n        <label>Persist / Sharing</label>\n        <div class=\"controls\">\n          <button id=\"copyJson\">Copy JSON</button>\n          <button id=\"downloadJson\">Download</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"pane center\" aria-label=\"Test Builder and Editor\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <div>\n          <label>Suite Name\n            <input id=\"suiteName\" type=\"text\">\n          </label>\n          <label>Test Name\n            <input id=\"testName\" type=\"text\">\n          </label>\n        </div>\n        <div style=\"text-align:right;\">\n          <label>Run Controls</label>\n          <div class=\"controls\">\n            <button id=\"runBtn\">Run</button>\n            <button id=\"stepBtn\">Step</button>\n            <button id=\"pauseBtn\">Pause</button>\n            <button id=\"stopBtn\">Stop</button>\n            <button id=\"rewindBtn\">Rewind</button>\n          </div>\n          <div class=\"controls\" style=\"margin-top:4px;\">\n            <label class=\"inline\">Speed <input id=\"speed\" type=\"range\" min=\"0\" max=\"1000\" value=\"200\" style=\"width:140px\"></label>\n            <label class=\"inline\">Breakpoint <input id=\"breakpointToggle\" type=\"checkbox\"></label>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"controls\" style=\"margin-top:8px;\">\n        <button id=\"addStepBtn\">Add Step</button>\n        <button id=\"insertStepBtn\">Insert Step at Cursor</button>\n        <button id=\"duplicateStepBtn\">Duplicate Step</button>\n        <button id=\"clearStepsBtn\">Clear Steps</button>\n      </div>\n\n      <div class=\"steps\" id=\"stepsContainer\" aria-live=\"polite\"></div>\n\n      <div style=\"margin-top:10px;\">\n        <label>Test-level Variables (initial state as JSON)</label>\n        <textarea id=\"initialVars\" placeholder='{\"count\":0,\"status\":\"idle\"}'></textarea>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <label>Notes / Description</label>\n        <textarea id=\"testNotes\" placeholder=\"Test description...\"></textarea>\n      </div>\n    </div>\n\n    <div class=\"pane right\" aria-label=\"Execution and State\">\n      <h2 style=\"font-size:14px;margin:0 0 8px 0;\">Execution</h2>\n\n      <div class=\"controls\">\n        <label>Worker Count\n          <input id=\"workers\" type=\"number\" min=\"1\" value=\"1\" />\n        </label>\n        <label>Run Until Breakpoint\n          <input id=\"runToBreakpoint\" type=\"checkbox\" />\n        </label>\n        <button id=\"stopAllBtn\">Stop All</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>Live Log</label>\n        <pre id=\"log\" class=\"log\"></pre>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>State (current)</label>\n        <pre id=\"stateView\" class=\"kv\"></pre>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>History Snapshots</label>\n        <div id=\"snapshots\" style=\"max-height:140px; overflow:auto; border:1px solid #ddd; padding:6px; font-family:monospace;\"></div>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>Assertions Summary</label>\n        <div id=\"assertSummary\" class=\"muted\">No runs yet</div>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    // Integration Testing Playground - heavy interactivity, plain visuals.\n\n    // Utility: deep clone\n    function deepClone(v){ return JSON.parse(JSON.stringify(v)); }\n\n    // Simple seeded RNG (mulberry32)\n    function makeRNG(seed){\n      let t = seed >>> 0;\n      return function(){\n        t += 0x6D2B79F5;\n        let r = Math.imul(t ^ t >>> 15, 1 | t);\n        r ^= r + Math.imul(r ^ r >>> 7, 61 | r);\n        return ((r ^ r >>> 14) >>> 0) / 4294967296;\n      };\n    }\n\n    // Model\n    let model = {\n      suites: [],\n      activeSuiteIndex: -1,\n      activeTestIndex: -1\n    };\n\n    // Execution engine supports parallel workers\n    let engine = {\n      running: false,\n      paused: false,\n      workers: [],\n      runIdSeq: 1\n    };\n\n    // DOM refs\n    const suiteSelect = document.getElementById('suiteSelect');\n    const testSelect = document.getElementById('testSelect');\n    const suiteName = document.getElementById('suiteName');\n    const testName = document.getElementById('testName');\n    const stepsContainer = document.getElementById('stepsContainer');\n    const initialVarsInput = document.getElementById('initialVars');\n    const testNotes = document.getElementById('testNotes');\n    const logEl = document.getElementById('log');\n    const stateView = document.getElementById('stateView');\n    const snapshotsEl = document.getElementById('snapshots');\n    const assertSummary = document.getElementById('assertSummary');\n    const speedInput = document.getElementById('speed');\n    const runBtn = document.getElementById('runBtn');\n    const stepBtn = document.getElementById('stepBtn');\n    const pauseBtn = document.getElementById('pauseBtn');\n    const stopBtn = document.getElementById('stopBtn');\n    const rewindBtn = document.getElementById('rewindBtn');\n    const addStepBtn = document.getElementById('addStepBtn');\n    const insertStepBtn = document.getElementById('insertStepBtn');\n    const duplicateStepBtn = document.getElementById('duplicateStepBtn');\n    const clearStepsBtn = document.getElementById('clearStepsBtn');\n    const seedInput = document.getElementById('seedInput');\n    const fuzzPaths = document.getElementById('fuzzPaths');\n    const runFuzzerBtn = document.getElementById('runFuzzerBtn');\n    const parallelRuns = document.getElementById('parallelRuns');\n    const workerSpeed = document.getElementById('workerSpeed');\n    const autoReset = document.getElementById('autoReset');\n    const newSuiteBtn = document.getElementById('newSuiteBtn');\n    const deleteSuiteBtn = document.getElementById('deleteSuiteBtn');\n    const newTestBtn = document.getElementById('newTestBtn');\n    const deleteTestBtn = document.getElementById('deleteTestBtn');\n    const exportBtn = document.getElementById('exportBtn');\n    const importBtn = document.getElementById('importBtn');\n    const loadSampleBtn = document.getElementById('loadSampleBtn');\n    const copyJsonBtn = document.getElementById('copyJson');\n    const downloadJsonBtn = document.getElementById('downloadJson');\n    const workersInput = document.getElementById('workers');\n    const stopAllBtn = document.getElementById('stopAllBtn');\n    const breakpointToggle = document.getElementById('breakpointToggle');\n    const runToBreakpoint = document.getElementById('runToBreakpoint');\n\n    // Helpers\n    function log(msg){\n      const time = new Date().toISOString().slice(11,23);\n      logEl.textContent += `[${time}] ${msg}\\n`;\n      logEl.scrollTop = logEl.scrollHeight;\n    }\n\n    function resetLog(){\n      logEl.textContent = '';\n    }\n\n    function updateSuiteTestSelectors(){\n      // update suite select\n      suiteSelect.innerHTML = '';\n      model.suites.forEach((s,i)=>{\n        const opt = document.createElement('option');\n        opt.value = i;\n        opt.textContent = s.name || `Suite ${i+1}`;\n        suiteSelect.appendChild(opt);\n      });\n      if(model.activeSuiteIndex >= model.suites.length) model.activeSuiteIndex = model.suites.length - 1;\n      suiteSelect.value = model.activeSuiteIndex >=0 ? model.activeSuiteIndex : '';\n      // update tests\n      refreshActiveSelections();\n    }\n\n    function refreshActiveSelections(){\n      testSelect.innerHTML = '';\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite){\n        suiteName.value = '';\n        testName.value = '';\n        stepsContainer.innerHTML = '';\n        initialVarsInput.value = '{}';\n        testNotes.value = '';\n        return;\n      }\n      suiteName.value = suite.name || '';\n      suite.tests.forEach((t,ti)=>{\n        const opt = document.createElement('option');\n        opt.value = ti;\n        opt.textContent = t.name || `Test ${ti+1}`;\n        testSelect.appendChild(opt);\n      });\n      if(model.activeTestIndex >= suite.tests.length) model.activeTestIndex = suite.tests.length - 1;\n      testSelect.value = model.activeTestIndex >=0 ? model.activeTestIndex : '';\n      renderTestEditor();\n    }\n\n    function renderTestEditor(){\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite || model.activeTestIndex < 0){ stepsContainer.innerHTML=''; initialVarsInput.value='{}'; testName.value=''; testNotes.value=''; return; }\n      const test = suite.tests[model.activeTestIndex];\n      testName.value = test.name || '';\n      initialVarsInput.value = JSON.stringify(test.initialVars || {}, null, 2);\n      testNotes.value = test.notes || '';\n      // Render steps\n      stepsContainer.innerHTML = '';\n      test.steps.forEach((step, idx) => {\n        const div = document.createElement('div');\n        div.className = 'step';\n        div.dataset.index = idx;\n        const header = document.createElement('div');\n        header.style.display = 'flex';\n        header.style.justifyContent = 'space-between';\n        header.style.alignItems = 'center';\n        header.innerHTML = `<div><strong>#${idx+1}</strong> <span class=\"muted\">${step.type}</span> - <span class=\"muted\">${step.title||''}</span></div>`;\n        const actions = document.createElement('div');\n        actions.innerHTML = `\n          <button class=\"small editBtn\">Edit</button>\n          <button class=\"small upBtn\">↑</button>\n          <button class=\"small downBtn\">↓</button>\n          <button class=\"small dupBtn\">Dup</button>\n          <button class=\"small delBtn\">Del</button>\n          <label class=\"checkbox-inline small\">BP <input type=\"checkbox\" class=\"bpChk\"></label>\n        `;\n        header.appendChild(actions);\n        div.appendChild(header);\n\n        const details = document.createElement('div');\n        details.style.marginTop='6px';\n        details.innerHTML = `<div><em class=\"muted\">${step.description || ''}</em></div>`;\n        div.appendChild(details);\n\n        stepsContainer.appendChild(div);\n\n        // wire buttons\n        const editBtn = div.querySelector('.editBtn');\n        const upBtn = div.querySelector('.upBtn');\n        const downBtn = div.querySelector('.downBtn');\n        const delBtn = div.querySelector('.delBtn');\n        const dupBtn = div.querySelector('.dupBtn');\n        const bpChk = div.querySelector('.bpChk');\n\n        bpChk.checked = !!step.breakpoint;\n\n        editBtn.onclick = ()=>openStepEditor(idx);\n        upBtn.onclick = ()=>{ moveStep(idx, idx-1); };\n        downBtn.onclick = ()=>{ moveStep(idx, idx+1); };\n        delBtn.onclick = ()=>{ deleteStep(idx); };\n        dupBtn.onclick = ()=>{ duplicateStep(idx); };\n        bpChk.onchange = (e)=>{ step.breakpoint = e.target.checked; saveModel(); };\n      });\n\n      // select first step editor by default\n    }\n\n    function openStepEditor(index){\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) return;\n      const test = suite.tests[model.activeTestIndex];\n      const step = test.steps[index];\n      // open a prompt-driven editor (plain UI)\n      const newTitle = prompt('Step title', step.title || '');\n      if(newTitle === null) return;\n      step.title = newTitle;\n      const newType = prompt('Step type (action/assert/delay/conditional/loop/mock/random):', step.type || 'action');\n      if(newType === null) return;\n      step.type = newType;\n      step.description = prompt('Description / help text', step.description || '') || '';\n      // type-specific params\n      if(step.type === 'action'){\n        const code = prompt('Action code (JS expression or assignment). Use \"vars\" object to read/write, e.g. vars.count = (vars.count||0)+1;','' + (step.params && step.params.code || 'vars.count = (vars.count||0) + 1;'));\n        if(code === null) return;\n        step.params = { code };\n      } else if(step.type === 'assert'){\n        const expr = prompt('Assertion expression (JS returning boolean). Use \"vars\" and \"last\" and \"rng\". Example: vars.count === 2','' + (step.params && step.params.expr || 'vars.count === 1'));\n        if(expr === null) return;\n        step.params = { expr };\n      } else if(step.type === 'delay'){\n        const ms = prompt('Delay milliseconds', step.params && step.params.ms || '100');\n        if(ms === null) return;\n        step.params = { ms: Number(ms) };\n      } else if(step.type === 'conditional'){\n        const expr = prompt('Condition expression (JS). If true, goto \"onTrue\" index, else \"onFalse\" index. Use \"vars\". Example: vars.count>3','' + (step.params && step.params.expr || 'vars.count>0'));\n        if(expr === null) return;\n        const onTrue = prompt('Index to jump to if true (1-based index or \"end\")', step.params && step.params.onTrue || (index+1).toString());\n        if(onTrue === null) return;\n        const onFalse = prompt('Index to jump to if false (1-based index or \"end\")', step.params && step.params.onFalse || (index+2).toString());\n        if(onFalse === null) return;\n        step.params = { expr, onTrue, onFalse };\n      } else if(step.type === 'loop'){\n        const count = prompt('Repeat count expression (JS) using \"vars\" and \"last\". Example: 3','' + (step.params && step.params.count || '3'));\n        if(count === null) return;\n        const bodyIndex = prompt('Start index of loop body (1-based)', '' + (step.params && step.params.bodyIndex || (index+1)));\n        if(bodyIndex === null) return;\n        step.params = { count, bodyIndex: Number(bodyIndex) };\n      } else if(step.type === 'mock'){\n        const name = prompt('Mock name (identifier)', step.params && step.params.name || 'serviceA');\n        if(name === null) return;\n        const latency = prompt('Latency ms expression (JS using rng)', step.params && step.params.latency || '50 + Math.floor(rng()*200)');\n        if(latency === null) return;\n        const failProb = prompt('Failure probability (0-1 expression)', step.params && step.params.failProb || 'rng()<0.2');\n        if(failProb === null) return;\n        step.params = { name, latency, failProb };\n      } else if(step.type === 'random'){\n        const actionCount = prompt('Number of random actions to choose from', step.params && step.params.actionCount || '3');\n        if(actionCount === null) return;\n        const template = prompt('Action templates (semicolon separated JS code using vars). Example: vars.x++; ; vars.x+=2;','' + (step.params && step.params.templates || 'vars.x++;;vars.x+=2;'));\n        if(template === null) return;\n        step.params = { actionCount: Number(actionCount), templates: template };\n      } else {\n        // generic params prompt\n        const raw = prompt('Arbitrary JSON params for step', JSON.stringify(step.params||{}));\n        if(raw === null) return;\n        try{ step.params = JSON.parse(raw); } catch(e){ step.params = { raw }; }\n      }\n      saveModel();\n      renderTestEditor();\n    }\n\n    function moveStep(from, to){\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) return;\n      const test = suite.tests[model.activeTestIndex];\n      if(to<0 || to>=test.steps.length) return;\n      const [s] = test.steps.splice(from,1);\n      test.steps.splice(to,0,s);\n      saveModel();\n      renderTestEditor();\n    }\n\n    function deleteStep(idx){\n      if(!confirm('Delete step #' + (idx+1) + '?')) return;\n      const suite = model.suites[model.activeSuiteIndex];\n      const test = suite.tests[model.activeTestIndex];\n      test.steps.splice(idx,1);\n      saveModel();\n      renderTestEditor();\n    }\n\n    function duplicateStep(idx){\n      const suite = model.suites[model.activeSuiteIndex];\n      const test = suite.tests[model.activeTestIndex];\n      test.steps.splice(idx+1, 0, deepClone(test.steps[idx]));\n      saveModel();\n      renderTestEditor();\n    }\n\n    function saveModel(){\n      // persist minimal fields from editor to model\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) return;\n      suite.name = suiteName.value;\n      const test = suite.tests[model.activeTestIndex];\n      if(!test) return;\n      test.name = testName.value;\n      try{\n        test.initialVars = JSON.parse(initialVarsInput.value || '{}');\n      }catch(e){\n        // keep old if parse fails\n      }\n      test.notes = testNotes.value;\n      updateSuiteTestSelectors();\n    }\n\n    // Execution primitives\n    function evaluateExpression(expr, ctx){\n      // safe-ish wrapper: provide vars, last, rng, lastResult\n      try{\n        const fn = new Function('vars','last','rng','lastRes','return (' + expr + ')');\n        return fn(ctx.vars, ctx.last, ctx.rng, ctx.lastRes);\n      }catch(e){\n        throw new Error('Eval error: ' + e.message + ' in expression: ' + expr);\n      }\n    }\n\n    async function executeStep(step, state, ctx){\n      // step: object; state: {vars, last, history}; ctx: {rng, runId, workerId, log}\n      const startVars = deepClone(state.vars);\n      const result = { status: 'ok', message:'', stepTitle: step.title || '', stepType: step.type };\n      try{\n        if(step.type === 'action'){\n          // code may be assignment expression or statements\n          const code = step.params && step.params.code || '';\n          // execute code with Function wrapper\n          const fn = new Function('vars','rng','last','lastRes', code);\n          const res = fn(state.vars, ctx.rng, state.last, state.lastRes);\n          state.lastRes = res;\n          result.message = 'action executed';\n        } else if(step.type === 'assert'){\n          const expr = step.params && step.params.expr || 'true';\n          const ok = !!evaluateExpression(expr, {vars:state.vars, last:state.last, rng:ctx.rng, lastRes: state.lastRes});\n          result.ok = ok;\n          result.status = ok ? 'pass' : 'fail';\n          result.message = 'assert ' + (ok ? 'passed' : 'FAILED') + ' ('+expr+')';\n        } else if(step.type === 'delay'){\n          const ms = Number(step.params && step.params.ms || 0);\n          result.message = `delay ${ms}ms`;\n          await new Promise(res=>setTimeout(res, ms));\n        } else if(step.type === 'conditional'){\n          const expr = step.params && step.params.expr || 'false';\n          const val = !!evaluateExpression(expr, {vars:state.vars, last:state.last, rng:ctx.rng, lastRes: state.lastRes});\n          result.cond = val;\n          result.message = 'condition ' + (val?'true':'false') + ' ('+expr+')';\n          // result.jumpTo property handled by runner\n        } else if(step.type === 'loop'){\n          const countExpr = step.params && step.params.count || '1';\n          const count = Number(evaluateExpression(countExpr, {vars:state.vars, last:state.last, rng:ctx.rng, lastRes: state.lastRes})) || 0;\n          result.message = `loop ${count} times`;\n          // we return count; runner handles jumping\n          result.loopCount = count;\n        } else if(step.type === 'mock'){\n          // simulate external call\n          const latency = Number(evaluateExpression(step.params.latency || '0', {vars:state.vars, last:state.last, rng:ctx.rng, lastRes: state.lastRes})) || 0;\n          const fail = !!evaluateExpression(step.params.failProb || 'false', {vars:state.vars, last:state.last, rng:ctx.rng, lastRes: state.lastRes});\n          result.message = `mock ${step.params.name} -> ${fail ? 'FAIL' : 'OK'} after ${latency}ms`;\n          await new Promise(res=>setTimeout(res, latency));\n          result.ok = !fail;\n          result.status = fail ? 'fail' : 'pass';\n          if(fail){\n            // optionally set an error variable\n            state.vars['error_'+(step.params.name||'mock')] = true;\n          }else{\n            state.vars['last_'+(step.params.name||'mock')] = 'ok';\n          }\n        } else if(step.type === 'random'){\n          // pick one template to execute\n          const templates = (step.params.templates || '').split(';;').filter(Boolean);\n          if(templates.length === 0){\n            result.message = 'no templates';\n          } else {\n            const idx = Math.floor(ctx.rng() * templates.length);\n            const code = templates[idx];\n            const fn = new Function('vars','rng','last','lastRes', code);\n            const res = fn(state.vars, ctx.rng, state.last, state.lastRes);\n            state.lastRes = res;\n            result.message = 'random action #' + idx;\n          }\n        } else {\n          result.message = 'unknown step type';\n        }\n        // update last\n        state.last = { stepTitle: step.title || '', type: step.type, varsDelta: diffVars(startVars, state.vars) };\n        return result;\n      }catch(e){\n        result.status = 'error';\n        result.message = 'Exception: ' + e.message;\n        return result;\n      }\n    }\n\n    function diffVars(before, after){\n      const dif = {};\n      const keys = new Set([...Object.keys(before||{}), ...Object.keys(after||{})]);\n      keys.forEach(k=>{\n        const a = before[k], b = after[k];\n        if(JSON.stringify(a) !== JSON.stringify(b)) dif[k] = { before: a, after: b };\n      });\n      return dif;\n    }\n\n    // Runner: executes a test instance (single worker)\n    async function runTestInstance(test, opts){\n      // opts: {runId, workerId, seed, speedMs, onLog, stopSignal, autoReset}\n      const runId = opts.runId || ('run'+(engine.runIdSeq++));\n      const rng = makeRNG(Number(opts.seed) || 1);\n      let state = { vars: deepClone(test.initialVars || {}), last: null, lastRes: null, history: [] };\n      const snapshots = [];\n      const assertions = { passed:0, failed:0, errors:0, total:0 };\n      const log = (m)=>opts.onLog && opts.onLog(`[${runId}#${opts.workerId}] ${m}`);\n      log('START (seed='+opts.seed+')');\n      // initial snapshot\n      snapshots.push({ step:0, vars: deepClone(state.vars) });\n      const steps = test.steps;\n      let idx = 0;\n      let loopCounterStack = []; // for nested loops: store {remaining, startIndex}\n      let stopped = false;\n      async function stopIfRequested(){\n        if(opts.stopSignal && opts.stopSignal.cancelled) { stopped = true; throw new Error('Stopped'); }\n      }\n      try{\n        while(idx < steps.length){\n          await stopIfRequested();\n          const step = steps[idx];\n          // breakpoint handling\n          if(step.breakpoint && breakpointToggle.checked){\n            log('Hit breakpoint at step ' + (idx+1) + ': ' + (step.title || step.type));\n            if(runToBreakpoint.checked){\n              // pause entire run loop\n              await new Promise((res,rej)=>{\n                opts.onLog && opts.onLog(`[${runId}#${opts.workerId}] Paused at breakpoint, waiting...`);\n                const cb = ()=>{ document.removeEventListener('continueRun', cb); res(); };\n                document.addEventListener('continueRun', cb);\n              });\n            } else {\n              // just pause briefly\n              await new Promise(r=>setTimeout(r, 50));\n            }\n          }\n\n          const res = await executeStep(step, state, {rng, runId, workerId: opts.workerId, log});\n          const sNum = idx+1;\n          const summary = `${sNum}/${steps.length} [${step.type}] ${step.title||''} => ${res.status || 'ok'} ${res.message? '- '+res.message : ''}`;\n          log(summary);\n          // snapshot after step\n          snapshots.push({ step: sNum, vars: deepClone(state.vars), last: state.last, res });\n          // assertions count\n          if(res.status === 'fail') assertions.failed++, assertions.total++;\n          else if(res.status === 'pass') assertions.passed++, assertions.total++;\n          else if(res.status === 'error') assertions.errors++, assertions.total++;\n          // conditional and loop handling\n          if(step.type === 'conditional'){\n            const cond = !!res.cond;\n            let target = cond ? step.params.onTrue : step.params.onFalse;\n            if(String(target).toLowerCase() === 'end'){ idx = steps.length; continue; }\n            const t = Number(target);\n            if(!isNaN(t)){\n              // convert 1-based index to 0-based\n              idx = Math.max(0, Math.min(steps.length, t-1));\n              continue;\n            } else {\n              // cannot parse, just next\n            }\n          } else if(step.type === 'loop'){\n            const count = res.loopCount || 0;\n            if(count <= 0){\n              idx++;\n              continue;\n            } else {\n              // push a loop frame\n              loopCounterStack.push({ remaining: count, bodyStart: (step.params && step.params.bodyIndex ? (step.params.bodyIndex - 1) : idx + 1), loopStepIndex: idx });\n              // go to bodyStart\n              idx = loopCounterStack[loopCounterStack.length-1].bodyStart;\n              continue;\n            }\n          } else {\n            // normal progression, but handle loop stack if we are at end of body\n            if(loopCounterStack.length > 0){\n              // if current index is last step or next index beyond last of loop? We check whether next step would surpass loop boundaries by detecting when we return to step after loop\n              // Simple approach: when we hit the step that started the loop, decrement remaining\n              const top = loopCounterStack[loopCounterStack.length-1];\n              if(idx === top.loopStepIndex){\n                top.remaining--;\n                if(top.remaining > 0){\n                  idx = top.bodyStart;\n                  continue;\n                } else {\n                  loopCounterStack.pop();\n                  idx++;\n                  continue;\n                }\n              }\n            }\n            idx++;\n          }\n\n          // pacing\n          if(opts.speedMs) await new Promise(r=>setTimeout(r, opts.speedMs));\n        }\n        log('COMPLETE');\n      }catch(e){\n        if(e.message === 'Stopped'){\n          log('STOPPED');\n        } else {\n          log('ERROR: ' + e.message);\n        }\n      } finally{\n        // final snapshot\n        snapshots.push({ step: 'end', vars: deepClone(state.vars) });\n      }\n      return { runId, snapshots, assertions, finalState: state.vars };\n    }\n\n    // UI: wiring\n    function ensureSuiteExists(){\n      if(model.suites.length === 0){\n        model.suites.push({ name: 'Default Suite', tests: [] });\n        model.activeSuiteIndex = 0;\n      }\n      if(model.suites[model.activeSuiteIndex].tests.length === 0){\n        model.suites[model.activeSuiteIndex].tests.push({\n          name: 'Default Test',\n          steps: [],\n          initialVars: {},\n          notes: ''\n        });\n        model.activeTestIndex = 0;\n      }\n      updateSuiteTestSelectors();\n    }\n\n    // Buttons\n    newSuiteBtn.onclick = ()=>{\n      const name = prompt('Suite name', 'Suite ' + (model.suites.length+1));\n      if(!name) return;\n      model.suites.push({ name, tests: [] });\n      model.activeSuiteIndex = model.suites.length - 1;\n      model.activeTestIndex = -1;\n      ensureSuiteExists();\n      saveModel();\n    };\n    deleteSuiteBtn.onclick = ()=>{\n      if(model.activeSuiteIndex < 0) return;\n      if(!confirm('Delete suite?')) return;\n      model.suites.splice(model.activeSuiteIndex,1);\n      model.activeSuiteIndex = Math.min(model.activeSuiteIndex, model.suites.length -1);\n      saveModel();\n      updateSuiteTestSelectors();\n    };\n    newTestBtn.onclick = ()=>{\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) { alert('Create a suite first'); return; }\n      const name = prompt('Test name', 'Test ' + (suite.tests.length+1));\n      if(!name) return;\n      suite.tests.push({ name, steps: [], initialVars: {}, notes: '' });\n      model.activeTestIndex = suite.tests.length - 1;\n      saveModel();\n      renderTestEditor();\n    };\n    deleteTestBtn.onclick = ()=>{\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) return;\n      if(model.activeTestIndex < 0) return;\n      if(!confirm('Delete test?')) return;\n      suite.tests.splice(model.activeTestIndex,1);\n      model.activeTestIndex = Math.max(0, suite.tests.length - 1);\n      saveModel();\n      updateSuiteTestSelectors();\n    };\n\n    suiteSelect.onchange = (e)=>{ model.activeSuiteIndex = Number(e.target.value); model.activeTestIndex = 0; refreshActiveSelections(); };\n    testSelect.onchange = (e)=>{ model.activeTestIndex = Number(e.target.value); renderTestEditor(); };\n\n    addStepBtn.onclick = ()=>{\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) { alert('Create a suite/test first'); return; }\n      const test = suite.tests[model.activeTestIndex];\n      if(!test) return;\n      // default new step\n      const newStep = { type:'action', title:'New action', description:'', params: { code: 'vars.count = (vars.count||0) + 1;' }, breakpoint:false };\n      test.steps.push(newStep);\n      saveModel();\n      renderTestEditor();\n    };\n    insertStepBtn.onclick = ()=>{\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) return;\n      const test = suite.tests[model.activeTestIndex];\n      if(!test) return;\n      const idx = prompt('Insert at index (1-based). Leave empty to append', '');\n      if(idx === null) return;\n      const i = idx ? Math.max(0, Number(idx)-1) : test.steps.length;\n      const newStep = { type:'action', title:'Inserted action', description:'', params: { code: 'vars.count = (vars.count||0) + 1;' } };\n      test.steps.splice(i,0,newStep);\n      saveModel();\n      renderTestEditor();\n    };\n    duplicateStepBtn.onclick = ()=>{\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite) return;\n      const test = suite.tests[model.activeTestIndex];\n      if(!test) return;\n      const idx = prompt('Duplicate index (1-based)', '1');\n      if(idx === null) return;\n      const i = Math.max(0, Number(idx)-1);\n      if(i < 0 || i >= test.steps.length){ alert('Invalid index'); return; }\n      test.steps.splice(i+1,0, deepClone(test.steps[i]));\n      saveModel();\n      renderTestEditor();\n    };\n    clearStepsBtn.onclick = ()=>{\n      if(!confirm('Clear all steps?')) return;\n      const suite = model.suites[model.activeSuiteIndex];\n      const test = suite.tests[model.activeTestIndex];\n      test.steps = [];\n      saveModel();\n      renderTestEditor();\n    };\n\n    exportBtn.onclick = ()=>{\n      const json = JSON.stringify(model, null, 2);\n      const w = window.open();\n      w.document.body.pre.textContent = json;\n      alert('JSON copy opened in new window (you can save from there)');\n    };\n    importBtn.onclick = ()=>{\n      const raw = prompt('Paste JSON to import');\n      if(!raw) return;\n      try{\n        const parsed = JSON.parse(raw);\n        model = parsed;\n        model.activeSuiteIndex = model.activeSuiteIndex || 0;\n        model.activeTestIndex = model.activeTestIndex || 0;\n        updateSuiteTestSelectors();\n      }catch(e){\n        alert('Parse error: ' + e.message);\n      }\n    };\n    loadSampleBtn.onclick = ()=>{ loadSample(); };\n\n    copyJsonBtn.onclick = ()=>{\n      const txt = JSON.stringify(model, null, 2);\n      navigator.clipboard && navigator.clipboard.writeText(txt).then(()=>alert('Copied'), ()=>alert('Clipboard failed'));\n    };\n    downloadJsonBtn.onclick = ()=>{\n      const blob = new Blob([JSON.stringify(model, null, 2)], {type: 'application/json'});\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a');\n      a.href = url; a.download = 'integration-tests.json';\n      a.click();\n      URL.revokeObjectURL(url);\n    };\n\n    // Run controls\n    let stopSignalGlobal = { cancelled: false };\n    runBtn.onclick = async ()=>{\n      saveModel();\n      resetLog();\n      assertSummary.textContent = 'Running...';\n      const suite = model.suites[model.activeSuiteIndex];\n      if(!suite){ alert('No suite'); return; }\n      const test = suite.tests[model.activeTestIndex];\n      if(!test){ alert('No test'); return; }\n      const workers = Number(parallelRuns.value) || 1;\n      const speedMs = Number(workerSpeed.value) || 0;\n      const seed = Number(seedInput.value) || 1;\n      stopSignalGlobal = { cancelled: false };\n      const results = [];\n      for(let w=0; w<workers; w++){\n        const opts = { runId: 'run'+(engine.runIdSeq++), workerId: w+1, seed: seed + w, speedMs, onLog: (m)=>log(m), stopSignal: stopSignalGlobal };\n        engine.workers.push(opts);\n      }\n      engine.running = true;\n      for(const opts of engine.workers){\n        runTestInstance(test, opts).then(r=>{\n          results.push(r);\n          // update final UI state using last result\n          if(r && r.finalState){\n            stateView.textContent = JSON.stringify(r.finalState, null, 2);\n            snapshotsEl.textContent = JSON.stringify(r.snapshots, null, 2);\n          }\n          updateAssertionsSummary(results);\n        }).catch(e=>{\n          log('Worker error: ' + e.message);\n        });\n      }\n      // wait for all\n      await Promise.all(engine.workers.map(o=>{})); // nothing, workers manage logs; provide mechanism to stop\n      // clear worker array\n      engine.workers = [];\n      engine.running = false;\n    };\n\n    function updateAssertionsSummary(results){\n      if(!results || results.length===0) { assertSummary.textContent = 'No runs yet'; return; }\n      const agg = { passed:0, failed:0, errors:0, total:0 };\n      results.forEach(r=>{\n        if(r && r.assertions){\n          agg.passed += r.assertions.passed || 0;\n          agg.failed += r.assertions.failed || 0;\n          agg.errors += r.assertions.errors || 0;\n          agg.total += r.assertions.total || 0;\n        }\n      });\n      assertSummary.textContent = `Assertions: ${agg.passed} passed, ${agg.failed} failed, ${agg.errors} errors (total ${agg.total}) across ${results.length} runs`;\n    }\n\n    pauseBtn.onclick = ()=>{ /* not implemented - toggle paused flag for future extension */ alert('Pause currently toggles via breakpoint or external continue event'); };\n\n    stopBtn.onclick = ()=>{\n      stopSignalGlobal.cancelled = true;\n      engine.workers = [];\n      engine.running = false;\n      log('Requested stop for current workers');\n    };\n\n    stopAllBtn.onclick = () => {\n      stopSignalGlobal.cancelled = true;\n      engine.workers = [];\n      engine.running = false;\n      log('STOP ALL requested');\n    };\n\n    rewindBtn.onclick = ()=>{\n      // reset logs and state\n      resetLog();\n      stateView.textContent = '{}';\n      snapshotsEl.textContent = '';\n      assertSummary.textContent = 'Rewound';\n      log('Rewind: cleared state and log');\n    };\n\n    // Step-run: execute single test run step-by-step (one worker)\n    stepBtn.onclick = async ()=>{\n      saveModel();\n      const suite = model.suites[model.activeSuiteIndex];\n      const test = suite && suite.tests[model.activeTestIndex];\n      if(!test) return;\n      // create a temporary single-step runner with snapshot history\n      const seed = Number(seedInput.value) || 1;\n      const rng = makeRNG(seed);\n      let state = { vars: deepClone(test.initialVars || {}), last: null, lastRes: null };\n      let index = 0;\n      let cont = true;\n      // We will prompt user repeatedly to step forward\n      while(cont && index < test.steps.length){\n        const step = test.steps[index];\n        const res = await executeStep(step, state, { rng, runId: 'interactive', workerId: 1, log:log });\n        log(`Step ${index+1}: ${res.status} - ${res.message}`);\n        stateView.textContent = JSON.stringify(state.vars, null, 2);\n        snapshotsEl.textContent += JSON.stringify({ idx:index+1, vars: state.vars, res }, null, 2) + '\\n';\n        if(step.breakpoint && breakpointToggle.checked){\n          alert('Hit breakpoint at step ' + (index+1));\n          // wait for user to continue or cancel\n          const c = confirm('Continue stepping?');\n          if(!c) break;\n        }\n        const contResp = confirm('Step forward to next? (Cancel to stop)');\n        if(!contResp) break;\n        index++;\n      }\n      log('Step run complete or stopped by user');\n    };\n\n    // Fuzzer: generate random sequences and run many paths\n    runFuzzerBtn.onclick = async ()=>{\n      saveModel();\n      const suite = model.suites[model.activeSuiteIndex];\n      const test = suite && suite.tests[model.activeTestIndex];\n      if(!test){ alert('No test selected'); return; }\n      const seed = Number(seedInput.value) || 1;\n      const paths = Number(fuzzPaths.value) || 10;\n      resetLog();\n      log(`Fuzzer: running ${paths} paths (seed ${seed})`);\n      const results = [];\n      for(let p=0;p<paths;p++){\n        const rng = makeRNG(seed + p);\n        // create a clone of test with some randomized steps: replace some actions with random increments\n        const clone = deepClone(test);\n        // mutate some action steps randomly\n        clone.steps.forEach(s=>{\n          if(s.type === 'action' && Math.random() < 0.3){\n            s.params.code = `vars.fuzz_${p} = (vars.fuzz_${p}||0) + ${Math.floor(rng()*10)};`;\n          }\n        });\n        const opts = { runId: 'fuzz'+p, workerId: 1, seed: seed + p, speedMs: 0, onLog: (m)=>log(m), stopSignal: { cancelled:false } };\n        const r = await runTestInstance(clone, opts);\n        results.push(r);\n        log('Fuzz path ' + p + ' finished');\n      }\n      // show aggregated summary\n      let totalPass=0, totalFail=0;\n      results.forEach(r=>{\n        totalPass += r.assertions.passed || 0;\n        totalFail += r.assertions.failed || 0;\n      });\n      assertSummary.textContent = `Fuzzer: ${paths} runs, ${totalPass} assertions passed, ${totalFail} failed.`;\n      log('Fuzzer complete.');\n    };\n\n    // Sample initial data\n    function loadSample(){\n      model = {\n        suites: [\n          {\n            name: 'Sample Suite',\n            tests: [\n              {\n                name: 'Checkout Flow Test',\n                initialVars: { cart: [], loggedIn: false, retries: 0 },\n                notes: 'Simulates a checkout workflow with branching and mocks.',\n                steps: [\n                  { type:'action', title:'Add item', description:'Add item to cart', params: { code: 'vars.cart = vars.cart || []; vars.cart.push({id: \"item1\", qty: 1});' }, breakpoint:false },\n                  { type:'action', title:'Login', description:'Attempt login', params: { code: 'if(!vars.loggedIn){ if(Math.random()>0.5){ vars.loggedIn = true } else { vars.loggedIn=false }}' }, breakpoint:false },\n                  { type:'mock', title:'Call payment service', description:'Simulate payment gateway', params:{ name:'payment', latency: '100 + Math.floor(rng()*200)', failProb: 'rng()<0.3' }, breakpoint:true },\n                  { type:'conditional', title:'Payment success?', description:'Branch on payment result', params:{ expr: 'vars.last_payment_ok === true || vars.last_payment_ok === undefined ? true : false', onTrue: '5', onFalse: 'end' }, breakpoint:false },\n                  { type:'action', title:'Finalize order', description:'Create order id', params:{ code: 'vars.orderId = \"ORD-\" + Math.floor(rng()*100000); vars.completed = true;' }, breakpoint:false },\n                  { type:'assert', title:'Order completed', description:'Check completed', params:{ expr: 'vars.completed === true' }, breakpoint:false }\n                ]\n              }\n            ]\n          }\n        ],\n        activeSuiteIndex: 0,\n        activeTestIndex: 0\n      };\n      updateSuiteTestSelectors();\n      saveModel();\n      renderTestEditor();\n    }\n\n    // Initialize simple sample\n    loadSample();\n\n    // Wire save on edit fields\n    suiteName.onchange = saveModel;\n    testName.onchange = saveModel;\n    initialVarsInput.onchange = saveModel;\n    testNotes.onchange = saveModel;\n\n    // Small keyboard hook: 'c' to continue a paused run (used by breakpoint resume)\n    document.addEventListener('keydown', (e)=>{\n      if(e.key === 'c'){\n        const ev = new Event('continueRun');\n        document.dispatchEvent(ev);\n        log('Continue event dispatched');\n      }\n    });\n\n    // Accessibility hint\n    log('Integration Testing Playground loaded. Press \"c\" to continue past breakpoints when paused.');\n\n  </script>\n</body>\n</html>"
