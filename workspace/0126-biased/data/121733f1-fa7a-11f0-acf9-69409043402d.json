  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Logistic Regression Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  label, button {\n    display: inline-block;\n    margin: 0.3em 0.6em 0.3em 0;\n  }\n  input[type=\"number\"] {\n    width: 4em;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 1em;\n  }\n  td, th {\n    border: 1px solid black;\n    padding: 0.25em 0.5em;\n    text-align: center;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n    margin-top: 0.3em;\n  }\n  #plotarea {\n    margin-top: 1em;\n    width: 500px;\n    height: 300px;\n    border: 1px solid black;\n    position: relative;\n  }\n  #plotarea canvas {\n    position: absolute;\n    top: 0;\n    left: 0;\n  }\n  #status {\n    margin-top: 1em;\n    min-height: 4em;\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n\n<h1>Interactive Logistic Regression Explorer</h1>\n\n<div>\n  <b>Step 1: Dataset Setup (Input your points)</b><br />\n  <label>X: <input type=\"number\" step=\"any\" id=\"inputX\" value=\"0\" /></label>\n  <label>Y: <input type=\"number\" step=\"any\" id=\"inputY\" value=\"0\" /></label>\n  <label>Class: \n    <select id=\"inputClass\">\n      <option value=\"0\">0</option>\n      <option value=\"1\" selected>1</option>\n    </select>\n  </label>\n  <button id=\"btnAddPoint\">Add Point</button>\n  <button id=\"btnClearPoints\">Clear Points</button>\n  <button id=\"btnRandomPoints\">Add Random Points</button>\n</div>\n\n<div>\n  <b>Dataset Points (X, Y, Class):</b>\n  <table id=\"pointsTable\" aria-label=\"Dataset points table\">\n    <thead>\n      <tr><th>#</th><th>X</th><th>Y</th><th>Class</th><th>Remove</th></tr>\n    </thead>\n    <tbody></tbody>\n  </table>\n</div>\n\n<hr />\n\n<div>\n  <b>Step 2: Initialize Logistic Regression Model</b><br />\n  <label>Initial Weight w0 (bias): <input type=\"number\" step=\"any\" id=\"w0init\" value=\"0\" /></label>\n  <label>Initial Weight w1 (coef for X): <input type=\"number\" step=\"any\" id=\"w1init\" value=\"0\" /></label>\n  <label>Initial Weight w2 (coef for Y): <input type=\"number\" step=\"any\" id=\"w2init\" value=\"0\" /></label>\n  <button id=\"btnInitModel\">Initialize Model</button>\n</div>\n\n<div>\n  <b>Current Weights:</b>\n  <textarea id=\"weightsDisplay\" readonly></textarea>\n</div>\n\n<hr />\n\n<div>\n  <b>Step 3: Logistic Regression Training Controls</b><br />\n  <label>Learning Rate (α): <input type=\"number\" step=\"any\" id=\"learningRate\" value=\"0.1\" min=\"0.0001\" max=\"1\" /></label><br />\n  <label>Steps per Training Batch: <input type=\"number\" step=\"1\" id=\"trainSteps\" value=\"10\" min=\"1\" max=\"1000\" /></label><br />\n  <button id=\"btnTrainBatch\">Train Batch</button>\n  <button id=\"btnTrainFull\">Train Until Convergence</button>\n  <button id=\"btnResetTraining\">Reset Training</button><br />\n  <label>\n    Convergence Threshold (weight changes <): <input type=\"number\" step=\"any\" id=\"convThreshold\" value=\"0.0001\" />\n  </label><br />\n  <label>\n    Max Training Iterations: <input type=\"number\" step=\"1\" id=\"maxIterations\" value=\"10000\" />\n  </label>\n</div>\n\n<div>\n  <b>Training Progress:</b>\n  <textarea id=\"trainingLog\" readonly></textarea>\n</div>\n\n<hr />\n\n<div>\n  <b>Step 4: Model Exploration and Prediction</b><br />\n  <label>Input point to predict:</label>\n  <label>X: <input type=\"number\" step=\"any\" id=\"predictX\" value=\"0\" /></label>\n  <label>Y: <input type=\"number\" step=\"any\" id=\"predictY\" value=\"0\" /></label>\n  <button id=\"btnPredict\">Predict Class & Probability</button><br />\n  <div id=\"predictionResult\"></div>\n</div>\n\n<hr />\n\n<div>\n  <b>Step 5: Visualization (Scatter plot and decision boundary)</b><br />\n  <button id=\"btnDrawPlot\">Draw Plot</button>\n  <button id=\"btnClearPlot\">Clear Plot</button>\n  <div id=\"plotarea\" aria-label=\"Plot area with dataset and decision boundary\">\n    <canvas id=\"pointsCanvas\" width=\"500\" height=\"300\"></canvas>\n    <canvas id=\"boundaryCanvas\" width=\"500\" height=\"300\"></canvas>\n  </div>\n</div>\n\n<hr />\n\n<div>\n  <b>Bonus: Manual Weight Adjustment for Deep Exploration</b><br />\n  <label>Set w0: <input type=\"number\" step=\"any\" id=\"manualW0\" value=\"0\" /></label>\n  <label>Set w1: <input type=\"number\" step=\"any\" id=\"manualW1\" value=\"0\" /></label>\n  <label>Set w2: <input type=\"number\" step=\"any\" id=\"manualW2\" value=\"0\" /></label>\n  <button id=\"btnSetWeights\">Set Weights Manually</button>\n</div>\n\n<hr />\n\n<div>\n  <b>Bonus: Export/Import Dataset and Model</b><br />\n  <button id=\"btnExport\">Export Dataset & Model</button>\n  <button id=\"btnImport\">Import Dataset & Model</button><br />\n  <textarea id=\"importExportArea\" placeholder=\"Exported JSON will appear here or paste JSON here to import\"></textarea>\n</div>\n\n<hr />\n\n<div id=\"status\" aria-live=\"polite\"></div>\n\n<script>\n(() => {\n  // Dataset format: array of objects {x:number,y:number,class:0|1}\n  let dataset = [];\n\n  // Logistic Regression model weights:\n  // w0 = bias, w1 and w2 are coefficients for x and y\n  let weights = { w0: 0, w1: 0, w2: 0 };\n\n  // Training state:\n  let trainingLog = [];\n  let trainingIteration = 0;\n  let trainingInProgress = false;\n\n  // DOM elements:\n  const inputX = document.getElementById('inputX');\n  const inputY = document.getElementById('inputY');\n  const inputClass = document.getElementById('inputClass');\n  const btnAddPoint = document.getElementById('btnAddPoint');\n  const btnClearPoints = document.getElementById('btnClearPoints');\n  const btnRandomPoints = document.getElementById('btnRandomPoints');\n  const pointsTableBody = document.querySelector('#pointsTable tbody');\n  const w0initInput = document.getElementById('w0init');\n  const w1initInput = document.getElementById('w1init');\n  const w2initInput = document.getElementById('w2init');\n  const btnInitModel = document.getElementById('btnInitModel');\n  const weightsDisplay = document.getElementById('weightsDisplay');\n  const learningRateInput = document.getElementById('learningRate');\n  const trainStepsInput = document.getElementById('trainSteps');\n  const btnTrainBatch = document.getElementById('btnTrainBatch');\n  const btnTrainFull = document.getElementById('btnTrainFull');\n  const convThresholdInput = document.getElementById('convThreshold');\n  const maxIterationsInput = document.getElementById('maxIterations');\n  const trainingLogArea = document.getElementById('trainingLog');\n  const predictXInput = document.getElementById('predictX');\n  const predictYInput = document.getElementById('predictY');\n  const btnPredict = document.getElementById('btnPredict');\n  const predictionResultDiv = document.getElementById('predictionResult');\n  const btnDrawPlot = document.getElementById('btnDrawPlot');\n  const btnClearPlot = document.getElementById('btnClearPlot');\n  const plotArea = document.getElementById('plotarea');\n  const pointsCanvas = document.getElementById('pointsCanvas');\n  const boundaryCanvas = document.getElementById('boundaryCanvas');\n\n  const manualW0Input = document.getElementById('manualW0');\n  const manualW1Input = document.getElementById('manualW1');\n  const manualW2Input = document.getElementById('manualW2');\n  const btnSetWeights = document.getElementById('btnSetWeights');\n\n  const btnExport = document.getElementById('btnExport');\n  const btnImport = document.getElementById('btnImport');\n  const importExportArea = document.getElementById('importExportArea');\n\n  const statusDiv = document.getElementById('status');\n\n  // Utilities\n  function sigmoid(z) {\n    // Bound input for safety (not required, but protects against overflow)\n    if(z < -30) return 0;\n    if(z > 30) return 1;\n    return 1 / (1 + Math.exp(-z));\n  }\n\n  // Dataset Management:\n  function updatePointsTable() {\n    pointsTableBody.innerHTML = '';\n    dataset.forEach((pt,i) => {\n      const tr = document.createElement('tr');\n      const idxTd = document.createElement('td');\n      idxTd.textContent = i+1;\n      const xTd = document.createElement('td');\n      xTd.textContent = pt.x.toFixed(3);\n      const yTd = document.createElement('td');\n      yTd.textContent = pt.y.toFixed(3);\n      const cTd = document.createElement('td');\n      cTd.textContent = pt.class;\n      const remTd = document.createElement('td');\n      const remBtn = document.createElement('button');\n      remBtn.textContent = 'Remove';\n      remBtn.type = 'button';\n      remBtn.addEventListener('click', () => {\n        dataset.splice(i,1);\n        updatePointsTable();\n        updateStatus(`Removed point #${i+1}`);\n      });\n      remTd.appendChild(remBtn);\n      tr.appendChild(idxTd);\n      tr.appendChild(xTd);\n      tr.appendChild(yTd);\n      tr.appendChild(cTd);\n      tr.appendChild(remTd);\n      pointsTableBody.appendChild(tr);\n    });\n  }\n\n  btnAddPoint.addEventListener('click', () => {\n    const x = parseFloat(inputX.value);\n    const y = parseFloat(inputY.value);\n    const c = parseInt(inputClass.value);\n    if (Number.isNaN(x) || Number.isNaN(y) || (c !== 0 && c !==1)) {\n      updateStatus('Invalid input values for point.');\n      return;\n    }\n    dataset.push({x, y, class:c});\n    updatePointsTable();\n    updateStatus(`Added point (x:${x}, y:${y}, class:${c})`);\n  });\n\n  btnClearPoints.addEventListener('click', () => {\n    dataset = [];\n    updatePointsTable();\n    updateStatus('Cleared all dataset points.');\n  });\n\n  btnRandomPoints.addEventListener('click', () => {\n    const count = 20;\n    // Generate 10 points for class 0 near (-1,-1), 10 points for class 1 near (1,1)\n    for(let i=0; i<10; i++){\n      dataset.push({\n        x: -1 + (Math.random() * 0.5 - 0.25),\n        y: -1 + (Math.random() * 0.5 - 0.25),\n        class: 0\n      });\n    }\n    for(let i=0; i<10; i++){\n      dataset.push({\n        x: 1 + (Math.random() * 0.5 - 0.25),\n        y: 1 + (Math.random() * 0.5 - 0.25),\n        class: 1\n      });\n    }\n    updatePointsTable();\n    updateStatus('Added 20 random points (clustered around (-1,-1) and (1,1)).');\n  });\n\n  // Model Initialization\n  btnInitModel.addEventListener('click', () => {\n    let w0 = parseFloat(w0initInput.value);\n    let w1 = parseFloat(w1initInput.value);\n    let w2 = parseFloat(w2initInput.value);\n    if ([w0,w1,w2].some(v => Number.isNaN(v))) {\n      updateStatus('Invalid initial weights.');\n      return;\n    }\n    weights = { w0, w1, w2 };\n    updateWeightsDisplay();\n    trainingLog = [];\n    trainingIteration = 0;\n    trainingInProgress = false;\n    trainingLogArea.value = '';\n    updateStatus('Model initialized with given weights.');\n  });\n\n  function updateWeightsDisplay() {\n    weightsDisplay.value =\n      `w0 (bias): ${weights.w0.toFixed(6)}\\n` +\n      `w1 (coef X): ${weights.w1.toFixed(6)}\\n` +\n      `w2 (coef Y): ${weights.w2.toFixed(6)}`;\n    manualW0Input.value = weights.w0.toFixed(6);\n    manualW1Input.value = weights.w1.toFixed(6);\n    manualW2Input.value = weights.w2.toFixed(6);\n  }\n\n  // Logistic Regression helper functions\n  function predictProbability(x,y) {\n    return sigmoid(weights.w0 + weights.w1*x + weights.w2*y);\n  }\n\n  // Single gradient step:\n  // Uses all points as batch, updates weights by gradient ascent on log-likelihood\n  function trainBatch(steps, lr, convThreshold) {\n    if (dataset.length === 0) {\n      updateStatus('Dataset is empty. Add points before training.');\n      return false;\n    }\n    let converged = false;\n    for(let step=0; step<steps; step++) {\n      trainingIteration++;\n      // Calculate gradients:\n      let grad0 = 0, grad1=0, grad2=0;\n      for(const pt of dataset){\n        const p = predictProbability(pt.x, pt.y);\n        const error = pt.class - p; // Note: gradient ascent, so error = y - p\n        grad0 += error;\n        grad1 += error * pt.x;\n        grad2 += error * pt.y;\n      }\n      // Average gradients:\n      const n = dataset.length;\n      grad0 /= n; grad1 /= n; grad2 /= n;\n\n      // Previous weights for convergence check\n      const oldW0 = weights.w0;\n      const oldW1 = weights.w1;\n      const oldW2 = weights.w2;\n\n      // Update weights:\n      weights.w0 += lr * grad0;\n      weights.w1 += lr * grad1;\n      weights.w2 += lr * grad2;\n\n      // Log progress\n      const wchg = Math.max(\n        Math.abs(weights.w0 - oldW0),\n        Math.abs(weights.w1 - oldW1),\n        Math.abs(weights.w2 - oldW2)\n      );\n\n      trainingLog.push(`Iteration ${trainingIteration}: w0=${weights.w0.toFixed(6)}, w1=${weights.w1.toFixed(6)}, w2=${weights.w2.toFixed(6)}, max weight change=${wchg.toExponential(1)}`);\n\n      if (wchg < convThreshold) {\n        converged = true;\n        break;\n      }\n    }\n    updateWeightsDisplay();\n    trainingLogArea.value = trainingLog.join('\\n');\n    trainingLogArea.scrollTop = trainingLogArea.scrollHeight;\n    if(converged) {\n      updateStatus(`Training converged after ${trainingIteration} iterations.`);\n      return true;\n    } else {\n      updateStatus(`Training completed ${steps} steps. Current iteration: ${trainingIteration}.`);\n      return false;\n    }\n  }\n\n  btnTrainBatch.addEventListener('click', () => {\n    const steps = parseInt(trainStepsInput.value);\n    const lr = parseFloat(learningRateInput.value);\n    const convThreshold = parseFloat(convThresholdInput.value);\n    if(steps < 1 || lr <= 0){\n      updateStatus('Invalid training parameters.');\n      return;\n    }\n    trainBatch(steps, lr, convThreshold);\n  });\n\n  btnTrainFull.addEventListener('click', () => {\n    if(dataset.length === 0){\n      updateStatus('Dataset empty. Add points before training.');\n      return;\n    }\n    trainingInProgress = true;\n    trainingLog = [];\n    trainingIteration = 0;\n    trainingLogArea.value = '';\n    const lr = parseFloat(learningRateInput.value);\n    const convThreshold = parseFloat(convThresholdInput.value);\n    const maxIt = parseInt(maxIterationsInput.value);\n\n    function trainStep() {\n      if(!trainingInProgress) return;\n      const converged = trainBatch(1, lr, convThreshold);\n      if(converged || trainingIteration >= maxIt){\n        trainingInProgress = false;\n        if(trainingIteration >= maxIt){\n          updateStatus(`Reached maximum iterations (${maxIt}). Training stopped.`);\n        }\n        return;\n      }\n      // No delay to allow user to interrupt or browser paint\n      setTimeout(trainStep, 0);\n    }\n    trainStep();\n  });\n\n  btnResetTraining.addEventListener('click', () => {\n    trainingLog = [];\n    trainingIteration = 0;\n    trainingInProgress = false;\n    trainingLogArea.value = '';\n    updateStatus('Training state reset.');\n  });\n\n  // Prediction interaction:\n  btnPredict.addEventListener('click', () => {\n    const x = parseFloat(predictXInput.value);\n    const y = parseFloat(predictYInput.value);\n    if(Number.isNaN(x) || Number.isNaN(y)){\n      predictionResultDiv.textContent = 'Invalid input coordinates.';\n      return;\n    }\n    const p = predictProbability(x,y);\n    const predictedClass = (p >= 0.5) ? 1 : 0;\n    predictionResultDiv.textContent = `Predicted probability for class 1: ${p.toFixed(5)}\\nPredicted class: ${predictedClass}`;\n  });\n\n  // Visualization:\n  // We'll draw points as circles:\n  // class 0: circle outline\n  // class 1: filled circle\n  // Draw decision boundary line for w0 + w1*x + w2*y = 0 =>\n  // y = (-w0 - w1*x)/w2\n  function drawPlot() {\n    const w = pointsCanvas.width;\n    const h = pointsCanvas.height;\n\n    const ctxPoints = pointsCanvas.getContext('2d');\n    const ctxBoundary = boundaryCanvas.getContext('2d');\n\n    // Clear\n    ctxPoints.clearRect(0,0,w,h);\n    ctxBoundary.clearRect(0,0,w,h);\n\n    if(dataset.length === 0){\n      updateStatus('No data points to plot.');\n      return;\n    }\n\n    // Find data ranges with margin\n    let xs = dataset.map(pt => pt.x);\n    let ys = dataset.map(pt => pt.y);\n    let xmin = Math.min(...xs);\n    let xmax = Math.max(...xs);\n    let ymin = Math.min(...ys);\n    let ymax = Math.max(...ys);\n\n    // Update plot area coordinates to have margin\n    const marginX = (xmax - xmin) * 0.15 || 1;\n    const marginY = (ymax - ymin) * 0.15 || 1;\n    xmin -= marginX;\n    xmax += marginX;\n    ymin -= marginY;\n    ymax += marginY;\n\n    // Save coordinates for prediction mapping\n    plotArea._coords = { xmin, xmax, ymin, ymax };\n\n    // Coordinate transforms:\n    function xToCanvas(x){ return ((x - xmin) / (xmax - xmin)) * w; }\n    function yToCanvas(y){ return h - ((y - ymin) / (ymax - ymin)) * h; }\n    function canvasToX(cx){ return xmin + (cx / w) * (xmax - xmin); }\n    function canvasToY(cy){ return ymin + ((h - cy) / h) * (ymax - ymin); }\n\n    // Draw points\n    for(const pt of dataset){\n      const cx = xToCanvas(pt.x);\n      const cy = yToCanvas(pt.y);\n      ctxPoints.beginPath();\n      if(pt.class === 1){\n        ctxPoints.arc(cx, cy, 5, 0, 2*Math.PI);\n        ctxPoints.fill();\n      } else {\n        ctxPoints.arc(cx, cy, 5, 0, 2*Math.PI);\n        ctxPoints.stroke();\n      }\n    }\n\n    // Draw decision boundary:\n    if(weights.w2 === 0) {\n      // Vertical line x = -w0/w1\n      if(weights.w1 !== 0){\n        const xline = -weights.w0/weights.w1;\n        if(xline >= xmin && xline <= xmax){\n          const cx = xToCanvas(xline);\n          ctxBoundary.beginPath();\n          ctxBoundary.moveTo(cx, 0);\n          ctxBoundary.lineTo(cx, h);\n          ctxBoundary.stroke();\n        }\n      }\n    } else {\n      // y = (-w0 - w1*x) / w2\n      // Draw line from x=xmin to x=xmax\n      const y1 = (-weights.w0 - weights.w1 * xmin)/weights.w2;\n      const y2 = (-weights.w0 - weights.w1 * xmax)/weights.w2;\n\n      const cy1 = yToCanvas(y1);\n      const cy2 = yToCanvas(y2);\n\n      ctxBoundary.beginPath();\n      ctxBoundary.moveTo(0, cy1);\n      ctxBoundary.lineTo(w, cy2);\n      ctxBoundary.stroke();\n    }\n\n    // Axis and labels (very basic: draw border lines)\n    ctxPoints.strokeRect(0,0,w,h);\n\n    updateStatus('Plot drawn with current points and decision boundary.');\n  }\n\n  btnDrawPlot.addEventListener('click', drawPlot);\n  btnClearPlot.addEventListener('click', () => {\n    pointsCanvas.getContext('2d').clearRect(0,0,pointsCanvas.width, pointsCanvas.height);\n    boundaryCanvas.getContext('2d').clearRect(0,0,boundaryCanvas.width, boundaryCanvas.height);\n    updateStatus('Plot cleared.');\n  });\n\n  // Bonus: Manual weight adjustment:\n  btnSetWeights.addEventListener('click', () => {\n    let w0 = parseFloat(manualW0Input.value);\n    let w1 = parseFloat(manualW1Input.value);\n    let w2 = parseFloat(manualW2Input.value);\n    if ([w0, w1, w2].some(v => Number.isNaN(v))) {\n      updateStatus('Invalid manual weights input.');\n      return;\n    }\n    weights = { w0, w1, w2 };\n    updateWeightsDisplay();\n    updateStatus('Weights manually updated.');\n  });\n\n  // Export / Import:\n  btnExport.addEventListener('click', () => {\n    const exportData = {\n      dataset: dataset,\n      weights: weights\n    };\n    try {\n      importExportArea.value = JSON.stringify(exportData, null, 2);\n      updateStatus('Exported dataset and model to JSON.');\n    } catch(e) {\n      updateStatus('Failed to export data: ' + e.message);\n    }\n  });\n\n  btnImport.addEventListener('click', () => {\n    const jsonText = importExportArea.value.trim();\n    if(!jsonText){\n      updateStatus('Import area is empty.');\n      return;\n    }\n    try {\n      const importData = JSON.parse(jsonText);\n      if(!importData.dataset || !importData.weights){\n        updateStatus('Import JSON must have \"dataset\" and \"weights\" keys.');\n        return;\n      }\n      // Validate dataset:\n      if(!Array.isArray(importData.dataset)) {\n        updateStatus('Dataset must be an array.');\n        return;\n      }\n      for(const pt of importData.dataset){\n        if(typeof pt.x !== 'number' || typeof pt.y !== 'number' || (pt.class !== 0 && pt.class !==1)){\n          updateStatus('Dataset points must have numeric x, y and class 0 or 1.');\n          return;\n        }\n      }\n      dataset = importData.dataset;\n      weights = importData.weights;\n      updatePointsTable();\n      updateWeightsDisplay();\n      trainingLog = [];\n      trainingIteration = 0;\n      trainingInProgress = false;\n      trainingLogArea.value = '';\n      updateStatus('Imported dataset and model successfully.');\n    } catch(e){\n      updateStatus('Failed to parse import JSON: ' + e.message);\n    }\n  });\n\n  // Status update helper:\n  function updateStatus(msg) {\n    const now = new Date();\n    const timestamp = now.toLocaleTimeString();\n    statusDiv.textContent = `[${timestamp}] ${msg}`;\n  }\n\n  // Initial setup:\n  updatePointsTable();\n  updateWeightsDisplay();\n  updateStatus('Ready.');\n\n  // Extra: allow clicking plot to set predict input and show prediction live\n  pointsCanvas.addEventListener('click', e => {\n    if(!plotArea._coords) return;\n    const rect = pointsCanvas.getBoundingClientRect();\n    const cx = e.clientX - rect.left;\n    const cy = e.clientY - rect.top;\n    const { xmin, xmax, ymin, ymax } = plotArea._coords;\n    const xVal = xmin + (cx / pointsCanvas.width) * (xmax - xmin);\n    const yVal = ymin + ((pointsCanvas.height - cy) / pointsCanvas.height) * (ymax - ymin);\n    predictXInput.value = xVal.toFixed(3);\n    predictYInput.value = yVal.toFixed(3);\n    btnPredict.click();\n  });\n\n  // Extra: clicking training log area selections will show iteration number in status\n  trainingLogArea.addEventListener('select', () => {\n    const selection = trainingLogArea.value.substring(trainingLogArea.selectionStart, trainingLogArea.selectionEnd);\n    if(!selection) return;\n    const match = selection.match(/Iteration (\\d+)/);\n    if(match){\n      updateStatus('Selected log for iteration #' + match[1]);\n    }\n  });\n\n}) ();\n</script>\n\n</body>\n</html>"
  },
