    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Breadth-First Search (BFS) Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        #graph-container {\n            margin: 20px 0;\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 300px;\n        }\n        .node {\n            display: inline-block;\n            width: 30px;\n            height: 30px;\n            border: 1px solid #000;\n            text-align: center;\n            line-height: 30px;\n            margin: 5px;\n            cursor: pointer;\n        }\n        .visited {\n            background-color: #ccc;\n        }\n        .queue {\n            background-color: #eee;\n        }\n        .current {\n            font-weight: bold;\n            border: 2px solid #000;\n        }\n        .controls {\n            margin: 10px 0;\n        }\n        .control-group {\n            margin: 10px 0;\n            padding: 1px 10px;\n            border: 1px solid #000;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n        #bfs-steps {\n            margin-top: 20px;\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 100px;\n        }\n        #queue-display {\n            margin: 10px 0;\n            padding: 5px;\n            border: 1px dashed #000;\n            min-height: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Breadth-First Search (BFS) Interactive Demo</h1>\n    \n    <div class=\"control-group\">\n        <h3>Graph Configuration</h3>\n        <div>\n            <label>Number of nodes: <input type=\"number\" id=\"node-count\" min=\"2\" max=\"20\" value=\"7\"></label>\n            <button id=\"generate-graph\">Generate Graph</button>\n        </div>\n        <div>\n            <label>Adjacency List (JSON):</label><br>\n            <textarea id=\"adjacency-list\">{\n    \"0\": [\"1\", \"2\"],\n    \"1\": [\"0\", \"3\", \"4\"],\n    \"2\": [\"0\", \"5\", \"6\"],\n    \"3\": [\"1\"],\n    \"4\": [\"1\"],\n    \"5\": [\"2\"],\n    \"6\": [\"2\"]\n}</textarea>\n            <button id=\"load-graph\">Load Graph</button>\n        </div>\n    </div>\n    \n    <div class=\"control-group\">\n        <h3>BFS Controls</h3>\n        <div>\n            <label>Start node: <input type=\"number\" id=\"start-node\" min=\"0\" value=\"0\"></label>\n            <label>Target node (optional): <input type=\"number\" id=\"target-node\" min=\"0\"></label>\n        </div>\n        <div class=\"controls\">\n            <button id=\"start-bfs\">Start BFS</button>\n            <button id=\"step-bfs\">Step</button>\n            <button id=\"reset-bfs\">Reset</button>\n            <button id=\"auto-step\">Auto Step (500ms)</button>\n            <button id=\"stop-auto\">Stop Auto</button>\n        </div>\n        <div>\n            Speed: <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\" step=\"100\">\n            <span id=\"speed-value\">500ms</span>\n        </div>\n    </div>\n    \n    <div id=\"queue-display\">\n        <strong>Queue:</strong> <span id=\"queue-content\">[]</span>\n    </div>\n    \n    <div id=\"graph-container\">\n        <p>Graph will appear here</p>\n    </div>\n    \n    <div id=\"bfs-steps\">\n        <p>BFS steps will appear here</p>\n    </div>\n    \n    <div class=\"control-group\">\n        <h3>BFS Explanation</h3>\n        <p>Breadth-First Search explores all neighbor nodes at the present depth prior to moving on to nodes at the next depth level.</p>\n        <p>Current step: <span id=\"current-step\">0</span></p>\n        <p>Visited nodes: <span id=\"visited-nodes\">None</span></p>\n        <p>Path to target: <span id=\"path-to-target\">Not calculated</span></p>\n    </div>\n\n    <script>\n        let graph = {};\n        let bfsState = {\n            queue: [],\n            visited: new Set(),\n            current: null,\n            parent: {},\n            step: 0,\n            target: null,\n            found: false,\n            autoStepInterval: null\n        };\n\n        // DOM elements\n        const graphContainer = document.getElementById('graph-container');\n        const adjacencyListInput = document.getElementById('adjacency-list');\n        const nodeCountInput = document.getElementById('node-count');\n        const startNodeInput = document.getElementById('start-node');\n        const targetNodeInput = document.getElementById('target-node');\n        const bfsStepsDiv = document.getElementById('bfs-steps');\n        const queueContentSpan = document.getElementById('queue-content');\n        const currentStepSpan = document.getElementById('current-step');\n        const visitedNodesSpan = document.getElementById('visited-nodes');\n        const pathToTargetSpan = document.getElementById('path-to-target');\n        const speedInput = document.getElementById('speed');\n        const speedValueSpan = document.getElementById('speed-value');\n\n        // Initialize\n        document.getElementById('generate-graph').addEventListener('click', generateRandomGraph);\n        document.getElementById('load-graph').addEventListener('click', loadGraphFromInput);\n        document.getElementById('start-bfs').addEventListener('click', startBFS);\n        document.getElementById('step-bfs').addEventListener('click', stepBFS);\n        document.getElementById('reset-bfs').addEventListener('click', resetBFS);\n        document.getElementById('auto-step').addEventListener('click', startAutoStep);\n        document.getElementById('stop-auto').addEventListener('click', stopAutoStep);\n        speedInput.addEventListener('input', updateSpeed);\n\n        // Generate a random graph\n        function generateRandomGraph() {\n            const nodeCount = parseInt(nodeCountInput.value);\n            graph = {};\n            \n            // Create nodes\n            for (let i = 0; i < nodeCount; i++) {\n                graph[i] = [];\n            }\n            \n            // Create random edges (each node connects to at least one other)\n            for (let i = 0; i < nodeCount; i++) {\n                const edgeCount = Math.max(1, Math.floor(Math.random() * 3));\n                const possibleEdges = [];\n                \n                for (let j = 0; j < nodeCount; j++) {\n                    if (j !== i) possibleEdges.push(j);\n                }\n                \n                // Shuffle and pick first edgeCount edges\n                possibleEdges.sort(() => Math.random() - 0.5);\n                for (let j = 0; j < Math.min(edgeCount, possibleEdges.length); j++) {\n                    const neighbor = possibleEdges[j];\n                    if (!graph[i].includes(neighbor)) {\n                        graph[i].push(neighbor);\n                    }\n                    if (!graph[neighbor].includes(i)) {\n                        graph[neighbor].push(i);\n                    }\n                }\n            }\n            \n            // Update the adjacency list input\n            adjacencyListInput.value = JSON.stringify(graph, null, 4);\n            renderGraph();\n            resetBFS();\n        }\n\n        // Load graph from JSON input\n        function loadGraphFromInput() {\n            try {\n                graph = JSON.parse(adjacencyListInput.value);\n                // Validate the graph\n                for (const node in graph) {\n                    if (!Array.isArray(graph[node])) {\n                        throw new Error(`Node ${node} has invalid edges`);\n                    }\n                }\n                renderGraph();\n                resetBFS();\n            } catch (e) {\n                alert('Invalid graph format: ' + e.message);\n            }\n        }\n\n        // Render the graph visually\n        function renderGraph() {\n            graphContainer.innerHTML = '';\n            \n            for (const node in graph) {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                nodeElement.id = `node-${node}`;\n                nodeElement.textContent = node;\n                nodeElement.addEventListener('click', () => {\n                    startNodeInput.value = node;\n                    resetBFS();\n                });\n                graphContainer.appendChild(nodeElement);\n            }\n        }\n\n        // Update node visualization\n        function updateNodeVisualization() {\n            // Reset all nodes\n            document.querySelectorAll('.node').forEach(nodeEl => {\n                nodeEl.className = 'node';\n            });\n            \n            // Mark visited nodes\n            bfsState.visited.forEach(node => {\n                const nodeEl = document.getElementById(`node-${node}`);\n                if (nodeEl) nodeEl.classList.add('visited');\n            });\n            \n            // Mark nodes in queue\n            bfsState.queue.forEach(node => {\n                const nodeEl = document.getElementById(`node-${node}`);\n                if (nodeEl) nodeEl.classList.add('queue');\n            });\n            \n            // Mark current node\n            if (bfsState.current !== null) {\n                const nodeEl = document.getElementById(`node-${bfsState.current}`);\n                if (nodeEl) nodeEl.classList.add('current');\n            }\n        }\n\n        // Start BFS\n        function startBFS() {\n            resetBFS();\n            const startNode = startNodeInput.value;\n            const targetNode = targetNodeInput.value;\n            \n            if (!graph.hasOwnProperty(startNode)) {\n                alert('Start node does not exist in graph');\n                return;\n            }\n            \n            if (targetNode && !graph.hasOwnProperty(targetNode)) {\n                alert('Target node does not exist in graph');\n                return;\n            }\n            \n            bfsState.queue.push(startNode);\n            bfsState.visited.add(startNode);\n            bfsState.parent[startNode] = null;\n            bfsState.target = targetNode || null;\n            \n            updateBFSDisplay();\n            updateNodeVisualization();\n        }\n\n        // Perform one step of BFS\n        function stepBFS() {\n            if (bfsState.queue.length === 0) {\n                addBFSLog('BFS complete');\n                return;\n            }\n            \n            bfsState.step++;\n            const currentNode = bfsState.queue.shift();\n            bfsState.current = currentNode;\n            \n            addBFSLog(`Processing node ${currentNode}`);\n            \n            // Check if we found the target\n            if (bfsState.target !== null && currentNode === bfsState.target) {\n                bfsState.found = true;\n                addBFSLog(`Found target node ${bfsState.target}!`);\n                showPathToTarget();\n                return;\n            }\n            \n            // Explore neighbors\n            const neighbors = graph[currentNode];\n            for (const neighbor of neighbors) {\n                if (!bfsState.visited.has(neighbor)) {\n                    bfsState.visited.add(neighbor);\n                    bfsState.queue.push(neighbor);\n                    bfsState.parent[neighbor] = currentNode;\n                    addBFSLog(`Discovered node ${neighbor} from ${currentNode}`);\n                }\n            }\n            \n            updateBFSDisplay();\n            updateNodeVisualization();\n        }\n\n        // Show path to target if found\n        function showPathToTarget() {\n            if (!bfsState.found || bfsState.target === null) {\n                pathToTargetSpan.textContent = 'Not found or no target specified';\n                return;\n            }\n            \n            const path = [];\n            let current = bfsState.target;\n            while (current !== null) {\n                path.unshift(current);\n                current = bfsState.parent[current];\n            }\n            \n            pathToTargetSpan.textContent = path.join(' → ');\n            updateBFSDisplay();\n            updateNodeVisualization();\n        }\n\n        // Reset BFS state\n        function resetBFS() {\n            bfsState = {\n                queue: [],\n                visited: new Set(),\n                current: null,\n                parent: {},\n                step: 0,\n                target: null,\n                found: false\n            };\n            stopAutoStep();\n            bfsStepsDiv.innerHTML = '<p>BFS steps will appear here</p>';\n            queueContentSpan.textContent = '[]';\n            currentStepSpan.textContent = '0';\n            visitedNodesSpan.textContent = 'None';\n            pathToTargetSpan.textContent = 'Not calculated';\n            updateNodeVisualization();\n        }\n\n        // Update BFS display information\n        function updateBFSDisplay() {\n            queueContentSpan.textContent = JSON.stringify(bfsState.queue);\n            currentStepSpan.textContent = bfsState.step;\n            visitedNodesSpan.textContent = Array.from(bfsState.visited).join(', ');\n        }\n\n        // Add log entry to BFS steps\n        function addBFSLog(message) {\n            const logEntry = document.createElement('div');\n            logEntry.textContent = `Step ${bfsState.step}: ${message}`;\n            bfsStepsDiv.appendChild(logEntry);\n            bfsStepsDiv.scrollTop = bfsStepsDiv.scrollHeight;\n        }\n\n        // Auto-step functionality\n        function startAutoStep() {\n            if (bfsState.queue.length === 0 && bfsState.step === 0) {\n                startBFS();\n            }\n            \n            if (bfsState.queue.length === 0 && bfsState.step > 0) {\n                return; // BFS already complete\n            }\n            \n            stopAutoStep();\n            const speed = parseInt(speedInput.value);\n            bfsState.autoStepInterval = setInterval(stepBFS, speed);\n        }\n\n        function stopAutoStep() {\n            if (bfsState.autoStepInterval) {\n                clearInterval(bfsState.autoStepInterval);\n                bfsState.autoStepInterval = null;\n            }\n        }\n\n        function updateSpeed() {\n            const speed = speedInput.value;\n            speedValueSpan.textContent = `${speed}ms`;\n            \n            if (bfsState.autoStepInterval) {\n                stopAutoStep();\n                startAutoStep();\n            }\n        }\n\n        // Initialize with a default graph\n        window.onload = function() {\n            loadGraphFromInput();\n        };\n    </script>\n</body>\n</html>"
  },
