ist.remove('active');\n            button.classList.add('disabled');\n        }\n\n        function sign() {\n            const password = document.getElementById('password-field').value;\n            const text = document.getElementById('text-field').value;\n            const signatureBuffer = signature.sign(password, 'SHA256');\n            const signatureHex = signatureBuffer.toString('hex');\n            const signatureBase64 = signatureBuffer.toString('base64');\n            document.getElementById('input-field-container').innerHTML = `\n                <p>Generated Signature (Hex): ${signatureHex}</p>\n                <p>Generated Signature (Base64): ${signatureBase64}</p>\n            `;\n        }\n    </script>\n</body>\n</html>"
