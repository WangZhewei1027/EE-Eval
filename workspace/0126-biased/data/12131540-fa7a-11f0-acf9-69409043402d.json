  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Tree Interactive Demo</title>\n<style>\n  /* Minimal, unstyled except minimal structure */\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n  }\n  #tree-display {\n    white-space: pre;\n    font-family: monospace;\n    margin-top: 10px;\n    margin-bottom: 10px;\n  }\n  #log {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    height: 150px;\n    overflow-y: scroll;\n    margin-top: 5px;\n    margin-bottom: 15px;\n    padding: 5px;\n    font-family: monospace;\n  }\n  fieldset {\n    margin-bottom: 20px;\n  }\n  input[type=\"number\"] {\n    width: 60px;\n  }\n  button {\n    margin: 2px 5px 2px 0;\n  }\n</style>\n</head>\n<body>\n<h1>Binary Search Tree (BST) Interactive Demo</h1>\n\n<fieldset>\n<legend>Node Operations</legend>\n<label for=\"insert-value\">Insert value:</label>\n<input type=\"number\" id=\"insert-value\" />\n<button id=\"insert-btn\">Insert</button>\n<br /><br />\n<label for=\"delete-value\">Delete value:</label>\n<input type=\"number\" id=\"delete-value\" />\n<button id=\"delete-btn\">Delete</button>\n<br /><br />\n<label for=\"search-value\">Search value:</label>\n<input type=\"number\" id=\"search-value\" />\n<button id=\"search-btn\">Search</button>\n<br /><br />\n<button id=\"clear-tree-btn\">Clear Tree</button>\n</fieldset>\n\n<fieldset>\n<legend>Traversals</legend>\n<button id=\"inorder-btn\">Inorder</button>\n<button id=\"preorder-btn\">Preorder</button>\n<button id=\"postorder-btn\">Postorder</button>\n<button id=\"levelorder-btn\">Level-order (BFS)</button>\n<br /><br />\n<label for=\"traversal-delay\">Traversal step delay (ms): </label>\n<input type=\"number\" id=\"traversal-delay\" value=\"500\" min=\"0\" step=\"100\" />\n<button id=\"traversal-toggle-btn\">Start Traversal</button>\n<button id=\"traversal-step-btn\" disabled>Step</button>\n<button id=\"traversal-reset-btn\">Reset Traversal</button>\n</fieldset>\n\n<fieldset>\n<legend>Tree Info & Queries</legend>\n<button id=\"height-btn\">Calculate Height</button>\n<button id=\"count-nodes-btn\">Count Nodes</button>\n<button id=\"count-leaves-btn\">Count Leaves</button>\n<button id=\"min-value-btn\">Find Minimum</button>\n<button id=\"max-value-btn\">Find Maximum</button>\n<button id=\"is-bst-btn\">Validate BST Property</button>\n<br /><br />\n<label for=\"kth-smallest-value\">Find k-th Smallest (k):</label>\n<input type=\"number\" id=\"kth-smallest-value\" min=\"1\" />\n<button id=\"kth-smallest-btn\">Find</button>\n<br /><br />\n<label for=\"range-min\">Range min:</label>\n<input type=\"number\" id=\"range-min\" />\n<label for=\"range-max\">max:</label>\n<input type=\"number\" id=\"range-max\" />\n<button id=\"range-search-btn\">Range Search</button>\n</fieldset>\n\n<fieldset>\n<legend>Node Highlight & Interaction</legend>\n<label for=\"highlight-value\">Highlight value:</label>\n<input type=\"number\" id=\"highlight-value\" />\n<button id=\"highlight-btn\">Highlight</button>\n<button id=\"clear-highlight-btn\">Clear Highlight</button>\n<br /><br />\n<button id=\"show-path-btn\">Show Path to Value</button>\n<input type=\"number\" id=\"path-value\" />\n<button id=\"clear-path-btn\">Clear Path Highlight</button>\n</fieldset>\n\n<fieldset>\n<legend>Batch Operations</legend>\n<label for=\"batch-input\">Comma separated integers:</label>\n<input type=\"text\" id=\"batch-input\" style=\"width: 300px\" />\n<button id=\"batch-insert-btn\">Batch Insert</button>\n<button id=\"batch-delete-btn\">Batch Delete</button>\n<button id=\"batch-search-btn\">Batch Search</button>\n</fieldset>\n\n<div>\n<h2>BST Structure Visualization</h2>\n<pre id=\"tree-display\">(Empty Tree)</pre>\n</div>\n\n<div>\n<h2>Console Log (Operation trace & info)</h2>\n<div id=\"log\"></div>\n<button id=\"clear-log-btn\">Clear Log</button>\n</div>\n\n<script>\n(() => {\n  'use strict';\n\n  // --- BST Node and Tree Implementation ---\n  class BSTNode {\n    constructor(value) {\n      this.value = value;\n      this.left = null;\n      this.right = null;\n    }\n  }\n\n  class BST {\n    constructor() {\n      this.root = null;\n    }\n\n    insert(value) {\n      if (typeof value !== 'number' || !Number.isFinite(value)) return false;\n      this.root = insertRec(this.root, value);\n      function insertRec(node, val) {\n        if (node === null) return new BSTNode(val);\n        if (val === node.value) return node; // no duplicates\n        if (val < node.value) node.left = insertRec(node.left, val);\n        else node.right = insertRec(node.right, val);\n        return node;\n      }\n      return true;\n    }\n\n    delete(value) {\n      let deleted = false;\n      const deleteRec = (node, val) => {\n        if (node === null) return null;\n        if (val < node.value) node.left = deleteRec(node.left, val);\n        else if (val > node.value) node.right = deleteRec(node.right, val);\n        else {\n          deleted = true;\n          // Node with only one child or no child\n          if (node.left === null) return node.right;\n          else if (node.right === null) return node.left;\n          // Node with two children\n          node.value = minValue(node.right);\n          node.right = deleteRec(node.right, node.value);\n        }\n        return node;\n      };\n      const minValue = (node) => {\n        let current = node;\n        while (current.left !== null) current = current.left;\n        return current.value;\n      };\n      this.root = deleteRec(this.root, value);\n      return deleted;\n    }\n\n    search(value) {\n      let node = this.root;\n      const path = [];\n      while (node !== null) {\n        path.push(node);\n        if (value === node.value) return { found: true, path };\n        if (value < node.value) node = node.left;\n        else node = node.right;\n      }\n      return { found: false, path };\n    }\n\n    inorder(callback) {\n      const arr = [];\n      inorderRec(this.root);\n      function inorderRec(node) {\n        if (!node) return;\n        inorderRec(node.left);\n        arr.push(node);\n        inorderRec(node.right);\n      }\n      return arr;\n    }\n\n    preorder(callback) {\n      const arr = [];\n      preorderRec(this.root);\n      function preorderRec(node) {\n        if (!node) return;\n        arr.push(node);\n        preorderRec(node.left);\n        preorderRec(node.right);\n      }\n      return arr;\n    }\n\n    postorder(callback) {\n      const arr = [];\n      postorderRec(this.root);\n      function postorderRec(node) {\n        if (!node) return;\n        postorderRec(node.left);\n        postorderRec(node.right);\n        arr.push(node);\n      }\n      return arr;\n    }\n\n    levelorder() {\n      const arr = [];\n      if (!this.root) return arr;\n      const queue = [this.root];\n      while(queue.length) {\n        const node = queue.shift();\n        arr.push(node);\n        if (node.left) queue.push(node.left);\n        if (node.right) queue.push(node.right);\n      }\n      return arr;\n    }\n\n    height() {\n      function heightRec(node) {\n        if (!node) return 0;\n        return 1 + Math.max(heightRec(node.left), heightRec(node.right));\n      }\n      return heightRec(this.root);\n    }\n\n    countNodes() {\n      let cnt = 0;\n      function countRec(node) {\n        if (!node) return;\n        cnt++;\n        countRec(node.left);\n        countRec(node.right);\n      }\n      countRec(this.root);\n      return cnt;\n    }\n\n    countLeaves() {\n      let cnt = 0;\n      function leavesRec(node) {\n        if (!node) return;\n        if (!node.left && !node.right) cnt++;\n        leavesRec(node.left);\n        leavesRec(node.right);\n      }\n      leavesRec(this.root);\n      return cnt;\n    }\n\n    findMin() {\n      if (!this.root) return null;\n      let current = this.root;\n      while (current.left) current = current.left;\n      return current.value;\n    }\n\n    findMax() {\n      if (!this.root) return null;\n      let current = this.root;\n      while (current.right) current = current.right;\n      return current.value;\n    }\n\n    isBST() {\n      function validate(node, low, high) {\n        if (!node) return true;\n        if ((low !== null && node.value <= low) || (high !== null && node.value >= high)) return false;\n        return validate(node.left, low, node.value) && validate(node.right, node.value, high);\n      }\n      return validate(this.root, null, null);\n    }\n\n    kthSmallest(k) {\n      if (typeof k !== 'number' || k < 1) return null;\n      let count = 0, result = null;\n      function inorderRec(node) {\n        if (!node || result !== null) return;\n        inorderRec(node.left);\n        count++;\n        if (count === k) {\n          result = node.value;\n          return;\n        }\n        inorderRec(node.right);\n      }\n      inorderRec(this.root);\n      return result;\n    }\n\n    rangeSearch(minVal, maxVal) {\n      const result = [];\n      function rangeRec(node) {\n        if (!node) return;\n        if (node.value > minVal) rangeRec(node.left);\n        if (node.value >= minVal && node.value <= maxVal) result.push(node.value);\n        if (node.value < maxVal) rangeRec(node.right);\n      }\n      rangeRec(this.root);\n      return result;\n    }\n\n    clear() {\n      this.root = null;\n    }\n  }\n\n  // --- Helpers for displaying the tree ---\n  // We'll show multi-level tree textual display (very rough)\n  // The approach: level-order with spacing and lines (not too fancy)\n  // Since minimal styling, simple textual lines with indentation and pointers\n\n  function getLevels(root) {\n    const levels = [];\n    if (!root) return levels;\n    let queue = [{node: root, level:0}];\n    while(queue.length) {\n      const {node, level} = queue.shift();\n      if (levels.length === level) levels.push([]);\n      levels[level].push(node);\n      if (node) {\n        queue.push({node: node.left, level: level+1});\n        queue.push({node: node.right, level: level+1});\n      }\n    }\n    // Remove trailing levels with only nulls\n    while (levels.length && levels[levels.length-1].every(n => n===null)) {\n      levels.pop();\n    }\n    return levels;\n  }\n\n  // Produce a simple textual tree representation vertically\n  // Each level on a line: print node values or spaces, pointer lines\n  // This is a minimal hack, no complex formatting\n  function renderTree(root, highlightValues = [], pathNodes = []) {\n    if (!root) return \"(Empty Tree)\";\n    const levels = getLevels(root);\n    const maxLevel = levels.length;\n    const maxWidth = Math.pow(2, maxLevel) - 1; // max elems at last level\n\n    // We'll represent the tree lines in an array of strings\n    let outputLines = [];\n    // For each level create a line using fixed width spacing\n    // nodeStr with mark if highlighted or path\n    for(let i=0; i<levels.length; i++) {\n      const level = levels[i];\n      // spacing count: total slots is maxWidth, nodes are placed with gaps\n      // slots for this level = 2^i\n      const slots = Math.pow(2, i);\n      const spaceBetween = Math.floor(maxWidth / slots);\n      let line = \"\";\n      for(let j=0; j<slots; j++) {\n        const node = level[j];\n        let nodeStr = \" \";\n        if (node) {\n          nodeStr = node.value.toString();\n          if (highlightValues.indexOf(node.value) !== -1) nodeStr = \"[\" + nodeStr + \"]\";\n          else if (pathNodes.indexOf(node) !== -1) nodeStr = \"(\"+nodeStr+\")\";\n        }\n        // pad nodeStr to length 3, left aligned (pad right)\n        if (nodeStr.length < 3) nodeStr = nodeStr + \" \".repeat(3 - nodeStr.length);\n        line += nodeStr;\n        if (j < slots -1) line += \" \".repeat(spaceBetween*3 -3);\n      }\n      outputLines.push(line);\n\n      // Add connection line if not last level\n      if (i < levels.length -1) {\n        // For each parent node, show / and \\ under them when children present\n        let connectionLine = \"\";\n        for(let j=0; j<slots; j++) {\n          const node = level[j];\n          if (node) {\n            // if left child exists\n            connectionLine += node.left ? \" / \" : \"   \";\n            connectionLine += \" \".repeat(spaceBetween*3 -3);\n            // similarly for right child, but spacing already handled by spaceBetween*3\n          } else {\n            // No parent node - spacing for two children\n            connectionLine += \"   \" + \" \".repeat(spaceBetween*3 -3);\n          }\n        }\n        outputLines.push(connectionLine);\n      }\n    }\n\n    return outputLines.join(\"\\n\");\n  }\n\n  // --- Main Script ---\n\n  // Elements\n  const insertValueInput = document.getElementById('insert-value');\n  const insertBtn = document.getElementById('insert-btn');\n\n  const deleteValueInput = document.getElementById('delete-value');\n  const deleteBtn = document.getElementById('delete-btn');\n\n  const searchValueInput = document.getElementById('search-value');\n  const searchBtn = document.getElementById('search-btn');\n\n  const clearTreeBtn = document.getElementById('clear-tree-btn');\n\n  const inorderBtn = document.getElementById('inorder-btn');\n  const preorderBtn = document.getElementById('preorder-btn');\n  const postorderBtn = document.getElementById('postorder-btn');\n  const levelorderBtn = document.getElementById('levelorder-btn');\n\n  const traversalDelayInput = document.getElementById('traversal-delay');\n  const traversalToggleBtn = document.getElementById('traversal-toggle-btn');\n  const traversalStepBtn = document.getElementById('traversal-step-btn');\n  const traversalResetBtn = document.getElementById('traversal-reset-btn');\n\n  const heightBtn = document.getElementById('height-btn');\n  const countNodesBtn = document.getElementById('count-nodes-btn');\n  const countLeavesBtn = document.getElementById('count-leaves-btn');\n  const minValueBtn = document.getElementById('min-value-btn');\n  const maxValueBtn = document.getElementById('max-value-btn');\n  const isBSTBtn = document.getElementById('is-bst-btn');\n\n  const kthSmallestInput = document.getElementById('kth-smallest-value');\n  const kthSmallestBtn = document.getElementById('kth-smallest-btn');\n\n  const rangeMinInput = document.getElementById('range-min');\n  const rangeMaxInput = document.getElementById('range-max');\n  const rangeSearchBtn = document.getElementById('range-search-btn');\n\n  const highlightValueInput = document.getElementById('highlight-value');\n  const highlightBtn = document.getElementById('highlight-btn');\n  const clearHighlightBtn = document.getElementById('clear-highlight-btn');\n\n  const showPathBtn = document.getElementById('show-path-btn');\n  const pathValueInput = document.getElementById('path-value');\n  const clearPathBtn = document.getElementById('clear-path-btn');\n\n  const batchInput = document.getElementById('batch-input');\n  const batchInsertBtn = document.getElementById('batch-insert-btn');\n  const batchDeleteBtn = document.getElementById('batch-delete-btn');\n  const batchSearchBtn = document.getElementById('batch-search-btn');\n\n  const treeDisplay = document.getElementById('tree-display');\n  const logDiv = document.getElementById('log');\n  const clearLogBtn = document.getElementById('clear-log-btn');\n\n  // State variables\n  const bst = new BST();\n\n  // For traversal walk\n  let traversalNodes = [];\n  let traversalIndex = 0;\n  let traversalTimer = null;\n  let traversalRunning = false;\n  let currentTraversalType = null; // inorder, preorder, postorder, levelorder\n  const highlightNodes = []; // for highlighting values\n  let pathHighlightNodes = [];\n\n  // Utility log function\n  function log(msg) {\n    const time = new Date().toLocaleTimeString();\n    logDiv.textContent += `[${time}] ${msg}\\n`;\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  function clearLog() {\n    logDiv.textContent = \"\";\n  }\n\n  function updateTreeDisplay() {\n    treeDisplay.textContent = renderTree(bst.root, highlightNodes, pathHighlightNodes);\n  }\n\n  // Highlight management\n  function addHighlight(value) {\n    if (!highlightNodes.includes(value)) highlightNodes.push(value);\n  }\n  function clearHighlights() {\n    highlightNodes.length = 0;\n  }\n  function clearPathHighlights() {\n    pathHighlightNodes.length = 0;\n  }\n\n  // Traversal step function\n  function traversalStep() {\n    if (traversalIndex >= traversalNodes.length) {\n      traversalStepEnd();\n      return;\n    }\n    // Highlight current node only, clearing prior highlights on traversal\n    clearHighlights();\n    addHighlight(traversalNodes[traversalIndex].value);\n    updateTreeDisplay();\n    log(`Traversal step: visiting node ${traversalNodes[traversalIndex].value} (${currentTraversalType})`);\n\n    traversalIndex++;\n  }\n\n  // Called when traversal ends/stops\n  function traversalStepEnd() {\n    traversalRunning = false;\n    traversalNodes = [];\n    traversalIndex = 0;\n    currentTraversalType = null;\n    traversalToggleBtn.textContent = \"Start Traversal\";\n    traversalStepBtn.disabled = true;\n    clearHighlights();\n    updateTreeDisplay();\n    if (traversalTimer) {\n      clearInterval(traversalTimer);\n      traversalTimer = null;\n    }\n    log(\"Traversal ended.\");\n  }\n\n  // Start traversal as per selected type\n  function startTraversal(type) {\n    if (traversalRunning) return; // already running\n    currentTraversalType = type.toLowerCase();\n    switch(currentTraversalType) {\n      case \"inorder\": traversalNodes = bst.inorder(); break;\n      case \"preorder\": traversalNodes = bst.preorder(); break;\n      case \"postorder\": traversalNodes = bst.postorder(); break;\n      case \"levelorder\": traversalNodes = bst.levelorder(); break;\n      default:\n        log(\"Unknown traversal type\");\n        return;\n    }\n    if (traversalNodes.length === 0) {\n      log(\"Tree is empty, nothing to traverse.\");\n      return;\n    }\n    traversalRunning = true;\n    traversalIndex = 0;\n    traversalToggleBtn.textContent = \"Stop Traversal\";\n    traversalStepBtn.disabled = false;\n    const delay = parseInt(traversalDelayInput.value) || 500;\n    if (delay > 0) {\n      traversalTimer = setInterval(() => {\n        traversalStep();\n        if (traversalIndex >= traversalNodes.length) traversalStepEnd();\n      }, delay);\n    } else {\n      // If delay is zero or not positive, disable timer and expect manual stepping\n      clearInterval(traversalTimer);\n      traversalTimer = null;\n      log(\"Traversal running in manual step mode (delay=0). Use Step button.\");\n    }\n    log(`Traversal started: ${type}`);\n  }\n\n  // Stop current traversal\n  function stopTraversal() {\n    traversalStepEnd();\n  }\n\n  // Reset traversal state\n  function resetTraversal() {\n    if (traversalRunning && traversalTimer) {\n      clearInterval(traversalTimer);\n      traversalTimer = null;\n    }\n    traversalRunning = false;\n    traversalNodes = [];\n    traversalIndex = 0;\n    currentTraversalType = null;\n    traversalToggleBtn.textContent = \"Start Traversal\";\n    traversalStepBtn.disabled = true;\n    clearHighlights();\n    updateTreeDisplay();\n    log(\"Traversal reset.\");\n  }\n\n  // --- Event Listeners ---\n\n  insertBtn.addEventListener('click', () => {\n    const v = parseInt(insertValueInput.value);\n    if (isNaN(v)) {\n      log(\"Insert: Invalid input\");\n      return;\n    }\n    const inserted = bst.insert(v);\n    if (inserted) {\n      log(`Inserted value ${v}`);\n      updateTreeDisplay();\n    } else {\n      log(`Insert: Value ${v} already exists or invalid`);\n    }\n  });\n\n  deleteBtn.addEventListener('click', () => {\n    const v = parseInt(deleteValueInput.value);\n    if (isNaN(v)) {\n      log(\"Delete: Invalid input\");\n      return;\n    }\n    const deleted = bst.delete(v);\n    if (deleted) {\n      log(`Deleted value ${v}`);\n      updateTreeDisplay();\n      // Also clear path or highlights if affected\n      clearHighlights();\n      clearPathHighlights();\n    } else {\n      log(`Delete: Value ${v} not found`);\n    }\n  });\n\n  searchBtn.addEventListener('click', () => {\n    const v = parseInt(searchValueInput.value);\n    if (isNaN(v)) {\n      log(\"Search: Invalid input\");\n      return;\n    }\n    const res = bst.search(v);\n    if (res.found) {\n      log(`Search: Value ${v} found. Path length: ${res.path.length}`);\n      clearHighlights();\n      clearPathHighlights();\n      res.path.forEach(n => addHighlight(n.value));\n      updateTreeDisplay();\n    } else {\n      log(`Search: Value ${v} not found. Closest path length: ${res.path.length}`);\n      clearHighlights();\n      clearPathHighlights();\n      res.path.forEach(n => addHighlight(n.value));\n      updateTreeDisplay();\n    }\n  });\n\n  clearTreeBtn.addEventListener('click', () => {\n    bst.clear();\n    clearHighlights();\n    clearPathHighlights();\n    updateTreeDisplay();\n    log(\"Tree cleared.\");\n    resetTraversal();\n  });\n\n  inorderBtn.addEventListener('click', () => {\n    if (traversalRunning) {\n      log(\"Traversal already running. Stop traversal to start another.\");\n      return;\n    }\n    startTraversal(\"inorder\");\n  });\n\n  preorderBtn.addEventListener('click', () => {\n    if (traversalRunning) {\n      log(\"Traversal already running. Stop traversal to start another.\");\n      return;\n    }\n    startTraversal(\"preorder\");\n  });\n\n  postorderBtn.addEventListener('click', () => {\n    if (traversalRunning) {\n      log(\"Traversal already running. Stop traversal to start another.\");\n      return;\n    }\n    startTraversal(\"postorder\");\n  });\n\n  levelorderBtn.addEventListener('click', () => {\n    if (traversalRunning) {\n      log(\"Traversal already running. Stop traversal to start another.\");\n      return;\n    }\n    startTraversal(\"levelorder\");\n  });\n\n  traversalToggleBtn.addEventListener('click', () => {\n    if (traversalRunning) {\n      stopTraversal();\n    } else {\n      if (!currentTraversalType) {\n        log(\"No traversal type selected. Use traversal buttons to start.\");\n        return;\n      }\n      startTraversal(currentTraversalType);\n    }\n  });\n\n  traversalStepBtn.addEventListener('click', () => {\n    if (!traversalRunning) {\n      log(\"Traversal not active. Start traversal first.\");\n      return;\n    }\n    if (traversalTimer) {\n      log(\"Traversal running in auto mode. Stop auto to step manually.\");\n      return;\n    }\n    traversalStep();\n    if (traversalIndex >= traversalNodes.length) traversalStepEnd();\n  });\n\n  traversalResetBtn.addEventListener('click', () => {\n    resetTraversal();\n  });\n\n  heightBtn.addEventListener('click', () => {\n    const h = bst.height();\n    log(`Tree height: ${h}`);\n  });\n\n  countNodesBtn.addEventListener('click', () => {\n    const c = bst.countNodes();\n    log(`Total nodes: ${c}`);\n  });\n\n  countLeavesBtn.addEventListener('click', () => {\n    const c = bst.countLeaves();\n    log(`Leaf nodes: ${c}`);\n  });\n\n  minValueBtn.addEventListener('click', () => {\n    const min = bst.findMin();\n    if (min === null) log(\"Tree is empty.\");\n    else log(`Minimum value: ${min}`);\n  });\n\n  maxValueBtn.addEventListener('click', () => {\n    const max = bst.findMax();\n    if (max === null) log(\"Tree is empty.\");\n    else log(`Maximum value: ${max}`);\n  });\n\n  isBSTBtn.addEventListener('click', () => {\n    const valid = bst.isBST();\n    log(`BST property valid: ${valid ? \"Yes\" : \"No\"}`);\n  });\n\n  kthSmallestBtn.addEventListener('click', () => {\n    const k = parseInt(kthSmallestInput.value);\n    if (isNaN(k) || k < 1) {\n      log(\"k-th Smallest: Invalid k value\");\n      return;\n    }\n    const val = bst.kthSmallest(k);\n    if (val === null) log(`k-th Smallest: Tree has fewer than ${k} nodes.`);\n    else log(`k-th Smallest value (k=${k}): ${val}`);\n  });\n\n  rangeSearchBtn.addEventListener('click', () => {\n    const minV = parseInt(rangeMinInput.value);\n    const maxV = parseInt(rangeMaxInput.value);\n    if (isNaN(minV) || isNaN(maxV) || minV > maxV) {\n      log(\"Range search: Invalid range input\");\n      return;\n    }\n    const results = bst.rangeSearch(minV, maxV);\n    log(`Range search [${minV}, ${maxV}] found ${results.length} value(s): ${results.join(\", \")}`);\n    clearHighlights();\n    results.forEach(v => addHighlight(v));\n    updateTreeDisplay();\n  });\n\n  highlightBtn.addEventListener('click', () => {\n    const v = parseInt(highlightValueInput.value);\n    if (isNaN(v)) {\n      log(\"Highlight: Invalid input\");\n      return;\n    }\n    clearHighlights();\n    addHighlight(v);\n    updateTreeDisplay();\n    log(`Highlighted node with value ${v} (even if not present)`);\n  });\n\n  clearHighlightBtn.addEventListener('click', () => {\n    clearHighlights();\n    updateTreeDisplay();\n    log(\"Cleared highlights.\");\n  });\n\n  showPathBtn.addEventListener('click', () => {\n    const v = parseInt(pathValueInput.value);\n    if (isNaN(v)) {\n      log(\"Show Path: Invalid input\");\n      return;\n    }\n    const res = bst.search(v);\n    clearPathHighlights();\n    if (res.path.length === 0) {\n      log(\"Show Path: Tree empty.\");\n      updateTreeDisplay();\n      return;\n    }\n    pathHighlightNodes.push(...res.path);\n    updateTreeDisplay();\n    if (res.found) {\n      log(`Path to value ${v} highlighted (${res.path.length} nodes)`);\n    } else {\n      log(`Value ${v} not found. Path to closest node highlighted (${res.path.length} nodes)`);\n    }\n  });\n\n  clearPathBtn.addEventListener('click', () => {\n    clearPathHighlights();\n    updateTreeDisplay();\n    log(\"Cleared path highlight.\");\n  });\n\n  batchInsertBtn.addEventListener('click', () => {\n    const values = batchInput.value.split(',').map(s => parseInt(s.trim())).filter(x => !isNaN(x));\n    if (values.length === 0) {\n      log(\"Batch Insert: No valid integers found.\");\n      return;\n    }\n    let insertedCount = 0;\n    values.forEach(v => {\n      if (bst.insert(v)) insertedCount++;\n    });\n    log(`Batch Insert: Tried ${values.length}, successfully inserted ${insertedCount} new nodes.`);\n    updateTreeDisplay();\n  });\n\n  batchDeleteBtn.addEventListener('click', () => {\n    const values = batchInput.value.split(',').map(s => parseInt(s.trim())).filter(x => !isNaN(x));\n    if (values.length === 0) {\n      log(\"Batch Delete: No valid integers found.\");\n      return;\n    }\n    let deletedCount = 0;\n    values.forEach(v => {\n      if (bst.delete(v)) deletedCount++;\n    });\n    log(`Batch Delete: Tried ${values.length}, successfully deleted ${deletedCount} nodes.`);\n    updateTreeDisplay();\n  });\n\n  batchSearchBtn.addEventListener('click', () => {\n    const values = batchInput.value.split(',').map(s => parseInt(s.trim())).filter(x => !isNaN(x));\n    if (values.length === 0) {\n      log(\"Batch Search: No valid integers found.\");\n      return;\n    }\n    clearHighlights();\n    let foundCount = 0;\n    values.forEach(v => {\n      const r = bst.search(v);\n      if (r.found) {\n        foundCount++;\n        addHighlight(v);\n      }\n    });\n    updateTreeDisplay();\n    log(`Batch Search: Searched ${values.length}. Found ${foundCount} values.`);\n  });\n\n  clearLogBtn.addEventListener('click', () => {\n    clearLog();\n  });\n\n  // Initialize\n  updateTreeDisplay();\n  clearHighlights();\n  clearPathHighlights();\n})();\n</script>\n\n</body>\n</html>"
