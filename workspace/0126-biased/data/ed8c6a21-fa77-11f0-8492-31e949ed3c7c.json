    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Doubly Linked List Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #8e44ad, #3498db);\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n        #container {\n            text-align: center;\n        }\n        h1 {\n            font-size: 3rem;\n            margin-bottom: 20px;\n        }\n        .list {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            transition: transform 0.3s ease-in-out;\n        }\n        .node {\n            background: #2c3e50;\n            border-radius: 10px;\n            padding: 20px;\n            margin: 0 10px;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n            position: relative;\n            transition: transform 0.3s ease;\n        }\n        .node:hover {\n            transform: scale(1.05);\n        }\n        .arrow {\n            margin: 0 5px;\n            font-size: 2rem;\n            transition: opacity 0.3s ease;\n        }\n        .arrow.hidden {\n            opacity: 0;\n        }\n        .button {\n            background: #e74c3c;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            margin-top: 25px;\n            cursor: pointer;\n            font-size: 1rem;\n            color: white;\n            transition: background 0.3s ease;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n        }\n        .button:hover {\n            background: #c0392b;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <h1>Doubly Linked List Visualization</h1>\n        <div class=\"list\" id=\"doublyLinkedList\">\n            <div class=\"node\">Node 1</div>\n            <span class=\"arrow\">⇄</span>\n            <div class=\"node\">Node 2</div>\n            <span class=\"arrow hidden\">⇄</span>\n            <div class=\"node\">Node 3</div>\n        </div>\n        <button class=\"button\" onclick=\"addNode()\">Add Node</button>\n    </div>\n\n    <script>\n        let nodeCount = 3;\n\n        function addNode() {\n            const list = document.getElementById('doublyLinkedList');\n            const newNode = document.createElement('div');\n            newNode.classList.add('node');\n            newNode.textContent = `Node ${++nodeCount}`;\n\n            const arrow = document.createElement('span');\n            arrow.classList.add('arrow');\n            arrow.textContent = \"⇄\";\n\n            if (list.lastChild.className === \"node\") {\n                list.appendChild(arrow);\n            }\n            list.appendChild(newNode);\n        }\n    </script>\n</body>\n</html>"
