    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tim Sort Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            line-height: 1.6;\n        }\n    </style>\n</head>\n<body>\n    <h1>Tim Sort Interactive Demo</h1>\n    \n    <label for=\"arrayInput\">Enter array (comma separated):</label>\n    <input type=\"text\" id=\"arrayInput\" value=\"5,21,7,1,89,16\" />\n    <button onclick=\"initSort()\">Initialize Sort</button>\n    <br/><br/>\n    \n    <button onclick=\"sortArray()\">Sort Array</button>\n    <button onclick=\"resetArray()\">Reset Array</button>\n    <label for=\"size\">Run size:</label>\n    <input type=\"number\" id=\"size\" value=\"5\" min=\"1\" />\n    <br/><br/>\n    \n    <h2>Current State:</h2>\n    <pre id=\"currentArray\"></pre>\n    \n    <script>\n        let originalArray = [];\n        let sortedArray = [];\n        let runSize = 5;\n\n        function initSort() {\n            originalArray = document.getElementById('arrayInput').value.split(',').map(Number);\n            sortedArray = [...originalArray];\n            displayCurrent();\n        }\n\n        function displayCurrent() {\n            document.getElementById('currentArray').innerText = JSON.stringify(sortedArray);\n        }\n\n        function insertionSort(arr, left, right) {\n            for (let i = left + 1; i <= right; i++) {\n                let key = arr[i];\n                let j = i - 1;\n                while (j >= left && arr[j] > key) {\n                    arr[j + 1] = arr[j];\n                    j--;\n                }\n                arr[j + 1] = key;\n            }\n        }\n\n        function merge(arr, left, mid, right) {\n            let leftArray = arr.slice(left, mid + 1);\n            let rightArray = arr.slice(mid + 1, right + 1);\n            let i = 0, j = 0, k = left;\n\n            while (i < leftArray.length && j < rightArray.length) {\n                if (leftArray[i] <= rightArray[j]) {\n                    arr[k++] = leftArray[i++];\n                } else {\n                    arr[k++] = rightArray[j++];\n                }\n            }\n            while (i < leftArray.length) {\n                arr[k++] = leftArray[i++];\n            }\n            while (j < rightArray.length) {\n                arr[k++] = rightArray[j++];\n            }\n        }\n\n        function timSort() {\n            for (let start = 0; start < sortedArray.length; start += runSize) {\n                let end = Math.min(start + runSize - 1, sortedArray.length - 1);\n                insertionSort(sortedArray, start, end);\n            }\n            for (let size = runSize; size < sortedArray.length; size *= 2) {\n                for (let left = 0; left < sortedArray.length; left += 2 * size) {\n                    let mid = Math.min(left + size - 1, sortedArray.length - 1);\n                    let right = Math.min((left + 2 * size - 1), (sortedArray.length - 1));\n                    if (mid < right) {\n                        merge(sortedArray, left, mid, right);\n                    }\n                }\n            }\n        }\n\n        function sortArray() {\n            runSize = parseInt(document.getElementById('size').value);\n            timSort();\n            displayCurrent();\n        }\n\n        function resetArray() {\n            document.getElementById('arrayInput').value = originalArray.join(',');\n            initSort();\n        }\n    </script>\n</body>\n</html>"
