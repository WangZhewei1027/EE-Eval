  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Big-O Notation Interactive Explorer</title>\n<style>\n/* Minimal styling only to make layout usable; keep visual plain (black on white). */\nbody { font-family: sans-serif; margin: 12px; color: #000; background: #fff; }\nh1 { font-size: 18px; margin: 0 0 8px 0; }\nsection { margin: 8px 0; padding: 0; }\nlabel { display: inline-block; margin-right: 8px; }\ninput[type=\"range\"] { width: 220px; vertical-align: middle; }\ncanvas { border: 1px solid #000; display: block; margin-top: 8px; }\ntextarea { width: 100%; height: 120px; }\nbutton { margin-right: 6px; }\n.small { font-size: 12px; }\n.split { display: flex; gap: 12px; }\n.col { flex: 1; }\n.log { white-space: pre-wrap; font-family: monospace; border: 1px solid #000; padding: 6px; height: 150px; overflow: auto; }\n.controls { margin-bottom: 8px; }\n.inline { display: inline-block; margin-right: 8px; }\n</style>\n</head>\n<body>\n<h1>Big-O Notation Interactive Explorer</h1>\n\n<section>\n  <div class=\"controls\">\n    <label for=\"mode\">Mode:</label>\n    <select id=\"mode\">\n      <option value=\"predefined\">Predefined Algorithm</option>\n      <option value=\"custom\">Custom Function</option>\n      <option value=\"compare\">Compare Algorithms</option>\n      <option value=\"fit\">Hypothesis Fit</option>\n    </select>\n  </div>\n\n  <!-- Predefined algorithms -->\n  <div id=\"predefinedArea\">\n    <label for=\"algorithm\">Algorithm:</label>\n    <select id=\"algorithm\">\n      <option value=\"const\">O(1) - Access element</option>\n      <option value=\"binary\">O(log n) - Binary Search</option>\n      <option value=\"linear\">O(n) - Linear Search</option>\n      <option value=\"merge\">O(n log n) - Merge Sort (counts comparisons & copies)</option>\n      <option value=\"bubble\">O(n^2) - Bubble Sort</option>\n      <option value=\"quick\">O(n log n) - Quick Sort (average)</option>\n      <option value=\"fib\">O(2^n) - Naive Fibonacci (counts calls)</option>\n      <option value=\"perm\">O(n!) - Permutation generation (counts permutations)</option>\n    </select>\n\n    <div style=\"margin-top:6px;\">\n      <label for=\"nSlider\">N (size):</label>\n      <input id=\"nSlider\" type=\"range\" min=\"1\" max=\"200\" value=\"20\">\n      <input id=\"nValue\" type=\"number\" value=\"20\" style=\"width:60px\">\n      <label class=\"small\"><input id=\"fastMode\" type=\"checkbox\"> Aggregate large steps</label>\n    </div>\n\n    <div style=\"margin-top:6px;\">\n      <label>Array pattern:</label>\n      <select id=\"pattern\">\n        <option value=\"random\">Random</option>\n        <option value=\"sorted\">Sorted</option>\n        <option value=\"reverse\">Reverse</option>\n        <option value=\"nearly\">Nearly-sorted</option>\n      </select>\n\n      <label style=\"margin-left:12px;\">Count:</label>\n      <label><input id=\"countComp\" type=\"checkbox\" checked> Comparisons</label>\n      <label><input id=\"countAssign\" type=\"checkbox\" checked> Assignments</label>\n    </div>\n\n    <div style=\"margin-top:8px;\">\n      <button id=\"runBtn\">Run Simulation</button>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"autoBtn\">Auto-Play</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"resetBtn\">Reset</button>\n      <label style=\"margin-left:8px;\">Speed:</label>\n      <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"300\">\n      <span id=\"speedVal\">300ms</span>\n    </div>\n  </div>\n\n  <!-- Custom function area -->\n  <div id=\"customArea\" style=\"display:none; margin-top:8px;\">\n    <div>\n      <label for=\"customExpr\">Custom count expression (JavaScript, in variable n):</label><br>\n      <input id=\"customExpr\" type=\"text\" value=\"n*n\" style=\"width:100%\">\n      <div class=\"small\">Examples: n, Math.log(n), n*Math.log(n), Math.pow(2,n) (avoid huge n)</div>\n    </div>\n    <div style=\"margin-top:6px;\">\n      <label for=\"customN\">N:</label>\n      <input id=\"customN\" type=\"number\" value=\"20\" style=\"width:80px\">\n      <button id=\"customRun\">Evaluate</button>\n      <button id=\"customPlot\">Plot range</button>\n    </div>\n  </div>\n\n  <!-- Compare area -->\n  <div id=\"compareArea\" style=\"display:none; margin-top:8px;\">\n    <div>\n      <label>Select up to 3 algorithms to compare</label><br>\n      <label><input type=\"checkbox\" class=\"cmpAlg\" value=\"linear\"> Linear</label>\n      <label><input type=\"checkbox\" class=\"cmpAlg\" value=\"binary\"> Binary</label>\n      <label><input type=\"checkbox\" class=\"cmpAlg\" value=\"merge\"> Merge</label>\n      <label><input type=\"checkbox\" class=\"cmpAlg\" value=\"bubble\"> Bubble</label>\n      <label><input type=\"checkbox\" class=\"cmpAlg\" value=\"quick\"> Quick</label>\n      <label><input type=\"checkbox\" class=\"cmpAlg\" value=\"fib\"> Fib(naive)</label>\n    </div>\n    <div style=\"margin-top:6px;\">\n      <label for=\"cmpRange\">Max N:</label>\n      <input id=\"cmpRange\" type=\"range\" min=\"5\" max=\"300\" value=\"100\">\n      <input id=\"cmpRangeVal\" type=\"number\" value=\"100\" style=\"width:80px\">\n      <button id=\"cmpRun\">Plot Compare</button>\n    </div>\n  </div>\n\n  <!-- Fit area -->\n  <div id=\"fitArea\" style=\"display:none; margin-top:8px;\">\n    <div>\n      <label>Hypothesis fit: choose algorithm to observe and test which Big-O class fits best</label>\n      <select id=\"fitAlg\">\n        <option value=\"bubble\">Bubble (n^2)</option>\n        <option value=\"merge\">Merge (n log n)</option>\n        <option value=\"linear\">Linear (n)</option>\n        <option value=\"fib\">Fib naive (2^n)</option>\n      </select>\n      <label style=\"margin-left:8px;\">Max N:</label>\n      <input id=\"fitMaxN\" type=\"number\" value=\"60\" style=\"width:80px\">\n      <button id=\"fitRun\">Run Fit</button>\n    </div>\n  </div>\n</section>\n\n<section class=\"split\">\n  <div class=\"col\">\n    <h2 class=\"small\">Operation Log / Step Inspector</h2>\n    <div id=\"opLog\" class=\"log\"></div>\n    <div style=\"margin-top:6px;\">\n      <button id=\"exportBtn\">Export Results (JSON)</button>\n      <button id=\"importBtn\">Import Results (paste JSON)</button>\n    </div>\n    <textarea id=\"importArea\" placeholder=\"Paste JSON here to import...\" style=\"display:none\"></textarea>\n  </div>\n\n  <div class=\"col\">\n    <h2 class=\"small\">Counts & Plot</h2>\n    <div>\n      <div id=\"countsSummary\" class=\"small\">No run yet.</div>\n      <canvas id=\"plot\" width=\"640\" height=\"240\"></canvas>\n    </div>\n    <div style=\"margin-top:6px;\">\n      <label><input id=\"showRef\" type=\"checkbox\" checked> Show reference curves (n, n log n, n^2)</label>\n      <label style=\"margin-left:12px;\"><input id=\"normalize\" type=\"checkbox\"> Normalize (scale max to 1)</label>\n    </div>\n  </div>\n</section>\n\n<section style=\"margin-top:12px;\">\n  <h2 class=\"small\">Model Fit Scores</h2>\n  <div id=\"fitResults\" class=\"small\">No fit performed.</div>\n</section>\n\n<script>\n/* Big-O Interactive Explorer: heavy on functionality, minimal visuals. */\n\n/* Utilities */\nfunction log(msg) {\n  const el = document.getElementById('opLog');\n  el.textContent = msg + \"\\\\n\" + el.textContent;\n}\nfunction appendLog(msg) {\n  const el = document.getElementById('opLog');\n  el.textContent = msg + \"\\\\n\" + el.textContent;\n}\nfunction clamp(v, a, b){ return Math.max(a, Math.min(b,v)); }\nfunction now() { return new Date().getTime(); }\n\n/* Algorithms: each provides:\n   - count(n, options) -> { comparisons: x, assignments: y, total: x+y }\n   - stepper(n, options) -> generator that yields step objects {desc, comps, assigns}\n   For huge counts, stepper may yield aggregated steps with large deltas.\n*/\n\nconst Algorithms = (function(){\n  function makeConst() {\n    return {\n      count(n){ return {comparisons:1, assignments:0, total:1}; },\n      stepper: function*(n){ yield {desc:'access constant (O(1))', comps:1, assigns:0}; }\n    };\n  }\n\n  function makeBinary() {\n    function count(n){ return {comparisons: Math.ceil(Math.log2(Math.max(1,n))) , assignments:0, total: Math.ceil(Math.log2(Math.max(1,n))) }; }\n    function* stepper(n, opts){\n      let l=0, r=n-1; let comps=0;\n      while(l<=r){\n        let m = Math.floor((l+r)/2);\n        comps++;\n        yield {desc:'compare mid index '+m, comps:1, assigns:0};\n        if(m === Math.floor((n-1)/2)){ // stop via synthetic match at middle for demo\n          break;\n        }\n        // for step demo we simply alternate the bounds\n        if((l+r)%2===0) { r = m-1; } else { l = m+1; }\n      }\n    }\n    return {count, stepper};\n  }\n\n  function makeLinear() {\n    function count(n){ return {comparisons:n, assignments:0, total:n}; }\n    function* stepper(n, opts){\n      for(let i=0;i<n;i++){\n        yield {desc:'check index '+i, comps:1, assigns:0};\n      }\n    }\n    return {count, stepper};\n  }\n\n  function makeBubble() {\n    function count(n){\n      let comps = Math.max(0, (n*(n-1))/2);\n      let assigns = 0; // we count swaps separately: each swap ~3 assignments\n      return {comparisons: comps, assignments: comps>0 ? comps*3/10 : 0, total: comps + (comps*3/10)};\n    }\n    function* stepper(n, opts){\n      let fast = !!opts.fastMode;\n      for(let i=0;i<n;i++){\n        for(let j=0;j<n-1-i;j++){\n          if(fast && n>60){\n            // group many together\n            if(j%100===0) { yield {desc:'grouped comparisons chunk', comps:100, assigns:0}; }\n            continue;\n          }\n          yield {desc:'compare a['+j+'] and a['+(j+1)+']', comps:1, assigns:0};\n          // synthetic swap occasionally for demo\n          if((j+i)%5===0){\n            yield {desc:'swap a['+j+'] and a['+(j+1)+']', comps:0, assigns:3};\n          }\n        }\n      }\n    }\n    return {count, stepper};\n  }\n\n  function makeMerge() {\n    function count(n){\n      // We'll compute comparisons ~ n log n (approx (n*ceil(log2 n)))\n      let comps = 0;\n      function mergesize(k){\n        return k <= 1 ? 0 : Math.floor(k)*Math.ceil(Math.log2(k));\n      }\n      // rougher but okay\n      comps = Math.floor(n * Math.max(1, Math.log2(Math.max(2,n))));\n      return {comparisons: comps, assignments: Math.floor(n*Math.max(1, Math.log2(Math.max(2,n)))), total: comps*2};\n    }\n    function* stepper(n, opts){\n      // We'll simulate merge process by levels\n      let levels = Math.ceil(Math.log2(Math.max(1,n)));\n      for(let level=0; level<levels; level++){\n        let chunk = Math.pow(2, level+1);\n        let groups = Math.ceil(n / chunk);\n        for(let g=0; g<groups; g++){\n          // group yield\n          let comps = Math.min(chunk, n - g*chunk);\n          if(opts.fastMode && n>200){\n            yield {desc:'merge-level '+level+' group '+g+' (aggregated)', comps: comps, assigns: comps};\n          } else {\n            for(let k=0;k<comps;k++) yield {desc:'merge step in group '+g+' item '+k, comps:1, assigns:1};\n          }\n        }\n      }\n    }\n    return {count, stepper};\n  }\n\n  function makeQuick() {\n    function count(n){\n      // average approximate n log n\n      let comps = Math.floor(n * Math.max(1, Math.log2(Math.max(2,n))));\n      return {comparisons: comps, assignments: Math.floor(comps*0.5), total: comps + Math.floor(comps*0.5)};\n    }\n    function* stepper(n, opts){\n      // We simulate partitions\n      function* quickSim(l,r){\n        if(l>=r) return;\n        let pivot = Math.floor((l+r)/2);\n        let partSize = r-l+1;\n        let comps = Math.max(1, Math.floor(partSize * 0.7));\n        if(opts.fastMode && partSize>80){\n          yield {desc:'partition (aggregated) ['+l+','+r+']', comps:comps, assigns:Math.floor(comps*0.3)};\n        } else {\n          for(let i=0;i<comps;i++) yield {desc:'partition compare in ['+l+','+r+']', comps:1, assigns:0};\n        }\n        let mid = pivot;\n        yield* quickSim(l, mid-1);\n        yield* quickSim(mid+1, r);\n      }\n      yield* quickSim(0, n-1);\n    }\n    return {count, stepper};\n  }\n\n  function makeFib() {\n    function count(n){\n      // number of calls ~ 2^n (approx)\n      let calls = Math.pow(2, Math.max(0,n-1));\n      return {comparisons: Math.floor(calls), assignments:0, total: Math.floor(calls)};\n    }\n    function* stepper(n, opts){\n      // We cannot really recurse expensively; we'll yield aggregated call expansions\n      function* fibSim(k){\n        if(k<=1){ yield {desc:'base case fib('+k+')', comps:1, assigns:0}; return; }\n        if(opts.fastMode && k>20){\n          // aggregated representation\n          let est = Math.pow(2, k-1);\n          yield {desc:'aggregate fib('+k+') expands into ~'+Math.floor(est)+' calls', comps: Math.floor(est), assigns:0};\n          return;\n        }\n        yield {desc:'call fib('+k+')', comps:1, assigns:0};\n        yield* fibSim(k-1);\n        yield* fibSim(k-2);\n      }\n      yield* fibSim(n);\n    }\n    return {count, stepper};\n  }\n\n  function makePermutations(){\n    function factorial(n){ let r=1; for(let i=2;i<=n;i++) r*=i; return r; }\n    function count(n){\n      // number of permutations n! ; we'll not return huge numbers beyond safe\n      let perms = factorial(Math.min(12,n)); // cap factorial computation\n      return {comparisons: perms, assignments: perms*1.5, total: perms*2.5};\n    }\n    function* stepper(n, opts){\n      // yield aggregated permutation generation\n      if(opts.fastMode && n>8){\n        yield {desc:'generate n! permutations aggregated', comps: factorial(Math.min(10,n)), assigns:0};\n        return;\n      }\n      // simple recursive permutation generator steps but aggregated\n      function* permSim(k){\n        if(k<=1){ yield {desc:'emit permutation', comps:1, assigns:0}; return; }\n        for(let i=0;i<k;i++){\n          yield* permSim(k-1);\n        }\n      }\n      yield* permSim(n);\n    }\n    return {count, stepper};\n  }\n\n  return {\n    const: makeConst(),\n    binary: makeBinary(),\n    linear: makeLinear(),\n    bubble: makeBubble(),\n    merge: makeMerge(),\n    quick: makeQuick(),\n    fib: makeFib(),\n    perm: makePermutations()\n  };\n})();\n\n/* Global state for stepping / autoplay */\nlet state = {\n  currentStepper: null,\n  running: false,\n  autoTimer: null,\n  accumulated: {comparisons:0, assignments:0, total:0},\n  lastCounts: null,\n  lastRunMetadata: null\n};\n\n/* DOM Hooks */\nconst modeSel = document.getElementById('mode');\nconst predefinedArea = document.getElementById('predefinedArea');\nconst customArea = document.getElementById('customArea');\nconst compareArea = document.getElementById('compareArea');\nconst fitArea = document.getElementById('fitArea');\n\nmodeSel.addEventListener('change', ()=> {\n  const v = modeSel.value;\n  predefinedArea.style.display = (v==='predefined' ? '' : 'none');\n  customArea.style.display = (v==='custom' ? '' : 'none');\n  compareArea.style.display = (v==='compare' ? '' : 'none');\n  fitArea.style.display = (v==='fit' ? '' : 'none');\n});\n\n/* N controls sync */\nconst nSlider = document.getElementById('nSlider');\nconst nValue = document.getElementById('nValue');\nnSlider.addEventListener('input', ()=>{ nValue.value = nSlider.value; });\nnValue.addEventListener('change', ()=>{ let v=parseInt(nValue.value)||1; v=clamp(v, parseInt(nSlider.min), parseInt(nSlider.max)); nSlider.value=v; nValue.value=v; });\n\nconst speed = document.getElementById('speed');\nconst speedVal = document.getElementById('speedVal');\nspeed.addEventListener('input', ()=>{ speedVal.textContent = speed.value + 'ms'; });\n\n/* Run, step, auto */\ndocument.getElementById('runBtn').addEventListener('click', runSimulation);\ndocument.getElementById('stepBtn').addEventListener('click', stepOnce);\ndocument.getElementById('autoBtn').addEventListener('click', startAuto);\ndocument.getElementById('pauseBtn').addEventListener('click', pauseAuto);\ndocument.getElementById('resetBtn').addEventListener('click', resetState);\ndocument.getElementById('exportBtn').addEventListener('click', exportResults);\ndocument.getElementById('importBtn').addEventListener('click', ()=> {\n  const area = document.getElementById('importArea');\n  area.style.display = area.style.display === 'none' ? '' : 'none';\n});\ndocument.getElementById('customRun').addEventListener('click', customEvaluate);\ndocument.getElementById('customPlot').addEventListener('click', customPlot);\ndocument.getElementById('cmpRun').addEventListener('click', runCompare);\ndocument.getElementById('cmpRange').addEventListener('input', ()=>{ document.getElementById('cmpRangeVal').value = document.getElementById('cmpRange').value; });\ndocument.getElementById('cmpRangeVal').addEventListener('change', ()=>{ let v=parseInt(document.getElementById('cmpRangeVal').value)||5; v=clamp(v,5,300); document.getElementById('cmpRange').value=v; document.getElementById('cmpRangeVal').value=v; });\ndocument.getElementById('fitRun').addEventListener('click', runFit);\ndocument.getElementById('importArea').addEventListener('paste', ()=> setTimeout(()=> tryImport(), 100));\ndocument.getElementById('exportBtn').addEventListener('click', exportResults);\ndocument.getElementById('importArea').addEventListener('change', tryImport);\n\n/* Main functions */\nfunction resetState(){\n  pauseAuto();\n  state.currentStepper = null;\n  state.running = false;\n  state.accumulated = {comparisons:0, assignments:0, total:0};\n  state.lastCounts = null;\n  document.getElementById('opLog').textContent = '';\n  document.getElementById('countsSummary').textContent = 'Reset.';\n  drawEmptyPlot();\n}\n\nfunction runSimulation(){\n  resetState();\n  const algKey = document.getElementById('algorithm').value;\n  const alg = Algorithms[algKey];\n  const n = parseInt(document.getElementById('nValue').value) || 1;\n  const fastMode = document.getElementById('fastMode').checked;\n  const pattern = document.getElementById('pattern').value;\n  const countComp = document.getElementById('countComp').checked;\n  const countAssign = document.getElementById('countAssign').checked;\n  // compute counts using count function\n  let counts = alg.count(n);\n  // filter by selected count types\n  let comps = countComp ? counts.comparisons : 0;\n  let assigns = countAssign ? counts.assignments : 0;\n  counts.calculated = {comparisons: comps, assignments: assigns, total: comps+assigns};\n  state.lastCounts = counts;\n  state.lastRunMetadata = {alg:algKey, n, pattern, timestamp: now()};\n  // prepare stepper\n  state.currentStepper = alg.stepper ? alg.stepper(n, {fastMode}) : null;\n  state.accumulated = {comparisons:0, assignments:0, total:0};\n  document.getElementById('countsSummary').textContent = 'Estimated counts: comparisons='+Math.round(counts.calculated.comparisons)+', assignments='+Math.round(counts.calculated.assignments)+', total='+Math.round(counts.calculated.total);\n  appendLog('Run: '+algKey+' n='+n+' pattern='+pattern+' | Est comps='+Math.round(counts.calculated.comparisons)+' assigns='+Math.round(counts.calculated.assignments));\n  // draw plot of counts at single N as a vertical bar\n  drawSinglePointPlot([{label:algKey, values:[counts.calculated.total], color:'#000'}], n);\n}\n\nfunction stepOnce(){\n  if(!state.currentStepper){\n    appendLog('No stepper loaded. Click Run Simulation first.');\n    return;\n  }\n  const it = state.currentStepper;\n  const res = it.next();\n  if(res.done){\n    appendLog('Stepper complete.');\n    state.currentStepper = null;\n    return;\n  }\n  const step = res.value || {};\n  state.accumulated.comparisons += step.comps || 0;\n  state.accumulated.assignments += step.assigns || 0;\n  state.accumulated.total = state.accumulated.comparisons + state.accumulated.assignments;\n  appendLog('STEP: '+step.desc + ' | +comps='+ (step.comps||0) + ' +assigns=' + (step.assigns||0) + ' | accumulated total='+state.accumulated.total);\n  document.getElementById('countsSummary').textContent = 'Step accumulated: comps='+state.accumulated.comparisons+', assigns='+state.accumulated.assignments+', total='+state.accumulated.total;\n}\n\nfunction startAuto(){\n  if(!state.currentStepper){\n    appendLog('No stepper loaded. Click Run Simulation first.');\n    return;\n  }\n  if(state.running) return;\n  state.running = true;\n  function tick(){\n    if(!state.running) return;\n    let i=0;\n    let chunk = 5; // steps per tick\n    while(i<chunk){\n      const it = state.currentStepper;\n      const res = it.next();\n      if(res.done){\n        appendLog('Auto-play completed.');\n        state.running = false;\n        state.currentStepper = null;\n        return;\n      }\n      const step = res.value || {};\n      state.accumulated.comparisons += step.comps || 0;\n      state.accumulated.assignments += step.assigns || 0;\n      state.accumulated.total = state.accumulated.comparisons + state.accumulated.assignments;\n      appendLog('STEP: '+step.desc + ' | +comps='+ (step.comps||0) + ' +assigns=' + (step.assigns||0) + ' | total='+state.accumulated.total);\n      i++;\n    }\n    document.getElementById('countsSummary').textContent = 'Step accumulated: comps='+state.accumulated.comparisons+', assigns='+state.accumulated.assignments+', total='+state.accumulated.total;\n    state.autoTimer = setTimeout(tick, parseInt(speed.value));\n  }\n  tick();\n}\n\nfunction pauseAuto(){\n  state.running = false;\n  if(state.autoTimer) clearTimeout(state.autoTimer);\n  state.autoTimer = null;\n}\n\n/* Plotting utilities */\nconst canvas = document.getElementById('plot');\nconst ctx = canvas.getContext('2d');\n\nfunction drawEmptyPlot(){\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  ctx.fillStyle = '#000';\n  ctx.fillText('No data plotted', 10, 20);\n}\n\nfunction drawSinglePointPlot(datasets, n){\n  // datasets: array {label, values:[singleValue], color}\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  const pad = 30;\n  const w = canvas.width - pad*2;\n  const h = canvas.height - pad*2;\n  // single point, draw bar(s)\n  let maxVal = 0;\n  datasets.forEach(d=> { if(d.values[0]>maxVal) maxVal=d.values[0]; });\n  if(maxVal===0) maxVal=1;\n  datasets.forEach((d, idx)=>{\n    const val = d.values[0];\n    const bw = w / datasets.length;\n    const x = pad + idx*bw;\n    const barH = (val/maxVal) * h;\n    ctx.strokeStyle = '#000';\n    ctx.strokeRect(x, pad + (h-barH), bw-6, barH);\n    ctx.fillText(d.label + ' ('+Math.round(val)+')', x, pad + h + 12);\n  });\n  ctx.fillText('N='+n, 10, 10);\n}\n\nfunction plotXY(curves, options){\n  // curves: array of {label, xs[], ys[]}\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  const pad = 40;\n  const w = canvas.width - pad*2;\n  const h = canvas.height - pad*2;\n  // determine bounds\n  let maxX = 1, maxY = 1;\n  curves.forEach(c=> {\n    for(let i=0;i<c.xs.length;i++){\n      maxX = Math.max(maxX, c.xs[i]);\n      maxY = Math.max(maxY, Math.abs(c.ys[i]));\n    }\n  });\n  if(document.getElementById('normalize').checked){\n    // scale each curve so its max is 1\n    curves = curves.map(c=>{\n      let m = Math.max(...c.ys.map(Math.abs));\n      if(m===0) m=1;\n      return {label:c.label, xs:c.xs, ys:c.ys.map(y=>y/m)};\n    });\n    maxY = 1;\n  }\n  // axes\n  ctx.strokeStyle = '#000';\n  ctx.beginPath();\n  ctx.moveTo(pad, pad);\n  ctx.lineTo(pad, pad+h);\n  ctx.lineTo(pad+w, pad+h);\n  ctx.stroke();\n  // draw curves\n  const colors = ['#000','#000','#000']; // keep simple black lines\n  curves.forEach((c, idx)=>{\n    ctx.beginPath();\n    for(let i=0;i<c.xs.length;i++){\n      const x = pad + (c.xs[i]/maxX) * w;\n      const y = pad + h - (Math.abs(c.ys[i])/maxY) * h;\n      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n    }\n    ctx.strokeStyle = '#000';\n    ctx.stroke();\n    ctx.fillText(c.label, pad + 8, pad + 12 + idx*12);\n  });\n}\n\n/* Custom functions */\nfunction customEvaluate(){\n  const expr = document.getElementById('customExpr').value;\n  const n = parseInt(document.getElementById('customN').value) || 1;\n  try {\n    const f = new Function('n', 'return ('+expr+');');\n    const v = f(n);\n    appendLog('Custom eval n='+n+' -> '+v);\n    document.getElementById('countsSummary').textContent = 'Custom evaluated: '+v;\n    drawSinglePointPlot([{label:'custom', values:[v]}], n);\n    state.lastCounts = {customExpr:expr, calculated:{total:v}, timestamp: now()};\n  } catch(e){\n    appendLog('Custom eval error: '+e.message);\n  }\n}\n\nfunction customPlot(){\n  const expr = document.getElementById('customExpr').value;\n  let f;\n  try{\n    f = new Function('n', 'return ('+expr+');');\n  }catch(e){\n    appendLog('Invalid expression: '+e.message);\n    return;\n  }\n  const max = 100;\n  let xs = [], ys = [];\n  for(let n=1;n<=max;n++){\n    try {\n      let v = f(n);\n      if(!isFinite(v)) v = NaN;\n      xs.push(n); ys.push(Number(v));\n    } catch(e){\n      xs.push(n); ys.push(NaN);\n    }\n  }\n  plotXY([{label:'custom', xs, ys}], {});\n  appendLog('Plotted custom function for n=1..'+max);\n  state.lastRunMetadata = {mode:'custom', expr};\n}\n\n/* Compare multiple algorithms */\nfunction runCompare(){\n  const checked = Array.from(document.querySelectorAll('.cmpAlg:checked')).map(i=>i.value);\n  if(checked.length===0){ appendLog('Select at least one algorithm to compare.'); return; }\n  if(checked.length>3){ appendLog('Select up to 3 algorithms only.'); return; }\n  const maxN = parseInt(document.getElementById('cmpRange').value) || 50;\n  const xs = [];\n  for(let n=1;n<=maxN;n++) xs.push(n);\n  const curves = [];\n  checked.forEach(key=>{\n    const alg = Algorithms[key];\n    const ys = xs.map(n=>{\n      const c = alg.count(n);\n      return c.comparisons + c.assignments;\n    });\n    curves.push({label:key, xs:xs, ys:ys});\n  });\n  // add references optionally\n  if(document.getElementById('showRef').checked){\n    const nxs = xs.slice();\n    curves.push({label:'n', xs:nxs, ys:nxs.map(n=>n)});\n    curves.push({label:'n log n', xs:nxs, ys:nxs.map(n=>n*Math.log2(Math.max(2,n)))});\n    curves.push({label:'n^2', xs:nxs, ys:nxs.map(n=>n*n)});\n  }\n  plotXY(curves, {});\n  appendLog('Compared: '+checked.join(', ')+' up to N='+maxN);\n  state.lastRunMetadata = {mode:'compare', algorithms:checked, maxN};\n}\n\n/* Hypothesis testing / Model fitting */\nfunction runFit(){\n  const algKey = document.getElementById('fitAlg').value;\n  const maxN = parseInt(document.getElementById('fitMaxN').value) || 60;\n  const alg = Algorithms[algKey];\n  // collect observed totals for range 1..maxN (but reduce points to avoid huge counts)\n  const xs = [];\n  const ys = [];\n  for(let n=1;n<=maxN;n++){\n    xs.push(n);\n    const c = alg.count(n);\n    ys.push(c.comparisons + c.assignments);\n  }\n  // candidate models: constant, log, n, n log n, n^2, n^p (fit exponent p), 2^n\n  const candidates = [\n    {name:'O(1)', func: n => 1},\n    {name:'O(log n)', func: n => Math.log2(Math.max(2,n))},\n    {name:'O(n)', func: n => n},\n    {name:'O(n log n)', func: n => n*Math.log2(Math.max(2,n))},\n    {name:'O(n^2)', func: n => n*n},\n    {name:'O(2^n)', func: n => Math.pow(2, n)}\n  ];\n  // convert to arrays and compute least-squares scale factor for each candidate\n  function scoreModel(modelFn){\n    const g = xs.map(modelFn);\n    // find scale factor c minimizing ||y - c*g||^2 => c = (y.g) / (g.g)\n    let yg=0, gg=0;\n    for(let i=0;i<xs.length;i++){\n      yg += ys[i]*g[i];\n      gg += g[i]*g[i];\n    }\n    const c = gg===0 ? 0 : yg/gg;\n    // compute relative error\n    let err=0, norm=0;\n    for(let i=0;i<xs.length;i++){\n      const pred = c * g[i];\n      err += Math.pow(ys[i]-pred,2);\n      norm += Math.pow(ys[i],2);\n    }\n    const rel = norm===0 ? 0 : Math.sqrt(err/norm);\n    return {c, rel};\n  }\n  const results = candidates.map(cand=>{\n    const s = scoreModel(cand.func);\n    return {name:cand.name, scale:s.c, relErr:s.rel};\n  });\n  // also fit polynomial exponent by linear regression in log-log for polynomial behavior\n  // compute log(y) = a + p*log(n)\n  let logs = [], logy = [];\n  for(let i=0;i<xs.length;i++){\n    if(ys[i]<=0) continue;\n    logs.push(Math.log(xs[i]));\n    logy.push(Math.log(ys[i]));\n  }\n  let pExp=null;\n  if(logs.length>1){\n    const meanX = logs.reduce((a,b)=>a+b,0)/logs.length;\n    const meanY = logy.reduce((a,b)=>a+b,0)/logy.length;\n    let num=0, den=0;\n    for(let i=0;i<logs.length;i++){ num += (logs[i]-meanX)*(logy[i]-meanY); den += (logs[i]-meanX)*(logs[i]-meanX); }\n    const p = den===0 ? 0 : num/den;\n    const a = meanY - p*meanX;\n    // compute relative error for this model\n    let err=0, norm=0;\n    for(let i=0;i<xs.length;i++){\n      const pred = Math.exp(a) * Math.pow(xs[i], p);\n      err += Math.pow(ys[i]-pred,2);\n      norm += Math.pow(ys[i],2);\n    }\n    const rel = norm===0 ? 0 : Math.sqrt(err/norm);\n    pExp = {p, a: Math.exp(a), relErr: rel};\n  }\n  // prepare results text\n  let txt = 'Fitting results for algorithm '+algKey+' (N=1..'+maxN+')\\\\n';\n  results.forEach(r => {\n    txt += r.name + ' | scale=' + (isFinite(r.scale)? r.scale.toExponential(3): r.scale) + ' | relErr=' + r.relErr.toFixed(4) + '\\\\n';\n  });\n  if(pExp){\n    txt += 'Best-fit power law: ~ ' + pExp.a.toExponential(2) + ' * n^' + pExp.p.toFixed(4) + ' | relErr=' + pExp.relErr.toFixed(4) + '\\\\n';\n  }\n  document.getElementById('fitResults').textContent = txt;\n  appendLog('Fit completed for '+algKey);\n  // Also plot observed and best candidate curves\n  const obs = {label:'observed', xs: xs, ys: ys};\n  const refCurves = [];\n  // include top 3 best candidates by relErr\n  const best = results.slice().sort((a,b)=>a.relErr-b.relErr).slice(0,3);\n  best.forEach(b=>{\n    const cand = candidates.find(c=>c.name===b.name);\n    refCurves.push({label: b.name, xs: xs, ys: xs.map(n=>b.scale * cand.func(n))});\n  });\n  if(pExp) refCurves.push({label:'fit power n^'+pExp.p.toFixed(2), xs: xs, ys: xs.map(n=>pExp.a*Math.pow(n, pExp.p))});\n  plotXY([obs].concat(refCurves), {});\n}\n\n/* Export / Import */\nfunction exportResults(){\n  const meta = state.lastRunMetadata || {};\n  const counts = state.lastCounts || {};\n  const exported = {meta, counts, timestamp: now()};\n  const txt = JSON.stringify(exported, null, 2);\n  // copy to clipboard if possible and also display\n  navigator.clipboard && navigator.clipboard.writeText(txt).then(()=> {\n    appendLog('Exported results copied to clipboard.');\n  }).catch(()=> {\n    appendLog('Exported JSON (not copied):\\\\n'+txt);\n  });\n}\n\nfunction tryImport(){\n  const area = document.getElementById('importArea');\n  try{\n    const data = JSON.parse(area.value);\n    appendLog('Imported data: ' + JSON.stringify(data).substring(0,200));\n    // apply if data contains counts and meta\n    if(data.counts){\n      state.lastCounts = data.counts;\n      state.lastRunMetadata = data.meta || {imported:true};\n      document.getElementById('countsSummary').textContent = 'Imported counts: '+JSON.stringify(data.counts).slice(0,80);\n    }\n  } catch(e){\n    appendLog('Import error: '+e.message);\n  }\n}\n\n/* Initialize */\ndrawEmptyPlot();\nappendLog('Big-O Interactive Explorer ready. Select mode and controls.');\n\n/* Safety: limit slider max depending on algorithm selection to avoid impossible runs */\ndocument.getElementById('algorithm').addEventListener('change', function(){\n  const v = this.value;\n  if(v==='fib'){ nSlider.max = 40; nSlider.value = Math.min(30, nSlider.value); nValue.value = nSlider.value; }\n  else if(v==='perm'){ nSlider.max = 12; nSlider.value = Math.min(8, nSlider.value); nValue.value = nSlider.value; }\n  else if(v==='bubble' || v==='merge' || v==='quick'){ nSlider.max = 400; nSlider.value = Math.min(200, nSlider.value); nValue.value = nSlider.value; }\n  else { nSlider.max = 200; nSlider.value = Math.min(100, nSlider.value); nValue.value = nSlider.value; }\n});\n\n/* Provide keyboard shortcuts for stepping and autoplay: S = step, A = auto, P = pause, R = run */\ndocument.addEventListener('keydown', function(e){\n  const key = e.key.toLowerCase();\n  if(key==='s') stepOnce();\n  if(key==='a') startAuto();\n  if(key==='p') pauseAuto();\n  if(key==='r') runSimulation();\n});\n\n/* Provide quick reproducibility: clicking on log messages toggles visibility */\ndocument.getElementById('opLog').addEventListener('click', function(){\n  if(this.style.height === '30px') this.style.height = '';\n  else this.style.height = '30px';\n});\n</script>\n</body>\n</html>"
  },
