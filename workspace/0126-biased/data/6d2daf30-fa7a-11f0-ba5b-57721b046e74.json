    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Bubble Sort</title>\n    <style>\n        body {\n            font-family: Arial, margin: 0;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 800px;\n            margin: 0 auto;\n        }\n        .array-container {\n            display: flex;\n            margin: 20px 0;\n            height: 200px;\n            align-items: flex-end;\n            border-bottom: 1px solid #000;\n        }\n        .array-bar {\n            flex: 1;\n            background-color: #ddd;\n            margin: 0 1px;\n            position: relative;\n            text-align: center;\n        }\n        .controls {\n            margin: 20px 0;\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n        }\n        .control-group {\n            margin-right: 20px;\n        }\n        .status {\n            margin: 20px 0;\n            padding: 10px;\n            border: 1px solid #000;\n        }\n        .comparison {\n            background-color: #ccc;\n        }\n        .swapped {\n            background-color: #999;\n        }\n        .sorted {\n            background-color: #555;\n            color: white;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Bubble Sort</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <label for=\"arraySize\">Array Size:</label>\n                <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"50\" value=\"15\">\n                <span id=\"arraySizeValue\">15</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"speed\">Speed:</label>\n                <input type=\"range\" id=\"speed\" min=\"1\" max=\"10\" value=\"5\">\n                <span id=\"speedValue\">5</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <button id=\"generate\">Generate New Array</button>\n                <button id=\"start\">Start Sort</button>\n                <button id=\"pause\" disabled>Pause</button>\n                <button id=\"step\" disabled>Step</button>\n                <button id=\"reset\">Reset</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"arrayInput\">Custom Array (comma separated):</label>\n                <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 5,3,8,1,2\">\n                <button id=\"useCustom\">Use Custom Array</button>\n            </div>\n        </div>\n        \n        <div class=\"status\" id=\"status\">\n            Status: Ready. Generate array or use custom array to begin.\n        </div>\n        \n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Sort Options:</h3>\n                <label><input type=\"radio\" name=\"direction\" value=\"asc\" checked> Ascending</label>\n                <label><input type=\"radio\" name=\"direction\" value=\"desc\"> Descending</label>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Display Options:</h3>\n                <label><input type=\"checkbox\" id=\"showValues\" checked> Show Values</label>\n                <label><input type=\"checkbox\" id=\"showIndices\"> Show Indices</label>\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Algorithm Details:</h3>\n                <div id=\"algorithmDetails\">\n                    <p>Current Pass: <span id=\"currentPass\">0</span></p>\n                    <p>Current Comparison: <span id=\"currentComparison\">0</span></p>\n                    <p>Total Swaps: <span id=\"totalSwaps\">0</span></p>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let array = [];\n        let isSorting = false;\n        let isPaused = false;\n        let sortingInterval;\n        let currentStep = 0;\n        let currentPass = 0;\n        let totalSwaps = 0;\n        let speed = 5;\n        let direction = 'asc';\n        \n        // DOM elements\n        const arrayContainer = document.getElementById('arrayContainer');\n        const arraySizeInput = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const speedInput = document.getElementById('speed');\n        const speedValue = document.getElementById('speedValue');\n        const generateBtn = document.getElementById('generate');\n        const startBtn = document.getElementById('start');\n        const pauseBtn = document.getElementById('pause');\n        const stepBtn = document.getElementById('step');\n        const resetBtn = document.getElementById('reset');\n        const statusEl = document.getElementById('status');\n        const arrayInput = document.getElementById('arrayInput');\n        const useCustomBtn = document.getElementById('useCustom');\n        const showValues = document.getElementById('showValues');\n        const showIndices = document.getElementById('showIndices');\n        const currentPassEl = document.getElementById('currentPass');\n        const currentComparisonEl = document.getElementById('currentComparison');\n        const totalSwapsEl = document.getElementById('totalSwaps');\n        \n        // Event listeners\n        arraySizeInput.addEventListener('input', updateArraySize);\n        speedInput.addEventListener('input', updateSpeed);\n        generateBtn.addEventListener('click', generateNewArray);\n        startBtn.addEventListener('click', startSorting);\n        pauseBtn.addEventListener('click', togglePause);\n        stepBtn.addEventListener('click', performStep);\n        resetBtn.addEventListener('click', reset);\n        useCustomBtn.addEventListener('click', useCustomArray);\n        document.querySelectorAll('input[name=\"direction\"]').forEach(radio => {\n            radio.addEventListener('change', (e) => {\n                direction = e.target.value;\n                if (!isSorting) {\n                    renderArray();\n                }\n            });\n        });\n        showValues.addEventListener('change', renderArray);\n        showIndices.addEventListener('change', renderArray);\n        \n        // Initialize\n        generateNewArray();\n        \n        // Functions\n        function updateArraySize() {\n            arraySizeValue.textContent = arraySizeInput.value;\n        }\n        \n        function updateSpeed() {\n            speed = speedInput.value;\n            speedValue.textContent = speed;\n            if (isSorting && !isPaused) {\n                clearInterval(sortingInterval);\n                sortingInterval = setInterval(performStep, 1100 - (speed * 100));\n            }\n        }\n        \n        function generateNewArray() {\n            if (isSorting) return;\n            \n            const size = parseInt(arraySizeInput.value);\n            array = [];\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * 100) + 1);\n            }\n            \n            resetState();\n            renderArray();\n            statusEl.textContent = 'New array generated. Ready to sort.';\n        }\n        \n        function useCustomArray() {\n            if (isSorting) return;\n            \n            try {\n                const input = arrayInput.value.trim();\n                if (!input) return;\n                \n                const newArray = input.split(',').map(num => {\n                    const parsed = parseInt(num.trim());\n                    if (isNaN(parsed)) throw new Error('Invalid number');\n                    return parsed;\n                });\n                \n                if (newArray.length < 2) {\n                    throw new Error('Array must have at least 2 elements');\n                }\n                \n                array = newArray;\n                arraySizeInput.value = array.length;\n                arraySizeValue.textContent = array.length;\n                \n                resetState();\n                renderArray();\n                statusEl.textContent = 'Custom array loaded. Ready to sort.';\n            } catch (e) {\n                statusEl.textContent = 'Error: ' + e.message;\n            }\n        }\n        \n        function resetState() {\n            currentStep = 0;\n            currentPass = 0;\n            totalSwaps = 0;\n            isSorting = false;\n            isPaused = false;\n            updateAlgorithmDetails();\n        }\n        \n        function renderArray(highlightIndices = [], state = '') {\n            arrayContainer.innerHTML = '';\n            const maxValue = Math.max(...array);\n            \n            array.forEach((value, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'array-bar';\n                \n                // Set height proportional to value\n                const heightPercentage = (value / maxValue) * 100;\n                bar.style.height = `${heightPercentage}%`;\n                \n                // Add classes based on state\n                if (highlightIndices.includes(index)) {\n                    bar.classList.add(state);\n                }\n                \n                // Add value and/or index if enabled\n                const label = document.createElement('div');\n                if (showValues.checked) {\n                    label.textContent = value;\n                }\n                if (showIndices.checked) {\n                    if (showValues.checked) label.textContent += ` (${index})`;\n                    else label.textContent = index;\n                }\n                bar.appendChild(label);\n                \n                arrayContainer.appendChild(bar);\n            });\n        }\n        \n        function startSorting() {\n            if (isSorting) return;\n            \n            isSorting = true;\n            startBtn.disabled = true;\n            pauseBtn.disabled = false;\n            stepBtn.disabled = false;\n            generateBtn.disabled = true;\n            useCustomBtn.disabled = true;\n            \n            statusEl.textContent = 'Sorting in progress...';\n            \n            sortingInterval = setInterval(performStep, 1100 - (speed * 100));\n        }\n        \n        function togglePause() {\n            isPaused = !isPaused;\n            pauseBtn.textContent = isPaused ? 'Resume' : 'Pause';\n            \n            if (isPaused) {\n                clearInterval(sortingInterval);\n                statusEl.textContent = 'Sorting paused.';\n            } else {\n                sortingInterval = setInterval(performStep, 1100 - (speed * 100));\n                statusEl.textContent = 'Sorting resumed...';\n            }\n        }\n        \n        function performStep() {\n            if (isPaused) return;\n            \n            // Check if sorting is complete\n            if (currentPass >= array.length - 1) {\n                completeSort();\n                return;\n            }\n            \n            const i = currentStep % (array.length - currentPass - 1);\n            \n            // Highlight the current comparison\n            renderArray([i, i + 1], 'comparison');\n            updateAlgorithmDetails();\n            statusEl.textContent = `Comparing elements at indices ${i} and ${i + 1}: ${array[i]} and ${array[i + 1]}`;\n            \n            // Determine if we should swap\n            let shouldSwap = false;\n            if (direction === 'asc') {\n                shouldSwap = array[i] > array[i + 1];\n            } else {\n                shouldSwap = array[i] < array[i + 1];\n            }\n            \n            if (shouldSwap) {\n                // Perform swap\n                [array[i], array[i + 1]] = [array[i + 1], array[i]];\n                totalSwaps++;\n                totalSwapsEl.textContent = totalSwaps;\n                \n                // Show swap\n                setTimeout(() => {\n                    renderArray([i, i + 1], 'swapped');\n                    statusEl.textContent = `Swapped elements at indices ${i} and ${i + 1}`;\n                }, (1100 - (speed * 100)) / 2);\n            }\n            \n            currentStep++;\n            \n            // Check if we've completed a pass\n            if (i === array.length - currentPass - 2) {\n                currentPass++;\n                currentPassEl.textContent = currentPass;\n                \n                // Mark the last element as sorted\n                setTimeout(() => {\n                    const sortedIndex = array.length - currentPass;\n                    renderArray([sortedIndex], 'sorted');\n                    statusEl.textContent = `Completed pass ${currentPass}. Element at index ${sortedIndex} is now in its final position.`;\n                }, (1100 - (speed * 100)) / 2);\n            }\n        }\n        \n        function completeSort() {\n            clearInterval(sortingInterval);\n            isSorting = false;\n            \n            // Mark all elements as sorted\n            renderArray(Array.from({length: array.length}, (_, i) => i), 'sorted');\n            statusEl.textContent = `Sorting complete! Total passes: ${currentPass}, total swaps: ${totalSwaps}`;\n            \n            startBtn.disabled = false;\n            pauseBtn.disabled = true;\n            stepBtn.disabled = true;\n            generateBtn.disabled = false;\n            useCustomBtn.disabled = false;\n        }\n        \n        function reset() {\n            clearInterval(sortingInterval);\n            isSorting = false;\n            isPaused = false;\n            \n            startBtn.disabled = false;\n            pauseBtn.disabled = true;\n            stepBtn.disabled = true;\n            generateBtn.disabled = false;\n            useCustomBtn.disabled = false;\n            pauseBtn.textContent = 'Pause';\n            \n            resetState();\n            renderArray();\n            statusEl.textContent = 'Reset. Ready to sort.';\n        }\n        \n        function updateAlgorithmDetails() {\n            currentPassEl.textContent = currentPass;\n            currentComparisonEl.textContent = currentStep % (array.length - currentPass - 1);\n            totalSwapsEl.textContent = totalSwaps;\n        }\n    </script>\n</body>\n</html>"
