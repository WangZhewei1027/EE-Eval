    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Depth-First Search (DFS) Interactive Demo</title>\n<style>\n  body { background: white; color: black; font-family: monospace, monospace; }\n  textarea, input, button, select {\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  textarea { width: 100%; height: 100px; }\n  #graph-input, #log { width: 100%; }\n  #graph-input { height: 150px; }\n  #controls > * { margin: 2px 0; display: block; }\n  #graph-list { max-height: 150px; overflow-y: auto; white-space: pre-wrap; font-family: monospace, monospace; border: 1px solid #000; }\n  #stack-list, #visited-list { max-height: 120px; overflow-y: auto; border: 1px solid #000; margin-bottom: 10px; }\n  #stack-list div, #visited-list div { padding: 2px; }\n  label { margin-top: 10px; display: block; }\n</style>\n</head>\n<body>\n<h1>Depth-First Search (DFS) Interactive Demo</h1>\n\n<div>\n  <label for=\"graph-input\">\n    Enter Graph Adjacency List (one node per line, format: node:neighbor1,neighbor2,...)\n  </label>\n  <textarea id=\"graph-input\" aria-label=\"Graph adjacency list input\" spellcheck=\"false\">\nA:B,C\nB:D,E\nC:F\nD:\nE:F\nF:\n  </textarea>\n  <button id=\"load-graph-btn\" type=\"button\">Load Graph</button>\n</div>\n\n<div id=\"status\" aria-live=\"polite\" style=\"margin-top:1em;\"></div>\n\n<hr />\n\n<div id=\"controls\" aria-label=\"DFS controls\" style=\"margin-top:1em;\">\n\n  <label for=\"start-node-input\">Start Node:</label>\n  <input type=\"text\" id=\"start-node-input\" aria-describedby=\"status\" size=\"3\" value=\"A\" />\n\n  <button id=\"start-dfs-btn\" type=\"button\" disabled>Start DFS</button>\n  <button id=\"step-btn\" type=\"button\" disabled>Next Step</button>\n  <button id=\"auto-run-btn\" type=\"button\" disabled>Auto Run</button>\n  <button id=\"pause-btn\" type=\"button\" disabled>Pause</button>\n  <button id=\"reset-btn\" type=\"button\" disabled>Reset</button>\n\n  <label for=\"speed-range\">Auto Run Speed (steps/second):</label>\n  <input type=\"range\" id=\"speed-range\" min=\"0.5\" max=\"5\" step=\"0.1\" value=\"1\" />\n  <span id=\"speed-display\">1</span>\n\n  <label for=\"inspect-node-input\">Inspect Node State:</label>\n  <input type=\"text\" id=\"inspect-node-input\" size=\"3\" />\n  <button id=\"inspect-btn\" type=\"button\">Inspect</button>\n  <pre id=\"inspect-output\" style=\"white-space: pre-wrap; max-height: 100px; overflow-y: auto;\"></pre>\n\n  <label for=\"manual-push-node\">Manual Push Node onto Stack:</label>\n  <input type=\"text\" id=\"manual-push-node\" size=\"3\" />\n  <button id=\"manual-push-btn\" type=\"button\">Push Node</button>\n\n  <label for=\"manual-pop-count\">Manual Pop Stack (count):</label>\n  <input type=\"number\" id=\"manual-pop-count\" min=\"1\" max=\"10\" value=\"1\" />\n  <button id=\"manual-pop-btn\" type=\"button\">Pop</button>\n</div>\n\n<hr />\n\n<div aria-label=\"Graph display and DFS state\" style=\"margin-top:1em;\">\n\n  <h2>Graph (Adjacency List)</h2>\n  <pre id=\"graph-list\" tabindex=\"0\" aria-live=\"polite\"></pre>\n\n  <h3>Stack (Top → Bottom)</h3>\n  <div id=\"stack-list\" tabindex=\"0\" aria-live=\"polite\"></div>\n\n  <h3>Visited Nodes</h3>\n  <div id=\"visited-list\" tabindex=\"0\" aria-live=\"polite\"></div>\n\n  <h3>Log</h3>\n  <pre id=\"log\" tabindex=\"0\" aria-live=\"polite\" style=\"height: 150px; overflow-y: auto;\"></pre>\n\n</div>\n\n<script>\n(() => {\n  // State variables\n  let graph = {};\n  let stack = [];\n  let visited = new Set();\n  let currentNode = null;\n  let running = false;\n  let intervalId = null;\n  let speed = 1000;\n  let logElem, graphListElem, stackListElem, visitedListElem, statusElem, inspectOutput;\n  let startNodeInput, startDfsBtn, stepBtn, autoRunBtn, pauseBtn, resetBtn;\n  let speedRange, speedDisplay;\n  let inspectNodeInput, inspectBtn;\n  let manualPushNodeInput, manualPushBtn;\n  let manualPopCountInput, manualPopBtn;\n  let loadGraphBtn, graphInput;\n\n  // Utility for safe parse adjacency input\n  function parseGraphInput(text) {\n    const lines = text.split('\\n').map(l => l.trim()).filter(l => l.length > 0);\n    const g = {};\n    for (const line of lines) {\n      // Format: node:neighbor1,neighbor2,...\n      const parts = line.split(':');\n      if (parts.length !== 2) {\n        throw new Error(`Invalid line (missing colon): \"${line}\"`);\n      }\n      const node = parts[0].trim();\n      if (!node) throw new Error(`Empty node in line: \"${line}\"`);\n      const neighborsRaw = parts[1].trim();\n      const neighbors = neighborsRaw.length === 0 ? [] : neighborsRaw.split(',').map(n => n.trim()).filter(n => n.length > 0);\n      g[node] = neighbors;\n    }\n    return g;\n  }\n\n  // Rendering functions\n  function renderGraph() {\n    let text = '';\n    for (const node of Object.keys(graph).sort()) {\n      text += node + ': ' + graph[node].join(', ') + '\\n';\n    }\n    graphListElem.textContent = text.trim();\n  }\n\n  function renderStack() {\n    if (stack.length === 0) {\n      stackListElem.textContent = '(empty)';\n      return;\n    }\n    stackListElem.innerHTML = '';\n    for (let i = stack.length - 1; i >= 0; i--) {\n      const div = document.createElement('div');\n      let label = stack[i];\n      if (i === stack.length - 1) label += ' ← top';\n      div.textContent = label;\n      stackListElem.appendChild(div);\n    }\n  }\n\n  function renderVisited() {\n    const visitedArr = Array.from(visited).sort();\n    if (visitedArr.length === 0) {\n      visitedListElem.textContent = '(none)';\n      return;\n    }\n    visitedListElem.textContent = visitedArr.join(', ');\n  }\n\n  function log(msg) {\n    const time = new Date().toLocaleTimeString();\n    logElem.textContent += `[${time}] ${msg}\\n`;\n    logElem.scrollTop = logElem.scrollHeight;\n  }\n\n  function setStatus(msg) {\n    statusElem.textContent = msg;\n  }\n\n  // DFS Step function\n  // Returns true if step taken, false if finished\n  function dfsStep() {\n    // If stack empty, done\n    if (stack.length === 0) {\n      setStatus('DFS complete: Stack empty.');\n      running = false;\n      updateControls(false, false, false, true);\n      return false;\n    }\n\n    const node = stack.pop();\n    log(`Popped node \"${node}\" from stack`);\n\n    if (!visited.has(node)) {\n      visited.add(node);\n      log(`Visiting node \"${node}\"`);\n\n      // Push neighbors in reverse order so leftmost neighbor is processed first\n      // To comply with conventional DFS order (preorder)\n      const neighbors = graph[node] || [];\n      for (let i = neighbors.length - 1; i >= 0; i--) {\n        const nbr = neighbors[i];\n        if (!visited.has(nbr)) {\n          stack.push(nbr);\n          log(`Pushed neighbor \"${nbr}\" onto stack`);\n        }\n      }\n    } else {\n      log(`Node \"${node}\" already visited; skipping`);\n    }\n\n    renderStack();\n    renderVisited();\n\n    return true;\n  }\n\n  // Control buttons management\n  function updateControls(canStart, canStep, canAutoRun, canReset) {\n    startDfsBtn.disabled = !canStart;\n    stepBtn.disabled = !canStep;\n    autoRunBtn.disabled = !canAutoRun;\n    pauseBtn.disabled = !running;\n    resetBtn.disabled = !canReset;\n    manualPushBtn.disabled = !canStep && !running;\n    manualPopBtn.disabled = !canStep && !running;\n  }\n\n  // Reset all state but keep graph loaded\n  function resetState() {\n    stack = [];\n    visited = new Set();\n    currentNode = null;\n    running = false;\n    if (intervalId !== null) {\n      clearInterval(intervalId);\n      intervalId = null;\n    }\n    renderStack();\n    renderVisited();\n    log('State reset.');\n    setStatus('Ready.');\n    updateControls(true, false, true, false);\n  }\n\n  // Initialize DFS starting stack and visited\n  function startDFS(startNode) {\n    if (!(startNode in graph)) {\n      setStatus(`Start node \"${startNode}\" not in graph.`);\n      return false;\n    }\n    stack = [startNode];\n    visited = new Set();\n    renderStack();\n    renderVisited();\n    log(`DFS started at node \"${startNode}\".`);\n    setStatus(`DFS started at \"${startNode}\".`);\n    updateControls(false, true, true, true);\n    return true;\n  }\n\n  // Auto run functions\n  function autoRunStart() {\n    if (running) return;\n    running = true;\n    updateControls(false, false, false, true);\n    setStatus('Auto running DFS...');\n    const delay = 1000 / speed;\n    intervalId = setInterval(() => {\n      const stepped = dfsStep();\n      if (!stepped) stopAutoRun();\n    }, delay);\n  }\n\n  function stopAutoRun() {\n    if (!running) return;\n    running = false;\n    setStatus('Auto run paused.');\n    updateControls(false, true, true, true);\n    if (intervalId !== null) {\n      clearInterval(intervalId);\n      intervalId = null;\n    }\n  }\n\n  // Inspect node info\n  function inspectNode(node) {\n    if (!(node in graph)) {\n      inspectOutput.textContent = `Node \"${node}\" does not exist in the graph.`;\n      return;\n    }\n    const neighbors = graph[node];\n    const visitedStatus = visited.has(node) ? 'visited' : 'not visited';\n    const inStack = stack.includes(node) ? 'in stack' : 'not in stack';\n    inspectOutput.textContent =\n      `Node \"${node}\":\\n` +\n      ` - Neighbors: ${neighbors.length > 0 ? neighbors.join(', ') : '(none)'}\\n` +\n      ` - Status: ${visitedStatus}\\n` +\n      ` - Stack presence: ${inStack}\\n` +\n      ` - Position in stack: ${inStack === 'in stack' ? stack.length - 1 - stack.lastIndexOf(node) : 'N/A'}`;\n  }\n\n  // Manual push / pop functions:\n  // Manual push node (can push duplicates in stack)\n  function manualPush(node) {\n    if (!(node in graph)) {\n      setStatus(`Cannot push: node \"${node}\" does not exist.`);\n      return;\n    }\n    stack.push(node);\n    log(`Manually pushed node \"${node}\" on stack.`);\n    renderStack();\n    updateControls(false, true, true, true);\n  }\n\n  // Manual pop count times\n  function manualPop(count) {\n    if (stack.length === 0) {\n      setStatus('Stack is empty. Cannot pop.');\n      return;\n    }\n    let poppedNodes = [];\n    for (let i = 0; i < count; i++) {\n      if (stack.length === 0) break;\n      poppedNodes.push(stack.pop());\n    }\n    log(`Manually popped node(s): ${poppedNodes.join(', ')}`);\n    renderStack();\n    updateControls(false, true, true, true);\n  }\n\n  // Event bindings and init\n  function init() {\n    graphInput = document.getElementById('graph-input');\n    loadGraphBtn = document.getElementById('load-graph-btn');\n    logElem = document.getElementById('log');\n    graphListElem = document.getElementById('graph-list');\n    stackListElem = document.getElementById('stack-list');\n    visitedListElem = document.getElementById('visited-list');\n    statusElem = document.getElementById('status');\n\n    startNodeInput = document.getElementById('start-node-input');\n    startDfsBtn = document.getElementById('start-dfs-btn');\n    stepBtn = document.getElementById('step-btn');\n    autoRunBtn = document.getElementById('auto-run-btn');\n    pauseBtn = document.getElementById('pause-btn');\n    resetBtn = document.getElementById('reset-btn');\n\n    speedRange = document.getElementById('speed-range');\n    speedDisplay = document.getElementById('speed-display');\n\n    inspectNodeInput = document.getElementById('inspect-node-input');\n    inspectBtn = document.getElementById('inspect-btn');\n    inspectOutput = document.getElementById('inspect-output');\n\n    manualPushNodeInput = document.getElementById('manual-push-node');\n    manualPushBtn = document.getElementById('manual-push-btn');\n    manualPopCountInput = document.getElementById('manual-pop-count');\n    manualPopBtn = document.getElementById('manual-pop-btn');\n\n    // Load graph button\n    loadGraphBtn.addEventListener('click', () => {\n      try {\n        graph = parseGraphInput(graphInput.value);\n        renderGraph();\n        log('Graph loaded successfully.');\n        setStatus('Graph loaded. Ready to start DFS.');\n        resetState();\n        startDfsBtn.disabled = false;\n      } catch (e) {\n        setStatus('Error loading graph: ' + e.message);\n      }\n    });\n\n    // Start DFS button\n    startDfsBtn.addEventListener('click', () => {\n      const startNode = startNodeInput.value.trim();\n      if (!startNode) {\n        setStatus('Enter a valid start node.');\n        return;\n      }\n      if (startDFS(startNode)) {\n        updateControls(false, true, true, true);\n        setStatus(`DFS started at \"${startNode}\". Use \"Next Step\" or \"Auto Run\".`);\n      }\n    });\n\n    // Step button\n    stepBtn.addEventListener('click', () => {\n      if (running) return; // ignore step clicks during auto run\n      const stepped = dfsStep();\n      if (!stepped) {\n        setStatus('DFS is complete.');\n        updateControls(false, false, false, true);\n      }\n    });\n\n    // Auto run button\n    autoRunBtn.addEventListener('click', () => {\n      if (running) return;\n      autoRunStart();\n    });\n\n    // Pause button\n    pauseBtn.addEventListener('click', () => {\n      stopAutoRun();\n    });\n\n    // Reset button\n    resetBtn.addEventListener('click', () => {\n      resetState();\n    });\n\n    // Speed input\n    speedRange.addEventListener('input', () => {\n      speed = parseFloat(speedRange.value);\n      speedDisplay.textContent = speed.toFixed(1);\n      if (running && intervalId !== null) {\n        clearInterval(intervalId);\n        intervalId = setInterval(() => {\n          const stepped = dfsStep();\n          if (!stepped) stopAutoRun();\n        }, 1000 / speed);\n      }\n    });\n\n    // Inspect node button\n    inspectBtn.addEventListener('click', () => {\n      const node = inspectNodeInput.value.trim();\n      if (!node) {\n        inspectOutput.textContent = 'Enter node to inspect.';\n        return;\n      }\n      inspectNode(node);\n    });\n\n    // Manual push button\n    manualPushBtn.addEventListener('click', () => {\n      if (running) {\n        setStatus('Cannot manually push nodes while auto running.');\n        return;\n      }\n      const node = manualPushNodeInput.value.trim();\n      if (!node) {\n        setStatus('Enter a node to push.');\n        return;\n      }\n      manualPush(node);\n    });\n\n    // Manual pop button\n    manualPopBtn.addEventListener('click', () => {\n      if (running) {\n        setStatus('Cannot manually pop stack while auto running.');\n        return;\n      }\n      let count = parseInt(manualPopCountInput.value, 10);\n      if (isNaN(count) || count < 1) {\n        setStatus('Enter a valid pop count >= 1.');\n        return;\n      }\n      manualPop(count);\n    });\n\n    // Initial load from default textarea content\n    try {\n      graph = parseGraphInput(graphInput.value);\n      renderGraph();\n      log('Graph loaded successfully.');\n      setStatus('Graph loaded. Ready to start DFS.');\n      resetState();\n      startDfsBtn.disabled = false;\n    } catch (e) {\n      setStatus('Error loading graph: ' + e.message);\n    }\n\n    speed = parseFloat(speedRange.value);\n    speedDisplay.textContent = speed.toFixed(1);\n  }\n\n  window.addEventListener('load', init);\n})();\n</script>\n</body>\n</html>"
  },
