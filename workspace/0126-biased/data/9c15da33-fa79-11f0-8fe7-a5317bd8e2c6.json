  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Routing Interactive Sandbox</title>\n<style>\n  /* Extremely minimal visual design: basic layout only */\n  html,body { height:100%; margin:0; font-family: sans-serif; }\n  .app { display:flex; height:100%; }\n  .panel { padding:8px; box-sizing:border-box; }\n  .left { width:320px; border-right:1px solid #000; overflow:auto; }\n  .center { flex:1; position:relative; }\n  .right { width:360px; border-left:1px solid #000; overflow:auto; }\n  canvas { width:100%; height:100%; display:block; background:white; }\n  .controls { margin-bottom:8px; }\n  label { display:block; margin-top:6px; font-size:13px; }\n  input[type=\"text\"], input[type=\"number\"], select { width:100%; box-sizing:border-box; }\n  button { margin-top:6px; width:100%; }\n  .small { width:auto; display:inline-block; margin-right:6px; }\n  textarea { width:100%; height:80px; box-sizing:border-box; }\n  table { width:100%; border-collapse:collapse; font-size:13px; }\n  th,td { text-align:left; padding:4px; border-bottom:1px dashed #000; }\n  .log { height:120px; overflow:auto; white-space:pre-wrap; font-size:12px; border:1px solid #000; padding:6px; }\n  .list { max-height:200px; overflow:auto; border:1px solid #000; padding:6px; }\n  input[type=\"range\"] { width:100%; }\n  hr { border: none; border-top:1px solid #000; margin:8px 0; }\n  .inline { display:inline-block; vertical-align:middle; }\n  .muted { font-size:12px; color:#000; opacity:0.7; }\n  /* No colors beyond default, no animations */\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"panel left\">\n    <h3>Graph Editing</h3>\n    <div class=\"controls\">\n      <label>Mode:</label>\n      <select id=\"mode\">\n        <option value=\"select\">Select / Drag</option>\n        <option value=\"add-node\">Add Node (click canvas)</option>\n        <option value=\"add-edge\">Add Edge (click two nodes)</option>\n        <option value=\"delete\">Delete (click node/edge)</option>\n        <option value=\"toggle-down\">Toggle Down (node/edge offline)</option>\n        <option value=\"pin-route\">Pin Manual Route (click nodes in order)</option>\n      </select>\n\n      <label>New Node Label (optional):</label>\n      <input type=\"text\" id=\"newNodeLabel\" placeholder=\"e.g. A, B, Router1\">\n\n      <label>Default Weight for New Edges:</label>\n      <input type=\"number\" id=\"defaultWeight\" value=\"1\" step=\"0.1\">\n\n      <label class=\"muted\">Edge options:</label>\n      <input type=\"checkbox\" id=\"defaultDirected\"> <label class=\"inline\">Directed by default</label>\n\n      <label>Edge capacity (default):</label>\n      <input type=\"number\" id=\"defaultCap\" value=\"10\" step=\"1\">\n\n      <button id=\"clearGraph\">Clear Graph</button>\n      <button id=\"randomGraph\">Generate Random Graph</button>\n      <label>Random nodes:</label>\n      <input type=\"number\" id=\"rgNodes\" value=\"8\" min=\"1\" step=\"1\">\n      <label>Random density (0-1):</label>\n      <input type=\"number\" step=\"0.1\" id=\"rgDensity\" value=\"0.2\" min=\"0\" max=\"1\">\n    </div>\n\n    <hr>\n\n    <h3>Selected Element</h3>\n    <div id=\"selectedInfo\">\n      <div class=\"muted\">Click a node or edge to see/edit properties.</div>\n    </div>\n\n    <hr>\n\n    <h3>Algorithms & Routing</h3>\n    <div class=\"controls\">\n      <label>Algorithm:</label>\n      <select id=\"algorithm\">\n        <option value=\"dijkstra\">Dijkstra (cost-aware)</option>\n        <option value=\"astar\">A* (heuristic)</option>\n        <option value=\"bfs\">BFS (unweighted)</option>\n      </select>\n\n      <label>Heuristic (for A*):</label>\n      <select id=\"heuristic\">\n        <option value=\"euclidean\">Euclidean (node positions)</option>\n        <option value=\"zero\">Zero (equivalent to Dijkstra)</option>\n      </select>\n\n      <label>Cost multiplier based on traffic (0..5):</label>\n      <input type=\"range\" id=\"trafficMult\" min=\"0\" max=\"5\" step=\"0.1\" value=\"1\">\n\n      <label>Source Node (id):</label>\n      <input type=\"text\" id=\"sourceNode\" placeholder=\"node id\">\n\n      <label>Target Node (id):</label>\n      <input type=\"text\" id=\"targetNode\" placeholder=\"node id\">\n\n      <label>Agent name (optional):</label>\n      <input type=\"text\" id=\"agentName\" placeholder=\"Agent1\">\n\n      <button id=\"computePath\">Compute Path (single)</button>\n      <button id=\"computeK\">Compute K-Shortest</button>\n      <label>K value:</label>\n      <input type=\"number\" id=\"kValue\" value=\"3\" min=\"1\" step=\"1\">\n\n      <hr>\n\n      <label>Playback / Step Controls:</label>\n      <div>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"runBtn\">Run</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <button id=\"stopBtn\">Stop</button>\n      </div>\n      <label>Play speed (ms per step):</label>\n      <input type=\"range\" id=\"playSpeed\" min=\"50\" max=\"2000\" step=\"50\" value=\"300\">\n    </div>\n\n    <hr>\n\n    <h3>Advanced Routing Tools</h3>\n    <div class=\"controls\">\n      <button id=\"computeAllTables\">Compute Routing Tables for All Nodes</button>\n      <button id=\"simulateTraffic\">Simulate Traffic (apply loads randomly)</button>\n      <label>Traffic intensity (0-1):</label>\n      <input type=\"range\" id=\"trafficIntensity\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.2\">\n\n      <button id=\"injectFailureSeq\">Record Failure Sequence</button>\n      <button id=\"playFailureSeq\">Play Failure Sequence</button>\n\n      <button id=\"saveGraph\">Export Graph JSON</button>\n      <button id=\"loadGraph\">Import Graph JSON</button>\n      <textarea id=\"graphJson\"></textarea>\n\n      <button id=\"undo\">Undo</button>\n      <button id=\"redo\">Redo</button>\n    </div>\n\n  </div>\n\n  <div class=\"panel center\">\n    <div style=\"padding:6px;\">\n      <strong>Canvas (click to interact)</strong>\n      <div class=\"muted\">Left-click to create/select. Drag nodes. Use mode selector for edge creation, deletion, toggling.</div>\n    </div>\n    <div style=\"position:absolute;left:6px;top:46px;z-index:10;\">\n      <div style=\"background:white;padding:4px;border:1px solid #000;\">\n        <span class=\"muted\">Mode:</span> <span id=\"modeLabel\">select</span>\n      </div>\n    </div>\n    <canvas id=\"canvas\"></canvas>\n  </div>\n\n  <div class=\"panel right\">\n    <h3>Routing Agents / Results</h3>\n    <div>\n      <button id=\"addAgent\">Add Agent (multi-run)</button>\n      <div class=\"list\" id=\"agentsList\"></div>\n    </div>\n\n    <hr>\n\n    <h3>Paths & Comparisons</h3>\n    <div id=\"pathsList\" class=\"list\"></div>\n    <button id=\"clearPaths\">Clear Displayed Paths</button>\n\n    <hr>\n\n    <h3>Event Log & History</h3>\n    <div class=\"log\" id=\"eventLog\"></div>\n    <button id=\"clearLog\">Clear Log</button>\n  </div>\n</div>\n\n<script>\n/* Routing Interactive Sandbox\n   - Minimal visuals, rich interactivity\n   - Many controls including editing, algorithms, step/run, traffic, failures, save/load, undo/redo\n*/\n\n// Basic utilities\nfunction uid(prefix) { return prefix + '_' + Math.random().toString(36).slice(2,9); }\nfunction dist(a,b){ return Math.hypot(a.x-b.x, a.y-b.y); }\n\n// Graph model\nlet graph = { nodes: [], edges: [] };\nlet selected = null;\nlet mode = 'select';\nlet defaultDirected = false;\nlet defaultWeight = 1;\nlet defaultCap = 10;\nlet pendingEdge = null;\nlet pinnedRoute = [];\nlet history = [], future = [];\nlet eventLog = [];\nlet failureSequence = [];\nlet isRecordingFailureSeq = false;\nlet running = false;\nlet runInterval = null;\nlet playSpeed = 300;\nlet currentAlgoState = null;\nlet displayedPaths = []; // array of path objects for visualization\nlet agents = []; // agents for multi-run\n\n// Canvas and drawing\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nfunction resizeCanvas(){\n  canvas.width = canvas.clientWidth;\n  canvas.height = canvas.clientHeight;\n  draw();\n}\nwindow.addEventListener('resize', resizeCanvas);\nresizeCanvas();\n\n// DOM refs\nconst modeSelect = document.getElementById('mode');\nconst modeLabel = document.getElementById('modeLabel');\nconst newNodeLabel = document.getElementById('newNodeLabel');\nconst defaultWeightInput = document.getElementById('defaultWeight');\nconst defaultDirectedInput = document.getElementById('defaultDirected');\nconst defaultCapInput = document.getElementById('defaultCap');\nconst selectedInfo = document.getElementById('selectedInfo');\nconst algorithmSelect = document.getElementById('algorithm');\nconst heuristicSelect = document.getElementById('heuristic');\nconst trafficMultInput = document.getElementById('trafficMult');\nconst sourceNodeInput = document.getElementById('sourceNode');\nconst targetNodeInput = document.getElementById('targetNode');\nconst agentNameInput = document.getElementById('agentName');\nconst computePathBtn = document.getElementById('computePath');\nconst computeKBtn = document.getElementById('computeK');\nconst kValueInput = document.getElementById('kValue');\nconst stepBtn = document.getElementById('stepBtn');\nconst runBtn = document.getElementById('runBtn');\nconst pauseBtn = document.getElementById('pauseBtn');\nconst stopBtn = document.getElementById('stopBtn');\nconst playSpeedInput = document.getElementById('playSpeed');\nconst agentsListDiv = document.getElementById('agentsList');\nconst pathsListDiv = document.getElementById('pathsList');\nconst eventLogDiv = document.getElementById('eventLog');\nconst clearLogBtn = document.getElementById('clearLog');\nconst addAgentBtn = document.getElementById('addAgent');\nconst computeAllTablesBtn = document.getElementById('computeAllTables');\nconst simulateTrafficBtn = document.getElementById('simulateTraffic');\nconst trafficIntensityInput = document.getElementById('trafficIntensity');\nconst injectFailureSeqBtn = document.getElementById('injectFailureSeq');\nconst playFailureSeqBtn = document.getElementById('playFailureSeq');\nconst saveGraphBtn = document.getElementById('saveGraph');\nconst loadGraphBtn = document.getElementById('loadGraph');\nconst graphJsonArea = document.getElementById('graphJson');\nconst undoBtn = document.getElementById('undo');\nconst redoBtn = document.getElementById('redo');\nconst clearGraphBtn = document.getElementById('clearGraph');\nconst randomGraphBtn = document.getElementById('randomGraph');\nconst rgNodesInput = document.getElementById('rgNodes');\nconst rgDensityInput = document.getElementById('rgDensity');\nconst clearPathsBtn = document.getElementById('clearPaths');\n\n// Initialize\nfunction pushHistory(action){\n  history.push(action);\n  if(history.length>200) history.shift();\n  future = [];\n}\nfunction logEvent(text){\n  const t = new Date().toISOString().slice(11,23) + ' - ' + text;\n  eventLog.push(t);\n  if(eventLog.length>400) eventLog.shift();\n  eventLogDiv.textContent = eventLog.join('\\n');\n  eventLogDiv.scrollTop = eventLogDiv.scrollHeight;\n}\nfunction setMode(m){\n  mode = m;\n  modeLabel.textContent = m;\n  modeSelect.value = m;\n  pendingEdge = null;\n  pinnedRoute = [];\n  draw();\n}\n\n// Graph utilities\nfunction addNode(x,y,label){\n  const id = uid('n');\n  const node = { id:id, x:x, y:y, label: label || id, down:false };\n  graph.nodes.push(node);\n  pushHistory({type:'addNode',node});\n  logEvent('Added node ' + node.id);\n  draw();\n  return node;\n}\nfunction addEdge(a,b,weight,directed,capacity){\n  const id = uid('e');\n  const edge = { id:id, from:a.id, to:b.id, weight: Number(weight||defaultWeight), directed: !!directed, down:false, capacity: Number(capacity||defaultCap), load:0 };\n  graph.edges.push(edge);\n  pushHistory({type:'addEdge',edge});\n  logEvent('Added edge ' + edge.id + ' ' + edge.from + '->' + edge.to + ' w=' + edge.weight);\n  draw();\n  return edge;\n}\nfunction removeNode(n){\n  graph.nodes = graph.nodes.filter(x=>x.id !== n.id);\n  const removedEdges = graph.edges.filter(e=>e.from===n.id || e.to===n.id);\n  graph.edges = graph.edges.filter(e=>e.from!==n.id && e.to!==n.id);\n  pushHistory({type:'removeNode',node:n,edges:removedEdges});\n  logEvent('Removed node ' + n.id);\n  draw();\n}\nfunction removeEdge(e){\n  graph.edges = graph.edges.filter(x=>x.id !== e.id);\n  pushHistory({type:'removeEdge',edge:e});\n  logEvent('Removed edge ' + e.id);\n  draw();\n}\nfunction findNodeAt(x,y){\n  for(let i=graph.nodes.length-1;i>=0;i--){\n    const n=graph.nodes[i];\n    const r=12;\n    if(Math.abs(n.x-x)<=r && Math.abs(n.y-y)<=r) return n;\n  }\n  return null;\n}\nfunction findEdgeAt(x,y){\n  // simple hit approx: check distance to segment\n  function distToSeg(px,py,x1,y1,x2,y2){\n    const dx=x2-x1, dy=y2-y1;\n    if(dx===0 && dy===0) return Math.hypot(px-x1,py-y1);\n    const t = ((px-x1)*dx + (py-y1)*dy)/(dx*dx+dy*dy);\n    if(t<0) return Math.hypot(px-x1,py-y1);\n    if(t>1) return Math.hypot(px-x2,py-y2);\n    const nx = x1 + t*dx, ny = y1 + t*dy;\n    return Math.hypot(px-nx,py-ny);\n  }\n  for(let i=0;i<graph.edges.length;i++){\n    const e=graph.edges[i];\n    const a = graph.nodes.find(n=>n.id===e.from);\n    const b = graph.nodes.find(n=>n.id===e.to);\n    if(!a || !b) continue;\n    const d = distToSeg(x,y,a.x,a.y,b.x,b.y);\n    if(d<6) return e;\n  }\n  return null;\n}\nfunction getAdj(node, opts){\n  const res = [];\n  for(const e of graph.edges){\n    if(e.down) continue;\n    if(opts.exclude && opts.exclude.includes(e.id)) continue;\n    if(e.from===node.id){\n      const to = graph.nodes.find(n=>n.id===e.to);\n      if(to && !to.down) res.push({edge:e,to});\n    }\n    if(!e.directed && e.to===node.id){\n      const to = graph.nodes.find(n=>n.id===e.from);\n      if(to && !to.down) res.push({edge:e,to});\n    }\n  }\n  return res;\n}\nfunction edgeEffectiveCost(edge){\n  // cost = weight * (1 + (load/capacity) * trafficMult)\n  const mult = Number(trafficMultInput.value)||1;\n  const loadRatio = edge.capacity>0 ? (edge.load/edge.capacity) : 0;\n  return edge.weight * (1 + loadRatio * mult);\n}\n\n// Drawing\nfunction draw(){\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  // draw edges\n  for(const e of graph.edges){\n    const a = graph.nodes.find(n=>n.id===e.from);\n    const b = graph.nodes.find(n=>n.id===e.to);\n    if(!a || !b) continue;\n    ctx.beginPath();\n    ctx.moveTo(a.x, a.y);\n    ctx.lineTo(b.x, b.y);\n    ctx.lineWidth = (displayedPaths.some(p=>p.edges && p.edges.includes(e.id)) ? 3 : 1);\n    ctx.strokeStyle = \"#000\";\n    ctx.setLineDash(e.down ? [6,6] : []);\n    ctx.stroke();\n    ctx.setLineDash([]);\n    // arrowhead for directed\n    if(e.directed){\n      const angle = Math.atan2(b.y-a.y, b.x-a.x);\n      const ax = b.x - 10 * Math.cos(angle);\n      const ay = b.y - 10 * Math.sin(angle);\n      const left = {x: ax - 6*Math.cos(angle - Math.PI/6), y: ay - 6*Math.sin(angle - Math.PI/6)};\n      const right= {x: ax - 6*Math.cos(angle + Math.PI/6), y: ay - 6*Math.sin(angle + Math.PI/6)};\n      ctx.beginPath();\n      ctx.moveTo(b.x, b.y);\n      ctx.lineTo(left.x, left.y);\n      ctx.lineTo(right.x,right.y);\n      ctx.closePath();\n      ctx.fillStyle = \"#000\";\n      ctx.fill();\n    }\n    // weight label at midpoint\n    const mx = (a.x + b.x)/2;\n    const my = (a.y + b.y)/2;\n    const w = Number(edgeEffectiveCost(e)).toFixed(2);\n    ctx.fillStyle = \"#000\";\n    ctx.font = \"12px sans-serif\";\n    ctx.fillText((e.weight || 0).toString() + \" [\" + w + \"]\", mx+4, my-4);\n    if(e.capacity !== undefined){\n      ctx.fillText(\"cap:\"+e.capacity+\" load:\"+e.load, mx+4, my+10);\n    }\n  }\n  // draw nodes\n  for(const n of graph.nodes){\n    ctx.beginPath();\n    ctx.arc(n.x, n.y, 12, 0, Math.PI*2);\n    ctx.fillStyle = \"#fff\";\n    ctx.fill();\n    ctx.strokeStyle = \"#000\";\n    ctx.lineWidth = (selected && selected.type==='node' && selected.id===n.id) ? 3 : 1;\n    ctx.stroke();\n    ctx.fillStyle = \"#000\";\n    ctx.font = \"12px sans-serif\";\n    ctx.fillText(n.label || n.id, n.x - 6, n.y + 4);\n    if(n.down){\n      ctx.fillText(\"X\", n.x+8, n.y-8);\n    }\n  }\n  // draw pinned route nodes connection\n  if(pinnedRoute.length>1){\n    ctx.beginPath();\n    for(let i=0;i<pinnedRoute.length;i++){\n      const n = pinnedRoute[i];\n      if(i===0) ctx.moveTo(n.x,n.y); else ctx.lineTo(n.x,n.y);\n    }\n    ctx.strokeStyle = \"#000\";\n    ctx.setLineDash([4,4]);\n    ctx.stroke();\n    ctx.setLineDash([]);\n  }\n\n  // annotate agents' current positions (text)\n  let y = 6;\n  for(const ag of agents){\n    ctx.fillStyle = \"#000\";\n    ctx.font = \"12px sans-serif\";\n    ctx.fillText(\"Agent \"+ag.name+\" state:\"+ag.state, 6, canvas.height - (agents.length - agents.indexOf(ag))*16 - 6);\n  }\n}\n\n// Canvas events for interaction\nlet dragging = null;\nlet dragOffset = {x:0,y:0};\ncanvas.addEventListener('mousedown', (ev)=>{\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left;\n  const y = ev.clientY - rect.top;\n  if(mode==='add-node'){\n    const label = newNodeLabel.value.trim() || undefined;\n    addNode(x,y,label);\n    return;\n  }\n  const node = findNodeAt(x,y);\n  const edge = findEdgeAt(x,y);\n  if(mode==='select'){\n    if(node){\n      selected = {type:'node', id:node.id};\n      dragNodeStart(node, x, y);\n      updateSelectedInfo();\n      draw();\n    } else if(edge){\n      selected = {type:'edge', id:edge.id};\n      updateSelectedInfo();\n      draw();\n    } else {\n      selected = null;\n      updateSelectedInfo();\n      draw();\n    }\n  } else if(mode==='add-edge'){\n    if(node){\n      if(!pendingEdge) {\n        pendingEdge = node;\n        logEvent('Picked first node for edge: ' + node.id);\n      } else {\n        if(pendingEdge.id === node.id){\n          logEvent('Cannot create self-edge skipped.');\n          pendingEdge = null;\n        } else {\n          const w = Number(defaultWeightInput.value) || 1;\n          const dir = defaultDirectedInput.checked;\n          addEdge(pendingEdge, node, w, dir, Number(defaultCapInput.value)||10);\n          pendingEdge = null;\n        }\n      }\n    }\n  } else if(mode==='delete'){\n    if(node){ removeNode(node); selected=null; updateSelectedInfo(); }\n    else if(edge){ removeEdge(edge); selected=null; updateSelectedInfo(); }\n  } else if(mode==='toggle-down'){\n    if(node){ node.down = !node.down; pushHistory({type:'toggleNode',id:node.id,down:node.down}); logEvent('Node '+node.id+' down='+node.down); if(isRecordingFailureSeq) failureSequence.push({type:'node',id:node.id,down:node.down}); draw(); }\n    else if(edge){ edge.down = !edge.down; pushHistory({type:'toggleEdge',id:edge.id,down:edge.down}); logEvent('Edge '+edge.id+' down='+edge.down); if(isRecordingFailureSeq) failureSequence.push({type:'edge',id:edge.id,down:edge.down}); draw(); }\n  } else if(mode==='pin-route'){\n    if(node){\n      pinnedRoute.push(node);\n      logEvent('Pinned node in manual route: ' + node.id);\n      if(pinnedRoute.length>1){\n        // show path in list\n        addDisplayedPath({name:'Pinned',nodes:pinnedRoute.map(n=>n.id),edges:[]});\n      }\n      draw();\n    }\n  }\n});\nfunction dragNodeStart(node,x,y){\n  dragging = node;\n  dragOffset.x = node.x - x;\n  dragOffset.y = node.y - y;\n}\ncanvas.addEventListener('mousemove', (ev)=>{\n  if(dragging){\n    const rect = canvas.getBoundingClientRect();\n    const x = ev.clientX - rect.left;\n    const y = ev.clientY - rect.top;\n    dragging.x = x + dragOffset.x;\n    dragging.y = y + dragOffset.y;\n    draw();\n  }\n});\ncanvas.addEventListener('mouseup', (ev)=>{\n  if(dragging){\n    pushHistory({type:'moveNode',id:dragging.id,x:dragging.x,y:dragging.y});\n    logEvent('Moved node '+dragging.id);\n    dragging = null;\n  }\n});\n\n// Selected info panel\nfunction updateSelectedInfo(){\n  selectedInfo.innerHTML = '';\n  if(!selected){ selectedInfo.innerHTML = '<div class=\"muted\">No selection</div>'; return; }\n  if(selected.type==='node'){\n    const n = graph.nodes.find(x=>x.id===selected.id);\n    if(!n) return;\n    const container = document.createElement('div');\n    container.innerHTML = '<div><strong>Node '+n.id+'</strong></div>';\n    const label = document.createElement('input'); label.type='text'; label.value=n.label;\n    label.addEventListener('change', ()=>{ pushHistory({type:'editNode',old:{...n},new:{...n,label:label.value}}); n.label = label.value; logEvent('Node label changed '+n.id); draw(); });\n    container.appendChild(document.createTextNode('Label:')); container.appendChild(label);\n    const down = document.createElement('button'); down.textContent = n.down? 'Bring Up' : 'Take Down';\n    down.addEventListener('click', ()=>{ n.down = !n.down; pushHistory({type:'toggleNode',id:n.id,down:n.down}); logEvent('Node '+n.id+' down='+n.down); draw(); });\n    container.appendChild(down);\n    const del = document.createElement('button'); del.textContent='Delete';\n    del.addEventListener('click', ()=>{ removeNode(n); selected=null; updateSelectedInfo(); });\n    container.appendChild(del);\n    selectedInfo.appendChild(container);\n  } else {\n    const e = graph.edges.find(x=>x.id===selected.id);\n    if(!e) return;\n    const container = document.createElement('div');\n    container.innerHTML = '<div><strong>Edge '+e.id+'</strong></div>';\n    const w = document.createElement('input'); w.type='number'; w.value=e.weight; w.step='0.1';\n    w.addEventListener('change', ()=>{ pushHistory({type:'editEdge',old:{...e},new:{...e,weight:Number(w.value)}}); e.weight = Number(w.value); logEvent('Edge weight changed '+e.id); draw(); });\n    container.appendChild(document.createTextNode('Weight:')); container.appendChild(w);\n    const cap = document.createElement('input'); cap.type='number'; cap.value=e.capacity; cap.step='1';\n    cap.addEventListener('change', ()=>{ pushHistory({type:'editEdge',old:{...e},new:{...e,capacity:Number(cap.value)}}); e.capacity = Number(cap.value); logEvent('Edge capacity changed '+e.id); draw(); });\n    container.appendChild(document.createTextNode('Capacity:')); container.appendChild(cap);\n    const dir = document.createElement('input'); dir.type='checkbox'; dir.checked = e.directed;\n    dir.addEventListener('change', ()=>{ pushHistory({type:'editEdge',old:{...e},new:{...e,directed:dir.checked}}); e.directed = dir.checked; logEvent('Edge directed toggled '+e.id); draw(); });\n    container.appendChild(document.createTextNode('Directed:')); container.appendChild(dir);\n    const down = document.createElement('button'); down.textContent = e.down? 'Enable' : 'Disable';\n    down.addEventListener('click', ()=>{ e.down = !e.down; pushHistory({type:'toggleEdge',id:e.id,down:e.down}); logEvent('Edge '+e.id+' down='+e.down); draw(); });\n    container.appendChild(down);\n    const del = document.createElement('button'); del.textContent = 'Delete';\n    del.addEventListener('click', ()=>{ removeEdge(e); selected=null; updateSelectedInfo(); });\n    container.appendChild(del);\n    selectedInfo.appendChild(container);\n  }\n}\n\n// Algorithms: Dijkstra, A*, BFS\nfunction computePathsSingle(sourceId, targetId, opts){\n  opts = opts || {};\n  const source = graph.nodes.find(n=>n.id===sourceId);\n  const target = graph.nodes.find(n=>n.id===targetId);\n  if(!source || !target) return {path:[],dist:Infinity,visited:[]};\n  const heuristic = (a,b)=>{\n    if(heuristicSelect.value==='euclidean') return dist(a,b);\n    return 0;\n  };\n  // Dijkstra/A* use priority queue\n  const pq = new MinHeap();\n  const distMap = {};\n  const prev = {};\n  const visited = [];\n  for(const n of graph.nodes) distMap[n.id] = Infinity;\n  distMap[source.id] = 0;\n  pq.push({id:source.id,pri:0});\n  while(!pq.empty()){\n    const cur = pq.pop();\n    const node = graph.nodes.find(n=>n.id===cur.id);\n    if(!node || node.down) continue;\n    if(distMap[node.id] !== cur.pri) continue;\n    visited.push(node.id);\n    if(node.id === target.id) break;\n    const adjs = getAdj(node, {exclude: opts.exclude || []});\n    for(const a of adjs){\n      const e = a.edge;\n      const to = a.to;\n      if(to.down) continue;\n      const c = edgeEffectiveCost(e);\n      const nd = distMap[node.id] + c;\n      if(nd < distMap[to.id]){\n        distMap[to.id] = nd;\n        prev[to.id] = {id:node.id,edge:e.id};\n        const heur = (algorithmSelect.value==='astar') ? heuristic(to,target) : 0;\n        pq.push({id:to.id,pri: nd + heur});\n      }\n    }\n  }\n  // build path\n  const path = [];\n  const edges = [];\n  let cur = target.id;\n  if(prev[cur]===undefined && cur!==source.id){\n    // unreachable\n    return {path:[],dist:Infinity,visited};\n  }\n  while(cur !== undefined && cur !== source.id){\n    path.unshift(cur);\n    const p = prev[cur];\n    if(!p) break;\n    edges.unshift(p.edge);\n    cur = p.id;\n  }\n  path.unshift(source.id);\n  return {path,edges,dist: distMap[target.id], visited};\n}\n\n// Simple BFS for unweighted\nfunction bfs(sourceId, targetId, opts){\n  const q = [sourceId];\n  const prev = {};\n  const visitedSet = new Set([sourceId]);\n  while(q.length){\n    const u = q.shift();\n    if(u===targetId) break;\n    const node = graph.nodes.find(n=>n.id===u);\n    if(!node || node.down) continue;\n    const adjs = getAdj(node, {exclude: opts.exclude || []});\n    for(const a of adjs){\n      const v = a.to.id;\n      if(visitedSet.has(v) || a.to.down) continue;\n      visitedSet.add(v);\n      prev[v] = {id:u,edge:a.edge.id};\n      q.push(v);\n    }\n  }\n  if(!visitedSet.has(targetId)) return {path:[],edges:[],dist:Infinity,visited:Array.from(visitedSet)};\n  const path = [];\n  const edges = [];\n  let cur = targetId;\n  while(cur !== undefined && cur !== sourceId){\n    path.unshift(cur);\n    edges.unshift(prev[cur].edge);\n    cur = prev[cur].id;\n  }\n  path.unshift(sourceId);\n  return {path,edges,dist:path.length-1,visited:Array.from(visitedSet)};\n}\n\n// K-shortest paths (Yen's algorithm simplified)\nfunction kShortest(sourceId, targetId, K){\n  const A = [];\n  const B = [];\n  const first = computePathsSingle(sourceId,targetId,{});\n  if(first.path.length===0) return [];\n  A.push(first);\n  for(let k=1;k<K;k++){\n    const prevA = A[k-1];\n    for(let i=0;i<prevA.path.length-1;i++){\n      const spurNode = prevA.path[i];\n      const rootPath = prevA.path.slice(0,i+1);\n      const rootEdges = prevA.edges.slice(0,i);\n      // remove edges that share the same rootPath with previous A\n      const removedEdges = [];\n      for(const p of A){\n        if(p.path.length > i && arrayEquals(rootPath, p.path.slice(0,i+1))){\n          // remove edge p.edges[i]\n          const eid = p.edges[i];\n          const eidx = graph.edges.findIndex(e=>e.id===eid);\n          if(eidx>=0){\n            removedEdges.push(graph.edges[eidx]);\n            graph.edges.splice(eidx,1);\n          }\n        }\n      }\n      const spurRes = computePathsSingle(spurNode, targetId, {});\n      // restore removed edges\n      for(const re of removedEdges) graph.edges.push(re);\n      if(spurRes.path.length===0) continue;\n      const totalPath = rootPath.slice(0,-1).concat(spurRes.path);\n      const totalEdges = rootEdges.concat(spurRes.edges);\n      const exists = B.some(b => arrayEquals(b.path, totalPath));\n      if(!exists) B.push({path: totalPath, edges: totalEdges, dist: spurRes.dist});\n    }\n    if(B.length===0) break;\n    B.sort((a,b)=>a.dist-b.dist);\n    A.push(B.shift());\n  }\n  return A;\n}\nfunction arrayEquals(a,b){ if(a.length!==b.length) return false; for(let i=0;i<a.length;i++) if(a[i]!==b[i]) return false; return true; }\n\n// Simple min-heap\nclass MinHeap {\n  constructor(){ this.data = []; }\n  push(x){ this.data.push(x); this._siftUp(this.data.length-1); }\n  pop(){ if(this.data.length===0) return null; const r=this.data[0]; const last=this.data.pop(); if(this.data.length>0){ this.data[0]=last; this._siftDown(0); } return r;}\n  empty(){ return this.data.length===0; }\n  _siftUp(i){ while(i>0){ const p=Math.floor((i-1)/2); if(this.data[p].pri<=this.data[i].pri) break; [this.data[p],this.data[i]]=[this.data[i],this.data[p]]; i=p; } }\n  _siftDown(i){ while(true){ const l=2*i+1,r=2*i+2; let smallest=i; if(l<this.data.length && this.data[l].pri < this.data[smallest].pri) smallest=l; if(r<this.data.length && this.data[r].pri < this.data[smallest].pri) smallest=r; if(smallest===i) break; [this.data[i],this.data[smallest]]=[this.data[smallest],this.data[i]]; i=smallest; } }\n}\n\n// Displaying paths\nfunction addDisplayedPath(obj){\n  // obj: {name, nodes:[ids], edges:[ids], dist}\n  obj.id = uid('path');\n  displayedPaths.push(obj);\n  renderPathsList();\n  draw();\n}\nfunction renderPathsList(){\n  pathsListDiv.innerHTML = '';\n  for(const p of displayedPaths){\n    const div = document.createElement('div');\n    div.textContent = '['+p.id+'] ' + (p.name || '') + ' dist:'+ (p.dist||'') + ' path:'+ (p.nodes? p.nodes.join('->') : (p.edges? p.edges.join(',') : ''));\n    const btn = document.createElement('button'); btn.textContent='Remove';\n    btn.addEventListener('click', ()=>{ displayedPaths = displayedPaths.filter(x=>x.id!==p.id); renderPathsList(); draw(); });\n    div.appendChild(btn);\n    pathsListDiv.appendChild(div);\n  }\n}\n\n// Agents multi-run\nfunction addAgent(){\n  const src = sourceNodeInput.value.trim();\n  const tgt = targetNodeInput.value.trim();\n  if(!src || !tgt) { alert('Set source and target'); return; }\n  const name = agentNameInput.value.trim() || ('A'+(agents.length+1));\n  const ag = { id: uid('ag'), name, source:src, target:tgt, algorithm: algorithmSelect.value, state:'idle', path:[], stepIndex:0, speed: Number(playSpeedInput.value) || 300 };\n  agents.push(ag);\n  pushHistory({type:'addAgent',agent:ag});\n  logEvent('Added agent ' + ag.name + ' ' + src + '->' + tgt);\n  renderAgents();\n}\nfunction renderAgents(){\n  agentsListDiv.innerHTML = '';\n  for(const ag of agents){\n    const div = document.createElement('div');\n    div.innerHTML = '<strong>'+ag.name+'</strong> ('+ag.algorithm+') src:'+ag.source+' tgt:'+ag.target+' state:'+ag.state;\n    const run = document.createElement('button'); run.textContent='Compute & Run';\n    run.addEventListener('click', ()=>{ computeAgentPath(ag); startAgentRun(ag); });\n    const stop = document.createElement('button'); stop.textContent='Stop';\n    stop.addEventListener('click', ()=>{ ag.state='stopped'; logEvent('Agent '+ag.name+' stopped'); renderAgents(); draw(); });\n    const del = document.createElement('button'); del.textContent='Delete';\n    del.addEventListener('click', ()=>{ agents = agents.filter(x=>x.id!==ag.id); pushHistory({type:'removeAgent',id:ag.id}); renderAgents(); draw(); });\n    div.appendChild(run); div.appendChild(stop); div.appendChild(del);\n    agentsListDiv.appendChild(div);\n  }\n}\nfunction computeAgentPath(agent){\n  let res;\n  if(agent.algorithm==='bfs') res = bfs(agent.source, agent.target, {});\n  else res = computePathsSingle(agent.source, agent.target, {});\n  agent.path = res.path || [];\n  agent.edges = res.edges || [];\n  agent.stepIndex = 0;\n  agent.state = 'computed';\n  addDisplayedPath({name: agent.name, nodes: agent.path.slice(), edges: agent.edges.slice(), dist:res.dist});\n  logEvent('Agent '+agent.name+' computed path len='+agent.path.length+' dist='+res.dist);\n  renderAgents();\n}\nfunction startAgentRun(agent){\n  if(!agent.path || agent.path.length===0){ logEvent('Agent '+agent.name+' has no path'); return; }\n  agent.state = 'running';\n  renderAgents();\n  let i = agent.stepIndex;\n  const step = ()=>{\n    if(agent.state !== 'running') return;\n    if(i >= agent.edges.length){\n      agent.state = 'arrived';\n      logEvent('Agent '+agent.name+' arrived at target');\n      renderAgents();\n      return;\n    }\n    // increment load on edge\n    const eid = agent.edges[i];\n    const e = graph.edges.find(x=>x.id===eid);\n    if(e){\n      e.load = Math.min(e.capacity, e.load + 1);\n      logEvent('Agent '+agent.name+' traversed edge '+e.id+' load='+e.load);\n    }\n    i++;\n    agent.stepIndex = i;\n    renderAgents();\n    draw();\n    setTimeout(step, agent.speed);\n  };\n  setTimeout(step, agent.speed);\n}\n\n// Step / Run control (for algorithm animation)\nlet stepQueue = [];\nfunction prepareStepRun(source, target){\n  // compute single algorithm step-by-step state\n  // For simplicity, recreate Dijkstra state generator\n  const S = {\n    source, target, closed: new Set(), open: new Map(), prev: {}, pq: new MinHeap(), visitedList: []\n  };\n  for(const n of graph.nodes) S.open.set(n.id, Infinity);\n  S.open.set(source, 0);\n  S.pq.push({id: source, pri: 0});\n  return S;\n}\nfunction stepOnce(){\n  if(!currentAlgoState) return;\n  const S = currentAlgoState;\n  while(!S.pq.empty()){\n    const cur = S.pq.pop();\n    const uid = cur.id;\n    if(S.closed.has(uid)) continue;\n    S.closed.add(uid);\n    S.visitedList.push(uid);\n    if(uid === S.target) break;\n    const node = graph.nodes.find(n=>n.id===uid);\n    if(!node) continue;\n    const adjs = getAdj(node, {});\n    for(const a of adjs){\n      const to = a.to.id;\n      if(S.closed.has(to)) continue;\n      const alt = S.open.get(uid) + edgeEffectiveCost(a.edge);\n      if(alt < (S.open.get(to) || Infinity)){\n        S.open.set(to, alt);\n        S.prev[to] = {id:uid,edge:a.edge.id};\n        S.pq.push({id:to,pri:alt});\n      }\n    }\n    break; // single step\n  }\n  // update visualization: show visited nodes as selected? We'll add a temporary displayed path for the current best path to target if exists\n  let path = [];\n  let edges = [];\n  if(S.prev[S.target]){\n    let cur = S.target;\n    while(cur && cur !== S.source){\n      path.unshift(cur);\n      edges.unshift(S.prev[cur].edge);\n      cur = S.prev[cur].id;\n    }\n    path.unshift(S.source);\n    addDisplayedPath({name:'StepPath',nodes:path,edges:edges,dist:S.open.get(S.target)});\n  }\n  if(S.pq.empty()){\n    currentAlgoState = null;\n    logEvent('Step run finished');\n  }\n}\nfunction runLoop(){\n  if(running) return;\n  running = true;\n  runInterval = setInterval(()=>{\n    if(!currentAlgoState){ clearInterval(runInterval); running=false; return; }\n    stepOnce();\n    draw();\n  }, playSpeed);\n}\nfunction pauseRun(){\n  if(runInterval) clearInterval(runInterval);\n  running = false;\n}\nfunction stopRun(){\n  currentAlgoState = null;\n  pauseRun();\n  logEvent('Run stopped');\n}\n\n// UI wiring\nmodeSelect.addEventListener('change',(e)=>setMode(e.target.value));\ndefaultWeightInput.addEventListener('change', ()=> defaultWeight = Number(defaultWeightInput.value));\ndefaultDirectedInput.addEventListener('change', ()=> defaultDirected = defaultDirectedInput.checked);\ndefaultCapInput.addEventListener('change', ()=> defaultCap = Number(defaultCapInput.value));\n\ncomputePathBtn.addEventListener('click', ()=>{\n  const s = sourceNodeInput.value.trim(); const t = targetNodeInput.value.trim();\n  if(!s || !t) { alert('Set source and target'); return; }\n  let res;\n  if(algorithmSelect.value==='bfs') res = bfs(s,t,{});\n  else res = computePathsSingle(s,t,{});\n  if(res.path.length===0) { logEvent('No path found'); alert('No path found'); return; }\n  addDisplayedPath({name:'Single '+(agentNameInput.value||'Query'), nodes: res.path, edges: res.edges, dist:res.dist});\n  logEvent('Computed path '+res.path.join('->')+' dist='+res.dist);\n});\n\ncomputeKBtn.addEventListener('click', ()=>{\n  const s = sourceNodeInput.value.trim(); const t = targetNodeInput.value.trim(); const K = Number(kValueInput.value)||3;\n  if(!s || !t){ alert('Set source and target'); return; }\n  const res = kShortest(s,t,K);\n  if(res.length===0){ alert('No paths found'); logEvent('K-shortest found none'); return; }\n  res.forEach((r,i)=> addDisplayedPath({name: 'K'+(i+1), nodes: r.path, edges: r.edges, dist:r.dist}));\n  logEvent('Computed K-shortest K='+K+' found='+res.length);\n});\n\nstepBtn.addEventListener('click', ()=>{\n  const s = sourceNodeInput.value.trim(); const t = targetNodeInput.value.trim();\n  if(!currentAlgoState){\n    if(!s || !t){ alert('Set source and target'); return; }\n    currentAlgoState = prepareStepRun(s,t);\n    logEvent('Prepared step run ' + s + '->' + t);\n  }\n  stepOnce();\n  draw();\n});\nrunBtn.addEventListener('click', ()=>{\n  const s = sourceNodeInput.value.trim(); const t = targetNodeInput.value.trim();\n  if(!currentAlgoState){\n    if(!s || !t){ alert('Set source and target'); return; }\n    currentAlgoState = prepareStepRun(s,t);\n    logEvent('Prepared run ' + s + '->' + t);\n  }\n  playSpeed = Number(playSpeedInput.value)||300;\n  runLoop();\n});\npauseBtn.addEventListener('click', ()=>{ pauseRun(); logEvent('Paused run'); });\nstopBtn.addEventListener('click', ()=>{ stopRun(); });\n\nplaySpeedInput.addEventListener('change', ()=> playSpeed = Number(playSpeedInput.value));\naddAgentBtn.addEventListener('click', ()=>{ addAgent(); renderAgents(); });\n\ncomputeAllTablesBtn.addEventListener('click', ()=>{\n  // compute routing table for each node using Dijkstra\n  const tables = {};\n  for(const n of graph.nodes){\n    const tab = {};\n    for(const m of graph.nodes){\n      if(n.id===m.id) continue;\n      const res = computePathsSingle(n.id, m.id, {});\n      if(res.path.length>0) tab[m.id] = {nextHop: res.path[1] || m.id, dist: res.dist, path: res.path};\n    }\n    tables[n.id]=tab;\n  }\n  // present summary\n  graphJsonArea.value = JSON.stringify(tables, null, 2);\n  logEvent('Computed routing tables for all nodes (output to JSON area)');\n});\n\nsimulateTrafficBtn.addEventListener('click', ()=>{\n  const intensity = Number(trafficIntensityInput.value)||0.2;\n  for(const e of graph.edges){\n    e.load = Math.round(Math.random()*intensity*e.capacity);\n  }\n  logEvent('Simulated traffic intensity '+intensity);\n  draw();\n});\n\ninjectFailureSeqBtn.addEventListener('click', ()=>{\n  isRecordingFailureSeq = !isRecordingFailureSeq;\n  injectFailureSeqBtn.textContent = isRecordingFailureSeq ? 'Stop Recording Failures' : 'Record Failure Sequence';\n  if(!isRecordingFailureSeq) logEvent('Stopped recording failures; sequence length '+failureSequence.length);\n  else { failureSequence = []; logEvent('Started recording failure sequence'); }\n});\n\nplayFailureSeqBtn.addEventListener('click', ()=>{\n  if(failureSequence.length===0){ alert('No recorded sequence'); return; }\n  // play back sequence stepwise\n  let i=0;\n  const playStep = ()=>{\n    if(i>=failureSequence.length) { logEvent('Finished playing failure sequence'); return; }\n    const ev = failureSequence[i++];\n    if(ev.type==='node'){\n      const n = graph.nodes.find(x=>x.id===ev.id);\n      if(n){ n.down = ev.down; }\n    } else {\n      const e = graph.edges.find(x=>x.id===ev.id);\n      if(e){ e.down = ev.down; }\n    }\n    draw();\n    logEvent('Playback set '+ev.type+' '+ev.id+' down='+ev.down);\n    setTimeout(playStep, 400);\n  };\n  playStep();\n});\n\nsaveGraphBtn.addEventListener('click', ()=>{\n  graphJsonArea.value = JSON.stringify(graph, null, 2);\n  logEvent('Exported graph to JSON area');\n});\nloadGraphBtn.addEventListener('click', ()=>{\n  try{\n    const obj = JSON.parse(graphJsonArea.value);\n    if(!obj.nodes || !obj.edges) throw 'invalid';\n    graph = obj;\n    pushHistory({type:'loadGraph',graph:JSON.parse(graphJsonArea.value)});\n    logEvent('Loaded graph from JSON area');\n    draw();\n  }catch(err){ alert('Invalid JSON'); }\n});\n\nundoBtn.addEventListener('click', ()=>{\n  const act = history.pop();\n  if(!act) return;\n  future.push(act);\n  // very simple undo behaviors\n  if(act.type==='addNode') graph.nodes = graph.nodes.filter(n=>n.id!==act.node.id);\n  else if(act.type==='addEdge') graph.edges = graph.edges.filter(e=>e.id!==act.edge.id);\n  else if(act.type==='removeNode') { graph.nodes.push(act.node); graph.edges.push(...act.edges); }\n  else if(act.type==='removeEdge') graph.edges.push(act.edge);\n  else if(act.type==='moveNode'){ const n = graph.nodes.find(x=>x.id===act.id); if(n){ n.x = n.x; n.y = n.y; } }\n  logEvent('Undo: '+(act.type||'action'));\n  draw();\n});\nredoBtn.addEventListener('click', ()=>{\n  const act = future.pop();\n  if(!act) return;\n  history.push(act);\n  // simple redo\n  if(act.type==='addNode') graph.nodes.push(act.node);\n  else if(act.type==='addEdge') graph.edges.push(act.edge);\n  logEvent('Redo: '+act.type);\n  draw();\n});\n\nclearLogBtn.addEventListener('click', ()=>{ eventLog = []; eventLogDiv.textContent=''; });\n\nclearGraphBtn.addEventListener('click', ()=>{\n  if(!confirm('Clear entire graph?')) return;\n  pushHistory({type:'clearGraph',graph:JSON.parse(JSON.stringify(graph))});\n  graph = {nodes:[], edges:[]};\n  selected = null;\n  logEvent('Cleared graph');\n  draw();\n});\n\nrandomGraphBtn.addEventListener('click', ()=>{\n  const n = Number(rgNodesInput.value)||8;\n  const dens = Number(rgDensityInput.value)||0.2;\n  graph = {nodes:[], edges:[]};\n  for(let i=0;i<n;i++){\n    addNode(40 + Math.random()*(canvas.width-80), 40 + Math.random()*(canvas.height-80), 'N'+(i+1));\n  }\n  // connect with probability\n  for(let i=0;i<graph.nodes.length;i++){\n    for(let j=i+1;j<graph.nodes.length;j++){\n      if(Math.random()<dens){\n        addEdge(graph.nodes[i], graph.nodes[j], Math.round((Math.random()*5+0.5)*10)/10, Math.random()<0.3, Math.round(Math.random()*20+5));\n      }\n    }\n  }\n  logEvent('Generated random graph nodes='+n+' density='+dens);\n  draw();\n});\n\nclearPathsBtn.addEventListener('click', ()=>{ displayedPaths = []; renderPathsList(); draw(); });\n\n// Utilities for logging/display\nfunction addToEventLogLine(text){ eventLogDiv.textContent += '\\n' + text; }\n\n// Helper to create some default graph for demonstration at load\n(function seedDemo(){\n  // create few nodes\n  addNode(100,80,'A'); addNode(240,60,'B'); addNode(380,80,'C');\n  addNode(100,200,'D'); addNode(240,220,'E'); addNode(380,200,'F');\n  // connect\n  addEdge(graph.nodes[0], graph.nodes[1], 3, false, 10);\n  addEdge(graph.nodes[1], graph.nodes[2], 2, false, 10);\n  addEdge(graph.nodes[0], graph.nodes[3], 2, false, 8);\n  addEdge(graph.nodes[3], graph.nodes[4], 1, false, 8);\n  addEdge(graph.nodes[4], graph.nodes[5], 4, false, 8);\n  addEdge(graph.nodes[2], graph.nodes[5], 1, false, 6);\n  addEdge(graph.nodes[1], graph.nodes[4], 2.5, true, 5);\n  logEvent('Demo graph created');\n})();\n\n// Misc utilities\nfunction getNodeById(id){ return graph.nodes.find(n=>n.id===id); }\n\n// Keep canvas interactive even when content changes\nsetInterval(()=>draw(), 1000);\n\n// Minimal helper to display selection text\nupdateSelectedInfo();\nrenderAgents();\nrenderPathsList();\n\n</script>\n</body>\n</html>"
