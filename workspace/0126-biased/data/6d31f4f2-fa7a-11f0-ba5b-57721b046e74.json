    "content": "<html>\n<head>\n    <title>Integration Testing Demo</title>\n    <script>\n        // Global state for our integration test scenarios\n        const state = {\n            currentScenario: null,\n            testResults: {},\n            userData: {\n                username: '',\n                password: '',\n                email: '',\n                preferences: {}\n            },\n            apiStatus: {\n                authService: 'offline',\n                dataService: 'offline',\n                paymentService: 'offline'\n            },\n            testCases: {\n                userRegistration: {\n                    steps: ['Validate Input', 'Check Email Availability', 'Create Account', 'Send Welcome Email'],\n                    status: 'not run'\n                },\n                orderProcessing: {\n                    steps: ['Validate Order', 'Check Inventory', 'Process Payment', 'Update Inventory', 'Send Confirmation'],\n                    status: 'not run'\n                },\n                userLogin: {\n                    steps: ['Validate Credentials', 'Check Account Status', 'Generate Session', 'Load Preferences'],\n                    status: 'not run'\n                }\n            }\n        };\n\n        // Initialize the application\n        function init() {\n            renderServiceStatus();\n            renderTestScenarios();\n            renderUserForm();\n            renderTestControls();\n            renderResultsArea();\n        }\n\n        // Toggle service status\n        function toggleService(service) {\n            state.apiStatus[service] = state.apiStatus[service] === 'online' ? 'offline' : 'online';\n            renderServiceStatus();\n        }\n\n        // Run a test scenario\n        function runTest(scenario) {\n            state.currentScenario = scenario;\n            state.testCases[scenario].status = 'running';\n            \n            // Simulate test execution with delays between steps\n            const steps = state.testCases[scenario].steps;\n            steps.forEach((step, index) => {\n                setTimeout(() => {\n                    document.getElementById(`step-${scenario}-${index}`).className = 'running';\n                    \n                    // Simulate step completion\n                    setTimeout(() => {\n                        const isSuccess = Math.random() > 0.2 || \n                            (state.apiStatus.authService === 'online' && \n                             state.apiStatus.dataService === 'online' && \n                             state.apiStatus.paymentService === 'online');\n                        \n                        document.getElementById(`step-${scenario}-${index}`).className = isSuccess ? 'passed' : 'failed';\n                        \n                        if (index === steps.length - 1) {\n                            state.testCases[scenario].status = isSuccess ? 'passed' : 'failed';\n                            updateResults();\n                        }\n                    }, 1000 + Math.random() * 2000);\n                }, index * 1500);\n            });\n            \n            updateResults();\n        }\n\n        // Update user data from form\n        function updateUserData(field, value) {\n            state.userData[field] = value;\n        }\n\n        // Update test results display\n        function updateResults() {\n            const resultsDiv = document.getElementById('test-results');\n            resultsDiv.innerHTML = '';\n            \n            if (state.currentScenario) {\n                const scenario = state.testCases[state.currentScenario];\n                const h3 = document.createElement('h3');\n                h3.textContent = `Test Scenario: ${state.currentScenario} - Status: ${scenario.status}`;\n                resultsDiv.appendChild(h3);\n                \n                const ul = document.createElement('ul');\n                scenario.steps.forEach((step, index) => {\n                    const li = document.createElement('li');\n                    li.id = `step-${state.currentScenario}-${index}`;\n                    li.textContent = step;\n                    ul.appendChild(li);\n                });\n                resultsDiv.appendChild(ul);\n            }\n            \n            // Show system state impact\n            const systemState = document.createElement('div');\n            systemState.innerHTML = `\n                <h4>System State After Test:</h4>\n                <p>User Data: ${JSON.stringify(state.userData)}</p>\n                <p>API Status: ${JSON.stringify(state.apiStatus)}</p>\n            `;\n            resultsDiv.appendChild(systemState);\n        }\n\n        // Render service status controls\n        function renderServiceStatus() {\n            const container = document.getElementById('service-status');\n            container.innerHTML = '<h3>Service Status Controls</h3>';\n            \n            for (const service in state.apiStatus) {\n                const div = document.createElement('div');\n                div.innerHTML = `\n                    ${service}: \n                    <button onclick=\"toggleService('${service}')\">\n                        ${state.apiStatus[service]}\n                    </button>\n                `;\n                container.appendChild(div);\n            }\n        }\n\n        // Render test scenario selection\n        function renderTestScenarios() {\n            const container = document.getElementById('test-scenarios');\n            container.innerHTML = '<h3>Test Scenarios</h3>';\n            \n            for (const scenario in state.testCases) {\n                const button = document.createElement('button');\n                button.textContent = `Run ${scenario}`;\n                button.onclick = () => runTest(scenario);\n                container.appendChild(button);\n            }\n        }\n\n        // Render user form for test data\n        function renderUserForm() {\n            const container = document.getElementById('user-form');\n            container.innerHTML = `\n                <h3>Test Data Input</h3>\n                <div>\n                    <label>Username: <input type=\"text\" onchange=\"updateUserData('username', this.value)\"></label>\n                </div>\n                <div>\n                    <label>Password: <input type=\"password\" onchange=\"updateUserData('password', this.value)\"></label>\n                </div>\n                <div>\n                    <label>Email: <input type=\"email\" onchange=\"updateUserData('email', this.value)\"></label>\n                </div>\n                <div>\n                    <label>\n                        <input type=\"checkbox\" onchange=\"updateUserData('preferences.newsletter', this.checked)\">\n                        Subscribe to newsletter\n                    </label>\n                </div>\n            `;\n        }\n\n        // Render test controls\n        function renderTestControls() {\n            const container = document.getElementById('test-controls');\n            container.innerHTML = `\n                <h3>Test Parameters</h3>\n                <div>\n                    <label>\n                        Test Timeout (ms): \n                        <input type=\"range\" min=\"1000\" max=\"10000\" value=\"5000\" id=\"timeout-slider\">\n                        <span id=\"timeout-value\">5000</span>\n                    </label>\n                </div>\n                <div>\n                    <label>\n                        Failure Rate (%): \n                        <input type=\"range\" min=\"0\" max=\"100\" value=\"20\" id=\"failure-slider\">\n                        <span id=\"failure-value\">20</span>\n                    </label>\n                </div>\n                <button onclick=\"runAllTests()\">Run All Tests</button>\n                <button onclick=\"resetTests()\">Reset All Tests</button>\n            `;\n            \n            // Update slider values\n            document.getElementById('timeout-slider').oninput = function() {\n                document.getElementById('timeout-value').textContent = this.value;\n            };\n            \n            document.getElementById('failure-slider').oninput = function() {\n                document.getElementById('failure-value').textContent = this.value;\n            };\n        }\n\n        // Render results area\n        function renderResultsArea() {\n            const container = document.getElementById('test-results');\n            container.innerHTML = '<h3>Test Results Will Appear Here</h3>';\n        }\n\n        // Run all tests sequentially\n        function runAllTests() {\n            const scenarios = Object.keys(state.testCases);\n            let currentIndex = 0;\n            \n            function runNext() {\n                if (currentIndex < scenarios.length) {\n                    runTest(scenarios[currentIndex]);\n                    currentIndex++;\n                    setTimeout(runNext, 5000);\n                }\n            }\n            \n            runNext();\n        }\n\n        // Reset all tests\n        function resetTests() {\n            for (const scenario in state.testCases) {\n                state.testCases[scenario].status = 'not run';\n            }\n            state.currentScenario = null;\n            renderResultsArea();\n        }\n    </script>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 1000px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        div {\n            margin-bottom: 15px;\n            padding: 10px;\n            border: 1px solid #ddd;\n        }\n        button {\n            padding: 5px 10px;\n            margin: 5px;\n        }\n        input[type=\"text\"], input[type=\"password\"], input[type=\"email\"] {\n            padding: 5px;\n            margin-left: 5px;\n        }\n        .running {\n            color: blue;\n            font-weight: bold;\n        }\n        .passed {\n            color: green;\n            font-weight: bold;\n        }\n        .failed {\n            color: red;\n            font-weight: bold;\n            text-decoration: line-through;\n        }\n        label {\n            display: block;\n            margin: 5px 0;\n        }\n    </style>\n</head>\n<body onload=\"init()\">\n    <h1>Integration Testing Demo</h1>\n    <p>This interactive demo shows how different system components work together during integration testing.</p>\n    \n    <div id=\"service-status\"></div>\n    \n    <div id=\"user-form\"></div>\n    \n    <div id=\"test-scenarios\"></div>\n    \n    <div id=\"test-controls\"></div>\n    \n    <div id=\"test-results\"></div>\n    \n    <div>\n        <h3>Integration Testing Concepts</h3>\n        <ul>\n            <li>Toggle service status to simulate different system states</li>\n            <li>Enter test data to see how it flows through the system</li>\n            <li>Run individual test scenarios or all tests sequentially</li>\n            <li>Observe how failures in one component affect others</li>\n            <li>See the system state change as tests execute</li>\n        </ul>\n    </div>\n</body>\n</html>"
