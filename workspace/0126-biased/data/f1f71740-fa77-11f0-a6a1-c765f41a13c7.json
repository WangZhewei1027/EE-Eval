    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Big-Theta Notation — Visual Demonstration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #08101a;\n    --glass: rgba(255,255,255,0.06);\n    --accent: #7ee7c3;\n    --accent-2: #86a8e7;\n    --muted: rgba(255,255,255,0.7);\n    --card-shadow: 0 8px 30px rgba(2,6,23,0.6);\n  }\n  html,body{height:100%;margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n  body{\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(134,168,231,0.08), transparent 10%),\n                radial-gradient(900px 500px at 90% 90%, rgba(126,231,195,0.04), transparent 12%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #e8eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle floating orbs */\n  .orb{\n    position:fixed;\n    border-radius:50%;\n    filter: blur(50px);\n    opacity:0.12;\n    pointer-events:none;\n    mix-blend-mode:screen;\n  }\n  .orb.one{width:520px;height:520px;left:-80px;top:-120px;background:linear-gradient(135deg,#6b8fee,#c77ee7);}\n  .orb.two{width:420px;height:420px;right:-100px;bottom:-100px;background:linear-gradient(135deg,#52e6b6,#6fe0ff);}\n\n  .wrap{\n    position:absolute;\n    inset:0;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n  }\n\n  .stage{\n    width:1200px;\n    max-width:calc(100% - 96px);\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    box-shadow:var(--card-shadow);\n    display:flex;\n    gap:26px;\n    align-items:stretch;\n    backdrop-filter: blur(6px) saturate(1.1);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  /* Left Info */\n  .panel{\n    width:420px;\n    min-width:320px;\n    padding:30px;\n    border-radius:14px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n  }\n  .title{\n    display:flex;\n    align-items:center;\n    gap:14px;\n  }\n  .logo{\n    width:56px;height:56px;border-radius:12px;\n    background:linear-gradient(135deg,var(--accent),var(--accent-2));\n    display:flex;align-items:center;justify-content:center;\n    font-weight:800;color:#042028;font-family:\"Playfair Display\",serif;\n    box-shadow: 0 8px 24px rgba(78,144,255,0.12), inset 0 -6px 20px rgba(255,255,255,0.15);\n    transform:rotate(-14deg);\n  }\n  .h1{\n    font-family:\"Playfair Display\",serif;\n    font-size:20px;\n    line-height:1;\n    color:white;\n  }\n  .muted{\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.35;\n  }\n\n  .explain{\n    margin-top:6px;\n    padding:14px;\n    border-radius:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n    border:1px solid rgba(255,255,255,0.02);\n    font-size:13px;color:rgba(255,255,255,0.9);\n    line-height:1.45;\n  }\n\n  .formula{\n    margin-top:6px;\n    padding:14px;\n    border-radius:12px;\n    background:linear-gradient(90deg, rgba(126,231,195,0.06), rgba(134,168,231,0.04));\n    color:#e9fcf4;font-weight:600;font-size:15px;\n    display:flex;justify-content:space-between;align-items:center;\n    box-shadow: inset 0 -6px 24px rgba(255,255,255,0.02);\n  }\n\n  .controls{\n    margin-top:auto;\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.04);\n    padding:10px 14px;border-radius:10px;font-weight:600;\n    cursor:pointer;transition:all .22s;backdrop-filter: blur(6px);\n  }\n  .btn:hover{transform:translateY(-3px);color:white;box-shadow:0 10px 30px rgba(12,18,40,0.35);}\n  .btn.primary{\n    background:linear-gradient(135deg,var(--accent),var(--accent-2));\n    color:#042028;border:none;\n    box-shadow: 0 10px 30px rgba(126,231,195,0.12);\n  }\n\n  .legend{\n    display:flex;gap:10px;align-items:center;font-size:13px;color:rgba(255,255,255,0.9);\n  }\n  .legend .item{display:flex;gap:8px;align-items:center}\n  .sw{width:14px;height:10px;border-radius:3px}\n\n  /* Right Graph */\n  .canvas{\n    flex:1;\n    padding:20px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.006));\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    position:relative;overflow:hidden;\n  }\n\n  .graph-title{\n    font-size:15px;font-weight:700;margin-bottom:6px;color:white;letter-spacing:0.2px;\n  }\n  .graph-sub{\n    font-size:12px;color:var(--muted);margin-bottom:12px;\n  }\n\n  /* svg styling */\n  svg{width:100%;height:420px;display:block}\n  .axis line, .axis path{stroke:rgba(255,255,255,0.06)}\n  .grid line{stroke:rgba(255,255,255,0.02)}\n  .gline{stroke:rgba(255,255,255,0.12);stroke-width:1.2;fill:none;mix-blend-mode:screen}\n  .gshade{fill:url(#shadeGrad);opacity:0.28}\n  .fline{stroke:#ffd86b; stroke-width:3; fill:none; filter: drop-shadow(0 8px 26px rgba(255,150,35,0.12)); stroke-linejoin:round; stroke-linecap:round}\n  .gline-main{stroke:rgba(255,255,255,0.9);stroke-width:2.2}\n  .bound{stroke-dasharray:6 6;stroke-width:1.4;stroke:rgba(255,255,255,0.16)}\n  .label{fill:rgba(255,255,255,0.75);font-size:12px}\n  .badge{\n    position:absolute;right:20px;top:20px;padding:10px 14px;border-radius:12px;background:rgba(255,255,255,0.03);\n    font-weight:700;color:var(--muted);font-size:13px;border:1px solid rgba(255,255,255,0.02)\n  }\n\n  /* small footer */\n  .foot{\n    margin-top:14px;font-size:12px;color:rgba(255,255,255,0.6);display:flex;justify-content:space-between;align-items:center;width:100%\n  }\n  .node{\n    display:inline-flex;gap:10px;align-items:center;\n  }\n\n  /* subtle animation helpers */\n  .pulse {\n    animation: pulseGlow 3s infinite;\n  }\n  @keyframes pulseGlow {\n    0%{filter: drop-shadow(0 0 0 rgba(126,231,195,0.06));}\n    50%{filter: drop-shadow(0 12px 40px rgba(126,231,195,0.12));}\n    100%{filter: drop-shadow(0 0 0 rgba(126,231,195,0.06));}\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .stage{flex-direction:column;align-items:stretch;padding:20px}\n    .panel{width:100%}\n    .canvas{order:2}\n  }\n</style>\n</head>\n<body>\n  <div class=\"orb one\"></div>\n  <div class=\"orb two\"></div>\n\n  <div class=\"wrap\">\n    <section class=\"stage\" aria-labelledby=\"title\">\n      <aside class=\"panel\" aria-hidden=\"false\">\n        <div class=\"title\">\n          <div class=\"logo\">Θ</div>\n          <div>\n            <div id=\"title\" class=\"h1\">Big-Theta (Θ) Notation</div>\n            <div class=\"muted\">A concise way to describe asymptotic growth</div>\n          </div>\n        </div>\n\n        <div class=\"explain\" id=\"explain\">\n          Big-Theta notation formalizes when two functions grow at the same rate asymptotically. If\n          f(n) is Θ(g(n)), then for sufficiently large n, f(n) is sandwiched between c₁·g(n) and c₂·g(n)\n          for positive constants c₁ and c₂.\n        </div>\n\n        <div class=\"formula\" id=\"formula\">\n          <div style=\"font-size:14px\">f(n) ∈ Θ(g(n))</div>\n          <div style=\"font-size:12px;color:rgba(2,6,23,0.6);background:white;padding:6px 10px;border-radius:8px;\">c₁·g(n) ≤ f(n) ≤ c₂·g(n)</div>\n        </div>\n\n        <div style=\"margin-top:12px;display:flex;flex-direction:column;gap:8px\">\n          <div class=\"legend\">\n            <div class=\"item\"><span class=\"sw\" style=\"background:linear-gradient(90deg,#ffe29f,#ffb86b)\"></span> f(n) — subject</div>\n            <div class=\"item\"><span class=\"sw\" style=\"background:linear-gradient(90deg,#86a8e7,#7ee7c3)\"></span> g(n) and bounds</div>\n            <div class=\"item\"><span class=\"sw\" style=\"background:linear-gradient(90deg,#ffffff,#ffffff);opacity:0.18}\"></span> Θ-region</div>\n          </div>\n        </div>\n\n        <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n          <button class=\"btn\" id=\"nextBtn\" title=\"Cycle example\">Next Example</button>\n          <button class=\"btn primary pulse\" id=\"playBtn\" title=\"Toggle animation\">Pause</button>\n        </div>\n\n        <div class=\"foot\" style=\"margin-top:14px\">\n          <div class=\"node\" style=\"gap:8px\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M12 2L15 11H9L12 2Z\" stroke=\"#7ee7c3\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            <div style=\"font-weight:700\">Asymptotic visualization</div>\n          </div>\n          <div style=\"color:rgba(255,255,255,0.6)\">Minimal controls • Designed for clarity</div>\n        </div>\n      </aside>\n\n      <main class=\"canvas\" aria-live=\"polite\">\n        <div class=\"badge\" id=\"exampleBadge\">Example 1/3</div>\n        <div style=\"text-align:center\">\n          <div class=\"graph-title\" id=\"graphTitle\">Linear vs Linear</div>\n          <div class=\"graph-sub\" id=\"graphSub\">f(n) and g(n) shown with Θ bounds</div>\n        </div>\n\n        <svg id=\"svg\" viewBox=\"0 0 900 420\" role=\"img\" aria-label=\"Graph showing functions and Theta bounds\">\n          <defs>\n            <linearGradient id=\"shadeGrad\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#86a8e7\"/>\n              <stop offset=\"100%\" stop-color=\"#7ee7c3\"/>\n            </linearGradient>\n            <linearGradient id=\"fGrad\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#ffdd86\"/>\n              <stop offset=\"100%\" stop-color=\"#ff9f5b\"/>\n            </linearGradient>\n            <filter id=\"soft\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"blur\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"blur\"/>\n            </filter>\n          </defs>\n\n          <!-- grid -->\n          <g class=\"grid\">\n            <line x1=\"50\" x2=\"50\" y1=\"20\" y2=\"380\" stroke-opacity=\"0.02\" />\n            <line x1=\"50\" x2=\"850\" y1=\"380\" y2=\"380\" stroke-opacity=\"0.02\" />\n            <!-- vertical ticks -->\n            <g id=\"xticks\"></g>\n            <g id=\"yticks\"></g>\n          </g>\n\n          <!-- region between c1*g and c2*g -->\n          <path id=\"regionPath\" class=\"gshade\" opacity=\"0.18\"></path>\n\n          <!-- g(n) main line -->\n          <path id=\"gPath\" class=\"gline-main\"></path>\n          <!-- c1*g and c2*g -->\n          <path id=\"c1Path\" class=\"bound\"></path>\n          <path id=\"c2Path\" class=\"bound\"></path>\n\n          <!-- f(n) path -->\n          <path id=\"fPath\" class=\"fline\" stroke=\"url(#fGrad)\"></path>\n\n          <!-- moving dot on f -->\n          <circle id=\"fDot\" r=\"6\" fill=\"#ffd86b\" stroke=\"rgba(0,0,0,0.08)\" stroke-width=\"2\" opacity=\"0.95\"></circle>\n\n          <!-- labels -->\n          <text id=\"labelG\" class=\"label\" x=\"70\" y=\"40\">g(n)</text>\n          <text id=\"labelF\" class=\"label\" x=\"120\" y=\"70\">f(n)</text>\n        </svg>\n      </main>\n    </section>\n  </div>\n\n<script>\n(() => {\n  // Examples: each has a name, subtitle, functions f(n) and g(n), bounds c1, c2, and domain N\n  const examples = [\n    {\n      name: \"Linear vs Linear\",\n      sub: \"f(n) = 1.5n + 4, g(n) = n  →  f ∈ Θ(g)\",\n      N: 60,\n      g: n => n,\n      f: n => 1.5*n + 4,\n      c1: 0.5,\n      c2: 2.0\n    },\n    {\n      name: \"Quadratic vs Quadratic\",\n      sub: \"f(n) = 1.2n² + 3n, g(n) = n²  →  f ∈ Θ(g)\",\n      N: 50,\n      g: n => n*n,\n      f: n => 1.2*n*n + 3*n,\n      c1: 0.7,\n      c2: 1.6\n    },\n    {\n      name: \"Exponential vs Polynomial\",\n      sub: \"f(n) = 2^n, g(n) = n²  →  f ∉ Θ(g) (grows much slower)\",\n      N: 18,\n      g: n => n*n,\n      f: n => Math.pow(2, n),\n      c1: 0.001,\n      c2: 1000\n    }\n  ];\n\n  // DOM\n  const svg = document.getElementById('svg');\n  const xticks = document.getElementById('xticks');\n  const yticks = document.getElementById('yticks');\n  const gPath = document.getElementById('gPath');\n  const fPath = document.getElementById('fPath');\n  const regionPath = document.getElementById('regionPath');\n  const c1Path = document.getElementById('c1Path');\n  const c2Path = document.getElementById('c2Path');\n  const fDot = document.getElementById('fDot');\n  const labelG = document.getElementById('labelG');\n  const labelF = document.getElementById('labelF');\n  const title = document.getElementById('graphTitle');\n  const sub = document.getElementById('graphSub');\n  const badge = document.getElementById('exampleBadge');\n  const explain = document.getElementById('explain');\n  const formula = document.getElementById('formula');\n\n  let idx = 0;\n  let playing = true;\n  const nextBtn = document.getElementById('nextBtn');\n  const playBtn = document.getElementById('playBtn');\n\n  nextBtn.addEventListener('click', () => {\n    idx = (idx + 1) % examples.length;\n    renderExample(examples[idx]);\n  });\n\n  playBtn.addEventListener('click', () => {\n    playing = !playing;\n    playBtn.textContent = playing ? 'Pause' : 'Play';\n    playBtn.classList.toggle('pulse', playing);\n  });\n\n  // SVG viewport margins\n  const M = {left:50,right:50,top:20,bottom:40};\n  const W = 900, H = 420;\n  const innerW = W - M.left - M.right;\n  const innerH = H - M.top - M.bottom;\n\n  function mapX(i, N) {\n    return M.left + (i / N) * innerW;\n  }\n  function mapY(v, vmax) {\n    // invert: larger v => lower y\n    const t = v / vmax;\n    return M.top + innerH * (1 - t);\n  }\n\n  // Build ticks (static)\n  function buildXTicks(N) {\n    xticks.innerHTML = '';\n    const step = Math.ceil(N / 10);\n    for (let i = 0; i <= N; i += step) {\n      const x = mapX(i, N);\n      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n      line.setAttribute('x1', x); line.setAttribute('x2', x);\n      line.setAttribute('y1', M.top); line.setAttribute('y2', H - M.bottom);\n      line.setAttribute('stroke', 'rgba(255,255,255,0.02)');\n      xticks.appendChild(line);\n\n      const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      t.setAttribute('x', x); t.setAttribute('y', H - 14);\n      t.setAttribute('text-anchor', 'middle');\n      t.setAttribute('class', 'label');\n      t.textContent = i;\n      xticks.appendChild(t);\n    }\n  }\n\n  function buildYTicks(maxV) {\n    yticks.innerHTML = '';\n    // choose geometric or linear ticks based on magnitude\n    const steps = 4;\n    for (let s = 0; s <= steps; s++) {\n      const v = maxV * s / steps;\n      const y = mapY(v, maxV);\n      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n      line.setAttribute('x1', M.left); line.setAttribute('x2', W - M.right);\n      line.setAttribute('y1', y); line.setAttribute('y2', y);\n      line.setAttribute('stroke', 'rgba(255,255,255,0.02)');\n      yticks.appendChild(line);\n\n      const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      t.setAttribute('x', M.left - 8); t.setAttribute('y', y + 4);\n      t.setAttribute('text-anchor', 'end');\n      t.setAttribute('class', 'label');\n      t.textContent = Math.round(v);\n      yticks.appendChild(t);\n    }\n  }\n\n  // Generate path d attribute from array of points\n  function pathFromPoints(points) {\n    if (!points.length) return '';\n    return points.map((p,i) => `${i===0?'M':'L'} ${p.x.toFixed(2)} ${p.y.toFixed(2)}`).join(' ');\n  }\n\n  // Render example\n  let animStart = null;\n  let animReq = null;\n  let animT = 0; // 0..1\n  function renderExample(ex) {\n    // descriptive\n    title.textContent = ex.name;\n    sub.textContent = ex.sub;\n    badge.textContent = `Example ${idx+1}/${examples.length}`;\n    explain.textContent = getExplanation(ex);\n    formula.innerHTML = `<div style=\"font-size:14px\">f(n) ∈ Θ(g(n))</div>\n                         <div style=\"font-size:12px;color:rgba(2,6,23,0.6);background:white;padding:6px 10px;border-radius:8px;\">${ex.c1}·g(n) ≤ f(n) ≤ ${ex.c2}·g(n)</div>`;\n\n    const N = ex.N;\n    buildXTicks(N);\n\n    // sample points for n from 0..N\n    const pts = [];\n    for (let i=0;i<=N;i++){\n      const gVal = ex.g(i);\n      const fVal = ex.f(i);\n      pts.push({i, g:gVal, f:fVal});\n    }\n    // compute max to scale\n    let maxVal = 1;\n    pts.forEach(p => {\n      maxVal = Math.max(maxVal, p.g * ex.c2, p.f);\n    });\n    // avoid extreme max for 2^n example when N large: cap to zoom out gracefully\n    if (maxVal > 1e6) maxVal = Math.pow(10, Math.ceil(Math.log10(maxVal)));\n\n    buildYTicks(maxVal);\n\n    // build points for paths\n    const gPoints = pts.map(p => ({x:mapX(p.i, N), y:mapY(p.g, maxVal)}));\n    const c1Points = pts.map(p => ({x:mapX(p.i, N), y:mapY(p.g * ex.c1, maxVal)}));\n    const c2Points = pts.map(p => ({x:mapX(p.i, N), y:mapY(p.g * ex.c2, maxVal)}));\n    const fPoints = pts.map(p => ({x:mapX(p.i, N), y:mapY(p.f, maxVal)}));\n\n    // region between c1 and c2 (c2 upper, c1 lower)\n    const regionD = (() => {\n      const top = c2Points.map(p=>`${p.x} ${p.y}`).join(' L ');\n      const bot = c1Points.slice().reverse().map(p=>`${p.x} ${p.y}`).join(' L ');\n      return `M ${top} L ${bot} Z`;\n    })();\n\n    regionPath.setAttribute('d', regionD);\n    // color and opacity dynamic: greenish if f mostly within, red if outside\n    const insideCount = pts.reduce((acc,p)=>acc + ((p.f >= p.g*ex.c1 && p.f <= p.g*ex.c2) ? 1 : 0), 0);\n    const insideRatio = insideCount / pts.length;\n    // set colors based on insideRatio\n    const shadeOpacity = 0.3;\n    regionPath.setAttribute('opacity', shadeOpacity);\n    // gradient shift via transform\n    regionPath.setAttribute('fill', 'url(#shadeGrad)');\n\n    // set base g and bounds\n    gPath.setAttribute('d', pathFromPoints(gPoints));\n    c1Path.setAttribute('d', pathFromPoints(c1Points));\n    c2Path.setAttribute('d', pathFromPoints(c2Points));\n    fPath.setAttribute('d', pathFromPoints(fPoints));\n\n    // set labels anchors near first points\n    labelG.setAttribute('x', gPoints[Math.min(6, gPoints.length-1)].x + 6);\n    labelG.setAttribute('y', gPoints[Math.min(6, gPoints.length-1)].y - 6);\n    labelF.setAttribute('x', fPoints[Math.min(10, fPoints.length-1)].x + 6);\n    labelF.setAttribute('y', fPoints[Math.min(10, fPoints.length-1)].y - 6);\n\n    // animate stroke draw: reset dasharray\n    [gPath, fPath, c1Path, c2Path].forEach(p => {\n      const len = p.getTotalLength ? p.getTotalLength() : 1000;\n      p.style.strokeDasharray = len;\n      p.style.strokeDashoffset = len;\n      p.getBoundingClientRect(); // force reflow\n      p.style.transition = 'stroke-dashoffset 1.2s ease-out';\n      p.style.strokeDashoffset = 0;\n    });\n\n    // put dot at start of f\n    const start = fPoints[0];\n    fDot.setAttribute('cx', start.x);\n    fDot.setAttribute('cy', start.y);\n\n    // dynamic visual cue: if majority inside, tint green else amber/red\n    const mainColor = insideRatio > 0.6 ? '#7ee7c3' : (insideRatio > 0.2 ? '#ffd86b' : '#ff7b7b');\n    const gStroke = document.querySelector('.gline-main');\n    gStroke.style.stroke = insideRatio > 0.6 ? 'rgba(255,255,255,0.95)' : 'rgba(255,255,255,0.9)';\n    // set region gradient stop colors (hack by setting gradient stops)\n    const stops = svg.querySelectorAll('#shadeGrad stop');\n    if (insideRatio > 0.6) {\n      stops[0].setAttribute('stop-color', '#86a8e7');\n      stops[1].setAttribute('stop-color', '#7ee7c3');\n    } else {\n      stops[0].setAttribute('stop-color', '#ffd86b');\n      stops[1].setAttribute('stop-color', '#ff9f5b');\n    }\n\n    // prepare animation parameters\n    animT = 0;\n    animStart = null;\n    if (animReq) cancelAnimationFrame(animReq);\n    // start loop\n    function loop(ts) {\n      if (!animStart) animStart = ts;\n      const dt = ts - animStart;\n      animT = ((dt / 1600) % 1); // cycle every 1.6s\n      // progress along fPoints\n      if (fPoints.length > 1) {\n        const pIdx = Math.floor(animT * (fPoints.length - 1));\n        const pNext = fPoints[Math.min(pIdx + 1, fPoints.length - 1)];\n        const pCur = fPoints[pIdx];\n        // interpolated position\n        const tsub = (animT * (fPoints.length - 1)) - pIdx;\n        const cx = pCur.x + (pNext.x - pCur.x) * tsub;\n        const cy = pCur.y + (pNext.y - pCur.y) * tsub;\n        fDot.setAttribute('cx', cx);\n        fDot.setAttribute('cy', cy);\n\n        // small oscillation to give life\n        const wobble = Math.sin((dt / 400) + pIdx) * 3;\n        fDot.setAttribute('cy', +cy + wobble);\n      }\n\n      // animate subtle vertical scale of region to emphasize membership\n      const scale = 1 + (Math.sin(dt / 900) * 0.02 * (insideRatio > 0.6 ? 1 : 0.6));\n      regionPath.setAttribute('transform', `translate(0,0) scale(1,${scale})`);\n      // fade fPath stroke if outside heavily\n      fPath.style.opacity = 0.95;\n      // paused?\n      if (playing) animReq = requestAnimationFrame(loop);\n      else animReq = null;\n    }\n    if (playing) animReq = requestAnimationFrame(loop);\n  }\n\n  function getExplanation(ex){\n    if (ex === examples[0]) return 'Here g(n) = n. The function f(n) closely tracks g(n) and stays between the bounds c₁·g and c₂·g for large n — so f(n) is Θ(g(n)).';\n    if (ex === examples[1]) return 'Both f(n) and g(n) grow like n². Constants differ, but asymptotically they have the same growth — Θ(n²).';\n    return '2^n grows exponentially and quickly outpaces any polynomial such as n². f(n) is not Θ(g(n)) because it eventually exceeds any constant multiple of g(n).';\n  }\n\n  // initialize first example\n  renderExample(examples[idx]);\n\n  // subtle entry animations\n  document.querySelectorAll('.panel, .canvas').forEach((el,i) => {\n    el.style.transform = 'translateY(12px)';\n    el.style.opacity = '0';\n    setTimeout(()=>{ el.style.transition = 'all 600ms cubic-bezier(.2,.9,.2,1)'; el.style.transform='translateY(0)'; el.style.opacity='1'; }, 80 + i*80);\n  });\n\n  // accessibility: keyboard control for next\n  window.addEventListener('keydown', (e)=>{\n    if (e.key === 'ArrowRight') nextBtn.click();\n    if (e.key === ' ') { e.preventDefault(); playBtn.click(); }\n  });\n\n})();\n</script>\n</body>\n</html>"
