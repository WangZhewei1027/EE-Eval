    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>NoSQL — The Future of Data</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Share+Tech+Mono&display=swap');\n\n  /* CSS Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0; height: 100%;\n    background: #0f172a; /* deep navy */\n    color: #e0e7ff;\n    font-family: 'Poppins', sans-serif;\n    overflow-x: hidden;\n  }\n\n  /* Container */\n  .container {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 4rem 2rem 6rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    position: relative;\n  }\n\n  /* Header */\n  header {\n    text-align: center;\n    margin-bottom: 3rem;\n    max-width: 700px;\n  }\n  header h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    color: #7dd3fc;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    text-shadow:\n      0 0 8px #22d3ee,\n      0 2px 15px #0284c7;\n    margin-bottom: 0.5rem;\n    user-select: none;\n  }\n  header p {\n    font-weight: 300;\n    font-size: 1.3rem;\n    line-height: 1.5;\n    margin-top: 0;\n    color: #a5b4fc;\n    user-select: none;\n  }\n\n  /* Graphic background container */\n  .graphic-wrapper {\n    width: 100%;\n    max-width: 900px;\n    aspect-ratio: 16 / 9;\n    background: radial-gradient(circle at center, #135eab 30%, #0f172a 90%);\n    border-radius: 1.25rem;\n    box-shadow:\n      0 0 30px #3b82f6aa,\n      inset 0 0 40px #60a5fa55;\n    position: relative;\n    overflow: visible;\n  }\n\n  /* NoSQL \"Nodes\" and \"Clusters\" visualization */\n  svg {\n    width: 100%;\n    height: 100%;\n    display: block;\n  }\n\n  /* Node style */\n  .node {\n    fill: #22d3ee;\n    filter: drop-shadow(0 0 5px #22d3eebb);\n    transition: fill 0.4s ease;\n  }\n  .node:hover {\n    fill: #0ea5e9;\n    cursor: default;\n  }\n\n  /* Cluster style */\n  .cluster {\n    fill: none;\n    stroke: #3b82f6dd;\n    stroke-width: 2.5;\n    filter: drop-shadow(0 0 8px #3b82f6bb);\n    r: 90;\n  }\n\n  /* Links */\n  .link {\n    stroke: #38bdf8aa;\n    stroke-width: 2;\n    stroke-linecap: round;\n    transition: stroke-width 0.3s ease;\n  }\n  .link:hover {\n    stroke-width: 3.5;\n  }\n\n  /* Legends and text */\n  .legend-text {\n    fill: #60a5faee;\n    font-family: 'Share Tech Mono', monospace;\n    font-size: 0.9rem;\n    user-select: none;\n  }\n\n  /* Button container */\n  .btn-container {\n    margin-top: 3rem;\n    display: flex;\n    gap: 1.125rem;\n  }\n\n  /* Buttons */\n  button {\n    background: linear-gradient(135deg, #3b82f6ee, #22d3eeee);\n    border: none;\n    border-radius: 0.6rem;\n    padding: 0.7rem 1.7rem;\n    color: #f0f9ff;\n    font-weight: 600;\n    font-size: 1.1rem;\n    cursor: pointer;\n    box-shadow:\n      0 0 15px #22d3eeaa;\n    transition:\n      background 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button:focus-visible {\n    outline: 2px solid #60a5faee;\n    outline-offset: 2px;\n  }\n  button:hover {\n    background: linear-gradient(135deg, #22d3eeff, #3b82f6ff);\n    box-shadow:\n      0 0 25px #3b82f6ff;\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(1px);\n    box-shadow:\n      0 0 10px #1e40afaa;\n  }\n\n  /* Smooth fade in for the main graphic */\n  .fade-in {\n    opacity: 0;\n    animation: fadeInSmooth 2s forwards;\n    animation-delay: 0.8s;\n  }\n  @keyframes fadeInSmooth {\n    to {\n      opacity: 1;\n    }\n  }\n\n  /* Animated nodes pulsing */\n  @keyframes pulseNode {\n    0%, 100% {\n      r: 18;\n      opacity: 0.85;\n      filter: drop-shadow(0 0 8px #22d3ee88);\n    }\n    50% {\n      r: 22;\n      opacity: 1;\n      filter: drop-shadow(0 0 14px #22d3eecc);\n    }\n  }\n\n  /* Typography small monospace heading for cluster labels */\n  .cluster-label {\n    fill: #93c5fddd;\n    font-family: 'Share Tech Mono', monospace;\n    font-size: 1rem;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    font-family: 'Share Tech Mono', monospace;\n    font-size: 0.85rem;\n    color: #64748b;\n    margin-top: 4rem;\n    user-select: none;\n  }\n\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"NoSQL concept visualization\">\n    <header>\n      <h1>NoSQL</h1>\n      <p>Flexible, schema-less, and scalable data storage — the future beyond traditional databases.</p>\n    </header>\n\n    <section class=\"graphic-wrapper fade-in\" aria-hidden=\"true\">\n      <!-- SVG visualization -->\n      <svg viewBox=\"0 0 900 506\" role=\"img\" aria-label=\"Stylized visualization of NoSQL database architecture with clusters and nodes\">\n\n        <!-- Large clusters as circles -->\n        <circle class=\"cluster\" cx=\"180\" cy=\"250\" r=\"95\" />\n        <circle class=\"cluster\" cx=\"720\" cy=\"250\" r=\"95\" />\n\n        <!-- Cluster Labels -->\n        <text class=\"cluster-label\" x=\"180\" y=\"245\" text-anchor=\"middle\" dominant-baseline=\"middle\">Document Store</text>\n        <text class=\"cluster-label\" x=\"720\" y=\"245\" text-anchor=\"middle\" dominant-baseline=\"middle\">Key-Value Store</text>\n\n        <!-- Nodes in Document Store cluster -->\n        <circle class=\"node\" cx=\"135\" cy=\"200\" r=\"20\" style=\"animation: pulseNode 4.5s infinite ease-in-out;\" />\n        <circle class=\"node\" cx=\"213\" cy=\"180\" r=\"20\" style=\"animation: pulseNode 4.3s infinite ease-in-out 0.3s;\" />\n        <circle class=\"node\" cx=\"175\" cy=\"310\" r=\"20\" style=\"animation: pulseNode 4.7s infinite ease-in-out 0.6s;\" />\n        <circle class=\"node\" cx=\"240\" cy=\"290\" r=\"20\" style=\"animation: pulseNode 4.4s infinite ease-in-out 0.15s;\" />\n        <circle class=\"node\" cx=\"100\" cy=\"275\" r=\"20\" style=\"animation: pulseNode 4.6s infinite ease-in-out 0.45s;\" />\n\n        <!-- Nodes in Key-Value Store cluster -->\n        <circle class=\"node\" cx=\"675\" cy=\"210\" r=\"20\" style=\"animation: pulseNode 4.3s infinite ease-in-out 0.2s;\" />\n        <circle class=\"node\" cx=\"765\" cy=\"250\" r=\"20\" style=\"animation: pulseNode 4.8s infinite ease-in-out 0.5s;\" />\n        <circle class=\"node\" cx=\"680\" cy=\"300\" r=\"20\" style=\"animation: pulseNode 4.5s infinite ease-in-out 0.1s;\" />\n        <circle class=\"node\" cx=\"740\" cy=\"330\" r=\"20\" style=\"animation: pulseNode 4.7s infinite ease-in-out 0.35s;\" />\n        <circle class=\"node\" cx=\"620\" cy=\"270\" r=\"20\" style=\"animation: pulseNode 4.4s infinite ease-in-out 0.6s;\" />\n\n        <!-- Links within Document Store -->\n        <line class=\"link\" x1=\"135\" y1=\"200\" x2=\"213\" y2=\"180\" />\n        <line class=\"link\" x1=\"213\" y1=\"180\" x2=\"240\" y2=\"290\" />\n        <line class=\"link\" x1=\"240\" y1=\"290\" x2=\"175\" y2=\"310\" />\n        <line class=\"link\" x1=\"175\" y1=\"310\" x2=\"100\" y2=\"275\" />\n        <line class=\"link\" x1=\"100\" y1=\"275\" x2=\"135\" y2=\"200\" />\n\n        <!-- Links within Key-Value Store -->\n        <line class=\"link\" x1=\"675\" y1=\"210\" x2=\"765\" y2=\"250\" />\n        <line class=\"link\" x1=\"765\" y1=\"250\" x2=\"740\" y2=\"330\" />\n        <line class=\"link\" x1=\"740\" y1=\"330\" x2=\"680\" y2=\"300\" />\n        <line class=\"link\" x1=\"680\" y1=\"300\" x2=\"620\" y2=\"270\" />\n        <line class=\"link\" x1=\"620\" y1=\"270\" x2=\"675\" y2=\"210\" />\n\n        <!-- Cross cluster connections (representing data flow, dotted lines) -->\n        <line class=\"link\" stroke-dasharray=\"6 8\" x1=\"275\" y1=\"250\" x2=\"625\" y2=\"250\" stroke=\"#7dd3fcaa\" stroke-width=\"1.7\" />\n        <circle class=\"node\" cx=\"275\" cy=\"250\" r=\"14\" fill=\"#60a5fa\" filter=\"drop-shadow(0 0 4px #60a5faaa)\" />\n        <circle class=\"node\" cx=\"625\" cy=\"250\" r=\"14\" fill=\"#60a5fa\" filter=\"drop-shadow(0 0 4px #60a5faaa)\" />\n\n        <text class=\"legend-text\" x=\"275\" y=\"230\" text-anchor=\"middle\" font-weight=\"600\">Query Router</text>\n        <text class=\"legend-text\" x=\"625\" y=\"230\" text-anchor=\"middle\" font-weight=\"600\">API Gateway</text>\n\n      </svg>\n    </section>\n\n    <section class=\"btn-container\" aria-label=\"Controls\">\n      <button type=\"button\" id=\"themeToggle\" aria-pressed=\"false\" aria-label=\"Toggle Light and Dark Theme\">\n        Switch to Light Theme\n      </button>\n      <button type=\"button\" id=\"infoBtn\" aria-label=\"Show NoSQL Info\">\n        What is NoSQL?\n      </button>\n    </section>\n\n    <!-- Info modal (simple) -->\n    <aside id=\"infoModal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"infoTitle\" aria-describedby=\"infoDesc\" hidden>\n      <div style=\"position: fixed; inset:0; background:rgba(15,23,42,0.9); display:flex; align-items:center; justify-content:center; z-index:9999; padding:1rem;\">\n        <article style=\"background:#1e293b; max-width:480px; border-radius:1rem; box-shadow:0 0 20px #3b82f6ee; color:#cbd5e1; padding:2rem; font-family:'Poppins', sans-serif; text-align:left; position: relative;\">\n          <h2 id=\"infoTitle\" style=\"color:#7dd3fc; margin-top:0; font-weight:600;\">What is NoSQL?</h2>\n          <p id=\"infoDesc\" style=\"line-height:1.6; font-weight:300; font-size:1rem; margin-bottom:1.5rem;\">\n            NoSQL databases are modern data storage systems designed to handle unstructured or semi-structured data. \n            They provide flexibility in data modeling without fixed schemas, horizontal scalability, and are optimized \n            for distributed data, making them ideal for big data and real-time web applications.\n          </p>\n          <button id=\"closeModal\" style=\"\n            background:#22d3ee;\n            color:#0f172a;\n            font-weight:600;\n            padding:0.6rem 1.3rem;\n            border:none;\n            border-radius:0.6rem;\n            cursor:pointer;\n            box-shadow:0 0 15px #22d3eecc;\n            font-size:1rem;\n            user-select:none;\n          \" aria-label=\"Close Information Modal\">Close</button>\n        </article>\n      </div>\n    </aside>\n\n  </main>\n\n<script>\n  // Elements\n  const themeToggleBtn = document.getElementById('themeToggle');\n  const infoBtn = document.getElementById('infoBtn');\n  const infoModal = document.getElementById('infoModal');\n  const closeModalBtn = document.getElementById('closeModal');\n\n  // Theme toggle logic\n  let darkTheme = true;\n  themeToggleBtn.addEventListener('click', () => {\n    darkTheme = !darkTheme;\n    if(darkTheme) {\n      document.body.style.background = '#0f172a';\n      document.body.style.color = '#e0e7ff';\n      themeToggleBtn.textContent = 'Switch to Light Theme';\n      themeToggleBtn.setAttribute('aria-pressed', 'false');\n    } else {\n      document.body.style.background = '#f1f5f9';\n      document.body.style.color = '#334155';\n      themeToggleBtn.textContent = 'Switch to Dark Theme';\n      themeToggleBtn.setAttribute('aria-pressed', 'true');\n    }\n  });\n\n  // Info modal show/hide\n  infoBtn.addEventListener('click', () => {\n    infoModal.hidden = false;\n    closeModalBtn.focus();\n  });\n  closeModalBtn.addEventListener('click', () => {\n    infoModal.hidden = true;\n    infoBtn.focus();\n  });\n\n  // Allow Esc key to close modal\n  document.addEventListener('keydown', (e) => {\n    if (!infoModal.hidden && e.key === 'Escape') {\n      e.preventDefault();\n      infoModal.hidden = true;\n      infoBtn.focus();\n    }\n  });\n</script>\n</body>\n</html>"
