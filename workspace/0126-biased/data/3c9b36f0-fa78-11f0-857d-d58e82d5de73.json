    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Compiler Concept - Visual Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@600&family=Source+Code+Pro:wght@400&display=swap');\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n  html, body {\n    height: 100%;\n    margin: 0;\n    background: linear-gradient(135deg, #1a1f3d, #040812);\n    color: #d0d6f9;\n    font-family: 'Source Code Pro', monospace;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  .container {\n    max-width: 1200px;\n    margin: 3rem auto 5rem;\n    padding: 0 2rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* Title */\n  header h1 {\n    font-family: 'Roboto Slab', serif;\n    font-weight: 600;\n    font-size: 3.8rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #8bf1ff;\n    text-align: center;\n    margin-bottom: 0.25em;\n    animation: glowTitle 3s ease-in-out infinite alternate;\n  }\n  @keyframes glowTitle {\n    0% {\n      text-shadow: 0 0 12px #8bf1ff88, 0 0 20px #34d9ffaa, 0 0 35px #45ccffcc;\n      color: #8bf1ff;\n    }\n    100% {\n      text-shadow: 0 0 26px #32dfffcc, 0 0 50px #32dfffdd, 0 0 120px #11beffdd;\n      color: #a3f9ff;\n    }\n  }\n  header p.subtitle {\n    font-family: 'Source Code Pro', monospace;\n    font-weight: 400;\n    font-size: 1.1rem;\n    color: #7ba9bb;\n    letter-spacing: 0.05em;\n    margin-bottom: 3rem;\n    user-select: none;\n  }\n\n  /* Diagram Container */\n  .diagram {\n    position: relative;\n    background: radial-gradient(ellipse at center, #142438 0%, #0a1223 80%);\n    border-radius: 2rem;\n    box-shadow:\n      inset 0 0 40px #0a8fffaa,\n      0 14px 40px #0a8fff88;\n    width: 100%;\n    max-width: 900px;\n    padding: 4rem 2rem 6rem;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: space-around;\n    gap: 3rem;\n  }\n\n  /* Phase Boxes */\n  .phase {\n    background: linear-gradient(145deg, #022b54, #01386a);\n    border-radius: 1.6rem;\n    box-shadow:\n      6px 6px 23px #011c39,\n      -6px -6px 20px #054882;\n    width: 220px;\n    min-height: 160px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    padding: 1.8rem 1.8rem 2.4rem;\n    position: relative;\n    color: #bde7ff;\n    cursor: default;\n    transition: transform 0.35s ease, box-shadow 0.35s ease;\n  }\n  .phase:hover {\n    transform: translateY(-10px);\n    box-shadow:\n      6px 6px 40px #0ac9ffcc,\n      -6px -6px 35px #0af4ffcc,\n      0 0 30px #46ecffcc;\n  }\n  .phase h3 {\n    font-family: 'Roboto Slab', serif;\n    font-size: 1.7rem;\n    margin: 0 0 0.5rem;\n    color: #4be8ff;\n    text-shadow:\n      0 0 7px #3acfff,\n      0 0 15px #37baff;\n  }\n  .phase p {\n    font-family: 'Source Code Pro', monospace;\n    font-size: 0.95rem;\n    line-height: 1.3;\n    color: #9bd8ffcc;\n  }\n\n  /* Connections with arrows using SVG paths */\n  svg.connections {\n    position: absolute;\n    top: 2rem;\n    left: 0;\n    width: 100%;\n    height: 90%;\n    pointer-events: none;\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Buttons */\n  .controls {\n    margin-top: 2rem;\n    text-align: center;\n  }\n  button {\n    background: linear-gradient(145deg, #0267c1, #023759);\n    border: none;\n    border-radius: 99px;\n    padding: 0.8rem 2.4rem;\n    font-size: 1.05rem;\n    font-family: 'Source Code Pro', monospace;\n    color: #a1d8ff;\n    letter-spacing: 0.08em;\n    cursor: pointer;\n    box-shadow:\n      4px 4px 12px #014b80,\n      inset -2px -2px 6px #0350aa;\n    transition: background 0.4s ease, box-shadow 0.4s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: linear-gradient(145deg, #03a9ff, #057fff);\n    box-shadow:\n      6px 6px 28px #33c9ffcc,\n      inset 0 0 20px #1fc1ffcc;\n    outline: none;\n  }\n  button:active {\n    transform: translateY(2px);\n  }\n\n  /* Code snippet box */\n  .code-sample {\n    background: #00182fbb;\n    border-radius: 1rem;\n    box-shadow: 0 0 30px #0f7aff99 inset;\n    padding: 1.6rem 1.8rem;\n    margin-top: 30px;\n    font-family: 'Source Code Pro', monospace;\n    user-select: text;\n    max-width: 900px;\n    color: #a9defd;\n    font-size: 1.0rem;\n    line-height: 1.4;\n    white-space: pre-wrap;\n    border-left: 4px solid #05aaffcc;\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 5rem;\n    font-size: 0.8rem;\n    font-family: 'Source Code Pro', monospace;\n    color: #44637e99;\n    letter-spacing: 0.1em;\n    user-select:none;\n  }\n\n  /* Responsive */\n  @media (max-width: 720px) {\n    .diagram {\n      flex-direction: column;\n      align-items: center;\n      padding: 3rem 1rem 4rem;\n    }\n    .phase {\n      width: 90%;\n      min-height: 140px;\n    }\n    .code-sample {\n      width: 90vw;\n      font-size: 0.9rem;\n    }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\" aria-label=\"Compiler Concept Visual Illustration\">\n    <header>\n      <h1 tabindex=\"0\">Compiler</h1>\n      <p class=\"subtitle\">Translating Code into Machine Brilliance</p>\n    </header>\n\n    <section class=\"diagram\" aria-hidden=\"true\" aria-label=\"Visual Diagram showing the compilation phases\">\n      <!-- Compiler Phases -->\n      <article class=\"phase\" style=\"z-index:5;\" id=\"phase-lexical\" aria-labelledby=\"label-lexical\">\n        <h3 id=\"label-lexical\">Lexical Analysis</h3>\n        <p>Transforms source code into tokens highlighting keywords, symbols, and identifiers.</p>\n      </article>\n      <article class=\"phase\" id=\"phase-syntax\" aria-labelledby=\"label-syntax\">\n        <h3 id=\"label-syntax\">Syntax Analysis</h3>\n        <p>Parses tokens per grammar rules producing an abstract syntax tree (AST).</p>\n      </article>\n      <article class=\"phase\" id=\"phase-semantic\" aria-labelledby=\"label-semantic\">\n        <h3 id=\"label-semantic\">Semantic Analysis</h3>\n        <p>Ensures meaning consistency — types, variable declarations, and scope checks.</p>\n      </article>\n      <article class=\"phase\" id=\"phase-optimization\" aria-labelledby=\"label-optimization\">\n        <h3 id=\"label-optimization\">Optimization</h3>\n        <p>Improves intermediate code to enhance performance and reduce resource use.</p>\n      </article>\n      <article class=\"phase\" id=\"phase-codegen\" aria-labelledby=\"label-codegen\">\n        <h3 id=\"label-codegen\">Code Generation</h3>\n        <p>Translates optimized code into machine language or bytecode for execution.</p>\n      </article>\n\n      <!-- SVG arrows connecting phases -->\n      <svg class=\"connections\" aria-hidden=\"true\" focusable=\"false\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\"\n            refX=\"10\" refY=\"3\" orient=\"auto\" fill=\"#05aaff\">\n            <path d=\"M0,0 L10,3 L0,6\" />\n          </marker>\n        </defs>\n\n        <!-- Lines connecting the boxes horizontally or vertically -->\n        <line x1=\"230\" y1=\"70\" x2=\"300\" y2=\"70\" stroke=\"#059aff99\" stroke-width=\"3\"\n          marker-end=\"url(#arrowhead)\" style=\"filter: drop-shadow(0 0 5px #0af4ff99);\"/>\n        <line x1=\"530\" y1=\"70\" x2=\"600\" y2=\"70\" stroke=\"#059aff99\" stroke-width=\"3\"\n          marker-end=\"url(#arrowhead)\" style=\"filter: drop-shadow(0 0 5px #0af4ff99);\"/>\n        <line x1=\"830\" y1=\"70\" x2=\"900\" y2=\"70\" stroke=\"#059aff99\" stroke-width=\"3\"\n          marker-end=\"url(#arrowhead)\" style=\"filter: drop-shadow(0 0 5px #0af4ff99);\"/>\n\n        <!-- Curved arrow to bottom for some phase branching -->\n        <path d=\"M 620 110 Q 660 140 700 110\" fill=\"none\" stroke=\"#05aaffaa\" stroke-width=\"3\"\n              marker-end=\"url(#arrowhead)\" style=\"filter: drop-shadow(0 0 5px #0af4ffaa);\" />\n      </svg>\n    </section>\n\n    <pre class=\"code-sample\" aria-label=\"Example source code input\">\n<span style=\"color:#54c0f8;\">int</span> <span style=\"color:#e0e0e0;\">main</span><span style=\"color:#7ec699;\">()</span> <span style=\"color:#e0e0e0;\">{</span>\n  <span style=\"color:#d1b89f;\">return</span> <span style=\"color:#fcae76;\">42</span><span style=\"color:#e0e0e0;\">;</span>\n<span style=\"color:#e0e0e0;\">}</span>\n    </pre>\n\n    <div class=\"controls\" role=\"region\" aria-label=\"Demo controls\">\n      <button id=\"toggle-theme\" aria-pressed=\"false\" aria-label=\"Toggle dark and light theme\">Toggle Theme</button>\n    </div>\n  </div>\n\n<script>\n  // Minimal interactivity: toggle dark/light theme with smooth transitions\n  const button = document.getElementById('toggle-theme');\n  let dark = true;\n\n  button.addEventListener('click', () => {\n    dark = !dark;\n    button.setAttribute('aria-pressed', String(!dark));\n    if (dark) {\n      document.documentElement.style.setProperty('--bg-gradient', 'linear-gradient(135deg, #1a1f3d, #040812)');\n      document.body.style.background = 'linear-gradient(135deg, #1a1f3d, #040812)';\n      document.body.style.color = '#d0d6f9';\n    } else {\n      document.documentElement.style.setProperty('--bg-gradient', 'linear-gradient(135deg, #f0f5fa, #d9e4f5)');\n      document.body.style.background = 'linear-gradient(135deg, #f0f5fa, #d9e4f5)';\n      document.body.style.color = '#33475b';\n    }\n  });\n</script>\n</body>\n</html>"
