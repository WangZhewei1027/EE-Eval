    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Hash Functions Explorer</title>\n</head>\n<body>\n<h1>Hash Functions Explorer</h1>\n\n<!-- Input and basic controls -->\n<section>\n  <h2>Input</h2>\n  <label>Text input: <input id=\"textInput\" type=\"text\" value=\"hello world\" style=\"width:60%\"></label>\n  <br><br>\n  <label>File input: <input id=\"fileInput\" type=\"file\"></label>\n  <br><br>\n  <button id=\"randomTextBtn\">Generate Random Text (32 chars)</button>\n  <button id=\"randomBytesBtn\">Generate Random Bytes (32)</button>\n  <br><br>\n  <label>Encoding of output:\n    <select id=\"outFormat\">\n      <option value=\"hex\">Hex</option>\n      <option value=\"base64\">Base64</option>\n      <option value=\"binary\">Binary string</option>\n    </select>\n  </label>\n  <br><br>\n</section>\n\n<hr>\n\n<!-- Algorithm selection and options -->\n<section>\n  <h2>Algorithms & Options</h2>\n  <label>Select algorithm:\n    <select id=\"algorithmSelect\">\n      <optgroup label=\"WebCrypto (native)\">\n        <option value=\"SHA-1\">SHA-1</option>\n        <option selected value=\"SHA-256\">SHA-256</option>\n        <option value=\"SHA-384\">SHA-384</option>\n        <option value=\"SHA-512\">SHA-512</option>\n      </optgroup>\n      <optgroup label=\"Toy / Demonstration\">\n        <option value=\"FNV-1a-32\">FNV-1a (32-bit)</option>\n        <option value=\"DJB2\">DJB2 (simple)</option>\n        <option value=\"XOR-rotate\">XOR-Rotate (simple custom)</option>\n        <option value=\"Murmur3-32\">MurmurHash3 (x86, 32-bit)</option>\n      </optgroup>\n    </select>\n  </label>\n  <br><br>\n  <label>Salt/key (for HMAC or salted hashing): <input id=\"saltInput\" type=\"text\" placeholder=\"optional\"></label>\n  <label>Salt mode:\n    <select id=\"saltMode\">\n      <option value=\"none\">None</option>\n      <option value=\"prefix\">Prefix</option>\n      <option value=\"suffix\">Suffix</option>\n      <option value=\"hmac\">HMAC-style</option>\n    </select>\n  </label>\n  <br><br>\n\n  <label>Block size (bytes, used for toy HMAC/Merkle): <input id=\"blockSize\" type=\"number\" value=\"64\" min=\"1\"></label>\n  <label>Endianness:\n    <select id=\"endianness\">\n      <option value=\"big\">big</option>\n      <option value=\"little\">little</option>\n    </select>\n  </label>\n  <br><br>\n\n  <label>Iterations (iterative hashing): <input id=\"iterations\" type=\"number\" value=\"1\" min=\"1\"></label>\n  <label>Max iterations per step chunk (for UI): <input id=\"iterChunk\" type=\"number\" value=\"1000\" min=\"1\"></label>\n  <br><br>\n\n  <button id=\"computeHashBtn\">Compute Hash</button>\n  <button id=\"computeAllBtn\">Compute Across All Algorithms</button>\n  <button id=\"copyResultBtn\">Copy Current Result</button>\n  <button id=\"downloadResultBtn\">Download Current Result</button>\n  <br><br>\n\n  <label>Streaming / chunk size (bytes) for file or long input: <input id=\"chunkSize\" type=\"number\" value=\"1024\" min=\"1\"></label>\n  <button id=\"startStreamBtn\">Start Streaming Hash (simulate)</button>\n  <button id=\"cancelStreamBtn\">Cancel Stream</button>\n  <div id=\"streamLog\" style=\"white-space:pre-wrap\"></div>\n</section>\n\n<hr>\n\n<!-- Output -->\n<section>\n  <h2>Output</h2>\n  <div>\n    <label>Result (<span id=\"resultAlg\">-</span>):</label>\n    <pre id=\"hashOutput\" style=\"white-space:pre-wrap\"></pre>\n  </div>\n  <div>\n    <label>Raw bytes (hex):</label>\n    <pre id=\"rawHex\" style=\"white-space:pre-wrap\"></pre>\n  </div>\n  <div>\n    <label>Binary (bit string):</label>\n    <pre id=\"rawBits\" style=\"white-space:pre-wrap\"></pre>\n  </div>\n</section>\n\n<hr>\n\n<!-- Exploration tools -->\n<section>\n  <h2>Exploration Tools</h2>\n\n  <details>\n    <summary>1) Avalanche Effect Explorer</summary>\n    <div>\n      <label>Base input: <input id=\"avBase\" type=\"text\" value=\"hello world\"></label>\n      <label>Algorithm: <select id=\"avAlg\">\n        <option value=\"SHA-256\">SHA-256</option>\n        <option value=\"FNV-1a-32\">FNV-1a-32</option>\n        <option value=\"Murmur3-32\">Murmur3-32</option>\n      </select></label>\n      <br><br>\n      <label>Number of flips to test (max bits): <input id=\"avFlips\" type=\"number\" value=\"16\" min=\"1\" max=\"1024\"></label>\n      <label>Flip strategy:\n        <select id=\"avStrategy\">\n          <option value=\"sequential\">Sequential bit flips</option>\n          <option value=\"random\">Random positions</option>\n        </select>\n      </label>\n      <br><br>\n      <button id=\"runAvalancheBtn\">Run Avalanche Test</button>\n      <button id=\"cancelAvalancheBtn\">Cancel</button>\n      <pre id=\"avalancheLog\" style=\"white-space:pre-wrap\"></pre>\n    </div>\n  </details>\n\n  <details>\n    <summary>2) Brute-force Preimage Finder (toy algorithms only)</summary>\n    <div>\n      <label>Target hash (hex for toy alg): <input id=\"bfTarget\" type=\"text\"></label>\n      <label>Algorithm: <select id=\"bfAlg\"><option value=\"FNV-1a-32\">FNV-1a-32</option><option value=\"DJB2\">DJB2</option><option value=\"Murmur3-32\">Murmur3-32</option></select></label>\n      <br><br>\n      <label>Charset: <input id=\"bfCharset\" type=\"text\" value=\"abc012345\"></label>\n      <label>Max length: <input id=\"bfMaxLen\" type=\"number\" value=\"4\" min=\"1\"></label>\n      <br><br>\n      <button id=\"startBruteBtn\">Start Brute Force</button>\n      <button id=\"stopBruteBtn\">Stop</button>\n      <pre id=\"bruteLog\" style=\"white-space:pre-wrap\"></pre>\n    </div>\n  </details>\n\n  <details>\n    <summary>3) Collision Search (Birthday-style) for small toy hashes</summary>\n    <div>\n      <label>Algorithm (toy): <select id=\"colAlg\"><option value=\"FNV-1a-32\">FNV-1a-32</option><option value=\"DJB2\">DJB2</option></select></label>\n      <label>Max attempts: <input id=\"colMax\" type=\"number\" value=\"100000\" min=\"1\"></label>\n      <br><br>\n      <button id=\"startCollisionBtn\">Start Collision Search</button>\n      <button id=\"stopCollisionBtn\">Stop</button>\n      <pre id=\"collisionLog\" style=\"white-space:pre-wrap\"></pre>\n    </div>\n  </details>\n\n  <details>\n    <summary>4) Merkle Tree Builder</summary>\n    <div>\n      <label>Enter many lines as leaves (newline separated):</label>\n      <br>\n      <textarea id=\"merkleLeaves\" rows=\"6\" cols=\"80\">leaf1\nleaf2\nleaf3\nleaf4</textarea>\n      <br>\n      <label>Algorithm: <select id=\"merkleAlg\"><option value=\"SHA-256\">SHA-256</option><option value=\"FNV-1a-32\">FNV-1a-32</option></select></label>\n      <br><br>\n      <button id=\"buildMerkleBtn\">Build Merkle Tree</button>\n      <pre id=\"merkleLog\" style=\"white-space:pre-wrap\"></pre>\n    </div>\n  </details>\n\n  <details>\n    <summary>5) HMAC Inspector</summary>\n    <div>\n      <label>Key: <input id=\"hmacKey\" type=\"text\" value=\"secret\"></label>\n      <label>Message: <input id=\"hmacMsg\" type=\"text\" value=\"hello\"></label>\n      <label>Algorithm: <select id=\"hmacAlg\"><option value=\"SHA-256\">SHA-256</option><option value=\"FNV-1a-32\">FNV-1a-32</option></select></label>\n      <br><br>\n      <button id=\"computeHmacBtn\">Compute HMAC (show inner/outer)</button>\n      <pre id=\"hmacLog\" style=\"white-space:pre-wrap\"></pre>\n    </div>\n  </details>\n\n</section>\n\n<hr>\n\n<!-- Misc utility -->\n<section>\n  <h2>Utilities</h2>\n  <button id=\"clearLogsBtn\">Clear All Logs</button>\n  <button id=\"resetDefaultsBtn\">Reset Inputs to Defaults</button>\n  <pre id=\"miscLog\" style=\"white-space:pre-wrap\"></pre>\n</section>\n\n<script>\n/*\n  Hash Functions Explorer\n  - Minimal visual design (plain HTML elements)\n  - Rich interactivity: multiple algorithms, streaming, avalanche, brute-force, collisions, Merkle, HMAC\n*/\n\n// Utility conversions\nfunction bufToHex(buf) {\n  const bytes = new Uint8Array(buf);\n  let s = '';\n  for (let b of bytes) s += ('0' + b.toString(16)).slice(-2);\n  return s;\n}\nfunction bufToBase64(buf) {\n  const bytes = new Uint8Array(buf);\n  let binary = '';\n  for (let b of bytes) binary += String.fromCharCode(b);\n  return btoa(binary);\n}\nfunction bufToBitString(buf) {\n  const bytes = new Uint8Array(buf);\n  let s = '';\n  for (let b of bytes) {\n    s += ('00000000' + b.toString(2)).slice(-8) + ' ';\n  }\n  return s.trim();\n}\nfunction hexToBuf(hex) {\n  hex = hex.replace(/\\s+/g,'');\n  if (hex.length % 2) hex = '0' + hex;\n  const len = hex.length / 2;\n  const out = new Uint8Array(len);\n  for (let i = 0; i < len; i++) out[i] = parseInt(hex.substr(i*2,2),16);\n  return out.buffer;\n}\nfunction strToBuf(str) {\n  return new TextEncoder().encode(str).buffer;\n}\nfunction bufConcat(a, b) {\n  const ua = new Uint8Array(a);\n  const ub = new Uint8Array(b);\n  const out = new Uint8Array(ua.length + ub.length);\n  out.set(ua, 0);\n  out.set(ub, ua.length);\n  return out.buffer;\n}\nfunction fromBase64ToBuf(b64) {\n  const binary = atob(b64);\n  const len = binary.length;\n  const out = new Uint8Array(len);\n  for (let i = 0; i < len; i++) out[i] = binary.charCodeAt(i);\n  return out.buffer;\n}\n\n// Toy algorithms\nfunction fnv1a32(buf) {\n  const bytes = new Uint8Array(buf);\n  let h = 0x811c9dc5 >>> 0;\n  for (let b of bytes) {\n    h ^= b;\n    h = (Math.imul(h, 0x01000193)) >>> 0;\n  }\n  // return as 4-byte array buffer\n  const out = new Uint8Array(4);\n  out[0] = (h >>> 24) & 0xff;\n  out[1] = (h >>> 16) & 0xff;\n  out[2] = (h >>> 8) & 0xff;\n  out[3] = (h >>> 0) & 0xff;\n  return out.buffer;\n}\nfunction djb2(buf) {\n  const bytes = new Uint8Array(buf);\n  let h = 5381 >>> 0;\n  for (let b of bytes) {\n    h = ((h << 5) + h + b) >>> 0;\n  }\n  const out = new Uint8Array(4);\n  out[0] = (h >>> 24) & 0xff;\n  out[1] = (h >>> 16) & 0xff;\n  out[2] = (h >>> 8) & 0xff;\n  out[3] = (h >>> 0) & 0xff;\n  return out.buffer;\n}\nfunction xorRotate(buf) {\n  const bytes = new Uint8Array(buf);\n  let a = 0x12345678 >>> 0;\n  for (let i = 0; i < bytes.length; i++) {\n    a ^= bytes[i];\n    a = ((a << (i % 8)) | (a >>> (32 - (i % 8)))) >>> 0;\n    a = (a + 0x9e3779b1) >>> 0;\n  }\n  const out = new Uint8Array(4);\n  out[0] = (a >>> 24) & 0xff;\n  out[1] = (a >>> 16) & 0xff;\n  out[2] = (a >>> 8) & 0xff;\n  out[3] = (a >>> 0) & 0xff;\n  return out.buffer;\n}\n// MurmurHash3 x86 32-bit\nfunction murmur3_32(buf, seed=0) {\n  const data = new Uint8Array(buf);\n  let h1 = seed >>> 0;\n  const c1 = 0xcc9e2d51;\n  const c2 = 0x1b873593;\n  const len = data.length;\n  const blockCount = Math.floor(len / 4);\n  for (let i = 0; i < blockCount; i++) {\n    let k1 = (data[i*4] & 0xff) | ((data[i*4+1] & 0xff) << 8) | ((data[i*4+2] & 0xff) << 16) | ((data[i*4+3] & 0xff) << 24);\n    k1 = Math.imul(k1, c1);\n    k1 = (k1 << 15) | (k1 >>> 17);\n    k1 = Math.imul(k1, c2);\n    h1 ^= k1;\n    h1 = (h1 << 13) | (h1 >>> 19);\n    h1 = (Math.imul(h1,5) + 0xe6546b64) >>> 0;\n  }\n  let k1 = 0;\n  const tailIndex = blockCount * 4;\n  switch (len & 3) {\n    case 3: k1 ^= (data[tailIndex+2] & 0xff) << 16;\n    case 2: k1 ^= (data[tailIndex+1] & 0xff) << 8;\n    case 1: k1 ^= (data[tailIndex] & 0xff);\n            k1 = Math.imul(k1, c1);\n            k1 = (k1 << 15) | (k1 >>> 17);\n            k1 = Math.imul(k1, c2);\n            h1 ^= k1;\n  }\n  h1 ^= len;\n  h1 ^= h1 >>> 16;\n  h1 = Math.imul(h1, 0x85ebca6b);\n  h1 ^= h1 >>> 13;\n  h1 = Math.imul(h1, 0xc2b2ae35);\n  h1 ^= h1 >>> 16;\n  const out = new Uint8Array(4);\n  out[0] = (h1 >>> 24) & 0xff;\n  out[1] = (h1 >>> 16) & 0xff;\n  out[2] = (h1 >>> 8) & 0xff;\n  out[3] = (h1 >>> 0) & 0xff;\n  return out.buffer;\n}\n\n// Generic computeHash that returns ArrayBuffer\nasync function computeHashByName(name, buf) {\n  // accept buf as ArrayBuffer\n  if (name === 'FNV-1a-32') return fnv1a32(buf);\n  if (name === 'DJB2') return djb2(buf);\n  if (name === 'XOR-rotate') return xorRotate(buf);\n  if (name === 'Murmur3-32') return murmur3_32(buf);\n  // WebCrypto names\n  const webAlgs = ['SHA-1','SHA-256','SHA-384','SHA-512'];\n  if (webAlgs.includes(name)) {\n    try {\n      return await crypto.subtle.digest(name, buf);\n    } catch (e) {\n      throw new Error('WebCrypto error: ' + e);\n    }\n  }\n  throw new Error('Unknown algorithm: ' + name);\n}\n\n// Helper to display result depending on outFormat\nfunction displayResult(buf, algName) {\n  const outFormat = document.getElementById('outFormat').value;\n  document.getElementById('resultAlg').textContent = algName;\n  const rawHex = bufToHex(buf);\n  document.getElementById('rawHex').textContent = rawHex;\n  document.getElementById('rawBits').textContent = bufToBitString(buf);\n  let displayed = '';\n  if (outFormat === 'hex') displayed = rawHex;\n  else if (outFormat === 'base64') displayed = bufToBase64(buf);\n  else if (outFormat === 'binary') displayed = bufToBitString(buf);\n  document.getElementById('hashOutput').textContent = displayed;\n}\n\n// Compose salt/key according to mode\nfunction applySalt(mode, saltStr, dataBuf) {\n  if (!saltStr) return dataBuf;\n  const saltBuf = strToBuf(saltStr);\n  if (mode === 'prefix') return bufConcat(saltBuf, dataBuf);\n  if (mode === 'suffix') return bufConcat(dataBuf, saltBuf);\n  if (mode === 'hmac') {\n    // HMAC-like composition: we'll use actual HMAC routine elsewhere; here treat as prefix for computeHashByName\n    return bufConcat(saltBuf, dataBuf);\n  }\n  return dataBuf;\n}\n\n// Compute hash with iterations and optionally HMAC-like key\nlet iterativeAbort = false;\ndocument.getElementById('computeHashBtn').addEventListener('click', async () => {\n  iterativeAbort = false;\n  const alg = document.getElementById('algorithmSelect').value;\n  let dataBuf;\n  const fileEl = document.getElementById('fileInput');\n  if (fileEl.files && fileEl.files[0]) {\n    const f = fileEl.files[0];\n    dataBuf = await f.arrayBuffer();\n  } else {\n    const txt = document.getElementById('textInput').value;\n    dataBuf = strToBuf(txt);\n  }\n  const saltMode = document.getElementById('saltMode').value;\n  const saltStr = document.getElementById('saltInput').value;\n  if (saltMode !== 'none' && saltMode !== 'hmac') {\n    dataBuf = applySalt(saltMode, saltStr, dataBuf);\n  }\n  const iterations = Math.max(1, parseInt(document.getElementById('iterations').value || '1',10));\n  const iterChunk = Math.max(1, parseInt(document.getElementById('iterChunk').value || '1000',10));\n  let currentBuf = dataBuf;\n  // if mode hmac, compute via HMAC routine\n  if (saltMode === 'hmac') {\n    try {\n      const hm = await computeHMAC(saltStr, currentBuf, alg, parseInt(document.getElementById('blockSize').value||'64',10));\n      displayResult(hm, alg + ' (HMAC)');\n    } catch (e) {\n      alert(e);\n    }\n    return;\n  }\n  try {\n    for (let i = 0; i < iterations; i++) {\n      if (iterativeAbort) { document.getElementById('miscLog').textContent = 'Operation aborted by user'; return; }\n      currentBuf = await computeHashByName(alg, currentBuf);\n      // occasionally yield to UI\n      if ((i+1) % iterChunk === 0) {\n        document.getElementById('miscLog').textContent = 'Iterations: ' + (i+1) + ' ...';\n        await new Promise(r => setTimeout(r,0));\n      }\n    }\n    displayResult(currentBuf, alg + ' x' + iterations);\n    document.getElementById('miscLog').textContent = 'Done iterations: ' + iterations;\n  } catch (e) {\n    alert('Error computing hash: ' + e);\n  }\n});\ndocument.getElementById('cancelStreamBtn').addEventListener('click', () => {\n  streamAbort = true;\n  iterativeAbort = true;\n});\n\n// Copy & download helpers\ndocument.getElementById('copyResultBtn').addEventListener('click', async () => {\n  const txt = document.getElementById('hashOutput').textContent;\n  try {\n    await navigator.clipboard.writeText(txt);\n    document.getElementById('miscLog').textContent = 'Copied result to clipboard';\n  } catch (e) {\n    document.getElementById('miscLog').textContent = 'Copy failed: ' + e;\n  }\n});\ndocument.getElementById('downloadResultBtn').addEventListener('click', () => {\n  const txt = document.getElementById('hashOutput').textContent;\n  const blob = new Blob([txt], { type: 'text/plain' });\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'hash.txt';\n  a.click();\n  URL.revokeObjectURL(url);\n});\n\n// Compute across all algorithms\ndocument.getElementById('computeAllBtn').addEventListener('click', async () => {\n  const algs = ['SHA-1','SHA-256','SHA-384','SHA-512','FNV-1a-32','DJB2','Murmur3-32','XOR-rotate'];\n  let dataBuf;\n  const fileEl = document.getElementById('fileInput');\n  if (fileEl.files && fileEl.files[0]) dataBuf = await fileEl.files[0].arrayBuffer();\n  else dataBuf = strToBuf(document.getElementById('textInput').value);\n  const saltMode = document.getElementById('saltMode').value;\n  const saltStr = document.getElementById('saltInput').value;\n  if (saltMode !== 'none' && saltMode !== 'hmac') dataBuf = applySalt(saltMode, saltStr, dataBuf);\n  const out = [];\n  for (let a of algs) {\n    try {\n      const h = await computeHashByName(a, dataBuf);\n      out.push(a + ': ' + bufToHex(h));\n    } catch (e) {\n      out.push(a + ': error');\n    }\n  }\n  document.getElementById('hashOutput').textContent = out.join('\\n');\n  document.getElementById('rawHex').textContent = '';\n  document.getElementById('rawBits').textContent = '';\n  document.getElementById('resultAlg').textContent = 'Multi';\n});\n\n// Streaming simulation (for large input or file)\nlet streamAbort = false;\ndocument.getElementById('startStreamBtn').addEventListener('click', async () => {\n  streamAbort = false;\n  const alg = document.getElementById('algorithmSelect').value;\n  const chunkSize = Math.max(1, parseInt(document.getElementById('chunkSize').value || '1024',10));\n  let totalBuf;\n  const fileEl = document.getElementById('fileInput');\n  if (fileEl.files && fileEl.files[0]) {\n    const file = fileEl.files[0];\n    const size = file.size;\n    document.getElementById('streamLog').textContent = 'Streaming file ' + file.name + ' size ' + size;\n    // simulate chunk processing using toy incremental or repeated digest\n    let processed = 0;\n    let stateBuf = new Uint8Array(0).buffer;\n    while (processed < size) {\n      if (streamAbort) { document.getElementById('streamLog').textContent += '\\nAborted'; return; }\n      const slice = file.slice(processed, Math.min(size, processed + chunkSize));\n      const partBuf = await slice.arrayBuffer();\n      // for toy algs, update state via specific mix; for WebCrypto we'll re-digest full concatenated so far\n      if (['FNV-1a-32','DJB2','XOR-rotate','Murmur3-32'].includes(alg)) {\n        // incremental update: mix current state with partBuf by concatenation and hashing\n        stateBuf = bufConcat(stateBuf, partBuf);\n        stateBuf = await computeHashByName(alg, stateBuf);\n      } else {\n        // WebCrypto: digest cumulative data so far to show progress (inefficient but for demo)\n        totalBuf = totalBuf ? bufConcat(totalBuf, partBuf) : partBuf;\n        stateBuf = await computeHashByName(alg, totalBuf);\n      }\n      processed += partBuf.byteLength;\n      document.getElementById('streamLog').textContent += '\\\\nProcessed ' + processed + ' / ' + size + ' bytes, interim hash: ' + bufToHex(stateBuf);\n      await new Promise(r => setTimeout(r, 0));\n    }\n    displayResult(stateBuf, alg + ' (streamed)');\n  } else {\n    // no file: stream the text input as chunks\n    const txt = document.getElementById('textInput').value;\n    const enc = new TextEncoder().encode(txt);\n    const size = enc.length;\n    let processed = 0;\n    let stateBuf = new Uint8Array(0).buffer;\n    while (processed < size) {\n      if (streamAbort) { document.getElementById('streamLog').textContent += '\\\\nAborted'; return; }\n      const end = Math.min(size, processed + chunkSize);\n      const part = enc.slice(processed, end).buffer;\n      if (['FNV-1a-32','DJB2','XOR-rotate','Murmur3-32'].includes(alg)) {\n        stateBuf = bufConcat(stateBuf, part);\n        stateBuf = await computeHashByName(alg, stateBuf);\n      } else {\n        totalBuf = totalBuf ? bufConcat(totalBuf, part) : part;\n        stateBuf = await computeHashByName(alg, totalBuf);\n      }\n      processed = end;\n      document.getElementById('streamLog').textContent += '\\\\nProcessed ' + processed + ' / ' + size + ' bytes, interim: ' + bufToHex(stateBuf);\n      await new Promise(r => setTimeout(r, 0));\n    }\n    displayResult(stateBuf, alg + ' (streamed)');\n  }\n});\n\n// Avalanche explorer\nlet avalancheAbort = false;\ndocument.getElementById('cancelAvalancheBtn').addEventListener('click', ()=> avalancheAbort = true);\ndocument.getElementById('runAvalancheBtn').addEventListener('click', async () => {\n  avalancheAbort = false;\n  const base = document.getElementById('avBase').value;\n  const alg = document.getElementById('avAlg').value;\n  const flips = Math.max(1, parseInt(document.getElementById('avFlips').value||'16',10));\n  const strategy = document.getElementById('avStrategy').value;\n  const baseBuf = strToBuf(base);\n  const baseHash = await computeHashByName(alg, baseBuf);\n  const baseHex = bufToHex(baseHash);\n  document.getElementById('avalancheLog').textContent = 'Base hash: ' + baseHex + '\\\\n';\n  const baseBits = new Uint8Array(baseHash).length * 8;\n  const outLines = [];\n  const hashBitLength = new Uint8Array(baseHash).length * 8;\n  let totalDistance = 0;\n  for (let i = 0; i < flips; i++) {\n    if (avalancheAbort) { outLines.push('Aborted'); break; }\n    const mutated = new Uint8Array(baseBuf.slice(0));\n    let pos;\n    if (strategy === 'sequential') {\n      pos = i % (mutated.length * 8 || 1);\n    } else {\n      pos = Math.floor(Math.random() * (mutated.length * 8 || 1));\n    }\n    const byteIndex = Math.floor(pos / 8);\n    const bitIndex = pos % 8;\n    if (mutated.length === 0) {\n      // extend by one byte if empty\n      const extended = new Uint8Array(1);\n      extended[0] = (1 << bitIndex);\n      mutated.set(extended, 0);\n    } else {\n      mutated[byteIndex] ^= (1 << bitIndex);\n    }\n    const h = await computeHashByName(alg, mutated.buffer);\n    const dist = hammingDistance(baseHash, h);\n    totalDistance += dist;\n    outLines.push('Flip #' + (i+1) + ' bit ' + pos + ' -> hash: ' + bufToHex(h) + ' diff bits: ' + dist + '/' + hashBitLength);\n    if ((i+1) % 20 === 0) await new Promise(r => setTimeout(r,0));\n  }\n  const avg = (flips>0)?(totalDistance/flips).toFixed(2):0;\n  outLines.push('\\\\nAverage changed bits: ' + avg + ' out of ' + (new Uint8Array(baseHash).length*8));\n  document.getElementById('avalancheLog').textContent += outLines.join('\\\\n');\n});\n\nfunction hammingDistance(bufA, bufB) {\n  const a = new Uint8Array(bufA);\n  const b = new Uint8Array(bufB);\n  const len = Math.min(a.length, b.length);\n  let d = 0;\n  for (let i = 0; i < len; i++) {\n    let x = a[i] ^ b[i];\n    while (x) { d += x & 1; x >>= 1; }\n  }\n  // if different length, count remaining bits as difference\n  if (a.length !== b.length) {\n    const longer = a.length > b.length ? a : b;\n    for (let i = len; i < longer.length; i++) {\n      let x = longer[i];\n      while (x) { d += x & 1; x >>= 1; }\n    }\n  }\n  return d;\n}\n\n// Brute-force preimage finder for toy algorithms\nlet bruteAbort = false;\ndocument.getElementById('startBruteBtn').addEventListener('click', async () => {\n  bruteAbort = false;\n  document.getElementById('bruteLog').textContent = '';\n  const targetHex = document.getElementById('bfTarget').value.replace(/\\s+/g,'');\n  if (!targetHex) { document.getElementById('bruteLog').textContent = 'Provide target hex'; return; }\n  const targetBuf = hexToBuf(targetHex);\n  const alg = document.getElementById('bfAlg').value;\n  const charset = document.getElementById('bfCharset').value || 'abc';\n  const maxLen = Math.max(1, parseInt(document.getElementById('bfMaxLen').value||'4',10));\n  let attempts = 0;\n  const start = Date.now();\n  let found = false;\n  async function tryString(s) {\n    attempts++;\n    const h = await computeHashByName(alg, strToBuf(s));\n    if (bufToHex(h) === bufToHex(targetBuf)) {\n      found = true;\n      document.getElementById('bruteLog').textContent += 'Found preimage: \"' + s + '\" after ' + attempts + ' attempts\\\\n';\n    }\n    if (attempts % 1000 === 0) {\n      document.getElementById('bruteLog').textContent = 'Attempts: ' + attempts;\n      await new Promise(r => setTimeout(r,0));\n    }\n  }\n  async function recurse(prefix, depth) {\n    if (bruteAbort || found) return;\n    if (prefix.length === depth) {\n      await tryString(prefix);\n      return;\n    }\n    for (let i = 0; i < charset.length; i++) {\n      if (bruteAbort || found) return;\n      await recurse(prefix + charset[i], depth);\n    }\n  }\n  for (let len = 1; len <= maxLen; len++) {\n    document.getElementById('bruteLog').textContent = 'Trying length ' + len;\n    await recurse('', len);\n    if (found || bruteAbort) break;\n  }\n  const took = ((Date.now() - start)/1000).toFixed(2);\n  if (!found) document.getElementById('bruteLog').textContent += 'Not found after ' + attempts + ' attempts in ' + took + 's';\n});\ndocument.getElementById('stopBruteBtn').addEventListener('click', () => bruteAbort = true);\n\n// Collision search\nlet collisionAbort = false;\ndocument.getElementById('startCollisionBtn').addEventListener('click', async () => {\n  collisionAbort = false;\n  document.getElementById('collisionLog').textContent = '';\n  const alg = document.getElementById('colAlg').value;\n  const max = Math.max(1, parseInt(document.getElementById('colMax').value||'10000',10));\n  const map = new Map();\n  let attempts = 0;\n  const start = Date.now();\n  while (attempts < max && !collisionAbort) {\n    attempts++;\n    const candidate = Math.random().toString(36).slice(2,10);\n    const h = await computeHashByName(alg, strToBuf(candidate));\n    const hex = bufToHex(h);\n    if (map.has(hex)) {\n      const other = map.get(hex);\n      document.getElementById('collisionLog').textContent = 'Collision found after ' + attempts + ' attempts:\\\\n' + candidate + ' and ' + other + ' -> ' + hex;\n      return;\n    } else {\n      map.set(hex, candidate);\n    }\n    if (attempts % 1000 === 0) {\n      document.getElementById('collisionLog').textContent = 'Attempts: ' + attempts;\n      await new Promise(r => setTimeout(r,0));\n    }\n  }\n  document.getElementById('collisionLog').textContent = 'No collision found in ' + attempts + ' attempts (time ' + ((Date.now()-start)/1000).toFixed(2) + 's)';\n});\ndocument.getElementById('stopCollisionBtn').addEventListener('click', ()=> collisionAbort = true);\n\n// Merkle tree builder\ndocument.getElementById('buildMerkleBtn').addEventListener('click', async () => {\n  const leavesText = document.getElementById('merkleLeaves').value;\n  const lines = leavesText.split(/\\\\r?\\\\n/).filter(Boolean);\n  if (lines.length === 0) { document.getElementById('merkleLog').textContent = 'No leaves'; return; }\n  const alg = document.getElementById('merkleAlg').value;\n  let level = [];\n  for (let i = 0; i < lines.length; i++) {\n    const h = await computeHashByName(alg, strToBuf(lines[i]));\n    level.push(h);\n    document.getElementById('merkleLog').textContent = 'Leaf ' + i + ': ' + bufToHex(h) + '\\\\n' + document.getElementById('merkleLog').textContent;\n  }\n  let depth = 0;\n  while (level.length > 1) {\n    const next = [];\n    for (let i = 0; i < level.length; i += 2) {\n      const a = level[i];\n      const b = (i+1 < level.length) ? level[i+1] : a; // duplicate if odd\n      const concat = bufConcat(a, b);\n      const ph = await computeHashByName(alg, concat);\n      next.push(ph);\n      document.getElementById('merkleLog').textContent += 'Parent of [' + i + (i+1<level.length?','+(i+1):',dup') + ']: ' + bufToHex(ph) + '\\\\n';\n    }\n    level = next;\n    depth++;\n  }\n  document.getElementById('merkleLog').textContent += '\\\\nRoot: ' + bufToHex(level[0]) + ' (depth ' + depth + ')';\n});\n\n// HMAC inspector (generic)\nasync function computeHMAC(keyStr, msgBuf, alg, blockSize=64) {\n  // keyStr is string; produce ArrayBuffer\n  let keyBuf = strToBuf(keyStr);\n  if (keyBuf.byteLength > blockSize) {\n    keyBuf = await computeHashByName(alg, keyBuf);\n  }\n  const keyArr = new Uint8Array(blockSize);\n  keyArr.set(new Uint8Array(keyBuf));\n  const ipad = new Uint8Array(blockSize);\n  const opad = new Uint8Array(blockSize);\n  for (let i = 0; i < blockSize; i++) {\n    ipad[i] = keyArr[i] ^ 0x36;\n    opad[i] = keyArr[i] ^ 0x5c;\n  }\n  const inner = bufConcat(ipad.buffer, msgBuf);\n  const innerHash = await computeHashByName(alg, inner);\n  const outer = bufConcat(opad.buffer, innerHash);\n  const final = await computeHashByName(alg, outer);\n  return final;\n}\ndocument.getElementById('computeHmacBtn').addEventListener('click', async () => {\n  const key = document.getElementById('hmacKey').value;\n  const msg = document.getElementById('hmacMsg').value;\n  const alg = document.getElementById('hmacAlg').value;\n  const blockSize = Math.max(1, parseInt(document.getElementById('blockSize').value||'64',10));\n  const innerLog = [];\n  // Show inner and outer pad\n  let keyBuf = strToBuf(key);\n  if (keyBuf.byteLength > blockSize) keyBuf = await computeHashByName(alg, keyBuf);\n  const keyArr = new Uint8Array(blockSize);\n  keyArr.set(new Uint8Array(keyBuf));\n  const ipad = new Uint8Array(blockSize);\n  const opad = new Uint8Array(blockSize);\n  for (let i = 0; i < blockSize; i++) {\n    ipad[i] = keyArr[i] ^ 0x36;\n    opad[i] = keyArr[i] ^ 0x5c;\n  }\n  innerLog.push('ipad (hex): ' + Array.from(ipad).map(b=>('0'+b.toString(16)).slice(-2)).join(''));\n  innerLog.push('opad (hex): ' + Array.from(opad).map(b=>('0'+b.toString(16)).slice(-2)).join(''));\n  const inner = bufConcat(ipad.buffer, strToBuf(msg));\n  const innerHash = await computeHashByName(alg, inner);\n  innerLog.push('inner hash: ' + bufToHex(innerHash));\n  const outer = bufConcat(opad.buffer, innerHash);\n  const final = await computeHashByName(alg, outer);\n  innerLog.push('outer hash (final HMAC): ' + bufToHex(final));\n  document.getElementById('hmacLog').textContent = innerLog.join('\\\\n');\n});\n\n// Misc utilities\ndocument.getElementById('clearLogsBtn').addEventListener('click', () => {\n  document.getElementById('streamLog').textContent = '';\n  document.getElementById('miscLog').textContent = '';\n  document.getElementById('avalancheLog').textContent = '';\n  document.getElementById('bruteLog').textContent = '';\n  document.getElementById('collisionLog').textContent = '';\n  document.getElementById('merkleLog').textContent = '';\n  document.getElementById('hmacLog').textContent = '';\n});\ndocument.getElementById('resetDefaultsBtn').addEventListener('click', () => {\n  document.getElementById('textInput').value = 'hello world';\n  document.getElementById('saltInput').value = '';\n  document.getElementById('outFormat').value = 'hex';\n  document.getElementById('algorithmSelect').value = 'SHA-256';\n  document.getElementById('iterations').value = '1';\n  document.getElementById('chunkSize').value = '1024';\n  document.getElementById('miscLog').textContent = 'Reset to defaults';\n});\n\n// Random generation buttons\ndocument.getElementById('randomTextBtn').addEventListener('click', () => {\n  const alpha = 'abcdefghijklmnopqrstuvwxyz0123456789';\n  let s = '';\n  for (let i = 0; i < 32; i++) s += alpha[Math.floor(Math.random()*alpha.length)];\n  document.getElementById('textInput').value = s;\n});\ndocument.getElementById('randomBytesBtn').addEventListener('click', () => {\n  const arr = new Uint8Array(32);\n  crypto.getRandomValues(arr);\n  document.getElementById('textInput').value = Array.from(arr).map(b=>('0'+b.toString(16)).slice(-2)).join(' ');\n});\n\n// File load preview: show brief and compute hash automatically if needed\ndocument.getElementById('fileInput').addEventListener('change', async () => {\n  const f = document.getElementById('fileInput').files[0];\n  if (!f) return;\n  document.getElementById('miscLog').textContent = 'Selected file: ' + f.name + ' size ' + f.size;\n});\n\n// Prevent accidental long loops on page unload\nwindow.addEventListener('beforeunload', (e) => {\n  if (false) { e.preventDefault(); e.returnValue = ''; }\n});\n</script>\n</body>\n</html>"
