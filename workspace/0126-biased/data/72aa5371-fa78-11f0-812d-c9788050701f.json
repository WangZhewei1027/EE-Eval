    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dijkstra's Algorithm Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --text: #636e72;\n            --highlight: #00cec9;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 2rem;\n            animation: fadeIn 1s ease-out;\n        }\n        \n        h1 {\n            font-size: 2.5rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.1rem;\n            color: var(--text);\n            font-weight: 300;\n            max-width: 600px;\n            line-height: 1.6;\n        }\n        \n        .container {\n            width: 100%;\n            max-width: 900px;\n            position: relative;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);\n            padding: 2rem;\n            margin-bottom: 2rem;\n            overflow: hidden;\n        }\n        \n        .graph-container {\n            position: relative;\n            height: 500px;\n            width: 100%;\n            margin: 0 auto;\n        }\n        \n        .node {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background: white;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: 600;\n            color: var(--dark);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n            z-index: 2;\n            transition: all 0.3s ease;\n            border: 3px solid var(--primary);\n        }\n        \n        .node.start {\n            border-color: var(--highlight);\n            transform: scale(1.1);\n        }\n        \n        .node.end {\n            border-color: var(--accent);\n        }\n        \n        .node.visited {\n            background-color: var(--secondary);\n            color: white;\n        }\n        \n        .node.path {\n            background-color: var(--highlight);\n            color: white;\n        }\n        \n        .edge {\n            position: absolute;\n            height: 3px;\n            background-color: var(--text);\n            transform-origin: left center;\n            z-index: 1;\n            opacity: 0.3;\n        }\n        \n        .edge.highlight {\n            background-color: var(--primary);\n            opacity: 1;\n            transition: all 0.5s ease;\n        }\n        \n        .edge.path {\n            background-color: var(--highlight);\n            opacity: 1;\n        }\n        \n        .weight {\n            position: absolute;\n            background: white;\n            padding: 0.2rem 0.5rem;\n            border-radius: 20px;\n            font-size: 0.8rem;\n            font-weight: 600;\n            color: var(--primary);\n            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);\n            transform: translate(-50%, -50%);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 1rem;\n            gap: 1rem;\n        }\n        \n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n            transition: all 0.3s ease;\n            outline: none;\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .info-panel {\n            background: white;\n            border-radius: 12px;\n            padding: 1.5rem;\n            margin-top: 2rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);\n            max-width: 900px;\n            animation: slideUp 0.8s ease-out;\n        }\n        \n        .info-panel h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.5rem;\n        }\n        \n        .info-panel p {\n            color: var(--text);\n            line-height: 1.7;\n            margin-bottom: 1rem;\n        }\n        \n        .steps {\n            margin-top: 2rem;\n            color: var(--text);\n        }\n        \n        .step {\n            display: flex;\n            align-items: center;\n            margin-bottom: 0.5rem;\n            padding: 0.5rem;\n            border-radius: 8px;\n            transition: all 0.3s ease;\n        }\n        \n        .step.active {\n            background: rgba(108, 92, 231, 0.1);\n            color: var(--primary);\n        }\n        \n        .step-number {\n            width: 25px;\n            height: 25px;\n            border-radius: 50%;\n            background: var(--secondary);\n            color: white;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 0.8rem;\n            font-weight: 600;\n            margin-right: 1rem;\n        }\n        \n        .step.active .step-number {\n            background: var(--primary);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n        \n        .pulse {\n            animation: pulse 1.5s infinite;\n        }\n        \n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 1.5rem;\n            margin-top: 1rem;\n        }\n        \n        .legend-item {\n            display: flex;\n            align-items: center;\n            font-size: 0.9rem;\n            color: var(--text);\n        }\n        \n        .legend-color {\n            width: 15px;\n            height: 15px;\n            border-radius: 3px;\n            margin-right: 0.5rem;\n        }\n        \n        .legend-start { background: var(--highlight); }\n        .legend-end { background: var(--accent); }\n        .legend-visited { background: var(--secondary); }\n        .legend-path { background: var(--primary); }\n        \n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--text);\n            font-size: 0.9rem;\n            font-weight: 300;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Dijkstra's Algorithm</h1>\n        <p class=\"subtitle\">Visualizing the shortest path between nodes in a weighted graph. Watch as the algorithm systematically explores paths from the start node to find the optimal route.</p>\n    </header>\n    \n    <div class=\"container\">\n        <div class=\"graph-container\" id=\"graph\"></div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color legend-start\"></div>\n                <span>Start Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color legend-end\"></div>\n                <span>End Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color legend-visited\"></div>\n                <span>Visited</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color legend-path\"></div>\n                <span>Shortest Path</span>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"controls\">\n        <button id=\"startBtn\">Run Algorithm</button>\n        <button id=\"resetBtn\">Reset</button>\n    </div>\n    \n    <div class=\"info-panel\">\n        <h2>How Dijkstra's Algorithm Works</h2>\n        <p>Dijkstra's algorithm finds the shortest path between nodes in a graph by systematically exploring paths from the starting node. It maintains a priority queue of nodes to visit, always expanding the node with the current minimum path cost.</p>\n        \n        <div class=\"steps\">\n            <div class=\"step\" id=\"step1\">\n                <div class=\"step-number\">1</div>\n                <div>Initialize distances: 0 for start node, ∞ for others</div>\n            </div>\n            <div class=\"step\" id=\"step2\">\n                <div class=\"step-number\">2</div>\n                <div>Mark start node as current and explore its neighbors</div>\n            </div>\n            <div class=\"step\" id=\"step3\">\n                <div class=\"step-number\">3</div>\n                <div>Update distances if a shorter path is found</div>\n            </div>\n            <div class=\"step\" id=\"step4\">\n                <div class=\"step-number\">4</div>\n                <div>Mark current node as visited and select next closest node</div>\n            </div>\n            <div class=\"step\" id=\"step5\">\n                <div class=\"step-number\">5</div>\n                <div>Repeat until all nodes are visited or destination is reached</div>\n            </div>\n            <div class=\"step\" id=\"step6\">\n                <div class=\"step-number\">6</div>\n                <div>Reconstruct shortest path from destination to start</div>\n            </div>\n        </div>\n    </div>\n    \n    <footer>\n        A visual demonstration of Dijkstra's algorithm for finding shortest paths in weighted graphs\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Graph configuration\n            const graph = {\n                nodes: [\n                    { id: 'A', x: 150, y: 100 },\n                    { id: 'B', x: 300, y: 50 },\n                    { id: 'C', x: 450, y: 150 },\n                    { id: 'D', x: 300, y: 250 },\n                    { id: 'E', x: 150, y: 300 },\n                    { id: 'F', x: 450, y: 300 }\n                ],\n                edges: [\n                    { from: 'A', to: 'B', weight: 4 },\n                    { from: 'A', to: 'D', weight: 2 },\n                    { from: 'B', to: 'C', weight: 3 },\n                    { from: 'B', to: 'D', weight: 3 },\n                    { from: 'C', to: 'D', weight: 1 },\n                    { from: 'C', to: 'F', weight: 2 },\n                    { from: 'D', to: 'E', weight: 5 },\n                    { from: 'E', to: 'F', weight: 3 }\n                ]\n            };\n            \n            const graphContainer = document.getElementById('graph');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let startNode = 'A';\n            let endNode = 'F';\n            let animationSpeed = 800;\n            let visitedNodes = [];\n            let shortestPath = [];\n            \n            // Initialize graph\n            function initGraph() {\n                graphContainer.innerHTML = '';\n                \n                // Create edges\n                graph.edges.forEach(edge => {\n                    const fromNode = graph.nodes.find(n => n.id === edge.from);\n                    const toNode = graph.nodes.find(n => n.id === edge.to);\n                    \n                    createEdge(fromNode, toNode, edge.weight);\n                });\n                \n                // Create nodes\n                graph.nodes.forEach(node => {\n                    createNode(node.id, node.x, node.y, node.id === startNode, node.id === endNode);\n                });\n            }\n            \n            // Create a node element\n            function createNode(id, x, y, isStart = false, isEnd = false) {\n                const node = document.createElement('div');\n                node.className = `node ${isStart ? 'start' : ''} ${isEnd ? 'end' : ''}`;\n                node.id = `node-${id}`;\n                node.textContent = id;\n                node.style.left = `${x}px`;\n                node.style.top = `${y}px`;\n                graphContainer.appendChild(node);\n            }\n            \n            // Create an edge element\n            function createEdge(fromNode, toNode, weight) {\n                const edge = document.createElement('div');\n                edge.className = 'edge';\n                \n                // Calculate edge position and angle\n                const dx = toNode.x - fromNode.x;\n                const dy = toNode.y - fromNode.y;\n                const length = Math.sqrt(dx * dx + dy * dy);\n                const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n                \n                edge.style.width = `${length}px`;\n                edge.style.left = `${fromNode.x + 25}px`;\n                edge.style.top = `${fromNode.y + 25}px`;\n                edge.style.transform = `rotate(${angle}deg)`;\n                \n                // Create weight label\n                const weightLabel = document.createElement('div');\n                weightLabel.className = 'weight';\n                weightLabel.textContent = weight;\n                weightLabel.style.left = `${fromNode.x + dx/2 + 25}px`;\n                weightLabel.style.top = `${fromNode.y + dy/2 + 25}px`;\n                \n                graphContainer.appendChild(edge);\n                graphContainer.appendChild(weightLabel);\n                \n                return edge;\n            }\n            \n            // Highlight edge between two nodes\n            function highlightEdge(fromId, toId) {\n                const edges = document.querySelectorAll('.edge');\n                edges.forEach(edge => {\n                    const fromNode = graph.nodes.find(n => n.id === fromId);\n                    const toNode = graph.nodes.find(n => n.id === toId);\n                    \n                    const dx = toNode.x - fromNode.x;\n                    const dy = toNode.y - fromNode.y;\n                    const length = Math.sqrt(dx * dx + dy * dy);\n                    \n                    if (edge.style.width === `${length}px` && \n                        edge.style.left === `${fromNode.x + 25}px` && \n                        edge.style.top === `${fromNode.y + 25}px`) {\n                        edge.classList.add('highlight');\n                    }\n                });\n            }\n            \n            // Mark node as visited\n            function visitNode(nodeId) {\n                const node = document.getElementById(`node-${nodeId}`);\n                node.classList.add('visited');\n                visitedNodes.push(nodeId);\n            }\n            \n            // Mark edge as part of shortest path\n            function markPathEdge(fromId, toId) {\n                const edges = document.querySelectorAll('.edge');\n                edges.forEach(edge => {\n                    const fromNode = graph.nodes.find(n => n.id === fromId);\n                    const toNode = graph.nodes.find(n => n.id === toId);\n                    \n                    const dx = toNode.x - fromNode.x;\n                    const dy = toNode.y - fromNode.y;\n                    const length = Math.sqrt(dx * dx + dy * dy);\n                    \n                    if (edge.style.width === `${length}px` && \n                        edge.style.left === `${fromNode.x + 25}px` && \n                        edge.style.top === `${fromNode.y + 25}px`) {\n                        edge.classList.remove('highlight');\n                        edge.classList.add('path');\n                    }\n                });\n            }\n            \n            // Mark node as part of shortest path\n            function markPathNode(nodeId) {\n                const node = document.getElementById(`node-${nodeId}`);\n                node.classList.remove('visited');\n                node.classList.add('path');\n                shortestPath.push(nodeId);\n            }\n            \n            // Reset all visual elements\n            function resetVisualization() {\n                visitedNodes = [];\n                shortestPath = [];\n                \n                document.querySelectorAll('.node').forEach(node => {\n                    node.classList.remove('visited', 'path');\n                    if (node.id === `node-${startNode}`) {\n                        node.classList.add('start');\n                    } else if (node.id === `node-${endNode}`) {\n                        node.classList.add('end');\n                    }\n                });\n                \n                document.querySelectorAll('.edge').forEach(edge => {\n                    edge.classList.remove('highlight', 'path');\n                });\n                \n                document.querySelectorAll('.step').forEach(step => {\n                    step.classList.remove('active');\n                });\n            }\n            \n            // Animate algorithm steps\n            function animateAlgorithmStep(stepNumber) {\n                document.querySelectorAll('.step').forEach(step => {\n                    step.classList.remove('active');\n                });\n                \n                document.getElementById(`step${stepNumber}`).classList.add('active');\n            }\n            \n            // Dijkstra's algorithm implementation\n            async function runDijkstra() {\n                resetVisualization();\n                startBtn.disabled = true;\n                \n                // Initialize distances\n                const distances = {};\n                const previous = {};\n                const nodes = new Set(graph.nodes.map(n => n.id));\n                \n                graph.nodes.forEach(node => {\n                    distances[node.id] = node.id === startNode ? 0 : Infinity;\n                    previous[node.id] = null;\n                });\n                \n                animateAlgorithmStep(1);\n                await new Promise(resolve => setTimeout(resolve, animationSpeed));\n                \n                while (nodes.size > 0) {\n                    // Find node with smallest distance\n                    let smallest = null;\n                    for (const node of nodes) {\n                        if (smallest === null || distances[node] < distances[smallest]) {\n                            smallest = node;\n                        }\n                    }\n                    \n                    if (smallest === null || distances[smallest] === Infinity) break;\n                    \n                    // Mark as visited\n                    nodes.delete(smallest);\n                    visitNode(smallest);\n                    \n                    animateAlgorithmStep(2);\n                    await new Promise(resolve => setTimeout(resolve, animationSpeed));\n                    \n                    // Update neighbors\n                    const neighbors = graph.edges.filter(e => e.from === smallest || e.to === smallest);\n                    \n                    for (const edge of neighbors) {\n                        const neighbor = edge.from === smallest ? edge.to : edge.from;\n                        \n                        if (!nodes.has(neighbor)) continue;\n                        \n                        const alt = distances[smallest] + edge.weight;\n                        \n                        animateAlgorithmStep(3);\n                        highlightEdge(smallest, neighbor);\n                        await new Promise(resolve => setTimeout(resolve, animationSpeed));\n                        \n                        if (alt < distances[neighbor]) {\n                            distances[neighbor] = alt;\n                            previous[neighbor] = smallest;\n                        }\n                    }\n                    \n                    animateAlgorithmStep(4);\n                    await new Promise(resolve => setTimeout(resolve, animationSpeed));\n                }\n                \n                animateAlgorithmStep(5);\n                \n                // Reconstruct path\n                let current = endNode;\n                const path = [];\n                \n                while (current !== startNode && previous[current] !== null) {\n                    path.unshift(current);\n                    current = previous[current];\n                }\n                \n                if (current === startNode) {\n                    path.unshift(startNode);\n                    \n                    // Animate path\n                    for (let i = 0; i < path.length - 1; i++) {\n                        markPathEdge(path[i], path[i+1]);\n                        markPathNode(path[i]);\n                        await new Promise(resolve => setTimeout(resolve, animationSpeed * 0.7));\n                    }\n                    \n                    markPathNode(path[path.length - 1]);\n                }\n                \n                animateAlgorithmStep(6);\n                startBtn.disabled = false;\n            }\n            \n            // Event listeners\n            startBtn.addEventListener('click', runDijkstra);\n            resetBtn.addEventListener('click', () => {\n                resetVisualization();\n                document.querySelectorAll('.step').forEach(step => {\n                    step.classList.remove('active');\n                });\n            });\n            \n            // Initialize\n            initGraph();\n        });\n    </script>\n</body>\n</html>"
  },
