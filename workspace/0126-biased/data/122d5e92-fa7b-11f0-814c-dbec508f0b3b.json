    "content": "<html>\n<head>\n    <title>Congestion Control</title>\n    <style>\n        body {\n            background-color: white;\n        }\n        input[type=\"text\"] {\n            width: 50%;\n            padding: 10px;\n            margin: 20px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        button {\n            width: 30%;\n            padding: 10px;\n            margin: 20px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n            cursor: pointer;\n        }\n        select {\n            width: 50%;\n            padding: 10px;\n            margin: 20px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .button-container {\n            display: flex;\n            justify-content: space-between;\n            margin: 20px auto;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"button-container\">\n        <button id=\"max-traffic\">Max Traffic</button>\n        <button id=\"low-traffic\">Low Traffic</button>\n        <button id=\"medium-traffic\">Medium Traffic</button>\n        <button id=\"high-traffic\">High Traffic</button>\n    </div>\n    <div class=\"form-container\">\n        <input type=\"text\" id=\"traffic-volume\" placeholder=\"Enter traffic volume\">\n        <button id=\"submit-traffic\">Submit</button>\n    </div>\n    <div class=\"result-container\">\n        <p id=\"traffic-status\"></p>\n    </div>\n\n    <script>\n        let trafficVolume = 0;\n        let trafficStatus = \"Low Traffic\";\n\n        const maxTrafficButton = document.getElementById(\"max-traffic\");\n        const lowTrafficButton = document.getElementById(\"low-traffic\");\n        const mediumTrafficButton = document.getElementById(\"medium-traffic\");\n        const highTrafficButton = document.getElementById(\"high-traffic\");\n\n        const trafficVolumeInput = document.getElementById(\"traffic-volume\");\n        const submitTrafficButton = document.getElementById(\"submit-traffic\");\n\n        const trafficStatusElement = document.getElementById(\"traffic-status\");\n\n        maxTrafficButton.addEventListener(\"click\", () => {\n            trafficStatus = \"Max Traffic\";\n            trafficVolume = 100;\n            trafficStatusElement.textContent = \"Max Traffic\";\n        });\n\n        lowTrafficButton.addEventListener(\"click\", () => {\n            trafficStatus = \"Low Traffic\";\n            trafficVolume = 50;\n            trafficStatusElement.textContent = \"Low Traffic\";\n        });\n\n        mediumTrafficButton.addEventListener(\"click\", () => {\n            trafficStatus = \"Medium Traffic\";\n            trafficVolume = 75;\n            trafficStatusElement.textContent = \"Medium Traffic\";\n        });\n\n        highTrafficButton.addEventListener(\"click\", () => {\n            trafficStatus = \"High Traffic\";\n            trafficVolume = 100;\n            trafficStatusElement.textContent = \"High Traffic\";\n        });\n\n        trafficVolumeInput.addEventListener(\"input\", () => {\n            trafficVolume = parseInt(trafficVolumeInput.value);\n            trafficStatusElement.textContent = `Traffic Volume: ${trafficVolume} units`;\n        });\n\n        submitTrafficButton.addEventListener(\"click\", () => {\n            if (trafficVolume <= 100) {\n                trafficStatus = \"Traffic is under control\";\n            } else {\n                trafficStatus = \"Traffic is congested\";\n            }\n            trafficStatusElement.textContent = `Traffic Status: ${trafficStatus}`;\n        });\n    </script>\n</body>\n</html>"
