  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Prim's Algorithm Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 8px;\n    line-height: 1.4em;\n  }\n  input, button, select, textarea {\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  .section {\n    margin-bottom: 1em;\n    border-top: 1px solid #000;\n    padding-top: 0.5em;\n  }\n  label {\n    display: inline-block;\n    margin-right: 1em;\n  }\n  #graphText {\n    width: 100%;\n    height: 150px;\n  }\n  #status {\n    white-space: pre-wrap;\n    margin-top: 0.5em;\n    border: 1px solid #000;\n    padding: 4px;\n    height: 130px;\n    overflow-y: auto;\n  }\n  #adjMatrix {\n    font-family: monospace, monospace;\n    font-size: 10pt;\n    white-space: pre;\n    overflow-x: auto;\n    max-width: 100%;\n    border: 1px solid #000;\n    padding: 4px;\n    margin-top: 0.3em;\n    height: 130px;\n  }\n  #edgeList {\n    font-family: monospace, monospace;\n    font-size: 10pt;\n    white-space: pre;\n    overflow-y: auto;\n    max-height: 130px;\n    border: 1px solid #000;\n    padding: 4px;\n    margin-top: 0.3em;\n  }\n</style>\n</head>\n<body>\n<h1>Prim's Algorithm Interactive Demo</h1>\n\n<div class=\"section\" id=\"graphInputSection\">\n  <h2>1. Define Graph</h2>\n  <p>\n    You can define an undirected weighted graph in one of two ways:\n  </p>\n  <ul>\n    <li>By adjacency matrix (enter weights separated by spaces; 0 or empty means no edge)</li>\n    <li>By edge list (one edge per line: node1 node2 weight)</li>\n  </ul>\n  <label for=\"nodeCount\">Number of Nodes (1-26): </label>\n  <input type=\"number\" id=\"nodeCount\" min=\"1\" max=\"26\" value=\"5\" />\n  <button id=\"generateEmptyMatrix\">Generate Empty Matrix</button>\n  <button id=\"autoGenerateGraph\">Auto-generate Random Graph</button>\n  <br /><br />\n  <label><input type=\"radio\" name=\"inputMode\" value=\"matrix\" checked /> Adjacency Matrix Input</label>\n  <label><input type=\"radio\" name=\"inputMode\" value=\"edgelist\" /> Edge List Input</label>\n  <br/><br/>\n  <textarea id=\"graphText\" placeholder=\"Enter graph data here...\"></textarea>\n  <br/>\n  <button id=\"loadGraph\">Load Graph</button>\n  <button id=\"clearGraphInput\">Clear Input</button>\n  <div id=\"inputFeedback\" style=\"white-space:pre-wrap; margin-top:4px; max-height:100px; overflow-y:auto;\"></div>\n</div>\n\n<div class=\"section\" id=\"graphDisplaySection\" style=\"display:none;\">\n  <h2>2. Current Graph</h2>\n  <div>\n    <b>Adjacency Matrix:</b>\n    <pre id=\"adjMatrix\"></pre>\n  </div>\n  <div>\n    <b>Edge List:</b>\n    <pre id=\"edgeList\"></pre>\n  </div>\n</div>\n\n<div class=\"section\" id=\"primControlSection\" style=\"display:none;\">\n  <h2>3. Prim's Algorithm Execution</h2>\n  <label for=\"startNode\">Start Node: </label>\n  <select id=\"startNode\"></select>\n  <br/><br/>\n  <button id=\"primInit\">Initialize Prim's Algorithm</button>\n  <button id=\"primStep\" disabled>Step</button>\n  <button id=\"primRun\" disabled>Run to Completion</button>\n  <button id=\"primReset\" disabled>Reset</button>\n  <button id=\"primClearAll\">Clear Everything</button>\n  <br /><br />\n  <label><input type=\"checkbox\" id=\"showDetails\" checked /> Show Algorithm Details</label>\n  <div id=\"status\"></div>\n</div>\n\n<div class=\"section\" id=\"explorationSection\" style=\"display:none;\">\n  <h2>4. Explore MST and Graph</h2>\n  <p>\n    Manipulate the graph or MST state directly:\n  </p>\n  <div>\n    <button id=\"addEdgeButton\">Add Edge</button>\n    <button id=\"removeEdgeButton\">Remove Edge</button>\n  </div>\n  <div id=\"edgeModifyControls\" style=\"margin-top:10px; display:none;\">\n    <label for=\"edgeNodeA\">Node A: </label>\n    <select id=\"edgeNodeA\"></select>\n    <label for=\"edgeNodeB\">Node B: </label>\n    <select id=\"edgeNodeB\"></select>\n    <label for=\"edgeWeight\">Weight: </label>\n    <input type=\"number\" id=\"edgeWeight\" min=\"0\" value=\"1\" />\n    <button id=\"applyEdgeChange\">Apply</button>\n    <button id=\"cancelEdgeChange\">Cancel</button>\n    <div id=\"edgeModifyFeedback\" style=\"margin-top:4px; white-space:pre-wrap;\"></div>\n  </div>\n  <br/>\n\n  <p>\n    MST Edges:\n  </p>\n  <pre id=\"mstEdges\" style=\"border:1px solid #000; padding:4px; height:150px; overflow-y:auto;\"></pre>\n\n  <p>\n    MST Total Weight: <span id=\"mstWeight\">0</span>\n  </p>\n</div>\n\n<script>\n(function() {\n  // Basic graph data structures and utility functions\n\n  // Graph represented as adjacency matrix: graph[nodeA][nodeB] = weight (0 or null means no edge)\n  let graph = [];\n  let nodeCount = 0;\n  // MST representation is edge list: [{u,v,weight}]\n  let mstEdges = [];\n  // Prim's internal state\n  let primState = null;\n  // Set of node IDs - strings of single uppercase letters\n  let nodes = [];\n\n  // Generate node labels ['A', 'B', ... up to 'Z'], max 26\n  function generateNodeLabels(n) {\n    const arr = [];\n    for(let i=0; i<n; i++) {\n      arr.push(String.fromCharCode(65 + i));\n    }\n    return arr;\n  }\n\n  // Parse graph from adjacency matrix input string\n  // Input: multi-line string with space-separated numbers or empty (for zero edges)\n  // Returns adjacency matrix or null if errors\n  function parseAdjacencyMatrix(text, n) {\n    const lines = text.trim().split('\\n');\n    if(lines.length !== n) return null;\n    const matrix = [];\n    for(let i=0; i<n; i++) {\n      const parts = lines[i].trim().split(/\\s+/);\n      if(parts.length !== n) return null;\n      const row = [];\n      for(let j=0; j<n; j++) {\n        let w = parts[j];\n        if(w === '' || w === '0') w = 0;\n        else {\n          w = Number(w);\n          if(Number.isNaN(w) || w < 0) return null;\n        }\n        row.push(w);\n      }\n      matrix.push(row);\n    }\n    // Enforce symmetry for undirected, allow zeros on diagonal\n    for(let i=0; i<n; i++) {\n      for(let j=i+1; j<n; j++) {\n        if(matrix[i][j] !== matrix[j][i]) return null;\n      }\n      if(matrix[i][i] !== 0) return null; // no self loops\n    }\n    return matrix;\n  }\n\n  // Parse graph from edge list input string\n  // Edge list format: nodeA nodeB weight per line\n  // Nodes must be within nodeCount labels\n  // Returns adjacency matrix or null if errors\n  function parseEdgeList(text, n) {\n    const localGraph = Array.from({length:n}, () => Array(n).fill(0));\n    const lines = text.trim().split('\\n').filter(l=>l.trim().length>0);\n    for(let line of lines) {\n      const parts = line.trim().split(/\\s+/);\n      if(parts.length !== 3) return null;\n      const [a,b,w] = parts;\n      const u = nodes.indexOf(a.toUpperCase());\n      const v = nodes.indexOf(b.toUpperCase());\n      const weight = Number(w);\n      if(u === -1 || v === -1) return null;\n      if(u === v) return null;\n      if(Number.isNaN(weight) || weight <= 0) return null;\n      localGraph[u][v] = weight;\n      localGraph[v][u] = weight;\n    }\n    return localGraph;\n  }\n\n  // Validate graph: adjacency matrix must be symmetric, no negatives\n  function validateGraph(g) {\n    const n = g.length;\n    for(let i=0; i<n; i++) {\n      if(g[i][i] !== 0) return false;\n      for(let j=0; j<n; j++) {\n        if(g[i][j] < 0) return false;\n        if(g[i][j] !== g[j][i]) return false;\n      }\n    }\n    return true;\n  }\n\n  // Convert adjacency matrix to edge list for all edges with weight > 0\n  function graphToEdgeList(g) {\n    const edges = [];\n    const n = g.length;\n    for(let i=0; i<n; i++) {\n      for(let j=i+1; j<n; j++) {\n        if(g[i][j] > 0) {\n          edges.push({u:i,v:j,weight:g[i][j]});\n        }\n      }\n    }\n    return edges;\n  }\n\n  // Print adjacency matrix as string aligned, row and col labels\n  function adjacencyMatrixString(g) {\n    const n = g.length;\n    let res = '    ';\n    for(let c=0; c<n; c++) {\n      res += nodes[c] + ' ';\n    }\n    res += '\\n';\n    for(let r=0; r<n; r++) {\n      res += nodes[r] + ' | ';\n      for(let c=0; c<n; c++) {\n        res += (g[r][c] === 0 ? '.' : g[r][c]) + ' ';\n      }\n      res += '\\n';\n    }\n    return res;\n  }\n\n  // Print edge list nicely\n  function edgeListString(el) {\n    if(el.length === 0) return '(none)';\n    let res = '';\n    for(let e of el) {\n      res += nodes[e.u] + '-' + nodes[e.v] + ' : ' + e.weight + '\\n';\n    }\n    return res.trim();\n  }\n\n  // Generate random connected undirected graph with n nodes and ~e edges\n  // Edge weights in [1..20]\n  function generateRandomGraph(n) {\n    // Start with tree to ensure connectivity\n    const g = Array.from({length:n}, ()=>Array(n).fill(0));\n    const connected = new Set([0]);\n    const remaining = new Set();\n    for(let i=1; i<n; i++) remaining.add(i);\n\n    // Connect remaining to connected forming a random spanning tree\n    while(remaining.size>0) {\n      const cArr = Array.from(connected);\n      const rArr = Array.from(remaining);\n      const u = cArr[Math.floor(Math.random()*cArr.length)];\n      const v = rArr[Math.floor(Math.random()*rArr.length)];\n      const w = Math.floor(Math.random()*20)+1;\n      g[u][v] = w;\n      g[v][u] = w;\n      connected.add(v);\n      remaining.delete(v);\n    }\n\n    // Now add extra random edges with probability to increase density\n    const edgeProb = 0.25; // 25% chance per non-edge\n    for(let i=0; i<n; i++) {\n      for(let j=i+1; j<n; j++) {\n        if(g[i][j] === 0) {\n          if(Math.random() < edgeProb) {\n            const w = Math.floor(Math.random()*20)+1;\n            g[i][j] = w;\n            g[j][i] = w;\n          }\n        }\n      }\n    }\n    return g;\n  }\n\n  // === PRIM'S ALGORITHM IMPLEMENTATION ===\n\n  // Prim's algorithm state:\n  //  - graph adjacency matrix\n  //  - set MST edges\n  //  - arrays: key[], parent[], inMST[]\n  //  - next step index or process\n  // We'll implement step-by-step interface\n\n  function primInit(graph, startNodeIndex) {\n    const n = graph.length;\n    const key = Array(n).fill(Infinity);\n    const parent = Array(n).fill(null);\n    const inMST = Array(n).fill(false);\n    key[startNodeIndex] = 0;\n    return {\n      graph,\n      n,\n      key,\n      parent,\n      inMST,\n      count: 0,\n      startNodeIndex\n    };\n  }\n\n  // In each step:\n  //  - Pick minimum key[] vertex not yet in MST\n  //  - Add it to MST\n  //  - Update keys of neighbors\n  // Return object describing this step detail for UI\n  // Return null if MST complete\n\n  function primStep(state) {\n    if(state.count >= state.n) return null; // done\n\n    // Pick min key vertex not yet in MST\n    let minKey = Infinity;\n    let u = -1;\n    for(let v=0; v<state.n; v++) {\n      if(!state.inMST[v] && state.key[v]<minKey) {\n        minKey = state.key[v];\n        u = v;\n      }\n    }\n    if(u === -1) {\n      // Should not happen if graph connected but possible in disconnected\n      return null;\n    }\n    // Add u to MST\n    state.inMST[u] = true;\n    state.count++;\n\n    // Update neighbors keys and parents\n    const oldKey = state.key.slice();\n    const oldParent = state.parent.slice();\n    const updatedNodes = [];\n    for(let v=0; v<state.n; v++) {\n      const w = state.graph[u][v];\n      if(w > 0 && !state.inMST[v] && w < state.key[v]) {\n        state.key[v] = w;\n        state.parent[v] = u;\n        updatedNodes.push(v);\n      }\n    }\n\n    return {\n      chosenNode: u,\n      updatedNodes,\n      keyBefore: oldKey,\n      parentBefore: oldParent\n    };\n  }\n\n  // After prim completes, MST edges = edges (v, parent[v]) for v ≠ startNode with parent != null\n\n  function extractMSTEdges(state) {\n    const edges = [];\n    for(let v=0; v<state.n; v++) {\n      if(state.parent[v] !== null) {\n        edges.push({\n          u: state.parent[v],\n          v: v,\n          weight: state.graph[state.parent[v]][v]\n        });\n      }\n    }\n    return edges;\n  }\n\n  // === UI MANAGEMENT ===\n\n  // Elements\n  const nodeCountInput = document.getElementById('nodeCount');\n  const generateEmptyMatrixBtn = document.getElementById('generateEmptyMatrix');\n  const autoGenerateGraphBtn = document.getElementById('autoGenerateGraph');\n  const graphTextArea = document.getElementById('graphText');\n  const loadGraphBtn = document.getElementById('loadGraph');\n  const clearGraphInputBtn = document.getElementById('clearGraphInput');\n  const inputFeedback = document.getElementById('inputFeedback');\n  const adjacencyMatrixPre = document.getElementById('adjMatrix');\n  const edgeListPre = document.getElementById('edgeList');\n  const graphDisplaySection = document.getElementById('graphDisplaySection');\n  const primControlSection = document.getElementById('primControlSection');\n  const explorationSection = document.getElementById('explorationSection');\n  const startNodeSelect = document.getElementById('startNode');\n  const primInitBtn = document.getElementById('primInit');\n  const primStepBtn = document.getElementById('primStep');\n  const primRunBtn = document.getElementById('primRun');\n  const primResetBtn = document.getElementById('primReset');\n  const primClearAllBtn = document.getElementById('primClearAll');\n  const statusDiv = document.getElementById('status');\n  const showDetailsCheckbox = document.getElementById('showDetails');\n  const mstEdgesPre = document.getElementById('mstEdges');\n  const mstWeightSpan = document.getElementById('mstWeight');\n\n  // Edge manipulation controls\n  const addEdgeButton = document.getElementById('addEdgeButton');\n  const removeEdgeButton = document.getElementById('removeEdgeButton');\n  const edgeModifyControls = document.getElementById('edgeModifyControls');\n  const edgeNodeASelect = document.getElementById('edgeNodeA');\n  const edgeNodeBSelect = document.getElementById('edgeNodeB');\n  const edgeWeightInput = document.getElementById('edgeWeight');\n  const applyEdgeChangeBtn = document.getElementById('applyEdgeChange');\n  const cancelEdgeChangeBtn = document.getElementById('cancelEdgeChange');\n  const edgeModifyFeedback = document.getElementById('edgeModifyFeedback');\n\n  // Input mode radio buttons\n  const inputModeRadios = document.querySelectorAll('input[name=\"inputMode\"]');\n\n  // State variables for edge modification UI\n  let edgeModifyMode = null; // \"add\" or \"remove\" or null\n\n  // Utility funcs for UI\n\n  // Sync startNodeSelect options with nodes array\n  function populateStartNodeSelect() {\n    startNodeSelect.innerHTML = '';\n    for(let n of nodes) {\n      const opt = document.createElement('option');\n      opt.value = n;\n      opt.textContent = n;\n      startNodeSelect.appendChild(opt);\n    }\n  }\n\n  // Populate selects for edge modification controls\n  function populateEdgeNodeSelects() {\n    edgeNodeASelect.innerHTML = '';\n    edgeNodeBSelect.innerHTML = '';\n    for(let n of nodes) {\n      let optA = document.createElement('option');\n      optA.value = n;\n      optA.textContent = n;\n      edgeNodeASelect.appendChild(optA);\n      let optB = document.createElement('option');\n      optB.value = n;\n      optB.textContent = n;\n      edgeNodeBSelect.appendChild(optB);\n    }\n  }\n\n  // Clear all sections & reset state\n  function clearAll() {\n    graph = [];\n    nodes = [];\n    nodeCount = 0;\n    mstEdges = [];\n    primState = null;\n    graphTextArea.value = '';\n    inputFeedback.textContent = '';\n    adjacencyMatrixPre.textContent = '';\n    edgeListPre.textContent = '';\n    statusDiv.textContent = '';\n    mstEdgesPre.textContent = '';\n    mstWeightSpan.textContent = '0';\n    primControlSection.style.display = 'none';\n    graphDisplaySection.style.display = 'none';\n    explorationSection.style.display = 'none';\n    edgeModifyControls.style.display = 'none';\n    edgeModifyFeedback.textContent = '';\n    primStepBtn.disabled = true;\n    primRunBtn.disabled = true;\n    primResetBtn.disabled = true;\n    populateStartNodeSelect();\n    populateEdgeNodeSelects();\n  }\n\n  // Display current graph adjacency matrix and edge list\n  function displayGraph() {\n    adjacencyMatrixPre.textContent = adjacencyMatrixString(graph);\n    edgeListPre.textContent = edgeListString(graphToEdgeList(graph));\n  }\n\n  // Load graph from UI input\n  function loadGraph() {\n    inputFeedback.textContent = '';\n    mstEdges = [];\n    primState = null;\n    primStepBtn.disabled = true;\n    primRunBtn.disabled = true;\n    primResetBtn.disabled = true;\n    mstEdgesPre.textContent = '';\n    mstWeightSpan.textContent = '0';\n    statusDiv.textContent = '';\n\n    const n = nodeCountInput.valueAsNumber;\n    if(!Number.isInteger(n) || n<1 || n>26) {\n      inputFeedback.textContent = 'Number of nodes must be an integer between 1 and 26.';\n      return false;\n    }\n    nodeCount = n;\n    nodes = generateNodeLabels(nodeCount);\n    let mode = 'matrix';\n    for(let r of inputModeRadios) {\n      if(r.checked) {\n        mode = r.value;\n        break;\n      }\n    }\n    const txt = graphTextArea.value.trim();\n    if(txt.length === 0) {\n      inputFeedback.textContent = 'Input is empty.';\n      return false;\n    }\n    let g = null;\n    if(mode === 'matrix') {\n      g = parseAdjacencyMatrix(txt, nodeCount);\n      if(g === null) {\n        inputFeedback.textContent = 'Error parsing adjacency matrix. Ensure it is ' + nodeCount + ' lines of ' + nodeCount + ' numbers, symmetric, no self-loops.';\n        return false;\n      }\n    } else if(mode === 'edgelist') {\n      g = parseEdgeList(txt, nodeCount);\n      if(g === null) {\n        inputFeedback.textContent = 'Error parsing edge list. Ensure each line is: NodeA NodeB Weight (positive integer), nodes A-' + nodes[nodeCount-1] + '.';\n        return false;\n      }\n    }\n    if(!validateGraph(g)) {\n      inputFeedback.textContent = 'Graph validation failed. Ensure correct undirected graph with non-negative weights, no loops, symmetric.';\n      return false;\n    }\n    graph = g;\n    populateStartNodeSelect();\n    populateEdgeNodeSelects();\n    displayGraph();\n    graphDisplaySection.style.display = 'block';\n    primControlSection.style.display = 'block';\n    explorationSection.style.display = 'block';\n    edgeModifyControls.style.display = 'none';\n    edgeModifyFeedback.textContent = '';\n    inputFeedback.textContent = 'Graph loaded successfully.';\n    mstEdgesPre.textContent = '';\n    mstWeightSpan.textContent = '0';\n    statusDiv.textContent = '';\n    primStepBtn.disabled = true;\n    primRunBtn.disabled = true;\n    primResetBtn.disabled = true;\n    primState = null;\n    mstEdges = [];\n    return true;\n  }\n\n  // Update MST edge display and weight\n  function updateMSTDisplay() {\n    mstEdgesPre.textContent = edgeListString(mstEdges);\n    let totalWeight = 0;\n    for(let e of mstEdges) {\n      totalWeight += e.weight;\n    }\n    mstWeightSpan.textContent = totalWeight.toString();\n  }\n\n  // Display prim algorithm details for a step\n  function displayPrimStepDetails(stepInfo) {\n    if(!showDetailsCheckbox.checked || !stepInfo) {\n      return;\n    }\n    let s = '';\n    s += 'Selected node for MST: ' + nodes[stepInfo.chosenNode] + '\\n';\n    if(stepInfo.updatedNodes.length > 0) {\n      s += 'Updated key[] and parent[] for nodes: ' + stepInfo.updatedNodes.map(i=>nodes[i]).join(', ') + '\\n';\n      s += 'Key Before: ' + stepInfo.keyBefore.map(x => x === Infinity ? '∞' : x).join(', ') + '\\n';\n      s += 'Parent Before: ' + stepInfo.parentBefore.map(p => p === null ? '-' : nodes[p]).join(', ') + '\\n';\n      s += '\\n';\n      s += 'Key After: ' + primState.key.map(x => x === Infinity ? '∞' : x).join(', ') + '\\n';\n      s += 'Parent After: ' + primState.parent.map(p => p === null ? '-' : nodes[p]).join(', ') + '\\n';\n    } else {\n      s += 'No key or parent updates in this step.\\n';\n    }\n    statusDiv.textContent = s;\n  }\n\n  // Run single prim step\n  function runPrimStep() {\n    if(!primState) {\n      statusDiv.textContent = 'Prim algorithm not initialized.';\n      return;\n    }\n    const stepRes = primStep(primState);\n    if(stepRes === null) {\n      primStepBtn.disabled = true;\n      primRunBtn.disabled = true;\n      primResetBtn.disabled = false;\n      mstEdges = extractMSTEdges(primState);\n      updateMSTDisplay();\n      statusDiv.textContent = 'Prim\\'s algorithm completed. MST constructed.';\n      return;\n    }\n    displayPrimStepDetails(stepRes);\n  }\n\n  // Run prim to completion\n  function runPrimToCompletion() {\n    if(!primState) return;\n    while(true) {\n      const stepRes = primStep(primState);\n      if(stepRes === null) break;\n    }\n    primStepBtn.disabled = true;\n    primRunBtn.disabled = true;\n    primResetBtn.disabled = false;\n    mstEdges = extractMSTEdges(primState);\n    updateMSTDisplay();\n    statusDiv.textContent = 'Prim\\'s algorithm completed. MST constructed.';\n  }\n\n  // Handle prim initialization\n  function onPrimInit() {\n    if(graph.length === 0) return;\n    const startNode = startNodeSelect.value;\n    const idx = nodes.indexOf(startNode);\n    if(idx === -1) {\n      statusDiv.textContent = 'Invalid start node selected.';\n      return;\n    }\n    primState = primInit(graph, idx);\n    statusDiv.textContent = 'Prim\\'s algorithm initialized with start node ' + startNode + '.\\nClick Step to proceed.';\n    primStepBtn.disabled = false;\n    primRunBtn.disabled = false;\n    primResetBtn.disabled = false;\n    mstEdges = [];\n    updateMSTDisplay();\n  }\n\n  // Reset prim algorithm but keep graph loaded\n  function resetPrim() {\n    primState = null;\n    mstEdges = [];\n    updateMSTDisplay();\n    statusDiv.textContent = 'Prim\\'s algorithm reset. Please initialize again.';\n    primStepBtn.disabled = true;\n    primRunBtn.disabled = true;\n    primResetBtn.disabled = true;\n  }\n\n  // Add edge to graph adjacency matrix\n  // returns true if added, false if error\n  function addEdge(u, v, w) {\n    if(u === v) return false;\n    if(w <= 0) return false;\n    if(graph[u][v] > 0) {\n      return false; // edge already exists\n    }\n    graph[u][v] = w;\n    graph[v][u] = w;\n    return true;\n  }\n\n  // Remove edge if exists\n  function removeEdge(u, v) {\n    if(u === v) return false;\n    if(graph[u][v] === 0) return false; // no edge to remove\n    graph[u][v] = 0;\n    graph[v][u] = 0;\n    return true;\n  }\n\n  // Handle add edge button click\n  function onClickAddEdge() {\n    edgeModifyMode = 'add';\n    edgeModifyControls.style.display = 'block';\n    edgeModifyFeedback.textContent = '';\n    edgeWeightInput.disabled = false;\n    edgeWeightInput.value = '1';\n  }\n\n  // Handle remove edge button click\n  function onClickRemoveEdge() {\n    edgeModifyMode = 'remove';\n    edgeModifyControls.style.display = 'block';\n    edgeModifyFeedback.textContent = '';\n    edgeWeightInput.disabled = true;\n    edgeWeightInput.value = '';\n  }\n\n  // Handle apply edge change button click\n  function onApplyEdgeChange() {\n    if(edgeModifyMode === null) return;\n    const a = edgeNodeASelect.value;\n    const b = edgeNodeBSelect.value;\n    if(a === b) {\n      edgeModifyFeedback.textContent = 'Node A and Node B cannot be the same.';\n      return;\n    }\n    const u = nodes.indexOf(a);\n    const v = nodes.indexOf(b);\n    if(edgeModifyMode === 'add') {\n      let w = edgeWeightInput.valueAsNumber;\n      if(!Number.isInteger(w) || w <= 0) {\n        edgeModifyFeedback.textContent = 'Weight must be a positive integer.';\n        return;\n      }\n      if(graph[u][v] > 0) {\n        edgeModifyFeedback.textContent = 'Edge already exists between '+a+' and '+b+'.';\n        return;\n      }\n      addEdge(u,v,w);\n      edgeModifyFeedback.textContent = 'Edge added between '+a+' and '+b+' with weight '+w+'.';\n    } else if(edgeModifyMode === 'remove') {\n      if(graph[u][v] === 0) {\n        edgeModifyFeedback.textContent = 'Edge does not exist between '+a+' and '+b+'.';\n        return;\n      }\n      removeEdge(u,v);\n      edgeModifyFeedback.textContent = 'Edge removed between '+a+' and '+b+'.';\n    }\n    displayGraph();\n    // Changing graph resets prim state and MST\n    primState = null;\n    mstEdges = [];\n    updateMSTDisplay();\n    primStepBtn.disabled = true;\n    primRunBtn.disabled = true;\n    primResetBtn.disabled = true;\n    statusDiv.textContent = 'Graph modified. Prim\\'s algorithm reset.';\n  }\n\n  // Handle cancel edge modification\n  function onCancelEdgeChange() {\n    edgeModifyMode = null;\n    edgeModifyControls.style.display = 'none';\n    edgeModifyFeedback.textContent = '';\n  }\n\n  // Generate empty adjacency matrix for current nodeCount\n  function generateEmptyMatrix() {\n    const n = nodeCountInput.valueAsNumber;\n    if(!Number.isInteger(n) || n < 1 || n > 26) {\n      inputFeedback.textContent = 'Invalid number of nodes for empty matrix generation.';\n      return;\n    }\n    let lines = [];\n    for(let i=0; i<n; i++) {\n      lines.push((Array(n).fill('0')).join(' '));\n    }\n    graphTextArea.value = lines.join('\\n');\n    inputFeedback.textContent = 'Empty adjacency matrix generated.';\n  }\n\n  // Auto generate random graph with current nodeCount\n  function autoGenerateGraph() {\n    const n = nodeCountInput.valueAsNumber;\n    if(!Number.isInteger(n) || n < 1 || n > 26) {\n      inputFeedback.textContent = 'Invalid number of nodes for graph generation.';\n      return;\n    }\n    const g = generateRandomGraph(n);\n    let lines = [];\n    for(let i=0; i<n; i++) {\n      lines.push(g[i].map(w=>w>0?w:0).join(' '));\n    }\n    graphTextArea.value = lines.join('\\n');\n    inputFeedback.textContent = 'Random connected graph generated.';\n  }\n\n  // Clear input text area and feedback\n  function clearInput() {\n    graphTextArea.value = '';\n    inputFeedback.textContent = '';\n  }\n\n  // Event handlers\n  loadGraphBtn.addEventListener('click', loadGraph);\n  clearGraphInputBtn.addEventListener('click', clearInput);\n  generateEmptyMatrixBtn.addEventListener('click', generateEmptyMatrix);\n  autoGenerateGraphBtn.addEventListener('click', autoGenerateGraph);\n  primInitBtn.addEventListener('click', onPrimInit);\n  primStepBtn.addEventListener('click', runPrimStep);\n  primRunBtn.addEventListener('click', runPrimToCompletion);\n  primResetBtn.addEventListener('click', resetPrim);\n  primClearAllBtn.addEventListener('click', clearAll);\n  addEdgeButton.addEventListener('click', onClickAddEdge);\n  removeEdgeButton.addEventListener('click', onClickRemoveEdge);\n  applyEdgeChangeBtn.addEventListener('click', onApplyEdgeChange);\n  cancelEdgeChangeBtn.addEventListener('click', onCancelEdgeChange);\n\n  // Update text area placeholder and label depending on mode\n  function updateInputPlaceholder() {\n    let mode = 'matrix';\n    for(let r of inputModeRadios) {\n      if(r.checked) mode = r.value;\n    }\n    if(mode === 'matrix') {\n      graphTextArea.placeholder = \n        'Enter adjacency matrix:\\n' +\n        'Example for 3 nodes:\\n' +\n        '0 2 0\\n' +\n        '2 0 3\\n' +\n        '0 3 0\\n' +\n        '(0 = no edge)';\n    } else {\n      graphTextArea.placeholder =\n        'Enter edge list:\\n' +\n        'One edge per line:\\n' +\n        'NodeA NodeB Weight\\n' +\n        'Example:\\n' +\n        'A B 2\\n' +\n        'B C 3';\n    }\n    clearInput();\n  }\n  for(let r of inputModeRadios) {\n    r.addEventListener('change', updateInputPlaceholder);\n  }\n  updateInputPlaceholder();\n\n  // Initialize empty state at startup\n  clearAll();\n\n  // Expose some methods for easier testing or extension if needed\n  window._primDemo = {\n    parseAdjacencyMatrix,\n    parseEdgeList,\n    generateRandomGraph,\n    primInit,\n    primStep,\n    extractMSTEdges\n  };\n})();\n</script>\n