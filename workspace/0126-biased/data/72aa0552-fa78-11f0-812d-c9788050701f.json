    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Visualizer</title>\n    <style>\n        :root {\n            --primary: #6366f1;\n            --primary-dark: #4f46e5;\n            --secondary: #f43f5e;\n            --background: #1e293b;\n            --card-bg: #334155;\n            --text: #f8fafc;\n            --text-secondary: #94a3b8;\n            --highlight: #fbbf24;\n            --found: #10b981;\n        }\n\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: var(--background);\n            color: var(--text);\n            margin: 0;\n            padding: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            min-height: 100vh;\n            line-height: 1.6;\n        }\n\n        .container {\n            max-width: 1200px;\n            width: 90%;\n            padding: 2rem;\n            box-sizing: border-box;\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            font-weight: 800;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-align: center;\n        }\n\n        .subtitle {\n            color: var(--text-secondary);\n            text-align: center;\n            margin-bottom: 2rem;\n            font-size: 1.1rem;\n        }\n\n        .visualization-container {\n            background: var(--card-bg);\n            border-radius: 12px;\n            padding: 2rem;\n            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);\n            margin-bottom: 2rem;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            margin: 3rem 0;\n            position: relative;\n            height: 120px;\n        }\n\n        .element {\n            width: 60px;\n            height: 60px;\n            background: linear-gradient(135deg, var(--primary), var(--primary-dark));\n            margin: 0 5px;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            position: relative;\n            cursor: default;\n        }\n\n        .element::after {\n            content: attr(data-index);\n            position: absolute;\n            top: -25px;\n            color: var(--text-secondary);\n            font-size: 0.9rem;\n            font-weight: normal;\n        }\n\n        .element.highlight {\n            transform: translateY(-10px) scale(1.1);\n            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);\n            background: linear-gradient(135deg, var(--secondary), #e11d48);\n        }\n\n        .element.middle {\n            transform: translateY(-20px) scale(1.3);\n            box-shadow: 0 12px 20px rgba(0, 0, 0, 0.3);\n            background: linear-gradient(135deg, var(--highlight), #f59e0b);\n            z-index: 2;\n        }\n\n        .element.found {\n            background: linear-gradient(135deg, var(--found), #059669);\n            animation: pulse 1s ease infinite;\n        }\n\n        .element.examined {\n            opacity: 0.4;\n            transform: translateY(0) scale(0.95);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n\n        .btn {\n            background: linear-gradient(135deg, var(--primary), var(--primary-dark));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 8px;\n            font-weight: 600;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n        }\n\n        .btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 7px 14px rgba(0, 0, 0, 0.2);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        .btn-secondary {\n            background: transparent;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n        }\n\n        .status {\n            text-align: center;\n            font-size: 1.2rem;\n            margin: 1rem 0;\n            min-height: 2rem;\n            color: var(--highlight);\n            font-weight: 600;\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            color: var(--text-secondary);\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .legend-highlight {\n            background: var(--secondary);\n        }\n\n        .legend-middle {\n            background: var(--highlight);\n        }\n\n        .legend-examined {\n            background: var(--primary);\n            opacity: 0.4;\n        }\n\n        .legend-found {\n            background: var(--found);\n        }\n\n        .info-panel {\n            background: var(--card-bg);\n            border-radius: 12px;\n            padding: 1.5rem;\n            margin-top: 2rem;\n            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);\n        }\n\n        .info-title {\n            font-size: 1.3rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            color: var(--text);\n        }\n\n        .info-text {\n            color: var(--text-secondary);\n            margin-bottom: 1rem;\n        }\n\n        .complexity {\n            display: flex;\n            justify-content: space-between;\n            margin-top: 1.5rem;\n        }\n\n        .complexity-item {\n            text-align: center;\n            background: rgba(255, 255, 255, 0.05);\n            padding: 1rem;\n            border-radius: 8px;\n            flex: 1;\n            margin: 0 0.5rem;\n        }\n\n        .complexity-title {\n            font-size: 0.9rem;\n            color: var(--text-secondary);\n            margin-bottom: 0.5rem;\n        }\n\n        .complexity-value {\n            font-size: 1.2rem;\n            font-weight: 700;\n            color: var(--text);\n        }\n\n        @keyframes pulse {\n            0% {\n                transform: scale(1);\n                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);\n            }\n            70% {\n                transform: scale(1.05);\n                box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);\n            }\n            100% {\n                transform: scale(1);\n                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);\n            }\n        }\n\n        .algorithm-steps {\n            margin-top: 2rem;\n            font-family: 'Fira Code', monospace;\n            background: rgba(0, 0, 0, 0.2);\n            padding: 1.5rem;\n            border-radius: 8px;\n            overflow-x: auto;\n        }\n\n        .code-line {\n            margin-bottom: 0.5rem;\n            color: var(--text);\n        }\n\n        .code-line.highlighted {\n            background: rgba(251, 191, 36, 0.2);\n            border-left: 3px solid var(--highlight);\n            padding-left: 10px;\n        }\n\n        @media (max-width: 768px) {\n            .element {\n                width: 40px;\n                height: 40px;\n                font-size: 0.9rem;\n                margin: 0 3px;\n            }\n            \n            .element::after {\n                top: -20px;\n                font-size: 0.7rem;\n            }\n            \n            .legend {\n                flex-wrap: wrap;\n                gap: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Binary Search Algorithm</h1>\n        <p class=\"subtitle\">Efficiently find elements in sorted arrays with O(log n) complexity</p>\n        \n        <div class=\"visualization-container\">\n            <div class=\"array-container\" id=\"arrayContainer\">\n                <!-- Elements will be generated by JavaScript -->\n            </div>\n            \n            <div class=\"status\" id=\"statusText\">Click \"Start Search\" to begin visualization</div>\n            \n            <div class=\"controls\">\n                <button class=\"btn\" id=\"startBtn\">Start Search</button>\n                <button class=\"btn btn-secondary\" id=\"resetBtn\">Reset</button>\n            </div>\n            \n            <div class=\"legend\">\n                <div class=\"legend-item\">\n                    <div class=\"legend-color legend-highlight\"></div>\n                    <span>Current element</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color legend-middle\"></div>\n                    <span>Midpoint</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color legend-examined\"></div>\n                    <span>Examined</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color legend-found\"></div>\n                    <span>Found</span>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"info-panel\">\n            <div class=\"info-title\">About Binary Search</div>\n            <p class=\"info-text\">\n                Binary search is an efficient algorithm for finding an item from a sorted list of items.\n                It works by repeatedly dividing in half the portion of the list that could contain the item,\n                until you've narrowed down the possible locations to just one.\n            </p>\n            \n            <div class=\"complexity\">\n                <div class=\"complexity-item\">\n                    <div class=\"complexity-title\">Best Case</div>\n                    <div class=\"complexity-value\">O(1)</div>\n                </div>\n                <div class=\"complexity-item\">\n                    <div class=\"complexity-title\">Average Case</div>\n                    <div class=\"complexity-value\">O(log n)</div>\n                </div>\n                <div class=\"complexity-item\">\n                    <div class=\"complexity-title\">Worst Case</div>\n                    <div class=\"complexity-value\">O(log n)</div>\n                </div>\n                <div class=\"complexity-item\">\n                    <div class=\"complexity-title\">Space</div>\n                    <div class=\"complexity-value\">O(1)</div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"algorithm-steps\">\n            <div class=\"code-line\">function binarySearch(array, target) {</div>\n            <div class=\"code-line\">  let left = 0;</div>\n            <div class=\"code-line\">  let right = array.length - 1;</div>\n            <div class=\"code-line\" id=\"highlightLine\">&nbsp;</div>\n            <div class=\"code-line\">  while (left <= right) {</div>\n            <div class=\"code-line\">    const mid = Math.floor((left + right) / 2);</div>\n            <div class=\"code-line\">    if (array[mid] === target) return mid;</div>\n            <div class=\"code-line\">    if (array[mid] < target) left = mid + 1;</div>\n            <div class=\"code-line\">    else right = mid - 1;</div>\n            <div class=\"code-line\">  }</div>\n            <div class=\"code-line\">  return -1;</div>\n            <div class=\"code-line\">}</div>\n        </div>\n    </div>\n\n    <script>\n        // Configuration\n        const ARRAY_SIZE = 15;\n        const MIN_VALUE = 10;\n        const MAX_VALUE = 99;\n        const ANIMATION_DELAY = 1000;\n        \n        // State\n        let array = [];\n        let target = 0;\n        let currentStep = 0;\n        let left = 0;\n        let right = 0;\n        let mid = 0;\n        let foundIndex = -1;\n        let isSearching = false;\n        \n        // DOM elements\n        const arrayContainer = document.getElementById('arrayContainer');\n        const startBtn = document.getElementById('startBtn');\n        const resetBtn = document.getElementById('resetBtn');\n        const statusText = document.getElementById('statusText');\n        const highlightLine = document.getElementById('highlightLine');\n        \n        // Initialize the visualization\n        function init() {\n            generateRandomArray();\n            renderArray();\n            resetSearch();\n        }\n        \n        // Generate a random sorted array\n        function generateRandomArray() {\n            array = [];\n            for (let i = 0; i < ARRAY_SIZE; i++) {\n                array.push(Math.floor(Math.random() * (MAX_VALUE - MIN_VALUE + 1)) + MIN_VALUE);\n            }\n            array.sort((a, b) => a - b);\n            target = array[Math.floor(Math.random() * array.length)];\n        }\n        \n        // Render the array with elements\n        function renderArray() {\n            arrayContainer.innerHTML = '';\n            array.forEach((value, index) => {\n                const element = document.createElement('div');\n                element.className = 'element';\n                element.textContent = value;\n                element.setAttribute('data-index', index);\n                element.id = `element-${index}`;\n                arrayContainer.appendChild(element);\n            });\n        }\n        \n        // Reset the visualization\n        function resetSearch() {\n            currentStep = 0;\n            left = 0;\n            right = array.length - 1;\n            mid = 0;\n            foundIndex = -1;\n            isSearching = false;\n            statusText.textContent = `Click \"Start Search\" to begin visualization (Looking for ${target})`;\n            \n            // Reset all elements\n            document.querySelectorAll('.element').forEach(el => {\n                el.className = 'element';\n            });\n            \n            // Reset code highlight\n            highlightLine.textContent = '';\n            highlightLine.className = 'code-line';\n        }\n        \n        // Perform one step of binary search\n        function searchStep() {\n            if (foundIndex !== -1 || left > right) {\n                endSearch();\n                return;\n            }\n            \n            currentStep++;\n            mid = Math.floor((left + right) / 2);\n            \n            // Update status\n            statusText.textContent = `Step ${currentStep}: Checking index ${mid} (value ${array[mid]})`;\n            \n            // Highlight code\n            highlightLine.textContent = '    const mid = Math.floor((left + right) / 2); // Calculate midpoint';\n            highlightLine.className = 'code-line highlighted';\n            \n            // Highlight elements\n            highlightElements(mid);\n            \n            // Check if found\n            if (array[mid] === target) {\n                foundIndex = mid;\n                setTimeout(() => {\n                    document.getElementById(`element-${mid}`).classList.add('found');\n                    statusText.textContent = `Found ${target} at index ${mid}!`;\n                    highlightLine.textContent = '    if (array[mid] === target) return mid; // Target found!';\n                    endSearch();\n                }, ANIMATION_DELAY);\n            } else if (array[mid] < target) {\n                setTimeout(() => {\n                    // Move left pointer\n                    document.getElementById(`element-${mid}`).classList.add('examined');\n                    highlightLine.textContent = '    if (array[mid] < target) left = mid + 1; // Search right half';\n                    \n                    for (let i = left; i <= mid; i++) {\n                        document.getElementById(`element-${i}`).classList.add('examined');\n                    }\n                    \n                    left = mid + 1;\n                    setTimeout(searchStep, ANIMATION_DELAY);\n                }, ANIMATION_DELAY);\n            } else {\n                setTimeout(() => {\n                    // Move right pointer\n                    document.getElementById(`element-${mid}`).classList.add('examined');\n                    highlightLine.textContent = '    else right = mid - 1; // Search left half';\n                    \n                    for (let i = mid; i <= right; i++) {\n                        document.getElementById(`element-${i}`).classList.add('examined');\n                    }\n                    \n                    right = mid - 1;\n                    setTimeout(searchStep, ANIMATION_DELAY);\n                }, ANIMATION_DELAY);\n            }\n        }\n        \n        // Highlight elements during search\n        function highlightElements(midIndex) {\n            document.querySelectorAll('.element').forEach(el => {\n                el.classList.remove('highlight', 'middle');\n            });\n            \n            if (left !== right) {\n                document.getElementById(`element-${left}`).classList.add('highlight');\n                document.getElementById(`element-${right}`).classList.add('highlight');\n            }\n            \n            document.getElementById(`element-${midIndex}`).classList.add('middle');\n        }\n        \n        // End the search\n        function endSearch() {\n            isSearching = false;\n            if (foundIndex === -1) {\n                statusText.textContent = `${target} not found in the array`;\n            }\n            highlightLine.textContent = '';\n            highlightLine.className = 'code-line';\n        }\n        \n        // Event listeners\n        startBtn.addEventListener('click', () => {\n            if (!isSearching) {\n                isSearching = true;\n                searchStep();\n            }\n        });\n        \n        resetBtn.addEventListener('click', init);\n        \n        // Initialize on load\n        window.addEventListener('load', init);\n    </script>\n</body>\n</html>"
