    "content": "<html>\n<head>\n    <title>Radix Sort</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        input {\n            padding: 10px;\n            margin: 5px;\n            border: 1px solid black;\n        }\n        button {\n            padding: 10px 20px;\n            margin: 5px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: white;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <h1>Radix Sort</h1>\n    <p>Radix Sort is a non-comparative sorting algorithm that works by grouping numbers by their largest digit first and then continuing with the next largest digit, and so on.</p>\n    <button id=\"radix-sort\">Radix Sort</button>\n    <button id=\"bubble-sort\">Bubble Sort</button>\n    <button id=\"merge-sort\">Merge Sort</button>\n    <button id=\"insert-sort\">Insertion Sort</button>\n    <button id=\"quick-sort\">Quick Sort</button>\n    <button id=\"kmp-sort\">KMP Sort</button>\n    <button id=\"radix-sort-example\">Radix Sort Example</button>\n    <button id=\"bubble-sort-example\">Bubble Sort Example</button>\n    <button id=\"merge-sort-example\">Merge Sort Example</button>\n    <button id=\"insert-sort-example\">Insertion Sort Example</button>\n    <button id=\"quick-sort-example\">Quick Sort Example</button>\n    <button id=\"kmp-sort-example\">KMP Sort Example</button>\n    <div id=\"radix-sort-example-container\"></div>\n\n    <script>\n        let radixSortExampleContainer = document.getElementById('radix-sort-example-container');\n        let radixSortExample = document.getElementById('radix-sort-example');\n        let bubbleSortExample = document.getElementById('bubble-sort-example');\n        let mergeSortExample = document.getElementById('merge-sort-example');\n        let insertionSortExample = document.getElementById('insert-sort-example');\n        let quickSortExample = document.getElementById('quick-sort-example');\n        let kmpSortExample = document.getElementById('kmp-sort-example');\n\n        function radixSortExample() {\n            let arr = Array.from({length: 100}, (_, i) => i).map(i => i);\n            radixSort(arr);\n            let sorted = arr.map(i => i.toString()).join('');\n            radixSortExampleContainer.innerHTML = `<p>Sorted array: ${sorted}</p>`;\n        }\n\n        function bubbleSortExample() {\n            let arr = Array.from({length: 100}, (_, i) => i);\n            bubbleSort(arr);\n            let sorted = arr.map(i => i.toString()).join('');\n            radixSortExampleContainer.innerHTML = `<p>Sorted array: ${sorted}</p>`;\n        }\n\n        function mergeSortExample() {\n            let arr = Array.from({length: 100}, (_, i) => i);\n            mergeSort(arr);\n            let sorted = arr.map(i => i.toString()).join('');\n            radixSortExampleContainer.innerHTML = `<p>Sorted array: ${sorted}</p>`;\n        }\n\n        function insertionSortExample() {\n            let arr = Array.from({length: 100}, (_, i) => i);\n            insertionSort(arr);\n            let sorted = arr.map(i => i.toString()).join('');\n            radixSortExampleContainer.innerHTML = `<p>Sorted array: ${sorted}</p>`;\n        }\n\n        function quickSortExample() {\n            let arr = Array.from({length: 100}, (_, i) => i);\n            quickSort(arr);\n            let sorted = arr.map(i => i.toString()).join('');\n            radixSortExampleContainer.innerHTML = `<p>Sorted array: ${sorted}</p>`;\n        }\n\n        function kmpSortExample() {\n            let arr = Array.from({length: 100}, (_, i) => i);\n            kmpSort(arr);\n            let sorted = arr.map(i => i.toString()).join('');\n            radixSortExampleContainer.innerHTML = `<p>Sorted array: ${sorted}</p>`;\n        }\n\n        function radixSort(arr) {\n            let max = Math.max(...arr);\n            let exp = 1;\n            while (exp <= max) {\n                let buckets = Array.from({length: 10}, () => []);\n                for (let num of arr) {\n                    let index = Math.floor(num / exp);\n                    buckets[index].push(num);\n                }\n                let sorted = [];\n                for (let bucket of buckets) {\n                    sorted.push(...bucket);\n                }\n                arr = sorted;\n                exp *= 10;\n            }\n        }\n\n        function display(arr) {\n            let output = '';\n            for (let i = 0; i < arr.length; i++) {\n                output += `${arr[i]} `;\n            }\n            radixSortExampleContainer.innerHTML = output;\n        }\n\n        let radixSortButton = document.getElementById('radix-sort');\n        let bubbleSortButton = document.getElementById('bubble-sort');\n        let mergeSortButton = document.getElementById('merge-sort');\n        let insertionSortButton = document.getElementById('insert-sort');\n        let quickSortButton = document.getElementById('quick-sort');\n        let kmpSortButton = document.getElementById('kmp-sort');\n\n        radixSortButton.addEventListener('click', radixSortExample);\n        bubbleSortButton.addEventListener('click', bubbleSortExample);\n        mergeSortButton.addEventListener('click', mergeSortExample);\n        insertionSortButton.addEventListener('click', insertionSortExample);\n        quickSortButton.addEventListener('click', quickSortExample);\n        kmpSortButton.addEventListener('click', kmpSortExample);\n\n        display('Radix Sort Example');\n    </script>\n</body>\n</html>"
