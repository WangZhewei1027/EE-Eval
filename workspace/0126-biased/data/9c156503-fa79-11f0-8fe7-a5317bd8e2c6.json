  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Paging Explorer - Interactive Demo</title>\n  <style>\n    /* Minimal styling only to keep layout readable - otherwise default browser styles */\n    body { font-family: Arial, sans-serif; margin: 12px; color: #000; background: #fff; }\n    section { margin-bottom: 12px; padding: 8px; border: 1px solid #ccc; }\n    label { margin-right: 6px; }\n    input[type=\"number\"], input[type=\"text\"], select, button { margin-right: 6px; }\n    table { border-collapse: collapse; width: 100%; margin-top: 8px; }\n    th, td { border: 1px solid #ccc; padding: 4px; text-align: left; }\n    .controls-row { margin-bottom: 6px; }\n    .log { white-space: pre-wrap; max-height: 120px; overflow: auto; border: 1px solid #ccc; padding: 6px; background: #fff; }\n    .small { font-size: 12px; color: #333; }\n  </style>\n</head>\n<body>\n  <h1>Paging Explorer (Plain Interface)</h1>\n\n  <section id=\"dataset-controls\">\n    <strong>Dataset & Server Simulation</strong>\n    <div class=\"controls-row\">\n      <label>Size:\n        <input id=\"datasetSize\" type=\"number\" min=\"10\" max=\"10000\" step=\"10\" value=\"200\">\n      </label>\n      <button id=\"regenData\">Regenerate</button>\n      <label>Seed:\n        <input id=\"seed\" type=\"text\" value=\"seed\">\n      </label>\n      <label>Network delay (ms):\n        <input id=\"netDelay\" type=\"range\" min=\"0\" max=\"2000\" step=\"50\" value=\"250\">\n        <span id=\"netDelayVal\">250</span>\n      </label>\n      <label><input id=\"offline\" type=\"checkbox\"> Offline (simulate failures)</label>\n      <label><input id=\"cacheEnabled\" type=\"checkbox\" checked> Cache pages</label>\n      <label><input id=\"prefetchEnabled\" type=\"checkbox\"> Prefetch neighbors</label>\n      <button id=\"clearCache\">Clear Cache</button>\n    </div>\n    <div class=\"controls-row small\">\n      Simulated server returns pages. Use delay/offline to explore error handling, caching & prefetching.\n    </div>\n  </section>\n\n  <section id=\"paging-controls\">\n    <strong>Paging Controls</strong>\n    <div class=\"controls-row\">\n      <label>Page Size:\n        <input id=\"pageSize\" type=\"number\" min=\"1\" max=\"1000\" value=\"20\">\n      </label>\n      <label>Current Page (1-based):\n        <input id=\"currentPage\" type=\"number\" min=\"1\" value=\"1\">\n      </label>\n      <button id=\"firstPage\">First</button>\n      <button id=\"prevPage\">Prev</button>\n      <button id=\"nextPage\">Next</button>\n      <button id=\"lastPage\">Last</button>\n      <label><input id=\"infinite\" type=\"checkbox\"> Infinite scroll mode</label>\n      <button id=\"loadMore\" disabled>Load More (infinite)</button>\n    </div>\n\n    <div class=\"controls-row\">\n      <label>Jump to page:\n        <input id=\"jumpPage\" type=\"number\" min=\"1\" value=\"1\">\n      </label>\n      <button id=\"jumpBtn\">Go</button>\n\n      <label>Go to item id:\n        <input id=\"gotoId\" type=\"number\" min=\"1\">\n      </label>\n      <button id=\"gotoBtn\">Find</button>\n\n      <label>Page Size Slider:\n        <input id=\"pageSizeRange\" type=\"range\" min=\"1\" max=\"200\" value=\"20\">\n      </label>\n    </div>\n\n    <div class=\"controls-row small\">\n      Page size changes affect navigation. Infinite mode appends pages; paging mode replaces view.\n    </div>\n  </section>\n\n  <section id=\"filter-sort-controls\">\n    <strong>Filter & Sort</strong>\n    <div class=\"controls-row\">\n      <label>Search text:\n        <input id=\"q\" type=\"text\" placeholder=\"search title...\">\n      </label>\n      <label>Category:\n        <select id=\"categoryFilter\">\n          <option value=\"\">(any)</option>\n        </select>\n      </label>\n      <label>Min value:\n        <input id=\"minValue\" type=\"number\" min=\"0\">\n      </label>\n      <label>Max value:\n        <input id=\"maxValue\" type=\"number\" min=\"0\">\n      </label>\n      <label>Sort:\n        <select id=\"sortField\">\n          <option value=\"id\">id</option>\n          <option value=\"title\">title</option>\n          <option value=\"value\">value</option>\n          <option value=\"date\">date</option>\n        </select>\n      </label>\n      <label>\n        <select id=\"sortDir\">\n          <option value=\"asc\">asc</option>\n          <option value=\"desc\">desc</option>\n        </select>\n      </label>\n      <button id=\"applyFilter\">Apply</button>\n      <button id=\"resetFilter\">Reset</button>\n    </div>\n    <div class=\"controls-row small\">\n      Use filters and sort to change server query. Filters are combined. Changing filters resets current page to 1.\n    </div>\n  </section>\n\n  <section id=\"page-manipulation\">\n    <strong>Page Operations & State</strong>\n    <div class=\"controls-row\">\n      <button id=\"pinPage\">Pin current page</button>\n      <button id=\"unpinPage\">Unpin current page</button>\n      <button id=\"showPinned\">Show pinned list</button>\n\n      <button id=\"bookmarkPage\">Bookmark page</button>\n      <button id=\"showBookmarks\">Show bookmarks</button>\n\n      <button id=\"snapshotState\">Snapshot state (undo stack)</button>\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n    </div>\n\n    <div class=\"controls-row\">\n      <label>Merge with page:\n        <input id=\"mergePage\" type=\"number\" min=\"1\" value=\"1\">\n      </label>\n      <button id=\"mergeBtn\">Merge (increase page size)</button>\n\n      <button id=\"splitBtn\">Split current page (halve page size)</button>\n    </div>\n\n    <div class=\"controls-row small\">\n      Merge/split are simple manipulations of pageSize to demonstrate structural transitions.\n    </div>\n  </section>\n\n  <section id=\"data-actions\">\n    <strong>Item & Bulk Actions</strong>\n    <div class=\"controls-row\">\n      <button id=\"selectAll\">Select All On Page</button>\n      <button id=\"clearSelection\">Clear Selection</button>\n      <button id=\"deleteSelected\">Delete Selected</button>\n      <button id=\"duplicateSelected\">Duplicate Selected</button>\n      <label>Bulk set category:\n        <input id=\"bulkCategory\" type=\"text\" placeholder=\"new cat\">\n      </label>\n      <button id=\"bulkSetCategory\">Apply</button>\n      <label>Bulk set value:\n        <input id=\"bulkValue\" type=\"number\" placeholder=\"value\">\n      </label>\n      <button id=\"bulkSetValue\">Apply</button>\n    </div>\n\n    <div class=\"controls-row\">\n      <button id=\"exportCSV\">Export current page CSV</button>\n      <input id=\"importFile\" type=\"file\" accept=\".csv\">\n      <button id=\"importBtn\">Import (from file)</button>\n      <button id=\"randomize\">Randomize values on page</button>\n      <button id=\"addItem\">Add item to dataset</button>\n    </div>\n\n    <div class=\"controls-row small\">\n      Inline edit: click a cell value to edit (title/value/category). Many operations modify dataset and are undoable.\n    </div>\n  </section>\n\n  <section id=\"page-view\">\n    <strong>Page View & Items</strong>\n    <div class=\"controls-row\">\n      <span id=\"status\">Status: idle</span>\n      <span id=\"meta\" style=\"margin-left:12px;\"></span>\n      <span id=\"cacheInfo\" style=\"margin-left:12px;\"></span>\n    </div>\n\n    <div id=\"listContainer\"></div>\n  </section>\n\n  <section id=\"debug\">\n    <strong>Inspector & Logs</strong>\n    <div class=\"controls-row\">\n      <button id=\"dumpDataset\">Dump dataset (console)</button>\n      <button id=\"clearLog\">Clear log</button>\n    </div>\n    <div id=\"log\" class=\"log\"></div>\n  </section>\n\n<script>\n(function(){\n  // ---------- Data Model ----------\n  let dataset = []; // full dataset in memory (server-side simulation)\n  let idCounter = 1;\n  let categories = [\"alpha\",\"beta\",\"gamma\",\"delta\",\"epsilon\"];\n  const state = {\n    pageSize: 20,\n    currentPage: 1, // 1-based\n    infinite: false,\n    loadedPages: [], // for infinite mode store loaded page indices\n    filters: { q: '', category: '', minValue: null, maxValue: null },\n    sort: { field: 'id', dir: 'asc' },\n    cacheEnabled: true,\n    prefetchEnabled: false,\n    offline: false,\n    netDelay: 250,\n    selection: new Set(), // selected item ids (global)\n    pinnedPages: new Set(),\n    bookmarks: [], // array of snapshots\n    history: { past: [], future: [] } // simple undo/redo storing dataset + state snapshot\n  };\n\n  // Simple page cache: key -> {timestamp, result}\n  const pageCache = new Map();\n\n  // Logging\n  function log(msg){\n    const el = document.getElementById('log');\n    const time = new Date().toISOString().slice(11,23);\n    el.textContent = `[${time}] ${msg}\\n` + el.textContent;\n  }\n\n  // ---------- Utilities ----------\n  function seededRandom(seed){\n    // simple seeded RNG (xfnv1a + mulberry32)\n    let h = 2166136261 >>> 0;\n    for (let i=0;i<seed.length;i++) h = Math.imul(h ^ seed.charCodeAt(i), 16777619);\n    return function(){ h += 0x6D2B79F5; let t = Math.imul(h ^ h >>> 15, 1 | h); t ^= t + Math.imul(t ^ t >>> 7, 61 | t); return ((t ^ t >>> 14) >>> 0) / 4294967296; };\n  }\n\n  function generateDataset(n, seedStr){\n    dataset = [];\n    idCounter = 1;\n    const rnd = seededRandom(seedStr || String(Date.now()));\n    for (let i=0;i<n;i++){\n      const id = idCounter++;\n      const cat = categories[Math.floor(rnd()*categories.length)];\n      const title = `${cat.toUpperCase()} Item ${id}`;\n      const value = Math.round(rnd()*1000);\n      const date = new Date(Date.now() - Math.round(rnd()*1000*60*60*24*365)).toISOString();\n      dataset.push({ id, title, category: cat, value, date });\n    }\n    log(`Generated dataset with ${n} items (seed=${seedStr})`);\n    // repopulate category filter options\n    const sel = document.getElementById('categoryFilter');\n    sel.innerHTML = '<option value=\"\">(any)</option>';\n    const uniq = Array.from(new Set(dataset.map(d=>d.category))).sort();\n    uniq.forEach(c=>{\n      const opt = document.createElement('option'); opt.value = c; opt.textContent = c; sel.appendChild(opt);\n    });\n  }\n\n  // ---------- Server-side \"fetch\" simulation ----------\n  function getCacheKey(params){\n    // include dataset length and a signature to allow invalidation when dataset changes\n    const signature = dataset.length + '|' + (dataset.length ? dataset[0].id + '-' + dataset[dataset.length-1].id : '') ;\n    return JSON.stringify({ params, signature });\n  }\n\n  function applyFiltersAndSort(data, filters, sort){\n    let out = data;\n    if (filters.q){\n      const q = filters.q.toLowerCase();\n      out = out.filter(it => it.title.toLowerCase().includes(q) || String(it.id)===q);\n    }\n    if (filters.category){\n      out = out.filter(it => it.category === filters.category);\n    }\n    if (filters.minValue != null && filters.minValue !== ''){\n      out = out.filter(it => it.value >= Number(filters.minValue));\n    }\n    if (filters.maxValue != null && filters.maxValue !== ''){\n      out = out.filter(it => it.value <= Number(filters.maxValue));\n    }\n    out = out.slice();\n    const field = sort.field;\n    const dir = sort.dir === 'asc' ? 1 : -1;\n    out.sort((a,b)=>{\n      let av = a[field], bv = b[field];\n      if (field === 'title' || field === 'category' || field === 'date') {\n        av = String(av); bv = String(bv);\n        return av.localeCompare(bv) * dir;\n      } else {\n        return (av - bv) * dir;\n      }\n    });\n    return out;\n  }\n\n  function fetchPageFromServer(pageIndex, pageSize, filters, sort, opts = {}){\n    // pageIndex is 1-based.\n    const params = { pageIndex, pageSize, filters, sort };\n    const cacheKey = getCacheKey(params);\n    const cached = pageCache.get(cacheKey);\n    if (state.cacheEnabled && cached){\n      log(`Cache hit for page ${pageIndex} (pageSize=${pageSize})`);\n      return Promise.resolve(Object.assign({}, cached.result));\n    }\n    if (state.offline && !opts.force){\n      return new Promise((_, rej) => {\n        setTimeout(()=> rej(new Error('Network offline simulated')), state.netDelay);\n      });\n    }\n\n    return new Promise((resolve, reject) => {\n      setTimeout(()=>{\n        try {\n          const all = applyFiltersAndSort(dataset, filters, sort);\n          const total = all.length;\n          const start = (pageIndex - 1) * pageSize;\n          const end = start + pageSize;\n          const pageItems = all.slice(start, end).map(i => ({...i})); // copy items\n          const result = { pageIndex, pageSize, total, items: pageItems };\n          if (state.cacheEnabled){\n            pageCache.set(cacheKey, { timestamp: Date.now(), result });\n            // keep cache size reasonable\n            if (pageCache.size > 500) {\n              // delete oldest\n              let oldestKey, oldestTs = Infinity;\n              for (const [k,v] of pageCache) if (v.timestamp < oldestTs) { oldestKey = k; oldestTs = v.timestamp; }\n              if (oldestKey) pageCache.delete(oldestKey);\n            }\n          }\n          resolve(result);\n        } catch (err) {\n          reject(err);\n        }\n      }, state.netDelay);\n    });\n  }\n\n  function fetchPage(pageIndex, pageSize, opts = {}){\n    const filters = JSON.parse(JSON.stringify(state.filters));\n    const sort = JSON.parse(JSON.stringify(state.sort));\n    return fetchPageFromServer(pageIndex, pageSize, filters, sort, opts).then(res=>{\n      // prefetch neighbors if enabled\n      if (state.prefetchEnabled && !opts.noprefetch){\n        const neighbors = [res.pageIndex - 1, res.pageIndex + 1].filter(p => p >= 1);\n        neighbors.forEach(p=>{\n          fetchPageFromServer(p, pageSize, filters, sort, { noprefetch: true }).catch(()=>{});\n        });\n      }\n      return res;\n    });\n  }\n\n  // ---------- UI Helpers ----------\n  function setStatus(msg){\n    document.getElementById('status').textContent = 'Status: ' + msg;\n  }\n\n  function updateMeta(total){\n    const meta = document.getElementById('meta');\n    meta.textContent = `Page ${state.currentPage} / pageSize ${state.pageSize} — total ${total != null ? total : '?'}`;\n    document.getElementById('cacheInfo').textContent = `Cache entries: ${pageCache.size}`;\n  }\n\n  function renderItems(result, append=false){\n    const container = document.getElementById('listContainer');\n    if (!append) container.innerHTML = '';\n    const info = document.createElement('div');\n    info.className = 'small';\n    info.textContent = `Showing page ${result.pageIndex} (items ${result.items.length}) — total ${result.total}`;\n    container.appendChild(info);\n\n    const table = document.createElement('table');\n    const thead = document.createElement('thead');\n    thead.innerHTML = '<tr><th><input id=\"pageSelectAll\" type=\"checkbox\"></th><th>id</th><th>title</th><th>category</th><th>value</th><th>date</th><th>actions</th></tr>';\n    table.appendChild(thead);\n    const tbody = document.createElement('tbody');\n    result.items.forEach(item=>{\n      const tr = document.createElement('tr');\n      const chk = document.createElement('input'); chk.type='checkbox'; chk.checked = state.selection.has(item.id);\n      chk.addEventListener('change', ()=> {\n        if (chk.checked) state.selection.add(item.id); else state.selection.delete(item.id);\n        updateSelectionUI();\n      });\n      const tdChk = document.createElement('td'); tdChk.appendChild(chk);\n      tr.appendChild(tdChk);\n\n      tr.appendChild(td('id', item.id));\n\n      // editable title\n      const tdTitle = td('title', item.title);\n      tdTitle.addEventListener('click', ()=> makeEditable(tdTitle, item, 'title'));\n      tr.appendChild(tdTitle);\n\n      const tdCat = td('category', item.category);\n      tdCat.addEventListener('click', ()=> makeEditable(tdCat, item, 'category'));\n      tr.appendChild(tdCat);\n\n      const tdVal = td('value', item.value);\n      tdVal.addEventListener('click', ()=> makeEditable(tdVal, item, 'value'));\n      tr.appendChild(tdVal);\n\n      tr.appendChild(td('date', item.date));\n\n      const actionTd = document.createElement('td');\n      const delBtn = document.createElement('button'); delBtn.textContent = 'Delete'; delBtn.addEventListener('click', ()=> {\n        snapshotForUndo('delete single');\n        dataset = dataset.filter(d => d.id !== item.id);\n        state.selection.delete(item.id);\n        invalidateCache();\n        loadCurrentPage();\n        log(`Deleted item id=${item.id}`);\n      });\n      const dupBtn = document.createElement('button'); dupBtn.textContent = 'Dup'; dupBtn.addEventListener('click', ()=> {\n        snapshotForUndo('duplicate single');\n        const newItem = Object.assign({}, item, { id: idCounter++ });\n        dataset.push(newItem);\n        invalidateCache();\n        loadCurrentPage();\n        log(`Duplicated item ${item.id} -> ${newItem.id}`);\n      });\n      actionTd.appendChild(delBtn); actionTd.appendChild(dupBtn);\n      tr.appendChild(actionTd);\n\n      tbody.appendChild(tr);\n    });\n    table.appendChild(tbody);\n    container.appendChild(table);\n\n    // page select all handler\n    const pageSelectAll = document.getElementById('pageSelectAll');\n    pageSelectAll.addEventListener('change', ()=>{\n      const checked = pageSelectAll.checked;\n      result.items.forEach(it=> {\n        if (checked) state.selection.add(it.id); else state.selection.delete(it.id);\n      });\n      // re-render to update checkboxes\n      loadCurrentPage(false);\n      updateSelectionUI();\n    });\n\n    updateMeta(result.total);\n    updateSelectionUI();\n  }\n\n  function td(cls, text){\n    const td = document.createElement('td');\n    td.className = cls;\n    td.textContent = text;\n    return td;\n  }\n\n  function makeEditable(tdElement, item, field){\n    const old = item[field];\n    const input = document.createElement('input');\n    input.type = (field === 'value') ? 'number' : 'text';\n    input.value = old;\n    tdElement.textContent = '';\n    tdElement.appendChild(input);\n    input.focus();\n    function save(){\n      const val = input.value;\n      if (String(val) !== String(old)){\n        snapshotForUndo(`edit ${field} id=${item.id}`);\n        // apply to master dataset\n        const idx = dataset.findIndex(d => d.id === item.id);\n        if (idx !== -1){\n          const parsed = (field === 'value') ? Number(val) : val;\n          dataset[idx][field] = parsed;\n          invalidateCache();\n          log(`Edited item ${item.id} : ${field} -> ${parsed}`);\n        }\n      }\n      // restore\n      tdElement.textContent = dataset.find(d => d.id === item.id)[field];\n      loadCurrentPage(false); // re-render\n    }\n    input.addEventListener('blur', save);\n    input.addEventListener('keydown', e => { if (e.key === 'Enter') input.blur(); if (e.key === 'Escape') { tdElement.textContent = old; } });\n  }\n\n  function updateSelectionUI(){\n    const selCount = state.selection.size;\n    document.getElementById('meta').textContent = `Page ${state.currentPage} / pageSize ${state.pageSize} — selected ${selCount}`;\n  }\n\n  function invalidateCache(){\n    if (!state.cacheEnabled) return;\n    // remove cached pages that depend on dataset signature: easiest is to clear all cache when dataset changes\n    pageCache.clear();\n    log('Cache invalidated due to dataset change');\n  }\n\n  // ---------- Navigation ----------\n  function loadCurrentPage(showStatus=true){\n    if (showStatus) setStatus('loading');\n    const pageIndex = state.currentPage;\n    const pageSize = state.pageSize;\n    if (state.infinite){\n      // infinite: accumulate loaded pages; if not loaded, fetch and append\n      if (state.loadedPages.includes(pageIndex)) {\n        setStatus('loaded (infinite, cached)');\n        // re-render using cached page results sequentially\n        renderInfinite();\n        return Promise.resolve();\n      }\n      return fetchPage(pageIndex, pageSize).then(res=>{\n        state.loadedPages.push(pageIndex);\n        state.loadedPages.sort((a,b)=>a-b);\n        if (showStatus) setStatus('loaded');\n        renderInfinite();\n        return res;\n      }).catch(err=>{\n        setStatus('error');\n        log('Error loading page: ' + err.message);\n      });\n    } else {\n      // normal paging\n      return fetchPage(pageIndex, pageSize).then(res=>{\n        setStatus('loaded');\n        renderItems(res, false);\n        return res;\n      }).catch(err=>{\n        setStatus('error');\n        log('Error loading page: ' + err.message);\n      });\n    }\n  }\n\n  function renderInfinite(){\n    // fetch all loaded pages and concatenate\n    const pages = state.loadedPages.slice().sort((a,b)=>a-b);\n    const promises = pages.map(p=> fetchPage(p, state.pageSize).catch(e=>null));\n    Promise.all(promises).then(results=>{\n      const mergedItems = [];\n      let total = 0;\n      results.forEach(r=>{ if (r){ mergedItems.push(...r.items); total = r.total; }});\n      renderItems({ pageIndex: pages[0] || 1, pageSize: state.pageSize, items: mergedItems, total }, false);\n      setStatus('infinite loaded');\n    });\n  }\n\n  // ---------- Actions ----------\n  function snapshotForUndo(actionName){\n    // store deep copy of dataset and state relevant to restore\n    const snap = {\n      dataset: JSON.parse(JSON.stringify(dataset)),\n      state: {\n        pageSize: state.pageSize,\n        currentPage: state.currentPage,\n        infinite: state.infinite,\n        filters: JSON.parse(JSON.stringify(state.filters)),\n        sort: JSON.parse(JSON.stringify(state.sort)),\n        selection: Array.from(state.selection)\n      },\n      actionName,\n      timestamp: Date.now()\n    };\n    state.history.past.push(snap);\n    // cap history\n    if (state.history.past.length > 40) state.history.past.shift();\n    state.history.future = [];\n    log(`Snapshot taken: ${actionName}`);\n  }\n\n  function undo(){\n    if (!state.history.past.length) { log('Nothing to undo'); return; }\n    const snap = state.history.past.pop();\n    const currentSnap = {\n      dataset: JSON.parse(JSON.stringify(dataset)),\n      state: {\n        pageSize: state.pageSize,\n        currentPage: state.currentPage,\n        infinite: state.infinite,\n        filters: JSON.parse(JSON.stringify(state.filters)),\n        sort: JSON.parse(JSON.stringify(state.sort)),\n        selection: Array.from(state.selection)\n      },\n      actionName: 'undo-capture',\n      timestamp: Date.now()\n    };\n    state.history.future.push(currentSnap);\n    dataset = snap.dataset;\n    state.pageSize = snap.state.pageSize;\n    state.currentPage = snap.state.currentPage;\n    state.infinite = snap.state.infinite;\n    state.filters = snap.state.filters;\n    state.sort = snap.state.sort;\n    state.selection = new Set(snap.state.selection);\n    invalidateCache();\n    loadCurrentPage();\n    log(`Undo: restored snapshot (${snap.actionName})`);\n  }\n\n  function redo(){\n    if (!state.history.future.length) { log('Nothing to redo'); return; }\n    const snap = state.history.future.pop();\n    const currentSnap = {\n      dataset: JSON.parse(JSON.stringify(dataset)),\n      state: {\n        pageSize: state.pageSize,\n        currentPage: state.currentPage,\n        infinite: state.infinite,\n        filters: JSON.parse(JSON.stringify(state.filters)),\n        sort: JSON.parse(JSON.stringify(state.sort)),\n        selection: Array.from(state.selection)\n      },\n      actionName: 'redo-capture',\n      timestamp: Date.now()\n    };\n    state.history.past.push(currentSnap);\n    dataset = snap.dataset;\n    state.pageSize = snap.state.pageSize;\n    state.currentPage = snap.state.currentPage;\n    state.infinite = snap.state.infinite;\n    state.filters = snap.state.filters;\n    state.sort = snap.state.sort;\n    state.selection = new Set(snap.state.selection);\n    invalidateCache();\n    loadCurrentPage();\n    log(`Redo: restored snapshot`);\n  }\n\n  // ---------- Bulk actions ----------\n  function deleteSelected(){\n    if (!state.selection.size) { log('No selection'); return; }\n    snapshotForUndo('delete selected');\n    const before = dataset.length;\n    dataset = dataset.filter(d => !state.selection.has(d.id));\n    const after = dataset.length;\n    state.selection.clear();\n    invalidateCache();\n    loadCurrentPage();\n    log(`Deleted ${before-after} selected items`);\n  }\n\n  function duplicateSelected(){\n    if (!state.selection.size) { log('No selection'); return; }\n    snapshotForUndo('duplicate selected');\n    const selected = dataset.filter(d => state.selection.has(d.id));\n    selected.forEach(s=>{\n      const copy = {...s, id: idCounter++};\n      dataset.push(copy);\n    });\n    invalidateCache();\n    loadCurrentPage();\n    log(`Duplicated ${selected.length} items`);\n  }\n\n  function bulkSetCategory(cat){\n    if (!state.selection.size) { log('No selection'); return; }\n    snapshotForUndo('bulk set category');\n    dataset.forEach(d => { if (state.selection.has(d.id)) d.category = cat; });\n    invalidateCache();\n    loadCurrentPage();\n    log(`Set category='${cat}' for ${state.selection.size} items`);\n  }\n\n  function bulkSetValue(val){\n    if (!state.selection.size) { log('No selection'); return; }\n    snapshotForUndo('bulk set value');\n    dataset.forEach(d => { if (state.selection.has(d.id)) d.value = Number(val); });\n    invalidateCache();\n    loadCurrentPage();\n    log(`Set value=${val} for ${state.selection.size} items`);\n  }\n\n  // ---------- CSV Export/Import ----------\n  function exportCSVPage(){\n    fetchPage(state.currentPage, state.pageSize).then(res=>{\n      const rows = [['id','title','category','value','date']];\n      res.items.forEach(it => rows.push([it.id, it.title, it.category, it.value, it.date]));\n      const csv = rows.map(r => r.map(c => `\"${String(c).replace(/\"/g,'\"\"')}\"`).join(',')).join('\\n');\n      const blob = new Blob([csv], {type: 'text/csv'});\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a'); a.href = url; a.download = `page-${state.currentPage}.csv`; a.click();\n      URL.revokeObjectURL(url);\n      log('Exported current page to CSV');\n    });\n  }\n\n  function importCSV(file){\n    if (!file) { log('No file selected'); return; }\n    const reader = new FileReader();\n    reader.onload = function(e){\n      const text = e.target.result;\n      const lines = text.split(/\\r?\\n/).map(l=>l.trim()).filter(l=>l);\n      const rows = lines.map(l=>{\n        // naive CSV parse for quoted values\n        const parts = l.split(/,(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)/).map(s => s.replace(/^\"|\"$/g,'').replace(/\"\"/g,'\"'));\n        return parts;\n      });\n      if (rows.length <= 1) { log('CSV appears empty'); return; }\n      const header = rows[0].map(h=>h.toLowerCase());\n      snapshotForUndo('import csv');\n      for (let i=1;i<rows.length;i++){\n        const r = rows[i];\n        if (r.length < header.length) continue;\n        const obj = {};\n        for (let j=0;j<header.length;j++){\n          obj[header[j]] = r[j];\n        }\n        const newItem = {\n          id: idCounter++,\n          title: obj.title || ('Imported ' + newItemId()),\n          category: obj.category || categories[Math.floor(Math.random()*categories.length)],\n          value: Number(obj.value) || 0,\n          date: obj.date || new Date().toISOString()\n        };\n        dataset.push(newItem);\n      }\n      invalidateCache();\n      loadCurrentPage();\n      log(`Imported ${rows.length-1} items from CSV`);\n    };\n    reader.readAsText(file);\n  }\n\n  function newItemId(){ return idCounter++; }\n\n  // ---------- Merge & Split ----------\n  function mergeWithPage(otherPage){\n    if (otherPage < 1) return;\n    // simple: set pageSize to currentPageSize + otherPageSize (here uniform sizes -> multiply)\n    // We'll set pageSize to the sum of items currently in both pages (from server current view)\n    Promise.all([fetchPage(state.currentPage, state.pageSize), fetchPage(otherPage, state.pageSize)]).then(results=>{\n      const a = results[0], b = results[1];\n      const newSize = a.items.length + b.items.length;\n      snapshotForUndo('merge pages');\n      state.pageSize = Math.max(1, newSize);\n      state.currentPage = Math.min(state.currentPage, otherPage);\n      invalidateCache();\n      loadCurrentPage();\n      log(`Merged page ${state.currentPage} and ${otherPage} -> new pageSize ${state.pageSize}`);\n    }).catch(err=> log('Merge failed: '+err.message));\n  }\n\n  function splitCurrentPage(){\n    // halve pageSize\n    if (state.pageSize <= 1) { log('Cannot split further'); return; }\n    snapshotForUndo('split page');\n    state.pageSize = Math.max(1, Math.floor(state.pageSize / 2));\n    invalidateCache();\n    loadCurrentPage();\n    log(`Split current page -> new pageSize ${state.pageSize}`);\n  }\n\n  // ---------- Pins & Bookmarks ----------\n  function pinCurrentPage(){\n    state.pinnedPages.add(state.currentPage);\n    log(`Pinned page ${state.currentPage}`);\n  }\n  function unpinCurrentPage(){\n    state.pinnedPages.delete(state.currentPage);\n    log(`Unpinned page ${state.currentPage}`);\n  }\n  function showPinned(){\n    if (!state.pinnedPages.size) { log('No pinned pages'); return; }\n    log('Pinned pages: ' + Array.from(state.pinnedPages).join(', '));\n  }\n  function bookmarkPage(){\n    const snap = {\n      when: new Date().toISOString(),\n      page: state.currentPage,\n      pageSize: state.pageSize,\n      filters: JSON.parse(JSON.stringify(state.filters)),\n      sort: JSON.parse(JSON.stringify(state.sort))\n    };\n    state.bookmarks.push(snap);\n    log(`Bookmarked: page ${snap.page} (size ${snap.pageSize})`);\n  }\n  function showBookmarks(){\n    if (!state.bookmarks.length) { log('No bookmarks'); return; }\n    log('Bookmarks:\\n' + state.bookmarks.map((b,i)=> `${i+1}. ${b.when} => page ${b.page} (size ${b.pageSize})`).join('\\n'));\n  }\n\n  // ---------- Misc ----------\n  function randomizePageValues(){\n    snapshotForUndo('randomize page');\n    fetchPage(state.currentPage, state.pageSize).then(res=>{\n      const ids = res.items.map(i=>i.id);\n      dataset.forEach(d => { if (ids.includes(d.id)) d.value = Math.round(Math.random()*1000); });\n      invalidateCache();\n      loadCurrentPage();\n      log('Randomized values on current page');\n    });\n  }\n\n  function addItem(){\n    snapshotForUndo('add item');\n    const cat = categories[Math.floor(Math.random()*categories.length)];\n    const it = { id: idCounter++, title: 'NEW ITEM ' + idCounter, category: cat, value: Math.round(Math.random()*500), date: new Date().toISOString() };\n    dataset.push(it);\n    invalidateCache();\n    loadCurrentPage();\n    log('Added item ' + it.id);\n  }\n\n  // ---------- Init & Event Wiring ----------\n  function wire(){\n    document.getElementById('regenData').addEventListener('click', ()=> {\n      const n = Number(document.getElementById('datasetSize').value) || 200;\n      const seed = document.getElementById('seed').value || 'seed';\n      snapshotForUndo('regenerate dataset');\n      generateDataset(n, seed);\n      invalidateCache();\n      state.currentPage = 1; state.loadedPages = []; state.selection.clear();\n      loadCurrentPage();\n    });\n\n    document.getElementById('netDelay').addEventListener('input', (e)=> {\n      state.netDelay = Number(e.target.value);\n      document.getElementById('netDelayVal').textContent = state.netDelay;\n    });\n\n    document.getElementById('offline').addEventListener('change', (e)=> { state.offline = e.target.checked; log('Offline: ' + state.offline); });\n\n    document.getElementById('cacheEnabled').addEventListener('change', (e)=> { state.cacheEnabled = e.target.checked; if (!state.cacheEnabled) pageCache.clear(); log('Cache enabled: ' + state.cacheEnabled); });\n\n    document.getElementById('prefetchEnabled').addEventListener('change', (e)=> { state.prefetchEnabled = e.target.checked; log('Prefetch neighbors: ' + state.prefetchEnabled); });\n\n    document.getElementById('clearCache').addEventListener('click', ()=>{ pageCache.clear(); log('Cache cleared'); updateMeta(); });\n\n    // paging controls\n    const pageSizeInput = document.getElementById('pageSize');\n    pageSizeInput.addEventListener('change', ()=> {\n      const val = Math.max(1, Number(pageSizeInput.value) || 1);\n      snapshotForUndo('pageSize change');\n      state.pageSize = val;\n      document.getElementById('pageSizeRange').value = val;\n      state.currentPage = 1;\n      invalidateCache();\n      loadCurrentPage();\n    });\n\n    document.getElementById('pageSizeRange').addEventListener('input', (e)=> {\n      const val = Number(e.target.value);\n      pageSizeInput.value = val;\n      pageSizeInput.dispatchEvent(new Event('change'));\n    });\n\n    document.getElementById('currentPage').addEventListener('change', (e)=> {\n      const p = Math.max(1, Number(e.target.value) || 1);\n      state.currentPage = p;\n      loadCurrentPage();\n    });\n\n    document.getElementById('firstPage').addEventListener('click', ()=> { state.currentPage = 1; document.getElementById('currentPage').value = 1; loadCurrentPage(); });\n    document.getElementById('prevPage').addEventListener('click', ()=> { state.currentPage = Math.max(1, state.currentPage-1); document.getElementById('currentPage').value = state.currentPage; loadCurrentPage(); });\n    document.getElementById('nextPage').addEventListener('click', ()=> { state.currentPage = state.currentPage+1; document.getElementById('currentPage').value = state.currentPage; loadCurrentPage(); });\n    document.getElementById('lastPage').addEventListener('click', ()=> {\n      // estimate last page from last known total via cache or compute by fetching page1 to know total\n      fetchPage(1, state.pageSize).then(r=> {\n        const last = Math.max(1, Math.ceil(r.total / state.pageSize));\n        state.currentPage = last;\n        document.getElementById('currentPage').value = last;\n        loadCurrentPage();\n      });\n    });\n\n    document.getElementById('infinite').addEventListener('change', (e)=> {\n      state.infinite = e.target.checked;\n      if (state.infinite) {\n        state.loadedPages = [state.currentPage];\n        document.getElementById('loadMore').disabled = false;\n      } else {\n        state.loadedPages = [];\n        document.getElementById('loadMore').disabled = true;\n      }\n      loadCurrentPage();\n      log('Infinite mode: ' + state.infinite);\n    });\n\n    document.getElementById('loadMore').addEventListener('click', ()=> {\n      // load next page and append\n      const next = Math.max(...state.loadedPages) + 1 || 1;\n      state.currentPage = next;\n      state.loadedPages.push(next);\n      loadCurrentPage();\n    });\n\n    document.getElementById('jumpBtn').addEventListener('click', ()=> {\n      const p = Math.max(1, Number(document.getElementById('jumpPage').value) || 1);\n      state.currentPage = p;\n      document.getElementById('currentPage').value = p;\n      loadCurrentPage();\n    });\n\n    document.getElementById('gotoBtn').addEventListener('click', ()=> {\n      const id = Number(document.getElementById('gotoId').value);\n      if (!id) return;\n      // find item's index in filtered+sorted list by asking server and scanning until found (naive)\n      // optimize: fetch first N pages until found\n      const pageSize = state.pageSize;\n      function searchPage(page){\n        return fetchPage(page, pageSize).then(r=>{\n          const found = r.items.find(it => it.id === id);\n          if (found) {\n            state.currentPage = page;\n            document.getElementById('currentPage').value = page;\n            loadCurrentPage();\n            log(`Found id=${id} on page ${page}`);\n            return true;\n          } else {\n            const lastPage = Math.max(1, Math.ceil(r.total / pageSize));\n            if (page < lastPage) return searchPage(page+1);\n            log(`Item id=${id} not found in dataset (with current filters)`);\n            return false;\n          }\n        }).catch(err=> { log('Search failed: '+err.message); return false; });\n      }\n      searchPage(1);\n    });\n\n    // filter & sort\n    document.getElementById('applyFilter').addEventListener('click', ()=> {\n      state.filters.q = document.getElementById('q').value.trim();\n      state.filters.category = document.getElementById('categoryFilter').value;\n      state.filters.minValue = document.getElementById('minValue').value;\n      state.filters.maxValue = document.getElementById('maxValue').value;\n      state.sort.field = document.getElementById('sortField').value;\n      state.sort.dir = document.getElementById('sortDir').value;\n      state.currentPage = 1; document.getElementById('currentPage').value = 1;\n      invalidateCache();\n      loadCurrentPage();\n      log('Applied filters/sort');\n    });\n    document.getElementById('resetFilter').addEventListener('click', ()=> {\n      document.getElementById('q').value = '';\n      document.getElementById('categoryFilter').value = '';\n      document.getElementById('minValue').value = '';\n      document.getElementById('maxValue').value = '';\n      document.getElementById('sortField').value = 'id';\n      document.getElementById('sortDir').value = 'asc';\n      document.getElementById('applyFilter').click();\n      log('Filters reset');\n    });\n\n    // page ops\n    document.getElementById('pinPage').addEventListener('click', pinCurrentPage);\n    document.getElementById('unpinPage').addEventListener('click', unpinCurrentPage);\n    document.getElementById('showPinned').addEventListener('click', showPinned);\n    document.getElementById('bookmarkPage').addEventListener('click', bookmarkPage);\n    document.getElementById('showBookmarks').addEventListener('click', showBookmarks);\n    document.getElementById('snapshotState').addEventListener('click', ()=> snapshotForUndo('manual snapshot'));\n    document.getElementById('undoBtn').addEventListener('click', undo);\n    document.getElementById('redoBtn').addEventListener('click', redo);\n\n    document.getElementById('mergeBtn').addEventListener('click', ()=> {\n      const other = Math.max(1, Number(document.getElementById('mergePage').value) || 1);\n      mergeWithPage(other);\n    });\n    document.getElementById('splitBtn').addEventListener('click', splitCurrentPage);\n\n    // item actions\n    document.getElementById('selectAll').addEventListener('click', ()=> {\n      // select all visible items on current page\n      fetchPage(state.currentPage, state.pageSize).then(res=>{\n        res.items.forEach(i=> state.selection.add(i.id));\n        loadCurrentPage(false);\n        updateSelectionUI();\n        log('Selected all items on page');\n      });\n    });\n    document.getElementById('clearSelection').addEventListener('click', ()=> { state.selection.clear(); loadCurrentPage(false); updateSelectionUI(); log('Cleared selection'); });\n    document.getElementById('deleteSelected').addEventListener('click', deleteSelected);\n    document.getElementById('duplicateSelected').addEventListener('click', duplicateSelected);\n    document.getElementById('bulkSetCategory').addEventListener('click', ()=> { const c = document.getElementById('bulkCategory').value.trim(); if (c) bulkSetCategory(c); });\n    document.getElementById('bulkSetValue').addEventListener('click', ()=> { const v = document.getElementById('bulkValue').value; if (v !== '') bulkSetValue(v); });\n\n    document.getElementById('exportCSV').addEventListener('click', exportCSVPage);\n    document.getElementById('importBtn').addEventListener('click', ()=> {\n      const f = document.getElementById('importFile').files[0];\n      importCSV(f);\n    });\n    document.getElementById('randomize').addEventListener('click', randomizePageValues);\n    document.getElementById('addItem').addEventListener('click', addItem);\n\n    document.getElementById('dumpDataset').addEventListener('click', ()=> { console.log(dataset); log('Dataset dumped to console'); });\n    document.getElementById('clearLog').addEventListener('click', ()=> { document.getElementById('log').textContent = ''; });\n\n    // misc: dataset size input reflect\n    document.getElementById('datasetSize').addEventListener('change', ()=> {\n      const v = Number(document.getElementById('datasetSize').value) || 200;\n      document.getElementById('datasetSize').value = Math.max(10, Math.min(10000, v));\n    });\n  }\n\n  // ---------- Boot ----------\n  function boot(){\n    wire();\n    // initial dataset\n    const size = Number(document.getElementById('datasetSize').value) || 200;\n    const seed = document.getElementById('seed').value || 'seed';\n    generateDataset(size, seed);\n    // initial UI sync\n    state.pageSize = Number(document.getElementById('pageSize').value) || 20;\n    state.currentPage = Number(document.getElementById('currentPage').value) || 1;\n    state.netDelay = Number(document.getElementById('netDelay').value) || 250;\n    state.cacheEnabled = document.getElementById('cacheEnabled').checked;\n    state.prefetchEnabled = document.getElementById('prefetchEnabled').checked;\n    state.offline = document.getElementById('offline').checked;\n    document.getElementById('netDelayVal').textContent = state.netDelay;\n    loadCurrentPage();\n  }\n\n  boot();\n})();\n</script>\n</body>\n</html>"
