  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>K-Means Clustering Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        canvas {\n            border: 1px solid #000;\n            margin: 10px 0;\n        }\n        .control-panel {\n            margin: 10px 0;\n            padding: 10px;\n            border: 1px solid #000;\n        }\n        .control-group {\n            margin: 10px 0;\n        }\n        button, input, select {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>K-Means Clustering Interactive Demo</h1>\n    \n    <div class=\"control-panel\">\n        <div class=\"control-group\">\n            <button id=\"generateRandom\">Generate Random Points</button>\n            <label>Points: <input type=\"number\" id=\"pointCount\" value=\"100\" min=\"10\" max=\"500\"></label>\n            <label>Clusters: <input type=\"number\" id=\"clusterCount\" value=\"3\" min=\"1\" max=\"10\"></label>\n        </div>\n        \n        <div class=\"control-group\">\n            <button id=\"runAlgorithm\">Run One Step</button>\n            <button id=\"runFull\">Run Full Algorithm</button>\n            <button id=\"reset\">Reset</button>\n            <label>Max Iterations: <input type=\"number\" id=\"maxIterations\" value=\"10\" min=\"1\" max=\"50\"></label>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Point Distribution:</label>\n            <select id=\"distributionType\">\n                <option value=\"random\">Random</option>\n                <option value=\"gaussian\">Gaussian Clusters</option>\n                <option value=\"rings\">Concentric Rings</option>\n                <option value=\"spiral\">Spiral</option>\n            </select>\n            <label>Cluster Variance: <input type=\"range\" id=\"clusterVariance\" min=\"1\" max=\"50\" value=\"20\"></label>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Initialization Method:</label>\n            <select id=\"initMethod\">\n                <option value=\"random\">Random Points</option>\n                <option value=\"kmeans++\">K-Means++</option>\n                <option value=\"manual\">Manual Placement</option>\n            </select>\n            <button id=\"placeCenters\" style=\"display:none;\">Place Centers</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Distance Metric:</label>\n            <select id=\"distanceMetric\">\n                <option value=\"euclidean\">Euclidean</option>\n                <option value=\"manhattan\">Manhattan</option>\n            </select>\n        </div>\n    </div>\n    \n    <canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n    \n    <div>\n        <p>Iteration: <span id=\"iterationCount\">0</span></p>\n        <p>Status: <span id=\"status\">Ready</span></p>\n    </div>\n    \n    <script>\n        // Canvas setup\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n        const width = canvas.width;\n        const height = canvas.height;\n        \n        // State variables\n        let points = [];\n        let centers = [];\n        let clusters = [];\n        let iteration = 0;\n        let isRunning = false;\n        let isManualPlacement = false;\n        let animationId = null;\n        \n        // DOM elements\n        const generateRandomBtn = document.getElementById('generateRandom');\n        const runAlgorithmBtn = document.getElementById('runAlgorithm');\n        const runFullBtn = document.getElementById('runFull');\n        const resetBtn = document.getElementById('reset');\n        const pointCountInput = document.getElementById('pointCount');\n        const clusterCountInput = document.getElementById('clusterCount');\n        const maxIterationsInput = document.getElementById('maxIterations');\n        const distributionTypeSelect = document.getElementById('distributionType');\n        const clusterVarianceInput = document.getElementById('clusterVariance');\n        const initMethodSelect = document.getElementById('initMethod');\n        const placeCentersBtn = document.getElementById('placeCenters');\n        const distanceMetricSelect = document.getElementById('distanceMetric');\n        const iterationCountSpan = document.getElementById('iterationCount');\n        const statusSpan = document.getElementById('status');\n        \n        // Event listeners\n        generateRandomBtn.addEventListener('click', generatePoints);\n        runAlgorithmBtn.addEventListener('click', runOneStep);\n        runFullBtn.addEventListener('click', runFullAlgorithm);\n        resetBtn.addEventListener('click', reset);\n        initMethodSelect.addEventListener('change', toggleManualPlacement);\n        placeCentersBtn.addEventListener('click', finishManualPlacement);\n        canvas.addEventListener('click', handleCanvasClick);\n        \n        // Initialize\n        reset();\n        \n        // Functions\n        function reset() {\n            points = [];\n            centers = [];\n            clusters = [];\n            iteration = 0;\n            isRunning = false;\n            isManualPlacement = false;\n            if (animationId) {\n                cancelAnimationFrame(animationId);\n                animationId = null;\n            }\n            \n            updateUI();\n            clearCanvas();\n            statusSpan.textContent = \"Ready\";\n        }\n        \n        function generatePoints() {\n            reset();\n            const count = parseInt(pointCountInput.value);\n            const distribution = distributionTypeSelect.value;\n            const variance = parseInt(clusterVarianceInput.value) / 10;\n            \n            points = [];\n            \n            if (distribution === 'random') {\n                for (let i = 0; i < count; i++) {\n                    points.push({\n                        x: Math.random() * width,\n                        y: Math.random() * height\n                    });\n                }\n            } else if (distribution === 'gaussian') {\n                const k = parseInt(clusterCountInput.value);\n                const pointsPerCluster = Math.floor(count / k);\n                \n                for (let c = 0; c < k; c++) {\n                    const centerX = 50 + Math.random() * (width - 100);\n                    const centerY = 50 + Math.random() * (height - 100);\n                    \n                    for (let i = 0; i < pointsPerCluster; i++) {\n                        points.push({\n                            x: centerX + (Math.random() - 0.5) * variance * 50,\n                            y: centerY + (Math.random() - 0.5) * variance * 50\n                        });\n                    }\n                }\n                \n                // Add remaining points\n                while (points.length < count) {\n                    points.push({\n                        x: Math.random() * width,\n                        y: Math.random() * height\n                    });\n                }\n            } else if (distribution === 'rings') {\n                const centerX = width / 2;\n                const centerY = height / 2;\n                const maxRadius = Math.min(width, height) / 2 - 20;\n                \n                for (let i = 0; i < count; i++) {\n                    const angle = Math.random() * Math.PI * 2;\n                    const radius = (Math.floor(Math.random() * 3) + 1) * (maxRadius / 3);\n                    const offset = (Math.random() - 0.5) * variance * 10;\n                    \n                    points.push({\n                        x: centerX + Math.cos(angle) * (radius + offset),\n                        y: centerY + Math.sin(angle) * (radius + offset)\n                    });\n                }\n            } else if (distribution === 'spiral') {\n                const centerX = width / 2;\n                const centerY = height / 2;\n                const maxRadius = Math.min(width, height) / 2 - 20;\n                \n                for (let i = 0; i < count; i++) {\n                    const t = Math.random() * Math.PI * 6;\n                    const radius = maxRadius * (t / (Math.PI * 6));\n                    const offset = (Math.random() - 0.5) * variance * 5;\n                    \n                    points.push({\n                        x: centerX + Math.cos(t) * (radius + offset),\n                        y: centerY + Math.sin(t) * (radius + offset)\n                    });\n                }\n            }\n            \n            initializeCenters();\n            updateUI();\n            draw();\n        }\n        \n        function initializeCenters() {\n            const k = parseInt(clusterCountInput.value);\n            centers = [];\n            \n            if (initMethodSelect.value === 'random') {\n                // Random initialization\n                for (let i = 0; i < k; i++) {\n                    centers.push({\n                        x: Math.random() * width,\n                        y: Math.random() * height,\n                        color: getRandomColor()\n                    });\n                }\n            } else if (initMethodSelect.value === 'kmeans++') {\n                // K-Means++ initialization\n                if (points.length === 0) return;\n                \n                // First center is random\n                centers.push({\n                    ...points[Math.floor(Math.random() * points.length)],\n                    color: getRandomColor()\n                });\n                \n                // Subsequent centers are chosen with probability proportional to D(x)^2\n                while (let centers.length < k) {\n                    const distances = points.map(p => {\n                        return Math.min(...centers.map(c => distance(p, c)));\n                    });\n                    \n                    const sum = distances.reduce((a, b) => a + b * b, 0);\n                    let threshold = Math.random() * sum;\n                    let i = 0;\n                    let runningSum = 0;\n                    \n                    while (i < points.length && runningSum < threshold) {\n                        runningSum += distances[i] * distances[i];\n                        i++;\n                    }\n                    \n                    centers.push({\n                        ...points[Math.max(0, i - 1)],\n                        color: getRandomColor()\n                    });\n                }\n            } else if (initMethodSelect.value === 'manual') {\n                isManualPlacement = true;\n                statusSpan.textContent = \"Click on canvas to place centers\";\n            }\n            \n            if (!isManualPlacement) {\n                assignPointsToClusters();\n            }\n        }\n        \n        function toggleManualPlacement() {\n            isManualPlacement = initMethodSelect.value === 'manual';\n            placeCentersBtn.style.display = isManualPlacement ? 'inline-block' : 'none';\n            \n            if (isManualPlacement && points.length > 0) {\n                statusSpan.textContent = \"Click on canvas to place centers\";\n            }\n        }\n        \n        function handleCanvasClick(e) {\n            if (!isManualPlacement) return;\n            \n            const rect = canvas.getBoundingClientRect();\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            \n            if (centers.length < parseInt(clusterCountInput.value)) {\n                centers.push({\n                    x: x,\n                    y: y,\n                    color: getRandomColor()\n                });\n                \n                draw();\n                statusSpan.textContent = `Placed center ${centers.length} of ${clusterCountInput.value}`;\n            }\n        }\n        \n        function finishManualPlacement() {\n            if (centers.length > 0) {\n                isManualPlacement = false;\n                assignPointsToClusters();\n                updateUI();\n            }\n        }\n        \n        function assignPointsToClusters() {\n            if (centers.length === 0) return;\n            \n            clusters = [];\n            for (let i = 0; i < centers.length; i++) {\n                clusters.push([]);\n            }\n            \n            for (const point of points) {\n                let minDist = Infinity;\n                let bestCluster = 0;\n                \n                for (let i = 0; i < centers.length; i++) {\n                    const dist = distance(point, centers[i]);\n                    if (dist < minDist) {\n                        minDist = dist;\n                        bestCluster = i;\n                    }\n                }\n                \n                clusters[bestCluster].push(point);\n            }\n            \n            iteration++;\n            iterationCountSpan.textContent = iteration;\n            statusSpan.textContent = \"Points assigned to clusters\";\n        }\n        \n        function updateCenters() {\n            let changed = false;\n            \n            for (let i = 0; i < centers.length; i++) {\n                if (clusters[i].length === 0) continue;\n                \n                const sum = clusters[i].reduce((acc, p) => {\n                    return { x: acc.x + p.x, y: acc.y + p.y };\n                }, { x: 0, y: 0 });\n                \n                const newX = sum.x / clusters[i].length;\n                const newY = sum.y / clusters[i].length;\n                \n                if (Math.abs(centers[i].x - newX) > 0.1 || Math.abs(centers[i].y - newY) > 0.1) {\n                    changed = true;\n                }\n                \n                centers[i].x = newX;\n                centers[i].y = newY;\n            }\n            \n            return changed;\n        }\n        \n        function runOneStep() {\n            if (points.length === 0 || centers.length === 0) {\n                statusSpan.textContent = \"Generate points first\";\n                return;\n            }\n            \n            if (isRunning) return;\n            isRunning = true;\n            \n            const changed = updateCenters();\n            assignPointsToClusters();\n            \n            draw();\n            \n            if (!changed) {\n                statusSpan.textContent = \"Converged - centers didn't change\";\n            } else {\n                statusSpan.textContent = \"Completed one iteration\";\n            }\n            \n            isRunning = false;\n        }\n        \n        function runFullAlgorithm() {\n            if (points.length === 0 || centers.length === 0) {\n                statusSpan.textContent = \"Generate points first\";\n                return;\n            }\n            \n            if (isRunning) return;\n            isRunning = true;\n            \n            const maxIterations = parseInt(maxIterationsInput.value);\n            let changed = true;\n            let iterations = 0;\n            \n            function step() {\n                if (!changed || iterations >= maxIterations) {\n                    isRunning = false;\n                    statusSpan.textContent = iterations >= maxIterations ? \n                        \"Reached max iterations\" : \"Converged - centers didn't change\";\n                    return;\n                }\n                \n                changed = updateCenters();\n                assignPointsToClusters();\n                iterations++;\n                \n                draw();\n                animationId = requestAnimationFrame(step);\n            }\n            \n            animationId = requestAnimationFrame(step);\n        }\n        \n        function distance(a, b) {\n            if (distanceMetricSelect.value === 'euclidean') {\n                return Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);\n            } else { // manhattan\n                return Math.abs(a.x - b.x) + Math.abs(a.y - b.y);\n            }\n        }\n        \n        function draw() {\n            clearCanvas();\n            \n            // Draw points\n            for (let i = 0; i < clusters.length; i++) {\n                const color = centers[i]?.color || '#000000';\n                \n                for (const point of clusters[i]) {\n                    ctx.fillStyle = color;\n                    ctx.beginPath();\n                    ctx.arc(point.x, point.y, 3, 0, Math.PI * 2);\n                    ctx.fill();\n                }\n            }\n            \n            // Draw centers\n            for (const center of centers) {\n                ctx.fillStyle = center.color';\n                ctx.beginPath();\n                ctx.arc(center.x, center.y, 8, 0, Math.PI * 2);\n                ctx.fill();\n                ctx.strokeStyle = '#000';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n            }\n        }\n        \n        function clearCanvas() {\n            ctx.fillStyle = '#fff';\n            ctx.fillRect(0, 0, width, height);\n        }\n        \n        function getRandomColor() {\n            const letters = '0123456789ABCDEF';\n            let color = '#';\n            for (let i = 0; i < 6; i++) {\n                color += letters[Math.floor(Math.random() * 16)];\n            }\n            return color;\n        }\n        \n        function updateUI() {\n            iterationCountSpan.textContent = iteration;\n            placeCentersBtn.style.display = isManualPlacement ? 'inline-block' : 'none';\n        }\n    </script>\n</body>\n</html>"
  },
