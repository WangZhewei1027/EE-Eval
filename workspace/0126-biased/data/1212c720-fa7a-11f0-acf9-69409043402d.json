  "question": "Deque",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deque Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  button, input[type=\"number\"], input[type=\"text\"] {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n  .deque-container {\n    margin: 1em 0;\n  }\n  .deque-item {\n    display: inline-block;\n    border: 1px solid black;\n    margin-right: 0.3em;\n    padding: 0.2em 0.5em;\n    min-width: 2em;\n    text-align: center;\n    user-select: none;\n  }\n  label {\n    user-select: none;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n    font-family: monospace, monospace;\n    font-size: 0.9em;\n    resize: vertical;\n  }\n  .error {\n    color: darkred;\n    user-select: none;\n  }\n  .help-text {\n    font-size: 0.9em;\n    user-select: none;\n    margin-top: 0.3em;\n  }\n</style>\n</head>\n<body>\n<h1>Deque Interactive Demonstration</h1>\n\n<section>\n  <fieldset>\n    <legend>Deque Initialization and Configuration</legend>\n    <label for=\"maxSizeInput\">Set Maximum Size (0 for unlimited): </label>\n    <input type=\"number\" id=\"maxSizeInput\" min=\"0\" step=\"1\" value=\"0\" />\n    <button id=\"setMaxSizeButton\">Set Max Size</button>\n    <div class=\"help-text\">Maximum size limits the number of elements deque can hold. 0 means unlimited.</div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Deque Operations</legend>\n    <div>\n      <label for=\"pushFrontInput\">Push Front: </label>\n      <input type=\"text\" id=\"pushFrontInput\" />\n      <button id=\"pushFrontBtn\">Push Front</button>\n    </div>\n    <div>\n      <label for=\"pushBackInput\">Push Back: </label>\n      <input type=\"text\" id=\"pushBackInput\" />\n      <button id=\"pushBackBtn\">Push Back</button>\n    </div>\n    <div>\n      <button id=\"popFrontBtn\">Pop Front</button>\n      <button id=\"popBackBtn\">Pop Back</button>\n    </div>\n    <div>\n      <button id=\"peekFrontBtn\">Peek Front</button>\n      <button id=\"peekBackBtn\">Peek Back</button>\n    </div>\n    <div>\n      <button id=\"clearBtn\">Clear Deque</button>\n    </div>\n    <div class=\"help-text\">\n      You can push any text data. Popping or peeking on empty deque will show an error.\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Advanced Deque Controls</legend>\n    <div>\n      <label for=\"removeValueInput\">Remove All Occurrences of Value: </label>\n      <input type=\"text\" id=\"removeValueInput\" />\n      <button id=\"removeValueBtn\">Remove Value</button>\n    </div>\n    <div>\n      <label for=\"countValueInput\">Count Occurrences of Value: </label>\n      <input type=\"text\" id=\"countValueInput\" />\n      <button id=\"countValueBtn\">Count</button>\n      <span id=\"countValueResult\"></span>\n    </div>\n    <div>\n      <label for=\"findValueInput\">Find Index of First Occurrence of Value: </label>\n      <input type=\"text\" id=\"findValueInput\" />\n      <button id=\"findValueBtn\">Find Index</button>\n      <span id=\"findValueResult\"></span>\n    </div>\n    <div>\n      <label for=\"insertAtIndexInput\">Insert at Index: </label>\n      <input type=\"number\" id=\"insertAtIndexInput\" min=\"0\" step=\"1\" />\n      <label for=\"insertAtValueInput\">Value: </label>\n      <input type=\"text\" id=\"insertAtValueInput\" />\n      <button id=\"insertAtBtn\">Insert</button>\n    </div>\n    <div>\n      <label for=\"removeAtIndexInput\">Remove at Index: </label>\n      <input type=\"number\" id=\"removeAtIndexInput\" min=\"0\" step=\"1\" />\n      <button id=\"removeAtBtn\">Remove</button>\n    </div>\n    <div class=\"help-text\">\n      Indexes start at 0 for front of deque. Attempting invalid operations will report errors.\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Deque State and Interaction Log</legend>\n    <div>\n      <label for=\"stateTextArea\">Current Deque State (Front → Back):</label>\n      <div id=\"dequeDisplay\" aria-live=\"polite\" style=\"min-height:2em;\"></div>\n    </div>\n    <div>\n      <label for=\"interactionLog\">Interaction Log:</label><br />\n      <textarea id=\"interactionLog\" readonly></textarea>\n      <button id=\"clearLogBtn\">Clear Log</button>\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Batch Operations and Persistence</legend>\n    <div>\n      <label for=\"batchInput\">Batch Operations (One per line):</label><br />\n      <textarea id=\"batchInput\" placeholder=\"Example commands:&#10;pushFront Hello&#10;pushBack World&#10;popFront&#10;insertAt 1 InsertedValue&#10;removeValue World\"></textarea><br />\n      <button id=\"runBatchBtn\">Run Batch</button>\n      <button id=\"loadJsonBtn\">Load Deque from JSON</button>\n      <input type=\"file\" id=\"loadJsonFile\" style=\"display:none\" accept=\".json\" />\n      <button id=\"saveJsonBtn\">Save Deque to JSON</button>\n    </div>\n    <div class=\"help-text\">\n      Supported batch commands:<br />\n      - pushFront VALUE<br />\n      - pushBack VALUE<br />\n      - popFront<br />\n      - popBack<br />\n      - peekFront<br />\n      - peekBack<br />\n      - clear<br />\n      - removeValue VALUE<br />\n      - countValue VALUE<br />\n      - findValue VALUE<br />\n      - insertAt INDEX VALUE<br />\n      - removeAt INDEX<br />\n      Lines starting with # are ignored.<br />\n      JSON files store the deque array and max size.\n    </div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Deque Properties</legend>\n    <div>\n      <button id=\"sizeBtn\">Get Current Size</button>\n      <span id=\"sizeResult\"></span>\n    </div>\n    <div>\n      <button id=\"isEmptyBtn\">Is Empty?</button>\n      <span id=\"isEmptyResult\"></span>\n    </div>\n    <div>\n      <button id=\"isFullBtn\">Is Full?</button>\n      <span id=\"isFullResult\"></span>\n    </div>\n  </fieldset>\n</section>\n\n<script>\n(() => {\n  // Internal state\n  let deque = [];\n  let maxSize = 0; // 0 means unlimited\n\n  // DOM references\n  const maxSizeInput = document.getElementById('maxSizeInput');\n  const setMaxSizeButton = document.getElementById('setMaxSizeButton');\n\n  const pushFrontInput = document.getElementById('pushFrontInput');\n  const pushFrontBtn = document.getElementById('pushFrontBtn');\n  const pushBackInput = document.getElementById('pushBackInput');\n  const pushBackBtn = document.getElementById('pushBackBtn');\n\n  const popFrontBtn = document.getElementById('popFrontBtn');\n  const popBackBtn = document.getElementById('popBackBtn');\n\n  const peekFrontBtn = document.getElementById('peekFrontBtn');\n  const peekBackBtn = document.getElementById('peekBackBtn');\n\n  const clearBtn = document.getElementById('clearBtn');\n\n  const removeValueInput = document.getElementById('removeValueInput');\n  const removeValueBtn = document.getElementById('removeValueBtn');\n\n  const countValueInput = document.getElementById('countValueInput');\n  const countValueBtn = document.getElementById('countValueBtn');\n  const countValueResult = document.getElementById('countValueResult');\n\n  const findValueInput = document.getElementById('findValueInput');\n  const findValueBtn = document.getElementById('findValueBtn');\n  const findValueResult = document.getElementById('findValueResult');\n\n  const insertAtIndexInput = document.getElementById('insertAtIndexInput');\n  const insertAtValueInput = document.getElementById('insertAtValueInput');\n  const insertAtBtn = document.getElementById('insertAtBtn');\n\n  const removeAtIndexInput = document.getElementById('removeAtIndexInput');\n  const removeAtBtn = document.getElementById('removeAtBtn');\n\n  const dequeDisplay = document.getElementById('dequeDisplay');\n  const interactionLog = document.getElementById('interactionLog');\n  const clearLogBtn = document.getElementById('clearLogBtn');\n\n  const batchInput = document.getElementById('batchInput');\n  const runBatchBtn = document.getElementById('runBatchBtn');\n  const loadJsonBtn = document.getElementById('loadJsonBtn');\n  const loadJsonFile = document.getElementById('loadJsonFile');\n  const saveJsonBtn = document.getElementById('saveJsonBtn');\n\n  const sizeBtn = document.getElementById('sizeBtn');\n  const sizeResult = document.getElementById('sizeResult');\n\n  const isEmptyBtn = document.getElementById('isEmptyBtn');\n  const isEmptyResult = document.getElementById('isEmptyResult');\n\n  const isFullBtn = document.getElementById('isFullBtn');\n  const isFullResult = document.getElementById('isFullResult');\n\n  // Utility to log interaction\n  function log(msg, type = \"info\") {\n    const timestamp = new Date().toLocaleTimeString();\n    interactionLog.value += `[${timestamp}] ${msg}\\n`;\n    interactionLog.scrollTop = interactionLog.scrollHeight;\n  }\n  // Utility for error\n  function error(msg) {\n    log(\"ERROR: \" + msg, \"error\");\n    alert(\"ERROR: \" + msg);\n  }\n\n  // Update Display and clearing auxiliary UI results\n  function updateDisplay() {\n    dequeDisplay.innerHTML = '';\n    if (deque.length === 0) {\n      dequeDisplay.textContent = \"(empty)\";\n    } else {\n      for (let i = 0; i < deque.length; i++) {\n        const span = document.createElement('span');\n        span.className = 'deque-item';\n        span.textContent = deque[i];\n        span.title = `Index ${i}`;\n        dequeDisplay.appendChild(span);\n      }\n    }\n    // Clear auxiliary results:\n    countValueResult.textContent = '';\n    findValueResult.textContent = '';\n    sizeResult.textContent = '';\n    isEmptyResult.textContent = '';\n    isFullResult.textContent = '';\n  }\n\n  // Check if full\n  function isFull() {\n    return maxSize > 0 && deque.length >= maxSize;\n  }\n\n  // API operations with checks and logging\n  function pushFront(value) {\n    if (value === '') {\n      error('Cannot push empty value.');\n      return;\n    }\n    if (isFull()) {\n      error('Deque is full. Cannot push.');\n      return;\n    }\n    deque.unshift(value);\n    log(`pushFront(\"${value}\")`);\n    updateDisplay();\n  }\n\n  function pushBack(value) {\n    if (value === '') {\n      error('Cannot push empty value.');\n      return;\n    }\n    if (isFull()) {\n      error('Deque is full. Cannot push.');\n      return;\n    }\n    deque.push(value);\n    log(`pushBack(\"${value}\")`);\n    updateDisplay();\n  }\n\n  function popFront() {\n    if (deque.length === 0) {\n      error('Deque is empty. Cannot pop front.');\n      return null;\n    }\n    const val = deque.shift();\n    log(`popFront() => \"${val}\"`);\n    updateDisplay();\n    return val;\n  }\n\n  function popBack() {\n    if (deque.length === 0) {\n      error('Deque is empty. Cannot pop back.');\n      return null;\n    }\n    const val = deque.pop();\n    log(`popBack() => \"${val}\"`);\n    updateDisplay();\n    return val;\n  }\n\n  function peekFront() {\n    if (deque.length === 0) {\n      error('Deque is empty. Cannot peek front.');\n      return null;\n    }\n    const val = deque[0];\n    log(`peekFront() => \"${val}\"`);\n    return val;\n  }\n\n  function peekBack() {\n    if (deque.length === 0) {\n      error('Deque is empty. Cannot peek back.');\n      return null;\n    }\n    const val = deque[deque.length - 1];\n    log(`peekBack() => \"${val}\"`);\n    return val;\n  }\n\n  function clearDeque() {\n    deque = [];\n    log('clear() - Deque emptied');\n    updateDisplay();\n  }\n\n  function removeAllOccurrences(value) {\n    if (value === '') {\n      error('Cannot remove empty value.');\n      return;\n    }\n    const originalLength = deque.length;\n    deque = deque.filter(el => el !== value);\n    const removedCount = originalLength - deque.length;\n    log(`removeValue(\"${value}\") - removed ${removedCount} occurrence(s).`);\n    updateDisplay();\n  }\n\n  function countOccurrences(value) {\n    if (value === '') {\n      error('Cannot count empty value.');\n      return 0;\n    }\n    const count = deque.reduce((acc, el) => (el === value ? acc + 1 : acc), 0);\n    log(`countValue(\"${value}\") => ${count}`);\n    return count;\n  }\n\n  function findFirstIndex(value) {\n    if (value === '') {\n      error('Cannot find index of empty value.');\n      return -1;\n    }\n    const idx = deque.indexOf(value);\n    if (idx === -1) {\n      log(`findValue(\"${value}\") => not found`);\n    } else {\n      log(`findValue(\"${value}\") => index ${idx}`);\n    }\n    return idx;\n  }\n\n  function insertAt(index, value) {\n    if (value === '') {\n      error('Cannot insert empty value.');\n      return;\n    }\n    if (!Number.isInteger(index) || index < 0 || index > deque.length) {\n      error(`Invalid index for insert: ${index}`);\n      return;\n    }\n    if (isFull()) {\n      error('Deque is full. Cannot insert.');\n      return;\n    }\n    deque.splice(index, 0, value);\n    log(`insertAt(index=${index}, value=\"${value}\")`);\n    updateDisplay();\n  }\n\n  function removeAt(index) {\n    if (!Number.isInteger(index) || index < 0 || index >= deque.length) {\n      error(`Invalid index for remove: ${index}`);\n      return null;\n    }\n    const removed = deque.splice(index, 1)[0];\n    log(`removeAt(index=${index}) => \"${removed}\"`);\n    updateDisplay();\n    return removed;\n  }\n\n  // Event listeners setup\n\n  setMaxSizeButton.addEventListener('click', () => {\n    let val = parseInt(maxSizeInput.value, 10);\n    if (isNaN(val) || val < 0) {\n      error('Maximum size must be a non-negative integer.');\n      return;\n    }\n    if (val > 0 && deque.length > val) {\n      error(`Current deque size (${deque.length}) is bigger than new max size (${val}). Clear or reduce deque first.`);\n      return;\n    }\n    maxSize = val;\n    log(`Max size set to ${maxSize === 0 ? 'unlimited' : maxSize}`);\n  });\n\n  pushFrontBtn.addEventListener('click', () => {\n    pushFront(pushFrontInput.value.trim());\n    pushFrontInput.value = '';\n  });\n\n  pushBackBtn.addEventListener('click', () => {\n    pushBack(pushBackInput.value.trim());\n    pushBackInput.value = '';\n  });\n\n  popFrontBtn.addEventListener('click', () => {\n    const v = popFront();\n    if (v !== null) alert(`Popped front: \"${v}\"`);\n  });\n\n  popBackBtn.addEventListener('click', () => {\n    const v = popBack();\n    if (v !== null) alert(`Popped back: \"${v}\"`);\n  });\n\n  peekFrontBtn.addEventListener('click', () => {\n    const v = peekFront();\n    if (v !== null) alert(`Front element: \"${v}\"`);\n  });\n\n  peekBackBtn.addEventListener('click', () => {\n    const v = peekBack();\n    if (v !== null) alert(`Back element: \"${v}\"`);\n  });\n\n  clearBtn.addEventListener('click', () => {\n    clearDeque();\n  });\n\n  removeValueBtn.addEventListener('click', () => {\n    removeAllOccurrences(removeValueInput.value.trim());\n    removeValueInput.value = '';\n  });\n\n  countValueBtn.addEventListener('click', () => {\n    const value = countValueInput.value.trim();\n    const count = countOccurrences(value);\n    countValueResult.textContent = `Count: ${count}`;\n  });\n\n  findValueBtn.addEventListener('click', () => {\n    const value = findValueInput.value.trim();\n    const idx = findFirstIndex(value);\n    if (idx === -1) {\n      findValueResult.textContent = 'Not found';\n    } else {\n      findValueResult.textContent = `Index: ${idx}`;\n    }\n  });\n\n  insertAtBtn.addEventListener('click', () => {\n    const idx = Number(insertAtIndexInput.value);\n    const val = insertAtValueInput.value.trim();\n    if (Number.isNaN(idx)) {\n      error('Insert index must be a number.');\n      return;\n    }\n    insertAt(idx, val);\n    insertAtIndexInput.value = '';\n    insertAtValueInput.value = '';\n  });\n\n  removeAtBtn.addEventListener('click', () => {\n    const idx = Number(removeAtIndexInput.value);\n    if (Number.isNaN(idx)) {\n      error('Remove index must be a number.');\n      return;\n    }\n    removeAt(idx);\n    removeAtIndexInput.value = '';\n  });\n\n  clearLogBtn.addEventListener('click', () => {\n    interactionLog.value = '';\n  });\n\n  // Batch commands parser and executor\n  function executeCommand(commandLine) {\n    const line = commandLine.trim();\n    if (line === '' || line.startsWith('#')) return; // skip empty or comments\n    const parts = line.split(/\\s+/);\n    const cmd = parts[0].toLowerCase();\n\n    try {\n      switch (cmd) {\n        case 'pushfront': {\n          if (parts.length < 2) throw 'pushFront requires a value argument.';\n          const val = line.substring(line.indexOf(' ') + 1);\n          pushFront(val);\n          break;\n        }\n        case 'pushback': {\n          if (parts.length < 2) throw 'pushBack requires a value argument.';\n          const val = line.substring(line.indexOf(' ') + 1);\n          pushBack(val);\n          break;\n        }\n        case 'popfront':\n          popFront();\n          break;\n        case 'popback':\n          popBack();\n          break;\n        case 'peekfront': {\n          const v = peekFront();\n          if (v !== null) alert(`Front element: \"${v}\"`);\n          break;\n        }\n        case 'peekback': {\n          const v = peekBack();\n          if (v !== null) alert(`Back element: \"${v}\"`);\n          break;\n        }\n        case 'clear':\n          clearDeque();\n          break;\n        case 'removevalue': {\n          if (parts.length < 2) throw 'removeValue requires a value argument.';\n          const val = line.substring(line.indexOf(' ') + 1);\n          removeAllOccurrences(val);\n          break;\n        }\n        case 'countvalue': {\n          if (parts.length < 2) throw 'countValue requires a value argument.';\n          const val = line.substring(line.indexOf(' ') + 1);\n          const count = countOccurrences(val);\n          alert(`Count of \"${val}\": ${count}`);\n          break;\n        }\n        case 'findvalue': {\n          if (parts.length < 2) throw 'findValue requires a value argument.';\n          const val = line.substring(line.indexOf(' ') + 1);\n          const idx = findFirstIndex(val);\n          alert(idx === -1 ? `\"${val}\" not found` : `\"${val}\" found at index ${idx}`);\n          break;\n        }\n        case 'insertat': {\n          if (parts.length < 3) throw 'insertAt requires index and value arguments.';\n          const idx = Number(parts[1]);\n          if (Number.isNaN(idx)) throw 'Invalid index for insertAt.';\n          const val = line.substring(line.indexOf(parts[2]));\n          insertAt(idx, val);\n          break;\n        }\n        case 'removeat': {\n          if (parts.length < 2) throw 'removeAt requires an index argument.';\n          const idx = Number(parts[1]);\n          if (Number.isNaN(idx)) throw 'Invalid index for removeAt.';\n          removeAt(idx);\n          break;\n        }\n        default:\n          throw `Unknown command: ${cmd}`;\n      }\n    } catch (err) {\n      error('Batch command error: ' + err);\n    }\n  }\n\n  runBatchBtn.addEventListener('click', () => {\n    const lines = batchInput.value.split('\\n');\n    log('Running batch commands...');\n    lines.forEach(executeCommand);\n    updateDisplay();\n    log('Batch commands completed.');\n  });\n\n  // Persistence: save/load deque and maxSize as JSON\n\n  function saveToJson() {\n    const data = {\n      maxSize,\n      deque,\n    };\n    const json = JSON.stringify(data, null, 2);\n    const blob = new Blob([json], { type: 'application/json' });\n    const url = URL.createObjectURL(blob);\n\n    const a = document.createElement('a');\n    a.href = url;\n    a.download = 'deque_state.json';\n    a.style.display = 'none';\n    document.body.appendChild(a);\n    a.click();\n    setTimeout(() => {\n      URL.revokeObjectURL(url);\n      document.body.removeChild(a);\n    }, 0);\n    log('Deque saved to JSON file.');\n  }\n\n  function loadFromJson(file) {\n    const reader = new FileReader();\n    reader.onload = (e) => {\n      try {\n        const data = JSON.parse(e.target.result);\n        if (!Array.isArray(data.deque) || typeof data.maxSize !== 'number') {\n          error('JSON file missing required deque structure.');\n          return;\n        }\n        if (data.maxSize > 0 && data.deque.length > data.maxSize) {\n          error('Deque size in file exceeds maxSize limit.');\n          return;\n        }\n        deque = data.deque;\n        maxSize = data.maxSize;\n        maxSizeInput.value = maxSize;\n        log('Deque loaded from JSON file.');\n        updateDisplay();\n      } catch {\n        error('Failed to parse JSON file.');\n      }\n    };\n    reader.readAsText(file);\n  }\n\n  saveJsonBtn.addEventListener('click', saveToJson);\n\n  loadJsonBtn.addEventListener('click', () => {\n    loadJsonFile.value = '';\n    loadJsonFile.click();\n  });\n\n  loadJsonFile.addEventListener('change', (e) => {\n    if (e.target.files.length === 0) {\n      error('No file selected.');\n      return;\n    }\n    const file = e.target.files[0];\n    loadFromJson(file);\n  });\n\n  // Properties buttons\n\n  sizeBtn.addEventListener('click', () => {\n    sizeResult.textContent = deque.length.toString();\n    log(`size() => ${deque.length}`);\n  });\n\n  isEmptyBtn.addEventListener('click', () => {\n    const empty = deque.length === 0;\n    isEmptyResult.textContent = empty ? 'Yes' : 'No';\n    log(`isEmpty() => ${empty}`);\n  });\n\n  isFullBtn.addEventListener('click', () => {\n    const full = isFull();\n    isFullResult.textContent = full ? 'Yes' : 'No';\n    log(`isFull() => ${full}`);\n  });\n\n  // Initial display\n  updateDisplay();\n})();\n</script>\n</body>\n</html>"
  },
