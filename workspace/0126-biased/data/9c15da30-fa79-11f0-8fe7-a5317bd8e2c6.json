  "question": "HTTP",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>HTTP Explorer - Interactive Demo</title>\n  <style>\n    /* Very minimal layout only to keep things usable.\n       No colors, no animations, just basic spacing. */\n    body { font-family: sans-serif; margin: 10px; }\n    section { border: 1px solid #000; padding: 8px; margin-bottom: 10px; }\n    label { display: inline-block; min-width: 80px; }\n    .row { margin: 6px 0; }\n    .controls { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }\n    textarea, input[type=\"text\"], select { min-width: 300px; }\n    pre { white-space: pre-wrap; word-wrap: break-word; border: 1px solid #000; padding: 6px; }\n    button { margin-right: 6px; }\n    .small { font-size: 12px; }\n    .panel { margin-top: 6px; padding: 6px; border: 1px dashed #000; }\n    .flex { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n    .step { border: 1px solid #000; padding: 6px; margin: 4px 0; }\n    .step.disabled { opacity: 0.5; }\n  </style>\n</head>\n<body>\n  <h1>HTTP Explorer (interactive)</h1>\n\n  <section id=\"modeSection\">\n    <strong>Mode</strong>\n    <div class=\"row controls\">\n      <label><input type=\"radio\" name=\"mode\" value=\"live\" checked> Live</label>\n      <label><input type=\"radio\" name=\"mode\" value=\"sim\"> Simulated</label>\n      <label><input type=\"checkbox\" id=\"followRedirects\" checked> Follow redirects</label>\n      <label>Timeout (ms): <input type=\"number\" id=\"timeout\" value=\"15000\" style=\"width:100px\"></label>\n      <label>Network delay (sim ms): <input type=\"range\" id=\"simDelay\" min=\"0\" max=\"5000\" value=\"200\"> <span id=\"simDelayLabel\">200</span></label>\n    </div>\n  </section>\n\n  <section id=\"requestBuilder\">\n    <strong>Request Builder</strong>\n    <div class=\"row controls\">\n      <label>Method</label>\n      <select id=\"method\">\n        <option>GET</option><option>POST</option><option>PUT</option><option>PATCH</option><option>DELETE</option><option>HEAD</option><option>OPTIONS</option>\n      </select>\n\n      <label>URL</label>\n      <input type=\"text\" id=\"url\" placeholder=\"https://api.example.com/resource\">\n\n      <label>Body type</label>\n      <select id=\"bodyType\">\n        <option value=\"none\">none</option>\n        <option value=\"raw\">raw</option>\n        <option value=\"json\">JSON</option>\n        <option value=\"form\">form-urlencoded</option>\n      </select>\n    </div>\n\n    <div class=\"panel\">\n      <div><strong>Query Parameters</strong> <button id=\"addQuery\">Add</button></div>\n      <div id=\"queryList\"></div>\n    </div>\n\n    <div class=\"panel\">\n      <div><strong>Headers</strong> <button id=\"addHeader\">Add</button></div>\n      <div id=\"headerList\"></div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"row\"><label>Auth</label>\n        <select id=\"authType\">\n          <option value=\"none\">None</option>\n          <option value=\"basic\">Basic</option>\n          <option value=\"bearer\">Bearer</option>\n          <option value=\"custom\">Custom header</option>\n        </select>\n      </div>\n      <div id=\"authPanel\"></div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"row\"><label>Body</label></div>\n      <textarea id=\"body\" rows=\"8\" placeholder='{\"key\":\"value\"}'></textarea>\n    </div>\n\n    <div class=\"row controls\">\n      <button id=\"sendBtn\">Send Request</button>\n      <button id=\"copyRequest\">Copy Raw Request</button>\n      <button id=\"saveVarFromRaw\">Save Response To Variable...</button>\n      <button id=\"examplesBtn\">Load Examples</button>\n    </div>\n\n  </section>\n\n  <section id=\"responseSection\">\n    <strong>Response</strong>\n    <div class=\"row\">\n      <label>Status:</label><span id=\"status\">-</span>\n      <label>Time (ms):</label><span id=\"time\">-</span>\n      <label>Size (bytes):</label><span id=\"size\">-</span>\n    </div>\n    <div class=\"row\">\n      <button id=\"toggleHeaders\">Show Headers</button>\n      <button id=\"togglePretty\">Toggle Pretty</button>\n      <button id=\"saveResponseFile\">Save Response to File</button>\n      <button id=\"clearResponse\">Clear</button>\n    </div>\n    <div id=\"responseHeaders\" style=\"display:none\" class=\"panel\"><pre id=\"headersPre\"></pre></div>\n    <div class=\"panel\">\n      <strong>Body</strong>\n      <pre id=\"bodyPre\">no response</pre>\n    </div>\n  </section>\n\n  <section id=\"variablesSection\">\n    <strong>Variables</strong>\n    <div class=\"row\">\n      <button id=\"showVars\">Show Variables</button>\n      <button id=\"clearVars\">Clear Variables</button>\n      <button id=\"exportVars\">Export Variables</button>\n      <button id=\"importVars\">Import Variables</button>\n    </div>\n    <pre id=\"varsPre\">{}</pre>\n  </section>\n\n  <section id=\"workflowSection\">\n    <strong>Workflow Builder</strong>\n    <div class=\"row controls\">\n      <button id=\"addStepBtn\">Add Step From Builder</button>\n      <button id=\"addManualStep\">Add Blank Step</button>\n      <button id=\"runWorkflow\">Run Workflow</button>\n      <label>Mode</label>\n      <select id=\"workflowMode\">\n        <option value=\"sequential\">Sequential</option>\n        <option value=\"parallel\">Parallel (concurrency)</option>\n      </select>\n      <label>Concurrency</label>\n      <input type=\"range\" id=\"concurrency\" min=\"1\" max=\"10\" value=\"3\"><span id=\"conLabel\">3</span>\n      <label><input type=\"checkbox\" id=\"stepThrough\"> Step-through</label>\n    </div>\n\n    <div id=\"stepsList\"></div>\n\n    <div class=\"panel\">\n      <div class=\"row\">\n        <label>Import/Export Workflow</label>\n        <button id=\"exportWorkflow\">Export</button>\n        <button id=\"importWorkflow\">Import</button>\n        <input type=\"file\" id=\"workflowFile\" style=\"display:none\">\n      </div>\n      <div class=\"row\">\n        <strong>Logs</strong> <input id=\"logFilter\" placeholder=\"filter text\">\n      </div>\n      <pre id=\"workflowLog\" style=\"height:200px; overflow:auto;\"></pre>\n    </div>\n  </section>\n\n  <section id=\"scriptSection\">\n    <strong>Script Runner (sandboxed helpers)</strong>\n    <div class=\"row\">\n      <textarea id=\"scriptArea\" rows=\"6\">// access 'vars' object and helpers:\n // console.log(\"vars\", vars);\n // await httpRequest(step) -> returns response object\n</textarea>\n    </div>\n    <div class=\"row\">\n      <button id=\"runScript\">Run Script</button>\n      <button id=\"clearScriptLog\">Clear Script Log</button>\n    </div>\n    <pre id=\"scriptLog\"></pre>\n  </section>\n\n  <section id=\"simRulesSection\">\n    <strong>Simulation Rules</strong>\n    <div class=\"row\">\n      <button id=\"addSimRule\">Add Rule</button>\n      <button id=\"clearSimRules\">Clear Rules</button>\n    </div>\n    <div id=\"simRulesList\"></div>\n  </section>\n\n  <section>\n    <strong>Quick Help & Examples</strong>\n    <div class=\"row\">\n      <button id=\"exampleGet\">Example: GET JSON</button>\n      <button id=\"examplePost\">Example: POST JSON</button>\n      <button id=\"exampleAuth\">Example: Login -> Get (chain)</button>\n    </div>\n    <div class=\"row small\">Placeholders: use {{varName}} in URL, headers, or body to substitute variables captured during workflow steps.</div>\n  </section>\n\n<script>\n(function(){\n  // Simple state\n  const state = {\n    mode: 'live',\n    simDelay: 200,\n    followRedirects: true,\n    timeout: 15000,\n    vars: {},\n    lastResponse: null,\n    simRules: [],\n    workflow: []\n  };\n\n  // Utilities\n  function qs(id){ return document.getElementById(id); }\n  function el(tag, text){ const e = document.createElement(tag); if(text) e.textContent=text; return e; }\n  function now(){ return new Date().getTime(); }\n  function safeJsonParse(s){ try { return JSON.parse(s); } catch(e){ return null; } }\n\n  // UI refs\n  const modeRadios = document.querySelectorAll('input[name=\"mode\"]');\n  const simDelay = qs('simDelay');\n  const simDelayLabel = qs('simDelayLabel');\n  const timeoutInput = qs('timeout');\n  const followRedirectsBox = qs('followRedirects');\n\n  const methodInput = qs('method');\n  const urlInput = qs('url');\n  const bodyType = qs('bodyType');\n  const bodyInput = qs('body');\n  const headerList = qs('headerList');\n  const queryList = qs('queryList');\n  const addHeaderBtn = qs('addHeader');\n  const addQueryBtn = qs('addQuery');\n  const authType = qs('authType');\n  const authPanel = qs('authPanel');\n\n  const sendBtn = qs('sendBtn');\n  const copyReqBtn = qs('copyRequest');\n  const saveVarFromRawBtn = qs('saveVarFromRaw');\n  const examplesBtn = qs('examplesBtn');\n\n  const statusSpan = qs('status');\n  const timeSpan = qs('time');\n  const sizeSpan = qs('size');\n  const bodyPre = qs('bodyPre');\n  const headersPre = qs('headersPre');\n  const toggleHeadersBtn = qs('toggleHeaders');\n  const togglePrettyBtn = qs('togglePretty');\n  const saveRespFileBtn = qs('saveResponseFile');\n  const clearRespBtn = qs('clearResponse');\n\n  const showVarsBtn = qs('showVars');\n  const clearVarsBtn = qs('clearVars');\n  const exportVarsBtn = qs('exportVars');\n  const importVarsBtn = qs('importVars');\n  const varsPre = qs('varsPre');\n\n  const addStepBtn = qs('addStepBtn');\n  const addManualStepBtn = qs('addManualStep');\n  const stepsList = qs('stepsList');\n  const runWorkflowBtn = qs('runWorkflow');\n  const workflowLog = qs('workflowLog');\n  const workflowMode = qs('workflowMode');\n  const concurrencyRange = qs('concurrency');\n  const conLabel = qs('conLabel');\n  const stepThrough = qs('stepThrough');\n  const exportWorkflowBtn = qs('exportWorkflow');\n  const importWorkflowBtn = qs('importWorkflow');\n  const workflowFileInput = qs('workflowFile');\n  const logFilterInput = qs('logFilter');\n\n  const scriptArea = qs('scriptArea');\n  const runScriptBtn = qs('runScript');\n  const scriptLog = qs('scriptLog');\n  const clearScriptLogBtn = qs('clearScriptLog');\n\n  const simRulesList = qs('simRulesList');\n  const addSimRuleBtn = qs('addSimRule');\n  const clearSimRulesBtn = qs('clearSimRules');\n\n  const exampleGetBtn = qs('exampleGet');\n  const examplePostBtn = qs('examplePost');\n  const exampleAuthBtn = qs('exampleAuth');\n\n  // Init UI small handlers\n  modeRadios.forEach(r => r.addEventListener('change', ()=> {\n    state.mode = document.querySelector('input[name=\"mode\"]:checked').value;\n    logSys('Mode set to: ' + state.mode);\n  }));\n  simDelay.addEventListener('input', ()=> { simDelayLabel.textContent = simDelay.value; state.simDelay = Number(simDelay.value); });\n  timeoutInput.addEventListener('change', ()=> { state.timeout = Number(timeoutInput.value); });\n  followRedirectsBox.addEventListener('change', ()=> { state.followRedirects = followRedirectsBox.checked; });\n\n  concurrencyRange.addEventListener('input', ()=> { conLabel.textContent = concurrencyRange.value; });\n\n  // Headers and Queries dynamic editors\n  function createKeyValueRow(container, key='', value='', onRemove){\n    const row = el('div');\n    const keyIn = el('input'); keyIn.type='text'; keyIn.value=key; keyIn.placeholder='key';\n    const valIn = el('input'); valIn.type='text'; valIn.value=value; valIn.placeholder='value';\n    const enabled = el('input'); enabled.type='checkbox'; enabled.checked=true;\n    const remove = el('button'); remove.textContent='Remove';\n    remove.addEventListener('click', ()=>{ container.removeChild(row); if(onRemove) onRemove(); });\n    row.appendChild(enabled);\n    row.appendChild(keyIn);\n    row.appendChild(valIn);\n    row.appendChild(remove);\n    container.appendChild(row);\n    return {row, keyIn, valIn, enabled};\n  }\n\n  addHeaderBtn.addEventListener('click', ()=> createKeyValueRow(headerList, 'Content-Type','application/json'));\n  addQueryBtn.addEventListener('click', ()=> createKeyValueRow(queryList, 'q',''));\n  // start with a common header row\n  createKeyValueRow(headerList, 'Accept','application/json');\n  createKeyValueRow(queryList, 'lang','en');\n\n  // Auth panel\n  function refreshAuthPanel(){\n    authPanel.innerHTML='';\n    const t = authType.value;\n    if(t==='basic'){\n      const user = el('input'); user.placeholder='username'; const pass = el('input'); pass.placeholder='password'; pass.type='password';\n      authPanel.appendChild(user); authPanel.appendChild(pass);\n    } else if(t==='bearer'){\n      const token = el('input'); token.placeholder='token';\n      authPanel.appendChild(token);\n    } else if(t==='custom'){\n      const name = el('input'); name.placeholder='Header-Name'; const val = el('input'); val.placeholder='value';\n      authPanel.appendChild(name); authPanel.appendChild(val);\n    }\n  }\n  authType.addEventListener('change', refreshAuthPanel);\n  refreshAuthPanel();\n\n  // Build raw request text\n  function buildRequestObjectFromBuilder(){\n    const method = methodInput.value;\n    const url = urlInput.value.trim();\n    const qparams = [];\n    for(const row of queryList.children){\n      const inputs = row.querySelectorAll('input');\n      const enabled = inputs[0].checked;\n      const key = inputs[1].value;\n      const val = inputs[2].value;\n      if(enabled && key) qparams.push([key,val]);\n    }\n    const headers = {};\n    for(const row of headerList.children){\n      const inputs = row.querySelectorAll('input');\n      const enabled = inputs[0].checked;\n      const key = inputs[1].value;\n      const val = inputs[2].value;\n      if(enabled && key) headers[key] = val;\n    }\n    // auth\n    const auth = { type: authType.value };\n    if(auth.type === 'basic'){\n      const [userInput, passInput] = authPanel.querySelectorAll('input');\n      auth.user = userInput ? userInput.value : '';\n      auth.pass = passInput ? passInput.value : '';\n    } else if(auth.type === 'bearer'){\n      const tokenInput = authPanel.querySelector('input');\n      auth.token = tokenInput ? tokenInput.value : '';\n    } else if(auth.type === 'custom'){\n      const [nameInput, valInput] = authPanel.querySelectorAll('input');\n      auth.name = nameInput ? nameInput.value : '';\n      auth.value = valInput ? valInput.value : '';\n    }\n    const body = bodyInput.value;\n    const btype = bodyType.value;\n    return { method, url, qparams, headers, auth, body, btype, followRedirects: state.followRedirects, timeout: state.timeout };\n  }\n\n  // Replace placeholders {{var}} using state.vars\n  function substituteTemplates(s, vars){\n    if(!s) return s;\n    return String(s).replace(/\\{\\{([^}]+)\\}\\}/g, (m,k)=>{\n      const val = getNestedVar(vars,k.trim());\n      return (val===undefined || val===null) ? '' : String(val);\n    });\n  }\n  function getNestedVar(vars, path){\n    // support dot paths a.b[0].c\n    try {\n      const parts = path.split('.').map(p=>p.trim()).filter(Boolean);\n      let cur = vars;\n      for(let p of parts){\n        if(Array.isArray(cur) && p.match(/^\\d+$/)){\n          cur = cur[Number(p)];\n        } else {\n          cur = cur[p];\n        }\n        if(cur===undefined) return undefined;\n      }\n      return cur;\n    } catch(e){ return undefined; }\n  }\n\n  // Build final fetch Request init and URL\n  function buildFetchRequest(req){\n    // apply template substitution\n    let url = substituteTemplates(req.url, state.vars);\n    // append query params\n    if(req.qparams && req.qparams.length){\n      const q = req.qparams.map(([k,v]) => encodeURIComponent(k) + '=' + encodeURIComponent(substituteTemplates(v, state.vars))).join('&');\n      if(url.includes('?')) url += '&' + q; else url += '?' + q;\n    }\n    const headers = new Headers();\n    for(const k of Object.keys(req.headers || {})){\n      headers.set(k, substituteTemplates(req.headers[k], state.vars));\n    }\n    // auth\n    if(req.auth){\n      if(req.auth.type==='basic'){\n        const token = btoa((req.auth.user||'') + ':' + (req.auth.pass||''));\n        headers.set('Authorization','Basic '+token);\n      } else if(req.auth.type==='bearer'){\n        headers.set('Authorization','Bearer '+(req.auth.token||''));\n      } else if(req.auth.type==='custom'){\n        if(req.auth.name) headers.set(req.auth.name, substituteTemplates(req.auth.value||'', state.vars));\n      }\n    }\n    let body = null;\n    if(req.btype && req.btype !== 'none'){\n      if(req.btype === 'json'){\n        headers.set('Content-Type','application/json');\n        body = req.body;\n      } else if(req.btype === 'form'){\n        headers.set('Content-Type','application/x-www-form-urlencoded');\n        body = req.body;\n      } else {\n        body = req.body;\n      }\n    }\n    const init = {\n      method: req.method,\n      headers: headers,\n      body: (['GET','HEAD'].includes(req.method)) ? undefined : body,\n      redirect: req.followRedirects ? 'follow' : 'manual'\n    };\n    return { url, init };\n  }\n\n  // Simulated HTTP engine\n  function matchSimRule(url, method){\n    for(const r of state.simRules){\n      try {\n        const m = new RegExp(r.pattern);\n        if(m.test(url) && (r.method==='' || r.method===method)) return r;\n      } catch(e){ continue; }\n    }\n    return null;\n  }\n\n  async function simulatedFetch(req){\n    const { url, init } = buildFetchRequest(req);\n    const rule = matchSimRule(url, req.method);\n    await delay(state.simDelay || 0);\n    if(!rule){\n      // default synthetic response\n      const body = JSON.stringify({ message: 'simulated response', url, method: req.method, vars: state.vars }, null, 2);\n      return makeResponse(200, {'content-type':'application/json'}, body);\n    }\n    // apply rule\n    const status = Number(rule.status) || 200;\n    const headers = {};\n    if(rule.headers){\n      try {\n        const parsed = JSON.parse(rule.headers);\n        Object.assign(headers, parsed);\n      } catch(e){\n        // parse simple header lines \"Key: Value\"\n        const lines = rule.headers.split('\\n');\n        lines.forEach(line=>{\n          const i = line.indexOf(':');\n          if(i>0){ headers[line.slice(0,i).trim().toLowerCase()] = line.slice(i+1).trim(); }\n        });\n      }\n    }\n    let body = rule.body || '';\n    // allow templates in body to include {{url}} or {{method}}\n    body = body.replace(/\\{\\{url\\}\\}/g, url).replace(/\\{\\{method\\}\\}/g, req.method);\n    // allow returning JSON with injected variables\n    if(rule.isJson) {\n      try { body = JSON.stringify(JSON.parse(body), null, 2); } catch(e){}\n    }\n    // simulate errors\n    if(rule.failType === 'timeout'){\n      await delay(10000);\n      throw new Error('Simulated timeout');\n    }\n    if(rule.failType === 'network'){\n      throw new Error('Simulated network error');\n    }\n    await delay(Number(rule.delay||0));\n    return makeResponse(status, headers, body);\n  }\n\n  function makeResponse(status, headers, body){\n    return {\n      ok: status>=200 && status<300,\n      status,\n      headers: new Map(Object.entries(headers || {})),\n      text: async ()=> body,\n      json: async ()=> {\n        try { return JSON.parse(body); } catch(e){ throw new Error('Invalid JSON'); }\n      }\n    };\n  }\n\n  function delay(ms){ return new Promise(res=>setTimeout(res, ms)); }\n\n  // Real fetch wrapper with timeout and minimal error handling\n  async function realFetchRequest(req){\n    const { url, init } = buildFetchRequest(req);\n    const controller = new AbortController();\n    const id = setTimeout(()=>controller.abort(), req.timeout || state.timeout);\n    init.signal = controller.signal;\n    const start = now();\n    try {\n      const resp = await fetch(url, init);\n      clearTimeout(id);\n      const elapsed = now() - start;\n      const headersObj = {};\n      try {\n        resp.headers.forEach((v,k)=>{ headersObj[k]=v; });\n      } catch(e){}\n      const text = await resp.text();\n      return { ok: resp.ok, status: resp.status, headers: headersObj, text, elapsed, size: text.length };\n    } catch (err){\n      clearTimeout(id);\n      throw err;\n    }\n  }\n\n  // Unified sendRequest used by builder/workflow/script\n  async function sendRequest(req, opts={}) {\n    const start = now();\n    if(state.mode === 'sim') {\n      const resp = await simulatedFetch(req);\n      const text = await resp.text();\n      const elapsed = now() - start;\n      return { ok: resp.ok, status: resp.status, headers: Object.fromEntries(resp.headers), text, elapsed, size: text.length };\n    } else {\n      // real fetch\n      try {\n        const r = await realFetchRequest(req);\n        return r;\n      } catch(e){\n        throw e;\n      }\n    }\n  }\n\n  // UI: send current builder request\n  sendBtn.addEventListener('click', async ()=>{\n    const req = buildRequestObjectFromBuilder();\n    setStatus('-', '-', 0);\n    bodyPre.textContent = 'sending...';\n    headersPre.textContent = '';\n    try {\n      const r = await sendRequest(req);\n      state.lastResponse = r;\n      setStatus(r.status, r.elapsed || r.time || '-', r.size || (r.text ? r.text.length : 0));\n      headersPre.textContent = JSON.stringify(r.headers||{}, null, 2);\n      bodyPre.textContent = r.text || '';\n      logSys('Request sent | ' + req.method + ' ' + req.url + ' | status: ' + r.status);\n    } catch(e){\n      setStatus('ERR', '-', 0);\n      bodyPre.textContent = 'Error: ' + (e.message || e);\n      logSys('Request error: ' + (e.message || e));\n    }\n  });\n\n  function setStatus(status, time, size){\n    statusSpan.textContent = status;\n    timeSpan.textContent = time;\n    sizeSpan.textContent = size;\n  }\n\n  // copy raw request text\n  copyReqBtn.addEventListener('click', ()=>{\n    const req = buildRequestObjectFromBuilder();\n    const {url, init} = buildFetchRequest(req);\n    const lines = [];\n    lines.push(req.method + ' ' + url);\n    for(const [k,v] of init.headers.entries ? init.headers.entries() : Object.entries(req.headers || {})){\n      lines.push(k+': '+v);\n    }\n    if(req.body) {\n      lines.push('');\n      lines.push(req.body);\n    }\n    navigator.clipboard.writeText(lines.join('\\n')).then(()=> logSys('Request copied to clipboard'));\n  });\n\n  // save last response body to variable\n  saveVarFromRawBtn.addEventListener('click', async ()=>{\n    if(!state.lastResponse){ alert('No response yet'); return; }\n    const name = prompt('Variable name to save response text into:');\n    if(!name) return;\n    try {\n      state.vars[name] = safeJsonParse(state.lastResponse.text) || state.lastResponse.text;\n      refreshVarsUI();\n      logSys('Saved last response into variable: ' + name);\n    } catch(e){ alert('Error saving variable'); }\n  });\n\n  // response toggles\n  toggleHeadersBtn.addEventListener('click', ()=> {\n    qs('responseHeaders').style.display = qs('responseHeaders').style.display === 'none' ? 'block' : 'none';\n  });\n  togglePrettyBtn.addEventListener('click', ()=> {\n    if(!state.lastResponse) return;\n    const parsed = safeJsonParse(state.lastResponse.text);\n    if(parsed) bodyPre.textContent = JSON.stringify(parsed, null, 2);\n    else bodyPre.textContent = state.lastResponse.text;\n  });\n  saveRespFileBtn.addEventListener('click', ()=> {\n    if(!state.lastResponse) return;\n    const blob = new Blob([state.lastResponse.text], {type:'text/plain'});\n    const url = URL.createObjectURL(blob);\n    const a = el('a'); a.href = url; a.download = 'response.txt'; document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n  });\n  clearRespBtn.addEventListener('click', ()=> {\n    state.lastResponse = null;\n    bodyPre.textContent = 'no response';\n    headersPre.textContent = '';\n    setStatus('-', '-', 0);\n  });\n\n  // Variables UI\n  function refreshVarsUI(){ varsPre.textContent = JSON.stringify(state.vars, null, 2); }\n  showVarsBtn.addEventListener('click', ()=> refreshVarsUI());\n  clearVarsBtn.addEventListener('click', ()=> { state.vars = {}; refreshVarsUI(); logSys('Variables cleared'); });\n  exportVarsBtn.addEventListener('click', ()=> {\n    const blob = new Blob([JSON.stringify(state.vars, null, 2)], {type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = el('a'); a.href = url; a.download = 'vars.json'; document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n  });\n  importVarsBtn.addEventListener('click', ()=> {\n    const t = prompt('Paste JSON for variables:');\n    if(!t) return;\n    try { state.vars = JSON.parse(t); refreshVarsUI(); logSys('Variables imported'); } catch(e){ alert('Invalid JSON'); }\n  });\n  refreshVarsUI();\n\n  // Workflow builder\n  function createStepElement(step){\n    const div = el('div'); div.className = 'step';\n    if(step.disabled) div.classList.add('disabled');\n    div.dataset.id = step.id;\n    const header = el('div'); header.className='flex';\n    const title = el('input'); title.value = step.name || ('Step ' + step.id);\n    const up = el('button'); up.textContent='↑';\n    const down = el('button'); down.textContent='↓';\n    const runNow = el('button'); runNow.textContent='Run';\n    const del = el('button'); del.textContent='Delete';\n    const enable = el('label'); const cb = el('input'); cb.type='checkbox'; cb.checked = !step.disabled; enable.appendChild(cb); enable.appendChild(document.createTextNode('enabled'));\n    header.appendChild(title); header.appendChild(up); header.appendChild(down); header.appendChild(runNow); header.appendChild(del); header.appendChild(enable);\n    div.appendChild(header);\n\n    // method/url/body preview\n    const mSelect = el('select'); ['GET','POST','PUT','PATCH','DELETE'].forEach(m=>{ const o=el('option'); o.value=o.textContent=m; if(m===step.request.method) o.selected=true; mSelect.appendChild(o); });\n    const urlIn = el('input'); urlIn.type='text'; urlIn.value = step.request.url;\n    const bodyIn = el('textarea'); bodyIn.rows=3; bodyIn.value = step.request.body || '';\n    const btypeSel = el('select'); ['none','raw','json','form'].forEach(opt=>{ const o=el('option'); o.value=o.textContent=opt; if(opt===step.request.btype) o.selected=true; btypeSel.appendChild(o); });\n\n    const headerEditor = el('div'); headerEditor.className='panel';\n    headerEditor.appendChild(el('div','Headers:'));\n    for(const k of Object.keys(step.request.headers||{})){\n      const v = step.request.headers[k];\n      const r = createKeyValueRow(headerEditor, k, v);\n      // no extra handlers needed\n    }\n    const queryEditor = el('div'); queryEditor.className='panel';\n    queryEditor.appendChild(el('div','Query Params:'));\n    for(const q of step.request.qparams || []){ createKeyValueRow(queryEditor, q[0], q[1]); }\n\n    const extractorPanel = el('div'); extractorPanel.className='panel';\n    extractorPanel.appendChild(el('div','Extractors (name -> path or regex): '));\n    const extractList = el('div');\n    extractorPanel.appendChild(extractList);\n    (step.extractors||[]).forEach(ex=>{\n      const r = el('div'); const nameIn = el('input'); nameIn.placeholder='varName'; nameIn.value = ex.name; const pathIn = el('input'); pathIn.placeholder='path or /regex/'; pathIn.value = ex.path; const rem = el('button'); rem.textContent='Remove';\n      rem.addEventListener('click', ()=> extractList.removeChild(r));\n      r.appendChild(nameIn); r.appendChild(pathIn); r.appendChild(rem); extractList.appendChild(r);\n    });\n    const addExtractorBtn = el('button'); addExtractorBtn.textContent='Add Extractor';\n    addExtractorBtn.addEventListener('click', ()=> {\n      const r = el('div'); const nameIn = el('input'); nameIn.placeholder='varName'; const pathIn = el('input'); pathIn.placeholder='path or /regex/'; const rem = el('button'); rem.textContent='Remove'; rem.addEventListener('click', ()=> extractList.removeChild(r));\n      r.appendChild(nameIn); r.appendChild(pathIn); r.appendChild(rem); extractList.appendChild(r);\n    });\n    extractorPanel.appendChild(addExtractorBtn);\n\n    // Condition\n    const condPanel = el('div'); condPanel.className='panel';\n    condPanel.appendChild(el('div','Condition (run step only if):'));\n    const condType = el('select');\n    ['none','lastStatusEquals','varEquals','bodyMatches'].forEach(c=>{ const o=el('option'); o.value=o.textContent=c; if(step.condition && step.condition.type===c) o.selected=true; condType.appendChild(o); });\n    const condInput = el('input'); condInput.type='text'; condInput.placeholder='value';\n    if(step.condition){\n      condInput.value = step.condition.value || '';\n    }\n    condPanel.appendChild(condType); condPanel.appendChild(condInput);\n\n    const footer = el('div'); footer.className='row controls';\n    footer.appendChild(mSelect); footer.appendChild(urlIn); footer.appendChild(btypeSel);\n    footer.appendChild(el('div','Body:')); footer.appendChild(bodyIn);\n\n    // Wire up controls\n    up.addEventListener('click', ()=> moveStep(step.id, -1));\n    down.addEventListener('click', ()=> moveStep(step.id, 1));\n    del.addEventListener('click', ()=> { removeStep(step.id); });\n    runNow.addEventListener('click', async ()=> {\n      const s = stepToObject(div);\n      await runSingleStep(s, { logPrefix: 'RunNow' });\n    });\n    cb.addEventListener('change', ()=> {\n      step.disabled = !cb.checked;\n      div.classList.toggle('disabled', step.disabled);\n    });\n\n    div.appendChild(headerEditor);\n    div.appendChild(queryEditor);\n    div.appendChild(extractorPanel);\n    div.appendChild(condPanel);\n    div.appendChild(footer);\n\n    function stepToObject(container){\n      // gather headers\n      const hdrs = {};\n      for(const r of headerEditor.querySelectorAll('div')){\n        const inputs = r.querySelectorAll('input');\n        if(inputs.length>=2){\n          const key = inputs[0].value;\n          const val = inputs[1].value;\n          if(key) hdrs[key]=val;\n        }\n      }\n      const qps = [];\n      for(const r of queryEditor.querySelectorAll('div')){\n        const inputs = r.querySelectorAll('input');\n        if(inputs.length>=2){\n          const key = inputs[0].value;\n          const val = inputs[1].value;\n          if(key) qps.push([key,val]);\n        }\n      }\n      const ext = [];\n      for(const r of extractList.querySelectorAll('div')){\n        const inputs = r.querySelectorAll('input');\n        if(inputs.length>=2){\n          const name = inputs[0].value;\n          const path = inputs[1].value;\n          if(name && path) ext.push({name,path});\n        }\n      }\n      const cond = { type: condType.value, value: condInput.value };\n      return {\n        id: step.id,\n        name: title.value,\n        disabled: !cb.checked,\n        request: { method: mSelect.value, url: urlIn.value, headers: hdrs, qparams: qps, btype: btypeSel.value, body: bodyIn.value },\n        extractors: ext,\n        condition: cond\n      };\n    }\n    div.getStepObject = ()=> stepToObject(div);\n    return div;\n  }\n\n  function addStep(stepObj){\n    state.workflow.push(stepObj);\n    renderSteps();\n  }\n  function renderSteps(){\n    stepsList.innerHTML = '';\n    state.workflow.forEach(s=>{\n      const el = createStepElement(s);\n      stepsList.appendChild(el);\n    });\n  }\n  function removeStep(id){\n    state.workflow = state.workflow.filter(s=>s.id!==id);\n    renderSteps();\n  }\n  function moveStep(id, dir){\n    const idx = state.workflow.findIndex(s=>s.id===id);\n    if(idx<0) return;\n    const to = idx+dir;\n    if(to<0 || to>=state.workflow.length) return;\n    const tmp = state.workflow[to];\n    state.workflow[to] = state.workflow[idx];\n    state.workflow[idx] = tmp;\n    renderSteps();\n  }\n\n  addStepBtn.addEventListener('click', ()=>{\n    const req = buildRequestObjectFromBuilder();\n    const step = {\n      id: Math.random().toString(36).slice(2,9),\n      name: req.method + ' ' + req.url,\n      disabled: false,\n      request: req,\n      extractors: [],\n      condition: { type: 'none', value: '' }\n    };\n    addStep(step);\n  });\n  addManualStepBtn.addEventListener('click', ()=>{\n    const step = {\n      id: Math.random().toString(36).slice(2,9),\n      name: 'New Step',\n      disabled: false,\n      request: { method: 'GET', url: '', headers: {}, qparams: [], btype: 'none', body: ''},\n      extractors: [],\n      condition: { type: 'none', value: '' }\n    };\n    addStep(step);\n  });\n\n  // Running workflow\n  function logSys(msg){\n    const time = new Date().toISOString();\n    workflowLog.textContent += '[' + time + '] ' + msg + '\\n';\n    workflowLog.scrollTop = workflowLog.scrollHeight;\n  }\n\n  async function runWorkflow(){\n    workflowLog.textContent = '';\n    // collect step objects from DOM\n    const stepEls = stepsList.querySelectorAll('.step');\n    const steps = Array.from(stepEls).map(se => se.getStepObject ? se.getStepObject() : null).filter(Boolean);\n    // apply if disabled\n    const mode = workflowMode.value;\n    const concurrency = Number(concurrencyRange.value);\n    logSys('Starting workflow: mode=' + mode + ' steps=' + steps.length);\n    if(mode === 'sequential'){\n      for(const s of steps){\n        if(s.disabled) { logSys('Skipping disabled: ' + s.name); continue; }\n        // condition check\n        if(!checkCondition(s.condition)){ logSys('Condition failed, skipping: ' + s.name); continue; }\n        const cont = stepThrough.checked ? await stepControl('next') : true;\n        if(!cont) { logSys('Execution stopped by user'); break; }\n        await runSingleStep(s, { logPrefix: 'STEP' });\n      }\n    } else {\n      // parallel with concurrency\n      const queue = steps.slice();\n      let running = 0;\n      const promises = [];\n      async function runNext(){\n        if(queue.length===0) return;\n        if(running >= concurrency) return;\n        const s = queue.shift();\n        if(s.disabled){ logSys('Skipping disabled: ' + s.name); return runNext(); }\n        if(!checkCondition(s.condition)){ logSys('Condition failed, skipping: ' + s.name); return runNext(); }\n        running++;\n        try {\n          await runSingleStep(s,{ logPrefix: 'PAR' });\n        } catch(e){ logSys('Step error: ' + e.message); }\n        running--;\n        return runNext();\n      }\n      const workers = [];\n      for(let i=0;i<concurrency;i++) workers.push(runNext());\n      await Promise.all(workers);\n    }\n    logSys('Workflow complete');\n  }\n\n  function checkCondition(cond){\n    if(!cond || !cond.type || cond.type==='none') return true;\n    if(cond.type==='lastStatusEquals'){\n      const last = state.lastResponse && state.lastResponse.status;\n      return String(last) === String(cond.value);\n    }\n    if(cond.type==='varEquals'){\n      const [name, expected] = cond.value.split('=').map(s=>s && s.trim());\n      return String(getNestedVar(state.vars, name)) === String(expected);\n    }\n    if(cond.type==='bodyMatches'){\n      const lastText = state.lastResponse && state.lastResponse.text || '';\n      try { const re = new RegExp(cond.value); return re.test(lastText); } catch(e){ return false; }\n    }\n    return true;\n  }\n\n  // step-through control (very simple)\n  function stepControl(promptText){\n    if(!stepThrough.checked) return Promise.resolve(true);\n    return new Promise(resolve=>{\n      const ok = confirm('Step-through enabled. Continue?');\n      resolve(ok);\n    });\n  }\n\n  async function runSingleStep(step, opts={}) {\n    const name = step.name || step.request.method + ' ' + step.request.url;\n    logSys((opts.logPrefix||'') + ' Running step: ' + name);\n    // substitute templates into request\n    const req = JSON.parse(JSON.stringify(step.request)); // shallow clone\n    // apply variables substitution inside request building later\n    try {\n      const r = await sendRequest(req);\n      state.lastResponse = r;\n      logSys('Response status: ' + r.status + ' for step: ' + name);\n      // attempt to auto-parse JSON\n      let parsed = safeJsonParse(r.text);\n      // extractors\n      for(const ex of step.extractors || []){\n        let value = undefined;\n        if(ex.path.startsWith('/')) {\n          // regex like /foo(\\d+)/\n          try {\n            const parts = ex.path.split('/');\n            const re = new RegExp(parts.slice(1,parts.length-1).join('/'));\n            const m = r.text.match(re);\n            if(m) value = m[1] || m[0];\n          } catch(e){}\n        } else {\n          // dot path, use parsed JSON when possible\n          if(parsed) value = getNestedVar(parsed, ex.path);\n        }\n        if(value !== undefined){\n          state.vars[ex.name] = value;\n          logSys('Extractor set var \"'+ex.name+'\" = ' + JSON.stringify(value));\n        } else {\n          logSys('Extractor \"'+ex.name+'\" produced no value');\n        }\n      }\n      refreshVarsUI();\n      return r;\n    } catch(e){\n      logSys('Step error: ' + e.message);\n      throw e;\n    }\n  }\n\n  runWorkflowBtn.addEventListener('click', ()=> runWorkflow());\n\n  // Export/import workflow\n  exportWorkflowBtn.addEventListener('click', ()=>{\n    const data = JSON.stringify(state.workflow, null, 2);\n    const blob = new Blob([data], {type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = el('a'); a.href = url; a.download = 'workflow.json'; document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n  });\n  importWorkflowBtn.addEventListener('click', ()=> workflowFileInput.click());\n  workflowFileInput.addEventListener('change', (ev)=>{\n    const f = ev.target.files[0];\n    if(!f) return;\n    const reader = new FileReader();\n    reader.onload = ()=> {\n      try {\n        const obj = JSON.parse(reader.result);\n        state.workflow = obj;\n        renderSteps();\n        logSys('Workflow imported');\n      } catch(e){ alert('Invalid workflow file'); }\n    };\n    reader.readAsText(f);\n  });\n\n  // Script runner (limited sandbox)\n  async function runUserScript(){\n    const code = scriptArea.value;\n    scriptLog.textContent += 'Running script...\\n';\n    // Provide limited API\n    const api = {\n      vars: state.vars,\n      httpRequest: async function(step){\n        // allow step object or builder object\n        const r = await sendRequest(step);\n        return r;\n      },\n      log: function(...args){ scriptLog.textContent += args.map(a=>String(a)).join(' ') + '\\\\n'; }\n    };\n    try {\n      // eslint-disable-next-line no-new-func\n      const AsyncFunction = Object.getPrototypeOf(async function(){}).constructor;\n      const fn = new AsyncFunction('api', code);\n      await fn(api);\n      scriptLog.textContent += 'Script completed\\\\n';\n      refreshVarsUI();\n    } catch(e){\n      scriptLog.textContent += 'Script error: ' + e.message + '\\\\n';\n    }\n  }\n  runScriptBtn.addEventListener('click', ()=> runUserScript());\n  clearScriptLogBtn.addEventListener('click', ()=> scriptLog.textContent='');\n\n  // Simulation rules UI\n  function renderSimRules(){\n    simRulesList.innerHTML = '';\n    state.simRules.forEach((r, idx)=>{\n      const d = el('div'); d.className='panel';\n      d.appendChild(el('div','Rule ' + (idx+1) + ' pattern: ' + r.pattern + ' method:' + (r.method||''));\n      const edit = el('button'); edit.textContent='Edit'; const del = el('button'); del.textContent='Delete';\n      d.appendChild(edit); d.appendChild(del);\n      const bodyPreview = el('pre'); bodyPreview.textContent = 'status: '+r.status + '\\\\nheaders:\\\\n' + (r.headers||'') + '\\\\nbody:\\\\n' + (r.body||'');\n      d.appendChild(bodyPreview);\n      edit.addEventListener('click', ()=> {\n        const pattern = prompt('Regex pattern to match URL:', r.pattern);\n        if(pattern===null) return;\n        const method = prompt('Method to match (leave empty for any):', r.method||'');\n        const status = prompt('Response status:', r.status||200);\n        const headers = prompt('Response headers (JSON or lines \"Key: Value\"):', r.headers||'');\n        const body = prompt('Response body:', r.body||'');\n        const isJson = confirm('Treat body as JSON (format/pretty)? OK = yes, Cancel = no');\n        const delay = prompt('Response delay ms (optional):', r.delay||0);\n        const failType = prompt('failType (timeout/network/none):', r.failType||'none');\n        Object.assign(r, { pattern, method, status, headers, body, isJson, delay, failType });\n        renderSimRules();\n      });\n      del.addEventListener('click', ()=> {\n        state.simRules.splice(idx,1); renderSimRules();\n      });\n      simRulesList.appendChild(d);\n    });\n  }\n  addSimRuleBtn.addEventListener('click', ()=>{\n    const pattern = prompt('Enter URL regex pattern to match (e.g. ^https://api.example.com/):', '.*');\n    if(pattern===null) return;\n    const method = prompt('Method to match (leave empty for any):','');\n    const status = prompt('Response status:', '200');\n    const headers = prompt('Response headers (JSON or lines \"Key: Value\"):', '{\"content-type\":\"application/json\"}');\n    const body = prompt('Response body:', '{\"message\":\"simulated\"}');\n    const isJson = confirm('Treat body as JSON?');\n    state.simRules.push({ pattern, method, status, headers, body, isJson, delay:0, failType:'none' });\n    renderSimRules();\n  });\n  clearSimRulesBtn.addEventListener('click', ()=> { state.simRules = []; renderSimRules(); });\n\n  // Examples\n  exampleGetBtn.addEventListener('click', ()=>{\n    methodInput.value = 'GET';\n    urlInput.value = 'https://jsonplaceholder.typicode.com/todos/1';\n    bodyType.value = 'none';\n  });\n  examplePostBtn.addEventListener('click', ()=>{\n    methodInput.value = 'POST';\n    urlInput.value = 'https://httpbin.org/post';\n    bodyType.value = 'json';\n    bodyInput.value = JSON.stringify({ name:'Alice', score:42 }, null, 2);\n    // add content-type header\n    createKeyValueRow(headerList, 'Content-Type', 'application/json');\n  });\n  exampleAuthBtn.addEventListener('click', ()=>{\n    // build a login->get chain\n    state.workflow = [];\n    const loginStep = {\n      id: 's1',\n      name: 'Login',\n      disabled: false,\n      request: { method:'POST', url: 'https://httpbin.org/basic-auth/{{user}}/{{pass}}', headers: {}, qparams: [], btype:'none', body:'' },\n      extractors: [{name:'authOk', path:'/authenticated'}],\n      condition: {type:'none', value:''}\n    };\n    const getStep = {\n      id: 's2',\n      name: 'Get Data',\n      disabled: false,\n      request: { method:'GET', url: 'https://jsonplaceholder.typicode.com/todos/{{todoId}}', headers: {}, qparams: [], btype:'none', body:'' },\n      extractors: [{name:'todoTitle', path:'title'}],\n      condition: {type:'none', value:''}\n    };\n    // preset variables\n    state.vars.user='user'; state.vars.pass='pass'; state.vars.todoId='1';\n    state.workflow.push(loginStep); state.workflow.push(getStep);\n    renderSteps();\n    refreshVarsUI();\n    logSys('Loaded example workflow (Login -> Get Data). Edit variables and requests as needed.');\n  });\n\n  // Workflow log filter\n  logFilterInput.addEventListener('input', ()=> {\n    const f = logFilterInput.value.trim();\n    const lines = workflowLog.textContent.split('\\\\n');\n    if(!f) qs('workflowLog').textContent = workflowLog.textContent;\n    else {\n      qs('workflowLog').textContent = lines.filter(l=>l.toLowerCase().includes(f.toLowerCase())).join('\\\\n');\n    }\n  });\n\n  // simple examples loader\n  examplesBtn.addEventListener('click', ()=>{\n    methodInput.value = 'GET';\n    urlInput.value = 'https://jsonplaceholder.typicode.com/posts';\n    bodyType.value = 'none';\n    bodyInput.value = '';\n  });\n\n  // Initialize\n  renderSteps();\n  renderSimRules();\n  refreshVarsUI();\n\n  // Expose some functions to console for exploration\n  window.HTTPEX = {\n    state,\n    sendRequest,\n    runWorkflow,\n    runSingleStep\n  };\n\n})();\n</script>\n</body>\n</html>"
  },
