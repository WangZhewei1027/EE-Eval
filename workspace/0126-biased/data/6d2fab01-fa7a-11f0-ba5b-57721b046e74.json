  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Big-Omega Notation Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 1000px;\n            margin: 0 auto;\n        }\n        .control-panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n            margin-bottom: 20px;\n        }\n        .graph-container {\n            height: 400px;\n            border: 1px solid #ccc;\n            margin-bottom: 20px;\n            position: relative;\n        }\n        .function-input {\n            width: 100px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin-bottom: 20px;\n        }\n        th, td {\n            border: 1px solid #ccc;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        .tabs {\n            display: flex;\n            margin-bottom: 10px;\n        }\n        .tab {\n            padding: 10px 20px;\n            cursor: pointer;\n            border: 1px solid #ccc;\n            margin-right: 5px;\n            background-color: #f2f2f2;\n        }\n        .tab.active {\n            background-color: white;\n            border-bottom: 1px solid white;\n        }\n        .tab-content {\n            display: none;\n        }\n        .tab-content.active {\n            display: block;\n        }\n        canvas {\n            width: 100%;\n            height: 100%;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Big-Omega (Ω) Notation Explorer</h1>\n        \n        <div class=\"tabs\">\n            <div class=\"tab active\" onclick=\"switchTab('definition')\">Definition</div>\n            <div class=\"tab\" onclick=\"switchTab('comparison')\">Function Comparison</div>\n            <div class=\"tab\" onclick=\"switchTab('proof')\">Proof Technique</div>\n            <div class=\"tab\" onclick=\"switchTab('practice')\">Practice</div>\n        </div>\n        \n        <div id=\"definition\" class=\"tab-content active\">\n            <h2>Big-Omega Notation Definition</h2>\n            <p>Big-Omega (Ω) notation describes the <strong>asymptotic lower bound</strong> of a function.</p>\n            <p>Formally: f(n) is Ω(g(n)) if there exist positive constants c and n₀ such that:</p>\n            <p>0 ≤ c·g(n) ≤ f(n) for all n ≥ n₀</p>\n            \n            <div class=\"control-panel\">\n                <h3>Interactive Definition Explorer</h3>\n                <div>\n                    <label>f(n): <input type=\"text\" id=\"f-definition\" value=\"n^2 + 3n + 2\" class=\"function-input\"></label>\n                    <label>g(n): <input type=\"text\" id=\"g-definition\" value=\"n^2\" class=\"function-input\"></label>\n                </div>\n                <div>\n                    <label>Constant c: <input type=\"range\" id=\"c-slider\" min=\"0.1\" max=\"2\" step=\"0.1\" value=\"1\"> <span id=\"c-value\">1</span></label>\n                </div>\n                <div>\n                    <label>Threshold n₀: <input type=\"range\" id=\"n0-slider\" min=\"1\" max=\"20\" step=\"1\" value=\"1\"> <span id=\"n0-value\">1</span></label>\n                </div>\n                <button onclick=\"updateDefinitionGraph()\">Update Graph</button>\n                <div class=\"graph-container\">\n                    <canvas id=\"definitionGraph\"></canvas>\n                </div>\n                <div id=\"definition-result\"></div>\n            </div>\n        </div>\n        \n        <div id=\"comparison\" class=\"tab-content\">\n            <h2>Function Comparison</h2>\n            <p>Compare different functions to see their Big-Omega relationships.</p>\n            \n            <div class=\"control-panel\">\n                <h3>Function Comparison Tool</h3>\n                <div>\n                    <label>Function 1: <input type=\"text\" id=\"func1\" value=\"n^2\" class=\"function-input\"></label>\n                    <label>Function 2: <input type=\"text\" id=\"func2\" value=\"n\" class=\"function-input\"></label>\n                </div>\n                <div>\n                    <label>Relationship: \n                        <select id=\"relationship\">\n                            <option value=\"omega\">Is Ω of</option>\n                            <option value=\"not-omega\">Is not Ω of</option>\n                        </select>\n                    </label>\n                </div>\n                <button onclick=\"checkRelationship()\">Check Relationship</button>\n                <div class=\"graph-container\">\n                    <canvas id=\"comparisonGraph\"></canvas>\n                </div>\n                <div id=\"comparison-result\"></div>\n            </div>\n            \n            <h3>Common Function Classes</h3>\n            <table>\n                <tr>\n                    <th>Function</th>\n                    <th>Big-Omega</th>\n                    <th>Explanation</th>\n                </tr>\n                <tr>\n                    <td>3n + 5</td>\n                    <td>Ω(n)</td>\n                    <td>Linear terms dominate constants</td>\n                </tr>\n                <tr>\n                    <td>n² + n log n</td>\n                    <td>Ω(n²)</td>\n                    <td>Quadratic term dominates</td>\n                </tr>\n                <tr>\n                    <td>2ⁿ + n³</td>\n                    <td>Ω(2ⁿ)</td>\n                    <td>Exponential dominates polynomial</td>\n                </tr>\n                <tr>\n                    <td>log n + 5</td>\n                    <td>Ω(log n)</td>\n                    <td>Logarithmic term dominates constant</td>\n                </tr>\n            </table>\n        </div>\n        \n        <div id=\"proof\" class=\"tab-content\">\n            <h2>Proof Technique</h2>\n            <p>To prove f(n) is Ω(g(n)), we need to find constants c > 0 and n₀ ≥ 0 such that:</p>\n            <p>f(n) ≥ c·g(n) for all n ≥ n₀</p>\n            \n            <div class=\"control-panel\">\n                <h3>Interactive Proof Builder</h3>\n                <div>\n                    <label>f(n): <input type=\"text\" id=\"f-proof\" value=\"3n^2 + 2n + 1\" class=\"function-input\"></label>\n                    <label>Prove it's Ω(<input type=\"text\" id=\"g-proof\" value=\"n^2\" class=\"function-input\">)</label>\n                </div>\n                <div>\n                    <button onclick=\"suggestProof()\">Suggest Proof Approach</button>\n                    <button onclick=\"verifyProof()\">Verify My Proof</button>\n                </div>\n                <div>\n                    <label>Your proof attempt:</label><br>\n                    <textarea id=\"proof-text\" rows=\"5\" cols=\"80\">We need to find c and n₀ such that 3n² + 2n + 1 ≥ c·n² for all n ≥ n₀.</textarea>\n                </div>\n                <div id=\"proof-result\"></div>\n            </div>\n            \n            <h3>Proof Strategies</h3>\n            <ul>\n                <li><strong>Dominant Term:</strong> Identify the term that grows fastest</li>\n                <li><strong>Limit Method:</strong> Compute lim(n→∞) f(n)/g(n)</li>\n                <li><strong>Inequality Construction:</strong> Find c where f(n) ≥ c·g(n)</li>\n            </ul>\n        </div>\n        \n        <div id=\"practice\" class=\"tab-content\">\n            <h2>Practice Problems</h2>\n            \n            <div class=\"control-panel\">\n                <h3>Problem Generator</h3>\n                <div>\n                    <label>Difficulty: \n                        <select id=\"difficulty\" onchange=\"generateProblem()\">\n                            <option value=\"easy\">Easy</option>\n                            <option value=\"medium\">Medium</option>\n                            <option value=\"hard\">Hard</option>\n                        </select>\n                    </label>\n                </div>\n                <div id=\"problem-statement\"></div>\n                <div>\n                    <label>Your answer (Ω(...)): <input type=\"text\" id=\"user-answer\"></label>\n                    <button onclick=\"checkAnswer()\">Check Answer</button>\n                </div>\n                <div id=\"answer-result\"></div>\n            </div>\n            \n            <h3>Big-Omega Properties</h3>\n            <table>\n                <tr>\n                    <th>Property</th>\n                    <th>Explanation</th>\n                </tr>\n                <tr>\n                    <td>Reflexivity</td>\n                    <td>f(n) is Ω(f(n))</td>\n                </tr>\n                <tr>\n                    <td>Transitivity</td>\n                    <td>If f(n) is Ω(g(n)) and g(n) is Ω(h(n)), then f(n) is Ω(h(n))</td>\n                </tr>\n                <tr>\n                    <td>Not symmetric</td>\n                    <td>f(n) is Ω(g(n)) does not imply g(n) is Ω(f(n))</td>\n                </tr>\n            </table>\n        </div>\n    </div>\n\n    <script>\n        // Tab switching\n        function switchTab(tabId) {\n            document.querySelectorAll('.tab').forEach(tab => {\n                tab.classList.remove('active');\n            });\n            document.querySelectorAll('.tab-content').forEach(content => {\n                content.classList.remove('active');\n            });\n            \n            document.querySelector(`.tab[onclick=\"switchTab('${tabId}')\"]`).classList.add('active');\n            document.getElementById(tabId).classList.add('active');\n            \n            // Redraw graphs when switching to their tabs\n            if (tabId === 'definition') {\n                updateDefinitionGraph();\n            } else if (tabId === 'comparison') {\n                drawComparisonGraph();\n            }\n        }\n        \n        // Math expression evaluator\n        function evaluateMathExpr(expr, n) {\n            // Replace ^ with ** for exponentiation\n            expr = expr.replace(/\\^/g, '**');\n            // Handle log cases\n            expr = expr.replace(/log\\(/g, 'Math.log(');\n            expr = expr.replace(/ln\\(/g, 'Math.log(');\n            expr = expr.replace(/lg\\(/g, '(Math.log(/Math.log(2))');\n            // Evaluate safely\n            try {\n                return eval(expr);\n            } catch (e) {\n                return NaN;\n            }\n        }\n        \n        // Definition tab functions\n        function updateDefinitionGraph() {\n            const fExpr = document.getElementById('f-definition').value;\n            const gExpr = document.getElementById('g-definition').value;\n            const c = parseFloat(document.getElementById('c-slider').value);\n            const n0 = parseInt(document.getElementById('n0-slider').value);\n            \n            document.getElementById('c-value').textContent = c;\n            document.getElementById('n0-value').textContent = n0;\n            \n            const canvas = document.getElementById('definitionGraph');\n            const ctx = canvas.getContext('2d');\n            const width = canvas.width = canvas.parentElement.clientWidth;\n            const height = canvas.height = canvas.parentElement.clientHeight;\n            \n            ctx.clearRect(0, 0, width, height);\n            \n            // Draw axes\n            ctx.beginPath();\n            ctx.moveTo(50, height - 50);\n            ctx.lineTo(width - 20, height - 50);\n            ctx.moveTo(50, height - 50);\n            ctx.lineTo(50, 20);\n            ctx.stroke();\n            \n            // Axis labels\n            ctx.fillText(\"n\", width - 15, height - 45);\n            ctx.fillText(\"f(n)\", 30, 15);\n            \n            // Find maximum n to display (up to 20 or where functions diverge)\n            const maxN = Math.min(20, Math.max(10, n0 + 5));\n            \n            // Calculate scale factors\n            const xScale = (width - 70) / maxN;\n            const maxF = Math.max(\n                ...Array.from({length: maxN}, (_, i) => evaluateMathExpr(fExpr, i + 1))\n            );\n            const yScale = (height - 70) / maxF;\n            \n            // Draw n₀ line\n            ctx.strokeStyle = '#999';\n            ctx.beginPath();\n            ctx.moveTo(50 + n0 * xScale, height - 50);\n            ctx.lineTo(50 + n0 * xScale, 20);\n            ctx.stroke();\n            ctx.fillText(\"n₀\", 50 + n0 * xScale - 10, height - 30);\n            \n            // Draw functions\n            ctx.strokeStyle = 'red';\n            drawFunction(ctx, fExpr, maxN, xScale, yScale, 50, height - 50);\n            \n            ctx.strokeStyle = 'blue';\n            drawFunction(ctx, gExpr, maxN, xScale, yScale, 50, height - 50);\n            \n            ctx.strokeStyle = 'green';\n            drawFunction(ctx, `${c}*(${gExpr})`, maxN, xScale, yScale, 50, height - 50);\n            \n            // Check if the relationship holds\n            let holds = true;\n            for (let n = n0; n <= maxN; n++) {\n                const fVal = evaluateMathExpr(fExpr, n);\n                const cgVal = evaluateMathExpr(`${c}*(${gExpr})`, n);\n                if (fVal < cgVal) {\n                    holds = false;\n                    break;\n                }\n            }\n            \n            const resultDiv = document.getElementById('definition-result');\n            if (holds) {\n                resultDiv.innerHTML = `<p>For c = ${c} and n₀ = ${n0}, the relationship holds: ${fExpr} is Ω(${gExpr})</p>`;\n            } else {\n                resultDiv.innerHTML = `<p>For c = ${c} and n₀ = ${n0}, the relationship does NOT hold: ${fExpr} is NOT Ω(${gExpr}) with these constants</p>`;\n            }\n        }\n        \n        function drawFunction(ctx, expr, maxN, xScale, yScale, xOffset, yOffset) {\n            ctx.beginPath();\n            for (let n = 1; n <= maxN; n++) {\n                const x = xOffset + n * xScale;\n                const y = yOffset - evaluateMathExpr(expr, n) * yScale;\n                \n                if (n === 1) {\n                    ctx.moveTo(x, y);\n                } else {\n                    ctx.lineTo(x, y);\n                }\n                \n                // Draw point\n                ctx.fillRect(x - 2, y - 2, 4, 4);\n            }\n            ctx.stroke();\n            \n            // Label the function\n            const lastY = yOffset - evaluateMathExpr(expr, maxN) * yScale;\n            ctx.fillText(expr, xOffset + maxN * xScale + 5, lastY);\n        }\n        \n        // Comparison tab functions\n        function drawComparisonGraph() {\n            const func1 = document.getElementById('func1').value;\n            const func2 = document.getElementById('func2').value;\n            \n            const canvas = document.getElementById('comparisonGraph');\n            const ctx = canvas.getContext('2d');\n            const width = canvas.width = canvas.parentElement.clientWidth;\n            const height = canvas.height = canvas.parentElement.clientHeight;\n            \n            ctx.clearRect(0, 0, width, height);\n            \n            // Draw axes\n            ctx.beginPath();\n            ctx.moveTo(50, height - 50);\n            ctx.lineTo(width - 20, height - 50);\n            ctx.moveTo(50, height - 50);\n            ctx.lineTo(50, 20);\n            ctx.stroke();\n            \n            // Axis labels\n            ctx.fillText(\"n\", width - 15, height - 45);\n            ctx.fillText(\"f(n)\", 30, 15);\n            \n            const maxN = 20;\n            \n            // Calculate scale factors\n            const xScale = (width - 70) / maxN;\n            const maxF = Math.max(\n                ...Array.from({length: maxN}, (_, i) => Math.max(\n                    evaluateMathExpr(func1, i + 1),\n                    evaluateMathExpr(func2, i + 1)\n                ))\n            );\n            const yScale = (height - 70) / maxF;\n            \n            // Draw functions\n            ctx.strokeStyle = 'red';\n            drawFunction(ctx, func1, maxN, xScale, yScale, 50, height - 50);\n            \n            ctx.strokeStyle = 'blue';\n            drawFunction(ctx, func2, maxN, xScale, yScale, 50, height - 50);\n        }\n        \n        function checkRelationship() {\n            const func1 = document.getElementById('func1').value;\n            const func2 = document.getElementById('func2').value;\n            const relationship = document.getElementById('relationship').value;\n            \n            // Simple check - doesn't handle all cases but good for demonstration\n            let isOmega = false;\n            let explanation = \"\";\n            \n            // Try to find a c and n0 where func1 >= c*func2 for all n >= n0\n            // This is a simplified check for demonstration purposes\n            const c = 0.5;\n            let n0 = 1;\n            let found = false;\n            \n            for (n0 = 1; n0 <= 20; n0++) {\n                let holds = true;\n                for (let n = n0; n <= 20; n++) {\n                    const f1 = evaluateMathExpr(func1, n);\n                    const f2 = evaluateMathExpr(func2, n);\n                    if (f1 < c * f2) {\n                        holds = false;\n                        break;\n                    }\n                }\n                if (holds) {\n                    found = true;\n                    break;\n                }\n            }\n            \n            isOmega = found;\n            \n            const resultDiv = document.getElementById('comparison-result');\n            if (relationship === 'omega') {\n                if (isOmega) {\n                    resultDiv.innerHTML = `<p>Correct! ${func1} is Ω(${func2}) (with c=${c}, n₀=${n0})</p>`;\n                } else {\n                    resultDiv.innerHTML = `<p>Incorrect. ${func1} is NOT Ω(${func2}) for any positive constant c.</p>`;\n                }\n            } else {\n                if (!isOmega) {\n                    resultDiv.innerHTML = `<p>Correct! ${func1} is NOT Ω(${func2})</p>`;\n                } else {\n                    resultDiv.innerHTML = `<p>Incorrect. ${func1} actually is Ω(${func2}) (with c=${c}, n₀=${n0}</p>`;\n                }\n            }\n        }\n        \n        // Proof tab functions\n        function suggestProof() {\n            const fExpr = document.getElementById('f-proof').value;\n            const gExpr = document.getElementById('g-proof').value;\n            \n            let suggestion = `To prove ${fExpr} is Ω(${gExpr}), follow these steps:\\n\\n`;\n            suggestion += `1. Identify the dominant term in ${fExpr}\\n`;\n            suggestion += `2. Find a constant c > 0 such that the dominant term is ≥ c*${gExpr}\\n`;\n            suggestion += `3. Find n₀ where this inequality holds for all n ≥ n₀\\n\\n`;\n            suggestion += `Example approach:\\n`;\n            suggestion += `For large n, ${fExpr} behaves like its dominant term. `;\n            suggestion += `We can choose c = 1 and find n₀ where the inequality holds.`;\n            \n            document.getElementById('proof-text').value = suggestion;\n        }\n        \n        function verifyProof() {\n            const proofText = document.getElementById('proof-text').value;\n            const fExpr = document.getElementById('f-proof').value;\n            const gExpr = document.getElementById('g-proof').value;\n            \n            // Very simple verification for demonstration\n            if (proofText.includes(\"c\") && proofText.includes(\"n₀\") && \n                proofText.includes(fExpr) && proofText.includes(gExpr)) {\n                document.getElementById('proof-result').innerHTML = `\n                    <p>Your proof looks structurally correct. To complete it:</p>\n                    <ol>\n                        <li>State specific values for c and n₀</li>\n                        <li>Show the inequality holds for all n ≥ n₀</li>\n                    </ol>\n                `;\n            } else {\n                document.getElementById('proof-result').innerHTML = `\n                    <p>Your proof is missing key elements. Make sure to:</p>\n                    <ul>\n                        <li>Specify constants c and n₀</li>\n                        <li>Show the inequality f(n) ≥ c·g(n)</li>\n                        <li>Consider the behavior as n grows large</li>\n                    </ul>\n                `;\n            }\n        }\n        \n        // Practice tab functions\n        const problems = {\n            easy: [\n                { function: \"2n + 5\", answer: \"n\" },\n                { function: \"n^2 + 3n\", answer: \"n^2\" },\n                { function: \"5 log n + 3\", answer: \"log n\" }\n            ],\n            medium: [\n                { function: \"3n^2 + n log n\", answer: \"n^2\" },\n                { function: \"n^3 + 2^n\", answer: \"2^n\" },\n                { function: \"n + sqrt(n)\", answer: \"n\" }\n            ],\n            hard: [\n                { function: \"n! + n^100\", answer: \"n!\" },\n                { function: \"log(n!)\", answer: \"n log n\" },\n                { function: \"2^(2n) + n^n\", answer: \"2^(2n)\" }\n            ]\n        };\n        \n        let currentProblem = null;\n        \n        function generateProblem() {\n            const difficulty = document.getElementById('difficulty').value;\n            const problemSet = problems[difficulty];\n            currentProblem = problemSet[Math.floor(Math.random() * problemSet.length)];\n            \n            document.getElementById('problem-statement').innerHTML = `\n                <p>Find the tightest Big-Omega bound for: <strong>${currentProblem.function}</strong></p>\n                <p>Enter your answer in the form Ω(...), e.g., Ω(n^2)</p>\n            `;\n            document.getElementById('user-answer').value = '';\n            document.getElementById('answer-result').innerHTML = '';\n        }\n        \n        function checkAnswer() {\n            const userAnswer = document.getElementById('user-answer').value.trim();\n            const correctAnswer = `Ω(${currentProblem.answer})`;\n            \n            if (userAnswer.toLowerCase() === correctAnswer.toLowerCase()) {\n                document.getElementById('answer-result').innerHTML = `\n                    <p>Correct! ${currentProblem.function} is ${correctAnswer}</p>\n                `;\n            } else {\n                document.getElementById('answer-result').innerHTML = `\n                    <p>Not quite. The correct answer is ${correctAnswer}.</p>\n                    <p>Explanation: For large n, the dominantTerm(currentProblem.function)} term dominates.</p>\n                `;\n            }\n        }\n        \n        // Helper to find dominant term (simplified)\n        function dominantTerm(expr) {\n            if (expr.includes('!')) return 'n!';\n            if (expr.includes('^n')) return '2^n';\n            if (expr.includes('n^')) return 'n^' + expr.match(/n\\^(\\d+)/)[1];\n            if (expr.includes('log')) return 'log n';\n            return 'n';\n        }\n        \n        // Initialize\n        window.onload = function() {\n            updateDefinitionGraph();\n            generateProblem();\n        };\n    </script>\n</body>\n</html>"
  },
