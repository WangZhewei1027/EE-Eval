    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Backpropagation - Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n  /* Root Colors and Variables */\n  :root {\n    --deep-bg: #0f111a;\n    --accent-blue: #4f98ca;\n    --accent-cyan: #6fd3f2;\n    --highlight-pink: #e85d7f;\n    --highlight-peach: #f7a072;\n    --text-light: #f2f2f7;\n    --text-muted: #a5aabd;\n    --neuron-fill: #14213d;\n    --arrow-glow: #4f98ca;\n    --shadow-glow: rgba(79,152,202, 0.4);\n  }\n\n  /* Reset & Base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0; padding: 0;\n    background: var(--deep-bg);\n    color: var(--text-light);\n    font-family: 'Poppins', sans-serif;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  .container {\n    max-width: 1100px;\n    margin: 2.5rem auto 5rem;\n    padding: 0 2rem;\n    text-align: center;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    letter-spacing: 0.06em;\n    color: var(--highlight-pink);\n    margin-bottom: 0.25em;\n    text-shadow:\n      0 0 5px var(--highlight-pink),\n      0 0 15px var(--highlight-pink);\n    user-select: none;\n  }\n\n  h2 {\n    font-weight: 500;\n    font-size: 1.3rem;\n    color: var(--text-muted);\n    margin-bottom: 2.5rem;\n    font-style: italic;\n    user-select: none;\n  }\n\n  p.description {\n    max-width: 600px;\n    margin: 1rem auto 3rem;\n    color: var(--text-muted);\n    font-weight: 400;\n    font-size: 1.1rem;\n    line-height: 1.6;\n    user-select: none;\n  }\n\n  /* Canvas Wrapper */\n  #viz-wrapper {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 3rem;\n  }\n\n  /* Buttons */\n  .btn-group {\n    margin-top: -1rem;\n    margin-bottom: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.2rem;\n  }\n  button {\n    background: transparent;\n    border: 2px solid var(--accent-blue);\n    color: var(--accent-blue);\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.65rem 1.8rem;\n    border-radius: 30px;\n    cursor: pointer;\n    transition:\n      background-color 0.35s ease,\n      color 0.35s ease,\n      box-shadow 0.35s ease;\n    user-select: none;\n    box-shadow: 0 0 0 transparent;\n  }\n  button:hover {\n    background-color: var(--accent-blue);\n    color: var(--deep-bg);\n    box-shadow:\n      0 0 12px var(--accent-blue),\n      0 0 25px var(--accent-blue),\n      0 0 30px var(--accent-blue);\n  }\n  button:focus {\n    outline-offset: 2px;\n    outline: 2px solid var(--highlight-peach);\n  }\n\n  /* Footer Note */\n  footer {\n    font-size: 0.85rem;\n    color: var(--text-muted);\n    font-style: italic;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* SVG Container */\n  svg {\n    max-width: 100%;\n    height: auto;\n    user-select: none;\n  }\n\n  /* Neural Network Styles */\n  .neuron {\n    fill: var(--neuron-fill);\n    stroke: var(--accent-cyan);\n    stroke-width: 3;\n    filter: drop-shadow(0 0 6px var(--shadow-glow));\n    transition: fill 0.4s ease;\n  }\n  .neuron.highlight {\n    fill: var(--highlight-peach);\n    stroke: var(--highlight-pink);\n    filter:\n      drop-shadow(0 0 8px var(--highlight-pink))\n      drop-shadow(0 0 15px var(--highlight-peach));\n  }\n\n  .layer-label {\n    fill: var(--text-muted);\n    font-weight: 600;\n    font-size: 13px;\n    user-select: none;\n  }\n\n  /* Connections */\n  .connection {\n    stroke: var(--accent-cyan);\n    stroke-width: 2;\n    opacity: 0.2;\n    filter: drop-shadow(0 0 2px var(--shadow-glow));\n    transition: stroke-opacity 0.5s ease;\n  }\n  .connection.highlight {\n    stroke: var(--highlight-peach);\n    opacity: 1;\n    stroke-width: 3.5;\n    filter:\n      drop-shadow(0 0 5px var(--highlight-peach))\n      drop-shadow(0 0 12px var(--highlight-pink));\n  }\n\n  /* Arrows for gradient */\n  .arrow {\n    fill: none;\n    stroke-width: 3;\n    pointer-events: none;\n  }\n  .arrow.forward {\n    stroke: var(--accent-blue);\n    stroke-opacity: 0.4;\n    filter: drop-shadow(0 0 4px var(--accent-blue));\n    transition: stroke-opacity 0.5s ease;\n  }\n  .arrow.backward {\n    stroke: var(--highlight-pink);\n    stroke-opacity: 0.1;\n    filter: drop-shadow(0 0 8px var(--highlight-pink));\n    transition: stroke-opacity 0.5s ease;\n  }\n  .arrow.highlight {\n    stroke-opacity: 1 !important;\n    filter:\n      drop-shadow(0 0 8px var(--highlight-pink))\n      drop-shadow(0 0 12px var(--highlight-peach));\n  }\n\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"Backpropagation visualization\">\n    <h1>Backpropagation</h1>\n    <h2>Gradient Flow in Neural Networks</h2>\n    <p class=\"description\">\n      Witness the elegant dance of signals through a simple 3-layer neural network.<br />\n      Forward propagation sends activations, while backpropagation gracefully flows gradients,<br />\n      enabling learning and adjustment with every step.<br />\n      This visualization highlights these processes with luminous, animated paths.\n    </p>\n\n    <div id=\"viz-wrapper\" aria-label=\"Neural network animation visualization\">\n      <svg id=\"network-viz\" viewBox=\"0 0 900 340\" role=\"img\" aria-describedby=\"desc\" aria-live=\"polite\" xmlns=\"http://www.w3.org/2000/svg\">\n        <desc id=\"desc\">Animated neural network illustrating forward and backward passes of backpropagation.</desc>\n        <!-- Layers Labels -->\n        <text class=\"layer-label\" x=\"120\" y=\"25\" text-anchor=\"middle\">Input Layer</text>\n        <text class=\"layer-label\" x=\"450\" y=\"25\" text-anchor=\"middle\">Hidden Layer</text>\n        <text class=\"layer-label\" x=\"780\" y=\"25\" text-anchor=\"middle\">Output Layer</text>\n\n        <!-- Neurons Input Layer -->\n        <circle class=\"neuron\" id=\"n-input-1\" cx=\"120\" cy=\"70\" r=\"18\" />\n        <circle class=\"neuron\" id=\"n-input-2\" cx=\"120\" cy=\"160\" r=\"18\" />\n        <circle class=\"neuron\" id=\"n-input-3\" cx=\"120\" cy=\"250\" r=\"18\" />\n\n        <!-- Neurons Hidden Layer -->\n        <circle class=\"neuron\" id=\"n-hidden-1\" cx=\"450\" cy=\"90\" r=\"20\" />\n        <circle class=\"neuron\" id=\"n-hidden-2\" cx=\"450\" cy=\"170\" r=\"20\" />\n        <circle class=\"neuron\" id=\"n-hidden-3\" cx=\"450\" cy=\"250\" r=\"20\" />\n\n        <!-- Neurons Output Layer -->\n        <circle class=\"neuron\" id=\"n-output-1\" cx=\"780\" cy=\"150\" r=\"22\" />\n\n        <!-- Connections Input -> Hidden -->\n        <line class=\"connection\" id=\"c-i1-h1\" x1=\"138\" y1=\"70\" x2=\"430\" y2=\"90\" />\n        <line class=\"connection\" id=\"c-i1-h2\" x1=\"138\" y1=\"70\" x2=\"430\" y2=\"170\" />\n        <line class=\"connection\" id=\"c-i1-h3\" x1=\"138\" y1=\"70\" x2=\"430\" y2=\"250\" />\n\n        <line class=\"connection\" id=\"c-i2-h1\" x1=\"138\" y1=\"160\" x2=\"430\" y2=\"90\" />\n        <line class=\"connection\" id=\"c-i2-h2\" x1=\"138\" y1=\"160\" x2=\"430\" y2=\"170\" />\n        <line class=\"connection\" id=\"c-i2-h3\" x1=\"138\" y1=\"160\" x2=\"430\" y2=\"250\" />\n\n        <line class=\"connection\" id=\"c-i3-h1\" x1=\"138\" y1=\"250\" x2=\"430\" y2=\"90\" />\n        <line class=\"connection\" id=\"c-i3-h2\" x1=\"138\" y1=\"250\" x2=\"430\" y2=\"170\" />\n        <line class=\"connection\" id=\"c-i3-h3\" x1=\"138\" y1=\"250\" x2=\"430\" y2=\"250\" />\n\n        <!-- Connections Hidden -> Output -->\n        <line class=\"connection\" id=\"c-h1-o1\" x1=\"470\" y1=\"90\" x2=\"758\" y2=\"150\" />\n        <line class=\"connection\" id=\"c-h2-o1\" x1=\"470\" y1=\"170\" x2=\"758\" y2=\"150\" />\n        <line class=\"connection\" id=\"c-h3-o1\" x1=\"470\" y1=\"250\" x2=\"758\" y2=\"150\" />\n\n        <!-- Arrow markers defs -->\n        <defs>\n          <marker id=\"arrowhead-forward\" markerWidth=\"10\" markerHeight=\"7\" \n            refX=\"10\" refY=\"3.5\" orient=\"auto\" >\n            <path d=\"M0,0 L10,3.5 L0,7 Z\" fill=\"var(--accent-blue)\" />\n          </marker>\n          <marker id=\"arrowhead-backward\" markerWidth=\"10\" markerHeight=\"7\" \n            refX=\"10\" refY=\"3.5\" orient=\"auto\" >\n            <path d=\"M0,0 L10,3.5 L0,7 Z\" fill=\"var(--highlight-pink)\" />\n          </marker>\n        </defs>\n\n        <!-- Forward Arrows (animated) -->\n        <path class=\"arrow forward\" id=\"f-i1-h1\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-i1-h2\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-i1-h3\" marker-end=\"url(#arrowhead-forward)\" />\n\n        <path class=\"arrow forward\" id=\"f-i2-h1\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-i2-h2\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-i2-h3\" marker-end=\"url(#arrowhead-forward)\" />\n\n        <path class=\"arrow forward\" id=\"f-i3-h1\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-i3-h2\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-i3-h3\" marker-end=\"url(#arrowhead-forward)\" />\n\n        <path class=\"arrow forward\" id=\"f-h1-o1\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-h2-o1\" marker-end=\"url(#arrowhead-forward)\" />\n        <path class=\"arrow forward\" id=\"f-h3-o1\" marker-end=\"url(#arrowhead-forward)\" />\n\n        <!-- Backward Arrows (animated) -->\n        <path class=\"arrow backward\" id=\"b-o1-h1\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-o1-h2\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-o1-h3\" marker-end=\"url(#arrowhead-backward)\" />\n\n        <path class=\"arrow backward\" id=\"b-h1-i1\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-h1-i2\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-h1-i3\" marker-end=\"url(#arrowhead-backward)\" />\n\n        <path class=\"arrow backward\" id=\"b-h2-i1\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-h2-i2\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-h2-i3\" marker-end=\"url(#arrowhead-backward)\" />\n\n        <path class=\"arrow backward\" id=\"b-h3-i1\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-h3-i2\" marker-end=\"url(#arrowhead-backward)\" />\n        <path class=\"arrow backward\" id=\"b-h3-i3\" marker-end=\"url(#arrowhead-backward)\" />\n      </svg>\n    </div>\n\n    <div class=\"btn-group\" role=\"group\" aria-label=\"Animation controls\">\n      <button id=\"btn-start\" aria-live=\"polite\" aria-pressed=\"false\">Start Animation</button>\n      <button id=\"btn-reset\" aria-live=\"polite\" aria-pressed=\"false\">Reset</button>\n    </div>\n\n    <footer>\n      Crafted with precision &amp; passion &mdash; Observe and learn.\n    </footer>\n  </main>\n\n<script>\n(() => {\n  \"use strict\";\n  const svg = document.getElementById('network-viz');\n  // Store neuron positions for ease\n  const neurons = {\n    input: [\n      { id: \"n-input-1\", cx: 120, cy: 70 },\n      { id: \"n-input-2\", cx: 120, cy: 160 },\n      { id: \"n-input-3\", cx: 120, cy: 250 }\n    ],\n    hidden: [\n      { id: \"n-hidden-1\", cx: 450, cy: 90 },\n      { id: \"n-hidden-2\", cx: 450, cy: 170 },\n      { id: \"n-hidden-3\", cx: 450, cy: 250 }\n    ],\n    output: [\n      { id: \"n-output-1\", cx: 780, cy: 150 }\n    ]\n  };\n\n  // Connection data (input->hidden and hidden->output)\n  const connections = {\n    input_hidden: [\n      [\"i1\",\"h1\"], [\"i1\",\"h2\"], [\"i1\",\"h3\"],\n      [\"i2\",\"h1\"], [\"i2\",\"h2\"], [\"i2\",\"h3\"],\n      [\"i3\",\"h1\"], [\"i3\",\"h2\"], [\"i3\",\"h3\"]\n    ],\n    hidden_output: [\n      [\"h1\",\"o1\"],\n      [\"h2\",\"o1\"],\n      [\"h3\",\"o1\"]\n    ]\n  };\n\n  // Arrows backward: output->hidden, hidden->input\n  const back_connections = {\n    output_hidden: [\n      [\"o1\",\"h1\"],\n      [\"o1\",\"h2\"],\n      [\"o1\",\"h3\"]\n    ],\n    hidden_input: [\n      [\"h1\",\"i1\"], [\"h1\",\"i2\"], [\"h1\",\"i3\"],\n      [\"h2\",\"i1\"], [\"h2\",\"i2\"], [\"h2\",\"i3\"],\n      [\"h3\",\"i1\"], [\"h3\",\"i2\"], [\"h3\",\"i3\"]\n    ]\n  };\n\n  // Helper to get neuron coords by short id\n  function neuronCoords(layerShort, indexShort) {\n    let layerMap = {\n      i: neurons.input,\n      h: neurons.hidden,\n      o: neurons.output\n    };\n    let layerArray = layerMap[layerShort];\n    if(!layerArray) return null;\n    // indexShort like \"1\", \"2\", \"3\" as strings\n    let idx = parseInt(indexShort, 10) - 1;\n    // Defensive\n    if (idx<0 || idx>=layerArray.length) return null;\n    const {cx, cy} = layerArray[idx];\n    return {cx, cy};\n  }\n\n  // Generate path d string for a connection line\n  // We want a smooth cubic bezier curve between points (p1) and (p2)\n  // For forward arrows: left to right, curve slight upward, for backward arrows: right to left, curve slight downward\n  function generatePath(p1, p2, direction=\"forward\") {\n    const offsetY = 30;\n    let d;\n    if (direction === \"forward\") {\n      // Curve upward\n      d = `M${p1.cx},${p1.cy} C${p1.cx + 110},${p1.cy - offsetY} ${p2.cx - 110},${p2.cy - offsetY} ${p2.cx},${p2.cy}`;\n    } else {\n      // Curve downward\n      d = `M${p1.cx},${p1.cy} C${p1.cx - 110},${p1.cy + offsetY} ${p2.cx + 110},${p2.cy + offsetY} ${p2.cx},${p2.cy}`;\n    }\n    return d;\n  }\n\n  // Initialize all arrow paths with correct d attribute\n  function initializeArrows() {\n    // Forward arrows Input -> Hidden\n    connections.input_hidden.forEach(([i,h]) => {\n      const id = `f-${i}-${h}`;\n      const path = document.getElementById(id);\n      if(path){\n        const p1 = neuronCoords(i[0], i[1]);\n        const p2 = neuronCoords(h[0], h[1]);\n        path.setAttribute('d', generatePath(p1, p2, \"forward\"));\n      }\n    });\n    // Forward arrows Hidden -> Output\n    connections.hidden_output.forEach(([h,o]) => {\n      const id = `f-${h}-${o}`;\n      const path = document.getElementById(id);\n      if(path){\n        const p1 = neuronCoords(h[0], h[1]);\n        const p2 = neuronCoords(o[0], o[1]);\n        path.setAttribute('d', generatePath(p1, p2, \"forward\"));\n      }\n    });\n    // Backward arrows Output -> Hidden\n    back_connections.output_hidden.forEach(([o,h]) => {\n      const id = `b-${o}-${h}`;\n      const path = document.getElementById(id);\n      if(path){\n        const p1 = neuronCoords(o[0], o[1]);\n        const p2 = neuronCoords(h[0], h[1]);\n        path.setAttribute('d', generatePath(p1, p2, \"backward\"));\n      }\n    });\n    // Backward arrows Hidden -> Input\n    back_connections.hidden_input.forEach(([h,i]) => {\n      const id = `b-${h}-${i}`;\n      const path = document.getElementById(id);\n      if(path){\n        const p1 = neuronCoords(h[0], h[1]);\n        const p2 = neuronCoords(i[0], i[1]);\n        path.setAttribute('d', generatePath(p1, p2, \"backward\"));\n      }\n    });\n  }\n\n  // Animate stroke-dashoffset for arrow paths to simulate flow of signals\n  // Direction: 'forward' or 'backward'\n  // Duration: how long each arrow animation lasts\n  // cycle through connections in sequence with smooth transitions\n\n  // We'll create two animation sequences:\n  // 1. Forward propagation: Input->Hidden then Hidden->Output\n  // 2. Backward propagation (backprop): Output->Hidden then Hidden->Input\n\n  // General animation helper\n  function animateArrowPath(pathElem, duration) {\n    if(!pathElem) return Promise.resolve();\n    return new Promise(resolve => {\n      const length = pathElem.getTotalLength();\n      pathElem.style.transition = 'none';\n      pathElem.style.strokeDasharray = length;\n      pathElem.style.strokeDashoffset = length;\n      // Force layout to reset transition\n      pathElem.getBoundingClientRect();\n      pathElem.style.transition = `stroke-dashoffset ${duration}ms linear`;\n      pathElem.style.strokeDashoffset = '0';\n      setTimeout(() => {\n        pathElem.style.transition = '';\n        resolve();\n      }, duration);\n    });\n  }\n\n  // Helper to highlight/unhighlight a set of elements by ids or array of DOM elements\n  function highlightElements(elements, add=true) {\n    elements.forEach(e => {\n      if(!e) return;\n      if(add) {\n        e.classList.add('highlight');\n      } else {\n        e.classList.remove('highlight');\n      }\n    });\n  }\n\n  // Highlight neurons by array of IDs\n  function highlightNeurons(ids, add=true){\n    ids.forEach(id => {\n      const node = document.getElementById(id);\n      if(node){\n        node.classList.toggle('highlight', add);\n      }\n    });\n  }\n  // Highlight connections by array of IDs\n  function highlightConnections(ids, add=true){\n    ids.forEach(id => {\n      const node = document.getElementById(id);\n      if(node){\n        node.classList.toggle('highlight', add);\n      }\n    });\n  }\n  // Highlight arrow paths by array of IDs\n  function highlightArrows(ids, add=true){\n    ids.forEach(id => {\n      const node = document.getElementById(id);\n      if(node){\n        node.classList.toggle('highlight', add);\n      }\n    });\n  }\n\n  // Main animation logic - async sequence with awaits for smooth continuous flow\n\n  // First: Forward pass animation\n  async function animateForward() {\n    // Highlight input neurons\n    highlightNeurons([\"n-input-1\",\"n-input-2\",\"n-input-3\"], true);\n    await sleep(400);\n\n    // Animate and highlight each Input->Hidden connection and hidden neuron\n    for(const [i,h] of connections.input_hidden) {\n      const cId = `c-${i}-${h}`;\n      const fId = `f-${i}-${h}`;\n      highlightConnections([cId], true);\n      highlightArrows([fId], true);\n      await animateArrowPath(document.getElementById(fId), 400);\n      highlightArrows([fId], false);\n    }\n    await sleep(150);\n\n    // Highlight hidden neurons\n    highlightNeurons([\"n-hidden-1\",\"n-hidden-2\",\"n-hidden-3\"], true);\n    await sleep(400);\n\n    // Animate and highlight each Hidden->Output connection and output neuron\n    for(const [h,o] of connections.hidden_output) {\n      const cId = `c-${h}-${o}`;\n      const fId = `f-${h}-${o}`;\n      highlightConnections([cId], true);\n      highlightArrows([fId], true);\n      await animateArrowPath(document.getElementById(fId), 500);\n      highlightArrows([fId], false);\n    }\n    await sleep(300);\n\n    // Highlight output neuron\n    highlightNeurons([\"n-output-1\"], true);\n    await sleep(800);\n  }\n\n  // Then: Backward pass animation\n  async function animateBackward() {\n    // Animate and highlight each Output->Hidden backward arrow\n    for(const [o,h] of back_connections.output_hidden) {\n      const bId = `b-${o}-${h}`;\n      highlightArrows([bId], true);\n      await animateArrowPath(document.getElementById(bId), 450);\n      highlightArrows([bId], false);\n      // Highlight hidden neuron for weight update emphasis\n      highlightNeurons([`n-hidden-${h[1]}`], true);\n      await sleep(100);\n    }\n    await sleep(250);\n\n    // Animate and highlight each Hidden->Input backward arrow and input neuron\n    for(const [h,i] of back_connections.hidden_input) {\n      const bId = `b-${h}-${i}`;\n      const iId = `n-input-${i[1]}`;\n      highlightArrows([bId], true);\n      await animateArrowPath(document.getElementById(bId), 450);\n      highlightNeurons([iId], true);\n      highlightArrows([bId], false);\n      await sleep(80);\n    }\n\n    await sleep(400);\n  }\n\n  // Reset all highlights and stroke widths\n  function resetHighlighting() {\n    // Neurons\n    [...neurons.input, ...neurons.hidden, ...neurons.output].forEach(({id}) => {\n      const node = document.getElementById(id);\n      node.classList.remove('highlight');\n    });\n    // Connections\n    [...connections.input_hidden, ...connections.hidden_output].forEach(([start,end]) => {\n      const connId = `c-${start}-${end}`;\n      const connNode = document.getElementById(connId);\n      if(connNode) connNode.classList.remove('highlight');\n    });\n    // Arrows\n    const arrowIds = [\n      ...connections.input_hidden.map(([i,h])=>`f-${i}-${h}`),\n      ...connections.hidden_output.map(([h,o])=>`f-${h}-${o}`),\n      ...back_connections.output_hidden.map(([o,h])=>`b-${o}-${h}`),\n      ...back_connections.hidden_input.map(([h,i])=>`b-${h}-${i}`)\n    ];\n    arrowIds.forEach(id => {\n      const node = document.getElementById(id);\n      if(node) {\n        node.classList.remove('highlight');\n        // Reset strokeDashoffset for instant reset\n        node.style.transition = 'none';\n        node.style.strokeDashoffset = node.getTotalLength();\n      }\n    });\n  }\n\n  // Utility: simple sleep\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Full animation sequence: forward, pause, backward, pause, loop\n  let animationRun = false;\n  let animationCancel = false;\n\n  async function animationSequence() {\n    animationRun = true;\n    animationCancel = false;\n    while(animationRun && !animationCancel) {\n      resetHighlighting();\n      await sleep(500);\n      await animateForward();\n      await sleep(900);\n      await animateBackward();\n      await sleep(1200);\n    }\n  }\n  function stopAnimation() {\n    animationRun = false;\n    animationCancel = true;\n    resetHighlighting();\n  }\n\n  // On page ready\n  initializeArrows();\n  resetHighlighting();\n\n  // Buttons\n  const btnStart = document.getElementById('btn-start');\n  const btnReset = document.getElementById('btn-reset');\n\n  btnStart.addEventListener('click', () => {\n    if(animationRun) {\n      // Stop animation\n      stopAnimation();\n      btnStart.textContent = \"Start Animation\";\n      btnStart.setAttribute('aria-pressed', 'false');\n    } else {\n      // Start animation\n      animationSequence();\n      btnStart.textContent = \"Stop Animation\";\n      btnStart.setAttribute('aria-pressed', 'true');\n    }\n  });\n\n  btnReset.addEventListener('click', () => {\n    stopAnimation();\n    btnStart.textContent = \"Start Animation\";\n    btnStart.setAttribute('aria-pressed', 'false');\n    resetHighlighting();\n  });\n\n})();\n</script>\n\n</body>\n</html>"
  },
