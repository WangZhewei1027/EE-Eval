    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        #cpu-scheduling-container {\n            width: 80%;\n            margin: 40px auto;\n            background-color: white;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        #cpu-scheduling-container h1 {\n            margin-bottom: 20px;\n        }\n        #cpu-scheduling-container p {\n            margin-bottom: 10px;\n        }\n        #cpu-scheduling-container input, #cpu-scheduling-container select {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        #cpu-scheduling-container button {\n            width: 100%;\n            padding: 10px 20px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #cpu-scheduling-container button:hover {\n            background-color: #3e8e41;\n        }\n        #cpu-scheduling-container select {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        #cpu-scheduling-container select option {\n            padding: 10px;\n        }\n        #cpu-scheduling-container input[type=\"number\"] {\n            padding: 10px;\n        }\n        #cpu-scheduling-container input[type=\"text\"] {\n            padding: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"cpu-scheduling-container\">\n        <h1>CPU Scheduling</h1>\n        <p>CPU Scheduling is the process of allocating CPU time to different tasks or processes based on their priority.</p>\n        <p>Here are the interactive controls for CPU Scheduling:</p>\n        <div id=\"cpu-scheduling-controls\">\n            <button id=\"cpu-scheduling-allocate-button\">Allocate CPU Time</button>\n            <button id=\"cpu-scheduling-deallocate-button\">Deallocate CPU Time</button>\n            <button id=\"cpu-scheduling-switch-button\">Switch CPU Time</button>\n            <input id=\"cpu-scheduling-priority-input\" type=\"number\" placeholder=\"Priority\">\n            <select id=\"cpu-scheduling-task-type-select\">\n                <option value=\"I/O\">I/O Task</option>\n                <option value=\"CPU\">CPU Task</option>\n            </select>\n        </div>\n        <div id=\"cpu-scheduling-output-container\"></div>\n    </div>\n\n    <script>\n        let cpuTime = 0;\n        let priority = 0;\n        let taskType = \"I/O\";\n        let allocated = false;\n        let deallocated = false;\n\n        document.getElementById(\"cpu-scheduling-allocate-button\").addEventListener(\"click\", allocateCPU);\n        document.getElementById(\"cpu-scheduling-deallocate-button\").addEventListener(\"click\", deallocateCPU);\n        document.getElementById(\"cpu-scheduling-switch-button\").addEventListener(\"click\", switchCPU);\n        document.getElementById(\"cpu-scheduling-priority-input\").addEventListener(\"input\", updatePriority);\n        document.getElementById(\"cpu-scheduling-task-type-select\").addEventListener(\"change\", updateTaskType);\n\n        function allocateCPU() {\n            if (allocated) return;\n            cpuTime = Math.floor(Math.random() * 100);\n            document.getElementById(\"cpu-scheduling-output-container\").innerHTML = `Allocated CPU Time: ${cpuTime}ms`;\n            allocated = true;\n        }\n\n        function deallocateCPU() {\n            if (!deallocated) return;\n            cpuTime = Math.floor(Math.random() * 100);\n            deallocated = true;\n            document.getElementById(\"cpu-scheduling-output-container\").innerHTML = `Deallocated CPU Time: ${cpuTime}ms`;\n        }\n\n        function switchCPU() {\n            if (taskType === \"I/O\") {\n                taskType = \"CPU\";\n                document.getElementById(\"cpu-scheduling-task-type-select\").innerHTML = `Task Type: CPU`;\n            } else {\n                taskType = \"I/O\";\n                document.getElementById(\"cpu-scheduling-task-type-select\").innerHTML = `Task Type: I/O`;\n            }\n        }\n\n        function updatePriority() {\n            priority = parseInt(document.getElementById(\"cpu-scheduling-priority-input\").value);\n            document.getElementById(\"cpu-scheduling-output-container\").innerHTML = `Priority: ${priority}`;\n        }\n\n        function updateTaskType() {\n            taskType = document.getElementById(\"cpu-scheduling-task-type-select\").value;\n            document.getElementById(\"cpu-scheduling-task-type-select\").innerHTML = `Task Type: ${taskType}`;\n        }\n    </script>\n</body>\n</html>"
