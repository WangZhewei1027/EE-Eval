    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dijkstra's Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f2f2f2;\n            margin: 20px;\n        }\n        #graph {\n            width: 800px;\n            height: 600px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            padding: 20px;\n            margin: 40px auto;\n        }\n        #graph canvas {\n            border: 1px solid #ddd;\n            border-radius: 10px;\n        }\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"graph\"></div>\n    <div>\n        <h1>Dijkstra's Algorithm</h1>\n        <p>Find the shortest path between two nodes in a graph using Dijkstra's algorithm.</p>\n    </div>\n    <div id=\"controls\">\n        <button id=\"start-button\">Start</button>\n        <button id=\"reset-button\">Reset</button>\n    </div>\n\n    <script>\n        class Graph {\n            constructor(graph) {\n                this.graph = graph;\n                this.nodes = Object.keys(graph);\n                this.edges = Object.keys(graph).map(node => [node, ...graph[node]]);\n                this.distances = {};\n                this.previousNodes = {};\n                this.unvisitedNodes = [...this.nodes];\n                this.startNode = this.unvisitedNodes[0];\n                this.endNode = this.nodes[graph.length - 1];\n                this.distances[this.startNode] = 0;\n                this.previousNodes[this.startNode] = null;\n            }\n\n            dijkstra() {\n                let unvisitedNodes = [...this.unvisitedNodes];\n                while (unvisitedNodes.length > 0) {\n                    let currentNode = unvisitedNodes.sort((a, b) => this.distances[a] - this.distances[b])[0];\n                    unvisitedNodes.splice(unvisitedNodes.indexOf(currentNode), 1);\n                    for (let neighbor of this.edges[currentNode]) {\n                        let distance = this.distances[currentNode] + this.edges[currentNode].reduce((a, b) => a + b, 0);\n                        if (distance < this.distances[neighbor]) {\n                            this.distances[neighbor] = distance;\n                            this.previousNodes[neighbor] = currentNode;\n                        }\n                    }\n                }\n                return this.distances;\n            }\n        }\n\n        let graph = {\n            'A': {'B': 1, 'C': 4, 'D': 7},\n            'B': {'A': 1, 'C': 2, 'D': 5},\n            'C': {'A': 4, 'B': 2, 'D': 1},\n            'D': {'A': 7, 'B': 5, 'C': 1}\n        };\n\n        let graphObject = new Graph(graph);\n        let distances = graphObject.dijkstra();\n\n        let canvas = document.getElementById('graph');\n        let ctx = canvas.getContext('2d');\n\n        for (let node in distances) {\n            let x = Math.floor((node - this.startNode) / (this.endNode - this.startNode) * canvas.width);\n            let y = Math.floor((node - this.startNode) / (this.endNode - this.startNode) * canvas.height);\n            ctx.beginPath();\n            ctx.arc(x, y, 10, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.fillStyle = 'black';\n            ctx.fillText(node, x + 5, y + 5);\n        }\n\n        let startNodeX = Math.floor(distances[this.startNode] / (this.endNode - this.startNode) * canvas.width);\n        let startNodeY = Math.floor(distances[this.startNode] / (this.endNode - this.startNode) * canvas.height);\n        ctx.beginPath();\n        ctx.arc(startNodeX, startNodeY, 20, 0, 2 * Math.PI);\n        ctx.fillStyle = 'red';\n        ctx.fill();\n        ctx.fillStyle = 'black';\n        ctx.fillText('Start', startNodeX + 10, startNodeY + 10);\n\n        let endNodeX = Math.floor(distances[this.endNode] / (this.endNode - this.startNode) * canvas.width);\n        let endNodeY = Math.floor(distances[this.endNode] / (this.endNode - this.startNode) * canvas.height);\n        ctx.beginPath();\n        ctx.arc(endNodeX, endNodeY, 20, 0, 2 * Math.PI);\n        ctx.fillStyle = 'red';\n        ctx.fill();\n        ctx.fillStyle = 'black';\n        ctx.fillText('End', endNodeX + 10, endNodeY + 10);\n\n        let startButton = document.getElementById('start-button');\n        let resetButton = document.getElementById('reset-button');\n\n        startButton.addEventListener('click', () => {\n            startNodeX = Math.floor(distances[this.startNode] / (this.endNode - this.startNode) * canvas.width);\n            startNodeY = Math.floor(distances[this.startNode] / (this.endNode - this.startNode) * canvas.height);\n            endNodeX = Math.floor(distances[this.endNode] / (this.endNode - this.startNode) * canvas.width);\n            endNodeY = Math.floor(distances[this.endNode] / (this.endNode - this.startNode) * canvas.height);\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            for (let node in distances) {\n                let x = Math.floor((node - this.startNode) / (this.endNode - this.startNode) * canvas.width);\n                let y = Math.floor((node - this.startNode) / (this.endNode - this.startNode) * canvas.height);\n                ctx.beginPath();\n                ctx.arc(x, y, 10, 0, 2 * Math.PI);\n                ctx.fillStyle = 'red';\n                ctx.fill();\n                ctx.fillStyle = 'black';\n                ctx.fillText(node, x + 5, y + 5);\n            }\n            ctx.beginPath();\n            ctx.arc(startNodeX, startNodeY, 20, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.fillStyle = 'black';\n            ctx.fillText('Start', startNodeX + 10, startNodeY + 10);\n            ctx.beginPath();\n            ctx.arc(endNodeX, endNodeY, 20, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.fillStyle = 'black';\n            ctx.fillText('End', endNodeX + 10, endNodeY + 10);\n        });\n\n        resetButton.addEventListener('click', () => {\n            startNodeX = Math.floor(distances[this.startNode] / (this.endNode - this.startNode) * canvas.width);\n            startNodeY = Math.floor(distances[this.startNode] / (this.endNode - this.startNode) * canvas.height);\n            endNodeX = Math.floor(distances[this.endNode] / (this.endNode - this.startNode) * canvas.width);\n            endNodeY = Math.floor(distances[this.endNode] / (this.endNode - this.startNode) * canvas.height);\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            for (let node in distances) {\n                let x = Math.floor((node - this.startNode) / (this.endNode - this.startNode) * canvas.width);\n                let y = Math.floor((node - this.startNode) / (this.endNode - this.startNode) * canvas.height);\n                ctx.beginPath();\n                ctx.arc(x, y, 10, 0, 2 * Math.PI);\n                ctx.fillStyle = 'red';\n                ctx.fill();\n                ctx.fillStyle = 'black';\n                ctx.fillText(node, x + 5, y + 5);\n            }\n            ctx.beginPath();\n            ctx.arc(startNodeX, startNodeY, 20, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.fillStyle = 'black';\n            ctx.fillText('Start', startNodeX + 10, startNodeY + 10);\n            ctx.beginPath();\n            ctx.arc(endNodeX, endNodeY, 20, 0, 2 * Math.PI);\n            ctx.fillStyle = 'red';\n            ctx.fill();\n            ctx.fillStyle = 'black';\n            ctx.fillText('End', endNodeX + 10, endNodeY + 10);\n        });\n    </scri