  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Interactive Bubble Sort Demo</title>\n<style>\n  /* Minimal styling: black text on white background */\n  body {\n    background: white;\n    color: black;\n    font-family: monospace, monospace;\n    margin: 10px;\n  }\n  textarea, input, button, select {\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin: 2px 0;\n  }\n  #arrayDisplay span {\n    display: inline-block;\n    min-width: 18px;\n    text-align: center;\n    border: 1px solid black;\n    margin: 0 1px;\n    padding: 2px 3px;\n    user-select: none;\n  }\n  #arrayDisplay span.highlight-compare {\n    font-weight: bold;\n    text-decoration: underline;\n  }\n  #arrayDisplay span.highlight-swap {\n    font-weight: bold;\n  }\n  #log {\n    white-space: pre-wrap;\n    max-height: 200px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 4px;\n    margin-top: 6px;\n  }\n  label {\n    display: inline-block;\n    width: 220px;\n  }\n  section {\n    margin-bottom: 14px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Interactive Bubble Sort Demonstration</h1>\n\n<section>\n  <label for=\"arrayInput\">Enter array values (comma separated integers):</label><br />\n  <input type=\"text\" id=\"arrayInput\" size=\"50\" value=\"5,3,8,4,2\" />\n  <button id=\"setArrayBtn\" title=\"Set new array to sort\">Set Array</button>\n  <button id=\"generateRandomBtn\" title=\"Generate random array\">Random Array</button>\n  <input type=\"number\" id=\"randomSize\" min=\"1\" max=\"50\" value=\"10\" style=\"width:60px;\" title=\"Size of random array\" /> elements\n</section>\n\n<section>\n  <label for=\"speedRange\">Sorting speed (delay in ms between steps):</label><br />\n  <input type=\"range\" id=\"speedRange\" min=\"10\" max=\"2000\" value=\"500\" step=\"10\" />\n  <span id=\"speedValue\">500ms</span>\n</section>\n\n<section>\n  <label for=\"modeSelect\">Select sort mode:</label><br />\n  <select id=\"modeSelect\">\n    <option value=\"auto\">Automatic Sort</option>\n    <option value=\"step\">Step-by-Step Manual</option>\n    <option value=\"inspect\">Deep Inspect Mode</option>\n  </select>\n</section>\n\n<section>\n  <button id=\"startBtn\">Start</button>\n  <button id=\"pauseBtn\" disabled>Pause</button>\n  <button id=\"stepBtn\" disabled>Step</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n  <button id=\"skipToEndBtn\" disabled>Skip To End</button>\n</section>\n\n<section>\n  <label>Current Array State:</label><br />\n  <div id=\"arrayDisplay\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n</section>\n\n<section>\n  <label>Sorting Log and Controls:</label><br />\n  <textarea id=\"log\" readonly rows=\"10\" aria-label=\"Sorting Log\"></textarea>\n</section>\n\n<section>\n  <label for=\"inspectIndex\">Inspect element at index:</label>\n  <input type=\"number\" id=\"inspectIndex\" min=\"0\" value=\"0\" style=\"width:60px;\" />\n  <button id=\"inspectValueBtn\">Show Value</button>\n</section>\n\n<section>\n  <label for=\"compareIndices\">Compare two indices (comma separated):</label>\n  <input type=\"text\" id=\"compareIndices\" size=\"10\" value=\"0,1\" />\n  <button id=\"compareBtn\">Compare</button>\n</section>\n\n<section>\n  <label for=\"swapIndices\">Swap two indices (comma separated):</label>\n  <input type=\"text\" id=\"swapIndices\" size=\"10\" value=\"0,1\" />\n  <button id=\"swapBtn\">Swap</button>\n</section>\n\n<section>\n  <label>Save / Load Array (JSON format):</label><br />\n  <textarea id=\"saveLoadArea\" rows=\"3\" cols=\"50\" aria-label=\"Save or load array\"></textarea><br />\n  <button id=\"saveBtn\">Save Current Array</button>\n  <button id=\"loadBtn\">Load Array</button>\n</section>\n\n<script>\n(() => {\n  const arrayInput = document.getElementById('arrayInput');\n  const setArrayBtn = document.getElementById('setArrayBtn');\n  const generateRandomBtn = document.getElementById('generateRandomBtn');\n  const randomSizeInput = document.getElementById('randomSize');\n  const speedRange = document.getElementById('speedRange');\n  const speedValue = document.getElementById('speedValue');\n  const modeSelect = document.getElementById('modeSelect');\n  const startBtn = document.getElementById('startBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const skipToEndBtn = document.getElementById('skipToEndBtn');\n  const arrayDisplay = document.getElementById('arrayDisplay');\n  const logArea = document.getElementById('log');\n  const inspectIndexInput = document.getElementById('inspectIndex');\n  const inspectValueBtn = document.getElementById('inspectValueBtn');\n  const compareIndicesInput = document.getElementById('compareIndices');\n  const compareBtn = document.getElementById('compareBtn');\n  const swapIndicesInput = document.getElementById('swapIndices');\n  const swapBtn = document.getElementById('swapBtn');\n  const saveLoadArea = document.getElementById('saveLoadArea');\n  const saveBtn = document.getElementById('saveBtn');\n  const loadBtn = document.getElementById('loadBtn');\n\n  let array = [];\n  let originalArray = [];\n  let sorting = false;\n  let paused = false;\n  let currentI = 0;\n  let currentJ = 0;\n  let sorted = false;\n  let timerId = null;\n  let compareHighlightIndices = [];\n  let swapHighlightIndices = [];\n  let logHistory = [];\n  \n  // Store full Bubble Sort state to support step and pause:\n  // i iterates from 0 to n-1\n  // j iterates from 0 to n-1-i-1\n\n  function log(msg) {\n    logHistory.push(msg);\n    // Limit log length to 1000 lines\n    if (logHistory.length > 1000) logHistory.shift();\n    logArea.value = logHistory.join('\\n');\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  function clearLog() {\n    logHistory = [];\n    logArea.value = '';\n  }\n\n  function parseArrayInput(text) {\n    // Parse comma separated integers, ignoring empty parts\n    const parts = text.split(',');\n    const nums = [];\n    for(let p of parts){\n      const v = p.trim();\n      if(v.length === 0) continue;\n      if(!/^[-+]?\\d+$/.test(v)) return null;\n      nums.push(parseInt(v, 10));\n    }\n    return nums;\n  }\n\n  function displayArray(highlightCompare = [], highlightSwap = []) {\n    arrayDisplay.innerHTML = '';\n    for(let k=0; k<array.length; k++){\n      const span = document.createElement('span');\n      span.textContent = array[k];\n      span.setAttribute('data-index', k);\n      if(highlightCompare.includes(k)) {\n        span.classList.add('highlight-compare');\n      }\n      if(highlightSwap.includes(k)) {\n        span.classList.add('highlight-swap');\n      }\n      span.title = `Value: ${array[k]}\\nIndex: ${k}`;\n      arrayDisplay.appendChild(span);\n    }\n  }\n\n  function resetSortingState() {\n    sorting = false;\n    paused = false;\n    timerId = null;\n    currentI = 0;\n    currentJ = 0;\n    sorted = false;\n    compareHighlightIndices = [];\n    swapHighlightIndices = [];\n    displayArray();\n    clearLog();\n    log(`Array reset: [${array.join(', ')}]`);\n  }\n\n  function setArray(newArray) {\n    if(!Array.isArray(newArray)) {\n      alert('Invalid array.');\n      return;\n    }\n    array = newArray.slice();\n    originalArray = newArray.slice();\n    resetSortingState();\n    enableControlButtons(true);\n    displayArray();\n  }\n\n  function generateRandomArray(size) {\n    const maxVal = 999;\n    const minVal = -999;\n    const arr = [];\n    for(let i=0; i<size; i++){\n      arr.push(Math.floor(Math.random() * (maxVal-minVal+1)) + minVal);\n    }\n    return arr;\n  }\n\n  function enableControlButtons(enabled) {\n    pauseBtn.disabled = !enabled;\n    stepBtn.disabled = !enabled;\n    resetBtn.disabled = !enabled;\n    skipToEndBtn.disabled = !enabled;\n  }\n\n  function disableAllControls() {\n    pauseBtn.disabled = true;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n    skipToEndBtn.disabled = true;\n    startBtn.disabled = true;\n  }\n\n  function enableAllControls() {\n    startBtn.disabled = false;\n    setArrayBtn.disabled = false;\n    generateRandomBtn.disabled = false;\n    speedRange.disabled = false;\n    modeSelect.disabled = false;\n    inspectValueBtn.disabled = false;\n    compareBtn.disabled = false;\n    swapBtn.disabled = false;\n    saveBtn.disabled = false;\n    loadBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n    skipToEndBtn.disabled = true;\n  }\n\n  function updateSpeedDisplay(){\n    speedValue.textContent = speedRange.value + 'ms';\n  }\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Bubble Sort step function returns true if sorting finished\n  function bubbleSortStep() {\n    if(sorted) return true;\n\n    const n = array.length;\n    if(currentI >= n - 1) {\n      sorted = true;\n      return true;\n    }\n\n    if(currentJ >= n - 1 - currentI) {\n      log(`Pass ${currentI+1} complete. No more comparisons in this pass.`);\n      currentI++;\n      currentJ = 0;\n      return currentI >= n-1;\n    }\n\n    compareHighlightIndices = [currentJ, currentJ+1];\n    displayArray(compareHighlightIndices);\n\n    log(`Comparing indices ${currentJ} and ${currentJ+1} (values ${array[currentJ]} and ${array[currentJ+1]})`);\n    if(array[currentJ] > array[currentJ+1]) {\n      // Swap\n      log(`Swapping since ${array[currentJ]} > ${array[currentJ+1]}`);\n      const temp = array[currentJ];\n      array[currentJ] = array[currentJ+1];\n      array[currentJ+1] = temp;\n      swapHighlightIndices = [currentJ, currentJ+1];\n      displayArray(swapHighlightIndices);\n    } else {\n      swapHighlightIndices = [];\n    }\n\n    currentJ++;\n    return false;\n  }\n\n  async function autoSort() {\n    startBtn.disabled = true;\n    pauseBtn.disabled = false;\n    resetBtn.disabled = false;\n    stepBtn.disabled = true;\n    skipToEndBtn.disabled = false;\n    setArrayBtn.disabled = true;\n    generateRandomBtn.disabled = true;\n    modeSelect.disabled = true;\n    speedRange.disabled = true;\n\n    sorting = true;\n    paused = false;\n    sorted = false;\n    currentI = 0;\n    currentJ = 0;\n    log('Automatic sorting started.');\n    while(sorting && !sorted) {\n      if(paused) {\n        log('Paused.');\n        break;\n      }\n      const finish = bubbleSortStep();\n      if(finish) {\n        sorted = true;\n        log('Sorting finished.');\n        displayArray();\n        break;\n      }\n      await sleep(parseInt(speedRange.value, 10));\n    }\n    if(sorted) {\n      sorting = false;\n      pauseBtn.disabled = true;\n      stepBtn.disabled = true;\n      startBtn.disabled = false;\n      setArrayBtn.disabled = false;\n      generateRandomBtn.disabled = false;\n      modeSelect.disabled = false;\n      speedRange.disabled = false;\n      skipToEndBtn.disabled = true;\n    }\n  }\n\n  function stepModeSortingStep() {\n    if(sorted) {\n      log('Array is already sorted.');\n      return;\n    }\n    const finish = bubbleSortStep();\n    if(finish) {\n      sorted = true;\n      log('Sorting finished.');\n      displayArray();\n    }\n  }\n\n  function pauseSorting() {\n    if(!sorting) return;\n    paused = true;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    startBtn.disabled = false;\n    log('Sorting paused.');\n  }\n\n  function resetSort() {\n    array = originalArray.slice();\n    sorting = false;\n    paused = false;\n    currentI = 0;\n    currentJ = 0;\n    sorted = false;\n    compareHighlightIndices = [];\n    swapHighlightIndices = [];\n    displayArray();\n    clearLog();\n    log(`Array reset: [${array.join(', ')}]`);\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = true;\n    resetBtn.disabled = false;\n    skipToEndBtn.disabled = true;\n    setArrayBtn.disabled = false;\n    generateRandomBtn.disabled = false;\n    modeSelect.disabled = false;\n    speedRange.disabled = false;\n  }\n\n  async function skipToEnd() {\n    if(sorted) {\n      log('Already sorted.');\n      return;\n    }\n    disableAllControls();\n    log('Skipping to end...');\n    while(!sorted) {\n      // step without delay for speed\n      sorted = false;\n      while(true){\n        const finish = bubbleSortStep();\n        if(finish) {\n          sorted = true;\n          break;\n        }\n      }\n      displayArray();\n    }\n    log('Sorting finished (skip to end).');\n    enableAllControls();\n    resetBtn.disabled = false;\n    skipToEndBtn.disabled = true;\n  }\n\n  // Event handlers\n\n  setArrayBtn.addEventListener('click', () => {\n    if(sorting) {\n      alert('Cannot set array while sorting is active.');\n      return;\n    }\n    const inputText = arrayInput.value;\n    const arr = parseArrayInput(inputText);\n    if(arr === null) {\n      alert('Input invalid. Please enter comma separated integers.');\n      return;\n    }\n    setArray(arr);\n  });\n\n  generateRandomBtn.addEventListener('click', () => {\n    if(sorting) {\n      alert('Cannot generate array while sorting is active.');\n      return;\n    }\n    let size = parseInt(randomSizeInput.value, 10);\n    if(isNaN(size) || size < 1) size = 10;\n    else if(size > 50) size = 50;\n    const arr = generateRandomArray(size);\n    arrayInput.value = arr.join(', ');\n    setArray(arr);\n  });\n\n  speedRange.addEventListener('input', () => {\n    updateSpeedDisplay();\n  });\n  updateSpeedDisplay();\n\n  modeSelect.addEventListener('change', () => {\n    if(sorting) {\n      alert('Cannot change mode while sorting.');\n      modeSelect.value = sortingMode;\n      return;\n    }\n    if(modeSelect.value === 'auto') {\n      stepBtn.disabled = true;\n      pauseBtn.disabled = true;\n      skipToEndBtn.disabled = false;\n      startBtn.disabled = false;\n    } else if(modeSelect.value === 'step') {\n      stepBtn.disabled = false;\n      pauseBtn.disabled = true;\n      skipToEndBtn.disabled = false;\n      startBtn.disabled = true;\n    } else if(modeSelect.value === 'inspect') {\n      stepBtn.disabled = true;\n      pauseBtn.disabled = true;\n      skipToEndBtn.disabled = true;\n      startBtn.disabled = true;\n    }\n  });\n\n  startBtn.addEventListener('click', () => {\n    if(sorting) {\n      alert('Already sorting.');\n      return;\n    }\n    if(array.length === 0) {\n      alert('Empty array. Set or generate an array first.');\n      return;\n    }\n    if(modeSelect.value === 'auto') {\n      autoSort();\n    } else if(modeSelect.value === 'step') {\n      log('In step-by-step mode, press Step button to advance.');\n      sorting = true;\n      paused = false;\n      sorted = false;\n      currentI = 0;\n      currentJ = 0;\n      startBtn.disabled = true;\n      pauseBtn.disabled = false;\n      stepBtn.disabled = false;\n      resetBtn.disabled = false;\n      skipToEndBtn.disabled = false;\n    }\n  });\n\n  pauseBtn.addEventListener('click', () => {\n    pauseSorting();\n  });\n\n  stepBtn.addEventListener('click', () => {\n    if(!sorting) {\n      alert('Sorting is not active.');\n      return;\n    }\n    if(modeSelect.value === 'step') {\n      stepModeSortingStep();\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    if(sorting) {\n      sorting = false;\n      paused = false;\n    }\n    resetSort();\n  });\n\n  skipToEndBtn.addEventListener('click', () => {\n    if(modeSelect.value === 'auto' || modeSelect.value === 'step') {\n      skipToEnd();\n    }\n  });\n\n  inspectValueBtn.addEventListener('click', () => {\n    const idx = parseInt(inspectIndexInput.value, 10);\n    if(isNaN(idx) || idx < 0 || idx >= array.length) {\n      alert('Invalid index to inspect.');\n      return;\n    }\n    alert(`Value at index ${idx} is ${array[idx]}.`);\n    log(`Inspected value at index ${idx}: ${array[idx]}`);\n  });\n\n  compareBtn.addEventListener('click', () => {\n    const text = compareIndicesInput.value.trim();\n    const parts = text.split(',');\n    if(parts.length !== 2) {\n      alert('Enter exactly two indices separated by a comma.');\n      return;\n    }\n    const i1 = parseInt(parts[0].trim(), 10);\n    const i2 = parseInt(parts[1].trim(), 10);\n    if(isNaN(i1) || isNaN(i2) || i1<0 || i1>=array.length || i2<0 || i2>=array.length){\n      alert('Invalid indices for compare.');\n      return;\n    }\n    displayArray([i1, i2]);\n    let comp = 0;\n    if(array[i1] < array[i2]) comp = -1;\n    else if(array[i1] > array[i2]) comp = 1;\n    alert(`Compare result: array[${i1}] (${array[i1]}) ${comp < 0 ? '<' : comp > 0 ? '>' : '=='} array[${i2}] (${array[i2]}).`);\n    log(`Manual compare indices ${i1} and ${i2}: ${array[i1]} vs ${array[i2]}`);\n  });\n\n  swapBtn.addEventListener('click', () => {\n    const text = swapIndicesInput.value.trim();\n    const parts = text.split(',');\n    if(parts.length !== 2) {\n      alert('Enter exactly two indices separated by a comma.');\n      return;\n    }\n    const i1 = parseInt(parts[0].trim(), 10);\n    const i2 = parseInt(parts[1].trim(), 10);\n    if(isNaN(i1) || isNaN(i2) || i1<0 || i1>=array.length || i2<0 || i2>=array.length){\n      alert('Invalid indices for swap.');\n      return;\n    }\n    if(i1 === i2) {\n      alert('Swapping same index does nothing.');\n      return;\n    }\n    // Perform swap\n    const temp = array[i1];\n    array[i1] = array[i2];\n    array[i2] = temp;\n    log(`Manually swapped indices ${i1} and ${i2}: new array [${array.join(', ')}]`);\n    displayArray([i1, i2]);\n  });\n\n  saveBtn.addEventListener('click', () => {\n    saveLoadArea.value = JSON.stringify(array);\n    log('Array saved to text box.');\n  });\n\n  loadBtn.addEventListener('click', () => {\n    const text = saveLoadArea.value.trim();\n    try {\n      const loadedArray = JSON.parse(text);\n      if(!Array.isArray(loadedArray)) throw new Error('Not an array');\n      if(loadedArray.some(x => typeof x !== 'number' || !Number.isInteger(x))) {\n        alert('Array must contain only integers.');\n        return;\n      }\n      setArray(loadedArray);\n      log('Array loaded from text box.');\n      alert('Array loaded successfully.');\n    } catch(e) {\n      alert('Invalid array JSON input.');\n    }\n  });\n\n  // Initialize with default array\n  setArray(parseArrayInput(arrayInput.value));\n  updateSpeedDisplay();\n\n  // Keyboard shortcuts for step and pause in step mode\n  document.addEventListener('keydown', e => {\n    if(modeSelect.value === 'step' && sorting) {\n      if(e.key === ' ') {\n        e.preventDefault();\n        stepModeSortingStep();\n      } else if(e.key.toLowerCase() === 'p') {\n        e.preventDefault();\n        pauseSorting();\n      }\n    }\n  });\n})();\n</script>\n\n</body>\n</html>"
  },
