  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Space Complexity Explorer</title>\n    <style>\n        body {\n            font-family: Arial, margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 1000px;\n            margin: 0 auto;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n            margin-bottom: 20px;\n        }\n        button, select, input {\n            margin: 5px;\n            padding: 5px;\n        }\n        .code {\n            font-family: monospace;\n            background-color: #f5f5f5;\n            padding: 10px;\n            overflow-x: auto;\n        }\n        .visualization {\n            height: 300px;\n            border: 1px solid #000;\n            position: relative;\n            overflow: hidden;\n            margin: 20px 0;\n        }\n        .complexity-table {\n            width: 100%;\n            border-collapse: collapse;\n        }\n        .complexity-table th, .complexity-table td {\n            border: 1px solid #000;\n            padding: 8px;\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Space Complexity Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Algorithm Selector</h2>\n            <select id=\"algorithmSelect\">\n                <option value=\"linear\">Linear Search</option>\n                <option value=\"binary\">Binary Search</option>\n                <option value=\"bubble\">Bubble Sort</option>\n                <option value=\"merge\">Merge Sort</option>\n                <option value=\"recursive\">Recursive Fibonacci</option>\n                <option value=\"dynamic\">Dynamic Programming Fibonacci</option>\n            </select>\n            <button id=\"showCodeBtn\">Show Code</button>\n            <button id=\"analyzeBtn\">Analyze Space Complexity</button>\n            <button id=\"visualizeBtn\">Visualize Memory Usage</button>\n        </div>\n        \n        <div class=\"panel\" id=\"codePanel\" style=\"display:none;\">\n            <h2>Algorithm Code</h2>\n            <div id=\"codeDisplay\" class=\"code\"></div>\n            <div>\n                <label>Input Size: <input type=\"range\" id=\"inputSize\" min=\"1\" max=\"100\" value=\"10\"></label>\n                <span id=\"inputSizeValue\">10</span>\n            </div>\n        </div>\n        \n        <div class=\"analysisPanel\" id=\"analysisPanel\" style=\"display:none;\">\n            <h2>Space Complexity Analysis</h2>\n            <div id=\"complexityExplanation\"></div>\n            <div class=\"visualization\" id=\"memoryVisualization\"></div>\n            <div>\n                <button id=\"stepForwardBtn\">Step Forward</button>\n                <button id=\"stepBackwardBtn\">Step Backward</button>\n                <button id=\"playBtn\">Play</button>\n                <button id=\"resetBtn\">Reset</button>\n                <span>Speed: </span>\n                <input type=\"range\" id=\"speedControl\" min=\"1\" max=\"10\" value=\"5\">\n            </div>\n        </div>\n        \n        <div class=\"panel\" id=\"comparisonPanel\" style=\"display:none;\">\n            <h2>Space Complexity Comparison</h2>\n            <table class=\"complexity-table\">\n                <thead>\n                    <tr>\n                        <th>Algorithm</th>\n                        <th>Best Case</th>\n                        <th>Average Case</th>\n                        <th>Worst Case</th>\n                        <th>Compare</th>\n                    </tr>\n                </thead>\n                <tbody id=\"comparisonTable\">\n                </tbody>\n            </table>\n            <button id=\"addToComparisonBtn\">Add Current Algorithm to Comparison</button>\n            <button id=\"clearComparisonBtn\">Clear Comparison</button>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Space Complexity Calculator</h2>\n            <div>\n                <label>Enter your algorithm's space complexity: </label>\n                <input type=\"text\" id=\"complexityInput\" placeholder=\"e.g., O(n), O(1), O(n^2)\">\n                <button id=\"calculateBtn\">Calculate</button>\n            </div>\n            <div id=\"calculationResult\" style=\"margin-top:10px;\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Algorithm data\n        const algorithms = {\n            linear: {\n                name: \"Linear Search\",\n                code: `function linearSearch(arr, target) {\n    for (let i = 0; i < arr.length; i++) {\n        if (arr[i] === target) return i;\n    }\n    return -1;\n}`,\n                space: {\n                    best: \"O(1)\",\n                    average: \"O(1)\",\n                    worst: \"O(1)\",\n                    explanation: \"Uses constant space for variables (i, arr, target) regardless of input size.\"\n                }\n            },\n            binary: {\n                name: \"Binary Search\",\n                code: `function binarySearch(arr, target) {\n    let left = 0;\n    let right = arr.length - 1;\n    \n    while (left <= right) {\n        const mid = Math.floor((left + right) / 2);\n        if (arr[mid] === target) return mid;\n        if (arr[mid] < target) left = mid + 1;\n        else right = mid - 1;\n    }\n    return -1;\n}`,\n                space: {\n                    best: \"O(1)\",\n                    average: \"O(1)\",\n                    worst: \"O(1)\",\n                    explanation: \"Uses constant space for variables (left, right, mid) regardless of input size.\"\n                }\n            },\n            bubble: {\n                name: \"Bubble Sort\",\n                code: `function bubbleSort(arr) {\n    let n = arr.length;\n    for (let i = 0; i < n-1; i++) {\n        for (let j = 0; j < n-i-1; j++) {\n            if (arr[j] > arr[j+1]) {\n                // Swap\n                let temp = arr[j];\n                arr[j] = arr[j+1];\n                arr[j+1] = temp;\n            }\n        }\n    }\n    return arr;\n}`,\n                space: {\n                    best: \"O(1)\",\n                    average: \"O(1)\",\n                    worst: \"O(1)\",\n                    explanation: \"Sorts in-place using constant extra space for temporary variables.\"\n                }\n            },\n            merge: {\n                name: \"Merge Sort\",\n                code: `function mergeSort(arr) {\n    if (arr.length <= 1) return arr;\n    \n    const mid = Math.floor(arr.length / 2);\n    const left = mergeSort(arr.slice(0, mid));\n    const right = mergeSort(arr.slice(mid));\n    \n    return merge(left, right);\n}\n\nfunction merge(left, right) {\n    let result = [];\n    let leftIndex = 0;\n    let rightIndex = 0;\n    \n    while (leftIndex < left.length && rightIndex < right.length) {\n        if (left[leftIndex] < right[rightIndex]) {\n            result.push(left[leftIndex]);\n        } else {\n            result.push(right[rightIndex]);\n        }\n    }\n    \n    return result.concat(left.slice(leftIndex)).concat(right.slice(rightIndex));\n}`,\n                space: {\n                    best: \"O(n)\",\n                    average: \"O(n)\",\n                    worst: \"O(n)\",\n                    explanation: \"Requires O(n) auxiliary space for temporary arrays during merging.\"\n                }\n            },\n            recursive: {\n                name: \"Recursive Fibonacci\",\n                code: `function fibonacci(n) {\n    if (n <= 1) return n;\n    return fibonacci(n-1) + fibonacci(n-2);\n}`,\n                space: {\n                    best: \"O(n)\",\n                    average: \"O(n)\",\n                    worst: \"O(n)\",\n                    explanation: \"Call stack grows linearly with n due to recursion depth.\"\n                }\n            },\n            dynamic: {\n                name: \"Dynamic Programming Fibonacci\",\n                code: `function fibonacci(n) {\n    if (n <= 1) return n;\n    \n    let fib = [0, 1];\n    for (let i = 2; i <= n; i++) {\n        fib[i] = fib[i-1] + fib[i-2];\n    }\n    \n    return fib[n];\n}`,\n                space: {\n                    best: \"O(n)\",\n                    average: \"O(n)\",\n                    worst: \"O(n)\",\n                    explanation: \"Uses an array of size n to store intermediate results.\"\n                }\n            }\n        };\n\n        // DOM elements\n        const algorithmSelect = document.getElementById('algorithmSelect');\n        const showCodeBtn = document.getElementById('showCodeBtn');\n        const analyzeBtn = document.getElementById('analyzeBtn');\n        const visualizeBtn = document.getElementById('visualizeBtn');\n        const codePanel = document.getElementById('codePanel');\n        const codeDisplay = document.getElementById('codeDisplay');\n        const inputSize = document.getElementById('inputSize');\n        const inputSizeValue = document.getElementById('inputSizeValue');\n        const analysisPanel = document.getElementById('analysisPanel');\n        const complexityExplanation = document.getElementById('complexityExplanation');\n        const memoryVisualization = document.getElementById('memoryVisualization');\n        const stepForwardBtn = document.getElementById('stepForwardBtn');\n        const stepBackwardBtn = document.getElementById('stepBackwardBtn');\n        const playBtn = document.getElementById('playBtn');\n        const resetBtn = document.getElementById('resetBtn');\n        const speedControl = document.getElementById('speedControl');\n        const comparisonPanel = document.getElementById('comparisonPanel');\n        const comparisonTable = document.getElementById('comparisonTable');\n        const addToComparisonBtn = document.getElementById('addToComparisonBtn');\n        const clearComparisonBtn = document.getElementById('clearComparisonBtn');\n        const complexityInput = document.getElementById('complexityInput');\n        const calculateBtn = document.getElementById('calculateBtn');\n        const calculationResult = document.getElementById('calculationResult');\n\n        // State\n        let currentAlgorithm = 'linear';\n        let currentStep = 0;\n        let animationInterval = null;\n        let comparisonAlgorithms = [];\n\n        // Event listeners\n        algorithmSelect.addEventListener('change', () => {\n            currentAlgorithm = algorithmSelect.value;\n            resetAnalysis();\n        });\n\n        showCodeBtn.addEventListener('click', () => {\n            codeDisplay.textContent = algorithms[currentAlgorithm].code;\n            codePanel.style.display = 'block';\n            analysisPanel.style.display = 'none';\n            comparisonPanel.style.display = 'none';\n        });\n\n        analyzeBtn.addEventListener('click', () => {\n            const algo = algorithms[currentAlgorithm];\n            complexityExplanation.innerHTML = `\n                <h3>${algo.name} Space Complexity</h3>\n                <p><strong>Best Case:</strong> ${algo.space.best}</p>\n                <p><strong>Average Case:</strong> ${algo.space.average}</p>\n                <p><strong>Worst Case:</strong> ${algo.space.worst}</p>\n                <p><strong>Explanation:</strong> ${algo.space.explanation}</p>\n            `;\n            analysisPanel.style.display = 'block';\n            codePanel.style.display = 'none';\n            comparisonPanel.style.display = 'none';\n        });\n\n        visualizeBtn.addEventListener('click', () => {\n            visualizeMemoryUsage();\n            analysisPanel.style.display = 'block';\n            codePanel.style.display = 'none';\n            comparisonPanel.style.display = 'none';\n        });\n\n        inputSize.addEventListener('input', () => {\n            inputSizeValue.textContent = inputSize.value;\n        });\n\n        stepForwardBtn.addEventListener('click', stepForward);\n        stepBackwardBtn.addEventListener('click', stepBackward);\n        playBtn.addEventListener('click', togglePlay);\n        resetBtn.addEventListener('click', resetVisualization);\n        speedControl.addEventListener('input', updateSpeed);\n\n        addToComparisonBtn.addEventListener('click', addToComparison);\n        clearComparisonBtn.addEventListener('click', clearComparison);\n\n        calculateBtn.addEventListener('click', calculateComplexity);\n\n        // Functions\n        function resetAnalysis() {\n            codePanel.style.display = 'none';\n            analysisPanel.style.display = 'none';\n            comparisonPanel.style.display = 'none';\n            resetVisualization();\n        }\n\n        function visualizeMemoryUsage() {\n            memoryVisualization.innerHTML = '';\n            currentStep = 0;\n            \n            const algo = algorithms[currentAlgorithm];\n            const size = parseInt(inputSize.value);\n            \n            if (currentAlgorithm === 'linear' || currentAlgorithm === 'binary') {\n                // Simple visualization for constant space\n                const container = document.createElement('div');\n                container.style.position = 'absolute';\n                container.style.bottom = '0';\n                container.style.left = '50%';\n                container.style.transform = 'translateX(-50%)';\n                container.style.width = '100px';\n                container.style.height = '50px';\n                container.style.backgroundColor = '#ddd';\n                container.style.border = '1px solid #000';\n                container.textContent = 'Constant Space';\n                memoryVisualization.appendChild(container);\n            } \n            else if (currentAlgorithm === 'merge') {\n                // Visualization for O(n) space\n                const maxHeight = memoryVisualization.clientHeight - 20;\n                const width = 20;\n                const spacing = 5;\n                \n                for (let i = 0; i < size; i++) {\n                    const bar = document.createElement('div');\n                    bar.style.position = 'absolute';\n                    bar.style.bottom = '0';\n                    bar.style.left = `${i * (width + spacing)}px`;\n                    bar.style.width = `${width}px`;\n                    bar.style.height = `${maxHeight * 0.3}px`;\n                    bar.style.backgroundColor = '#ddd';\n                    bar.style.border = '1px solid #000';\n                    bar.textContent = 'Aux';\n                    memoryVisualization.appendChild(bar);\n                }\n            }\n            else if (currentAlgorithm === 'recursive') {\n                // Visualization for recursive call stack\n                const maxHeight = memoryVisualization.clientHeight;\n                const width = 30;\n                \n                for (let i = 0; i < Math.min(size, 10); i++) {\n                    const frame = document.createElement('div');\n                    frame.style.position = 'absolute';\n                    frame.style.bottom = `${i * 30}px`;\n                    frame.style.left = '50%';\n                    frame.style.transform = 'translateX(-50%)';\n                    frame.style.width = `${width + i * 5}px`;\n                    frame.style.height = '25px';\n                    frame.style.backgroundColor = '#ddd';\n                    frame.style.border = '1px solid #000';\n                    frame.textContent = `fib(${size - i})`;\n                    memoryVisualization.appendChild(frame);\n                }\n            }\n            else if (currentAlgorithm === 'dynamic') {\n                // Visualization for DP array\n                const maxHeight = memoryVisualization.clientHeight - 20;\n                const width = 20;\n                const spacing = 5;\n                \n                for (let i = 0; i < size; i++) {\n                    const cell = document.createElement('div');\n                    cell.style.position = 'absolute';\n                    cell.style.bottom = '0';\n                    cell.style.left = `${i * (width + spacing)}px`;\n                    cell.style.width = `${width}px`;\n                    cell.style.height = `${maxHeight * 0.5}px`;\n                    cell.style.backgroundColor = '#ddd';\n                    cell.style.border = '1px solid #000';\n                    cell.textContent = i <= 1 ? i : '?';\n                    memoryVisualization.appendChild(cell);\n                }\n            }\n        }\n\n        function stepForward() {\n            // In a real implementation, this would advance the visualization step\n            currentStep++;\n            updateVisualization();\n        }\n\n        function stepBackward() {\n            if (currentStep > 0) {\n                currentStep--;\n                updateVisualization();\n            }\n        }\n\n        function togglePlay() {\n            if (animationInterval) {\n                clearInterval(animationInterval);\n                animationInterval = null;\n                playBtn.textContent = 'Play';\n            } else {\n                playBtn.textContent = 'Pause';\n                animationInterval = setInterval(stepForward, 1000 / speedControl.value);\n            }\n        }\n\n        function resetVisualization() {\n            if (animationInterval) {\n                clearInterval(animationInterval);\n                animationInterval = null;\n                playBtn.textContent = 'Play';\n            }\n            currentStep = 0;\n            updateVisualization();\n        }\n\n        function updateVisualization() {\n            // Update visualization based on current step\n            // This is a simplified version - a real implementation would have more detailed steps\n            const elements = memoryVisualization.querySelectorAll('div');\n            elements.forEach((el, index) => {\n                if (index < currentStep) {\n                    el.style.backgroundColor = '#aaa';\n                } else {\n                    el.style.backgroundColor = '#ddd';\n                }\n            });\n        }\n\n        function updateSpeed() {\n            if (animationInterval) {\n                clearInterval(animationInterval);\n                animationInterval = setInterval(stepForward, 1000 / speedControl.value);\n            }\n        }\n\n        function addToComparison() {\n            const algo = algorithms[currentAlgorithm];\n            if (!comparisonAlgorithms.includes(currentAlgorithm)) {\n                comparisonAlgorithms.push(currentAlgorithm);\n                updateComparisonTable();\n                comparisonPanel.style.display = 'block';\n            }\n        }\n\n        function clearComparison() {\n            comparisonAlgorithms = [];\n            comparisonTable.innerHTML = '';\n            comparisonPanel.style.display = 'none';\n        }\n\n        function updateComparisonTable() {\n            comparisonTable.innerHTML = '';\n            comparisonAlgorithms.forEach(algoKey => {\n                const algo = algorithms[algoKey];\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${algo.name}</td>\n                    <td>${algo.space.best}</td>\n                    <td>${algo.space.average}</td>\n                    <td>${algo.space.worst}</td>\n                    <td><button onclick=\"removeFromComparison('${algoKey}')\">Remove</button></td>\n                `;\n                comparisonTable.appendChild(row);\n            });\n        }\n\n        function removeFromComparison(algoKey) {\n            comparisonAlgorithms = comparisonAlgorithms.filter(a => a !== algoKey);\n            updateComparisonTable();\n            if (comparisonAlgorithms.length === 0) {\n                comparisonPanel.style.display = 'none';\n            }\n        }\n\n        function calculateComplexity() {\n            const complexity = complexityInput.value.trim();\n            const validComplexities = ['O(1)', 'O(log n)', 'O(n)', 'O(n log n)', 'O(n^2)', 'O(2^n)', 'O(n!)'];\n            \n            if (!validComplexities.includes(complexity)) {\n                calculationResult.innerHTML = `<p style=\"color:red;\">Invalid complexity notation. Please use one of: ${validComplexities.join(', ')}</p>`;\n                return;\n            }\n            \n            let explanation = '';\n            let example = '';\n            \n            switch(complexity) {\n                case 'O(1)':\n                    explanation = 'Constant space - memory usage doesn't grow with input size.';\n                    example = 'Example: A function that uses a fixed number of variables.';\n                    break;\n                case 'O(log n)':\n                    explanation = 'Logarithmic space - memory usage increases logarithmically with input size.';\n                    example = 'Example: Some recursive algorithms that divide the problem in half each step.';\n                    break;\n                case 'O(n)':\n                    explanation = 'Linear space - memory usage grows proportionally with input size.';\n                    example = 'Example: Creating a copy of an array or building a hash table.';\n                    break;\n                case 'O(n log n)':\n                    explanation = 'Linearithmic space - memory usage is between linear and quadratic.';\n                    example = 'Example: Some sorting algorithms that use additional space.';\n                    break;\n                case 'O(n^2)':\n                    explanation = 'Quadratic space - memory usage grows with the square of input size.';\n                    example = 'Example: Creating a 2D array or adjacency matrix.';\n                    break;\n                case 'O(2^n)':\n                    explanation = 'Exponential space - memory usage grows very rapidly.';\n                    example = 'Example: Some brute-force recursive algorithms.';\n                    break;\n                case 'O(n!)':\n                    explanation = 'Factorial space - memory usage grows extremely rapidly.';\n                    example = 'Example: Algorithms that generate all permutations.';\n                    break;\n            }\n            \n            calculationResult.innerHTML = `\n                <h3>${complexity} Space Complexity</h3>\n                <p><strong>Explanation:</strong> ${explanation}</p>\n                <p><strong>Example:</strong> ${example}</p>\n                <p><strong>When to use:</strong> ${getWhenToUse(complexity)}</p>\n            `;\n        }\n\n        function getWhenToUse(complexity) {\n            switch(complexity) {\n                case 'O(1)': return 'Ideal - use whenever possible.';\n                case 'O(log n)': return 'Excellent - scales very well with large inputs.';\n                case 'O(n)': return 'Good - acceptable for most practical purposes.';\n                case 'O(n log n)': return 'Fair - acceptable for moderate input sizes.';\n                case 'O(n^2)': return 'Poor - avoid for large inputs.';\n                case 'O(2^n)': return 'Very poor - only for very small inputs.';\n                case 'O(n!)': return 'Extremely poor - avoid except for tiny inputs.';\n                default: return '';\n            }\n        }\n\n        // Make removeFromComparison available globally\n        window.removeFromComparison = removeFromComparison;\n\n        // Initialize\n        resetAnalysis();\n    </script>\n</body>\n</html>"
