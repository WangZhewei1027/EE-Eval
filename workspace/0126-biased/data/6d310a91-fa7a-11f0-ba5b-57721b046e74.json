  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Transaction System</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #000; padding: 10px; margin-bottom: 10px; }\n        .hidden { display: none; }\n        table { width: 100%; border-collapse: collapse; }\n        th, td { border: 1px solid #000; padding: 5px; text-align: left; }\n        input, select, button { margin: 5px 0; }\n        .error { color: red; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Transaction System</h1>\n        \n        <!-- Account Selection -->\n        <div class=\"panel\" id=\"accountPanel\">\n            <h2>Account Selection</h2>\n            <div>\n                <label>Select Account:</label>\n                <select id=\"accountSelect\">\n                    <option value=\"\">-- Select Account --</option>\n                    <option value=\"checking\">Checking (Balance: $1,500.00)</option>\n                    <option value=\"savings\">Savings (Balance: $5,000.00)</option>\n                    <option value=\"credit\">Credit Card (Balance: -$250.00)</option>\n                </select>\n                <button id=\"viewAccountBtn\">View Account Details</button>\n            </div>\n            <div id=\"accountDetails\" class=\"hidden\">\n                <h3>Account Details</h3>\n                <div id=\"accountInfo\"></div>\n                <button id=\"newTransactionBtn\">New Transaction</button>\n                <button id=\"viewHistoryBtn\">View Transaction History</button>\n            </div>\n        </div>\n        \n        <!-- Transaction Creation -->\n        <div class=\"panel hidden\" id=\"transactionPanel\">\n            <h2>Create Transaction</h2>\n            <div>\n                <label>Transaction Type:</label>\n                <select id=\"transactionType\">\n                    <option value=\"deposit\">Deposit</option>\n                    <option value=\"withdrawal\">Withdrawal</option>\n                    <option value=\"transfer\">Transfer</option>\n                    <option value=\"payment\">Payment</option>\n                </select>\n            </div>\n            \n            <div id=\"amountSection\">\n                <label>Amount: $</label>\n                <input type=\"number\" id=\"transactionAmount\" min=\"0.01\" step=\"0.01\">\n            </div>\n            \n            <div id=\"transferSection\" class=\"hidden\">\n                <label>Transfer To:</label>\n                <select id=\"transferAccount\">\n                    <option value=\"\">-- Select Account --</option>\n                    <option value=\"checking\">Checking</option>\n                    <option value=\"savings\">Savings</option>\n                    <option value=\"credit\">Credit Card</option>\n                </select>\n            </div>\n            \n            <div id=\"paymentSection\" class=\"hidden\">\n                <label>Payee:</label>\n                <input type=\"text\" id=\"payeeName\" placeholder=\"Payee name\">\n                <label>Account Number:</label>\n                <input type=\"text\" id=\"payeeAccount\" placeholder=\"Account number\">\n            </div>\n            \n            <div>\n                <label>Description:</label>\n                <input type=\"text\" id=\"transactionDesc\" placeholder=\"Transaction description\">\n            </div>\n            \n            <div>\n                <label>Date:</label>\n                <input type=\"date\" id=\"transactionDate\">\n            </div>\n            \n            <div id=\"transactionError\" class=\"error\"></div>\n            \n            <button id=\"previewTransactionBtn\">Preview Transaction</button>\n            <button id=\"cancelTransactionBtn\">Cancel</button>\n        </div>\n        \n        <!-- Transaction Preview -->\n        <div class=\"panel hidden\" id=\"previewPanel\">\n            <h2>Transaction Preview</h2>\n            <div id=\"previewDetails\"></div>\n            <button id=\"confirmTransactionBtn\">Confirm Transaction</button>\n            <button id=\"editTransactionBtn\">Edit Transaction</button>\n        </div>\n        \n        <!-- Transaction History -->\n        <div class=\"panel hidden\" id=\"historyPanel\">\n            <h2>Transaction History</h2>\n            <div>\n                <label>Filter by:</label>\n                <select id=\"historyFilter\">\n                    <option value=\"all\">All Transactions</option>\n                    <option value=\"deposit\">Deposits</option>\n                    <option value=\"withdrawal\">Withdrawals</option>\n                    <option value=\"transfer\">Transfers</option>\n                    <option value=\"payment\">Payments</option>\n                </select>\n                <label>Date Range:</label>\n                <input type=\"date\" id=\"historyStartDate\">\n                <input type=\"date\" id=\"historyEndDate\">\n                <button id=\"applyFilterBtn\">Apply Filter</button>\n            </div>\n            <table id=\"historyTable\">\n                <thead>\n                    <tr>\n                        <th>Date</th>\n                        <th>Description</th>\n                        <th>Type</th>\n                        <th>Amount</th>\n                        <th>Balance</th>\n                    </tr>\n                </thead>\n                <tbody id=\"historyTableBody\"></tbody>\n            </table>\n            <button id=\"closeHistoryBtn\">Close History</button>\n        </div>\n        \n        <!-- Confirmation -->\n        <div class=\"panel hidden\" id=\"confirmationPanel\">\n            <h2>Transaction Complete</h2>\n            <div id=\"confirmationDetails\"></div>\n            <button id=\"newTransactionFromConfirmBtn\">New Transaction</button>\n            <button id=\"viewAccountFromConfirmBtn\">View Account</button>\n        </div>\n    </div>\n\n    <script>\n        // State management\n        const state = {\n            currentAccount: null,\n            accounts: {\n                checking: { balance: 1500.00, transactions: [] },\n                savings: { balance: 5000.00, transactions: [] },\n                credit: { balance: -250.00, transactions: [] }\n            },\n            transactionInProgress: null\n        };\n\n        // DOM elements\n        const elements = {\n            accountSelect: document.getElementById('accountSelect'),\n            viewAccountBtn: document.getElementById('viewAccountBtn'),\n            accountDetails: document.getElementById('accountDetails'),\n            accountInfo: document.getElementById('accountInfo'),\n            newTransactionBtn: document.getElementById('newTransactionBtn'),\n            viewHistoryBtn: document.getElementById('viewHistoryBtn'),\n            transactionPanel: document.getElementById('transactionPanel'),\n            transactionType: document.getElementById('transactionType'),\n            transactionAmount: document.getElementById('transactionAmount'),\n            transferSection: document.getElementById('transferSection'),\n            transferAccount: document.getElementById('transferAccount'),\n            paymentSection: document.getElementById('paymentSection'),\n            payeeName: document.getElementById('payeeName'),\n            payeeAccount: document.getElementById('payeeAccount'),\n            transactionDesc: document.getElementById('transactionDesc'),\n            transactionDate: document.getElementById('transactionDate'),\n            transactionError: document.getElementById('transactionError'),\n            previewTransactionBtn: document.getElementById('previewTransactionBtn'),\n            cancelTransactionBtn: document.getElementById('cancelTransactionBtn'),\n            previewPanel: document.getElementById('previewPanel'),\n            previewDetails: document.getElementById('previewDetails'),\n            confirmTransactionBtn: document.getElementById('confirmTransactionBtn'),\n            editTransactionBtn: document.getElementById('editTransactionBtn'),\n            historyPanel: document.getElementById('historyPanel'),\n            historyFilter: document.getElementById('historyFilter'),\n            historyStartDate: document.getElementById('historyStartDate'),\n            historyEndDate: document.getElementById('historyEndDate'),\n            applyFilterBtn: document.getElementById('applyFilterBtn'),\n            historyTableBody: document.getElementById('historyTableBody'),\n            closeHistoryBtn: document.getElementById('closeHistoryBtn'),\n            confirmationPanel: document.getElementById('confirmationPanel'),\n            confirmationDetails: document.getElementById('confirmationDetails'),\n            newTransactionFromConfirmBtn: document.getElementById('newTransactionFromConfirmBtn'),\n            viewAccountFromConfirmBtn: document.getElementById('viewAccountFromConfirmBtn')\n        };\n\n        // Initialize date fields\n        const today = new Date().toISOString().split('T')[0];\n        elements.transactionDate.value = today;\n        elements.historyStartDate.value = new Date(new Date().setMonth(new Date().getMonth() - 1)).toISOString().split('T')[0];\n        elements.historyEndDate.value = today;\n\n        // Event listeners\n        elements.viewAccountBtn.addEventListener('click', viewAccount);\n        elements.newTransactionBtn.addEventListener('click', startNewTransaction);\n        elements.viewHistoryBtn.addEventListener('click', viewTransactionHistory);\n        elements.transactionType.addEventListener('change', handleTransactionTypeChange);\n        elements.previewTransactionBtn.addEventListener('click', previewTransaction);\n        elements.cancelTransactionBtn.addEventListener('click', cancelTransaction);\n        elements.confirmTransactionBtn.addEventListener('click', confirmTransaction);\n        elements.editTransactionBtn.addEventListener('click', editTransaction);\n        elements.applyFilterBtn.addEventListener('click', applyHistoryFilter);\n        elements.closeHistoryBtn.addEventListener('click', closeHistory);\n        elements.newTransactionFromConfirmBtn.addEventListener('click', startNewTransaction);\n        elements.viewAccountFromConfirmBtn.addEventListener('click', viewAccountFromConfirm);\n\n        // Functions\n        function viewAccount() {\n            const accountId = elements.accountSelect.value;\n            if (!accountId) {\n                alert('Please select an account');\n                return;\n            }\n            \n            state.currentAccount = accountId;\n            const account = state.accounts[accountId];\n            \n            elements.accountInfo.innerHTML = `\n                <p><strong>Account:</strong> ${accountId.charAt(0).toUpperCase() + accountId.slice(1)}</p>\n                <p><strong>Balance:</strong> $${account.balance.toFixed(2)}</p>\n                <p><strong>Last Transaction:</strong> ${account.transactions.length > 0 ? \n                    account.transactions[0].date + 'No transactions yet' : 'No transactions yet'}</p>\n            `;\n            \n            elements.accountDetails.classList.remove('hidden');\n        }\n\n        function startNewTransaction() {\n            elements.transactionPanel.classList.remove('hidden');\n            elements.accountDetails.classList.add('hidden');\n            elements.previewPanel.classList.add('hidden');\n            elements.historyPanel.classList.add('hidden');\n            elements.confirmationPanel.classList.add('hidden');\n            \n            // Reset form\n            elements.transactionAmount.value = '';\n            elements.transactionDesc.value = '';\n            elements.transactionDate.value = today;\n            elements.transactionError.textContent = '';\n            \n            state.transactionInProgress = {\n                account: state.currentAccount,\n                type: 'deposit',\n                amount: 0,\n                description: '',\n                date: today\n            };\n            \n            handleTransactionTypeChange();\n        }\n\n        function handleTransactionTypeChange() {\n            const type = elements.transactionType.value;\n            \n            elements.transferSection.classList.add('hidden');\n            elements.paymentSection.classList.add('hidden');\n            \n            if (type === 'transfer') {\n                elements.transferSection.classList.remove('hidden');\n                // Remove current account from transfer options\n                Array.from(elements.transferAccount.options).forEach(option => {\n                    option.disabled = option.value === state.currentAccount;\n                });\n            } else if (type === 'payment') {\n                elements.paymentSection.classList.remove('hidden');\n            }\n        }\n\n        function previewTransaction() {\n            const amount = parseFloat(elements.transactionAmount.value);\n            if (isNaN(amount) || amount <= 0) {\n                elements.transactionError.textContent = 'Please enter a valid amount';\n                return;\n            }\n            \n            const type = elements.transactionType.value;\n            const description = elements.transactionDesc.value || 'No description';\n            const date = elements.transactionDate.value;\n            \n            state.transactionInProgress = {\n                account: state.currentAccount,\n                type,\n                amount,\n                description,\n                date,\n                transferAccount: type === 'transfer' ? elements.transferAccount.value : null,\n                payeeName: type === 'payment' ? elements.payeeName.value : null,\n                payeeAccount: type === 'payment' ? elements.payeeAccount.value : null\n            };\n            \n            // Validate transfer\n            if (type === 'transfer' && !state.transactionInProgress.transferAccount) {\n                elements.transactionError.textContent = 'Please select a transfer account';\n                return;\n            }\n            \n            // Validate payment\n            if (type === 'payment' && (!state.transactionInProgress.payeeName || !state.transactionInProgress.payeeAccount)) {\n                elements.transactionError.textContent = 'Please enter payee details';\n                return;\n            }\n            \n            // Check sufficient funds for withdrawals/transfers/payments\n            if ((type === 'withdrawal' || type === 'transfer' || type === 'payment') && \n                amount > state.accounts[state.currentAccount].balance) {\n                elements.transactionError.textContent = 'Insufficient funds';\n                return;\n            }\n            \n            elements.transactionError.textContent = '';\n            \n            // Show preview\n            let previewText = `\n                <p><strong>Type:</strong> ${type.charAt(0).toUpperCase() + type.slice(1)}</p>\n                <p><strong>Amount:</strong> $${amount.toFixed(2)}</p>\n                <p><strong>Date:</strong> ${date}</p>\n                <p><strong>Description:</strong> ${description}</p>\n            `;\n            \n            if (type === 'transfer') {\n                previewText += `<p><strong>Transfer To:</strong> ${state.transactionInProgress.transferAccount.charAt(0).toUpperCase() + state.transactionInProgress.transferAccount.slice(1)}</p>`;\n            }\n            \n            if (type === 'payment') {\n                previewText += `\n                    <p><strong>Payee:</strong> ${state.transactionInProgress.payeeName}</p>\n                    <p><strong>Account:</strong> ${state.transactionInProgress.payeeAccount}</p>\n                `;\n            }\n            \n            elements.previewDetails.innerHTML = previewText;\n            elements.transactionPanel.classList.add('hidden');\n            elements.previewPanel.classList.remove('hidden');\n        }\n\n        function cancelTransaction() {\n            elements.transactionPanel.classList.add('hidden');\n            elements.accountDetails.classList.remove('hidden');\n            state.transactionInProgress = null;\n        }\n\n        function confirmTransaction() {\n            const transaction = state.transactionInProgress;\n            const account = state.accounts[transaction.account];\n            \n            // Process transaction\n            const transactionRecord = {\n                id: Date.now(),\n                date: transaction.date,\n                type: transaction.type,\n                amount: transaction.amount,\n                description: transaction.description,\n                balanceBefore: account.balance\n            };\n            \n            switch (transaction.type) {\n                case 'deposit':\n                    account.balance += transaction.amount;\n                    break;\n                case 'withdrawal':\n                    account.balance -= transaction.amount;\n                    break;\n                case 'transfer':\n                    account.balance -= transaction.amount;\n                    state.accounts[transaction.transferAccount].balance += transaction.amount;\n                    \n                    // Create transaction record for destination account\n                    const destTransaction = {\n                        id: transactionRecord.id,\n                        date: transaction.date,\n                        type: 'deposit',\n                        amount: transaction.amount,\n                        description: `Transfer from ${transaction.account}`,\n                        balanceBefore: state.accounts[transaction.transferAccount].balance - transaction.amount\n                    };\n                    state.accounts[transaction.transferAccount].transactions.unshift(destTransaction);\n                    break;\n                case 'payment':\n                    account.balance -= transaction.amount;\n                    transactionRecord.payee = transaction.payeeName;\n                    transactionRecord.payeeAccount = transaction.payeeAccount;\n                    break;\n            }\n            \n            transactionRecord.balanceAfter = account.balance;\n            account.transactions.unshift(transactionRecord);\n            \n            // Show confirmation\n            elements.confirmationDetails.innerHTML = `\n                <p>Transaction completed successfully</p>\n                <p><strong>New Balance:</strong> $${account.balance.toFixed(2)}</p>\n                <p><strong>Transaction ID:</strong> ${transactionRecord.id}</p>\n            `;\n            \n            elements.previewPanel.classList.add('hidden');\n            elements.confirmationPanel.classList.remove('hidden');\n            state.transactionInProgress = null;\n        }\n\n        function editTransaction() {\n            elements.previewPanel.classList.add('hidden');\n            elements.transactionPanel.classList.remove('hidden');\n        }\n\n        function viewTransactionHistory() {\n            elements.historyPanel.classList.remove('hidden');\n            elements.accountDetails.classList.add('hidden');\n            applyHistoryFilter();\n        }\n\n        function applyHistoryFilter() {\n            const filter = state.currentAccount;\n            const typeFilter = elements.historyFilter.value;\n            const startDate = elements.historyStartDate.value;\n            const endDate = elements.historyEndDate.value;\n            \n            const transactions = state.accounts[filter].transactions;\n            \n            let filteredTransactions = transactions;\n            \n            if (typeFilter !== 'all') {\n                filteredTransactions = filteredTransactions.filter(t => t.type === typeFilter);\n            }\n            \n            if (startDate) {\n                filteredTransactions = filteredTransactions.filter(t => t.date >= startDate);\n            }\n            \n            if (endDate) {\n                filteredTransactions = filteredTransactions.filter(t => t.date <= endDate);\n            }\n            \n            // Populate table\n            elements.historyTableBody.innerHTML = '';\n            \n            if (filteredTransactions.length === 0) {\n                elements.historyTableBody.innerHTML = '<tr><td colspan=\"5\">No transactions found</td></tr>';\n                return;\n            }\n            \n            filteredTransactions.forEach(t => {\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${t.date}</td>\n                    <td>${t.description}</td>\n                    <td>${t.type.charAt(0).toUpperCase() + t.type.slice(1)}</td>\n                    <td>${t.type === 'withdrawal' || t.type === 'payment' || t.type === 'transfer' ? '-' : ''}$${t.amount.toFixed(2)}</td>\n                    <td>$${t.balanceAfter.toFixed(2)}</td>\n                `;\n                elements.historyTableBody.appendChild(row);\n            });\n        }\n\n        function closeHistory() {\n            elements.historyPanel.classList.add('hidden');\n            elements.accountDetails.classList.remove('hidden');\n        }\n\n        function viewAccountFromConfirm() {\n            elements.confirmationPanel.classList.add('hidden');\n            viewAccount();\n        }\n\n        // Initialize with some sample transactions\n        function initializeSampleData() {\n            const now = new Date();\n            const yesterday = new Date(now);\n            yesterday.setDate(now.getDate() - 1);\n            const lastWeek = new Date(now);\n            lastWeek.setDate(now.getDate() - 7);\n            \n            state.accounts.checking.transactions = [\n                {\n                    id: 1001,\n                    date: now.toISOString().split('T')[0],\n                    type: 'deposit',\n                    amount: 500.00,\n                    description: 'Paycheck',\n                    balanceBefore: 1000.00,\n                    balanceAfter: 1500.00\n                },\n                {\n                    id: 1002,\n                    date: yesterday.toISOString().split('T')[0],\n                    type: 'withdrawal',\n                    amount: 200.00,\n                    description: 'ATM Withdrawal',\n                    balanceBefore: 1200.00,\n                    balanceAfter: 1000.00\n                }\n            ];\n            \n            state.accounts.savings.transactions = [\n                {\n                    id: 2001,\n                    date: lastWeek.toISOString().split('T')[0],\n                    type: 'deposit',\n                    amount: 1000.00,\n                    description: 'Monthly savings',\n                    balanceBefore: 4000.00,\n                    balanceAfter: 5000.00\n                }\n            ];\n            \n            state.accounts.credit.transactions = [\n                {\n                    id: 3001,\n                    date: yesterday.toISOString().split('T')[0],\n                    type: 'payment',\n                    amount: 50.00,\n                    description: 'Grocery store',\n                    balanceBefore: -200.00,\n                    balanceAfter: -250.00\n                }\n            ];\n        }\n\n        initializeSampleData();\n    </script>\n</body>\n</html>"
  },
