  "question": "Context Switching",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Context Switching Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  .section {\n    margin-bottom: 1em;\n    border: 1px solid black;\n    padding: 0.5em;\n  }\n  label, button {\n    cursor: pointer;\n  }\n  input[type=\"text\"], textarea {\n    width: 100%;\n    font-family: monospace;\n    font-size: 1em;\n  }\n  select {\n    font-family: monospace;\n    font-size: 1em;\n  }\n  .log {\n    white-space: pre-wrap;\n    height: 10em;\n    overflow-y: scroll;\n    border: 1px solid black;\n    padding: 0.3em;\n    font-size: 0.9em;\n    background-color: white;\n    margin-top: 0.3em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Context Switching Interactive Demo</h1>\n\n<div class=\"section\" id=\"context-creation-section\">\n  <h2>Create/Edit Context</h2>\n  <label for=\"ctx-name-input\">Context Name:</label><br />\n  <input type=\"text\" id=\"ctx-name-input\" placeholder=\"Enter context name\" /><br /><br />\n\n  <label for=\"ctx-description-input\">Context Description:</label><br />\n  <textarea id=\"ctx-description-input\" rows=\"3\" placeholder=\"Describe this context\"></textarea><br /><br />\n\n  <label for=\"ctx-data-input\">Context Data (JSON format):</label><br />\n  <textarea id=\"ctx-data-input\" rows=\"5\" placeholder='{\"key1\": \"value1\", \"key2\": 2}'></textarea><br /><br />\n\n  <button id=\"ctx-save-btn\">Save Context</button>\n  <button id=\"ctx-clear-btn\">Clear Inputs</button>\n  <div id=\"ctx-validation-msg\" style=\"color:red; font-weight:bold; margin-top:0.3em;\"></div>\n</div>\n\n<div class=\"section\" id=\"context-list-section\">\n  <h2>Available Contexts</h2>\n  <select id=\"ctx-list\" size=\"6\" style=\"width: 100%;\"></select><br /><br />\n  <button id=\"ctx-load-btn\" disabled>Load Selected Context</button>\n  <button id=\"ctx-delete-btn\" disabled>Delete Selected Context</button>\n</div>\n\n<div class=\"section\" id=\"context-switching-section\">\n  <h2>Context Switching</h2>\n  <div>\n    <label>Current Context:</label>\n    <span id=\"current-context-name\">[None]</span><br />\n    <textarea id=\"current-context-data\" rows=\"6\" readonly placeholder=\"No context loaded\"></textarea>\n  </div>\n  <br />\n  <label for=\"switch-target-select\">Switch To Context:</label><br />\n  <select id=\"switch-target-select\" style=\"width: 100%;\"></select><br /><br />\n\n  <label for=\"switch-mode-select\">Switch Mode:</label><br />\n  <select id=\"switch-mode-select\" style=\"width: 100%;\">\n    <option value=\"instant\">Instant (Replace)</option>\n    <option value=\"overlay\">Overlay (Merge)</option>\n    <option value=\"sandbox\">Sandbox (Isolated copy)</option>\n  </select><br /><br />\n\n  <button id=\"perform-switch-btn\" disabled>Perform Context Switch</button><br /><br />\n\n  <label for=\"switch-undo-levels\">Undo Levels (steps to remember):</label><br />\n  <input type=\"number\" min=\"1\" max=\"100\" id=\"switch-undo-levels\" value=\"10\" /><br /><br />\n\n  <button id=\"undo-switch-btn\" disabled>Undo Last Switch</button>\n  <button id=\"redo-switch-btn\" disabled>Redo Switch</button>\n  <br /><br />\n\n  <label for=\"switch-history-select\">Switch History:</label><br />\n  <select id=\"switch-history-select\" size=\"5\" style=\"width: 100%;\"></select><br /><br />\n\n  <button id=\"load-history-select-btn\" disabled>Load Selected History State as Current</button>\n</div>\n\n<div class=\"section\" id=\"interaction-logging-section\">\n  <h2>Interaction Log</h2>\n  <button id=\"clear-log-btn\">Clear Log</button><br /><br />\n  <div class=\"log\" id=\"interaction-log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n</div>\n\n<script>\n(function(){\n  // Storage keys\n  const STORAGE_CTX_KEY = \"cs_contexts\";\n  const STORAGE_HISTORY_KEY = \"cs_switch_history\";\n\n  // State variables\n  let contexts = {}; // { name: {name, description, dataObject} }\n  let currentContext = null; // {name, description, dataObject}\n  let switchHistory = []; // array of {timestamp, fromContextName, toContextName, mode, stateSnapshot}\n  let undoIndex = -1; // points to current position in history for undo/redo\n  let maxUndoLevels = 10;\n\n  // DOM references\n  const ctxNameInput = document.getElementById(\"ctx-name-input\");\n  const ctxDescriptionInput = document.getElementById(\"ctx-description-input\");\n  const ctxDataInput = document.getElementById(\"ctx-data-input\");\n  const ctxSaveBtn = document.getElementById(\"ctx-save-btn\");\n  const ctxClearBtn = document.getElementById(\"ctx-clear-btn\");\n  const ctxValidationMsg = document.getElementById(\"ctx-validation-msg\");\n  const ctxListSelect = document.getElementById(\"ctx-list\");\n  const ctxLoadBtn = document.getElementById(\"ctx-load-btn\");\n  const ctxDeleteBtn = document.getElementById(\"ctx-delete-btn\");\n\n  const currentContextNameSpan = document.getElementById(\"current-context-name\");\n  const currentContextDataArea = document.getElementById(\"current-context-data\");\n  const switchTargetSelect = document.getElementById(\"switch-target-select\");\n  const switchModeSelect = document.getElementById(\"switch-mode-select\");\n  const performSwitchBtn = document.getElementById(\"perform-switch-btn\");\n  const switchUndoLevelsInput = document.getElementById(\"switch-undo-levels\");\n  const undoSwitchBtn = document.getElementById(\"undo-switch-btn\");\n  const redoSwitchBtn = document.getElementById(\"redo-switch-btn\");\n  const switchHistorySelect = document.getElementById(\"switch-history-select\");\n  const loadHistorySelectBtn = document.getElementById(\"load-history-select-btn\");\n\n  const interactionLog = document.getElementById(\"interaction-log\");\n  const clearLogBtn = document.getElementById(\"clear-log-btn\");\n\n  // Utility functions\n  function logInteraction(msg){\n    const now = new Date();\n    const timestamp = now.toLocaleTimeString() + \".\" + now.getMilliseconds().toString().padStart(3, '0');\n    interactionLog.textContent += `[${timestamp}] ${msg}\\n`;\n    interactionLog.scrollTop = interactionLog.scrollHeight;\n  }\n\n  function saveContextsToStorage(){\n    try{\n      localStorage.setItem(STORAGE_CTX_KEY, JSON.stringify(contexts));\n      logInteraction(\"Contexts saved to localStorage.\");\n    } catch(e) {\n      logInteraction(\"Error saving contexts: \" + e.toString());\n    }\n  }\n\n  function loadContextsFromStorage(){\n    const json = localStorage.getItem(STORAGE_CTX_KEY);\n    if(json){\n      try{\n        contexts = JSON.parse(json);\n        // Validate all contexts, remove any invalid ones\n        for(let k in contexts){\n          if(!contexts[k].name || !contexts[k].hasOwnProperty(\"dataObject\")){\n            delete contexts[k];\n          }\n        }\n      } catch(e){\n        contexts = {};\n        logInteraction(\"Failed to parse contexts from localStorage, starting fresh.\");\n      }\n    }\n  }\n\n  function saveHistoryToStorage(){\n    try{\n      localStorage.setItem(STORAGE_HISTORY_KEY, JSON.stringify({history:switchHistory, undoIndex:undoIndex}));\n      logInteraction(\"Switch history saved to localStorage.\");\n    } catch(e) {\n      logInteraction(\"Error saving history: \" + e.toString());\n    }\n  }\n\n  function loadHistoryFromStorage(){\n    const json = localStorage.getItem(STORAGE_HISTORY_KEY);\n    if(json){\n      try{\n        const obj = JSON.parse(json);\n        if(Array.isArray(obj.history) && typeof obj.undoIndex === \"number\"){\n          switchHistory = obj.history;\n          undoIndex = obj.undoIndex;\n        } else {\n          switchHistory = [];\n          undoIndex = -1;\n        }\n      } catch(e){\n        switchHistory = [];\n        undoIndex = -1;\n      }\n    }\n  }\n\n  // UI update functions\n  function updateContextList(){\n    // Clear\n    ctxListSelect.innerHTML = \"\";\n    switchTargetSelect.innerHTML = \"\";\n\n    // Alphabetical order\n    const ordered = Object.keys(contexts).sort();\n    for(let name of ordered){\n      const option1 = document.createElement(\"option\");\n      option1.value = name;\n      option1.textContent = name;\n      ctxListSelect.appendChild(option1);\n\n      const option2 = document.createElement(\"option\");\n      option2.value = name;\n      option2.textContent = name;\n      switchTargetSelect.appendChild(option2);\n    }\n\n    ctxLoadBtn.disabled = ctxListSelect.selectedIndex === -1 || ctxListSelect.options.length === 0;\n    ctxDeleteBtn.disabled = ctxLoadBtn.disabled;\n\n    performSwitchBtn.disabled = switchTargetSelect.selectedIndex === -1 || switchTargetSelect.options.length === 0 || currentContext === null || \n      switchTargetSelect.value === currentContext.name;\n  }\n\n  function updateCurrentContextDisplay(){\n    if(currentContext){\n      currentContextNameSpan.textContent = currentContext.name;\n      try {\n        currentContextDataArea.value = JSON.stringify(currentContext.dataObject, null, 2);\n      } catch(e){\n        currentContextDataArea.value = \"[Unable to display data]\";\n      }\n    } else {\n      currentContextNameSpan.textContent = \"[None]\";\n      currentContextDataArea.value = \"\";\n    }\n  }\n\n  function updateUndoRedoButtons(){\n    undoSwitchBtn.disabled = undoIndex <= 0;\n    redoSwitchBtn.disabled = undoIndex >= switchHistory.length-1 || undoIndex === -1;\n  }\n\n  function updateHistoryList(){\n    switchHistorySelect.innerHTML = \"\";\n    switchHistory.forEach((entry,i)=>{\n      const option = document.createElement(\"option\");\n      const d = new Date(entry.timestamp);\n      option.value = i;\n      option.textContent = `${i+1}: ${entry.fromContextName || \"[none]\"} → ${entry.toContextName || \"[none]\"} | Mode: ${entry.mode} | ${d.toLocaleString()}`;\n      switchHistorySelect.appendChild(option);\n    });\n    loadHistorySelectBtn.disabled = switchHistorySelect.selectedIndex === -1 || switchHistorySelect.options.length === 0;\n  }\n\n  // Context operations\n  function validateContextInputs(name, description, dataStr){\n    if(!name.trim()) return \"Context Name cannot be empty.\";\n    if(name.match(/^\\s+$/)) return \"Context Name cannot be just whitespace.\";\n    if(name.length > 50) return \"Context Name must be 50 characters or less.\";\n    try {\n      JSON.parse(dataStr);\n    } catch (e){\n      return \"Context Data must be valid JSON: \" + e.message;\n    }\n    return null;\n  }\n\n  // Save or update context\n  function saveContext(){\n    const name = ctxNameInput.value.trim();\n    const description = ctxDescriptionInput.value.trim();\n    const dataStr = ctxDataInput.value.trim();\n\n    const validationMsg = validateContextInputs(name, description, dataStr);\n    if(validationMsg){\n      ctxValidationMsg.textContent = validationMsg;\n      return;\n    }\n    ctxValidationMsg.textContent = \"\";\n\n    const dataObj = JSON.parse(dataStr);\n\n    contexts[name] = { name, description, dataObject: dataObj };\n    saveContextsToStorage();\n    logInteraction(`Context \"${name}\" saved.`);\n    updateContextList();\n    clearContextInputs();\n  }\n\n  function clearContextInputs(){\n    ctxNameInput.value = \"\";\n    ctxDescriptionInput.value = \"\";\n    ctxDataInput.value = \"\";\n    ctxValidationMsg.textContent = \"\";\n  }\n\n  function loadSelectedContext(){\n    const name = ctxListSelect.value;\n    if(name && contexts[name]){\n      ctxNameInput.value = contexts[name].name;\n      ctxDescriptionInput.value = contexts[name].description;\n      ctxDataInput.value = JSON.stringify(contexts[name].dataObject, null, 2);\n      ctxValidationMsg.textContent = \"\";\n      logInteraction(`Context \"${name}\" loaded into editor.`);\n    }\n  }\n\n  function deleteSelectedContext(){\n    const name = ctxListSelect.value;\n    if(name && contexts[name]){\n      if(currentContext && currentContext.name === name){\n        alert(\"Cannot delete context currently loaded. Switch to a different context first.\");\n        return;\n      }\n      if(confirm(`Delete context \"${name}\"? This action cannot be undone.`)){\n        delete contexts[name];\n        saveContextsToStorage();\n        logInteraction(`Context \"${name}\" deleted.`);\n        updateContextList();\n      }\n    }\n  }\n\n  // Context switching workflow\n  function performSwitch(){\n    if(!currentContext){\n      alert(\"You must first load a context to perform switching.\");\n      return;\n    }\n    const targetName = switchTargetSelect.value;\n    const switchMode = switchModeSelect.value;\n    if(!targetName || !contexts[targetName]){\n      alert(\"Please select a valid target context.\");\n      return;\n    }\n    if(targetName === currentContext.name){\n      alert(\"Cannot switch to the same context currently loaded.\");\n      return;\n    }\n\n    // Prepare new state\n    const targetContext = contexts[targetName];\n    let newDataObj;\n\n    try {\n      switch(switchMode){\n        case \"instant\":\n          // Replace currentContext with targetContext completely\n          newDataObj = deepClone(targetContext.dataObject);\n          break;\n        case \"overlay\":\n          // Merge targetContext data into currentContext data (target values override)\n          newDataObj = mergeDeep(deepClone(currentContext.dataObject), targetContext.dataObject);\n          break;\n        case \"sandbox\":\n          // Make isolated working copy based on targetContext, not affecting stored context until saved\n          newDataObj = deepClone(targetContext.dataObject);\n          break;\n        default:\n          alert(\"Unknown switch mode!\");\n          return;\n      }\n    } catch(e){\n      alert(\"Error performing switch operation: \" + e.message);\n      return;\n    }\n\n    // Save undo state and update history\n    const historyEntry = {\n      timestamp: Date.now(),\n      fromContextName: currentContext.name,\n      toContextName: targetName,\n      mode: switchMode,\n      stateSnapshot: deepClone(newDataObj)\n    };\n\n    // Trim history if needed\n    if(undoIndex < switchHistory.length -1){\n      switchHistory.splice(undoIndex+1);\n    }\n\n    switchHistory.push(historyEntry);\n    undoIndex++;\n    maxUndoLevels = Math.max(1, Math.min(100, Number(switchUndoLevelsInput.value) || 10));\n    if(switchHistory.length > maxUndoLevels){\n      switchHistory.shift();\n      undoIndex--;\n    }\n\n    currentContext = {\n      name: targetName,\n      description: targetContext.description,\n      dataObject: newDataObj\n    };\n\n    saveHistoryToStorage();\n    updateHistoryList();\n    updateCurrentContextDisplay();\n    updateUndoRedoButtons();\n    updateContextList();\n    performSwitchBtn.disabled = true;\n    logInteraction(`Switched context to \"${targetName}\" using mode \"${switchMode}\".`);\n  }\n\n  // Utilities: deep clone and deep merge\n  function deepClone(obj){\n    return JSON.parse(JSON.stringify(obj));\n  }\n\n  // Deep merge - target overrides source, merges recursively objects, arrays replaced directly\n  function mergeDeep(source, target){\n    if(typeof source !== \"object\" || source === null) return deepClone(target);\n    if(typeof target !== \"object\" || target === null) return deepClone(target);\n\n    let output = Array.isArray(source) ? [] : {};\n    if(Array.isArray(source) && Array.isArray(target)){\n      // Replace arrays directly\n      return deepClone(target);\n    }\n\n    const keys = new Set([...Object.keys(source), ...Object.keys(target)]);\n    keys.forEach(key => {\n      const sVal = source[key];\n      const tVal = target[key];\n      if(tVal === undefined){\n        output[key] = deepClone(sVal);\n      } else if(sVal === undefined){\n        output[key] = deepClone(tVal);\n      } else if(typeof sVal === 'object' && sVal !== null && typeof tVal === 'object' && tVal !== null && !Array.isArray(sVal) && !Array.isArray(tVal)){\n        output[key] = mergeDeep(sVal, tVal);\n      } else {\n        output[key] = deepClone(tVal);\n      }\n    });\n    return output;\n  }\n\n  // Undo / Redo switching\n  function undoSwitch(){\n    if(undoIndex <= 0){\n      alert(\"No more undo steps available.\");\n      return;\n    }\n    undoIndex--;\n    const historyEntry = switchHistory[undoIndex];\n    if(!historyEntry){\n      alert(\"Undo state invalid.\");\n      return;\n    }\n    currentContext = {\n      name: historyEntry.toContextName,\n      description: contexts[historyEntry.toContextName] ? contexts[historyEntry.toContextName].description : \"\",\n      dataObject: deepClone(historyEntry.stateSnapshot)\n    };\n    saveHistoryToStorage();\n    updateCurrentContextDisplay();\n    updateUndoRedoButtons();\n    updateContextList();\n    updateHistoryList();\n    logInteraction(`Undo: switched back to \"${currentContext.name}\"`);\n  }\n\n  function redoSwitch(){\n    if(undoIndex >= switchHistory.length -1){\n      alert(\"No more redo steps available.\");\n      return;\n    }\n    undoIndex++;\n    const historyEntry = switchHistory[undoIndex];\n    if(!historyEntry){\n      alert(\"Redo state invalid.\");\n      return;\n    }\n    currentContext = {\n      name: historyEntry.toContextName,\n      description: contexts[historyEntry.toContextName] ? contexts[historyEntry.toContextName].description : \"\",\n      dataObject: deepClone(historyEntry.stateSnapshot)\n    };\n    saveHistoryToStorage();\n    updateCurrentContextDisplay();\n    updateUndoRedoButtons();\n    updateContextList();\n    updateHistoryList();\n    logInteraction(`Redo: switched forward to \"${currentContext.name}\"`);\n  }\n\n  // Load selected history state as current context (snapshot only, does not modify history or undoIndex)\n  function loadHistorySelectedState(){\n    const idx = switchHistorySelect.selectedIndex;\n    if(idx === -1 || !switchHistory[idx]){\n      alert(\"Please select a valid history entry.\");\n      return;\n    }\n    const entry = switchHistory[idx];\n    currentContext = {\n      name: entry.toContextName,\n      description: contexts[entry.toContextName] ? contexts[entry.toContextName].description : \"\",\n      dataObject: deepClone(entry.stateSnapshot)\n    };\n    updateCurrentContextDisplay();\n    updateContextList();\n    performSwitchBtn.disabled = true;\n    logInteraction(`Loaded history state #${idx+1} (\"${entry.toContextName}\") as current context (no history changed).`);\n  }\n\n  // Event listeners\n\n  ctxSaveBtn.addEventListener(\"click\", e => {\n    e.preventDefault();\n    saveContext();\n  });\n\n  ctxClearBtn.addEventListener(\"click\", e => {\n    e.preventDefault();\n    clearContextInputs();\n  });\n\n  ctxListSelect.addEventListener(\"change\", e => {\n    ctxLoadBtn.disabled = ctxListSelect.selectedIndex === -1;\n    ctxDeleteBtn.disabled = ctxLoadBtn.disabled;\n  });\n\n  ctxLoadBtn.addEventListener(\"click\", e => {\n    e.preventDefault();\n    loadSelectedContext();\n  });\n\n  ctxDeleteBtn.addEventListener(\"click\", e => {\n    e.preventDefault();\n    deleteSelectedContext();\n  });\n\n  switchTargetSelect.addEventListener(\"change\", e => {\n    if(currentContext){\n      performSwitchBtn.disabled = switchTargetSelect.selectedIndex === -1 ||\n        switchTargetSelect.value === currentContext.name;\n    } else {\n      performSwitchBtn.disabled = true;\n    }\n  });\n\n  switchModeSelect.addEventListener(\"change\", e => {\n    if(currentContext && switchTargetSelect.selectedIndex !== -1) {\n      performSwitchBtn.disabled = switchTargetSelect.value === currentContext.name;\n    } else {\n      performSwitchBtn.disabled = true;\n    }\n  });\n\n  performSwitchBtn.addEventListener(\"click\", e=>{\n    e.preventDefault();\n    performSwitch();\n  });\n\n  switchUndoLevelsInput.addEventListener(\"change\", e => {\n    let val = Number(switchUndoLevelsInput.value);\n    if(isNaN(val) || val < 1) val = 1;\n    if(val > 100) val = 100;\n    maxUndoLevels = val;\n    switchUndoLevelsInput.value = val;\n    logInteraction(`Undo levels set to ${val}`);\n  });\n\n  undoSwitchBtn.addEventListener(\"click\", e=>{\n    e.preventDefault();\n    undoSwitch();\n  });\n\n  redoSwitchBtn.addEventListener(\"click\", e=>{\n    e.preventDefault();\n    redoSwitch();\n  });\n\n  switchHistorySelect.addEventListener(\"change\", e=>{\n    loadHistorySelectBtn.disabled = switchHistorySelect.selectedIndex === -1;\n  });\n\n  loadHistorySelectBtn.addEventListener(\"click\", e=>{\n    e.preventDefault();\n    loadHistorySelectedState();\n  });\n\n  clearLogBtn.addEventListener(\"click\", e=>{\n    e.preventDefault();\n    interactionLog.textContent = \"\";\n  });\n\n  // Initialization\n  function init(){\n    loadContextsFromStorage();\n    loadHistoryFromStorage();\n    updateContextList();\n    updateHistoryList();\n    updateUndoRedoButtons();\n    updateCurrentContextDisplay();\n    performSwitchBtn.disabled = true;\n    ctxLoadBtn.disabled = true;\n    ctxDeleteBtn.disabled = true;\n    undoSwitchBtn.disabled = true;\n    redoSwitchBtn.disabled = true;\n    loadHistorySelectBtn.disabled = true;\n    logInteraction(\"Context Switching demo initialized.\");\n  }\n\n  init();\n\n  // For accessibility, trap enter on context name to save quickly\n  ctxNameInput.addEventListener(\"keydown\", e=>{\n    if(e.key === \"Enter\"){\n      e.preventDefault();\n      saveContext();\n    }\n  });\n\n  // Accessibility: trigger load selected context with Enter key\n  ctxListSelect.addEventListener(\"keydown\", e=>{\n    if(e.key === \"Enter\" && !ctxLoadBtn.disabled){\n      e.preventDefault();\n      loadSelectedContext();\n    }\n  });\n\n  // Accessibility: trigger switch with Enter key in switchTargetSelect or switchModeSelect\n  [switchTargetSelect, switchModeSelect].forEach(el=>{\n    el.addEventListener(\"keydown\", e=>{\n      if(e.key === \"Enter\" && !performSwitchBtn.disabled){\n        e.preventDefault();\n        performSwitch();\n      }\n    });\n  });\n\n  // Accessibility: trigger history load with Enter key on history select\n  switchHistorySelect.addEventListener(\"keydown\", e=>{\n    if(e.key === \"Enter\" && !loadHistorySelectBtn.disabled){\n      e.preventDefault();\n      loadHistorySelectedState();\n    }\n  });\n\n})();\n\n</script>\n</body>\n</html>"
  },
