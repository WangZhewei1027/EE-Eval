  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Version Control Simulator</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  textarea {\n    width: 100%;\n    height: 150px;\n    font-family: monospace, monospace;\n  }\n  input[type=\"text\"] {\n    width: 250px;\n  }\n  button, input[type=\"text\"], select {\n    margin: 2px 0;\n  }\n  .section {\n    margin-bottom: 16px;\n  }\n  #commitList {\n    max-height: 200px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 4px;\n  }\n  #branchList {\n    max-height: 100px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 4px;\n  }\n  #logOutput {\n    max-height: 200px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 4px;\n    font-size: 0.85em;\n    white-space: pre-wrap;\n  }\n  #graphOutput {\n    font-family: monospace;\n    white-space: pre;\n    border: 1px solid black;\n    padding: 4px;\n    max-height: 200px;\n    overflow-y: auto;\n  }\n</style>\n</head>\n<body>\n\n<h1>Version Control Simulator (Minimal)</h1>\n\n<div class=\"section\" id=\"workspaceSection\">\n  <h2>Workspace (Unstaged Changes)</h2>\n  <textarea id=\"workspaceInput\" aria-label=\"Workspace text area\" placeholder=\"Edit your project files here...\"></textarea><br />\n  <button id=\"stageAllBtn\">Stage All Changes</button>\n  <button id=\"discardChangesBtn\">Discard All Unstaged Changes</button>\n  <div>\n    <label><input type=\"checkbox\" id=\"autoStageCheckbox\" /> Auto Stage changes on edit</label>\n  </div>\n</div>\n\n<div class=\"section\" id=\"stagingSection\">\n  <h2>Staging Area (Staged Changes)</h2>\n  <textarea id=\"stagingArea\" aria-label=\"Staging area\" readonly></textarea><br />\n  <button id=\"unstageAllBtn\">Unstage All Changes</button>\n</div>\n\n<div class=\"section\" id=\"commitSection\">\n  <h2>Commit</h2>\n  <label for=\"commitMessage\">Commit Message:</label><br />\n  <input type=\"text\" id=\"commitMessage\" aria-label=\"Commit message input\" placeholder=\"Enter commit message\" /><br />\n  <button id=\"commitBtn\">Commit Staged Changes</button>\n</div>\n\n<div class=\"section\" id=\"branchesSection\">\n  <h2>Branches</h2>\n  <div id=\"branchList\" aria-label=\"Branches list\" tabindex=\"0\"></div>\n  <input type=\"text\" id=\"newBranchName\" aria-label=\"New branch name input\" placeholder=\"New branch name\" />\n  <button id=\"createBranchBtn\">Create Branch</button>\n  <button id=\"checkoutBranchBtn\">Checkout Selected Branch</button>\n  <button id=\"mergeBranchBtn\">Merge Selected Branch Into Current</button>\n  <button id=\"deleteBranchBtn\">Delete Selected Branch</button>\n  <div id=\"branchError\" style=\"color: black; font-weight: bold;\"></div>\n</div>\n\n<div class=\"section\" id=\"commitHistorySection\">\n  <h2>Commit History / Log</h2>\n  <div id=\"logOutput\" role=\"log\"></div>\n  <label for=\"logFilter\">Filter commits: </label>\n  <input type=\"text\" id=\"logFilter\" aria-label=\"Log filter input\" placeholder=\"Filter by message or hash\" />\n  <button id=\"refreshLogBtn\">Refresh Log</button>\n</div>\n\n<div class=\"section\" id=\"graphSection\">\n  <h2>Repository Graph</h2>\n  <div id=\"graphOutput\" aria-label=\"Commit graph\"></div>\n</div>\n\n<script>\n(() => {\n  // --- Data Structures for the Version Control Sim ---\n\n  // Commit structure:\n  // id (hash) - string\n  // message - string\n  // content - string (snapshot of file content)\n  // parents - array of parent commit ids (for merges 2-parents)\n  // timestamp - number (Date.now())\n\n  // Branch structure:\n  // name - string\n  // commitId - string (points to a commit)\n\n  // State:\n  // workspaceContent: string\n  // stagedContent: string or null (null = nothing staged)\n  // commits: map<string, commit>\n  // branches: map<string, branch>\n  // currentBranch: string\n  // HEAD: string (commit id the repo points to)\n  // working directory content is separate from HEAD commit.content\n\n  // Utility function to generate short-ish commit id (hash)\n  function generateCommitId() {\n    // random 7-char alphanum:\n    const chars = \"abcdef0123456789\";\n    let id = \"\";\n    for (let i = 0; i < 7; i++) {\n      id += chars[Math.floor(Math.random() * chars.length)];\n    }\n    return id;\n  }\n\n  // Deep clone object (simple JSON clone)\n  function clone(obj) {\n    return JSON.parse(JSON.stringify(obj));\n  }\n\n  // Simple timestamp formatting\n  function formatDate(t) {\n    const d = new Date(t);\n    return d.toISOString().replace(\"T\", \" \").slice(0, 19);\n  }\n\n  // --- Internal State Variables ---\n  // Initialize repo with initial commit\n\n  let commits = {};\n  let branches = {};\n  let workspaceContent = \"\";\n  let stagingContent = null;\n  let currentBranch = \"main\";\n  let HEAD = null;\n\n  // Initialize repository\n  function initRepo() {\n    const initialCommitId = generateCommitId();\n    const initialCommit = {\n      id: initialCommitId,\n      message: \"Initial commit\",\n      content: \"\",\n      parents: [],\n      timestamp: Date.now()\n    };\n    commits[initialCommitId] = initialCommit;\n    branches[\"main\"] = {\n      name: \"main\",\n      commitId: initialCommitId\n    };\n    currentBranch = \"main\";\n    HEAD = initialCommitId;\n    workspaceContent = \"\";\n    stagingContent = null;\n  }\n\n  initRepo();\n\n  // --- DOM Elements ---\n  const workspaceInput = document.getElementById(\"workspaceInput\");\n  const stagingArea = document.getElementById(\"stagingArea\");\n  const stageAllBtn = document.getElementById(\"stageAllBtn\");\n  const discardChangesBtn = document.getElementById(\"discardChangesBtn\");\n  const autoStageCheckbox = document.getElementById(\"autoStageCheckbox\");\n\n  const unstagedWarning = null;\n\n  const commitMessageInput = document.getElementById(\"commitMessage\");\n  const commitBtn = document.getElementById(\"commitBtn\");\n\n  const branchListDiv = document.getElementById(\"branchList\");\n  const newBranchNameInput = document.getElementById(\"newBranchName\");\n  const createBranchBtn = document.getElementById(\"createBranchBtn\");\n  const checkoutBranchBtn = document.getElementById(\"checkoutBranchBtn\");\n  const mergeBranchBtn = document.getElementById(\"mergeBranchBtn\");\n  const deleteBranchBtn = document.getElementById(\"deleteBranchBtn\");\n  const branchErrorDiv = document.getElementById(\"branchError\");\n\n  const logOutputDiv = document.getElementById(\"logOutput\");\n  const logFilterInput = document.getElementById(\"logFilter\");\n  const refreshLogBtn = document.getElementById(\"refreshLogBtn\");\n\n  const graphOutputDiv = document.getElementById(\"graphOutput\");\n\n  // --- Helpers for repo state ---\n\n  // Returns commit by id or null\n  function getCommit(id) {\n    return commits[id] || null;\n  }\n\n  // Returns the commit ID the given branch points to or null\n  function getBranchCommitId(branchName) {\n    return branches[branchName] ? branches[branchName].commitId : null;\n  }\n\n  // Returns the commit object for HEAD\n  function getHeadCommit() {\n    return getCommit(HEAD);\n  }\n\n  // Returns true if workspaceContent differs from HEAD content\n  function workspaceDiffersFromHEAD() {\n    const headCommit = getHeadCommit();\n    return workspaceContent !== (headCommit ? headCommit.content : \"\");\n  }\n\n  // Returns true if staging area has any changes compared to HEAD\n  function stagingHasChanges() {\n    if (stagingContent === null) return false;\n    const headCommit = getHeadCommit();\n    return stagingContent !== (headCommit ? headCommit.content : \"\");\n  }\n\n  // Returns true if staging is empty\n  function stagingIsEmpty() {\n    return stagingContent === null;\n  }\n\n  // --- Update DOM to reflect current state ---\n\n  function updateWorkspaceDisplay() {\n    // Set workspace input if different\n    if (workspaceInput.value !== workspaceContent) {\n      workspaceInput.value = workspaceContent;\n    }\n  }\n\n  function updateStagingDisplay() {\n    stagingArea.value = stagingContent === null ? \"\" : stagingContent;\n  }\n\n  // Display branches with current highlighted\n  // Allows selecting one branch at a time (for checkout, merge etc)\n  // Use <select> with size for minimal UI or clickable divs\n\n  // We'll create a list of radio buttons + label for branches\n  function updateBranchesDisplay() {\n    branchListDiv.innerHTML = \"\";\n    const sortedBranchNames = Object.keys(branches).sort((a,b)=>a.localeCompare(b));\n    sortedBranchNames.forEach(branchName => {\n      const br = branches[branchName];\n      const branchElemId = \"branchRadio_\" + branchName;\n      const isChecked = (branchName === currentBranch);\n      const radio = document.createElement(\"input\");\n      radio.type = \"radio\";\n      radio.name = \"branchSelection\";\n      radio.id = branchElemId;\n      radio.value = branchName;\n      if (isChecked) radio.checked = true;\n\n      const label = document.createElement(\"label\");\n      label.htmlFor = branchElemId;\n      label.appendChild(document.createTextNode(branchName));\n      if (branchName === currentBranch) {\n        label.appendChild(document.createTextNode(\" (current)\"));\n      }\n\n      const container = document.createElement(\"div\");\n      container.appendChild(radio);\n      container.appendChild(label);\n\n      branchListDiv.appendChild(container);\n    });\n  }\n\n  // Refresh the log output\n  // We show commit id, message, timestamp, parents, branch refs\n  // Apply filter to messages/ids\n  // Order: newest (HEAD) to oldest\n\n  // We traverse commits from HEAD backwards\n  function getAllCommitsForLog() {\n    // Return array of commits reachable from current HEAD\n    // with no duplicates\n    const seen = new Set();\n    const result = [];\n\n    function traverse(id) {\n      if (!id || seen.has(id)) return;\n      const c = getCommit(id);\n      if (!c) return;\n      seen.add(id);\n      result.push(c);\n      c.parents.forEach(p => traverse(p));\n    }\n\n    traverse(HEAD);\n    // We have newest first in result order, sort them newest first by timestamp to ensure order\n    result.sort((a,b) => b.timestamp - a.timestamp);\n    return result;\n  }\n\n  function updateLogDisplay() {\n    const filter = logFilterInput.value.trim().toLowerCase();\n    const commitsToShow = getAllCommitsForLog().filter(c => {\n      if (!filter) return true;\n      return c.id.toLowerCase().includes(filter)\n          || (c.message.toLowerCase().includes(filter));\n    });\n    let logText = \"\";\n    commitsToShow.forEach(c => {\n      const parentsText = c.parents.length ? c.parents.join(\", \") : \"[none]\";\n      // Check if branch points here\n      const branchRefs = [];\n      for (const bName in branches) {\n        if (branches[bName].commitId === c.id) {\n          branchRefs.push(bName);\n        }\n      }\n      const branchStr = branchRefs.length ? \"branches: \" + branchRefs.join(\", \") : \"\";\n      logText += `Commit: ${c.id}\\nMessage: ${c.message}\\nParents: ${parentsText}\\nTime: ${formatDate(c.timestamp)}\\n${branchStr}\\n\\n`;\n    });\n    if (logText === \"\") logText = \"[No commits match filter]\";\n    logOutputDiv.textContent = logText;\n  }\n\n  // Graph output: simplified ASCII graph showing commits and branches.\n  // We'll show commits in order of creation and indicate parents and branch heads.\n  // Represent commits as nodes with commit id,\n  // branches as labels next to their commits,\n  // parents with links (arrows)\n  //\n  // This will be a textual adjacency list essentially:\n  // CommitID (branches: ...) -> parents: ...\n  // Also show a chain starting from HEAD backwards, with pipes.\n\n  function updateGraphDisplay() {\n    // We'll list all commits reachable from HEAD (like log), ordered youngest to oldest\n    const commitsOrder = getAllCommitsForLog().slice().reverse(); // oldest to newest\n\n    // Map commits to sequential indices to draw vertical graph\n    const lines = [];\n    // For each commit, show info with parents & branch refs\n\n    commitsOrder.forEach((commit, idx) => {\n      const branchesHere = [];\n      for (const bName in branches) {\n        if (branches[bName].commitId === commit.id) branchesHere.push(bName);\n      }\n      let line = `${commit.id}`;\n      if (branchesHere.length) {\n        line += \" (branches: \" + branchesHere.join(\", \") + \")\";\n      }\n      line += \" parents: \";\n      if (commit.parents.length === 0) {\n        line += \"[none]\";\n      } else {\n        line += commit.parents.join(\", \");\n      }\n      line += \" - \\\"\" + commit.message + \"\\\"\";\n      lines.push(line);\n    });\n\n    // Additional: Draw linear chain from HEAD (desc) to root (asc) using characters:\n    // HEAD commit at the bottom with arrows pointing to parents above.\n\n    // Using vertical pipe '|', commit blocks with '|- commitID' style\n\n    // Build linear path from HEAD backwards (pick first parent only)\n    let linearPath = [];\n    let current = HEAD;\n    while(current) {\n      linearPath.push(current);\n      const commit = getCommit(current);\n      if (!commit) break;\n      if (commit.parents.length > 0) {\n        current = commit.parents[0];\n      } else {\n        break;\n      }\n    }\n\n    linearPath.reverse();\n\n    // Build string with commit and pipe connections and branch markers\n    let graphText = \"\";\n    linearPath.forEach((cid, i) => {\n      const c = getCommit(cid);\n      if (!c) return;\n      const branchesHere = [];\n      for (const bName in branches) {\n        if (branches[bName].commitId === cid) branchesHere.push(bName);\n      }\n      let line = \"\";\n      if (i > 0) {\n        line += \"   |   \\n\";\n      }\n      line += `--o-- ${cid}`;\n      if (branchesHere.length) line += \" (\" + branchesHere.join(\", \") + \")\";\n      line += `\\n      \"${c.message}\"`;\n      graphText += line + \"\\n\";\n    });\n\n    graphText += \"\\nAll commits reachable from HEAD:\\n\";\n    lines.forEach(ln => {\n      graphText += \"* \" + ln + \"\\n\";\n    });\n\n    graphOutputDiv.textContent = graphText;\n  }\n\n  // --- User Actions ---\n\n  // Stage all changes = copy workspace content to staging area\n  stageAllBtn.addEventListener(\"click\", () => {\n    if (workspaceContent === getHeadCommit().content) {\n      alert(\"No changes to stage.\");\n      return;\n    }\n    stagingContent = workspaceContent;\n    updateStagingDisplay();\n  });\n\n  // Discard all unstaged changes: revert workspace to HEAD commit content, but leave staging intact\n  discardChangesBtn.addEventListener(\"click\", () => {\n    if (!workspaceDiffersFromHEAD()) {\n      alert(\"No unstaged changes to discard.\");\n      return;\n    }\n    if (!confirm(\"Discard all unstaged changes? This cannot be undone.\")) {\n      return;\n    }\n    workspaceContent = getHeadCommit().content;\n    updateWorkspaceDisplay();\n  });\n\n  // Unstage all changes: clear staging area (but keep workspace untouched)\n  unstageAllBtn.addEventListener(\"click\", () => {\n    if (stagingIsEmpty()) {\n      alert(\"No staged changes to unstage.\");\n      return;\n    }\n    if (!confirm(\"Unstage all staged changes?\")) {\n      return;\n    }\n    stagingContent = null;\n    updateStagingDisplay();\n  });\n\n  // Commit staged changes with message\n  commitBtn.addEventListener(\"click\", () => {\n    if (stagingIsEmpty()) {\n      alert(\"No staged changes to commit.\");\n      return;\n    }\n    const msg = commitMessageInput.value.trim();\n    if (!msg) {\n      alert(\"Please enter a commit message.\");\n      return;\n    }\n    // Create new commit object\n    let parentCommitId = HEAD;\n    const newCommitId = generateCommitId();\n\n    // Timestamp now\n    const newCommit = {\n      id: newCommitId,\n      message: msg,\n      content: stagingContent,\n      parents: [parentCommitId].filter(Boolean),\n      timestamp: Date.now()\n    };\n    commits[newCommitId] = newCommit;\n\n    // Update current branch tip and HEAD\n    branches[currentBranch].commitId = newCommitId;\n    HEAD = newCommitId;\n    stagingContent = null;\n\n    // Update workspace to new content (commit content)\n    workspaceContent = newCommit.content;\n    updateWorkspaceDisplay();\n    updateStagingDisplay();\n\n    // Clear commit message field\n    commitMessageInput.value = \"\";\n\n    refreshAllDisplays();\n  });\n\n  // Workspace edit event: update workspaceContent state\n  // If auto stage enabled, update staging content as well\n  workspaceInput.addEventListener(\"input\", () => {\n    workspaceContent = workspaceInput.value;\n    if (autoStageCheckbox.checked) {\n      stagingContent = workspaceContent;\n      updateStagingDisplay();\n    }\n  });\n\n  // Branch operations\n\n  // Create branch from current HEAD\n  createBranchBtn.addEventListener(\"click\", () => {\n    const newName = newBranchNameInput.value.trim();\n    if (!newName) {\n      branchErrorDiv.textContent = \"Branch name cannot be empty.\";\n      return;\n    }\n    if (branches[newName]) {\n      branchErrorDiv.textContent = \"Branch name already exists.\";\n      return;\n    }\n    // Validate branch name: no spaces, etc\n    if (!/^[-a-zA-Z0-9_]+$/.test(newName)) {\n      branchErrorDiv.textContent = \"Invalid branch name. Use letters, numbers, '-', '_'.\";\n      return;\n    }\n    branches[newName] = {\n      name: newName,\n      commitId: HEAD\n    };\n    newBranchNameInput.value = \"\";\n    branchErrorDiv.textContent = \"\";\n    updateBranchesDisplay();\n  });\n\n  // Get selected branch from branch list\n  function getSelectedBranch() {\n    const radios = branchListDiv.querySelectorAll(\"input[name=branchSelection]\");\n    for (const r of radios) {\n      if (r.checked) return r.value;\n    }\n    return null;\n  }\n\n  // Checkout branch: update currentBranch, HEAD, workspace content and staging cleared\n  checkoutBranchBtn.addEventListener(\"click\", () => {\n    const selected = getSelectedBranch();\n    if (!selected) {\n      branchErrorDiv.textContent = \"No branch selected.\";\n      return;\n    }\n    if (selected === currentBranch) {\n      branchErrorDiv.textContent = \"Already on branch '\" + selected + \"'.\";\n      return;\n    }\n    // Warn if unstaged or staged changes present and not committed, to avoid losing work\n    if (stagingHasChanges() || workspaceDiffersFromHEAD()) {\n      if (!confirm(\"Checkout will discard unstaged/staged changes. Continue?\")) {\n        return;\n      }\n    }\n    currentBranch = selected;\n    HEAD = branches[currentBranch].commitId;\n    const headCommit = getHeadCommit();\n    workspaceContent = headCommit ? headCommit.content : \"\";\n    stagingContent = null;\n    branchErrorDiv.textContent = \"\";\n    updateWorkspaceDisplay();\n    updateStagingDisplay();\n    updateBranchesDisplay();\n    refreshAllDisplays();\n  });\n\n  // Merge selected branch into current branch\n  // For simplicity, use a very naive merge:\n  // If contents equal ==> no merge needed\n  // If one branch is ancestor of the other ==> fast forward\n  // Otherwise create a new merge commit with 2 parents and merge contents by line lines:\n\n  mergeBranchBtn.addEventListener(\"click\", () => {\n    const selected = getSelectedBranch();\n    if (!selected) {\n      branchErrorDiv.textContent = \"No branch selected.\";\n      return;\n    }\n    if (selected === currentBranch) {\n      branchErrorDiv.textContent = \"Cannot merge branch into itself.\";\n      return;\n    }\n    // Check out current and selected branch commit ids\n    const currentCommitId = branches[currentBranch].commitId;\n    const mergeCommitId = branches[selected].commitId;\n    if (!currentCommitId || !mergeCommitId) {\n      branchErrorDiv.textContent = \"Invalid commit pointers for merge.\";\n      return;\n    }\n\n    // Find if mergeCommitId is ancestor of currentCommitId (fast-forward no)\n    if (isAncestor(mergeCommitId, currentCommitId)) {\n      branchErrorDiv.textContent = \"Merge branch is ancestor of current. Nothing to merge.\";\n      return;\n    }\n    // Find if currentCommitId is ancestor of mergeCommitId => fast forward possible\n    if (isAncestor(currentCommitId, mergeCommitId)) {\n      if (!confirm(\"Fast-forward merge possible. Proceed?\")) return;\n      // Fast forward: move current branch pointer\n      branches[currentBranch].commitId = mergeCommitId;\n      HEAD = mergeCommitId;\n      const headC = getHeadCommit();\n      workspaceContent = headC ? headC.content : \"\";\n      stagingContent = null;\n      branchErrorDiv.textContent = \"Fast-forward merged.\";\n      updateWorkspaceDisplay();\n      updateStagingDisplay();\n      updateBranchesDisplay();\n      refreshAllDisplays();\n      return;\n    }\n\n    // Non fast-forward merge: create new merge commit with two parents\n    // Merge contents by line:\n    // Simple strategy: if contents equal -> nothing to merge; else\n    // For each line, if line differs merge as:\n    // - common lines: keep\n    // - conflicting lines: show <<<<<<< current\\ncurrent line\\n=======\\nmerge line\\n>>>>>>>\n\n    const currentContent = commits[currentCommitId].content;\n    const mergeContent = commits[mergeCommitId].content;\n\n    const mergedResult = mergeContentsByLines(currentContent, mergeContent);\n\n    // Open commit message prompt - user must enter merge commit message\n    let mergeMsg = prompt(\"Enter merge commit message (default: Merge branch '\" + selected + \"' into '\" + currentBranch + \"')\");\n    if (mergeMsg === null) return; // canceled\n    mergeMsg = mergeMsg.trim() || `Merge branch '${selected}' into '${currentBranch}'`;\n\n    // Create merge commit with two parents\n    const newMergeCommitId = generateCommitId();\n    const newMergeCommit = {\n      id: newMergeCommitId,\n      message: mergeMsg,\n      content: mergedResult,\n      parents: [currentCommitId, mergeCommitId],\n      timestamp: Date.now()\n    };\n\n    commits[newMergeCommitId] = newMergeCommit;\n    branches[currentBranch].commitId = newMergeCommitId;\n    HEAD = newMergeCommitId;\n    workspaceContent = mergedResult;\n    stagingContent = null;\n    branchErrorDiv.textContent = \"\";\n    updateWorkspaceDisplay();\n    updateStagingDisplay();\n    updateBranchesDisplay();\n    refreshAllDisplays();\n  });\n\n  // Delete selected branch\n  deleteBranchBtn.addEventListener(\"click\", () => {\n    const selected = getSelectedBranch();\n    if (!selected) {\n      branchErrorDiv.textContent = \"No branch selected.\";\n      return;\n    }\n    if (selected === currentBranch) {\n      branchErrorDiv.textContent = \"Cannot delete the current branch.\";\n      return;\n    }\n    // Confirm delete\n    if (!confirm(\"Delete branch '\" + selected + \"'? This is permanent.\")) return;\n    delete branches[selected];\n    branchErrorDiv.textContent = \"\";\n    updateBranchesDisplay();\n  });\n\n  // --- Utilities ---\n\n  // Check ancestor relationship (is aId an ancestor of bId?)\n  // Traverse parents of bId looking for aId\n  function isAncestor(aId, bId) {\n    if (!aId || !bId) return false;\n    if (aId === bId) return true;\n    let visited = new Set();\n    let stack = [bId];\n    while (stack.length) {\n      let cur = stack.pop();\n      if (cur === aId) return true;\n      if (visited.has(cur)) continue;\n      visited.add(cur);\n      const c = getCommit(cur);\n      if (!c) continue;\n      c.parents.forEach(p => stack.push(p));\n    }\n    return false;\n  }\n\n  // Merge two strings of multi-line text by lines with conflict markers if different\n  function mergeContentsByLines(base, incoming) {\n    const baseLines = base.split(/\\r?\\n/);\n    const incomingLines = incoming.split(/\\r?\\n/);\n\n    const maxLines = Math.max(baseLines.length, incomingLines.length);\n    let mergedLines = [];\n    for (let i=0; i < maxLines; i++) {\n      const bLine = baseLines[i] === undefined ? \"\" : baseLines[i];\n      const iLine = incomingLines[i] === undefined ? \"\" : incomingLines[i];\n      if (bLine === iLine) {\n        mergedLines.push(bLine);\n      } else {\n        // conflict\n        mergedLines.push(\"<<<<<<< current branch\");\n        mergedLines.push(bLine);\n        mergedLines.push(\"=======\");\n        mergedLines.push(iLine);\n        mergedLines.push(\">>>>>>> merged branch\");\n      }\n    }\n    return mergedLines.join(\"\\n\");\n  }\n\n  // Refresh all relevant displays\n  function refreshAllDisplays() {\n    updateBranchesDisplay();\n    updateLogDisplay();\n    updateGraphDisplay();\n  }\n\n  // --- Initialize Interface State ---\n\n  updateWorkspaceDisplay();\n  updateStagingDisplay();\n  updateBranchesDisplay();\n  updateLogDisplay();\n  updateGraphDisplay();\n\n  // Refresh log btn handler\n  refreshLogBtn.addEventListener(\"click\", () => {\n    updateLogDisplay();\n  });\n\n  // Fast refresh log on filter change\n  logFilterInput.addEventListener(\"input\", () => {\n    updateLogDisplay();\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
