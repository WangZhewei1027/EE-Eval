.addEventListener('click', () => {\n            try {\n                let codeStr = code.value;\n                let result = runCode(codeStr);\n                output.innerHTML = result;\n            } catch (e) {\n                output.innerHTML = `Error: ${e.message}`;\n            }\n        });\n\n        function runCode(codeStr) {\n            try {\n                let result = runInterpreter(codeStr);\n                return result;\n            } catch (e) {\n                return `Error: ${e.message}`;\n            }\n        }\n\n        function runInterpreter(codeStr) {\n            // Simulate a complex interpreter logic\n            if (codeStr.includes('if')) {\n                let condition = codeStr.split(' ')[1];\n                if (condition === 'true') {\n                    return 'Condition is true';\n                } else {\n                    return 'Condition is false';\n                }\n            } else if (codeStr.includes('def')) {\n                let funcName = codeStr.split(' ')[1];\n                let func = eval(funcName);\n                return func.toString();\n            } else {\n                return 'Unknown code';\n            }\n        }\n    </script>\n</body>\n</html>"
