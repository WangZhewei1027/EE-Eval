    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hash Table Visualization</title>\n    <style>\n        body {\n            font-family: \"Arial\", sans-serif;\n            background-color: #f2f2f2;\n            margin: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            background-color: #ffffff;\n            border-radius: 12px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);\n            padding: 20px;\n            text-align: center;\n            width: 70%;\n            max-width: 600px;\n        }\n        h1 {\n            color: #333;\n            font-size: 2.5em;\n            margin-bottom: 20px;\n            transition: color 0.3s ease;\n        }\n        h1:hover {\n            color: #007BFF;\n        }\n        .hash-table {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 10px;\n            margin-top: 20px;\n        }\n        .bucket {\n            background: linear-gradient(135deg, #6FB1FC, #4364F7);\n            border-radius: 8px;\n            padding: 20px;\n            color: #fff;\n            font-size: 1.2em;\n            position: relative;\n            overflow: hidden;\n            transition: transform 0.3s ease;\n        }\n        .bucket:hover {\n            transform: scale(1.05);\n        }\n        .bucket::after {\n            content: '';\n            position: absolute;\n            bottom: -10%;\n            right: -10%;\n            width: 150%;\n            height: 150%;\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 50%;\n            transition: transform 0.4s ease;\n            z-index: 0;\n        }\n        .bucket:hover::after {\n            transform: scale(0.8);\n        }\n        .bucket-content {\n            position: relative;\n            z-index: 1;\n        }\n        button {\n            background-color: #007BFF;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            font-size: 1.1em;\n            cursor: pointer;\n            transition: background 0.3s ease;\n        }\n        button:hover {\n            background-color: #0056b3;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Hash Table Visualization</h1>\n        <div class=\"hash-table\" id=\"hashTable\"></div>\n        <button id=\"populateButton\">Populate Hash Table</button>\n    </div>\n\n    <script>\n        const hashTableElement = document.getElementById(\"hashTable\");\n\n        const generateRandomData = () => {\n            const data = [];\n            for (let i = 0; i < 8; i++) {\n                data.push(`Key ${i + 1}: Value ${Math.floor(Math.random() * 100)}`);\n            }\n            return data;\n        };\n\n        const populateHashTable = () => {\n            const data = generateRandomData();\n            hashTableElement.innerHTML = '';\n            data.forEach(item => {\n                const bucket = document.createElement(\"div\");\n                bucket.className = \"bucket\";\n                bucket.innerHTML = `<div class=\"bucket-content\">${item}</div>`;\n                hashTableElement.appendChild(bucket);\n            });\n        };\n\n        document.getElementById(\"populateButton\").addEventListener(\"click\", populateHashTable);\n    </script>\n</body>\n</html>"
