    "role": "assistant",
    "content": "<html>\n<head>\n    <title>B-Tree Index Interactive Demo</title>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            line-height: 1.5;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        .tree-container {\n            min-height: 300px;\n            border: 1px solid #000;\n            padding: 10px;\n            overflow: auto;\n        }\n        .node {\n            border: 1px solid #000;\n            margin: 5px;\n            padding: 5px;\n            display: inline-block;\n            vertical-align: top;\n        }\n        .key {\n            display: inline-block;\n            padding: 2px 5px;\n            margin: 2px;\n            border: 1px solid #999;\n        }\n        .highlight {\n            background-color: #eee;\n        }\n        .pointer {\n            font-style: italic;\n            color: #666;\n        }\n        .stats {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>B-Tree Index Interactive Demo</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Tree Configuration</h3>\n                <div>\n                    <label>Order (minimum degree t):</label>\n                    <input type=\"range\" id=\"orderSlider\" min=\"2\" max=\"5\" value=\"3\">\n                    <span id=\"orderValue\">3</span>\n                </div>\n                <button id=\"rebuildTree\">Rebuild Tree</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Operations</h3>\n                <div>\n                    <input type=\"number\" id=\"insertValue\" placeholder=\"Value to insert\">\n                    <button id=\"insertBtn\">Insert</button>\n                </div>\n                <div>\n                    <input type=\"number\" id=\"deleteValue\" placeholder=\"Value to delete\">\n                    <button id=\"deleteBtn\">Delete</button>\n                </div>\n                <div>\n                    <input type=\"number\" id=\"searchValue\" placeholder=\"Value to search\">\n                    <button id=\"searchBtn\">Search</button>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Visualization</h3>\n                <div>\n                    <label>Animation Speed:</label>\n                    <input type=\"range\" id=\"speedSlider\" min=\"100\" max=\"2000\" value=\"500\">\n                </div>\n                <div>\n                    <button id=\"showAll\">Show All Nodes</button>\n                    <button id=\"collapseAll\">Collapse All</button>\n                </div>\n                <div>\n                    <label><input type=\"checkbox\" id=\"showPointers\"> Show Pointers</label>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Bulk Operations</h3>\n                <div>\n                    <input type=\"text\" id=\"bulkValues\" placeholder=\"Comma-separated values\">\n                    <button id=\"bulkInsert\">Bulk Insert</button>\n                </div>\n                <div>\n                    <button id=\"randomTree\">Generate Random Tree</button>\n                    <input type=\"number\" id=\"randomCount\" value=\"10\" min=\"1\" max=\"50\">\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"tree-container\" id=\"treeContainer\">\n            <!-- Tree will be rendered here -->\n        </div>\n        \n        <div class=\"stats\">\n            <h3>Tree Statistics</h3>\n            <div>Height: <span id=\"treeHeight\">0</span></div>\n            <div>Node Count: <span id=\"nodeCount\">0</span></div>\n            <div>Key Count: <span id=\"keyCount\">0</span></div>\n            <div id=\"operationLog\"></div>\n        </div>\n    </div>\n\n    <script>\n        // B-Tree implementation\n        class BTreeNode {\n            constructor(t, isLeaf) {\n                this.t = t;\n                this.isLeaf = isLeaf;\n                this.keys = [];\n                this.children = [];\n                this.collapsed = false;\n            }\n            \n            traverse(level = 0, callback) {\n                callback(this, level);\n                if (!this.isLeaf && !this.collapsed) {\n                    for (let child of this.children) {\n                        child.traverse(level + 1, callback);\n                    }\n                }\n            }\n            \n            search(k) {\n                let i = 0;\n                while (i < this.keys.length && k > this.keys[i]) {\n                    i++;\n                }\n                \n                if (i < this.keys.length && k === this.keys[i]) {\n                    return { node: this, index: i };\n                }\n                \n                if (this.isLeaf) {\n                    return null;\n                }\n                \n                return this.children[i].search(k);\n            }\n            \n            // Other B-Tree methods would be here (insert, delete, split, etc.)\n            // Omitted for brevity but would be implemented in a full version\n        }\n\n        class BTree {\n            constructor(t) {\n                this.root = null;\n                this.t = t;\n                this.animationSpeed = 500;\n                this.highlightedNodes = new Set();\n                this.operationLog = [];\n            }\n            \n            insert(k) {\n                this.logOperation(`Inserting ${k}`);\n                if (this.root === null) {\n                    this.root = new BTreeNode(this.t, true);\n                    this.root.keys.push(k);\n                    return;\n                }\n                \n                if (this.root.keys.length === 2 * this.t - 1) {\n                    const s = new BTreeNode(this.t, false);\n                    s.children.push(this.root);\n                    this.splitChild(s, 0);\n                    this.root = s;\n                }\n                \n                this.insertNonFull(this.root, k);\n            }\n            \n            insertNonFull(node, k) {\n                let i = node.keys.length - 1;\n                \n                if (node.isLeaf) {\n                    while (i >= 0 && k < node.keys[i]) {\n                        i--;\n                    }\n                    node.keys.splice(i + 1, 0, k);\n                    return;\n                }\n                \n                while (i >= 0 && k < node.keys[i]) {\n                    i--;\n                }\n                i++;\n                \n                if (node.children[i].keys.length === 2 * this.t - 1) {\n                    this.splitChild(node, i);\n                    if (k > node.keys[i]) {\n                        i++;\n                    }\n                }\n                \n                this.insertNonFull(node.children[i], k);\n            }\n            \n            splitChild(parent, i) {\n                const t = this.t;\n                const y = parent.children[i];\n                const z = new BTreeNode(t, y.isLeaf);\n                \n                z.keys = y.keys.splice(t, t - 1);\n                if (!y.isLeaf) {\n                    z.children = y.children.splice(t, t);\n                }\n                \n                parent.children.splice(i + 1, 0, z);\n                parent.keys.splice(i, 0, y.keys.pop());\n            }\n            \n            delete(k) {\n                this.logOperation(`Deleting ${k}`);\n                if (!this.root) {\n                    return;\n                }\n                \n                this.deleteKey(this.root, k);\n                \n                if (this.root.keys.length === 0) {\n                    if (this.root.isLeaf) {\n                        this.root = null;\n                    } else {\n                        this.root = this.root.children[0];\n                    }\n                }\n            }\n            \n            deleteKey(node, k) {\n                const idx = node.keys.findIndex(key => key >= k);\n                \n                if (idx < node.keys.length && node.keys[idx] === k) {\n                    if (node.isLeaf) {\n                        node.keys.splice(idx, 1);\n                    } else {\n                        this.deleteInternalNode(node, idx);\n                    }\n                    return;\n                }\n                \n                if (node.isLeaf) {\n                    return;\n                }\n                \n                const child = node.children[idx];\n                if (child.keys.length >= this.t) {\n                    this.deleteKey(child, k);\n                    return;\n                }\n                \n                let siblingIdx;\n                let sibling;\n                \n                if (idx > 0 && node.children[idx - 1].keys.length >= this.t) {\n                    siblingIdx = idx - 1;\n                    sibling = node.children[siblingIdx];\n                    this.rotateRight(node, idx, sibling);\n                } else if (idx < node.children.length - 1 && node.children[idx + 1].keys.length >= this.t) {\n                    siblingIdx = idx + 1;\n                    sibling = node.children[siblingIdx];\n                    this.rotateLeft(node, idx, sibling);\n                } else {\n                    if (idx < node.children.length - 1) {\n                        this.merge(node, idx);\n                    } else {\n                        this.merge(node, idx - 1);\n                    }\n                }\n                \n                this.deleteKey(node.children[idx], k);\n            }\n            \n            // Other B-Tree methods would be here...\n            \n            traverse(callback) {\n                if (this.root) {\n                    this.root.traverse(0, callback);\n                }\n            }\n            \n            getHeight() {\n                let height = 0;\n                let node = this.root;\n                while (node) {\n                    height++;\n                    if (node.isLeaf) break;\n                    node = node.children[0];\n                }\n                return height;\n            }\n            \n            getNodeCount() {\n                let count = 0;\n                this.traverse(() => count++);\n                return count;\n            }\n            \n            getKeyCount() {\n                let count = 0;\n                this.traverse(node => count += node.keys.length);\n                return count;\n            }\n            \n            logOperation(message) {\n                this.operationLog.push(message);\n                if (this.operationLog.length > 10) {\n                    this.operationLog.shift();\n                }\n            }\n            \n            // Visualization helpers\n            highlightNode(node, highlight = true) {\n                if (highlight) {\n                    this.highlightedNodes.add(node);\n                } else {\n                    this.highlightedNodes.delete(node);\n                }\n            }\n            \n            clearHighlights() {\n                this.highlightedNodes.clear();\n            }\n        }\n\n        // UI Controller\n        class BTreeUI {\n            constructor() {\n                this.tree = new BTree(3);\n                this.initializeControls();\n                this.renderTree();\n            }\n            \n            initializeControls() {\n                // Order slider\n                document.getElementById('orderSlider').addEventListener('input', (e) => {\n                    document.getElementById('orderValue').textContent = e.target.value;\n                });\n                \n                // Rebuild tree\n                document.getElementById('rebuildTree').addEventListener('click', () => {\n                    const newOrder = parseInt(document.getElementById('orderSlider').textContent);\n                    this.tree = new BTree(newOrder);\n                    this.renderTree();\n                });\n                \n                // Insert\n                document.getElementById('insertBtn').addEventListener('click', () => {\n                    const value = parseInt(document.getElementById('insertValue').value);\n                    if (!isNaN(value)) {\n                        this.tree.insert(value);\n                        this.renderTree();\n                        document.getElementById('insertValue').value = '';\n                    }\n                });\n                \n                // Delete\n                document.getElementById('deleteBtn').addEventListener('click', () => {\n                    const value = parseInt(document.getElementById('deleteValue').value);\n                    if (!isNaN(value)) {\n                        this.tree.delete(value);\n                        this.renderTree();\n                        document.getElementById('deleteValue').value = '';\n                    }\n                });\n                \n                // Search\n                document.getElementById('searchBtn').addEventListener('click', () => {\n                    const value = parseInt(document.getElementById('searchValue').value);\n                    if (!isNaN(value)) {\n                        this.tree.clearHighlights();\n                        const result = this.tree.root ? this.tree.root.search(value) : null;\n                        if (result) {\n                            this.tree.highlightNode(result.node);\n                        }\n                        this.renderTree();\n                        setTimeout(() => {\n                            this.tree.clearHighlights();\n                            this.renderTree();\n                        }, 2000);\n                    }\n                });\n                \n                // Animation speed\n                document.getElementById('speedSlider').addEventListener('input', (e) => {\n                    this.tree.animationSpeed = 2100 - e.target.value;\n                });\n                \n                // Show all nodes\n                document.getElementById('showAll').addEventListener('click', () => {\n                    this.tree.traverse(node => node.collapsed = false);\n                    this.renderTree();\n                });\n                \n                // Collapse all\n                document.getElementById('collapseAll').addEventListener('click', () => {\n                    this.tree.traverse(node => {\n                        if (!node.isLeaf) node.collapsed = true;\n                    });\n                    this.renderTree();\n                });\n                \n                // Bulk insert\n                document.getElementById('bulkInsert').addEventListener('click', () => {\n                    const values = document.getElementById('bulkValues').value\n                        .split(',')\n                        .map(v => parseInt(v.trim()))\n                        .filter(v => !isNaN(v));\n                    \n                    values.forEach(v => this.tree.insert(v));\n                    this.renderTree();\n                    document.getElementById('bulkValues').value = '';\n                });\n                \n                // Random tree\n                document.getElementById('randomTree').addEventListener('click', () => {\n                    const count = parseInt(document.getElementById('randomCount').value) || 10;\n                    this.tree = new BTree(parseInt(document.getElementById('orderValue').textContent));\n                    \n                    for (let i = 0; i < count; i++) {\n                        const value = Math.floor(Math.random() * 100);\n                        this.tree.insert(value);\n                    }\n                    \n                    this.renderTree();\n                });\n                \n                // Toggle node collapse\n                document.getElementById('clickableTree').addEventListener('click', (e) => {\n                    const nodeElement = e.target.closest('.node');\n                    if (nodeElement) {\n                        const nodeId = nodeElement.dataset.nodeId;\n                        // In a real implementation, we'd find the node and toggle its collapsed state\n                        this.renderTree();\n                    }\n                });\n            }\n            \n            renderTree() {\n                const container = document.getElementById('treeContainer');\n                container.innerHTML = '';\n                \n                if (!this.tree.root) {\n                    container.textContent = 'Tree is empty';\n                    return;\n                }\n                \n                const showPointers = document.getElementById('showPointers').checked;\n                \n                this.tree.traverse((node, level) => {\n                    const nodeDiv = document.createElement('div');\n                    nodeDiv.className = 'node';\n                    nodeDiv.style.marginLeft = `${level * 20}px`;\n                    \n                    if (this.tree.highlightedNodes.has(node)) {\n                        nodeDiv.classList.add('highlight');\n                    }\n                    \n                    // Keys\n                    node.keys.forEach(key => {\n                        const keySpan = document.createElement('span');\n                        keySpan.className = 'key';\n                        keySpan.textContent = key;\n                        nodeDiv.appendChild(keySpan);\n                    });\n                    \n                    // Pointers (if enabled)\n                    if (showPointers && !node.isLeaf && !node.collapsed) {\n                        node.children.forEach((child, i) => {\n                            const pointerSpan = document.createElement('span');\n                            pointerSpan.className = 'pointer';\n                            pointerSpan.textContent = ` → ${i < node.keys.length ? '≤' : '>'}`;\n                            nodeDiv.appendChild(pointerSpan);\n                        });\n                    }\n                    \n                    // Collapse/expand indicator\n                    if (!node.isLeaf) {\n                        const toggleSpan = document.createElement('span');\n                        toggleSpan.className = 'pointer';\n                        toggleSpan.textContent = node.collapsed ? ' [+]' : ' [-]';\n                        toggleSpan.style.cursor = 'pointer';\n                        toggleSpan.onclick = () => {\n                            node.collapsed = !node.collapsed;\n                            this.renderTree();\n                        };\n                        nodeDiv.appendChild(toggleSpan);\n                    }\n                    \n                    container.appendChild(nodeDiv);\n                });\n                \n                // Update stats\n                document.getElementById('treeHeight').textContent = this.tree.getHeight();\n                document.getElementById('nodeCount').textContent = this.tree.getNodeCount();\n                document.getElementById('keyCount').textContent = this.tree.getKeyCount();\n                \n                // Update operation log\n                const logElement = document.getElementById('operationLog');\n                logElement.innerHTML = this.tree.operationLog\n                    .map(op => `<div>${op}</div>`)\n                    .join('');\n            }\n        }\n\n        // Initialize the UI when the page loads\n        window.onload = () => {\n            const btreeUI = new BTreeUI();\n            window.btreeUI = btreeUI; // Make available in console for debugging\n            \n            // Add some initial values\n            [10, 20, 5, 15, 30, 25, 35, 3, 8, 12, 18, 22, 28, 33, 40].forEach(v => {\n                btreeUI.tree.insert(v);\n            });\n            btreeUI.renderTree();\n        };\n    </script>\n</body>\n</html>"
