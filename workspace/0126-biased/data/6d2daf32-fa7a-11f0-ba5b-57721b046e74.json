    "content": "<html>\n<head>\n    <title>Insertion Sort Interactive</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 800px;\n            margin: 0 auto;\n        }\n        .array-container {\n            display: flex;\n            margin: 20px 0;\n            height: 100px;\n            align-items: flex-end;\n        }\n        .array-element {\n            flex: 1;\n            background-color: #f0f0f0;\n            margin: 0 2px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative;\n        }\n        .array-value {\n            position: absolute;\n            bottom: 5px;\n        }\n        .controls {\n            margin: 20px 0;\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n        }\n        .control-group {\n            margin-right: 20px;\n        }\n        .status {\n            margin: 20px 0;\n            padding: 10px;\n            border: 1px solid #ccc;\n            min-height: 50px;\n        }\n        .highlight {\n            background-color: #ffcccc;\n        }\n        .sorted {\n            background-color: #ccffcc;\n        }\n        .current {\n            background-color: #ccccff;\n        }\n        .key {\n            background-color: #ffffcc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Insertion Sort Interactive</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <label for=\"arraySize\">Array Size:</label>\n                <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"20\" value=\"10\">\n                <span id=\"arraySizeValue\">10</span>\n                <button id=\"generateArray\">Generate New Array</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <button id=\"startSort\">Start Sort</button>\n                <button id=\"nextStep\">Next Step</button>\n                <button id=\"pauseSort\">Pause</button>\n                <button id=\"reset\">Reset</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"speed\">Speed:</label>\n                <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\" step=\"100\">\n                <span id=\"speedValue\">500ms</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"arrayInput\">Custom Array (comma separated):</label>\n                <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 5,3,8,1,2\">\n                <button id=\"useCustomArray\">Use This Array</button>\n            </div>\n        </div>\n        \n        <div class=\"array-container\" id=\"arrayDisplay\"></div>\n        \n        <div class=\"status\" id=\"status\">\n            Ready. Click \"Generate New Array\" or provide a custom array to begin.\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>Insertion Sort Explanation</h2>\n            <p>Insertion sort works by dividing the array into a sorted and unsorted part. Values from the unsorted part are picked and placed at the correct position in the sorted part.</p>\n            <p>Steps:</p>\n            <ol>\n                <li>Start with the second element (index 1) as the key</li>\n                <li>Compare the key with elements in the sorted part (to its left)</li>\n                <li>Shift elements greater than the key one position to the right</li>\n                <li>Insert the key in its correct position</li>\n                <li>Repeat for all elements</li>\n            </ol>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let array = [];\n        let sortedUpTo = 0;\n        let currentKeyIndex = 1;\n        let currentCompareIndex = 0;\n        let isSorting = false;\n        let sortInterval = null;\n        let speed = 500;\n        \n        // DOM elements\n        const arrayDisplay = document.getElementById('arrayDisplay');\n        const statusElement = document.getElementById('status');\n        const arraySizeInput = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const generateArrayBtn = document.getElementById('generateArray');\n        const startSortBtn = document.getElementById('startSort');\n        const nextStepBtn = document.getElementById('nextStep');\n        const pauseSortBtn = document.getElementById('pauseSort');\n        const resetBtn = document.getElementById('reset');\n        const speedInput = document.getElementById('speed');\n        const speedValue = document.getElementById('speedValue');\n        const arrayInput = document.getElementById('arrayInput');\n        const useCustomArrayBtn = document.getElementById('useCustomArray');\n        \n        // Initialize\n        generateRandomArray();\n        renderArray();\n        \n        // Event listeners\n        arraySizeInput.addEventListener('input', function() {\n            arraySizeValue.textContent = this.value;\n        });\n        \n        generateArrayBtn.addEventListener('click', function() {\n            generateRandomArray();\n            resetSort();\n            renderArray();\n            updateStatus(\"New array generated. Ready to sort.\");\n        });\n        \n        startSortBtn.addEventListener('click', function() {\n            if (!isSorting) {\n                isSorting = true;\n                sortInterval = setInterval(performSortStep, speed);\n                updateStatus(\"Sorting in progress...\");\n            }\n        });\n        \n        nextStepBtn.addEventListener('click', function() {\n            if (!isSorting) {\n                performSortStep();\n            }\n        });\n        \n        pauseSortBtn.addEventListener('click', function() {\n            if (isSorting) {\n                clearInterval(sortInterval);\n                isSorting = false;\n                updateStatus(\"Sorting paused.\");\n            }\n        });\n        \n        resetBtn.addEventListener('click', function() {\n            resetSort();\n            renderArray();\n            updateStatus(\"Sorting reset. Ready to begin again.\");\n        });\n        \n        speedInput.addEventListener('input', function() {\n            speed = parseInt(this.value);\n            speedValue.textContent = speed + 'ms';\n            \n            if (isSorting) {\n                clearInterval(sortInterval);\n                sortInterval = setInterval(performSortStep, speed);\n            }\n        });\n        \n        useCustomArrayBtn.addEventListener('click', function() {\n            const input = arrayInput.value.trim();\n            if (input) {\n                try {\n                    const newArray = input.split(',').map(num => parseInt(num.trim()));\n                    if (newArray.some(isNaN)) {\n                        throw new Error(\"Invalid number in array\");\n                    }\n                    array = newArray;\n                    resetSort();\n                    renderArray();\n                    updateStatus(\"Custom array loaded. Ready to sort.\");\n                } catch (e) {\n                    updateStatus(\"Error: Please enter valid numbers separated by commas.\");\n                }\n            }\n        });\n        \n        // Functions\n        function generateRandomArray() {\n            const size = parseInt(arraySizeInput.value);\n            array = [];\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * 90) + 10); // Values between 10-99\n            }\n        }\n        \n        function renderArray() {\n            arrayDisplay.innerHTML = '';\n            \n            for (let i = 0; i < array.length; i++) {\n                const element = document.createElement('div');\n                element.className = 'array-element';\n                element.style.height = `${array[i]}%`;\n                \n                const valueLabel = document.createElement('div');\n                valueLabel.className = 'array-value';\n                valueLabel.textContent = array[i];\n                element.appendChild(valueLabel);\n                \n                if (i < sortedUpTo) {\n                    element.classList.add('sorted');\n                }\n                \n                if (i === currentKeyIndex) {\n                    element.classList.add('key');\n                }\n                \n                if (i === currentCompareIndex && currentCompareIndex !== currentKeyIndex) {\n                    element.classList.add('current');\n                }\n                \n                arrayDisplay.appendChild(element);\n            }\n        }\n        \n        function performSortStep() {\n            if (currentKeyIndex >= array.length) {\n                clearInterval(sortInterval);\n                isSorting = false;\n                updateStatus(\"Sorting complete!\");\n                return;\n            }\n            \n            if (currentCompareIndex > 0 && array[currentCompareIndex - 1] > array[currentKeyIndex]) {\n                // Shift element to the right\n                array[currentCompareIndex] = array[currentCompareIndex - 1];\n                currentCompareIndex--;\n                updateStatus(`Shifting ${array[currentCompareIndex]} to the right`);\n            } else {\n                // Insert the key\n                array[currentCompareIndex] = array[currentKeyIndex];\n                updateStatus(`Inserting ${array[currentCompareIndex]} at position ${currentCompareIndex}`);\n                \n                // Move to next key\n                currentKeyIndex++;\n                sortedUpTo = currentKeyIndex - 1;\n                currentCompareIndex = currentKeyIndex;\n                \n                if (currentKeyIndex < array.length) {\n                    updateStatus(`Now sorting with key value ${array[currentKeyIndex]}`);\n                }\n            }\n            \n            renderArray();\n        }\n        \n        function resetSort() {\n            sortedUpTo = 0;\n            currentKeyIndex = 1;\n            currentCompareIndex = 1;\n            isSorting = false;\n            if (sortInterval) {\n                clearInterval(sortInterval);\n                sortInterval = null;\n            }\n        }\n        \n        function updateStatus(message) {\n            statusElement.textContent = message;\n        }\n    </script>\n</body>\n</html>"
