    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Load Balancing Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #74ebd5, #acb6e5);\n            color: #333;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n\n        .container {\n            text-align: center;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 10px 50px rgba(0, 0, 0, 0.2);\n            padding: 40px 20px;\n            width: 90%;\n            max-width: 800px;\n            position: relative;\n            overflow: hidden;\n        }\n\n        h1 {\n            font-size: 2.5em;\n            margin: 0;\n            color: #4a4a4a;\n            animation: fadeIn 2s;\n        }\n\n        p {\n            font-size: 1.2em;\n            line-height: 1.6;\n            margin-top: 15px;\n            color: #555;\n            animation: fadeIn 3s;\n        }\n\n        .load-balancer {\n            display: flex;\n            justify-content: space-around;\n            align-items: flex-end;\n            height: 200px;\n            margin-top: 40px;\n            animation: dropIn 2s;\n        }\n\n        .server {\n            width: 60px;\n            height: 0;\n            background: #6fa3ef;\n            border-radius: 10px;\n            transition: height 0.5s ease-in-out;\n        }\n\n        .server.active {\n            height: 100%;\n            animation: rise 0.5s ease-in forwards;\n        }\n\n        .load-balancer-controls {\n            margin-top: 20px;\n        }\n\n        .button {\n            padding: 10px 20px;\n            background: #20c997;\n            border: none;\n            border-radius: 20px;\n            color: white;\n            font-size: 1em;\n            cursor: pointer;\n            transition: background 0.3s ease;\n            margin: 5px;\n        }\n\n        .button:hover {\n            background: #118c74;\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes dropIn {\n            from {\n                transform: scale(0);\n                opacity: 0;\n            }\n            to {\n                transform: scale(1);\n                opacity: 1;\n            }\n        }\n\n        @keyframes rise {\n            from {\n                height: 0;\n            }\n            to {\n                height: 100%;\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <h1>Load Balancing Visualization</h1>\n        <p>Witness how load is distributed among servers, optimizing resource usage for efficiency.</p>\n\n        <div class=\"load-balancer\">\n            <div class=\"server\" id=\"server1\"></div>\n            <div class=\"server\" id=\"server2\"></div>\n            <div class=\"server\" id=\"server3\"></div>\n        </div>\n\n        <div class=\"load-balancer-controls\">\n            <button class=\"button\" id=\"loadButton\">Distribute Load</button>\n        </div>\n    </div>\n\n    <script>\n        const servers = document.querySelectorAll('.server');\n        const loadButton = document.getElementById('loadButton');\n\n        loadButton.addEventListener('click', () => {\n            servers.forEach((server, index) => {\n                server.classList.remove('active');\n                setTimeout(() => {\n                    server.classList.add('active');\n                }, index * 500); // Stagger start of animations\n            });\n        });\n    </script>\n</body>\n\n</html>"
