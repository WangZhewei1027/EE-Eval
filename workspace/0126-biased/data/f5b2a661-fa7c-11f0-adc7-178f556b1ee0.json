    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Index</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #text {\n            font-size: 16px;\n            font-weight: bold;\n        }\n        #explanation {\n            font-size: 18px;\n            margin-bottom: 20px;\n        }\n        #demonstration {\n            font-size: 16px;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>B-Tree Index</h1>\n    <p id=\"text\">A B-Tree index is a data structure used to efficiently store and retrieve large amounts of data in a database or file system.</p>\n    <p id=\"explanation\">A B-Tree index is a self-balancing search tree data structure, which means it automatically adjusts its balance to ensure that the search time remains relatively constant even when the input data is randomly distributed.</p>\n    <p id=\"demonstration\">Click the button below to see the B-Tree index in action.</p>\n    <button id=\"demonstration-button\">Demonstrate B-Tree Index</button>\n\n    <script>\n        const textElement = document.getElementById('text');\n        const explanationElement = document.getElementById('explanation');\n        const demonstrationButton = document.getElementById('demonstration-button');\n\n        // Function to generate B-Tree index\n        function generateBTreeIndex(data, depth = 0) {\n            let root = { root: null, leaf: null };\n\n            // Insert each element into the B-Tree index\n            for (let i = 0; i < data.length; i++) {\n                let key = data[i][0];\n                let value = data[i][1];\n\n                // Insert the key into the B-Tree index\n                if (depth == 0) {\n                    root.root = { key, value, left: null, right: null };\n                } else {\n                    let node = root;\n                    while (node.left != null && depth > 0) {\n                        node = node.left;\n                        depth--;\n                    }\n                    if (node.left == null) {\n                        node.left = { key, value, left: null, right: null };\n                    } else {\n                        node.right = { key, value, left: null, right: null };\n                    }\n                }\n            }\n\n            // Rebalance the B-Tree index\n            rebalanceBTree(root);\n        }\n\n        // Function to rebalance the B-Tree index\n        function rebalanceBTree(node) {\n            if (node != null) {\n                // Calculate the height of the left and right subtrees\n                let leftHeight = getHeight(node.left);\n                let rightHeight = getHeight(node.right);\n\n                // If the height of the left subtree is greater than the height of the right subtree\n                if (leftHeight > rightHeight) {\n                    // Rotate the right subtree to the left\n                    rotateRight(node);\n                } else {\n                    // Rotate the left subtree to the right\n                    rotateLeft(node);\n                }\n\n                // Rebalance the B-Tree index\n                rebalanceBTree(node.left);\n                rebalanceBTree(node.right);\n            }\n        }\n\n        // Function to calculate the height of a node\n        function getHeight(node) {\n            if (node == null) {\n                return 0;\n            } else {\n                return Math.max(getHeight(node.left), getHeight(node.right)) + 1;\n            }\n        }\n\n        // Function to rotate a node to the left\n        function rotateLeft(node) {\n            let temp = node.left;\n            node.left = temp.right;\n            temp.right = node;\n            return temp;\n        }\n\n        // Function to rotate a node to the right\n        function rotateRight(node) {\n            let temp = node.right;\n            node.right = temp.left;\n            temp.left = node;\n            return temp;\n        }\n\n        // Function to insert a key into the B-Tree index\n        function insert(key, value, node) {\n            if (node == null) {\n                return { key, value, left: null, right: null };\n            } else {\n                if (key < node.key) {\n                    node.left = insert(key, value, node.left);\n                } else {\n                    node.right = insert(key, value, node.right);\n                }\n                return node;\n            }\n        }\n\n        // Function to search for a key in the B-Tree index\n        function search(key, node) {\n            if (node == null) {\n                return false;\n            } else if (key < node.key) {\n                return search(key, node.left);\n            } else if (key > node.key) {\n                return search(key, node.right);\n            } else {\n                return true;\n            }\n        }\n\n        // Function to display the B-Tree index\n        function display(node, depth = 0) {\n            if (node != null) {\n                display(node.left, depth + 1);\n                textElement.innerHTML += 'Key: ' + node.key + ', Value: ' + node.value + ', Left: ' + (node.left ? node.left.key : 'None'), ', Right: ' + (node.right ? node.right.key : 'None'), '\\n';\n                display(node.right, depth + 1);\n            }\n        }\n\n        // Insert a key-value pair into the B-Tree index\n        function insertData(data) {\n            let root = generateBTreeIndex(data);\n            display(root);\n        }\n\n        // Demonstrate the B-Tree index\n        demonstrationButton.addEventListener('click', () => {\n            insertData([\n                ['John', 25],\n                ['Alice', 30],\n                ['Bob', 20],\n                ['Eve', 35]\n            ]);\n        });\n    </script>\n</body>\n</html>"
