  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Deque Interactive Sandbox</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n/* Extremely minimal plain styling: black text on white background, basic layout */\nhtml,body { margin: 8px; padding: 0; font-family: monospace; color: #000; background: #fff; }\nsection { margin-bottom: 12px; padding: 6px 0; border-top: 1px solid #000; }\nh1 { font-size: 18px; margin: 0 0 6px 0; }\nlabel { display:inline-block; margin-right:6px; }\ninput[type=\"text\"], input[type=\"number\"], textarea, select { font-family: monospace; }\nbutton { margin-right:6px; margin-top:4px; }\n.row { margin-bottom:6px; }\n.displayDeque { min-height:40px; margin-top:6px; white-space:normal; }\n.node { display:inline-block; padding:4px 8px; margin-right:4px; border:1px solid #000; vertical-align:middle; }\n.node.index { font-size:10px; color:#000; display:block; text-align:center; margin-top:2px; }\n.controls { margin-bottom:6px; }\n.small { width:60px; }\n.medium { width:120px; }\n.large { width:320px; }\ntextarea { width:100%; height:100px; }\n.split { display:flex; gap:12px; }\n.col { flex:1; }\n.log { max-height:240px; overflow:auto; white-space:pre-wrap; border:1px solid #000; padding:6px; }\n.note { font-size:12px; margin-top:4px; }\nkbd { border:1px solid #000; padding:2px 4px; font-size:12px; background:transparent; }\n</style>\n</head>\n<body>\n\n<h1>Deque Interactive Sandbox</h1>\n\n<!-- Basic operations -->\n<section>\n  <strong>Basic operations</strong>\n  <div class=\"row controls\">\n    <label>Value(s): <input id=\"valInput\" type=\"text\" class=\"large\" placeholder=\"single value, CSV, or JSON array\"></label>\n    <label>Count: <input id=\"countInput\" type=\"number\" class=\"small\" value=\"1\" min=\"1\"></label>\n    <button id=\"pushFrontBtn\">pushFront</button>\n    <button id=\"pushBackBtn\">pushBack</button>\n    <button id=\"popFrontBtn\">popFront</button>\n    <button id=\"popBackBtn\">popBack</button>\n    <button id=\"peekFrontBtn\">peekFront</button>\n    <button id=\"peekBackBtn\">peekBack</button>\n    <button id=\"clearBtn\">clear</button>\n  </div>\n\n  <div class=\"row controls\">\n    <label>Insert index: <input id=\"insertIndex\" type=\"number\" class=\"small\" value=\"0\" min=\"0\"></label>\n    <label>Insert value: <input id=\"insertVal\" type=\"text\" class=\"medium\"></label>\n    <button id=\"insertAtBtn\">insertAt(index)</button>\n    <label>Delete index: <input id=\"deleteIndex\" type=\"number\" class=\"small\" value=\"0\" min=\"0\"></label>\n    <button id=\"deleteAtBtn\">deleteAt(index)</button>\n    <label>Set index: <input id=\"setIndex\" type=\"number\" class=\"small\" value=\"0\" min=\"0\"></label>\n    <label>Set value: <input id=\"setVal\" type=\"text\" class=\"medium\"></label>\n    <button id=\"setAtBtn\">setAt(index)</button>\n  </div>\n\n  <div class=\"row controls\">\n    <label>Rotate k: <input id=\"rotateK\" type=\"number\" class=\"small\" value=\"1\"></label>\n    <button id=\"rotateLeftBtn\">rotateLeft</button>\n    <button id=\"rotateRightBtn\">rotateRight</button>\n    <button id=\"reverseBtn\">reverse</button>\n    <label>Capacity: <input id=\"capacitySlider\" type=\"range\" min=\"1\" max=\"200\" value=\"200\"></label>\n    <span id=\"capacityDisplay\">200</span>\n    <label><input id=\"autoExpand\" type=\"checkbox\"> auto-expand</label>\n  </div>\n</section>\n\n<!-- Bulk and generation -->\n<section>\n  <strong>Bulk generation & transform</strong>\n  <div class=\"row controls\">\n    <label>Fill random n: <input id=\"randN\" type=\"number\" class=\"small\" value=\"5\" min=\"1\"></label>\n    <label>min: <input id=\"randMin\" type=\"number\" class=\"small\" value=\"0\"></label>\n    <label>max: <input id=\"randMax\" type=\"number\" class=\"small\" value=\"99\"></label>\n    <label>seed: <input id=\"randSeed\" type=\"text\" class=\"small\" placeholder=\"optional\"></label>\n    <button id=\"fillRandomBtn\">fillRandom</button>\n    <button id=\"fillRangeBtn\">fillRange(start,end,step)</button>\n  </div>\n\n  <div class=\"row controls\">\n    <label>Range start: <input id=\"rangeStart\" type=\"number\" class=\"small\" value=\"0\"></label>\n    <label>end: <input id=\"rangeEnd\" type=\"number\" class=\"small\" value=\"10\"></label>\n    <label>step: <input id=\"rangeStep\" type=\"number\" class=\"small\" value=\"1\"></label>\n    <label>side: \n      <select id=\"rangeSide\" class=\"small\">\n        <option value=\"back\">back</option>\n        <option value=\"front\">front</option>\n      </select>\n    </label>\n  </div>\n\n  <div class=\"row controls\">\n    <label>Map expression (x): <input id=\"mapExpr\" type=\"text\" class=\"large\" placeholder=\"e.g., x*2\"></label>\n    <button id=\"applyMapBtn\">map</button>\n    <label>Filter expression (x): <input id=\"filterExpr\" type=\"text\" class=\"large\" placeholder=\"e.g., x%2==0\"></label>\n    <button id=\"applyFilterBtn\">filter</button>\n    <button id=\"compactBtn\">compact (remove null/undef)</button>\n  </div>\n</section>\n\n<!-- Transactions and batches -->\n<section>\n  <strong>Transactions, batch mode & undo/redo</strong>\n  <div class=\"row controls\">\n    <button id=\"beginTxBtn\">Begin Transaction</button>\n    <button id=\"commitTxBtn\">Commit</button>\n    <button id=\"rollbackTxBtn\">Rollback</button>\n    <label><input id=\"batchMode\" type=\"checkbox\"> Batch mode (record then apply)</label>\n    <button id=\"applyBatchBtn\">Apply Batch</button>\n    <button id=\"clearBatchBtn\">Clear Batch</button>\n    <label>Batch preview: <input id=\"batchPreview\" type=\"text\" class=\"large\" readonly></label>\n  </div>\n\n  <div class=\"row controls\">\n    <button id=\"undoBtn\">undo</button>\n    <button id=\"redoBtn\">redo</button>\n    <label>History size: <input id=\"historySize\" type=\"number\" class=\"small\" value=\"100\" min=\"1\"></label>\n    <button id=\"clearHistoryBtn\">clearHistory</button>\n  </div>\n</section>\n\n<!-- Script runner and stepper -->\n<section>\n  <strong>Script runner & operation stepper</strong>\n  <div class=\"row split\">\n    <div class=\"col\">\n      <label>Script commands (one per line). Supported: pushFront v, pushBack v, popFront, popBack, insertAt i v, deleteAt i, rotateLeft k, rotateRight k, reverse, clear, wait ms, fillRandom n min max [seed]</label>\n      <textarea id=\"scriptArea\">pushBack 1\npushBack 2\npushFront 0\nrotateRight 1\npopBack\n</textarea>\n      <div class=\"row controls\">\n        <label>Step delay ms: <input id=\"stepDelay\" type=\"number\" class=\"small\" value=\"300\" min=\"0\"></label>\n        <button id=\"runScriptBtn\">Run Script</button>\n        <button id=\"stepScriptBtn\">Step Script</button>\n        <button id=\"stopScriptBtn\">Stop</button>\n      </div>\n    </div>\n\n    <div class=\"col\">\n      <label>Operation Log / Step controls</label>\n      <div class=\"row controls\">\n        <button id=\"stepBackBtn\">Step Back</button>\n        <button id=\"stepForwardBtn\">Step Forward</button>\n        <button id=\"playBtn\">Play</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <label>Speed ms: <input id=\"playSpeed\" type=\"number\" class=\"small\" value=\"500\" min=\"10\"></label>\n      </div>\n      <div id=\"opLog\" class=\"log\"></div>\n    </div>\n  </div>\n</section>\n\n<!-- Search, inspect, save/load -->\n<section>\n  <strong>Search / View / Save & Load</strong>\n  <div class=\"row controls\">\n    <label>Find value: <input id=\"findVal\" type=\"text\" class=\"medium\"></label>\n    <button id=\"findBtn\">Find</button>\n    <button id=\"highlightAllBtn\">Highlight All</button>\n    <label>Index to view: <input id=\"viewIndex\" type=\"number\" class=\"small\" value=\"0\" min=\"0\"></label>\n    <button id=\"viewIndexBtn\">viewAt</button>\n  </div>\n\n  <div class=\"row controls\">\n    <button id=\"saveBtn\">Save Snapshot (JSON)</button>\n    <button id=\"loadBtn\">Load Snapshot</button>\n    <button id=\"exportBtn\">Export Log</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Snapshot / Import:</label>\n    <textarea id=\"snapshotArea\" placeholder='Paste JSON snapshot to load'></textarea>\n  </div>\n</section>\n\n<!-- Random test runner -->\n<section>\n  <strong>Random test runner & validator</strong>\n  <div class=\"row controls\">\n    <label>Ops: <input id=\"randOps\" type=\"number\" class=\"small\" value=\"50\"></label>\n    <label>Seed: <input id=\"randTestSeed\" type=\"text\" class=\"small\" placeholder=\"optional\"></label>\n    <label>Capacity limit: <input id=\"randCap\" type=\"number\" class=\"small\" value=\"200\"></label>\n    <button id=\"runRandTestBtn\">Run Random Test</button>\n    <button id=\"validateBtn\">Validate vs array</button>\n  </div>\n  <div class=\"note\">Random test will perform many random deque ops and can compare results to a native array simulation. Use seed for reproducibility.</div>\n</section>\n\n<!-- Deque visual display and metadata -->\n<section>\n  <strong>Deque Visualization</strong>\n  <div id=\"meta\" class=\"row\">\n    <span>front index: <span id=\"frontIdx\">0</span></span>\n    <span style=\"margin-left:12px\">back index: <span id=\"backIdx\">0</span></span>\n    <span style=\"margin-left:12px\">size: <span id=\"sizeDisplay\">0</span></span>\n    <span style=\"margin-left:12px\">capacity: <span id=\"capDisplay\">200</span></span>\n  </div>\n  <div id=\"dequeDisplay\" class=\"displayDeque\"></div>\n  <div class=\"note\">Click a node to copy value into \"Value(s)\" input. Use keyboard focus to speed testing. Many controls can be chained.</div>\n</section>\n\n<script>\n/*\n  Deque Interactive Sandbox\n  - Plain interface, many interactive controls\n  - Provides transactional, batch, script, random test, history, stepping, save/load\n*/\n\n(function(){\n  // Basic deque implementation with capacity\n  class Deque {\n    constructor(capacity=200, autoExpand=true){\n      this._data = [];\n      this.capacity = capacity;\n      this.autoExpand = autoExpand;\n    }\n    toArray(){ return this._data.slice(); }\n    size(){ return this._data.length; }\n    isEmpty(){ return this.size() === 0; }\n    front(){ return this._data[0]; }\n    back(){ return this._data[this._data.length-1]; }\n    ensureCapacity(n){\n      if(this.autoExpand) {\n        if (n > this.capacity) this.capacity = n;\n      } else {\n        if (n > this.capacity) throw new Error(\"Capacity exceeded\");\n      }\n    }\n    pushFront(v){ this.ensureCapacity(this.size()+1); this._data.unshift(v); }\n    pushBack(v){ this.ensureCapacity(this.size()+1); this._data.push(v); }\n    popFront(){ if(this.isEmpty()) return undefined; return this._data.shift(); }\n    popBack(){ if(this.isEmpty()) return undefined; return this._data.pop(); }\n    insertAt(i,v){ if(i<0 || i>this.size()) throw new Error(\"Index out of range\"); this.ensureCapacity(this.size()+1); this._data.splice(i,0,v); }\n    deleteAt(i){ if(i<0 || i>=this.size()) throw new Error(\"Index out of range\"); return this._data.splice(i,1)[0]; }\n    setAt(i,v){ if(i<0 || i>=this.size()) throw new Error(\"Index out of range\"); this._data[i]=v; }\n    rotateLeft(k=1){\n      if(this.isEmpty()) return;\n      k = ((k % this.size()) + this.size()) % this.size();\n      for(let i=0;i<k;i++) this.pushBack(this.popFront());\n    }\n    rotateRight(k=1){\n      if(this.isEmpty()) return;\n      k = ((k % this.size()) + this.size()) % this.size();\n      for(let i=0;i<k;i++) this.pushFront(this.popBack());\n    }\n    reverse(){ this._data.reverse(); }\n    clear(){ this._data = []; }\n    fillRange(start,end,step=1,side='back'){ if(step===0) throw new Error(\"step cannot be 0\");\n      if(step>0){\n        for(let v=start; v<=end; v+=step){\n          if(side==='back') this.pushBack(v); else this.pushFront(v);\n        }\n      } else {\n        for(let v=start; v>=end; v+=step){\n          if(side==='back') this.pushBack(v); else this.pushFront(v);\n        }\n      }\n    }\n    fillRandom(n,min=0,max=100,seed=null,side='back'){\n      let rand = seededRand(seed);\n      for(let i=0;i<n;i++){\n        let v = Math.floor(rand() * (max - min + 1)) + min;\n        if(side==='back') this.pushBack(v); else this.pushFront(v);\n      }\n    }\n    map(fn){ this._data = this._data.map(fn); }\n    filter(fn){ this._data = this._data.filter(fn); }\n    compact(){ this._data = this._data.filter(x => x !== null && x !== undefined); }\n  }\n\n  // Simple seeded RNG (Mulberry32)\n  function seededRand(seed){\n    if(seed===null || seed===undefined || seed==='') return Math.random;\n    let s = 0;\n    for(let i=0;i<seed.toString().length;i++) s = (s<<5)-s + seed.toString().charCodeAt(i);\n    s = s >>> 0;\n    return function(){\n      s |= 0;\n      s = s + 0x6D2B79F5 | 0;\n      let t = Math.imul(s ^ s>>>15, 1 | s);\n      t = t + Math.imul(t ^ t>>>7, 61 | t) ^ t;\n      return ((t ^ t>>>14) >>> 0) / 4294967296;\n    }\n  }\n\n  // State management\n  const state = {\n    deque: new Deque(200,true),\n    history: [], // snapshots {arr,desc}\n    historyPos: -1,\n    maxHistory: 100,\n    batch: [],\n    inTransaction: false,\n    txBackup: null,\n    opLog: [],\n    steppingLog: [], // recorded operations for stepper with state snapshots\n    stepPos: -1,\n    script: null,\n    playing: false,\n    playTimer: null\n  };\n\n  // DOM refs\n  const refs = {};\n  [\n    \"valInput\",\"countInput\",\"pushFrontBtn\",\"pushBackBtn\",\"popFrontBtn\",\"popBackBtn\",\"peekFrontBtn\",\"peekBackBtn\",\"clearBtn\",\n    \"insertIndex\",\"insertVal\",\"insertAtBtn\",\"deleteIndex\",\"deleteAtBtn\",\"setIndex\",\"setVal\",\"setAtBtn\",\n    \"rotateK\",\"rotateLeftBtn\",\"rotateRightBtn\",\"reverseBtn\",\"capacitySlider\",\"capacityDisplay\",\"autoExpand\",\n    \"randN\",\"randMin\",\"randMax\",\"randSeed\",\"fillRandomBtn\",\"fillRangeBtn\",\"rangeStart\",\"rangeEnd\",\"rangeStep\",\"rangeSide\",\n    \"mapExpr\",\"applyMapBtn\",\"filterExpr\",\"applyFilterBtn\",\"compactBtn\",\n    \"beginTxBtn\",\"commitTxBtn\",\"rollbackTxBtn\",\"batchMode\",\"applyBatchBtn\",\"clearBatchBtn\",\"batchPreview\",\n    \"undoBtn\",\"redoBtn\",\"historySize\",\"clearHistoryBtn\",\n    \"scriptArea\",\"runScriptBtn\",\"stepScriptBtn\",\"stopScriptBtn\",\"stepDelay\",\"opLog\",\"stepBackBtn\",\"stepForwardBtn\",\"playBtn\",\"pauseBtn\",\"playSpeed\",\n    \"findVal\",\"findBtn\",\"highlightAllBtn\",\"viewIndex\",\"viewIndexBtn\",\"saveBtn\",\"loadBtn\",\"exportBtn\",\"snapshotArea\",\n    \"randOps\",\"randTestSeed\",\"randCap\",\"runRandTestBtn\",\"validateBtn\",\n    \"dequeDisplay\",\"frontIdx\",\"backIdx\",\"sizeDisplay\",\"capDisplay\",\"opLog\"\n  ].forEach(id => refs[id] = document.getElementById(id));\n\n  // Utility: parse values from input allowing CSV or JSON array or single\n  function parseValues(text){\n    text = (text||\"\").trim();\n    if(text === \"\") return [];\n    // Try JSON\n    try{\n      const j = JSON.parse(text);\n      if(Array.isArray(j)) return j;\n      return [j];\n    }catch(e){}\n    // CSV by comma\n    if(text.indexOf(\",\") >= 0){\n      return text.split(\",\").map(s=>parsePrimitive(s.trim()));\n    }\n    // single primitive\n    return [parsePrimitive(text)];\n  }\n  function parsePrimitive(s){\n    if(s === \"null\") return null;\n    if(s === \"undefined\") return undefined;\n    if(s === \"true\") return true;\n    if(s === \"false\") return false;\n    if(!isNaN(Number(s)) && s !== \"\") return Number(s);\n    return s;\n  }\n\n  // Display update\n  function render(){\n    const dq = state.deque;\n    // meta\n    refs.frontIdx.textContent = dq.size() ? 0 : \"-\";\n    refs.backIdx.textContent = dq.size() ? (dq.size()-1) : \"-\";\n    refs.sizeDisplay.textContent = dq.size();\n    refs.capDisplay.textContent = dq.capacity;\n    refs.capacityDisplay.textContent = dq.capacity;\n    // deque display\n    const arr = dq.toArray();\n    const container = refs.dequeDisplay;\n    container.innerHTML = \"\";\n    for(let i=0;i<arr.length;i++){\n      const node = document.createElement(\"div\");\n      node.className = \"node\";\n      node.dataset.index = i;\n      node.textContent = String(arr[i]);\n      const idx = document.createElement(\"div\");\n      idx.className = \"node index\";\n      idx.textContent = i;\n      node.appendChild(idx);\n      node.addEventListener(\"click\", ()=> {\n        refs.valInput.value = JSON.stringify(arr[i]);\n      });\n      container.appendChild(node);\n    }\n    // update logs\n    updateOpLog();\n    updateBatchPreview();\n    // enable/disable history buttons\n    refs.undoBtn.disabled = state.historyPos <= 0;\n    refs.redoBtn.disabled = state.historyPos >= state.history.length-1;\n  }\n\n  // History snapshotting\n  function pushHistory(desc){\n    // Trim forward if not at end\n    if(state.historyPos < state.history.length-1){\n      state.history = state.history.slice(0, state.historyPos+1);\n    }\n    // enforce max\n    const snap = {\n      arr: state.deque.toArray(),\n      cap: state.deque.capacity,\n      autoExpand: state.deque.autoExpand,\n      desc: desc || \"op\"\n    };\n    state.history.push(snap);\n    if(state.history.length > state.maxHistory) state.history.shift();\n    state.historyPos = state.history.length-1;\n    // log for stepping\n    state.opLog.push({desc, snap: JSON.parse(JSON.stringify(snap))});\n    state.steppingLog.push({desc, snap: JSON.parse(JSON.stringify(snap))});\n  }\n\n  function undo(){\n    if(state.historyPos <= 0) return;\n    state.historyPos--;\n    const snap = state.history[state.historyPos];\n    restoreSnapshot(snap, false);\n  }\n  function redo(){\n    if(state.historyPos >= state.history.length-1) return;\n    state.historyPos++;\n    const snap = state.history[state.historyPos];\n    restoreSnapshot(snap, false);\n  }\n  function restoreSnapshot(snap, record=true){\n    state.deque._data = snap.arr.slice();\n    state.deque.capacity = snap.cap;\n    state.deque.autoExpand = snap.autoExpand;\n    if(record) pushHistory(\"restore\");\n    render();\n  }\n\n  function logOp(text){\n    const time = new Date().toLocaleTimeString();\n    state.opLog.push({desc: '['+time+'] '+text});\n    updateOpLog();\n  }\n  function updateOpLog(){\n    const elem = refs.opLog;\n    // mix both structured op logs and textual logs\n    const out = [];\n    for(let i=0;i<state.opLog.length;i++){\n      const e = state.opLog[i];\n      if(typeof e === 'string') out.push(e);\n      else if(e.desc && e.snap) out.push((i===state.historyPos ? \"▶ \" : \"   \") + (e.desc||'op'));\n      else if(e.desc) out.push(e.desc);\n    }\n    elem.textContent = out.join(\"\\n\");\n  }\n\n  // Batch handling\n  function updateBatchPreview(){\n    refs.batchPreview.value = state.batch.join(\" | \");\n  }\n\n  // Attach event handlers for buttons\n  refs.pushFrontBtn.addEventListener(\"click\", ()=> {\n    const vals = parseValues(refs.valInput.value);\n    const count = Math.max(1, Number(refs.countInput.value)||1);\n    if(vals.length===0) { alert(\"No value to push\"); return; }\n    performOp(()=> {\n      for(let i=0;i<count;i++){\n        if(vals.length === 1) state.deque.pushFront(cloneValue(vals[0]));\n        else state.deque.pushFront(cloneValue(vals[i % vals.length]));\n      }\n    }, `pushFront ${JSON.stringify(vals)} x${count}`);\n  });\n  refs.pushBackBtn.addEventListener(\"click\", ()=> {\n    const vals = parseValues(refs.valInput.value);\n    const count = Math.max(1, Number(refs.countInput.value)||1);\n    if(vals.length===0) { alert(\"No value to push\"); return; }\n    performOp(()=> {\n      for(let i=0;i<count;i++){\n        if(vals.length === 1) state.deque.pushBack(cloneValue(vals[0]));\n        else state.deque.pushBack(cloneValue(vals[i % vals.length]));\n      }\n    }, `pushBack ${JSON.stringify(vals)} x${count}`);\n  });\n  refs.popFrontBtn.addEventListener(\"click\", ()=> {\n    const n = Math.max(1, Number(refs.countInput.value)||1);\n    performOp(()=> {\n      let out = [];\n      for(let i=0;i<n;i++) out.push(state.deque.popFront());\n      alert(\"popped front: \" + JSON.stringify(out));\n    }, `popFront x${n}`);\n  });\n  refs.popBackBtn.addEventListener(\"click\", ()=> {\n    const n = Math.max(1, Number(refs.countInput.value)||1);\n    performOp(()=> {\n      let out = [];\n      for(let i=0;i<n;i++) out.push(state.deque.popBack());\n      alert(\"popped back: \" + JSON.stringify(out));\n    }, `popBack x${n}`);\n  });\n  refs.peekFrontBtn.addEventListener(\"click\", ()=> {\n    alert(\"peekFront -> \" + JSON.stringify(state.deque.front()));\n  });\n  refs.peekBackBtn.addEventListener(\"click\", ()=> {\n    alert(\"peekBack -> \" + JSON.stringify(state.deque.back()));\n  });\n  refs.clearBtn.addEventListener(\"click\", ()=> {\n    performOp(()=> state.deque.clear(), \"clear\");\n  });\n\n  refs.insertAtBtn.addEventListener(\"click\", ()=> {\n    const i = Number(refs.insertIndex.value);\n    const vals = parseValues(refs.insertVal.value);\n    if(vals.length===0) { alert(\"No value to insert\"); return; }\n    performOp(()=> {\n      // insert multiple preserving order\n      for(let k=0;k<vals.length;k++){\n        state.deque.insertAt(i+k, cloneValue(vals[k]));\n      }\n    }, `insertAt ${i} ${JSON.stringify(vals)}`);\n  });\n  refs.deleteAtBtn.addEventListener(\"click\", ()=> {\n    const i = Number(refs.deleteIndex.value);\n    performOp(()=> {\n      const v = state.deque.deleteAt(i);\n      alert(\"deleted: \"+JSON.stringify(v));\n    }, `deleteAt ${i}`);\n  });\n  refs.setAtBtn.addEventListener(\"click\", ()=> {\n    const i = Number(refs.setIndex.value);\n    const vals = parseValues(refs.setVal.value);\n    if(vals.length===0){ alert(\"No value\"); return; }\n    performOp(()=> state.deque.setAt(i, cloneValue(vals[0])), `setAt ${i} ${JSON.stringify(vals[0])}`);\n  });\n\n  refs.rotateLeftBtn.addEventListener(\"click\", ()=> {\n    const k = Number(refs.rotateK.value) || 1;\n    performOp(()=> state.deque.rotateLeft(k), `rotateLeft ${k}`);\n  });\n  refs.rotateRightBtn.addEventListener(\"click\", ()=> {\n    const k = Number(refs.rotateK.value) || 1;\n    performOp(()=> state.deque.rotateRight(k), `rotateRight ${k}`);\n  });\n  refs.reverseBtn.addEventListener(\"click\", ()=> {\n    performOp(()=> state.deque.reverse(), \"reverse\");\n  });\n\n  refs.capacitySlider.addEventListener(\"input\", ()=> {\n    const v = Number(refs.capacitySlider.value);\n    refs.capacityDisplay.textContent = v;\n    state.deque.capacity = v;\n    render();\n  });\n  refs.autoExpand.addEventListener(\"change\", ()=> {\n    state.deque.autoExpand = refs.autoExpand.checked;\n    render();\n  });\n\n  // Bulk generation\n  refs.fillRandomBtn.addEventListener(\"click\", ()=> {\n    const n = Number(refs.randN.value) || 0;\n    const min = Number(refs.randMin.value) || 0;\n    const max = Number(refs.randMax.value) || 0;\n    const seed = refs.randSeed.value || null;\n    performOp(()=> state.deque.fillRandom(n,min,max,seed), `fillRandom n=${n} min=${min} max=${max} seed=${seed}`);\n  });\n  refs.fillRangeBtn.addEventListener(\"click\", ()=> {\n    const start = Number(refs.rangeStart.value);\n    const end = Number(refs.rangeEnd.value);\n    const step = Number(refs.rangeStep.value) || 1;\n    const side = refs.rangeSide.value || 'back';\n    performOp(()=> state.deque.fillRange(start,end,step,side), `fillRange ${start}..${end} step=${step} side=${side}`);\n  });\n\n  // Map/Filter\n  refs.applyMapBtn.addEventListener(\"click\", ()=> {\n    const expr = refs.mapExpr.value.trim();\n    if(!expr){ alert(\"Provide expression using 'x' variable\"); return; }\n    performOp(()=> {\n      const fn = new Function(\"x\",\"i\",\"arr\",\"return (\"+expr+\")\");\n      state.deque.map((x,i,arr)=>fn(x,i,arr));\n    }, `map (${expr})`);\n  });\n  refs.applyFilterBtn.addEventListener(\"click\", ()=> {\n    const expr = refs.filterExpr.value.trim();\n    if(!expr){ alert(\"Provide filter expression using 'x'\"); return; }\n    performOp(()=> {\n      const fn = new Function(\"x\",\"i\",\"arr\",\"return (\"+expr+\")\");\n      state.deque.filter((x,i,arr)=>fn(x,i,arr));\n    }, `filter (${expr})`);\n  });\n  refs.compactBtn.addEventListener(\"click\", ()=> {\n    performOp(()=> state.deque.compact(), 'compact');\n  });\n\n  // Transactions\n  refs.beginTxBtn.addEventListener(\"click\", ()=> {\n    if(state.inTransaction) { alert(\"Already in transaction\"); return; }\n    state.inTransaction = true;\n    state.txBackup = {\n      arr: state.deque.toArray(),\n      cap: state.deque.capacity,\n      autoExpand: state.deque.autoExpand\n    };\n    logOp(\"Begin Transaction\");\n  });\n  refs.commitTxBtn.addEventListener(\"click\", ()=> {\n    if(!state.inTransaction) { alert(\"No active transaction\"); return; }\n    state.inTransaction = false;\n    state.txBackup = null;\n    pushHistory(\"commit transaction\");\n    logOp(\"Commit Transaction\");\n    render();\n  });\n  refs.rollbackTxBtn.addEventListener(\"click\", ()=> {\n    if(!state.inTransaction) { alert(\"No active transaction\"); return; }\n    state.inTransaction = false;\n    restoreSnapshot({arr: state.txBackup.arr, cap: state.txBackup.cap, autoExpand: state.txBackup.autoExpand}, true);\n    state.txBackup = null;\n    logOp(\"Rollback Transaction\");\n    render();\n  });\n\n  // Batch mode\n  refs.batchMode.addEventListener(\"change\", ()=> {\n    if(refs.batchMode.checked){\n      state.batch = [];\n      logOp(\"Batch mode ON\");\n    } else {\n      logOp(\"Batch mode OFF\");\n    }\n    updateBatchPreview();\n  });\n  refs.applyBatchBtn.addEventListener(\"click\", ()=> {\n    if(state.batch.length===0) { alert(\"Batch empty\"); return; }\n    performOp(()=> {\n      state.batch.forEach(cmd => runSingleCommand(cmd, false));\n    }, \"applyBatch: \" + state.batch.join(\";\");\n    );\n    state.batch = [];\n    updateBatchPreview();\n  });\n  refs.clearBatchBtn.addEventListener(\"click\", ()=> {\n    state.batch = [];\n    updateBatchPreview();\n  });\n\n  // Undo/Redo\n  refs.undoBtn.addEventListener(\"click\", ()=> undo());\n  refs.redoBtn.addEventListener(\"click\", ()=> redo());\n  refs.historySize.addEventListener(\"change\", ()=> {\n    state.maxHistory = Math.max(1, Number(refs.historySize.value)||100);\n  });\n  refs.clearHistoryBtn.addEventListener(\"click\", ()=> {\n    state.history = [];\n    state.historyPos = -1;\n    state.opLog = [];\n    state.steppingLog = [];\n    updateOpLog();\n  });\n\n  // Script runner\n  let scriptLines = [];\n  let scriptPos = 0;\n  let scriptTimer = null;\n\n  refs.runScriptBtn.addEventListener(\"click\", ()=> {\n    const text = refs.scriptArea.value;\n    scriptLines = text.split(\"\\n\").map(s=>s.trim()).filter(s=>s.length>0);\n    scriptPos = 0;\n    runScriptAuto();\n  });\n  refs.stepScriptBtn.addEventListener(\"click\", ()=> {\n    const text = refs.scriptArea.value;\n    if(scriptLines.length ===0){ scriptLines = text.split(\"\\n\").map(s=>s.trim()).filter(s=>s.length>0); scriptPos=0; }\n    if(scriptPos < scriptLines.length) {\n      const line = scriptLines[scriptPos++];\n      runSingleCommand(line, true);\n    } else {\n      alert(\"Script complete\");\n    }\n  });\n  refs.stopScriptBtn.addEventListener(\"click\", ()=> {\n    stopScript();\n  });\n  function runScriptAuto(){\n    stopScript();\n    const delay = Math.max(0, Number(refs.stepDelay.value)||0);\n    if(scriptPos >= scriptLines.length) { scriptPos=0; }\n    function step(){\n      if(scriptPos >= scriptLines.length){ stopScript(); return; }\n      const line = scriptLines[scriptPos++];\n      runSingleCommand(line, true);\n      scriptTimer = setTimeout(step, delay);\n    }\n    scriptTimer = setTimeout(step, delay);\n  }\n  function stopScript(){ if(scriptTimer) clearTimeout(scriptTimer); scriptTimer = null; }\n\n  // Stepper controls\n  refs.stepBackBtn.addEventListener(\"click\", ()=> {\n    if(state.stepPos <= 0) return;\n    state.stepPos--;\n    const snap = state.steppingLog[state.stepPos].snap;\n    restoreSnapshot(snap, false);\n    render();\n  });\n  refs.stepForwardBtn.addEventListener(\"click\", ()=> {\n    if(state.stepPos >= state.steppingLog.length-1) return;\n    state.stepPos++;\n    const snap = state.steppingLog[state.stepPos].snap;\n    restoreSnapshot(snap, false);\n    render();\n  });\n  refs.playBtn.addEventListener(\"click\", ()=> {\n    if(state.playing) return;\n    state.playing = true;\n    const speed = Math.max(10, Number(refs.playSpeed.value)||500);\n    state.playTimer = setInterval(()=> {\n      if(state.stepPos < state.steppingLog.length-1){\n        state.stepPos++;\n        const snap = state.steppingLog[state.stepPos].snap;\n        restoreSnapshot(snap, false);\n      } else {\n        clearInterval(state.playTimer);\n        state.playing = false;\n      }\n    }, speed);\n  });\n  refs.pauseBtn.addEventListener(\"click\", ()=> {\n    if(state.playTimer) clearInterval(state.playTimer);\n    state.playing = false;\n  });\n\n  // Find and view at index\n  refs.findBtn.addEventListener(\"click\", ()=> {\n    const v = parseValues(refs.findVal.value);\n    if(v.length===0) return alert(\"Provide value to find\");\n    const arr = state.deque.toArray();\n    const matches = [];\n    for(let i=0;i<arr.length;i++){\n      if(equalValues(arr[i], v[0])) matches.push(i);\n    }\n    alert(\"Matches at indexes: \" + JSON.stringify(matches));\n    highlightIndexes(matches);\n  });\n  refs.highlightAllBtn.addEventListener(\"click\", ()=> {\n    const v = parseValues(refs.findVal.value);\n    if(v.length===0) return alert(\"Provide value to highlight\");\n    const arr = state.deque.toArray();\n    const matches = [];\n    for(let i=0;i<arr.length;i++){\n      if(equalValues(arr[i], v[0])) matches.push(i);\n    }\n    highlightIndexes(matches);\n  });\n  refs.viewIndexBtn.addEventListener(\"click\", ()=> {\n    const i = Number(refs.viewIndex.value);\n    const arr = state.deque.toArray();\n    if(i<0 || i>=arr.length) return alert(\"Index out of range\");\n    alert(\"Value at \"+i+\" = \"+JSON.stringify(arr[i]));\n  });\n\n  // Save/load\n  refs.saveBtn.addEventListener(\"click\", ()=> {\n    const snap = {\n      arr: state.deque.toArray(),\n      cap: state.deque.capacity,\n      autoExpand: state.deque.autoExpand,\n      history: state.history.slice()\n    };\n    refs.snapshotArea.value = JSON.stringify(snap, null, 2);\n  });\n  refs.loadBtn.addEventListener(\"click\", ()=> {\n    try{\n      const obj = JSON.parse(refs.snapshotArea.value);\n      if(!obj || !Array.isArray(obj.arr)) throw new Error(\"Invalid snapshot\");\n      state.deque._data = obj.arr.slice();\n      state.deque.capacity = obj.cap || state.deque.capacity;\n      state.deque.autoExpand = obj.autoExpand!==undefined ? obj.autoExpand : state.deque.autoExpand;\n      if(Array.isArray(obj.history)) state.history = obj.history.slice();\n      state.historyPos = state.history.length-1;\n      render();\n    }catch(e){ alert(\"Failed to load snapshot: \"+e.message); }\n  });\n  refs.exportBtn.addEventListener(\"click\", ()=> {\n    const text = refs.opLog.textContent || \"\";\n    const blob = new Blob([text], {type: \"text/plain\"});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement(\"a\");\n    a.href = url; a.download = \"deque_log.txt\"; document.body.appendChild(a); a.click(); a.remove();\n    URL.revokeObjectURL(url);\n  });\n\n  // Random test runner\n  refs.runRandTestBtn.addEventListener(\"click\", ()=> {\n    const ops = Number(refs.randOps.value) || 0;\n    const seed = refs.randTestSeed.value || \"rand\";\n    const cap = Number(refs.randCap.value) || 200;\n    runRandomTest(ops, seed, cap);\n  });\n  refs.validateBtn.addEventListener(\"click\", ()=> {\n    runValidation();\n  });\n\n  // Utility functions\n  function performOp(fn, desc){\n    try{\n      if(refs.batchMode.checked){\n        // in batch mode, capture the command text not actual function\n        state.batch.push(desc || \"batchedOp\");\n        updateBatchPreview();\n        logOp(\"Batch queued: \" + desc);\n        return;\n      }\n      fn();\n      if(state.inTransaction){\n        // don't push history now; wait for commit\n        logOp(\"transaction op: \" + desc);\n      } else {\n        pushHistory(desc);\n      }\n      render();\n    }catch(e){\n      alert(\"Operation failed: \" + e.message);\n    }\n  }\n\n  function cloneValue(v){\n    try { return JSON.parse(JSON.stringify(v)); } catch { return v; }\n  }\n\n  function equalValues(a,b){\n    try { return JSON.stringify(a) === JSON.stringify(b); } catch { return a===b; }\n  }\n\n  function highlightIndexes(indexes){\n    const nodes = refs.dequeDisplay.querySelectorAll(\".node\");\n    nodes.forEach(n => n.style.border = \"1px solid #000\");\n    indexes.forEach(i => {\n      const n = refs.dequeDisplay.querySelector('.node[data-index=\"'+i+'\"]');\n      if(n) n.style.border = \"3px solid\";\n    });\n  }\n\n  // Script command runner (supports some commands)\n  function runSingleCommand(line, recordHistory=true){\n    const parts = line.trim().split(/\\s+/);\n    if(parts.length===0) return;\n    const cmd = parts[0];\n    try{\n      switch(cmd){\n        case 'pushFront': {\n          const val = parts.slice(1).join(\" \");\n          const parsed = parseValues(val);\n          performOp(()=> {\n            parsed.forEach(v=>state.deque.pushFront(v));\n          }, line);\n        } break;\n        case 'pushBack': {\n          const val = parts.slice(1).join(\" \");\n          const parsed = parseValues(val);\n          performOp(()=> {\n            parsed.forEach(v=>state.deque.pushBack(v));\n          }, line);\n        } break;\n        case 'popFront': performOp(()=> state.deque.popFront(), line); break;\n        case 'popBack': performOp(()=> state.deque.popBack(), line); break;\n        case 'insertAt': {\n          const i = Number(parts[1]);\n          const val = parts.slice(2).join(\" \");\n          const parsed = parseValues(val);\n          performOp(()=> {\n            for(let k=0;k<parsed.length;k++) state.deque.insertAt(i+k, parsed[k]);\n          }, line);\n        } break;\n        case 'deleteAt': {\n          const i = Number(parts[1]);\n          performOp(()=> state.deque.deleteAt(i), line);\n        } break;\n        case 'rotateLeft': { const k = Number(parts[1]||1); performOp(()=> state.deque.rotateLeft(k), line); } break;\n        case 'rotateRight': { const k = Number(parts[1]||1); performOp(()=> state.deque.rotateRight(k), line); } break;\n        case 'reverse': performOp(()=> state.deque.reverse(), line); break;\n        case 'clear': performOp(()=> state.deque.clear(), line); break;\n        case 'wait': {\n          const ms = Number(parts[1]||0);\n          // blocking wait is not desirable. We'll schedule next actions externally (used in scripts with stepper)\n          const p = new Promise(resolve=> setTimeout(resolve, ms));\n          p.then(()=>{ /* resume */ });\n        } break;\n        case 'fillRandom': {\n          const n = Number(parts[1]||0);\n          const min = Number(parts[2]||0);\n          const max = Number(parts[3]||100);\n          const seed = parts[4] || null;\n          performOp(()=> state.deque.fillRandom(n,min,max,seed), line);\n        } break;\n        case 'fillRange': {\n          const start = Number(parts[1]||0);\n          const end = Number(parts[2]||0);\n          const step = Number(parts[3]||1);\n          performOp(()=> state.deque.fillRange(start,end,step), line);\n        } break;\n        default:\n          // treat as JS expression like eval for ad-hoc commands\n          try{\n            // allow commands like \"setAt 1 99\" as shorthand\n            if(line.includes('=')){\n              // e.g., idx=1; val=5; setAt(idx,val)\n            }\n            // ignore unknowns\n            logOp(\"Unknown command: \"+line);\n          }catch(e){ logOp(\"Error running line: \"+e.message); }\n      }\n    }catch(e){\n      alert(\"Script command error: \"+e.message);\n    }\n    render();\n  }\n\n  // Random test runner\n  function runRandomTest(ops, seed, cap){\n    const rng = seededRand(seed || Math.random().toString());\n    const sim = { arr: [], deque: new Deque(cap,true) };\n    state.deque.clear();\n    state.deque.capacity = cap;\n    state.deque.autoExpand = true;\n    state.opLog = [];\n    for(let i=0;i<ops;i++){\n      const r = Math.floor(rng()*6);\n      try{\n        switch(r){\n          case 0: { // pushBack\n            const v = Math.floor(rng()*1000);\n            sim.arr.push(v);\n            state.deque.pushBack(v);\n            pushHistory(`rand pushBack ${v}`);\n          } break;\n          case 1: { // pushFront\n            const v = Math.floor(rng()*1000);\n            sim.arr.unshift(v);\n            state.deque.pushFront(v);\n            pushHistory(`rand pushFront ${v}`);\n          } break;\n          case 2: { // popBack\n            const a = sim.arr.length? sim.arr.pop() : undefined;\n            const b = state.deque.popBack();\n            if(!equalValues(a,b)) throw new Error(`Mismatch popBack at op ${i}: sim ${a} vs dq ${b}`);\n            pushHistory('rand popBack');\n          } break;\n          case 3: { // popFront\n            const a = sim.arr.length? sim.arr.shift() : undefined;\n            const b = state.deque.popFront();\n            if(!equalValues(a,b)) throw new Error(`Mismatch popFront at op ${i}: sim ${a} vs dq ${b}`);\n            pushHistory('rand popFront');\n          } break;\n          case 4: { // rotate\n            const k = Math.floor(rng()*3);\n            if(Math.random()>0.5){\n              // rotateLeft\n              for(let t=0;t<k;t++) if(sim.arr.length) sim.arr.push(sim.arr.shift());\n              state.deque.rotateLeft(k);\n              pushHistory('rand rotateLeft '+k);\n            } else {\n              for(let t=0;t<k;t++) if(sim.arr.length) sim.arr.unshift(sim.arr.pop());\n              state.deque.rotateRight(k);\n              pushHistory('rand rotateRight '+k);\n            }\n          } break;\n          case 5: { // delete random index if any\n            if(sim.arr.length){\n              const idx = Math.floor(rng()*sim.arr.length);\n              const a = sim.arr.splice(idx,1)[0];\n              const b = state.deque.deleteAt(idx);\n              if(!equalValues(a,b)) throw new Error(`Mismatch deleteAt ${idx}: sim ${a} vs dq ${b}`);\n              pushHistory(`rand deleteAt ${idx}`);\n            }\n          } break;\n        }\n      }catch(e){\n        alert(\"Random test failure: \"+e.message);\n        render();\n        return;\n      }\n    }\n    alert(\"Random test completed successfully. Size: \" + state.deque.size());\n    render();\n  }\n\n  // Validate vs array\n  function runValidation(){\n    // compare current deque to JavaScript array\n    const arr = state.deque.toArray();\n    const clone = arr.slice();\n    // perform transforms specified in opLog and re-simulate? Instead, just show arr and prompt user.\n    alert(\"Current deque as array: \" + JSON.stringify(arr));\n  }\n\n  // Initialize: set defaults and initial history snapshot\n  function init(){\n    state.deque = new Deque(Number(refs.capacitySlider.value)||200,true);\n    refs.autoExpand.checked = state.deque.autoExpand;\n    pushHistory(\"initial\");\n    state.stepPos = state.steppingLog.length-1;\n    render();\n    // keyboard shortcuts\n    window.addEventListener(\"keydown\", (e)=>{\n      if(e.ctrlKey && e.key === 'z') { undo(); e.preventDefault(); }\n      if(e.ctrlKey && e.key === 'y') { redo(); e.preventDefault(); }\n    });\n  }\n\n  init();\n\n  // Expose some helpers to console for deep exploration if user opens devtools\n  window.__dequeSandbox = {\n    state, refs, Deque, seededRand,\n    performOp, runSingleCommand, pushHistory, restoreSnapshot\n  };\n\n})();\n</script>\n\n</body>\n</html>"
