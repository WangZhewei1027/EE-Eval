    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Topological Sort — Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n    margin: 0; padding: 0;\n  }\n  html, body {\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Montserrat', sans-serif;\n    color: #fafafa;\n    overflow: hidden;\n  }\n\n  #container {\n    min-height: 100vh;\n    padding: 3rem 2rem 5rem 2rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.6rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #f0eae8;\n    text-shadow:\n      0 0 7px #ffb74d99,\n      0 0 20px #ff6f0099,\n      0 0 30px #ff6f0022;\n    margin-bottom: 1.2rem;\n  }\n\n  p.subtitle {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 500;\n    font-size: 1.2rem;\n    letter-spacing: 0.04em;\n    color: #b0bebfcc;\n    max-width: 460px;\n    margin-bottom: 3.5rem;\n    user-select: text;\n  }\n\n  #canvas-wrapper {\n    position: relative;\n    width: 760px;\n    height: 480px;\n    background:\n      radial-gradient(circle at center, #152f4d 40%, #0b1c2c 90%);\n    border-radius: 18px;\n    box-shadow:\n      0 0 50px 6px #ff6f00aa inset,\n      0 12px 40px #ff6f00dd;\n    overflow: visible;\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n  }\n\n  .node {\n    cursor: default;\n    filter: drop-shadow(0 0 2.2px #ffad4055);\n    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);\n  }\n  .node circle {\n    fill: #ff6f00;\n    stroke: #ffb74d;\n    stroke-width: 2.5px;\n    filter: drop-shadow(0 0 6px #ffb74dbb);\n  }\n  .node text {\n    fill: #fff8e7;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.25rem;\n    pointer-events: none;\n    user-select: none;\n    text-shadow: 0 0 4px rgba(255 255 255 / 0.25);\n  }\n\n  .edge {\n    stroke: #ffa726cc;\n    stroke-width: 2.2;\n    fill: none;\n    filter: drop-shadow(0 0 4px #ffa726aa);\n    marker-end: url(#arrowhead);\n    transition: stroke 0.4s ease;\n  }\n\n  /* Highlighted states during sort */\n  .edge.active {\n    stroke: #fff3e0;\n    stroke-width: 3.8;\n    filter: drop-shadow(0 0 10px #fff3e055);\n  }\n  .node.active circle {\n    fill: #fff3e0;\n    stroke: #ff6f00;\n    filter: drop-shadow(0 0 14px #fff3e099);\n  }\n  .node.sorted circle {\n    fill: #90caf9;\n    stroke: #42a5f5;\n    filter: drop-shadow(0 0 18px #42a5f599);\n    transition: fill 1s ease, stroke 1s ease, filter 1s ease;\n  }\n  .node.sorted text {\n    fill: #0d47a1;\n    font-weight: 800;\n    transition: fill 1s ease;\n  }\n\n  footer {\n    margin-top: 4rem;\n    font-size: 0.85rem;\n    color: #ffb74dc0;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n    text-align: center;\n  }\n\n  #btns {\n    position: absolute;\n    top: 12px;\n    right: 14px;\n    display: flex;\n    gap: 12px;\n  }\n\n  button {\n    background: linear-gradient(135deg, #ff6f00dd, #ffa726bb);\n    border: none;\n    border-radius: 8px;\n    padding: 0.45rem 1.25rem;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 0.95rem;\n    color: #fff;\n    letter-spacing: 0.06em;\n    cursor: pointer;\n    user-select: none;\n    box-shadow:\n      0 3px 8px #ff6f0028,\n      0 0 6px #ff6f0088 inset;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  button:hover,\n  button:focus-visible {\n    background: linear-gradient(135deg, #ffa726ff, #ffb74dcc);\n    box-shadow:\n      0 4px 14px #ffb74ddd,\n      0 0 12px #ffb74ddd inset;\n    outline: none;\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Tooltip */\n  #tooltip {\n    position: absolute;\n    background: #ff6f0099;\n    color: #fff3e0;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 0.85rem;\n    padding: 0.25rem 0.6rem;\n    border-radius: 6px;\n    pointer-events: none;\n    user-select: none;\n    filter: drop-shadow(0 0 5px #ff6f0099);\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    white-space: nowrap;\n    z-index: 5;\n  }\n</style>\n</head>\n<body>\n<div id=\"container\">\n  <h1>Topological Sort</h1>\n  <p class=\"subtitle\">\n    A linear ordering of the vertices in a <em>directed acyclic graph</em> so that for every directed edge <code>u → v</code>, <br /> <strong>u appears before v</strong> in the ordering.\n  </p>\n\n  <div id=\"canvas-wrapper\" aria-label=\"Topological sort visualization\" role=\"img\">\n    <svg viewBox=\"0 0 760 480\" aria-hidden=\"true\" id=\"graph-svg\">\n\n      <defs>\n        <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"7\" \n          refX=\"23\" refY=\"3.3\" orient=\"auto\" markerUnits=\"strokeWidth\">\n          <path d=\"M0,0 L8,3.3 L0,7 Z\" fill=\"#ffa726cc\"/>\n        </marker>\n      </defs>\n\n      <!-- Edges -->\n      <path id=\"edge-0-1\" class=\"edge\" d=\"M146 196 Q190 146 236 146\" />\n      <path id=\"edge-0-2\" class=\"edge\" d=\"M146 196 Q190 246 236 266\" />\n      <path id=\"edge-1-3\" class=\"edge\" d=\"M236 146 L340 146\" />\n      <path id=\"edge-2-3\" class=\"edge\" d=\"M236 266 Q280 246 343 186\" />\n      <path id=\"edge-3-4\" class=\"edge\" d=\"M343 186 L457 186\" />\n      <path id=\"edge-2-5\" class=\"edge\" d=\"M236 266 Q320 315 370 320\" />\n      <path id=\"edge-5-4\" class=\"edge\" d=\"M370 320 L457 186\" />\n      <path id=\"edge-4-6\" class=\"edge\" d=\"M457 186 L560 186\" />\n      <path id=\"edge-5-6\" class=\"edge\" d=\"M370 320 Q460 382 560 266\" />\n\n      <!-- Nodes -->\n      <g class=\"node\" id=\"node-0\" transform=\"translate(146,196)\" aria-label=\"Node 0\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">0</text>\n      </g>\n      <g class=\"node\" id=\"node-1\" transform=\"translate(236,146)\" aria-label=\"Node 1\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">1</text>\n      </g>\n      <g class=\"node\" id=\"node-2\" transform=\"translate(236,266)\" aria-label=\"Node 2\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">2</text>\n      </g>\n      <g class=\"node\" id=\"node-3\" transform=\"translate(343,186)\" aria-label=\"Node 3\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">3</text>\n      </g>\n      <g class=\"node\" id=\"node-4\" transform=\"translate(457,186)\" aria-label=\"Node 4\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">4</text>\n      </g>\n      <g class=\"node\" id=\"node-5\" transform=\"translate(370,320)\" aria-label=\"Node 5\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">5</text>\n      </g>\n      <g class=\"node\" id=\"node-6\" transform=\"translate(560,186)\" aria-label=\"Node 6\">\n        <circle r=\"30\" />\n        <text dominant-baseline=\"middle\" text-anchor=\"middle\">6</text>\n      </g>\n\n    </svg>\n\n    <div id=\"btns\" aria-label=\"Controls\">\n      <button id=\"start-btn\" aria-pressed=\"false\" aria-label=\"Start topological sort animation\">Start Animation</button>\n      <button id=\"reset-btn\" disabled aria-label=\"Reset visualization to initial state\">Reset</button>\n    </div>\n  </div>\n\n  <footer>\n    Visualization &mdash; Topological Sort Algorithm &mdash; &copy; 2024\n  </footer>\n\n</div>\n\n<div id=\"tooltip\" role=\"tooltip\" aria-hidden=\"true\"></div>\n\n<script>\n(() => {\n  const graph = {\n    nodes: 7,\n    edges: [\n      [0,1], [0,2], [1,3], [2,3], [3,4], [2,5], [5,4], [4,6], [5,6]\n    ]\n  };\n\n  // References to DOM elements\n  const nodesEl = Array.from({length: graph.nodes}, (_, i) => document.getElementById(`node-${i}`));\n  const edgesEl = graph.edges.map(([from, to]) => document.getElementById(`edge-${from}-${to}`));\n  const startBtn = document.getElementById('start-btn');\n  const resetBtn = document.getElementById('reset-btn');\n  const tooltip = document.getElementById('tooltip');\n\n  // In-degree array\n  let inDegree = [];\n  let adjList = [];\n  let sortedOrder = [];\n  let animationIndex = 0;\n  let animationTimer = null;\n\n  // Initialize graph data structure\n  function initGraph() {\n    inDegree = Array(graph.nodes).fill(0);\n    adjList = Array.from({length: graph.nodes}, () => []);\n    for (const [u,v] of graph.edges) {\n      adjList[u].push(v);\n      inDegree[v]++;\n    }\n  }\n\n  // Clear all highlights and states\n  function clearAll() {\n    nodesEl.forEach(n => {\n      n.classList.remove('active','sorted');\n      n.style.transform = 'translate(0,0)';\n    });\n    edgesEl.forEach(e => {\n      e.classList.remove('active');\n      e.style.transition = '';\n      e.style.strokeDasharray = '';\n      e.style.strokeDashoffset = '';\n    });\n    sortedOrder = [];\n    animationIndex = 0;\n    tooltip.style.opacity = '0';\n    startBtn.disabled = false;\n    startBtn.setAttribute('aria-pressed', 'false');\n    resetBtn.disabled = true;\n  }\n\n  // Animate stroke dash offset for edges\n  function animateEdgeHighlight(edge) {\n    // Animate stroke drawing from start to end\n    const length = edge.getTotalLength();\n    edge.style.strokeDasharray = length;\n    edge.style.strokeDashoffset = length;\n    edge.style.transition = 'stroke-dashoffset 800ms ease-out, stroke 300ms';\n    edge.classList.add('active');\n    requestAnimationFrame(() => {\n      edge.style.strokeDashoffset = '0';\n    });\n  }\n\n  // Animate highlight on node with pulse effect\n  function animateNodeHighlight(node) {\n    node.classList.add('active');\n    node.animate([\n      { transform: 'scale(1)' },\n      { transform: 'scale(1.13)' },\n      { transform: 'scale(1)' }\n    ], {\n      duration: 700,\n      easing: 'cubic-bezier(0.4,0,0.2,1)',\n      fill: 'forwards'\n    });\n  }\n\n  // Perform Kahn's topological sort step-by-step with animation\n  function runTopologicalSortAnimation() {\n    const queue = [];\n    const inD = [...inDegree];\n    const adj = adjList;\n\n    // find all zero in-degree vertices at start\n    for(let i=0; i<inD.length; i++){\n      if(inD[i]===0) queue.push(i);\n    }\n    if(queue.length===0) return; // no valid topological sort (cycle)\n\n    startBtn.disabled = true;\n    startBtn.setAttribute('aria-pressed', 'true');\n    resetBtn.disabled = false;\n\n    animationIndex = 0;\n    sortedOrder = [];\n    tooltip.style.opacity = '0';\n\n    // Custom iterative step animation\n    function step() {\n      if(queue.length === 0){\n        // Completed - highlight sorted nodes in final style with delay\n        sortedOrder.forEach((nodeIdx, i) => {\n          setTimeout(() => {\n            nodesEl[nodeIdx].classList.remove('active');\n            nodesEl[nodeIdx].classList.add('sorted');\n          }, i * 240);\n        });\n        return;\n      }\n\n      const nodeIdx = queue.shift();\n      sortedOrder.push(nodeIdx);\n\n      // Animate node highlight for the current visited node\n      animateNodeHighlight(nodesEl[nodeIdx]);\n      showTooltipOnNode(nodesEl[nodeIdx], `Processing node ${nodeIdx}`);\n\n      // For all edges from current node, animate them and decrement in-degree\n      let delay = 0;\n      for(const neighbor of adj[nodeIdx]){\n        // Highlight the edge node->neighbor with stroke animation\n        const edgePath = document.getElementById(`edge-${nodeIdx}-${neighbor}`);\n        if(edgePath){\n          setTimeout(() => {\n            animateEdgeHighlight(edgePath);\n          }, delay);\n        }\n        delay += 280;\n      }\n\n      // After highlighting edges, reduce neighbors inDegree and add zero in-degree neighbors to queue\n      setTimeout(() => {\n        for(const neighbor of adj[nodeIdx]){\n          inD[neighbor]--;\n          if(inD[neighbor] === 0){\n            queue.push(neighbor);\n          }\n        }\n        animationIndex++;\n        step();\n      }, delay + 900);\n\n    }\n    step();\n  }\n\n  // Show tooltip next to a node with message - fade in/out\n  function showTooltipOnNode(nodeEl, message) {\n    const svgRect = document.getElementById('canvas-wrapper').getBoundingClientRect();\n    const nodeCircle = nodeEl.querySelector('circle');\n    const matrix = nodeEl.getCTM();\n    const cx = +nodeCircle.getAttribute('r');\n    const cy = +nodeCircle.getAttribute('r');\n\n    // Node center coords in screen space\n    const point = {\n      x: matrix.e,\n      y: matrix.f\n    };\n\n    tooltip.textContent = message;\n    tooltip.style.opacity = '1';\n    tooltip.style.left = `${svgRect.left + point.x + 36}px`;\n    tooltip.style.top = `${svgRect.top + point.y - 18}px`;\n    tooltip.setAttribute('aria-hidden', 'false');\n\n    // Fade tooltip out after 1.6s\n    clearTimeout(tooltip._fadeTimeout);\n    tooltip._fadeTimeout = setTimeout(() => {\n      tooltip.style.opacity = '0';\n      tooltip.setAttribute('aria-hidden', 'true');\n    }, 1600);\n  }\n\n  // On reset button click\n  resetBtn.addEventListener('click', () => {\n    if(animationTimer) clearTimeout(animationTimer);\n    clearAll();\n  });\n\n  // Start animation on button click\n  startBtn.addEventListener('click', () => {\n    clearAll();\n    runTopologicalSortAnimation();\n  });\n\n  // Initialize graph & UI\n  initGraph();\n  clearAll();\n\n  // Accessibility: keyboard focus styles for buttons\n  document.addEventListener('keydown', e => {\n    if(e.key === 'Tab'){\n      if(document.activeElement.tagName === 'BUTTON'){\n        document.activeElement.style.boxShadow = '0 0 8px 3px #ffb74dcc';\n      }\n    }\n  });\n  document.addEventListener('focusout', e => {\n    if(e.target.tagName === 'BUTTON'){\n      e.target.style.boxShadow = 'none';\n    }\n  });\n})();\n</script>\n</body>\n</html>"
