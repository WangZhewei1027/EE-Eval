    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Kruskal's Algorithm Interactive Demo</title>\n<style>\n/* Minimal styling only to ensure layout is usable. Keep everything basic. */\nbody { font-family: sans-serif; margin: 8px; color: black; background: white; }\n.controls { display: block; margin-bottom: 8px; }\n.section { margin: 6px 0; padding: 6px; border: 1px solid black; }\n.row { margin: 4px 0; }\ncanvas { display: block; border: 1px solid black; }\ntextarea { width: 100%; height: 80px; }\n.small { width: 60px; }\n.inline { display: inline-block; margin-right: 8px; }\n#edgeList { max-height: 220px; overflow: auto; border: 1px solid black; padding: 4px; }\n#history { max-height: 120px; overflow: auto; border: 1px solid black; padding: 4px; white-space: pre-wrap; }\n</style>\n</head>\n<body>\n<h1>Kruskal's Algorithm Interactive Demo</h1>\n\n<div class=\"controls\">\n\n  <div class=\"section\">\n    <div><strong>Canvas Interaction Modes</strong></div>\n    <div class=\"row\">\n      <button id=\"mode_add_node\">Add Node</button>\n      <button id=\"mode_move\">Move Nodes</button>\n      <button id=\"mode_add_edge\">Add Edge</button>\n      <button id=\"mode_delete\">Delete Element</button>\n      <button id=\"mode_select\">Select</button>\n      <span class=\"inline\">Current mode: <span id=\"modeLabel\">Add Node</span></span>\n    </div>\n    <div class=\"row\">\n      Click on canvas to add nodes in Add Node mode. In Add Edge mode click two nodes to create an edge.\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div><strong>Node / Graph Controls</strong></div>\n    <div class=\"row\">\n      <label>Node radius <input id=\"nodeRadius\" class=\"small\" type=\"number\" value=\"15\"></label>\n      <button id=\"btnAddNodeAtRandom\">Add Node (random)</button>\n      <button id=\"btnClearNodes\">Clear Nodes & Edges</button>\n      <button id=\"btnSamples\">Load Sample Graphs</button>\n    </div>\n    <div class=\"row\">\n      <label>Random generate:\n        Nodes <input id=\"randNodes\" class=\"small\" type=\"number\" value=\"6\" min=\"1\" max=\"50\">\n        Edge prob <input id=\"randProb\" class=\"small\" type=\"number\" value=\"0.4\" step=\"0.05\" min=\"0\" max=\"1\">\n        MinW <input id=\"randMinW\" class=\"small\" type=\"number\" value=\"1\">\n        MaxW <input id=\"randMaxW\" class=\"small\" type=\"number\" value=\"10\">\n      </label>\n      <button id=\"btnRandomGraph\">Generate</button>\n      <button id=\"btnCompleteGraph\">Complete</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div><strong>Edge Creation</strong></div>\n    <div class=\"row\">\n      <label>Default edge weight <input id=\"edgeWeightDefault\" class=\"small\" type=\"number\" value=\"1\"></label>\n      <label>Allow parallel edges <input id=\"allowParallel\" type=\"checkbox\"></label>\n      <label>Auto-snap weight on add <input id=\"autoSnapWeight\" type=\"checkbox\" checked></label>\n      <button id=\"btnClearEdges\">Clear Edges</button>\n    </div>\n    <div class=\"row\">\n      When in Add Edge mode, click two nodes. Use Select mode to choose nodes/edges for editing.\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div><strong>Kruskal Controls</strong></div>\n    <div class=\"row\">\n      <button id=\"btnResetAlgo\">Reset Algorithm</button>\n      <button id=\"btnComputeAll\">Compute MST (auto)</button>\n      <button id=\"btnStep\">Step</button>\n      <button id=\"btnBack\">Step Back</button>\n      <button id=\"btnAutoRun\">Auto Run</button>\n      <label>Speed ms <input id=\"autoSpeed\" class=\"small\" type=\"number\" value=\"700\"></label>\n    </div>\n    <div class=\"row\">\n      <label>Mode:\n        <select id=\"minOrMax\">\n          <option value=\"min\">Minimum spanning tree</option>\n          <option value=\"max\">Maximum spanning tree</option>\n        </select>\n      </label>\n      <label>Tie break:\n        <select id=\"tieBreak\">\n          <option value=\"stable\">Stable (insertion order)</option>\n          <option value=\"random\">Random</option>\n          <option value=\"byEndpoints\">By endpoints</option>\n        </select>\n      </label>\n      <label>Union by:\n        <select id=\"ufVariant\">\n          <option value=\"rank\">Rank</option>\n          <option value=\"size\">Size</option>\n        </select>\n      </label>\n      <label>Path compression <input id=\"ufCompress\" type=\"checkbox\" checked></label>\n    </div>\n    <div class=\"row\">\n      <button id=\"btnAcceptEdge\">Force Accept Current Edge</button>\n      <button id=\"btnRejectEdge\">Force Reject Current Edge</button>\n      <button id=\"btnFinish\">Finish (accept remaining valid edges)</button>\n    </div>\n    <div class=\"row\">\n      <button id=\"btnUndo\">Undo</button>\n      <button id=\"btnRedo\">Redo</button>\n      <button id=\"btnValidate\">Validate MST</button>\n      <div class=\"inline\">MST weight: <span id=\"mstWeight\">0</span></div>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div><strong>Advanced / Exploration</strong></div>\n    <div class=\"row\">\n      <button id=\"btnBrute\">Brute-force check (n <= 8)</button>\n      <button id=\"btnComparePrim\">Compare with Prim</button>\n      <button id=\"btnAllSpanningCount\">Count all spanning trees (Kirchhoff) for small n</button>\n    </div>\n    <div class=\"row\">\n      Brute force enumerates all spanning trees and reports if current MST is optimal. This may be slow for n>8.\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div><strong>Import / Export</strong></div>\n    <div class=\"row\">\n      <button id=\"btnExportJSON\">Export Graph JSON</button>\n      <button id=\"btnImportJSON\">Import Graph JSON</button>\n      <button id=\"btnExportEdgeList\">Export Edge List CSV</button>\n      <button id=\"btnImportEdgeList\">Import Edge List CSV</button>\n    </div>\n    <div class=\"row\">\n      <textarea id=\"importExportArea\" placeholder='Paste JSON or CSV here for import; export will appear here'></textarea>\n    </div>\n  </div>\n\n</div>\n\n<div style=\"display:flex; gap:8px;\">\n  <div style=\"flex:1; min-width:320px;\">\n    <canvas id=\"canvas\" width=\"800\" height=\"520\"></canvas>\n    <div class=\"section\">\n      <div class=\"row\"><strong>History</strong></div>\n      <div id=\"history\"></div>\n    </div>\n  </div>\n\n  <div style=\"width:360px;\">\n    <div class=\"section\">\n      <div><strong>Edge List</strong></div>\n      <div id=\"edgeList\"></div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Union-Find State</strong></div>\n      <div id=\"ufState\"></div>\n    </div>\n\n    <div class=\"section\">\n      <div><strong>Algorithm Log & Info</strong></div>\n      <div id=\"algoLog\"></div>\n    </div>\n  </div>\n</div>\n\n<script>\n// Kruskal Interactive Demo\n// Minimal visual style; rich interactivity.\n//\n// Data structures: nodes, edges, algorithm state, history snapshots.\n\n// Utility functions\nfunction uid(prefix) {\n  return prefix + '_' + Math.random().toString(36).slice(2,9);\n}\nfunction clamp(v,a,b){return Math.max(a,Math.min(b,v));}\nfunction deepCopy(obj){ return JSON.parse(JSON.stringify(obj)); }\n\n// Graph model\nlet nodes = []; // {id, x, y}\nlet edges = []; // {id, u, v, w, status, insertedAt}\nlet nextNodeId = 1;\nlet nextEdgeId = 1;\n\n// UI elements\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nconst modeLabel = document.getElementById('modeLabel');\nconst edgeListDiv = document.getElementById('edgeList');\nconst historyDiv = document.getElementById('history');\nconst ufStateDiv = document.getElementById('ufState');\nconst algoLogDiv = document.getElementById('algoLog');\nconst mstWeightSpan = document.getElementById('mstWeight');\n\n// Controls\nconst modeButtons = {\n  add_node: document.getElementById('mode_add_node'),\n  move: document.getElementById('mode_move'),\n  add_edge: document.getElementById('mode_add_edge'),\n  delete: document.getElementById('mode_delete'),\n  select: document.getElementById('mode_select')\n};\nconst nodeRadiusInput = document.getElementById('nodeRadius');\nconst btnAddNodeAtRandom = document.getElementById('btnAddNodeAtRandom');\nconst btnClearNodes = document.getElementById('btnClearNodes');\nconst btnSamples = document.getElementById('btnSamples');\n\nconst randNodesInput = document.getElementById('randNodes');\nconst randProbInput = document.getElementById('randProb');\nconst randMinW = document.getElementById('randMinW');\nconst randMaxW = document.getElementById('randMaxW');\nconst btnRandomGraph = document.getElementById('btnRandomGraph');\nconst btnCompleteGraph = document.getElementById('btnCompleteGraph');\n\nconst edgeWeightDefault = document.getElementById('edgeWeightDefault');\nconst allowParallel = document.getElementById('allowParallel');\nconst autoSnapWeight = document.getElementById('autoSnapWeight');\nconst btnClearEdges = document.getElementById('btnClearEdges');\n\nconst btnResetAlgo = document.getElementById('btnResetAlgo');\nconst btnComputeAll = document.getElementById('btnComputeAll');\nconst btnStep = document.getElementById('btnStep');\nconst btnBack = document.getElementById('btnBack');\nconst btnAutoRun = document.getElementById('btnAutoRun');\nconst autoSpeed = document.getElementById('autoSpeed');\n\nconst minOrMax = document.getElementById('minOrMax');\nconst tieBreak = document.getElementById('tieBreak');\nconst ufVariant = document.getElementById('ufVariant');\nconst ufCompress = document.getElementById('ufCompress');\n\nconst btnAcceptEdge = document.getElementById('btnAcceptEdge');\nconst btnRejectEdge = document.getElementById('btnRejectEdge');\nconst btnFinish = document.getElementById('btnFinish');\n\nconst btnUndo = document.getElementById('btnUndo');\nconst btnRedo = document.getElementById('btnRedo');\nconst btnValidate = document.getElementById('btnValidate');\n\nconst btnBrute = document.getElementById('btnBrute');\nconst btnComparePrim = document.getElementById('btnComparePrim');\nconst btnAllSpanningCount = document.getElementById('btnAllSpanningCount');\n\nconst btnExportJSON = document.getElementById('btnExportJSON');\nconst btnImportJSON = document.getElementById('btnImportJSON');\nconst btnExportEdgeList = document.getElementById('btnExportEdgeList');\nconst btnImportEdgeList = document.getElementById('btnImportEdgeList');\nconst importExportArea = document.getElementById('importExportArea');\n\nconst btnAddNode = document.getElementById('mode_add_node');\n\n// Modes\nlet mode = 'add_node';\nfunction setMode(m){\n  mode = m;\n  modeLabel.textContent = {\n    add_node: 'Add Node',\n    move: 'Move Nodes',\n    add_edge: 'Add Edge',\n    delete: 'Delete',\n    select: 'Select'\n  }[m] || m;\n}\nfor (let key in modeButtons) {\n  modeButtons[key].addEventListener('click', ()=> setMode(key));\n}\nsetMode('add_node');\n\n// Canvas state\nlet dragging = null; // node id\nlet dragOffset = {x:0,y:0};\nlet selectedNodeForEdge = null;\nlet selectedElement = null;\n\n// Algorithm state\nlet algoState = {\n  running: false,\n  autoRun: false,\n  timer: null,\n  sortedEdges: [], // array of edge ids in sorted order for current run\n  index: 0, // next to consider\n  uf: null,\n  snapshots: [], // history snapshots for undo/redo (push after each operation)\n  redoStack: []\n};\n\n// Union-Find implementation with options\nclass UnionFind {\n  constructor(n, variant='rank', compress=true){\n    this.n = n;\n    this.parent = new Array(n);\n    for (let i=0;i<n;i++) this.parent[i]=i;\n    this.rank = new Array(n).fill(0);\n    this.size = new Array(n).fill(1);\n    this.variant = variant;\n    this.compress = compress;\n  }\n  find(i){\n    if (this.parent[i] === i) return i;\n    if (this.compress) {\n      this.parent[i] = this.find(this.parent[i]);\n      return this.parent[i];\n    } else {\n      return this.findNoCompress(i);\n    }\n  }\n  findNoCompress(i){\n    if (this.parent[i] === i) return i;\n    return this.findNoCompress(this.parent[i]);\n  }\n  union(a,b){\n    a = this.find(a); b = this.find(b);\n    if (a===b) return false;\n    if (this.variant === 'size') {\n      if (this.size[a] < this.size[b]) { [a,b] = [b,a]; }\n      this.parent[b]=a;\n      this.size[a] += this.size[b];\n    } else { // rank\n      if (this.rank[a] < this.rank[b]) { [a,b] = [b,a]; }\n      this.parent[b] = a;\n      if (this.rank[a] === this.rank[b]) this.rank[a]++;\n    }\n    return true;\n  }\n  snapshot(){\n    return {\n      parent: this.parent.slice(),\n      rank: this.rank.slice(),\n      size: this.size.slice()\n    };\n  }\n  restore(snap){\n    this.parent = snap.parent.slice();\n    this.rank = snap.rank.slice();\n    this.size = snap.size.slice();\n  }\n  components(){\n    let comps = {};\n    for (let i=0;i<this.n;i++){\n      let r = this.find(i);\n      if (!comps[r]) comps[r] = [];\n      comps[r].push(i);\n    }\n    return comps;\n  }\n}\n\n// History and snapshot helpers\nfunction pushSnapshot(label){\n  const snap = {\n    nodes: deepCopy(nodes),\n    edges: deepCopy(edges),\n    algo: {\n      sortedEdges: algoState.sortedEdges.slice(),\n      index: algoState.index,\n      ufSnap: algoState.uf ? algoState.uf.snapshot() : null,\n      mstWeight: computeMSTWeightFromEdges()\n    },\n    label: label || new Date().toISOString()\n  };\n  algoState.snapshots.push(snap);\n  // keep redo stack cleared\n  algoState.redoStack = [];\n  renderHistory();\n}\nfunction undo(){\n  if (algoState.snapshots.length <= 1) return;\n  // move current snapshot to redo\n  const last = algoState.snapshots.pop();\n  algoState.redoStack.push(last);\n  const prev = algoState.snapshots[algoState.snapshots.length-1];\n  restoreSnapshot(prev);\n  renderAll();\n}\nfunction redo(){\n  if (algoState.redoStack.length === 0) return;\n  const snap = algoState.redoStack.pop();\n  algoState.snapshots.push(snap);\n  restoreSnapshot(snap);\n  renderAll();\n}\nfunction restoreSnapshot(snap){\n  nodes = deepCopy(snap.nodes);\n  edges = deepCopy(snap.edges);\n  // restore algo\n  algoState.sortedEdges = snap.algo.sortedEdges.slice();\n  algoState.index = snap.algo.index;\n  if (snap.algo.ufSnap) {\n    const n = nodes.length;\n    algoState.uf = new UnionFind(n, ufVariant.value, ufCompress.checked);\n    algoState.uf.restore(snap.algo.ufSnap);\n  } else {\n    algoState.uf = null;\n  }\n  updateMSTWeightDisplay();\n}\n\n// Graph functions\nfunction addNode(x,y, id=null){\n  const nid = id || nextNodeId++;\n  nodes.push({id: nid, x: x, y: y});\n  pushSnapshot('Add node ' + nid);\n  renderAll();\n}\nfunction removeNodeAt(x,y){\n  const r = parseInt(nodeRadiusInput.value) || 15;\n  for (let i=nodes.length-1;i>=0;i--){\n    const n = nodes[i];\n    const d2 = (n.x-x)*(n.x-x) + (n.y-y)*(n.y-y);\n    if (d2 <= r*r){\n      // remove edges attached\n      edges = edges.filter(e => e.u !== n.id && e.v !== n.id);\n      nodes.splice(i,1);\n      pushSnapshot('Delete node ' + n.id);\n      renderAll();\n      return true;\n    }\n  }\n  return false;\n}\nfunction addEdge(u, v, w, id=null){\n  if (u === v) return null;\n  if (!allowParallel.checked) {\n    for (let e of edges){\n      if ((e.u===u && e.v===v) || (e.u===v && e.v===u)) return null;\n    }\n  }\n  const eid = id || nextEdgeId++;\n  const insertedAt = Date.now();\n  edges.push({id: eid, u: u, v: v, w: Number(w), status: 'pending', insertedAt: insertedAt});\n  pushSnapshot('Add edge ' + eid);\n  renderAll();\n  return eid;\n}\nfunction removeEdgeById(eid){\n  const idx = edges.findIndex(e => e.id === eid);\n  if (idx>=0){\n    edges.splice(idx,1);\n    pushSnapshot('Remove edge ' + eid);\n    renderAll();\n  }\n}\nfunction findNodeAt(x,y){\n  const r = parseInt(nodeRadiusInput.value) || 15;\n  for (let i=nodes.length-1;i>=0;i--){\n    const n = nodes[i];\n    const d2 = (n.x-x)*(n.x-x) + (n.y-y)*(n.y-y);\n    if (d2 <= r*r) return n;\n  }\n  return null;\n}\nfunction findEdgeAt(x,y){\n  // find nearest edge by distance to segment\n  let best = null, bestD = 10;\n  for (let e of edges){\n    const a = nodes.find(n=>n.id===e.u);\n    const b = nodes.find(n=>n.id===e.v);\n    if (!a||!b) continue;\n    const d = pointToSegmentDistance(x,y,a.x,a.y,b.x,b.y);\n    if (d < bestD) {\n      bestD = d;\n      best = e;\n    }\n  }\n  return best;\n}\nfunction pointToSegmentDistance(px,py,x1,y1,x2,y2){\n  const A = px - x1;\n  const B = py - y1;\n  const C = x2 - x1;\n  const D = y2 - y1;\n  const dot = A*C + B*D;\n  const len2 = C*C + D*D;\n  let t = len2===0 ? 0 : dot / len2;\n  t = Math.max(0, Math.min(1, t));\n  const cx = x1 + t*C;\n  const cy = y1 + t*D;\n  const dx = px - cx;\n  const dy = py - cy;\n  return Math.sqrt(dx*dx + dy*dy);\n}\n\n// Rendering\nfunction renderAll(){\n  drawCanvas();\n  renderEdgeList();\n  renderUFState();\n  renderAlgoLog();\n  updateMSTWeightDisplay();\n}\nfunction drawCanvas(){\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  ctx.lineWidth = 1;\n  // Draw edges\n  for (let e of edges){\n    const a = nodes.find(n=>n.id===e.u);\n    const b = nodes.find(n=>n.id===e.v);\n    if (!a || !b) continue;\n    ctx.beginPath();\n    ctx.moveTo(a.x, a.y);\n    ctx.lineTo(b.x, b.y);\n    if (e.status === 'accepted') {\n      ctx.lineWidth = 3;\n    } else {\n      ctx.lineWidth = 1;\n    }\n    if (e.status === 'rejected'){\n      ctx.setLineDash([4,4]);\n    } else {\n      ctx.setLineDash([]);\n    }\n    ctx.strokeStyle = 'black';\n    ctx.stroke();\n    ctx.setLineDash([]);\n    // weight label\n    const mx = (a.x + b.x)/2;\n    const my = (a.y + b.y)/2;\n    ctx.fillStyle = 'black';\n    ctx.font = '12px sans-serif';\n    ctx.fillText(e.w, mx + 6, my - 6);\n  }\n  // Draw nodes\n  const r = parseInt(nodeRadiusInput.value) || 15;\n  for (let n of nodes){\n    ctx.beginPath();\n    ctx.lineWidth = 1;\n    ctx.setLineDash([]);\n    ctx.arc(n.x, n.y, r, 0, Math.PI*2);\n    ctx.strokeStyle = 'black';\n    ctx.stroke();\n    ctx.fillStyle = 'black';\n    ctx.font = '12px sans-serif';\n    ctx.fillText(String(n.id), n.x - 4, n.y + 4);\n  }\n  // If in add edge mode and one node selected, highlight it (draw inner circle)\n  if (mode === 'add_edge' && selectedNodeForEdge){\n    const n = nodes.find(x=>x.id===selectedNodeForEdge);\n    if (n){\n      ctx.beginPath();\n      ctx.arc(n.x, n.y, r-5, 0, Math.PI*2);\n      ctx.stroke();\n    }\n  }\n}\n\n// Edge list rendering with editing controls (plain HTML)\nfunction renderEdgeList(){\n  edgeListDiv.innerHTML = '';\n  if (edges.length === 0) {\n    edgeListDiv.textContent = '(no edges)';\n    return;\n  }\n  // sort for display by id\n  const list = edges.slice().sort((a,b)=> a.id - b.id);\n  for (let e of list){\n    const row = document.createElement('div');\n    row.style.borderBottom = '1px dashed #ccc';\n    row.style.padding = '2px 0';\n    row.style.display = 'flex';\n    row.style.alignItems = 'center';\n    row.style.gap = '6px';\n    const idSpan = document.createElement('span');\n    idSpan.textContent = '#' + e.id;\n    idSpan.style.minWidth='36px';\n    row.appendChild(idSpan);\n    const uv = document.createElement('span');\n    uv.textContent = `${e.u} - ${e.v}`;\n    uv.style.minWidth='48px';\n    row.appendChild(uv);\n    const wInput = document.createElement('input');\n    wInput.type = 'number';\n    wInput.className = 'small';\n    wInput.value = e.w;\n    wInput.addEventListener('change', ()=>{\n      e.w = Number(wInput.value);\n      pushSnapshot('Edit weight ' + e.id);\n      resetAlgorithmState();\n      renderAll();\n    });\n    row.appendChild(wInput);\n    const status = document.createElement('span');\n    status.textContent = e.status;\n    status.style.minWidth = '80px';\n    row.appendChild(status);\n    const btnSel = document.createElement('button');\n    btnSel.textContent = 'Select';\n    btnSel.addEventListener('click', ()=>{\n      selectedElement = {type:'edge', id:e.id};\n      renderAll();\n    });\n    row.appendChild(btnSel);\n    const btnDel = document.createElement('button');\n    btnDel.textContent = 'Delete';\n    btnDel.addEventListener('click', ()=>{\n      removeEdgeById(e.id);\n    });\n    row.appendChild(btnDel);\n    edgeListDiv.appendChild(row);\n  }\n}\n\n// Algorithm operations\nfunction prepareAlgorithm(){\n  // Reset statuses to pending\n  for (let e of edges) e.status = 'pending';\n  // Prepare sortedEdges based on weight and tie-break\n  const tie = tieBreak.value;\n  const arr = edges.map((e, idx)=> ({e:e, idx: idx}));\n  const ascending = (minOrMax.value === 'min');\n  arr.sort((A,B)=>{\n    if (A.e.w !== B.e.w) return ascending ? A.e.w - B.e.w : B.e.w - A.e.w;\n    // tie-breaks\n    if (tie === 'stable') return A.e.insertedAt - B.e.insertedAt;\n    if (tie === 'random') return Math.random() - 0.5;\n    if (tie === 'byEndpoints') {\n      const a1 = Math.min(A.e.u, A.e.v), a2 = Math.max(A.e.u,A.e.v);\n      const b1 = Math.min(B.e.u, B.e.v), b2 = Math.max(B.e.u,B.e.v);\n      if (a1 !== b1) return a1 - b1;\n      return a2 - b2;\n    }\n    return 0;\n  });\n  algoState.sortedEdges = arr.map(x=>x.e.id);\n  // Setup UF\n  algoState.uf = new UnionFind(nodes.length, ufVariant.value, ufCompress.checked);\n  // map node id to index\n  const idMap = {};\n  for (let i=0;i<nodes.length;i++) idMap[nodes[i].id] = i;\n  algoState.nodeIndexMap = idMap;\n  algoState.index = 0;\n  // update edges status\n  for (let e of edges) e.status = 'pending';\n  pushSnapshot('Prepare algorithm');\n  renderAll();\n}\n\n// compute next step\nfunction stepOnce(auto=false){\n  if (!algoState.sortedEdges || algoState.index >= algoState.sortedEdges.length) {\n    algoState.running = false;\n    log('Algorithm finished.');\n    return false;\n  }\n  const eid = algoState.sortedEdges[algoState.index];\n  const e = edges.find(x=>x.id===eid);\n  if (!e){ algoState.index++; return true; }\n  // record current snapshot before change\n  pushSnapshot('Consider edge ' + e.id);\n  const uidx = algoState.nodeIndexMap[e.u];\n  const vidx = algoState.nodeIndexMap[e.v];\n  if (uidx == null || vidx == null) {\n    e.status = 'rejected';\n    algoState.index++;\n    renderAll();\n    return true;\n  }\n  // check cycle\n  const fu = algoState.uf.find(uidx);\n  const fv = algoState.uf.find(vidx);\n  if (fu === fv) {\n    e.status = 'rejected';\n    algoState.index++;\n    log(`Edge ${e.id} rejected (would form cycle).`);\n  } else {\n    // accept\n    e.status = 'accepted';\n    algoState.uf.union(fu, fv);\n    algoState.index++;\n    log(`Edge ${e.id} accepted.`);\n  }\n  renderAll();\n  return true;\n}\n\n// Step back: restore previous snapshot if exists\nfunction stepBack(){\n  // Undo one snapshot (except the initial snapshot)\n  undo();\n}\n\n// Compute MST fully (auto)\nfunction computeAll(){\n  resetAlgorithmState();\n  prepareAlgorithm();\n  // run steps until end\n  while (algoState.index < algoState.sortedEdges.length){\n    const cont = stepOnce();\n    if (!cont) break;\n  }\n  updateMSTWeightDisplay();\n}\n\n// Reset algorithm state (but keep graph)\nfunction resetAlgorithmState(){\n  algoState.sortedEdges = [];\n  algoState.index = 0;\n  algoState.uf = null;\n  // reset edge statuses\n  for (let e of edges) e.status = 'pending';\n  pushSnapshot('Reset algorithm');\n  renderAll();\n}\n\n// Auto-run controls\nfunction startAutoRun(){\n  if (algoState.autoRun) return;\n  algoState.autoRun = true;\n  btnAutoRun.textContent = 'Stop Auto Run';\n  const ms = Math.max(10, Number(autoSpeed.value) || 700);\n  algoState.timer = setInterval(()=>{\n    if (!algoState.sortedEdges || algoState.index >= algoState.sortedEdges.length) {\n      stopAutoRun();\n      return;\n    }\n    stepOnce(true);\n  }, ms);\n}\nfunction stopAutoRun(){\n  algoState.autoRun = false;\n  btnAutoRun.textContent = 'Auto Run';\n  if (algoState.timer) clearInterval(algoState.timer);\n  algoState.timer = null;\n}\n\n// Force accept/reject current edge\nfunction forceAcceptCurrent(){\n  if (!algoState.sortedEdges || algoState.index >= algoState.sortedEdges.length) return;\n  const eid = algoState.sortedEdges[algoState.index];\n  const e = edges.find(x=>x.id===eid);\n  if (!e) return;\n  pushSnapshot('Force accept ' + eid);\n  const uidx = algoState.nodeIndexMap[e.u];\n  const vidx = algoState.nodeIndexMap[e.v];\n  if (uidx == null || vidx == null) { e.status = 'rejected'; algoState.index++; renderAll(); return; }\n  const fu = algoState.uf.find(uidx);\n  const fv = algoState.uf.find(vidx);\n  if (fu !== fv) {\n    e.status = 'accepted';\n    algoState.uf.union(fu, fv);\n  } else {\n    // still accept if forced\n    e.status = 'accepted';\n  }\n  algoState.index++;\n  renderAll();\n}\nfunction forceRejectCurrent(){\n  if (!algoState.sortedEdges || algoState.index >= algoState.sortedEdges.length) return;\n  const eid = algoState.sortedEdges[algoState.index];\n  const e = edges.find(x=>x.id===eid);\n  if (!e) return;\n  pushSnapshot('Force reject ' + eid);\n  e.status = 'rejected';\n  algoState.index++;\n  renderAll();\n}\n\n// Finish: accept remaining valid edges greedily\nfunction finishRemaining(){\n  if (!algoState.sortedEdges) prepareAlgorithm();\n  while (algoState.index < algoState.sortedEdges.length){\n    const eid = algoState.sortedEdges[algoState.index];\n    const e = edges.find(x=>x.id===eid);\n    if (!e) { algoState.index++; continue; }\n    const uidx = algoState.nodeIndexMap[e.u];\n    const vidx = algoState.nodeIndexMap[e.v];\n    if (uidx == null || vidx == null) { e.status='rejected'; algoState.index++; continue; }\n    const fu = algoState.uf.find(uidx);\n    const fv = algoState.uf.find(vidx);\n    if (fu !== fv){\n      e.status = 'accepted';\n      algoState.uf.union(fu,fv);\n    } else {\n      e.status = 'rejected';\n    }\n    algoState.index++;\n  }\n  pushSnapshot('Finish');\n  renderAll();\n}\n\n// Helpers\nfunction updateMSTWeightDisplay(){\n  const w = computeMSTWeightFromEdges();\n  mstWeightSpan.textContent = String(w);\n}\nfunction computeMSTWeightFromEdges(){\n  let s = 0;\n  for (let e of edges){\n    if (e.status === 'accepted') s += Number(e.w);\n  }\n  return s;\n}\n\n// Logging\nfunction log(msg){\n  const time = new Date().toLocaleTimeString();\n  algoLogDiv.textContent = `[${time}] ${msg}\\n` + algoLogDiv.textContent;\n  if (algoLogDiv.textContent.split('\\n').length > 400) {\n    algoLogDiv.textContent = algoLogDiv.textContent.split('\\n').slice(0,400).join('\\n');\n  }\n}\nfunction renderHistory(){\n  historyDiv.textContent = algoState.snapshots.map((s,i)=> `${i}: ${s.label}`).reverse().join('\\n');\n}\nfunction renderUFState(){\n  if (!algoState.uf || !algoState.nodeIndexMap){\n    ufStateDiv.textContent = '(not initialized)';\n    return;\n  }\n  const uf = algoState.uf;\n  const nodesOrdered = nodes.map(n => n.id);\n  let txt = 'Parent array (index -> parentIndex):\\n';\n  for (let i=0;i<nodes.length;i++){\n    txt += `${i}(${nodes[i].id}) -> ${uf.parent[i]} (${nodes[uf.parent[i]] ? nodes[uf.parent[i]].id : 'x'})\\n`;\n  }\n  txt += '\\nRank:\\n' + uf.rank.join(', ') + '\\n';\n  txt += '\\nSize:\\n' + uf.size.join(', ') + '\\n';\n  txt += '\\nComponents:\\n';\n  const comps = uf.components();\n  for (let r in comps){\n    txt += `[${r}] -> ` + comps[r].map(i=> nodes[i].id).join(', ') + '\\n';\n  }\n  ufStateDiv.textContent = txt;\n}\nfunction renderAlgoLog(){\n  // no-op for now; log displayed in algoLogDiv already\n}\n\n// Validation: check if accepted edges form a spanning tree and minimal\nfunction validateMST(){\n  // check connectivity\n  const accepted = edges.filter(e=>e.status==='accepted');\n  if (accepted.length === 0 && nodes.length>0){\n    alert('No accepted edges.');\n    return;\n  }\n  // Build UF on node indices\n  const idMap = {};\n  for (let i=0;i<nodes.length;i++) idMap[nodes[i].id]=i;\n  const uf = new UnionFind(nodes.length,'rank',true);\n  for (let e of accepted){\n    const u = idMap[e.u], v = idMap[e.v];\n    if (u==null || v==null) continue;\n    uf.union(u,v);\n  }\n  const comps = uf.components();\n  const compCount = Object.keys(comps).length;\n  if (compCount !== 1 && nodes.length>0){\n    alert('Accepted edges do not form a spanning tree (graph is disconnected). Components: ' + compCount);\n    return;\n  }\n  // check edge count = n-1\n  if (accepted.length !== nodes.length - 1){\n    alert(`Accepted edges count is ${accepted.length}, expected ${nodes.length-1}. Not a tree.`);\n    return;\n  }\n  // Check minimality by computing Kruskal's algorithm independently\n  // We'll compute standard Kruskal (min or max depending)\n  const idToIndex = idMap;\n  const sorted = edges.slice().sort((a,b)=>{\n    const asc = minOrMax.value==='min';\n    if (a.w !== b.w) return asc ? a.w - b.w : b.w - a.w;\n    return a.insertedAt - b.insertedAt;\n  });\n  const uf2 = new UnionFind(nodes.length, ufVariant.value, ufCompress.checked);\n  let weight2 = 0;\n  const chosen = [];\n  for (let e of sorted){\n    const u = idToIndex[e.u], v = idToIndex[e.v];\n    if (u==null || v==null) continue;\n    if (uf2.find(u) !== uf2.find(v)){\n      uf2.union(u,v);\n      chosen.push(e);\n      weight2 += Number(e.w);\n    }\n  }\n  const ourW = computeMSTWeightFromEdges();\n  if (ourW === weight2){\n    alert('Valid spanning tree and matches Kruskal optimal weight: ' + ourW);\n  } else {\n    alert('Spanning tree but weight ' + ourW + ' differs from algorithmic optimal ' + weight2);\n  }\n}\n\n// Brute force enumeration of spanning trees (small n)\nfunction bruteForceCheck(){\n  if (nodes.length > 8) {\n    alert('Brute force only allowed for n <= 8.');\n    return;\n  }\n  // Build edge list indexes\n  const idMap = {};\n  for (let i=0;i<nodes.length;i++) idMap[nodes[i].id]=i;\n  const E = edges.length;\n  const bestWeight = Infinity;\n  let bests = [];\n  let countTrees = 0;\n  let bestWeightVal = Infinity;\n  for (let mask=0; mask < (1<<E); mask++){\n    // select edges with bits equal to count = n-1\n    if (popcount(mask) !== nodes.length - 1) continue;\n    // Build UF and check connectivity/no cycles\n    const uf = new UnionFind(nodes.length, 'rank', true);\n    let ok = true;\n    let weight = 0;\n    for (let j=0;j<E;j++){\n      if (mask & (1<<j)){\n        const e = edges[j];\n        const u = idMap[e.u], v = idMap[e.v];\n        if (u==null||v==null){ ok=false; break; }\n        if (uf.find(u) === uf.find(v)){ ok=false; break; }\n        uf.union(u,v);\n        weight += Number(e.w);\n      }\n    }\n    if (!ok) continue;\n    // check connectivity\n    const comps = uf.components();\n    if (Object.keys(comps).length !== 1) continue;\n    countTrees++;\n    if (weight < bestWeightVal){\n      bestWeightVal = weight;\n      bests = [mask];\n    } else if (weight === bestWeightVal){\n      bests.push(mask);\n    }\n  }\n  const currentWeight = computeMSTWeightFromEdges();\n  let msg = `Brute force: total spanning trees found: ${countTrees}\\nBest weight: ${bestWeightVal}\\nNumber of optimal trees: ${bests.length}\\nCurrent MST weight: ${currentWeight}\\n`;\n  if (currentWeight === bestWeightVal) msg += 'Current accepted edges have optimal weight.\\n';\n  else msg += 'Current accepted edges are NOT optimal.\\n';\n  alert(msg);\n}\nfunction popcount(n){ let c=0; while(n){ c+=n&1; n>>=1;} return c; }\n\n// Prim's algorithm for comparison (simple)\nfunction primCompare(){\n  if (nodes.length === 0) return;\n  const idMap = {};\n  for (let i=0;i<nodes.length;i++) idMap[nodes[i].id]=i;\n  const n = nodes.length;\n  const adj = Array.from({length:n}, ()=>[]);\n  for (let e of edges){\n    const u = idMap[e.u], v = idMap[e.v];\n    if (u==null||v==null) continue;\n    adj[u].push({v:v,w:Number(e.w)});\n    adj[v].push({v:u,w:Number(e.w)});\n  }\n  const visited = new Array(n).fill(false);\n  const dist = new Array(n).fill(Infinity);\n  const parent = new Array(n).fill(-1);\n  dist[0]=0;\n  for (let i=0;i<n;i++){\n    let u = -1;\n    for (let j=0;j<n;j++){\n      if (!visited[j] && (u===-1 || dist[j] < dist[u])) u = j;\n    }\n    if (u === -1) break;\n    visited[u]=true;\n    for (let e of adj[u]){\n      if (!visited[e.v] && e.w < dist[e.v]){\n        dist[e.v] = e.w;\n        parent[e.v] = u;\n      }\n    }\n  }\n  let total = 0;\n  const chosen = [];\n  for (let i=1;i<n;i++){\n    if (parent[i] === -1) {\n      alert('Graph not connected; Prim cannot produce MST.');\n      return;\n    }\n    chosen.push([nodes[parent[i]].id, nodes[i].id]);\n    // find weight\n    const ed = edges.find(e => (e.u===nodes[parent[i]].id && e.v===nodes[i].id) || (e.v===nodes[parent[i]].id && e.u===nodes[i].id));\n    total += ed ? Number(ed.w) : 0;\n  }\n  alert(`Prim produced total weight ${total}. Edges: ${JSON.stringify(chosen)}`);\n}\n\n// Count spanning trees by Kirchhoff (matrix-tree theorem) - small n\nfunction countSpanningTreesKirchhoff(){\n  if (nodes.length > 9){\n    alert('Counting spanning trees by Kirchhoff is limited to small n (<=9).');\n    return;\n  }\n  // Build Laplacian\n  const idMap = {};\n  for (let i=0;i<nodes.length;i++) idMap[nodes[i].id]=i;\n  const n = nodes.length;\n  const L = Array.from({length:n}, ()=> new Array(n).fill(0));\n  for (let e of edges){\n    const u = idMap[e.u], v = idMap[e.v];\n    if (u==null||v==null) continue;\n    L[u][u] += 1;\n    L[v][v] += 1;\n    L[u][v] -= 1;\n    L[v][u] -= 1;\n  }\n  // delete last row/col and compute determinant\n  const M = [];\n  for (let i=0;i<n-1;i++){\n    M.push(L[i].slice(0,n-1));\n  }\n  const det = determinant(M);\n  alert('Number of spanning trees (Kirchhoff): ' + Math.round(det));\n}\nfunction determinant(a){\n  // simple numeric gaussian elimination\n  const n = a.length;\n  const mat = a.map(row=>row.map(v=>Number(v)));\n  let det = 1;\n  for (let i=0;i<n;i++){\n    let pivot = i;\n    for (let j=i;j<n;j++) if (Math.abs(mat[j][i]) > Math.abs(mat[pivot][i])) pivot = j;\n    if (Math.abs(mat[pivot][i]) < 1e-12) return 0;\n    if (pivot !== i) { [mat[i], mat[pivot]] = [mat[pivot], mat[i]]; det *= -1; }\n    det *= mat[i][i];\n    const div = mat[i][i];\n    for (let j=i+1;j<n;j++){\n      const f = mat[j][i] / div;\n      for (let k=i;k<n;k++) mat[j][k] -= f * mat[i][k];\n    }\n  }\n  return det;\n}\n\n// Import / Export\nfunction exportJSON(){\n  const obj = {nodes: nodes, edges: edges};\n  importExportArea.value = JSON.stringify(obj, null, 2);\n}\nfunction importJSON(text){\n  try {\n    const obj = JSON.parse(text);\n    if (!obj.nodes || !obj.edges) { alert('Invalid JSON: must have nodes and edges'); return; }\n    nodes = obj.nodes.map(n=>({id:n.id,x:n.x,y:n.y}));\n    edges = obj.edges.map(e=>({id:e.id,u:e.u,v:e.v,w:Number(e.w),status:e.status||'pending', insertedAt:e.insertedAt||Date.now()}));\n    // reset counters\n    nextNodeId = nodes.reduce((a,b)=>Math.max(a,b.id),0) + 1;\n    nextEdgeId = edges.reduce((a,b)=>Math.max(a,b.id),0) + 1;\n    // push snapshot\n    pushSnapshot('Import JSON');\n    renderAll();\n  } catch (e){ alert('Invalid JSON: ' + e.message); }\n}\nfunction exportEdgeListCSV(){\n  const lines = edges.map(e => `${e.id},${e.u},${e.v},${e.w}`);\n  importExportArea.value = lines.join('\\n');\n}\nfunction importEdgeListCSV(text){\n  const lines = text.split('\\n').map(l=>l.trim()).filter(l=>l);\n  const newEdges = [];\n  for (let l of lines){\n    const parts = l.split(',').map(s=>s.trim());\n    if (parts.length < 4) continue;\n    const id = Number(parts[0]);\n    const u = isNaN(Number(parts[1])) ? parts[1] : Number(parts[1]);\n    const v = isNaN(Number(parts[2])) ? parts[2] : Number(parts[2]);\n    const w = Number(parts[3]);\n    newEdges.push({id: id, u:u, v:v, w:w, status:'pending', insertedAt:Date.now()});\n  }\n  // Merge: ensure nodes exist for endpoints\n  for (let e of newEdges){\n    if (!nodes.find(n=>n.id===e.u)) {\n      nodes.push({id: e.u, x: Math.random()*(canvas.width-40)+20, y: Math.random()*(canvas.height-40)+20});\n    }\n    if (!nodes.find(n=>n.id===e.v)) {\n      nodes.push({id: e.v, x: Math.random()*(canvas.width-40)+20, y: Math.random()*(canvas.height-40)+20});\n    }\n    edges.push(e);\n  }\n  nextNodeId = nodes.reduce((a,b)=>Math.max(a,b.id),0) + 1;\n  nextEdgeId = edges.reduce((a,b)=>Math.max(a,b.id),0) + 1;\n  pushSnapshot('Import CSV');\n  renderAll();\n}\n\n// Utility UI helpers\nfunction logUI(msg){\n  historyDiv.textContent = msg + '\\n' + historyDiv.textContent;\n}\n\n// Sample graphs\nfunction loadSamples(){\n  nodes = [];\n  edges = [];\n  nextNodeId = 1; nextEdgeId = 1;\n  // sample 1\n  addNode(120,80, 1); addNode(240,60,2); addNode(360,100,3); addNode(200,200,4); addNode(320,220,5);\n  addEdge(1,2,4); addEdge(1,4,2); addEdge(2,3,6); addEdge(2,4,4); addEdge(4,5,1); addEdge(3,5,3);\n  // snapshots already pushed by addEdge/addNode, but after adding many we want single snapshot\n  pushSnapshot('Loaded sample graph');\n  renderAll();\n}\n\n// Canvas events\ncanvas.addEventListener('mousedown', (ev)=>{\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left;\n  const y = ev.clientY - rect.top;\n  if (mode === 'add_node'){\n    addNode(x,y);\n    return;\n  }\n  if (mode === 'move'){\n    const n = findNodeAt(x,y);\n    if (n){\n      dragging = n.id;\n      dragOffset.x = x - n.x;\n      dragOffset.y = y - n.y;\n    }\n    return;\n  }\n  if (mode === 'add_edge'){\n    const n = findNodeAt(x,y);\n    if (n){\n      if (!selectedNodeForEdge){\n        selectedNodeForEdge = n.id;\n      } else {\n        if (selectedNodeForEdge === n.id){\n          selectedNodeForEdge = null;\n        } else {\n          // create edge between selectedNodeForEdge and n.id\n          const w = Number(edgeWeightDefault.value) || 1;\n          addEdge(selectedNodeForEdge, n.id, w);\n          if (autoSnapWeight.checked) edgeWeightDefault.value = Math.round((Number(edgeWeightDefault.value)+w)/2);\n          selectedNodeForEdge = null;\n        }\n      }\n      renderAll();\n    }\n    return;\n  }\n  if (mode === 'delete'){\n    if (removeNodeAt(x,y)) return;\n    const e = findEdgeAt(x,y);\n    if (e){ removeEdgeById(e.id); }\n    return;\n  }\n  if (mode === 'select'){\n    const n = findNodeAt(x,y);\n    if (n){\n      selectedElement = {type:'node', id:n.id};\n      renderAll();\n      return;\n    }\n    const e = findEdgeAt(x,y);\n    if (e){\n      selectedElement = {type:'edge', id:e.id};\n      renderAll();\n      return;\n    }\n    selectedElement = null;\n    renderAll();\n  }\n});\ncanvas.addEventListener('mousemove', (ev)=>{\n  if (!dragging) return;\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left;\n  const y = ev.clientY - rect.top;\n  const n = nodes.find(n=>n.id===dragging);\n  if (n){\n    n.x = clamp(x - dragOffset.x, 10, canvas.width-10);\n    n.y = clamp(y - dragOffset.y, 10, canvas.height-10);\n    renderAll();\n  }\n});\ncanvas.addEventListener('mouseup', (ev)=>{\n  if (dragging){\n    pushSnapshot('Move node ' + dragging);\n    dragging = null;\n  }\n});\n\n// Buttons handlers\nbtnAddNodeAtRandom.addEventListener('click', ()=>{\n  const x = Math.random()*(canvas.width-40)+20;\n  const y = Math.random()*(canvas.height-40)+20;\n  addNode(x,y);\n});\nbtnClearNodes.addEventListener('click', ()=>{\n  if (!confirm('Clear all nodes and edges?')) return;\n  nodes = [];\n  edges = [];\n  nextNodeId = 1; nextEdgeId = 1;\n  pushSnapshot('Clear graph');\n  renderAll();\n});\nbtnSamples.addEventListener('click', ()=> loadSamples());\n\nbtnRandomGraph.addEventListener('click', ()=>{\n  const n = Number(randNodesInput.value) || 5;\n  const p = Number(randProbInput.value) || 0.3;\n  const minW = Number(randMinW.value) || 1;\n  const maxW = Number(randMaxW.value) || 10;\n  nodes = [];\n  edges = [];\n  nextNodeId = 1; nextEdgeId = 1;\n  for (let i=0;i<n;i++){\n    addNode(Math.random()*(canvas.width-60)+30, Math.random()*(canvas.height-60)+30);\n  }\n  // nodes added triggered snapshots; remove excess snapshots to keep single snapshot later\n  for (let i=0;i<n;i++){\n    if (Math.random() < p){\n      for (let j=i+1;j<n;j++){\n        if (Math.random() < p) {\n          const w = Math.floor(Math.random()*(maxW-minW+1)) + minW;\n          addEdge(nodes[i].id, nodes[j].id, w);\n        }\n      }\n    }\n  }\n  pushSnapshot('Random graph');\n  renderAll();\n});\nbtnCompleteGraph.addEventListener('click', ()=>{\n  const n = Number(randNodesInput.value) || 5;\n  nodes = []; edges = []; nextNodeId = 1; nextEdgeId = 1;\n  for (let i=0;i<n;i++) addNode(Math.random()*(canvas.width-60)+30, Math.random()*(canvas.height-60)+30);\n  const minW = Number(randMinW.value) || 1;\n  const maxW = Number(randMaxW.value) || 10;\n  for (let i=0;i<n;i++){\n    for (let j=i+1;j<n;j++){\n      const w = Math.floor(Math.random()*(maxW-minW+1)) + minW;\n      addEdge(nodes[i].id, nodes[j].id, w);\n    }\n  }\n  pushSnapshot('Complete graph');\n  renderAll();\n});\n\nbtnClearEdges.addEventListener('click', ()=>{\n  if (!confirm('Clear all edges?')) return;\n  edges = [];\n  nextEdgeId = 1;\n  pushSnapshot('Clear edges');\n  renderAll();\n});\n\nbtnResetAlgo.addEventListener('click', ()=> {\n  resetAlgorithmState();\n});\nbtnComputeAll.addEventListener('click', ()=> {\n  resetAlgorithmState();\n  prepareAlgorithm();\n  computeAll();\n});\nbtnStep.addEventListener('click', ()=> {\n  if (!algoState.sortedEdges || algoState.sortedEdges.length === 0) prepareAlgorithm();\n  stepOnce();\n});\nbtnBack.addEventListener('click', ()=> {\n  stepBack();\n});\nbtnAutoRun.addEventListener('click', ()=> {\n  if (algoState.autoRun) stopAutoRun(); else {\n    if (!algoState.sortedEdges || algoState.sortedEdges.length === 0) prepareAlgorithm();\n    startAutoRun();\n  }\n});\nbtnAcceptEdge.addEventListener('click', ()=> forceAcceptCurrent());\nbtnRejectEdge.addEventListener('click', ()=> forceRejectCurrent());\nbtnFinish.addEventListener('click', ()=> finishRemaining());\nbtnUndo.addEventListener('click', ()=> undo());\nbtnRedo.addEventListener('click', ()=> redo());\nbtnValidate.addEventListener('click', ()=> validateMST());\n\nbtnBrute.addEventListener('click', ()=> bruteForceCheck());\nbtnComparePrim.addEventListener('click', ()=> primCompare());\nbtnAllSpanningCount.addEventListener('click', ()=> countSpanningTreesKirchhoff());\n\nbtnExportJSON.addEventListener('click', ()=> exportJSON());\nbtnImportJSON.addEventListener('click', ()=> {\n  const txt = importExportArea.value.trim();\n  if (!txt) { alert('Paste JSON into the text area first'); return; }\n  importJSON(txt);\n});\nbtnExportEdgeList.addEventListener('click', ()=> exportEdgeListCSV());\nbtnImportEdgeList.addEventListener('click', ()=> {\n  const txt = importExportArea.value.trim();\n  if (!txt) { alert('Paste CSV into the text area first'); return; }\n  importEdgeListCSV(txt);\n});\n\n// Undo/Redo support via buttons\nwindow.addEventListener('keydown',(ev)=>{\n  if (ev.ctrlKey && ev.key === 'z') { undo(); }\n  if (ev.ctrlKey && ev.key === 'y') { redo(); }\n});\n\n// initialize with an initial snapshot\npushSnapshot('Initial empty state');\nrenderAll();\n\n// small utility: ensure snapshot when closing or resizing etc.\nwindow.addEventListener('beforeunload', ()=> { /* nothing heavy */ });\n\n// Expose some debug functions to console\nwindow._demo = {\n  nodes, edges, addNode, addEdge, prepareAlgorithm, stepOnce, computeAll\n};\n</script>\n</body>\n</html>"
