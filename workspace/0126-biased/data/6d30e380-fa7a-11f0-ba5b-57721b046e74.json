  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive NoSQL Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #ccc; padding: 15px; }\n        .row { display: flex; gap: 20px; }\n        .col { flex: 1; }\n        button, select, input { margin: 5px 0; padding: 5px; }\n        textarea { width: 100%; height: 200px; font-family: monospace; }\n        table { border-collapse: collapse; width: 100%; }\n        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }\n        .hidden { display: none; }\n        #queryResults { max-height: 300px; overflow-y: auto; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>NoSQL Interactive Explorer</h1>\n        \n        <div class=\"row\">\n            <div class=\"col\">\n                <div class=\"panel\">\n                    <h2>Database Selection</h2>\n                    <select id=\"dbType\">\n                        <option value=\"document\">Document Store (MongoDB-like)</option>\n                        <option value=\"keyvalue\">Key-Value (Redis-like)</option>\n                        <option value=\"column\">Column Family (Cassandra-like)</option>\n                        <option value=\"graph\">Graph (Neo4j-like)</option>\n                    </select>\n                    <button id=\"initDb\">Initialize Database</button>\n                    <div id=\"dbStatus\">No database initialized</div>\n                </div>\n                \n                <div class=\"panel\" id=\"documentControls\">\n                    <h2>Document Operations</h2>\n                    <div>\n                        <h3>Create Document</h3>\n                        <textarea id=\"newDocument\">{\"name\": \"Example\", \"value\": 42, \"tags\": [\"demo\", \"test\"]}</textarea>\n                        <button id=\"createDocument\">Insert Document</button>\n                    </div>\n                    <div>\n                        <h3>Query Documents</h3>\n                        <input type=\"text\" id=\"queryField\" placeholder=\"Field name\">\n                        <input type=\"text\" id=\"queryValue\" placeholder=\"Value\">\n                        <button id=\"queryDocuments\">Find Documents</button>\n                        <button id=\"getAllDocuments\">Get All Documents</button>\n                    </div>\n                </div>\n                \n                <div class=\"panel hidden\" id=\"graphControls\">\n                    <h2>Graph Operations</h2>\n                    <div>\n                        <h3>Create Node</h3>\n                        <input type=\"text\" id=\"nodeLabel\" placeholder=\"Label\">\n                        <textarea id=\"nodeProperties\">{\"name\": \"Node1\"}</textarea>\n                        <button id=\"createNode\">Add Node</button>\n                    </div>\n                    <div>\n                        <h3>Create Relationship</h3>\n                        <input type=\"text\" id=\"relType\" placeholder=\"Relationship type\">\n                        <input type=\"text\" id=\"fromNode\" placeholder=\"From node ID\">\n                        <input type=\"text\" id=\"toNode\" placeholder=\"To node ID\">\n                        <button id=\"createRelationship\">Add Relationship</button>\n                    </div>\n                    <div>\n                        <h3>Traverse Graph</h3>\n                        <input type=\"text\" id=\"startNode\" placeholder=\"Start node ID\">\n                        <input type=\"number\" id=\"depth\" placeholder=\"Depth\" value=\"1\" min=\"1\" max=\"5\">\n                        <button id=\"traverseGraph\">Traverse</button>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"col\">\n                <div class=\"panel\">\n                    <h2>Query Results</h2>\n                    <div id=\"queryResults\"></div>\n                </div>\n                \n                <div class=\"panel\">\n                    <h2>Database Statistics</h2>\n                    <div id=\"stats\">\n                        <div>Documents/Nodes: <span id=\"docCount\">0</span></div>\n                        <div>Relationships: <span id=\"relCount\">0</span></div>\n                        <div>Storage Size: <span id=\"storageSize\">0</span> KB</div>\n                    </div>\n                    <button id=\"refreshStats\">Refresh Statistics</button>\n                </div>\n                \n                <div class=\"panel\">\n                    <h2>Advanced Operations</h2>\n                    <div>\n                        <button id=\"createIndex\">Create Index</button>\n                        <input type=\"text\" id=\"indexField\" placeholder=\"Field to index\">\n                    </div>\n                    <div>\n                        <button id=\"runAggregation\">Run Aggregation</button>\n                        <select id=\"aggOperation\">\n                            <option value=\"count\">Count</option>\n                            <option value=\"sum\">Sum</option>\n                            <option value=\"avg\">Average</option>\n                            <option value=\"max\">Maximum</option>\n                            <option value=\"min\">Minimum</option>\n                        </select>\n                        <input type=\"text\" id=\"aggField\" placeholder=\"Field to aggregate\">\n                    </div>\n                    <div>\n                        <button id=\"runTransaction\">Run Transaction</button>\n                        <textarea id=\"transactionOps\">[{\"op\": \"insert\", \"data\": {\"test\": \"value\"}}]</textarea>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Database state\n        let db = {\n            type: null,\n            documents: [],\n            nodes: [],\n            relationships: [],\n            indexes: {}\n        };\n        \n        // UI Elements\n        const dbTypeSelect = document.getElementById('dbType');\n        const initDbBtn = document.getElementById('initDb');\n        const dbStatus = document.getElementById('dbStatus');\n        const docControls = document.getElementById('documentControls');\n        const graphControls = document.getElementById('graphControls');\n        const queryResults = document.getElementById('queryResults');\n        const docCount = document.getElementById('docCount');\n        const relCount = document.getElementById('relCount');\n        const storageSize = document.getElementById('storageSize');\n        \n        // Initialize database\n        initDbBtn.addEventListener('click', () => {\n            db.type = dbTypeSelect.value;\n            db.documents = [];\n            db.nodes = [];\n            db.relationships = [];\n            db.indexes = {};\n            \n            dbStatus.textContent = `${dbTypeSelect.options[dbTypeSelect.selectedIndex].text} initialized`;\n            \n            // Show appropriate controls\n            docControls.classList.toggle('hidden', db.type !== 'document');\n            graphControls.classList.toggle('hidden', db.type !== 'graph');\n            \n            updateStats();\n        });\n        \n        // Document operations\n        document.getElementById('createDocument').addEventListener('click', () => {\n            try {\n                const doc = JSON.parse(document.getElementById('newDocument').value);\n                doc._id = generateId();\n                db.documents.push(doc);\n                updateStats();\n                queryResults.textContent = `Document inserted with ID: ${doc._id}`;\n            } catch (e) {\n                queryResults.textContent = `Error: ${e.message}`;\n            }\n        });\n        \n        document.getElementById('queryDocuments').addEventListener('click', () => {\n            const field = document.getElementById('queryField').value;\n            const value = document.getElementById('queryValue').value;\n            \n            let results;\n            if (field && value) {\n                results = db.documents.filter(doc => {\n                    if (doc[field] === undefined) return false;\n                    if (Array.isArray(doc[field])) {\n                        return doc[field].includes(value);\n                    }\n                    return doc[field].toString() === value;\n                });\n            } else {\n                results = db.documents;\n            }\n            \n            displayResults(results);\n        });\n        \n        document.getElementById('getAllDocuments').addEventListener('click', () => {\n            displayResults(db.documents);\n        });\n        \n        // Graph operations\n        document.getElementById('createNode').addEventListener('click', () => {\n            try {\n                const label = document.getElementById('nodeLabel').value;\n                const properties = JSON.parse(document.getElementById('nodeProperties').value);\n                const node = {\n                    id: generateId(),\n                    label,\n                    properties\n                };\n                db.nodes.push(node);\n                updateStats();\n                queryResults.textContent = `Node created with ID: ${node.id}`;\n            } catch (e) {\n                queryResults.textContent = `Error: ${e.message}`;\n            }\n        });\n        \n        document.getElementById('createRelationship').addEventListener('click', () => {\n            const type = document.getElementById('relType').value;\n            const fromId = document.getElementById('fromNode').value;\n            const toId = document.getElementById('toNode').value;\n            \n            const fromNode = db.nodes.find(n => n.id === fromId);\n            const toNode = db.nodes.find(n => n.id === toId);\n            \n            if (!fromNode || !toNode) {\n                queryResults.textContent = 'Error: One or both nodes not found';\n                return;\n            }\n            \n            const rel = {\n                id: generateId(),\n                type,\n                from: fromId,\n                to: toId,\n                properties: {}\n            };\n            \n            db.relationships.push(rel);\n            updateStats();\n            queryResults.textContent = `Relationship created with ID: ${rel.id}`;\n        });\n        \n        document.getElementById('traverseGraph').addEventListener('click', () => {\n            const startId = document.getElementById('startNode').value;\n            const depth = parseInt(document.getElementById('depth').value);\n            \n            const startNode = db.nodes.find(n => n.id === startId);\n            if (!startNode) {\n                queryResults.textContent = 'Error: Start node not found';\n                return;\n            }\n            \n            const result = traverseGraph(startId, depth);\n            displayResults(result);\n        });\n        \n        // Advanced operations\n        document.getElementById('createIndex').addEventListener('click', () => {\n            const field = document.getElementById('indexField').value;\n            if (!field) {\n                queryResults.textContent = 'Error: Please specify a field to index';\n                return;\n            }\n            \n            if (!db.indexes[field]) {\n                db.indexes[field] = {};\n                db.documents.forEach((doc, idx) => {\n                    if (doc[field] !== undefined) {\n                        const value = doc[field].toString();\n                        if (!db.indexes[field][value]) {\n                            db.indexes[field][value] = [];\n                        }\n                        db.indexes[field][value].push(idx);\n                    }\n                });\n                queryResults.textContent = `Index created on field: ${field}`;\n            } else {\n                queryResults.textContent = `Index already exists on field: ${field}`;\n            }\n        });\n        \n        document.getElementById('runAggregation').addEventListener('click', () => {\n            const op = document.getElementById('aggOperation').value;\n            const field = document.getElementById('aggField').value;\n            \n            if (!field) {\n                queryResults.textContent = 'Error: Please specify a field to aggregate';\n                return;\n            }\n            \n            const values = db.documents\n                .map(doc => doc[field])\n                .filter(val => val !== undefined);\n            \n            if (values.length === 0) {\n                queryResults.textContent = `No documents have field: ${field}`;\n                return;\n            }\n            \n            let result;\n            switch (op) {\n                case 'count':\n                    result = values.length;\n                    break;\n                case 'sum':\n                    result = values.reduce((a, b) => a + b, 0);\n                    break;\n                case 'avg':\n                    result = values.reduce((a, b) => a + b, 0) / values.length;\n                    break;\n                case 'max':\n                    result = Math.max(...values);\n                    break;\n                case 'min':\n                    result = Math.min(...values);\n                    break;\n                default:\n                    result = 'Unknown operation';\n            }\n            \n            queryResults.textContent = `Aggregation result (${op} of ${field}): ${result}`;\n        });\n        \n        document.getElementById('runTransaction').addEventListener('click', () => {\n            try {\n                const ops = JSON.parse(document.getElementById('transactionOps').value);\n                const results = [];\n                \n                ops.forEach(op => {\n                    if (op.op === 'insert') {\n                        const doc = op.data;\n                        doc._id = generateId();\n                        db.documents.push(doc);\n                        results.push(`Inserted document with ID: ${doc._id}`);\n                    } else if (op.op === 'update') {\n                        const updated = db.documents.filter(d => {\n                            return Object.entries(op.query).every(([k, v]) => d[k] === v);\n                        }).map(d => {\n                            Object.assign(d, op.update);\n                            return d._id;\n                        });\n                        results.push(`Updated ${updated.length} documents: ${updated.join(', ')}`);\n                    } else if (op.op === 'delete') {\n                        const toDelete = db.documents.filter(d => {\n                            return Object.entries(op.query).every(([k, v]) => d[k] === v);\n                        });\n                        db.documents = db.documents.filter(d => {\n                            return !Object.entries(op.query).every(([k, v]) => d[k] === v);\n                        });\n                        results.push(`Deleted ${toDelete.length} documents`);\n                    }\n                });\n                \n                updateStats();\n                queryResults.textContent = results.join('\\n');\n            } catch (e) {\n                queryResults.textContent = `Transaction error: ${e.message}`;\n            }\n        });\n        \n        // Utility functions\n        function generateId() {\n            return Math.random().toString(36).substr(2, 9);\n        }\n        \n        function updateStats() {\n            docCount.textContent = db.type === 'graph' ? db.nodes.length : db.documents.length;\n            relCount.textContent = db.relationships.length;\n            storageSize.textContent = Math.floor(JSON.stringify(db).length / 1024);\n        }\n        \n        function displayResults(results) {\n            if (results.length === 0) {\n                queryResults.textContent = 'No results found';\n                return;\n            }\n            \n            if (typeof results[0] === 'string') {\n                queryResults.textContent = results.join('\\n');\n                return;\n            }\n            \n            if (db.type === 'graph' && results[0].hasOwnProperty('path')) {\n                // Special handling for graph traversal results\n                let html = '<table><tr><th>Path</th><th>Nodes</th><th>Relationships</th></tr>';\n                results.forEach(path => {\n                    html += `<tr>\n                        <td>${path.path.join(' → ')}</td>\n                        <td>${path.nodes.map(n => n.id).join(', ')}</td>\n                        <td>${path.relationships.map(r => r.id).join(', ')}</td>\n                    </tr>`;\n                });\n                html += '</table>';\n                queryResults.innerHTML = html;\n                return;\n            }\n            \n            // Default table display for documents/nodes\n            const sample = Object.keys(results[0]);\n            let html = '<table><tr>';\n            sample.forEach(key => {\n                html += `<th>${key}</th>`;\n            });\n            html += '</tr>';\n            \n            results.forEach(item => {\n                html += '<tr>';\n                sample.forEach(key => {\n                    let value = item[key];\n                    if (typeof value === 'object') {\n                        value = JSON.stringify(value);\n                    }\n                    html += `<td>${value}</td>`;\n                });\n                html += '</tr>';\n            });\n            \n            html += '</table>';\n            queryResults.innerHTML = html;\n        }\n        \n        function traverseGraph(startId, depth, visited = new Set(), currentDepth = 0, path = []) {\n            if (currentDepth > depth) return [];\n            if (visited.has(startId)) return [];\n            \n            visited.add(startId);\n            const startNode = db.nodes.find(n => n.id === startId);\n            if (!path.length) path = [startId];\n            \n            const results = [{\n                path: [...path],\n                nodes: [startNode],\n                relationships: []\n            }];\n            \n            if (currentDepth === depth) return results;\n            \n            const rels = db.relationships.filter(r => r.from === startId || r.to === startId);\n            \n            for (const rel of rels) {\n                const nextId = rel.from === startId ? rel.to : rel.from;\n                const newPath = [...path, nextId];\n                \n                const subResults = traverseGraph(\n                    nextId,\n                    depth,\n                    new Set([...visited]),\n                    currentDepth + 1,\n                    newPath\n                );\n                \n                subResults.forEach(res => {\n                    res.nodes.unshift(startNode);\n                    res.relationships.unshift(rel);\n                });\n                \n                results.push(...subResults);\n            }\n            \n            return results;\n        }\n        \n        // Initialize with document database\n        dbTypeSelect.value = 'document';\n        initDbBtn.click();\n    </script>\n</body>\n</html>"
  },
