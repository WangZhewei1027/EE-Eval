    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Decision Tree</title>\n    <style>\n        body {\n            font-family: monospace;\n            text-align: left;\n            margin: 0;\n            padding: 0;\n        }\n        .tree {\n            position: relative;\n            width: 800px;\n            height: 600px;\n            border: 1px solid black;\n            padding: 10px;\n            font-size: 12px;\n            line-height: 1.2;\n        }\n        .tree input {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: 1px solid black;\n            font-size: 12px;\n        }\n        .tree button {\n            position: absolute;\n            top: 10px;\n            right: 10px;\n            padding: 10px;\n            font-size: 12px;\n            cursor: pointer;\n        }\n        .tree input:hover, .tree button:hover {\n            background-color: #ccc;\n        }\n        .tree select {\n            padding: 10px;\n            font-size: 12px;\n            cursor: pointer;\n        }\n        .tree select:focus {\n            outline: 2px solid black;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"tree\" id=\"tree\"></div>\n    <div class=\"input-container\">\n        <label for=\"input1\">Input 1:</label>\n        <input type=\"number\" id=\"input1\" value=\"10\">\n        <button id=\"button1\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input2\">Input 2:</label>\n        <input type=\"number\" id=\"input2\" value=\"20\">\n        <button id=\"button2\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input3\">Input 3:</label>\n        <input type=\"number\" id=\"input3\" value=\"30\">\n        <button id=\"button3\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input4\">Input 4:</label>\n        <input type=\"number\" id=\"input4\" value=\"40\">\n        <button id=\"button4\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input5\">Input 5:</label>\n        <input type=\"number\" id=\"input5\" value=\"50\">\n        <button id=\"button5\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input6\">Input 6:</label>\n        <input type=\"number\" id=\"input6\" value=\"60\">\n        <button id=\"button6\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input7\">Input 7:</label>\n        <input type=\"number\" id=\"input7\" value=\"70\">\n        <button id=\"button7\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input8\">Input 8:</label>\n        <input type=\"number\" id=\"input8\" value=\"80\">\n        <button id=\"button8\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input9\">Input 9:</label>\n        <input type=\"number\" id=\"input9\" value=\"90\">\n        <button id=\"button9\">Submit</button>\n    </div>\n    <div class=\"input-container\">\n        <label for=\"input10\">Input 10:</label>\n        <input type=\"number\" id=\"input10\" value=\"100\">\n        <button id=\"button10\">Submit</button>\n    </div>\n    <button id=\"submit\">Submit Decision Tree</button>\n    <div id=\"result\"></div>\n\n    <script>\n        const tree = document.getElementById(\"tree\");\n        const inputs = document.querySelectorAll(\"input\");\n        const buttons = document.querySelectorAll(\"button\");\n        const result = document.getElementById(\"result\");\n\n        let inputsValues = [];\n        let buttonsClick = {};\n\n        inputs.forEach((input) => {\n            input.addEventListener(\"change\", () => {\n                inputsValues.push(input.value);\n            });\n        });\n\n        buttons.forEach((button) => {\n            button.addEventListener(\"click\", () => {\n                inputsValues.push(button.value);\n                buttonsClick[button.id] = true;\n            });\n        });\n\n        tree.addEventListener(\"click\", (e) => {\n            if (e.target.classList.contains(\"input\") || e.target.classList.contains(\"button\")) {\n                const inputId = e.target.classList.contains(\"input\") ? e.target.id : e.target.parentNode.id;\n                inputsValues = inputs.filter((input) => input.id !== inputId);\n                buttonsClick[inputId] = true;\n                inputs.forEach((input) => {\n                    if (input.id !== inputId) {\n                        input.value = \"\";\n                    }\n                });\n            }\n        });\n\n        const submitButton = document.getElementById(\"submit\");\n        submitButton.addEventListener(\"click\", () => {\n            const decisionTree = {\n                inputs: inputsValues,\n                buttons: Object.keys(buttonsClick),\n            };\n\n            // Create a simple decision tree model\n            const treeModel = {\n                root: {\n                    inputs: decisionTree.inputs,\n                    buttons: decisionTree.buttons,\n                },\n                node: (node) => {\n                    if (node.buttons) {\n                        return {\n                            inputs: node.inputs,\n                            buttons: node.buttons,\n                            children: [],\n                        };\n                    } else if (node.inputs.length === 0) {\n                        return {\n                            inputs: [],\n                            buttons: [],\n                            children: [],\n                        };\n                    } else {\n                        const children = node.inputs.map((input) => ({\n                            inputs: input,\n                            buttons: Object.keys(buttonsClick).filter((buttonId) => buttonsClick[buttonId]),\n                            children: [],\n                        }));\n                        return {\n                            inputs: node.inputs,\n                            buttons: node.buttons,\n                            children,\n                        };\n                    }\n                },\n            };\n\n            // Perform the decision tree\n            function makeDecision(node) {\n                if (node.children.length > 0) {\n                    const child = node.children[0];\n                    const decision = child.node(node);\n                    return decision;\n                } else {\n                    return node.inputs[0];\n                }\n            }\n\n            // Start the decision tree\n            const decision = makeDecision(treeModel.root);\n            result.textContent = `Decision: ${decision}`;\n        });\n    </script>\n</body>\n</html>"
