ct: none;\n        }\n        .slider input[type=\"range\"]::-ms-thumb {\n            width: 20px;\n            height: 20px;\n            background-color: #f00;\n            border: none;\n            font-size: 16px;\n            margin: 0 10px;\n            -webkit-user-select: none;\n            -moz-user-select: none;\n            user-select: none;\n        }\n        .slider input[type=\"range\"]::-ms-thumb-glow {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 20px;\n            height: 20px;\n            background-color: #f00;\n            border: none;\n            font-size: 16px;\n            margin: 0 10px;\n            -webkit-user-select: none;\n            -moz-user-select: none;\n            user-select: none;\n        }\n        .slider input[type=\"range\"]::-ms-thumb-glow-out {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 20px;\n            height: 20px;\n            background-color: #f00;\n            border: none;\n            font-size: 16px;\n            margin: 0 10px;\n            -webkit-user-select: none;\n            -moz-user-select: none;\n            user-select: none;\n        }\n        .slider input[type=\"range\"]::-ms-thumb-glow-in {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 20px;\n            height: 20px;\n            background-color: #f00;\n            border: none;\n            font-size: 16px;\n            margin: 0 10px;\n            -webkit-user-select: none;\n            -moz-user-select: none;\n            user-select: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Big-Theta Notation</h1>\n        <p>This is a demonstration of Big-Theta Notation, a measure of the time or space complexity of an algorithm.</p>\n        <div class=\"slider\">\n            <input type=\"range\" id=\"slider\" min=\"1\" max=\"10\" value=\"5\">\n            <label for=\"slider\">Slider Value</label>\n        </div>\n        <div class=\"button\">\n            <button id=\"button\">Calculate Big-Theta</button>\n        </div>\n        <p id=\"result\"></p>\n    </div>\n\n    <script>\n        const slider = document.getElementById('slider');\n        const button = document.getElementById('button');\n        const resultElement = document.getElementById('result');\n\n        function calculateBigTheta() {\n            const value = parseFloat(slider.value);\n            const timeComplexity = value;\n            const spaceComplexity = 1 / value;\n            const bigTheta = timeComplexity + spaceComplexity;\n            resultElement.innerText = `Big-Theta Notation: Time Complexity: ${timeComplexity}O, Space Complexity: ${spaceComplexity}O`;\n        }\n\n        button.addEventListener('click', calculateBigTheta);\n\n        slider.addEventListener('input', calculateBigTheta);\n    </script>\n</body>\n</html>"
