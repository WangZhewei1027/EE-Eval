    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Prim's Algorithm — Visual Elegance</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #081122;\n    --card: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --accent: #7c5cff;\n    --accent-2: #00e0c2;\n    --glass: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --gold: #ffd166;\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    background: radial-gradient(1200px 800px at 10% 10%, rgba(124,92,255,0.12), transparent 8%),\n                radial-gradient(900px 600px at 90% 85%, rgba(0,224,194,0.06), transparent 8%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e8eefc;\n    overflow:hidden;\n  }\n\n  /* Decorative floating blobs */\n  .blob{\n    position:absolute;\n    width:580px;height:580px;\n    border-radius:50%;\n    filter:blur(60px) saturate(140%);\n    opacity:0.08;\n    mix-blend-mode:screen;\n    transform:translate3d(0,0,0);\n    will-change:transform,opacity;\n    animation:floaty 12s ease-in-out infinite alternate;\n  }\n  .blob.a{ left:-120px; top:-60px; background:linear-gradient(135deg,#7c5cff,#4c7bff); animation-duration:16s;}\n  .blob.b{ right:-180px; bottom:-160px; background:linear-gradient(135deg,#00e0c2,#6ef0ff); animation-duration:20s; opacity:0.06;}\n  @keyframes floaty{\n    from{ transform: translate3d(0,0,0) scale(1); }\n    to{ transform: translate3d(20px,18px,0) scale(1.06); }\n  }\n\n  /* Layout */\n  .stage{\n    position:relative;\n    width:100%;\n    height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n    gap:24px;\n  }\n\n  .panel{\n    width:1100px;\n    max-width:calc(100% - 96px);\n    height:700px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    box-sizing:border-box;\n    box-shadow: 0 20px 60px rgba(4,8,18,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:grid;\n    grid-template-columns: 1fr 380px;\n    gap:18px;\n    position:relative;\n    overflow:hidden;\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n\n  header.top {\n    grid-column: 1 / -1;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n    margin-bottom:4px;\n  }\n\n  .title{\n    display:flex;\n    flex-direction:column;\n  }\n  .title h1{\n    margin:0;\n    font-weight:700;\n    font-size:20px;\n    letter-spacing:0.6px;\n    color: #fff;\n  }\n  .title p{\n    margin:6px 0 0 0;\n    color:var(--muted);\n    font-size:13px;\n    opacity:0.9;\n  }\n\n  .controls{\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n\n  .btn {\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));\n    color: #fff;\n    border-radius:12px;\n    padding:10px 16px;\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    border:1px solid rgba(255,255,255,0.04);\n    cursor:pointer;\n    font-weight:600;\n    letter-spacing:0.4px;\n    transition: transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n    box-shadow: 0 6px 18px rgba(14,18,36,0.45);\n  }\n  .btn:active{ transform: translateY(1px) scale(.998); }\n  .btn.secondary{\n    background:transparent;\n    border:1px dashed rgba(255,255,255,0.04);\n    padding:8px 12px;\n    font-weight:600;\n    color:var(--muted);\n    box-shadow:none;\n  }\n\n  /* Right info card */\n  .info{\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n    align-items:stretch;\n    min-width:260px;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n  .info h3{\n    margin:0;\n    font-size:14px;\n    color:var(--muted);\n    letter-spacing:0.6px;\n  }\n  .stats{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:4px;\n  }\n  .tile{\n    flex:1;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px;\n    padding:12px;\n    box-shadow: 0 10px 30px rgba(8,12,24,0.45);\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .tile strong{\n    font-size:20px;\n    display:block;\n    color:#fff;\n  }\n  .tile span{ font-size:12px; color:var(--muted); }\n\n  .legend{\n    margin-top:6px;\n    display:flex;\n    gap:8px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .caption{\n    margin-top:8px;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.45;\n  }\n\n  /* Canvas area */\n  .canvas-wrap{\n    position:relative;\n    background: linear-gradient(135deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border-radius:12px;\n    overflow:visible;\n    padding:18px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: inset 0 -12px 36px rgba(0,0,0,0.25);\n  }\n\n  svg{\n    width:100%;\n    height:100%;\n    max-height:620px;\n    overflow:visible;\n  }\n\n  /* Node style */\n  .node {\n    cursor:default;\n    transition: transform .28s cubic-bezier(.2,.9,.2,1), filter .28s ease;\n    transform-origin:center center;\n  }\n  .node .core{\n    fill: url(#node-grad);\n    stroke: rgba(255,255,255,0.12);\n    stroke-width:1.2;\n    filter: drop-shadow(0 6px 18px rgba(20,30,50,0.5));\n  }\n  .node .label {\n    font-size:13px;\n    text-anchor:middle;\n    dominant-baseline:central;\n    fill: #fff;\n    font-weight:700;\n    pointer-events:none;\n    letter-spacing:0.6px;\n  }\n  .node .sub {\n    font-size:10px;\n    fill: var(--muted);\n    font-weight:600;\n    transform: translateY(16px);\n  }\n  .node.in-tree .core{\n    stroke: url(#accent-stroke);\n    stroke-width:2.4;\n    filter: drop-shadow(0 12px 36px rgba(124,92,255,0.24));\n  }\n  .node.pulse .core{\n    transform-origin:center center;\n    animation:nodePulse 900ms ease forwards;\n  }\n  @keyframes nodePulse{\n    0%{ transform: scale(1); filter: drop-shadow(0 12px 36px rgba(124,92,255,0.08)); }\n    50%{ transform: scale(1.18); filter: drop-shadow(0 20px 48px rgba(124,92,255,0.18)); }\n    100%{ transform: scale(1.02); filter: drop-shadow(0 12px 36px rgba(124,92,255,0.12)); }\n  }\n\n  /* Edge styles */\n  .edge{\n    stroke: rgba(255,255,255,0.08);\n    stroke-width:2.2;\n    fill:none;\n    stroke-linecap:round;\n    transition: stroke 420ms ease, stroke-width 420ms ease, filter .28s ease;\n    filter: drop-shadow(0 6px 20px rgba(8,8,20,0.45));\n  }\n  .edge.highlight{\n    stroke: url(#edge-grad);\n    stroke-width:4.6;\n    filter: drop-shadow(0 18px 48px rgba(124,92,255,0.18));\n  }\n  .edge.dim{\n    opacity:0.18;\n    stroke-dasharray:6 8;\n  }\n\n  .weight {\n    font-size:12px;\n    fill: #fff;\n    font-weight:700;\n    text-anchor:middle;\n    pointer-events:none;\n    dominant-baseline:central;\n    opacity:0.9;\n    transition: fill .28s ease;\n  }\n\n  /* small caption timeline */\n  .timeline{\n    margin-top:8px;\n    font-size:13px;\n    color:var(--muted);\n    height:120px;\n    overflow:hidden;\n  }\n  .step{\n    display:flex;\n    gap:10px;\n    align-items:flex-start;\n    margin-bottom:8px;\n    opacity:0.9;\n  }\n  .step .dot{\n    width:10px;height:10px;border-radius:50%;\n    background: rgba(255,255,255,0.04);\n    border: 1px solid rgba(255,255,255,0.03);\n    margin-top:4px;\n    flex-shrink:0;\n  }\n  .step.active .dot{\n    background:linear-gradient(90deg,var(--accent),var(--accent-2));\n    box-shadow:0 6px 20px rgba(124,92,255,0.14);\n    border: none;\n  }\n  .step p{ margin:0; color:var(--muted); font-size:13px; line-height:1.35; }\n\n  /* Footer overlay for totals */\n  .footer{\n    position:absolute;\n    left:38px;\n    bottom:24px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .total{\n    display:flex;\n    gap:8px;\n    align-items:center;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:8px 12px;\n    border-radius:12px;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n    font-weight:700;\n    color:#fff;\n  }\n\n  /* responsive */\n  @media (max-width:1100px){\n    .panel{ grid-template-columns: 1fr; height:calc(100vh - 120px); }\n    .info{ order:2; width:100%; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"blob a\" aria-hidden=\"true\"></div>\n  <div class=\"blob b\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\">\n    <div class=\"panel\" role=\"main\" aria-label=\"Prim's Algorithm visualization\">\n      <header class=\"top\">\n        <div class=\"title\">\n          <h1>Prim's Algorithm</h1>\n          <p>An animated, aesthetic depiction of building a Minimum Spanning Tree</p>\n        </div>\n        <div class=\"controls\" aria-hidden=\"true\">\n          <button id=\"replayBtn\" class=\"btn\" title=\"Replay the animation\">\n            ▶ Replay\n          </button>\n        </div>\n      </header>\n\n      <div class=\"canvas-wrap\" aria-hidden=\"false\">\n        <svg id=\"svg\" viewBox=\"0 0 1000 700\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Graph visualization\">\n          <!-- defs for gradients and filters -->\n          <defs>\n            <linearGradient id=\"node-grad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#2b2f6f\"/>\n              <stop offset=\"100%\" stop-color=\"#4c7bff\"/>\n            </linearGradient>\n\n            <linearGradient id=\"accent-stroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"100%\" stop-color=\"#00e0c2\"/>\n            </linearGradient>\n\n            <linearGradient id=\"edge-grad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"100%\" stop-color=\"#00e0c2\"/>\n            </linearGradient>\n\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"10\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- group for edges and nodes that will be populated by JS -->\n          <g id=\"edges\" />\n          <g id=\"weights\" />\n          <g id=\"nodes\" />\n        </svg>\n      </div>\n\n      <aside class=\"info\" aria-hidden=\"true\">\n        <h3>Algorithm Flow</h3>\n        <div class=\"stats\">\n          <div class=\"tile\">\n            <span style=\"color:var(--muted);font-size:12px;\">Start vertex</span>\n            <strong id=\"startNode\">A</strong>\n          </div>\n          <div class=\"tile\">\n            <span style=\"color:var(--muted);font-size:12px;\">MST Total Weight</span>\n            <strong id=\"totalWeight\">—</strong>\n          </div>\n        </div>\n\n        <div class=\"legend\">\n          <svg width=\"90\" height=\"26\" viewBox=\"0 0 90 26\" style=\"flex-shrink:0\">\n            <g transform=\"translate(10,13)\">\n              <line x1=\"0\" y1=\"0\" x2=\"40\" y2=\"0\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n              <circle cx=\"0\" cy=\"0\" r=\"6\" fill=\"#2b2f6f\" stroke=\"rgba(255,255,255,0.08)\"/>\n            </g>\n          </svg>\n          <div style=\"display:flex;flex-direction:column\">\n            <div style=\"font-weight:700;color:#fff\">Undirected weighted graph</div>\n            <div style=\"font-size:12px;color:var(--muted)\">Watch the MST assemble edge by edge</div>\n          </div>\n        </div>\n\n        <div class=\"caption\">\n          Prim's algorithm grows a tree by always choosing the smallest edge that connects the growing tree to a new vertex. This elegant demonstration highlights each chosen edge and shows the progressive accumulation of the minimum spanning tree.\n        </div>\n\n        <div class=\"timeline\" id=\"timeline\" aria-hidden=\"true\">\n          <!-- steps will be injected here -->\n        </div>\n\n      </aside>\n\n      <div class=\"footer\" aria-hidden=\"true\">\n        <div class=\"total\">\n          <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" style=\"flex-shrink:0\">\n            <path d=\"M12 2l2.5 6.5L21 10l-5 3.7L17 21l-5-3.3L7 21l1-7.3L3 10l6.5-1.5z\" fill=\"#ffd166\"/>\n          </svg>\n          <div>\n            <div style=\"font-size:11px;color:var(--muted)\">Minimum Spanning Tree</div>\n            <div id=\"finalWeight\" style=\"font-weight:800;font-size:14px;color:#fff\">Total: —</div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Minimal interactivity: replay button only\n  const replayBtn = document.getElementById('replayBtn');\n\n  // Graph definition (nodes with positions, edges with weights)\n  const nodes = [\n    { id: 0, label: 'A', x: 180, y: 160 },\n    { id: 1, label: 'B', x: 420, y: 90 },\n    { id: 2, label: 'C', x: 660, y: 160 },\n    { id: 3, label: 'D', x: 820, y: 330 },\n    { id: 4, label: 'E', x: 680, y: 520 },\n    { id: 5, label: 'F', x: 420, y: 590 },\n    { id: 6, label: 'G', x: 160, y: 520 },\n    { id: 7, label: 'H', x: 110, y: 340 }\n  ];\n\n  // Weighted undirected edges\n  const edges = [\n    { u:0, v:1, w:8 },\n    { u:0, v:7, w:11 },\n    { u:1, v:2, w:7 },\n    { u:1, v:7, w:2 },\n    { u:2, v:3, w:6 },\n    { u:2, v:8, w:2 }, // invalid index to test - we'll not use node 8; fix list: remove\n    // remove invalid edge, replace with connections to 4\n    { u:2, v:4, w:9 }, // C-E\n    { u:3, v:4, w:5 },\n    { u:4, v:5, w:4 },\n    { u:5, v:6, w:10 },\n    { u:6, v:7, w:1 },\n    { u:7, v:1, w:2 }, // duplicate connection for aesthetic (H-B) weight 2 already added as 1-7\n    { u:5, v:1, w:14 },\n    { u:6, v:0, w:7 }\n  ];\n\n  // Clean edges to ensure unique and valid entries\n  const cleanedEdges = [];\n  const seen = new Set();\n  for (const e of edges) {\n    if (e.u == null || e.v == null) continue;\n    if (e.u < 0 || e.v < 0 || e.u >= nodes.length || e.v >= nodes.length) continue;\n    const key = e.u < e.v ? `${e.u}-${e.v}` : `${e.v}-${e.u}`;\n    if (seen.has(key)) continue;\n    seen.add(key);\n    cleanedEdges.push({ u:e.u, v:e.v, w:e.w });\n  }\n\n  // Use cleaned edges\n  const edgeList = cleanedEdges;\n\n  const svg = document.getElementById('svg');\n  const edgesGroup = document.getElementById('edges');\n  const nodesGroup = document.getElementById('nodes');\n  const weightsGroup = document.getElementById('weights');\n  const timeline = document.getElementById('timeline');\n  const startNodeEl = document.getElementById('startNode');\n  const totalWeightEl = document.getElementById('totalWeight');\n  const finalWeightEl = document.getElementById('finalWeight');\n\n  // Utility to create SVG elements\n  function createNS(tag, attrs = {}) {\n    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);\n    for (const k in attrs) el.setAttribute(k, attrs[k]);\n    return el;\n  }\n\n  // Draw base graph quietly; edges faint, nodes subtle\n  function drawGraph() {\n    edgesGroup.innerHTML = '';\n    nodesGroup.innerHTML = '';\n    weightsGroup.innerHTML = '';\n\n    // draw edges as slightly curved paths\n    edgeList.forEach((e, idx) => {\n      const a = nodes[e.u];\n      const b = nodes[e.v];\n      const midx = (a.x + b.x) / 2;\n      const midy = (a.y + b.y) / 2;\n      const dx = b.x - a.x;\n      const dy = b.y - a.y;\n      const len = Math.hypot(dx,dy);\n      // perpendicular offset scaled by distance for gentle curve\n      const perp = 20 + Math.min(80, len / 12);\n      const nx = -dy / len;\n      const ny = dx / len;\n      const cx = midx + nx * perp;\n      const cy = midy + ny * perp;\n\n      const path = createNS('path', {\n        d: `M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`,\n        class: 'edge',\n        'data-idx': idx,\n        id: `edge-${idx}`\n      });\n      edgesGroup.appendChild(path);\n\n      // weight label at a point near the curve midpoint\n      const t = 0.52;\n      // approximate quadratic bezier point\n      const x = (1-t)*(1-t)*a.x + 2*(1-t)*t*cx + t*t*b.x;\n      const y = (1-t)*(1-t)*a.y + 2*(1-t)*t*cy + t*t*b.y;\n\n      const textBg = createNS('rect', {\n        x: x - 20,\n        y: y - 14,\n        width: 40,\n        height: 22,\n        rx: 8,\n        fill: 'rgba(10,12,20,0.65)',\n        stroke: 'rgba(255,255,255,0.04)',\n        'data-eidx': idx\n      });\n      // tiny weight text\n      const text = createNS('text', {\n        x: x,\n        y: y,\n        class: 'weight',\n        'data-eidx': idx\n      });\n      text.textContent = e.w;\n\n      // place rectangle and text in group for weight\n      const g = createNS('g');\n      g.appendChild(textBg);\n      g.appendChild(text);\n      weightsGroup.appendChild(g);\n    });\n\n    // draw nodes\n    nodes.forEach((n) => {\n      const g = createNS('g', { class: 'node', id: `node-${n.id}`, transform: `translate(${n.x},${n.y})` });\n      const core = createNS('circle', { cx: 0, cy: 0, r: 22, class: 'core' });\n      const label = createNS('text', { class: 'label', x: 0, y: -2 });\n      label.textContent = n.label;\n      const sub = createNS('text', { class: 'sub', x:0, y: 18 });\n      sub.textContent = `v${n.id}`;\n      g.appendChild(core);\n      g.appendChild(label);\n      g.appendChild(sub);\n      nodesGroup.appendChild(g);\n    });\n  }\n\n  // Prim's algorithm implementation (returns ordered chosen edges)\n  function primMST(start = 0){\n    const n = nodes.length;\n    const inTree = new Array(n).fill(false);\n    const dist = new Array(n).fill(Infinity);\n    const parent = new Array(n).fill(-1);\n    dist[start] = 0;\n    const resEdges = [];\n\n    for (let k=0;k<n;k++){\n      // pick min dist not inTree\n      let u=-1;\n      let best = Infinity;\n      for (let i=0;i<n;i++){\n        if(!inTree[i] && dist[i] < best){ best = dist[i]; u=i; }\n      }\n      if (u === -1) break;\n      inTree[u] = true;\n      if (parent[u] !== -1) {\n        // find weight of edge parent[u]-u\n        const e = edgeList.find(x => (x.u===u && x.v===parent[u]) || (x.v===u && x.u===parent[u]));\n        resEdges.push({ u: parent[u], v: u, w: e ? e.w : dist[u] });\n      }\n      // relax neighbors\n      edgeList.forEach(e => {\n        const v = (e.u === u ? e.v : (e.v === u ? e.u : -1));\n        if (v !== -1 && !inTree[v] && e.w < dist[v]) {\n          dist[v] = e.w;\n          parent[v] = u;\n        }\n      });\n    }\n    return resEdges;\n  }\n\n  // Create timeline entries for visualization\n  function prepareTimeline(mstEdges, start){\n    timeline.innerHTML = '';\n    const intro = document.createElement('div');\n    intro.className = 'step';\n    intro.innerHTML = `<div class=\"dot\" style=\"width:12px;height:12px;border-radius:50%;background:linear-gradient(90deg,var(--accent),var(--accent-2));box-shadow:0 8px 28px rgba(124,92,255,0.12)\"></div>\n                       <p><strong>Start at vertex ${nodes[start].label}</strong><br><span style=\"color:var(--muted)\">Prim's algorithm will expand the tree by choosing the smallest connecting edges.</span></p>`;\n    timeline.appendChild(intro);\n\n    mstEdges.forEach((e, idx) => {\n      const step = document.createElement('div');\n      step.className = 'step';\n      step.id = `step-${idx}`;\n      step.innerHTML = `<div class=\"dot\"></div>\n        <p>Chosen edge: <strong>${nodes[e.u].label} — ${nodes[e.v].label}</strong> <span style=\"color:var(--muted)\"> (weight ${e.w})</span></p>`;\n      timeline.appendChild(step);\n    });\n\n    const done = document.createElement('div');\n    done.className = 'step';\n    done.id = 'step-final';\n    done.innerHTML = `<div class=\"dot\"></div>\n      <p><strong>MST Complete</strong><br><span style=\"color:var(--muted)\">Total vertices connected and spanning tree assembled.</span></p>`;\n    timeline.appendChild(done);\n  }\n\n  // Animate sequence of building MST\n  function animateMST(start = 0, onComplete = ()=>{}) {\n    // reset visuals\n    totalWeightEl.textContent = '—';\n    finalWeightEl.textContent = 'Total: —';\n    drawGraph();\n\n    // compute MST edges in prim order\n    const mstEdges = primMST(start);\n    prepareTimeline(mstEdges, start);\n\n    // mark start node as in-tree visually\n    const startNode = document.getElementById(`node-${start}`);\n    if (startNode) startNode.classList.add('in-tree');\n\n    // helper to get path length for stroke-dash animations\n    function animatePathDraw(pathEl, duration=800){\n      const total = pathEl.getTotalLength();\n      pathEl.style.transition = 'none';\n      pathEl.style.strokeDasharray = total;\n      pathEl.style.strokeDashoffset = total;\n      // force reflow\n      void pathEl.getBoundingClientRect();\n      pathEl.style.transition = `stroke-dashoffset ${duration}ms cubic-bezier(.2,.9,.24,1)`;\n      pathEl.style.strokeDashoffset = 0;\n      return new Promise(r => setTimeout(r, duration + 50));\n    }\n\n    // sequence through edges\n    let accWeight = 0;\n    let promise = Promise.resolve();\n    // slight initial pause\n    promise = promise.then(()=> new Promise(r => setTimeout(r, 600)));\n\n    mstEdges.forEach((e, idx) => {\n      promise = promise.then(()=> {\n        // highlight timeline\n        const stepEl = document.getElementById(`step-${idx}`);\n        document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));\n        if (stepEl) stepEl.classList.add('active');\n\n        // find corresponding edge SVG\n        // there may be edges with swapped u/v; we find the matching path by coordinates\n        const matchIdx = edgeList.findIndex(ed => (ed.u===e.u && ed.v===e.v) || (ed.u===e.v && ed.v===e.u));\n        const pathEl = document.getElementById(`edge-${matchIdx}`);\n        const weightText = weightsGroup.querySelector(`[data-eidx=\"${matchIdx}\"]`);\n        // nodes\n        const nu = document.getElementById(`node-${e.u}`);\n        const nv = document.getElementById(`node-${e.v}`);\n\n        // reveal edge drawing\n        if (pathEl) pathEl.classList.remove('dim');\n\n        // animate draw\n        return animatePathDraw(pathEl, 860).then(()=> {\n          // accentuate the edge and nodes\n          if (pathEl) {\n            pathEl.classList.add('highlight');\n            // small flourish animation\n            pathEl.animate([\n              { filter: 'drop-shadow(0 6px 20px rgba(8,8,20,0.45))', transform: 'scale(1)' },\n              { filter: 'drop-shadow(0 20px 56px rgba(124,92,255,0.18))', transform: 'scale(1.00)' }\n            ], { duration: 520, easing: 'cubic-bezier(.2,.9,.2,1)' });\n          }\n          // mark nodes as in-tree and pulse\n          if (nu) { nu.classList.add('pulse'); nu.classList.add('in-tree'); }\n          if (nv) { nv.classList.add('pulse'); nv.classList.add('in-tree'); }\n\n          // update weight displays\n          accWeight += e.w;\n          totalWeightEl.textContent = accWeight;\n          finalWeightEl.textContent = `Total: ${accWeight}`;\n\n          // subtle delay\n          return new Promise(r => setTimeout(r, 680));\n        }).then(()=> {\n          // remove pulse after\n          if (nu) nu.classList.remove('pulse');\n          if (nv) nv.classList.remove('pulse');\n        });\n      });\n    });\n\n    // finish\n    promise.then(()=> {\n      document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));\n      const fin = document.getElementById('step-final');\n      if (fin) fin.classList.add('active');\n      onComplete();\n    });\n  }\n\n  // initial draw and autoplay\n  drawGraph();\n  // apply dim class to all edges initially\n  document.querySelectorAll('.edge').forEach(el => el.classList.add('dim'));\n\n  // autoplay on load after tiny delay\n  setTimeout(()=> {\n    // choose start node 0\n    startNodeEl.textContent = nodes[0].label;\n    animateMST(0);\n  }, 480);\n\n  // replay button handler\n  replayBtn.addEventListener('click', () => {\n    replayBtn.disabled = true;\n    replayBtn.style.opacity = '0.9';\n    replayBtn.textContent = '⟳ Replaying';\n    // reset some classes\n    document.querySelectorAll('.node').forEach(n => { n.classList.remove('in-tree','pulse'); });\n    document.querySelectorAll('.edge').forEach(e => { e.classList.remove('highlight'); e.style.strokeDashoffset = ''; e.style.strokeDasharray = ''; e.classList.add('dim'); });\n    // small re-draw\n    setTimeout(()=> {\n      animateMST(0, ()=> {\n        replayBtn.disabled = false;\n        replayBtn.textContent = '▶ Replay';\n      });\n    }, 260);\n  });\n\n  // small polish: gentle idle motion for nodes\n  (function floatNodes(){\n    const nodeEls = Array.from(document.querySelectorAll('.node'));\n    nodeEls.forEach((n, i) => {\n      const delay = (i % 4) * 120;\n      n.animate([\n        { transform: n.getAttribute('transform') + ' translate(0,0)' },\n        { transform: n.getAttribute('transform') + ' translate(0,6px)' },\n        { transform: n.getAttribute('transform') + ' translate(0,0)' }\n      ], { duration: 4200 + (i*120), delay, iterations: Infinity, easing: 'cubic-bezier(.2,.9,.2,1)' });\n    });\n  })();\n\n})();\n</script>\n</body>\n</html>"
