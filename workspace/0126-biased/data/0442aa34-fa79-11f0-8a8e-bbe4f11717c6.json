    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kruskal's Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n\n        .container {\n            max-width: 600px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .header {\n            background-color: #333;\n            color: #fff;\n            padding: 10px;\n            text-align: center;\n            border-bottom: 1px solid #555;\n        }\n\n        .algorithm {\n            margin-bottom: 40px;\n        }\n\n        .algorithm-section {\n            background-color: #f7f7f7;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .algorithm-section h2 {\n            margin-top: 0;\n        }\n\n        .algorithm-section p {\n            margin-bottom: 10px;\n        }\n\n        .algorithm-button {\n            background-color: #333;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .algorithm-button:hover {\n            background-color: #444;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Kruskal's Algorithm</h1>\n            <p>Visualizing the Minimum Spanning Tree of a Graph</p>\n        </div>\n        <div class=\"algorithm\">\n            <h2>Step 1: Sort the Graph</h2>\n            <p>Sort the edges of the graph in non-decreasing order of their weights.</p>\n\n            <div class=\"algorithm-section\">\n                <h2>Step 2: Find the Minimum Spanning Tree</h2>\n                <p>Use Kruskal's algorithm to find the minimum spanning tree of the sorted graph.</p>\n            </div>\n\n            <div class=\"algorithm-section\">\n                <h2>Step 3: Print the MST</h2>\n                <p>Print the edges of the minimum spanning tree.</p>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        function kruskalSort(edges) {\n            // Sort the edges in non-decreasing order of their weights\n            edges.sort((a, b) => a.weight - b.weight);\n\n            // Initialize the disjoint set\n            const disjointSet = {};\n            for (const edge of edges) {\n                disjointSet[edge.from] = edge.from;\n                disjointSet[edge.to] = edge.to;\n            }\n\n            // Find the root of each node\n            const roots = {};\n            for (const edge of edges) {\n                roots[edge.from] = edge.from;\n                roots[edge.to] = edge.to;\n            }\n\n            // Merge the nodes with the same root\n            for (const edge of edges) {\n                if (roots[edge.from] !== roots[edge.to]) {\n                    disjointSet[edge.from] = edge.to;\n                }\n            }\n\n            // Add the edges to the minimum spanning tree\n            const mst = [];\n            for (const edge of edges) {\n                if (disjointSet[edge.from] !== disjointSet[edge.to]) {\n                    mst.push(edge);\n                }\n            }\n\n            return mst;\n        }\n\n        function printMST(mst) {\n            console.log(\"Minimum Spanning Tree:\");\n            for (const edge of mst) {\n                console.log(`Edge from ${edge.from} to ${edge.to} with weight ${edge.weight}`);\n            }\n        }\n\n        // Example usage\n        const edges = [\n            { from: 0, to: 1, weight: 10 },\n            { from: 1, to: 2, weight: 5 },\n            { from: 2, to: 3, weight: 15 },\n            { from: 3, to: 0, weight: 20 },\n        ];\n\n        const mst = kruskalSort(edges);\n        printMST(mst);\n    </script>\n</body>\n</html>"
