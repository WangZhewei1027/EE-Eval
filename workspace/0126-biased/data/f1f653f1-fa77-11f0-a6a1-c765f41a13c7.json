    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Floyd–Warshall — A Visual Elegance</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Poppins:wght@400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #081225;\n      --card: rgba(255,255,255,0.04);\n      --glass: rgba(255,255,255,0.03);\n      --accent: #6EE7B7;\n      --accent-2: #60A5FA;\n      --muted: rgba(255,255,255,0.55);\n      --glass-border: rgba(255,255,255,0.06);\n      --neon: rgba(110,231,183,0.15);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(96,165,250,0.06), transparent 8%),\n                  radial-gradient(900px 500px at 90% 90%, rgba(110,231,183,0.06), transparent 10%),\n                  linear-gradient(180deg, var(--bg-1), var(--bg-2) 60%);\n      color:#e6eef8;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:48px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      gap:32px;\n    }\n\n    /* Container */\n    .frame{\n      width:1180px;\n      max-width:96vw;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:20px;\n      padding:28px;\n      box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      border:1px solid rgba(255,255,255,0.03);\n      display:grid;\n      grid-template-columns: 1.15fr 0.85fr;\n      gap:22px;\n      align-items:stretch;\n    }\n\n    /* Left: Graph */\n    .panel-graph{\n      position:relative;\n      padding:28px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), transparent);\n      border-radius:16px;\n      overflow:hidden;\n      border:1px solid var(--glass-border);\n    }\n    .panel-graph .header{\n      display:flex;\n      align-items:center;\n      gap:14px;\n      margin-bottom:12px;\n    }\n    .badge{\n      width:56px;height:56px;border-radius:12px;\n      background:linear-gradient(135deg,var(--accent),var(--accent-2));\n      display:flex;align-items:center;justify-content:center;\n      font-weight:700;color:#03233a;font-size:18px;\n      box-shadow: 0 6px 22px rgba(96,165,250,0.12);\n    }\n    .title{\n      display:flex;flex-direction:column;\n    }\n    .title h1{\n      margin:0;font-family:Poppins, Inter;\n      font-weight:600;font-size:18px;letter-spacing:-0.2px;\n      color:#eaf8ff;\n    }\n    .title p{margin:0;margin-top:4px;color:var(--muted);font-size:13px}\n\n    /* Graph canvas */\n    .graph-area{\n      position:relative;\n      height:520px;\n      margin-top:18px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n    svg { width:100%; height:100%; overflow:visible; }\n\n    /* Right column UI */\n    .panel-side{\n      padding:22px;\n      border-radius:16px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), transparent);\n      border:1px solid var(--glass-border);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      min-height:520px;\n    }\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border-radius:12px;\n      padding:14px;\n      border:1px solid rgba(255,255,255,0.02);\n      box-shadow: 0 6px 18px rgba(5,8,18,0.38);\n    }\n    .explain h2{margin:0;font-family:Poppins;font-size:16px}\n    .explain p{margin:8px 0 0 0;color:var(--muted);font-size:13px;line-height:1.35}\n\n    /* Matrices */\n    .matrices{display:flex;gap:12px;align-items:center}\n    .matrix{\n      display:grid;\n      grid-template-columns: repeat(6, 38px);\n      gap:8px;\n      padding:12px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.018), transparent);\n      border-radius:10px;\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .matrix .cell{\n      width:38px;height:38px;border-radius:8px;\n      display:flex;align-items:center;justify-content:center;\n      font-size:12px;font-weight:600;color:#dff9ef;\n      background:linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.006));\n      transition: all 280ms cubic-bezier(.2,.9,.2,1);\n      box-shadow: 0 6px 14px rgba(8,15,30,0.25);\n      border:1px solid rgba(255,255,255,0.02);\n      transform-origin:center;\n    }\n    .matrix .cell.inf{color:rgba(255,255,255,0.25);font-weight:500}\n    .matrix .cell.highlight{\n      transform:translateY(-6px) scale(1.04);\n      box-shadow: 0 18px 36px rgba(96,165,250,0.12);\n      background:linear-gradient(180deg, rgba(96,165,250,0.14), rgba(110,231,183,0.04));\n      color:#001b20;\n    }\n    .matrix .cell.updated{\n      animation:pop 520ms cubic-bezier(.2,.9,.2,1);\n      background: linear-gradient(180deg, rgba(110,231,183,0.14), rgba(90,200,240,0.05));\n      box-shadow: 0 26px 44px rgba(96,165,250,0.12);\n    }\n    @keyframes pop{\n      0%{transform:scale(1);opacity:0.25}\n      40%{transform:scale(1.08);opacity:1}\n      100%{transform:scale(1.02)}\n    }\n\n    .matrix-title{font-size:12px;color:var(--muted);margin-bottom:8px}\n\n    .controls{\n      display:flex;gap:10px;align-items:center;justify-content:center;margin-top:8px;\n    }\n    .btn{\n      padding:10px 14px;border-radius:12px;border:none;background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);\n      color:#dff9ef;font-weight:600;cursor:pointer;font-size:13px;\n      display:inline-flex;gap:10px;align-items:center;justify-content:center;\n      transition:all 200ms ease;border:1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 8px 28px rgba(5,8,18,0.45);\n    }\n    .btn.primary{\n      background:linear-gradient(90deg,var(--accent),var(--accent-2));\n      color:#042233;border:0;\n      box-shadow: 0 10px 30px rgba(96,165,250,0.12), 0 2px 0 rgba(255,255,255,0.04) inset;\n    }\n    .btn:active{transform:translateY(2px)}\n\n    /* k timeline */\n    .timeline{\n      display:flex;gap:10px;align-items:center;justify-content:center;padding:8px;\n    }\n    .k-node{\n      width:40px;height:40px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.012), transparent);\n      display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--muted);\n      border:1px solid rgba(255,255,255,0.02);transition:all 240ms ease;\n    }\n    .k-node.active{\n      background:linear-gradient(180deg,var(--accent),var(--accent-2));\n      color:#042233; transform:translateY(-6px) scale(1.06);\n      box-shadow: 0 18px 32px rgba(96,165,250,0.12);\n    }\n\n    .legend{display:flex;gap:12px;align-items:center;justify-content:flex-end;color:var(--muted);font-size:12px}\n    .legend .dot{width:10px;height:10px;border-radius:3px;background:var(--accent)}\n    .footer-note{font-size:12px;color:var(--muted);text-align:center;margin-top:4px}\n\n    /* small responsive */\n    @media (max-width:980px){\n      .frame{grid-template-columns:1fr; padding:18px}\n      .graph-area{height:440px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"frame\" role=\"application\" aria-label=\"Floyd-Warshall visualization\">\n    <div class=\"panel-graph\">\n      <div class=\"header\">\n        <div class=\"badge\">FW</div>\n        <div class=\"title\">\n          <h1>Floyd–Warshall — All Pairs Shortest Paths</h1>\n          <p>A graceful algorithmic ballet: dynamic relaxation across a matrix of distances.</p>\n        </div>\n      </div>\n\n      <div class=\"graph-area\">\n        <svg id=\"graph\" viewBox=\"0 0 1000 520\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"false\">\n          <defs>\n            <linearGradient id=\"g-edge\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#60A5FA\" stop-opacity=\"0.18\"/>\n              <stop offset=\"1\" stop-color=\"#6EE7B7\" stop-opacity=\"0.14\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-40%\" y=\"-40%\" width=\"180%\" height=\"180%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- decorative soft lights -->\n          <circle cx=\"150\" cy=\"80\" r=\"120\" fill=\"url(#g-edge)\" opacity=\"0.06\"/>\n          <circle cx=\"920\" cy=\"420\" r=\"160\" fill=\"#6ee7b7\" opacity=\"0.03\"/>\n\n          <!-- edges group -->\n          <g id=\"edges\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.6\" fill=\"none\"></g>\n\n          <!-- path highlight (dynamic shortest path) -->\n          <g id=\"path-highlight\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"6\" fill=\"none\" filter=\"url(#glow)\"></g>\n\n          <!-- weight labels -->\n          <g id=\"weights\"></g>\n\n          <!-- nodes -->\n          <g id=\"nodes\"></g>\n\n          <!-- overlay labels -->\n          <g id=\"overlay\"></g>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"panel-side\">\n      <div class=\"card explain\">\n        <h2>What you'll see</h2>\n        <p>Floyd–Warshall iteratively picks an intermediate vertex k and attempts to improve each pair distance (i, j) by routing through k: if dist[i][k] + dist[k][j] < dist[i][j], the matrix updates. Watch the matrix animate, the chosen k glow along the timeline, and the best path between the pair being evaluated pulse on the graph.</p>\n      </div>\n\n      <div class=\"card\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n          <div>\n            <div class=\"matrix-title\">Distance Matrix</div>\n            <div id=\"matrix\" class=\"matrix\" aria-hidden=\"false\"></div>\n          </div>\n          <div style=\"margin-left:12px\">\n            <div class=\"matrix-title\">Next Matrix</div>\n            <div id=\"nextmatrix\" class=\"matrix\" aria-hidden=\"false\"></div>\n          </div>\n        </div>\n\n        <div class=\"controls\" style=\"margin-top:16px;\">\n          <button id=\"playBtn\" class=\"btn primary\" title=\"Play / Pause\">\n            <span id=\"playIcon\">⏯︎</span>&nbsp;<span id=\"playLabel\">Pause</span>\n          </button>\n          <button id=\"resetBtn\" class=\"btn\" title=\"Reset to initial\">\n            Reset\n          </button>\n        </div>\n\n        <div class=\"timeline\" style=\"margin-top:14px;\">\n          <!-- k nodes will be injected -->\n        </div>\n        <div class=\"footer-note\">Current k highlighted; matrix cells pop when updated.</div>\n      </div>\n\n      <div class=\"card legend\" style=\"margin-top:auto\">\n        <div style=\"display:flex;flex-direction:column\">\n          <div style=\"font-weight:600;color:#eaf8ff\">Live status</div>\n          <div style=\"margin-top:6px;color:var(--muted)\">Auto-play on load; limited controls: Play/Pause and Reset.</div>\n        </div>\n        <div style=\"display:flex;flex-direction:column;align-items:flex-end\">\n          <div style=\"display:flex;gap:8px;align-items:center\"><div class=\"dot\" style=\"background:var(--accent)\"></div><div style=\"color:var(--muted)\">Updating</div></div>\n          <div style=\"font-size:11px;color:var(--muted);margin-top:8px\">Graph shows the current best path for the active (i → j) pair.</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(() => {\n  const INF = 9999;\n  const n = 6;\n\n  // Initial adjacency (symmetric = undirected)\n  const initial = [\n    [0, 7, INF, 5, INF, INF],\n    [7, 0, 8, 9, INF, 7],\n    [INF, 8, 0, INF, 5, INF],\n    [5, 9, INF, 0, 15, 6],\n    [INF, INF, 5, 15, 0, 8],\n    [INF, 7, INF, 6, 8, 0]\n  ];\n\n  // Node positions for aesthetics (circle-like)\n  const nodePos = [\n    {x:160,y:120},\n    {x:420,y:60},\n    {x:740,y:110},\n    {x:820,y:360},\n    {x:540,y:420},\n    {x:200,y:360},\n  ];\n\n  // Deep copy helpers\n  function cloneMatrix(m){ return m.map(r => r.slice()); }\n\n  // Build dist and next matrices\n  let dist = cloneMatrix(initial);\n  let next = Array.from({length:n}, (_,i) => Array.from({length:n}, (_,j) => {\n    if (initial[i][j] !== INF && i!==j) return j;\n    return null;\n  }));\n\n  // Steps queue (triples of k,i,j)\n  const steps = [];\n  for(let k=0;k<n;k++){\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        steps.push({k,i,j});\n      }\n    }\n  }\n\n  // DOM refs\n  const svg = document.getElementById('graph');\n  const edgesG = document.getElementById('edges');\n  const nodesG = document.getElementById('nodes');\n  const weightsG = document.getElementById('weights');\n  const pathG = document.getElementById('path-highlight');\n  const overlayG = document.getElementById('overlay');\n  const matrixEl = document.getElementById('matrix');\n  const nextMatrixEl = document.getElementById('nextmatrix');\n  const timelineEl = document.querySelector('.timeline');\n  const playBtn = document.getElementById('playBtn');\n  const playLabel = document.getElementById('playLabel');\n  const playIcon = document.getElementById('playIcon');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // For animation control\n  let running = true;\n  let stepIndex = 0;\n  let animTimer = null;\n  const stepDelay = 420; // ms per (i,j) check\n\n  // Draw base graph\n  function drawGraph() {\n    edgesG.innerHTML = '';\n    nodesG.innerHTML = '';\n    weightsG.innerHTML = '';\n\n    // Draw thin background edges\n    for(let i=0;i<n;i++){\n      for(let j=i+1;j<n;j++){\n        if (initial[i][j] !== INF && i!==j){\n          const p1 = nodePos[i], p2 = nodePos[j];\n          const dx = p2.x - p1.x;\n          const dy = p2.y - p1.y;\n          // compute slight curve control\n          const mx = (p1.x + p2.x)/2;\n          const my = (p1.y + p2.y)/2;\n          const cx = mx - dy*0.08;\n          const cy = my + dx*0.06;\n          const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n          path.setAttribute('d', `M ${p1.x} ${p1.y} Q ${cx} ${cy} ${p2.x} ${p2.y}`);\n          path.setAttribute('stroke', 'url(#g-edge)');\n          path.setAttribute('opacity','0.28');\n          path.setAttribute('stroke-width','3');\n          edgesG.appendChild(path);\n\n          // weight label (mid)\n          const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n          label.setAttribute('x', mx - dy*0.03);\n          label.setAttribute('y', my + dx*0.02);\n          label.setAttribute('font-size','14');\n          label.setAttribute('fill','#c9f5df');\n          label.setAttribute('opacity','0.85');\n          label.setAttribute('text-anchor','middle');\n          label.setAttribute('font-weight','600');\n          label.textContent = (initial[i][j]>=INF? '∞' : initial[i][j]);\n          weightsG.appendChild(label);\n        }\n      }\n    }\n\n    // Draw nodes\n    for(let i=0;i<n;i++){\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${nodePos[i].x}, ${nodePos[i].y})`);\n      const outer = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      outer.setAttribute('r','34');\n      outer.setAttribute('fill','rgba(255,255,255,0.02)');\n      outer.setAttribute('stroke','rgba(255,255,255,0.03)');\n      outer.setAttribute('stroke-width','1');\n      const node = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      node.setAttribute('r','26');\n      node.setAttribute('fill','url(#g-edge)');\n      node.setAttribute('stroke','#042233');\n      node.setAttribute('stroke-width','1.5');\n      node.style.transition = 'transform 240ms ease, filter 240ms ease';\n      const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n      label.setAttribute('y','6');\n      label.setAttribute('text-anchor','middle');\n      label.setAttribute('font-size','14');\n      label.setAttribute('font-weight','700');\n      label.setAttribute('fill','#042233');\n      label.textContent = String(i);\n      g.appendChild(outer);\n      g.appendChild(node);\n      g.appendChild(label);\n      g.classList.add('node-group');\n      g.setAttribute('data-node', String(i));\n      nodesG.appendChild(g);\n    }\n\n    // Decorative center glow overlay\n    const overlayCircle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    overlayCircle.setAttribute('cx','500');\n    overlayCircle.setAttribute('cy','260');\n    overlayCircle.setAttribute('r','240');\n    overlayCircle.setAttribute('fill','none');\n    overlayCircle.setAttribute('stroke','rgba(110,231,183,0.03)');\n    overlayCircle.setAttribute('stroke-width','1');\n    overlayG.appendChild(overlayCircle);\n  }\n\n  // Build matrix UI\n  function buildMatrixUI() {\n    matrixEl.innerHTML = '';\n    nextMatrixEl.innerHTML = '';\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        const c = document.createElement('div');\n        c.classList.add('cell');\n        c.setAttribute('data-i',i); c.setAttribute('data-j',j);\n        c.textContent = formatVal(dist[i][j]);\n        if (dist[i][j] >= INF) c.classList.add('inf');\n        matrixEl.appendChild(c);\n\n        const nx = document.createElement('div');\n        nx.classList.add('cell');\n        nx.setAttribute('data-i',i); nx.setAttribute('data-j',j);\n        nx.textContent = next[i][j] === null ? '-' : String(next[i][j]);\n        nx.style.color = 'rgba(255,255,255,0.45)';\n        nextMatrixEl.appendChild(nx);\n      }\n    }\n  }\n\n  function formatVal(v){ return v >= INF ? '∞' : String(v); }\n\n  // Update a single cell UI\n  function setCell(i,j,val, updated=false) {\n    const sel = `.cell[data-i=\"${i}\"][data-j=\"${j}\"]`;\n    const el = matrixEl.querySelector(sel);\n    if (!el) return;\n    el.textContent = formatVal(val);\n    if (val >= INF) el.classList.add('inf'); else el.classList.remove('inf');\n    if (updated) {\n      el.classList.add('updated');\n      setTimeout(()=> el.classList.remove('updated'), 700);\n    }\n  }\n  function setNextCell(i,j,v) {\n    const sel = `.cell[data-i=\"${i}\"][data-j=\"${j}\"]`;\n    const el = nextMatrixEl.querySelector(sel);\n    if (!el) return;\n    el.textContent = v === null ? '-' : String(v);\n  }\n\n  // Highlight row/col and k in matrix\n  function highlightCells(i,j,k,active=false) {\n    // clear all\n    matrixEl.querySelectorAll('.cell').forEach(c => c.classList.remove('highlight'));\n    // highlight row i and col j\n    matrixEl.querySelectorAll('.cell').forEach(c => {\n      const ci = +c.getAttribute('data-i'), cj = +c.getAttribute('data-j');\n      if (ci === i || cj === j) {\n        if (ci === i && cj === j && active) c.classList.add('highlight');\n        else c.style.opacity = active ? '0.94' : '0.72';\n      } else {\n        c.style.opacity = active ? '0.35' : '0.6';\n      }\n    });\n    // reset opacities after short time\n    if (!active) {\n      setTimeout(()=> {\n        matrixEl.querySelectorAll('.cell').forEach(c => c.style.opacity = '');\n      }, stepDelay - 60);\n    }\n  }\n\n  // Timeline UI: k nodes\n  function buildTimeline() {\n    timelineEl.innerHTML = '';\n    for(let k=0;k<n;k++){\n      const el = document.createElement('div');\n      el.classList.add('k-node');\n      el.textContent = k;\n      el.setAttribute('data-k',k);\n      timelineEl.appendChild(el);\n    }\n  }\n  function setActiveK(k) {\n    const nodes = timelineEl.querySelectorAll('.k-node');\n    nodes.forEach(n => n.classList.toggle('active', +n.getAttribute('data-k') === k));\n    // Slightly animate node on graph\n    const ng = nodesG.querySelector(`g[data-node=\"${k}\"]`);\n    if (ng) {\n      const circ = ng.querySelector('circle:nth-child(2)');\n      circ.style.transform = 'scale(1.09)';\n      circ.style.filter = 'blur(0.6px)';\n      setTimeout(()=> { circ.style.transform='scale(1)'; circ.style.filter=''; }, 420);\n    }\n  }\n\n  // Path reconstruction using next matrix\n  function pathFor(i,j) {\n    if (next[i][j] === null) return null;\n    const path = [i];\n    let cur = i;\n    while (cur !== j) {\n      cur = next[cur][j];\n      if (cur === null) return null;\n      path.push(cur);\n      if (path.length > n) break;\n    }\n    return path;\n  }\n\n  // Render highlighted path on the graph (glowing)\n  function drawPath(path) {\n    pathG.innerHTML = '';\n    if (!path || path.length < 2) return;\n    for(let s=0;s<path.length-1;s++){\n      const a = nodePos[path[s]], b = nodePos[path[s+1]];\n      const mx = (a.x+b.x)/2;\n      const my = (a.y+b.y)/2;\n      const dx = b.x - a.x;\n      const dy = b.y - a.y;\n      const cx = mx - dy*0.06;\n      const cy = my + dx*0.04;\n      const p = document.createElementNS('http://www.w3.org/2000/svg','path');\n      p.setAttribute('d', `M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`);\n      p.setAttribute('stroke', '#6EE7B7');\n      p.setAttribute('opacity','0.95');\n      p.setAttribute('stroke-linecap','round');\n      p.setAttribute('stroke-linejoin','round');\n      p.setAttribute('fill','none');\n      p.style.transition = 'stroke-dashoffset 420ms ease, opacity 360ms ease';\n      p.style.strokeDasharray = 400;\n      p.style.strokeDashoffset = 400;\n      pathG.appendChild(p);\n      // reveal stroke\n      setTimeout(()=> {\n        p.style.strokeDashoffset = 0;\n      }, 30 + s*60);\n    }\n  }\n\n  // Main stepper\n  function step() {\n    if (!running) return;\n    if (stepIndex >= steps.length) {\n      // finished\n      running = false;\n      playLabel.textContent = 'Play';\n      playIcon.textContent = '▶';\n      // final highlight\n      highlightCells(-1,-1,-1,false);\n      setActiveK(-1);\n      return;\n    }\n    const {k,i,j} = steps[stepIndex];\n    // Indicate active k at the start of its block\n    if (i===0 && j===0) setActiveK(k);\n\n    // highlight row/col and active cell\n    highlightCells(i,j,k,true);\n\n    // show path for current pair i->j\n    const currentPath = pathFor(i,j);\n    drawPath(currentPath);\n\n    // evaluate relaxation\n    const via = (dist[i][k] >= INF || dist[k][j] >= INF) ? INF : (dist[i][k] + dist[k][j]);\n    const before = dist[i][j];\n\n    // subtle flash if checking\n    const cellSel = `.cell[data-i=\"${i}\"][data-j=\"${j}\"]`;\n    const el = matrixEl.querySelector(cellSel);\n    if (el) {\n      el.style.boxShadow = '0 14px 34px rgba(96,165,250,0.09)';\n      setTimeout(()=> { el.style.boxShadow = ''; }, 300);\n    }\n\n    if (via < before) {\n      dist[i][j] = via;\n      next[i][j] = next[i][k];\n      setCell(i,j,via,true);\n      setNextCell(i,j,next[i][j]);\n    }\n    // schedule next step\n    stepIndex++;\n    animTimer = setTimeout(step, stepDelay);\n  }\n\n  // Play/Pause toggle\n  playBtn.addEventListener('click', () => {\n    running = !running;\n    if (running) {\n      playLabel.textContent = 'Pause';\n      playIcon.textContent = '⏯︎';\n      if (stepIndex >= steps.length) {\n        // If ended, restart from initial?\n        resetAll();\n      } else {\n        step();\n      }\n    } else {\n      playLabel.textContent = 'Play';\n      playIcon.textContent = '▶';\n      clearTimeout(animTimer);\n    }\n  });\n\n  // Reset handler\n  function resetAll() {\n    clearTimeout(animTimer);\n    dist = cloneMatrix(initial);\n    next = Array.from({length:n}, (_,i) => Array.from({length:n}, (_,j) => {\n      if (initial[i][j] !== INF && i!==j) return j;\n      return null;\n    }));\n    stepIndex = 0;\n    running = true;\n    buildMatrixUI();\n    buildTimeline();\n    drawGraph();\n    setActiveK(-1);\n    playLabel.textContent = 'Pause';\n    playIcon.textContent = '⏯︎';\n    // start stepping a heartbeat later for visual readiness\n    setTimeout(step, 420);\n  }\n\n  resetBtn.addEventListener('click', () => {\n    running = false;\n    playLabel.textContent = 'Play';\n    playIcon.textContent = '▶';\n    resetAll();\n  });\n\n  // Initial render\n  drawGraph();\n  buildMatrixUI();\n  buildTimeline();\n  // start animating automatically\n  setTimeout(() => { step(); }, 700);\n\n  // Extra: periodically highlight a \"featured pair\" text near top overlay\n  const overlayTxt = document.createElementNS('http://www.w3.org/2000/svg','text');\n  overlayTxt.setAttribute('x','60'); overlayTxt.setAttribute('y','28');\n  overlayTxt.setAttribute('font-size','13'); overlayTxt.setAttribute('fill','#bff7de');\n  overlayTxt.setAttribute('font-weight','600');\n  overlayTxt.textContent = 'Now checking pairs and evolving distances…';\n  overlayG.appendChild(overlayTxt);\n\n  // Accessibility: allow space to toggle play/pause\n  window.addEventListener('keydown',(e)=>{\n    if (e.code === 'Space') {\n      e.preventDefault();\n      playBtn.click();\n    } else if (e.key === 'r' || e.key === 'R') {\n      resetBtn.click();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
