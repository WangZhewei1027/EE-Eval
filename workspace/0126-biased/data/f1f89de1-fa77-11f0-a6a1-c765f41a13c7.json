    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Agile Methodology — Visual Demonstration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Poppins:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071226;\n    --accent-1: #6EE7B7; /* mint */\n    --accent-2: #60A5FA; /* sky */\n    --accent-3: #F472B6; /* pink */\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.7);\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.04);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    font-synthesis: none;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    height:100%;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(96,165,250,0.06), transparent 8%),\n                radial-gradient(900px 400px at 90% 90%, rgba(244,114,182,0.04), transparent 8%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color:#E6EEF8;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    overflow:hidden;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:36px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Ambient animated particles */\n  .ambient{\n    pointer-events:none;\n    position:fixed;\n    inset:0;\n    z-index:0;\n    overflow:hidden;\n  }\n  .orb{\n    position:absolute;\n    border-radius:999px;\n    filter:blur(28px);\n    mix-blend-mode:screen;\n    opacity:0.45;\n    animation: float 12s ease-in-out infinite;\n  }\n  .orb.o1{width:420px;height:420px;left:-5%;top:5%;background:linear-gradient(135deg,var(--accent-2),#7C3AED);}\n  .orb.o2{width:300px;height:300px;right:-8%;bottom:10%;background:linear-gradient(135deg,var(--accent-3),#FB923C);animation-duration:16s;opacity:0.35}\n  .orb.o3{width:220px;height:220px;left:40%;top:60%;background:linear-gradient(135deg,var(--accent-1),#34D399);animation-duration:18s;opacity:0.28}\n  @keyframes float{\n    0%{transform:translateY(0) scale(1)}\n    50%{transform:translateY(-28px) scale(1.04)}\n    100%{transform:translateY(0) scale(1)}\n  }\n\n  /* Main card */\n  .stage{\n    position:relative;\n    z-index:5;\n    width:min(1180px,96vw);\n    height:min(720px,86vh);\n    border-radius:20px;\n    padding:34px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(10px) saturate(120%);\n    border:1px solid rgba(255,255,255,0.03);\n    display:grid;\n    grid-template-columns: 1.08fr 1fr;\n    gap:28px;\n    overflow:hidden;\n  }\n\n  /* Header */\n  .header{\n    grid-column:1/-1;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:20px;\n    margin-bottom:6px;\n  }\n  .brand{\n    display:flex;\n    gap:14px;\n    align-items:center;\n  }\n  .logo{\n    width:64px;height:64px;border-radius:12px;\n    background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow: 0 8px 24px rgba(72,84,121,0.18), inset 0 -6px 18px rgba(255,255,255,0.06);\n  }\n  .logo svg{filter:drop-shadow(0 4px 18px rgba(8,22,56,0.36));}\n  .title{\n    line-height:1;\n  }\n  .title h1{font-family:Poppins, Inter; font-weight:700; font-size:20px; margin:0; letter-spacing:-0.4px}\n  .title p{margin:0; font-size:12px; color:var(--muted); opacity:0.95}\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--muted);\n    font-weight:600;\n    cursor:pointer;\n    transition:transform .22s ease, box-shadow .22s ease;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    font-size:13px;\n  }\n  .btn:active{transform:translateY(1px) scale(.997)}\n  .btn.primary{\n    background:linear-gradient(90deg,var(--accent-2),var(--accent-1));\n    color:#071226;\n    box-shadow: 0 10px 30px rgba(96,165,250,0.12);\n  }\n  .btn.ghost{\n    border:1px solid rgba(255,255,255,0.04);\n  }\n\n  /* Left panel - board */\n  .board{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    display:flex;\n    gap:12px;\n    box-shadow: 0 8px 24px rgba(6,10,20,0.5);\n    position:relative;\n    overflow:hidden;\n  }\n  .lane{\n    flex:1;\n    min-width:0;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  .lane-title{\n    font-weight:700; font-size:13px; color:var(--muted);\n    display:flex;align-items:center;gap:8px;\n  }\n  .lane .cards{\n    background:linear-gradient(180deg, rgba(255,255,255,0.015), transparent);\n    border-radius:12px;\n    padding:12px;\n    flex:1;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n    min-height:180px;\n  }\n  .card{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px;\n    padding:10px 12px;\n    box-shadow: 0 6px 18px rgba(5,10,20,0.35);\n    font-size:13px;\n    color: #ECF9F1;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:10px;\n    transform-origin:center;\n  }\n  .card .label{\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .pill{\n    padding:6px 8px;\n    border-radius:999px;\n    font-weight:700;\n    font-size:11px;\n  }\n  .pill.todo{background:rgba(96,165,250,0.14); color:var(--accent-2)}\n  .pill.doing{background:rgba(99,102,241,0.14); color:#8b5cf6}\n  .pill.done{background:rgba(110,231,183,0.14); color:var(--accent-1)}\n\n  /* animate cards across lanes to subtly show flow */\n  .card.move-a{animation: floatCard 10s linear infinite; animation-delay:0s}\n  .card.move-b{animation: floatCard 12s linear infinite; animation-delay:1.2s}\n  .card.move-c{animation: floatCard 9s linear infinite; animation-delay:0.6s}\n  @keyframes floatCard{\n    0%{transform:translateY(0) scale(1)}\n    25%{transform:translateY(-6px) scale(1.01)}\n    50%{transform:translateY(0) scale(1)}\n    75%{transform:translateY(6px) scale(.995)}\n    100%{transform:translateY(0) scale(1)}\n  }\n\n  /* Right panel - cycle */\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    box-shadow: 0 8px 24px rgba(6,10,20,0.5);\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:18px;\n    position:relative;\n    overflow:visible;\n  }\n\n  .sprint-loop{\n    width:320px; height:320px; display:grid;place-items:center;\n    position:relative;\n  }\n  .loop-svg{width:100%; height:100%}\n  /* rotating pointer */\n  .pointer{\n    position:absolute;\n    width:12px;\n    height:12px;\n    border-radius:50%;\n    background:var(--accent-3);\n    box-shadow: 0 8px 22px rgba(244,114,182,0.14),0 0 28px rgba(244,114,182,0.18);\n    transform-origin:160px 160px;\n    animation: spin 6.2s cubic-bezier(.2,.9,.2,1) infinite;\n  }\n  .pointer::after{\n    content:\"\";\n    position:absolute;\n    left:50%; top:50%;\n    transform:translate(-50%,-50%) scale(0.9);\n    width:100%;height:100%;\n    border-radius:50%;\n    background:linear-gradient(90deg,var(--accent-3),#FDE68A);\n    opacity:0.85;\n    filter:blur(6px);\n  }\n  @keyframes spin{\n    0%{transform:rotate(0deg) translateX(144px) scale(1)}\n    100%{transform:rotate(360deg) translateX(144px) scale(1)}\n  }\n\n  .loop-steps{\n    position:absolute;\n    inset:0;\n    display:grid;\n    grid-template-columns:repeat(3,1fr);\n    grid-template-rows:repeat(3,1fr);\n    pointer-events:none;\n    z-index:4;\n  }\n  .step{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-size:13px;\n    color:var(--muted);\n    font-weight:700;\n    opacity:0.95;\n  }\n  .step.plan{grid-area:1/2/2/3}\n  .step.dev{grid-area:2/3/3/4}\n  .step.review{grid-area:3/2/4/3}\n  .step.retro{grid-area:2/1/3/2}\n\n  /* progress rings */\n  .ring-wrap{position:relative; width:220px;height:220px; display:grid;place-items:center}\n  .ring{\n    position:absolute; width:220px; height:220px;\n    transform:rotate(-90deg);\n  }\n  .ring circle{fill:none; stroke-width:10; stroke-linecap:round}\n  .ring .bg{stroke:rgba(255,255,255,0.03)}\n  .ring .p1{stroke: url(#g1); stroke-dasharray:628; stroke-dashoffset:628; animation: dash1 5.8s linear infinite}\n  .ring .p2{stroke: url(#g2); stroke-dasharray:628; stroke-dashoffset:628; animation: dash2 7.2s linear infinite}\n  .ring .p3{stroke: url(#g3); stroke-dasharray:628; stroke-dashoffset:628; animation: dash3 6.6s linear infinite}\n  @keyframes dash1{0%{stroke-dashoffset:628}50%{stroke-dashoffset:160}100%{stroke-dashoffset:628}}\n  @keyframes dash2{0%{stroke-dashoffset:628}45%{stroke-dashoffset:80}100%{stroke-dashoffset:628}}\n  @keyframes dash3{0%{stroke-dashoffset:628}55%{stroke-dashoffset:240}100%{stroke-dashoffset:628}}\n\n  .panel h3{margin:0;font-family:Poppins;font-weight:700;letter-spacing:-0.6px}\n  .panel p{margin:0;color:var(--muted);font-size:13px;opacity:0.95}\n\n  /* subtle footer labels */\n  .meta{\n    margin-top:6px;\n    color:rgba(255,255,255,0.6);\n    font-size:12px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  /* Modal */\n  .modal{\n    position:fixed;\n    left:0;top:0;right:0;bottom:0;\n    background:linear-gradient(180deg,rgba(2,6,23,0.6),rgba(2,6,23,0.72));\n    display:grid;\n    place-items:center;\n    z-index:60;\n    opacity:0;\n    pointer-events:none;\n    transition:opacity .28s ease;\n  }\n  .modal.open{opacity:1;pointer-events:auto}\n  .modal-card{\n    width:min(720px,92vw);\n    background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));\n    border-radius:16px;\n    padding:24px;\n    box-shadow: 0 18px 50px rgba(3,8,23,0.7);\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .modal-card h2{margin:0 0 8px 0;font-family:Poppins;font-weight:700}\n  .principles{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:12px}\n  .principle{\n    background:var(--card);\n    padding:12px;border-radius:10px;font-size:13px;color:var(--muted);\n    box-shadow:inset 0 -6px 20px rgba(255,255,255,0.01);\n  }\n\n  /* Pause overlay hint */\n  .hint{\n    position:absolute; right:24px; bottom:22px; z-index:10;\n    background:linear-gradient(90deg,var(--accent-2),var(--accent-1));\n    color:#06202b; padding:10px 12px;border-radius:999px;\n    font-weight:700; font-size:13px;\n    box-shadow: 0 12px 30px rgba(96,165,250,0.12);\n  }\n\n  /* paused state - freeze animations elegantly */\n  .paused .orb,\n  .paused .card.move-a, .paused .card.move-b, .paused .card.move-c,\n  .paused .pointer,\n  .paused .ring .p1, .paused .ring .p2, .paused .ring .p3 {\n    animation-play-state:paused !important;\n  }\n  .paused .orb{opacity:0.18;transform:none !important}\n  .paused .pointer{opacity:0.75}\n  .paused .card{transform:none !important}\n  .paused .btn.primary{filter:grayscale(.08) contrast(.95)}\n  .paused .hint{opacity:0.85}\n\n  /* small screens */\n  @media (max-width:920px){\n    .stage{grid-template-columns:1fr; height:auto; padding:20px}\n    .header{flex-direction:column; align-items:flex-start; gap:10px}\n    .board{order:2}\n    .panel{order:1; width:100%}\n    .sprint-loop{width:260px;height:260px}\n  }\n\n  /* reduced motion preference */\n  @media (prefers-reduced-motion: reduce) {\n    .orb, .card.move-a, .card.move-b, .card.move-c, .pointer, .ring .p1, .ring .p2, .ring .p3 { animation: none !important; }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <div class=\"orb o1\"></div>\n    <div class=\"orb o2\"></div>\n    <div class=\"orb o3\"></div>\n  </div>\n\n  <main class=\"stage\" role=\"main\" aria-label=\"Agile methodology visual overview\">\n    <div class=\"header\" aria-hidden=\"false\">\n      <div class=\"brand\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <!-- stylized agile swirl -->\n          <svg width=\"38\" height=\"38\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"lgA\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#60A5FA\"/>\n                <stop offset=\"1\" stop-color=\"#6EE7B7\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M24 6c6.627 0 12 5.373 12 12 0 8-12 18-12 18S12 26 12 18c0-6.627 5.373-12 12-12z\" fill=\"url(#lgA)\"/>\n            <circle cx=\"34\" cy=\"16\" r=\"3.8\" fill=\"#FFFFFF\" opacity=\"0.9\"/>\n          </svg>\n        </div>\n        <div class=\"title\">\n          <h1>Agile Methodology</h1>\n          <p>Iterate • Collaborate • Deliver — A visual narrative</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n        <button class=\"btn ghost\" id=\"btnPrinciples\" aria-haspopup=\"dialog\" title=\"View Agile principles\">\n          <!-- Info icon -->\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\" style=\"opacity:.95\">\n            <path d=\"M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Z\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <path d=\"M12 8.8v.01M12 11v5\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n          Principles\n        </button>\n        <button class=\"btn primary\" id=\"btnPause\" title=\"Pause/Resume motion\" aria-pressed=\"false\">\n          <!-- Play/Pause icon will toggle -->\n          <svg id=\"iconPlay\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\" style=\"display:none\">\n            <path d=\"M5 3v18l15-9L5 3z\" fill=\"#06202b\"/>\n          </svg>\n          <svg id=\"iconPause\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"#06202b\"/>\n          </svg>\n          Pause Motion\n        </button>\n      </div>\n    </div>\n\n    <!-- Left: Board -->\n    <section class=\"board\" aria-label=\"Sample scrum board\">\n      <div class=\"lane\" aria-hidden=\"true\">\n        <div class=\"lane-title\">To Do</div>\n        <div class=\"cards\">\n          <div class=\"card move-a\">\n            <div class=\"label\"><div class=\"pill todo\">UX</div><div>Design landing hero</div></div>\n            <div style=\"opacity:.9;font-weight:700\">3d</div>\n          </div>\n          <div class=\"card move-b\">\n            <div class=\"label\"><div class=\"pill todo\">API</div><div>Define endpoints</div></div>\n            <div style=\"opacity:.9;font-weight:700\">2d</div>\n          </div>\n          <div class=\"card move-c\">\n            <div class=\"label\"><div class=\"pill todo\">QA</div><div>Write test cases</div></div>\n            <div style=\"opacity:.9;font-weight:700\">1d</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"lane\" aria-hidden=\"true\">\n        <div class=\"lane-title\">In Progress</div>\n        <div class=\"cards\">\n          <div class=\"card move-b\">\n            <div class=\"label\"><div class=\"pill doing\">FE</div><div>Implement header</div></div>\n            <div style=\"opacity:.9;font-weight:700\">1d</div>\n          </div>\n          <div class=\"card move-c\">\n            <div class=\"label\"><div class=\"pill doing\">DB</div><div>Schema changes</div></div>\n            <div style=\"opacity:.9;font-weight:700\">2d</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"lane\" aria-hidden=\"true\">\n        <div class=\"lane-title\">Done</div>\n        <div class=\"cards\">\n          <div class=\"card move-a\">\n            <div class=\"label\"><div class=\"pill done\">Docs</div><div>Readme update</div></div>\n            <div style=\"opacity:.9;font-weight:700\">—</div>\n          </div>\n          <div class=\"card move-b\">\n            <div class=\"label\"><div class=\"pill done\">CI</div><div>Pipeline set up</div></div>\n            <div style=\"opacity:.9;font-weight:700\">—</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Right: Sprint Loop -->\n    <aside class=\"panel\" aria-label=\"Sprint cycle visualization\">\n      <div style=\"display:flex;flex-direction:column;align-items:center;gap:8px\">\n        <h3>Sprint Cycle</h3>\n        <p style=\"color:var(--muted)\">A continuous loop of planning, building, reviewing and reflecting</p>\n      </div>\n\n      <div class=\"sprint-loop\" aria-hidden=\"true\">\n        <div class=\"ring-wrap\">\n          <svg class=\"ring\" viewBox=\"0 0 320 320\" role=\"img\" aria-label=\"Sprint progress rings\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#60A5FA\"/><stop offset=\"1\" stop-color=\"#6EE7B7\"/></linearGradient>\n              <linearGradient id=\"g2\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#F472B6\"/><stop offset=\"1\" stop-color=\"#FDE68A\"/></linearGradient>\n              <linearGradient id=\"g3\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#A78BFA\"/><stop offset=\"1\" stop-color=\"#60A5FA\"/></linearGradient>\n            </defs>\n            <circle class=\"bg\" cx=\"160\" cy=\"160\" r=\"100\"></circle>\n            <circle class=\"p1\" cx=\"160\" cy=\"160\" r=\"100\"></circle>\n            <circle class=\"p2\" cx=\"160\" cy=\"160\" r=\"82\"></circle>\n            <circle class=\"p3\" cx=\"160\" cy=\"160\" r=\"64\"></circle>\n          </svg>\n        </div>\n\n        <div class=\"loop-steps\" aria-hidden=\"true\">\n          <div class=\"step plan\">Plan</div>\n          <div class=\"step dev\">Develop</div>\n          <div class=\"step review\">Review</div>\n          <div class=\"step retro\">Retrospect</div>\n        </div>\n\n        <div class=\"pointer\" aria-hidden=\"true\" title=\"Sprint progress pointer\"></div>\n      </div>\n\n      <div class=\"meta\" aria-hidden=\"true\">\n        <div style=\"display:flex;align-items:center;gap:8px\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 13h4v8H3zM9 3h4v18H9zM15 7h4v14h-4z\" fill=\"#fff\" opacity=\"0.9\"/></svg>\n          <span style=\"opacity:.9\">Iterative improvements • Sprint cadence</span>\n        </div>\n      </div>\n\n    </aside>\n\n    <div class=\"hint\" aria-hidden=\"true\">Visual only — minimal controls</div>\n  </main>\n\n  <!-- Modal: Principles -->\n  <div class=\"modal\" id=\"modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modalTitle\" aria-hidden=\"true\">\n    <div class=\"modal-card\" role=\"document\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;gap:12px\">\n        <div>\n          <h2 id=\"modalTitle\">Agile Values & Principles</h2>\n          <p style=\"margin:0;color:var(--muted)\">A concise reference to guide iterative teams</p>\n        </div>\n        <div style=\"display:flex;gap:8px\">\n          <button class=\"btn ghost\" id=\"closeModal\" aria-label=\"Close principles\">Close</button>\n        </div>\n      </div>\n\n      <div class=\"principles\" style=\"margin-top:14px\">\n        <div class=\"principle\"><strong>Individuals & interactions</strong><div style=\"opacity:.85;margin-top:6px\">People over processes — collaborate often.</div></div>\n        <div class=\"principle\"><strong>Working software</strong><div style=\"opacity:.85;margin-top:6px\">Deliver incremental value frequently.</div></div>\n        <div class=\"principle\"><strong>Customer collaboration</strong><div style=\"opacity:.85;margin-top:6px\">Engage stakeholders continuously.</div></div>\n        <div class=\"principle\"><strong>Responding to change</strong><div style=\"opacity:.85;margin-top:6px\">Adapt plans based on feedback.</div></div>\n      </div>\n\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:18px\">\n        <div style=\"color:var(--muted);font-size:13px\">Core mindset: experiment, learn fast, adjust.</div>\n        <div style=\"display:flex;gap:8px\">\n          <button class=\"btn primary\" id=\"ackModal\">Acknowledge</button>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n  (function(){\n    const body = document.body;\n    const btnPause = document.getElementById('btnPause');\n    const btnPrinciples = document.getElementById('btnPrinciples');\n    const modal = document.getElementById('modal');\n    const closeModal = document.getElementById('closeModal');\n    const ackModal = document.getElementById('ackModal');\n\n    let paused = false;\n\n    // Toggle pause/resume motion\n    btnPause.addEventListener('click', () => {\n      paused = !paused;\n      body.classList.toggle('paused', paused);\n      btnPause.setAttribute('aria-pressed', String(paused));\n      // swap icons and text\n      document.getElementById('iconPause').style.display = paused ? 'none' : 'inline';\n      document.getElementById('iconPlay').style.display = paused ? 'inline' : 'none';\n      btnPause.querySelector('svg').style.marginRight = '4px';\n      btnPause.textContent = paused ? 'Resume Motion' : 'Pause Motion';\n      btnPause.prepend(paused ? document.getElementById('iconPlay') : document.getElementById('iconPause'));\n    });\n\n    // Modal controls (principles)\n    function openModal(){\n      modal.classList.add('open');\n      modal.setAttribute('aria-hidden','false');\n      // trap focus simply\n      closeModal.focus();\n    }\n    function closeModalFn(){\n      modal.classList.remove('open');\n      modal.setAttribute('aria-hidden','true');\n      btnPrinciples.focus();\n    }\n\n    btnPrinciples.addEventListener('click', openModal);\n    closeModal.addEventListener('click', closeModalFn);\n    ackModal.addEventListener('click', closeModalFn);\n\n    // close modal on escape\n    window.addEventListener('keydown', (e) => {\n      if(e.key === 'Escape' && modal.classList.contains('open')) closeModalFn();\n    });\n\n    // Initialize: small tasteful entry animation for overlayed panels (no heavy interactivity)\n    window.addEventListener('load', () => {\n      // subtle initial spark\n      setTimeout(()=> {\n        const stage = document.querySelector('.stage');\n        stage.style.transform = 'translateY(0)';\n      }, 200);\n    });\n\n    // Respect reduced motion: if user prefers reduced motion, ensure pause is no-op visually\n    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');\n    if(mq.matches){\n      btnPause.setAttribute('disabled', 'true');\n      btnPause.title = 'Animations are disabled in system preferences';\n      btnPause.style.opacity = '0.6';\n    }\n  })();\n</script>\n\n</body>\n</html>"
