  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Radix Sort Interactive Simulator</title>\n  <style>\n    /* Extremely minimal visual design: plain black text on white background */\n    html,body { margin: 8px; padding: 0; font-family: monospace; color: black; background: white; }\n    .section { margin-bottom: 12px; }\n    label { display: inline-block; min-width: 120px; }\n    input[type=\"text\"], input[type=\"number\"], select, textarea { font-family: monospace; }\n    textarea { width: 98%; height: 56px; }\n    button { margin: 2px; }\n    .row { margin-bottom: 6px; }\n    .buckets { white-space: pre; font-family: monospace; }\n    .panel { border: 1px solid #00000010; padding: 6px; margin-bottom: 6px; }\n    .small { font-size: 12px; }\n    .log { height: 160px; overflow: auto; border: 1px solid #ccc; padding: 4px; }\n    .history-list { height: 160px; overflow: auto; border: 1px solid #ccc; padding: 4px; }\n    .inline { display: inline-block; vertical-align: middle; }\n    /* keep visuals minimal; subtle borders only */\n  </style>\n</head>\n<body>\n  <h1>Radix Sort Interactive Simulator</h1>\n\n  <div class=\"section panel\" id=\"inputPanel\">\n    <div class=\"row\">\n      <label>Array (comma sep):</label>\n      <input type=\"text\" id=\"arrayInput\" size=\"80\" value=\"170,45,75,90,802,24,2,66\">\n      <button id=\"loadArrayBtn\">Load Array</button>\n      <button id=\"clearArrayBtn\">Clear</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Randomize:</label>\n      Size: <input type=\"number\" id=\"randSize\" value=\"8\" min=\"1\" style=\"width:60px\">\n      Min: <input type=\"number\" id=\"randMin\" value=\"0\" style=\"width:60px\">\n      Max: <input type=\"number\" id=\"randMax\" value=\"999\" style=\"width:80px\">\n      <button id=\"randBtn\">Randomize</button>\n      <label class=\"inline small\">Presets:</label>\n      <select id=\"presets\">\n        <option value=\"\">-- select preset --</option>\n        <option value=\"170,45,75,90,802,24,2,66\">Classic Example</option>\n        <option value=\"3,1,4,1,5,9,2,6,5,3,5\">Small Repeated</option>\n        <option value=\"1000,100,10,1,0\">Descending Magnitudes</option>\n        <option value=\"-5,-1,-3,2,0,1,-2\">Negatives Mixed</option>\n        <option value=\"255,128,64,32,16,8,4,2,1\">Powers of Two</option>\n      </select>\n    </div>\n\n    <div class=\"row\">\n      <label>Add value:</label>\n      <input type=\"text\" id=\"addValue\" size=\"10\">\n      <button id=\"addBtn\">Add</button>\n      <label style=\"min-width:80px;\">Remove index:</label>\n      <input type=\"number\" id=\"removeIndex\" style=\"width:60px\">\n      <button id=\"removeBtn\">Remove</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Edit current array:</label>\n      <button id=\"editCurrentBtn\">Edit Current State Array</button>\n      <button id=\"recomputeFromHereBtn\">Recompute From Here</button>\n    </div>\n\n  </div>\n\n  <div class=\"section panel\" id=\"settingsPanel\">\n    <div class=\"row\">\n      <label>Variant:</label>\n      <select id=\"variant\">\n        <option value=\"LSD\">LSD (Least Significant Digit)</option>\n        <option value=\"MSD\">MSD (Most Significant Digit)</option>\n      </select>\n\n      <label style=\"min-width:80px;\">Base (radix):</label>\n      <input type=\"number\" id=\"base\" value=\"10\" min=\"2\" max=\"36\" style=\"width:60px\">\n      <label style=\"min-width:80px;\">Mode:</label>\n      <select id=\"placementMode\">\n        <option value=\"buckets\">Bucket Append</option>\n        <option value=\"counting\">Counting-Stable</option>\n      </select>\n    </div>\n\n    <div class=\"row\">\n      <label>Max digits:</label>\n      <input type=\"number\" id=\"maxDigits\" value=\"auto\" style=\"width:80px\">\n      <label style=\"min-width:80px;\">Auto:</label>\n      <input type=\"checkbox\" id=\"autoDigits\" checked>\n      <label style=\"min-width:80px;\">Stable (force):</label>\n      <input type=\"checkbox\" id=\"forceStable\" checked>\n    </div>\n\n    <div class=\"row\">\n      <label>Handle negatives:</label>\n      <input type=\"checkbox\" id=\"handleNeg\" checked>\n      <label style=\"min-width:80px;\">Direction:</label>\n      <select id=\"direction\">\n        <option value=\"asc\">Ascending</option>\n        <option value=\"desc\">Descending</option>\n      </select>\n      <label style=\"min-width:80px;\">Representation:</label>\n      <select id=\"repr\">\n        <option value=\"dec\">Decimal</option>\n        <option value=\"bin\">Binary</option>\n        <option value=\"hex\">Hex</option>\n      </select>\n    </div>\n\n    <div class=\"row\">\n      <label>Show details:</label>\n      <input type=\"checkbox\" id=\"showCounts\" checked>Counts\n      <input type=\"checkbox\" id=\"showLogs\" checked>Logs\n      <input type=\"checkbox\" id=\"showHistory\" checked>History\n    </div>\n  </div>\n\n  <div class=\"section panel\" id=\"simControl\">\n    <div class=\"row\">\n      <button id=\"buildBtn\">Build Full History</button>\n      <button id=\"playBtn\">Play</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"stepBackBtn\">Step Back</button>\n      <button id=\"stepForwardBtn\">Step Forward</button>\n      <button id=\"toStartBtn\">To Start</button>\n      <button id=\"toEndBtn\">To End</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Speed (ms):</label>\n      <input type=\"range\" id=\"speed\" min=\"50\" max=\"2000\" value=\"500\">\n      <span id=\"speedVal\">500</span>\n      <label style=\"min-width:80px;\">Auto-run:</label>\n      <input type=\"checkbox\" id=\"autorun\">\n      <label style=\"min-width:80px;\">Step index:</label>\n      <input type=\"number\" id=\"stepIndexInput\" style=\"width:80px\">\n      <button id=\"gotoStepBtn\">Go</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Bookmarks:</label>\n      <input type=\"text\" id=\"bookmarkName\" placeholder=\"name\">\n      <button id=\"addBookmarkBtn\">Add Bookmark</button>\n      <select id=\"bookmarksList\"></select>\n      <button id=\"gotoBookmarkBtn\">Go</button>\n      <button id=\"delBookmarkBtn\">Delete</button>\n    </div>\n  </div>\n\n  <div class=\"section panel\" id=\"statusPanel\">\n    <div class=\"row\">\n      <label>Current Step:</label>\n      <span id=\"currentStep\">0</span> / <span id=\"totalSteps\">0</span>\n      <label style=\"min-width:120px;\">Pass / Digit:</label>\n      <span id=\"currentPass\">-</span>\n      <label style=\"min-width:120px;\">Action:</label>\n      <span id=\"currentAction\">-</span>\n    </div>\n  </div>\n\n  <div class=\"section panel\" id=\"visualPanel\">\n    <div class=\"row\">\n      <label>Main array:</label>\n      <div id=\"mainArray\" class=\"inline\"></div>\n    </div>\n\n    <div class=\"row\">\n      <label>Buckets:</label>\n      <div id=\"buckets\" class=\"buckets\"></div>\n    </div>\n\n    <div class=\"row\" id=\"countsRow\">\n      <label>Counts / Prefix:</label>\n      <div id=\"counts\" class=\"inline\"></div>\n    </div>\n\n    <div class=\"row\">\n      <label>Digit extraction (per element):</label>\n      <div id=\"digitMap\" class=\"inline small\"></div>\n    </div>\n  </div>\n\n  <div class=\"section panel\" id=\"historyPanel\">\n    <div class=\"row\">\n      <label>History (click to jump):</label>\n      <div id=\"historyList\" class=\"history-list\"></div>\n    </div>\n\n    <div class=\"row\">\n      <label>Logs:</label>\n      <div id=\"logArea\" class=\"log\"></div>\n    </div>\n\n    <div class=\"row\">\n      <label>Export / Import History:</label>\n      <button id=\"exportBtn\">Export JSON</button>\n      <button id=\"importBtn\">Import JSON</button>\n      <textarea id=\"exportArea\" placeholder=\"history JSON appears here or paste JSON to import\"></textarea>\n      <div>\n        <button id=\"clearHistoryBtn\">Clear History</button>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Radix Sort Interactive Simulator\n    (function(){\n      // DOM refs\n      const arrayInput = document.getElementById('arrayInput');\n      const loadArrayBtn = document.getElementById('loadArrayBtn');\n      const clearArrayBtn = document.getElementById('clearArrayBtn');\n      const randBtn = document.getElementById('randBtn');\n      const randSize = document.getElementById('randSize');\n      const randMin = document.getElementById('randMin');\n      const randMax = document.getElementById('randMax');\n      const presets = document.getElementById('presets');\n      const addValue = document.getElementById('addValue');\n      const addBtn = document.getElementById('addBtn');\n      const removeIndex = document.getElementById('removeIndex');\n      const removeBtn = document.getElementById('removeBtn');\n      const editCurrentBtn = document.getElementById('editCurrentBtn');\n      const recomputeFromHereBtn = document.getElementById('recomputeFromHereBtn');\n\n      const variantSelect = document.getElementById('variant');\n      const baseInput = document.getElementById('base');\n      const placementMode = document.getElementById('placementMode');\n      const maxDigitsInput = document.getElementById('maxDigits');\n      const autoDigits = document.getElementById('autoDigits');\n      const forceStable = document.getElementById('forceStable');\n      const handleNeg = document.getElementById('handleNeg');\n      const directionSelect = document.getElementById('direction');\n      const reprSelect = document.getElementById('repr');\n      const showCounts = document.getElementById('showCounts');\n      const showLogs = document.getElementById('showLogs');\n      const showHistory = document.getElementById('showHistory');\n\n      const buildBtn = document.getElementById('buildBtn');\n      const playBtn = document.getElementById('playBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const stepBackBtn = document.getElementById('stepBackBtn');\n      const stepForwardBtn = document.getElementById('stepForwardBtn');\n      const toStartBtn = document.getElementById('toStartBtn');\n      const toEndBtn = document.getElementById('toEndBtn');\n      const speed = document.getElementById('speed');\n      const speedVal = document.getElementById('speedVal');\n      const autorun = document.getElementById('autorun');\n      const stepIndexInput = document.getElementById('stepIndexInput');\n      const gotoStepBtn = document.getElementById('gotoStepBtn');\n\n      const addBookmarkBtn = document.getElementById('addBookmarkBtn');\n      const bookmarkName = document.getElementById('bookmarkName');\n      const bookmarksList = document.getElementById('bookmarksList');\n      const gotoBookmarkBtn = document.getElementById('gotoBookmarkBtn');\n      const delBookmarkBtn = document.getElementById('delBookmarkBtn');\n\n      const currentStepSpan = document.getElementById('currentStep');\n      const totalStepsSpan = document.getElementById('totalSteps');\n      const currentPassSpan = document.getElementById('currentPass');\n      const currentActionSpan = document.getElementById('currentAction');\n\n      const mainArrayDiv = document.getElementById('mainArray');\n      const bucketsDiv = document.getElementById('buckets');\n      const countsDiv = document.getElementById('counts');\n      const digitMapDiv = document.getElementById('digitMap');\n\n      const historyListDiv = document.getElementById('historyList');\n      const logArea = document.getElementById('logArea');\n\n      const exportBtn = document.getElementById('exportBtn');\n      const importBtn = document.getElementById('importBtn');\n      const exportArea = document.getElementById('exportArea');\n      const clearHistoryBtn = document.getElementById('clearHistoryBtn');\n\n      // State\n      let workingArray = []; // base array\n      let history = []; // array of state snapshots\n      let currentIndex = 0;\n      let playTimer = null;\n      let bookmarks = {};\n      speedVal.textContent = speed.value;\n\n      // Utility helpers\n      function parseArrayString(s){\n        if(!s || !s.trim()) return [];\n        return s.split(',').map(x=>x.trim()).filter(x=>x.length>0).map(x=>{\n          const n = Number(x);\n          return Number.isFinite(n) ? n : parseInt(x, 10) || 0;\n        });\n      }\n\n      function snapshot(state){ // deep snapshot helper\n        return JSON.parse(JSON.stringify(state));\n      }\n\n      function formatValue(v){\n        const repr = reprSelect.value;\n        if(repr === 'dec') return String(v);\n        if(repr === 'bin') return '0b' + (v>>>0).toString(2);\n        if(repr === 'hex') return '0x' + (v>>>0).toString(16).toUpperCase();\n        return String(v);\n      }\n\n      // Digit extraction dealing with negatives via offset\n      function computeOffsetIfNeeded(arr, useNeg){\n        if(!useNeg) return 0;\n        const min = arr.reduce((m,x)=>Math.min(m,x), Infinity);\n        return (min < 0) ? -min : 0;\n      }\n\n      function getDigit(value, pos, base, offset){\n        let v = value + (offset||0);\n        v = Math.abs(v);\n        const d = Math.floor(v / Math.pow(base, pos)) % base;\n        return Math.floor(d);\n      }\n\n      function maxDigitsForArray(arr, base, offset){\n        const mx = arr.reduce((m,x)=>Math.max(m, Math.abs(x + (offset||0))), 0);\n        if(mx === 0) return 1;\n        return Math.floor(Math.log(mx) / Math.log(base)) + 1;\n      }\n\n      // History builder for LSD with options of bucket append or counting-stable\n      function buildHistoryFromArray(arr, options){\n        // options: {variant, base, maxDigits, autoDigits, placementMode, direction, stable, handleNeg}\n        const states = [];\n        const base = options.base;\n        const variant = options.variant;\n        const placementMode = options.placementMode;\n        const direction = options.direction;\n        const stableForced = options.stable;\n        const handleNeg = options.handleNeg;\n        // compute offset for negatives\n        const offset = computeOffsetIfNeeded(arr, handleNeg);\n        const working = arr.slice();\n        const maxDigits = options.autoDigits ? maxDigitsForArray(working, base, offset) : Math.max(1, options.maxDigits);\n\n        // Add initial state\n        states.push(snapshot({\n          pass: -1,\n          digitPos: -1,\n          array: working.slice(),\n          buckets: null,\n          counts: null,\n          action: 'Initial array',\n          variant,\n          base,\n          offset\n        }));\n\n        if(variant === 'LSD'){\n          for(let digitPos=0; digitPos<maxDigits; digitPos++){\n            // start pass\n            let buckets = new Array(base);\n            for(let i=0;i<base;i++) buckets[i]=[];\n            states.push(snapshot({\n              pass: digitPos,\n              digitPos,\n              array: working.slice(),\n              buckets: buckets.map(b=>b.slice()),\n              counts: null,\n              action: 'Start pass ' + digitPos + ' (LSD)',\n              variant,\n              base,\n              offset\n            }));\n            if(placementMode === 'buckets'){\n              // place each element into bucket with per-element steps\n              for(let i=0;i<working.length;i++){\n                const val = working[i];\n                const d = getDigit(val, digitPos, base, offset);\n                states.push(snapshot({\n                  pass: digitPos,\n                  digitPos,\n                  array: working.slice(),\n                  buckets: buckets.map(b=>b.slice()),\n                  counts: null,\n                  action: `Taking element index ${i} value ${val} -> digit ${d}`,\n                  highlight: {index:i, bucket:d},\n                  variant,\n                  base,\n                  offset\n                }));\n                buckets[d].push(val);\n                states.push(snapshot({\n                  pass: digitPos,\n                  digitPos,\n                  array: working.slice(),\n                  buckets: buckets.map(b=>b.slice()),\n                  counts: null,\n                  action: `Placed ${val} into bucket ${d}`,\n                  highlight: {index:i, bucket:d},\n                  variant,\n                  base,\n                  offset\n                }));\n              }\n              // Flatten buckets with per-extraction steps\n              const old = working.slice();\n              const newArr = [];\n              const bucketOrder = (direction === 'asc') ? [...Array(base).keys()] : [...Array(base).keys()].reverse();\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: old.slice(),\n                buckets: buckets.map(b=>b.slice()),\n                counts: null,\n                action: `Flattening buckets (order: ${bucketOrder.join(',')})`,\n                variant, base, offset\n              }));\n              for(const bIdx of bucketOrder){\n                while(buckets[bIdx].length>0){\n                  const v = buckets[bIdx].shift();\n                  newArr.push(v);\n                  states.push(snapshot({\n                    pass: digitPos,\n                    digitPos,\n                    array: old.slice(), // keep old until after flatten finishes? show many micro-steps with new output as a separate field\n                    buckets: buckets.map(b=>b.slice()),\n                    counts: null,\n                    outputBuilding: newArr.slice(),\n                    action: `Moved ${v} from bucket ${bIdx} to output`,\n                    variant, base, offset\n                  }));\n                }\n              }\n              // update working\n              working.length = 0;\n              newArr.forEach(x=>working.push(x));\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: working.slice(),\n                buckets: buckets.map(b=>b.slice()),\n                counts: null,\n                action: `After pass ${digitPos}, array = [${working.join(', ')}]`,\n                variant, base, offset\n              }));\n            } else if(placementMode === 'counting'){\n              // Counting-stable approach (typical stable LSD)\n              const counts = new Array(base).fill(0);\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: working.slice(),\n                buckets: null,\n                counts: counts.slice(),\n                action: 'Counting digits',\n                variant, base, offset\n              }));\n              // count digits\n              for(let i=0;i<working.length;i++){\n                const v = working[i];\n                const d = getDigit(v, digitPos, base, offset);\n                counts[d]++;\n                states.push(snapshot({\n                  pass: digitPos,\n                  digitPos,\n                  array: working.slice(),\n                  buckets: null,\n                  counts: counts.slice(),\n                  action: `Counted digit ${d} from element ${v} (counts updated)`,\n                  highlight: {index:i, bucket:d},\n                  variant, base, offset\n                }));\n              }\n              // prefix sums\n              const prefix = counts.slice();\n              for(let i=1;i<prefix.length;i++) prefix[i]+=prefix[i-1];\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: working.slice(),\n                buckets: null,\n                counts: prefix.slice(),\n                action: 'Prefix sums computed',\n                variant, base, offset\n              }));\n              // build output by iterating original array in reverse for stability\n              const output = new Array(working.length);\n              for(let i=working.length-1;i>=0;i--){\n                const v = working[i];\n                const d = getDigit(v, digitPos, base, offset);\n                prefix[d]--;\n                const pos = prefix[d];\n                output[pos] = v;\n                states.push(snapshot({\n                  pass: digitPos,\n                  digitPos,\n                  array: working.slice(),\n                  buckets: null,\n                  counts: prefix.slice(),\n                  outputBuilding: output.slice(),\n                  action: `Placed ${v} at output[${pos}] using digit ${d}`,\n                  highlight: {index:i, bucket:d},\n                  variant, base, offset\n                }));\n              }\n              // finalize\n              working.length = 0;\n              output.forEach(x=>working.push(x));\n              if(direction === 'desc') working.reverse();\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: working.slice(),\n                buckets: null,\n                counts: null,\n                action: `After pass ${digitPos} (counting), array = [${working.join(', ')}]`,\n                variant, base, offset\n              }));\n            }\n          }\n          // final state\n          states.push(snapshot({\n            pass: maxDigits,\n            digitPos: maxDigits,\n            array: working.slice(),\n            buckets: null,\n            counts: null,\n            action: 'Completed LSD radix sort',\n            variant, base, offset\n          }));\n        } else if(variant === 'MSD'){\n          // MSD: recursive partitioning starting from highest digit\n          // We'll generate steps that show partitioning and then recursively sort buckets if necessary.\n          const maxd = maxDigits;\n          function msdRecursive(subArr, digitPos, pathPrefix){\n            // subArr is array, digitPos is current digit (starting from maxd-1 down to 0)\n            const startState = {\n              pass: digitPos,\n              digitPos,\n              array: null,\n              buckets: null,\n              counts: null,\n              action: `MSD partition at digit ${digitPos} for segment ${pathPrefix}`,\n              variant, base, offset\n            };\n            // create buckets\n            const buckets = new Array(base);\n            for(let i=0;i<base;i++) buckets[i]=[];\n            // put items into buckets (per-element steps)\n            for(let i=0;i<subArr.length;i++){\n              const v = subArr[i];\n              const d = getDigit(v, digitPos, base, offset);\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: null,\n                buckets: buckets.map(b=>b.slice()),\n                counts: null,\n                action: `${pathPrefix}: taking ${v} -> digit ${d}`,\n                highlight: {value:v, bucket:d},\n                variant, base, offset\n              }));\n              buckets[d].push(v);\n              states.push(snapshot({\n                pass: digitPos,\n                digitPos,\n                array: null,\n                buckets: buckets.map(b=>b.slice()),\n                counts: null,\n                action: `${pathPrefix}: placed ${v} into bucket ${d}`,\n                variant, base, offset\n              }));\n            }\n            // record partition completion\n            states.push(snapshot({\n              pass: digitPos,\n              digitPos,\n              array: null,\n              buckets: buckets.map(b=>b.slice()),\n              counts: null,\n              action: `${pathPrefix}: partitioned into ${buckets.map(b=>b.length).join(',')}`,\n              variant, base, offset\n            }));\n            // recursively sort each non-empty bucket if digitPos > 0\n            let rebuilt = [];\n            const bucketOrder = (direction === 'asc') ? [...Array(base).keys()] : [...Array(base).keys()].reverse();\n            for(const bIdx of bucketOrder){\n              const bucket = buckets[bIdx];\n              if(bucket.length>1 && digitPos>0){\n                states.push(snapshot({\n                  pass: digitPos,\n                  digitPos,\n                  array: null,\n                  buckets: buckets.map(b=>b.slice()),\n                  counts: null,\n                  action: `${pathPrefix}: descending into bucket ${bIdx} (size ${bucket.length})`,\n                  variant, base, offset\n                }));\n                const sortedBucket = msdRecursive(bucket, digitPos-1, pathPrefix + '['+bIdx+']');\n                // sortedBucket is array\n                rebuilt = rebuilt.concat(sortedBucket);\n              } else {\n                // no recursion needed, append as-is\n                rebuilt = rebuilt.concat(bucket);\n              }\n            }\n            // after combining buckets\n            states.push(snapshot({\n              pass: digitPos,\n              digitPos,\n              array: rebuilt.slice(),\n              buckets: buckets.map(b=>b.slice()),\n              counts: null,\n              action: `${pathPrefix}: after combining buckets at digit ${digitPos}`,\n              variant, base, offset\n            }));\n            return rebuilt;\n          }\n\n          // Kick off MSD by creating an initial bucket partition at highest digit\n          const initialMax = maxDigits - 1;\n          // record initial pass\n          states.push(snapshot({\n            pass: initialMax,\n            digitPos: initialMax,\n            array: arr.slice(),\n            buckets: null,\n            counts: null,\n            action: `Start MSD with highest digit ${initialMax}`,\n            variant, base, offset\n          }));\n          // run recursive\n          const sorted = msdRecursive(arr.slice(), initialMax, 'root');\n          states.push(snapshot({\n            pass: -999,\n            digitPos: -999,\n            array: sorted.slice(),\n            buckets: null,\n            counts: null,\n            action: 'Completed MSD radix sort',\n            variant, base, offset\n          }));\n        }\n\n        return states;\n      }\n\n      // Rendering functions\n      function renderCurrent(){\n        const total = history.length;\n        if(total === 0){\n          currentIndex = 0;\n          currentStepSpan.textContent = '0';\n          totalStepsSpan.textContent = '0';\n          mainArrayDiv.textContent = '';\n          bucketsDiv.textContent = '';\n          countsDiv.textContent = '';\n          digitMapDiv.textContent = '';\n          currentPassSpan.textContent = '-';\n          currentActionSpan.textContent = '-';\n          historyListDiv.innerHTML = '';\n          logArea.textContent = '';\n          return;\n        }\n        if(currentIndex < 0) currentIndex = 0;\n        if(currentIndex >= total) currentIndex = total - 1;\n        const st = history[currentIndex];\n        currentStepSpan.textContent = currentIndex;\n        totalStepsSpan.textContent = total - 1;\n        currentPassSpan.textContent = (typeof st.pass === 'number' ? st.pass : '-');\n        currentActionSpan.textContent = st.action || '-';\n        // main array display\n        const arr = st.array || (st.outputBuilding ? st.outputBuilding : null) || [];\n        const arrDisplay = (arr && arr.length>0) ? arr.map((v,i)=>`[${i}]: ${formatValue(v)}`).join('  ') : '(empty)';\n        mainArrayDiv.textContent = arrDisplay;\n        // buckets\n        if(st.buckets && Array.isArray(st.buckets)){\n          const bucketLines = st.buckets.map((b,i)=>`${i}: [${b.map(x=>formatValue(x)).join(', ')}]`);\n          bucketsDiv.textContent = bucketLines.join('\\n');\n        } else {\n          bucketsDiv.textContent = '(none)';\n        }\n        // counts\n        if(showCounts.checked && st.counts){\n          countsDiv.textContent = '[' + st.counts.join(', ') + ']';\n        } else {\n          countsDiv.textContent = '';\n        }\n        // digit map for current array and digitPos\n        if(st.array && typeof st.digitPos === 'number' && st.digitPos >= 0 && st.base){\n          const dm = st.array.map(v=>`${formatValue(v)}->${getDigit(v, st.digitPos, st.base, st.offset)}`).join('  ');\n          digitMapDiv.textContent = dm;\n        } else if(st.array){\n          // show digits for next possible digit pos 0\n          const dm = st.array.map(v=>`${formatValue(v)}`).join('  ');\n          digitMapDiv.textContent = dm;\n        } else digitMapDiv.textContent = '';\n\n        // logs\n        if(showLogs.checked){\n          // show a small amount of log: present action list up to current step\n          logArea.textContent = history.slice(0, currentIndex+1).map((s,i)=>`${i}: ${s.action}`).join('\\n');\n        } else {\n          logArea.textContent = '';\n        }\n\n        // history list clickable\n        if(showHistory.checked){\n          historyListDiv.innerHTML = '';\n          history.forEach((s,i)=>{\n            const el = document.createElement('div');\n            el.textContent = `${i}: ${s.action}`;\n            el.style.cursor = 'pointer';\n            el.onclick = ()=>{ currentIndex = i; renderCurrent(); pause(); };\n            if(i === currentIndex) el.style.fontWeight = 'bold';\n            historyListDiv.appendChild(el);\n          });\n        } else {\n          historyListDiv.innerHTML = '';\n        }\n        stepIndexInput.value = currentIndex;\n      }\n\n      function buildAndRender(){\n        // parse current input into workingArray\n        workingArray = parseArrayString(arrayInput.value);\n        const options = {\n          variant: variantSelect.value,\n          base: Math.max(2, Math.min(36, parseInt(baseInput.value) || 10)),\n          placementMode: placementMode.value,\n          direction: directionSelect.value,\n          autoDigits: autoDigits.checked,\n          maxDigits: (autoDigits.checked ? 0 : Math.max(1, parseInt(maxDigitsInput.value) || 1)),\n          stable: forceStable.checked,\n          handleNeg: handleNeg.checked\n        };\n        history = buildHistoryFromArray(workingArray, options);\n        currentIndex = 0;\n        renderCurrent();\n      }\n\n      // Controls actions\n      loadArrayBtn.addEventListener('click', ()=>{ workingArray = parseArrayString(arrayInput.value); buildAndRender(); });\n      clearArrayBtn.addEventListener('click', ()=>{ arrayInput.value=''; workingArray=[]; buildAndRender(); });\n      presets.addEventListener('change', ()=>{\n        if(presets.value) arrayInput.value = presets.value;\n      });\n      randBtn.addEventListener('click', ()=>{\n        const size = Math.max(1, parseInt(randSize.value) || 8);\n        const min = parseInt(randMin.value) || 0;\n        const max = parseInt(randMax.value) || (min+100);\n        const arr = [];\n        for(let i=0;i<size;i++){\n          const r = Math.floor(Math.random()*(max-min+1))+min;\n          // include some negatives randomly\n          if(handleNeg.checked && Math.random()<0.15) arr.push(r * -1);\n          else arr.push(r);\n        }\n        arrayInput.value = arr.join(', ');\n        workingArray = arr.slice();\n        buildAndRender();\n      });\n\n      addBtn.addEventListener('click', ()=>{\n        const v = addValue.value.trim();\n        if(!v) return;\n        const n = Number(v);\n        if(!isNaN(n)) workingArray.push(n);\n        else workingArray.push(parseInt(v,10) || 0);\n        arrayInput.value = workingArray.join(', ');\n        buildAndRender();\n      });\n\n      removeBtn.addEventListener('click', ()=>{\n        const idx = parseInt(removeIndex.value);\n        if(!Number.isFinite(idx)) return;\n        if(idx<0 || idx>=workingArray.length) return;\n        workingArray.splice(idx,1);\n        arrayInput.value = workingArray.join(', ');\n        buildAndRender();\n      });\n\n      editCurrentBtn.addEventListener('click', ()=>{\n        if(history.length === 0) return;\n        const st = history[currentIndex];\n        const arr = st.array || [];\n        const newStr = prompt('Edit the array at current state (comma-separated). Note: changes only affect subsequent recomputation if you choose \"Recompute From Here\".', arr.join(', '));\n        if(newStr === null) return;\n        try {\n          const newArr = parseArrayString(newStr);\n          // place edited snapshot into current state array for visual editing only\n          history[currentIndex].array = newArr.slice();\n          // show editing but not recompute automatically\n          renderCurrent();\n        } catch(e){\n          alert('Invalid input');\n        }\n      });\n\n      recomputeFromHereBtn.addEventListener('click', ()=>{\n        if(history.length === 0) return;\n        // Ask whether to recompute full history from this state using its array snapshot\n        const st = history[currentIndex];\n        const arr = st.array || [];\n        const should = confirm('Recompute full history from this state array and current settings? This will discard history and rebuild from this array.');\n        if(!should) return;\n        arrayInput.value = arr.join(', ');\n        workingArray = arr.slice();\n        buildAndRender();\n      });\n\n      buildBtn.addEventListener('click', ()=>{\n        buildAndRender();\n      });\n\n      // Playback controls\n      function play(){\n        if(history.length === 0) return;\n        if(playTimer) clearInterval(playTimer);\n        playTimer = setInterval(()=>{\n          currentIndex++;\n          if(currentIndex >= history.length){\n            clearInterval(playTimer);\n            playTimer = null;\n            return;\n          }\n          renderCurrent();\n        }, parseInt(speed.value));\n      }\n      function pause(){\n        if(playTimer) clearInterval(playTimer);\n        playTimer = null;\n      }\n      playBtn.addEventListener('click', ()=>{ play(); });\n      pauseBtn.addEventListener('click', ()=>{ pause(); });\n\n      stepForwardBtn.addEventListener('click', ()=>{\n        if(currentIndex < history.length-1) currentIndex++;\n        renderCurrent();\n      });\n      stepBackBtn.addEventListener('click', ()=>{\n        if(currentIndex > 0) currentIndex--;\n        renderCurrent();\n      });\n      toStartBtn.addEventListener('click', ()=>{\n        currentIndex = 0;\n        renderCurrent();\n      });\n      toEndBtn.addEventListener('click', ()=>{\n        currentIndex = Math.max(0, history.length-1);\n        renderCurrent();\n      });\n\n      speed.addEventListener('input', ()=>{\n        speedVal.textContent = speed.value;\n        if(playTimer){\n          // restart timer with new speed\n          pause();\n          play();\n        }\n      });\n\n      gotoStepBtn.addEventListener('click', ()=>{\n        const idx = parseInt(stepIndexInput.value);\n        if(Number.isFinite(idx) && idx>=0 && idx<history.length){\n          currentIndex = idx;\n          renderCurrent();\n        }\n      });\n\n      // Bookmarks\n      addBookmarkBtn.addEventListener('click', ()=>{\n        const name = bookmarkName.value.trim() || ('bm' + Date.now());\n        bookmarks[name] = currentIndex;\n        refreshBookmarksUI();\n      });\n      gotoBookmarkBtn.addEventListener('click', ()=>{\n        const nm = bookmarksList.value;\n        if(!nm) return;\n        const idx = bookmarks[nm];\n        if(Number.isFinite(idx)) currentIndex = idx;\n        renderCurrent();\n      });\n      delBookmarkBtn.addEventListener('click', ()=>{\n        const nm = bookmarksList.value;\n        if(!nm) return;\n        delete bookmarks[nm];\n        refreshBookmarksUI();\n      });\n      function refreshBookmarksUI(){\n        bookmarksList.innerHTML = '';\n        Object.keys(bookmarks).forEach(k=>{\n          const opt = document.createElement('option');\n          opt.value = k;\n          opt.textContent = k + ' -> ' + bookmarks[k];\n          bookmarksList.appendChild(opt);\n        });\n      }\n\n      // History export/import\n      exportBtn.addEventListener('click', ()=>{\n        exportArea.value = JSON.stringify(history);\n      });\n      importBtn.addEventListener('click', ()=>{\n        const txt = exportArea.value.trim();\n        if(!txt) return;\n        try {\n          const imported = JSON.parse(txt);\n          if(!Array.isArray(imported)) throw new Error('Invalid history JSON');\n          history = imported;\n          currentIndex = 0;\n          renderCurrent();\n        } catch(e){\n          alert('Import failed: ' + e.message);\n        }\n      });\n\n      clearHistoryBtn.addEventListener('click', ()=>{\n        history = [];\n        currentIndex = 0;\n        renderCurrent();\n      });\n\n      // Clicking on log lines jumps to that step\n      logArea.addEventListener('click', (ev)=>{\n        // try to parse clicked line number from caret position\n        const text = logArea.textContent;\n        const pos = logArea.selectionStart || 0;\n        // fallback: jump to next line index if cannot determine\n      });\n\n      // Initialize with default build\n      buildAndRender();\n\n      // Auto-run if set\n      autorun.addEventListener('change', ()=>{\n        if(autorun.checked) play();\n        else pause();\n      });\n\n      // Keyboard shortcuts (simple)\n      window.addEventListener('keydown', (ev)=>{\n        if(ev.key === 'ArrowRight') { stepForwardBtn.click(); ev.preventDefault(); }\n        else if(ev.key === 'ArrowLeft') { stepBackBtn.click(); ev.preventDefault(); }\n        else if(ev.key === ' ') { if(playTimer) pause(); else play(); ev.preventDefault(); }\n      });\n\n      // Basic input validation when settings change\n      baseInput.addEventListener('change', ()=>{ if(parseInt(baseInput.value)<2) baseInput.value = 2; });\n      maxDigitsInput.addEventListener('change', ()=>{ if(maxDigitsInput.value === '' || maxDigitsInput.value === 'auto') { autoDigits.checked = true; } });\n\n      // Re-render when toggling labels or options for immediate feedback (doesn't rebuild history)\n      [reprSelect, showCounts, showLogs, showHistory].forEach(el=>{\n        el.addEventListener('change', ()=>{ renderCurrent(); });\n      });\n\n    })();\n  </script>\n</body>\n</html>"
