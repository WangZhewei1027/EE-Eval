    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Array Interactive Demo</title>\n</head>\n<body>\n<h1>Array Interactive Demo</h1>\n\n<p>\nThis tool lets you create, modify, inspect, and manipulate an array with rich interactive controls. Experiment with element values, array size, built-in methods, and visualize intermediate states.\n</p>\n\n<hr />\n\n<!-- Array Creation -->\n<section>\n<h2>Create / Reset Array</h2>\n<label for=\"arraySizeInput\">Array Size (1 to 1000):</label>\n<input type=\"number\" id=\"arraySizeInput\" min=\"1\" max=\"1000\" value=\"5\" />\n<button id=\"createArrayBtn\">Create Empty Array</button>\n<button id=\"createRandomArrayBtn\">Create Random Array (0-99)</button>\n<button id=\"createSequenceArrayBtn\">Create Sequence Array (0 to n-1)</button>\n</section>\n\n<hr />\n\n<!-- Array Display and Edit -->\n<section>\n<h2>Array Contents</h2>\n<p>Modify elements directly. Empty cells are shown as empty.</p>\n<div id=\"arrayContainer\" style=\"display:flex;flex-wrap:wrap;max-width:100%;\"></div>\n<button id=\"addElementBtn\">Add Element to End</button>\n<button id=\"removeElementBtn\">Remove Last Element</button>\n<button id=\"clearArrayBtn\">Clear Array</button>\n</section>\n\n<hr />\n\n<!-- Element Advanced Editing -->\n<section>\n<h2>Edit Single Element</h2>\n<label for=\"editIndexInput\">Index (0-based):</label>\n<input type=\"number\" id=\"editIndexInput\" min=\"0\" value=\"0\" />\n<label for=\"editValueInput\">New Value (string/number):</label>\n<input type=\"text\" id=\"editValueInput\" />\n<button id=\"setElementBtn\">Set Element</button>\n<p id=\"editElementError\" style=\"color:red;\"></p>\n</section>\n\n<hr />\n\n<!-- Array Operations -->\n<section>\n<h2>Array Operations / Methods</h2>\n\n<!-- Push / Pop -->\n<h3>Push / Pop</h3>\n<label for=\"pushValueInput\">Value to Push:</label>\n<input type=\"text\" id=\"pushValueInput\" />\n<button id=\"pushBtn\">Push</button>\n<button id=\"popBtn\">Pop</button>\n<p id=\"pushPopResult\"></p>\n\n<!-- Shift / Unshift -->\n<h3>Shift / Unshift</h3>\n<label for=\"unshiftValueInput\">Value to Unshift:</label>\n<input type=\"text\" id=\"unshiftValueInput\" />\n<button id=\"unshiftBtn\">Unshift</button>\n<button id=\"shiftBtn\">Shift</button>\n<p id=\"shiftUnshiftResult\"></p>\n\n<!-- Splice -->\n<h3>Splice</h3>\n<label for=\"spliceStartInput\">Start Index:</label>\n<input type=\"number\" id=\"spliceStartInput\" min=\"0\" value=\"0\" />\n<label for=\"spliceDeleteCountInput\">Delete Count:</label>\n<input type=\"number\" id=\"spliceDeleteCountInput\" min=\"0\" value=\"0\" />\n<label for=\"spliceItemsInput\">Items to Insert (comma separated):</label>\n<input type=\"text\" id=\"spliceItemsInput\" placeholder=\"a,b,c\" />\n<button id=\"spliceBtn\">Splice</button>\n<p id=\"spliceResult\"></p>\n\n<!-- Slice -->\n<h3>Slice</h3>\n<label for=\"sliceStartInput\">Start Index:</label>\n<input type=\"number\" id=\"sliceStartInput\" min=\"0\" value=\"0\" />\n<label for=\"sliceEndInput\">End Index (exclusive):</label>\n<input type=\"number\" id=\"sliceEndInput\" min=\"0\" value=\"0\" />\n<button id=\"sliceBtn\">Slice</button>\n<p id=\"sliceResult\"></p>\n\n<!-- IndexOf / LastIndexOf -->\n<h3>IndexOf / LastIndexOf</h3>\n<label for=\"searchValueInput\">Value to Search:</label>\n<input type=\"text\" id=\"searchValueInput\" />\n<button id=\"indexOfBtn\">IndexOf</button>\n<button id=\"lastIndexOfBtn\">LastIndexOf</button>\n<p id=\"indexOfResult\"></p>\n\n<!-- Join -->\n<h3>Join</h3>\n<label for=\"joinSeparatorInput\">Separator:</label>\n<input type=\"text\" id=\"joinSeparatorInput\" value=\",\" />\n<button id=\"joinBtn\">Join</button>\n<p id=\"joinResult\"></p>\n\n<!-- Sort -->\n<h3>Sort</h3>\n<label for=\"sortTypeSelect\">Sort Type:</label>\n<select id=\"sortTypeSelect\">\n  <option value=\"default\">Default (toString, Unicode)</option>\n  <option value=\"numericAsc\">Numeric Ascending</option>\n  <option value=\"numericDesc\">Numeric Descending</option>\n  <option value=\"stringAsc\">String Ascending (locale)</option>\n  <option value=\"stringDesc\">String Descending (locale)</option>\n</select>\n<button id=\"sortBtn\">Sort</button>\n\n<!-- Reverse -->\n<button id=\"reverseBtn\">Reverse Array</button>\n\n<p id=\"sortReverseResult\"></p>\n</section>\n\n<hr />\n\n<!-- Map / Filter / Reduce -->\n<section>\n<h2>Functional Methods</h2>\n\n<!-- Map -->\n<h3>Map</h3>\n<label for=\"mapExpressionInput\">Mapping Function f(x):</label>\n<input type=\"text\" id=\"mapExpressionInput\" placeholder=\"e.g. x*2, x+'a', x.length\" style=\"width: 60%;\" />\n<button id=\"mapBtn\">Map</button>\n<p id=\"mapResult\"></p>\n\n<!-- Filter -->\n<h3>Filter</h3>\n<label for=\"filterExpressionInput\">Filter Function f(x): returns true/false</label>\n<input type=\"text\" id=\"filterExpressionInput\" placeholder=\"e.g. x > 5, x.includes('a')\" style=\"width: 60%;\" />\n<button id=\"filterBtn\">Filter</button>\n<p id=\"filterResult\"></p>\n\n<!-- Reduce -->\n<h3>Reduce</h3>\n<label for=\"reduceExpressionInput\">Reduce Function (acc, x):</label>\n<input type=\"text\" id=\"reduceExpressionInput\" placeholder=\"e.g. acc + x, acc.concat(x)\" style=\"width: 60%;\" />\n<label for=\"reduceInitialInput\">Initial Value (JSON):</label>\n<input type=\"text\" id=\"reduceInitialInput\" placeholder=\"e.g. 0, '[]', '{}'\" style=\"width: 40%;\" />\n<button id=\"reduceBtn\">Reduce</button>\n<p id=\"reduceResult\"></p>\n</section>\n\n<hr />\n\n<!-- Search / Filter / Find -->\n<section>\n<h2>Search & Find</h2>\n\n<!-- Find -->\n<label for=\"findExpressionInput\">Find Function f(x): returns true/false</label>\n<input type=\"text\" id=\"findExpressionInput\" placeholder=\"e.g. x > 10, x.startsWith('a')\" style=\"width: 60%;\" />\n<button id=\"findBtn\">Find</button>\n<p id=\"findResult\"></p>\n\n<!-- FindIndex -->\n<label for=\"findIndexExpressionInput\">FindIndex Function f(x): returns true/false</label>\n<input type=\"text\" id=\"findIndexExpressionInput\" placeholder=\"e.g. x === 'foo'\" style=\"width: 60%;\" />\n<button id=\"findIndexBtn\">FindIndex</button>\n<p id=\"findIndexResult\"></p>\n</section>\n\n<hr />\n\n<!-- Info / Debug -->\n<section>\n<h2>Array Info & JSON View</h2>\n<p>Current length: <span id=\"arrayLength\">0</span></p>\n<p>Current array JSON:</p>\n<textarea id=\"arrayJsonView\" rows=\"5\" cols=\"80\" readonly></textarea>\n<button id=\"copyJsonBtn\">Copy JSON to clipboard</button>\n</section>\n\n<script>\n// Core State\nlet array = [];\n\n// Utils\n\nfunction updateArrayLength() {\n  document.getElementById(\"arrayLength\").textContent = array.length;\n}\n\nfunction isIntegerString(s) {\n  return /^-?\\d+$/.test(s.trim());\n}\n\nfunction parseValue(val) {\n  // Try to parse number or boolean or leave string\n  let trimmed = val.trim();\n  if(trimmed === \"\") return \"\";\n  if(trimmed.toLowerCase() === \"true\") return true;\n  if(trimmed.toLowerCase() === \"false\") return false;\n  if(!isNaN(trimmed)) return Number(trimmed);\n  return trimmed;\n}\n\nfunction renderArray() {\n  const container = document.getElementById(\"arrayContainer\");\n  container.innerHTML = \"\";\n\n  for (let i = 0; i < array.length; i++) {\n    const input = document.createElement(\"input\");\n    input.type = \"text\";\n    input.value = array[i] === undefined ? \"\" : String(array[i]);\n    input.style.width = \"4em\";\n    input.style.margin = \"0 0.2em 0.2em 0\";\n    input.dataset.index = i;\n    input.title = `Index ${i}`;\n    input.addEventListener(\"change\", (e) => {\n      const idx = Number(e.target.dataset.index);\n      array[idx] = parseValue(e.target.value);\n      updateJsonView();\n      updateArrayLength();\n    });\n    container.appendChild(input);\n  }\n  updateArrayLength();\n  updateJsonView();\n}\n\nfunction updateJsonView() {\n  document.getElementById(\"arrayJsonView\").value = JSON.stringify(array, null, 2);\n}\n\n// Creation\n\ndocument.getElementById(\"createArrayBtn\").onclick = function () {\n  let n = Number(document.getElementById(\"arraySizeInput\").value);\n  if (n <= 0 || n > 1000 || !Number.isInteger(n)) {\n    alert(\"Array size must be an integer between 1 and 1000.\");\n    return;\n  }\n  array = new Array(n).fill(undefined);\n  renderArray();\n};\n\ndocument.getElementById(\"createRandomArrayBtn\").onclick = function () {\n  let n = Number(document.getElementById(\"arraySizeInput\").value);\n  if (n <= 0 || n > 1000 || !Number.isInteger(n)) {\n    alert(\"Array size must be an integer between 1 and 1000.\");\n    return;\n  }\n  array = [];\n  for (let i = 0; i < n; i++) {\n    array.push(Math.floor(Math.random() * 100));\n  }\n  renderArray();\n};\n\ndocument.getElementById(\"createSequenceArrayBtn\").onclick = function () {\n  let n = Number(document.getElementById(\"arraySizeInput\").value);\n  if (n <= 0 || n > 1000 || !Number.isInteger(n)) {\n    alert(\"Array size must be an integer between 1 and 1000.\");\n    return;\n  }\n  array = [];\n  for (let i = 0; i < n; i++) {\n    array.push(i);\n  }\n  renderArray();\n};\n\n// Add / Remove Elements\n\ndocument.getElementById(\"addElementBtn\").onclick = function () {\n  array.push(\"\");\n  renderArray();\n};\n\ndocument.getElementById(\"removeElementBtn\").onclick = function () {\n  if (array.length > 0) {\n    array.pop();\n    renderArray();\n  }\n};\n\ndocument.getElementById(\"clearArrayBtn\").onclick = function () {\n  array = [];\n  renderArray();\n};\n\n// Edit Single Element (by index)\n\ndocument.getElementById(\"setElementBtn\").onclick = function () {\n  const idx = Number(document.getElementById(\"editIndexInput\").value);\n  const val = document.getElementById(\"editValueInput\").value;\n  const errorP = document.getElementById(\"editElementError\");\n  errorP.textContent = \"\";\n  if (!Number.isInteger(idx) || idx < 0 || idx >= array.length) {\n    errorP.textContent = \"Invalid index.\";\n    return;\n  }\n  array[idx] = parseValue(val);\n  renderArray();\n  document.getElementById(\"editValueInput\").value = \"\";\n};\n\n// Push / Pop\n\ndocument.getElementById(\"pushBtn\").onclick = function () {\n  let val = document.getElementById(\"pushValueInput\").value;\n  val = parseValue(val);\n  array.push(val);\n  renderArray();\n  document.getElementById(\"pushPopResult\").textContent = `Pushed value: ${val}`;\n  document.getElementById(\"pushValueInput\").value = \"\";\n};\n\ndocument.getElementById(\"popBtn\").onclick = function () {\n  if (array.length === 0) {\n    document.getElementById(\"pushPopResult\").textContent = \"Array is empty.\";\n    return;\n  }\n  const popped = array.pop();\n  renderArray();\n  document.getElementById(\"pushPopResult\").textContent = `Popped value: ${popped}`;\n};\n\n// Shift / Unshift\n\ndocument.getElementById(\"unshiftBtn\").onclick = function () {\n  let val = document.getElementById(\"unshiftValueInput\").value;\n  val = parseValue(val);\n  array.unshift(val);\n  renderArray();\n  document.getElementById(\"shiftUnshiftResult\").textContent = `Unshifted value: ${val}`;\n  document.getElementById(\"unshiftValueInput\").value = \"\";\n};\n\ndocument.getElementById(\"shiftBtn\").onclick = function () {\n  if (array.length === 0) {\n    document.getElementById(\"shiftUnshiftResult\").textContent = \"Array is empty.\";\n    return;\n  }\n  let shifted = array.shift();\n  renderArray();\n  document.getElementById(\"shiftUnshiftResult\").textContent = `Shifted value: ${shifted}`;\n};\n\n// Splice\n\ndocument.getElementById(\"spliceBtn\").onclick = function () {\n  let start = Number(document.getElementById(\"spliceStartInput\").value);\n  let deleteCount = Number(document.getElementById(\"spliceDeleteCountInput\").value);\n  const itemsStr = document.getElementById(\"spliceItemsInput\").value;\n  if (!Number.isInteger(start) || start < 0) {\n    document.getElementById(\"spliceResult\").textContent = \"Invalid start index.\";\n    return;\n  }\n  if (!Number.isInteger(deleteCount) || deleteCount < 0) {\n    document.getElementById(\"spliceResult\").textContent = \"Invalid delete count.\";\n    return;\n  }\n  // Parse insert items\n  let insertItems = [];\n  if (itemsStr.trim() !== \"\") {\n    insertItems = itemsStr.split(\",\").map(s => parseValue(s));\n  }\n  // Clamp start\n  if (start > array.length) start = array.length; \n  let removed = array.splice(start, deleteCount, ...insertItems);\n  renderArray();\n  document.getElementById(\"spliceResult\").textContent = `Removed items: ${JSON.stringify(removed)}`;\n  document.getElementById(\"spliceItemsInput\").value = \"\";\n};\n\n// Slice\n\ndocument.getElementById(\"sliceBtn\").onclick = function () {\n  let start = Number(document.getElementById(\"sliceStartInput\").value);\n  let end = Number(document.getElementById(\"sliceEndInput\").value);\n  if (!Number.isInteger(start) || start < 0) {\n    document.getElementById(\"sliceResult\").textContent = \"Invalid slice start.\";\n    return;\n  }\n  if (!Number.isInteger(end) || end < 0) {\n    end = array.length; // default to length if invalid\n  }\n  let sliced = array.slice(start, end);\n  document.getElementById(\"sliceResult\").textContent = `Sliced array: ${JSON.stringify(sliced)}`;\n};\n\n// IndexOf / LastIndexOf\n\nfunction searchValueFromInput() {\n  return parseValue(document.getElementById(\"searchValueInput\").value);\n}\n\ndocument.getElementById(\"indexOfBtn\").onclick = function() {\n  let searchVal = searchValueFromInput();\n  let idx = array.indexOf(searchVal);\n  document.getElementById(\"indexOfResult\").textContent = `IndexOf ${JSON.stringify(searchVal)}: ${idx}`;\n};\n\ndocument.getElementById(\"lastIndexOfBtn\").onclick = function() {\n  let searchVal = searchValueFromInput();\n  let idx = array.lastIndexOf(searchVal);\n  document.getElementById(\"indexOfResult\").textContent = `LastIndexOf ${JSON.stringify(searchVal)}: ${idx}`;\n};\n\n// Join\n\ndocument.getElementById(\"joinBtn\").onclick = function() {\n  let sep = document.getElementById(\"joinSeparatorInput\").value;\n  let joined = array.join(sep);\n  document.getElementById(\"joinResult\").textContent = `Joined string: ${joined}`;\n};\n\n// Sort\n\ndocument.getElementById(\"sortBtn\").onclick = function() {\n  const type = document.getElementById(\"sortTypeSelect\").value;\n  try {\n    switch(type) {\n      case \"default\":\n        array.sort();\n        break;\n      case \"numericAsc\":\n        array.sort((a,b) => (Number(a) || 0) - (Number(b) || 0));\n        break;\n      case \"numericDesc\":\n        array.sort((a,b) => (Number(b) || 0) - (Number(a) || 0));\n        break;\n      case \"stringAsc\":\n        array.sort((a,b) => {\n          let sa= a === undefined ? \"\" : String(a);\n          let sb= b === undefined ? \"\" : String(b);\n          return sa.localeCompare(sb);\n        });\n        break;\n      case \"stringDesc\":\n        array.sort((a,b) => {\n          let sa= a === undefined ? \"\" : String(a);\n          let sb= b === undefined ? \"\" : String(b);\n          return sb.localeCompare(sa);\n        });\n        break;\n    }\n    renderArray();\n    document.getElementById(\"sortReverseResult\").textContent = \"Array sorted.\";\n  } catch(e) {\n    document.getElementById(\"sortReverseResult\").textContent = \"Error sorting: \"+e.message;\n  }\n};\n\ndocument.getElementById(\"reverseBtn\").onclick = function() {\n  array.reverse();\n  renderArray();\n  document.getElementById(\"sortReverseResult\").textContent = \"Array reversed.\";\n};\n\n// Map\n\nfunction safeEvalMapFunc(expr) {\n  // Returns a function f(x) defined by expr, safely guarded\n  try {\n    // Create a Function with input x, return expression\n    // Disallow some dangerous keywords\n    if (expr.match(/(window|document|eval|Function|while|for|break|return|var|let|const|this|=>|class|new|import|export|require)/)) {\n      return null;\n    }\n    let fn = new Function(\"x\", \"return (\"+expr+\");\");\n    // Test call with sample\n    fn(1);\n    return fn;\n  } catch(e) {\n    return null;\n  }\n}\n\ndocument.getElementById(\"mapBtn\").onclick = function() {\n  let expr = document.getElementById(\"mapExpressionInput\").value.trim();\n  const p = document.getElementById(\"mapResult\");\n  if(expr === \"\") {\n    p.textContent = \"Please enter a mapping expression.\";\n    return;\n  }\n  let fn = safeEvalMapFunc(expr);\n  if(!fn) {\n    p.textContent = \"Invalid or unsafe function expression.\";\n    return;\n  }\n  try {\n    let mapped = array.map(fn);\n    p.textContent = \"Mapped array: \" + JSON.stringify(mapped);\n  } catch(e) {\n    p.textContent = \"Error applying map: \"+e.message;\n  }\n};\n\n// Filter\n\ndocument.getElementById(\"filterBtn\").onclick = function() {\n  let expr = document.getElementById(\"filterExpressionInput\").value.trim();\n  const p = document.getElementById(\"filterResult\");\n  if(expr === \"\") {\n    p.textContent = \"Please enter a filter expression.\";\n    return;\n  }\n  let fn = safeEvalMapFunc(expr);\n  if(!fn) {\n    p.textContent = \"Invalid or unsafe function expression.\";\n    return;\n  }\n  try {\n    let filtered = array.filter(fn);\n    p.textContent = \"Filtered array: \" + JSON.stringify(filtered);\n  } catch(e) {\n    p.textContent = \"Error applying filter: \"+e.message;\n  }\n};\n\n// Reduce\n\nfunction safeEvalReduceFunc(expr) {\n  // Returns a function f(acc, x) defined by expr or null\n  try {\n    if (expr.match(/(window|document|eval|Function|while|for|break|return|var|let|const|this|=>|class|new|import|export|require)/)) {\n      return null;\n    }\n    let fn = new Function(\"acc\", \"x\", \"return (\"+expr+\");\");\n    fn(0,0);\n    return fn;\n  } catch(e) {\n    return null;\n  }\n}\n\ndocument.getElementById(\"reduceBtn\").onclick = function() {\n  const expr = document.getElementById(\"reduceExpressionInput\").value.trim();\n  const initialRaw = document.getElementById(\"reduceInitialInput\").value.trim();\n  const p = document.getElementById(\"reduceResult\");\n  if(expr === \"\") {\n    p.textContent = \"Please enter a reduce function expression.\";\n    return;\n  }\n  let fn = safeEvalReduceFunc(expr);\n  if(!fn) {\n    p.textContent = \"Invalid or unsafe reduce function expression.\";\n    return;\n  }\n  let initial;\n  try {\n    if (initialRaw === \"\") {\n      p.textContent = \"Please enter an initial value for reduce.\";\n      return;\n    } else {\n      initial = JSON.parse(initialRaw);\n    }\n  } catch(e) {\n    p.textContent = \"Initial value must be valid JSON.\";\n    return;\n  }\n  try {\n    let result = array.reduce(fn, initial);\n    p.textContent = \"Reduce result: \" + JSON.stringify(result);\n  } catch(e) {\n    p.textContent = \"Error applying reduce: \"+e.message;\n  }\n};\n\n\n// Find\n\ndocument.getElementById(\"findBtn\").onclick = function() {\n  let expr = document.getElementById(\"findExpressionInput\").value.trim();\n  const p = document.getElementById(\"findResult\");\n  if(expr === \"\") {\n    p.textContent = \"Please enter a find expression.\";\n    return;\n  }\n  let fn = safeEvalMapFunc(expr);\n  if(!fn) {\n    p.textContent = \"Invalid or unsafe find function expression.\";\n    return;\n  }\n  try {\n    let found = array.find(fn);\n    p.textContent = \"Find result: \" + (found === undefined ? \"undefined\" : JSON.stringify(found));\n  } catch(e) {\n    p.textContent = \"Error applying find: \"+e.message;\n  }\n};\n\n// FindIndex\n\ndocument.getElementById(\"findIndexBtn\").onclick = function() {\n  let expr = document.getElementById(\"findIndexExpressionInput\").value.trim();\n  const p = document.getElementById(\"findIndexResult\");\n  if(expr === \"\") {\n    p.textContent = \"Please enter a findIndex expression.\";\n    return;\n  }\n  let fn = safeEvalMapFunc(expr);\n  if(!fn) {\n    p.textContent = \"Invalid or unsafe findIndex function expression.\";\n    return;\n  }\n  try {\n    let idx = array.findIndex(fn);\n    p.textContent = \"FindIndex result: \" + idx;\n  } catch(e) {\n    p.textContent = \"Error applying findIndex: \"+e.message;\n  }\n};\n\n// Copy JSON\n\ndocument.getElementById(\"copyJsonBtn\").onclick = function() {\n  const textArea = document.getElementById(\"arrayJsonView\");\n  textArea.select();\n  document.execCommand('copy');\n  alert(\"Array JSON copied to clipboard.\");\n};\n\n// Initialize with default empty array and render\n\narray = [];\nrenderArray();\n\n</script>\n</body>\n</html>"
