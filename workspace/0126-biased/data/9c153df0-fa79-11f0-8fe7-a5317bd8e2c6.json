    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Thread Simulator - Interactive</title>\n  <style>\n    /* Intentionally minimal styling - default browser styles only */\n  </style>\n</head>\n<body>\n  <h1>Thread Simulator</h1>\n\n  <div>\n    <strong>Create Thread</strong><br>\n    Name: <input id=\"newName\" placeholder=\"thread1\">\n    Priority: <input id=\"newPriority\" type=\"number\" value=\"5\" style=\"width:60px\">\n    Behavior (one instruction per line):\n    <br>\n    <textarea id=\"newBehavior\" rows=\"6\" cols=\"60\">COMPUTE 3\nLOCK L1\nCOMPUTE 2\nUNLOCK L1\nSEND C1 Hello\nEXIT</textarea>\n    <br>\n    Predefined:\n    <select id=\"preset\">\n      <option value=\"\">--choose preset--</option>\n      <option value=\"producer\">Producer (send 5 messages)</option>\n      <option value=\"consumer\">Consumer (receive 5 messages)</option>\n      <option value=\"priority_inversion\">Priority Inversion (two threads)</option>\n      <option value=\"deadlock\">Deadlock (two locks opposite order)</option>\n      <option value=\"join_example\">Join example (parent waits child)</option>\n    </select>\n    <button id=\"createThread\">Create Thread</button>\n    <button id=\"createClones\">Create 5 Clones</button>\n    <button id=\"clearAll\">Clear All</button>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Scheduler Controls</strong><br>\n    Mode:\n    <select id=\"schedulerMode\">\n      <option value=\"round_robin\">Round Robin</option>\n      <option value=\"priority\">Priority</option>\n      <option value=\"manual\">Manual (user pick)</option>\n    </select>\n    Quantum (ticks): <input id=\"quantum\" type=\"number\" value=\"2\" style=\"width:60px\">\n    Speed (ms per tick): <input id=\"tickMs\" type=\"number\" value=\"400\" style=\"width:70px\">\n    Preemption: <input id=\"preempt\" type=\"checkbox\" checked>\n    Random events: <input id=\"randomEvents\" type=\"checkbox\">\n    <button id=\"run\">Run</button>\n    <button id=\"pause\">Pause</button>\n    <button id=\"step\">Step</button>\n    Run for N ticks: <input id=\"runTicks\" type=\"number\" value=\"20\" style=\"width:70px\">\n    <button id=\"runFor\">Run N</button>\n    <button id=\"resetSim\">Reset Simulation Clock</button>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Locks and Channels</strong><br>\n    Create Lock name: <input id=\"lockName\" placeholder=\"L1\" style=\"width:80px\">\n    <button id=\"createLock\">Create Lock</button>\n    <br>\n    Create Channel name: <input id=\"chanName\" placeholder=\"C1\" style=\"width:80px\">\n    Buffer size: <input id=\"chanSize\" type=\"number\" value=\"1\" style=\"width:50px\">\n    <button id=\"createChan\">Create Channel</button>\n    <button id=\"autoSetup\">Auto Setup (producer/consumer C1)</button>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Threads</strong>\n    <div id=\"threads\"></div>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Locks</strong>\n    <div id=\"locks\"></div>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Channels</strong>\n    <div id=\"channels\"></div>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Workflows & Scenarios</strong><br>\n    <button id=\"wfPriorityInversion\">Setup Priority Inversion</button>\n    <button id=\"wfDeadlock\">Setup Deadlock</button>\n    <button id=\"wfProducerConsumer\">Setup Producer/Consumer</button>\n    <button id=\"wfJoin\">Setup Join Example</button>\n    <button id=\"wfStarvation\">Setup Starvation</button>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Execution & Debug</strong><br>\n    Breakpoint (threadId:pc) <input id=\"breakpoint\" placeholder=\"t1:3\" style=\"width:120px\">\n    <button id=\"setBreakpoint\">Set</button>\n    <button id=\"clearBreakpoints\">Clear</button>\n    Step until breakpoint: <button id=\"runToBp\">Run to BP</button>\n    Watch expression (threadId.var) <input id=\"watchExpr\" placeholder=\"t1.x\" style=\"width:120px\">\n    <button id=\"addWatch\">Add Watch</button>\n    <div id=\"watches\"></div>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Log / Timeline</strong>\n    <div>\n      Time: <span id=\"simTime\">0</span>\n      <input id=\"timelineScrub\" type=\"range\" min=\"0\" max=\"0\" value=\"0\" style=\"width:300px\">\n      <button id=\"replay\">Replay</button>\n      <button id=\"clearLog\">Clear Log</button>\n    </div>\n    <textarea id=\"log\" rows=\"10\" cols=\"120\" readonly></textarea>\n  </div>\n\n  <script>\n    // Minimal default visual; functionality prioritized.\n    (function() {\n      // Data structures\n      let nextThreadId = 1;\n      const threads = {}; // id -> thread\n      const locks = {}; // name -> {owner:tid|null, waiters:[]}\n      const channels = {}; // name -> {buffer:[], size, waitersR:[], waitersW:[]}\n      let sim = {\n        time: 0,\n        running: false,\n        interval: null,\n        tickMs: 400,\n        schedulerMode: 'round_robin',\n        quantum: 2,\n        preempt: true,\n        randomEvents: false,\n        log: [],\n        timelineIndex: 0,\n        breakpoints: [], // {tid, pc}\n        watches: [] // {expr, last}\n      };\n\n      // Utility\n      function logEvent(msg) {\n        const t = sim.time;\n        const entry = {time: t, text: msg};\n        sim.log.push(entry);\n        document.getElementById('log').value += `[${t}] ${msg}\\n`;\n        updateTimelineControls();\n      }\n\n      function updateTimelineControls() {\n        const r = document.getElementById('timelineScrub');\n        r.max = Math.max(0, sim.log.length - 1);\n        r.value = sim.log.length - 1;\n        document.getElementById('simTime').textContent = sim.time;\n      }\n\n      // Thread model\n      function createThread(name, priority, behaviorText) {\n        const id = 't' + nextThreadId++;\n        const lines = behaviorText.split('\\n').map(l => l.trim()).filter(l => l.length);\n        const instr = lines.map(parseInstr);\n        const th = {\n          id, name: name || id, priority: Number(priority) || 5,\n          prog: instr, pc: 0, state: 'NEW', computeLeft:0, sleepLeft:0,\n          waitingFor: null, joinedBy: [], local: {}, quantumLeft: 0\n        };\n        threads[id] = th;\n        logEvent(`Created thread ${id} (${th.name})`);\n        renderAll();\n        return th;\n      }\n\n      function cloneThread(sourceId) {\n        const s = threads[sourceId];\n        if (!s) return;\n        return createThread(s.name + '_clone', s.priority, s.prog.map(instrToText).join('\\n'));\n      }\n\n      function parseInstr(line) {\n        // Commands: COMPUTE n, SLEEP n, LOCK name, UNLOCK name, SEND chan val, RECEIVE chan var,\n        // YIELD, WAIT var op value (not used), SIGNAL cond, JOIN tid, EXIT\n        const parts = line.split(/\\s+/);\n        const op = parts[0].toUpperCase();\n        const args = parts.slice(1);\n        return {raw: line, op, args};\n      }\n\n      function instrToText(instr) {\n        return instr.raw;\n      }\n\n      // Locks and channels\n      function createLock(name) {\n        if (!name) name = 'L' + (Object.keys(locks).length+1);\n        if (locks[name]) {\n          logEvent(`Lock ${name} already exists`);\n          return;\n        }\n        locks[name] = {owner: null, waiters: []};\n        logEvent(`Created lock ${name}`);\n        renderAll();\n      }\n\n      function createChannel(name, size) {\n        if (!name) name = 'C' + (Object.keys(channels).length+1);\n        if (channels[name]) {\n          logEvent(`Channel ${name} already exists`);\n          return;\n        }\n        channels[name] = {buffer: [], size: Math.max(0, Number(size)||0), waitersR: [], waitersW: []};\n        logEvent(`Created channel ${name} (size ${channels[name].size})`);\n        renderAll();\n      }\n\n      // Scheduling & execution\n      function pickNextThread() {\n        // Return thread id or null\n        const runnable = Object.values(threads).filter(t => t.state === 'RUNNABLE' || t.state === 'NEW');\n        if (runnable.length === 0) return null;\n\n        if (sim.schedulerMode === 'manual') {\n          // find any thread marked \"manualRun\" by UI\n          const manual = runnable.find(t => t.manualRun);\n          if (manual) return manual.id;\n          // else pick first\n          return runnable[0].id;\n        }\n        if (sim.schedulerMode === 'priority') {\n          runnable.sort((a,b) => b.priority - a.priority || a.id.localeCompare(b.id));\n          return runnable[0].id;\n        }\n        // round robin: maintain last chosen pointer (simple mod)\n        if (!sim._rrIndex) sim._rrIndex = 0;\n        // sort for deterministic order\n        runnable.sort((a,b) => a.id.localeCompare(b.id));\n        // find index\n        const idx = sim._rrIndex % runnable.length;\n        sim._rrIndex++;\n        return runnable[idx].id;\n      }\n\n      function stepOnce() {\n        sim.time++;\n        // decrement sleeping/compute on blocked threads\n        for (const t of Object.values(threads)) {\n          if (t.state === 'SLEEPING') {\n            t.sleepLeft--;\n            if (t.sleepLeft <= 0) {\n              t.state = 'RUNNABLE';\n              logEvent(`${t.id} woke from sleep`);\n            }\n          }\n          if (t.state === 'RUNNING') {\n            // nothing here; running thread handled below\n          }\n        }\n\n        // random events\n        if (sim.randomEvents && Math.random() < 0.1) {\n          const ids = Object.keys(threads);\n          if (ids.length) {\n            const tid = ids[Math.floor(Math.random()*ids.length)];\n            const t = threads[tid];\n            // random yield or sleep\n            if (Math.random() < 0.5) {\n              if (t.state === 'RUNNABLE') {\n                t.state = 'SLEEPING';\n                t.sleepLeft = 1 + Math.floor(Math.random()*3);\n                logEvent(`${t.id} randomly sleeping (${t.sleepLeft})`);\n              }\n            } else {\n              if (t.state === 'RUNNING') {\n                t.state = 'RUNNABLE';\n                logEvent(`${t.id} randomly yielded`);\n              }\n            }\n          }\n        }\n\n        // find currently running thread\n        let running = Object.values(threads).find(t => t.state === 'RUNNING');\n        if (running && sim.preempt) {\n          running.quantumLeft--;\n          if (running.quantumLeft <= 0) {\n            running.state = 'RUNNABLE';\n            logEvent(`${running.id} preempted (quantum)`);\n            running = null;\n          }\n        }\n\n        if (!running) {\n          const nextId = pickNextThread();\n          if (nextId) {\n            running = threads[nextId];\n            if (running.state === 'NEW') running.state = 'RUNNABLE';\n            running.state = 'RUNNING';\n            running.quantumLeft = sim.quantum;\n            logEvent(`${running.id} scheduled to RUN`);\n          }\n        }\n\n        if (running) {\n          executeInstruction(running);\n        }\n\n        // update watches and check breakpoints\n        for (const w of sim.watches) {\n          const val = evalWatch(w.expr);\n          if (val !== w.last) {\n            w.last = val;\n            logEvent(`Watch ${w.expr} => ${JSON.stringify(val)}`);\n          }\n        }\n        for (const bp of sim.breakpoints) {\n          const t = threads[bp.tid];\n          if (t && t.pc === bp.pc) {\n            logEvent(`Breakpoint hit ${bp.tid}@${bp.pc}`);\n            pauseSim();\n            // do not auto-clear bp\n          }\n        }\n\n        renderAll();\n        updateTimelineControls();\n      }\n\n      function executeInstruction(t) {\n        if (t.state !== 'RUNNING') return;\n        if (t.pc < 0 || t.pc >= t.prog.length) {\n          t.state = 'TERMINATED';\n          logEvent(`${t.id} reached end and terminated`);\n          notifyJoiners(t);\n          return;\n        }\n        const instr = t.prog[t.pc];\n        const op = instr.op;\n        const args = instr.args;\n        logEvent(`${t.id} executing ${instr.raw}`);\n        switch (op) {\n          case 'COMPUTE':\n            {\n              const n = Number(args[0]) || 1;\n              if (!t.computeLeft) t.computeLeft = n;\n              t.computeLeft--;\n              if (t.computeLeft <= 0) {\n                t.computeLeft = 0;\n                t.pc++;\n              } // else remain on this instruction\n            }\n            break;\n          case 'SLEEP':\n            {\n              const n = Number(args[0]) || 1;\n              t.sleepLeft = n;\n              t.state = 'SLEEPING';\n              t.pc++;\n            }\n            break;\n          case 'YIELD':\n            t.state = 'RUNNABLE';\n            t.pc++;\n            break;\n          case 'LOCK':\n            {\n              const name = args[0];\n              if (!locks[name]) createLock(name);\n              const L = locks[name];\n              if (!L.owner) {\n                L.owner = t.id;\n                logEvent(`${t.id} acquired lock ${name}`);\n                t.pc++;\n              } else {\n                // block\n                t.state = 'BLOCKED';\n                t.waitingFor = {type:'lock', name};\n                L.waiters.push(t.id);\n                logEvent(`${t.id} blocked waiting lock ${name}`);\n              }\n            }\n            break;\n          case 'UNLOCK':\n            {\n              const name = args[0];\n              const L = locks[name];\n              if (!L) { logEvent(`${t.id} unlock ${name} but lock missing`); t.pc++; break; }\n              if (L.owner !== t.id) {\n                logEvent(`${t.id} attempted to unlock ${name} but is not owner`);\n                t.pc++;\n                break;\n              }\n              L.owner = null;\n              t.pc++;\n              logEvent(`${t.id} unlocked ${name}`);\n              if (L.waiters.length) {\n                const nid = L.waiters.shift();\n                L.owner = nid;\n                const nt = threads[nid];\n                if (nt) {\n                  nt.state = 'RUNNABLE';\n                  nt.waitingFor = null;\n                  logEvent(`${nid} acquired ${name} (woken)`);\n                }\n              }\n            }\n            break;\n          case 'SEND':\n            {\n              const cname = args[0];\n              const val = args.slice(1).join(' ') || '';\n              if (!channels[cname]) createChannel(cname,1);\n              const C = channels[cname];\n              if (C.size === 0) {\n                // unbuffered: if receiver waiting, deliver; else block writer\n                if (C.waitersR.length) {\n                  const rid = C.waitersR.shift();\n                  const rthread = threads[rid];\n                  if (rthread) {\n                    rthread.local._recv = val;\n                    rthread.state = 'RUNNABLE';\n                    logEvent(`${t.id} sent unbuffered ${val} to ${rid}`);\n                  }\n                  t.pc++;\n                } else {\n                  // block writer\n                  t.state = 'BLOCKED';\n                  t.waitingFor = {type:'chan_send', name:cname, val};\n                  C.waitersW.push(t.id);\n                  logEvent(`${t.id} blocked sending to ${cname} (unbuffered)`);\n                }\n              } else {\n                // buffered\n                if (C.buffer.length < C.size) {\n                  C.buffer.push(val);\n                  t.pc++;\n                  logEvent(`${t.id} buffered ${val} to ${cname}`);\n                  // wake a receiver\n                  if (C.waitersR.length) {\n                    const rid = C.waitersR.shift();\n                    const rthread = threads[rid];\n                    if (rthread) {\n                      const msg = C.buffer.shift();\n                      rthread.local._recv = msg;\n                      rthread.state = 'RUNNABLE';\n                      logEvent(`${rid} received ${msg} from ${cname} (woken)`);\n                    }\n                  }\n                } else {\n                  // buffer full\n                  t.state = 'BLOCKED';\n                  t.waitingFor = {type:'chan_send', name:cname, val};\n                  C.waitersW.push(t.id);\n                  logEvent(`${t.id} blocked sending to ${cname} (buffer full)`);\n                }\n              }\n            }\n            break;\n          case 'RECEIVE':\n            {\n              const cname = args[0];\n              const varName = args[1] || '_';\n              if (!channels[cname]) createChannel(cname,1);\n              const C = channels[cname];\n              if (C.size === 0) {\n                // unbuffered: if sender waiting, receive; else block receiver\n                if (C.waitersW.length) {\n                  const wid = C.waitersW.shift();\n                  const wthread = threads[wid];\n                  const val = wthread.waitingFor && wthread.waitingFor.val ? wthread.waitingFor.val : null;\n                  if (wthread) {\n                    // wake writer\n                    wthread.state = 'RUNNABLE';\n                    wthread.waitingFor = null;\n                    logEvent(`${wid} unblocked sending to ${cname}`);\n                  }\n                  t.local[varName] = val;\n                  t.local._recv = val;\n                  t.pc++;\n                  logEvent(`${t.id} received unbuffered ${val} from ${wid}`);\n                } else {\n                  // block receiver\n                  t.state = 'BLOCKED';\n                  t.waitingFor = {type:'chan_recv', name:cname};\n                  C.waitersR.push(t.id);\n                  logEvent(`${t.id} blocked receiving from ${cname} (unbuffered)`);\n                }\n              } else {\n                // buffered\n                if (C.buffer.length) {\n                  const val = C.buffer.shift();\n                  t.local[varName] = val;\n                  t.local._recv = val;\n                  t.pc++;\n                  logEvent(`${t.id} received ${val} from ${cname}`);\n                  // wake any waiting senders\n                  if (C.waitersW.length) {\n                    const wid = C.waitersW.shift();\n                    const wthread = threads[wid];\n                    if (wthread && wthread.waitingFor) {\n                      C.buffer.push(wthread.waitingFor.val);\n                      wthread.waitingFor = null;\n                      wthread.state = 'RUNNABLE';\n                      logEvent(`${wid} resumed and buffered to ${cname}`);\n                    }\n                  }\n                } else {\n                  // buffer empty\n                  t.state = 'BLOCKED';\n                  t.waitingFor = {type:'chan_recv', name:cname};\n                  C.waitersR.push(t.id);\n                  logEvent(`${t.id} blocked receiving from ${cname} (buffer empty)`);\n                }\n              }\n            }\n            break;\n          case 'JOIN':\n            {\n              const targetId = args[0];\n              const target = threads[targetId];\n              if (!target || target.state === 'TERMINATED') {\n                logEvent(`${t.id} join ${targetId} immediate (target ended)`);\n                t.pc++;\n              } else {\n                t.state = 'BLOCKED';\n                t.waitingFor = {type:'join', tid: targetId};\n                if (target) target.joinedBy.push(t.id);\n                logEvent(`${t.id} blocked joining ${targetId}`);\n              }\n            }\n            break;\n          case 'EXIT':\n            t.state = 'TERMINATED';\n            logEvent(`${t.id} EXIT`);\n            notifyJoiners(t);\n            break;\n          default:\n            // unknown - skip\n            logEvent(`${t.id} unknown instruction ${instr.raw} - skipped`);\n            t.pc++;\n        }\n      }\n\n      function notifyJoiners(t) {\n        if (t.joinedBy && t.joinedBy.length) {\n          for (const jid of t.joinedBy) {\n            const jt = threads[jid];\n            if (jt && jt.state === 'BLOCKED' && jt.waitingFor && jt.waitingFor.type === 'join' && jt.waitingFor.tid === t.id) {\n              jt.state = 'RUNNABLE';\n              jt.waitingFor = null;\n              logEvent(`${jt.id} woken from join on ${t.id}`);\n            }\n          }\n          t.joinedBy = [];\n        }\n      }\n\n      // UI rendering\n      function renderAll() {\n        renderThreads();\n        renderLocks();\n        renderChannels();\n        renderWatches();\n      }\n\n      function renderThreads() {\n        const el = document.getElementById('threads');\n        el.innerHTML = '';\n        const keys = Object.keys(threads).sort();\n        if (!keys.length) { el.textContent = '(no threads)'; return; }\n        for (const id of keys) {\n          const t = threads[id];\n          const div = document.createElement('div');\n          div.style.marginBottom = '6px';\n          const header = document.createElement('span');\n          header.textContent = `${t.id} (${t.name}) [${t.state}] pc=${t.pc}/${t.prog.length} prio=${t.priority}`;\n          div.appendChild(header);\n          div.appendChild(document.createTextNode(' '));\n          const btnStart = document.createElement('button'); btnStart.textContent='Start/Make Runnable';\n          btnStart.onclick = () => { if (t.state==='NEW') t.state='RUNNABLE'; else t.state='RUNNABLE'; logEvent(`${t.id} set RUNNABLE`); renderAll(); };\n          div.appendChild(btnStart);\n          const btnRun = document.createElement('button'); btnRun.textContent='Run now';\n          btnRun.onclick = () => { for (const th of Object.values(threads)) th.manualRun=false; t.manualRun=true; sim.schedulerMode='manual'; document.getElementById('schedulerMode').value='manual'; logEvent(`${t.id} marked for manual run`); renderAll(); };\n          div.appendChild(btnRun);\n          const btnStep = document.createElement('button'); btnStep.textContent='Step';\n          btnStep.onclick = () => { // run a controlled step with this thread\n            for (const th of Object.values(threads)) th.manualRun=false;\n            t.manualRun=true; sim.schedulerMode='manual';\n            stepOnce();\n          };\n          div.appendChild(btnStep);\n          const btnPause = document.createElement('button'); btnPause.textContent='Pause';\n          btnPause.onclick = () => { if (t.state==='RUNNING') t.state='RUNNABLE'; logEvent(`${t.id} paused`); renderAll(); };\n          div.appendChild(btnPause);\n          const btnKill = document.createElement('button'); btnKill.textContent='Terminate';\n          btnKill.onclick = () => { t.state='TERMINATED'; logEvent(`${t.id} forced terminated`); notifyJoiners(t); renderAll(); };\n          div.appendChild(btnKill);\n          const btnEdit = document.createElement('button'); btnEdit.textContent='Edit';\n          btnEdit.onclick = () => { const newb = prompt('Edit behavior (one instruction per line)', t.prog.map(instrToText).join('\\n')); if (newb!==null) { t.prog = newb.split('\\n').map(parseInstr); t.pc=0; logEvent(`${t.id} program edited`); renderAll(); } };\n          div.appendChild(btnEdit);\n          const btnPC = document.createElement('button'); btnPC.textContent='Set PC';\n          btnPC.onclick = () => { const v = prompt('Set PC index', String(t.pc)); const n = Number(v); if (!isNaN(n)) { t.pc = Math.max(0, Math.min(t.prog.length, n)); logEvent(`${t.id} pc set to ${t.pc}`); renderAll(); } };\n          div.appendChild(btnPC);\n          const priInput = document.createElement('input'); priInput.type='number'; priInput.value=t.priority; priInput.style.width='60px';\n          priInput.onchange = () => { t.priority = Number(priInput.value); logEvent(`${t.id} priority set to ${t.priority}`); renderAll(); };\n          div.appendChild(priInput);\n          // show local variables preview\n          const local = document.createElement('span'); local.textContent = ' Locals: ' + JSON.stringify(t.local);\n          div.appendChild(local);\n          // show program snippet\n          const prog = document.createElement('pre');\n          prog.textContent = t.prog.map((p,i) => (i===t.pc ? '-> ' : '   ') + i + ': ' + p.raw).join('\\n');\n          prog.style.margin = '4px 0';\n          div.appendChild(prog);\n\n          el.appendChild(div);\n        }\n      }\n\n      function renderLocks() {\n        const el = document.getElementById('locks');\n        el.innerHTML = '';\n        const names = Object.keys(locks).sort();\n        if (!names.length) { el.textContent='(no locks)'; return; }\n        for (const name of names) {\n          const L = locks[name];\n          const d = document.createElement('div');\n          d.textContent = `${name}: owner=${L.owner || '-'}, waiters=[${(L.waiters||[]).join(',')}] `;\n          const btn = document.createElement('button'); btn.textContent='Force release';\n          btn.onclick = () => { L.owner = null; logEvent(`Lock ${name} force-released`); // wake first waiter\n            if (L.waiters.length) {\n              const nid = L.waiters.shift();\n              L.owner = nid;\n              const nt = threads[nid];\n              if (nt) { nt.state = 'RUNNABLE'; nt.waitingFor = null; logEvent(`${nid} acquired ${name} (force wake)`); }\n            }\n            renderAll();\n          };\n          d.appendChild(btn);\n          el.appendChild(d);\n        }\n      }\n\n      function renderChannels() {\n        const el = document.getElementById('channels');\n        el.innerHTML = '';\n        const names = Object.keys(channels).sort();\n        if (!names.length) { el.textContent='(no channels)'; return; }\n        for (const name of names) {\n          const C = channels[name];\n          const d = document.createElement('div');\n          d.textContent = `${name}: buffer=[${C.buffer.join(',')}] size=${C.size} waitR=[${C.waitersR.join(',')}] waitW=[${C.waitersW.join(',')}] `;\n          const btn = document.createElement('button'); btn.textContent='Purge';\n          btn.onclick = () => { C.buffer = []; C.waitersR = []; C.waitersW = []; logEvent(`${name} purged`); renderAll(); };\n          d.appendChild(btn);\n          el.appendChild(d);\n        }\n      }\n\n      // Controls wiring\n      document.getElementById('createThread').onclick = () => {\n        const name = document.getElementById('newName').value || null;\n        const pr = document.getElementById('newPriority').value || 5;\n        const beh = document.getElementById('newBehavior').value;\n        createThread(name, pr, beh);\n      };\n      document.getElementById('createClones').onclick = () => {\n        // creates 5 clones of last created thread if exists\n        const ids = Object.keys(threads);\n        if (!ids.length) return;\n        const last = ids[ids.length-1];\n        for (let i=0;i<5;i++) cloneThread(last);\n      };\n      document.getElementById('clearAll').onclick = () => {\n        if (!confirm('Clear all threads, locks, channels, and logs?')) return;\n        for (const k of Object.keys(threads)) delete threads[k];\n        for (const k of Object.keys(locks)) delete locks[k];\n        for (const k of Object.keys(channels)) delete channels[k];\n        sim.log = [];\n        document.getElementById('log').value = '';\n        sim.time = 0;\n        renderAll();\n      };\n\n      document.getElementById('createLock').onclick = () => {\n        const n = document.getElementById('lockName').value || null;\n        createLock(n);\n      };\n      document.getElementById('createChan').onclick = () => {\n        const n = document.getElementById('chanName').value || null;\n        const s = document.getElementById('chanSize').value || 0;\n        createChannel(n, Number(s));\n      };\n\n      document.getElementById('autoSetup').onclick = () => {\n        createChannel('C1', 2);\n        const prod = createThread('producer', 5, 'COMPUTE 1\\nSEND C1 msg1\\nSEND C1 msg2\\nSEND C1 msg3\\nSEND C1 msg4\\nSEND C1 msg5\\nEXIT');\n        const cons = createThread('consumer', 5, 'RECEIVE C1 x\\nRECEIVE C1 x\\nRECEIVE C1 x\\nRECEIVE C1 x\\nRECEIVE C1 x\\nEXIT');\n        renderAll();\n      };\n\n      document.getElementById('schedulerMode').onchange = function() {\n        sim.schedulerMode = this.value;\n        logEvent(`Scheduler mode set to ${this.value}`);\n      };\n      document.getElementById('quantum').onchange = function() { sim.quantum = Math.max(1, Number(this.value)||1); logEvent(`Quantum set to ${sim.quantum}`); };\n      document.getElementById('tickMs').onchange = function() { sim.tickMs = Math.max(10, Number(this.value)||10); logEvent(`Tick interval set to ${sim.tickMs}ms`); if (sim.running) restartSimInterval(); };\n      document.getElementById('preempt').onchange = function() { sim.preempt = this.checked; logEvent(`Preemption ${this.checked ? 'enabled' : 'disabled'}`); };\n      document.getElementById('randomEvents').onchange = function() { sim.randomEvents = this.checked; logEvent(`Random events ${this.checked ? 'on' : 'off'}`); };\n\n      document.getElementById('run').onclick = function() { startSim(); };\n      document.getElementById('pause').onclick = function() { pauseSim(); };\n      document.getElementById('step').onclick = function() { stepOnce(); };\n      document.getElementById('runFor').onclick = function() { const n=Number(document.getElementById('runTicks').value)||1; runForTicks(n); };\n      document.getElementById('resetSim').onclick = function() { sim.time = 0; document.getElementById('simTime').textContent = sim.time; logEvent('Simulation clock reset'); };\n\n      function startSim() {\n        if (sim.running) return;\n        sim.running = true;\n        restartSimInterval();\n        logEvent('Simulation started');\n      }\n      function pauseSim() {\n        if (!sim.running) return;\n        sim.running = false;\n        if (sim.interval) { clearInterval(sim.interval); sim.interval = null; }\n        logEvent('Simulation paused');\n      }\n      function restartSimInterval() {\n        if (sim.interval) clearInterval(sim.interval);\n        sim.interval = setInterval(() => {\n          stepOnce();\n        }, sim.tickMs || 200);\n      }\n\n      function runForTicks(n) {\n        let count=0;\n        startSim();\n        const stopAt = sim.time + n;\n        const check = setInterval(() => {\n          if (sim.time >= stopAt) {\n            pauseSim();\n            clearInterval(check);\n            logEvent(`Run for ${n} ticks completed`);\n          }\n        }, 50);\n      }\n\n      // Timeline controls\n      document.getElementById('clearLog').onclick = function() {\n        sim.log = [];\n        document.getElementById('log').value = '';\n        updateTimelineControls();\n      };\n      document.getElementById('timelineScrub').oninput = function() {\n        const idx = Number(this.value);\n        const area = document.getElementById('log');\n        if (sim.log.length === 0) { area.value = ''; return; }\n        area.value = sim.log.slice(0, idx+1).map(e => `[${e.time}] ${e.text}`).join('\\n');\n        document.getElementById('simTime').textContent = sim.log[idx] ? sim.log[idx].time : sim.time;\n      };\n      document.getElementById('replay').onclick = function() {\n        if (sim.log.length === 0) return;\n        let i=0;\n        const area = document.getElementById('log');\n        area.value = '';\n        const rep = setInterval(() => {\n          if (i>=sim.log.length) { clearInterval(rep); return; }\n          area.value += `[${sim.log[i].time}] ${sim.log[i].text}\\n`;\n          i++;\n        }, 50);\n      };\n\n      // Breakpoints and watches\n      document.getElementById('setBreakpoint').onclick = function() {\n        const v = document.getElementById('breakpoint').value.trim();\n        if (!v) return;\n        const parts = v.split(':');\n        const tid = parts[0]; const pc = Number(parts[1]);\n        if (!threads[tid]) { alert('No such thread'); return; }\n        if (isNaN(pc)) { alert('Invalid pc'); return; }\n        sim.breakpoints.push({tid, pc});\n        logEvent(`Breakpoint set ${tid}@${pc}`);\n      };\n      document.getElementById('clearBreakpoints').onclick = function() {\n        sim.breakpoints = [];\n        logEvent('Breakpoints cleared');\n      };\n      document.getElementById('runToBp').onclick = function() {\n        startSim();\n        // will pause when breakpoint is hit (logic in stepOnce)\n      };\n\n      document.getElementById('addWatch').onclick = function() {\n        const e = document.getElementById('watchExpr').value.trim();\n        if (!e) return;\n        sim.watches.push({expr:e, last: undefined});\n        logEvent(`Watch added: ${e}`);\n        renderWatches();\n      };\n      function renderWatches() {\n        const el = document.getElementById('watches');\n        el.innerHTML = '';\n        if (!sim.watches.length) { el.textContent='(no watches)'; return; }\n        for (const w of sim.watches) {\n          const d = document.createElement('div');\n          d.textContent = `${w.expr} -> ${JSON.stringify(w.last)}`;\n          const btn = document.createElement('button'); btn.textContent='Remove';\n          btn.onclick = () => { const i = sim.watches.indexOf(w); if (i>=0) sim.watches.splice(i,1); renderWatches(); };\n          d.appendChild(btn);\n          el.appendChild(d);\n        }\n      }\n      function evalWatch(expr) {\n        // expr format: tid.var e.g., t1.x or t2._recv or t1.local.key\n        try {\n          const parts = expr.split('.');\n          const tid = parts.shift();\n          const obj = threads[tid];\n          if (!obj) return undefined;\n          let cur = obj;\n          for (const p of parts) {\n            if (cur === undefined) return undefined;\n            cur = cur[p];\n          }\n          return cur;\n        } catch(e) { return undefined; }\n      }\n\n      // Workflows\n      document.getElementById('wfPriorityInversion').onclick = function() {\n        // setup simple priority inversion: low holds lock, high waits, medium preempts low\n        createLock('L1');\n        const low = createThread('low', 1, 'LOCK L1\\nCOMPUTE 5\\nUNLOCK L1\\nEXIT');\n        const med = createThread('medium', 5, 'COMPUTE 4\\nEXIT');\n        const high = createThread('high', 10, 'COMPUTE 1\\nLOCK L1\\nCOMPUTE 1\\nUNLOCK L1\\nEXIT');\n        sim.schedulerMode = 'priority';\n        document.getElementById('schedulerMode').value = 'priority';\n        logEvent('Priority inversion scenario setup');\n      };\n\n      document.getElementById('wfDeadlock').onclick = function() {\n        // two threads locking opposite order\n        createLock('A'); createLock('B');\n        createThread('tA', 5, 'LOCK A\\nCOMPUTE 1\\nLOCK B\\nCOMPUTE 1\\nUNLOCK B\\nUNLOCK A\\nEXIT');\n        createThread('tB', 5, 'LOCK B\\nCOMPUTE 1\\nLOCK A\\nCOMPUTE 1\\nUNLOCK A\\nUNLOCK B\\nEXIT');\n        logEvent('Deadlock scenario setup');\n      };\n\n      document.getElementById('wfProducerConsumer').onclick = function() {\n        createChannel('Q', 2);\n        createThread('producer', 5, 'COMPUTE 1\\nSEND Q 1\\nSEND Q 2\\nSEND Q 3\\nEXIT');\n        createThread('consumer', 5, 'RECEIVE Q x\\nRECEIVE Q x\\nRECEIVE Q x\\nEXIT');\n        logEvent('Producer/Consumer scenario setup');\n      };\n\n      document.getElementById('wfJoin').onclick = function() {\n        const child = createThread('child', 5, 'COMPUTE 3\\nEXIT');\n        createThread('parent', 5, `JOIN ${child.id}\\nCOMPUTE 1\\nEXIT`);\n        logEvent('Join scenario setup');\n      };\n\n      document.getElementById('wfStarvation').onclick = function() {\n        // many low-priority threads and one high-priority that never gets CPU if scheduling is naive\n        for (let i=0;i<6;i++) createThread('low'+i, 1, 'COMPUTE 10\\nEXIT');\n        createThread('high', 10, 'COMPUTE 1\\nEXIT');\n        sim.schedulerMode = 'round_robin';\n        document.getElementById('schedulerMode').value = 'round_robin';\n        logEvent('Starvation scenario setup');\n      };\n\n      // Presets in creation area\n      document.getElementById('preset').onchange = function() {\n        const v = this.value;\n        if (!v) return;\n        if (v === 'producer') {\n          document.getElementById('newBehavior').value = 'COMPUTE 1\\nSEND C1 m1\\nSEND C1 m2\\nSEND C1 m3\\nEXIT';\n        } else if (v === 'consumer') {\n          document.getElementById('newBehavior').value = 'RECEIVE C1 x\\nRECEIVE C1 x\\nRECEIVE C1 x\\nEXIT';\n        } else if (v === 'priority_inversion') {\n          document.getElementById('newBehavior').value = 'LOCK L1\\nCOMPUTE 5\\nUNLOCK L1\\nEXIT';\n        } else if (v === 'deadlock') {\n          document.getElementById('newBehavior').value = 'LOCK A\\nCOMPUTE 1\\nLOCK B\\nCOMPUTE 1\\nUNLOCK B\\nUNLOCK A\\nEXIT';\n        } else if (v === 'join_example') {\n          document.getElementById('newBehavior').value = 'JOIN tX\\nCOMPUTE 1\\nEXIT';\n        }\n      };\n\n      // initial sample\n      createLock('L1');\n      createChannel('C1',1);\n      createThread('main', 5, 'COMPUTE 2\\nLOCK L1\\nCOMPUTE 1\\nUNLOCK L1\\nSEND C1 ping\\nRECEIVE C1 x\\nEXIT');\n\n      // expose some globals for advanced interactive console use\n      window._simulator = {\n        threads, locks, channels, createThread, createLock, createChannel, stepOnce, startSim, pauseSim, sim, logEvent\n      };\n\n      renderAll();\n      updateTimelineControls();\n    })();\n  </script>\n</body>\n</html>"
