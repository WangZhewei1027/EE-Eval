    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Graph (Directed)</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        input[type=\"text\"] {\n            width: 100%;\n            height: 10px;\n            padding: 0 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n        input[type=\"number\"] {\n            width: 100%;\n            height: 10px;\n            padding: 0 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n        }\n        button {\n            width: 100%;\n            height: 10px;\n            padding: 0 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n        input[type=\"submit\"] {\n            width: 100%;\n            height: 10px;\n            padding: 0 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            box-sizing: border-box;\n            cursor: pointer;\n        }\n        input[type=\"submit\"]:hover {\n            background-color: #ccc;\n        }\n        .graph-container {\n            width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .graph-container h2 {\n            margin-bottom: 20px;\n        }\n        .graph-container button {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"graph-container\">\n        <h2>Graph (Directed)</h2>\n        <form>\n            <button type=\"button\" id=\"add-node\">Add Node</button>\n            <button type=\"button\" id=\"add-edge\">Add Edge</button>\n            <button type=\"button\" id=\"clear-graph\">Clear Graph</button>\n            <button type=\"button\" id=\"save-graph\" disabled>Save Graph</button>\n        </form>\n        <div id=\"graph\"></div>\n        <input type=\"text\" id=\"node-name\" placeholder=\"Node Name\">\n        <input type=\"number\" id=\"edge-weight\" placeholder=\"Edge Weight\">\n        <button type=\"submit\" id=\"add-node-btn\">Add Node</button>\n    </div>\n\n    <script>\n        let graph = {\n            nodes: [],\n            edges: []\n        };\n\n        document.getElementById('add-node').addEventListener('click', addNode);\n        document.getElementById('add-edge').addEventListener('click', addEdge);\n        document.getElementById('clear-graph').addEventListener('click', clearGraph);\n        document.getElementById('save-graph').addEventListener('click', saveGraph);\n\n        function addNode() {\n            const nodeName = document.getElementById('node-name').value;\n            if (nodeName) {\n                graph.nodes.push({ id: nodeName, weight: 0 });\n                renderGraph();\n                document.getElementById('node-name').value = '';\n            }\n        }\n\n        function addEdge() {\n            const edgeWeight = document.getElementById('edge-weight').value;\n            if (edgeWeight) {\n                const edge = { from: graph.nodes[0].id, to: graph.nodes[0].id, weight: edgeWeight };\n                graph.edges.push(edge);\n                renderGraph();\n                document.getElementById('edge-weight').value = '';\n            }\n        }\n\n        function clearGraph() {\n            graph.nodes = [];\n            graph.edges = [];\n            renderGraph();\n        }\n\n        function saveGraph() {\n            const graphData = JSON.stringify(graph);\n            document.getElementById('graph').innerHTML = `<graph id=\"graph\">${graphData}</graph>`;\n            document.getElementById('save-graph').disabled = true;\n        }\n\n        function renderGraph() {\n            const graphHTML = graph.nodes.map(node => `\n                <div class=\"node\" data-id=\"${node.id}\" data-weight=\"${node.weight}\">\n                    <input type=\"text\" id=\"node-name-${node.id}\" value=\"${node.name}\">\n                    <input type=\"number\" id=\"edge-weight-${node.id}\" value=\"${node.weight}\">\n                    <button type=\"button\" id=\"remove-node-${node.id}\">Remove Node</button>\n                </div>\n            `).join('');\n            document.getElementById('graph').innerHTML = graphHTML;\n        }\n\n        function removeNode(nodeId) {\n            graph.nodes = graph.nodes.filter(node => node.id !== nodeId);\n            renderGraph();\n        }\n\n        function updateEdgeWeight(edgeId, weight) {\n            graph.edges[edgeId].weight = weight;\n            renderGraph();\n        }\n\n        function updateNodeWeight(nodeId, weight) {\n            graph.nodes[nodeId].weight = weight;\n            renderGraph();\n        }\n    </script>\n</body>\n</html>"
