    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>TCP/IP: The Visual Symphony</title>\n    <style>\n        :root {\n            --primary: #2c3e50;\n            --secondary: #3498db;\n            --accent: #e74c3c;\n            --light: #ecf0f1;\n            --dark: #1a252f;\n            --success: #2ecc71;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: var(--primary);\n            color: var(--light);\n            overflow-x: hidden;\n            line-height: 1.6;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s ease-out forwards;\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            margin-bottom: 1rem;\n            background: linear-gradient(135deg, var(--secondary), var(--light));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            font-weight: 700;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--light);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .visualization {\n            position: relative;\n            height: 500px;\n            margin: 5rem 0;\n            border-radius: 15px;\n            background: linear-gradient(145deg, rgba(44, 62, 80, 0.7), rgba(26, 37, 47, 0.9));\n            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);\n            overflow: hidden;\n            opacity: 0;\n            transform: scale(0.95);\n            transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .visualization.visible {\n            opacity: 1;\n            transform: scale(1);\n        }\n\n        .layers {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 80%;\n            height: 80%;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            padding: 2rem;\n        }\n\n        .layer {\n            position: relative;\n            height: 15%;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            padding: 0 2rem;\n            color: var(--light);\n            font-weight: 500;\n            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);\n            transition: all 0.3s ease;\n            overflow: hidden;\n        }\n\n        .layer:hover {\n            background: rgba(255, 255, 255, 0.1);\n            transform: translateY(-3px);\n        }\n\n        .layer::after {\n            content: '';\n            position: absolute;\n            left: 0;\n            top: 0;\n            height: 100%;\n            width: 5px;\n            background: var(--secondary);\n        }\n\n        .layer:nth-child(1)::after { background: var(--accent); }\n        .layer:nth-child(2)::after { background: var(--success); }\n        .layer:nth-child(3)::after { background: var(--secondary); }\n        .layer:nth-child(4)::after { background: #f39c12; }\n\n        .packet-flow {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n        }\n\n        .packet {\n            position: absolute;\n            width: 15px;\n            height: 15px;\n            border-radius: 50%;\n            background: var(--light);\n            filter: drop-shadow(0 0 10px rgba(236, 240, 241, 0.7));\n            animation: float 8s linear infinite;\n            opacity: 0;\n        }\n\n        @keyframes float {\n            0% {\n                left: -50px;\n                opacity: 0;\n            }\n            10% {\n                opacity: 1;\n            }\n            90% {\n                opacity: 1;\n            }\n            100% {\n                left: calc(100% + 50px);\n                opacity: 0;\n            }\n        }\n\n        .explanation {\n            margin: 5rem 0;\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            opacity: 0;\n            transition: opacity 1s ease;\n        }\n\n        .explanation.visible {\n            opacity: 1;\n        }\n\n        .card {\n            background: linear-gradient(145deg, rgba(44, 62, 80, 0.7), rgba(26, 37, 47, 0.9));\n            border-radius: 12px;\n            padding: 2rem;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n        }\n\n        .card:hover {\n            transform: translateY(-10px);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);\n        }\n\n        .card h3 {\n            color: var(--secondary);\n            margin-bottom: 1rem;\n            font-size: 1.5rem;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin: 3rem 0;\n            gap: 1rem;\n        }\n\n        button {\n            padding: 0.8rem 2rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(135deg, var(--secondary), var(--accent));\n            color: white;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(52, 152, 219, 0.4);\n        }\n\n        button:active {\n            transform: translateY(1px);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent);\n            transform: translateX(-100%);\n            transition: transform 0.4s ease;\n        }\n\n        button:hover::after {\n            transform: translateX(0);\n        }\n\n        .footer {\n            text-align: center;\n            margin-top: 5rem;\n            padding: 2rem;\n            color: rgba(255, 255, 255, 0.6);\n            font-size: 0.9rem;\n        }\n\n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .visualization {\n                height: 400px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>TCP/IP Protocol Suite</h1>\n            <p class=\"subtitle\">A visual representation of the fundamental communication protocols that power the Internet, presented with elegant clarity.</p>\n        </header>\n\n        <div class=\"visualization\" id=\"stack\">\n            <div class=\"layers\">\n                <div class=\"layer\">Application Layer (HTTP, FTP, SMTP)</div>\n                <div class=\"layer\">Transport Layer (TCP, UDP)</div>\n                <div class=\"layer\">Internet Layer (IP)</div>\n                <div class=\"layer\">Network Access Layer (Ethernet, WiFi)</div>\n            </div>\n            <div class=\"packet-flow\" id=\"packetFlow\"></div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"animateBtn\">Animate Data Flow</button>\n            <button id=\"explainBtn\">Show Protocol Details</button>\n        </div>\n\n        <div class=\"explanation\" id=\"explanation\">\n            <div class=\"card\">\n                <h3>Application Layer</h3>\n                <p>The top layer where network applications and protocols like HTTP, FTP, and SMTP operate. This layer provides services directly to user applications.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Transport Layer</h3>\n                <p>Responsible for end-to-end communication and error recovery. TCP provides reliable, ordered delivery, while UDP offers faster but unreliable transmission.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Internet Layer</h3>\n                <p>The IP (Internet Protocol) layer handles addressing and routing of packets across network boundaries. It's connectionless and doesn't guarantee delivery.</p>\n            </div>\n            <div class=\"card\">\n                <h3>Network Access</h3>\n                <p>The physical network components that handle transmission of raw bits over the network medium (cables, WiFi). Includes MAC addresses and physical signaling.</p>\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <p>© 2023 TCP/IP Visual Symphony | Designed for aesthetic education</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Animate elements on scroll\n            const observer = new IntersectionObserver((entries) => {\n                entries.forEach(entry => {\n                    if (entry.isIntersecting) {\n                        entry.target.classList.add('visible');\n                    }\n                });\n            }, { threshold: 0.1 });\n\n            document.querySelectorAll('.visualization, .explanation').forEach(el => {\n                observer.observe(el);\n            });\n\n            // Packet animation function\n            function createPackets() {\n                const flow = document.getElementById('packetFlow');\n                flow.innerHTML = '';\n                \n                const colors = ['#3498db', '#e74c3c', '#2ecc71', '#f1c40f'];\n                const delays = [0, 0.5, 1, 1.5, 2, 2.5];\n                \n                delays.forEach(delay => {\n                    colors.forEach((color, idx) => {\n                        const packet = document.createElement('div');\n                        packet.classList.add('packet');\n                        packet.style.background = color;\n                        packet.style.top = `${20 + (idx * 20)}%`;\n                        packet.style.animationDelay = `${delay}s`;\n                        flow.appendChild(packet);\n                        \n                        // Create a duplicate with different timing\n                        const packet2 = document.createElement('div');\n                        packet2.classList.add('packet');\n                        packet2.style.background = color;\n                        packet2.style.top = `${40 + (idx * 15)}%`;\n                        packet2.style.animationDelay = `${delay + 0.3}s`;\n                        flow.appendChild(packet2);\n                    });\n                });\n            }\n\n            // Button controls\n            document.getElementById('animateBtn').addEventListener('click', function() {\n                createPackets();\n                this.textContent = this.textContent.includes('Restart') ? 'Restart Animation' : 'Restart Animation';\n            });\n\n            document.getElementById('explainBtn').addEventListener('click', function() {\n                const explanation = document.getElementById('explanation');\n                explanation.style.display = explanation.style.display === 'none' ? 'grid' : 'grid';\n                this.textContent = explanation.style.display === 'none' ? 'Show Protocol Details' : 'Hide Protocol Details';\n            });\n\n            // Initial animations\n            setTimeout(() => {\n                document.querySelector('header').style.opacity = 1;\n                document.querySelector('header').style.transform = 'translateY(0)';\n            }, 300);\n\n            // Initial packet creation\n            createPackets();\n        });\n    </script>\n</body>\n</html>"
