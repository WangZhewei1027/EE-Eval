    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Tree — Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset and base */\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  html, body {\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #eaeaea;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 2rem 1rem 4rem 1rem;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    letter-spacing: 0.1em;\n    margin-bottom: 0.8rem;\n    text-transform: uppercase;\n    text-align: center;\n    color: #cdf0ea;\n    text-shadow: 0 0 6px #9ee3e8aa;\n    user-select: none;\n  }\n\n  h2 {\n    font-weight: 300;\n    font-size: 1.2rem;\n    color: #a3b1c6cc;\n    margin-bottom: 3rem;\n    text-align: center;\n    max-width: 380px;\n    line-height: 1.4;\n  }\n\n  #container {\n    position: relative;\n    width: 860px;\n    max-width: 95vw;\n    aspect-ratio: 1 / 0.75;\n    background: rgba(255 255 255 / 0.05);\n    border-radius: 1.2rem;\n    box-shadow:\n      inset 0 0 24px #34e0e099,\n      0 8px 32px rgba(18,138,198,0.4);\n    padding-top: 3rem;\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* COLORS & GLOW */\n  :root {\n    --node-fill: #1f456e;\n    --node-glow: #35d8ff;\n    --line-color: #5cc8ffcc;\n    --line-glow: #4bcfffaa;\n    --highlight-fill: #33d9b2;\n    --highlight-glow: #2adea9cc;\n  }\n\n  /* Node style */\n  .node {\n    cursor: default;\n    filter:\n      drop-shadow(0 0 4px var(--node-glow))\n      drop-shadow(0 0 10px var(--node-glow));\n    transition: filter 0.3s ease;\n  }\n\n  .node circle {\n    fill: var(--node-fill);\n    stroke: #b4eaffcc;\n    stroke-width: 2;\n    transition: fill 0.3s ease, stroke 0.3s ease;\n  }\n\n  .node text {\n    fill: #c4ecffdd;\n    font-weight: 600;\n    font-size: 14px;\n    user-select: none;\n    pointer-events: none;\n    font-variant-numeric: tabular-nums;\n    letter-spacing: 0.07em;\n  }\n\n  /* Lines style */\n  .link {\n    stroke: var(--line-color);\n    stroke-width: 3;\n    transition: stroke 0.3s ease;\n    filter: drop-shadow(0 0 4px var(--line-glow));\n  }\n\n  /* Hover effect to highlight branches */\n  /* Limited interactivity - subtle glow on hover on node */\n  .node:hover circle {\n    fill: var(--highlight-fill);\n    stroke: #92ffe9cc;\n    filter:\n      drop-shadow(0 0 8px var(--highlight-glow))\n      drop-shadow(0 0 20px var(--highlight-glow));\n  }\n  .node:hover ~ .link {\n    stroke: var(--highlight-glow);\n    stroke-width: 3.5;\n    filter: drop-shadow(0 0 8px var(--highlight-glow));\n  }\n\n  /* BUTTONS panel */\n  #buttons {\n    margin-top: 2rem;\n    display: flex;\n    gap: 1rem;\n    justify-content: center;\n  }\n\n  button {\n    background: #1c3c5c;\n    border: 2px solid #2eccdbcc;\n    border-radius: 9999px;\n    color: #a4f9f8;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.65rem 1.6rem;\n    cursor: pointer;\n    transition:\n      background-color 0.35s ease,\n      color 0.35s ease,\n      border-color 0.35s ease,\n      box-shadow 0.35s ease;\n    user-select: none;\n    box-shadow: 0 0 16px #31dbdbaa;\n    text-shadow: 0 0 6px #31dbdbbb;\n  }\n  button:focus {\n    outline: none;\n    box-shadow: 0 0 24px #48f9f9dd;\n  }\n  button:hover {\n    background-color: #27e5f9;\n    border-color: #19b8ca99;\n    color: #064d56;\n    box-shadow:\n      0 0 24px #00f3ffdd,\n      0 2px 14px #00e0ffcc;\n  }\n\n  /* Animations */\n\n  /* subtle fade-in for entire container */\n  #container {\n    opacity: 0;\n    animation: fadeInSmooth 2s ease forwards;\n  }\n\n  @keyframes fadeInSmooth {\n    to {\n      opacity: 1;\n    }\n  }\n\n  /* Animate edges drawing */\n  .link {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n    animation: drawLine 1.2s forwards;\n    animation-timing-function: cubic-bezier(.19,1,.22,1);\n  }\n\n  /* Each line will have delay, set later in JS */\n\n  @keyframes drawLine {\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Nodes fade & scale in */\n  .node {\n    opacity: 0;\n    transform-origin: center center;\n    animation: appearNode 0.7s forwards;\n    animation-timing-function: cubic-bezier(0.39,0.575,0.565,1);\n  }\n\n  /* Delays added in JS for stagger */\n\n  @keyframes appearNode {\n    0% {\n      opacity: 0;\n      transform: scale(0.5);\n    }\n    100% {\n      opacity: 1;\n      transform: scale(1);\n    }\n  }\n\n  /* Footer text */\n  #footer {\n    margin-top: 3rem;\n    font-weight: 300;\n    font-size: 0.85rem;\n    color: #5080a999;\n    font-style: italic;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n  <h1>Binary Tree</h1>\n  <h2>An elegant, animated visualization of the canonical binary tree structure with balanced geometry and luminous aesthetic.</h2>\n  <div id=\"container\" aria-label=\"Binary Tree Visualization\">\n    <svg viewBox=\"0 0 860 645\" aria-hidden=\"true\" role=\"img\" >\n      <g id=\"links\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <!-- Links inserted by JS -->\n      </g>\n      <g id=\"nodes\" >\n        <!-- Nodes inserted by JS -->\n      </g>\n    </svg>\n  </div>\n  <div id=\"buttons\" aria-label=\"Controls\">\n    <button id=\"btnExpand\" aria-pressed=\"false\" aria-label=\"Toggle expand or collapse tree\">Expand Tree</button>\n  </div>\n  <div id=\"footer\">© Visual Concept by ChatGPT &mdash; June 2024</div>\n\n<script>\n  (() => {\n    /* Binary Tree representation with positions for aesthetics\n      Node IDs follow a 1-based system:\n        1\n       / \\\n      2   3\n     / \\ / \\\n    4  5 6  7\n    We provide balanced x,y coords for nice visual.\n\n    Two tree states:\n      - Collapsed: only root and 2 children (levels 1 and 2)\n      - Expanded: full tree with level 3 nodes\n    */\n    \n    const svgNS = \"http://www.w3.org/2000/svg\";\n\n    // Node positioning for expanded tree (7 nodes)\n    // (x,y) in SVG viewbox coords (860x645)\n    // Balanced horizontally by levels\n\n    const expandedNodes = [\n      {id:1, val:1, x: 430, y: 70},\n      {id:2, val:2, x: 220, y: 200},\n      {id:3, val:3, x: 640, y: 200},\n      {id:4, val:4, x: 120, y: 350},\n      {id:5, val:5, x: 320, y: 350},\n      {id:6, val:6, x: 545, y: 350},\n      {id:7, val:7, x: 740, y: 350},\n    ];\n\n    // Links between nodes for expanded tree\n    const expandedLinks = [\n      {from:1, to:2},\n      {from:1, to:3},\n      {from:2, to:4},\n      {from:2, to:5},\n      {from:3, to:6},\n      {from:3, to:7},\n    ];\n\n    // Collapsed tree (3 nodes) positions:\n    const collapsedNodes = [\n      {id:1, val:1, x: 430, y: 70},\n      {id:2, val:2, x: 250, y: 250},\n      {id:3, val:3, x: 610, y: 250},\n    ];\n    // Collapsed links:\n    const collapsedLinks = [\n      {from:1, to:2},\n      {from:1, to:3},\n    ];\n\n    const svg = document.querySelector(\"#container svg\");\n    const nodesGroup = document.getElementById(\"nodes\");\n    const linksGroup = document.getElementById(\"links\");\n    const btnExpand = document.getElementById(\"btnExpand\");\n\n    // Generic function to create svg element\n    function createSVG(tag, attrs = {}, extraClass = '') {\n      const el = document.createElementNS(svgNS, tag);\n      for (let [k,v] of Object.entries(attrs)) {\n        el.setAttribute(k, v);\n      }\n      if(extraClass) el.classList.add(extraClass);\n      return el;\n    }\n\n    // Create line link element with animation delay\n    function createLink(fromNode, toNode, delay) {\n      const line = createSVG(\"line\", {\n        class:\"link\",\n        'x1': fromNode.x,\n        'y1': fromNode.y,\n        'x2': toNode.x,\n        'y2': toNode.y,\n        style: `animation-delay: ${delay}s`,\n        // accessibility no need, lines are decorative so aria-hidden\n        'aria-hidden': 'true',\n      });\n      return line;\n    }\n\n    // Create a node group with circle and text\n    function createNode(nodeData, delay) {\n      /*\n        We'll create a group <g> with class 'node' and animation delay.\n        Circle radius 26 px.\n        Text with node value centered vertically and horizontally.\n      */\n      const g = createSVG(\"g\", {\n        class: \"node\",\n        style: `animation-delay: ${delay}s`,\n        tabindex: \"-1\",\n        role: \"img\",\n        'aria-label': `Node ${nodeData.val}`\n      }, 'node');\n\n      // Circle with subtle ripple gradient fill\n      const circ = createSVG(\"circle\", {\n        cx: nodeData.x,\n        cy: nodeData.y,\n        r: 26,\n        filter: \"url(#glow)\",\n        'aria-hidden': 'true',\n      });\n\n      // Text for value (centered)\n      const txt = createSVG(\"text\", {\n        x: nodeData.x,\n        y: nodeData.y + 5,\n        'text-anchor': 'middle',\n        'dominant-baseline': 'middle',        \n      });\n      txt.textContent = nodeData.val;\n\n      g.appendChild(circ);\n      g.appendChild(txt);\n      return g;\n    }\n\n    // Clear current nodes and links\n    function clearTree() {\n      while(nodesGroup.firstChild) nodesGroup.removeChild(nodesGroup.firstChild);\n      while(linksGroup.firstChild) linksGroup.removeChild(linksGroup.firstChild);\n    }\n\n    // Render tree given nodes and links arrays\n    function renderTree(nodes, links) {\n      clearTree();\n\n      // Animate: We'll stagger nodes and links with small delays\n      // Draw all links first (so lines behind nodes)\n      links.forEach((link,i) => {\n        // Delay on each link 0.2 + i*0.15\n        const fromNode = nodes.find(n=>n.id===link.from);\n        const toNode = nodes.find(n=>n.id===link.to);\n        const delay = 0.35 + i*0.17;\n        if(fromNode && toNode) {\n          const linkEl = createLink(fromNode,toNode,delay);\n          linksGroup.appendChild(linkEl);\n        }\n      });\n\n      // Draw nodes\n      nodes.forEach((node,i) => {\n        const delay = 0.1 + i*0.15;\n        const nodeEl = createNode(node, delay);\n        nodesGroup.appendChild(nodeEl);\n      });\n    }\n\n    // Create SVG glow filter for nodes (for sophisticated neon look)\n    function createGlows() {\n      const defs = createSVG('defs');\n      const filter = createSVG('filter', { id: 'glow', x:'-50%', y:'-50%', width:'200%', height:'200%' });\n\n      const feGaussianBlur = createSVG('feDropShadow', {\n        dx: '0',\n        dy: '0',\n        stdDeviation: '5',\n        floodColor: '#2ae0ff',\n        floodOpacity: '0.7'\n      });\n\n      filter.appendChild(feGaussianBlur);\n      defs.appendChild(filter);\n      svg.appendChild(defs);\n    }\n\n    createGlows();\n\n    // State management\n    let expanded = false;\n\n    function updateUI() {\n      if(expanded) {\n        renderTree(expandedNodes, expandedLinks);\n        btnExpand.textContent = \"Collapse Tree\";\n        btnExpand.setAttribute('aria-pressed', 'true');\n      } else {\n        renderTree(collapsedNodes, collapsedLinks);\n        btnExpand.textContent = \"Expand Tree\";\n        btnExpand.setAttribute('aria-pressed', 'false');\n      }\n    }\n\n    // Initial render\n    updateUI();\n\n    // Button event for toggling expand/collapse\n    btnExpand.addEventListener('click', () => {\n      expanded = !expanded;\n      updateUI();\n    });\n\n  })();\n</script>\n</body>\n</html>"
