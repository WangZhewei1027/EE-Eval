    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Quick Sort Visualization — Aesthetic Demo</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n  :root {\n    --color-bg: #0a0f2c;\n    --color-primary: #ffd966;\n    --color-secondary: #ff6f91;\n    --color-accent: #7ae7ff;\n    --color-neutral: #d3d3d3;\n    --color-shadow: rgba(255, 217, 102, 0.45);\n    --color-bar-base: #2b2f4a;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    background: linear-gradient(135deg, #0a0f2c 0%, #171b3a 100%);\n    margin: 0;\n    font-family: 'Montserrat', sans-serif;\n    color: var(--color-neutral);\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  header {\n    text-align: center;\n    padding: 3rem 1rem 1rem;\n    user-select: none;\n  }\n  header h1 {\n    font-weight: 700;\n    font-size: 3.6rem;\n    letter-spacing: 0.14em;\n    color: var(--color-primary);\n    margin-bottom: 0.1em;\n    text-shadow:\n      0 0 12px var(--color-primary),\n      0 0 28px var(--color-primary);\n  }\n  header p {\n    font-weight: 400;\n    font-size: 1.25rem;\n    font-style: italic;\n    color: var(--color-accent);\n    text-shadow: 0 0 5px var(--color-accent);\n  }\n\n  main {\n    max-width: 900px;\n    margin: 3rem auto 6rem;\n    padding: 0 1.5rem;\n  }\n\n  .viz-container {\n    position: relative;\n    height: 380px;\n    background: radial-gradient(circle at center, #191f42 30%, #0a0f2c 100%);\n    border-radius: 1.15rem;\n    box-shadow:\n      inset 0 0 70px #141a3b,\n      0 10px 40px -5px rgba(255, 217, 102, 0.3);\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    padding: 0 18px 2rem 18px;\n    user-select: none;\n  }\n\n  .bars {\n    display: flex;\n    align-items: flex-end;\n    gap: 10px;\n    width: 100%;\n    max-width: 820px;\n    height: 340px;\n  }\n\n  .bar {\n    --h: 100%;\n    flex: 1 1 16px;\n    max-width: 32px;\n    position: relative;\n    border-radius: 0.55rem 0.55rem 0.12rem 0.12rem;\n    background-color: var(--color-bar-base);\n    box-shadow:\n      inset 0 -8px 10px rgba(255 217 102 / 0.2),\n      0 0 25px rgba(255 217 102 / 0.1);\n    cursor: default;\n    transition:\n      background-color 0.55s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.55s cubic-bezier(0.4, 0, 0.2, 1),\n      height 0.9s cubic-bezier(0.4, 0, 0.2, 1),\n      filter 0.55s ease;\n    will-change: height, background-color, box-shadow, filter;\n  }\n  .bar:after {\n    content: attr(data-val);\n    position: absolute;\n    top: -2.9rem;\n    left: 50%;\n    transform: translateX(-50%);\n    font-weight: 700;\n    color: var(--color-accent);\n    font-size: 1rem;\n    letter-spacing: 0.05em;\n    user-select: none;\n    text-shadow:\n      0 0 5px var(--color-accent);\n  }\n\n  /* Height defined by inline style --h variable */\n  .bar {\n    height: calc(var(--h) * 1%);\n  }\n\n  /* Bar states */\n\n  .bar.pivot {\n    background-color: var(--color-secondary);\n    box-shadow:\n      0 0 24px var(--color-secondary),\n      inset 0 0 16px var(--color-secondary);\n    filter: drop-shadow(0 0 10px var(--color-secondary));\n    z-index: 2;\n  }\n  .bar.comparing {\n    background-color: var(--color-accent);\n    box-shadow:\n      0 0 24px var(--color-accent),\n      inset 0 0 16px var(--color-accent);\n    filter: drop-shadow(0 0 8px var(--color-accent));\n  }\n  .bar.swapped {\n    background-color: var(--color-primary);\n    box-shadow:\n      0 0 32px var(--color-primary),\n      inset 0 0 22px var(--color-primary);\n    filter: drop-shadow(0 0 12px var(--color-primary));\n  }\n  .bar.sorted {\n    background-color: #44dd88;\n    box-shadow:\n      0 0 28px #44dd88,\n      inset 0 0 18px #44dd88;\n    filter: drop-shadow(0 0 10px #44dd88);\n  }\n\n  /* Buttons */\n\n  .controls {\n    display: flex;\n    justify-content: center;\n    gap: 24px;\n    margin: 0 auto 1rem;\n    user-select: none;\n  }\n  button {\n    background: transparent;\n    border: 2.5px solid var(--color-primary);\n    padding: 0.85rem 2.5rem;\n    border-radius: 3.2rem;\n    letter-spacing: 0.14em;\n    color: var(--color-primary);\n    font-weight: 700;\n    font-size: 1.05rem;\n    cursor: pointer;\n    transition:\n      color 0.3s ease,\n      background-color 0.3s ease,\n      border-color 0.3s ease,\n      box-shadow 0.3s ease;\n    font-family: 'Montserrat', sans-serif;\n    box-shadow: 0 0 25px rgba(255, 217, 102, 0.2);\n  }\n  button:hover,\n  button:focus-visible {\n    outline: none;\n    background-color: var(--color-primary);\n    color: var(--color-bg);\n    border-color: var(--color-primary);\n    box-shadow:\n      0 0 40px var(--color-primary);\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  footer {\n    text-align: center;\n    padding: 3rem 1rem 5rem;\n    font-size: 0.85rem;\n    color: #666d8b;\n    font-weight: 400;\n    font-style: italic;\n    letter-spacing: 0.08em;\n    user-select: none;\n  }\n\n  @media (max-width: 480px) {\n    header h1 {\n      font-size: 2.7rem;\n      letter-spacing: 0.12em;\n    }\n    header p {\n      font-size: 1rem;\n    }\n    .bars {\n      gap: 6px;\n      max-width: 100%;\n    }\n    .bar {\n      max-width: 14px;\n    }\n    main {\n      margin: 2rem 1rem 5rem;\n    }\n  }\n\n</style>\n</head>\n<body>\n<header role=\"banner\" aria-label=\"Page header\">\n  <h1>QUICK SORT</h1>\n  <p>Elegant Visualization &amp; Animation</p>\n</header>\n<main role=\"main\" aria-label=\"Quick Sort visualization\">\n  <div class=\"viz-container\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n    <div class=\"bars\" aria-label=\"Array bars representing numbers to sort\"></div>\n  </div>\n  <nav class=\"controls\" aria-label=\"Visualization controls\">\n    <button id=\"startBtn\" aria-controls=\"bars\" aria-disabled=\"false\" aria-live=\"polite\" title=\"Start sorting animation\">START</button>\n    <button id=\"resetBtn\" aria-controls=\"bars\" aria-disabled=\"false\" aria-live=\"polite\" title=\"Reset to new random array\">RESET</button>\n  </nav>\n</main>\n<footer>\n  Crafted with meticulous care &mdash; Experience the finesse of Quick Sort.\n</footer>\n<script>\n  (() => {\n    const barsContainer = document.querySelector('.bars');\n    const startBtn = document.getElementById('startBtn');\n    const resetBtn = document.getElementById('resetBtn');\n\n    // Config\n    const ARRAY_SIZE = 30;\n    const MIN_VALUE = 7;\n    const MAX_VALUE = 95;\n\n    let array = [];\n    let sorting = false;\n\n    // Utility: delay (ms)\n    const delay = (ms) => new Promise(res => setTimeout(res, ms));\n\n    // Create initial random array, avoid duplicates for cleaner visualization\n    function createRandomArray(size, min, max) {\n      const s = new Set();\n      while (s.size < size) {\n        s.add(Math.floor(Math.random() * (max - min + 1)) + min);\n      }\n      return Array.from(s);\n    }\n\n    // Render bars based on current array values & states\n    // states arg: {pivotIndex, compareIndices, swapIndices, sortedIndices}\n    function renderBars(states = {}) {\n      const {\n        pivotIndex = null,\n        compareIndices = [],\n        swapIndices = [],\n        sortedIndices = []\n      } = states;\n\n      barsContainer.innerHTML = '';\n      const max = Math.max(...array);\n\n      array.forEach((val, i) => {\n        const bar = document.createElement('div');\n        bar.classList.add('bar');\n        bar.style.setProperty('--h', val * 1);\n        bar.setAttribute('data-val', val);\n        bar.setAttribute('role', 'img');\n        bar.setAttribute('aria-label', `Value ${val}`);\n\n        // Assign classes for states\n        if (sortedIndices.includes(i)) bar.classList.add('sorted');\n        else if (swapIndices.includes(i)) bar.classList.add('swapped');\n        else if (pivotIndex === i) bar.classList.add('pivot');\n        else if (compareIndices.includes(i)) bar.classList.add('comparing');\n\n        barsContainer.appendChild(bar);\n      });\n    }\n\n    // Quick Sort with visual steps & animations\n    async function quickSort(left = 0, right = array.length - 1) {\n      if (left >= right) {\n        if (left === right) sortedIndices.add(left);\n        return;\n      }\n\n      let pivotIndex = right;\n      let pivotValue = array[pivotIndex];\n      let i = left;\n\n      renderBars({ pivotIndex, sortedIndices: Array.from(sortedIndices) });\n      await delay(600);\n\n      for (let j = left; j < right; j++) {\n        if (!sorting) return;\n\n        renderBars({\n          pivotIndex,\n          compareIndices: [j, i],\n          sortedIndices: Array.from(sortedIndices)\n        });\n        await delay(250);\n\n        if (array[j] < pivotValue) {\n          if (i !== j) {\n            [array[i], array[j]] = [array[j], array[i]];\n\n            renderBars({\n              pivotIndex,\n              swapIndices: [i, j],\n              sortedIndices: Array.from(sortedIndices)\n            });\n            await delay(500);\n          }\n          i++;\n        }\n      }\n\n      // Swap pivot with i\n      if (i !== pivotIndex) {\n        [array[i], array[pivotIndex]] = [array[pivotIndex], array[i]];\n        renderBars({ swapIndices: [i, pivotIndex], sortedIndices: Array.from(sortedIndices) });\n        await delay(650);\n      }\n\n      sortedIndices.add(i);\n\n      // Mark pivot position sorted\n      renderBars({ sortedIndices: Array.from(sortedIndices) });\n      await delay(400);\n\n      // Recurse left side\n      await quickSort(left, i - 1);\n      // Recurse right side\n      await quickSort(i + 1, right);\n    }\n\n    // Sorted indices set for visual styling\n    let sortedIndices;\n\n    /** Reset visualization to new random array */\n    function resetVisualization() {\n      if (sorting) return;\n      array = createRandomArray(ARRAY_SIZE, MIN_VALUE, MAX_VALUE);\n      sortedIndices = new Set();\n      renderBars();\n    }\n\n    /** Start sorting animation */\n    async function startVisualization() {\n      if (sorting) return;\n      sorting = true;\n      startBtn.setAttribute('aria-disabled', 'true');\n      resetBtn.setAttribute('aria-disabled', 'true');\n      startBtn.disabled = true;\n      resetBtn.disabled = true;\n\n      await quickSort();\n\n      // Final mark all as sorted (in case any missed)\n      sortedIndices = new Set(array.map((_, i) => i));\n      renderBars({ sortedIndices: Array.from(sortedIndices) });\n\n      sorting = false;\n      startBtn.removeAttribute('aria-disabled');\n      resetBtn.removeAttribute('aria-disabled');\n      startBtn.disabled = false;\n      resetBtn.disabled = false;\n    }\n\n    // Initialization\n    resetVisualization();\n\n    // Event listeners\n    startBtn.addEventListener('click', () => {\n      if (!sorting) startVisualization();\n    });\n    resetBtn.addEventListener('click', () => {\n      if (!sorting) resetVisualization();\n    });\n\n    // Accessibility: focus indicators visible only with keyboard\n    document.body.addEventListener('keydown', (e) => {\n      if (e.key === 'Tab') document.body.classList.add('user-is-tabbing');\n    });\n    document.body.addEventListener('mousedown', () => {\n      document.body.classList.remove('user-is-tabbing');\n    });\n  })();\n</script>\n</body>\n</html>"
