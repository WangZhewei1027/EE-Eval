    "content": "<html>\n<head>\n    <title>Interactive Array Explorer</title>\n    <script>\n        let array = [];\n        let history = [];\n        let maxHistory = 20;\n        \n        function init() {\n            updateDisplay();\n            document.getElementById('arrayLength').addEventListener('input', updateLengthControls);\n            document.getElementById('randomizeBtn').addEventListener('click', randomizeArray);\n            document.getElementById('reverseBtn').addEventListener('click', reverseArray);\n            document.getElementById('sortBtn').addEventListener('click', sortArray);\n            document.getElementById('shuffleBtn').addEventListener('click', shuffleArray);\n            document.getElementById('pushBtn').addEventListener('click', pushValue);\n            document.getElementById('popBtn').addEventListener('click', popValue);\n            document.getElementById('unshiftBtn').addEventListener('click', unshiftValue);\n            document.getElementById('shiftBtn').addEventListener('click', shiftValue);\n            document.getElementById('spliceBtn').addEventListener('click', spliceArray);\n            document.getElementById('mapBtn').addEventListener('click', mapArray);\n            document.getElementById('filterBtn').addEventListener('click', filterArray);\n            document.getElementById('reduceBtn').addEventListener('click', reduceArray);\n            document.getElementById('findBtn').addEventListener('click', findInArray);\n            document.getElementById('undoBtn').addEventListener('click', undoAction);\n            document.getElementById('arrayLength').value = 10;\n            createArray();\n        }\n        \n        function saveState() {\n            history.push([...array]);\n            if (history.length > maxHistory) {\n                history.shift();\n            }\n        }\n        \n        function undoAction() {\n            if (history.length > 0) {\n                array = history.pop();\n                updateDisplay();\n            }\n        }\n        \n        function createArray() {\n            saveState();\n            const length = parseInt(document.getElementById('arrayLength').value);\n            array = new Array(length).fill(0);\n            updateDisplay();\n        }\n        \n        function randomizeArray() {\n            saveState();\n            const min = parseInt(document.getElementById('randomMin').value);\n            const max = parseInt(document.getElementById('randomMax').value);\n            array = array.map(() => Math.floor(Math.random() * (max - min + 1)) + min);\n            updateDisplay();\n        }\n        \n        function reverseArray() {\n            saveState();\n            array.reverse();\n            updateDisplay();\n        }\n        \n        function sortArray() {\n            saveState();\n            const order = document.getElementById('sortOrder').value;\n            if (order === 'asc') {\n                array.sort((a, b) => a - b);\n            } else {\n                array.sort((a, b) => b - a);\n            }\n            updateDisplay();\n        }\n        \n        function shuffleArray() {\n            saveState();\n            for (let i = array.length - 1; i > 0; i--) {\n                const j = Math.floor(Math.random() * (i + 1));\n                [array[i], array[j]] = [array[j], array[i]];\n            }\n            updateDisplay();\n        }\n        \n        function pushValue() {\n            saveState();\n            const value = parseInt(document.getElementById('pushValue').value);\n            array.push(value);\n            updateDisplay();\n        }\n        \n        function popValue() {\n            saveState();\n            const popped = array.pop();\n            document.getElementById('operationResult').textContent = `Popped: ${popped}`;\n            updateDisplay();\n        }\n        \n        function unshiftValue() {\n            saveState();\n            const value = parseInt(document.getElementById('unshiftValue').value);\n            array.unshift(value);\n            updateDisplay();\n        }\n        \n        function shiftValue() {\n            saveState();\n            const shifted = array.shift();\n            document.getElementById('operationResult').textContent = `Shifted: ${shifted}`;\n            updateDisplay();\n        }\n        \n        function spliceArray() {\n            saveState();\n            const start = parseInt(document.getElementById('spliceStart').value);\n            const deleteCount = parseInt(document.getElementById('spliceDelete').value);\n            const value = parseInt(document.getElementById('spliceValue').value);\n            \n            if (deleteCount > 0) {\n                const deleted = array.splice(start, deleteCount, value);\n                document.getElementById('operationResult').textContent = `Deleted: ${deleted.join(', ')}`;\n            } else {\n                array.splice(start, 0, value);\n            }\n            updateDisplay();\n        }\n        \n        function mapArray() {\n            saveState();\n            const operation = document.getElementById('mapOperation').value;\n            switch(operation) {\n                case 'square':\n                    array = array.map(x => x * x);\n                    break;\n                case 'double':\n                    array = array.map(x => x * 2);\n                    break;\n                case 'increment':\n                    array = array.map(x => x + 1);\n                    break;\n                case 'decrement':\n                    array = array.map(x => x - 1);\n                    break;\n            }\n            updateDisplay();\n        }\n        \n        function filterArray() {\n            saveState();\n            const condition = document.getElementById('filterCondition').value;\n            const value = parseInt(document.getElementById('filterValue').value);\n            \n            switch(condition) {\n                case 'gt':\n                    array = array.filter(x => x > value);\n                    break;\n                case 'lt':\n                    array = array.filter(x => x < value);\n                    break;\n                case 'eq':\n                    array = array.filter(x => x === value);\n                    break;\n                case 'even':\n                    array = array.filter(x => x % 2 === 0);\n                    break;\n                case 'odd':\n                    array = array.filter(x => x % 2 !== 0);\n                    break;\n            }\n            updateDisplay();\n        }\n        \n        function reduceArray() {\n            const operation = document.getElementById('reduceOperation').value;\n            let result;\n            \n            switch(operation) {\n                case 'sum':\n                    result = array.reduce((acc, val) => acc + val, 0);\n                    break;\n                case 'product':\n                    result = array.reduce((acc, val) => acc * val, 1);\n                    break;\n                case 'max':\n                    result = array.reduce((acc, val) => Math.max(acc, val), -Infinity);\n                    break;\n                case 'min':\n                    result = array.reduce((acc, val) => Math.min(acc, val), Infinity);\n                    break;\n            }\n            \n            document.getElementById('operationResult').textContent = `Result: ${result}`;\n        }\n        \n        function findInArray() {\n            const condition = document.getElementById('findCondition').value;\n            const value = parseInt(document.getElementById('findValue').value);\n            let result;\n            \n            switch(condition) {\n                case 'gt':\n                    result = array.find(x => x > value);\n                    break;\n                case 'lt':\n                    result = array.find(x => x < value);\n                    break;\n                case 'eq':\n                    result = array.find(x => x === value);\n                    break;\n            }\n            \n            document.getElementById('operationResult').textContent = `Found: ${result}`;\n        }\n        \n        function updateLengthControls() {\n            const length = document.getElementById('arrayLength').value;\n            document.getElementById('lengthValue').textContent = length;\n        }\n        \n        function updateDisplay() {\n            document.getElementById('arrayDisplay').textContent = `[${array.join(', ')}]`;\n            document.getElementById('arrayInfo').textContent = `Length: ${array.length}`;\n            document.getElementById('historyCount').textContent = `Undo steps: ${history.length}`;\n        }\n    </script>\n</head>\n<body onload=\"init()\">\n    <h1>Interactive Array Explorer</h1>\n    \n    <div>\n        <h2>Array Creation</h2>\n        <div>\n            <label>Length: <span id=\"lengthValue\">10</span></label>\n            <input type=\"range\" id=\"arrayLength\" min=\"1\" max=\"50\" value=\"10\">\n            <button onclick=\"createArray()\">Create Array</button>\n        </div>\n        \n        <div>\n            <label>Random Range: </label>\n            <input type=\"number\" id=\"randomMin\" value=\"1\" min=\"-100\" max=\"100\">\n            <span> to </span>\n            <input type=\"number\" id=\"randomMax\" value=\"100\" min=\"-100\" max=\"100\">\n            <button id=\"randomizeBtn\">Randomize Values</button>\n        </div>\n    </div>\n    \n    <div>\n        <h2>Array Display</h2>\n        <div id=\"arrayDisplay\">[]</div>\n        <div id=\"arrayInfo\">Length: 0</div>\n        <div id=\"operationResult\"></div>\n    </div>\n    \n    <div>\n        <h2>Basic Operations</h2>\n        <div>\n            <button id=\"reverseBtn\">Reverse</button>\n            <button id=\"sortBtn\">Sort</button>\n            <select id=\"sortOrder\">\n                <option value=\"asc\">Ascending</option>\n                <option value=\"desc\">Descending</option>\n            </select>\n            <button id=\"shuffleBtn\">Shuffle</button>\n        </div>\n        \n        <div>\n            <input type=\"number\" id=\"pushValue\" value=\"0\">\n            <button id=\"pushBtn\">Push</button>\n            <button id=\"popBtn\">Pop</button>\n        </div>\n        \n        <div>\n            <input type=\"number\" id=\"unshiftValue\" value=\"0\">\n            <button id=\"unshiftBtn\">Unshift</button>\n            <button id=\"shiftBtn\">Shift</button>\n        </div>\n        \n        <div>\n            <label>Splice: </label>\n            <input type=\"number\" id=\"spliceStart\" value=\"0\" min=\"0\" placeholder=\"Start\">\n            <input type=\"number\" id=\"spliceDelete\" value=\"0\" min=\"0\" placeholder=\"Delete\">\n            <input type=\"number\" id=\"spliceValue\" value=\"0\" placeholder=\"Value\">\n            <button id=\"spliceBtn\">Splice</button>\n        </div>\n    </div>\n    \n    <div>\n        <h2>Functional Operations</h2>\n        <div>\n            <label>Map: </label>\n            <select id=\"mapOperation\">\n                <option value=\"square\">Square</option>\n                <option value=\"double\">Double</option>\n                <option value=\"increment\">Increment</option>\n                <option value=\"decrement\">Decrement</option>\n            </select>\n            <button id=\"mapBtn\">Apply Map</button>\n        </div>\n        \n        <div>\n            <label>Filter: </label>\n            <select id=\"filterCondition\">\n                <option value=\"gt\">Greater than</option>\n                <option value=\"lt\">Less than</option>\n                <option value=\"eq\">Equal to</option>\n                <option value=\"even\">Even</option>\n                <option value=\"odd\">Odd</option>\n            </select>\n            <input type=\"number\" id=\"filterValue\" value=\"0\">\n            <button id=\"filterBtn\">Apply Filter</button>\n        </div>\n        \n        <div>\n            <label>Reduce: </label>\n            <select id=\"reduceOperation\">\n                <option value=\"sum\">Sum</option>\n                <option value=\"product\">Product</option>\n                <option value=\"max\">Maximum</option>\n                <option value=\"min\">Minimum</option>\n            </select>\n            <button id=\"reduceBtn\">Calculate</button>\n        </div>\n        \n        <div>\n            <label>Find: </label>\n            <select id=\"findCondition\">\n                <option value=\"gt\">Greater than</option>\n                <option value=\"lt\">Less than</option>\n                <option value=\"eq\">Equal to</option>\n            </select>\n            <input type=\"number\" id=\"findValue\" value=\"0\">\n            <button id=\"findBtn\">Find</button>\n        </div>\n    </div>\n    \n    <div>\n        <h2>History</h2>\n        <div>\n            <span id=\"historyCount\">Undo steps: 0</span>\n            <button id=\"undoBtn\">Undo</button>\n        </div>\n    </div>\n</body>\n</html>"
