etwork() {\n            let inputs = trainingData.map(data => data.input);\n            let outputs = trainingData.map(data => data.output);\n            let predictions = [];\n\n            for (let i = 0; i < inputs.length; i++) {\n                let prediction = predict(inputs[i], weights, biases);\n                predictions.push(prediction);\n            }\n\n            for (let i = 0; i < inputs.length; i++) {\n                let error = prediction - outputs[i];\n                weights[i] += 0.1 * error * inputs[i];\n                biases[i] += 0.1 * error * outputs[i];\n            }\n\n            console.log(\"Training complete.\");\n        }\n\n        function predict(input) {\n            let sum = 0;\n            for (let i = 0; i < input.length; i++) {\n                sum += input[i] * weights[i];\n            }\n            return sum;\n        }\n\n        let training = true;\n        let input = [];\n        let output = [];\n\n        function updateWeightsAndBiases() {\n            if (training) {\n                let inputs = trainingData.map(data => data.input);\n                let outputs = trainingData.map(data => data.output);\n                let predictions = [];\n\n                for (let i = 0; i < inputs.length; i++) {\n                    let prediction = predict(inputs[i], weights, biases);\n                    predictions.push(prediction);\n                }\n\n                for (let i = 0; i < inputs.length; i++) {\n                    let error = prediction - outputs[i];\n                    weights[i] += 0.1 * error * inputs[i];\n                    biases[i] += 0.1 * error * outputs[i];\n                }\n\n                if (input.length < 10) {\n                    input.push(...inputs);\n                    output.push(...outputs);\n                } else {\n                    let inputs = input.slice(0, 10);\n                    let outputs = output.slice(0, 10);\n                    let predictions = [];\n\n                    for (let i = 0; i < inputs.length; i++) {\n                        let prediction = predict(inputs[i], weights, biases);\n                        predictions.push(prediction);\n                    }\n\n                    for (let i = 0; i < inputs.length; i++) {\n                        let error = prediction - outputs[i];\n                        weights[i] += 0.1 * error * inputs[i];\n                        biases[i] += 0.1 * error * outputs[i];\n                    }\n\n                    input = inputs.slice(10);\n                    output = outputs.slice(10);\n                }\n\n                if (input.length < 10) {\n                    input.push(...inputs);\n                    output.push(...outputs);\n                } else {\n                    let inputs = input.slice(0, 10);\n                    let outputs = output.slice(0, 10);\n                    let predictions = [];\n\n                    for (let i = 0; i < inputs.length; i++) {\n                        let prediction = predict(inputs[i], weights, biases);\n                        predictions.push(prediction);\n                    }\n\n                    for (let i = 0; i < inputs.length; i++) {\n                        let error = prediction - outputs[i];\n                        weights[i] += 0.1 * error * inputs[i];\n                        biases[i] += 0.1 * error * outputs[i];\n                    }\n\n                    input = inputs.slice(10);\n                    output = outputs.slice(10);\n                }\n            }\n        }\n\n        function updateWeightsAndBiasesButton() {\n            if (training) {\n                updateWeightsAndBiases();\n            }\n        }\n\n        let button = document.getElementById(\"train-button\");\n        let button2 = document.getElementById(\"predict-button\");\n        button.addEventListener(\"click\", trainNetwork);\n        button2.addEventListener(\"click\", updateWeightsAndBiasesButton);\n    </scri