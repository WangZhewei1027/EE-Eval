    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Virtual Memory — Visual Demonstration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#071028;\n    --glass: rgba(255,255,255,0.06);\n    --accent: #7ee7c6;\n    --accent2: #6ec1ff;\n    --muted: rgba(255,255,255,0.45);\n    --danger: #ff6b6b;\n    --card: rgba(255,255,255,0.03);\n    --glass-border: rgba(255,255,255,0.06);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(110,193,255,0.06), transparent),\n                radial-gradient(900px 500px at 90% 90%, rgba(126,231,198,0.03), transparent),\n                linear-gradient(180deg,var(--bg1), var(--bg2));\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  .app {\n    max-width:1200px;\n    margin:48px auto;\n    padding:28px;\n    border-radius:20px;\n    box-shadow: var(--shadow);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    overflow: hidden;\n  }\n\n  header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n    margin-bottom:22px;\n  }\n\n  .title {\n    display:flex;\n    flex-direction:column;\n  }\n\n  h1{\n    margin:0;\n    font-weight:800;\n    letter-spacing:-0.02em;\n    font-size:28px;\n    color: #f8fbff;\n    text-shadow: 0 6px 30px rgba(110,193,255,0.05);\n  }\n\n  .subtitle{\n    margin-top:6px;\n    color:var(--muted);\n    font-size:13px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  .pill {\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    padding:6px 10px;\n    border-radius:999px;\n    font-weight:600;\n    font-size:12px;\n    background: linear-gradient(90deg, rgba(110,193,255,0.08), rgba(126,231,198,0.04));\n    color:var(--accent2);\n    border:1px solid rgba(110,193,255,0.07);\n  }\n\n  .controls{\n    display:flex;\n    gap:10px;\n  }\n\n  .btn{\n    appearance:none;\n    border:1px solid rgba(255,255,255,0.06);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color: #e6f7ff;\n    padding:10px 14px;\n    border-radius:12px;\n    cursor:pointer;\n    font-weight:700;\n    font-size:13px;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n    transition: transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n  }\n  .btn:active{ transform: translateY(1px) }\n  .btn.ghost{\n    background: transparent;\n    border:1px dashed rgba(255,255,255,0.04);\n    opacity:0.92;\n    font-weight:600;\n    color:var(--muted);\n  }\n  .btn .dot{\n    width:10px;height:10px;border-radius:50%;\n    background: linear-gradient(90deg,var(--accent),var(--accent2));\n    box-shadow: 0 6px 18px rgba(110,193,255,0.12), 0 0 20px rgba(126,231,198,0.06);\n  }\n\n  .main {\n    display:grid;\n    grid-template-columns: 1fr 420px 1fr;\n    gap:26px;\n    align-items:stretch;\n  }\n\n  .panel {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    border:1px solid var(--glass-border);\n    min-height:360px;\n    position:relative;\n    overflow:visible;\n    box-shadow: 0 8px 30px rgba(8,12,20,0.45);\n  }\n\n  .panel .head{\n    display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;\n  }\n\n  .panel h3{\n    margin:0;color:#e9f7ff;font-size:15px;font-weight:700;\n  }\n\n  .panel .muted{\n    color:var(--muted);\n    font-weight:600;\n    font-size:13px;\n  }\n\n  /* Virtual Address Space (left) */\n  .vas{\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    align-items:center;\n    padding-top:8px;\n  }\n\n  .stack{\n    width:160px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.015));\n    border-radius:12px;\n    padding:12px;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n    align-items:stretch;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  .page {\n    height:44px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    padding:10px;\n    color:var(--muted);\n    font-weight:700;\n    font-size:13px;\n    position:relative;\n    overflow:visible;\n    box-shadow: 0 6px 16px rgba(2,8,24,0.35);\n    transition: transform .28s cubic-bezier(.2,.9,.3,1), box-shadow .25s ease;\n  }\n\n  .page .tag{\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n  }\n\n  .chip{\n    width:36px;height:28px;border-radius:8px;\n    background:linear-gradient(180deg, rgba(126,231,198,0.06), rgba(110,193,255,0.04));\n    border:1px solid rgba(110,193,255,0.08);\n    color:var(--accent);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-family:\"JetBrains Mono\", monospace;\n    font-size:12px;\n    font-weight:700;\n  }\n\n  .page.hit{\n    transform: translateX(6px) scale(1.01);\n    box-shadow: 0 20px 40px rgba(110,193,255,0.06);\n    border-color: rgba(126,231,198,0.12);\n  }\n  .page.fault{\n    border:1px solid rgba(255,107,107,0.18);\n    box-shadow: 0 12px 40px rgba(255,107,107,0.06);\n    transform: translateX(4px);\n  }\n\n  /* Center: Page Table */\n  .ptable{\n    display:grid;\n    grid-template-rows: auto 1fr;\n    gap:10px;\n  }\n\n  .table-grid{\n    display:grid;\n    grid-template-columns: repeat(2,1fr);\n    gap:8px;\n    margin-top:8px;\n  }\n\n  .entry {\n    padding:10px 12px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.014), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    color:var(--muted);\n    font-weight:700;\n    font-size:13px;\n  }\n\n  .entry .status{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n  }\n\n  .dot-free{\n    width:12px;height:12px;border-radius:50%;\n    background: transparent;\n    border:2px dashed rgba(255,255,255,0.04);\n  }\n  .dot-inmem{\n    width:12px;height:12px;border-radius:50%;\n    background: linear-gradient(90deg,var(--accent),var(--accent2));\n    box-shadow: 0 6px 16px rgba(110,193,255,0.08);\n  }\n  .dot-swap{\n    width:12px;height:12px;border-radius:50%;\n    background:linear-gradient(90deg,var(--danger), #ffa3a3);\n    box-shadow: 0 8px 20px rgba(255,107,107,0.06);\n  }\n\n  .mapping{\n    margin-top:10px;\n    display:flex;\n    justify-content:space-between;\n    gap:10px;\n  }\n\n  /* Physical Memory (right) */\n  .pmem{\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    padding-top:8px;\n    align-items:center;\n  }\n\n  .frames{\n    width:220px;\n    display:grid;\n    grid-template-columns: 1fr;\n    gap:12px;\n  }\n\n  .frame {\n    height:56px;\n    padding:10px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    color:var(--muted);\n    font-weight:800;\n    font-size:13px;\n    position:relative;\n    overflow:visible;\n  }\n\n  .frame .f-label{\n    display:flex;gap:8px;align-items:center;\n  }\n\n  .frame.empty{\n    opacity:0.65;\n    filter:grayscale(10%);\n  }\n\n  .frame.occupied{\n    box-shadow: 0 18px 40px rgba(110,193,255,0.04);\n    border-color: rgba(110,193,255,0.06);\n    transform: translateX(-4px);\n  }\n\n  .swap-area{\n    margin-top:20px;\n    border-radius:12px;\n    padding:12px;\n    background: linear-gradient(90deg, rgba(126,231,198,0.02), rgba(110,193,255,0.02));\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .disk{\n    width:64px;height:48px;border-radius:8px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    display:flex;align-items:center;justify-content:center;\n    color:var(--muted);\n    font-weight:800;font-family:\"JetBrains Mono\", monospace;\n    font-size:13px;\n    box-shadow: inset 0 -8px 20px rgba(2,6,23,0.25);\n  }\n\n  /* Arrows and overlays */\n  .canvas {\n    position:absolute;\n    left:0;right:0;top:0;bottom:0;\n    pointer-events:none;\n  }\n\n  .toast{\n    position:absolute;\n    left:50%;\n    top:-26px;\n    transform:translateX(-50%);\n    background: linear-gradient(90deg, rgba(110,193,255,0.09), rgba(126,231,198,0.05));\n    padding:8px 14px;\n    border-radius:999px;\n    color:var(--accent2);\n    font-weight:800;\n    border:1px solid rgba(110,193,255,0.06);\n    font-size:13px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n    box-shadow: 0 12px 50px rgba(110,193,255,0.04);\n    opacity:0;\n    transform-origin:center;\n  }\n\n  .toast.show{\n    animation: toast-in .6s cubic-bezier(.2,.9,.3,1) forwards;\n  }\n  @keyframes toast-in {\n    from { opacity:0; transform: translateX(-50%) translateY(-6px) scale(.98); }\n    to { opacity:1; transform: translateX(-50%) translateY(0) scale(1); }\n  }\n\n  /* Floating clone for animations */\n  .float {\n    position:fixed;\n    z-index:150;\n    pointer-events:none;\n    border-radius:10px;\n    padding:10px;\n    min-width:120px;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    transform-origin:center;\n    will-change: transform, opacity;\n  }\n\n  .guide {\n    margin-top:14px;\n    display:flex;\n    gap:12px;\n    color:var(--muted);\n    font-size:13px;\n    align-items:center;\n  }\n\n  .footer-note{\n    margin-top:18px;\n    color:var(--muted);\n    font-size:13px;\n    display:flex;\n    gap:8px;\n    align-items:center;\n  }\n\n  /* small responsive */\n  @media (max-width:1100px){\n    .main { grid-template-columns: 1fr; }\n    .pmem { order:3 }\n    .vas { order:1 }\n    .ptable { order:2 }\n  }\n\n  /* Subtle animated background lines */\n  .bg-lines {\n    position:absolute;\n    inset:0;\n    opacity:0.06;\n    background-image:\n      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px),\n      linear-gradient(180deg, rgba(255,255,255,0.02) 1px, transparent 1px);\n    background-size: 120px 120px, 120px 120px;\n    transform: translateZ(0);\n  }\n\n  /* small badges */\n  .badge {\n    font-size:12px;\n    padding:6px 8px;\n    border-radius:10px;\n    background: rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n  }\n\n  /* animated pulse for page fault */\n  @keyframes faultPulse {\n    0% { box-shadow: 0 0 0 0 rgba(255,107,107,0.12); }\n    70% { box-shadow: 0 0 0 18px rgba(255,107,107,0.02); }\n    100% { box-shadow: 0 0 0 0 rgba(255,107,107,0); }\n  }\n\n</style>\n</head>\n<body>\n<div class=\"app\" id=\"app\">\n  <div class=\"bg-lines\" aria-hidden=\"true\"></div>\n\n  <header>\n    <div class=\"title\">\n      <h1>Virtual Memory</h1>\n      <div class=\"subtitle\">\n        <span class=\"pill\">Demand Paging • Page Table • Swap</span>\n        <span style=\"opacity:0.8\">Elegant visual simulation</span>\n      </div>\n    </div>\n\n    <div class=\"controls\" aria-hidden=\"false\">\n      <button class=\"btn\" id=\"playPause\" title=\"Play / Pause\">\n        <div class=\"dot\" id=\"playDot\"></div>\n        <span id=\"playLabel\">Play</span>\n      </button>\n      <button class=\"btn ghost\" id=\"resetBtn\" title=\"Reset simulation\">Reset</button>\n    </div>\n  </header>\n\n  <div class=\"main\">\n    <!-- Virtual Address Space -->\n    <section class=\"panel\" aria-labelledby=\"vas\">\n      <div class=\"head\">\n        <h3 id=\"vas\">Virtual Address Space</h3>\n        <div class=\"muted\">Virtual Pages (8)</div>\n      </div>\n\n      <div class=\"vas\">\n        <div class=\"stack\" id=\"vasStack\" aria-hidden=\"false\">\n          <!-- pages inserted by JS -->\n        </div>\n\n        <div class=\"guide\">\n          <div class=\"badge\">Page = 4 KB</div>\n          <div class=\"muted\">Addresses → Page #</div>\n        </div>\n      </div>\n\n      <div class=\"toast\" id=\"toast\"> <strong id=\"toastText\">Page Fault</strong> </div>\n    </section>\n\n    <!-- Page Table -->\n    <section class=\"panel\" aria-labelledby=\"ptable\">\n      <div class=\"head\">\n        <h3 id=\"ptable\">Page Table</h3>\n        <div class=\"muted\">Mapping: Virtual → Physical / Swap</div>\n      </div>\n\n      <div class=\"ptable\">\n        <div style=\"display:flex;gap:10px;align-items:center;\">\n          <div style=\"font-weight:700;color:var(--muted);\">Entries</div>\n          <div style=\"flex:1\"></div>\n          <div class=\"muted\">TLB: <span style=\"color:var(--accent)\">illustrative</span></div>\n        </div>\n\n        <div class=\"table-grid\" id=\"pageTable\">\n          <!-- table entries inserted by JS -->\n        </div>\n      </div>\n\n    </section>\n\n    <!-- Physical Memory -->\n    <section class=\"panel\" aria-labelledby=\"pmem\">\n      <div class=\"head\">\n        <h3 id=\"pmem\">Physical Memory</h3>\n        <div class=\"muted\">Frames: 4</div>\n      </div>\n\n      <div class=\"pmem\">\n        <div class=\"frames\" id=\"frames\">\n          <!-- frames inserted by JS -->\n        </div>\n\n        <div class=\"swap-area\" aria-hidden=\"false\" title=\"Swap space\">\n          <div class=\"disk\">SWAP</div>\n          <div class=\"muted\">Disk-backed swap (evicted pages)</div>\n        </div>\n\n        <div class=\"footer-note\">\n          <div style=\"font-weight:700;color:var(--muted)\">Visualization:</div>\n          <div class=\"muted\">Access sequence animates mapping, hits and faults</div>\n        </div>\n      </div>\n    </section>\n  </div>\n\n  <svg class=\"canvas\" id=\"svgCanvas\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n</div>\n\n<script>\n(function(){\n  // Configuration\n  const TOTAL_PAGES = 8;\n  const FRAMES = 4;\n  const ACCESS_SEQUENCE = [1,3,2,6,3,7,0,4,2,5,3,6]; // predetermined for a nice demo\n  const STEP_DELAY = 1200;\n\n  // State\n  let mapping = new Array(TOTAL_PAGES).fill(null); // maps page -> frame index or {swap:true}\n  let frames = new Array(FRAMES).fill(null); // frames -> page number\n  let lru = []; // most recent at end\n  let seqIndex = 0;\n  let playing = false;\n  let timer = null;\n\n  // DOM refs\n  const vasStack = document.getElementById('vasStack');\n  const table = document.getElementById('pageTable');\n  const framesEl = document.getElementById('frames');\n  const toast = document.getElementById('toast');\n  const toastText = document.getElementById('toastText');\n  const svg = document.getElementById('svgCanvas');\n  const playPause = document.getElementById('playPause');\n  const playLabel = document.getElementById('playLabel');\n  const playDot = document.getElementById('playDot');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Utilities\n  function createEl(tag, cls){ const e = document.createElement(tag); if(cls) e.className = cls; return e; }\n\n  // Initialize UI elements\n  function buildUI(){\n    vasStack.innerHTML = '';\n    table.innerHTML = '';\n    framesEl.innerHTML = '';\n    svg.innerHTML = '';\n\n    for(let p=TOTAL_PAGES-1; p>=0; p--){ // stack top at bottom visually\n      const card = createEl('div','page');\n      card.dataset.page = p;\n      card.id = 'page-'+p;\n      card.innerHTML = `<div class=\"tag\"><div style=\"opacity:0.9\">P${p}</div></div>\n                        <div class=\"chip\">${p}</div>`;\n      vasStack.appendChild(card);\n    }\n\n    for(let p=0;p<TOTAL_PAGES;p++){\n      const e = createEl('div','entry');\n      e.id = 'entry-'+p;\n      e.innerHTML = `<div>Page ${p}</div><div class=\"status\"><div class=\"dot-free\"></div><div style=\"min-width:36px;text-align:right\">—</div></div>`;\n      table.appendChild(e);\n    }\n\n    for(let f=0; f<FRAMES; f++){\n      const e = createEl('div','frame empty');\n      e.id = 'frame-'+f;\n      e.innerHTML = `<div class=\"f-label\"><div style=\"font-weight:800\">Frame ${f}</div></div><div class=\"muted\">free</div>`;\n      framesEl.appendChild(e);\n    }\n  }\n\n  // Small helper to show toast\n  function showToast(text, cls){\n    toastText.textContent = text;\n    toast.classList.add('show');\n    if(cls === 'fault') toast.style.borderColor = 'rgba(255,107,107,0.12)';\n    setTimeout(()=> { toast.classList.remove('show'); toast.style.borderColor = ''; }, 1000);\n  }\n\n  function updateTableUI(){\n    for(let p=0;p<TOTAL_PAGES;p++){\n      const e = document.getElementById('entry-'+p);\n      const status = e.querySelector('.status');\n      const dot = status.children[0];\n      const label = status.children[1];\n      if(mapping[p] === null){\n        dot.className = 'dot-free';\n        label.textContent = '—';\n      } else if (typeof mapping[p] === 'object' && mapping[p].swap){\n        dot.className = 'dot-swap';\n        label.textContent = 'swap';\n      } else {\n        dot.className = 'dot-inmem';\n        label.textContent = '→ F'+mapping[p];\n      }\n    }\n  }\n\n  function updateFramesUI(){\n    for(let f=0; f<FRAMES; f++){\n      const el = document.getElementById('frame-'+f);\n      const page = frames[f];\n      if(page === null){\n        el.classList.remove('occupied');\n        el.classList.add('empty');\n        el.querySelector('.muted').textContent = 'free';\n        el.querySelector('.f-label').innerHTML = `<div style=\"font-weight:800\">Frame ${f}</div>`;\n      } else {\n        el.classList.add('occupied'); el.classList.remove('empty');\n        el.querySelector('.muted').textContent = `P${page}`;\n        el.querySelector('.f-label').innerHTML = `<div style=\"font-weight:800\">Frame ${f}</div><div style=\"margin-left:8px;color:var(--accent);font-family:JetBrains Mono\">${page*4096}B</div>`;\n      }\n    }\n  }\n\n  // Floating clone animation: move page element visually to frame\n  function animateMove(pageIdx, targetEl, opts = {}) {\n    return new Promise(resolve => {\n      const source = document.getElementById('page-'+pageIdx);\n      const sourceRect = source.getBoundingClientRect();\n      const targetRect = targetEl.getBoundingClientRect();\n\n      const clone = source.cloneNode(true);\n      clone.classList.add('float');\n      clone.style.left = (sourceRect.left)+'px';\n      clone.style.top = (sourceRect.top)+'px';\n      clone.style.width = sourceRect.width+'px';\n      clone.style.height = sourceRect.height+'px';\n      clone.style.opacity = '0.98';\n      clone.style.transition = 'transform .9s cubic-bezier(.2,.9,.25,1), opacity .6s ease';\n      document.body.appendChild(clone);\n\n      // compute translation\n      const dx = (targetRect.left + targetRect.width/2) - (sourceRect.left + sourceRect.width/2);\n      const dy = (targetRect.top + targetRect.height/2) - (sourceRect.top + sourceRect.height/2);\n\n      // slight scale for arrival\n      requestAnimationFrame(()=> {\n        clone.style.transform = `translate(${dx}px, ${dy}px) scale(.96)`;\n        clone.style.opacity = '0.98';\n      });\n\n      // optional ripple on target\n      if(opts.ripple){\n        targetEl.animate([{boxShadow:'0 0 0 0 rgba(126,231,198,0.0)'},{boxShadow:'0 24px 60px rgba(126,231,198,0.05)'},{boxShadow:'0 6px 16px rgba(126,231,198,0.02)'}],{duration:900,easing:'cubic-bezier(.2,.9,.25,1)'});\n      }\n\n      setTimeout(()=> {\n        clone.style.opacity = '0';\n        setTimeout(()=> { clone.remove(); resolve(); }, 300);\n      }, 900);\n    });\n  }\n\n  // animate eviction to swap area (bottom disk)\n  function animateEvict(pageIdx){\n    return new Promise(resolve => {\n      const source = document.getElementById('page-'+pageIdx);\n      const sourceRect = source.getBoundingClientRect();\n      const disk = document.querySelector('.disk');\n      const diskRect = disk.getBoundingClientRect();\n\n      const clone = source.cloneNode(true);\n      clone.classList.add('float');\n      clone.style.left = sourceRect.left+'px';\n      clone.style.top = sourceRect.top+'px';\n      clone.style.width = sourceRect.width+'px';\n      clone.style.height = sourceRect.height+'px';\n      clone.style.transition = 'transform 1s cubic-bezier(.2,.9,.25,1), opacity .5s ease';\n      document.body.appendChild(clone);\n\n      const dx = (diskRect.left + diskRect.width/2) - (sourceRect.left + sourceRect.width/2);\n      const dy = (diskRect.top + diskRect.height/2) - (sourceRect.top + sourceRect.height/2);\n\n      requestAnimationFrame(()=> {\n        clone.style.transform = `translate(${dx}px, ${dy}px) rotate(6deg) scale(.85)`;\n        clone.style.opacity = '0.92';\n      });\n\n      setTimeout(()=> {\n        clone.style.opacity = '0';\n        disk.animate([{transform:'scale(1)'},{transform:'scale(1.04)'},{transform:'scale(1)'}],{duration:700});\n        setTimeout(()=> { clone.remove(); resolve(); }, 700);\n      }, 1100);\n    });\n  }\n\n  // Visual highlights\n  function highlightHit(pageIdx, duration=700){\n    const p = document.getElementById('page-'+pageIdx);\n    p.classList.add('hit');\n    setTimeout(()=> p.classList.remove('hit'), duration);\n  }\n  function highlightFault(pageIdx, duration=900){\n    const p = document.getElementById('page-'+pageIdx);\n    p.classList.add('fault');\n    p.style.animation = 'faultPulse 1s ease';\n    setTimeout(()=> { p.classList.remove('fault'); p.style.animation=''; }, duration);\n  }\n\n  // Core access handling: returns Promise to chain animations\n  async function accessPage(pageIdx){\n    // brief highlight on VAS page\n    const pageEl = document.getElementById('page-'+pageIdx);\n    pageEl.scrollIntoView({behavior:'smooth', block:'center'});\n    await new Promise(r=> setTimeout(r,160));\n\n    // if in memory -> hit\n    if(mapping[pageIdx] !== null && !(typeof mapping[pageIdx] === 'object' && mapping[pageIdx].swap)){\n      // Hit\n      const f = mapping[pageIdx];\n      highlightHit(pageIdx);\n      showToast(`HIT: P${pageIdx} → Frame ${f}`);\n      // animate small arrow (simple clone movement to frame)\n      await animateMove(pageIdx, document.getElementById('frame-'+f), {ripple:true});\n      // LRU update\n      updateLRU(pageIdx);\n      updateFramesUI();\n      updateTableUI();\n      await new Promise(r=> setTimeout(r, 220));\n      return;\n    }\n\n    // Page Fault\n    highlightFault(pageIdx);\n    showToast(`PAGE FAULT: P${pageIdx}`, 'fault');\n    await new Promise(r=> setTimeout(r, 240));\n\n    // find free frame\n    let free = frames.indexOf(null);\n    if(free === -1){\n      // need to evict LRU (least recently used is at start)\n      const evictPage = lru.shift(); // remove LRU\n      const evictFrame = mapping[evictPage];\n      // animate eviction\n      await animateEvict(evictPage);\n      // mark evicted page as swapped\n      mapping[evictPage] = {swap:true};\n      frames[evictFrame] = null;\n      updateFramesUI();\n      updateTableUI();\n      await new Promise(r=> setTimeout(r, 180));\n      free = evictFrame;\n    }\n\n    // animate bringing page into frame\n    await animateMove(pageIdx, document.getElementById('frame-'+free), {ripple:true});\n    // commit mapping\n    mapping[pageIdx] = free;\n    frames[free] = pageIdx;\n    updateLRU(pageIdx);\n    updateFramesUI();\n    updateTableUI();\n    await new Promise(r=> setTimeout(r, 120));\n  }\n\n  function updateLRU(pageIdx){\n    const idx = lru.indexOf(pageIdx);\n    if(idx !== -1) lru.splice(idx,1);\n    lru.push(pageIdx);\n    // cap lru to frames size in case of many\n    if(lru.length > FRAMES) lru = lru.slice(-FRAMES);\n  }\n\n  // Sequence runner\n  async function stepSequence(){\n    if(seqIndex >= ACCESS_SEQUENCE.length){\n      playing = false;\n      updatePlayBtn();\n      return;\n    }\n    const page = ACCESS_SEQUENCE[seqIndex++];\n    await accessPage(page);\n    if(playing) {\n      timer = setTimeout(stepSequence, STEP_DELAY);\n    }\n  }\n\n  function play(){\n    if(playing) return;\n    playing = true;\n    updatePlayBtn();\n    if(seqIndex >= ACCESS_SEQUENCE.length) seqIndex = 0;\n    timer = setTimeout(stepSequence, 300);\n  }\n\n  function pause(){\n    playing = false;\n    updatePlayBtn();\n    if(timer) { clearTimeout(timer); timer = null; }\n  }\n\n  function reset(){\n    pause();\n    seqIndex = 0;\n    mapping = new Array(TOTAL_PAGES).fill(null);\n    frames = new Array(FRAMES).fill(null);\n    lru = [];\n    updateTableUI();\n    updateFramesUI();\n    // subtle animation: fade content\n    const app = document.getElementById('app');\n    app.animate([{opacity:0.94},{opacity:1}],{duration:380});\n  }\n\n  function updatePlayBtn(){\n    playLabel.textContent = playing ? 'Pause' : 'Play';\n    playDot.style.background = playing ? 'linear-gradient(90deg,var(--danger), #ff9f9f)' : 'linear-gradient(90deg,var(--accent),var(--accent2))';\n  }\n\n  // Attach handlers\n  playPause.addEventListener('click', ()=>{\n    if(playing) pause(); else play();\n  });\n  resetBtn.addEventListener('click', reset);\n\n  // on load build UI and set initial state (empty)\n  buildUI();\n  updateTableUI();\n  updateFramesUI();\n\n  // small initial demo: preload one page into frame 0 to show both states\n  (function preload(){\n    // Put P1 into frame 0 for an initial hit possibility\n    mapping[1] = 0;\n    frames[0] = 1;\n    lru.push(1);\n    updateTableUI();\n    updateFramesUI();\n  })();\n\n  // Polished subtle entrance animation\n  document.getElementById('app').animate([{transform:'translateY(6px)', opacity:0},{transform:'translateY(0)', opacity:1}],{duration:700, easing:'cubic-bezier(.2,.9,.25,1)'});\n\n  // Accessibility: press space to toggle play/pause\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){ e.preventDefault(); if(playing) pause(); else play(); }\n    if(e.key === 'r' || e.key === 'R'){ reset(); }\n  });\n\n})();\n</script>\n</body>\n</html>"
