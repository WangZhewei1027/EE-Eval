    "content": "<html>\n<head>\n    <title>K-Means Clustering</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .button-container {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 20px;\n        }\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            background-color: #4CAF50;\n            color: #fff;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h2>K-Means Clustering</h2>\n        <p>Number of clusters: <input type=\"number\" id=\"num_clusters\" value=\"3\" /></p>\n        <p>Max iterations: <input type=\"number\" id=\"max_iterations\" value=\"100\" /></p>\n        <button id=\"generate_button\">Generate Clustering</button>\n        <button id=\"reset_button\">Reset</button>\n        <div class=\"button-container\">\n            <button id=\"cluster_button\">Cluster</button>\n            <button id=\"visualize_button\">Visualize</button>\n            <button id=\"save_button\">Save</button>\n        </div>\n        <div class=\"cluster-container\">\n            <h2>Cluster 1</h2>\n            <div id=\"cluster1\"></div>\n            <h2>Cluster 2</h2>\n            <div id=\"cluster2\"></div>\n            <h2>Cluster 3</h2>\n            <div id=\"cluster3\"></div>\n        </div>\n    </div>\n\n    <script>\n        let num_clusters = 3;\n        let max_iterations = 100;\n        let clusters = [];\n\n        document.getElementById('generate_button').addEventListener('click', generate_clusters);\n        document.getElementById('reset_button').addEventListener('click', reset_clusters);\n        document.getElementById('cluster_button').addEventListener('click', cluster_clusters);\n        document.getElementById('visualize_button').addEventListener('click', visualize_clusters);\n        document.getElementById('save_button').addEventListener('click', save_clusters);\n\n        function generate_clusters() {\n            let data = [];\n            for (let i = 0; i < 100; i++) {\n                data.push({\n                    x: Math.random() * 100,\n                    y: Math.random() * 100\n                });\n            }\n            let kmeans = new KMeans(num_clusters, data, max_iterations);\n            let clusters = kmeans.cluster();\n            for (let i = 0; i < num_clusters; i++) {\n                clusters[i].data.forEach(point => {\n                    document.getElementById(`cluster${i+1}`).innerHTML += `<div class=\"point\">${point.x} ${point.y}</div>`;\n                });\n            }\n        }\n\n        function reset_clusters() {\n            num_clusters = 3;\n            max_iterations = 100;\n            clusters = [];\n            document.getElementById('cluster1').innerHTML = '';\n            document.getElementById('cluster2').innerHTML = '';\n            document.getElementById('cluster3').innerHTML = '';\n        }\n\n        function cluster_clusters() {\n            let data = [];\n            for (let i = 0; i < 100; i++) {\n                data.push({\n                    x: Math.random() * 100,\n                    y: Math.random() * 100\n                });\n            }\n            let kmeans = new KMeans(num_clusters, data, max_iterations);\n            let clusters = kmeans.cluster();\n            for (let i = 0; i < num_clusters; i++) {\n                clusters[i].data.forEach(point => {\n                    document.getElementById(`cluster${i+1}`).innerHTML += `<div class=\"point\">${point.x} ${point.y}</div>`;\n                });\n            }\n        }\n\n        function visualize_clusters() {\n            let data = [];\n            for (let i = 0; i < 100; i++) {\n                data.push({\n                    x: Math.random() * 100,\n                    y: Math.random() * 100\n                });\n            }\n            let clusters = [];\n            for (let i = 0; i < num_clusters; i++) {\n                let cluster_data = [];\n                for (let j = 0; j < 100; j++) {\n                    cluster_data.push({\n                        x: Math.random() * 100,\n                        y: Math.random() * 100\n                    });\n                }\n                clusters.push(cluster_data);\n            }\n            let points = document.querySelectorAll('.point');\n            let clusters_points = document.querySelectorAll('.cluster');\n            for (let i = 0; i < num_clusters; i++) {\n                for (let j = 0; j < clusters.length; j++) {\n                    for (let k = 0; k < clusters[j].length; k++) {\n                        if (clusters[j][k].x < 100 && clusters[j][k].y < 100) {\n                            points[j].innerHTML += `<div class=\"point\" data-point=\"${clusters[j][k].x}\" data-point-index=\"${j}\">Point ${clusters[j][k].x} ${clusters[j][k].y}</div>`;\n                        }\n                    }\n                }\n            }\n        }\n\n        function save_clusters() {\n            let clusters_data = [];\n            for (let i = 0; i < num_clusters; i++) {\n                let cluster_data = [];\n                for (let j = 0; j < clusters[i].length; j++) {\n                    cluster_data.push({\n                        x: clusters[i][j].x,\n                        y: clusters[i][j].y,\n                        point_index: i\n                    });\n                }\n                clusters_data.push(cluster_data);\n            }\n            let data = {\n                points: document.querySelectorAll('.point'),\n                clusters: clusters_data\n            };\n            let blob = new Blob([JSON.stringify(data)], { type: 'application/json' });\n            let link = document.createElement('a');\n            link.href = URL.createObjectURL(blob);\n            link.download = 'clusters.json';\n            link.click();\n        }\n\n        function KMeans(num_clusters, data, max_iterations) {\n            let kmeans = {};\n            for (let i = 0; i < num_clusters; i++) {\n                kmeans[i] = new KMeansImpl(data, i, max_iterations);\n            }\n            return kmeans;\n        }\n\n        function KMeansImpl(data, cluster_index, max_iterations) {\n            let centroids = data.slice(0, cluster_index).map(point => ({ x: point.x, y: point.y }));\n            for (let i = 0; i < max_iterations; i++) {\n                let clusters = data.slice(cluster_index);\n                let new_centroids = [];\n                for (let j = 0; j < clusters.length; j++) {\n                    let point = clusters[j].pop();\n                    let minDistance = Infinity;\n                    let bestIndex = -1;\n                    for (let k = 0; k < centroids.length; k++) {\n                        let distance = Math.sqrt(Math.pow(point.x - centroids[k].x, 2) + Math.pow(point.y - centroids[k].y, 2));\n                        if (distance < minDistance) {\n                            minDistance = distance;\n                            bestIndex = k;\n                        }\n                    }\n                    new_centroids.push({ x: point.x, y: point.y, index: bestIndex });\n                }\n                centroids = new_centroids;\n                if (centroids.every(point => point.index === cluster_index)) {\n                    break;\n                }\n            }\n            return centroids;\n        }\n    </script>\n    <script src=\"https://cdn.jsdelivr.net/npm/kmeansjs@1.0.2/dist/kmeans.min.js\"></script>\n</body>\n</html>"
