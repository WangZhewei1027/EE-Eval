    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Heap (Min) - Concept Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Root & Reset */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0; height: 100%;\n    background: linear-gradient(135deg, #0a0f2c, #1a1f4a);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f2;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 40px 20px 60px;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 2.8rem;\n    margin-bottom: 8px;\n    letter-spacing: 1.2px;\n    color: #7cd1f9;\n    text-shadow:\n      0 0 6px #52b8ff,\n      0 0 15px #52b8ff55;\n  }\n\n  p.subtitle {\n    font-weight: 300;\n    font-size: 1.15rem;\n    margin-top: 0;\n    margin-bottom: 36px;\n    color: #a3b4d6;\n    max-width: 460px;\n    text-align: center;\n    letter-spacing: 0.55px;\n  }\n\n  /* Main container */\n  main {\n    position: relative;\n    width: min(800px, 95vw);\n    background: linear-gradient(145deg, #151c49, #0e1431);\n    border-radius: 24px;\n    padding: 48px 44px 76px;\n    box-shadow:\n      inset 0 0 15px #183660,\n      0 10px 30px rgba(41, 119, 238, 0.45);\n    user-select: none;\n  }\n\n  /* Heap container is a stylish tree container with subtle glow */\n  .heap-container {\n    position: relative;\n    margin: 0 auto;\n    width: 720px;\n    max-width: 95vw;\n    user-select: none;\n  }\n\n  /* Lines connector style */\n  svg.connectors {\n    position: absolute;\n    top: 0; left: 0;\n    width: 100%;\n    height: 100%;\n    pointer-events: none;\n    overflow: visible;\n    filter: drop-shadow(0 0 1.5px #5e99ffaa);\n  }\n\n  /* Heap node style */\n  .node {\n    position: absolute;\n    width: 64px;\n    height: 64px;\n    background: radial-gradient(circle at 25% 25%, #4e79f9, #2f4bf2);\n    border-radius: 50%;\n    box-shadow:\n      0 0 12px #5f91ffcc,\n      inset 0 0 5px #b0d3ffcc;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    font-size: 1.5rem;\n    color: #eaf2ff;\n    text-shadow:\n      0 0 10px #89afff,\n      0 0 18px #83aaffcc;\n    transition: transform 0.7s ease, box-shadow 0.7s ease;\n    cursor: default;\n  }\n\n  .node.minroot {\n    background: radial-gradient(circle at 25% 25%, #ff8c4e, #ff7632);\n    box-shadow:\n      0 0 16px #ff8c4ebb,\n      inset 0 0 10px #ffad7533;\n    color: #fff6e7;\n    text-shadow:\n      0 0 12px #ff9955,\n      0 0 22px #ff7a22cc;\n  }\n\n  /* Subtle pulse animation for the root */\n  @keyframes pulseRoot {\n    0%, 100% { box-shadow: 0 0 16px #ff8c4ebb, inset 0 0 10px #ffad7533; }\n    50% { box-shadow: 0 0 28px #ffb366dd, inset 0 0 18px #ffcc9955; }\n  }\n  .node.minroot {\n    animation: pulseRoot 3.8s ease-in-out infinite;\n  }\n\n  /* Positions for a perfect min heap shape: 3 levels (7 nodes) */\n  .heap-container {\n    height: 320px;\n  }\n\n  .node.pos-0 { top: 0; left: calc(50% - 32px); }\n  .node.pos-1 { top: 110px; left: calc(25% - 32px); }\n  .node.pos-2 { top: 110px; left: calc(75% - 32px); }\n  .node.pos-3 { top: 220px; left: calc(12.5% - 32px); }\n  .node.pos-4 { top: 220px; left: calc(37.5% - 32px); }\n  .node.pos-5 { top: 220px; left: calc(62.5% - 32px); }\n  .node.pos-6 { top: 220px; left: calc(87.5% - 32px); }\n\n  /* Connectors lines style */\n  line.connector-line {\n    stroke: #5e9affcc;\n    stroke-width: 3;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 3px #5e9affdd);\n    transition: stroke 0.7s ease;\n  }\n\n  /* Controls panel */\n  .controls {\n    margin-top: 48px;\n    text-align: center;\n  }\n  button.btn {\n    background: linear-gradient(145deg, #274699, #3e5bb3);\n    border: none;\n    border-radius: 28px;\n    padding: 14px 34px;\n    font-weight: 600;\n    font-size: 1.15rem;\n    color: #d2e7ff;\n    letter-spacing: 0.7px;\n    cursor: pointer;\n    box-shadow:\n      0 5px 12px #3a62adcc,\n      inset 0 -3px 8px #1e3369;\n    transition:\n      background 0.5s ease,\n      box-shadow 0.35s ease,\n      transform 0.22s ease;\n  }\n  button.btn:hover {\n    background: linear-gradient(145deg, #3e5bb3, #274699);\n    box-shadow:\n      0 8px 22px #527debcc,\n      inset 0 -2px 10px #2b4cab;\n    transform: translateY(-3px);\n  }\n  button.btn:active {\n    transform: translateY(-1px);\n    box-shadow:\n      0 3px 10px #3259b166,\n      inset 0 -1px 6px #213c7a;\n  }\n\n  /* Tooltip */\n  .tooltip {\n    position: fixed;\n    bottom: 18px;\n    right: 38px;\n    background: #1a2250bb;\n    backdrop-filter: blur(8px);\n    border-radius: 20px;\n    padding: 10px 22px;\n    font-weight: 300;\n    font-size: 1rem;\n    color: #a1b6ebdd;\n    box-shadow: 0 0 13px #3463c7a8;\n    user-select: none;\n    cursor: default;\n    transition: opacity 0.4s ease;\n    max-width: 280px;\n  }\n\n  /* Subtle floating animation for the tooltip */\n  @keyframes floatTooltip {\n    0%, 100% { transform: translateY(0); opacity: 1; }\n    50% { transform: translateY(-6px); opacity: 0.78; }\n  }\n  .tooltip {\n    animation: floatTooltip 6s ease-in-out infinite;\n  }\n\n  /* Scrollbar hidden for aesthetic */\n  ::-webkit-scrollbar {\n    width: 0px;\n    background: transparent;\n  }\n</style>\n</head>\n<body>\n  <h1>Heap (Min)</h1>\n  <p class=\"subtitle\">A visually stunning presentation of a Min Heap data structure.<br />Observe the heap property with the smallest element at the root.</p>\n\n  <main role=\"main\" aria-label=\"Min Heap visualization\">\n    <div class=\"heap-container\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <!-- Nodes -->\n      <div class=\"node pos-0 minroot\" aria-label=\"Root node with value 8\" tabindex=\"0\">8</div>\n      <div class=\"node pos-1\" aria-label=\"Left child node with value 12\" tabindex=\"0\">12</div>\n      <div class=\"node pos-2\" aria-label=\"Right child node with value 15\" tabindex=\"0\">15</div>\n      <div class=\"node pos-3\" aria-label=\"Left child node with value 20\" tabindex=\"0\">20</div>\n      <div class=\"node pos-4\" aria-label=\"Left child node with value 18\" tabindex=\"0\">18</div>\n      <div class=\"node pos-5\" aria-label=\"Right child node with value 25\" tabindex=\"0\">25</div>\n      <div class=\"node pos-6\" aria-label=\"Right child node with value 30\" tabindex=\"0\">30</div>\n\n      <!-- SVG Connector Lines -->\n      <svg class=\"connectors\" aria-hidden=\"true\" role=\"presentation\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <!-- From root(0) -->\n        <line class=\"connector-line\" x1=\"360\" y1=\"64\" x2=\"180\" y2=\"110\" />\n        <line class=\"connector-line\" x1=\"360\" y1=\"64\" x2=\"540\" y2=\"110\" />\n        <!-- From left child(1) -->\n        <line class=\"connector-line\" x1=\"180\" y1=\"174\" x2=\"90\" y2=\"220\" />\n        <line class=\"connector-line\" x1=\"180\" y1=\"174\" x2=\"270\" y2=\"220\" />\n        <!-- From right child(2) -->\n        <line class=\"connector-line\" x1=\"540\" y1=\"174\" x2=\"450\" y2=\"220\" />\n        <line class=\"connector-line\" x1=\"540\" y1=\"174\" x2=\"630\" y2=\"220\" />\n      </svg>\n    </div>\n\n    <div class=\"controls\" aria-label=\"Heap controls\">\n      <button id=\"btnHeapify\" class=\"btn\" aria-pressed=\"false\" aria-label=\"Run Heapify animation\">Run Heapify animation</button>\n    </div>\n  </main>\n\n  <div class=\"tooltip\" role=\"note\" aria-atomic=\"true\">\n    The Min Heap property ensures the root node is the smallest element.<br />Children nodes are always larger or equal to their parent.\n  </div>\n\n<script>\n  (function(){\n    const btnHeapify = document.getElementById('btnHeapify');\n    const nodes = Array.from(document.querySelectorAll('.node'));\n    /*\n      We'll animate a simple heapify transform:\n      Start from unordered values -> After animation -> Min Heap order\n    */\n    // Original unordered values (for demo purpose)\n    const unorderedValues = [20, 18, 15, 30, 25, 12, 8];\n    // Final min heap values for this tree\n    const heapValues = [8, 12, 15, 20, 18, 25, 30];\n\n    // Positions for nodes (x,y) for animating\n    // nodes pos0..6 center coords based on CSS\n    // Calculation: node 0: top=0 left=50% - 32 => x=50%*720=360, y=32\n    const positions = [\n      {x:360, y:32}, // root\n      {x:180, y:142}, // 1\n      {x:540, y:142}, // 2\n      {x:90, y:252},  // 3\n      {x:270, y:252}, // 4\n      {x:450, y:252}, // 5\n      {x:630, y:252}, // 6\n    ];\n\n    // Shuffle the nodes' displayed values to unordered at the start\n    function resetValues() {\n      nodes.forEach((node,i) => {\n        node.textContent = unorderedValues[i];\n        node.classList.remove('minroot');\n      });\n      nodes[0].classList.remove('minroot');\n      btnHeapify.setAttribute('aria-pressed', 'false');\n      btnHeapify.textContent = \"Run Heapify animation\";\n    }\n\n    // Animate heapify with subtle scaling and shadow glow\n    async function animateHeapify(){\n      btnHeapify.setAttribute('aria-pressed', 'true');\n      btnHeapify.disabled = true;\n      btnHeapify.textContent = \"Heapifying...\";\n\n      // Step 1: Highlight nodes in initial order with subtle glow and slight scale\n      for(let i=0; i<nodes.length; i++){\n        nodes[i].style.transition = \"transform 0.35s ease, box-shadow 0.35s ease\";\n        nodes[i].style.transform = \"scale(1.05) translateY(-6px)\";\n        nodes[i].style.boxShadow = \"0 0 18px #78b2ffdd, inset 0 0 12px #a1c6ffbb\";\n        await new Promise(r => setTimeout(r, 180));\n      }\n      // Relax highlight\n      await new Promise(r => setTimeout(r, 300));\n      nodes.forEach(node => {\n        node.style.transform = \"\";\n        node.style.boxShadow = \"\";\n      });\n\n      // Step 2: Animate node value swaps (fake \"heapify\" update - realistic visual)\n      // We'll animate fade out/in transitions on text changes, plus re-assign minroot\n      for(let i=0; i<nodes.length; i++){\n        await new Promise(r => setTimeout(r, 180));\n        // Fade out text\n        nodes[i].style.transition = \"color 0.4s ease, text-shadow 0.4s ease\";\n        nodes[i].style.color = \"transparent\";\n        nodes[i].style.textShadow = \"none\";\n        await new Promise(r => setTimeout(r, 450));\n        // Update value\n        nodes[i].textContent = heapValues[i];\n        // Fade in\n        nodes[i].style.color = i===0 ? \"#fff6e7\" : \"#eaf2ff\";\n        nodes[i].style.textShadow =\n          i===0 \n          ? \"0 0 12px #ff9955, 0 0 22px #ff7a22cc\"\n          : \"0 0 10px #89afff, 0 0 18px #83aaffcc\";\n      }\n      // Step 3: Mark root node distinct and animate pulse\n      nodes.forEach(node => node.classList.remove('minroot'));\n      nodes[0].classList.add('minroot');\n\n      await new Promise(r => setTimeout(r, 650));\n      btnHeapify.textContent = \"Reset to Unordered\";\n      btnHeapify.disabled = false;\n    }\n\n    // When user clicks the button...\n    btnHeapify.addEventListener('click', () => {\n      const pressed = btnHeapify.getAttribute('aria-pressed') === 'true';\n      if(pressed) {\n        // reset\n        resetValues();\n      }\n      else {\n        animateHeapify();\n      }\n    });\n\n    // Initialize unordered on page load\n    resetValues();\n  })();\n</script>\n</body>\n</html>"
