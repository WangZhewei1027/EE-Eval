  "question": "OSI Model",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>OSI Model Interactive Explorer</title>\n    <style>\n        body {\n            font-family: Arial, margin: 20px;\n            line-height: 1.6;\n        }\n        .layer {\n            border: 1px solid #000;\n            margin: 5px;\n            padding: 10px;\n            cursor: pointer;\n        }\n        .details {\n            display: none;\n            margin-left: 20px;\n            border-left: 1px solid #000;\n            padding-left: 10px;\n        }\n        .active {\n            background-color: #f0f0f0;\n        }\n        #packet-visualization {\n            border: 1px solid #000;\n            height: 200px;\n            margin: 20px 0;\n            position: relative;\n        }\n        .packet-segment {\n            position: absolute;\n            border: 1px solid #000;\n            text-align: center;\n            overflow: hidden;\n        }\n        #controls {\n            margin: 20px 0;\n        }\n        select, input, button {\n            margin: 5px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin-bottom: 20px;\n        }\n        th, td {\n            border: 1px solid #000;\n            padding: 8px;\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <h1>OSI Model Interactive Explorer</h1>\n    \n    <div id=\"controls\">\n        <button id=\"btn-start\">Start Transmission</button>\n        <button id=\"btn-reset\">Reset</button>\n        <select id=\"protocol-select\">\n            <option value=\"http\">HTTP</option>\n            <option value=\"ftp\">FTP</option>\n            <option value=\"smtp\">SMTP</option>\n        </select>\n        <input type=\"text\" id=\"message-input\" placeholder=\"Enter message to send\">\n        <button id=\"btn-send\">Send</button>\n        <br>\n        <label>Transmission Speed: <input type=\"range\" id=\"speed-slider\" min=\"1\" max=\"10\" value=\"5\"></label>\n        <label>Show Details: <input type=\"checkbox\" id=\"show-details\" checked></label>\n    </div>\n    \n    <div id=\"packet-visualization\"></div>\n    \n    <div id=\"osi-model\">\n        <div class=\"layer\" data-layer=\"7\">\n            <h3>7. Application Layer</h3>\n            <div class=\"details\" id=\"layer7\">\n                <p>Interface between network and application software</p>\n                <table>\n                    <tr><th>Protocols</th><th>Functions</th><th>Examples</th></tr>\n                    <tr><td>HTTP, FTP, SMTP</td><td>Network process to application</td><td>Web browsers, email clients</td></tr>\n                </table>\n                <div id=\"app-controls\">\n                    <button class=\"protocol-btn\" data-protocol=\"http\">HTTP Request</button>\n                    <button class=\"protocol-btn\" data-protocol=\"ftp\">FTP Transfer</button>\n                    <button class=\"protocol-btn\" data-protocol=\"smtp\">Send Email</button>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"layer\" data-layer=\"6\">\n            <h3>6. Presentation Layer</h3>\n            <div class=\"details\" id=\"layer6\">\n                <p>Data representation and encryption</p>\n                <table>\n                    <tr><th>Functions</th><th>Examples</th></tr>\n                    <tr><td>Data translation, encryption/decryption, compression</td><td>SSL, JPEG, MPEG</td></tr>\n                </table>\n                <div>\n                    <label>Encryption: <select id=\"encryption-select\">\n                        <option value=\"none\">None</option>\n                        <option value=\"ssl\">SSL</option>\n                        <option value=\"tls\">TLS</option>\n                    </select></label>\n                    <label>Compression: <select id=\"compression-select\">\n                        <option value=\"none\">None</option>\n                        <option value=\"gzip\">Gzip</option>\n                        <option value=\"deflate\">Deflate</option>\n                    </select></label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"layer\" data-layer=\"5\">\n            <h3>5. Session Layer</h3>\n            <div class=\"details\" id=\"layer5\">\n                <p>Manages connections between computers</p>\n                <table>\n                    <tr><th>Functions</th><th>Examples</th></tr>\n                    <tr><td>Establish, manage, terminate connections</td><td>NetBIOS, RPC</td></tr>\n                </table>\n                <div>\n                    <button id=\"btn-establish\">Establish Session</button>\n                    <button id=\"btn-terminate\">Terminate Session</button>\n                    <label>Session Timeout: <input type=\"number\" id=\"timeout-input\" value=\"30\"> sec</label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"layer\" data-layer=\"4\">\n            <h3>4. Transport Layer</h3>\n            <div class=\"details\" id=\"layer4\">\n                <p>End-to-end connections and reliability</p>\n                <table>\n                    <tr><th>Protocols</th><th>Functions</th></tr>\n                    <tr><td>TCP, UDP</td><td>Flow control, error checking, segmentation</td></tr>\n                </table>\n                <div>\n                    <label>Protocol: <select id=\"transport-select\">\n                        <option value=\"tcp\">TCP (Reliable)</option>\n                        <option value=\"udp\">UDP (Fast)</option>\n                    </select></label>\n                    <button id=\"btn-segment\">Segment Data</button>\n                    <button id=\"transport-status\">Status: Idle</button>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"layer\" data-layer=\"3\">\n            <h3>3. Network Layer</h3>\n            <div class=\"details\" id=\"layer3\">\n                <p>Logical addressing and routing</p>\n                <table>\n                    <tr><th>Protocols</th><th>Functions</th></tr>\n                    <tr><td>IP, ICMP, ARP</td><td>Routing, logical addressing, path determination</td></tr>\n                </table>\n                <div>\n                    <label>Source IP: <input type=\"text\" id=\"source-ip\" value=\"192.168.1.1\"></label>\n                    <label>Destination IP: <input type=\"text\" id=\"dest-ip\" value=\"10.0.0.1\"></label>\n                    <button id=\"btn-route\">Calculate Route</button>\n                    <div id=\"route-output\"></div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"layer\" data-layer=\"2\">\n            <h3>2. Data Link Layer</h3>\n            <div class=\"details\" id=\"layer2\">\n                <p>Physical addressing and error detection</p>\n                <table>\n                    <tr><th>Protocols</th><th>Functions</th></tr>\n                    <tr><td>Ethernet, PPP</td><td>Framing, physical addressing, error detection</td></tr>\n                </table>\n                <div>\n                    <label>Source MAC: <input type=\"text\" id=\"source-mac\" value=\"00:1A:2B:3C:4D:5E\"></label>\n                    <label>Destination MAC: <input type=\"text\" id=\"dest-mac\" value=\"00:5E:4D:3C:2B:1A\"></label>\n                    <button id=\"btn-frame\">Create Frame</button>\n                    <label>Error Simulation: <select id=\"error-select\">\n                        <option value=\"none\">None</option>\n                        <option value=\"bit\">Bit Error</option>\n                        <option value=\"crc\">CRC Error</option>\n                    </select></label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"layer\" data-layer=\"1\">\n            <h3>1. Physical Layer</h3>\n            <div class=\"details\" id=\"layer1\">\n                <p>Physical connection and bit transmission</p>\n                <table>\n                    <tr><th>Media</th><th>Functions</th></tr>\n                    <tr><td>Cables, connectors, signals</td><td>Bit transmission, electrical/optical signals</td></tr>\n                </table>\n                <div>\n                    <label>Media Type: <select id=\"media-select\">\n                        <option value=\"ethernet\">Ethernet</option>\n                        <option value=\"fiber\">Fiber Optic</option>\n                        <option value=\"wireless\">Wireless</option>\n                    </select></label>\n                    <button id=\"btn-transmit\">Transmit Bits</button>\n                    <div id=\"bit-visualization\"></div>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    <div id=\"log-output\">\n        <h3>Transmission Log</h3>\n        <textarea id=\"log-area\" rows=\"10\" cols=\"100\" readonly></textarea>\n    </div>\n    \n    <script>\n        // Global state\n        let currentPacket = {};\n        let transmissionActive = false;\n        let sessionEstablished = false;\n        let currentSegment = 0;\n        let totalSegments = 0;\n        \n        // DOM elements\n        const layers = document.querySelectorAll('.layer');\n        const details = document.querySelectorAll('.details');\n        const packetVis = document.getElementById('packet-visualization');\n        const logArea = document.getElementById('log-area');\n        \n        // Initialize\n        document.getElementById('show-details').addEventListener('change', function() {\n            const show = this.checked;\n            details.forEach(detail => {\n                detail.style.display = show ? 'block' : 'none';\n            });\n        });\n        \n        // Layer click handlers\n        layers.forEach(layer => {\n            layer.addEventListener('click', function() {\n                const layerNum = this.getAttribute('data-layer');\n                const detail = document.getElementById(`layer${layerNum}`);\n                \n                // Toggle active class\n                layers.forEach(l => l.classList.remove('active'));\n                this.classList.add('active');\n                \n                // Show details if enabled\n                if (document.getElementById('show-details').checked) {\n                    detail.style.display = 'block';\n                }\n                \n                // Special actions based on layer\n                if (layerNum === '4' && transmissionActive) {\n                    updateTransportStatus();\n                }\n            });\n        });\n        \n        // Control handlers\n        document.getElementById('btn-start').addEventListener('click', startTransmission);\n        document.getElementById('btn-reset').addEventListener('click', resetAll);\n        document.getElementById('btn-send').addEventListener('click', prepareMessage);\n        document.getElementById('btn-establish').addEventListener('click', establishSession);\n        document.getElementById('btn-terminate').addEventListener('click', terminateSession);\n        document.getElementById('btn-segment').addEventListener('click', segmentData);\n        document.getElementById('btn-route').addEventListener('click', calculateRoute);\n        document.getElementById('btn-frame').addEventListener('click', createFrame);\n        document.getElementById('btn-transmit').addEventListener('click', transmitBits);\n        \n        // Protocol buttons\n        document.querySelectorAll('.protocol-btn').forEach(btn => {\n            btn.addEventListener('click', function() {\n                const protocol = this.getAttribute('data-protocol');\n                document.getElementById('protocol-select').value = protocol;\n                log(`Selected protocol: ${protocol.toUpperCase()}`);\n            });\n        });\n        \n        // Speed slider\n        document.getElementById('speed-slider').addEventListener('input', function() {\n            log(`Transmission speed set to: ${this.value}/10`);\n        });\n        \n        function startTransmission() {\n            transmissionActive = true;\n            log('Starting transmission process...');\n            visualizePacket();\n            updateTransportStatus();\n        }\n        \n        function resetAll() {\n            transmissionActive = false;\n            sessionEstablished = false;\n            currentSegment = 0;\n            totalSegments = 0;\n            currentPacket = {};\n            packetVis.innerHTML = '';\n            logArea.value = '';\n            log('System reset');\n        }\n        \n        function prepareMessage() {\n            const message = document.getElementById('message-input').value;\n            if (!message) {\n                log('Error: No message entered');\n                return;\n            }\n            \n            const protocol = document.getElementById('protocol-select').value;\n            currentPacket = {\n                protocol,\n                message,\n                encrypted: document.getElementById('encryption-select').value,\n                compressed: document.getElementById('compression-select').value\n            };\n            \n            log(`Preparing ${protocol.toUpperCase()} message: \"${message}\"`);\n            log(`Encryption: ${currentPacket.encrypted.toUpperCase()}, Compression: ${currentPacket.compressed.toUpperCase()}`);\n            \n            if (transmissionActive) {\n                segmentData();\n            }\n        }\n        \n        function establishSession() {\n            const timeout = document.getElementById('timeout-input').value;\n            sessionEstablished = true;\n            log(`Session established with timeout: ${timeout} seconds`);\n            document.getElementById('btn-establish').disabled = true;\n            document.getElementById('btn-terminate').disabled = false;\n        }\n        \n        function terminateSession() {\n            sessionEstablished = false;\n            log('Session terminated');\n            document.getElementById('btn-establish').disabled = false;\n            document.getElementById('btn-terminate').disabled = true;\n        }\n        \n        function segmentData() {\n            if (!currentPacket.message) {\n                log('Error: No message to segment');\n                return;\n            }\n            \n            const transport = document.getElementById('transport-select').value;\n            const segmentSize = transport === 'tcp' ? 10 : 20; // Smaller segments for TCP\n            \n            // Split message into segments\n            const segments = [];\n            for (let i = 0; i < currentPacket.message.length; i += segmentSize) {\n                segments.push(currentPacket.message.substring(i, i + segmentSize));\n            }\n            \n            currentPacket.segments = segments;\n            totalSegments = segments.length;\n            currentSegment = 0;\n            \n            log(`Data divided into ${totalSegments} ${transport.toUpperCase()} segments`);\n            updateTransportStatus();\n            \n            if (transport === 'tcp') {\n                log('TCP: Initiating 3-way handshake');\n                setTimeout(() => log('TCP: Handshake completed'), 500);\n            }\n            \n            visualizePacket();\n        }\n        \n        function updateTransportStatus() {\n            if (!transmissionActive) return;\n            \n            const status = document.getElementById('transport-status');\n            if (currentPacket.segments) {\n                status.textContent = `Status: Transmitting segment ${currentSegment + 1} of ${totalSegments}`;\n                \n                // Simulate segment transmission\n                if (currentSegment < totalSegments) {\n                    setTimeout(() => {\n                        currentSegment++;\n                        if (currentSegment < totalSegments) {\n                            updateTransportStatus();\n                            visualizePacket();\n                        } else {\n                            status.textContent = 'Status: Transmission complete';\n                            log('All segments transmitted successfully');\n                        }\n                    }, 1000 / document.getElementById('speed-slider').value);\n                }\n            } else {\n                status.textContent = 'Status: Waiting for data';\n            }\n        }\n        \n        function calculateRoute() {\n            const src = document.getElementById('source-ip').value;\n            const dest = document.getElementById('dest-ip').value;\n            \n            if (!src || !dest) {\n                log('Error: Please enter both source and destination IPs');\n                return;\n            }\n            \n            // Simulate routing\n            const hops = Math.floor(Math.random() * 5) + 2;\n            let route = `Route from ${src} to ${dest}:\\n`;\n            \n            for (let i = 0; i < hops; i++) {\n                const ip = `10.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}`;\n                route += `Hop ${i+1}: ${ip} (${Math.floor(Math.random() * 10)}ms)\\n`;\n            }\n            \n            document.getElementById('route-output').textContent = route;\n            log(`Route calculated with ${hops} hops`);\n            visualizePacket();\n        }\n        \n        function createFrame() {\n            const srcMac = document.getElementById('source-mac').value;\n            const destMac = document.getElementById('dest-mac').value;\n            const errorType = document.getElementById('error-select').value;\n            \n            if (!srcMac || !destMac) {\n                log('Error: Please enter both source and destination MACs');\n                return;\n            }\n            \n            let frame = `Frame: From ${srcMac} to ${destMac}`;\n            \n            if (errorType !== 'none') {\n                frame += ` (Simulated ${errorType.toUpperCase()} error)`;\n                log(`Frame created with ${errorType.toUpperCase()} error`);\n            } else {\n                log('Frame created successfully');\n            }\n            \n            visualizePacket();\n        }\n        \n        function transmitBits() {\n            const media = document.getElementById('media-select').value;\n            const bitCount = Math.floor(Math.random() * 50) + 20;\n            let bits = '';\n            \n            for (let i = 0; i < bitCount; i++) {\n                bits += Math.random() > 0.5 ? '1' : '0';\n            }\n            \n            document.getElementById('bit-visualization').textContent = `Transmitting (${media}): ${bits}`;\n            log(`Transmitting ${bitCount} bits over ${media}`);\n            visualizePacket();\n        }\n        \n        function visualizePacket() {\n            packetVis.innerHTML = '';\n            \n            if (!currentPacket.message) return;\n            \n            // Create packet segments\n            const layers = [\n                { name: 'Application', height: 30, color: '#ddd' },\n                { name: 'Presentation', height: 25, color: '#eee' },\n                { name: 'Session', height: 20, color: '#ddd' },\n                { name: 'Transport', height: 25, color: '#eee' },\n                { name: 'Network', height: 30, color: '#ddd' },\n                { name: 'Data Link', height: 25, color: '#eee' },\n                { name: 'Physical', height: 20, color: '#ddd' }\n            ];\n            \n            const packetWidth = 200;\n            let yPos = 0;\n            \n            layers.forEach((layer, index) => {\n                const segment = document.createElement('div');\n                segment.className = 'packet-segment';\n                segment.style.width = `${packetWidth}px`;\n                segment.style.height = `${layer.height}px`;\n                segment.style.top = `${yPos}px`;\n                segment.style.left = '50px';\n                segment.style.backgroundColor = layer.color;\n                segment.textContent = layer.name;\n                \n                // Add layer-specific content\n                if (index === 0 && currentPacket.protocol) {\n                    segment.textContent += ` (${currentPacket.protocol.toUpperCase()})`;\n                }\n                if (index === 1 && currentPacket.encrypted !== 'none') {\n                    segment.textContent += ` + ${currentPacket.encrypted.toUpperCase()}`;\n                }\n                if (index === 3 && currentPacket.segments) {\n                    segment.textContent += ` Seg ${currentSegment + 1}/${totalSegments}`;\n                }\n                \n                packetVis.appendChild(segment);\n                yPos += layer.height;\n            });\n        }\n        \n        function log(message) {\n            logArea.value += `[${new Date().toLocaleTimeString()}] ${message}\\n`;\n            logArea.scrollTop = logArea.scrollHeight;\n        }\n    </script>\n</body>\n</html>"
  },
