    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B+ Tree Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #e0eafc, #cfdef3);\n            color: #333;\n            margin: 0;\n            padding: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            text-align: center;\n        }\n        h1 {\n            font-size: 2.5rem;\n            margin-bottom: 20px;\n            color: #3a4764;\n        }\n        .bptree {\n            position: relative;\n            display: inline-block;\n            margin: 10px;\n        }\n        .node {\n            background: #4a90e2;\n            border-radius: 10px;\n            color: white;\n            padding: 10px 15px;\n            display: inline-block;\n            transition: transform 0.3s ease;\n            width: 60px;\n            text-align: center;\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);\n        }\n        .link {\n            width: 2px;\n            background: #4a90e2;\n            position: absolute;\n            transition: height 0.3s ease;\n        }\n        .buttons {\n            margin-top: 20px;\n        }\n        button {\n            background: #ff6f61;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 15px;\n            cursor: pointer;\n            font-size: 1rem;\n            margin: 5px;\n            transition: background 0.3s ease;\n        }\n        button:hover {\n            background: #ff4b3a;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>B+ Tree Visualization</h1>\n        <div class=\"bptree\" id=\"bptree\">\n            <div class=\"node\">20</div>\n            <div class=\"link\" style=\"height: 70px; top: 30px; left: 30px;\"></div>\n            <div class=\"node\" style=\"position: absolute; top: 100px; left: 0;\">10</div>\n            <div class=\"node\" style=\"position: absolute; top: 100px; left: 80px;\">15</div>\n            <div class=\"link\" style=\"height: 70px; top: 30px; left: 90px;\"></div>\n            <div class=\"node\" style=\"position: absolute; top: 100px; left: 160px;\">30</div>\n            <div class=\"node\" style=\"position: absolute; top: 100px; left: 240px;\">35</div>\n        </div>\n        <div class=\"buttons\">\n            <button onclick=\"animateTree()\">Animate Tree</button>\n            <button onclick=\"resetTree()\">Reset</button>\n        </div>\n    </div>\n\n    <script>\n        function animateTree() {\n            const nodes = document.querySelectorAll('.node');\n            nodes.forEach((node, index) => {\n                node.style.transform = 'translateY(-10px)';\n                setTimeout(() => {\n                    node.style.transform = 'translateY(0)';\n                }, index * 300);\n            });\n        }\n\n        function resetTree() {\n            const nodes = document.querySelectorAll('.node');\n            nodes.forEach(node => {\n                node.style.transform = 'translateY(0)';\n            });\n        }\n    </script>\n</body>\n</html>"
