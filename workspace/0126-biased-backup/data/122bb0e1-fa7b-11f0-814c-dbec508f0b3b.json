    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tim Sort</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        input[type=\"text\"], input[type=\"number\"], select, button {\n            padding: 0;\n            margin: 0;\n            width: 100%;\n            box-sizing: border-box;\n            font-size: 16px;\n            font-family: monospace;\n            border: none;\n            background-color: #f0f0f0;\n            color: #333;\n        }\n        button {\n            padding: 0 20px;\n            margin: 0 10px;\n            cursor: pointer;\n        }\n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            font-family: monospace;\n            border: none;\n            background-color: #f0f0f0;\n            color: #333;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n        .button:active {\n            background-color: #aaa;\n        }\n        .button:disabled {\n            background-color: #ccc;\n            cursor: not-allowed;\n        }\n        .button:disabled:active {\n            background-color: #aaa;\n        }\n        .button:disabled:active:active {\n            background-color: #ccc;\n        }\n        .button:disabled:active:disabled {\n            background-color: #ccc;\n        }\n        .button:disabled:active:disabled:active {\n            background-color: #aaa;\n        }\n        .button:disabled:active:disabled:active:disabled {\n            background-color: #aaa;\n        }\n        .button:disabled:active:disabled:active:disabled:active {\n            background-color: #aaa;\n        }\n        .button:disabled:active:disabled:active:disabled:active:active {\n            background-color: #aaa;\n        }\n        .button:disabled:active:disabled:active:disabled:active:active:active {\n            background-color: #aaa;\n        }\n    </style>\n</head>\n<body>\n    <input type=\"text\" id=\"input\" placeholder=\"Enter text\">\n    <button id=\"add\">Add</button>\n    <button id=\"subtract\">Subtract</button>\n    <button id=\"multiply\">Multiply</button>\n    <button id=\"divide\">Divide</button>\n    <button id=\"equal\">Equal</button>\n    <button id=\"clear\">Clear</button>\n    <button id=\"undo\">Undo</button>\n    <button id=\"redo\">Redo</button>\n    <button id=\"next\">Next</button>\n    <button id=\"prev\">Prev</button>\n    <div id=\"output\"></div>\n    <script>\n        let input = document.getElementById('input');\n        let add = document.getElementById('add');\n        let subtract = document.getElementById('subtract');\n        let multiply = document.getElementById('multiply');\n        let divide = document.getElementById('divide');\n        let equal = document.getElementById('equal');\n        let clear = document.getElementById('clear');\n        let undo = document.getElementById('undo');\n        let redo = document.getElementById('redo');\n        let next = document.getElementById('next');\n        let prev = document.getElementById('prev');\n        let output = document.getElementById('output');\n\n        add.addEventListener('click', addText);\n        subtract.addEventListener('click', subtractText);\n        multiply.addEventListener('click', multiplyText);\n        divide.addEventListener('click', divideText);\n        equal.addEventListener('click', equalText);\n        clear.addEventListener('click', clearText);\n        undo.addEventListener('click', undoText);\n        redo.addEventListener('click', redoText);\n        next.addEventListener('click', nextText);\n        prev.addEventListener('click', prevText);\n\n        function addText() {\n            let text = input.value;\n            if (text !== '') {\n                output.innerText += text + '\\n';\n            }\n        }\n\n        function subtractText() {\n            let text = input.value;\n            if (text !== '') {\n                output.innerText = output.innerText.slice(0, -1) + text + '\\n';\n            }\n        }\n\n        function multiplyText() {\n            let text = input.value;\n            if (text !== '') {\n                output.innerText += text + '\\n';\n            }\n        }\n\n        function divideText() {\n            let text = input.value;\n            if (text !== '') {\n                output.innerText += text + '\\n';\n            }\n        }\n\n        function equalText() {\n            output.innerText = output.innerText.slice(0, -1) + input.value + '\\n';\n        }\n\n        function clearText() {\n            output.innerText = '';\n            input.value = '';\n        }\n\n        function undoText() {\n            if (output.innerText !== '') {\n                output.innerText = output.innerText.slice(0, -1);\n            }\n        }\n\n        function redoText() {\n            if (output.innerText !== '') {\n                output.innerText = output.innerText.slice(0, -1) + output.innerText.slice(-1);\n            }\n        }\n\n        function nextText() {\n            let text = output.innerText;\n            if (text !== '') {\n                output.innerText = text + '\\n';\n            } else {\n                output.innerText = '';\n            }\n        }\n\n        function prevText() {\n            let text = output.innerText;\n            if (text !== '') {\n                output.innerText = text.slice(0, -1) + '\\n';\n            } else {\n                output.innerText = '';\n            }\n        }\n    </script>\n</body>\n</html>"
