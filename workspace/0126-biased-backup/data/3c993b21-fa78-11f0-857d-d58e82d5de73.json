    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Mutex Concept — Elegant Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display&display=swap');\n\n  /* Root and base */\n  :root {\n    --color-dark: #0a192f;\n    --color-primary: #3ddc97;\n    --color-secondary: #00ffad;\n    --color-accent: #f9a825;\n    --color-bg-gradient-start: #091633;\n    --color-bg-gradient-end: #1f2a47;\n    --color-text-light: #e6f1ff;\n    --color-text-muted: #a0aec0;\n    --shadow-glow: 0 0 10px var(--color-primary);\n    --shadow-glow-strong: 0 0 20px var(--color-secondary);\n  }\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(145deg, var(--color-bg-gradient-start), var(--color-bg-gradient-end));\n    font-family: 'Montserrat', sans-serif;\n    color: var(--color-text-light);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  #container {\n    max-width: 960px;\n    width: 90vw;\n    background: linear-gradient(135deg, #142c56dd, #203a79dd);\n    border-radius: 2rem;\n    padding: 3.5rem 4rem 4rem 4rem;\n    box-shadow: \n      inset 0 0 40px 2px var(--color-primary),\n      0 25px 40px rgb(0 255 173 / 0.25);\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Title */\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.8rem;\n    line-height: 1.1;\n    text-align: center;\n    color: var(--color-primary);\n    text-shadow:\n      0 0 8px var(--color-primary),\n      0 0 20px var(--color-secondary);\n    margin-bottom: 1.25rem;\n  }\n  .subtitle {\n    text-align: center;\n    font-weight: 300;\n    font-size: 1.25rem;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    color: var(--color-text-muted);\n    margin-bottom: 3.5rem;\n    user-select: none;\n  }\n\n  /* Visual Concept Wrapper */\n  #mutex-visual {\n    width: 100%;\n    aspect-ratio: 16 / 9;\n    position: relative;\n    filter: drop-shadow(0 0 6px var(--color-primary));\n  }\n\n  /* The \"Mutex\" circle */\n  .mutex-circle {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 14rem;\n    height: 14rem;\n    background: var(--color-bg-gradient-end);\n    border-radius: 50%;\n    border: 6px solid var(--color-primary);\n    box-shadow:\n      0 0 20px 6px var(--color-primary),\n      inset 0 0 40px rgba(61, 220, 151, 0.65);\n    transform: translate(-50%, -50%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    filter: drop-shadow(0 0 12px var(--color-secondary));\n    user-select: none;\n  }\n\n  .mutex-label {\n    font-family: 'Playfair Display', serif;\n    font-size: 3rem;\n    font-weight: 700;\n    color: var(--color-primary);\n    text-shadow:\n      0 0 12px var(--color-secondary),\n      0 0 24px var(--color-primary);\n    user-select: none;\n  }\n\n  /* Threads container */\n  #threads {\n    position: absolute;\n    width: 100%;\n    height: 100%;\n    top: 0;\n    left: 0;\n  }\n\n  /* Thread style */\n  .thread {\n    position: absolute;\n    width: 6rem;\n    height: 14rem;\n    background:\n      linear-gradient(120deg, #0a192f 40%, var(--color-primary) 60%);\n    border-radius: 3rem / 1.4rem;\n    box-shadow:\n      0 0 10px 2px var(--color-primary),\n      inset 0 0 8px 2px var(--color-secondary);\n    filter: drop-shadow(0 0 3px var(--color-secondary));\n    transition:\n      background 0.6s ease,\n      box-shadow 0.6s ease;\n    /* Anchor bottom center for rotation origin */\n    transform-origin: 50% 90%;\n  }\n\n  /* Thread Label */\n  .thread-label {\n    position: absolute;\n    bottom: 1.8rem;\n    width: 100%;\n    text-align: center;\n    font-size: 1rem;\n    font-weight: 600;\n    color: var(--color-primary);\n    user-select: none;\n    text-shadow: 0 0 4px var(--color-secondary);\n    letter-spacing: 0.04em;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  /* Positions and animations for threads */\n  #thread-1 {\n    left: 22%;\n    bottom: 25%;\n    transform-origin: 50% 100%;\n    animation: threadPendulum1 6.5s ease-in-out infinite;\n    cursor: default;\n  }\n  #thread-2 {\n    left: 42%;\n    bottom: 26%;\n    transform-origin: 50% 100%;\n    animation: threadPendulum2 7s ease-in-out infinite;\n  }\n  #thread-3 {\n    left: 65%;\n    bottom: 23%;\n    transform-origin: 50% 100%;\n    animation: threadPendulum3 6.2s ease-in-out infinite;\n  }\n\n  /* Animations */\n  @keyframes threadPendulum1 {\n    0%, 100% { transform: rotate(-12deg); background: linear-gradient(120deg, #081823 40%, var(--color-primary) 60%); box-shadow: 0 0 10px 2px var(--color-primary), inset 0 0 8px 2px var(--color-secondary); }\n    50% { transform: rotate(9deg); background: linear-gradient(120deg, #0d2e41 40%, var(--color-secondary) 60%); box-shadow: 0 0 20px 4px var(--color-secondary), inset 0 0 14px 4px var(--color-primary);}\n  }\n  @keyframes threadPendulum2 {\n    0%, 100% { transform: rotate(10deg); background: linear-gradient(120deg, #081823 40%, var(--color-primary) 60%); box-shadow: 0 0 10px 2px var(--color-primary), inset 0 0 8px 2px var(--color-secondary);}\n    50% { transform: rotate(-8deg); background: linear-gradient(120deg, #0d2e41 40%, var(--color-secondary) 60%); box-shadow: 0 0 20px 4px var(--color-secondary), inset 0 0 14px 4px var(--color-primary);}\n  }\n  @keyframes threadPendulum3 {\n    0%, 100% { transform: rotate(-7deg); background: linear-gradient(120deg, #081823 40%, var(--color-primary) 60%); box-shadow: 0 0 10px 2px var(--color-primary), inset 0 0 8px 2px var(--color-secondary);}\n    50% { transform: rotate(12deg); background: linear-gradient(120deg, #0d2e41 40%, var(--color-secondary) 60%); box-shadow: 0 0 20px 4px var(--color-secondary), inset 0 0 14px 4px var(--color-primary);}\n  }\n\n  /* Mutex Locked/Unlocked status ring */\n  #status-ring {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 20rem;\n    height: 20rem;\n    border-radius: 50%;\n    border: 8px solid transparent;\n    box-shadow:\n      0 0 40px 6px var(--color-secondary);\n    transform: translate(-50%, -50%);\n    transition: border-color 1s ease;\n    pointer-events: none;\n    z-index: 0;\n  }\n  #status-ring.locked {\n    border-color: var(--color-primary);\n    box-shadow: 0 0 48px 12px var(--color-primary);\n  }\n  #status-ring.unlocked {\n    border-color: var(--color-secondary);\n    box-shadow: 0 0 48px 12px var(--color-secondary);\n  }\n\n  /* Lock Icon in center */\n  #lock-icon {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 5rem;\n    height: 7rem;\n    fill: var(--color-text-light);\n    filter: drop-shadow(0 0 6px var(--color-primary));\n    user-select: none;\n    pointer-events: none;\n    transform: translate(-50%, -50%);\n    transition: fill 0.8s ease;\n    z-index: 10;\n  }\n  #lock-icon.unlocked {\n    fill: var(--color-secondary);\n    filter: drop-shadow(0 0 12px var(--color-secondary));\n  }\n  \n  /* Description */\n  #description {\n    margin-top: 3rem;\n    font-size: 1.1rem;\n    line-height: 1.5;\n    color: var(--color-text-muted);\n    text-align: center;\n    font-style: italic;\n    max-width: 780px;\n    user-select: none;\n  }\n\n  /* Buttons container */\n  #buttons {\n    margin-top: 3.5rem;\n    text-align: center;\n  }\n  button {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: var(--color-text-light);\n    background-color: var(--color-primary);\n    border: none;\n    border-radius: 1.2rem;\n    padding: 0.68rem 2.6rem;\n    margin: 0 0.5rem;\n    cursor: pointer;\n    box-shadow: 0 0 15px 0 var(--color-primary);\n    transition:\n      background-color 0.5s ease,\n      box-shadow 0.8s ease,\n      transform 0.3s ease;\n    user-select: none;\n    outline-offset: 4px;\n  }\n  button:hover,\n  button:focus {\n    background-color: var(--color-secondary);\n    box-shadow: 0 0 25px 4px var(--color-secondary);\n    transform: scale(1.12);\n  }\n  button:focus {\n    outline: 2.5px solid var(--color-accent);\n  }\n\n  /* Tooltip on buttons */\n  button[title] {\n    position: relative;\n  }\n  button[title]:hover::after,\n  button[title]:focus::after {\n    content: attr(title);\n    position: absolute;\n    bottom: 110%;\n    left: 50%;\n    transform: translateX(-50%);\n    background-color: #143554dd;\n    color: var(--color-text-light);\n    padding: 0.25rem 0.7rem;\n    border-radius: 0.4rem;\n    font-size: 0.9rem;\n    white-space: nowrap;\n    box-shadow: 0 0 10px 1px rgba(0, 255, 173, 0.8);\n    opacity: 1;\n    transition: opacity 0.3s ease;\n    pointer-events: none;\n    user-select: none;\n  }\n\n  button[title]::after {\n    opacity: 0;\n    pointer-events: none;\n  }\n\n  /* Scrollbar hidden */\n  ::-webkit-scrollbar {\n    width: 0;\n    height: 0;\n  }\n\n  /* Responsive scaling */\n  @media (max-width: 620px) {\n    h1 {\n      font-size: 2.9rem;\n    }\n    #mutex-visual {\n      aspect-ratio: 4 / 5;\n    }\n    .mutex-circle {\n      width: 10rem;\n      height: 10rem;\n    }\n    #status-ring {\n      width: 15rem;\n      height: 15rem;\n    }\n    #lock-icon {\n      width: 4rem;\n      height: 5.5rem;\n    }\n    .thread {\n      width: 4.6rem;\n      height: 10rem;\n    }\n    .thread-label {\n      font-size: 0.9rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <main id=\"container\" role=\"main\" aria-label=\"Mutex concept demonstration\">\n    <h1>Mutex</h1>\n    <div class=\"subtitle\">Mutual Exclusion Concept</div>\n    <section id=\"mutex-visual\" aria-describedby=\"description\" aria-live=\"polite\" aria-atomic=\"true\">\n      <div id=\"status-ring\" class=\"locked\" aria-label=\"Mutex is currently locked\"></div>\n      <svg id=\"lock-icon\" class=\"locked\" aria-hidden=\"true\" viewBox=\"0 0 64 88\" role=\"img\" >\n        <path d=\"M48 32v-8a16 16 0 0 0-32 0v8H8a8 8 0 0 0-8 8v32a8 8 0 0 0 8 8h48a8 8 0 0 0 8-8V40a8 8 0 0 0-8-8ZM24 24a8 8 0 0 1 16 0v8H24Zm28 48H12V44h40Z\"/>\n      </svg>\n      <div class=\"mutex-circle\" aria-label=\"Critical Section\"><span class=\"mutex-label\">CS</span></div>\n      <div id=\"threads\" aria-label=\"Threads trying to access critical section\">\n        <div class=\"thread\" id=\"thread-1\" tabindex=\"-1\" aria-label=\"Thread 1 (waiting)\">\n          <div class=\"thread-label\">Thread 1</div>\n        </div>\n        <div class=\"thread\" id=\"thread-2\" tabindex=\"-1\" aria-label=\"Thread 2 (waiting)\">\n          <div class=\"thread-label\">Thread 2</div>\n        </div>\n        <div class=\"thread\" id=\"thread-3\" tabindex=\"-1\" aria-label=\"Thread 3 (waiting)\">\n          <div class=\"thread-label\">Thread 3</div>\n        </div>\n      </div>\n    </section>\n    <p id=\"description\">\n      A <strong>mutex</strong> (mutual exclusion) is a synchronization primitive used to avoid simultaneous access to a <em>critical section</em> by multiple threads. Only one thread can <strong>lock</strong> the mutex, gaining exclusive access, while others must wait. This visualization shows threads as pendulums circling around the critical section, which is locked or unlocked by toggling the mutex state, demonstrating safe coordination in concurrent programming.\n    </p>\n    <div id=\"buttons\" role=\"group\" aria-label=\"Control mutex lock state\">\n      <button id=\"toggleLock\" title=\"Toggle Mutex Lock State\" aria-pressed=\"true\" aria-live=\"polite\" aria-controls=\"mutex-visual\">\n        Unlock Mutex\n      </button>\n    </div>\n  </main>\n<script>\n  (() => {\n    const statusRing = document.getElementById('status-ring');\n    const lockIcon = document.getElementById('lock-icon');\n    const toggleLockBtn = document.getElementById('toggleLock');\n    const threads = document.querySelectorAll('.thread');\n    const container = document.getElementById('mutex-visual');\n    let locked = true;\n\n    // Update states and ARIA labels\n    function updateState() {\n      if (locked) {\n        statusRing.classList.remove('unlocked');\n        statusRing.classList.add('locked');\n        lockIcon.classList.remove('unlocked');\n        lockIcon.classList.add('locked');\n        lockIcon.setAttribute('aria-label', 'Lock icon: Locked');\n        statusRing.setAttribute('aria-label', 'Mutex is currently locked');\n        toggleLockBtn.textContent = 'Unlock Mutex';\n        toggleLockBtn.setAttribute('aria-pressed', 'true');\n\n        threads.forEach((t, i) => {\n          t.setAttribute('aria-label', `Thread ${i+1} (waiting)`);\n          t.style.filter = `drop-shadow(0 0 3px var(--color-primary))`;\n        });\n      } else {\n        statusRing.classList.remove('locked');\n        statusRing.classList.add('unlocked');\n        lockIcon.classList.remove('locked');\n        lockIcon.classList.add('unlocked');\n        lockIcon.setAttribute('aria-label', 'Lock icon: Unlocked');\n        statusRing.setAttribute('aria-label', 'Mutex is currently unlocked');\n        toggleLockBtn.textContent = 'Lock Mutex';\n        toggleLockBtn.setAttribute('aria-pressed', 'false');\n\n        // Animate one thread \"inside\" the CS, others waiting\n        threads.forEach((t, i) => {\n          if (i === 1) { // Thread 2 enters Critical Section\n            t.style.transition = 'transform 1s ease, filter 1s ease';\n            t.style.transformOrigin = 'center bottom';\n            // Position thread-2 inside circle (center)\n            t.style.left = '50%';\n            t.style.bottom = '50%';\n            // Stop pendulum swing\n            t.style.animationPlayState = 'paused';\n            t.style.filter = 'drop-shadow(0 0 20px var(--color-secondary))';\n            t.setAttribute('aria-label', `Thread 2 (inside critical section)`);\n          } else {\n            t.style.transition = 'transform 0.6s ease, filter 0.6s ease, left 0.8s ease, bottom 0.8s ease';\n            // Restore original pendulum positions after small delay\n            setTimeout(() => {\n              if(i === 0) {\n                t.style.left = '22%';\n                t.style.bottom = '25%';\n              } else if(i === 2) {\n                t.style.left = '65%';\n                t.style.bottom = '23%';\n              }\n              t.style.animationPlayState = 'running';\n              t.style.filter = 'drop-shadow(0 0 3px var(--color-primary))';\n              t.setAttribute('aria-label', `Thread ${i + 1} (waiting)`);\n            }, 300);\n          }\n        });\n      }\n    }\n\n    toggleLockBtn.addEventListener('click', () => {\n      locked = !locked;\n      updateState();\n    });\n\n    // Initial state\n    updateState();\n\n  })();\n</script>\n</body>\n</html>"
