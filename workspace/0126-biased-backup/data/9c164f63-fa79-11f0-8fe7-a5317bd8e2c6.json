    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Interpreter — Interactive Demo</title>\n<style>\n/* Minimal / mostly empty to satisfy embedding requirement */\n</style>\n</head>\n<body>\n<h1>Interpreter — Interactive Demo</h1>\n\n<p>Plain, functional interface. Edit the program, compile, run, step, set breakpoints, snapshot, fork runs, compare runs. Everything is text-based and minimal.</p>\n\n<div>\n  <label>Sample programs:\n    <select id=\"sampleSelect\">\n      <option value=\"fib\">Fibonacci (recursive)</option>\n      <option value=\"count\">While loop counter</option>\n      <option value=\"closure\">Closure and RET</option>\n      <option value=\"ifelse\">If / Else example</option>\n      <option value=\"factorial\">Factorial (iterative)</option>\n      <option value=\"mutate\">Mutate example</option>\n    </select>\n  </label>\n  <button id=\"loadSample\">Load sample</button>\n</div>\n\n<div>\n  <label>Program (edit):</label><br>\n  <textarea id=\"program\" rows=\"18\" cols=\"95\">// Example language:\n // let x = 1;\n // fun add(a,b){ return a + b; }\n // print(add(2,3));\n\n // Sample program - Fibonacci by default:\n fun fib(n) {\n   if (n <= 1) {\n     return n;\n   } else {\n     return fib(n-1) + fib(n-2);\n   }\n }\n\n print(\"fib(6) = \" + fib(6));\n</textarea>\n</div>\n\n<div>\n  <button id=\"parseBtn\">Tokenize & Parse</button>\n  <button id=\"compileBtn\">Compile</button>\n  <button id=\"runBtn\">Run</button>\n  <button id=\"pauseBtn\">Pause</button>\n  <button id=\"stepBtn\">Step (Into)</button>\n  <button id=\"stepOverBtn\">Step Over</button>\n  <button id=\"stepOutBtn\">Step Out</button>\n  <button id=\"resetBtn\">Reset</button>\n  <label>Speed: <input type=\"range\" id=\"speed\" min=\"0\" max=\"1000\" value=\"200\"></label>\n  <label>Auto-run until breakpoints: <input type=\"checkbox\" id=\"autoRunBreakpoints\"></label>\n</div>\n\n<div>\n  <label>Initial Environment (JSON):</label><br>\n  <input id=\"initEnv\" style=\"width:95%\" value='{\"print\": \"builtin\"}'>\n</div>\n\n<div>\n  <label>Breakpoints (comma list of instr ids): <input id=\"breakpointsInput\" style=\"width:50%\"></label>\n  <button id=\"toggleBreakpointAtPC\">Toggle breakpoint at current PC</button>\n  <button id=\"clearBreakpoints\">Clear breakpoints</button>\n</div>\n\n<div>\n  <button id=\"snapshotBtn\">Snapshot</button>\n  <button id=\"restoreBtn\">Restore</button>\n  <button id=\"forkBtn\">Fork current VM (create branch)</button>\n  <button id=\"compareBtn\">Compare with last run</button>\n  <button id=\"mutateRenameBtn\">Rename variable (simple replace)</button>\n  <input id=\"renameFrom\" placeholder=\"from\" value=\"x\">\n  <input id=\"renameTo\" placeholder=\"to\" value=\"y\">\n  <button id=\"mutateInlineBtn\">Inline constant (replace literal)</button>\n  <input id=\"inlineFrom\" placeholder=\"from literal\">\n  <input id=\"inlineTo\" placeholder=\"to literal\">\n</div>\n\n<hr>\n\n<div style=\"display:flex;gap:10px;\">\n  <div style=\"flex:1;\">\n    <h3>Tokens</h3>\n    <pre id=\"tokens\" style=\"height:180px;overflow:auto;border:1px solid #000;\"></pre>\n    <h3>AST (JSON)</h3>\n    <pre id=\"ast\" style=\"height:220px;overflow:auto;border:1px solid #000;\"></pre>\n  </div>\n\n  <div style=\"flex:1;\">\n    <h3>Instructions</h3>\n    <pre id=\"instructions\" style=\"height:300px;overflow:auto;border:1px solid #000;\"></pre>\n    <h4>Click an instruction to toggle breakpoint</h4>\n  </div>\n\n  <div style=\"width:350px;\">\n    <h3>Execution / Debug</h3>\n    <div>PC: <span id=\"pc\">-</span> &nbsp; Frame: <span id=\"frameIdx\">-</span></div>\n    <div>Breakpoints: <span id=\"bpsList\">none</span></div>\n    <h4>Stack</h4>\n    <pre id=\"stack\" style=\"height:120px;overflow:auto;border:1px solid #000;\"></pre>\n    <h4>Call Stack</h4>\n    <pre id=\"callstack\" style=\"height:120px;overflow:auto;border:1px solid #000;\"></pre>\n    <h4>Global Env</h4>\n    <pre id=\"globals\" style=\"height:120px;overflow:auto;border:1px solid #000;\"></pre>\n  </div>\n</div>\n\n<hr>\n\n<div style=\"display:flex;gap:10px;\">\n  <div style=\"flex:1;\">\n    <h3>Output</h3>\n    <pre id=\"output\" style=\"height:200px;overflow:auto;border:1px solid #000;\"></pre>\n    <h3>Trace Log</h3>\n    <pre id=\"trace\" style=\"height:200px;overflow:auto;border:1px solid #000;\"></pre>\n  </div>\n\n  <div style=\"width:420px;\">\n    <h3>Snapshots / Branches</h3>\n    <pre id=\"snapshots\" style=\"height:420px;overflow:auto;border:1px solid #000;\"></pre>\n  </div>\n</div>\n\n<script>\n// Minimal but functional interpreter demo JavaScript\n\n// Language: small C/JS-like syntax with:\n// let/assignment, fun, return, if/else, while, print builtin, expressions, calls, blocks, numbers, strings, booleans\n\n// Tokenizer\nfunction tokenize(input) {\n  const tokens = [];\n  const re = /\\s*([A-Za-z_][A-Za-z0-9_]*|[0-9]+(?:\\.[0-9]+)?|\"([^\"\\\\]|\\\\.)*\"|'([^'\\\\]|\\\\.)*'|<=|>=|==|!=|&&|\\|\\||[+\\-*/%<>=!(),;{}]|\\S)/y;\n  let m;\n  while ((m = re.exec(input)) !== null) {\n    let t = m[1];\n    if (/^\"([^\"\\\\]|\\\\.)*\"$/.test(t) || /^'([^'\\\\]|\\\\.)*'$/.test(t)) {\n      // string literal\n      const raw = t;\n      const val = raw.slice(1, -1).replace(/\\\\n/g, \"\\n\").replace(/\\\\t/g, \"\\t\").replace(/\\\\\"/g, '\"').replace(/\\\\\\\\/g, \"\\\\\");\n      tokens.push({type:'string', value: val});\n    } else if (/^[0-9]+(?:\\.[0-9]+)?$/.test(t)) {\n      tokens.push({type:'number', value: Number(t)});\n    } else if (/^[A-Za-z_][A-Za-z0-9_]*$/.test(t)) {\n      tokens.push({type:'ident', value: t});\n    } else {\n      tokens.push({type: t, value: t});\n    }\n  }\n  tokens.push({type: 'EOF'});\n  return tokens;\n}\n\n// Parser: recursive descent\nfunction parse(tokens) {\n  let i = 0;\n  function peek() { return tokens[i]; }\n  function next() { return tokens[i++]; }\n  function expect(type, val) {\n    const t = peek();\n    if (!t || (t.type !== type && t.value !== type)) {\n      throw new Error('Expected ' + type + ' but got ' + JSON.stringify(t));\n    }\n    return next();\n  }\n\n  function parseProgram() {\n    const body = [];\n    while (peek().type !== 'EOF') {\n      body.push(parseStatement());\n    }\n    return {type:'Program', body};\n  }\n\n  function parseStatement() {\n    const t = peek();\n    if (t.type === 'ident' && t.value === 'let') {\n      next();\n      const name = expect('ident').value;\n      expect('=');\n      const expr = parseExpression();\n      optional(';');\n      return {type:'VariableDeclaration', id:name, init:expr};\n    }\n    if (t.type === 'ident' && t.value === 'fun') {\n      next();\n      const nameOrParen = peek();\n      let name = null;\n      if (nameOrParen.type === 'ident') name = next().value;\n      expect('(');\n      const params = [];\n      if (peek().type !== ')') {\n        while (true) {\n          params.push(expect('ident').value);\n          if (peek().type === ',') { next(); continue; }\n          break;\n        }\n      }\n      expect(')');\n      const body = parseBlock();\n      return {type:'FunctionDeclaration', id:name, params, body};\n    }\n    if (t.type === 'ident' && t.value === 'return') {\n      next();\n      const arg = (peek().type === ';' ? null : parseExpression());\n      optional(';');\n      return {type:'ReturnStatement', argument: arg};\n    }\n    if (t.type === 'ident' && t.value === 'if') {\n      next();\n      expect('(');\n      const test = parseExpression();\n      expect(')');\n      const consequent = parseBlock();\n      let alternate = null;\n      if (peek().type === 'ident' && peek().value === 'else') {\n        next();\n        alternate = parseBlock();\n      }\n      return {type:'IfStatement', test, consequent, alternate};\n    }\n    if (t.type === 'ident' && t.value === 'while') {\n      next();\n      expect('(');\n      const test = parseExpression();\n      expect(')');\n      const body = parseBlock();\n      return {type:'WhileStatement', test, body};\n    }\n    if (t.type === '{') {\n      return parseBlock();\n    }\n    // expression or assignment\n    const expr = parseExpression();\n    optional(';');\n    // if expression is assignment to identifier and not a call, treat as assignment\n    if (expr.type === 'AssignmentExpression') return {type:'ExpressionStatement', expression:expr};\n    if (expr.type === 'CallExpression' || expr.type === 'BinaryExpression' || expr.type === 'UnaryExpression' || expr.type === 'Identifier' || expr.type === 'Literal' || expr.type === 'MemberExpression') {\n      return {type:'ExpressionStatement', expression:expr};\n    }\n    return {type:'ExpressionStatement', expression:expr};\n  }\n\n  function parseBlock() {\n    if (peek().type === '{') {\n      next();\n      const body = [];\n      while (peek().type !== '}') {\n        if (peek().type === 'EOF') throw new Error('Unterminated block');\n        body.push(parseStatement());\n      }\n      next();\n      return {type:'BlockStatement', body};\n    } else {\n      // single statement as block\n      const stmt = parseStatement();\n      return {type:'BlockStatement', body:[stmt]};\n    }\n  }\n\n  function optional(tok) {\n    if (peek().type === tok) { next(); return true; }\n    return false;\n  }\n\n  // Expression parsing (precedence climbing)\n  function parseExpression() {\n    return parseAssignment();\n  }\n\n  function parseAssignment() {\n    const left = parseLogicalOr();\n    if (peek().type === '=') {\n      next();\n      const right = parseAssignment();\n      if (left.type === 'Identifier') {\n        return {type:'AssignmentExpression', operator:'=', left:left, right:right};\n      } else {\n        throw new Error('Invalid assignment target');\n      }\n    }\n    return left;\n  }\n\n  function parseLogicalOr() {\n    let node = parseLogicalAnd();\n    while (peek().type === '||') {\n      const op = next().type;\n      const right = parseLogicalAnd();\n      node = {type:'BinaryExpression', operator: op, left: node, right: right};\n    }\n    return node;\n  }\n  function parseLogicalAnd() {\n    let node = parseEquality();\n    while (peek().type === '&&') {\n      const op = next().type;\n      const right = parseEquality();\n      node = {type:'BinaryExpression', operator: op, left: node, right: right};\n    }\n    return node;\n  }\n  function parseEquality() {\n    let node = parseRelational();\n    while (peek().type === '==' || peek().type === '!=') {\n      const op = next().type;\n      const right = parseRelational();\n      node = {type:'BinaryExpression', operator: op, left: node, right: right};\n    }\n    return node;\n  }\n  function parseRelational() {\n    let node = parseAdditive();\n    while (peek().type === '<' || peek().type === '>' || peek().type === '<=' || peek().type === '>=') {\n      const op = next().type;\n      const right = parseAdditive();\n      node = {type:'BinaryExpression', operator: op, left: node, right: right};\n    }\n    return node;\n  }\n  function parseAdditive() {\n    let node = parseMultiplicative();\n    while (peek().type === '+' || peek().type === '-') {\n      const op = next().type;\n      const right = parseMultiplicative();\n      node = {type:'BinaryExpression', operator: op, left: node, right: right};\n    }\n    return node;\n  }\n  function parseMultiplicative() {\n    let node = parseUnary();\n    while (peek().type === '*' || peek().type === '/' || peek().type === '%') {\n      const op = next().type;\n      const right = parseUnary();\n      node = {type:'BinaryExpression', operator: op, left: node, right: right};\n    }\n    return node;\n  }\n  function parseUnary() {\n    if (peek().type === '!' || peek().type === '-') {\n      const op = next().type;\n      const arg = parseUnary();\n      return {type:'UnaryExpression', operator: op, argument: arg};\n    }\n    return parsePrimary();\n  }\n  function parsePrimary() {\n    const t = peek();\n    if (t.type === 'number') { next(); return {type:'Literal', value: t.value}; }\n    if (t.type === 'string') { next(); return {type:'Literal', value: t.value}; }\n    if (t.type === 'ident') {\n      const id = next().value;\n      if (peek().type === '(') {\n        // call\n        next();\n        const args = [];\n        if (peek().type !== ')') {\n          while (true) {\n            args.push(parseExpression());\n            if (peek().type === ',') { next(); continue; }\n            break;\n          }\n        }\n        expect(')');\n        return {type:'CallExpression', callee:{type:'Identifier', name:id}, arguments: args};\n      } else {\n        return {type:'Identifier', name: id};\n      }\n    }\n    if (t.type === '(') {\n      next();\n      const expr = parseExpression();\n      expect(')');\n      return expr;\n    }\n    throw new Error('Unexpected token in expression: ' + JSON.stringify(t));\n  }\n\n  const ast = parseProgram();\n  return ast;\n}\n\n// Compiler: compile AST to instruction arrays; each function gets its own instructions with id\nlet instrIdCounter = 1;\nfunction compileProgram(ast) {\n  instrIdCounter = 1;\n  const funcTable = [];\n  function compileNode(node, instrs, add) {\n    add = add || function(i){ instrs.push(i); };\n    switch (node.type) {\n      case 'Program':\n        for (const s of node.body) compileNode(s, instrs);\n        add({op:'PUSH_CONST', arg: null}); // program returns null\n        add({op:'RETURN'});\n        break;\n      case 'BlockStatement':\n        for (const s of node.body) compileNode(s, instrs);\n        break;\n      case 'VariableDeclaration':\n        compileNode(node.init, instrs);\n        add({op:'STORE', arg: node.id});\n        break;\n      case 'FunctionDeclaration':\n        // compile function body to its own instr array and record function object\n        const funcInstr = [];\n        const fid = instrIdCounter++;\n        funcInstr._id = fid;\n        // parameters are node.params\n        // create local variables for params will be handled at call setup\n        // compile function body\n        compileNode(node.body, funcInstr);\n        funcInstr.push({op:'PUSH_CONST', arg: null});\n        funcInstr.push({op:'RETURN'});\n        funcTable.push({id: fid, params: node.params, instrs: funcInstr});\n        add({op:'PUSH_CONST', arg: {type:'function_literal', id: fid, params: node.params}});\n        if (node.id) {\n          add({op:'STORE', arg: node.id});\n        } else {\n          // anonymous function expression on stack (if used)\n        }\n        break;\n      case 'ReturnStatement':\n        if (node.argument) compileNode(node.argument, instrs);\n        else instrs.push({op:'PUSH_CONST', arg: null});\n        instrs.push({op:'RETURN'});\n        break;\n      case 'IfStatement':\n        compileNode(node.test, instrs);\n        const jfalseIdx = instrs.length;\n        instrs.push({op:'JUMP_IF_FALSE', arg: null}); // patch\n        compileNode(node.consequent, instrs);\n        const jendIdx = instrs.length;\n        instrs.push({op:'JUMP', arg: null}); // patch\n        // patch false jump to here\n        instrs[jfalseIdx].arg = instrs.length;\n        if (node.alternate) compileNode(node.alternate, instrs);\n        instrs[jendIdx].arg = instrs.length;\n        break;\n      case 'WhileStatement':\n        const loopStart = instrs.length;\n        compileNode(node.test, instrs);\n        const jumpEndIdx = instrs.length;\n        instrs.push({op:'JUMP_IF_FALSE', arg: null});\n        compileNode(node.body, instrs);\n        instrs.push({op:'JUMP', arg: loopStart});\n        instrs[jumpEndIdx].arg = instrs.length;\n        break;\n      case 'ExpressionStatement':\n        compileNode(node.expression, instrs);\n        instrs.push({op:'POP'});\n        break;\n      case 'AssignmentExpression':\n        compileNode(node.right, instrs);\n        add({op:'STORE', arg: node.left.name});\n        break;\n      case 'CallExpression':\n        // compile arguments left-to-right\n        for (const a of node.arguments) compileNode(a, instrs);\n        // push function reference (identifier)\n        if (node.callee.type === 'Identifier') {\n          add({op:'LOAD', arg: node.callee.name});\n        } else {\n          throw new Error('Unsupported callee type'); // simplified\n        }\n        add({op:'CALL', arg: node.arguments.length});\n        break;\n      case 'BinaryExpression':\n        compileNode(node.left, instrs);\n        compileNode(node.right, instrs);\n        add({op:'BINARY', arg: node.operator});\n        break;\n      case 'UnaryExpression':\n        compileNode(node.argument, instrs);\n        add({op:'UNARY', arg: node.operator});\n        break;\n      case 'Identifier':\n        add({op:'LOAD', arg: node.name});\n        break;\n      case 'Literal':\n        add({op:'PUSH_CONST', arg: node.value});\n        break;\n      default:\n        throw new Error('Compile: unknown node type ' + node.type);\n    }\n  }\n\n  const mainInstrs = [];\n  compileNode(ast, mainInstrs);\n  mainInstrs._id = instrIdCounter++;\n  return {main: mainInstrs, functions: funcTable};\n}\n\n// Runtime VM\nfunction createVM(compiled, initEnv) {\n  // env is chain of objects: {vars: {}, parent: env or null}\n  function makeEnv(parent) { return {vars: Object.create(null), parent: parent}; }\n  const globalEnv = makeEnv(null);\n  // initialize with initEnv keys\n  try {\n    const parsed = (typeof initEnv === 'string') ? JSON.parse(initEnv) : initEnv;\n    if (parsed && typeof parsed === 'object') {\n      for (const k of Object.keys(parsed)) {\n        if (parsed[k] === 'builtin') {\n          // an easy way to configure builtins via initial environment:\n          // known builtins: print\n          if (k === 'print') {\n            globalEnv.vars['print'] = {type:'builtin', fn: (args, vm)=>{ vm.appendOutput(args.map(v=>String(v)).join(' ')); return null; }};\n          } else {\n            globalEnv.vars[k] = parsed[k];\n          }\n        } else {\n          globalEnv.vars[k] = parsed[k];\n        }\n      }\n    }\n  } catch(e){}\n  // also ensure print exists\n  if (!('print' in globalEnv.vars)) {\n    globalEnv.vars['print'] = {type:'builtin', fn: (args, vm)=>{ vm.appendOutput(args.map(v=>String(v)).join(' ')); return null; }};\n  }\n\n  // map function literals id -> compiled instructions and params\n  const funcMap = new Map();\n  for (const f of compiled.functions) {\n    f.instrs._id = f.id;\n    funcMap.set(f.id, f);\n  }\n\n  // VM structure\n  const vm = {\n    // frames: array of frames {instrs, ip, env, retStackSize}\n    frames: [],\n    stack: [],\n    outputLines: [],\n    trace: [],\n    breakpoints: new Set(), // store \"instrId:pc\" as string for disambiguation\n    running: false,\n    paused: false,\n    // for stepping semantics\n    requestedStep: null,\n    // functions\n    appendOutput(text) {\n      this.outputLines.push(String(text));\n      updateUI();\n    },\n    pushFrame(instrs, env) {\n      this.frames.push({instrs: instrs, ip:0, env: env, retStackSize: this.stack.length});\n    },\n    popFrame() {\n      return this.frames.pop();\n    },\n    currentFrame() {\n      return this.frames[this.frames.length-1] || null;\n    },\n    lookup(name, env) {\n      let cur = env;\n      while (cur) {\n        if (Object.prototype.hasOwnProperty.call(cur.vars, name)) return {found:true, env:cur};\n        cur = cur.parent;\n      }\n      return {found:false, env: env}; // default to current env for store\n    },\n    stepInstruction() {\n      const frame = this.currentFrame();\n      if (!frame) return {status:'halted'};\n      if (frame.ip >= frame.instrs.length) {\n        // frame ended without return: pop it\n        this.popFrame();\n        return {status:'frame_end'};\n      }\n      const ins = frame.instrs[frame.ip];\n      // trace\n      this.trace.push('[' + (frame.instrs._id || '?') + ':' + frame.ip + '] ' + JSON.stringify(ins));\n      frame.ip++;\n      switch (ins.op) {\n        case 'PUSH_CONST':\n          this.stack.push(ins.arg);\n          break;\n        case 'LOAD': {\n          const res = this.lookup(ins.arg, frame.env);\n          if (res.found) {\n            this.stack.push(res.env.vars[ins.arg]);\n          } else {\n            this.stack.push(undefined);\n          }\n          break;\n        }\n        case 'STORE': {\n          const val = this.stack.pop();\n          const res = this.lookup(ins.arg, frame.env);\n          if (res.found) {\n            res.env.vars[ins.arg] = val;\n          } else {\n            // store in current frame env\n            frame.env.vars[ins.arg] = val;\n          }\n          break;\n        }\n        case 'POP':\n          this.stack.pop();\n          break;\n        case 'JUMP':\n          frame.ip = ins.arg;\n          break;\n        case 'JUMP_IF_FALSE': {\n          const v = this.stack.pop();\n          let cond = Boolean(v);\n          if (!cond) frame.ip = ins.arg;\n          break;\n        }\n        case 'BINARY': {\n          const b = this.stack.pop();\n          const a = this.stack.pop();\n          let res;\n          switch (ins.arg) {\n            case '+': res = (a==null?0:a) + (b==null?0:b); break;\n            case '-': res = a - b; break;\n            case '*': res = a * b; break;\n            case '/': res = a / b; break;\n            case '%': res = a % b; break;\n            case '<': res = a < b; break;\n            case '>': res = a > b; break;\n            case '<=': res = a <= b; break;\n            case '>=': res = a >= b; break;\n            case '==': res = a == b; break;\n            case '!=': res = a != b; break;\n            case '&&': res = a && b; break;\n            case '||': res = a || b; break;\n            default: throw new Error('Unknown binary ' + ins.arg);\n          }\n          this.stack.push(res);\n          break;\n        }\n        case 'UNARY': {\n          const a = this.stack.pop();\n          if (ins.arg === '-') this.stack.push(-a);\n          else if (ins.arg === '!') this.stack.push(!a);\n          else throw new Error('Unknown unary ' + ins.arg);\n          break;\n        }\n        case 'CALL': {\n          // pop function (top is function?) We compiled with args first then function\n          const argCount = ins.arg;\n          const fn = this.stack.pop();\n          const args = [];\n          for (let k=0;k<argCount;k++) {\n            args.unshift(this.stack.pop());\n          }\n          // builtin function?\n          if (fn && fn.type === 'builtin') {\n            const ret = fn.fn(args, this);\n            this.stack.push(ret);\n            break;\n          }\n          if (!fn) {\n            this.stack.push(undefined);\n            break;\n          }\n          if (fn.type === 'function_literal') {\n            const meta = funcMap.get(fn.id);\n            if (!meta) throw new Error('Unknown function id ' + fn.id);\n            // create new env with parent = fn.env if closure captured, but we didn't implement capturing of envs at creation time\n            // For simplicity, capture global env as parent when function literal was created: we will store env pointer when the literal was created on stack.\n            // But here we didn't store, so instead use current frame.env as parent (lexical scoping approximation)\n            const parentEnv = frame.env; // lexical approximated\n            const newEnv = makeEnv(parentEnv);\n            // set params\n            for (let p=0;p<meta.params.length;p++) {\n              newEnv.vars[meta.params[p]] = (p < args.length ? args[p] : undefined);\n            }\n            // push return placeholder then new frame\n            this.pushFrame(meta.instrs, newEnv);\n            break;\n          }\n          // else if function is a compiled closure object stored in env\n          if (fn && typeof fn === 'object' && fn.__is_compiled_function) {\n            const meta = fn.meta;\n            const newEnv = makeEnv(fn.env); // capture env stored on function object\n            for (let p=0;p<meta.params.length;p++) {\n              newEnv.vars[meta.params[p]] = (p < args.length ? args[p] : undefined);\n            }\n            this.pushFrame(meta.instrs, newEnv);\n            break;\n          }\n          this.stack.push(undefined);\n          break;\n        }\n        case 'RETURN': {\n          const ret = this.stack.pop();\n          // pop frames until ret stack size?\n          const ended = this.popFrame();\n          // push return value onto previous frame stack\n          if (this.currentFrame()) this.stack.push(ret);\n          else {\n            // program return\n            this.stack.push(ret);\n            this.running = false;\n          }\n          break;\n        }\n        default:\n          throw new Error('Unknown op ' + ins.op);\n      }\n      return {status:'ok', instr: ins, frame: frame};\n    },\n    runUntilPause(stepMs, onTick) {\n      if (this.running) return;\n      this.running = true;\n      this.paused = false;\n      const runLoop = () => {\n        if (!this.running || this.paused) return;\n        // check breakpoint before executing instruction\n        const frame = this.currentFrame();\n        if (!frame) { this.running = false; updateUI(); return; }\n        const key = (frame.instrs._id || '?') + ':' + frame.ip;\n        if (this.breakpoints.has(key) && document.getElementById('autoRunBreakpoints').checked) {\n          // hit breakpoint\n          this.appendTrace('Hit breakpoint ' + key);\n          this.paused = true;\n          updateUI();\n          return;\n        }\n        try {\n          const res = this.stepInstruction();\n          updateUI();\n          if (res && res.status === 'frame_end') {\n            // keep running\n          }\n        } catch(e) {\n          this.appendTrace('Runtime error: ' + e.message);\n          this.running = false;\n          this.paused = true;\n          updateUI();\n          return;\n        }\n        if (typeof onTick === 'function') onTick();\n        // schedule next\n        const ms = Number(document.getElementById('speed').value) || 200;\n        setTimeout(runLoop, ms);\n      };\n      runLoop();\n    },\n    pause() {\n      this.paused = true; this.running = false;\n    },\n    appendTrace(s) { this.trace.push(String(s)); updateUI(); },\n    // utility to create function literal object capturing env\n    makeFunctionLiteral(fid, env) {\n      return {type:'function_literal', id: fid, __is_compiled_function:true, meta: funcMap.get(fid), env: env};\n    }\n  };\n\n  // create main frame env chain: global\n  vm.pushFrame(compiled.main, globalEnv);\n  // Note: when compiling, we pushed literal function objects as constants onto the main instruction array with {type:'function_literal', id: fid}\n  // We want those to become closure objects that capture the environment at creation time. We'll process compiled.main to replace any PUSH_CONST function_literal to closure with env.\n  function instantiateFunctionLiterals(instrs, env) {\n    for (let idx=0; idx<instrs.length; idx++) {\n      const ins = instrs[idx];\n      if (ins && ins.op === 'PUSH_CONST' && ins.arg && ins.arg.type === 'function_literal') {\n        // replace with closure that stores env pointer\n        instrs[idx] = {op:'PUSH_CONST', arg: vm.makeFunctionLiteral(ins.arg.id, env)};\n      }\n    }\n  }\n  instantiateFunctionLiterals(compiled.main, globalEnv);\n  for (const f of compiled.functions) {\n    // each function body may contain nested function literals; we will instantiate when executing MAKE_FUNCTION by creating closure at that time,\n    // but also we can pre-instantiate with global env for top-level.\n    instantiateFunctionLiterals(f.instrs, globalEnv);\n  }\n\n  return vm;\n}\n\n// UI wiring and state\nlet currentCompiled = null;\nlet currentVM = null;\nlet lastRunState = null;\nlet snapshots = [];\n\nconst el = {\n  program: document.getElementById('program'),\n  tokens: document.getElementById('tokens'),\n  ast: document.getElementById('ast'),\n  instructions: document.getElementById('instructions'),\n  stack: document.getElementById('stack'),\n  callstack: document.getElementById('callstack'),\n  globals: document.getElementById('globals'),\n  output: document.getElementById('output'),\n  trace: document.getElementById('trace'),\n  pc: document.getElementById('pc'),\n  frameIdx: document.getElementById('frameIdx'),\n  bpsList: document.getElementById('bpsList'),\n  snapshots: document.getElementById('snapshots'),\n  breakpointsInput: document.getElementById('breakpointsInput'),\n  initEnv: document.getElementById('initEnv')\n};\n\nfunction safeJSON(obj) {\n  try { return JSON.stringify(obj, replacer, 2); } catch (e) { return String(obj); }\n  function replacer(k,v){ if (typeof v === 'function') return '[Function]'; if (v && v.__is_compiled_function) return '[FunctionLiteral id='+v.id+']'; return v; }\n}\n\ndocument.getElementById('parseBtn').onclick = () => {\n  try {\n    const src = el.program.value;\n    const toks = tokenize(src);\n    el.tokens.textContent = safeJSON(toks);\n    const ast = parse(toks);\n    el.ast.textContent = safeJSON(ast);\n    currentCompiled = null;\n  } catch(e) {\n    el.tokens.textContent = 'Parse error: ' + e.message;\n  }\n};\n\ndocument.getElementById('compileBtn').onclick = () => {\n  try {\n    const src = el.program.value;\n    const toks = tokenize(src);\n    const ast = parse(toks);\n    const compiled = compileProgram(ast);\n    currentCompiled = compiled;\n    displayInstructions(compiled);\n    el.ast.textContent = safeJSON(ast);\n    el.tokens.textContent = safeJSON(toks);\n    currentVM = null;\n    el.output.textContent = '';\n    el.trace.textContent = '';\n  } catch(e) {\n    el.tokens.textContent = 'Compile error: ' + e.message;\n  }\n};\n\nfunction displayInstructions(compiled) {\n  const out = [];\n  function render(instrs) {\n    const id = instrs._id || '?';\n    out.push('== instrs id: ' + id + ' ==');\n    for (let i=0;i<instrs.length;i++) {\n      const ins = instrs[i];\n      out.push('['+id+':' + i + '] ' + JSON.stringify(ins));\n    }\n  }\n  render(compiled.main);\n  for (const f of compiled.functions) render(f.instrs);\n  el.instructions.textContent = out.join('\\n');\n}\n\ndocument.getElementById('runBtn').onclick = () => {\n  if (!currentCompiled) {\n    document.getElementById('compileBtn').click();\n    if (!currentCompiled) return;\n  }\n  if (!currentVM) {\n    try {\n      currentVM = createVM(currentCompiled, el.initEnv.value);\n    } catch(e) {\n      el.trace.textContent += 'VM init error: ' + e.message + '\\n';\n      return;\n    }\n  }\n  currentVM.runUntilPause();\n  updateUI();\n  // record as last run baseline after completion (when done)\n  const checkFinished = setInterval(()=> {\n    if (!currentVM || currentVM.running === false) {\n      if (currentVM) lastRunState = snapshotVM(currentVM);\n      clearInterval(checkFinished);\n    }\n  }, 200);\n};\n\ndocument.getElementById('pauseBtn').onclick = () => {\n  if (currentVM) { currentVM.pause(); updateUI(); }\n};\n\ndocument.getElementById('stepBtn').onclick = () => {\n  if (!currentCompiled) { document.getElementById('compileBtn').click(); }\n  if (!currentVM) currentVM = createVM(currentCompiled, el.initEnv.value);\n  // step single instruction\n  try {\n    const res = currentVM.stepInstruction();\n    updateUI();\n  } catch(e) {\n    currentVM.appendTrace('Runtime error: ' + e.message);\n  }\n};\n\ndocument.getElementById('stepOverBtn').onclick = () => {\n  if (!currentCompiled) { document.getElementById('compileBtn').click(); }\n  if (!currentVM) currentVM = createVM(currentCompiled, el.initEnv.value);\n  // step over: if current instruction is CALL, run until return to same frame\n  const frame = currentVM.currentFrame();\n  if (!frame) return;\n  const key = frame.instrs._id + ':' + frame.ip;\n  // determine