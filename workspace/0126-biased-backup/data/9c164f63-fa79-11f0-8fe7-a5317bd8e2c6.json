 = () => {\n  if (!currentVM) return;\n  const f = currentVM.currentFrame();\n  if (!f) return;\n  const key = (f.instrs._id || '?') + ':' + f.ip;\n  if (currentVM.breakpoints.has(key)) currentVM.breakpoints.delete(key);\n  else currentVM.breakpoints.add(key);\n  updateUI();\n};\n\ndocument.getElementById('breakpointsInput').onchange = () => {\n  const s = document.getElementById('breakpointsInput').value.trim();\n  if (!currentVM) currentVM = currentCompiled ? createVM(currentCompiled, el.initEnv.value) : null;\n  if (!currentVM) return;\n  currentVM.breakpoints.clear();\n  if (s) {\n    const parts = s.split(',');\n    for (const p of parts) {\n      const t = p.trim();\n      if (t) currentVM.breakpoints.add(t);\n    }\n  }\n  updateUI();\n};\n\ndocument.getElementById('clearBreakpoints').onclick = () => {\n  if (currentVM) currentVM.breakpoints.clear();\n  updateUI();\n};\n\ndocument.getElementById('snapshotBtn').onclick = () => {\n  if (!currentVM) return;\n  try {\n    const snap = snapshotVM(currentVM);\n    snapshots.push(snap);\n    renderSnapshots();\n  } catch(e) {\n    alert('Snapshot failed: ' + e.message);\n  }\n};\n\ndocument.getElementById('restoreBtn').onclick = () => {\n  if (snapshots.length === 0) return;\n  const snap = snapshots[snapshots.length - 1];\n  currentVM = restoreSnapshot(snap);\n  updateUI();\n};\n\ndocument.getElementById('forkBtn').onclick = () => {\n  if (!currentVM) return;\n  const snap = snapshotVM(currentVM);\n  // create forked VM by restoring snapshot\n  const fork = restoreSnapshot(snap);\n  // give fork a branch id and store\n  snapshots.push(snap);\n  renderSnapshots();\n  alert('Fork created and snapshot saved. Use Restore to switch to it.');\n};\n\ndocument.getElementById('compareBtn').onclick = () => {\n  if (!lastRunState || !currentVM) {\n    alert('Need a last run baseline and a VM to compare');\n    return;\n  }\n  const cur = snapshotVM(currentVM);\n  const diffs = diffSnapshots(lastRunState, cur);\n  el.trace.textContent += '\\n=== Compare diffs ===\\n' + diffs.join('\\n') + '\\n';\n  updateUI();\n};\n\ndocument.getElementById('mutateRenameBtn').onclick = () => {\n  const from = document.getElementById('renameFrom').value.trim();\n  const to = document.getElementById('renameTo').value.trim();\n  if (!from || !to) return;\n  // simple textual replace within program\n  const src = el.program.value;\n  const re = new RegExp('\\\\b' + from + '\\\\b', 'g');\n  el.program.value = src.replace(re, to);\n  document.getElementById('compileBtn').click();\n};\n\ndocument.getElementById('mutateInlineBtn').onclick = () => {\n  const from = document.getElementById('inlineFrom').value;\n  const to = document.getElementById('inlineTo').value;\n  if (!from) return;\n  const src = el.program.value;\n  // naive replace of exact literal appearance\n  el.program.value = src.split(from).join(to);\n  document.getElementById('compileBtn').click();\n};\n\n// sample loader\ndocument.getElementById('loadSample').onclick = () => {\n  const v = document.getElementById('sampleSelect').value;\n  let text = '';\n  if (v === 'fib') {\n    text = `fun fib(n) {\n  if (n <= 1) {\n    return n;\n  } else {\n    return fib(n-1) + fib(n-2);\n  }\n}\nprint(\"fib(6) = \" + fib(6));`;\n  } else if (v === 'count') {\n    text = `let i = 0;\nwhile (i < 5) {\n  print(\"i = \" + i);\n  i = i + 1;\n}\nprint(\"done\");`;\n  } else if (v === 'closure') {\n    text = `fun makeAdder(x) {\n  fun add(y) { return x + y; }\n  return add;\n}\nlet f = makeAdder(10);\nprint(f(7));`;\n  } else if (v === 'ifelse') {\n    text = `let a = 5;\nif (a % 2 == 0) {\n  print(\"even\");\n} else {\n  print(\"odd\");\n}\n`;\n  } else if (v === 'factorial') {\n    text = `fun fact(n) {\n  let r = 1;\n  while (n > 1) {\n    r = r * n;\n    n = n - 1;\n  }\n  return r;\n}\nprint(fact(6));`;\n  } else if (v === 'mutate') {\n    text = `let x = 1;\nfun inc() { x = x + 1; return x; }\nprint(inc());\nprint(inc());`;\n  }\n  el.program.value = text;\n  document.getElementById('compileBtn').click();\n};\n\n// snapshots UI\nfunction renderSnapshots() {\n  const out = [];\n  for (let i=0;i<snapshots.length;i++) {\n    const s = snapshots[i];\n    out.push('Snapshot ' + i + ': time=' + new Date(s.time).toISOString());\n    out.push('  frames=' + s.frames.length + ' stack=' + s.stack.length);\n    out.push('  globals: ' + safeJSON(s.globals));\n  }\n  el.snapshots.textContent = out.join('\\n');\n}\n\n// snapshot VM state (best-effort)\nfunction snapshotVM(vm) {\n  // copy frames info, stack, globals, output, trace\n  // NOTE: functions and env closures may contain references; we will preserve references by shallow copying objects.\n  const frames = vm.frames.map(f => {\n    return {instrsId: f.instrs._id, ip: f.ip, env: shallowCopyEnvChain(f.env), retStackSize: f.retStackSize};\n  });\n  return {\n    time: Date.now(),\n    frames: frames,\n    stack: shallowCopyArray(vm.stack),\n    output: shallowCopyArray(vm.outputLines),\n    trace: shallowCopyArray(vm.trace),\n    globals: shallowCopyEnvChain(vm.frames[0] ? vm.frames[0].env : null),\n    breakpoints: Array.from(vm.breakpoints)\n  };\n\n  function shallowCopyEnvChain(env) {\n    if (!env) return null;\n    const chain = [];\n    let cur = env;\n    while(cur) {\n      chain.push(Object.assign({}, cur.vars));\n      cur = cur.parent;\n    }\n    return chain;\n  }\n  function shallowCopyArray(arr) {\n    return arr.map(v => (v && typeof v === 'object') ? v : v);\n  }\n}\n\n// restore snapshot to create a fresh VM approximating state (limitations apply)\nfunction restoreSnapshot(snapshot) {\n  if (!currentCompiled) throw new Error('No compiled program to restore into');\n  const vm = createVM(currentCompiled, el.initEnv.value);\n  // try to map snapshot frames to compiled instruction arrays by instrsId\n  vm.frames = [];\n  for (const f of snapshot.frames) {\n    const instrs = findInstrById(currentCompiled, f.instrsId) || currentCompiled.main;\n    const env = rebuildEnvChain(f.env);\n    vm.frames.push({instrs: instrs, ip: f.ip, env: env, retStackSize: f.retStackSize});\n  }\n  vm.stack = Array.isArray(snapshot.stack) ? snapshot.stack.slice() : [];\n  vm.outputLines = snapshot.output ? snapshot.output.slice() : [];\n  vm.trace = snapshot.trace ? snapshot.trace.slice() : [];\n  vm.breakpoints = new Set(snapshot.breakpoints || []);\n  return vm;\n\n  function rebuildEnvChain(chain) {\n    if (!chain) return null;\n    let parent = null;\n    for (let i = chain.length - 1; i >= 0; i--) {\n      const e = {vars: Object.assign({}, chain[i]), parent: parent};\n      parent = e;\n    }\n    return parent;\n  }\n  function findInstrById(compiled, id) {\n    if (compiled.main._id == id) return compiled.main;\n    for (const f of compiled.functions) if (f.instrs._id == id) return f.instrs;\n    return null;\n  }\n}\n\nfunction diffSnapshots(a,b) {\n  const diffs = [];\n  diffs.push('Output diff:');\n  diffs.push('  A output: ' + (a.output || []).join(' | '));\n  diffs.push('  B output: ' + (b.output || []).join(' | '));\n  // compare global vars as best-effort\n  diffs.push('Globals diff:');\n  const ga = a.globals && a.globals[0] ? a.globals[0] : {};\n  const gb = b.globals && b.globals[0] ? b.globals[0] : {};\n  const keys = new Set([...Object.keys(ga||{}), ...Object.keys(gb||{})]);\n  for (const k of keys) {\n    if (String(ga[k]) !== String(gb[k])) diffs.push('  ' + k + ': A=' + ga[k] + ' B=' + gb[k]);\n  }\n  return diffs;\n}\n\n// update UI status\nfunction updateUI() {\n  // instructions highlight\n  if (currentCompiled) {\n    displayInstructions(currentCompiled);\n  }\n  if (!currentVM) {\n    el.stack.textContent = '';\n    el.callstack.textContent = '';\n    el.globals.textContent = '';\n    el.output.textContent = '';\n    el.trace.textContent = '';\n    el.pc.textContent = '-';\n    el.frameIdx.textContent = '-';\n    el.bpsList.textContent = '';\n    return;\n  }\n  // show stack\n  el.stack.textContent = safeJSON(currentVM.stack);\n  // callstack\n  el.callstack.textContent = currentVM.frames.map((f, idx) => {\n    return 'Frame ' + idx + ' instrsId=' + (f.instrs._id || '?') + ' ip=' + f.ip + ' retStack=' + f.retStackSize;\n  }).join('\\n');\n  // globals: show vars of first frame env (global)\n  const g = currentVM.frames[0] ? currentVM.frames[0].env : null;\n  el.globals.textContent = safeJSON(g ? g.vars : {});\n  el.output.textContent = (currentVM.outputLines || []).join('\\n');\n  el.trace.textContent = (currentVM.trace || []).join('\\n');\n  const cf = currentVM.currentFrame();\n  if (cf) {\n    el.pc.textContent = (cf.instrs._id || '?') + ':' + cf.ip;\n    el.frameIdx.textContent = currentVM.frames.length - 1;\n  } else {\n    el.pc.textContent = '-';\n    el.frameIdx.textContent = '-';\n  }\n  el.bpsList.textContent = Array.from(currentVM.breakpoints).join(', ');\n  renderSnapshots();\n}\n\n// instruction click to toggle breakpoint\nel.instructions.onclick = function(e) {\n  const txt = el.instructions.textContent;\n  const sel = window.getSelection().toString();\n  // attempt to find bracket like [id:pc]\n  const re = /\\[(\\S+:\\d+)\\]/g;\n  // find nearest occurance of [something] under click by reading caret position - fallback: prompt\n  let match, found = null;\n  while ((match = re.exec(txt)) !== null) {\n    found = match[1];\n    break;\n  }\n  if (!currentVM) {\n    if (currentCompiled) currentVM = createVM(currentCompiled, el.initEnv.value);\n  }\n  if (!found && currentVM) {\n    // fallback: toggle input-specified\n    const s = prompt('Enter breakpoint label (instrId:pc) to toggle');\n    if (!s) return;\n    if (currentVM.breakpoints.has(s)) currentVM.breakpoints.delete(s); else currentVM.breakpoints.add(s);\n  } else if (found && currentVM) {\n    if (currentVM.breakpoints.has(found)) currentVM.breakpoints.delete(found); else currentVM.breakpoints.add(found);\n  }\n  updateUI();\n};\n\n// initial compile\ndocument.getElementById('compileBtn').click();\n\n</s