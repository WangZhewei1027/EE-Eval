    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Jump Search — Visual Demonstration</title>\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#081029;\n    --accent1:#7c5cff;\n    --accent2:#34d399;\n    --muted:#9aa7c0;\n    --glass: rgba(255,255,255,0.04);\n    --tile:#0b1220;\n    --found:#ffd166;\n    --notfound:#ff7b72;\n  }\n\n  /* Page layout */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.08), transparent 6%),\n                radial-gradient(900px 500px at 90% 90%, rgba(52,211,153,0.06), transparent 6%),\n                linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:36px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    min-height:100vh;\n    gap:28px;\n  }\n\n  /* Card */\n  .card{\n    width:1100px;\n    max-width:calc(100vw - 64px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    box-shadow: 0 20px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    gap:24px;\n    align-items:flex-start;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Subtle decorative light */\n  .card::after{\n    content:\"\";\n    position:absolute;\n    right:-120px;\n    top:-80px;\n    width:380px;\n    height:380px;\n    background: radial-gradient(circle at 30% 30%, rgba(124,92,255,0.18), transparent 20%),\n                radial-gradient(circle at 70% 70%, rgba(52,211,153,0.12), transparent 20%);\n    filter: blur(40px);\n    transform: rotate(25deg);\n    pointer-events:none;\n    mix-blend-mode:screen;\n  }\n\n  /* Left: visual panel */\n  .visual{\n    flex:1.35;\n    min-width:420px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n  }\n\n  .header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n  }\n\n  .title{\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .title h1{\n    margin:0;\n    font-size:20px;\n    letter-spacing:0.2px;\n    color:linear-gradient(#fff,#ddd);\n  }\n  .title p{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    font-size:13px;\n    cursor:pointer;\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    transition: all 220ms cubic-bezier(.2,.9,.2,1);\n    box-shadow: 0 6px 20px rgba(2,6,23,0.6);\n  }\n  .btn:hover{ transform: translateY(-3px); color:#fff; border-color:rgba(255,255,255,0.06) }\n  .btn.secondary{\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    color:var(--muted);\n  }\n\n  /* Array container */\n  .array-wrap{\n    background: linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    padding:22px;\n    border-radius:16px;\n    border:1px solid rgba(255,255,255,0.02);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n  }\n  .array{\n    display:flex;\n    gap:14px;\n    align-items:flex-end;\n    justify-content:center;\n    padding:18px 6px;\n    min-height:140px;\n  }\n\n  /* tiles */\n  .tile{\n    width:56px;\n    height:72px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    gap:6px;\n    color:var(--muted);\n    font-weight:700;\n    transition: transform 300ms cubic-bezier(.2,.9,.2,1), box-shadow 300ms, background 300ms, color 300ms;\n    position:relative;\n    box-shadow: 0 8px 18px rgba(2,6,23,0.45);\n    overflow:visible;\n  }\n  .tile .val{\n    font-size:16px;\n  }\n  .tile .idx{\n    font-size:11px;\n    color:rgba(255,255,255,0.12);\n    position:absolute;\n    bottom:8px;\n  }\n\n  /* highlighted states */\n  .tile.jump{\n    transform: translateY(-10px) scale(1.03);\n    background: linear-gradient(180deg, rgba(124,92,255,0.14), rgba(124,92,255,0.06));\n    color:#fff;\n    box-shadow: 0 18px 40px rgba(124,92,255,0.12), 0 6px 12px rgba(2,6,23,0.45);\n    border-color: rgba(124,92,255,0.3);\n  }\n  .tile.search{\n    transform: translateY(-6px) scale(1.02);\n    background: linear-gradient(180deg, rgba(52,211,153,0.12), rgba(52,211,153,0.04));\n    color:#e9fff7;\n    border-color: rgba(52,211,153,0.2);\n    box-shadow: 0 14px 32px rgba(52,211,153,0.06);\n  }\n  .tile.match{\n    background: linear-gradient(180deg, rgba(255,209,102,0.14), rgba(255,209,102,0.04));\n    color:#111827;\n    transform: translateY(-14px) scale(1.08);\n    box-shadow: 0 26px 60px rgba(255,209,102,0.12);\n    border-color: rgba(255,209,102,0.3);\n  }\n  .tile.nomatch{\n    background: linear-gradient(180deg, rgba(255,123,114,0.12), rgba(255,123,114,0.04));\n    color:#fff;\n    transform: translateY(-6px) scale(1.01);\n    border-color: rgba(255,123,114,0.2);\n    box-shadow: 0 12px 30px rgba(255,123,114,0.06);\n  }\n\n  /* pointer (indicator) */\n  .pointer{\n    position:absolute;\n    top:12px;\n    left:50%;\n    transform:translateX(-50%);\n    height:64px;\n    width:64px;\n    border-radius:12px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n    transition: transform 420ms cubic-bezier(.2,.9,.2,1);\n    z-index:10;\n  }\n  .pointer .orb{\n    width:16px;\n    height:16px;\n    background:linear-gradient(180deg,var(--accent1), #6b3bff);\n    border-radius:999px;\n    box-shadow: 0 8px 24px rgba(124,92,255,0.22), 0 2px 6px rgba(0,0,0,0.4);\n    transform:translateY(-3px);\n    transition: all 220ms;\n  }\n  .pointer .label{\n    position:absolute;\n    top:64px;\n    left:50%;\n    transform:translateX(-50%);\n    font-size:12px;\n    color:var(--muted);\n    background: rgba(255,255,255,0.02);\n    padding:6px 10px;\n    border-radius:8px;\n    border:1px solid rgba(255,255,255,0.02);\n    white-space:nowrap;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n  }\n\n  /* Right: explanation panel */\n  .panel{\n    flex:0.9;\n    min-width:280px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n  }\n  .panel .box{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border-radius:12px;\n    padding:16px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .panel h3{ margin:0; font-size:14px;}\n  .panel p{ margin:8px 0 0; color:var(--muted); font-size:13px; line-height:1.45; }\n\n  .metric{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n    margin-top:8px;\n  }\n  .metric .val{\n    font-size:18px;\n    font-weight:800;\n    color:#fff;\n  }\n  .small{\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  /* Legend */\n  .legend{\n    display:flex;\n    gap:10px;\n    align-items:center;\n    margin-top:12px;\n    flex-wrap:wrap;\n  }\n  .swatch{\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    background: rgba(255,255,255,0.015);\n    padding:8px 10px;\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.02);\n    color:var(--muted);\n    font-size:13px;\n  }\n  .dot{\n    width:12px;\n    height:12px;\n    border-radius:4px;\n    box-shadow: 0 6px 18px rgba(0,0,0,0.6);\n  }\n\n  /* Footer small text */\n  .credits{\n    margin-top:8px;\n    color:rgba(255,255,255,0.09);\n    font-size:12px;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width:900px){\n    .card{flex-direction:column; width:92%}\n    .visual{min-width:unset}\n    .panel{min-width:unset}\n    .array{gap:10px}\n    .tile{width:48px;height:68px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"card\" role=\"region\" aria-label=\"Jump Search Visualization\">\n    <div class=\"visual\">\n      <div class=\"header\">\n        <div class=\"title\">\n          <h1>Jump Search — Animated Visualization</h1>\n          <p>Observe how Jump Search leaps ahead in blocks and then performs a linear scan.</p>\n        </div>\n\n        <div class=\"controls\" aria-hidden=\"false\">\n          <button id=\"playBtn\" class=\"btn\" title=\"Play / Pause (toggle)\">\n            ▶︎ Play\n          </button>\n          <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset and choose new target\">\n            ⟳ Reset\n          </button>\n        </div>\n      </div>\n\n      <div class=\"array-wrap\">\n        <div id=\"pointer\" class=\"pointer\" aria-hidden=\"true\" style=\"left:50%\">\n          <div class=\"orb\"></div>\n          <div class=\"label\" id=\"pointerLabel\">jump</div>\n        </div>\n        <div id=\"array\" class=\"array\" aria-hidden=\"false\"></div>\n\n        <div style=\"display:flex; justify-content:space-between; align-items:center; margin-top:12px;\">\n          <div class=\"small\">Step size: <strong id=\"stepSize\" style=\"color:#fff; margin-left:6px;\">—</strong></div>\n          <div class=\"small\">Target: <strong id=\"targetValue\" style=\"color:#fff; margin-left:6px;\">—</strong></div>\n        </div>\n      </div>\n\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div class=\"small\">Status: <span id=\"status\" style=\"color:var(--muted); margin-left:8px;\">Preparing…</span></div>\n        <div class=\"small\">Array length: <strong id=\"lengthVal\">—</strong></div>\n      </div>\n    </div>\n\n    <aside class=\"panel\" aria-hidden=\"false\">\n      <div class=\"box\">\n        <h3>How Jump Search works</h3>\n        <p>Jump Search moves ahead by fixed-size jumps (√n) until it finds a block where the target could be. It then performs a linear scan inside that block. This reduces the number of comparisons compared to a full linear scan on large arrays.</p>\n\n        <div class=\"metric\">\n          <div>\n            <div class=\"small\">Jump size</div>\n            <div class=\"val\" id=\"jumpMetric\">—</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div class=\"small\">Comparisons</div>\n            <div class=\"val\" id=\"compMetric\">0</div>\n          </div>\n        </div>\n\n        <div class=\"legend\">\n          <div class=\"swatch\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#7c5cff,#6b3bff)\"></span><span>Jump check</span></div>\n          <div class=\"swatch\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#34d399,#10b981)\"></span><span>Linear scan</span></div>\n          <div class=\"swatch\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#ffd166,#ffdd99)\"></span><span>Found</span></div>\n          <div class=\"swatch\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#ff7b72,#ff4b4b)\"></span><span>Not found</span></div>\n        </div>\n\n        <div class=\"credits\">Minimal controls — autoplay demonstrates the algorithm. Use Reset to run a new example.</div>\n      </div>\n\n      <div class=\"box\">\n        <h3>Live narrative</h3>\n        <p id=\"narration\" style=\"color:var(--muted); margin-top:8px;\">The visualization will start automatically. Watch the pointer jump and the tiles highlight as comparisons are made.</p>\n      </div>\n    </aside>\n  </div>\n\n<script>\n/* Jump Search Visualization\n   - Minimal controls: Play/Pause and Reset\n   - Autoplays on load, demonstrates step by step\n*/\n\n(() => {\n  const arrayEl = document.getElementById('array');\n  const pointerEl = document.getElementById('pointer');\n  const pointerLabel = document.getElementById('pointerLabel');\n  const stepSizeEl = document.getElementById('stepSize');\n  const jumpMetric = document.getElementById('jumpMetric');\n  const compMetric = document.getElementById('compMetric');\n  const targetEl = document.getElementById('targetValue');\n  const lengthVal = document.getElementById('lengthVal');\n  const narration = document.getElementById('narration');\n  const statusEl = document.getElementById('status');\n\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  let tiles = [];\n  let arr = [];\n  let n = 25;\n  let step = 0;\n  let comparisons = 0;\n  let isPaused = false;\n  let abort = false;\n  let foundIndex = -1;\n  let targetValue = null;\n\n  // Utility sleep with pause/resume support\n  function sleep(ms){\n    return new Promise(resolve => {\n      let start = performance.now();\n      function frame(t){\n        if (abort) { resolve(); return; }\n        if (isPaused){\n          requestAnimationFrame(frame);\n          return;\n        }\n        if (t - start >= ms) resolve();\n        else requestAnimationFrame(frame);\n      }\n      requestAnimationFrame(frame);\n    });\n  }\n\n  // Create sorted array with aesthetic spacing\n  function createArray(length){\n    const base = [];\n    let cur = Math.floor(Math.random()*3) + 5;\n    for(let i=0;i<length;i++){\n      cur += Math.floor(Math.random()*6)+2;\n      base.push(cur);\n    }\n    return base;\n  }\n\n  function renderArray(){\n    arrayEl.innerHTML = '';\n    tiles = [];\n    for(let i=0;i<n;i++){\n      const t = document.createElement('div');\n      t.className = 'tile';\n      t.innerHTML = `<div class=\"val\">${arr[i]}</div><div class=\"idx\">${i}</div>`;\n      arrayEl.appendChild(t);\n      tiles.push(t);\n    }\n  }\n\n  function updateMetrics(){\n    stepSizeEl.textContent = step;\n    jumpMetric.textContent = `⌊√${n}⌋ = ${step}`;\n    compMetric.textContent = comparisons;\n    lengthVal.textContent = n;\n    targetEl.textContent = targetValue;\n  }\n\n  function resetVisuals(){\n    tiles.forEach(t=>{\n      t.classList.remove('jump','search','match','nomatch');\n    });\n    pointerEl.style.opacity = 1;\n  }\n\n  function movePointerToIndex(index, label='jump'){\n    // index is 0..n-1, position pointer above tile\n    const tile = tiles[index];\n    const parentRect = arrayEl.getBoundingClientRect();\n    const tileRect = tile.getBoundingClientRect();\n    const cardRect = document.querySelector('.card').getBoundingClientRect();\n    // compute left relative to card container\n    const left = tileRect.left - cardRect.left + tileRect.width/2;\n    pointerEl.style.transform = `translateX(${left - (pointerEl.parentElement.getBoundingClientRect().width/2)}px)`;\n    pointerLabel.textContent = label;\n    pointerEl.style.transition = 'transform 480ms cubic-bezier(.2,.9,.2,1)';\n  }\n\n  async function highlightJump(index){\n    resetVisuals();\n    tiles[index].classList.add('jump');\n    movePointerToIndex(index, 'jump');\n    narration.textContent = `Jump to index ${index} (value ${arr[index]}). Comparing to target ${targetValue}…`;\n    statusEl.textContent = 'Jumping';\n    await sleep(850);\n  }\n\n  async function highlightSearch(index){\n    // called during linear scan\n    tiles[index].classList.add('search');\n    movePointerToIndex(index, 'scan');\n    narration.textContent = `Linear scan at index ${index} (value ${arr[index]})…`;\n    statusEl.textContent = 'Scanning';\n    await sleep(700);\n    // flash result\n    if (arr[index] === targetValue){\n      tiles[index].classList.remove('search');\n      tiles[index].classList.add('match');\n      narration.textContent = `Value found at index ${index}!`;\n      statusEl.textContent = 'Found';\n    } else {\n      tiles[index].classList.remove('search');\n      tiles[index].classList.add('nomatch');\n      narration.textContent = `Not a match at index ${index}.`;\n      statusEl.textContent = 'Scanning';\n    }\n    await sleep(420);\n  }\n\n  async function visualizeJumpSearch(){\n    abort = false;\n    comparisons = 0;\n    updateMetrics();\n    resetVisuals();\n    await sleep(350);\n\n    const jump = step;\n    let prev = 0;\n    let idx = jump - 1;\n\n    // Jump phase\n    while (idx < n && !abort){\n      comparisons++;\n      updateMetrics();\n      await highlightJump(idx);\n\n      // comparison\n      if (arr[idx] >= targetValue){\n        narration.textContent = `arr[${idx}] = ${arr[idx]} ≥ target ${targetValue}. Found candidate block [${Math.max(0, idx-jump+1)} … ${idx}]`;\n        await sleep(600);\n        break;\n      } else {\n        narration.textContent = `arr[${idx}] = ${arr[idx]} < target ${targetValue}. Jump ahead.`;\n        prev = idx + 1;\n        idx += jump;\n        comparisons++;\n        updateMetrics();\n        await sleep(420);\n        // if idx past end\n        if (idx >= n){\n          narration.textContent = `Reached end of array. Candidate block is [${prev} … ${n-1}]`;\n          idx = n - 1;\n          await sleep(600);\n          break;\n        }\n      }\n    }\n\n    // Linear phase: scan from prev to idx\n    let found = -1;\n    for(let i = prev; i <= idx && !abort; i++){\n      comparisons++;\n      updateMetrics();\n      await highlightSearch(i);\n      if (arr[i] === targetValue){\n        found = i;\n        break;\n      }\n    }\n\n    if (abort) {\n      statusEl.textContent = 'Aborted';\n      narration.textContent = 'Visualization interrupted.';\n      return;\n    }\n\n    if (found >= 0){\n      movePointerToIndex(found, 'found');\n      pointerEl.querySelector('.orb').style.background = 'linear-gradient(180deg,#ffd166,#ffdd99)';\n      narration.textContent = `Success! Target ${targetValue} found at index ${found}. Comparisons: ${comparisons}.`;\n      statusEl.textContent = 'Success';\n      updateMetrics();\n    } else {\n      // show not found state elegantly\n      pointerEl.querySelector('.orb').style.background = 'linear-gradient(180deg,#ff7b72,#ff4b4b)';\n      narration.textContent = `Target ${targetValue} not found. Comparisons: ${comparisons}.`;\n      statusEl.textContent = 'Not found';\n      // subtly mark last block as inspected\n      for(let i = prev; i <= idx; i++){\n        tiles[i].classList.add('nomatch');\n      }\n      updateMetrics();\n    }\n  }\n\n  function chooseTarget(){\n    // with 70% chance pick an actual element, else random missing value\n    const pickExisting = Math.random() < 0.7;\n    if (pickExisting){\n      const idx = Math.floor(Math.random()*n);\n      targetValue = arr[idx];\n    } else {\n      // pick value between arr elements that is not present\n      const pos = Math.floor(Math.random()*(n-1));\n      targetValue = Math.floor((arr[pos] + arr[pos+1]) / 2);\n      // ensure not equal (rare)\n      if (arr.includes(targetValue)){\n        targetValue += 1;\n      }\n    }\n  }\n\n  async function startVisualization(){\n    isPaused = false;\n    playBtn.textContent = '⏸︎ Pause';\n    playBtn.setAttribute('aria-pressed', 'true');\n    resetBtn.disabled = false;\n    pointerEl.querySelector('.orb').style.background = 'linear-gradient(180deg,var(--accent1), #6b3bff)';\n    await visualizeJumpSearch();\n    // auto pause at end\n    isPaused = true;\n    playBtn.textContent = '▶︎ Play';\n    playBtn.setAttribute('aria-pressed', 'false');\n  }\n\n  function initialize(){\n    n = 25 + Math.floor(Math.random()*6) - 3; // around 25\n    if (n < 18) n = 18;\n    arr = createArray(n);\n    step = Math.max(2, Math.floor(Math.sqrt(n)));\n    comparisons = 0;\n    chooseTarget();\n    renderArray();\n    resetVisuals();\n    updateMetrics();\n    narration.textContent = 'Ready. Press Play or wait — autoplay will run.';\n    statusEl.textContent = 'Ready';\n    // center pointer initially above middle tile\n    const mid = Math.floor(n/2);\n    setTimeout(()=> {\n      movePointerToIndex(mid, 'start');\n      pointerEl.style.opacity = 1;\n    }, 60);\n    // autoplay\n    isPaused = false;\n    abort = false;\n    startVisualization();\n  }\n\n  // Controls\n  playBtn.addEventListener('click', ()=>{\n    if (isPaused){\n      // resume or start if done\n      isPaused = false;\n      playBtn.textContent = '⏸︎ Pause';\n      playBtn.setAttribute('aria-pressed', 'true');\n      // If the visualization was finished, restart small sequence\n      if (statusEl.textContent === 'Ready' || statusEl.textContent === 'Success' || statusEl.textContent === 'Not found' || statusEl.textContent==='Aborted'){\n        abort = false;\n        // ensure reset visuals and rerun with same target\n        resetVisuals();\n        startVisualization();\n      }\n    } else {\n      isPaused = true;\n      playBtn.textContent = '▶︎ Play';\n      playBtn.setAttribute('aria-pressed', 'false');\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    abort = true; // stop any active visualization quickly\n    setTimeout(()=> {\n      // fresh start\n      initialize();\n    }, 120);\n  });\n\n  // start on load\n  initialize();\n\n  // Recompute pointer position on resize for fluidity\n  window.addEventListener('resize', ()=> {\n    // reposition pointer near center or found tile\n    const focused = document.querySelector('.tile.match') || document.querySelector('.tile.jump') || document.querySelector('.tile.search') || null;\n    const idx = focused ? parseInt(focused.querySelector('.idx').textContent) : Math.floor(n/2);\n    try{ movePointerToIndex(idx, pointerLabel.textContent || 'jump'); } catch(e){}\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
