    "content": "<html>\n<head>\n    <title>Recursion</title>\n    <style>\n        body {\n            background-color: white;\n            font-family: monospace;\n        }\n        #recursion-container {\n            width: 800px;\n            height: 600px;\n            border: 1px solid black;\n            margin: 50px auto;\n        }\n        #recursion-container button {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #recursion-container input[type=\"number\"] {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            width: 100%;\n            cursor: pointer;\n        }\n        #recursion-container select {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            width: 100%;\n            cursor: pointer;\n        }\n        #recursion-container textarea {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            width: 100%;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"recursion-container\">\n        <button>Start</button>\n        <button>Stop</button>\n        <button>Reset</button>\n        <input type=\"number\" id=\"num-input\" value=\"0\" step=\"any\">\n        <select id=\"step-select\">\n            <option value=\"1\">Step 1</option>\n            <option value=\"2\">Step 2</option>\n            <option value=\"3\">Step 3</option>\n        </select>\n        <input type=\"text\" id=\"result-text\" readonly>\n        <textarea id=\"result-textarea\" readonly></textarea>\n    </div>\n\n    <script>\n        let num = 0;\n        let step = 1;\n        let result = '';\n\n        document.getElementById('num-input').addEventListener('input', function() {\n            num = parseInt(this.value);\n            if (isNaN(num)) {\n                alert('Please enter a number.');\n            } else {\n                result = 'Step ' + step + ': ' + num;\n                document.getElementById('result-text').innerHTML = result;\n            }\n        });\n\n        document.getElementById('step-select').addEventListener('change', function() {\n            step = parseInt(this.value);\n            result = 'Step ' + step + ': ' + num;\n            document.getElementById('result-text').innerHTML = result;\n        });\n\n        document.getElementById('start').addEventListener('click', function() {\n            num = 0;\n            step = 1;\n            result = '';\n            document.getElementById('num-input').value = '0';\n            document.getElementById('step-select').value = '1';\n            document.getElementById('result-text').innerHTML = '';\n        });\n\n        document.getElementById('stop').addEventListener('click', function() {\n            num = 0;\n            step = 1;\n            result = '';\n            document.getElementById('num-input').value = '0';\n            document.getElementById('step-select').value = '1';\n            document.getElementById('result-text').innerHTML = '';\n        });\n\n        document.getElementById('reset').addEventListener('click', function() {\n            num = 0;\n            step = 1;\n            result = '';\n            document.getElementById('num-input').value = '0';\n            document.getElementById('step-select').value = '1';\n            document.getElementById('result-text').innerHTML = '';\n        });\n    </script>\n</body>\n</html>"
