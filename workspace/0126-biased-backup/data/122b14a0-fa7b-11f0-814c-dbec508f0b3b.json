    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"text\"], input[type=\"number\"], select {\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        input[type=\"text\"], input[type=\"number\"], select {\n            width: 50%;\n        }\n        button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n        .tree {\n            margin-top: 20px;\n        }\n        .tree ul {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n        .tree li {\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n        .tree li:last-child {\n            border-bottom: none;\n        }\n        .tree li input[type=\"text\"], .tree li select {\n            display: block;\n            margin-bottom: 10px;\n        }\n        .tree li button {\n            float: right;\n            margin-left: 10px;\n        }\n        .tree li button:hover {\n            background-color: #ccc;\n        }\n        .tree li button:active {\n            background-color: #aaa;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"tree\">\n        <ul>\n            <li>\n                <input type=\"text\" placeholder=\"Enter a value\" />\n                <button>Insert</button>\n                <button>Remove</button>\n                <button>Update</button>\n                <button>Print</button>\n            </li>\n            <li>\n                <input type=\"text\" placeholder=\"Enter a value\" />\n                <button>Insert</button>\n                <button>Remove</button>\n                <button>Update</button>\n                <button>Print</button>\n            </li>\n            <li>\n                <input type=\"text\" placeholder=\"Enter a value\" />\n                <button>Insert</button>\n                <button>Remove</button>\n                <button>Update</button>\n                <button>Print</button>\n            </li>\n            <li>\n                <input type=\"text\" placeholder=\"Enter a value\" />\n                <button>Insert</button>\n                <button>Remove</button>\n                <button>Update</button>\n                <button>Print</button>\n            </li>\n        </ul>\n        <button>Clear Tree</button>\n    </div>\n\n    <script>\n        let tree = document.querySelector('.tree');\n        let treeElement = tree.querySelector('ul');\n        let values = [];\n\n        function insert(value) {\n            values.push(value);\n            updateTree();\n        }\n\n        function remove(value) {\n            values = values.filter(v => v !== value);\n            updateTree();\n        }\n\n        function updateTree() {\n            treeElement.innerHTML = '';\n            values.forEach((value, index) => {\n                let li = document.createElement('li');\n                li.textContent = `${index + 1}. ${value}`;\n                treeElement.appendChild(li);\n                let input = document.createElement('input');\n                input.type = 'text';\n                input.value = value;\n                li.appendChild(input);\n                let buttons = document.createElement('button');\n                buttons.textContent = 'Remove';\n                buttons.addEventListener('click', remove);\n                li.appendChild(buttons);\n                let button = document.createElement('button');\n                button.textContent = 'Update';\n                button.addEventListener('click', update);\n                li.appendChild(button);\n                let button2 = document.createElement('button');\n                button2.textContent = 'Print';\n                button2.addEventListener('click', print);\n                li.appendChild(button2);\n            });\n        }\n\n        function print() {\n            console.log(values.join(', '));\n        }\n\n        function update(value) {\n            values = values.map(v => v + ' -> ' + value);\n            updateTree();\n        }\n\n        function clear() {\n            values = [];\n            updateTree();\n        }\n\n        document.querySelectorAll('input[type=\"text\"]').forEach(input => {\n            input.addEventListener('input', insert);\n        });\n\n        document.querySelectorAll('button').forEach(button => {\n            button.addEventListener('click', remove);\n        });\n\n        document.querySelectorAll('button').forEach(button => {\n            button.addEventListener('click', update);\n        });\n\n        document.querySelectorAll('button').forEach(button => {\n            button.addEventListener('click', print);\n        });\n\n        document.querySelectorAll('button').forEach(button => {\n            button.addEventListener('click', clear);\n        });\n    </script>\n</body>\n</html>"
