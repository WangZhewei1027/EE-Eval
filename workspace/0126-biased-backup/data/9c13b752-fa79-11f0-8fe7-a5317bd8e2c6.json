    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Graph (Undirected) - Interactive Demo</title>\n<style>\n/* Minimal styling: keep plain black on white, basic layout only */\nbody { font-family: sans-serif; margin: 8px; color: black; background: white; }\nbutton,input,select,textarea { font: inherit; }\n#main { display: flex; gap: 8px; align-items: flex-start; }\n#controls { max-width: 360px; min-width: 260px; }\ncanvas { border: 1px solid black; cursor: crosshair; }\nfieldset { margin-bottom: 8px; }\nlabel { display: inline-block; width: 140px; }\nsmall { display: block; margin-top: 6px; }\n</style>\n</head>\n<body>\n\n<h2>Graph (Undirected) — Interactive Demo</h2>\n<p>Plain interface focused on interactivity. Click canvas to create nodes. Drag nodes to move. Shift+drag from a node to another node to create an edge. Use the many controls below to explore the graph and algorithms.</p>\n\n<div id=\"main\">\n  <div id=\"controls\">\n    <fieldset>\n      <legend>Basic Tools</legend>\n      <button id=\"btnNew\">New Graph (Clear)</button>\n      <button id=\"btnUndo\">Undo (Ctrl+Z)</button>\n      <button id=\"btnRedo\">Redo (Ctrl+Y)</button>\n      <button id=\"btnSelectNone\">Deselect</button>\n      <button id=\"btnDelete\">Delete Selected (Del)</button>\n      <div style=\"margin-top:6px\">\n        <label>Default weight:</label>\n        <input id=\"defaultWeight\" type=\"number\" value=\"1\" step=\"1\" style=\"width:80px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Create mode:</label>\n        <select id=\"createMode\">\n          <option value=\"click\">Click to add node</option>\n          <option value=\"drag-edge\">Shift+Drag to add edge</option>\n        </select>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Auto-snap to grid:</label>\n        <input id=\"snapGrid\" type=\"checkbox\">\n      </div>\n      <small>Shortcuts: N=create node mode, E=edge mode, Del=delete, Shift+drag=edge from node, Ctrl+Z undo</small>\n    </fieldset>\n\n    <fieldset>\n      <legend>Generation</legend>\n      <div>\n        <label>Type:</label>\n        <select id=\"genType\">\n          <option value=\"erdos\">Erdos-Rényi (p)</option>\n          <option value=\"geometric\">Geometric (r)</option>\n          <option value=\"complete\">Complete</option>\n          <option value=\"bipartite\">Bipartite</option>\n          <option value=\"tree\">Random Tree</option>\n        </select>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Number of nodes:</label>\n        <input id=\"genN\" type=\"number\" value=\"10\" style=\"width:70px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Parameter (p/r/..):</label>\n        <input id=\"genParam\" type=\"number\" value=\"0.2\" step=\"0.05\" style=\"width:70px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Part A size (bipartite):</label>\n        <input id=\"bipA\" type=\"number\" value=\"4\" style=\"width:70px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Weight range:</label>\n        <input id=\"wmin\" type=\"number\" value=\"1\" style=\"width:50px\"> to\n        <input id=\"wmax\" type=\"number\" value=\"10\" style=\"width:50px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <button id=\"btnGenerate\">Generate Graph</button>\n        <button id=\"btnRandomizeWeights\">Randomize Weights</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Editing</legend>\n      <div>\n        <label>Rename selected:</label>\n        <input id=\"renameInput\" type=\"text\" style=\"width:140px\">\n        <button id=\"btnRename\">Rename</button>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Set weight for edge:</label>\n        <input id=\"edgeWeightInput\" type=\"number\" value=\"1\" style=\"width:80px\">\n        <button id=\"btnSetEdgeWeight\">Apply</button>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Connect two nodes:</label>\n        <input id=\"connectA\" type=\"number\" placeholder=\"id A\" style=\"width:60px\">\n        <input id=\"connectB\" type=\"number\" placeholder=\"id B\" style=\"width:60px\">\n        <button id=\"btnConnect\">Connect</button>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Move selected by (dx,dy):</label>\n        <input id=\"moveDx\" type=\"number\" value=\"10\" style=\"width:50px\">,\n        <input id=\"moveDy\" type=\"number\" value=\"0\" style=\"width:50px\">\n        <button id=\"btnMove\">Move</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Views / Export</legend>\n      <div>\n        <label>Show labels:</label>\n        <input id=\"showLabels\" type=\"checkbox\" checked>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Show weights:</label>\n        <input id=\"showWeights\" type=\"checkbox\" checked>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Show degrees:</label>\n        <input id=\"showDegrees\" type=\"checkbox\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <button id=\"btnAdjList\">Adjacency List</button>\n        <button id=\"btnAdjMatrix\">Adjacency Matrix</button>\n        <button id=\"btnIncidence\">Incidence Matrix</button>\n      </div>\n      <div style=\"margin-top:6px\">\n        <button id=\"btnSaveJSON\">Save JSON</button>\n        <input id=\"fileLoad\" type=\"file\" style=\"display:inline-block\">\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Algorithms (step control)</legend>\n      <div>\n        <label>Selected node id (for algos):</label>\n        <input id=\"algoStart\" type=\"number\" style=\"width:80px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <button id=\"btnBFS\">BFS (step)</button>\n        <button id=\"btnDFS\">DFS (step)</button>\n        <button id=\"btnDijkstra\">Dijkstra (step)</button>\n        <button id=\"btnMST\">Kruskal MST (step)</button>\n        <button id=\"btnComponents\">Connected Components</button>\n      </div>\n      <div style=\"margin-top:6px\">\n        <label>Algorithm speed (ms per step):</label>\n        <input id=\"algoSpeed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\" style=\"width:180px\">\n      </div>\n      <div style=\"margin-top:6px\">\n        <button id=\"btnAlgRun\">Run to end</button>\n        <button id=\"btnAlgStop\">Stop</button>\n        <button id=\"btnAlgReset\">Reset States</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Logs / Info</legend>\n      <textarea id=\"log\" rows=\"10\" style=\"width:100%\"></textarea>\n      <div style=\"margin-top:6px\">\n        <button id=\"btnClearLog\">Clear Log</button>\n      </div>\n    </fieldset>\n\n  </div>\n\n  <div>\n    <canvas id=\"canvas\" width=\"900\" height=\"640\"></canvas>\n    <div style=\"margin-top:6px\">\n      <label>Zoom: </label><input id=\"zoom\" type=\"range\" min=\"0.3\" max=\"2.5\" value=\"1\" step=\"0.05\">\n      <label>Pan lock:</label><input id=\"panLock\" type=\"checkbox\">\n      <small>Use mouse wheel to zoom, middle-drag or hold Space and drag to pan.</small>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\nUndirected Graph Interactive Demo\n- Many interactive controls\n- Minimal visual styling (black on white)\n- Canvas-based rendering with multiple workflows\n*/\n\n(function(){\n\n// Canvas and drawing\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\n\n// Controls\nconst btnNew = document.getElementById('btnNew');\nconst btnUndo = document.getElementById('btnUndo');\nconst btnRedo = document.getElementById('btnRedo');\nconst btnSelectNone = document.getElementById('btnSelectNone');\nconst btnDelete = document.getElementById('btnDelete');\nconst defaultWeightInput = document.getElementById('defaultWeight');\nconst createModeSelect = document.getElementById('createMode');\nconst snapGridChk = document.getElementById('snapGrid');\n\nconst genType = document.getElementById('genType');\nconst genN = document.getElementById('genN');\nconst genParam = document.getElementById('genParam');\nconst bipA = document.getElementById('bipA');\nconst wmin = document.getElementById('wmin');\nconst wmax = document.getElementById('wmax');\nconst btnGenerate = document.getElementById('btnGenerate');\nconst btnRandomizeWeights = document.getElementById('btnRandomizeWeights');\n\nconst renameInput = document.getElementById('renameInput');\nconst btnRename = document.getElementById('btnRename');\nconst edgeWeightInput = document.getElementById('edgeWeightInput');\nconst btnSetEdgeWeight = document.getElementById('btnSetEdgeWeight');\nconst connectA = document.getElementById('connectA');\nconst connectB = document.getElementById('connectB');\nconst btnConnect = document.getElementById('btnConnect');\nconst moveDx = document.getElementById('moveDx');\nconst moveDy = document.getElementById('moveDy');\nconst btnMove = document.getElementById('btnMove');\n\nconst showLabels = document.getElementById('showLabels');\nconst showWeights = document.getElementById('showWeights');\nconst showDegrees = document.getElementById('showDegrees');\nconst btnAdjList = document.getElementById('btnAdjList');\nconst btnAdjMatrix = document.getElementById('btnAdjMatrix');\nconst btnIncidence = document.getElementById('btnIncidence');\nconst btnSaveJSON = document.getElementById('btnSaveJSON');\nconst fileLoad = document.getElementById('fileLoad');\n\nconst algoStart = document.getElementById('algoStart');\nconst btnBFS = document.getElementById('btnBFS');\nconst btnDFS = document.getElementById('btnDFS');\nconst btnDijkstra = document.getElementById('btnDijkstra');\nconst btnMST = document.getElementById('btnMST');\nconst btnComponents = document.getElementById('btnComponents');\nconst algoSpeed = document.getElementById('algoSpeed');\nconst btnAlgRun = document.getElementById('btnAlgRun');\nconst btnAlgStop = document.getElementById('btnAlgStop');\nconst btnAlgReset = document.getElementById('btnAlgReset');\n\nconst logArea = document.getElementById('log');\nconst btnClearLog = document.getElementById('btnClearLog');\n\nconst zoomInput = document.getElementById('zoom');\nconst panLock = document.getElementById('panLock');\n\nlet W = canvas.width, H = canvas.height;\n\n// Data model\nlet graph = { nodes: [], edges: [] };\nlet nextNodeId = 1;\nlet nextEdgeId = 1;\n\nfunction cloneGraph(g){\n  return {\n    nodes: g.nodes.map(n => ({...n})),\n    edges: g.edges.map(e => ({...e}))\n  };\n}\n\n// History (undo/redo)\nlet history = [];\nlet historyPtr = -1;\nfunction pushHistory(label){\n  // store deep clone\n  history = history.slice(0, historyPtr+1);\n  history.push({g: cloneGraph(graph), label: label || ''});\n  historyPtr = history.length - 1;\n  updateUndoRedoButtons();\n}\nfunction undo(){\n  if(historyPtr <= 0) return;\n  historyPtr--;\n  const snap = history[historyPtr];\n  graph = cloneGraph(snap.g);\n  clearAlgorithmState();\n  render();\n  updateUndoRedoButtons();\n}\nfunction redo(){\n  if(historyPtr >= history.length - 1) return;\n  historyPtr++;\n  const snap = history[historyPtr];\n  graph = cloneGraph(snap.g);\n  clearAlgorithmState();\n  render();\n  updateUndoRedoButtons();\n}\nfunction updateUndoRedoButtons(){\n  btnUndo.disabled = historyPtr <= 0;\n  btnRedo.disabled = historyPtr >= history.length -1;\n}\n\n// Selection state\nlet selectedNode = null;\nlet selectedEdge = null;\n\n// Interaction state\nlet draggingNode = null;\nlet dragOffset = {x:0,y:0};\nlet isPanning = false;\nlet lastMouse = {x:0,y:0};\nlet creatingEdgeFrom = null;\nlet ghostMouse = null;\nlet spacePan = false;\n\n// View transform\nlet view = { tx: 0, ty: 0, scale: 1 };\n\n// Algorithm state\nlet algState = null;\nlet algTimer = null;\n\n// Utility functions\nfunction screenToWorld(p){\n  return { x: (p.x - view.tx)/view.scale, y: (p.y - view.ty)/view.scale };\n}\nfunction worldToScreen(p){\n  return { x: p.x*view.scale + view.tx, y: p.y*view.scale + view.ty };\n}\n\nfunction findNodeAt(pos){\n  for(let i = graph.nodes.length-1; i >=0; i--){\n    const n = graph.nodes[i];\n    const s = worldToScreen(n);\n    const r = (n.r||18) * view.scale;\n    const dx = pos.x - s.x, dy = pos.y - s.y;\n    if(dx*dx + dy*dy <= r*r) return n;\n  }\n  return null;\n}\n\nfunction findEdgeAt(pos){\n  // return edge if click near line\n  const threshold = 8;\n  for(let i=0;i<graph.edges.length;i++){\n    const e = graph.edges[i];\n    const a = worldToScreen(graph.nodesById[e.a]);\n    const b = worldToScreen(graph.nodesById[e.b]);\n    const d = pointToSegmentDistance(pos, a, b);\n    if(d <= threshold) return e;\n  }\n  return null;\n}\nfunction pointToSegmentDistance(p,a,b){\n  const vx = b.x - a.x, vy = b.y - a.y;\n  const wx = p.x - a.x, wy = p.y - a.y;\n  const c = (vx*wx + vy*wy) / (vx*vx + vy*vy || 1);\n  const t = Math.max(0, Math.min(1, c));\n  const cx = a.x + vx*t, cy = a.y + vy*t;\n  const dx = p.x - cx, dy = p.y - cy;\n  return Math.sqrt(dx*dx + dy*dy);\n}\n\nfunction addNode(x,y,label){\n  const snap = { id: nextNodeId++, x:x, y:y, label: label || String(nextNodeId-1), r: 18, state: 'normal', component: null };\n  graph.nodes.push(snap);\n  pushHistory('add node');\n  rebuildIndex();\n  return snap;\n}\n\nfunction removeNode(id){\n  const node = graph.nodes.find(n => n.id === id);\n  if(!node) return;\n  graph.nodes = graph.nodes.filter(n => n.id !== id);\n  graph.edges = graph.edges.filter(e => e.a !== id && e.b !== id);\n  pushHistory('remove node');\n  rebuildIndex();\n}\nfunction addEdge(a,b,w){\n  if(a===b) return null;\n  // ensure undirected unique\n  if(graph.edges.some(e => (e.a===a && e.b===b) || (e.a===b && e.b===a))) return null;\n  const edge = { id: nextEdgeId++, a:a, b:b, weight: w==null? Number(defaultWeightInput.value) : Number(w), state:'normal', inMST:false };\n  graph.edges.push(edge);\n  pushHistory('add edge');\n  rebuildIndex();\n  return edge;\n}\nfunction removeEdge(id){\n  graph.edges = graph.edges.filter(e => e.id !== id);\n  pushHistory('remove edge');\n  rebuildIndex();\n}\n\nfunction rebuildIndex(){\n  // build convenience maps\n  graph.nodesById = Object.create(null);\n  graph.edgesById = Object.create(null);\n  graph.adj = Object.create(null);\n  graph.nodes.forEach(n => { graph.nodesById[n.id] = n; graph.adj[n.id] = []; });\n  graph.edges.forEach(e => { graph.edgesById[e.id] = e; graph.adj[e.a].push({to:e.b, edgeId:e.id}); graph.adj[e.b].push({to:e.a, edgeId:e.id});});\n}\n\nfunction clearSelection(){\n  selectedNode = null;\n  selectedEdge = null;\n}\n\nfunction clearAlgorithmState(){\n  algState = null;\n  if(algTimer){ clearInterval(algTimer); algTimer = null; }\n  // reset node edge states\n  graph.nodes.forEach(n => { n.state = 'normal'; n.dist = null; n.prev = null; n.component = null; });\n  graph.edges.forEach(e => { e.state = 'normal'; e.inMST = false; });\n  render();\n}\n\n// Rendering\nfunction render(){\n  ctx.clearRect(0,0,W,H);\n  // draw edges\n  graph.edges.forEach(e => {\n    const a = graph.nodesById[e.a];\n    const b = graph.nodesById[e.b];\n    if(!a || !b) return;\n    const A = worldToScreen(a), B = worldToScreen(b);\n    ctx.beginPath();\n    ctx.lineWidth = e.inMST ? 4 : (e.state === 'current' ? 3 : 1);\n    ctx.moveTo(A.x, A.y);\n    ctx.lineTo(B.x, B.y);\n    ctx.strokeStyle = 'black';\n    ctx.stroke();\n    // weight label\n    if(showWeights.checked){\n      const mx = (A.x + B.x)/2, my = (A.y + B.y)/2;\n      ctx.font = `${12 * view.scale}px sans-serif`;\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillStyle = 'black';\n      ctx.fillText(String(e.weight), mx, my);\n    }\n  });\n  // ghost edge\n  if(creatingEdgeFrom && ghostMouse){\n    const a = worldToScreen(creatingEdgeFrom);\n    ctx.beginPath();\n    ctx.moveTo(a.x,a.y);\n    ctx.lineTo(ghostMouse.x, ghostMouse.y);\n    ctx.lineWidth = 1;\n    ctx.stroke();\n  }\n  // draw nodes\n  graph.nodes.forEach(n => {\n    const s = worldToScreen(n);\n    const r = (n.r||18) * view.scale;\n    ctx.beginPath();\n    const lw = (n === selectedNode) ? 3 : (n.state === 'frontier' ? 3 : 1);\n    ctx.lineWidth = lw;\n    ctx.fillStyle = 'white';\n    ctx.strokeStyle = 'black';\n    ctx.arc(s.x, s.y, r, 0, Math.PI*2);\n    ctx.fill();\n    ctx.stroke();\n    // label\n    if(showLabels.checked){\n      ctx.font = `${12 * view.scale}px sans-serif`;\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      let text = n.label || String(n.id);\n      if(showDegrees.checked){\n        const deg = graph.adj[n.id] ? graph.adj[n.id].length : 0;\n        text = `${text} (${deg})`;\n      }\n      // append component or dist if present\n      if(n.component != null) text += ` [c:${n.component}]`;\n      if(n.state === 'visited') text += ' v';\n      if(n.dist != null) text += ` d:${n.dist}`;\n      ctx.fillStyle = 'black';\n      ctx.fillText(text, s.x, s.y);\n    } else {\n      // still show id small\n      ctx.font = `${10 * view.scale}px sans-serif`;\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillStyle = 'black';\n      ctx.fillText(String(n.id), s.x, s.y);\n    }\n  });\n  // edge selection highlight\n  if(selectedEdge){\n    const e = selectedEdge;\n    const a = worldToScreen(graph.nodesById[e.a]);\n    const b = worldToScreen(graph.nodesById[e.b]);\n    ctx.beginPath();\n    ctx.lineWidth = 4;\n    ctx.moveTo(a.x,a.y);\n    ctx.lineTo(b.x,b.y);\n    ctx.stroke();\n  }\n}\n\n// Mouse and keyboard handling\nlet mouseDown = false;\ncanvas.addEventListener('mousedown', (ev) => {\n  const p = {x: ev.offsetX, y: ev.offsetY};\n  lastMouse = p;\n  mouseDown = true;\n  const world = screenToWorld(p);\n  const node = findNodeAt(p);\n  const edge = findEdgeAt(p);\n  if(ev.button === 1){ // middle mouse => pan\n    isPanning = true;\n    return;\n  }\n  if(spacePan || (ev.button === 0 && panLock.checked && !node)){\n    isPanning = true;\n    return;\n  }\n  if(node){\n    // select node\n    selectedNode = node;\n    selectedEdge = null;\n    // start drag\n    draggingNode = node;\n    dragOffset.x = node.x - world.x;\n    dragOffset.y = node.y - world.y;\n    // shift+drag for edge creation\n    if(ev.shiftKey || createModeSelect.value === 'drag-edge'){\n      creatingEdgeFrom = node;\n      ghostMouse = p;\n    }\n  } else if(edge){\n    selectedEdge = edge;\n    selectedNode = null;\n    draggingNode = null;\n  } else {\n    // click on empty area: create node if mode instructs\n    if(createModeSelect.value === 'click' && ev.button === 0 && !ev.shiftKey){\n      const worldP = screenToWorld(p);\n      let gx = worldP.x, gy = worldP.y;\n      if(snapGridChk.checked){\n        gx = Math.round(gx/20)*20;\n        gy = Math.round(gy/20)*20;\n      }\n      const n = addNode(gx, gy, String(nextNodeId));\n      selectedNode = n;\n      selectedEdge = null;\n      render();\n    }\n    clearSelection();\n  }\n  render();\n});\n\ncanvas.addEventListener('mousemove', (ev) => {\n  const p = {x:ev.offsetX, y:ev.offsetY};\n  const world = screenToWorld(p);\n  if(mouseDown){\n    if(isPanning){\n      const dx = p.x - lastMouse.x;\n      const dy = p.y - lastMouse.y;\n      view.tx += dx;\n      view.ty += dy;\n      lastMouse = p;\n      render();\n      return;\n    }\n    if(creatingEdgeFrom){\n      ghostMouse = p;\n      render();\n      return;\n    }\n    if(draggingNode){\n      // move node\n      draggingNode.x = world.x + dragOffset.x;\n      draggingNode.y = world.y + dragOffset.y;\n      render();\n    }\n  } else {\n    // hover highlight\n  }\n});\n\ncanvas.addEventListener('mouseup', (ev) => {\n  mouseDown = false;\n  const p = {x: ev.offsetX, y: ev.offsetY};\n  if(isPanning){\n    isPanning = false;\n    return;\n  }\n  if(creatingEdgeFrom){\n    const targetNode = findNodeAt(p);\n    if(targetNode && targetNode !== creatingEdgeFrom){\n      const w = Number(defaultWeightInput.value);\n      const e = addEdge(creatingEdgeFrom.id, targetNode.id, w);\n      if(!e){\n        log(`Edge already exists between ${creatingEdgeFrom.id} and ${targetNode.id}`);\n      }\n    }\n    creatingEdgeFrom = null;\n    ghostMouse = null;\n    rebuildIndex();\n    render();\n    return;\n  }\n  if(draggingNode){\n    pushHistory('move node');\n    draggingNode = null;\n    render();\n  }\n});\n\ncanvas.addEventListener('dblclick', (ev) => {\n  const p = {x: ev.offsetX, y: ev.offsetY};\n  const node = findNodeAt(p);\n  if(node){\n    const name = prompt('Rename node', node.label || node.id);\n    if(name !== null){\n      node.label = name;\n      pushHistory('rename node');\n      render();\n    }\n  } else {\n    const edge = findEdgeAt(p);\n    if(edge){\n      const w = prompt('Edit edge weight', String(edge.weight));\n      if(w !== null){\n        edge.weight = Number(w);\n        pushHistory('edit edge');\n        render();\n      }\n    }\n  }\n});\n\n// wheel for zoom\ncanvas.addEventListener('wheel', (ev) => {\n  ev.preventDefault();\n  const delta = -ev.deltaY;\n  let factor = delta > 0 ? 1.07 : 0.93;\n  const oldScale = view.scale;\n  const mouse = {x: ev.offsetX, y: ev.offsetY};\n  const worldBefore = screenToWorld(mouse);\n  view.scale *= factor;\n  view.scale = Math.max(0.2, Math.min(3, view.scale));\n  const worldAfter = screenToWorld(mouse);\n  // adjust translation so world point under cursor stays same\n  view.tx += (worldAfter.x - worldBefore.x) * view.scale;\n  view.ty += (worldAfter.y - worldBefore.y) * view.scale;\n  zoomInput.value = view.scale;\n  render();\n});\n\n// Keyboard\nwindow.addEventListener('keydown', (ev) => {\n  if(ev.ctrlKey && ev.key === 'z'){ ev.preventDefault(); undo(); }\n  if(ev.ctrlKey && ev.key === 'y'){ ev.preventDefault(); redo(); }\n  if(ev.key === 'Delete'){ ev.preventDefault(); deleteSelected(); }\n  if(ev.key === 'n' || ev.key === 'N'){ createModeSelect.value = 'click'; }\n  if(ev.key === 'e' || ev.key === 'E'){ createModeSelect.value = 'drag-edge'; }\n  if(ev.key === ' '){ spacePan = true; }\n});\nwindow.addEventListener('keyup', (ev) => { if(ev.key === ' ') spacePan = false; });\n\n// Buttons behavior\nbtnNew.addEventListener('click', () => {\n  if(!confirm('Clear the graph?')) return;\n  graph = {nodes:[], edges:[]};\n  nextNodeId = 1; nextEdgeId = 1;\n  rebuildIndex();\n  pushHistory('new graph');\n  clearAlgorithmState();\n  render();\n});\nbtnUndo.addEventListener('click', undo);\nbtnRedo.addEventListener('click', redo);\nbtnSelectNone.addEventListener('click', () => { clearSelection(); render(); });\nbtnDelete.addEventListener('click', deleteSelected);\n\nfunction deleteSelected(){\n  if(selectedNode){\n    removeNode(selectedNode.id);\n    selectedNode = null;\n    render();\n  } else if(selectedEdge){\n    removeEdge(selectedEdge.id);\n    selectedEdge = null;\n    render();\n  }\n}\n\n// Generation\nbtnGenerate.addEventListener('click', () => {\n  const type = genType.value;\n  const N = Math.max(0, Math.floor(Number(genN.value)));\n  const param = Number(genParam.value);\n  const minW = Number(wmin.value), maxW = Number(wmax.value);\n  // center nodes\n  graph = {nodes:[], edges:[]};\n  nextNodeId = 1; nextEdgeId = 1;\n  const padding = 40;\n  function randPos(i){\n    return {x: padding + Math.random()*(W-padding*2), y: padding + Math.random()*(H-padding*2)};\n  }\n  if(type === 'erdos'){\n    for(let i=0;i<N;i++){\n      const p = randPos(i);\n      addNode(p.x,p.y,String(nextNodeId));\n    }\n    rebuildIndex();\n    for(let i=0;i<graph.nodes.length;i++){\n      for(let j=i+1;j<graph.nodes.length;j++){\n        if(Math.random() < param){\n          const w = randomInt(minW,maxW);\n          graph.nodesById = graph.nodesById || {};\n          addEdge(graph.nodes[i].id, graph.nodes[j].id, w);\n        }\n      }\n    }\n  } else if(type === 'geometric'){\n    for(let i=0;i<N;i++){\n      const p = randPos(i);\n      addNode(p.x,p.y,String(nextNodeId));\n    }\n    rebuildIndex();\n    const r = Math.max(20, (param||0.2) * Math.min(W,H));\n    for(let i=0;i<graph.nodes.length;i++){\n      for(let j=i+1;j<graph.nodes.length;j++){\n        const a = graph.nodes[i], b = graph.nodes[j];\n        const dx = a.x-b.x, dy = a.y-b.y;\n        if(Math.sqrt(dx*dx+dy*dy) <= r){\n          addEdge(a.id,b.id, randomInt(minW,maxW));\n        }\n      }\n    }\n  } else if(type === 'complete'){\n    for(let i=0;i<N;i++){\n      const p = randPos(i);\n      addNode(p.x,p.y,String(nextNodeId));\n    }\n    rebuildIndex();\n    for(let i=0;i<graph.nodes.length;i++){\n      for(let j=i+1;j<graph.nodes.length;j++){\n        addEdge(graph.nodes[i].id, graph.nodes[j].id, randomInt(minW,maxW));\n      }\n    }\n  } else if(type === 'bipartite'){\n    const aSize = Math.max(1, Math.min(N-1, Number(bipA.value)));\n    const bSize = N - aSize;\n    const leftX = W/3, rightX = 2*W/3;\n    for(let i=0;i<aSize;i++){\n      addNode(leftX + (Math.random()-0.5)*100, 80 + i*(H-160)/Math.max(1,aSize), 'A'+(i+1));\n    }\n    for(let j=0;j<bSize;j++){\n      addNode(rightX + (Math.random()-0.5)*100, 80 + j*(H-160)/Math.max(1,bSize), 'B'+(j+1));\n    }\n    rebuildIndex();\n    const prob = Math.min(1, Math.max(0, param));\n    const left = graph.nodes.slice(0,aSize), right = graph.nodes.slice(aSize);\n    left.forEach(la => {\n      right.forEach(rb => {\n        if(Math.random() < prob) addEdge(la.id, rb.id, randomInt(minW,maxW));\n      });\n    });\n  } else if(type === 'tree'){\n    for(let i=0;i<N;i++){\n      const p = randPos(i);\n      addNode(p.x,p.y,String(nextNodeId));\n    }\n    rebuildIndex();\n    // random tree via connecting node i to random j<i\n    for(let i=1;i<graph.nodes.length;i++){\n      const j = Math.floor(Math.random()*i);\n      addEdge(graph.nodes[i].id, graph.nodes[j].id, randomInt(minW,maxW));\n    }\n  }\n  rebuildIndex();\n  pushHistory('generate');\n  render();\n});\n\nbtnRandomizeWeights.addEventListener('click', () => {\n  graph.edges.forEach(e => e.weight = randomInt(Number(wmin.value), Number(wmax.value)));\n  pushHistory('randomize weights');\n  render();\n});\n\n// Adjacency and matrices\nbtnAdjList.addEventListener('click', () => {\n  rebuildIndex();\n  const lines = graph.nodes.map(n => {\n    const neighbors = (graph.adj[n.id] || []).map(x => `${x.to}(e${x.edgeId})`).join(', ');\n    return `${n.id}: ${neighbors}`;\n  });\n  log(lines.join('\\n'));\n});\nbtnAdjMatrix.addEventListener('click', () => {\n  rebuildIndex();\n  const ids = graph.nodes.map(n => n.id);\n  const mapIndex = {};\n  ids.forEach((id,i) => mapIndex[id]=i);\n  const N = ids.length;\n  let out = '   ' + ids.join(' ') + '\\n';\n  for(let i=0;i<N;i++){\n    const row = [];\n    for(let j=0;j<N;j++){\n      const a = ids[i], b = ids[j];\n      const exists = graph.edges.some(e => (e.a===a && e.b===b) || (e.a===b && e.b===a));\n      row.push(exists?1:0);\n    }\n    out += ids[i] + ': ' + row.join(' ') + '\\n';\n  }\n  log(out);\n});\nbtnIncidence.addEventListener('click', () => {\n  rebuildIndex();\n  const ids = graph.nodes.map(n => n.id);\n  const eids = graph.edges.map(e => e.id);\n  let out = 'incidence (nodes x edges)\\n   ' + eids.join(' ') + '\\n';\n  for(let n of graph.nodes){\n    const row = graph.edges.map(e => (e.a===n.id || e.b===n.id)?1:0);\n    out += n.id + ': ' + row.join(' ') + '\\n';\n  }\n  log(out);\n});\n\n// Save/Load\nbtnSaveJSON.addEventListener('click', () => {\n  const data = JSON.stringify({nodes:graph.nodes, edges:graph.edges}, null, 2);\n  const blob = new Blob([data], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'graph.json';\n  a.click();\n  URL.revokeObjectURL(url);\n});\nfileLoad.addEventListener('change', (ev) => {\n  const file = ev.target.files[0];\n  if(!file) return;\n  const reader = new FileReader();\n  reader.onload = () => {\n    try{\n      const obj = JSON.parse(reader.result);\n      if(obj.nodes && obj.edges){\n        graph.nodes = obj.nodes.map(n => ({...n}));\n        graph.edges = obj.edges.map(e => ({...e}));\n        nextNodeId = Math.max( (graph.nodes.map(n=>n.id).concat(0)).reduce((a,b)=>Math.max(a,b)), 0) + 1;\n        nextEdgeId = Math.max( (graph.edges.map(e=>e.id).concat(0)).reduce((a,b)=>Math.max(a,b)), 0) + 1;\n        rebuildIndex();\n        pushHistory('load');\n        render();\n      } else {\n        alert('Invalid graph JSON');\n      }\n    } catch(err){\n      alert('Error parsing file: ' + err);\n    }\n  };\n  reader.readAsText(file);\n});\n\n// Rename and edge weight set\nbtnRename.addEventListener('click', () => {\n  if(!selectedNode){ alert('Select a node first'); return; }\n  selectedNode.label = renameInput.value || selectedNode.label;\n  pushHistory('rename');\n  render();\n});\nbtnSetEdgeWeight.addEventListener('click', () => {\n  if(!selectedEdge){ alert('Select an edge first'); return; }\n  selectedEdge.weight = Number(edgeWeightInput.value);\n  pushHistory('set weight');\n  render();\n});\nbtnConnect.addEventListener('click', () => {\n  const a = Number(connectA.value), b = Number(connectB.value);\n  if(!graph.nodesById || !graph.nodesById[a] || !graph.nodesById[b]){ alert('Invalid node ids'); return; }\n  addEdge(a,b, Number(edgeWeightInput.value));\n  rebuildIndex();\n  render();\n});\nbtnMove.addEventListener('click', () => {\n  if(!selectedNode){ alert('Select a node first'); return; }\n  selectedNode.x += Number(moveDx.value);\n  selectedNode.y += Number(moveDy.value);\n  pushHistory('move node');\n  render();\n});\n\n// Delete via function key in other places\nfunction log(text){\n  logArea.value += text + '\\n';\n  logArea.scrollTop = logArea.scrollHeight;\n}\nbtnClearLog.addEventListener('click', () => { logArea.value = ''; });\n\n// Algorithm implementations with step control\n\n/* BFS step iterator */\nfunction bfsInit(startId){\n  rebuildIndex();\n  const start = graph.nodesById[startId];\n  if(!start) { log('Start node not found'); return null; }\n  graph.nodes.forEach(n=>{ n.state='normal'; n.dist = Infinity; n.prev = null; });\n  const queue = [startId];\n  start.state = 'frontier';\n  start.dist = 0;\n  const state = {type:'bfs', queue:queue, visited:new Set([startId]), log:[], started:true};\n  log(`BFS start at ${startId}`);\n  return state;\n}\nfunction bfsStep(state){\n  if(!state || state.queue.length === 0){\n    log('BFS complete');\n    return false;\n  }\n  const u = state.queue.shift();\n  const uNode = graph.nodesById[u];\n  uNode.state = 'visited';\n  state.log.push(u);\n  log(`Visit ${u}`);\n  // explore neighbors\n  const neighbors = graph.adj[u] ? graph.adj[u].map(x=>x.to) : [];\n  neighbors.forEach(v => {\n    const vNode = graph.nodesById[v];\n    if(!state.visited.has(v)){\n      state.visited.add(v);\n      vNode.state = 'frontier';\n      vNode.dist = uNode.dist + 1;\n      vNode.prev = u;\n      state.queue.push(v);\n      log(`  Enqueue ${v} (dist=${vNode.dist})`);\n    }\n  });\n  return state.queue.length > 0;\n}\n\n/* DFS iterative (explicit stack) */\nfunction dfsInit(startId){\n  rebuildIndex();\n  const start = graph.nodesById[startId];\n  if(!start){ log('Start node not found'); return null; }\n  graph.nodes.forEach(n=>{ n.state='normal'; n.prev=null; });\n  const stack = [startId];\n  start.state = 'frontier';\n  const visited = new Set();\n  const state = {type:'dfs', stack:stack, visited: visited, log:[]};\n  log(`DFS start at ${startId}`);\n  return state;\n}\nfunction dfsStep(state){\n  if(!state || state.stack.length === 0){\n    log('DFS complete');\n    return false;\n  }\n  const u = state.stack.pop();\n  if(state.visited.has(u)) return state.stack.length > 0;\n  state.visited.add(u);\n  const uNode = graph.nodesById[u];\n  uNode.state = 'visited';\n  state.log.push(u);\n  log(`Visit ${u}`);\n  const neighbors = (graph.adj[u]||[]).map(x=>x.to);\n  // push neighbors in reverse for typical order\n  for(let i=neighbors.length-1;i>=0;i--){\n    const v = neighbors[i];\n    if(!state.visited.has(v)){\n      state.stack.push(v);\n      graph.nodesById[v].state = 'frontier';\n      graph.nodesById[v].prev = u;\n      log(`  Push ${v}`);\n    }\n  }\n  return state.stack.length > 0;\n}\n\n/* Dijkstra */\nfunction dijkstraInit(startId){\n  rebuildIndex();\n  if(!graph.nodesById[startId]){ log('Start node not found'); return null; }\n  const dist = Object.create(null);\n  const prev = Object.create(null);\n  graph.nodes.forEach(n => { dist[n.id] = Infinity; prev[n.id] = null; n.state='normal'; n.dist = Infinity; });\n  dist[startId] = 0;\n  graph.nodesById[startId].dist = 0;\n  const pq = graph.nodes.map(n => ({id:n.id, dist:dist[n.id]}));\n  const state = {type:'dijkstra', dist, prev, pq};\n  log(`Dijkstra start at ${startId}`);\n  return state;\n}\nfunction dijkstraStep(state){\n  // simple O(n^2) poll min from pq\n  if(!state) return false;\n  // rebuild pq with current dist\n  state.pq = graph.nodes.map(n=>({id:n.id, dist: state.dist[n.id]}));\n  state.pq.sort((a,b)=>a.dist-b.dist);\n  const item = state.pq.shift();\n  if(item.dist === Infinity) { log('All remaining unreachable'); return false; }\n  const u = item.id;\n  if(graph.nodesById[u].state === 'visited') return state.pq.length > 0;\n  graph.nodesById[u].state = 'visited';\n  graph.nodesById[u].dist = state.dist[u];\n  log(`Settle ${u} dist=${state.dist[u]}`);\n  const neighbors = graph.adj[u] || [];\n  neighbors.forEach(ne => {\n    const v = ne.to;\n    const e = graph.edgesById[ne.edgeId];\n    const alt = state.dist[u] + (e ? Number(e.weight) : 1);\n    if(alt < state.dist[v]){\n      state.dist[v] = alt;\n      state.prev[v] = u;\n      graph.nodesById[v].state = 'frontier';\n      graph.nodesById[v].dist = alt;\n      log(`  Relax ${v} to dist=${alt}`);\n    }\n  });\n  return state.pq.length > 0;\n}\n\n/* Kruskal MST step-by-step */\nfunction mstKruskalInit(){\n  rebuildIndex();\n  const edges = graph.edges.slice().sort((a,b)=>a.weight - b.weight);\n  const parent = {};\n  graph.nodes.forEach(n => parent[n.id]=n.id);\n  function find(x){ return parent[x] === x ? x : (parent[x]=find(parent[x])); }\n  function unite(a,b){ parent[find(b)] = find(a); }\n  const state = { type:'kruskal', edges, parent, find, unite, idx:0, chosen:[] };\n  graph.edges.forEach(e=>{ e.inMST = false; e.state='normal'; });\n  log('Kruskal MST init');\n  return state;\n}\nfunction mstKruskalStep(state){\n  if(!state || state.idx >= state.edges.length) { log('Kruskal complete'); return false; }\n  const e = state.edges[state.idx++];\n  const a = e.a, b = e.b;\n  if(state.find(a) !== state.find(b)){\n    state.unite(a,b);\n    e.inMST = true;\n    state.chosen.push(e.id);\n    log(`Choose edge ${e.id} (${a}-${b}) weight=${e.weight}`);\n  } else {\n    log(`Skip edge ${e.id} (${a}-${b}) - would form cycle`);\n  }\n  render();\n  return state.idx < state.edges.length;\n}\n\n/* Connected components */\nfunction components(){\n  rebuildIndex();\n  const comp = {};\n  let cid = 0;\n  graph.nodes.forEach(n => { n.component = null; });\n  for(const n of graph.nodes){\n    if(n.component != null) continue;\n    cid++;\n    // BFS from n\n    const queue = [n.id];\n    n.component = cid;\n    while(queue.length){\n      const u = queue.shift();\n      (graph.adj[u]||[]).forEach(x => {\n        const v = graph.nodesById[x.to];\n        if(v.component == null){\n          v.component = cid;\n          queue.push(v.id);\n        }\n      });\n    }\n  }\n  log(`Found ${cid} components`);\n  render();\n}\n\n// Algorithm runner utilities\nfunction startAlgorithm(type){\n  const start = Number(algoStart.value);\n  if(type === 'bfs'){\n    algState = bfsInit(start);\n  } else if(type === 'dfs'){\n    algState = dfsInit(start);\n  } else if(type === 'dijkstra'){\n    algState = dijkstraInit(start);\n  } else if(type === 'mst'){\n    algState = mstKruskalInit();\n  }\n  if(!algState) return;\n  // step once\n  runAlgStep();\n}\nfunction runAlgStep(){\n  if(!algState) return;\n  const t = algState.type;\n  render();\n  let cont = false;\n  if(t === 'bfs') cont = bfsStep(algState);\n  else if(t === 'dfs') cont = dfsStep(algState);\n  else if(t === 'dijkstra') cont = dijkstraStep(algState);\n  else if(t === 'kruskal') cont = mstKruskalStep(algState);\n  render();\n  if(!cont){\n    algState = null;\n  }\n}\n\nbtnBFS.addEventListener('click', () => { startAlgorithm('bfs'); });\nbtnDFS.addEventListener('click', () => { startAlgorithm('dfs'); });\nbtnDijkstra.addEventListener('click', () => { startAlgorithm('dijkstra'); });\nbtnMST.addEventListener('click', () => { startAlgorithm('mst'); });\nbtnComponents.addEventListener('click', () => { components(); });\n\nbtnAlgRun.addEventListener('click', () => {\n  if(!algState) { log('No active algorithm to run. Press a (step) button first.'); return; }\n  const speed = Number(algoSpeed.value);\n  if(algTimer) clearInterval(algTimer);\n  algTimer = setInterval(() => {\n    if(!algState){ clearInterval(algTimer); algTimer = null; return; }\n    runAlgStep();\n    if(!algState){ clearInterval(algTimer); algTimer = null; }\n  }, speed);\n});\nbtnAlgStop.addEventListener('click', () => { if(algTimer) clearInterval(algTimer); algTimer = null; algState = null; render(); });\nbtnAlgReset.addEventListener('click', () => { clearAlgorithmState(); render(); });\n\n// Edge selection: click behavior on canvas: add listener for click outside dragging - handled in mousedown/up\n\n// Set up initial state\nfunction randomInt(a,b){ return Math.floor(a + Math.random()*(b-a+1)); }\n\n// Build adjacency, etc. at start\nrebuildIndex();\npushHistory('initial');\nrender();\n\n// zoom input\nzoomInput.addEventListener('input', () => {\n  const newScale = Number(zoomInput.value);\n  // adjust tx/ty to keep center stable\n  const center = {x: W/2, y: H/2};\n  const worldBefore = screenToWorld(center);\n  view.scale = newScale;\n  const worldAfter = screenToWorld(center);\n  view.tx += (worldAfter.x - worldBefore.x) * view.scale;\n  view.ty += (worldAfter.y - worldBefore.y) * view.scale;\n  render();\n});\n\n// Click on canvas to select edge if clicked\ncanvas.addEventListener('click', (ev) => {\n  // only handle simple clicks (no drag)\n  if(ev.detail !== 1) return;\n  const p = {x:ev.offsetX, y:ev.offsetY};\n  const node = findNodeAt(p);\n  if(node){\n    selectedNode = node;\n    selectedEdge = null;\n    render();\n    return;\n  }\n  const edge = findEdgeAt(p);\n  if(edge){\n    selectedEdge = edge;\n    selectedNode = null;\n    render();\n    return;\n  }\n  selectedEdge = null;\n  selectedNode = null;\n  render();\n});\n\n// Edge weight editing when clicking an edge: done via double-click currently.\n\n// Initialize some helpful logs\nlog('Ready. Create nodes by clicking canvas. Use Shift+drag to connect nodes, or use the Connect fields.');\nlog('Algorithms: set start node id in \"Selected node id\" and press BFS/DFS/Dijkstra, then use Run to execute automatically.');\n\n// Rebuild indexes if graph changes externally\nfunction ensureIndex(){\n  rebuildIndex();\n}\n})();\n</script>\n\n</body>\n</html>"
