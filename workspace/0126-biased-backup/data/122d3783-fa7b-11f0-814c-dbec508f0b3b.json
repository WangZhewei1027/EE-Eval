    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>HTTP Example</title>\n    <style>\n        body {\n            background-color: #000;\n            font-family: monospace;\n        }\n        input[type=\"text\"], input[type=\"number\"], input[type=\"checkbox\"], select {\n            width: 100%;\n            padding: 10px;\n            margin: 10px 0;\n            border: 1px solid #000;\n            border-radius: 5px;\n        }\n        button {\n            width: 100%;\n            padding: 10px;\n            margin: 10px 0;\n            border: none;\n            border-radius: 5px;\n            background-color: #000;\n            color: #fff;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #000000;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        .error {\n            color: red;\n        }\n    </style>\n</head>\n<body>\n    <h1>HTTP Example</h1>\n    <p id=\"message\"></p>\n    <form id=\"form\">\n        <label for=\"url\">URL:</label>\n        <input type=\"text\" id=\"url\" name=\"url\" placeholder=\"Enter URL\">\n        <button id=\"submit\">Submit</button>\n        <button id=\"clear\">Clear</button>\n        <button id=\"refresh\">Refresh</button>\n        <button id=\"reset\">Reset</button>\n        <button id=\"submit-error\">Submit (Error Handling)</button>\n    </form>\n    <div id=\"output\"></div>\n\n    <script>\n        let message = document.getElementById('message');\n        let form = document.getElementById('form');\n        let urlInput = document.getElementById('url');\n        let submitButton = document.getElementById('submit');\n        let clearButton = document.getElementById('clear');\n        let refreshButton = document.getElementById('refresh');\n        let resetButton = document.getElementById('reset');\n        let submitWithErrorButton = document.getElementById('submit-error');\n\n        // URL Input\n        urlInput.addEventListener('input', () => {\n            message.textContent = 'URL: ' + urlInput.value;\n        });\n\n        // Submit Button\n        submitButton.addEventListener('click', () => {\n            if (urlInput.value.trim() !== '') {\n                fetch(urlInput.value)\n                    .then(response => response.json())\n                    .then(data => {\n                        message.textContent = 'Success: ' + data.message;\n                        form.reset();\n                    })\n                    .catch(error => {\n                        message.textContent = 'Error: ' + error.message;\n                    });\n            } else {\n                message.textContent = 'Please enter a URL';\n            }\n        });\n\n        // Clear Button\n        clearButton.addEventListener('click', () => {\n            message.textContent = '';\n            form.reset();\n        });\n\n        // Refresh Button\n        refreshButton.addEventListener('click', () => {\n            fetch('https://api.github.com/users/octocat')\n                .then(response => response.json())\n                .then(data => {\n                    message.textContent = 'Success: ' + data.message;\n                    form.reset();\n                })\n                .catch(error => {\n                    message.textContent = 'Error: ' + error.message;\n                });\n        });\n\n        // Reset Button\n        resetButton.addEventListener('click', () => {\n            message.textContent = '';\n            form.reset();\n        });\n\n        // Submit with Error Handling\n        submitWithErrorButton.addEventListener('click', () => {\n            fetch(urlInput.value)\n                .then(response => response.json())\n                .then(data => {\n                    message.textContent = 'Success: ' + data.message;\n                    form.reset();\n                })\n                .catch(error => {\n                    message.textContent = 'Error: ' + error.message;\n                });\n        });\n    </script>\n</body>\n</html>"
