    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bellman-Ford Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #f0f4f8;\n            color: #333;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            height: 100vh;\n            margin: 0;\n        }\n\n        h1 {\n            font-size: 36px;\n            margin-bottom: 20px;\n            color: #6200ea;\n        }\n\n        .graph-container {\n            position: relative;\n            width: 80vw;\n            height: 50vh;\n            border: 2px solid #6200ea;\n            border-radius: 12px;\n            background-color: #fff;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .node {\n            width: 40px;\n            height: 40px;\n            border-radius: 50%;\n            background: #03a9f4;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: absolute;\n            transition: background 0.3s;\n        }\n\n        .node.active {\n            background: #ffea00;\n        }\n\n        .edge {\n            position: absolute;\n            width: 2px;\n            height: 200px;\n            background: #ccc;\n            transition: background 0.3s;\n        }\n\n        .edge.active {\n            background: #ff5722;\n        }\n\n        button {\n            margin-top: 20px;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 8px;\n            background-color: #6200ea;\n            color: white;\n            font-size: 16px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n\n        button:hover {\n            background-color: #3700b3;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Bellman-Ford Algorithm Visualization</h1>\n<div class=\"graph-container\" id=\"graphContainer\"></div>\n<button id=\"startButton\">Run Algorithm</button>\n\n<script>\n    const graphContainer = document.getElementById('graphContainer');\n    const startButton = document.getElementById('startButton');\n\n    const nodes = [\n        { id: 'A', x: 50, y: 200 },\n        { id: 'B', x: 200, y: 50 },\n        { id: 'C', x: 200, y: 250 },\n        { id: 'D', x: 350, y: 150 }\n    ];\n\n    const edges = [\n        { from: 'A', to: 'B', weight: 1 },\n        { from: 'A', to: 'C', weight: 4 },\n        { from: 'B', to: 'C', weight: 2 },\n        { from: 'B', to: 'D', weight: 5 },\n        { from: 'C', to: 'D', weight: 1 }\n    ];\n\n    nodes.forEach(node => {\n        const div = document.createElement('div');\n        div.classList.add('node');\n        div.style.left = node.x + 'px';\n        div.style.top = node.y + 'px';\n        div.innerText = node.id;\n        div.dataset.id = node.id;\n        graphContainer.appendChild(div);\n    });\n\n    edges.forEach(edge => {\n        const fromNode = nodes.find(n => n.id === edge.from);\n        const toNode = nodes.find(n => n.id === edge.to);\n        \n        const div = document.createElement('div');\n        div.classList.add('edge');\n        const startX = fromNode.x + 20;\n        const startY = fromNode.y + 20;\n        const endX = toNode.x + 20;\n        const endY = toNode.y + 20;\n\n        div.style.left = Math.min(startX, endX) + 'px';\n        div.style.top = Math.min(startY, endY) + 'px';\n        div.style.height = Math.sqrt((endX - startX) ** 2 + (endY - startY) ** 2) + 'px';\n        div.style.transform = `rotate(${Math.atan2(endY - startY, endX - startX) * (180 / Math.PI)}deg)`;\n        graphContainer.appendChild(div);\n    });\n\n    startButton.addEventListener('click', () => {\n        let iterations = 0;\n        const maxIterations = nodes.length - 1;\n        const interval = setInterval(() => {\n            if (iterations > maxIterations) {\n                clearInterval(interval);\n            } else {\n                nodes.forEach((node, index) => {\n                    setTimeout(() => {\n                        document.querySelectorAll('.node')[index].classList.add('active');\n                        document.querySelectorAll('.edge').forEach(edge => {\n                            edge.classList.add('active');\n                        });\n                    }, iterations * 1000);\n                });\n                iterations++;\n            }\n        }, 1000);\n    });\n</script>\n</body>\n</html>"
