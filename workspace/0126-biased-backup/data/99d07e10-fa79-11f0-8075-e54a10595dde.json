    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive DNS Exploration</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .control { margin: 10px 0; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive DNS Exploration</h1>\n\n<div class=\"control\">\n    <label for=\"domain\">Enter Domain Name:</label>\n    <input type=\"text\" id=\"domain\" placeholder=\"example.com\">\n</div>\n\n<div class=\"control\">\n    <label for=\"record-type\">Select Record Type:</label>\n    <select id=\"record-type\">\n        <option value=\"A\">A</option>\n        <option value=\"AAAA\">AAAA</option>\n        <option value=\"CNAME\">CNAME</option>\n        <option value=\"MX\">MX</option>\n        <option value=\"TXT\">TXT</option>\n    </select>\n</div>\n\n<div class=\"control\">\n    <button id=\"lookup-btn\">Look Up</button>\n</div>\n\n<div class=\"control\">\n    <label for=\"timeout\">Set Timeout (ms):</label>\n    <input type=\"number\" id=\"timeout\" value=\"1000\" min=\"500\">\n    <button id=\"set-timeout-btn\">Set Timeout</button>\n</div>\n\n<div class=\"control\">\n    <label for=\"ipv4\">IPV4 Address:</label>\n    <input type=\"text\" id=\"ipv4\" placeholder=\"e.g. 192.0.2.1\">\n</div>\n\n<div class=\"control\">\n    <button id=\"resolve-ip-btn\">Resolve Domain from IP</button>\n</div>\n\n<div class=\"control\">\n    <button id=\"clear-btn\">Clear History</button>\n</div>\n\n<h2>Output:</h2>\n<pre id=\"output\"></pre>\n\n<script>\n    const domainInput = document.getElementById('domain');\n    const recordTypeInput = document.getElementById('record-type');\n    const lookupButton = document.getElementById('lookup-btn');\n    const timeoutInput = document.getElementById('timeout');\n    const setTimeoutButton = document.getElementById('set-timeout-btn');\n    const ipv4Input = document.getElementById('ipv4');\n    const resolveIpButton = document.getElementById('resolve-ip-btn');\n    const clearButton = document.getElementById('clear-btn');\n    const outputArea = document.getElementById('output');\n\n    let timeoutValue = 1000;\n\n    function delay(ms) {\n        return new Promise(resolve => setTimeout(resolve, ms));\n    }\n\n    lookupButton.onclick = async () => {\n        const domain = domainInput.value;\n        const recordType = recordTypeInput.value;\n        outputArea.textContent += `Looking up ${recordType} record for ${domain}...\\n`;\n        await delay(timeoutValue);\n        // Simulate DNS response\n        outputArea.textContent += `Response for ${domain}: ${recordType} record found!\\n`;\n    };\n\n    setTimeoutButton.onclick = () => {\n        timeoutValue = parseInt(timeoutInput.value);\n        outputArea.textContent += `Timeout set to ${timeoutValue} ms.\\n`;\n    };\n\n    resolveIpButton.onclick = async () => {\n        const ipv4 = ipv4Input.value;\n        outputArea.textContent += `Resolving domain from IP ${ipv4}...\\n`;\n        await delay(timeoutValue);\n        // Simulate reverse DNS lookup response\n        outputArea.textContent += `Response: Domain for ${ipv4} found!\\n`;\n    };\n\n    clearButton.onclick = () => {\n        outputArea.textContent = '';\n    };\n</script>\n\n</body>\n</html>"
