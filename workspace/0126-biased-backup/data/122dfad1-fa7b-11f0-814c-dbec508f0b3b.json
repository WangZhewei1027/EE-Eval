    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Regression</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"text\"] {\n            width: 50%;\n        }\n        select {\n            width: 50%;\n        }\n        button {\n            width: 20%;\n            margin-left: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Linear Regression</h1>\n    <p>Linear Regression is a supervised learning algorithm used for predicting a continuous output variable based on one or more input features. It is widely used in machine learning and data science.</p>\n    <div id=\"controls\">\n        <label for=\"x\">X (input feature):</label>\n        <input type=\"text\" id=\"x\" value=\"1\">\n        <label for=\"y\">Y (output variable):</label>\n        <input type=\"text\" id=\"y\" value=\"2\">\n        <label for=\"slope\">Slope (m):</label>\n        <input type=\"number\" id=\"slope\" value=\"0\">\n        <label for=\"intercept\">Intercept (b):</label>\n        <input type=\"number\" id=\"intercept\" value=\"0\">\n        <button id=\"fit-button\">Fit</button>\n    </div>\n    <div id=\"output\">\n        <label for=\"x\">X (input feature):</label>\n        <input type=\"text\" id=\"x\" value=\"1\">\n        <label for=\"y\">Y (output variable):</label>\n        <input type=\"text\" id=\"y\" value=\"2\">\n        <label for=\"prediction\">Prediction:</label>\n        <input type=\"text\" id=\"prediction\" value=\"0\">\n    </div>\n    <script>\n        let x, y, slope, intercept;\n        let plotData = [];\n\n        // Initialize variables\n        function init() {\n            x = document.getElementById(\"x\").value;\n            y = document.getElementById(\"y\").value;\n            slope = document.getElementById(\"slope\").value;\n            intercept = document.getElementById(\"intercept\").value;\n            plotData = [];\n            updatePlot();\n        }\n\n        // Update plot\n        function updatePlot() {\n            for (let i = 0; i < plotData.length; i++) {\n                let xValue = parseFloat(x) + i;\n                let yValue = parseFloat(y) + i * slope + intercept;\n                plotData.push([xValue, yValue]);\n            }\n            plotData.sort((a, b) => a[0] - b[0]);\n            plotHTML = \"\";\n            for (let i = 0; i < plotData.length; i++) {\n                plotHTML += `<p>(${plotData[i][0]}, ${plotData[i][1]})</p>`;\n            }\n            document.getElementById(\"output\").innerHTML = plotHTML;\n        }\n\n        // Fit the model\n        function fit() {\n            let data = [];\n            for (let i = 0; i < plotData.length; i++) {\n                data.push([parseFloat(x) + i, parseFloat(y) + i * slope + intercept]);\n            }\n            let m = 0;\n            let b = 0;\n            for (let i = 0; i < data.length; i++) {\n                m += data[i][1] - (m + slope) * data[i][0];\n                b += data[i][1] - (m + slope) * data[i][0] - (data[i][0] * data[i][1]) / 2;\n            }\n            slope = m / data.length;\n            intercept = b - slope * data[0][0];\n            updatePlot();\n        }\n\n        // Add event listeners\n        document.getElementById(\"fit-button\").addEventListener(\"click\", fit);\n\n        // Initialize\n        init();\n    </script>\n</body>\n</html>"
