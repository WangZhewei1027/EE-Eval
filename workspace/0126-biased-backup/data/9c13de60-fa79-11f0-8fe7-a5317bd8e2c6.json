  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Insertion Sort — Interactive Demo</title>\n  <style>\n    /* Minimal layout only. No colors, no animations. Default browser styles apply. */\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif; margin: 12px; }\n    .panel { margin-bottom: 12px; padding: 6px; border: 1px solid #00000010; }\n    label { display: inline-block; margin-right: 6px; }\n    input[type=\"text\"], input[type=\"number\"], select { width: auto; }\n    pre { white-space: pre-wrap; }\n    .arrayview { font-family: monospace; }\n    button { margin: 2px; }\n    textarea { width: 100%; height: 80px; }\n  </style>\n</head>\n<body>\n\n<h1>Insertion Sort — Interactive Demo</h1>\n\n<div class=\"panel\" id=\"controlsPanel\">\n  <div>\n    <label>Array (comma separated):</label>\n    <input type=\"text\" id=\"arrayInput\" value=\"5,3,8,1,2\">\n    <button id=\"initBtn\">Initialize</button>\n    <button id=\"randomBtn\">Randomize</button>\n    <label>Size:</label><input type=\"number\" id=\"randSize\" value=\"8\" min=\"1\" style=\"width:50px;\">\n    <label>Min:</label><input type=\"number\" id=\"randMin\" value=\"0\" style=\"width:60px;\">\n    <label>Max:</label><input type=\"number\" id=\"randMax\" value=\"20\" style=\"width:60px;\">\n    <label>Seed (optional):</label><input type=\"text\" id=\"randSeed\" style=\"width:80px;\">\n  </div>\n\n  <div>\n    <label>Variant:</label>\n    <select id=\"variantSelect\">\n      <option value=\"standard\">Standard (shifting)</option>\n      <option value=\"binary\">Binary Insertion</option>\n      <option value=\"sentinel\">Sentinel (requires first element as sentinel)</option>\n    </select>\n\n    <label>Direction:</label>\n    <label><input type=\"radio\" name=\"dir\" value=\"asc\" checked> Ascending</label>\n    <label><input type=\"radio\" name=\"dir\" value=\"desc\"> Descending</label>\n\n    <label>Granularity:</label>\n    <label><input type=\"radio\" name=\"gran\" value=\"micro\" checked> Micro-step</label>\n    <label><input type=\"radio\" name=\"gran\" value=\"macro\"> Outer-iteration (macro)</label>\n  </div>\n\n  <div>\n    <label>Speed (ms per step):</label>\n    <input type=\"range\" id=\"speed\" min=\"10\" max=\"2000\" value=\"400\">\n    <span id=\"speedVal\">400</span> ms\n  </div>\n\n  <div>\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"backBtn\">Back</button>\n    <button id=\"playBtn\">Play</button>\n    <button id=\"pauseBtn\" disabled>Pause</button>\n    <button id=\"runToEndBtn\">Run to End</button>\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <button id=\"clearHistoryBtn\">Clear History</button>\n  </div>\n\n  <div>\n    <label>Breakpoint type:</label>\n    <select id=\"bpType\">\n      <option value=\"iEquals\">outer index i ==</option>\n      <option value=\"comparisonsGE\">comparisons >=</option>\n      <option value=\"valuePresent\">when value present equals</option>\n      <option value=\"stepGE\">steps >=</option>\n    </select>\n    <input type=\"number\" id=\"bpVal\" style=\"width:80px;\">\n    <button id=\"addBpBtn\">Add Breakpoint</button>\n    <button id=\"clearBpBtn\">Clear Breakpoints</button>\n    <div id=\"bpList\"></div>\n  </div>\n\n  <div>\n    <label><input type=\"checkbox\" id=\"logCheckbox\" checked> Enable log</label>\n    <label><input type=\"checkbox\" id=\"autoSnapshot\"> Auto-snapshot on each step</label>\n  </div>\n\n  <div>\n    <label>Export/Import State:</label>\n    <button id=\"exportBtn\">Export</button>\n    <button id=\"importBtn\">Import</button>\n    <input type=\"file\" id=\"importFile\" style=\"display:none;\">\n  </div>\n</div>\n\n<div class=\"panel\">\n  <h3>Array View</h3>\n  <div id=\"arrayView\" class=\"arrayview\"></div>\n  <div>\n    <label>Edit index:</label><input type=\"number\" id=\"editIndex\" style=\"width:60px;\">\n    <label>Value:</label><input type=\"text\" id=\"editValue\" style=\"width:80px;\">\n    <button id=\"applyEditBtn\">Apply</button>\n    <button id=\"pushBtn\">Push value</button>\n    <button id=\"popBtn\">Pop</button>\n    <button id=\"shuffleBtn\">Shuffle</button>\n    <button id=\"sortNativeBtn\">Sort Native (for setup)</button>\n  </div>\n  <div>\n    <label>Freeze index (prevent changes):</label><input type=\"number\" id=\"freezeIndex\" style=\"width:60px;\">\n    <button id=\"toggleFreezeBtn\">Toggle Freeze</button>\n    <div id=\"freezeList\"></div>\n  </div>\n</div>\n\n<div class=\"panel\">\n  <h3>Pseudo-code (current line in bold)</h3>\n  <pre id=\"pseudocode\">\n1. for i = 1 to n-1\n2.   key = A[i]\n3.   j = i - 1\n4.   while j >= 0 and A[j] > key\n5.     A[j+1] = A[j]\n6.     j = j - 1\n7.   A[j+1] = key\n  </pre>\n</div>\n\n<div class=\"panel\">\n  <h3>State, Counters & Controls</h3>\n  <div id=\"stateView\"></div>\n  <div>\n    <label>Micro-step debug output (short):</label>\n    <input type=\"checkbox\" id=\"showMicro\"> Show micro-step messages\n  </div>\n  <div>\n    <label>Snapshot name:</label><input type=\"text\" id=\"snapshotName\" style=\"width:160px;\">\n    <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n    <select id=\"snapshotList\"></select>\n    <button id=\"loadSnapshotBtn\">Load Snapshot</button>\n    <button id=\"delSnapshotBtn\">Delete Snapshot</button>\n  </div>\n</div>\n\n<div class=\"panel\">\n  <h3>Log</h3>\n  <div style=\"display:flex;\">\n    <button id=\"clearLogBtn\">Clear Log</button>\n    <button id=\"copyLogBtn\">Copy Log</button>\n  </div>\n  <textarea id=\"logArea\"></textarea>\n</div>\n\n<div class=\"panel\">\n  <h3>History (snapshots)</h3>\n  <div>\n    <button id=\"showHistoryBtn\">Show History Summary</button>\n    <button id=\"exportHistoryBtn\">Export History</button>\n  </div>\n  <pre id=\"historyView\"></pre>\n</div>\n\n<script>\n(function(){\n\n/*\n  Insertion Sort Interactive Demo\n  - Many interactive controls\n  - Micro and macro stepping\n  - Variants: standard, binary, sentinel\n  - Breakpoints, history, undo/redo, snapshots\n  - Extremely minimal visual style\n*/\n\n/* Utility functions */\nfunction deepCopy(obj) {\n  return JSON.parse(JSON.stringify(obj));\n}\nfunction randSeeded(s) {\n  // simple mulberry32\n  let h = 2166136261 ^ s;\n  return function() {\n    h += 0x6D2B79F5 | 0;\n    var t = Math.imul(h ^ h >>> 15, 1 | h);\n    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;\n    return ((t ^ t >>> 14) >>> 0) / 4294967296;\n  }\n}\nfunction assert(b,m){ if(!b) console.warn(\"assert fail\",m); }\n\n/* DOM elements */\nconst arrayInput = document.getElementById('arrayInput');\nconst initBtn = document.getElementById('initBtn');\nconst randomBtn = document.getElementById('randomBtn');\nconst randSize = document.getElementById('randSize');\nconst randMin = document.getElementById('randMin');\nconst randMax = document.getElementById('randMax');\nconst randSeed = document.getElementById('randSeed');\nconst variantSelect = document.getElementById('variantSelect');\nconst speed = document.getElementById('speed');\nconst speedVal = document.getElementById('speedVal');\nconst stepBtn = document.getElementById('stepBtn');\nconst backBtn = document.getElementById('backBtn');\nconst playBtn = document.getElementById('playBtn');\nconst pauseBtn = document.getElementById('pauseBtn');\nconst runToEndBtn = document.getElementById('runToEndBtn');\nconst undoBtn = document.getElementById('undoBtn');\nconst redoBtn = document.getElementById('redoBtn');\nconst clearHistoryBtn = document.getElementById('clearHistoryBtn');\nconst bpType = document.getElementById('bpType');\nconst bpVal = document.getElementById('bpVal');\nconst addBpBtn = document.getElementById('addBpBtn');\nconst clearBpBtn = document.getElementById('clearBpBtn');\nconst bpListDiv = document.getElementById('bpList');\nconst logCheckbox = document.getElementById('logCheckbox');\nconst autoSnapshotCheckbox = document.getElementById('autoSnapshot');\nconst exportBtn = document.getElementById('exportBtn');\nconst importBtn = document.getElementById('importBtn');\nconst importFile = document.getElementById('importFile');\n\nconst arrayView = document.getElementById('arrayView');\nconst editIndex = document.getElementById('editIndex');\nconst editValue = document.getElementById('editValue');\nconst applyEditBtn = document.getElementById('applyEditBtn');\nconst pushBtn = document.getElementById('pushBtn');\nconst popBtn = document.getElementById('popBtn');\nconst shuffleBtn = document.getElementById('shuffleBtn');\nconst sortNativeBtn = document.getElementById('sortNativeBtn');\nconst freezeIndex = document.getElementById('freezeIndex');\nconst toggleFreezeBtn = document.getElementById('toggleFreezeBtn');\nconst freezeListDiv = document.getElementById('freezeList');\n\nconst pseudocode = document.getElementById('pseudocode');\nconst stateView = document.getElementById('stateView');\nconst showMicro = document.getElementById('showMicro');\n\nconst snapshotName = document.getElementById('snapshotName');\nconst saveSnapshotBtn = document.getElementById('saveSnapshotBtn');\nconst snapshotList = document.getElementById('snapshotList');\nconst loadSnapshotBtn = document.getElementById('loadSnapshotBtn');\nconst delSnapshotBtn = document.getElementById('delSnapshotBtn');\n\nconst logArea = document.getElementById('logArea');\nconst clearLogBtn = document.getElementById('clearLogBtn');\nconst copyLogBtn = document.getElementById('copyLogBtn');\n\nconst historyView = document.getElementById('historyView');\nconst showHistoryBtn = document.getElementById('showHistoryBtn');\nconst exportHistoryBtn = document.getElementById('exportHistoryBtn');\n\n/* Internal model */\nlet model = {\n  arr: [],\n  n: 0,\n  i: 1,\n  j: null,\n  key: null,\n  lo: null, hi: null, mid: null, binaryPhase: null,\n  phase: 'idle', // idle, start, selectKey, compare, shift, insert, done, binarySearch, binaryShift\n  variant: 'standard',\n  dir: 'asc',\n  granularity: 'micro',\n  counts: { comparisons:0, assignments:0, shifts:0, swaps:0, steps:0 },\n  stepNumber: 0,\n  frozen: new Set(),\n  breakpoints: [],\n};\n\nlet playing = false;\nlet playTimer = null;\nlet history = []; // snapshots for stepping backward/forward (full snapshot list)\nlet historyPtr = -1; // points to current state in history array\nlet redoStack = [];\nlet snapshots = {}; // named snapshots\nlet microLogEnabled = true;\n\n/* Pseudocode lines mapping for highlighting */\nconst pseudocodeLines = [\n  'for i = 1 to n-1',\n  '  key = A[i]',\n  '  j = i - 1',\n  '  while j >= 0 and A[j] > key',\n  '    A[j+1] = A[j]',\n  '    j = j - 1',\n  '  A[j+1] = key'\n];\n\n/* Initialize UI values */\nspeedVal.textContent = speed.value;\n\n/* Render functions */\nfunction renderArrayView() {\n  const a = model.arr;\n  const n = a.length;\n  let parts = [];\n  for (let idx=0; idx<n; idx++) {\n    const val = a[idx];\n    let repr = String(val);\n    if (model.frozen.has(idx)) repr = '[' + repr + ']';\n    if (idx === model.i) repr = '(' + repr + ')'; // current i marker\n    if (model.key !== null && idx === (model._insertIndex || -999) && model.phase === 'insert') {\n      // not necessary but reserved\n    }\n    if (idx === model.j) repr = '<' + repr + '>'; // j marker\n    if (idx === (model.i-1) && model.phase==='selectKey') repr = '*' + repr + '*';\n    parts.push(repr);\n  }\n  // Mark sorted portion [0..i-1] for display\n  let display = '';\n  if (model.n > 0) {\n    let sortedPortion = a.slice(0, Math.max(0, Math.min(model.i, n)));\n    let rest = a.slice(Math.max(0, Math.min(model.i, n)));\n    display = '[' + sortedPortion.map((v,i)=>String(v)).join(', ') + '] ' + rest.map((v)=>String(v)).join(', ');\n  } else {\n    display = '';\n  }\n  // Also show explicit indices under values\n  let indices = a.map((_,i)=>i).join(' ');\n  arrayView.innerText = 'Array: ' + display + '\\nFull: ' + a.join(', ') + '\\nIndices: ' + indices;\n}\n\nfunction renderPseudoCode() {\n  // Map model.phase to a pseudocode line to bold\n  const map = {\n    'start': 0,\n    'selectKey': 1,\n    'setJ': 2,\n    'compare': 3,\n    'shift': 4,\n    'decJ': 5,\n    'insert': 6,\n    'binarySearch': 3,\n    'binaryShift': 4\n  };\n  let highlight = map[model.phase];\n  if (model.variant === 'sentinel') {\n    // sentinel slightly different but reuse lines\n  }\n  let text = pseudocodeLines.map((L, idx)=> {\n    if (idx === highlight) return ('> ' + L);\n    return '  ' + L;\n  }).join('\\n');\n  pseudocode.innerText = text;\n}\n\nfunction renderStateView() {\n  let s = [];\n  s.push('i: ' + String(model.i) + '   j: ' + String(model.j) + '   key: ' + String(model.key));\n  s.push('phase: ' + model.phase + '   variant: ' + model.variant + '   granularity: ' + model.granularity);\n  s.push('direction: ' + model.dir);\n  s.push('counts: comparisons=' + model.counts.comparisons + ', assignments=' + model.counts.assignments + ', shifts=' + model.counts.shifts + ', swaps=' + model.counts.swaps);\n  s.push('stepNumber: ' + model.stepNumber);\n  stateView.innerText = s.join('\\n');\n}\n\nfunction renderBPList() {\n  if (model.breakpoints.length === 0) {\n    bpListDiv.innerText = 'No breakpoints';\n    return;\n  }\n  bpListDiv.innerText = model.breakpoints.map((bp,i)=> (i+1)+'. ['+bp.type+'] ' + bp.value).join('\\n');\n}\n\nfunction renderFreezeList() {\n  const arr = Array.from(model.frozen).sort((a,b)=>a-b);\n  freezeListDiv.innerText = 'Frozen indices: ' + (arr.length? arr.join(', '): 'none');\n}\n\nfunction log(msg) {\n  if (!logCheckbox.checked) return;\n  const time = new Date().toLocaleTimeString();\n  logArea.value += '[' + time + '] ' + msg + '\\n';\n  logArea.scrollTop = logArea.scrollHeight;\n}\n\n/* History management */\nfunction pushHistorySnapshot(note) {\n  const snapshot = {\n    model: deepCopy({\n      arr: model.arr,\n      n: model.n,\n      i: model.i,\n      j: model.j,\n      key: model.key,\n      lo: model.lo, hi: model.hi, mid: model.mid,\n      phase: model.phase,\n      variant: model.variant,\n      dir: model.dir,\n      granularity: model.granularity,\n      counts: model.counts,\n      stepNumber: model.stepNumber,\n      frozen: Array.from(model.frozen)\n    }),\n    note: note || ('step ' + model.stepNumber),\n    time: new Date().toISOString()\n  };\n  // If pointer not at end, truncate redo history\n  if (historyPtr < history.length - 1) {\n    history = history.slice(0, historyPtr+1);\n  }\n  history.push(snapshot);\n  historyPtr = history.length - 1;\n  // clear redo stack\n  redoStack = [];\n  renderHistorySummary();\n}\n\nfunction restoreHistoryIndex(idx) {\n  if (idx < 0 || idx >= history.length) return;\n  const s = history[idx];\n  const m = s.model;\n  model.arr = m.arr.slice();\n  model.n = m.n;\n  model.i = m.i;\n  model.j = m.j;\n  model.key = m.key;\n  model.lo = m.lo; model.hi = m.hi; model.mid = m.mid;\n  model.phase = m.phase;\n  model.variant = m.variant;\n  model.dir = m.dir;\n  model.granularity = m.granularity;\n  model.counts = m.counts;\n  model.stepNumber = m.stepNumber;\n  model.frozen = new Set(m.frozen);\n  historyPtr = idx;\n  renderAll();\n}\n\n/* Snapshot management */\nfunction saveSnapshot(name) {\n  if (!name) name = ('snap_' + (new Date().toISOString()));\n  snapshots[name] = {\n    arr: model.arr.slice(),\n    model: deepCopy({\n      i: model.i, j: model.j, key: model.key, phase: model.phase, counts: model.counts, stepNumber: model.stepNumber\n    })\n  };\n  refreshSnapshotList();\n}\n\nfunction loadSnapshot(name) {\n  if (!snapshots[name]) {\n    alert('No snapshot named ' + name);\n    return;\n  }\n  model.arr = snapshots[name].arr.slice();\n  model.n = model.arr.length;\n  model.i = snapshots[name].model.i || 1;\n  model.j = snapshots[name].model.j || null;\n  model.key = snapshots[name].model.key || null;\n  model.phase = snapshots[name].model.phase || 'idle';\n  model.counts = snapshots[name].model.counts || {comparisons:0,assignments:0,shifts:0,swaps:0};\n  model.stepNumber = snapshots[name].model.stepNumber || 0;\n  pushHistorySnapshot('restore snapshot ' + name);\n  renderAll();\n}\n\nfunction refreshSnapshotList() {\n  snapshotList.innerHTML = '';\n  for (let k in snapshots) {\n    const opt = document.createElement('option');\n    opt.value = k;\n    opt.text = k;\n    snapshotList.add(opt);\n  }\n}\n\n/* Algorithm controls */\n\n/* Comparator based on direction */\nfunction needShiftCompare(arr_j, key) {\n  // returns true if arr_j should be moved to the right (arr_j > key for ascending)\n  if (model.dir === 'asc') return arr_j > key;\n  return arr_j < key;\n}\n\nfunction stepMicro() {\n  // single smallest unit step (compare/shift/insert)\n  if (model.phase === 'done') {\n    log('Already finished.');\n    return false;\n  }\n  if (model.phase === 'idle') {\n    // initialize outer start\n    if (model.n <= 1) {\n      model.phase = 'done';\n      pushHistorySnapshot('done');\n      renderAll();\n      log('Done (array length <= 1).');\n      return false;\n    }\n    model.phase = 'start';\n    pushHistorySnapshot('enter start');\n    renderAll();\n    return true;\n  }\n  // If sentinel variant requires special initial setup\n  if (model.variant === 'sentinel' && model.phase === 'start' && model.i === 1) {\n    // ensure first element is sentinel smaller than all (for ascending)\n    // We'll not auto-modify; user can set element\n  }\n\n  // Normal micro-step state machine\n  if (model.phase === 'start') {\n    if (model.i >= model.n) {\n      model.phase = 'done';\n      model.stepNumber++;\n      pushHistorySnapshot('finished');\n      renderAll();\n      log('Sorting finished.');\n      return false;\n    }\n    // capture key\n    model.key = model.arr[model.i];\n    model.j = model.i - 1;\n    model.phase = 'selectKey';\n    model.stepNumber++;\n    pushHistorySnapshot('select key at i=' + model.i);\n    renderAll();\n    log('Selected key=' + model.key + ' at i=' + model.i);\n    return true;\n  }\n\n  if (model.phase === 'selectKey') {\n    // set j and move to compare\n    model.phase = 'compare';\n    pushHistorySnapshot('set j=' + model.j);\n    renderAll();\n    return true;\n  }\n\n  if (model.phase === 'compare') {\n    if (model.variant === 'binary') {\n      // initialize binary search for insertion point: lo = 0, hi = i-1\n      if (model.binaryPhase !== 'searching') {\n        model.lo = 0;\n        model.hi = model.i - 1;\n        model.binaryPhase = 'searching';\n        pushHistorySnapshot('begin binary search i=' + model.i);\n        renderAll();\n        log('Binary search: starting lo=' + model.lo + ' hi=' + model.hi + ' key=' + model.key);\n        return true;\n      }\n      // binary micro-step: if lo > hi we're done\n      if (model.lo > model.hi) {\n        model._insertIndex = model.lo;\n        model.binaryPhase = 'shifting';\n        pushHistorySnapshot('binary found pos=' + model._insertIndex);\n        renderAll();\n        log('Binary found position ' + model._insertIndex);\n        return true;\n      } else {\n        model.mid = Math.floor((model.lo + model.hi) / 2);\n        model.counts.comparisons++;\n        model.stepNumber++;\n        pushHistorySnapshot('binary compare mid=' + model.mid);\n        renderAll();\n        log('Binary compare key ' + model.key + ' with A['+model.mid+']=' + model.arr[model.mid]);\n        // Compare arr[mid] and key, adjust lo/hi\n        if (needShiftCompare(model.arr[model.mid], model.key)) {\n          // arr[mid] > key for ascending -> search left\n          model.hi = model.mid - 1;\n          log('Binary: move hi -> ' + model.hi);\n        } else {\n          model.lo = model.mid + 1;\n          log('Binary: move lo -> ' + model.lo);\n        }\n        return true;\n      }\n    } else {\n      // standard variant compare\n      if (model.j >= 0) {\n        model.counts.comparisons++;\n        model.stepNumber++;\n        pushHistorySnapshot('compare j=' + model.j + ' key=' + model.key);\n        renderAll();\n        const shouldShift = needShiftCompare(model.arr[model.j], model.key);\n        log('Compare A['+model.j+']=' + model.arr[model.j] + ' and key=' + model.key + ' -> shift? ' + shouldShift);\n        if (shouldShift) {\n          model.phase = 'shift';\n          return true;\n        } else {\n          model.phase = 'insert';\n          return true;\n        }\n      } else {\n        model.phase = 'insert';\n        pushHistorySnapshot('compare j < 0 -> insert');\n        renderAll();\n        return true;\n      }\n    }\n  }\n\n  if (model.phase === 'shift') {\n    // perform a shift: A[j+1] = A[j]\n    if (model.frozen.has(model.j+1)) {\n      log('Index ' + (model.j+1) + ' frozen; cannot shift. Breaking.');\n      model.phase = 'done';\n      pushHistorySnapshot('blocked by freeze');\n      renderAll();\n      return false;\n    }\n    model.arr[model.j+1] = model.arr[model.j];\n    model.counts.assignments++;\n    model.counts.shifts++;\n    model.stepNumber++;\n    pushHistorySnapshot('shift j=' + model.j);\n    log('Shifted A['+(model.j)+'] to A['+(model.j+1)+']');\n    // After shift, decrement j and continue compare\n    model.phase = 'compare';\n    model.j = model.j - 1;\n    return true;\n  }\n\n  if (model.phase === 'insert') {\n    // perform final insertion: A[j+1] = key\n    const pos = model.j + 1;\n    if (model.frozen.has(pos)) {\n      log('Insert position ' + pos + ' frozen; cannot insert. Aborting.');\n      model.phase = 'done';\n      pushHistorySnapshot('blocked insert');\n      renderAll();\n      return false;\n    }\n    model.arr[pos] = model.key;\n    model.counts.assignments++;\n    model.stepNumber++;\n    pushHistorySnapshot('insert at ' + pos);\n    log('Inserted key ' + model.key + ' at position ' + pos);\n    // Clear key and move i\n    model.key = null;\n    model.i++;\n    model.j = null;\n    model.phase = 'start';\n    // reset binaryPhase if any\n    model.binaryPhase = null;\n    model.lo = model.hi = model.mid = null;\n    return true;\n  }\n\n  if (model.phase === 'done') {\n    return false;\n  }\n\n  return false;\n}\n\nfunction stepMacro() {\n  // Macro: perform one full outer iteration (i.e., entire insertion for current i)\n  if (model.phase === 'done') {\n    log('Already finished.');\n    return false;\n  }\n  if (model.i >= model.n) {\n    model.phase = 'done';\n    pushHistorySnapshot('done');\n    renderAll();\n    log('Done.');\n    return false;\n  }\n  // perform outer iteration\n  pushHistorySnapshot('macro iteration start i=' + model.i);\n  model.key = model.arr[model.i];\n  let j = model.i - 1;\n  model.counts.assignments++; // capturing key\n  model.stepNumber++;\n  log('Macro: key=' + model.key);\n  if (model.variant === 'binary') {\n    // find insert position\n    let lo = 0, hi = model.i - 1;\n    while (lo <= hi) {\n      const mid = Math.floor((lo+hi)/2);\n      model.counts.comparisons++;\n      if (needShiftCompare(model.arr[mid], model.key)) {\n        hi = mid - 1;\n      } else {\n        lo = mid + 1;\n      }\n    }\n    const pos = lo;\n    // shift\n    for (let k = model.i - 1; k >= pos; k--) {\n      if (model.frozen.has(k+1)) {\n        log('Macro blocked by freeze at ' + (k+1));\n        model.phase = 'done';\n        pushHistorySnapshot('blocked macro freeze');\n        renderAll();\n        return false;\n      }\n      model.arr[k+1] = model.arr[k];\n      model.counts.assignments++;\n      model.counts.shifts++;\n    }\n    model.arr[pos] = model.key;\n    model.counts.assignments++;\n    log('Macro: inserted at ' + pos);\n    model.key = null;\n    model.i++;\n    model.phase = 'start';\n    pushHistorySnapshot('macro iteration end i=' + (model.i-1));\n    renderAll();\n    return true;\n  } else {\n    // standard shifting\n    while (j >= 0 && needShiftCompare(model.arr[j], model.key)) {\n      if (model.frozen.has(j+1)) {\n        log('Macro blocked by freeze at ' + (j+1));\n        model.phase = 'done';\n        pushHistorySnapshot('blocked macro freeze');\n        renderAll();\n        return false;\n      }\n      model.arr[j+1] = model.arr[j];\n      model.counts.assignments++;\n      model.counts.shifts++;\n      model.counts.comparisons++; // the condition check\n      j--;\n    }\n    // final comparison that fails when j<0 or condition false might not be counted above, ensure it's accounted\n    if (j >= 0) model.counts.comparisons++;\n    model.arr[j+1] = model.key;\n    model.counts.assignments++;\n    model.key = null;\n    model.i++;\n    model.phase = 'start';\n    pushHistorySnapshot('macro iteration end i=' + (model.i-1));\n    renderAll();\n    log('Macro: inserted at ' + (j+1));\n    return true;\n  }\n}\n\n/* Stepping control wrapper */\nfunction stepForward() {\n  if (checkBreakpointsBeforeStep()) {\n    log('Breakpoint triggered before step; halting.');\n    return false;\n  }\n\n  pushHistorySnapshot('pre-step snapshot');\n  let progressed = false;\n  if (model.granularity === 'micro') {\n    progressed = stepMicro();\n  } else {\n    progressed = stepMacro();\n  }\n  if (autoSnapshotCheckbox.checked) {\n    saveSnapshot('auto_' + (new Date().toISOString()));\n  }\n  renderAll();\n  checkBreakpointsAfterStep();\n  return progressed;\n}\n\nfunction stepBackward() {\n  // pop history if possible to go back one action\n  if (historyPtr <= 0) {\n    log('No earlier history to go back to.');\n    return;\n  }\n  historyPtr--;\n  restoreHistoryIndex(historyPtr);\n  renderAll();\n  log('Stepped back to history index ' + historyPtr);\n}\n\n/* Undo/Redo for user-level commands (not micro steps) */\nfunction doUndo() {\n  if (historyPtr <= 0) { log('Nothing to undo'); return; }\n  redoStack.push(history[historyPtr]);\n  historyPtr--;\n  restoreHistoryIndex(historyPtr);\n  log('Undo: restored history index ' + historyPtr);\n}\n\nfunction doRedo() {\n  if (redoStack.length === 0) { log('Nothing to redo'); return; }\n  const s = redoStack.pop();\n  history.push(s);\n  historyPtr = history.length - 1;\n  restoreHistoryIndex(historyPtr);\n  log('Redo: restored next state at history index ' + historyPtr);\n}\n\n/* Breakpoints */\nfunction addBreakpoint(type, value) {\n  model.breakpoints.push({ type: type, value: value });\n  renderBPList();\n  log('Added breakpoint [' + type + '] ' + value);\n}\nfunction clearBreakpoints() {\n  model.breakpoints = [];\n  renderBPList();\n  log('Cleared breakpoints');\n}\nfunction checkBreakpointCondition(bp) {\n  if (!bp) return false;\n  if (bp.type === 'iEquals') {\n    return model.i === Number(bp.value);\n  }\n  if (bp.type === 'comparisonsGE') {\n    return model.counts.comparisons >= Number(bp.value);\n  }\n  if (bp.type === 'valuePresent') {\n    return model.arr.includes(Number(bp.value));\n  }\n  if (bp.type === 'stepGE') {\n    return model.stepNumber >= Number(bp.value);\n  }\n  return false;\n}\nfunction checkBreakpointsBeforeStep() {\n  for (let bp of model.breakpoints) {\n    if (bp.type === 'iEquals') {\n      if (model.i === Number(bp.value)) return true;\n    } else if (bp.type === 'comparisonsGE') {\n      if (model.counts.comparisons >= Number(bp.value)) return true;\n    } else if (bp.type === 'valuePresent') {\n      if (model.arr.includes(Number(bp.value))) return true;\n    } else if (bp.type === 'stepGE') {\n      if (model.stepNumber >= Number(bp.value)) return true;\n    }\n  }\n  return false;\n}\nfunction checkBreakpointsAfterStep() {\n  for (let bp of model.breakpoints) {\n    if (checkBreakpointCondition(bp)) {\n      log('Breakpoint hit: ' + bp.type + ' ' + bp.value);\n      doPause();\n      return true;\n    }\n  }\n  return false;\n}\n\n/* Play/Auto */\nfunction doPlay() {\n  if (playing) return;\n  playing = true;\n  playBtn.disabled = true;\n  pauseBtn.disabled = false;\n  const delay = Number(speed.value);\n  playTimer = setInterval(()=> {\n    const progressed = stepForward();\n    if (!progressed || model.phase === 'done') {\n      doPause();\n    }\n  }, delay);\n  log('Started playing at ' + delay + ' ms/step');\n}\n\nfunction doPause() {\n  if (!playing) return;\n  playing = false;\n  playBtn.disabled = false;\n  pauseBtn.disabled = true;\n  clearInterval(playTimer);\n  playTimer = null;\n  log('Paused');\n}\n\n/* Run to end loop (blocks UI but uses timeouts) */\nfunction runToEnd() {\n  doPause();\n  function runChunk() {\n    let steps = 0;\n    while (steps < 1000 && model.phase !== 'done') {\n      const progressed = stepForward();\n      if (!progressed) break;\n      steps++;\n    }\n    if (model.phase !== 'done') {\n      setTimeout(runChunk, 0);\n    } else {\n      log('Run to end completed.');\n      renderAll();\n    }\n  }\n  runChunk();\n}\n\n/* Initialization and helpers */\nfunction initializeFromInput() {\n  // parse array input\n  const text = arrayInput.value.trim();\n  let arr = [];\n  if (text.length > 0) {\n    arr = text.split(',').map(s => {\n      const t = s.trim();\n      if (t === '') return 0;\n      const n = Number(t);\n      return isNaN(n) ? t : n;\n    });\n  }\n  model.arr = arr;\n  model.n = model.arr.length;\n  model.i = 1;\n  model.j = null;\n  model.key = null;\n  model.phase = 'idle';\n  model.counts = {comparisons:0,assignments:0,shifts:0,swaps:0};\n  model.stepNumber = 0;\n  model.frozen = new Set();\n  model.breakpoints = [];\n  model.variant = variantSelect.value;\n  // direction\n  model.dir = document.querySelector('input[name=\"dir\"]:checked').value;\n  model.granularity = document.querySelector('input[name=\"gran\"]:checked').value;\n  history = [];\n  historyPtr = -1;\n  redoStack = [];\n  pushHistorySnapshot('initialized');\n  renderAll();\n  log('Initialized array with ' + model.arr.length + ' elements.');\n}\n\n/* Randomize generation */\nfunction generateRandom() {\n  let size = Number(randSize.value) || 8;\n  let min = Number(randMin.value) || 0;\n  let max = Number(randMax.value) || (min + 20);\n  let seedText = randSeed.value.trim();\n  let rnd = Math.random;\n  if (seedText !== '') {\n    let s = 0;\n    for (let ch of seedText) s = s * 31 + ch.charCodeAt(0);\n    rnd = randSeeded(s >>> 0);\n  }\n  let arr = [];\n  for (let i=0;i<size;i++) {\n    const v = Math.floor(rnd() * (max - min + 1)) + min;\n    arr.push(v);\n  }\n  arrayInput.value = arr.join(', ');\n  initializeFromInput();\n}\n\n/* Edit array utilities */\nfunction applyEdit() {\n  const idx = Number(editIndex.value);\n  if (isNaN(idx)) { alert('Invalid index'); return; }\n  if (idx < 0 || idx >= model.arr.length) { alert('Index out of range'); return; }\n  if (model.frozen.has(idx)) { alert('Index frozen'); return; }\n  let val = editValue.value;\n  const n = Number(val);\n  if (!isNaN(n)) val = n;\n  model.arr[idx] = val;\n  pushHistorySnapshot('edit index ' + idx);\n  renderAll();\n  log('Edited A['+idx+'] = ' + val);\n}\n\nfunction pushValue() {\n  let val = editValue.value;\n  const n = Number(val);\n  if (!isNaN(n)) val = n;\n  model.arr.push(val);\n  model.n = model.arr.length;\n  pushHistorySnapshot('push value ' + val);\n  renderAll();\n  log('Pushed value ' + val);\n}\n\nfunction popValue() {\n  if (model.arr.length === 0) return;\n  if (model.frozen.has(model.arr.length-1)) { alert('Last index frozen'); return; }\n  const v = model.arr.pop();\n  model.n = model.arr.length;\n  pushHistorySnapshot('pop value ' + v);\n  renderAll();\n  log('Popped value ' + v);\n}\n\nfunction shuffleArray() {\n  for (let i = model.arr.length - 1; i > 0; i--) {\n    const j = Math.floor(Math.random() * (i + 1));\n    [model.arr[i], model.arr[j]] = [model.arr[j], model.arr[i]];\n  }\n  pushHistorySnapshot('shuffle');\n  renderAll();\n  log('Shuffled array');\n}\n\n/* Freeze toggling */\nfunction toggleFreeze(idx) {\n  if (model.frozen.has(idx)) {\n    model.frozen.delete(idx);\n    log('Unfroze index ' + idx);\n  } else {\n    model.frozen.add(idx);\n    log('Froze index ' + idx);\n  }\n  renderFreezeList();\n}\n\n/* Export/Import */\nfunction exportState() {\n  const data = {\n    model: model,\n    history: history,\n    snapshots: snapshots\n  };\n  const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'insertion_demo_export.json';\n  a.click();\n  URL.revokeObjectURL(url);\n  log('Exported state to file.');\n}\n\nfunction importStateFile(file) {\n  const reader = new FileReader();\n  reader.onload = function(e) {\n    try {\n      const data = JSON.parse(e.target.result);\n      // restore basic model\n      if (data.model && data.model.arr) {\n        model.arr = data.model.arr.slice();\n        model.n = model.arr.length;\n        model.i = data.model.i || 1;\n        model.j = data.model.j || null;\n        model.key = data.model.key || null;\n        model.phase = data.model.phase || 'idle';\n        model.counts = data.model.counts || {comparisons:0,assignments:0,shifts:0,swaps:0};\n        model.stepNumber = data.model.stepNumber || 0;\n        model.frozen = new Set(data.model.frozen || []);\n      }\n      if (data.history) {\n        history = data.history;\n        historyPtr = history.length - 1;\n      }\n      if (data.snapshots) snapshots = data.snapshots;\n      refreshSnapshotList();\n      pushHistorySnapshot('import restore');\n      renderAll();\n      log('Imported state from file.');\n    } catch (err) {\n      alert('Failed to import: ' + err);\n    }\n  };\n  reader.readAsText(file);\n}\n\n/* History rendering */\nfunction renderHistorySummary() {\n  historyView.innerText = history.map((h,i)=> i + ': ' + h.note + ' @ ' + h.time).join('\\n');\n}\n\n/* High-level UI rendering */\nfunction renderAll() {\n  renderArrayView();\n  renderPseudoCode();\n  renderStateView();\n  renderBPList();\n  renderFreezeList();\n  renderHistorySummary();\n  refreshSnapshotList();\n}\n\n/* Event wiring */\ninitBtn.addEventListener('click', ()=> initializeFromInput());\nrandomBtn.addEventListener('click', ()=> generateRandom());\nspeed.addEventListener('input', ()=> { speedVal.textContent = speed.value; });\nstepBtn.addEventListener('click', ()=> stepForward());\nbackBtn.addEventListener('click', ()=> stepBackward());\nplayBtn.addEventListener('click', ()=> doPlay());\npauseBtn.addEventListener('click', ()=> doPause());\nrunToEndBtn.addEventListener('click', ()=> runToEnd());\nundoBtn.addEventListener('click', ()=> doUndo());\nredoBtn.addEventListener('click', ()=> doRedo());\nclearHistoryBtn.addEventListener('click', ()=> { history = []; historyPtr = -1; renderHistorySummary(); log('Cleared history'); });\n\naddBpBtn.addEventListener('click', ()=> {\n  addBreakpoint(bpType.value, bpVal.value);\n});\nclearBpBtn.addEventListener('click', ()=> clearBreakpoints());\n\nexportBtn.addEventListener('click', ()=> exportState());\nimportBtn.addEventListener('click', ()=> importFile.click());\nimportFile.addEventListener('change', (ev)=> {\n  const f = ev.target.files[0];\n  if (f) importStateFile(f);\n  importFile.value = '';\n});\n\napplyEditBtn.addEventListener('click', ()=> applyEdit());\npushBtn.addEventListener('click', ()=> pushValue());\npopBtn.addEventListener('click', ()=> popValue());\nshuffleBtn.addEventListener('click', ()=> { shuffleArray(); });\nsortNativeBtn.addEventListener('click', ()=> { model.arr.sort((a,b)=> (typeof a==='number' && typeof b==='number') ? a-b : String(a).localeCompare(String(b))); pushHistorySnapshot('native sort'); renderAll(); });\n\ntoggleFreezeBtn.addEventListener('click', ()=> {\n  const idx = Number(freezeIndex.value);\n  if (isNaN(idx)) { alert('Invalid'); return; }\n  if (idx < 0 || idx >= model.arr.length) { alert('Index out of range'); return; }\n  toggleFreeze(idx);\n});\n\nsaveSnapshotBtn.addEventListener('click', ()=> {\n  const name = snapshotName.value.trim() || ('snap_' + new Date().toISOString());\n  saveSnapshot(name);\n  log('Saved snapshot ' + name);\n});\nloadSnapshotBtn.addEventListener('click', ()=> {\n  const name = snapshotList.value;\n  if (!name) { alert('Select snapshot'); return; }\n  loadSnapshot(name);\n});\ndelSnapshotBtn.addEventListener('click', ()=> {\n  const name = snapshotList.value;\n  if (!name) { alert('Select snapshot'); return; }\n  delete snapshots[name];\n  refreshSnapshotList();\n  log('Deleted snapshot ' + name);\n});\n\nclearLogBtn.addEventListener('click', ()=> { logArea.value = ''; });\ncopyLogBtn.addEventListener('click', ()=> { navigator.clipboard && navigator.clipboard.writeText(logArea.value); });\n\nshowHistoryBtn.addEventListener('click', ()=> renderHistorySummary());\nexportHistoryBtn.addEventListener('click', ()=> {\n  const blob = new Blob([JSON.stringify(history, null, 2)], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'insertion_history.json';\n  a.click();\n  URL.revokeObjectURL(url);\n  log('Exported history.');\n});\n\n/* Undo/Redo keyboard shortcuts */\ndocument.addEventListener('keydown', (ev)=> {\n  if (ev.ctrlKey && ev.key === 'z') {\n    doUndo();\n  }\n  if (ev.ctrlKey && ev.key === 'y') {\n    doRedo();\n  }\n});\n\n/* Init default */\ninitializeFromInput();\nrenderAll();\n\n/* Small helpers for long-run UI interactions */\nfunction checkBreakpointsBeforeStep() {\n  // If any breakpoint is satisfied before next action, stop and return true\n  for (let bp of model.breakpoints) {\n    if (bp.type === 'iEquals' && model.i === Number(bp.value)) return true;\n    if (bp.type === 'comparisonsGE' && model.counts.comparisons >= Number(bp.value)) return true;\n    if (bp.type === 'valuePresent' && model.arr.includes(Number(bp.value))) return true;\n    if (bp.type === 'stepGE' && model.stepNumber >= Number(bp.value)) return true;\n  }\n  return false;\n}\n\n/* Expose some quick API on window for debugging (optional) */\nwindow.__insertionModel = model;\nwindow.__stepForward = stepForward;\nwindow.__stepBackward = stepBackward;\n\n})(); // end closure\n</script>\n\n</body>\n</html>"
