    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Depth-First Search — A Visual Poem</title>\n<style>\n  :root{\n    --bg-1: #071428;\n    --bg-2: #0b2233;\n    --card: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.65);\n    --accent: #55f0ff;\n    --accent-2: #9d77ff;\n    --accent-3: #ff6fb3;\n    --glass-2: rgba(255,255,255,0.02);\n    --neon: rgba(85,240,255,0.12);\n    --success: #7ef2c7;\n    --shadow: 0 10px 30px rgba(2,6,23,0.7);\n    font-synthesis: none;\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 700px at 10% 10%, rgba(157,119,255,0.08), transparent 10%),\n                radial-gradient(900px 500px at 90% 80%, rgba(255,111,179,0.05), transparent 10%),\n                linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n    color: #eaf6ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  .stage{\n    max-width:1200px;\n    margin:48px auto;\n    padding:36px;\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:28px;\n    align-items:start;\n  }\n\n  header{\n    grid-column:1 / -1;\n    display:flex;\n    align-items:center;\n    gap:20px;\n  }\n\n  .brand{\n    width:84px;\n    height:84px;\n    border-radius:16px;\n    background: linear-gradient(135deg,var(--accent-2),var(--accent-3));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 6px 30px rgba(157,119,255,0.12), inset 0 -6px 24px rgba(255,255,255,0.06);\n    transform: rotate(-10deg);\n    flex-shrink:0;\n  }\n  .brand svg{filter:drop-shadow(0 6px 18px rgba(0,0,0,0.4));}\n\n  h1{\n    font-size:20px;\n    letter-spacing:0.4px;\n    margin:0;\n    color: #f7fbff;\n  }\n  p.lead{\n    margin:4px 0 0 0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Canvas Card */\n  .card{\n    border-radius:20px;\n    padding:24px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    min-height:520px;\n    position:relative;\n    overflow:hidden;\n    backdrop-filter: blur(6px);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  /* Decorative blobs */\n  .card::before, .card::after{\n    content:\"\";\n    position:absolute;\n    border-radius:50%;\n    filter: blur(40px);\n    opacity:0.9;\n    pointer-events:none;\n  }\n  .card::before{\n    width:420px;height:420px;\n    background: radial-gradient(circle at 30% 30%, rgba(85,240,255,0.12), transparent 30%), linear-gradient(90deg, rgba(157,119,255,0.06), rgba(255,111,179,0.04));\n    top:-120px; left:-120px;\n    transform: rotate(12deg);\n  }\n  .card::after{\n    width:320px;height:320px;\n    background: radial-gradient(circle at 70% 70%, rgba(157,119,255,0.10), transparent 20%), linear-gradient(90deg, rgba(85,240,255,0.02), rgba(255,111,179,0.02));\n    bottom:-100px; right:-140px;\n  }\n\n  /* Graph area */\n  .canvas{\n    width:100%;\n    height:520px;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  svg{\n    width:100%;\n    height:100%;\n    overflow:visible;\n  }\n\n  /* Node style */\n  .node{\n    cursor:default;\n    transition: transform 420ms cubic-bezier(.2,.9,.25,1), filter 420ms;\n    filter: drop-shadow(0 8px 24px rgba(7,18,40,0.6));\n  }\n  .node .core{\n    transform-origin:center;\n    transition: r 420ms, fill 420ms, stroke-width 420ms, opacity 420ms;\n    stroke: rgba(255,255,255,0.08);\n  }\n  .node .glow{\n    pointer-events:none;\n    opacity:0;\n    transition: opacity 420ms;\n    filter: blur(8px);\n  }\n  .node.visited .glow{ opacity:1; }\n  .node.visited .core{ stroke-width:2.5; }\n\n  .label{\n    font-size:12px;\n    fill: #eaf6ff;\n    text-anchor:middle;\n    dominant-baseline:middle;\n    pointer-events:none;\n    user-select:none;\n  }\n  .sublabel{\n    font-size:10px;\n    fill: var(--muted);\n    text-anchor:middle;\n    dominant-baseline:middle;\n    pointer-events:none;\n  }\n\n  /* Edge style */\n  .edge{\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:4;\n    fill:none;\n    transition: stroke 420ms, stroke-width 420ms, opacity 420ms;\n    stroke-linecap:round;\n  }\n  .edge.highlight{\n    stroke: url(#edgeGrad);\n    stroke-width:6;\n    opacity:1;\n    filter: drop-shadow(0 8px 28px rgba(85,240,255,0.12));\n  }\n\n  /* Traveler dot */\n  #traveler{\n    fill: var(--accent);\n    stroke: white;\n    stroke-width:1.4;\n    opacity:0;\n    filter: drop-shadow(0 6px 20px rgba(85,240,255,0.14));\n    transition: opacity 150ms;\n  }\n\n  /* Side panel */\n  .side{\n    border-radius:18px;\n    padding:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    min-height:520px;\n    box-shadow: var(--shadow);\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    position:relative;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:4px;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    border-radius:12px;\n    padding:10px 14px;\n    font-weight:600;\n    font-size:13px;\n    cursor:pointer;\n    color: #051226;\n    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-2) 100%);\n    box-shadow: 0 6px 20px rgba(85,240,255,0.08), inset 0 -6px 18px rgba(255,255,255,0.06);\n    transition: transform 160ms ease, box-shadow 160ms;\n    flex:1;\n  }\n  .btn:active{ transform: translateY(2px) }\n  .btn.secondary{\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color: var(--muted);\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow:none;\n    flex:0;\n    padding:10px 12px;\n  }\n\n  .meta{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:8px;\n  }\n  .meta .title{\n    font-weight:700;\n    font-size:15px;\n    color:#f5fbff;\n  }\n  .meta .muted{\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  /* Stack visualization */\n  .stack{\n    margin-top:8px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:12px;\n    min-height:160px;\n    display:flex;\n    flex-direction:column-reverse;\n    gap:8px;\n    border:1px solid rgba(255,255,255,0.02);\n    overflow:hidden;\n  }\n\n  .frame{\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px;\n    padding:10px 12px;\n    display:flex;\n    align-items:center;\n    gap:10px;\n    justify-content:space-between;\n    color:var(--muted);\n    font-weight:600;\n    transform-origin:center;\n    transition: transform 360ms cubic-bezier(.2,.9,.25,1), opacity 360ms;\n    box-shadow: 0 6px 30px rgba(6,12,22,0.35), inset 0 -6px 16px rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  .frame .node-badge{\n    width:36px;\n    height:36px;\n    border-radius:10px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color: #eaf6ff;\n    font-weight:700;\n    font-size:13px;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .frame.enter{ transform: translateY(8px) scale(0.98); opacity:0; animation: enter 420ms forwards; }\n  .frame.pop{ transform: translateY(-12px) scale(0.98); opacity:0; animation: pop 420ms forwards; }\n  @keyframes enter{\n    from { transform: translateY(10px) scale(0.98); opacity:0; }\n    to { transform: translateY(0) scale(1); opacity:1; }\n  }\n  @keyframes pop{\n    from { transform: translateY(0) scale(1); opacity:1; }\n    to { transform: translateY(-10px) scale(0.98); opacity:0; }\n  }\n\n  .pseudocode{\n    margin-top:8px;\n    border-radius:12px;\n    padding:12px;\n    background: linear-gradient(180deg, rgba(2,5,12,0.45), rgba(2,5,12,0.35));\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Segoe UI Mono\", monospace;\n    color: #bfefff;\n    font-size:12px;\n    line-height:1.5;\n    border: 1px solid rgba(85,240,255,0.06);\n  }\n\n  .muted-note{\n    font-size:12px;\n    color:var(--muted);\n    margin-top:10px;\n  }\n\n  footer{\n    grid-column:1 / -1;\n    display:flex;\n    justify-content:center;\n    margin-top:8px;\n    color:var(--muted);\n    font-size:12px;\n    gap:8px;\n    align-items:center;\n  }\n\n  /* subtle responsiveness */\n  @media (max-width:980px){\n    .stage{ grid-template-columns:1fr; padding:20px; }\n    .side{ order:2; }\n    .card{ order:1; min-height:420px; }\n    .canvas{ height:420px; }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"stage\" role=\"main\" aria-label=\"Depth-First Search visualization\">\n    <header>\n      <div class=\"brand\" aria-hidden=\"true\">\n        <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n          <path d=\"M12 2L15.5 8.5L22 12L15.5 15.5L12 22L8.5 15.5L2 12L8.5 8.5L12 2Z\" fill=\"white\" opacity=\"0.12\"/>\n          <path d=\"M12 6.5L14.3 9.6L17.8 11.1L14.3 12.7L12 15.8L9.7 12.7L6.2 11.1L9.7 9.6L12 6.5Z\" fill=\"white\" />\n        </svg>\n      </div>\n      <div>\n        <h1>Depth-First Search (DFS)</h1>\n        <p class=\"lead\">Traverse deep into a graph before backtracking — watch the stack flow and edges illuminate.</p>\n      </div>\n    </header>\n\n    <section class=\"card\" aria-hidden=\"false\">\n      <div class=\"canvas\" id=\"canvas\">\n        <svg id=\"graph\" viewBox=\"0 0 720 520\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"edgeGrad\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#9d77ff\"/>\n              <stop offset=\"50%\" stop-color=\"#55f0ff\"/>\n              <stop offset=\"100%\" stop-color=\"#ff6fb3\"/>\n            </linearGradient>\n\n            <radialGradient id=\"nodeGlow\" cx=\"50%\" cy=\"50%\">\n              <stop offset=\"0%\" stop-color=\"rgba(85,240,255,0.16)\"/>\n              <stop offset=\"60%\" stop-color=\"rgba(157,119,255,0.06)\"/>\n              <stop offset=\"100%\" stop-color=\"transparent\"/>\n            </radialGradient>\n\n            <filter id=\"soft\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"blur\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"blur\"/>\n            </filter>\n          </defs>\n\n          <!-- Edges will be injected here -->\n          <g id=\"edges\"></g>\n\n          <!-- Node group -->\n          <g id=\"nodes\"></g>\n\n          <!-- traveler -->\n          <circle id=\"traveler\" r=\"7\"></circle>\n        </svg>\n      </div>\n    </section>\n\n    <aside class=\"side\" aria-label=\"Controls and stack\">\n      <div class=\"meta\">\n        <div>\n          <div class=\"title\">Traversal Controls</div>\n          <div class=\"muted\">Start the DFS animation; observe stack and backtracking</div>\n        </div>\n        <div class=\"muted\">Start node: <strong style=\"color:#dffcff\">1</strong></div>\n      </div>\n\n      <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n        <button id=\"startBtn\" class=\"btn\" title=\"Start DFS\">Start</button>\n        <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset visualization\">Reset</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <div class=\"muted\" style=\"font-weight:700;margin-bottom:6px;\">Call Stack (top ↓)</div>\n        <div class=\"stack\" id=\"stack\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n      </div>\n\n      <div style=\"flex:1\"></div>\n\n      <div>\n        <div class=\"muted\" style=\"font-weight:700;margin-bottom:6px;\">Pseudocode</div>\n        <pre class=\"pseudocode\">\nDFS(node):\n  mark node visited\n  push node onto stack\n  for neighbor in neighbors(node):\n    if not visited(neighbor):\n      DFS(neighbor)\n  pop node from stack\n        </pre>\n        <div class=\"muted-note\">This animation shows discovery (push), traversal along edges, and backtracking (pop).</div>\n      </div>\n    </aside>\n\n    <footer> <span>Visual by DFS — elegant traversal. Minimal controls; immersive observation.</span></footer>\n  </div>\n\n<script>\n(function(){\n  // Graph definition: nodes with coords and adjacency (undirected)\n  const nodesData = {\n    1: {x:360, y:80, label:'1'},\n    2: {x:200, y:160, label:'2'},\n    3: {x:520, y:160, label:'3'},\n    4: {x:120, y:300, label:'4'},\n    5: {x:280, y:300, label:'5'},\n    6: {x:440, y:300, label:'6'},\n    7: {x:600, y:300, label:'7'},\n    8: {x:240, y:420, label:'8'},\n    9: {x:480, y:420, label:'9'}\n  };\n\n  const edgesList = [\n    [1,2],[1,3],\n    [2,4],[2,5],\n    [3,6],[3,7],\n    [5,8],[6,9],\n    [5,6],[4,8]\n  ];\n\n  const svg = document.getElementById('graph');\n  const edgesGroup = document.getElementById('edges');\n  const nodesGroup = document.getElementById('nodes');\n  const traveler = document.getElementById('traveler');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const stackEl = document.getElementById('stack');\n\n  // Create edge elements\n  const edgeElements = {};\n  edgesList.forEach((e,idx) => {\n    const [a,b] = e;\n    const p1 = nodesData[a], p2 = nodesData[b];\n    // create a gentle curve: control point offset perpendicular by based on index\n    const midX = (p1.x + p2.x) / 2;\n    const midY = (p1.y + p2.y) / 2;\n    const dx = p2.x - p1.x, dy = p2.y - p1.y;\n    const len = Math.hypot(dx,dy);\n    const nx = -dy/len, ny = dx/len; // normal\n    const offset = Math.min(60, 30 + (idx%3)*8);\n    const cx = midX + nx*offset, cy = midY + ny*offset;\n    const d = `M ${p1.x} ${p1.y} Q ${cx} ${cy} ${p2.x} ${p2.y}`;\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    path.setAttribute('d', d);\n    path.setAttribute('class','edge');\n    path.setAttribute('data-from', String(a));\n    path.setAttribute('data-to', String(b));\n    path.setAttribute('id','edge-'+a+'-'+b);\n    edgesGroup.appendChild(path);\n    edgeElements[`e${a}-${b}`] = path;\n    edgeElements[`e${b}-${a}`] = path; // same path for both directions\n  });\n\n  // Create node elements\n  const nodeElements = {};\n  Object.keys(nodesData).forEach(k=>{\n    const id = Number(k);\n    const n = nodesData[id];\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('class','node');\n    g.setAttribute('id','node-'+id);\n    g.setAttribute('transform',`translate(${n.x},${n.y})`);\n    g.setAttribute('data-id',String(id));\n\n    // glow\n    const glow = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    glow.setAttribute('r',28);\n    glow.setAttribute('class','glow');\n    glow.setAttribute('fill','url(#nodeGlow)');\n    glow.setAttribute('opacity','0.0');\n\n    // core circle (visual)\n    const core = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    core.setAttribute('class','core');\n    core.setAttribute('r',20);\n    core.setAttribute('fill','rgba(255,255,255,0.03)');\n    core.setAttribute('stroke','rgba(255,255,255,0.06)');\n    core.setAttribute('stroke-width','1.2');\n\n    // overlay: visited gradient via a small colored circle\n    const accent = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    accent.setAttribute('r',14);\n    accent.setAttribute('fill','url(#edgeGrad)');\n    accent.setAttribute('opacity',0);\n    accent.setAttribute('class','accent');\n\n    // label\n    const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n    label.setAttribute('class','label');\n    label.setAttribute('y','6'); // centered\n    label.textContent = n.label;\n\n    g.appendChild(glow);\n    g.appendChild(core);\n    g.appendChild(accent);\n    g.appendChild(label);\n    nodesGroup.appendChild(g);\n    nodeElements[id] = {g, core, accent, glow};\n  });\n\n  // DFS action queue construction\n  const adjacency = {};\n  Object.keys(nodesData).forEach(k => adjacency[k]=[]);\n  edgesList.forEach(([a,b])=>{\n    adjacency[a].push(b);\n    adjacency[b].push(a);\n  });\n\n  // Order neighbors for a pleasant traversal determinism\n  Object.keys(adjacency).forEach(k=>{\n    adjacency[k].sort((x,y)=>x-y);\n  });\n\n  let actions = [];\n  function buildActions(start){\n    actions = [];\n    const visited = {};\n    function rec(u){\n      actions.push({type:'push', node:u});\n      visited[u]=true;\n      actions.push({type:'visit', node:u});\n      const neighbors = adjacency[u] || [];\n      for(const v of neighbors){\n        actions.push({type:'edge-check', from:u, to:v});\n        if(!visited[v]){\n          actions.push({type:'edge-traverse', from:u, to:v});\n          rec(v);\n        } else {\n          actions.push({type:'edge-skipped', from:u, to:v});\n        }\n      }\n      actions.push({type:'pop', node:u});\n    }\n    rec(start);\n  }\n\n  // Build actions for start node 1\n  buildActions(1);\n\n  // Animation engine\n  let idx = 0;\n  let running = false;\n  let travelerAnim = null;\n\n  function resetVisuals(){\n    // reset nodes\n    Object.values(nodeElements).forEach(({g,core,accent,glow})=>{\n      g.classList.remove('visited');\n      core.setAttribute('fill','rgba(255,255,255,0.03)');\n      accent.setAttribute('opacity',0);\n      glow.setAttribute('opacity',0);\n      g.style.opacity = 1;\n      g.style.transform = '';\n    });\n    // reset edges\n    Object.values(edgeElements).forEach(path=>{\n      path.classList.remove('highlight');\n      path.style.opacity = 1;\n    });\n    // stack clear\n    stackEl.innerHTML = '';\n    // traveler hide\n    traveler.style.opacity = 0;\n    traveler.setAttribute('cx',0);\n    traveler.setAttribute('cy',0);\n    // reset counters\n    idx = 0;\n    running = false;\n    startBtn.disabled = false;\n  }\n\n  function pushStack(n){\n    const frame = document.createElement('div');\n    frame.className = 'frame enter';\n    frame.setAttribute('data-node', String(n));\n    frame.innerHTML = `<div style=\"display:flex;align-items:center;gap:10px\">\n      <div class=\"node-badge\">${n}</div>\n      <div style=\"font-weight:700;color:#efffff\">node ${n}</div>\n      </div>\n      <div style=\"color:var(--muted);font-size:12px\">dfs()</div>`;\n    stackEl.appendChild(frame);\n    // keep max reasonable items\n    if(stackEl.children.length > 10){\n      stackEl.removeChild(stackEl.firstElementChild);\n    }\n  }\n\n  function popStack(n){\n    // find last frame with data-node = n\n    const frames = Array.from(stackEl.children);\n    for(let i=frames.length-1;i>=0;i--){\n      const f = frames[i];\n      if(f.getAttribute('data-node') === String(n)){\n        f.classList.add('pop');\n        setTimeout(()=> {\n          if(f.parentNode) f.parentNode.removeChild(f);\n        },380);\n        break;\n      }\n    }\n  }\n\n  // helper to animate traveler along a path element; returns a Promise\n  function travelPath(pathEl, duration=650){\n    return new Promise((resolve)=>{\n      const total = pathEl.getTotalLength();\n      let start = null;\n      traveler.style.opacity = 1;\n      function step(ts){\n        if(!start) start = ts;\n        const t = Math.min(1,(ts-start)/duration);\n        const len = t * total;\n        const pt = pathEl.getPointAtLength(len);\n        traveler.setAttribute('cx', pt.x);\n        traveler.setAttribute('cy', pt.y);\n        if(t < 1) requestAnimationFrame(step);\n        else {\n          setTimeout(()=>{\n            traveler.style.opacity = 0;\n            resolve();\n          }, 120);\n        }\n      }\n      requestAnimationFrame(step);\n    });\n  }\n\n  // Process a single action\n  async function processAction(act){\n    switch(act.type){\n      case 'push': {\n        pushStack(act.node);\n        // emphasize node slightly\n        const ne = nodeElements[act.node];\n        if(ne){\n          ne.g.style.transform = 'scale(1.04)';\n          ne.g.style.transition = 'transform 420ms cubic-bezier(.2,.9,.25,1)';\n        }\n        await sleep(120);\n        break;\n      }\n      case 'visit': {\n        const ne = nodeElements[act.node];\n        if(ne){\n          ne.g.classList.add('visited');\n          ne.core.setAttribute('fill','url(#edgeGrad)');\n          ne.accent.setAttribute('opacity',1);\n          ne.glow.setAttribute('opacity',1);\n          // gentle pulse\n          ne.g.animate([\n            { transform: 'scale(1)' },\n            { transform: 'scale(1.06)' },\n            { transform: 'scale(1)' }\n          ], { duration:800, easing:'cubic-bezier(.2,.9,.25,1)' });\n        }\n        await sleep(280);\n        break;\n      }\n      case 'edge-check': {\n        // faint highlight\n        const p = edgeElements[`e${act.from}-${act.to}`];\n        if(p){\n          p.style.opacity = 0.6;\n          p.style.transition = 'opacity 320ms';\n          await sleep(120);\n          p.style.opacity = 0.12;\n        } else {\n          await sleep(120);\n        }\n        break;\n      }\n      case 'edge-skipped': {\n        // brief flicker to show crossed edge\n        const p = edgeElements[`e${act.from}-${act.to}`];\n        if(p){\n          p.style.opacity = 0.3;\n          p.style.transition = 'opacity 180ms';\n          await sleep(160);\n          p.style.opacity = 0.06;\n        } else await sleep(140);\n        break;\n      }\n      case 'edge-traverse': {\n        const p = edgeElements[`e${act.from}-${act.to}`];\n        if(p){\n          p.classList.add('highlight');\n          // animate traveler along p\n          await travelPath(p, 520);\n          // leave path highlighted for a moment\n          await sleep(220);\n          p.classList.remove('highlight');\n          p.style.opacity = 0.2;\n        } else {\n          await sleep(420);\n        }\n        break;\n      }\n      case 'pop': {\n        // pop stack item and slight shrink node\n        popStack(act.node);\n        const ne = nodeElements[act.node];\n        if(ne){\n          ne.g.animate([\n            { transform: 'scale(1.06)' },\n            { transform: 'scale(0.98)' },\n            { transform: 'scale(1)' }\n          ], { duration:420, easing:'cubic-bezier(.2,.9,.25,1)' });\n          ne.g.style.transform = '';\n        }\n        await sleep(260);\n        break;\n      }\n    }\n  }\n\n  function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }\n\n  async function run(){\n    if(running) return;\n    running = true;\n    startBtn.disabled = true;\n    for(; idx < actions.length; idx++){\n      const a = actions[idx];\n      await processAction(a);\n      // short breathe between actions\n      await sleep(80);\n      if(!running) break;\n    }\n    running = false;\n    startBtn.disabled = false;\n  }\n\n  // Start button\n  startBtn.addEventListener('click', ()=>{\n    // disable start while running\n    run().catch(console.error);\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    // kill any running sequence\n    running = false;\n    // small visual reset wiggle\n    document.querySelectorAll('.node').forEach(n => n.style.transform = '');\n    resetVisuals();\n    // rebuild actions fresh (just in case)\n    buildActions(1);\n  });\n\n  // initial subtle idle animation: small glows breathing\n  function idlePulse(){\n    Object.values(nodeElements).forEach((obj, i) => {\n      const delay = (i%4) * 150;\n      setTimeout(()=> {\n        obj.g.animate([\n          { transform: 'translateY(0px) scale(1)' },\n          { transform: 'translateY(-4px) scale(1.02)' },\n          { transform: 'translateY(0px) scale(1)' }\n        ], { duration:2600 + (i%3)*140, iterations: Infinity, easing:'ease-in-out', delay:0 });\n      }, delay);\n    });\n  }\n  idlePulse();\n\n  // initial tiny hint: auto-run after a short delay to encourage observation (respects \"mostly observe\" guideline)\n  let autoRunTimeout = setTimeout(()=> {\n    startBtn.click();\n  }, 900);\n\n  // Clean up if user interacts with reset quickly\n  resetBtn.addEventListener('click', ()=> clearTimeout(autoRunTimeout));\n\n  // initial state\n  resetVisuals();\n\n  // Accessibility: keyboard start with space on the start button\n  startBtn.addEventListener('keyup', (e)=> {\n    if(e.key === ' ' || e.key === 'Enter') startBtn.click();\n  });\n\n})();\n</script>\n</body>\n</html>"
