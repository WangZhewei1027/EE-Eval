    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Undirected Graph Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background: linear-gradient(135deg, #e0eafc, #cfdef3);\n        }\n        h1 {\n            position: absolute;\n            top: 20px;\n            font-size: 3em;\n            color: #2c3e50;\n            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.15);\n        }\n        #graph-container {\n            width: 80vmin;\n            height: 80vmin;\n            border: 5px solid #2980b9;\n            border-radius: 15px;\n            background: white;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n            position: relative;\n            overflow: hidden;\n        }\n        .node {\n            width: 40px;\n            height: 40px;\n            background-color: #3498db;\n            border-radius: 50%;\n            position: absolute;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: bold;\n            transition: background-color 0.3s ease;\n        }\n        .node:hover {\n            background-color: #2980b9;\n        }\n        .edge {\n            position: absolute;\n            height: 2px;\n            background-color: #2980b9;\n            transition: transform 0.3s ease;\n        }\n        button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #e74c3c;\n            color: white;\n            font-size: 1em;\n            cursor: pointer;\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            box-shadow: 0 5px 15px rgba(0,0,0,0.3);\n            transition: background-color 0.3s;\n        }\n        button:hover {\n            background-color: #c0392b;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Undirected Graph Visualization</h1>\n    <div id=\"graph-container\"></div>\n    <button id=\"draw-graph\">Draw Graph</button>\n\n    <script>\n        const nodes = [\n            { id: 1, x: 100, y: 150 },\n            { id: 2, x: 300, y: 50 },\n            { id: 3, x: 200, y: 300 },\n            { id: 4, x: 400, y: 200 }\n        ];\n\n        const edges = [\n            { from: 1, to: 2 },\n            { from: 1, to: 3 },\n            { from: 2, to: 4 },\n            { from: 3, to: 4 }\n        ];\n\n        function createGraph() {\n            const container = document.getElementById('graph-container');\n            container.innerHTML = ''; // Clear previous nodes/edges\n\n            nodes.forEach(node => {\n                const nodeElement = document.createElement('div');\n                nodeElement.classList.add('node');\n                nodeElement.textContent = node.id;\n                nodeElement.style.left = `${node.x}px`;\n                nodeElement.style.top = `${node.y}px`;\n                container.appendChild(nodeElement);\n            });\n\n            edges.forEach(edge => {\n                const fromNode = nodes.find(n => n.id === edge.from);\n                const toNode = nodes.find(n => n.id === edge.to);\n                const edgeElement = document.createElement('div');\n                edgeElement.classList.add('edge');\n\n                const length = Math.hypot(toNode.x - fromNode.x, toNode.y - fromNode.y);\n                edgeElement.style.width = `${length}px`;\n                edgeElement.style.transformOrigin = \"0 0\";\n                edgeElement.style.transform = `translate(${fromNode.x}px, ${fromNode.y}px) rotate(${Math.atan2(toNode.y - fromNode.y, toNode.x - fromNode.x)}rad)`;\n\n                container.appendChild(edgeElement);\n            });\n        }\n\n        document.getElementById('draw-graph').addEventListener('click', createGraph);\n    </script>\n\n</body>\n</html>"
