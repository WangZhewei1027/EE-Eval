    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body {\n            font-family: 'Helvetica Neue', Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n            color: #333;\n        }\n        h1 {\n            text-align: center;\n            color: #4A90E2;\n            margin-bottom: 40px;\n        }\n        #bst-container {\n            position: relative;\n            max-width: 900px;\n            margin: auto;\n            padding: 20px;\n            border-radius: 15px;\n            background: white;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n        }\n        .node {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background-color: #8E44AD;\n            color: white;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.5em;\n            transition: transform 0.5s;\n            box-shadow: 0 4px 10px rgba(0,0,0,0.15);\n        }\n        .link {\n            position: absolute;\n            width: 2px;\n            background-color: #555;\n            transition: height 0.5s;\n        }\n        button {\n            margin: 20px auto;\n            display: block;\n            padding: 15px 30px;\n            font-size: 16px;\n            color: white;\n            background-color: #4A90E2;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n            box-shadow: 0 4px 10px rgba(0,0,0,0.1);\n        }\n        button:hover {\n            background-color: #357ABD;\n        }\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        .hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree Visualization</h1>\n    <div id=\"bst-container\"></div>\n    <button id=\"showTree\">Show BST</button>\n\n    <script>\n        const bstData = [\n            { value: 8, left: 3, right: 10 },\n            { value: 3, left: 1, right: 6 },\n            { value: 10, left: null, right: 14 },\n            { value: 6, left: 4, right: 7 },\n            { value: 1, left: null, right: null },\n            { value: 4, left: null, right: null },\n            { value: 7, left: null, right: null },\n            { value: 14, left: 13, right: null },\n            { value: 13, left: null, right: null }\n        ];\n\n        const bstContainer = document.getElementById('bst-container');\n\n        function createNode(node, x, y) {\n            const nodeElem = document.createElement('div');\n            nodeElem.className = 'node';\n            nodeElem.style.left = `${x}px`;\n            nodeElem.style.top = `${y}px`;\n            nodeElem.innerText = node.value;\n            bstContainer.appendChild(nodeElem);\n            return nodeElem;\n        }\n\n        function createLink(parentX, parentY, childX, childY) {\n            const link = document.createElement('div');\n            link.className = 'link';\n            link.style.left = `${parentX + 25}px`;\n            link.style.top = `${parentY + 50}px`;\n            const height = childY - parentY - 50;\n            link.style.height = `${height}px`;\n            bstContainer.appendChild(link);\n        }\n\n        function positionNodes(nodes, x, y, spacing) {\n            if (nodes.length === 0) return;\n            const midIndex = Math.floor(nodes.length / 2);\n            const node = nodes[midIndex];\n\n            const nodeElem = createNode(node, x, y);\n            const leftX = x - spacing / 2;\n            const rightX = x + spacing / 2;\n\n            if (node.left !== null) {\n                const leftNode = nodes.find(n => n.value === node.left);\n                createLink(x, y, leftX, y + 100);\n                positionNodes([leftNode], leftX, y + 100, spacing / 2);\n            }\n            if (node.right !== null) {\n                const rightNode = nodes.find(n => n.value === node.right);\n                createLink(x, y, rightX, y + 100);\n                positionNodes([rightNode], rightX, y + 100, spacing / 2);\n            }\n        }\n\n        document.getElementById('showTree').addEventListener('click', () => {\n            bstContainer.innerHTML = '';\n            positionNodes(bstData, 400, 20, 400);\n        });\n    </script>\n</body>\n</html>"
