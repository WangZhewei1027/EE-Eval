  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>B+ Tree Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre;\n  }\n  input, button, select {\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  #treeDisplay {\n    overflow-x: auto;\n    max-height: 400px;\n    border: 1px solid #000;\n    padding: 6px;\n    margin-top: 6px;\n    white-space: pre-wrap;\n  }\n  #log {\n    max-height: 100px;\n    overflow-y: scroll;\n    white-space: pre-wrap;\n    border: 1px solid #000;\n    margin-top: 6px;\n    padding: 4px;\n    font-size: 12px;\n  }\n  #controls > div {\n    margin-bottom: 12px;\n  }\n  label {\n    display: inline-block;\n    width: 90px;\n  }\n</style>\n</head>\n<body>\n<h1>B+ Tree Interactive Explorer</h1>\n\n<div id=\"setupSection\">\n  <div>\n    <label>Order (M):</label>\n    <input type=\"number\" id=\"inputOrder\" value=\"4\" min=\"3\" max=\"10\" /> (Max children per node)\n  </div>\n  <div>\n    <button id=\"btnCreateTree\">Create New B+ Tree</button>\n    <button id=\"btnResetTree\" disabled>Reset Tree</button>\n  </div>\n</div>\n\n<hr />\n\n<div id=\"controls\" style=\"display:none;\">\n  <div>\n    <label for=\"inputInsert\">Insert key:</label>\n    <input type=\"number\" id=\"inputInsert\" />\n    <button id=\"btnInsert\">Insert</button>\n  </div>\n  <div>\n    <label for=\"inputDelete\">Delete key:</label>\n    <input type=\"number\" id=\"inputDelete\" />\n    <button id=\"btnDelete\">Delete</button>\n  </div>\n  <div>\n    <label for=\"inputSearch\">Search key:</label>\n    <input type=\"number\" id=\"inputSearch\" />\n    <button id=\"btnSearch\">Search</button>\n  </div>\n  <div>\n    <label>Traverse:</label>\n    <button id=\"btnTraverseForward\">Forward</button>\n    <button id=\"btnTraverseBackward\">Backward</button>\n    <input type=\"number\" id=\"inputTraversePos\" min=\"1\" placeholder=\"Pos\" style=\"width: 50px;\" />\n    <button id=\"btnTraversePos\">Go</button>\n  </div>\n  <div>\n    <label>Bulk Insert:</label>\n    <input id=\"inputBulkInsert\" placeholder=\"Comma spaced keys\" style=\"width: 220px;\" />\n    <button id=\"btnBulkInsert\">Insert All</button>\n  </div>\n  <div>\n    <label>Bulk Delete:</label>\n    <input id=\"inputBulkDelete\" placeholder=\"Comma spaced keys\" style=\"width: 220px;\" />\n    <button id=\"btnBulkDelete\">Delete All</button>\n  </div>\n  <div>\n    <label>Load From JSON:</label>\n    <textarea id=\"inputLoadJSON\" rows=\"3\" cols=\"40\" placeholder='{\"order\":4,\"keys\":[...],\"tree\":{...}}'></textarea><br/>\n    <button id=\"btnLoadJSON\">Load Tree</button>\n  </div>\n  <div>\n    <label>Export Tree JSON:</label>\n    <button id=\"btnExportJSON\">Export</button>\n    <textarea id=\"outputExportJSON\" rows=\"4\" cols=\"60\" readonly></textarea>\n  </div>\n  <div>\n    <label>Current Tree Height:</label><span id=\"treeHeight\">N/A</span>\n  </div>\n</div>\n\n<h2>Tree Visualization (Textual / Structural)</h2>\n<div id=\"treeDisplay\"></div>\n\n<h2>Operational Log</h2>\n<div id=\"log\"></div>\n\n<script>\n(() => {\n  // B+ Tree Node class\n  class BPlusTreeNode {\n    constructor(order, isLeaf = false) {\n      this.order = order;\n      this.isLeaf = isLeaf;\n      this.keys = [];\n      this.children = [];\n      this.next = null; // For leaves, points to next leaf for linked list traversal\n      this.parent = null; // reference to parent node, for convenience (not required)\n    }\n\n    // Find child index for a key\n    findChildIndex(key) {\n      // Returns child index to follow for key\n      for (let i = 0; i < this.keys.length; i++) {\n        if (key < this.keys[i]) return i;\n      }\n      return this.keys.length;\n    }\n  }\n\n  class BPlusTree {\n    constructor(order) {\n      if (order < 3) throw new Error('Order must be at least 3');\n      this.order = order;\n      this.root = new BPlusTreeNode(order, true);\n      this.leafHead = this.root; // facilitate traversal\n      this.size = 0;\n    }\n\n    // Search for a key. Returns {found:boolean, node:BPlusTreeNode, index:number} with position\n    search(key) {\n      let current = this.root;\n      while (!current.isLeaf) {\n        let idx = current.findChildIndex(key);\n        current = current.children[idx];\n      }\n      const idx = current.keys.indexOf(key);\n      return {\n        found: idx !== -1,\n        node: current,\n        index: idx\n      };\n    }\n\n    // Insert a single key (non-duplicate)\n    insert(key) {\n      if (this.search(key).found) {\n        return false; // duplicate keys not allowed\n      }\n      let leaf = this._findLeafNode(key);\n      this._insertIntoLeaf(leaf, key);\n      this.size++;\n      return true;\n    }\n\n    // Delete a key\n    delete(key) {\n      let s = this.search(key);\n      if (!s.found) return false;\n      this._deleteEntry(s.node, key);\n      this.size--;\n      return true;\n    }\n\n    // Find leaf node for a key\n    _findLeafNode(key) {\n      let current = this.root;\n      while (!current.isLeaf) {\n        let idx = current.findChildIndex(key);\n        current = current.children[idx];\n      }\n      return current;\n    }\n\n    _insertIntoLeaf(leaf, key) {\n      let pos = 0;\n      while (pos < leaf.keys.length && leaf.keys[pos] < key) pos++;\n      leaf.keys.splice(pos, 0, key);\n\n      if (leaf.keys.length < this.order) {\n        return;\n      }\n      // Need to split leaf\n      this._splitLeaf(leaf);\n    }\n\n    _splitLeaf(leaf) {\n      const mid = Math.ceil(this.order / 2);\n      const newLeaf = new BPlusTreeNode(this.order, true);\n      newLeaf.keys = leaf.keys.splice(mid);\n      // Insert newLeaf into leaf linked list\n      newLeaf.next = leaf.next;\n      leaf.next = newLeaf;\n\n      // Promote first key of newLeaf upwards\n      const promoteKey = newLeaf.keys[0];\n\n      this._insertIntoParent(leaf, promoteKey, newLeaf);\n    }\n\n    _insertIntoParent(leftNode, key, rightNode) {\n      if (leftNode === this.root) {\n        // Create new root\n        const root = new BPlusTreeNode(this.order, false);\n        root.keys = [key];\n        root.children = [leftNode, rightNode];\n        this.root = root;\n        leftNode.parent = root;\n        rightNode.parent = root;\n        return;\n      }\n\n      const parent = leftNode.parent;\n      let pos = 0;\n      while (pos < parent.children.length && parent.children[pos] !== leftNode) pos++;\n      parent.keys.splice(pos, 0, key);\n      parent.children.splice(pos + 1, 0, rightNode);\n      rightNode.parent = parent;\n\n      if (parent.keys.length < this.order) {\n        return;\n      }\n      this._splitInternal(parent);\n    }\n\n    _splitInternal(node) {\n      const midIndex = Math.floor(this.order / 2);\n      const promoteKey = node.keys[midIndex];\n\n      const newNode = new BPlusTreeNode(this.order, false);\n\n      newNode.keys = node.keys.splice(midIndex + 1);\n      newNode.children = node.children.splice(midIndex + 1);\n      newNode.children.forEach(c => { c.parent = newNode; });\n\n      node.keys.splice(midIndex, 1); // remove promoteKey from node\n\n      this._insertIntoParent(node, promoteKey, newNode);\n    }\n\n    _deleteEntry(node, key) {\n      if (node.isLeaf) {\n        // Remove key from leaf\n        const idx = node.keys.indexOf(key);\n        if (idx === -1) return;\n        node.keys.splice(idx, 1);\n      } else {\n        // Internal node: key is separator\n        let idx = node.keys.indexOf(key);\n        if (idx === -1) return;\n        node.keys.splice(idx, 1);\n        // The child link at idx+1 remains (we don't delete children here explicitly)\n      }\n\n      if (node === this.root) {\n        this._adjustRoot();\n        return;\n      }\n\n      const minKeys = Math.ceil((this.order - 1) / 2);\n      if (node.keys.length >= minKeys) {\n        return; // no underflow\n      }\n\n      this._rebalance(node);\n    }\n\n    _adjustRoot() {\n      const root = this.root;\n      if (!root.isLeaf && root.children.length === 1) {\n        this.root = root.children[0];\n        this.root.parent = null;\n      } else if (root.isLeaf && root.keys.length === 0) {\n        this.root = new BPlusTreeNode(this.order, true);\n        this.leafHead = this.root;\n        this.size = 0;\n      }\n    }\n\n    _rebalance(node) {\n      const parent = node.parent;\n      if (!parent) return;\n      const idx = parent.children.indexOf(node);\n\n      const minKeys = Math.ceil((this.order - 1) / 2);\n\n      // Try the left sibling\n      let leftSibling = null;\n      if (idx > 0) leftSibling = parent.children[idx - 1];\n      // Try the right sibling\n      let rightSibling = null;\n      if (idx < parent.children.length - 1) rightSibling = parent.children[idx + 1];\n\n      // Try to borrow from left sibling\n      if (leftSibling && leftSibling.keys.length > minKeys) {\n        if (node.isLeaf) {\n          const borrowKey = leftSibling.keys.pop();\n          node.keys.unshift(borrowKey);\n          parent.keys[idx - 1] = node.keys[0];\n        } else {\n          // Internal case\n          const borrowKey = parent.keys[idx - 1];\n          const borrowChild = leftSibling.children.pop();\n          node.children.unshift(borrowChild);\n          borrowChild.parent = node;\n\n          parent.keys[idx - 1] = leftSibling.keys.pop();\n          node.keys.unshift(borrowKey);\n        }\n        return;\n      }\n      // Try to borrow from right sibling\n      if (rightSibling && rightSibling.keys.length > minKeys) {\n        if (node.isLeaf) {\n          const borrowKey = rightSibling.keys.shift();\n          node.keys.push(borrowKey);\n          parent.keys[idx] = rightSibling.keys[0];\n        } else {\n          const borrowKey = parent.keys[idx];\n          const borrowChild = rightSibling.children.shift();\n          node.children.push(borrowChild);\n          borrowChild.parent = node;\n\n          parent.keys[idx] = rightSibling.keys.shift();\n          node.keys.push(borrowKey);\n        }\n        return;\n      }\n\n      // Merge with sibling if borrowing not possible\n      if (leftSibling) {\n        this._mergeNodes(leftSibling, node, idx - 1);\n      } else if (rightSibling) {\n        this._mergeNodes(node, rightSibling, idx);\n      }\n    }\n\n    _mergeNodes(leftNode, rightNode, parentKeyIndex) {\n      const parent = leftNode.parent;\n      if (leftNode.isLeaf) {\n        // Merge keys and link\n        leftNode.keys = leftNode.keys.concat(rightNode.keys);\n        leftNode.next = rightNode.next;\n      } else {\n        const mergeKey = parent.keys[parentKeyIndex];\n        leftNode.keys.push(mergeKey);\n        leftNode.keys = leftNode.keys.concat(rightNode.keys);\n        leftNode.children = leftNode.children.concat(rightNode.children);\n        leftNode.children.forEach(c => {c.parent = leftNode;});\n      }\n      // Remove rightNode from parent's children\n      parent.keys.splice(parentKeyIndex, 1);\n      parent.children.splice(parentKeyIndex + 1, 1);\n\n      // If parent is root and empty, adjust root\n      if (parent === this.root && parent.keys.length === 0) {\n        this.root = leftNode;\n        leftNode.parent = null;\n        return;\n      }\n      if (parent.keys.length < Math.ceil((this.order - 1) / 2)) {\n        this._rebalance(parent);\n      }\n    }\n\n    // Traverse all keys in order from left to right leaf-linked list\n    traverseForward() {\n      const result = [];\n      let curr = this.leafHead;\n      while (curr) {\n        for (let key of curr.keys) {\n          result.push(key);\n        }\n        curr = curr.next;\n      }\n      return result;\n    }\n    // Traverse all keys from tail backwards (not directly stored) so we must get forward and reverse\n    traverseBackward() {\n      const keys = this.traverseForward();\n      return keys.reverse();\n    }\n\n    // Get tree height\n    height() {\n      let height = 0;\n      let node = this.root;\n      while (node) {\n        height++;\n        if (node.isLeaf) break;\n        node = node.children[0];\n      }\n      return height;\n    }\n\n    // Return JSON-ready serialized structure of tree for export\n    serialize() {\n      function nodeToObj(node) {\n        const obj = {\n          isLeaf: node.isLeaf,\n          keys: node.keys.slice(),\n          children: []\n        };\n        if (!node.isLeaf) {\n          for (const c of node.children) {\n            obj.children.push(nodeToObj(c));\n          }\n        }\n        return obj;\n      }\n      return {\n        order: this.order,\n        size: this.size,\n        root: nodeToObj(this.root)\n      };\n    }\n\n    // Load tree from serialized JSON object (should be validated before)\n    static deserialize(obj) {\n      function objToNode(o) {\n        const node = new BPlusTreeNode(o.keys.length > 0 ? o.keys.length + 1 : 2, o.isLeaf);\n        // We cannot use keys length for order here, so we have to keep order from top.\n        node.isLeaf = o.isLeaf;\n        node.keys = o.keys.slice();\n        if (!o.isLeaf) {\n          node.children = o.children.map(c => {\n            const childNode = objToNode(c);\n            childNode.parent = node;\n            return childNode;\n          });\n        }\n        return node;\n      }\n      const tree = new BPlusTree(obj.order);\n      tree.root = objToNode(obj.root);\n\n      // fix parents for root is already done during loading\n\n      // rebuild leaf linked list\n      const leaves = [];\n      function collectLeaves(n) {\n        if (n.isLeaf) {\n          leaves.push(n);\n        } else {\n          n.children.forEach(c => collectLeaves(c));\n        }\n      }\n      collectLeaves(tree.root);\n      leaves.sort((a, b) => a.keys[0] - b.keys[0]); // rough ascending order based on first key\n      for (let i = 0; i < leaves.length - 1; i++) {\n        leaves[i].next = leaves[i + 1];\n      }\n      if(leaves.length>0) {\n        leaves[leaves.length - 1].next = null;\n        tree.leafHead = leaves[0];\n      } else {\n        // no leaves in tree means empty tree\n        tree.leafHead = tree.root;\n      }\n\n      // size count can be approximated by summing leaf keys\n      function countLeafKeys(n) {\n        if (n.isLeaf) return n.keys.length;\n        return n.children.reduce((acc, c) => acc + countLeafKeys(c), 0);\n      }\n      tree.size = countLeafKeys(tree.root);\n\n      return tree;\n    }\n  }\n\n  // --------- UI and interaction logic ---------\n  let bptree = null;\n\n  // DOM elements\n  const inputOrder = document.getElementById('inputOrder');\n  const btnCreateTree = document.getElementById('btnCreateTree');\n  const btnResetTree = document.getElementById('btnResetTree');\n\n  const controlsDiv = document.getElementById('controls');\n  const inputInsert = document.getElementById('inputInsert');\n  const btnInsert = document.getElementById('btnInsert');\n  const inputDelete = document.getElementById('inputDelete');\n  const btnDelete = document.getElementById('btnDelete');\n  const inputSearch = document.getElementById('inputSearch');\n  const btnSearch = document.getElementById('btnSearch');\n  const btnTraverseForward = document.getElementById('btnTraverseForward');\n  const btnTraverseBackward = document.getElementById('btnTraverseBackward');\n  const inputTraversePos = document.getElementById('inputTraversePos');\n  const btnTraversePos = document.getElementById('btnTraversePos');\n\n  const inputBulkInsert = document.getElementById('inputBulkInsert');\n  const btnBulkInsert = document.getElementById('btnBulkInsert');\n  const inputBulkDelete = document.getElementById('inputBulkDelete');\n  const btnBulkDelete = document.getElementById('btnBulkDelete');\n\n  const inputLoadJSON = document.getElementById('inputLoadJSON');\n  const btnLoadJSON = document.getElementById('btnLoadJSON');\n  const btnExportJSON = document.getElementById('btnExportJSON');\n  const outputExportJSON = document.getElementById('outputExportJSON');\n\n  const treeDisplay = document.getElementById('treeDisplay');\n  const logDiv = document.getElementById('log');\n  const treeHeightSpan = document.getElementById('treeHeight');\n\n  function log(msg) {\n    const now = new Date();\n    const timeStr = now.toLocaleTimeString();\n    logDiv.textContent += `[${timeStr}] ${msg}\\n`;\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  function clearLog() {\n    logDiv.textContent = '';\n  }\n\n  function renderTree() {\n    if (!bptree) {\n      treeDisplay.textContent = 'No tree.';\n      return;\n    }\n    // Textual printing of tree structure level by level\n    const lines = [];\n    // BFS\n    const queue = [];\n    queue.push(bptree.root);\n    let level = 0;\n    while (queue.length > 0) {\n      const levelSize = queue.length;\n      let line = `Level ${level}: `;\n      const nodeInfos = [];\n      for (let i = 0; i < levelSize; i++) {\n        const node = queue.shift();\n        const keysStr = node.keys.length === 0 ? '[∅]' : `[${node.keys.join(',')}]`;\n        const leafMark = node.isLeaf ? 'L' : 'I';\n        nodeInfos.push(`${leafMark}${keysStr}`);\n        if (!node.isLeaf) {\n          for (const c of node.children) {\n            queue.push(c);\n          }\n        }\n      }\n      line += nodeInfos.join(' | ');\n      lines.push(line);\n      level++;\n    }\n\n    // Also show leaf linked list keys\n    let leafLine = 'Leaves: ';\n    let leafNode = bptree.leafHead;\n    const leafKeys = [];\n    while (leafNode) {\n      leafKeys.push(`[${leafNode.keys.join(',')}]`);\n      leafNode = leafNode.next;\n    }\n    leafLine += leafKeys.join(' -> ');\n    lines.push('');\n    lines.push(leafLine);\n\n    // Tree height and size\n    lines.push('');\n    lines.push(`Tree order (M): ${bptree.order}`);\n    lines.push(`Tree height: ${bptree.height()}`);\n    lines.push(`Total keys stored: ${bptree.size}`);\n\n    treeDisplay.textContent = lines.join('\\n');\n    treeHeightSpan.textContent = bptree.height();\n  }\n\n  function createTreeFromOrder() {\n    const order = parseInt(inputOrder.value, 10);\n    if (isNaN(order) || order < 3 || order > 10) {\n      alert('Order must be an integer between 3 and 10.');\n      return null;\n    }\n    return new BPlusTree(order);\n  }\n\n  function parseNumbersFromInput(text) {\n    if (!text) return [];\n    // Split comma, space, semicolon separated\n    return text.split(/[\\s,;]+/).map(s => s.trim()).filter(s => s.length>0).map(x => {\n      const n = parseInt(x,10);\n      return isNaN(n)?null:n;\n    }).filter(x => x !== null);\n  }\n\n  // BUTTON event handlers\n\n  btnCreateTree.addEventListener('click', () => {\n    const tree = createTreeFromOrder();\n    if (!tree) return;\n    bptree = tree;\n    btnResetTree.disabled = false;\n    controlsDiv.style.display = 'block';\n    log(`Created new B+ tree of order ${bptree.order}.`);\n    renderTree();\n  });\n\n  btnResetTree.addEventListener('click', () => {\n    if (!bptree) return;\n    bptree = createTreeFromOrder();\n    if (!bptree) return;\n    log(`Tree reset to empty B+ tree of order ${bptree.order}.`);\n    renderTree();\n  });\n\n  btnInsert.addEventListener('click', () => {\n    if (!bptree) return;\n    const key = parseInt(inputInsert.value, 10);\n    if (isNaN(key)) {\n      alert('Please enter a valid integer key to insert.');\n      return;\n    }\n    const ok = bptree.insert(key);\n    if (ok) {\n      log(`Inserted key ${key}.`);\n    } else {\n      log(`Insert failed: Key ${key} already exists.`);\n      alert('Key already exists in the tree (no duplicates allowed).');\n    }\n    renderTree();\n  });\n\n  btnDelete.addEventListener('click', () => {\n    if (!bptree) return;\n    const key = parseInt(inputDelete.value, 10);\n    if (isNaN(key)) {\n      alert('Please enter a valid integer key to delete.');\n      return;\n    }\n    const ok = bptree.delete(key);\n    if (ok) {\n      log(`Deleted key ${key}.`);\n    } else {\n      log(`Delete failed: Key ${key} not found.`);\n      alert('Key not found in the tree.');\n    }\n    renderTree();\n  });\n\n  btnSearch.addEventListener('click', () => {\n    if (!bptree) return;\n    const key = parseInt(inputSearch.value, 10);\n    if (isNaN(key)) {\n      alert('Please enter a valid integer key to search.');\n      return;\n    }\n    const res = bptree.search(key);\n    if (res.found) {\n      log(`Key ${key} found in leaf node at index ${res.index}.`);\n      alert(`Key ${key} FOUND in the tree.`);\n    } else {\n      log(`Key ${key} NOT found.`);\n      alert(`Key ${key} NOT found in the tree.`);\n    }\n  });\n\n  btnTraverseForward.addEventListener('click', () => {\n    if (!bptree) return;\n    const allKeys = bptree.traverseForward();\n    log(`Traverse forward: ${allKeys.length} keys: ${allKeys.join(', ')}`);\n    alert(`Traverse forward:\\n${allKeys.join(', ')}`);\n  });\n\n  btnTraverseBackward.addEventListener('click', () => {\n    if (!bptree) return;\n    const allKeys = bptree.traverseBackward();\n    log(`Traverse backward: ${allKeys.length} keys: ${allKeys.join(', ')}`);\n    alert(`Traverse backward:\\n${allKeys.join(', ')}`);\n  });\n\n  btnTraversePos.addEventListener('click', () => {\n    if (!bptree) return;\n    const pos = parseInt(inputTraversePos.value, 10);\n    if (isNaN(pos) || pos < 1) {\n      alert('Please enter a valid positive position to traverse to.');\n      return;\n    }\n    const allKeys = bptree.traverseForward();\n    if (pos > allKeys.length) {\n      alert('Position exceeds number of keys in the tree.');\n      return;\n    }\n    log(`Traverse position ${pos}: Key ${allKeys[pos -1]}`);\n    alert(`Key at position ${pos}: ${allKeys[pos -1]}`);\n  });\n\n  btnBulkInsert.addEventListener('click', () => {\n    if (!bptree) return;\n    const keys = parseNumbersFromInput(inputBulkInsert.value);\n    if (keys.length === 0) {\n      alert('Enter at least one valid integer key for bulk insertion.');\n      return;\n    }\n    let insertedCount = 0;\n    let skippedCount = 0;\n    for (const k of keys) {\n      if (bptree.insert(k)) insertedCount++;\n      else skippedCount++;\n    }\n    log(`Bulk insert: ${insertedCount} keys inserted, ${skippedCount} skipped (duplicates).`);\n    alert(`Bulk Insert complete.\\nInserted: ${insertedCount}\\nSkipped duplicates: ${skippedCount}`);\n    renderTree();\n  });\n\n  btnBulkDelete.addEventListener('click', () => {\n    if (!bptree) return;\n    const keys = parseNumbersFromInput(inputBulkDelete.value);\n    if (keys.length === 0) {\n      alert('Enter at least one valid integer key for bulk deletion.');\n      return;\n    }\n    let deletedCount = 0;\n    let notFoundCount = 0;\n    for (const k of keys) {\n      if (bptree.delete(k)) deletedCount++;\n      else notFoundCount++;\n    }\n    log(`Bulk delete: ${deletedCount} keys deleted, ${notFoundCount} keys not found.`);\n    alert(`Bulk Delete complete.\\nDeleted: ${deletedCount}\\nNot found: ${notFoundCount}`);\n    renderTree();\n  });\n\n  btnLoadJSON.addEventListener('click', () => {\n    let obj = null;\n    try {\n      obj = JSON.parse(inputLoadJSON.value);\n    } catch(e) {\n      alert('Invalid JSON input.');\n      return;\n    }\n    try {\n      const tree = BPlusTree.deserialize(obj);\n      bptree = tree;\n      controlsDiv.style.display = 'block';\n      btnResetTree.disabled = false;\n      log('B+ Tree loaded from JSON.');\n      renderTree();\n    } catch(e) {\n      alert('Failed to load tree from JSON. Check data format.');\n    }\n  });\n\n  btnExportJSON.addEventListener('click', () => {\n    if (!bptree) {\n      alert('No tree to export.');\n      return;\n    }\n    const obj = bptree.serialize();\n    const jsonStr = JSON.stringify(obj, null, 2);\n    outputExportJSON.value = jsonStr;\n    log('Exported tree to JSON.');\n  });\n\n  // Keyboard shortcuts to speed up testing\n  document.addEventListener('keydown', e => {\n    if (!bptree || controlsDiv.style.display === 'none') return;\n    // Insert key - Enter on insert input\n    if (e.target === inputInsert && e.key === 'Enter') {\n      btnInsert.click();\n    }\n    // Delete key - Enter on delete input\n    if (e.target === inputDelete && e.key === 'Enter') {\n      btnDelete.click();\n    }\n    // Search key - Enter on search input\n    if (e.target === inputSearch && e.key === 'Enter') {\n      btnSearch.click();\n    }\n    // Bulk Insert - ctrl+Enter triggers bulk insert if focus on bulkInsert\n    if ((e.target === inputBulkInsert) && e.ctrlKey && e.key.toLowerCase() === 'enter') {\n      btnBulkInsert.click();\n    }\n    // Bulk Delete - ctrl+Enter triggers bulk delete if focus on bulkDelete\n    if ((e.target === inputBulkDelete) && e.ctrlKey && e.key.toLowerCase() === 'enter') {\n      btnBulkDelete.click();\n    }\n  });\n\n  // Initial page state\n  controlsDiv.style.display = 'none';\n  btnResetTree.disabled = true;\n\n  // For deep exploration, add a detailed node info popup on tree display click\n\n  treeDisplay.addEventListener('click', e => {\n    if (!bptree) return;\n    // Let user click on text to get nodes info (approximate)\n    // We will ask for a key input to inspect node containing that key\n    const keyInput = prompt('Enter a key to inspect its leaf node:');\n    if (keyInput === null) return;\n    const key = parseInt(keyInput, 10);\n    if (isNaN(key)) {\n      alert('Invalid number entered.');\n      return;\n    }\n    const s = bptree.search(key);\n    if (!s.found) {\n      alert(`Key ${key} not found in tree.`);\n      return;\n    }\n    // Display detailed node info\n    const node = s.node;\n    const idx = s.index;\n    let msg = `Leaf node containing key ${key}:\\n\\n`;\n    msg += `Keys in node: ${node.keys.join(', ')}\\n`;\n    msg += `Index of key in node: ${idx}\\n`;\n    const nextKeys = node.next ? node.next.keys.join(', ') : 'None (no next leaf)';\n    msg += `Next leaf node keys: ${nextKeys}\\n`;\n    alert(msg);\n  });\n})();\n</script>\n\n</body>\n</html>"
