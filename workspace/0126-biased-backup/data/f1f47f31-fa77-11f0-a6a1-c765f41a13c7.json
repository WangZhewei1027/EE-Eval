    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Stack — Visual Concept</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071028;\n    --accent: #6ee7b7;\n    --accent-2: #8b5cf6;\n    --muted: rgba(255,255,255,0.08);\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --card-edge: rgba(255,255,255,0.06);\n    --card-text: #eef2ff;\n    --glass-border: rgba(255,255,255,0.06);\n    --shadow: 0 10px 30px rgba(2,6,23,0.65);\n    font-synthesis: none;\n  }\n\n  /* Base reset */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(139,92,246,0.12), transparent 12%),\n                radial-gradient(800px 400px at 90% 80%, rgba(110,231,183,0.06), transparent 10%),\n                linear-gradient(180deg,var(--bg1) 0%, var(--bg2) 100%);\n    color:var(--card-text);\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n  }\n\n  /* Outer card */\n  .stage{\n    width: min(1100px, 96vw);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    display:grid;\n    grid-template-columns: 560px 1fr;\n    gap:28px;\n    box-shadow: var(--shadow);\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Decorative top glow */\n  .stage::before{\n    content:\"\";\n    position:absolute;\n    left:-10%;\n    top:-40%;\n    width:60%;\n    height:60%;\n    background: radial-gradient(closest-side, rgba(139,92,246,0.10), transparent 40%);\n    filter: blur(40px);\n    transform: rotate(12deg);\n    pointer-events:none;\n  }\n  .stage::after{\n    content:\"\";\n    position:absolute;\n    right:-20%;\n    bottom:-30%;\n    width:60%;\n    height:60%;\n    background: radial-gradient(closest-side, rgba(110,231,183,0.06), transparent 40%);\n    filter: blur(40px);\n    pointer-events:none;\n  }\n\n  /* Left column: Stack visual */\n  .visual {\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border: 1px solid var(--glass-border);\n    position:relative;\n    overflow:visible;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n    min-height:420px;\n  }\n\n  .visual-header{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n\n  .title{\n    font-size:20px;\n    font-weight:600;\n    letter-spacing:-0.02em;\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n\n  .badge{\n    background: linear-gradient(90deg,var(--accent),var(--accent-2));\n    color:#032024;\n    padding:8px 12px;\n    border-radius:999px;\n    font-weight:700;\n    font-size:13px;\n    box-shadow: 0 6px 18px rgba(139,92,246,0.12);\n  }\n\n  .meta{\n    font-size:12px;\n    color:rgba(255,255,255,0.6);\n    display:flex;\n    gap:10px;\n    align-items:center;\n    white-space:nowrap;\n  }\n\n  /* Stack well */\n  .well{\n    position:relative;\n    height:320px;\n    margin-top:12px;\n    display:flex;\n    align-items:flex-end;\n    justify-content:center;\n    perspective:1200px;\n  }\n\n  /* stack base plate */\n  .plate{\n    position:absolute;\n    bottom:12px;\n    width:86%;\n    height:64px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid var(--glass-border);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform:translateZ(-60px);\n  }\n  .platemark{\n    color: rgba(255,255,255,0.2);\n    font-size:12px;\n    letter-spacing:1px;\n    text-transform:uppercase;\n  }\n\n  /* stack cards container */\n  .stack {\n    position:relative;\n    width:260px;\n    height:100%;\n    display:block;\n  }\n\n  .card {\n    --twist: 0deg;\n    position:absolute;\n    left:50%;\n    transform-origin:50% 100%;\n    translate: -50% 0;\n    width:220px;\n    height:56px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--card-edge);\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    padding:12px 14px;\n    color:var(--card-text);\n    box-shadow: 0 18px 40px rgba(2,6,23,0.6), 0 2px 0 rgba(255,255,255,0.02) inset;\n    backdrop-filter: blur(6px) saturate(120%);\n    transition: transform 520ms cubic-bezier(.2,.9,.2,1), opacity 420ms ease, filter 420ms ease;\n    will-change: transform, opacity;\n    user-select:none;\n  }\n\n  .card .label{\n    font-weight:700;\n    font-size:15px;\n    letter-spacing:-0.01em;\n  }\n  .card .sub{\n    font-size:12px;\n    color:rgba(255,255,255,0.65);\n    font-weight:600;\n  }\n\n  /* decorative edge gradient for each card */\n  .card::before{\n    content:\"\";\n    position:absolute;\n    left:0;\n    top:0;\n    bottom:0;\n    width:6px;\n    border-top-left-radius:12px;\n    border-bottom-left-radius:12px;\n    background: linear-gradient(180deg, rgba(139,92,246,0.85), rgba(110,231,183,0.85));\n    transform-origin:left center;\n    opacity:0.95;\n  }\n\n  /* top highlight */\n  .glow {\n    position:absolute;\n    right:14px;\n    top:14px;\n    width:60%;\n    height:42%;\n    background: linear-gradient(90deg, rgba(255,255,255,0.04), transparent);\n    border-radius:8px;\n    transform: rotate(-12deg);\n    filter: blur(14px);\n    pointer-events:none;\n  }\n\n  /* Buttons */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--card-text);\n    border:1px solid rgba(255,255,255,0.04);\n    cursor:pointer;\n    font-weight:700;\n    letter-spacing:0.01em;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition: transform 200ms cubic-bezier(.2,.9,.2,1), box-shadow 300ms;\n    box-shadow: 0 6px 20px rgba(2,6,23,0.45);\n    font-size:13px;\n  }\n  .btn:active{ transform: translateY(1px) scale(0.998); }\n  .btn:focus{ outline: none; box-shadow: 0 6px 28px rgba(139,92,246,0.14); }\n\n  .btn.push{\n    background: linear-gradient(90deg, rgba(110,231,183,0.12), rgba(139,92,246,0.08));\n    border: 1px solid rgba(110,231,183,0.08);\n    color: #eafff1;\n  }\n  .btn.pop{\n    background: linear-gradient(90deg, rgba(139,92,246,0.06), rgba(110,231,183,0.03));\n    border: 1px solid rgba(255,255,255,0.03);\n    color: #fff6ff;\n  }\n\n  .controls .count{\n    margin-left:auto;\n    font-size:13px;\n    color:rgba(255,255,255,0.7);\n    display:flex;\n    gap:10px;\n    align-items:center;\n    background: linear-gradient(90deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    padding:6px 10px;\n    border-radius:999px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Right column: explanation */\n  .info{\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.008));\n    border: 1px solid var(--glass-border);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    position:relative;\n  }\n\n  .headline{\n    font-size:18px;\n    font-weight:700;\n    letter-spacing:-0.01em;\n  }\n  .lead{\n    color:rgba(255,255,255,0.75);\n    font-size:13px;\n    line-height:1.65;\n  }\n\n  .codecard{\n    margin-top:8px;\n    padding:16px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(2,6,23,0.22), rgba(2,6,23,0.14));\n    border: 1px solid rgba(255,255,255,0.03);\n    color: #bfead5;\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n    font-size:13px;\n    box-shadow: 0 12px 30px rgba(2,6,23,0.5);\n    overflow:hidden;\n  }\n\n  .code {\n    display:block;\n    white-space:pre;\n    line-height:1.5;\n  }\n\n  /* small visual hint for LIFO flow */\n  .flow{\n    display:flex;\n    gap:8px;\n    align-items:center;\n    margin-top:8px;\n  }\n\n  .flow .dot{\n    width:12px;\n    height:12px;\n    border-radius:50%;\n    background: linear-gradient(90deg,var(--accent),var(--accent-2));\n    box-shadow: 0 6px 18px rgba(139,92,246,0.12);\n  }\n  .flow .arrow{\n    color:rgba(255,255,255,0.6);\n    font-weight:700;\n    transform:translateY(-2px);\n  }\n\n  /* small footer decorative */\n  .footer{\n    margin-top:auto;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n  .signature{\n    color:rgba(255,255,255,0.5);\n    font-size:13px;\n  }\n\n  /* Animations for popping/pushing */\n  @keyframes floatIn {\n    from { transform: translate(-50%, 160px) rotate(6deg) scale(0.92); opacity:0.0 }\n    60% { transform: translate(-50%, -12px) rotate(-2deg) scale(1.02); opacity:1 }\n    to { transform: translate(-50%, 0px) rotate(0deg) scale(1); opacity:1 }\n  }\n  @keyframes floatOut {\n    from { transform: translate(-50%, 0px) rotate(0deg) scale(1); opacity:1 }\n    to { transform: translate(-50%, -220px) rotate(12deg) scale(0.96); opacity:0 }\n  }\n\n  /* subtle stagger for deeper cards */\n\n  /* responsive */\n  @media (max-width:980px){\n    .stage{ grid-template-columns: 1fr; }\n    .visual{ order:2 }\n    .info{ order:1 }\n    .well{ height:260px }\n  }\n\n</style>\n</head>\n<body>\n  <section class=\"stage\" aria-labelledby=\"heading\">\n    <div class=\"visual\" role=\"region\" aria-label=\"Stack visualization\">\n      <div>\n        <div class=\"visual-header\">\n          <div>\n            <div class=\"title\">Stack <span style=\"font-size:12px;color:rgba(255,255,255,0.55);font-weight:600;margin-left:8px\">LIFO — Last In, First Out</span></div>\n            <div class=\"meta\" style=\"margin-top:8px\">\n              <div style=\"display:flex;gap:8px;align-items:center\">\n                <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9\">\n                  <defs></defs>\n                  <path d=\"M12 2v20\" stroke=\"rgba(255,255,255,0.65)\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n                  <path d=\"M5 9h14\" stroke=\"rgba(255,255,255,0.65)\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n                </svg>\n                <span style=\"font-weight:700;color:rgba(255,255,255,0.85)\">Abstract Structure</span>\n              </div>\n              <div style=\"background:rgba(255,255,255,0.02);padding:6px 10px;border-radius:10px;font-size:12px;\">\n                Depth visualized\n              </div>\n            </div>\n          </div>\n          <div style=\"display:flex;flex-direction:column;align-items:flex-end\">\n            <div class=\"badge\">Conceptual</div>\n            <div style=\"font-size:12px;color:rgba(255,255,255,0.5);margin-top:8px\">Elegant demo</div>\n          </div>\n        </div>\n\n        <div class=\"well\" aria-hidden=\"false\">\n          <div class=\"stack\" id=\"stack\">\n            <!-- Cards injected here -->\n            <div class=\"glow\" aria-hidden=\"true\"></div>\n          </div>\n\n          <div class=\"plate\">\n            <div class=\"platemark\">Stack Base</div>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"display:flex;align-items:center;gap:14px;margin-top:16px\">\n        <div class=\"controls\" aria-hidden=\"false\">\n          <button class=\"btn push\" id=\"pushBtn\" title=\"Push an item onto the stack\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.95\"><path d=\"M12 5v14M5 12h14\" stroke=\"rgba(0,0,0,0.7)\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            Push\n          </button>\n          <button class=\"btn pop\" id=\"popBtn\" title=\"Pop the top item off the stack\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.95\"><path d=\"M19 12H5M12 5v14\" stroke=\"rgba(0,0,0,0.7)\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            Pop\n          </button>\n          <div class=\"count\" aria-live=\"polite\"><strong id=\"count\">0</strong> items</div>\n        </div>\n      </div>\n    </div>\n\n    <aside class=\"info\" role=\"complementary\">\n      <div>\n        <div class=\"headline\">Stack — The elegant simplicity of LIFO</div>\n        <div class=\"lead\">\n          A stack is a linear data structure that follows the Last-In-First-Out discipline.\n          Items are added to the \"top\" and removed from the \"top\". The visual at left illustrates depth,\n          order, and motion — watch new elements land on top and depart from the same face.\n        </div>\n\n        <div class=\"flow\" aria-hidden=\"true\">\n          <div style=\"display:flex;flex-direction:column;gap:6px\">\n            <div style=\"width:66px;height:8px;background:linear-gradient(90deg,var(--accent),var(--accent-2));border-radius:6px;box-shadow:0 8px 24px rgba(139,92,246,0.08)\"></div>\n            <div style=\"font-size:11px;color:rgba(255,255,255,0.6);\">Push (add)</div>\n          </div>\n          <div class=\"arrow\">→</div>\n          <div style=\"display:flex;flex-direction:column;gap:6px\">\n            <div style=\"width:66px;height:8px;background:linear-gradient(90deg,var(--accent-2),var(--accent));border-radius:6px;box-shadow:0 8px 24px rgba(110,231,183,0.06)\"></div>\n            <div style=\"font-size:11px;color:rgba(255,255,255,0.6);\">Pop (remove)</div>\n          </div>\n        </div>\n\n        <div class=\"codecard\" aria-hidden=\"false\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\">\n            <div style=\"font-weight:700\">Pseudo</div>\n            <div style=\"font-size:12px;color:rgba(255,255,255,0.55)\">LIFO</div>\n          </div>\n          <code class=\"code\">\npush(stack, item) {\n  stack[top + 1] = item\n  top = top + 1\n}\n\npop(stack) {\n  item = stack[top]\n  top = top - 1\n  return item\n}\n          </code>\n        </div>\n      </div>\n\n      <div class=\"footer\">\n        <div class=\"signature\">Aesthetic Data Structures — Visualized</div>\n        <div style=\"font-size:12px;color:rgba(255,255,255,0.55)\">Tip: Use the Push/Pop controls</div>\n      </div>\n    </aside>\n  </section>\n\n<script>\n(function(){\n  const stackEl = document.getElementById('stack');\n  const pushBtn = document.getElementById('pushBtn');\n  const popBtn = document.getElementById('popBtn');\n  const countEl = document.getElementById('count');\n\n  let items = []; // simple stack data\n  let idCounter = 1;\n  const maxDepth = 9;\n\n  // initial seeded items for visual richness\n  for(let i=0;i<3;i++){ seedPush(); }\n\n  function seedPush(){\n    const label = `Item ${idCounter++}`;\n    const colorSeed = Math.random();\n    const obj = { id: Date.now() + Math.random(), label, colorSeed };\n    items.push(obj);\n    renderStack(true);\n  }\n\n  function renderStack(animated){\n    // clamp to maxDepth by keeping only most recent if exceeding, but still keep count\n    const visible = items.slice(-maxDepth);\n    // cleanup existing nodes that are not matching\n    const existing = Array.from(stackEl.querySelectorAll('.card'));\n    // remove nodes not in visible\n    existing.forEach(node=>{\n      const nid = node.dataset.nid;\n      if(!visible.find(v=>String(v.id)===nid)){\n        node.remove();\n      }\n    });\n\n    // create or update nodes for visible items\n    visible.forEach((it, idx)=>{\n      let node = stackEl.querySelector(`.card[data-nid=\"${it.id}\"]`);\n      const depthIndex = visible.length - idx - 1; // 0 = bottom, increasing upward\n      const bottomOffset = depthIndex * 18; // spacing between cards\n      const z = 220 + idx;\n      if(!node){\n        node = document.createElement('div');\n        node.className = 'card';\n        node.dataset.nid = it.id;\n        node.innerHTML = `<div class=\"label\">${escapeHtml(it.label)}</div><div class=\"sub\">#${items.indexOf(it)+1}</div>`;\n        stackEl.appendChild(node);\n        // initial off-screen for push animation\n        if(animated && idx === visible.length - 1){\n          node.style.animation = 'floatIn 640ms cubic-bezier(.2,.9,.2,1) both';\n        } else {\n          node.style.opacity = 1;\n        }\n      } else {\n        node.style.animation = '';\n      }\n\n      // random subtle rotation for depth (consistent per item)\n      const twist = Math.round((it.colorSeed * 8) - 4); // -4..4 degrees\n      // compute transform to place card\n      const translateY = -bottomOffset;\n      const rotateZ = twist + (idx===visible.length-1 ? 0 : (idx*0.4));\n      node.style.transform = `translate(-50%, ${translateY}px) rotate(${rotateZ}deg)`;\n      node.style.zIndex = String(z);\n\n      // staggered color tint for edge\n      const hue = 230 + Math.round(it.colorSeed * 60);\n      node.style.setProperty('--edge-color', `hsl(${hue} 85% 60%)`);\n      // subtle depth blur/brightness\n      const blur = Math.min(8, 2 + idx*1.2);\n      node.style.filter = `drop-shadow(0 ${6+idx}px ${12+idx*2}px rgba(2,6,23,${0.35 + idx*0.02}))`;\n      node.style.opacity = 1 - (visible.length - idx - 1)*0.02;\n    });\n\n    // update count\n    countEl.textContent = String(items.length);\n\n    // animate re-positioning for remaining nodes\n    const nodes = Array.from(stackEl.querySelectorAll('.card'));\n    nodes.forEach((n, index)=>{\n      // gentle transition on transform is controlled by CSS transition\n      // nothing else to do here\n    });\n\n    // disable pop if empty\n    popBtn.disabled = items.length === 0;\n    pushBtn.disabled = items.length >= 9999; // safeguard\n    popBtn.style.opacity = items.length === 0 ? 0.5 : 1;\n  }\n\n  // push handler\n  pushBtn.addEventListener('click', ()=>{\n    const label = `Item ${idCounter++}`;\n    const obj = { id: Date.now() + Math.random(), label, colorSeed: Math.random() };\n    items.push(obj);\n    // if we exceed a visual threshold, keep full count but only render last maxDepth items\n    renderStack(true);\n  });\n\n  // pop handler\n  popBtn.addEventListener('click', ()=>{\n    if(items.length === 0) return;\n    // animate top visible card out\n    const top = items.pop();\n    const node = stackEl.querySelector(`.card[data-nid=\"${top.id}\"]`);\n    if(node){\n      node.style.animation = 'floatOut 540ms cubic-bezier(.2,.9,.2,1) both';\n      // after animation remove node and re-render\n      setTimeout(()=>{ node.remove(); renderStack(false); }, 560);\n    } else {\n      renderStack(false);\n    }\n    // update count immediately for clarity\n    countEl.textContent = String(items.length);\n  });\n\n  // subtle automatic demo pulse to guide the eye (non-intrusive)\n  let demoTimer = setInterval(()=>{\n    // small gentle push-pop demo only if user hasn't interacted (limit interactivity)\n    // But to honor extremely limited interactivity, don't auto-modify if user clicked\n  }, 4000);\n\n  // keyboard support for accessibility: P = push, O = pop\n  let interacted = false;\n  [pushBtn, popBtn].forEach(btn => btn.addEventListener('click', ()=>{ interacted = true; clearInterval(demoTimer);} ));\n\n  document.addEventListener('keydown', (e)=>{\n    if(e.key === 'p' || e.key === 'P'){ pushBtn.click(); }\n    if(e.key === 'o' || e.key === 'O'){ popBtn.click(); }\n  });\n\n  // tiny helper\n  function escapeHtml(s){ return s.replace(/[&<>\"']/g, c=>({ \"&\":\"&amp;\",\"<\":\"&lt;\",\">\":\"&gt;\",'\"':\"&quot;\",\"'\":\"&#39;\" })[c]); }\n\n  // initial render\n  renderStack(false);\n\n})();\n</script>\n</body>\n</html>"
  },
