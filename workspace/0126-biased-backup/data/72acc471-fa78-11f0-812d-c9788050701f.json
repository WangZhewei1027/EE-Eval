    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>The Beauty of Git</title>\n    <style>\n        :root {\n            --primary: #f05133;\n            --secondary: #4078c0;\n            --dark: #2d2d2d;\n            --light: #f5f5f5;\n            --accent: #6cc644;\n            --highlight: #ffdd40;\n            --code-bg: #f8f8f8;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #fafafa 0%, #eaeaea 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 4rem;\n            position: relative;\n        }\n\n        h1 {\n            font-size: 4rem;\n            font-weight: 800;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            letter-spacing: -0.05em;\n        }\n\n        .subtitle {\n            font-size: 1.5rem;\n            color: #666;\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .git-logo {\n            width: 120px;\n            height: 120px;\n            margin: 2rem auto;\n            position: relative;\n            animation: float 6s ease-in-out infinite;\n        }\n\n        .git-logo svg {\n            width: 100%;\n            height: 100%;\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0) rotate(0deg); }\n            50% { transform: translateY(-15px) rotate(2deg); }\n        }\n\n        .concept-container {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            margin: 4rem 0;\n        }\n\n        .concept-card {\n            background: white;\n            border-radius: 16px;\n            padding: 2rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            border: 1px solid rgba(0, 0, 0, 0.05);\n        }\n\n        .concept-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n        }\n\n        .concept-card h2 {\n            font-size: 1.8rem;\n            margin-bottom: 1rem;\n            color: var(--primary);\n        }\n\n        .concept-card p {\n            color: #555;\n            line-height: 1.6;\n            margin-bottom: 1.5rem;\n        }\n\n        .concept-icon {\n            width: 60px;\n            height: 60px;\n            background: linear-gradient(45deg, var(--secondary), var(--primary));\n            border-radius: 12px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin-bottom: 1.5rem;\n            color: white;\n            font-size: 1.8rem;\n        }\n\n        .branch-visualization {\n            width: 100%;\n            height: 400px;\n            margin: 4rem 0;\n            position: relative;\n        }\n\n        .branch-line {\n            position: absolute;\n            top: 50px;\n            left: 50%;\n            width: 4px;\n            height: 300px;\n            background: var(--dark);\n            transform: translateX(-50%);\n        }\n\n        .commit {\n            position: absolute;\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            background: var(--primary);\n            border: 4px solid white;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);\n            z-index: 2;\n            transition: all 0.4s ease;\n        }\n\n        .commit-label {\n            position: absolute;\n            font-size: 0.9rem;\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            pointer-events: none;\n            background: white;\n            padding: 0.3rem 0.8rem;\n            border-radius: 20px;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .branch {\n            position: absolute;\n            height: 4px;\n            background: var(--secondary);\n            z-index: 1;\n            transition: all 0.4s ease;\n        }\n\n        .branch-label {\n            position: absolute;\n            font-size: 0.9rem;\n            font-weight: 600;\n            color: var(--secondary);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin: 2rem 0;\n        }\n\n        button {\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.8rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 500;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(64, 120, 192, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(64, 120, 192, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .footer {\n            text-align: center;\n            margin-top: 4rem;\n            color: #888;\n            font-size: 0.9rem;\n        }\n\n        .animate-graph {\n            animation: graphPulse 2s infinite alternate;\n        }\n\n        @keyframes graphPulse {\n            0% { transform: scale(1); }\n            100% { transform: scale(1.02); }\n        }\n\n        .highlight {\n            position: absolute;\n            background: var(--highlight);\n            width: 100%;\n            height: 30%;\n            top: 0;\n            left: 0;\n            z-index: -1;\n            opacity: 0.3;\n            border-radius: 16px 16px 0 0;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <div class=\"git-logo\">\n                <svg viewBox=\"0 0 32 32\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M2.585 17.413a1.999 1.999 0 0 1 0-2.826L14.587 2.585c.78-.78 2.046-.78 2.826 0l12.002 12.002c.78.78.78 2.046 0 2.826L17.413 29.415c-.78.78-2.046.78-2.826 0L2.585 17.413z\" fill=\"#F05133\"/>\n                    <path d=\"M12.149 5.062l-7.083 7.083a1.999 1.999 0 0 0 0 2.826l7.083 7.083a1.999 1.999 0 0 0 2.826 0l1.714-1.714-4.043-4.043a1.25 1.25 0 1 1 1.768-1.768l4.043 4.043 3.3-3.3a1.25 1.25 0 1 1 1.768 1.768l-3.3 3.3 1.779 1.779a1.999 1.999 0 0 0 2.826 0l7.083-7.083a1.999 1.999 0 0 0 0-2.826l-7.083-7.083a1.999 1.999 0 0 0-2.826 0l-1.714 1.714 4.043 4.043a1.25 1.25 0 1 1-1.768 1.768l-4.043-4.043-3.3 3.3a1.25 1.25 0 1 1-1.768-1.768l3.3-3.3-1.779-1.779a1.999 1.999 0 0 0-2.826 0z\" fill=\"#ffffff\"/>\n                </svg>\n            </div>\n            <h1>Git Visualized</h1>\n            <p class=\"subtitle\">The distributed version control system that revolutionized software development, presented with elegance and clarity.</p>\n        </header>\n\n        <div class=\"concept-container\">\n            <div class=\"concept-card\">\n                <div class=\"highlight\"></div>\n                <div class=\"concept-icon\">⎇</div>\n                <h2>Distributed</h2>\n                <p>Every developer has the full history of the project locally, enabling offline work and fast operations. No single point of failure.</p>\n            </div>\n            <div class=\"concept-card\">\n                <div class=\"highlight\"></div>\n                <div class=\"concept-icon\">⏱</div>\n                <h2>Version Control</h2>\n                <p>Track changes to files over time. Revert to previous states, compare changes, and see who modified what and when.</p>\n            </div>\n            <div class=\"concept-card\">\n                <div class=\"highlight\"></div>\n                <div class=\"concept-icon\">⎃</div>\n                <h2>Branching</h2>\n                <p>Create lightweight branches to isolate development work without affecting other branches. Merge when ready.</p>\n            </div>\n        </div>\n\n        <div class=\"branch-visualization animate-graph\">\n            <div class=\"branch-line\"></div>\n            \n            <div class=\"branch\" id=\"main-branch\" style=\"width: 100px; top: 80px; left: 50%; transform: translateX(-50%);\"></div>\n            <div class=\"branch-label\" style=\"top: 70px; left: calc(50% + 60px);\">main</div>\n            \n            <div class=\"commit\" id=\"commit-1\" style=\"top: 80px; left: 50%; transform: translateX(-50%);\"></div>\n            <div class=\"commit-label\" style=\"top: 60px; left: calc(50% + 20px);\">Initial commit</div>\n            \n            <div class=\"commit\" id=\"commit-2\" style=\"top: 150px; left: 50%; transform: translateX(-50%);\"></div>\n            <div class=\"commit-label\" style=\"top: 130px; left: calc(50% + 20px);\">Add login page</div>\n            \n            <div class=\"branch\" id=\"feature-branch\" style=\"width: 100px; top: 220px; left: calc(50% - 50px); transform: rotate(-30deg); transform-origin: right center;\"></div>\n            <div class=\"branch-label\" style=\"top: 200px; left: calc(50% - 40px);\">feature/auth</div>\n            \n            <div class=\"commit\" id=\"commit-3\" style=\"top: 220px; left: calc(50% - 100px);\"></div>\n            <div class=\"commit-label\" style=\"top: 200px; left: calc(50% - 130px);\">Auth middleware</div>\n            \n            <div class=\"commit\" id=\"commit-4\" style=\"top: 300px; left: calc(50% - 100px);\"></div>\n            <div class=\"commit-label\" style=\"top: 280px; left: calc(50% - 130px);\">JWT support</div>\n            \n            <div class=\"branch\" id=\"merge-line\" style=\"width: 100px; height: 4px; top: 380px; left: calc(50% - 100px);\"></div>\n            <div class=\"commit\" id=\"commit-5\" style=\"top: 380px; left: 50%; transform: translateX(-50%);\"></div>\n            <div class=\"commit-label\" style=\"top: 360px; left: calc(50% + 20px);\">Merge auth</div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"animate-btn\">Animate Flow</button>\n        </div>\n\n        <div class=\"concept-container\">\n            <div class=\"concept-card\">\n                <div class=\"highlight\"></div>\n                <div class=\"concept-icon\">✓</div>\n                <h2>Staging Area</h2>\n                <p>A unique feature of Git that lets you craft commits precisely by staging changes before committing them.</p>\n            </div>\n            <div class=\"concept-card\">\n                <div class=\"highlight\"></div>\n                <div class=\"concept-icon\">⎌</div>\n                <h2>Undo Anything</h2>\n                <p>Git makes it nearly impossible to lose work. Mistakes can almost always be undone with the right commands.</p>\n            </div>\n            <div class=\"concept-card\">\n                <div class=\"highlight\"></div>\n                <div class=\"concept-icon\">⚡</div>\n                <h2>Fast & Efficient</h2>\n                <p>Git operations are mostly local, making them extremely fast. Designed to handle large projects with speed.</p>\n            </div>\n        </div>\n\n        <div class=\"footer\">\n            <p>A visual exploration of Git's core concepts • Git logo is a trademark of Software Freedom Conservancy</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const commits = document.querySelectorAll('.commit');\n            const labels = document.querySelectorAll('.commit-label');\n            const animateBtn = document.getElementById('animate-btn');\n            let isAnimating = false;\n\n            // Highlight commits on hover\n            commits.forEach((commit, index) => {\n                commit.addEventListener('mouseover', () => {\n                    labels[index].style.opacity = '1';\n                    commit.style.transform = commit.style.transform.replace('scale(1)', 'scale(1.3)');\n                    commit.style.boxShadow = '0 5px 20px rgba(240, 81, 51, 0.4)';\n                });\n\n                commit.addEventListener('mouseout', () => {\n                    labels[index].style.opacity = '0';\n                    commit.style.transform = commit.style.transform.replace('scale(1.3)', 'scale(1)');\n                    commit.style.boxShadow = '0 3px 10px rgba(0, 0, 0, 0.1)';\n                });\n            });\n\n            // Animate git flow on button click\n            animateBtn.addEventListener('click', () => {\n                if (isAnimating) return;\n                isAnimating = true;\n                \n                const branchVisualization = document.querySelector('.branch-visualization');\n                branchVisualization.classList.remove('animate-graph');\n\n                // Reset all elements to initial state\n                document.getElementById('feature-branch').style.width = '0';\n                document.getElementById('merge-line').style.width = '0';\n                document.getElementById('merge-line').style.height = '4px';\n                \n                commits.forEach(commit => {\n                    commit.style.opacity = '0.3';\n                    commit.style.transform = commit.style.transform + ' scale(0.7)';\n                });\n\n                // Animate the feature branch creation\n                setTimeout(() => {\n                    document.getElementById('commit-1').style.opacity = '1';\n                    document.getElementById('commit-1').style.transform = 'translateX(-50%) scale(1.5)';\n                }, 300);\n\n                setTimeout(() => {\n                    document.getElementById('commit-1').style.transform = 'translateX(-50%) scale(1)';\n                    document.getElementById('commit-2').style.opacity = '1';\n                    document.getElementById('commit-2').style.transform = 'translateX(-50%) scale(1.5)';\n                }, 800);\n\n                setTimeout(() => {\n                    document.getElementById('commit-2').style.transform = 'translateX(-50%) scale(1)';\n                    document.getElementById('feature-branch').style.width = '100px';\n                    document.getElementById('commit-3').style.opacity = '1';\n                    document.getElementById('commit-3').style.transform = 'scale(1.5)';\n                }, 1300);\n\n                setTimeout(() => {\n                    document.getElementById('commit-3').style.transform = 'scale(1)';\n                    document.getElementById('commit-4').style.opacity = '1';\n                    document.getElementById('commit-4').style.transform = 'scale(1.5)';\n                }, 1800);\n\n                setTimeout(() => {\n                    document.getElementById('commit-4').style.transform = 'scale(1)';\n                    document.getElementById('merge-line').style.width = '100px';\n                    document.getElementById('merge-line').style.height = '80px';\n                }, 2300);\n\n                setTimeout(() => {\n                    document.getElementById('commit-5').style.opacity = '1';\n                    document.getElementById('commit-5').style.transform = 'translateX(-50%) scale(1.5)';\n                }, 2800);\n\n                setTimeout(() => {\n                    document.getElementById('commit-5').style.transform = 'translateX(-50%) scale(1)';\n                    isAnimating = false;\n                    branchVisualization.classList.add('animate-graph');\n                }, 3300);\n            });\n        });\n    </script>\n</body>\n</html>"
