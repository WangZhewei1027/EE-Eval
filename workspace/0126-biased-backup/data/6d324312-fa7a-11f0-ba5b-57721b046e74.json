  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Garbage Collection Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #000; padding: 10px; }\n        .memory-visualization { height: 300px; border: 1px solid #000; position: relative; }\n        .memory-block { position: absolute; border: 1px solid #000; text-align: center; }\n        hidden { display: none; }\n        button, input, select { margin: 5px; }\n        .controls { display: flex; flex-wrap: wrap; gap: 10px; }\n        .control-group { border: 1px solid #000; padding: 10px; margin-bottom: 10px; }\n        .log { height: 150px; overflow-y: scroll; border: 1px solid #000; padding: 5px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Garbage Collection Interactive Demo</h1>\n        \n        <div class=\"panel\">\n            <h2>Memory Visualization</h2>\n            <div id=\"memory\" class=\"memory-visualization\"></div>\n            <div>\n                Memory Usage: <span id=\"memory-usage\">0</span>% \n                <input type=\"range\" id=\"memory-limit\" min=\"10\" max=\"100\" value=\"80\"> \n                (Limit: <span id=\"limit-value\">80</span>%)\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Controls</h2>\n            <div class=\"controls\">\n                <div class=\"control-group\">\n                    <h3>Object Creation</h3>\n                    <div>\n                        <button id=\"create-small\">Create Small Object (1%)</button>\n                        <button id=\"create-medium\">Create Medium Object (5%)</button>\n                        <button id=\"create-large\">Create Large Object (10%)</button>\n                    </div>\n                    <div>\n                        <input type=\"number\" id=\"custom-size\" min=\"1\" max=\"20\" value=\"5\">\n                        <button id=\"create-custom\">Create Custom Size Object</button>\n                    </div>\n                    <div>\n                        <button id=\"create-reachable\">Create Reachable Object</button>\n                        <button id=\"create-unreachable\">Create Unreachable Object</button>\n                    </div>\n                </div>\n                \n                <div class=\"control-group\">\n                    <h3>References</h3>\n                    <div>\n                        <select id=\"from-object\"></select> → \n                        <select id=\"to-object\"></select>\n                        <button id=\"add-reference\">Add Reference</button>\n                    </div>\n                    <div>\n                        <select id=\"remove-ref-select\"></select>\n                        <button id=\"remove-reference\">Remove Reference</button>\n                    </div>\n                    <div>\n                        <button id=\"clear-references\">Clear All References</button>\n                    </div>\n                </div>\n                \n                <div class=\"control-group\">\n                    <h3>Garbage Collection</h3>\n                    <div>\n                        <select id=\"gc-type\">\n                            <option value=\"mark-sweep\">Mark and Sweep</option>\n                            <option value=\"reference-counting\">Reference Counting</option>\n                            <option value=\"generational\">Generational</option>\n                        </select>\n                        <button id=\"run-gc\">Run Garbage Collector</button>\n                    </div>\n                    <div>\n                        <button id=\"auto-gc\">Toggle Auto GC</button>\n                        <span id=\"auto-gc-status\">(OFF)</span>\n                    </div>\n                    <div>\n                        GC Interval (ms): <input type=\"number\" id=\"gc-interval\" min=\"100\" max=\"10000\" value=\"2000\">\n                    </div>\n                </div>\n                \n                <div class=\"control-group\">\n                    <h3>Simulation</h3>\n                    <div>\n                        <button id=\"reset\">Reset Memory</button>\n                    </div>\n                    <div>\n                        <button id=\"fill-memory\">Fill Memory to Limit</button>\n                    </div>\n                    <div>\n                        <button id=\"create-cycle\">Create Reference Cycle</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Object Graph</h2>\n            <div id=\"object-graph\" style=\"height: 200px; overflow: auto; border: 1px solid #000;\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Event Log</h2>\n            <div id=\"log\" class=\"log\"></div>\n        </div>\n    </div>\n\n    <script>\n        // State management\n        const state = {\n            objects: [],\n            references: [],\n            nextId: 1,\n            memoryLimit: 80,\n            autoGC: false,\n            gcInterval: 2000,\n            intervalId: null,\n            gcTypes: {\n                'mark-sweep': {\n                    name: 'Mark and Sweep',\n                    description: 'Traverses all reachable objects from roots, then sweeps unreachable ones'\n                },\n                'reference-counting': {\n                    name: 'Reference Counting',\n                    description: 'Counts references to each object and collects when count reaches zero'\n                },\n                'generational': {\n                    name: 'Generational',\n                    description: 'Divides objects by age and collects younger generations more frequently'\n                }\n            }\n        };\n\n        // DOM elements\n        const elements = {\n            memory: document.getElementById('memory'),\n            memoryUsage: document.getElementById('memory-usage'),\n            memoryLimit: document.getElementById('memory-limit'),\n            limitValue: document.getElementById('limit-value'),\n            createSmall: document.getElementById('create-small'),\n            createMedium: document.getElementById('create-medium'),\n            createLarge: document.getElementById('create-large'),\n            createCustom: document.getElementById('create-custom'),\n            customSize: document.getElementById('custom-size'),\n            createReachable: document.getElementById('create-reachable'),\n            createUnreachable: document.getElementById('create-unreachable'),\n            fromObject: document.getElementById('from-object'),\n            toObject: document.getElementById('to-object'),\n            addReference: document.getElementById('add-reference'),\n            removeRefSelect: document.getElementById('remove-ref-select'),\n            removeReference: document.getElementById('remove-reference'),\n            clearReferences: document.getElementById('clear-references'),\n            gcType: document.getElementById('gc-type'),\n            runGc: document.getElementById('run-gc'),\n            autoGc: document.getElementById('auto-gc'),\n            autoGcStatus: document.getElementById('auto-gc-status'),\n            gcInterval: document.getElementById('gc-interval'),\n            reset: document.getElementById('reset'),\n            fillMemory: document.getElementById('fill-memory'),\n            createCycle: document.getElementById('create-cycle'),\n            objectGraph: document.getElementById('object-graph'),\n            log: document.getElementById('log')\n        };\n\n        // Helper functions\n        function log(message) {\n            const entry = document.createElement('div');\n            entry.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;\n            elements.log.appendChild(entry);\n            elements.log.scrollTop = elements.log.scrollHeight;\n        }\n\n        function getMemoryUsage() {\n            return state.objects.reduce((sum, obj) => sum + obj.size, 0);\n        }\n\n        function updateMemoryUsage() {\n            const usage = getMemoryUsage();\n            elements.memoryUsage.textContent = usage;\n            elements.limitValue.textContent = state.memoryLimit;\n            \n            // Update memory visualization\n            elements.memory.innerHTML = '';\n            state.objects.forEach(obj => {\n                const block = document.createElement('div');\n                block.className = 'memory-block';\n                block.id = `obj-${obj.id}`;\n                block.style.width = '50px';\n                block.style.height = `${obj.size * 2}px`;\n                block.style.left = `${Math.random() * 80}%`;\n                block.style.top = `${Math.random() * 80}%`;\n                block.textContent = `Obj ${obj.id}`;\n                block.title = `Size: ${obj.size}% | Refs: ${state.references.filter(r => r.from === obj.id).length}`;\n                \n                if (obj.reachable) {\n                    block.style.backgroundColor = '#e0e0e0';\n                } else {\n                    block.style.backgroundColor = '#f0f0f0';\n                    block.style.border = '1px dashed #999';\n                }\n                \n                elements.memory.appendChild(block);\n            });\n        }\n\n        function updateObjectSelects() {\n            elements.fromObject.innerHTML = '';\n            elements.toObject.innerHTML = '';\n            elements.removeRefSelect.innerHTML = '<option value=\"\">Select reference to remove</option>';\n            \n            state.objects.forEach(obj => {\n                const option1 = document.createElement('option');\n                option1.value = obj.id;\n                option1.textContent = `Object ${obj.id}`;\n                elements.fromObject.appendChild(option1);\n                \n                const option2 = document.createElement('option');\n                option2.value = obj.id;\n                option2.textContent = `Object ${obj.id}`;\n                elements.toObject.appendChild(option2);\n            });\n            \n            state.references.forEach(ref => {\n                const option = document.createElement('option');\n                option.value = ref.id;\n                option.textContent = `Object ${ref.from} → Object ${ref.to}`;\n                elements.removeRefSelect.appendChild(option);\n            });\n        }\n\n        function updateObjectGraph() {\n            elements.objectGraph.innerHTML = '';\n            \n            if (state.objects.length === 0) {\n                elements.objectGraph.textContent = 'No objects in memory';\n                return;\n            }\n            \n            const roots = state.objects.filter(obj => \n                !state.references.some(ref => ref.to === obj.id)\n            );\n            \n            const graph = document.createElement('div');\n            \n            if (roots.length > 0) {\n                const rootsTitle = document.createElement('div');\n                rootsTitle.textContent = 'Roots:';\n                graph.appendChild(rootsTitle);\n                \n                const rootsList = document.createElement('div');\n                rootsList.style.marginLeft = '20px';\n                roots.forEach(root => {\n                    const rootItem = document.createElement('div');\n                    rootItem.textContent = `Object ${root.id}`;\n                    rootsList.appendChild(rootItem);\n                    buildReferenceTree(root.id, rootsList, 40);\n                });\n                graph.appendChild(rootsList);\n            } else {\n                graph.textContent = 'No root objects (everything is garbage)';\n            }\n            \n            elements.objectGraph.appendChild(graph);\n        }\n        \n        function buildReferenceTree(objectId, parentElement, indent) {\n            const references = state.references.filter(ref => ref.from === objectId);\n            \n            if (references.length === 0) return;\n            \n            references.forEach(ref => {\n                const refItem = document.createElement('div');\n                refItem.style.marginLeft = `${indent}px`;\n                refItem.textContent = `→ Object ${ref.to}`;\n                parentElement.appendChild(refItem);\n                buildReferenceTree(ref.to, parentElement, indent + 20);\n            });\n        }\n\n        function markReachableObjects() {\n            // Reset reachability\n            state.objects.forEach(obj => obj.reachable = false);\n            \n            // Find roots (objects not referenced by any other object)\n            const roots = state.objects.filter(obj => \n                !state.references.some(ref => ref.to === obj.id)\n            );\n            \n            // Mark all reachable objects from roots\n            function markFromObject(id) {\n                const obj = state.objects.find(o => o.id === id);\n                if (!obj || obj.reachable) return;\n                \n                obj.reachable = true;\n                state.references\n                    .filter(ref => ref.from === id)\n                    .forEach(ref => markFromObject(ref.to));\n            }\n            \n            roots.forEach(root => markFromObject(root.id));\n        }\n\n        // Core functionality\n        function createObject(size, reachable = true) {\n            if (getMemoryUsage() + size > state.memoryLimit) {\n                log(`Cannot create object: memory limit would be exceeded (${getMemoryUsage()} + ${size} > ${state.memoryLimit})`);\n                if (state.autoGC) {\n                    runGarbageCollection();\n                    if (getMemoryUsage() + size <= state.memoryLimit) {\n                        return createObject(size, reachable);\n                    }\n                }\n                return null;\n            }\n            \n            const obj = {\n                id: state.nextId++,\n                size: size,\n                reachable: reachable\n            };\n            \n            state.objects.push(obj);\n            log(`Created Object ${obj.id} (size: ${size}%, reachable: ${reachable})`);\n            updateMemoryUsage();\n            updateObjectSelects();\n            updateObjectGraph();\n            \n            return obj;\n        }\n\n        function addReference(fromId, toId) {\n            if (fromId === toId) {\n                log('Cannot create self-reference (this would create a cycle)');\n                return;\n            }\n            \n            const fromObj = state.objects.find(o => o.id === parseInt(fromId));\n            const toObj = state.objects.find(o => o.id === parseInt(toId));\n            \n            if (!fromObj || !toObj) {\n                log('Invalid object reference');\n                return;\n            }\n            \n            if (state.references.some(ref => ref.from === fromId && ref.to === toId)) {\n                log(`Reference from Object ${fromId} to Object ${toId} already exists`);\n                return;\n            }\n            \n            const ref = {\n                id: state.nextId++,\n                from: parseInt(fromId),\n                to: parseInt(toId)\n            };\n            \n            state.references.push(ref);\n            log(`Added reference: Object ${fromId} → Object ${toId}`);\n            updateObjectSelects();\n            updateObjectGraph();\n        }\n\n        function removeReference(refId) {\n            const index = state.references.findIndex(ref => ref.id === parseInt(refId));\n            if (index === -1) {\n                log('Invalid reference ID');\n                return;\n            }\n            \n            const ref = state.references[index];\n            state.references.splice(index, 1);\n            log(`Removed reference: Object ${ref.from} → Object ${ref.to}`);\n            updateObjectSelects();\n            updateObjectGraph();\n        }\n\n        function runGarbageCollection() {\n            const gcType = state.gcTypes[elements.gcType.value];\n            log(`Running ${gcType.name} garbage collection...`);\n            log(`Description: ${gcType.description}`);\n            \n            // Mark phase (for mark-sweep and generational)\n            if (elements.gcType.value === 'mark-sweep' || elements.gcType.value === 'generational') {\n                markReachableObjects();\n            }\n            \n            // Reference counting (for reference-counting GC)\n            if (elements.gcType.value === 'reference-counting') {\n                // In a real ref-counting system, we'd decrement counts when references are removed\n                // Here we'll just simulate it by checking for objects with no references\n                state.objects.forEach(obj => {\n                    obj.reachable = state.references.some(ref => ref.to === obj.id);\n                });\n            }\n            \n            // Sweep phase - remove unreachable objects\n            const beforeCount = state.objects.length;\n            state.objects = state.objects.filter(obj => {\n                if (!obj.reachable) {\n                    log(`Collected Object ${obj.id} (size: ${obj.size}%)`);\n                    // Remove all references to/from this object\n                    state.references = state.references.filter(ref => \n                        ref.from !== obj.id && ref.to !== obj.id\n                    );\n                    return false;\n                }\n                return true;\n            });\n            \n            const collected = beforeCount - state.objects.length;\n            log(`Garbage collection complete. Collected ${collected} objects.`);\n            \n            updateMemoryUsage();\n            updateObjectSelects();\n            updateObjectGraph();\n        }\n\n        function toggleAutoGC() {\n            state.autoGC = !state.autoGC;\n            elements.autoGcStatus.textContent = state.autoGC ? '(ON)' : '(OFF)';\n            \n            if (state.autoGC) {\n                state.intervalId = setInterval(() => {\n                    if (getMemoryUsage() > state.memoryLimit * 0.8) {\n                        runGarbageCollection();\n                    }\n                }, state.gcInterval);\n                log(`Auto GC enabled (interval: ${state.gcInterval}ms)`);\n            } else {\n                clearInterval(state.intervalId);\n                log('Auto GC disabled');\n            }\n        }\n\n        function resetMemory() {\n            state.objects = [];\n            state.references = [];\n            state.nextId = 1;\n            log('Memory reset');\n            updateMemoryUsage();\n            updateObjectSelects();\n            updateObjectGraph();\n        }\n\n        function fillMemory() {\n            const remaining = state.memoryLimit - getMemoryUsage();\n            if (remaining <= 0) {\n                log('Memory is already full');\n                return;\n            }\n            \n            const size = Math.min(5, remaining);\n            createObject(size);\n            \n            if (getMemoryUsage() < state.memoryLimit) {\n                setTimeout(fillMemory, 100);\n            }\n        }\n\n        function createReferenceCycle() {\n            if (state.objects.length < 2) {\n                log('Need at least 2 objects to create a cycle');\n                return;\n            }\n            \n            // Create a cycle between the first and last objects\n            const first = state.objects[0].id;\n            const last = state.objects[state.objects.length - 1].id;\n            \n            addReference(first, last);\n            addReference(last, first);\n            \n            log(`Created reference cycle between Object ${first} and Object ${last}`);\n        }\n\n        // Event listeners\n        elements.createSmall.addEventListener('click', () => createObject(1));\n        elements.createMedium.addEventListener('click', () => createObject(5));\n        elements.createLarge.addEventListener('click', () => createObject(10));\n        elements.createCustom.addEventListener('click', () => {\n            const size = parseInt(elements.customSize.value);\n            if (size >= 1 && size <= 20) {\n                createObject(size);\n            }\n        });\n        elements.createReachable.addEventListener('click', () => createObject(5, true));\n        elements.createUnreachable.addEventListener('click', () => createObject(5, false));\n        \n        elements.addReference.addEventListener('click', () => {\n            addReference(elements.fromObject.value, elements.toObject.value);\n        });\n        \n        elements.removeReference.addEventListener('click', () => {\n            removeReference(elements.removeRefSelect.value);\n        });\n        \n        elements.clearReferences.addEventListener('click', () => {\n            state.references = [];\n            log('Cleared all references');\n            updateObjectSelects();\n            updateObjectGraph();\n        });\n        \n        elements.runGc.addEventListener('click', runGarbageCollection);\n        elements.autoGc.addEventListener('click', toggleAutoGC);\n        elements.gcInterval.addEventListener('change', () => {\n            state.gcInterval = parseInt(elements.gcInterval.value);\n            if (state.autoGC) {\n                clearInterval(state.intervalId);\n                state.intervalId = setInterval(() => {\n                    if (getMemoryUsage() > state.memoryLimit * 0.8) {\n                        runGarbageCollection();\n                    }\n                }, state.gcInterval);\n                log(`Auto GC interval updated to ${state.gcInterval}ms`);\n            }\n        });\n        \n        elements.reset.addEventListener('click', resetMemory);\n        elements.fillMemory.addEventListener('click', fillMemory);\n        elements.createCycle.addEventListener('click', createReferenceCycle);\n        \n        elements.memoryLimit.addEventListener('input', () => {\n            state.memoryLimit = parseInt(elements.memoryLimit.value);\n            elements.limitValue.textContent = state.memoryLimit;\n        });\n\n        // Initialize\n        log('Garbage Collection Interactive Demo initialized');\n        updateMemoryUsage();\n    </script>\n</body>\n</html>"
  },
