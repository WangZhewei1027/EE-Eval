    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Transaction Concept - Visual Experience</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Root and base */\n  :root {\n    --color-primary: #3a86ff;\n    --color-secondary: #8338ec;\n    --color-accent: #ff006e;\n    --color-bg: #0f1123;\n    --color-bg-alt: #1a1d3d;\n    --color-text-primary: #e0e6f3;\n    --color-text-secondary: #9ca3af;\n    --shadow-glow: 0 0 12px rgba(58, 134, 255, 0.6);\n  }\n\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: var(--color-bg);\n    font-family: 'Poppins', sans-serif;\n    color: var(--color-text-primary);\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    user-select: none;\n  }\n\n  .container {\n    max-width: 960px;\n    margin: 3rem auto 4rem;\n    padding: 0 1.5rem;\n    text-align: center;\n    position: relative;\n    z-index: 2;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.8rem;\n    letter-spacing: 0.08em;\n    margin-bottom: 0.3em;\n    color: var(--color-primary);\n    text-shadow:\n      0 0 8px var(--color-primary),\n      0 0 20px var(--color-primary);\n  }\n\n  h2 {\n    margin-top: 0;\n    font-weight: 300;\n    font-size: 1.3rem;\n    color: var(--color-text-secondary);\n    letter-spacing: 0.1em;\n    margin-bottom: 3rem;\n    text-transform: uppercase;\n    font-style: italic;\n  }\n\n  /* Transaction card */\n  .transaction-card {\n    background: var(--color-bg-alt);\n    border-radius: 20px;\n    padding: 2.8rem 3rem 3rem;\n    box-shadow:\n      0 0 60px rgba(131, 56, 236, 0.35),\n      inset 0 0 30px rgba(58, 134, 255, 0.3);\n    position: relative;\n    overflow: visible;\n    cursor: default;\n    user-select: none;\n    max-width: 600px;\n    margin: 0 auto 4rem;\n    transition: box-shadow 0.5s ease;\n  }\n  .transaction-card:hover {\n    box-shadow:\n      0 0 90px rgba(131, 56, 236, 0.65),\n      inset 0 0 50px rgba(58, 134, 255, 0.5);\n  }\n\n  /* Header row */\n  .row {\n    display: flex;\n    justify-content: space-between;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: var(--color-primary);\n    letter-spacing: 0.1em;\n    margin-bottom: 1rem;\n    user-select: text;\n  }\n  .row span {\n    flex: 1;\n    text-align: center;\n  }\n  .row span.left {\n    text-align: left;\n  }\n  .row span.right {\n    text-align: right;\n  }\n\n  /* Divider lines */\n  .divider {\n    height: 2px;\n    margin: 1.3rem 0 2.5rem;\n    border-radius: 10px;\n    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));\n    filter: drop-shadow(0 0 4px var(--color-primary));\n  }\n\n  /* Transaction details */\n  .trans-details {\n    font-weight: 300;\n    font-size: 1.1rem;\n    color: #c3c9ffcc;\n    margin-bottom: 2.8rem;\n    line-height: 1.4em;\n  }\n\n  /* Amount box */\n  .amount {\n    font-size: 3.1rem;\n    font-weight: 600;\n    letter-spacing: 0.1em;\n    color: var(--color-accent);\n    text-shadow:\n      0 0 10px var(--color-accent),\n      0 0 30px var(--color-accent);\n    user-select: text;\n  }\n\n  /* Status with subtle animation */\n  .status {\n    margin-top: 2rem;\n    font-weight: 600;\n    font-size: 1.15rem;\n    color: var(--color-primary);\n    letter-spacing: 0.12em;\n    position: relative;\n    display: inline-block;\n    text-transform: uppercase;\n    padding: 0.25rem 1.2rem;\n    border-radius: 50px;\n    background: linear-gradient(45deg, var(--color-primary), var(--color-secondary));\n    box-shadow:\n      0 0 14px var(--color-primary);\n    animation: pulse 3.5s infinite ease-in-out;\n    user-select: none;\n  }\n\n  @keyframes pulse {\n    0%, 100% {\n      box-shadow:\n        0 0 14px var(--color-primary),\n        0 0 30px var(--color-secondary);\n      background-position: 0% 50%;\n    }\n    50% {\n      box-shadow:\n        0 0 26px var(--color-secondary),\n        0 0 52px var(--color-primary);\n      background-position: 100% 50%;\n    }\n  }\n\n  /* Buttons container */\n  .btn-group {\n    display: flex;\n    justify-content: center;\n    gap: 1.4rem;\n    margin-top: 3rem;\n  }\n  button {\n    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));\n    border: none;\n    padding: 0.75rem 2.2rem;\n    color: var(--color-text-primary);\n    font-weight: 600;\n    font-size: 1rem;\n    border-radius: 28px;\n    cursor: pointer;\n    box-shadow:\n      0 0 12px var(--color-primary);\n    transition: all 0.3s ease;\n    user-select: none;\n    letter-spacing: 0.07em;\n  }\n  button:hover {\n    box-shadow:\n      0 0 18px var(--color-secondary),\n      0 0 30px var(--color-accent);\n    transform: translateY(-3px) scale(1.05);\n  }\n  button:active {\n    transform: translateY(0) scale(0.98);\n    box-shadow:\n      0 0 12px var(--color-primary);\n  }\n\n  /* SVG background visuals */\n  svg#bg-graphic {\n    position: fixed;\n    top: 0; left: 50%;\n    width: 150vmin;\n    height: 150vmin;\n    transform: translateX(-50%);\n    z-index: 0;\n    pointer-events: none;\n    user-select: none;\n    filter: drop-shadow(0 0 5px var(--color-primary));\n    opacity: 0.18;\n    animation: slowRotate 120s linear infinite;\n  }\n\n  @keyframes slowRotate {\n    from {\n      transform: translateX(-50%) rotate(0deg);\n    }\n    to {\n      transform: translateX(-50%) rotate(360deg);\n    }\n  }\n\n  /* Transaction flow depiction */\n  .flow-diagram {\n    margin-top: 4rem;\n    position: relative;\n    max-width: 700px;\n    margin-left: auto;\n    margin-right: auto;\n    user-select: none;\n  }\n\n  .step {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: var(--color-bg-alt);\n    border-radius: 48px;\n    box-shadow:\n      0 0 20px rgba(131, 56, 236, 0.5);\n    color: var(--color-primary);\n    font-weight: 600;\n    font-size: 1.1rem;\n    padding: 1rem 2.8rem;\n    margin: 0.6rem 0;\n    position: relative;\n    transition: background 0.4s ease;\n  }\n  .step:not(:last-child)::after {\n    content: '';\n    position: absolute;\n    right: -50px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 48px;\n    height: 4px;\n    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));\n    box-shadow:\n      0 0 8px var(--color-primary);\n    border-radius: 2px;\n    animation: moveArrow 2s infinite linear;\n  }\n  .step:last-child::after {\n    display: none;\n  }\n\n  @keyframes moveArrow {\n    0% {\n      background-position: 0% 50%;\n    }\n    100% {\n      background-position: 100% 50%;\n    }\n  }\n\n  /* Smaller text inside steps */\n  .step small {\n    display: block;\n    color: var(--color-text-secondary);\n    font-weight: 300;\n    font-size: 0.8rem;\n    margin-top: 0.22rem;\n  }\n\n  /* Footer text */\n  footer {\n    margin-top: 4rem;\n    font-size: 0.85rem;\n    font-weight: 300;\n    color: var(--color-text-secondary);\n    letter-spacing: 0.06em;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n  <svg id=\"bg-graphic\" viewBox=\"0 0 800 800\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" role=\"img\" focusable=\"false\">\n    <!-- Abstract layered circles & waves -->\n    <defs>\n      <radialGradient id=\"grad1\" cx=\"50%\" cy=\"50%\" r=\"60%\">\n        <stop offset=\"0%\" stop-color=\"#3a86ff\" stop-opacity=\"0.3\"/>\n        <stop offset=\"100%\" stop-color=\"#8338ec\" stop-opacity=\"0\"/>\n      </radialGradient>\n      <radialGradient id=\"grad2\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n        <stop offset=\"0%\" stop-color=\"#ff006e\" stop-opacity=\"0.25\"/>\n        <stop offset=\"100%\" stop-color=\"#3a86ff\" stop-opacity=\"0\"/>\n      </radialGradient>\n      <filter id=\"blur1\" x=\"-40%\" y=\"-40%\" width=\"180%\" height=\"180%\" color-interpolation-filters=\"sRGB\">\n        <feGaussianBlur stdDeviation=\"18\" />\n      </filter>\n    </defs>\n\n    <circle cx=\"400\" cy=\"400\" r=\"280\" fill=\"url(#grad1)\" filter=\"url(#blur1)\" />\n    <circle cx=\"320\" cy=\"360\" r=\"165\" fill=\"url(#grad2)\" filter=\"url(#blur1)\" />\n    <circle cx=\"500\" cy=\"440\" r=\"190\" fill=\"url(#grad2)\" filter=\"url(#blur1)\" />\n    \n    <path fill=\"none\" stroke=\"#8338ec\" stroke-width=\"10\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.15\"\n      d=\"M 180 600 Q 400 100 620 600\" />\n    <path fill=\"none\" stroke=\"#3a86ff\" stroke-width=\"8\" stroke-linejoin=\"round\" stroke-dasharray=\"22 30\" opacity=\"0.12\"\n      d=\"M 140 650 Q 400 150 660 650\" />\n    \n  </svg>\n\n  <main class=\"container\" role=\"main\" aria-label=\"Transaction Concept Visual\">\n    <h1>TRANSACTION</h1>\n    <h2>Seamless Digital Exchange</h2>\n\n    <section class=\"transaction-card\" aria-label=\"Transaction details card\">\n      <div class=\"row\" aria-hidden=\"true\">\n        <span class=\"left\">Sender</span>\n        <span>Transaction ID</span>\n        <span class=\"right\">Receiver</span>\n      </div>\n      <div class=\"row\" style=\"margin-bottom: 1.8rem;\">\n        <span class=\"left\" style=\"color:#a2c7ff; user-select: text;\">0xF2b9...a48d</span>\n        <span style=\"color:#bb99ff; user-select: text;\">TX-9845B8273</span>\n        <span class=\"right\" style=\"color:#ffaec0; user-select: text;\">0x3Ca1...1Fa3</span>\n      </div>\n\n      <div class=\"divider\" aria-hidden=\"true\"></div>\n\n      <p class=\"trans-details\">\n        Initiating a trustless transfer of digital assets safeguarded by cryptography and immutable ledgers.\n        Confirmations assure security and transparency in the ledger network.\n      </p>\n\n      <div class=\"amount\" aria-label=\"Transaction amount\" tabindex=\"0\">+ 2.375 BTC</div>\n      <div class=\"status\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"text\" tabindex=\"0\">CONFIRMED</div>\n\n      <div class=\"btn-group\" role=\"group\" aria-label=\"Transaction controls\">\n        <button id=\"btnToggleStatus\" aria-pressed=\"false\" aria-label=\"Toggle transaction status\">Toggle Status</button>\n        <button id=\"btnCopyID\" aria-label=\"Copy transaction ID to clipboard\">Copy TX ID</button>\n      </div>\n    </section>\n\n    <section class=\"flow-diagram\" aria-label=\"Transaction processing flow diagram\" role=\"list\">\n      <div class=\"step\" role=\"listitem\" tabindex=\"0\" aria-description=\"Funds sent from wallet\">\n        Initiation\n        <small>Sender’s Wallet</small>\n      </div>\n      <div class=\"step\" role=\"listitem\" tabindex=\"0\" aria-description=\"Network validation and cryptographic consensus\">\n        Validation\n        <small>Network Consensus</small>\n      </div>\n      <div class=\"step\" role=\"listitem\" tabindex=\"0\" aria-description=\"Block inclusion and confirmation\">\n        Confirmation\n        <small>Blockchain Ledger</small>\n      </div>\n      <div class=\"step\" role=\"listitem\" tabindex=\"0\" aria-description=\"Funds delivered to recipient’s wallet\">\n        Completion\n        <small>Receiver’s Wallet</small>\n      </div>\n    </section>\n\n    <footer>\n      &copy; 2024 Visual Concepts - Crafted with passion for excellence in digital finance design.\n    </footer>\n  </main>\n\n  <script>\n    (() => {\n      const btnToggle = document.getElementById('btnToggleStatus');\n      const status = document.querySelector('.status');\n      const txIDText = 'TX-9845B8273';\n      const btnCopy = document.getElementById('btnCopyID');\n\n      const statuses = ['CONFIRMED', 'PENDING', 'FAILED'];\n      const colors = {\n        CONFIRMED: 'linear-gradient(45deg, #3a86ff, #8338ec)',\n        PENDING: 'linear-gradient(45deg, #ffba08, #faa307)',\n        FAILED: 'linear-gradient(45deg, #ff006e, #d90429)',\n      };\n      const shadows = {\n        CONFIRMED: '0 0 14px #3a86ff, 0 0 30px #8338ec',\n        PENDING: '0 0 14px #ffba08, 0 0 30px #faa307',\n        FAILED: '0 0 14px #ff006e, 0 0 30px #d90429',\n      };\n\n      let currentIndex = 0;\n\n      // Update status visuals and label\n      function updateStatus(i) {\n        const s = statuses[i];\n        status.textContent = s;\n        status.style.background = colors[s];\n        status.style.boxShadow = shadows[s];\n        status.setAttribute('aria-label', `Transaction status: ${s.toLowerCase()}`);\n        btnToggle.setAttribute('aria-pressed', i !== 0 ? 'true' : 'false');\n      }\n\n      btnToggle.addEventListener('click', () => {\n        currentIndex = (currentIndex + 1) % statuses.length;\n        updateStatus(currentIndex);\n      });\n\n      btnCopy.addEventListener('click', async () => {\n        try {\n          await navigator.clipboard.writeText(txIDText);\n          btnCopy.textContent = 'Copied!';\n          setTimeout(() => (btnCopy.textContent = 'Copy TX ID'), 1600);\n        } catch {\n          btnCopy.textContent = 'Failed';\n          setTimeout(() => (btnCopy.textContent = 'Copy TX ID'), 1600);\n        }\n      });\n\n      // Initial state\n      updateStatus(0);\n    })();\n  </script>\n</body>\n</html>"
