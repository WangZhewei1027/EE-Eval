  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Relational Database Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        table { border-collapse: collapse; margin-bottom: 20px; }\n        th, td { border: 1px solid #000; padding: 8px; text-align: left; }\n        .container { display: flex; gap: 20px; }\n        .panel { flex: 1; }\n        .query-builder { border: 1px solid #000; padding: 10px; margin-bottom: 20px; }\n        .hidden { display: none; }\n        button, select, input { margin: 5px; }\n    </style>\n</head>\n<body>\n    <h1>Relational Database Explorer</h1>\n    \n    <div class=\"container\">\n        <div class=\"panel\">\n            <h2>Database Schema</h2>\n            <select id=\"schema-selector\" onchange=\"loadTableSchema()\">\n                <option value=\"\">Select a table</option>\n                <option value=\"customers\">Customers</option>\n                <option value=\"orders\">Orders</option>\n                <option value=\"products\">Products</option>\n                <option value=\"order_items\">Order Items</option>\n            </select>\n            \n            <div id=\"schema-details\"></div>\n            \n            <h2>Relationships</h2>\n            <div id=\"relationships\">\n                <p>Customers 1 → ∞ Orders (customer_id)</p>\n                <p>Orders 1 → ∞ Order Items (order_id)</p>\n                <p>Products 1 → ∞ Order Items (product_id)</p>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Query Builder</h2>\n            <div class=\"query-builder\">\n                <div>\n                    <label>SELECT\">SELECT</label>\n                    <select id=\"select-columns\" multiple>\n                        <option value=\"*\">* (All columns)</option>\n                    </select>\n                </div>\n                <div>\n                    <label>FROM</label>\n                    <select id=\"from-table\" onchange=\"updateJoinOptions()\">\n                        <option value=\"\">Select table</option>\n                        <option value=\"customers\">Customers</option>\n                        <option value=\"orders\">Orders</option>\n                        <option value=\"products\">Products</option>\n                    </select>\n                </div>\n                <div id=\"join-section\" class=\"hidden\">\n                    <label>JOIN</label>\n                    <select id=\"join-type\">\n                        <option value=\"INNER\">INNER JOIN</option>\n                        <option value=\"LEFT\">LEFT JOIN</option>\n                        <option value=\"RIGHT\">RIGHT JOIN</option>\n                    </select>\n                    <select id=\"join-table\">\n                        <option value=\"\">Select table</option>\n                    </select>\n                    <div id=\"join-condition\" class=\"hidden\">\n                        <span>ON</span>\n                        <select id=\"left-join-column\"></select>\n                        <span>=</span>\n                        <select id=\"right-join-column\"></select>\n                    </div>\n                </div>\n                <div>\n                    <label>WHERE</label>\n                    <select id=\"where-column\"></select>\n                    <select id=\"where-operator\">\n                        <option value=\"=\">=</option>\n                        <option value=\">\">></option>\n                        <option value=\"<\"><</option>\n                        <option value=\"LIKE\">LIKE</option>\n                    </select>\n                    <input type=\"text\" id=\"where-value\">\n                </div>\n                <button onclick=\"executeQuery()\">Execute Query</button>\n                <button onclick=\"resetQuery()\">Reset</button>\n            </div>\n            \n            <h2>Query Results</h2>\n            <div id=\"query-results\"></div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Data Manipulation</h2>\n        <div>\n            <button onclick=\"showInsertForm()\">Insert Record</button>\n            <button onclick=\"showUpdateForm()\">Update Record</button>\n            <button onclick=\"showDeleteForm()\">Delete Record</button>\n        </div>\n        \n        <div id=\"insert-form\" class=\"hidden\">\n            <h3>Insert Record</h3>\n            <select id=\"insert-table\" onchange=\"loadInsertFields()\">\n                <option value=\"\">Select table</option>\n                <option value=\"customers\">Customers</option>\n                <option value=\"orders\">Orders</option>\n                <option value=\"products\">Products</option>\n            </select>\n            <div id=\"insert-fields\"></div>\n            <button onclick=\"performInsert()\">Insert</button>\n            <button onclick=\"hideInsertForm()\">Cancel</button>\n        </div>\n        \n        <div id=\"update-form\" class=\"hidden\">\n            <h3>Update Record</h3>\n            <select id=\"update-table\" onchange=\"loadUpdateFields()\">\n                <option value=\"\">Select table</option>\n                <option value=\"customers\">Customers</option>\n                <option value=\"orders\">Orders</option>\n                <option value=\"products\">Products</option>\n            </select>\n            <div id=\"update-fields\"></div>\n            <button onclick=\"performUpdate()\">Update</button>\n            <button onclick=\"hideUpdateForm()\">Cancel</button>\n        </div>\n        \n        <div id=\"delete-form\" class=\"hidden\">\n            <h3>Delete Record</h3>\n            <select id=\"delete-table\" onchange=\"loadDeleteFields()\">\n                <option value=\"\">Select table</option>\n                <option value=\"customers\">Customers</option>\n                <option value=\"orders\">Orders</option>\n                <option value=\"products\">Products</option>\n            </select>\n            <div id=\"delete-fields\"></div>\n            <button onclick=\"performDelete()\">Delete</button>\n            <button onclick=\"hideDeleteForm()\">Cancel</button>\n        </div>\n    </div>\n\n    <script>\n        // Sample database\n        const database = {\n            customers: [\n                { id: 1, name: \"John Doe\", email: \"john@example.com\", phone: \"555-1234\" },\n                { id: 2, name: \"Jane Smith\", email: \"jane@example.com\", phone: \"555-5678\" },\n                { id: 3, name: \"Bob Johnson\", email: \"bob@example.com\", phone: \"555-9012\" }\n            ],\n            orders: [\n                { id: 1, customer_id: 1, order_date: \"2023-01-15\", total: 125.50 },\n                { id: 2, customer_id: 2, order_date: \"2023-01-16\", total: 89.99 },\n                { id: 3, customer_id: 1, order_date: \"2023-01-18\", total: 45.75 }\n            ],\n            products: [\n                { id: 1, name: \"Laptop\", price: 999.99, category: \"Electronics\" },\n                { id: 2, name: \"Smartphone\", price: 699.99, category: \"Electronics\" },\n                { id: 3, name: \"Headphones\", price: 149.99, category: \"Electronics\" }\n            ],\n            order_items: [\n                { id: 1, order_id: 1, product_id: 1, quantity: 1, price: 999.99 },\n                { id: 2, order_id: 1, product_id: 3, quantity: 2, price: 149.99 },\n                { id: 3, order_id: 2, product_id: 2, quantity: 1, price: 699.99 }\n            ]\n        };\n\n        // Schema information\n        const schema = {\n            customers: [\n                { name: \"id\", type: \"INTEGER\", primary_key: true },\n                { name: \"name\", type: \"VARCHAR(100)\" },\n                { name: \"email\", type: \"VARCHAR(100)\" },\n                { name: \"phone\", type: \"VARCHAR(20)\" }\n            ],\n            orders: [\n                { name: \"id\", type: \"INTEGER\", primary_key: true },\n                { name: \"customer_id\", type: \"INTEGER\", foreign_key: \"customers.id\" },\n                { name: \"order_date\", type: \"DATE\" },\n                { name: \"total\", type: \"DECIMAL(10,2)\" }\n            ],\n            products: [\n                { name: \"id\", type: \"INTEGER\", primary_key: true },\n                { name: \"name\", type: \"VARCHAR(100)\" },\n                { name: \"price\", type: \"DECIMAL(10,2)\" },\n                { name: \"category\", type: \"VARCHAR(50)\" }\n            ],\n            order_items: [\n                { name: \"id\", type: \"INTEGER\", primary_key: true },\n                { name: \"order_id\", type: \"INTEGER\", foreign_key: \"orders.id\" },\n                { name: \"product_id\", type: \"INTEGER\", foreign_key: \"products.id\" },\n                { name: \"quantity\", type: \"INTEGER\" },\n                { name: \"price\", type: \"DECIMAL(10,2)\" }\n            ]\n        };\n\n        // Load table schema details\n        function loadTableSchema() {\n            const tableName = document.getElementById(\"schema-selector\").value;\n            const detailsDiv = document.getElementById(\"schema-details\");\n            \n            if (!tableName) {\n                detailsDiv.innerHTML = \"\";\n                return;\n            }\n            \n            let html = `<h3>${tableName}</h3><table><tr><th>Column</th><th>Type</th><th>Key</th></tr>`;\n            \n            schema[tableName].forEach(column => {\n                let keyType = \"\";\n                if (column.primary_key) keyType = \"PRIMARY KEY\";\n                else if (column.foreign_key) keyType = `FOREIGN KEY (${column.foreign_key})`;\n                \n                html += `<tr>\n                    <td>${column.name}</td>\n                    <td>${column.type}</td>\n                    <td>${keyType}</td>\n                </tr>`;\n            });\n            \n            html += \"</table>\";\n            detailsDiv.innerHTML = html;\n            \n            // Update query builder options\n            updateColumnSelectors(tableName);\n        }\n\n        // Update column selectors in query builder\n        function updateColumnSelectors(tableName) {\n            const selectColumns = document.getElementById(\"select-columns\");\n            const whereColumn = document.getElementById(\"where-column\");\n            \n            // Clear existing options (except the first one)\n            while (selectColumns.options.length > 1) {\n                selectColumns.remove(1);\n            }\n            while (whereColumn.options.length > 0) {\n                whereColumn.remove(0);\n            }\n            \n            // Add new options\n            schema[tableName].forEach(column => {\n                const option1 = document.createElement(\"option\");\n                option1.value = column.name;\n                option1.textContent = `${tableName}.${column.name}`;\n                selectColumns.appendChild(option1);\n                \n                const option2 = document.createElement(\"option\");\n                option2.value = column.name;\n                option2.textContent = `${tableName}.${column.name}`;\n                whereColumn.appendChild(option2);\n            });\n        }\n\n        // Update join options when FROM table changes\n        function updateJoinOptions() {\n            const fromTable = document.getElementById(\"from-table\").value;\n            const joinTableSelect = document.getElementById(\"join-table\");\n            const joinSection = document.getElementById(\"join-section\");\n            \n            // Clear existing options\n            while (joinTableSelect.options.length > 1) {\n                joinTableSelect.remove(1);\n            }\n            \n            if (!fromTable) {\n                joinSection.classList.add(\"hidden\");\n                return;\n            }\n            \n            // Show join section\n            joinSection.classList.remove(\"hidden\");\n            \n            // Add possible join options (all tables except the current one)\n            Object.keys(schema).forEach(table => {\n                if (table !== fromTable) {\n                    const option = document.createElement(\"option\");\n                    option.value = table;\n                    option.textContent = table;\n                    joinTableSelect.appendChild(option);\n                }\n            });\n        }\n\n        // Update join condition when join table changes\n        function updateJoinCondition() {\n            const fromTable = document.getElementById(\"from-table\").value;\n            const joinTable = document.getElementById(\"join-table\").value;\n            const leftColumn = document.getElementById(\"left-join-column\");\n            const rightColumn = document.getElementById(\"right-join-column\");\n            const joinCondition = document.getElementById(\"join-condition\");\n            \n            // Clear existing options\n            while (leftColumn.options.length > 0) {\n                leftColumn.remove(0);\n            }\n            while (rightColumn.options.length > 0) {\n                rightColumn.remove(0);\n            }\n            \n            if (!fromTable || !joinTable) {\n                joinCondition.classList.add(\"hidden\");\n                return;\n            }\n            \n            // Show join condition\n            joinCondition.classList.remove(\"hidden\");\n            \n            // Add columns from FROM table\n            schema[fromTable].forEach(column => {\n                const option = document.createElement(\"option\");\n                option.value = column.name;\n                option.textContent = `${fromTable}.${column.name}`;\n                leftColumn.appendChild(option);\n            });\n            \n            // Add columns from JOIN table\n            schema[joinTable].forEach(column => {\n                const option = document.createElement(\"option\");\n                option.value = column.name;\n                option.textContent = `${joinTable}.${column.name}`;\n                rightColumn.appendChild(option);\n            });\n        }\n\n        // Execute the query\n        function executeQuery() {\n            const selectColumns = Array.from(document.getElementById(\"select-columns\").selectedOptions)\n                .map(opt => opt.value);\n            const fromTable = document.getElementById(\"from-table\").value;\n            const joinType = document.getElementById(\"join-type\").value;\n            const joinTable = document.getElementById(\"join-table\").value;\n            const leftJoinColumn = document.getElementById(\"left-join-column\").value;\n            const rightJoinColumn = document.getElementById(\"right-join-column\").value;\n            const whereColumn = document.getElementById(\"where-column\").value;\n            const whereOperator = document.getElementById(\"where-operator\").value;\n            const whereValue = document.getElementById(\"where-value\").value;\n            \n            let results = [];\n            \n            if (!fromTable) {\n                alert(\"Please select a table to query\");\n                return;\n            }\n            \n            // Simple query without join\n            if (!joinTable || !leftJoinColumn || !rightJoinColumn) {\n                results = database[fromTable];\n                \n                // Apply WHERE clause if specified\n                if (whereColumn && whereValue) {\n                    results = results.filter(row => {\n                        const rowValue = row[whereColumn];\n                        if (whereOperator === \"=\") return rowValue == whereValue;\n                        if (whereOperator === \">\") return rowValue > whereValue;\n                        if (whereOperator === \"<\") return rowValue < whereValue;\n                        if (whereOperator === \"LIKE\") return String(rowValue).includes(whereValue);\n                        return true;\n                    });\n                }\n            } else {\n                // Join query\n                const leftTable = database[fromTable];\n                const rightTable = database[joinTable];\n                \n                leftTable.forEach(leftRow => {\n                    rightTable.forEach(rightRow => {\n                        if (leftRow[leftJoinColumn] == rightRow[rightJoinColumn]) {\n                            let combinedRow = {};\n                            \n                            // Add all columns from left table\n                            Object.keys(leftRow).forEach(key => {\n                                combinedRow[`${fromTable}.${key}`] = leftRow[key];\n                            });\n                            \n                            // Add all columns from right table\n                            Object.keys(rightRow).forEach(key => {\n                                combinedRow[`${joinTable}.${key}`] = rightRow[key];\n                            });\n                            \n                            results.push(combinedRow);\n                        }\n                    });\n                });\n            }\n            \n            // Filter columns if not selecting all\n            if (selectColumns.length > 0 && !selectColumns.includes(\"*\")) {\n                results = results.map(row => {\n                    let filteredRow = {};\n                    selectColumns.forEach(col => {\n                        if (row[col] !== undefined) {\n                            filteredRow[col] = row[col];\n                        }\n                    });\n                    return filteredRow;\n                });\n            }\n            \n            // Display results\n            displayResults(results);\n        }\n\n        // Display query results\n        function displayResults(results) {\n            const resultsDiv = document.getElementById(\"query-results\");\n            \n            if (results.length === 0) {\n                resultsDiv.innerHTML = \"<p>No results found</p>\";\n                return;\n            }\n            \n            let html = \"<table><tr>\";\n            \n            // Create headers\n            Object.keys(results[0]).forEach(col => {\n                html += `<th>${col}</th>`;\n            });\n            \n            html += \"</tr>\";\n            \n            // Add rows\n            results.forEach(row => {\n                html += \"<tr>\";\n                Object.values(row).forEach(val => {\n                    html += `<td>${val}</td>`;\n                });\n                html += \"</tr>\";\n            });\n            \n            html += \"</table>\";\n            resultsDiv.innerHTML = html;\n        }\n\n        // Reset query builder\n        function resetQuery() {\n            document.getElementById(\"from-table\").value = \"\";\n            document.getElementById(\"select-columns\").selectedIndex = 0;\n            document.getElementById(\"where-column\").value = \"\";\n            document.getElementById(\"where-operator\").value = \"=\";\n            document.getElementById(\"where-value\").value = \"\";\n            document.getElementById(\"join-section\").classList.add(\"hidden\");\n            document.getElementById(\"query-results\").innerHTML = \"\";\n        }\n\n        // Data manipulation functions\n        function showInsertForm() {\n            document.getElementById(\"insert-form\").classList.remove(\"hidden\");\n            document.getElementById(\"update-form\").classList.add(\"hidden\");\n            document.getElementById(\"delete-form\").classList.add(\"hidden\");\n        }\n\n        function hideInsertForm() {\n            document.getElementById(\"insert-form\").classList.add(\"hidden\");\n        }\n\n        function loadInsertFields() {\n            const table = document.getElementById(\"insert-table\").value;\n            const fieldsDiv = document.getElementById(\"insert-fields\");\n            \n            fieldsDiv.innerHTML = \"\";\n            \n            if (!table) return;\n            \n            schema[table].forEach(column => {\n                if (!column.primary_key) { // Skip auto-increment primary keys\n                    const label = document.createElement(\"label\");\n                    label.textContent = column.name;\n                    fieldsDiv.appendChild(label);\n                    \n                    const input = document.createElement(\"input\");\n                    input.type = \"text\";\n                    input.id = `insert-${column.name}`;\n                    input.placeholder = column.type;\n                    fieldsDiv.appendChild(input);\n                    \n                    fieldsDiv.appendChild(document.createElement(\"br\"));\n                }\n            });\n        }\n\n        function performInsert() {\n            const table = document.getElementById(\"insert-table\").value;\n            const fieldsDiv = document.getElementById(\"insert-fields\");\n            const inputs = fieldsDiv.querySelectorAll(\"input\");\n            \n            if (!table) {\n                alert(\"Please select a table\");\n                return;\n            }\n            \n            const newRecord = {};\n            schema[table].forEach(column => {\n                if (!column.primary_key) {\n                    const input = document.getElementById(`insert-${column.name}`);\n                    if (input) {\n                        newRecord[column.name] = input.value;\n                    }\n                }\n            });\n            \n            // Generate ID for new record\n            if (schema[table].some(col => col.primary_key)) {\n                const idField = schema[table].find(col => col.primary_key).name;\n                const maxId = Math.max(...database[table].map(r => r[idField]), 0);\n                newRecord[idField] = maxId + 1;\n            }\n            \n            database[table].push(newRecord);\n            alert(\"Record inserted successfully\");\n            hideInsertForm();\n        }\n\n        function showUpdateForm() {\n            document.getElementById(\"update-form\").classList.remove(\"hidden\");\n            document.getElementById(\"insert-form\").classList.add(\"hidden\");\n            document.getElementById(\"delete-form\").classList.add(\"hidden\");\n        }\n\n        function hideUpdateForm() {\n            document.getElementById(\"update-form\").classList.add(\"hidden\");\n        }\n\n        function loadUpdateFields() {\n            const table = document.getElementById(\"update-table\").value;\n            const fieldsDiv = document.getElementById(\"update-fields\");\n            \n            fieldsDiv.innerHTML = \"\";\n            \n            if (!table) return;\n            \n            // Add ID selector\n            const idField = schema[table].find(col => col.primary_key).name;\n            const idLabel = document.createElement(\"label\");\n            idLabel.textContent = `Select ${idField} to update:`;\n            fieldsDiv.appendChild(idLabel);\n            \n            const idSelect = document.createElement(\"select\");\n            idSelect.id = \"update-id\";\n            database[table].forEach(record => {\n                const option = document.createElement(\"option\");\n                option.value = record[idField];\n                option.textContent = record[idField];\n                idSelect.appendChild(option);\n            });\n            fieldsDiv.appendChild(idSelect);\n            fieldsDiv.appendChild(document.createElement(\"br\"));\n            \n            // Add fields to update\n            schema[table].forEach(column => {\n                if (!column.primary_key) {\n                    const label = document.createElement(\"label\");\n                    label.textContent = column.name;\n                    fieldsDiv.appendChild(label);\n                    \n                    const input = document.createElement(\"input\");\n                    input.type = \"text\";\n                    input.id = `update-${column.name}`;\n                    input.placeholder = column.type;\n                    fieldsDiv.appendChild(input);\n                    \n                    fieldsDiv.appendChild(document.createElement(\"br\"));\n                }\n            });\n        }\n\n        function performUpdate() {\n            const table = document.getElementById(\"update-table\").value;\n            const idField = schema[table].find(col => col.primary_key).name;\n            const id = document.getElementById(\"update-id\").value;\n            \n            if (!table || !id) {\n                alert(\"Please select a table and record\");\n                return;\n            }\n            \n            const record = database[table].find(r => r[idField] == id);\n            if (!record) {\n                alert(\"Record not found\");\n                return;\n            }\n            \n            schema[table].forEach(column => {\n                if (!column.primary_key) {\n                    const input = document.getElementById(`update-${column.name}`);\n                    if (input && input.value) {\n                        record[column.name] = input.value;\n                    }\n                }\n            });\n            \n            alert(\"Record updated successfully\");\n            hideUpdateForm();\n        }\n\n        function showDeleteForm() {\n            document.getElementById(\"delete-form\").classList.remove(\"hidden\");\n            document.getElementById(\"insert-form\").classList.add(\"hidden\");\n            document.getElementById(\"update-form\").classList.add(\"hidden\");\n        }\n\n        function hideDeleteForm() {\n            document.getElementById(\"delete-form\").classList.add(\"hidden\");\n        }\n\n        function loadDeleteFields() {\n            const table = document.getElementById(\"delete-table\").value;\n            const fieldsDiv = document.getElementById(\"delete-fields\");\n            \n            fieldsDiv.innerHTML = \"\";\n            \n            if (!table) return;\n            \n            const idField = schema[table].find(col => col.primary_key).name;\n            const label = document.createElement(\"label\");\n            label.textContent = `Select ${idField} to delete:`;\n            fieldsDiv.appendChild(label);\n            \n            const select = document.createElement(\"select\");\n            select.id = \"delete-id\";\n            database[table].forEach(record => {\n                const option = document.createElement(\"option\");\n                option.value = record[idField];\n                option.textContent = record[idField];\n                select.appendChild(option);\n            });\n            fieldsDiv.appendChild(select);\n        }\n\n        function performDelete() {\n            const table = document.getElementById(\"delete-table\").value;\n            const idField = schema[table].find(col => col.primary_key).name;\n            const id = document.getElementById(\"delete-id\").value;\n            \n            if (!table || !id) {\n                alert(\"Please select a table and record\");\n                return;\n            }\n            \n            const index = database[table].findIndex(r => r[idField] == id);\n            if (index === -1) {\n                alert(\"Record not found\");\n                return;\n            }\n            \n            if (confirm(\"Are you sure you want to delete this record?\")) {\n                database[table].splice(index, 1);\n                alert(\"Record deleted successfully\");\n                hideDeleteForm();\n            }\n        }\n\n        // Initialize event listeners\n        document.getElementById(\"join-table\").addEventListener(\"change\", updateJoinCondition);\n    </script>\n</body>\n</html>"
  },
