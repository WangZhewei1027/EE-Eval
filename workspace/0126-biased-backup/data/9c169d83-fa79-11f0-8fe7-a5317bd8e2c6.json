  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Interactive Logistic Regression Playground</title>\n<style>\n/* Minimal, plain layout only to keep elements arranged; no colors, no decoration */\nbody { font-family: Arial, sans-serif; margin: 10px; }\nsection { margin-bottom: 12px; }\nlabel { display: inline-block; width: 160px; }\ninput[type=\"range\"] { width: 160px; }\ntextarea { width: 100%; height: 90px; }\ncanvas { border: 1px solid #000; cursor: crosshair; }\nbutton { margin-right: 6px; margin-top:4px; }\nsmall { display:block; margin-top:6px; }\n</style>\n</head>\n<body>\n<h2>Logistic Regression Interactive Playground</h2>\n\n<section>\n  <strong>Overview:</strong>\n  <div>\n    This interactive demo allows you to create or load 2D datasets, add/remove points manually, train logistic regression with many options (batch/SGD/Newton), step through training, explore decision boundary and probability surface, adjust regularization and learning rate, and evaluate metrics like loss, accuracy, confusion, and ROC/AUC. Use controls below. Visuals are intentionally minimal.\n  </div>\n</section>\n\n<section>\n  <strong>Canvas (click to add point).</strong><br>\n  <canvas id=\"plot\" width=\"520\" height=\"520\"></canvas>\n  <div>\n    <label>Add label on click:</label>\n    <input type=\"radio\" name=\"addLabel\" id=\"addLabel0\" value=\"0\"><label for=\"addLabel0\">0</label>\n    <input type=\"radio\" name=\"addLabel\" id=\"addLabel1\" value=\"1\" checked><label for=\"addLabel1\">1</label>\n    <button id=\"delLast\">Delete Last</button>\n    <button id=\"clearPoints\">Clear Points</button>\n    <button id=\"toggleLabels\">Toggle Point Labels</button>\n    <button id=\"flipAll\">Flip All Labels</button>\n  </div>\n  <small>Right-click a point to toggle its label. Shift+click to move last point.</small>\n</section>\n\n<section>\n  <strong>Data generation / Import</strong>\n  <div>\n    <label>Preset:</label>\n    <select id=\"preset\">\n      <option value=\"two_gaussians\">Two Gaussians</option>\n      <option value=\"xor\">XOR-like</option>\n      <option value=\"circle\">Concentric Circles</option>\n      <option value=\"linearly_separable\">Linearly Separable</option>\n    </select>\n    <label>Seed:</label><input id=\"seed\" type=\"number\" value=\"1\" style=\"width:70px\">\n  </div>\n  <div>\n    <label>Points per class:</label><input id=\"nPerClass\" type=\"number\" value=\"50\" style=\"width:70px\">\n    <label>Separation:</label><input id=\"separation\" type=\"range\" min=\"0\" max=\"5\" step=\"0.1\" value=\"1.2\">\n    <span id=\"sepVal\">1.2</span>\n  </div>\n  <div>\n    <label>Noise:</label><input id=\"noise\" type=\"range\" min=\"0\" max=\"2\" step=\"0.01\" value=\"0.3\">\n    <span id=\"noiseVal\">0.30</span>\n    <label>Class imbalance (% class1):</label><input id=\"imbalance\" type=\"range\" min=\"1\" max=\"99\" value=\"50\">\n    <span id=\"imbVal\">50%</span>\n  </div>\n  <div>\n    <button id=\"generate\">Generate Data</button>\n    <button id=\"clusterAdd\">Add Cluster</button>\n    <button id=\"randomize\">Randomize Coordinates</button>\n  </div>\n  <div>\n    <label>CSV Import (x,y,label ; header optional):</label>\n    <textarea id=\"csvInput\" placeholder=\"x,y,label\"></textarea>\n    <button id=\"importCsv\">Import CSV</button>\n    <button id=\"exportCsv\">Export CSV</button>\n  </div>\n</section>\n\n<section>\n  <strong>Feature / Model Options</strong>\n  <div>\n    <label>Features mapping degree:</label>\n    <input id=\"polyDegree\" type=\"number\" min=\"1\" max=\"5\" value=\"1\" style=\"width:60px\">\n    <label>Include bias:</label><input id=\"includeBias\" type=\"checkbox\" checked>\n    <label>Feature scaling:</label>\n    <select id=\"scaling\">\n      <option value=\"none\">None</option>\n      <option value=\"standard\">Standardize (z)</option>\n      <option value=\"minmax\">MinMax [-1,1]</option>\n    </select>\n  </div>\n  <div>\n    <label>Regularization (L2 lambda):</label><input id=\"lambda\" type=\"number\" min=\"0\" step=\"0.01\" value=\"0.0\" style=\"width:80px\">\n    <label>Learning rate:</label><input id=\"lr\" type=\"number\" min=\"0.0001\" step=\"0.0001\" value=\"0.1\" style=\"width:80px\">\n    <label>Optimizer:</label>\n    <select id=\"optimizer\">\n      <option value=\"bgd\">Batch GD</option>\n      <option value=\"sgd\">SGD</option>\n      <option value=\"mbgd\">Mini-batch</option>\n      <option value=\"newton\">Newton</option>\n    </select>\n  </div>\n  <div>\n    <label>Batch size (for SGD/Mini):</label><input id=\"batchSize\" type=\"number\" min=\"1\" value=\"10\" style=\"width:80px\">\n    <label>Momentum (SGD):</label><input id=\"momentum\" type=\"number\" min=\"0\" max=\"0.99\" step=\"0.01\" value=\"0.0\" style=\"width:80px\">\n  </div>\n  <div>\n    <label>Init weights (comma) or empty random:</label>\n    <input id=\"initWeights\" type=\"text\" style=\"width:320px\" placeholder=\"e.g. 0.1,0.2,0\">\n    <label>Freeze intercept:</label><input id=\"freezeBias\" type=\"checkbox\">\n  </div>\n</section>\n\n<section>\n  <strong>Training Controls</strong>\n  <div>\n    <label>Max iterations:</label><input id=\"maxIter\" type=\"number\" value=\"200\" style=\"width:80px\">\n    <label>Auto-train delay (ms):</label><input id=\"autoDelay\" type=\"number\" value=\"100\" style=\"width:80px\">\n  </div>\n  <div>\n    <button id=\"initModel\">Init/Reset Model</button>\n    <button id=\"train\">Train (run all)</button>\n    <button id=\"step\">Step (one update)</button>\n    <button id=\"toggleAuto\">Start Auto-train</button>\n    <button id=\"pause\">Pause</button>\n    <button id=\"applyOneEpoch\">One epoch</button>\n  </div>\n  <div>\n    <button id=\"exportModel\">Export Model JSON</button>\n    <button id=\"importModelBtn\">Import Model JSON</button>\n    <input id=\"modelImportInput\" type=\"text\" placeholder='{\"w\":[...],\"options\":{}}' style=\"width:420px\">\n  </div>\n</section>\n\n<section>\n  <strong>Visualization Options</strong>\n  <div>\n    <label>Show probability surface:</label><input id=\"showSurface\" type=\"checkbox\" checked>\n    <label>Probability threshold (classify):</label><input id=\"threshold\" type=\"range\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0.5\">\n    <span id=\"thVal\">0.50</span>\n    <label>Contour resolution (grid):</label><input id=\"gridRes\" type=\"number\" min=\"10\" max=\"200\" value=\"80\" style=\"width:80px\">\n  </div>\n  <div>\n    <button id=\"repaint\">Redraw</button>\n    <button id=\"evaluate\">Evaluate Metrics</button>\n    <button id=\"rocPlot\">Plot ROC</button>\n  </div>\n</section>\n\n<section>\n  <strong>Status & Metrics</strong>\n  <div id=\"status\">\n    Iteration: <span id=\"iter\">0</span>,\n    Loss: <span id=\"loss\">-</span>,\n    Accuracy: <span id=\"acc\">-</span>,\n    Precision: <span id=\"prec\">-</span>,\n    Recall: <span id=\"rec\">-</span>,\n    F1: <span id=\"f1\">-</span>,\n    AUC: <span id=\"auc\">-</span>\n  </div>\n  <div>\n    Weights: <span id=\"weights\">[]</span>\n  </div>\n</section>\n\n<section>\n  <strong>ROC / Auxiliary plot</strong>\n  <canvas id=\"roc\" width=\"520\" height=\"180\"></canvas>\n  <div>\n    <button id=\"clearRoc\">Clear ROC</button>\n    <button id=\"calcAuc\">Compute AUC</button>\n  </div>\n</section>\n\n<script>\n/*\n  Interactive Logistic Regression Playground\n  - Minimal visuals\n  - Many controls and interaction paths\n*/\n\n(function(){\n  // Utilities\n  function rand(seed) { // simple seeded RNG (LCG)\n    seed = seed >>> 0;\n    return function() {\n      seed = (1664525 * seed + 1013904223) >>> 0;\n      return seed / 4294967296;\n    };\n  }\n  function sigmoid(z){ return 1/(1+Math.exp(-z)); }\n  function dot(a,b){ var s=0; for(var i=0;i<a.length;i++) s+=a[i]*b[i]; return s; }\n  function zeros(n){ return Array(n).fill(0); }\n  function add(a,b){ return a.map((v,i)=>v+b[i]); }\n  function sub(a,b){ return a.map((v,i)=>v-b[i]); }\n  function scale(a,c){ return a.map(v=>v*c); }\n  function approxEqual(a,b,eps=1e-9){ return Math.abs(a-b)<=eps; }\n  function gaussian(mu, sigma, rnd) {\n    // Box-Muller\n    var u1 = rnd(), u2 = rnd();\n    var z0 = Math.sqrt(-2*Math.log(u1))*Math.cos(2*Math.PI*u2);\n    return mu + sigma*z0;\n  }\n\n  // DOM\n  var canvas = document.getElementById('plot');\n  var ctx = canvas.getContext('2d');\n  var rocCanvas = document.getElementById('roc');\n  var rocCtx = rocCanvas.getContext('2d');\n\n  // Controls\n  var seedInput = document.getElementById('seed');\n  var preset = document.getElementById('preset');\n  var nPerClass = document.getElementById('nPerClass');\n  var separation = document.getElementById('separation');\n  var sepVal = document.getElementById('sepVal');\n  var noise = document.getElementById('noise');\n  var noiseVal = document.getElementById('noiseVal');\n  var imbalance = document.getElementById('imbalance');\n  var imbVal = document.getElementById('imbVal');\n  var generateBtn = document.getElementById('generate');\n  var clusterAddBtn = document.getElementById('clusterAdd');\n  var randomizeBtn = document.getElementById('randomize');\n  var csvInput = document.getElementById('csvInput');\n  var importCsvBtn = document.getElementById('importCsv');\n  var exportCsvBtn = document.getElementById('exportCsv');\n  var addLabel0 = document.getElementById('addLabel0');\n  var addLabel1 = document.getElementById('addLabel1');\n  var delLastBtn = document.getElementById('delLast');\n  var clearPointsBtn = document.getElementById('clearPoints');\n  var toggleLabelsBtn = document.getElementById('toggleLabels');\n  var flipAllBtn = document.getElementById('flipAll');\n\n  var polyDegree = document.getElementById('polyDegree');\n  var includeBias = document.getElementById('includeBias');\n  var scaling = document.getElementById('scaling');\n  var lambdaInput = document.getElementById('lambda');\n  var lrInput = document.getElementById('lr');\n  var optimizer = document.getElementById('optimizer');\n  var batchSize = document.getElementById('batchSize');\n  var momentumInput = document.getElementById('momentum');\n  var initWeightsInput = document.getElementById('initWeights');\n  var freezeBias = document.getElementById('freezeBias');\n\n  var maxIter = document.getElementById('maxIter');\n  var autoDelay = document.getElementById('autoDelay');\n  var initModelBtn = document.getElementById('initModel');\n  var trainBtn = document.getElementById('train');\n  var stepBtn = document.getElementById('step');\n  var toggleAutoBtn = document.getElementById('toggleAuto');\n  var pauseBtn = document.getElementById('pause');\n  var applyOneEpochBtn = document.getElementById('applyOneEpoch');\n  var exportModelBtn = document.getElementById('exportModel');\n  var importModelBtn = document.getElementById('importModelBtn');\n  var modelImportInput = document.getElementById('modelImportInput');\n\n  var showSurface = document.getElementById('showSurface');\n  var threshold = document.getElementById('threshold');\n  var thVal = document.getElementById('thVal');\n  var gridRes = document.getElementById('gridRes');\n  var repaintBtn = document.getElementById('repaint');\n  var evaluateBtn = document.getElementById('evaluate');\n  var rocPlotBtn = document.getElementById('rocPlot');\n\n  var iterSpan = document.getElementById('iter');\n  var lossSpan = document.getElementById('loss');\n  var accSpan = document.getElementById('acc');\n  var precSpan = document.getElementById('prec');\n  var recSpan = document.getElementById('rec');\n  var f1Span = document.getElementById('f1');\n  var aucSpan = document.getElementById('auc');\n  var weightsSpan = document.getElementById('weights');\n\n  var clearRocBtn = document.getElementById('clearRoc');\n  var calcAucBtn = document.getElementById('calcAuc');\n\n  // State\n  var data = []; // {x:..., y:..., label:0/1}\n  var model = { w: [], options: {} };\n  var rng = rand(1);\n  var autoTimer = null;\n  var iter = 0;\n  var lastGrad = null;\n  var velocity = null;\n\n  // Coordinate mapping\n  var view = { xmin:-5, xmax:5, ymin:-5, ymax:5, w:canvas.width, h:canvas.height, pad:20 };\n\n  // Helpers: data & features\n  function screenToData(sx, sy){\n    var x = view.xmin + (sx/view.w)*(view.xmax-view.xmin);\n    var y = view.ymax - (sy/view.h)*(view.ymax-view.ymin); // invert Y\n    return {x:x, y:y};\n  }\n  function dataToScreen(x,y){\n    var sx = ((x - view.xmin)/(view.xmax-view.xmin))*view.w;\n    var sy = ((view.ymax - y)/(view.ymax-view.ymin))*view.h;\n    return {sx:sx, sy:sy};\n  }\n\n  function mapFeatures(x,y,degree,includeBiasFlag){\n    // returns array of features (polynomial up to degree for 2D)\n    var features = [];\n    if(includeBiasFlag) features.push(1);\n    if(degree===1){\n      features.push(x); features.push(y);\n      return features;\n    }\n    // polynomial combinations: x^i * y^j for i+j<=degree\n    for(var i=0;i<=degree;i++){\n      for(var j=0;j<=degree-i;j++){\n        if(i===0 && j===0){\n          if(includeBiasFlag) continue;\n        }\n        features.push(Math.pow(x,i)*Math.pow(y,j));\n      }\n    }\n    return features;\n  }\n\n  function buildDesignMatrix(dataPoints, options){\n    var N = dataPoints.length;\n    var degree = options.degree;\n    var bias = options.includeBias;\n    var X = [];\n    for(var i=0;i<N;i++){\n      X.push(mapFeatures(dataPoints[i].x, dataPoints[i].y, degree, bias));\n    }\n    return X;\n  }\n\n  function featureNames(degree, includeBiasFlag){\n    var names = [];\n    if(includeBiasFlag) names.push('1');\n    if(degree===1){ names.push('x'); names.push('y'); return names; }\n    for(var i=0;i<=degree;i++){\n      for(var j=0;j<=degree-i;j++){\n        if(i===0 && j===0){\n          if(includeBiasFlag) continue;\n        }\n        names.push('x^'+i+' y^'+j);\n      }\n    }\n    return names;\n  }\n\n  function scaleFeatures(X, method){\n    // returns scaled matrix and scale metadata\n    var m = X.length, n = X[0].length;\n    var meta = {method:method, mean: [], std:[], min:[], max:[]};\n    var Xs = X.map(row => row.slice());\n    if(method==='none') return {X:Xs, meta:meta};\n    for(var j=0;j<n;j++){\n      var col = Xs.map(r=>r[j]);\n      var mean = col.reduce((a,b)=>a+b,0)/m;\n      var std = Math.sqrt(col.map(v=>(v-mean)*(v-mean)).reduce((a,b)=>a+b,0)/m) || 1;\n      var min = Math.min.apply(null,col);\n      var max = Math.max.apply(null,col);\n      meta.mean.push(mean); meta.std.push(std); meta.min.push(min); meta.max.push(max);\n      for(var i=0;i<m;i++){\n        if(method==='standard') Xs[i][j] = (Xs[i][j]-mean)/std;\n        if(method==='minmax') Xs[i][j] = (2*(Xs[i][j]-min)/(max-min || 1))-1;\n      }\n    }\n    return {X:Xs, meta:meta};\n  }\n\n  // Initialize default dataset\n  function generateDataFromPreset(presetName, params){\n    var rnd = rand(params.seed || 1);\n    var pts = [];\n    var n = params.nPerClass||50;\n    var sep = params.separation || 1.2;\n    var noiseLevel = params.noise || 0.3;\n    var imbalancePct = params.imb || 50;\n    if(presetName==='two_gaussians'){\n      // two gaussians centered at (-sep,0) and (sep,0)\n      var n1 = Math.round(n * (imbalancePct/100));\n      var n2 = n;\n      for(var i=0;i<n1;i++){\n        var x = gaussian(-sep, noiseLevel, rnd);\n        var y = gaussian(0, noiseLevel, rnd);\n        pts.push({x:x,y:y,label:0});\n      }\n      for(var i=0;i<n2;i++){\n        var x = gaussian(sep, noiseLevel, rnd);\n        var y = gaussian(0, noiseLevel, rnd);\n        pts.push({x:x,y:y,label:1});\n      }\n    } else if(presetName==='xor'){\n      for(var i=0;i<2*n;i++){\n        var sx = (i%2===0) ? -sep : sep;\n        var sy = ((Math.floor(i/n))%2===0) ? -sep : sep;\n        var x = gaussian(sx, noiseLevel, rnd);\n        var y = gaussian(sy, noiseLevel, rnd);\n        var lab = ((sx>0) ^ (sy>0)) ? 1 : 0;\n        pts.push({x:x,y:y,label:lab});\n      }\n    } else if(presetName==='circle'){\n      // concentric circles: label1 inside, label0 outside\n      for(var i=0;i<2*n;i++){\n        var r = (i<n) ? (0.5 + noiseLevel*Math.abs(gaussian(0,1,rnd))) : (sep + noiseLevel*Math.abs(gaussian(0,1,rnd)));\n        var theta = rnd()*2*Math.PI;\n        var x = r*Math.cos(theta);\n        var y = r*Math.sin(theta);\n        var lab = (i<n) ? 1 : 0;\n        pts.push({x:x,y:y,label:lab});\n      }\n    } else if(presetName==='linearly_separable'){\n      for(var i=0;i<n*2;i++){\n        var x = gaussian((i<n)?-sep:sep, noiseLevel, rnd);\n        var y = gaussian(i%2===0?sep:-sep, noiseLevel, rnd)*0.5;\n        var lab = i<n?0:1;\n        pts.push({x:x,y:y,label:lab});\n      }\n    } else {\n      // random\n      for(var i=0;i<2*n;i++){\n        var x = (rnd()*10)-5;\n        var y = (rnd()*10)-5;\n        var lab = rnd()>0.5?1:0;\n        pts.push({x:x,y:y,label:lab});\n      }\n    }\n    return pts;\n  }\n\n  function importCsv(text){\n    var lines = text.trim().split(/\\r?\\n/).map(l=>l.trim()).filter(l=>l.length>0);\n    var pts = [];\n    for(var i=0;i<lines.length;i++){\n      var line = lines[i];\n      if(i===0 && /[a-zA-Z]/.test(line) && line.split(',').length>=3) continue; // header\n      var parts = line.split(',');\n      if(parts.length<3) continue;\n      var x = parseFloat(parts[0]), y = parseFloat(parts[1]);\n      var lab = parseInt(parts[2]);\n      if(isNaN(x)||isNaN(y)||isNaN(lab)) continue;\n      pts.push({x:x,y:y,label:lab});\n    }\n    return pts;\n  }\n\n  function exportCsvData(arr){\n    return arr.map(p=>[p.x,p.y,p.label].join(',')).join('\\n');\n  }\n\n  // Model, training\n  function initModelFromOptions(options, featureCount){\n    var w = [];\n    var initText = initWeightsInput.value.trim();\n    if(initText){\n      var parts = initText.split(',').map(s=>parseFloat(s.trim())).filter(x=>!isNaN(x));\n      if(parts.length===featureCount){\n        w = parts.slice();\n      } else {\n        // try pad or trim\n        w = [];\n        for(var i=0;i<featureCount;i++){\n          w.push(parts[i]||0);\n        }\n      }\n    } else {\n      // small random init\n      var r = rand((+seedInput.value)||1);\n      for(var j=0;j<featureCount;j++){\n        w.push((r()-0.5)*0.2);\n      }\n    }\n    model.w = w;\n    model.options = JSON.parse(JSON.stringify(options));\n    iter = 0;\n    lastGrad = zeros(w.length);\n    velocity = zeros(w.length);\n    updateStatus();\n    repaint();\n  }\n\n  function predictProbaRow(xRow, w){\n    return sigmoid(dot(w, xRow));\n  }\n\n  function computeLossAndGrad(X, yLabels, w, lambda){\n    var m = X.length;\n    var loss=0;\n    var grad = zeros(w.length);\n    for(var i=0;i<m;i++){\n      var xi = X[i];\n      var yi = yLabels[i];\n      var z = dot(w, xi);\n      var pi = sigmoid(z);\n      // negative log-likelihood\n      loss += - (yi*Math.log(pi+1e-15) + (1-yi)*Math.log(1-pi+1e-15));\n      var err = pi - yi;\n      for(var j=0;j<w.length;j++){\n        grad[j] += err*xi[j];\n      }\n    }\n    loss /= m;\n    for(var j=0;j<w.length;j++){\n      // regularization (skip bias if bias included as first)\n      var regTerm = 0;\n      if(lambda && lambda>0){\n        // do not penalize bias if model.options.includeBias true and we assume bias at index 0\n        if(!(model.options.includeBias && j===0)){\n          regTerm = (lambda/(2*m))*w[j]*w[j];\n        }\n      }\n      // Note: gradient reg:\n      if(lambda && lambda>0){\n        if(!(model.options.includeBias && j===0)) grad[j] += (lambda/m)*w[j];\n      }\n      loss += regTerm;\n    }\n    for(var j=0;j<grad.length;j++) grad[j] /= m;\n    return {loss:loss, grad:grad};\n  }\n\n  function computeHessian(X, w){\n    var m = X.length; var n = w.length;\n    var H = []; for(var i=0;i<n;i++){ H[i]=zeros(n); }\n    for(var i=0;i<m;i++){\n      var xi = X[i];\n      var z = dot(w, xi); var pi = sigmoid(z);\n      var s = pi*(1-pi);\n      for(var a=0;a<n;a++){\n        for(var b=0;b<n;b++){\n          H[a][b] += s*xi[a]*xi[b];\n        }\n      }\n    }\n    for(var a=0;a<n;a++){ for(var b=0;b<n;b++){ H[a][b] /= m; } }\n    return H;\n  }\n\n  function invertMatrix(A){\n    // Gauss-Jordan inversion (square)\n    var n = A.length;\n    var M = [];\n    for(var i=0;i<n;i++){\n      M[i] = A[i].slice();\n      for(var j=0;j<n;j++){\n        M[i].push(i===j?1:0);\n      }\n    }\n    for(var i=0;i<n;i++){\n      // pivot\n      var maxrow = i;\n      for(var k=i+1;k<n;k++) if(Math.abs(M[k][i])>Math.abs(M[maxrow][i])) maxrow=k;\n      if(Math.abs(M[maxrow][i])<1e-12) return null; // singular\n      var tmp = M[i]; M[i]=M[maxrow]; M[maxrow]=tmp;\n      var div = M[i][i];\n      for(var j=0;j<2*n;j++) M[i][j] /= div;\n      for(var r=0;r<n;r++){\n        if(r===i) continue;\n        var factor = M[r][i];\n        for(var j=0;j<2*n;j++) M[r][j] -= factor*M[i][j];\n      }\n    }\n    var inv = [];\n    for(var i=0;i<n;i++) inv.push(M[i].slice(n,2*n));\n    return inv;\n  }\n\n  function matVecMul(A, v){\n    var r = [];\n    for(var i=0;i<A.length;i++){\n      r.push(dot(A[i], v));\n    }\n    return r;\n  }\n\n  function trainStepBatch(X, y, opts){\n    var lambda = opts.lambda || 0;\n    var lr = opts.lr || 0.1;\n    var w = model.w.slice();\n    var res = computeLossAndGrad(X,y,w,lambda);\n    var grad = res.grad;\n    if(opts.optimizer==='newton'){\n      var H = computeHessian(X,w);\n      // regularize Hessian diag\n      for(var d=0;d<H.length;d++) H[d][d] += (lambda/X.length);\n      var Hinv = invertMatrix(H);\n      if(Hinv){\n        var delta = matVecMul(Hinv, grad);\n        for(var j=0;j<w.length;j++){\n          if(opts.freezeBias && j===0) continue;\n          w[j] -= delta[j];\n        }\n      } else {\n        // fallback to gradient\n        for(var j=0;j<w.length;j++){\n          if(opts.freezeBias && j===0) continue;\n          w[j] -= lr*grad[j];\n        }\n      }\n    } else {\n      // gradient descent with momentum\n      if(!velocity) velocity = zeros(w.length);\n      var mu = opts.momentum || 0;\n      for(var j=0;j<w.length;j++){\n        if(opts.freezeBias && j===0) continue;\n        velocity[j] = mu*velocity[j] + (1-mu)*grad[j];\n        w[j] -= lr*velocity[j];\n      }\n    }\n    model.w = w;\n    lastGrad = grad;\n    return res;\n  }\n\n  function trainOneEpoch(Xall, yall, opts){\n    var m = Xall.length;\n    var w = model.w.slice();\n    var order = Array.from({length:m}, (v,i)=>i);\n    for(var i=0;i<m;i++){ var j = Math.floor(Math.random()*m); var t=order[i]; order[i]=order[j]; order[j]=t; }\n    if(opts.optimizer==='bgd' || opts.optimizer==='newton'){\n      // full batch update\n      var res = trainStepBatch(Xall,yall,opts);\n      return res;\n    } else if(opts.optimizer==='sgd'){\n      var lr = opts.lr;\n      for(var idx=0; idx<m; idx++){\n        var i = order[idx];\n        var xi = Xall[i], yi = yall[i];\n        var z = dot(model.w, xi);\n        var pi = sigmoid(z);\n        var err = pi - yi;\n        var grad = xi.map(v=>err*v);\n        for(var j=0;j<w.length;j++){\n          if(opts.freezeBias && j===0) continue;\n          // no regularization per sample; approximate\n          w[j] -= lr*grad[j];\n        }\n        model.w = w.slice();\n      }\n      var res = computeLossAndGrad(Xall,yall,w,opts.lambda);\n      lastGrad = res.grad;\n      return res;\n    } else {\n      // mini-batch\n      var batch = [];\n      var b = opts.batchSize || 10;\n      var totalRes = {loss:0, grad:zeros(model.w.length)};\n      var count=0;\n      for(var start=0; start<m; start+=b){\n        var end = Math.min(m, start+b);\n        var Xb=[], yb=[];\n        for(var i=start;i<end;i++){ Xb.push(Xall[order[i]]); yb.push(yall[order[i]]); }\n        var res = trainStepBatch(Xb,yb,opts);\n        totalRes.loss += res.loss;\n        totalRes.grad = add(totalRes.grad, res.grad);\n        count++;\n      }\n      totalRes.loss /= Math.max(1,count);\n      totalRes.grad = scale(totalRes.grad, 1/Math.max(1,count));\n      lastGrad = totalRes.grad;\n      return totalRes;\n    }\n  }\n\n  // Rendering\n  function clearCanvas(){\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n  }\n\n  function drawAxes(){\n    ctx.beginPath();\n    // border\n    ctx.rect(0,0,canvas.width,canvas.height);\n    ctx.stroke();\n    // center lines\n    var c = dataToScreen(0,0);\n    ctx.beginPath();\n    ctx.moveTo(0, c.sy); ctx.lineTo(canvas.width, c.sy);\n    ctx.moveTo(c.sx, 0); ctx.lineTo(c.sx, canvas.height);\n    ctx.stroke();\n  }\n\n  function drawProbabilitySurface(){\n    if(!showSurface.checked) return;\n    var res = +gridRes.value;\n    var nx = res, ny = res;\n    var dx = (view.xmax-view.xmin)/(nx-1);\n    var dy = (view.ymax-view.ymin)/(ny-1);\n    var degree = +polyDegree.value;\n    var include = includeBias.checked;\n    var Xgrid = [];\n    for(var i=0;i<nx;i++){\n      for(var j=0;j<ny;j++){\n        var x = view.xmin + i*dx;\n        var y = view.ymin + j*dy;\n        var features = mapFeatures(x,y,degree,include);\n        // apply scaling if active using model.options.scaling meta\n        if(model.options && model.options.scaling && model.options.scaling !== 'none' && model.scaleMeta){\n          for(var k=0;k<features.length;k++){\n            if(model.options.scaling==='standard'){\n              features[k] = (features[k]-model.scaleMeta.mean[k])/model.scaleMeta.std[k];\n            } else if(model.options.scaling==='minmax'){\n              features[k] = (2*(features[k]-model.scaleMeta.min[k])/(model.scaleMeta.max[k]-model.scaleMeta.min[k] || 1))-1;\n            }\n          }\n        }\n        var p = predictProbaRow(features, model.w);\n        // draw small rectangle with opacity proportional to p\n        var scr = dataToScreen(x,y);\n        var alpha = p;\n        ctx.fillStyle = 'rgba(0,0,0,'+ (alpha*0.6) +')';\n        ctx.fillRect(scr.sx, scr.sy, canvas.width/nx+0.5, canvas.height/ny+0.5);\n      }\n    }\n  }\n\n  function drawDecisionBoundary(){\n    // For linear (degree=1) we can draw exact line: w0 + w1 x + w2 y = 0 => y = (-w0 - w1 x)/w2\n    var degree = +polyDegree.value;\n    var include = includeBias.checked;\n    if(degree===1 && include && model.w.length>=3){\n      var w0 = model.w[0], w1=model.w[1], w2=model.w[2];\n      if(Math.abs(w2) < 1e-12) return;\n      var x1 = view.xmin, y1 = (-w0 - w1*x1)/w2;\n      var x2 = view.xmax, y2 = (-w0 - w1*x2)/w2;\n      var p1 = dataToScreen(x1,y1), p2 = dataToScreen(x2,y2);\n      ctx.beginPath();\n      ctx.moveTo(p1.sx, p1.sy);\n      ctx.lineTo(p2.sx, p2.sy);\n      ctx.stroke();\n    } else {\n      // approximate contour at threshold value by sampling grid\n      var th = +threshold.value;\n      var res = +gridRes.value;\n      var nx = res, ny = res;\n      var dx = (view.xmax-view.xmin)/(nx-1);\n      var dy = (view.ymax-view.ymin)/(ny-1);\n      // simple marching squares-like threshold drawing: draw square borders where sign crosses threshold\n      ctx.beginPath();\n      for(var i=0;i<nx-1;i++){\n        for(var j=0;j<ny-1;j++){\n          var x = view.xmin + i*dx;\n          var y = view.ymin + j*dy;\n          var p = [];\n          for(var di=0;di<2;di++){\n            for(var dj=0;dj<2;dj++){\n              var xi = x + di*dx;\n              var yj = y + dj*dy;\n              var f = mapFeatures(xi,yj,degree,include);\n              if(model.options && model.options.scaling && model.scaleMeta){\n                for(var k=0;k<f.length;k++){\n                  if(model.options.scaling==='standard') f[k] = (f[k]-model.scaleMeta.mean[k])/model.scaleMeta.std[k];\n                  else if(model.options.scaling==='minmax') f[k] = (2*(f[k]-model.scaleMeta.min[k])/(model.scaleMeta.max[k]-model.scaleMeta.min[k] || 1))-1;\n                }\n              }\n              p.push(predictProbaRow(f, model.w));\n            }\n          }\n          // check if any edges cross threshold\n          var crosses = (p[0]<th)!=(p[1]<th) || (p[1]<th)!=(p[3]<th) || (p[3]<th)!=(p[2]<th) || (p[2]<th)!=(p[0]<th);\n          if(crosses){\n            var s1 = dataToScreen(x, y);\n            var s2 = dataToScreen(x+dx, y+dy);\n            ctx.rect(s1.sx, s1.sy, s2.sx-s1.sx+1, s2.sy-s1.sy+1);\n          }\n        }\n      }\n      ctx.stroke();\n    }\n  }\n\n  function drawPoints(){\n    for(var i=0;i<data.length;i++){\n      var p = data[i];\n      var s = dataToScreen(p.x, p.y);\n      ctx.beginPath();\n      ctx.arc(s.sx, s.sy, 4, 0, Math.PI*2);\n      ctx.fillStyle = (p.label? 'rgba(0,0,0,1)':'rgba(0,0,0,0)'); // filled for class1\n      if(p.label) ctx.fill();\n      ctx.stroke();\n    }\n  }\n\n  function repaint(){\n    clearCanvas();\n    drawAxes();\n    if(model.w && model.w.length>0 && data.length>0){\n      drawProbabilitySurface();\n      ctx.beginPath(); ctx.strokeStyle='rgba(0,0,0,1)'; drawDecisionBoundary();\n    }\n    drawPoints();\n    // show weights textual\n    weightsSpan.textContent = '[' + (model.w || []).map(v=>v.toFixed(4)).join(', ') + ']';\n  }\n\n  // Evaluation metrics\n  function evaluateAll(){\n    if(data.length===0) return;\n    var degree = +polyDegree.value;\n    var include = includeBias.checked;\n    var X = buildDesignMatrix(data, {degree:degree, includeBias:include});\n    // scale appropriately using model.scaleMeta if present\n    if(model.scaleMeta && model.options && model.options.scaling!=='none'){\n      for(var i=0;i<X.length;i++){\n        for(var j=0;j<X[i].length;j++){\n          if(model.options.scaling==='standard') X[i][j] = (X[i][j]-model.scaleMeta.mean[j])/model.scaleMeta.std[j];\n          else if(model.options.scaling==='minmax') X[i][j] = (2*(X[i][j]-model.scaleMeta.min[j])/(model.scaleMeta.max[j]-model.scaleMeta.min[j] || 1))-1;\n        }\n      }\n    }\n    var probs = X.map(x => predictProbaRow(x, model.w));\n    var th = +threshold.value;\n    var preds = probs.map(p=>p>=th?1:0);\n    var y = data.map(p=>p.label);\n    // metrics\n    var TP=0,FP=0,TN=0,FN=0;\n    for(var i=0;i<y.length;i++){\n      if(y[i]===1 && preds[i]===1) TP++;\n      if(y[i]===0 && preds[i]===1) FP++;\n      if(y[i]===0 && preds[i]===0) TN++;\n      if(y[i]===1 && preds[i]===0) FN++;\n    }\n    var acc = (TP+TN)/(TP+TN+FP+FN);\n    var prec = TP/(TP+FP || 1);\n    var rec = TP/(TP+FN || 1);\n    var f1 = 2*prec*rec/(prec+rec || 1);\n    var loss = computeLossAndGrad(X, y, model.w, +lambdaInput.value).loss;\n    iterSpan.textContent = iter;\n    lossSpan.textContent = loss.toFixed(4);\n    accSpan.textContent = acc.toFixed(3);\n    precSpan.textContent = prec.toFixed(3);\n    recSpan.textContent = rec.toFixed(3);\n    f1Span.textContent = f1.toFixed(3);\n    // AUC\n    var auc = computeAUC(y, probs);\n    aucSpan.textContent = (auc===null)?'-':auc.toFixed(3);\n    return {TP:TP,FP:FP,TN:TN,FN:FN,acc:acc,prec:prec,rec:rec,f1:f1,loss:loss,auc:auc};\n  }\n\n  function computeAUC(y, scores){\n    // simple trapezoid on ROC\n    var items = y.map((lab,i)=>({lab:lab, score:scores[i]}));\n    items.sort((a,b)=>b.score-a.score);\n    var tp=0, fp=0;\n    var P = y.reduce((a,b)=>a+b,0);\n    var N = y.length - P;\n    if(P===0 || N===0) return null;\n    var tpr = [0], fpr=[0];\n    var lastScore = null;\n    for(var i=0;i<items.length;i++){\n      if(items[i].lab===1) tp++; else fp++;\n      tpr.push(tp/P); fpr.push(fp/N);\n    }\n    // trapezoidal rule\n    var auc = 0;\n    for(var i=1;i<fpr.length;i++){\n      auc += (fpr[i]-fpr[i-1])*(tpr[i]+tpr[i-1])/2;\n    }\n    return auc;\n  }\n\n  function plotROC(){\n    var dataEval = evaluateAll();\n    if(!dataEval) return;\n    // compute curve points\n    var degree = +polyDegree.value;\n    var include = includeBias.checked;\n    var X = buildDesignMatrix(data, {degree:degree, includeBias:include});\n    if(model.scaleMeta && model.options && model.options.scaling!=='none'){\n      for(var i=0;i<X.length;i++){\n        for(var j=0;j<X[i].length;j++){\n          if(model.options.scaling==='standard') X[i][j] = (X[i][j]-model.scaleMeta.mean[j])/model.scaleMeta.std[j];\n          else if(model.options.scaling==='minmax') X[i][j] = (2*(X[i][j]-model.scaleMeta.min[j])/(model.scaleMeta.max[j]-model.scaleMeta.min[j] || 1))-1;\n        }\n      }\n    }\n    var probs = X.map(x => predictProbaRow(x, model.w));\n    var y = data.map(p=>p.label);\n    var items = y.map((lab,i)=>({lab:lab, score:probs[i]}));\n    items.sort((a,b)=>b.score-a.score);\n    var P = y.reduce((a,b)=>a+b,0), N=y.length-P;\n    var tp=0, fp=0;\n    var points = [{x:0,y:0}];\n    for(var i=0;i<items.length;i++){\n      if(items[i].lab===1) tp++; else fp++;\n      points.push({x:fp/N, y:tp/P});\n    }\n    points.push({x:1,y:1});\n    // draw\n    rocCtx.clearRect(0,0,rocCanvas.width, rocCanvas.height);\n    // axes\n    rocCtx.beginPath(); rocCtx.rect(0,0,rocCanvas.width, rocCanvas.height); rocCtx.stroke();\n    // diagonal\n    rocCtx.beginPath();\n    rocCtx.moveTo(0, rocCanvas.height);\n    rocCtx.lineTo(rocCanvas.width, 0);\n    rocCtx.stroke();\n    // curve\n    rocCtx.beginPath();\n    for(var i=0;i<points.length;i++){\n      var sx = points[i].x * rocCanvas.width;\n      var sy = (1-points[i].y) * rocCanvas.height;\n      if(i===0) rocCtx.moveTo(sx, sy); else rocCtx.lineTo(sx, sy);\n    }\n    rocCtx.stroke();\n    // compute AUC\n    var auc = computeAUC(y, probs);\n    aucSpan.textContent = auc===null?'-':auc.toFixed(4);\n    // annotate\n    rocCtx.fillText('AUC: ' + (auc===null?'-':auc.toFixed(4)), 8, 12);\n  }\n\n  // Event handlers\n  canvas.addEventListener('click', function(evt){\n    var rect = canvas.getBoundingClientRect();\n    var sx = evt.clientX - rect.left;\n    var sy = evt.clientY - rect.top;\n    var d = screenToData(sx, sy);\n    if(evt.shiftKey && data.length>0){\n      // move last point\n      data[data.length-1].x = d.x; data[data.length-1].y = d.y;\n    } else {\n      var lab = addLabel1.checked?1:0;\n      data.push({x:d.x, y:d.y, label:lab});\n    }\n    repaint();\n  });\n\n  canvas.addEventListener('contextmenu', function(evt){\n    evt.preventDefault();\n    var rect = canvas.getBoundingClientRect();\n    var sx = evt.clientX - rect.left;\n    var sy = evt.clientY - rect.top;\n    var d = screenToData(sx, sy);\n    // find nearest point\n    var minIdx=-1, minDist=1e9;\n    for(var i=0;i<data.length;i++){\n      var s = dataToScreen(data[i].x, data[i].y);\n      var dx = s.sx - sx, dy = s.sy - sy;\n      var dist = Math.sqrt(dx*dx+dy*dy);\n      if(dist < minDist){ minDist = dist; minIdx = i; }\n    }\n    if(minIdx>=0 && minDist<8){\n      data[minIdx].label = 1-data[minIdx].label;\n      repaint();\n    }\n  });\n\n  delLastBtn.addEventListener('click', function(){ data.pop(); repaint(); });\n  clearPointsBtn.addEventListener('click', function(){ data = []; repaint(); });\n  toggleLabelsBtn.addEventListener('click', function(){\n    for(var i=0;i<data.length;i++) data[i].label = data[i].label?0:1;\n    repaint();\n  });\n  flipAllBtn.addEventListener('click', function(){\n    for(var i=0;i<data.length;i++) data[i].label = 1-data[i].label;\n    repaint();\n  });\n\n  separation.addEventListener('input', function(){ sepVal.textContent = separation.value; });\n  noise.addEventListener('input', function(){ noiseVal.textContent = Number(noise.value).toFixed(2); });\n  imbalance.addEventListener('input', function(){ imbVal.textContent = imbalance.value + '%'; });\n  threshold.addEventListener('input', function(){ thVal.textContent = Number(threshold.value).toFixed(2); repaint(); });\n\n  generateBtn.addEventListener('click', function(){\n    var params = {\n      seed: +seedInput.value || 1,\n      nPerClass: +nPerClass.value,\n      separation: +separation.value,\n      noise: +noise.value,\n      imb: +imbalance.value\n    };\n    var pts = generateDataFromPreset(preset.value, params);\n    data = pts;\n    repaint();\n  });\n\n  clusterAddBtn.addEventListener('click', function(){\n    // add small cluster with random center near existing data or origin\n    var r = rand((+seedInput.value)||1);\n    var cx = (r()-0.5)*4; var cy = (r()-0.5)*4;\n    for(var i=0;i<+nPerClass.value;i++){\n      var x = gaussian(cx, +noise.value, r);\n      var y = gaussian(cy, +noise.value, r);\n      var lab = r()>0.5?1:0;\n      data.push({x:x,y:y,label:lab});\n    }\n    repaint();\n  });\n\n  randomizeBtn.addEventListener('click', function(){\n    var r = rand((+seedInput.value)||1);\n    for(var i=0;i<data.length;i++){\n      data[i].x += (r()-0.5)*0.5;\n      data[i].y += (r()-0.5)*0.5;\n    }\n    repaint();\n  });\n\n  importCsvBtn.addEventListener('click', function(){\n    var txt = csvInput.value;\n    if(!txt) return;\n    var pts = importCsv(txt);\n    if(pts.length>0) data = pts;\n    repaint();\n  });\n\n  exportCsvBtn.addEventListener('click', function(){\n    var csv = exportCsvData(data);\n    csvInput.value = csv;\n    alert('CSV exported to textarea.');\n  });\n\n  initModelBtn.addEventListener('click', function(){\n    if(data.length===0){ alert('No data to build features from.'); return;}\n    var opts = { degree:+polyDegree.value, includeBias:includeBias.checked, scaling:scaling.value, lambda:+lambdaInput.value, lr:+lrInput.value, optimizer:optimizer.value, batchSize:+batchSize.value, momentum:+momentumInput.value, freezeBias:freezeBias.checked };\n    // build design matrix for scaling meta\n    var X = buildDesignMatrix(data, opts);\n    var scaled = scaleFeatures(X, opts.scaling);\n    model.scaleMeta = scaled.meta;\n    // Use scaled.X only for training; but we will store scale meta and apply on prediction\n    initModelFromOptions(opts, scaled.X[0].length);\n    model.Xtrain = scaled.X;\n    model.ytrain = data.map(p=>p.label);\n    alert('Model initialized with ' + model.w.length + ' weights.');\n  });\n\n  trainBtn.addEventListener('click', function(){\n    if(!model.w || model.w.length===0){ alert('Initialize model first.'); return; }\n    // prepare training set\n    var opts = model.options;\n    opts.lr = +lrInput.value;\n    opts.lambda = +lambdaInput.value;\n    opts.momentum = +momentumInput.value;\n    opts.batchSize = +batchSize.value;\n    opts.optimizer = optimizer.value;\n    opts.freezeBias = freezeBias.checked;\n    // recompute scaled data with current scaling choice\n    var Xraw = buildDesignMatrix(data, {degree:opts.degree, includeBias:opts.includeBias});\n    var scaled = scaleFeatures(Xraw, opts.scaling);\n    model.scaleMeta = scaled.meta;\n    var X = scaled.X;\n    var y = data.map(p=>p.label);\n    var maxit = +maxIter.value;\n    for(var k=0;k<maxit;k++){\n      iter++;\n      var res = trainOneEpoch(X, y, opts);\n      if(k%10===0) repaint();\n    }\n    repaint();\n    evaluateAll();\n    alert('Training complete.');\n  });\n\n  stepBtn.addEventListener('click', function(){\n    if(!model.w || model.w.length===0){ alert('Initialize model first.'); return; }\n    var opts = model.options;\n    opts.lr = +lrInput.value;\n    opts.lambda = +lambdaInput.value;\n    opts.momentum = +momentumInput.value;\n    opts.batchSize = +batchSize.value;\n    opts.optimizer = optimizer.value;\n    opts.freezeBias = freezeBias.checked;\n    // ensure scaled X is consistent\n    var Xraw = buildDesignMatrix(data, {degree:opts.degree, includeBias:opts.includeBias});\n    var scaled = scaleFeatures(Xraw, opts.scaling);\n    model.scaleMeta = scaled.meta;\n    var X = scaled.X;\n    var y = data.map(p=>p.label);\n    iter++;\n    var res;\n    if(opts.optimizer==='bgd' || opts.optimizer==='newton') res = trainStepBatch(X,y,opts);\n    else res = trainOneEpoch(X,y,opts);\n    repaint();\n    evaluateAll();\n  });\n\n  toggleAutoBtn.addEventListener('click', function(){\n    if(autoTimer){\n      clearInterval(autoTimer); autoTimer=null; toggleAutoBtn.textContent='Start Auto-train';\n    } else {\n      if(!model.w || model.w.length===0){ alert('Initialize model first.'); return; }\n      toggleAutoBtn.textContent='Stop Auto-train';\n      var delay = +autoDelay.value;\n      autoTimer = setInterval(function(){\n        if(!model.w || model.w.length===0) return;\n        stepBtn.click();\n      }, delay);\n    }\n  });\n\n  pauseBtn.addEventListener('click', function(){ if(autoTimer){ clearInterval(autoTimer); autoTimer=null; toggleAutoBtn.textContent='Start Auto-train'; } });\n\n  applyOneEpochBtn.addEventListener('click', function(){\n    if(!model.w || model.w.length===0){ alert('Initialize model first.'); return; }\n    var opts = model.options;\n    opts.lr = +lrInput.value;\n    opts.lambda = +lambdaInput.value;\n    opts.momentum = +momentumInput.value;\n    opts.batchSize = +batchSize.value;\n    opts.optimizer = optimizer.value;\n    opts.freezeBias = freezeBias.checked;\n    var Xraw = buildDesignMatrix(data, {degree:opts.degree, includeBias:opts.includeBias});\n    var scaled = scaleFeatures(Xraw, opts.scaling);\n    model.scaleMeta = scaled.meta;\n    var X = scaled.X;\n    var y = data.map(p=>p.label);\n    iter++;\n    var res = trainOneEpoch(X,y,opts);\n    repaint();\n    evaluateAll();\n  });\n\n  exportModelBtn.addEventListener('click', function(){\n    var out = {w:model.w, options:model.options, scaleMeta:model.scaleMeta};\n    var s = JSON.stringify(out);\n    modelImportInput.value = s;\n    alert('Model JSON exported to input box.');\n  });\n\n  importModelBtn.addEventListener('click', function(){\n    var txt = modelImportInput.value;\n    if(!txt) return;\n    try{\n      var obj = JSON.parse(txt);\n      if(obj.w && obj.options){\n        model.w = obj.w.slice();\n        model.options = obj.options;\n        model.scaleMeta = obj.scaleMeta || null;\n        iter = 0;\n        repaint();\n      } else alert('Invalid model JSON.');\n    }catch(e){ alert('Parse error: '+e.message); }\n  });\n\n  repaintBtn.addEventListener('click', repaint);\n  evaluateBtn.addEventListener('click', evaluateAll);\n  rocPlotBtn.addEventListener('click', plotROC);\n\n  clearRocBtn.addEventListener('click', function(){ rocCtx.clearRect(0,0,rocCanvas.width, rocCanvas.height); });\n  calcAucBtn.addEventListener('click', function(){ var ev = evaluateAll(); alert('AUC: ' + (ev.auc===null?'-':ev.auc.toFixed(4))); });\n\n  // Export and import full experiment\n  document.addEventListener('keydown', function(e){\n    if(e.ctrlKey && e.key==='e'){ // Ctrl+E export experiment\n      e.preventDefault();\n      var obj = {data:data, model:model, view:view};\n      modelImportInput.value = JSON.stringify(obj);\n      alert('Experiment exported to input.');\n    }\n    if(e.ctrlKey && e.key==='i'){ // Ctrl+I import experiment\n      e.preventDefault();\n      try{\n        var obj = JSON.parse(modelImportInput.value);\n        if(obj.data) data = obj.data;\n        if(obj.model) { model = obj.model; }\n        repaint();\n        alert('Imported experiment.');\n      }catch(err){ alert('Import error: '+err.message); }\n    }\n  });\n\n  // Startup: generate initial data\n  generateBtn.click();\n\n  // Small helper: compute loss/grad on demand when toggling optimizer\n  optimizer.addEventListener('change', function(){\n    // no-op; user can init model again\n  });\n\n  // Ensure initial status\n  updateStatus();\n\n  function updateStatus(){\n    iterSpan.textContent = iter;\n    lossSpan.textContent = '-';\n    accSpan.textContent = '-';\n    weightsSpan.textContent = model.w? ('[' + model.w.map(v=>v.toFixed(4)).join(', ')+']') : '[]';\n  }\n\n  // Provide advanced exploratory controls via console-friendly functions (for power users)\n  window._lr_playground = {\n    data: data,\n    model: model,\n    repaint: repaint,\n    evaluate: evaluateAll,\n    setView: function(xmin,xmax,ymin,ymax){ view.xmin=xmin; view.xmax=xmax; view.ymin=ymin; view.ymax=ymax; repaint(); }\n  };\n\n})();\n</script>\n</body>\n</html>"
