    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Visual Symphony</title>\n    <style>\n        :root {\n            --primary: #2c3e50;\n            --secondary: #3498db;\n            --accent: #e74c3c;\n            --light: #ecf0f1;\n            --dark: #1a252f;\n            --highlight: #f1c40f;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', 'Roboto', sans-serif;\n            background: linear-gradient(135deg, var(--primary), var(--dark));\n            color: var(--light);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            overflow-x: hidden;\n        }\n\n        .header {\n            text-align: center;\n            margin-bottom: 2rem;\n            position: relative;\n            z-index: 10;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1.2s ease-out 0.3s forwards;\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            letter-spacing: 2px;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--light), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            font-weight: 300;\n            opacity: 0.8;\n            max-width: 600px;\n            line-height: 1.6;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 1200px;\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n\n        .tree-container {\n            position: relative;\n            width: 100%;\n            min-height: 500px;\n            margin: 2rem 0;\n            perspective: 1000px;\n        }\n\n        .tree {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            transform-style: preserve-3d;\n            transform: rotateX(10deg);\n        }\n\n        .node {\n            position: absolute;\n            background: rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(10px);\n            border-radius: 12px;\n            border: 2px solid rgba(255, 255, 255, 0.2);\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);\n            padding: 1rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            transform-origin: center;\n            opacity: 0;\n        }\n\n        .node.active {\n            opacity: 1;\n        }\n\n        .node::before {\n            content: '';\n            position: absolute;\n            top: -2px;\n            left: -2px;\n            right: -2px;\n            bottom: -2px;\n            border-radius: 12px;\n            background: linear-gradient(45deg, var(--secondary), var(--accent));\n            z-index: -1;\n            opacity: 0.7;\n        }\n\n        .keys {\n            display: flex;\n            gap: 0.5rem;\n        }\n\n        .key {\n            background: rgba(255, 255, 255, 0.9);\n            color: var(--dark);\n            width: 40px;\n            height: 40px;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: 600;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n        }\n\n        .key.highlight {\n            transform: scale(1.2);\n            background: var(--highlight);\n            box-shadow: 0 0 20px rgba(241, 196, 15, 0.6);\n        }\n\n        .children {\n            display: flex;\n            gap: 2rem;\n            margin-top: 1rem;\n        }\n\n        .child-pointer {\n            position: relative;\n            width: 40px;\n            height: 40px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: var(--light);\n            opacity: 0.7;\n            font-size: 1.5rem;\n        }\n\n        .controls {\n            margin-top: 2rem;\n            display: flex;\n            gap: 1rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        button {\n            background: rgba(255, 255, 255, 0.1);\n            border: 2px solid rgba(255, 255, 255, 0.3);\n            color: var(--light);\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(5px);\n        }\n\n        button:hover {\n            background: rgba(255, 255, 255, 0.2);\n            transform: translateY(-2px);\n        }\n\n        button:active {\n            transform: translateY(1px);\n        }\n\n        .legend {\n            margin-top: 2rem;\n            display: flex;\n            gap: 2rem;\n            background: rgba(0, 0, 0, 0.2);\n            padding: 1rem 2rem;\n            border-radius: 12px;\n            backdrop-filter: blur(10px);\n            opacity: 0;\n            animation: fadeIn 1s ease-out 2s forwards;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .legend-color.key {\n            background: rgba(255, 255, 255, 0.9);\n        }\n\n        .legend-color.highlight {\n            background: var(--highlight);\n        }\n\n        .legend-color.pointer {\n            background: transparent;\n            border: 2px solid rgba(255, 255, 255, 0.7);\n        }\n\n        .particles {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            pointer-events: none;\n        }\n\n        .particle {\n            position: absolute;\n            width: 2px;\n            height: 2px;\n            border-radius: 50%;\n            background: rgba(255, 255, 255, 0.5);\n            animation: float 15s infinite linear;\n        }\n\n        @keyframes float {\n            0% {\n                transform: translateY(0) rotate(0deg);\n                opacity: 0;\n            }\n            10% {\n                opacity: 1;\n            }\n            90% {\n                opacity: 1;\n            }\n            100% {\n                transform: translateY(-500px) rotate(360deg);\n                opacity: 0;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>B-Tree Index</h1>\n            <p class=\"subtitle\">A balanced tree data structure that maintains sorted data and allows efficient search, sequential access, insertions, and deletions.</p>\n        </div>\n\n        <div class=\"tree-container\">\n            <div class=\"tree\" id=\"tree\"></div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"animateBtn\">Animate Search</button>\n            <button id=\"resetBtn\">Reset View</button>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color key\"></div>\n                <span>Key Value</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color highlight\"></div>\n                <span>Search Target</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color pointer\"></div>\n                <span>Child Pointer</span>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Create floating particles\n            createParticles();\n\n            // Build and render the B-Tree\n            const bTree = createSampleBTree();\n            renderBTree(bTree);\n\n            // Button event listeners\n            document.getElementById('animateBtn').addEventListener('click', () => {\n                animateSearch(bTree, Math.floor(Math.random() * 50) + 10);\n            });\n\n            document.getElementById('resetBtn').addEventListener('click', () => {\n                resetAnimation(bTree);\n            });\n        });\n\n        function createParticles() {\n            const container = document.getElementById('particles');\n            const particleCount = 50;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                // Random properties\n                const size = Math.random() * 3 + 1;\n                const posX = Math.random() * 100;\n                const delay = Math.random() * 15;\n                const duration = Math.random() * 10 + 10;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.bottom = `-10px`;\n                particle.style.animationDelay = `${delay}s`;\n                particle.style.animationDuration = `${duration}s`;\n                \n                container.appendChild(particle);\n            }\n        }\n\n        function createSampleBTree() {\n            return {\n                keys: [25],\n                children: [\n                    {\n                        keys: [10, 20],\n                        children: [\n                            { keys: [5, 8], children: [] },\n                            { keys: [12, 15], children: [] },\n                            { keys: [22, 24], children: [] }\n                        ]\n                    },\n                    {\n                        keys: [35, 40],\n                        children: [\n                            { keys: [28, 30], children: [] },\n                            { keys: [36, 38], children: [] },\n                            { keys: [42, 45, 48], children: [] }\n                        ]\n                    }\n                ]\n            };\n        }\n\n        function renderBTree(tree, parentX = 50, parentY = 0, level = 0, nodeIdx = 0) {\n            const treeContainer = document.getElementById('tree');\n            const node = document.createElement('div');\n            node.classList.add('node');\n            \n            // Calculate position based on tree level and node index\n            const xPos = parentX + (nodeIdx - 1) * (30 - level * 5);\n            const yPos = parentY + level * 120;\n            \n            // Set initial position\n            node.style.left = `${xPos}%`;\n            node.style.top = `${yPos}px`;\n            \n            // Create keys\n            const keysContainer = document.createElement('div');\n            keysContainer.classList.add('keys');\n            \n            tree.keys.forEach(key => {\n                const keyElement = document.createElement('div');\n                keyElement.classList.add('key');\n                keyElement.textContent = key;\n                keysContainer.appendChild(keyElement);\n            });\n            \n            node.appendChild(keysContainer);\n            \n            // Add child pointers if they exist\n            if (tree.children && tree.children.length > 0) {\n                const childrenContainer = document.createElement('div');\n                childrenContainer.classList.add('children');\n                \n                for (let i = 0; i <= tree.keys.length; i++) {\n                    const pointer = document.createElement('div');\n                    pointer.classList.add('child-pointer');\n                    pointer.innerHTML = '↓';\n                    childrenContainer.appendChild(pointer);\n                }\n                \n                node.appendChild(childrenContainer);\n            }\n            \n            treeContainer.appendChild(node);\n            \n            // Animate node appearance\n            setTimeout(() => {\n                node.classList.add('active');\n            }, 200 + level * 200 + nodeIdx * 100);\n            \n            // Recursively render children\n            if (tree.children && tree.children.length > 0) {\n                const childCount = tree.children.length;\n                const spread = Math.min(30, 80 / childCount);\n                \n                tree.children.forEach((child, idx) => {\n                    const childX = xPos + ((idx - (childCount - 1) / 2) * spread);\n                    renderBTree(child, childX, yPos + 100, level + 1, idx);\n                });\n            }\n        }\n\n        function animateSearch(tree, targetValue, path = [], delay = 0) {\n            resetAnimation(tree);\n            \n            const nodes = document.querySelectorAll('.node');\n            const keys = document.querySelectorAll('.key');\n            \n            // Reset all highlights\n            keys.forEach(key => {\n                key.classList.remove('highlight');\n            });\n            \n            // Find the path to the target\n            const searchPath = findSearchPath(tree, targetValue);\n            \n            // Animate each step in the path\n            searchPath.forEach((step, index) => {\n                setTimeout(() => {\n                    const node = nodes[step.nodeIndex];\n                    \n                    // Highlight the node\n                    node.style.transform = 'scale(1.05)';\n                    node.style.boxShadow = '0 0 30px rgba(52, 152, 219, 0.6)';\n                    \n                    // Highlight the key being checked\n                    if (step.keyIndex !== undefined) {\n                        const keyIndex = Array.from(node.querySelectorAll('.key')).findIndex(\n                            key => parseInt(key.textContent) === step.keyValue\n                        );\n                        \n                        if (keyIndex !== -1) {\n                            node.querySelectorAll('.key')[keyIndex].classList.add('highlight');\n                        }\n                    }\n                    \n                    // Return node to normal after delay\n                    setTimeout(() => {\n                        node.style.transform = '';\n                        node.style.boxShadow = '';\n                    }, 800);\n                    \n                }, index * 1200 + delay);\n            });\n            \n            // Show result message\n            const found = searchPath[searchPath.length - 1].found;\n            setTimeout(() => {\n                const message = found \n                    ? `Found value ${targetValue} in the B-Tree!`\n                    : `Value ${targetValue} not found in the B-Tree.`;\n                \n                alert(message);\n            }, searchPath.length * 1200 + delay);\n        }\n\n        function findSearchPath(tree, targetValue, path = [], nodeIndex = 0) {\n            let keysChecked = [];\n            let found = false;\n            \n            // Check each key in the node\n            for (let i = 0; i < tree.keys.length; i++) {\n                keysChecked.push({\n                    nodeIndex: nodeIndex,\n                    keyIndex: i,\n                    keyValue: tree.keys[i],\n                    found: false\n                });\n                \n                if (targetValue === tree.keys[i]) {\n                    keysChecked[keysChecked.length - 1].found = true;\n                    found = true;\n                    return keysChecked;\n                }\n                \n                if (targetValue < tree.keys[i]) {\n                    // Go to left child\n                    if (tree.children && tree.children.length > i) {\n                        const childPath = findSearchPath(\n                            tree.children[i], \n                            targetValue, \n                            path, \n                            nodeIndex + 1 + i\n                        );\n                        return [...keysChecked, ...childPath];\n                    }\n                    break;\n                }\n            }\n            \n            // Check rightmost child if exists\n            if (!found && tree.children && tree.children.length > tree.keys.length) {\n                const childPath = findSearchPath(\n                    tree.children[tree.children.length - 1], \n                    targetValue, \n                    path, \n                    nodeIndex + 1 + tree.keys.length\n                );\n                return [...keysChecked, ...childPath];\n            }\n            \n            return keysChecked;\n        }\n\n        function resetAnimation(tree) {\n            const nodes = document.querySelectorAll('.node');\n            const keys = document.querySelectorAll('.key');\n            \n            nodes.forEach(node => {\n                node.style.transform = '';\n                node.style.boxShadow = '';\n            });\n            \n            keys.forEach(key => {\n                key.classList.remove('highlight');\n            });\n        }\n    </script>\n</body>\n</html>"
