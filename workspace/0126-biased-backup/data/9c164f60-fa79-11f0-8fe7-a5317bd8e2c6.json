  "question": "Design Patterns",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Design Patterns Interactive Playground</title>\n<style>\n/* Minimal: only layout helpers to keep things usable. No colors, no fonts, no styling beyond necessary spacing. */\nbody { margin: 10px; font-family: sans-serif; }\n.section { margin-bottom: 12px; }\n.row { display: flex; gap: 10px; align-items: flex-start; }\n.col { display: flex; flex-direction: column; gap: 8px; }\n.box { padding: 8px; border: 1px solid #000; }\n.small { font-size: 12px; }\ntextarea, input, select { font-family: monospace; }\nbutton { cursor: pointer; }\ndetails summary { cursor: pointer; }\n</style>\n</head>\n<body>\n<h1>Design Patterns Interactive Playground</h1>\n\n<div class=\"row\">\n  <div style=\"flex:1\" class=\"col\">\n    <div class=\"section box\">\n      <div>\n        Controls:\n        <button id=\"btn-run\">Run</button>\n        <button id=\"btn-step\">Step</button>\n        <button id=\"btn-pause\">Pause</button>\n        <button id=\"btn-reset\">Reset</button>\n        <label>Speed <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"500\"></label>\n      </div>\n      <div class=\"small\">\n        <label>Log level:\n          <select id=\"logLevel\">\n            <option value=\"info\">Info</option>\n            <option value=\"debug\">Debug</option>\n            <option value=\"minimal\">Minimal</option>\n          </select>\n        </label>\n        <label>Seed: <input id=\"seed\" type=\"number\" value=\"1\" style=\"width:80px\"></label>\n      </div>\n    </div>\n\n    <details class=\"box\" open>\n      <summary>Patterns Toolbox (expand each to use)</summary>\n\n      <div id=\"toolbox\">\n\n        <details class=\"box\" id=\"factoryPanel\">\n          <summary>Factory Pattern</summary>\n          <div>\n            <label>Product name: <input id=\"factory-product-name\" value=\"Widget\"></label>\n            <label>Default value: <input id=\"factory-product-default\" value=\"0\"></label>\n            <button id=\"factory-create-type\">Create Product Type</button>\n            <button id=\"factory-create-instance\">Create Instance</button>\n            <div class=\"small\">\n              <label>Choose type:\n                <select id=\"factory-type-select\"></select>\n              </label>\n              <label>Instance count: <input id=\"factory-instance-count\" type=\"number\" value=\"1\" style=\"width:60px\"></label>\n            </div>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Singleton Pattern</summary>\n          <div>\n            <label>Singleton name: <input id=\"singleton-name\" value=\"AppConfig\"></label>\n            <button id=\"singleton-create\">Create/Get Singleton</button>\n            <button id=\"singleton-set\">Set value on singleton</button>\n            <input id=\"singleton-value\" value=\"42\">\n            <div class=\"small\">Singleton instances are unique by name.</div>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Observer Pattern</summary>\n          <div>\n            <button id=\"observer-create-subject\">Create Subject</button>\n            <button id=\"observer-create-observer\">Create Observer</button>\n            <div>\n              <label>Subject:\n                <select id=\"observer-subject-select\"></select>\n              </label>\n              <label>Observer:\n                <select id=\"observer-observer-select\"></select>\n              </label>\n              <button id=\"observer-subscribe\">Subscribe</button>\n              <button id=\"observer-unsubscribe\">Unsubscribe</button>\n              <button id=\"observer-publish\">Publish Event</button>\n              <input id=\"observer-event-payload\" value=\"hello\">\n            </div>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Strategy Pattern</summary>\n          <div>\n            <button id=\"strategy-create-context\">Create Context</button>\n            <button id=\"strategy-create-strategy\">Create Strategy</button>\n            <div>\n              <label>Context:\n                <select id=\"strategy-context-select\"></select>\n              </label>\n              <label>Strategy:\n                <select id=\"strategy-select\"></select>\n              </label>\n              <button id=\"strategy-assign\">Assign Strategy</button>\n              <button id=\"strategy-execute\">Execute Strategy</button>\n              <input id=\"strategy-input\" value=\"5\" style=\"width:60px\">\n            </div>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Command Pattern (with Undo/Redo)</summary>\n          <div>\n            <button id=\"cmd-create-receiver\">Create Receiver</button>\n            <button id=\"cmd-create-command\">Create Increment Command</button>\n            <label>Receiver:\n              <select id=\"cmd-receiver-select\"></select>\n            </label>\n            <button id=\"cmd-execute\">Execute Command</button>\n            <button id=\"cmd-undo\">Undo</button>\n            <button id=\"cmd-redo\">Redo</button>\n            <div class=\"small\">Commands support execute and undo. Try many sequences.</div>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>State Pattern</summary>\n          <div>\n            <button id=\"state-create-context\">Create State Context</button>\n            <button id=\"state-add-state\">Add State</button>\n            <label>Context:\n              <select id=\"state-context-select\"></select>\n            </label>\n            <label>State name: <input id=\"state-name\" value=\"idle\"></label>\n            <button id=\"state-switch\">Switch State</button>\n            <button id=\"state-auto\">Start Auto Transition</button>\n            <button id=\"state-stop-auto\">Stop Auto</button>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Decorator Pattern</summary>\n          <div>\n            <button id=\"decorator-create-base\">Create Base Object</button>\n            <button id=\"decorator-wrap\">Wrap with Decorator</button>\n            <label>Base:\n              <select id=\"decorator-base-select\"></select>\n            </label>\n            <label>Decorator note: <input id=\"decorator-note\" value=\"extra\"></label>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Adapter Pattern</summary>\n          <div>\n            <button id=\"adapter-create-foreign\">Create Foreign Object</button>\n            <button id=\"adapter-adapt\">Create Adapter</button>\n            <label>Foreign:\n              <select id=\"adapter-foreign-select\"></select>\n            </label>\n            <label>Adapter name: <input id=\"adapter-name\" value=\"Adapted\"></label>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Composite Pattern</summary>\n          <div>\n            <button id=\"composite-create\">Create Component</button>\n            <button id=\"composite-add-child\">Add Child</button>\n            <label>Parent:\n              <select id=\"composite-parent-select\"></select>\n            </label>\n            <label>Child:\n              <select id=\"composite-child-select\"></select>\n            </label>\n            <button id=\"composite-traverse\">Traverse</button>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Proxy Pattern</summary>\n          <div>\n            <button id=\"proxy-create-target\">Create Target</button>\n            <button id=\"proxy-create-proxy\">Create Proxy</button>\n            <label>Target:\n              <select id=\"proxy-target-select\"></select>\n            </label>\n            <label>Proxy name: <input id=\"proxy-name\" value=\"ControlledProxy\"></label>\n            <button id=\"proxy-toggle-access\">Toggle Access Allowed</button>\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Chain of Responsibility</summary>\n          <div>\n            <button id=\"chain-create-node\">Create Node</button>\n            <button id=\"chain-link-nodes\">Link Nodes</button>\n            <label>From:\n              <select id=\"chain-from-select\"></select>\n            </label>\n            <label>To:\n              <select id=\"chain-to-select\"></select>\n            </label>\n            <button id=\"chain-send\">Send Request</button>\n            <input id=\"chain-request\" value=\"task:5\">\n          </div>\n        </details>\n\n        <details class=\"box\">\n          <summary>Memento (Snapshot/Restore)</summary>\n          <div>\n            <button id=\"memento-snapshot\">Snapshot Selected</button>\n            <button id=\"memento-restore\">Restore To Snapshot</button>\n            <label>Object:\n              <select id=\"memento-object-select\"></select>\n            </label>\n            <label>Snapshots:\n              <select id=\"memento-snapshot-select\"></select>\n            </label>\n          </div>\n        </details>\n\n      </div>\n    </details>\n\n    <div class=\"box section\">\n      <div>\n        Scenarios:\n        <select id=\"scenario-select\">\n          <option value=\"\">--Choose preset scenario--</option>\n          <option value=\"observerDemo\">Observer Notification Demo</option>\n          <option value=\"commandUndoRedo\">Command Undo/Redo Demo</option>\n          <option value=\"decoratorFlow\">Decorator + Factory Flow</option>\n          <option value=\"compositeTraversal\">Composite Traversal Demo</option>\n        </select>\n        <button id=\"scenario-run\">Run Scenario</button>\n      </div>\n      <div class=\"small\">Choose a scenario to auto-run a multi-pattern flow. You can step through or run at speed.</div>\n    </div>\n\n  </div>\n\n  <div style=\"flex:1.2\" class=\"col\">\n    <div class=\"box section\">\n      <strong>Object Registry</strong>\n      <div>\n        <button id=\"refresh-registry\">Refresh</button>\n        <button id=\"export-state\">Export State</button>\n        <button id=\"import-state\">Import State</button>\n      </div>\n      <pre id=\"registry\" style=\"height:220px; overflow:auto;\"></pre>\n    </div>\n\n    <div class=\"box section\">\n      <strong>Inspector</strong>\n      <div>\n        <label>Select object:\n          <select id=\"inspector-select\"></select>\n        </label>\n        <button id=\"inspect-refresh\">Refresh</button>\n        <button id=\"inspect-delete\">Delete</button>\n      </div>\n      <pre id=\"inspector\" style=\"height:160px; overflow:auto;\"></pre>\n      <div>\n        <button id=\"inspector-invoke\">Invoke Method</button>\n        <input id=\"inspector-method\" value=\"info\" style=\"width:140px\">\n        <input id=\"inspector-arg\" value=\"\" style=\"width:160px\">\n      </div>\n    </div>\n\n  </div>\n\n  <div style=\"flex:0.9\" class=\"col\">\n    <div class=\"box section\">\n      <strong>Log</strong>\n      <div>\n        <button id=\"log-clear\">Clear</button>\n        <button id=\"log-export\">Export</button>\n        <button id=\"log-toggle-autoscroll\">Toggle Autoscroll</button>\n      </div>\n      <pre id=\"log\" style=\"height:400px; overflow:auto;\"></pre>\n    </div>\n\n    <div class=\"box section\">\n      <strong>Save / Load State</strong>\n      <div>\n        <button id=\"save-state\">Save to JSON</button>\n        <button id=\"load-state\">Load from JSON</button>\n      </div>\n      <textarea id=\"state-json\" style=\"width:100%;height:120px;\"></textarea>\n    </div>\n\n    <div class=\"box section small\">\n      Tip: Use the toolbox to create types and instances, link objects, then inspect and trigger behaviors. Many combinations are possible: Factory outputs can be decorated, observed, proxied, adapted, composed, commanded, snapped and restored.\n    </div>\n  </div>\n\n</div>\n\n<script>\n/*\n  Design Patterns Interactive Playground\n  - Multiple patterns implemented with runtime registry and UI controls\n  - Minimal visual styling; heavy interactivity\n  - Lots of possible workflows and states\n*/\n\n(function(){\n  // Utility\n  let idCounter = 1;\n  function uid(prefix){\n    return (prefix||'id') + '-' + (idCounter++);\n  }\n  function deepClone(obj){ return JSON.parse(JSON.stringify(obj)); }\n  function now(){ return (new Date()).toISOString().slice(11,23); }\n\n  // Log\n  const logEl = document.getElementById('log');\n  let autoscroll = true;\n  function log(msg, level='info'){\n    const lv = document.getElementById('logLevel').value;\n    if (lv === 'minimal' && level === 'debug') return;\n    const line = `[${now()}] ${level.toUpperCase()}: ${msg}`;\n    logEl.textContent += line + \"\\\\n\";\n    if (autoscroll) logEl.scrollTop = logEl.scrollHeight;\n  }\n  document.getElementById('log-clear').addEventListener('click', ()=> logEl.textContent='');\n  document.getElementById('log-export').addEventListener('click', ()=>{\n    const txt = logEl.textContent;\n    const w = window.open();\n    w.document.body.pre.textContent = txt;\n  });\n  document.getElementById('log-toggle-autoscroll').addEventListener('click', ()=> autoscroll = !autoscroll);\n\n  // Runtime registry\n  const registry = {\n    objects: {}, // id -> object wrapper { id, type, kind, data, meta }\n    singletons: {}, // name -> instance id\n    commands: { stack: [], cur: -1 },\n    snapshots: {}, // id -> [snapshots]\n    chains: {}, // store chain head mapping\n    runLoop: false,\n    scheduler: null,\n    speed: parseInt(document.getElementById('speed').value,10)\n  };\n\n  // Update speed\n  document.getElementById('speed').addEventListener('input', (e)=> registry.speed = parseInt(e.target.value,10) );\n\n  function addObject(kind, data, meta){\n    const id = uid(kind);\n    registry.objects[id] = { id, kind, data: data || {}, meta: meta || {} };\n    refreshAllSelectors();\n    log(`Created ${kind} ${id}`, 'debug');\n    return id;\n  }\n  function removeObject(id){\n    if (!registry.objects[id]) return;\n    delete registry.objects[id];\n    // remove references in other objects\n    Object.values(registry.objects).forEach(obj=>{\n      if (Array.isArray(obj.data.children)) obj.data.children = obj.data.children.filter(c=>c!==id);\n      if (Array.isArray(obj.data.observers)) obj.data.observers = obj.data.observers.filter(o=>o!==id);\n      if (obj.data.subject === id) obj.data.subject = null;\n    });\n    refreshAllSelectors();\n    log(`Deleted object ${id}`, 'debug');\n  }\n\n  // Refresh registry view\n  function refreshRegistry(){\n    const raw = Object.values(registry.objects).map(o=>{\n      return { id: o.id, kind: o.kind, data: o.data, meta: o.meta };\n    });\n    document.getElementById('registry').textContent = JSON.stringify(raw, null, 2);\n    refreshAllSelectors();\n  }\n  document.getElementById('refresh-registry').addEventListener('click', refreshRegistry);\n\n  // Inspector\n  function refreshInspectorList(){\n    const sel = document.getElementById('inspector-select');\n    sel.innerHTML = '';\n    Object.values(registry.objects).forEach(o=>{\n      const opt = document.createElement('option');\n      opt.value = o.id; opt.text = `${o.id} (${o.kind})`;\n      sel.add(opt);\n    });\n  }\n  function showInspector(){\n    const sel = document.getElementById('inspector-select');\n    const id = sel.value;\n    const area = document.getElementById('inspector');\n    if (!id || !registry.objects[id]) { area.textContent = 'No object selected.'; return; }\n    area.textContent = JSON.stringify(registry.objects[id], null, 2);\n  }\n  document.getElementById('inspect-refresh').addEventListener('click', showInspector);\n  document.getElementById('inspect-delete').addEventListener('click', ()=>{\n    const id = document.getElementById('inspector-select').value;\n    if (!id) return;\n    removeObject(id);\n    refreshRegistry();\n  });\n  document.getElementById('inspector-invoke').addEventListener('click', ()=>{\n    const id = document.getElementById('inspector-select').value;\n    const method = document.getElementById('inspector-method').value;\n    const arg = document.getElementById('inspector-arg').value;\n    if (!id || !registry.objects[id]) return;\n    try {\n      const obj = registry.objects[id];\n      // Special-case some methods supported by pattern wrappers\n      if (obj.data.methods && typeof obj.data.methods[method] === 'function'){\n        obj.data.methods[method](arg);\n        log(`Invoked ${method} on ${id} with arg='${arg}'`);\n        refreshRegistry();\n      } else {\n        log(`Method ${method} not found on ${id}`, 'info');\n      }\n    } catch(e){\n      log('Invoke error: '+e.message,'info');\n    }\n  });\n\n  // Helper to populate selects by kind/metadata\n  function fillSelectByKind(selectId, kindFilter, includeAll){\n    const sel = document.getElementById(selectId);\n    if (!sel) return;\n    const prev = sel.value;\n    sel.innerHTML = '';\n    Object.values(registry.objects).forEach(o=>{\n      if (typeof kindFilter === 'function' ? kindFilter(o) : (!kindFilter || o.kind === kindFilter)){\n        const opt = document.createElement('option');\n        opt.value = o.id; opt.text = `${o.id} (${o.kind})`;\n        sel.add(opt);\n      }\n    });\n    if (prev) sel.value = prev;\n  }\n\n  function refreshAllSelectors(){\n    // Fill various selectors\n    fillSelectByKind('inspector-select'); // all\n    fillSelectByKind('observer-subject-select', o => o.kind === 'subject' || o.kind === 'factory-product' || o.kind === 'singleton');\n    fillSelectByKind('observer-observer-select', o => o.kind === 'observer' || o.kind === 'singleton' || o.kind === 'proxy');\n    fillSelectByKind('factory-type-select', o => o.kind === 'factory-type');\n    fillSelectByKind('strategy-context-select', o => o.kind === 'strategy-context');\n    fillSelectByKind('strategy-select', o => o.kind === 'strategy');\n    fillSelectByKind('cmd-receiver-select', o => o.kind === 'receiver');\n    fillSelectByKind('state-context-select', o => o.kind === 'state-context');\n    fillSelectByKind('decorator-base-select', o => o.kind === 'base' || o.kind === 'factory-product');\n    fillSelectByKind('adapter-foreign-select', o => o.kind === 'foreign');\n    fillSelectByKind('composite-parent-select', o => o.kind === 'component');\n    fillSelectByKind('composite-child-select', o => o.kind === 'component');\n    fillSelectByKind('proxy-target-select', o => o.kind === 'target' || o.kind === 'factory-product');\n    fillSelectByKind('chain-from-select', o => o.kind === 'chain-node');\n    fillSelectByKind('chain-to-select', o => o.kind === 'chain-node');\n    fillSelectByKind('memento-object-select', o => o.kind !== 'snapshot');\n    fillSelectByKind('memento-snapshot-select', o => o.kind === 'snapshot');\n    fillSelectByKind('adapter-foreign-select', o => o.kind === 'foreign');\n    fillSelectByKind('decorator-base-select', o => o.kind === 'base' || o.kind === 'factory-product');\n    fillSelectByKind('factory-type-select', o => o.kind === 'factory-type');\n    refreshInspectorList();\n    // Also update scenario option if needed\n  }\n\n  // Save/load state\n  document.getElementById('save-state').addEventListener('click', ()=>{\n    const state = {\n      objects: registry.objects,\n      singletons: registry.singletons,\n      commands: registry.commands,\n      snapshots: registry.snapshots\n    };\n    const json = JSON.stringify(state, null, 2);\n    document.getElementById('state-json').value = json;\n    log('State serialized to textarea', 'debug');\n  });\n  document.getElementById('load-state').addEventListener('click', ()=>{\n    try {\n      const obj = JSON.parse(document.getElementById('state-json').value);\n      registry.objects = obj.objects || {};\n      registry.singletons = obj.singletons || {};\n      registry.commands = obj.commands || { stack: [], cur: -1 };\n      registry.snapshots = obj.snapshots || {};\n      refreshRegistry();\n      log('State loaded from textarea', 'debug');\n    } catch(e){\n      log('Invalid JSON for load', 'info');\n    }\n  });\n\n  document.getElementById('export-state').addEventListener('click', ()=>{\n    document.getElementById('state-json').value = JSON.stringify({ objects: registry.objects }, null, 2);\n    log('Exported state to JSON box', 'debug');\n  });\n  document.getElementById('import-state').addEventListener('click', ()=>{\n    try {\n      const obj = JSON.parse(document.getElementById('state-json').value);\n      if (obj.objects) registry.objects = obj.objects;\n      refreshRegistry();\n      log('Imported state', 'debug');\n    } catch(e){\n      log('Import failed: invalid JSON', 'info');\n    }\n  });\n\n  // Factory implementation\n  const factoryTypes = {}; // local mapping name->type data\n  document.getElementById('factory-create-type').addEventListener('click', ()=>{\n    const name = document.getElementById('factory-product-name').value || 'Product';\n    const def = document.getElementById('factory-product-default').value || '';\n    const typeId = addObject('factory-type', { name, default: def }, { created: Date.now() });\n    factoryTypes[typeId] = { name, default: def };\n    refreshRegistry();\n  });\n  document.getElementById('factory-create-instance').addEventListener('click', ()=>{\n    const sel = document.getElementById('factory-type-select');\n    if (!sel.value) { log('No factory type selected', 'info'); return; }\n    const count = parseInt(document.getElementById('factory-instance-count').value,10) || 1;\n    for (let i=0;i<count;i++){\n      const type = registry.objects[sel.value];\n      const id = addObject('factory-product', { typeRef: sel.value, value: type.data.default || 0 }, { createdFrom: sel.value });\n      // give product some methods\n      registry.objects[id].data.methods = {\n        set: function(v){ this.value = v; log(`Product ${id} set to ${v}`, 'debug'); },\n        inc: function(v){ this.value = Number(this.value) + (Number(v)||1); log(`Product ${id} incremented to ${this.value}`, 'debug'); }\n      };\n    }\n    refreshRegistry();\n  });\n\n  // Singleton\n  document.getElementById('singleton-create').addEventListener('click', ()=>{\n    const name = document.getElementById('singleton-name').value || 'Singleton';\n    if (registry.singletons[name]){\n      log(`Retrieved singleton ${name} => ${registry.singletons[name]}`, 'debug');\n      return;\n    }\n    const id = addObject('singleton', { name, value: null }, { singletonName: name });\n    registry.singletons[name] = id;\n    refreshRegistry();\n    log(`Created singleton ${name} as ${id}`, 'debug');\n  });\n  document.getElementById('singleton-set').addEventListener('click', ()=>{\n    const name = document.getElementById('singleton-name').value || 'Singleton';\n    const v = document.getElementById('singleton-value').value;\n    const id = registry.singletons[name];\n    if (!id) { log('No such singleton; create it first', 'info'); return; }\n    registry.objects[id].data.value = v;\n    log(`Set singleton ${name}(${id}) value='${v}'`, 'debug');\n    refreshRegistry();\n  });\n\n  // Observer\n  function createSubject(){\n    const id = addObject('subject', { observers: [], lastEvent: null }, {});\n    registry.objects[id].data.methods = {\n      notify: function(payload){\n        this.lastEvent = payload;\n        log(`Subject ${id} notifies payload=${JSON.stringify(payload)}`, 'debug');\n        this.observers.forEach(obsId => {\n          const obs = registry.objects[obsId];\n          if (obs && obs.data && typeof obs.data.onNotify === 'function'){\n            obs.data.onNotify(payload, id);\n          }\n        });\n      }\n    };\n    return id;\n  }\n  function createObserver(){\n    const id = addObject('observer', { seen: [] }, {});\n    registry.objects[id].data.onNotify = function(payload, subjectId){\n      this.seen.push({ from: subjectId, payload: payload, t: Date.now() });\n      log(`Observer ${id} received event from ${subjectId}: ${JSON.stringify(payload)}`, 'debug');\n    };\n    return id;\n  }\n  document.getElementById('observer-create-subject').addEventListener('click', ()=> { createSubject(); refreshRegistry(); });\n  document.getElementById('observer-create-observer').addEventListener('click', ()=> { createObserver(); refreshRegistry(); });\n  document.getElementById('observer-subscribe').addEventListener('click', ()=>{\n    const subj = document.getElementById('observer-subject-select').value;\n    const obs = document.getElementById('observer-observer-select').value;\n    if (!subj || !obs) return;\n    const s = registry.objects[subj]; const o = registry.objects[obs];\n    s.data.observers = s.data.observers || [];\n    if (!s.data.observers.includes(obs)) s.data.observers.push(obs);\n    log(`Subscribed ${obs} to ${subj}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('observer-unsubscribe').addEventListener('click', ()=>{\n    const subj = document.getElementById('observer-subject-select').value;\n    const obs = document.getElementById('observer-observer-select').value;\n    if (!subj || !obs) return;\n    const s = registry.objects[subj];\n    s.data.observers = (s.data.observers || []).filter(x=>x!==obs);\n    log(`Unsubscribed ${obs} from ${subj}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('observer-publish').addEventListener('click', ()=>{\n    const subj = document.getElementById('observer-subject-select').value;\n    const payload = document.getElementById('observer-event-payload').value;\n    if (!subj) return;\n    registry.objects[subj].data.methods.notify({ payload, time: Date.now() });\n    refreshRegistry();\n  });\n\n  // Strategy\n  document.getElementById('strategy-create-context').addEventListener('click', ()=>{\n    const id = addObject('strategy-context', { strategy: null }, {});\n    registry.objects[id].data.methods = {\n      execute: function(arg){\n        if (!this.strategy) { log(`Context ${id} has no strategy`, 'info'); return; }\n        const s = registry.objects[this.strategy];\n        if (s && s.data && typeof s.data.fn === 'function'){\n          const res = s.data.fn(arg);\n          log(`Strategy executed in ${id} with arg=${arg} => ${res}`, 'debug');\n          return res;\n        }\n      }\n    };\n    refreshRegistry();\n  });\n  document.getElementById('strategy-create-strategy').addEventListener('click', ()=>{\n    const id = addObject('strategy', { fn: null }, {});\n    // create a simple strategy: square or multiply factor\n    const idx = Object.keys(registry.objects).length % 3;\n    registry.objects[id].data.fn = function(arg){\n      const n = Number(arg)||0;\n      if (idx === 0) return n*2;\n      if (idx === 1) return n*n;\n      return n+10;\n    };\n    refreshRegistry();\n  });\n  document.getElementById('strategy-assign').addEventListener('click', ()=>{\n    const ctx = document.getElementById('strategy-context-select').value;\n    const strat = document.getElementById('strategy-select').value;\n    if (!ctx || !strat) return;\n    registry.objects[ctx].data.strategy = strat;\n    log(`Assigned strategy ${strat} to context ${ctx}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('strategy-execute').addEventListener('click', ()=>{\n    const ctx = document.getElementById('strategy-context-select').value;\n    const arg = document.getElementById('strategy-input').value;\n    if (!ctx) return;\n    const res = registry.objects[ctx].data.methods.execute.call(registry.objects[ctx].data, arg);\n    refreshRegistry();\n  });\n\n  // Command pattern with undo/redo\n  document.getElementById('cmd-create-receiver').addEventListener('click', ()=>{\n    const id = addObject('receiver', { value: 0 }, {});\n    registry.objects[id].data.methods = {\n      inc: function(amount){ this.value = Number(this.value) + (Number(amount)||1); log(`Receiver ${id} value=${this.value}`, 'debug'); },\n      dec: function(amount){ this.value = Number(this.value) - (Number(amount)||1); log(`Receiver ${id} value=${this.value}`, 'debug'); }\n    };\n    refreshRegistry();\n  });\n  function createIncrementCommand(receiverId, amount){\n    return {\n      id: uid('cmd'),\n      receiver: receiverId,\n      amount: amount,\n      execute: function(){ const r = registry.objects[this.receiver]; r.data.methods.inc.call(r.data, this.amount); },\n      undo: function(){ const r = registry.objects[this.receiver]; r.data.methods.dec.call(r.data, this.amount); }\n    };\n  }\n  document.getElementById('cmd-create-command').addEventListener('click', ()=>{\n    const recv = document.getElementById('cmd-receiver-select').value;\n    if (!recv) { log('Create a receiver first', 'info'); return; }\n    const cmd = createIncrementCommand(recv, 1);\n    // push to prepared slot (not executed yet)\n    registry.preparedCommand = cmd;\n    log(`Prepared command ${cmd.id} for receiver ${recv}`, 'debug');\n  });\n  document.getElementById('cmd-execute').addEventListener('click', ()=>{\n    const cmd = registry.preparedCommand;\n    if (!cmd) { log('No prepared command; create one', 'info'); return; }\n    cmd.execute();\n    // push to stack\n    registry.commands.stack = registry.commands.stack.slice(0, registry.commands.cur+1);\n    registry.commands.stack.push(cmd);\n    registry.commands.cur++;\n    registry.preparedCommand = null;\n    log(`Executed command ${cmd.id}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('cmd-undo').addEventListener('click', ()=>{\n    if (registry.commands.cur < 0) { log('Nothing to undo', 'info'); return; }\n    const cmd = registry.commands.stack[registry.commands.cur];\n    cmd.undo();\n    registry.commands.cur--;\n    log(`Undid command ${cmd.id}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('cmd-redo').addEventListener('click', ()=>{\n    if (registry.commands.cur >= registry.commands.stack.length-1) { log('Nothing to redo', 'info'); return; }\n    registry.commands.cur++;\n    const cmd = registry.commands.stack[registry.commands.cur];\n    cmd.execute();\n    log(`Redid command ${cmd.id}`, 'debug');\n    refreshRegistry();\n  });\n\n  // State Pattern\n  function createStateContext(){\n    const id = addObject('state-context', { states: {}, current: null, auto: false }, {});\n    registry.objects[id].data.methods = {\n      addState: function(name, onEnter){\n        this.states[name] = { onEnter: onEnter || function(){ log('entered '+name,'debug'); } };\n      },\n      switch: function(to){\n        if (!this.states[to]) { log(`State ${to} not found`, 'info'); return; }\n        this.current = to;\n        const s = this.states[to];\n        if (s && typeof s.onEnter === 'function') s.onEnter.call(this, to);\n        log(`Context ${id} switched to ${to}`, 'debug');\n      }\n    };\n    return id;\n  }\n  document.getElementById('state-create-context').addEventListener('click', ()=> { createStateContext(); refreshRegistry(); });\n  document.getElementById('state-add-state').addEventListener('click', ()=>{\n    const ctx = document.getElementById('state-context-select').value;\n    const name = document.getElementById('state-name').value || 's';\n    if (!ctx) return;\n    registry.objects[ctx].data.methods.addState.call(registry.objects[ctx].data, name, function(n){\n      log(`Context ${ctx} entered state ${n}`, 'debug');\n      // simple auto-transition: if state name contains 'next' switch to something else\n    });\n    refreshRegistry();\n  });\n  document.getElementById('state-switch').addEventListener('click', ()=>{\n    const ctx = document.getElementById('state-context-select').value;\n    const name = document.getElementById('state-name').value || '';\n    if (!ctx) return;\n    registry.objects[ctx].data.methods.switch.call(registry.objects[ctx].data, name);\n    refreshRegistry();\n  });\n  // Auto transitions (scheduler)\n  const autoTimers = {};\n  document.getElementById('state-auto').addEventListener('click', ()=>{\n    const ctx = document.getElementById('state-context-select').value;\n    if (!ctx) return;\n    if (autoTimers[ctx]) return;\n    autoTimers[ctx] = setInterval(() => {\n      const obj = registry.objects[ctx];\n      if (!obj) { clearInterval(autoTimers[ctx]); delete autoTimers[ctx]; return; }\n      const keys = Object.keys(obj.data.states);\n      if (keys.length === 0) return;\n      const cur = obj.data.current;\n      const idx = Math.max(0, keys.indexOf(cur));\n      const next = keys[(idx+1) % keys.length];\n      obj.data.methods.switch.call(obj.data, next);\n      refreshRegistry();\n    }, registry.speed || 500);\n    log(`Started auto for ${ctx}`, 'debug');\n  });\n  document.getElementById('state-stop-auto').addEventListener('click', ()=>{\n    const ctx = document.getElementById('state-context-select').value;\n    if (!ctx || !autoTimers[ctx]) return;\n    clearInterval(autoTimers[ctx]); delete autoTimers[ctx];\n    log(`Stopped auto for ${ctx}`, 'debug');\n  });\n\n  // Decorator\n  document.getElementById('decorator-create-base').addEventListener('click', ()=>{\n    const id = addObject('base', { text: 'base', decoratedWith: [] }, {});\n    registry.objects[id].data.methods = {\n      info: function(){ log(`Base ${id} text='${this.text}', decorators=${JSON.stringify(this.decoratedWith)}`, 'debug'); }\n    };\n    refreshRegistry();\n  });\n  document.getElementById('decorator-wrap').addEventListener('click', ()=>{\n    const baseId = document.getElementById('decorator-base-select').value;\n    const note = document.getElementById('decorator-note').value || 'dec';\n    if (!baseId) return;\n    const decoratorId = addObject('decorator', { base: baseId, note }, {});\n    // wrap by adding decorator ref to base\n    registry.objects[baseId].data.decoratedWith.push(decoratorId);\n    // add a method to decorator that augments base\n    registry.objects[decoratorId].data.methods = {\n      info: function(){\n        const base = registry.objects[this.base];\n        const prev = base.data.text;\n        const newv = prev + '['+this.note+']';\n        base.data.text = newv;\n        log(`Decorator ${decoratorId} wrapped base ${this.base}, new text='${newv}'`, 'debug');\n      }\n    };\n    refreshRegistry();\n  });\n\n  // Adapter\n  document.getElementById('adapter-create-foreign').addEventListener('click', ()=>{\n    const id = addObject('foreign', { foreignValue: Math.random()*100 }, {});\n    registry.objects[id].data.methods = {\n      getForeign: function(){ return this.foreignValue; }\n    };\n    refreshRegistry();\n  });\n  document.getElementById('adapter-adapt').addEventListener('click', ()=>{\n    const foreign = document.getElementById('adapter-foreign-select').value;\n    const name = document.getElementById('adapter-name').value || 'Adapter';\n    if (!foreign) return;\n    const id = addObject('adapter', { foreignRef: foreign, name }, {});\n    // Adapter exposes an 'get' method mapped to foreign.getForeign\n    registry.objects[id].data.methods = {\n      get: function(){ const f = registry.objects[this.foreignRef]; if (!f) return null; return f.data.methods.getForeign.call(f.data); }\n    };\n    refreshRegistry();\n  });\n\n  // Composite\n  document.getElementById('composite-create').addEventListener('click', ()=>{\n    const id = addObject('component', { children: [], name: 'node' }, {});\n    registry.objects[id].data.methods = {\n      addChild: function(childId){ this.children.push(childId); },\n      removeChild: function(childId){ this.children = this.children.filter(c=>c!==childId); },\n      traverse: function(fn, depth=0){\n        fn(this, depth);\n        this.children.forEach(cid => {\n          const c = registry.objects[cid];\n          if (c && c.data && typeof c.data.methods.traverse === 'function') c.data.methods.traverse.call(c.data, fn, depth+1);\n        });\n      }\n    };\n    refreshRegistry();\n  });\n  document.getElementById('composite-add-child').addEventListener('click', ()=>{\n    const parent = document.getElementById('composite-parent-select').value;\n    const child = document.getElementById('composite-child-select').value;\n    if (!parent || !child) return;\n    registry.objects[parent].data.methods.addChild.call(registry.objects[parent].data, child);\n    log(`Added child ${child} to ${parent}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('composite-traverse').addEventListener('click', ()=>{\n    const parent = document.getElementById('composite-parent-select').value;\n    if (!parent) return;\n    const out = [];\n    registry.objects[parent].data.methods.traverse.call(registry.objects[parent].data, (node, d)=> out.push(' '.repeat(d*2) + (node.name || node.id)));\n    log('Traverse result:\\\\n' + out.join('\\\\n'), 'debug');\n  });\n\n  // Proxy\n  document.getElementById('proxy-create-target').addEventListener('click', ()=>{\n    const id = addObject('target', { allowed: true, secret: 's_'+Math.floor(Math.random()*100) }, {});\n    registry.objects[id].data.methods = {\n      readSecret: function(){ return this.secret; }\n    };\n    refreshRegistry();\n  });\n  document.getElementById('proxy-create-proxy').addEventListener('click', ()=>{\n    const target = document.getElementById('proxy-target-select').value;\n    const name = document.getElementById('proxy-name').value || 'Proxy';\n    if (!target) return;\n    const id = addObject('proxy', { targetRef: target, allowed: true, name }, {});\n    registry.objects[id].data.methods = {\n      readSecret: function(){ const t = registry.objects[this.targetRef]; if (!this.allowed) { log(`Proxy ${id} denied access to ${this.targetRef}`, 'debug'); return null; } return t.data.methods.readSecret.call(t.data); }\n    };\n    refreshRegistry();\n  });\n  document.getElementById('proxy-toggle-access').addEventListener('click', ()=>{\n    const p = document.getElementById('proxy-target-select').value;\n    // allow toggling for proxies referring to that target\n    Object.values(registry.objects).forEach(o=>{\n      if (o.kind === 'proxy' && o.data.targetRef === p) o.data.allowed = !o.data.allowed;\n    });\n    log(`Toggled proxies referencing ${p}`, 'debug');\n    refreshRegistry();\n  });\n\n  // Chain of responsibility\n  document.getElementById('chain-create-node').addEventListener('click', ()=>{\n    const id = addObject('chain-node', { next: null, idnum: Math.floor(Math.random()*100) }, {});\n    registry.objects[id].data.handle = function(request){\n      // simple handling: handles if request contains number less than idnum\n      const parts = String(request).split(':');\n      const val = Number(parts[1])||0;\n      if (val <= this.idnum){\n        log(`Node ${id} handled request ${request}`, 'debug');\n        return { handled: true, node: id };\n      }\n      return { handled:false };\n    };\n    refreshRegistry();\n  });\n  document.getElementById('chain-link-nodes').addEventListener('click', ()=>{\n    const from = document.getElementById('chain-from-select').value;\n    const to = document.getElementById('chain-to-select').value;\n    if (!from || !to) return;\n    registry.objects[from].data.next = to;\n    log(`Linked ${from} -> ${to}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('chain-send').addEventListener('click', ()=>{\n    let head = document.getElementById('chain-from-select').value;\n    const req = document.getElementById('chain-request').value;\n    if (!head) return;\n    let cur = head;\n    while (cur){\n      const node = registry.objects[cur];\n      const res = node.data.handle(req);\n      if (res && res.handled) { log(`Request ${req} handled by ${cur}`, 'debug'); break; }\n      cur = node.data.next;\n    }\n    if (!cur) log(`Request ${req} reached end of chain unhandled`, 'debug');\n  });\n\n  // Memento\n  document.getElementById('memento-snapshot').addEventListener('click', ()=>{\n    const objId = document.getElementById('memento-object-select').value;\n    if (!objId) return;\n    const snap = deepClone(registry.objects[objId]);\n    const snapId = addObject('snapshot', { snapshotFor: objId, snapshot: snap }, {});\n    registry.snapshots[objId] = registry.snapshots[objId] || [];\n    registry.snapshots[objId].push(snapId);\n    // Add snapshot reference to snapshot object for inspector\n    registry.objects[snapId].data.snapshotT = Date.now();\n    log(`Snapshot ${snapId} created for ${objId}`, 'debug');\n    refreshRegistry();\n  });\n  document.getElementById('memento-restore').addEventListener('click', ()=>{\n    const objId = document.getElementById('memento-object-select').value;\n    const snapId = document.getElementById('memento-snapshot-select').value;\n    if (!objId || !snapId) return;\n    const snap = registry.objects[snapId].data.snapshot;\n    if (!snap) { log('Invalid snapshot', 'info'); return; }\n    registry.objects[objId] = deepClone(snap);\n    registry.objects[objId].id = objId; // preserve id\n    log(`Restored ${objId} from ${snapId}`, 'debug');\n    refreshRegistry();\n  });\n\n  // Scenarios\n  const scenarios = {\n    observerDemo: function(){\n      // Create subject and multiple observers and publish\n      const s = createSubject();\n      const o1 = createObserver();\n      const o2 = createObserver();\n      registry.objects[s].data.observers.push(o1, o2);\n      refreshRegistry();\n      log('Scenario: publishing sample events', 'debug');\n      registry.objects[s].data.methods.notify({ scenario: 'observerDemo', count: 1 });\n      setTimeout(()=> registry.objects[s].data.methods.notify({ scenario: 'observerDemo', count: 2 }), 500);\n    },\n    commandUndoRedo: function(){\n      const r = addObject('receiver', { value: 0 }, {});\n      registry.objects[r].data.methods = {\n        inc: function(a){ this.value += a; log(`receiver ${r} value=${this.value}`, 'debug'); },\n        dec: function(a){ this.value -= a; log(`receiver ${r} value=${this.value}`, 'debug'); }\n      };\n      const c1 = createIncrementCommand(r, 5);\n      const c2 = createIncrementCommand(r, 3);\n      // exec sequentially\n      c1.execute(); registry.commands.stack.push(c1); registry.commands.cur++;\n      setTimeout(()=>{ c2.execute(); registry.commands.stack.push(c2); registry.commands.cur++; refreshRegistry(); }, 300);\n      setTimeout(()=>{ registry.commands.stack[registry.commands.cur].undo(); registry.commands.cur--; refreshRegistry(); }, 800);\n    },\n    decoratorFlow: function(){\n      // factory, create base product, then decorate repeatedly\n      const t = addObject('factory-type', { name:'Thing', default: '0' }, {});\n      const p = addObject('factory-product', { typeRef: t, value: 0, decoratedWith: [] }, {});\n      registry.objects[p].data.methods = { inc: function(){ this.value = Number(this.value)+1; } };\n      const d1 = addObject('decorator', { base: p, note: 'red' }, {});\n      const d2 = addObject('decorator', { base: p, note: 'wrap' }, {});\n      registry.objects[p].data.decoratedWith = [d1, d2];\n      log('Decorator scenario created product and two decorators', 'debug');\n      refreshRegistry();\n    },\n    compositeTraversal: function(){\n      const root = addObject('component', { children: [], name: 'root' }, {});\n      const a = addObject('component', { children: [], name: 'A' }, {});\n      const b = addObject('component', { children: [], name: 'B' }, {});\n      const c = addObject('component', { children: [], name: 'C' }, {});\n      registry.objects[root].data.children.push(a,b);\n      registry.objects[b].data.children.push(c);\n      registry.objects[root].data.methods = registry.objects[a].data.methods = registry.objects[b].data.methods = registry.objects[c].data.methods = {\n        traverse: function(fn, depth=0){\n          fn(this, depth);\n          (this.children||[]).forEach(cid => {\n            const node = registry.objects[cid];\n            if (node) node.data.methods.traverse.call(node.data, fn, depth+1);\n          });\n        }\n      };\n      refreshRegistry();\n      registry.objects[root].data.methods.traverse.call(registry.objects[root].data, (n,d)=> log('-'.repeat(d)+ (n.name || 'node'), 'debug'));\n    }\n  };\n  document.getElementById('scenario-run').addEventListener('click', ()=>{\n    const sel = document.getElementById('scenario-select').value;\n    if (!sel) return;\n    scenarios[sel]();\n  });\n\n  // Run / Step / Scheduler\n  document.getElementById('btn-run').addEventListener('click', ()=>{\n    if (registry.runLoop) return;\n    registry.runLoop = true;\n    log('Run started', 'debug');\n    registry.scheduler = setInterval(() => {\n      // One tick: auto-invoke some active behaviors (e.g., notify random subject, auto state)\n      // For demo: pick a random subject and notify\n      const subjects = Object.values(registry.objects).filter(o=>o.kind==='subject');\n      if (subjects.length){\n        const idx = Math.floor(Math.random()*subjects.length);\n        const s = subjects[idx];\n        s.data.methods.notify({ tick: Date.now() });\n      }\n      refreshRegistry();\n    }, registry.speed || 500);\n  });\n  document.getElementById('btn-pause').addEventListener('click', ()=>{\n    registry.runLoop = false;\n    if (registry.scheduler) clearInterval(registry.scheduler);\n    registry.scheduler = null;\n    log('Run paused', 'debug');\n  });\n  document.getElementById('btn-step').addEventListener('click', ()=>{\n    // One step: same as one tick above but synchronous\n    const subjects = Object.values(registry.objects).filter(o=>o.kind==='subject');\n    if (subjects.length){\n      const idx = Math.floor(Math.random()*subjects.length);\n      const s = subjects[idx];\n      s.data.methods.notify({ step: Date.now() });\n      log('Step executed', 'debug');\n    } else {\n      log('Step: no subjects to notify', 'debug');\n    }\n    refreshRegistry();\n  });\n  document.getElementById('btn-reset').addEventListener('click', ()=>{\n    // Clear registry entirely\n    Object.keys(registry.objects).forEach(k=> delete registry.objects[k]);\n    registry.singletons = {};\n    registry.commands = { stack: [], cur: -1 };\n    registry.snapshots = {};\n    idCounter = 1;\n    refreshRegistry();\n    log('Reset playground', 'debug');\n  });\n\n  // Initial refresh\n  refreshRegistry();\n\n  // UI bindings for many selects to refresh when registry changes\n  setInterval(refreshRegistry, 1000);\n\n  // Wire remaining buttons that reference selectors by id to ensure refresh before use\n  document.getElementById('refresh-registry').addEventListener('click', refreshRegistry);\n\n  // Populate some initial objects for quick start\n  addObject('subject', { observers: [], lastEvent: null }, {});\n  addObject('observer', { seen: [] }, {});\n  addObject('factory-type', { name:'Sample', default:1 }, {});\n  refreshRegistry();\n\n  // Export log to console for convenience\n  log('Interactive playground ready', 'debug');\n})();\n</script>\n</body>\n</html>"
  },
