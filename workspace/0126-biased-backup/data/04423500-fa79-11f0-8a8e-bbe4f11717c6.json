    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Insertion Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .header {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n        .header h1 {\n            margin: 0;\n        }\n        .footer {\n            background-color: #e74c3c;\n            color: #fff;\n            padding: 10px;\n            border-top: 1px solid #ccc;\n        }\n        .footer h1 {\n            margin: 0;\n        }\n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Insertion Sort</h1>\n            <p>Learn how to implement this efficient sorting algorithm in JavaScript</p>\n        </div>\n        <div class=\"footer\">\n            <p>&copy; 2023 Insertion Sort Tutorial</p>\n        </div>\n        <div class=\"button\">\n            <button id=\"sort-btn\">Sort Array</button>\n        </div>\n        <div class=\"button\">\n            <button id=\"clear-btn\">Clear Array</button>\n        </div>\n        <div class=\"button\">\n            <button id=\"reset-btn\">Reset Array</button>\n        </div>\n        <div class=\"button\">\n            <button id=\"sort-btn-2\">Sort Array (Descending)</button>\n        </div>\n        <div class=\"button\">\n            <button id=\"clear-btn-2\">Clear Array (Descending)</button>\n        </div>\n        <div class=\"button\">\n            <button id=\"reset-btn-2\">Reset Array (Descending)</button>\n        </div>\n    </div>\n\n    <script>\n        let array = [64, 34, 25, 12, 22, 11, 90];\n        let sortBtn = document.getElementById('sort-btn');\n        let clearBtn = document.getElementById('clear-btn');\n        let resetBtn = document.getElementById('reset-btn');\n        let sortBtn2 = document.getElementById('sort-btn-2');\n        let clearBtn2 = document.getElementById('clear-btn-2');\n        let resetBtn2 = document.getElementById('reset-btn-2');\n\n        function sortArray(array) {\n            for (let i = 0; i < array.length; i++) {\n                for (let j = i + 1; j < array.length; j++) {\n                    if (array[i] > array[j]) {\n                        let temp = array[i];\n                        array[i] = array[j];\n                        array[j] = temp;\n                    }\n                }\n            }\n            return array;\n        }\n\n        function clearArray(array) {\n            array = [];\n            return array;\n        }\n\n        function resetArray(array) {\n            array = [];\n            return array;\n        }\n\n        sortBtn.addEventListener('click', () => {\n            array = sortArray(array);\n            document.getElementById('array').innerHTML = 'Sorted Array: ' + array.join(', ');\n        });\n\n        clearBtn.addEventListener('click', () => {\n            array = clearArray(array);\n            document.getElementById('array').innerHTML = 'Array after clearing: ' + array.join(', ');\n        });\n\n        resetBtn.addEventListener('click', () => {\n            array = resetArray(array);\n            document.getElementById('array').innerHTML = 'Array after resetting: ' + array.join(', ');\n        });\n\n        sortBtn2.addEventListener('click', () => {\n            array = sortArray(array);\n            document.getElementById('array-2').innerHTML = 'Sorted Array (Descending): ' + array.join(', ');\n        });\n\n        clearBtn2.addEventListener('click', () => {\n            array = clearArray(array);\n            document.getElementById('array-2').innerHTML = 'Array after clearing (Descending): ' + array.join(', ');\n        });\n\n        resetBtn2.addEventListener('click', () => {\n            array = resetArray(array);\n            document.getElementById('array-2').innerHTML = 'Array after resetting (Descending): ' + array.join(', ');\n        });\n    </script>\n\n    <div id=\"array\"></div>\n    <div id=\"array-2\"></div>\n</body>\n</html>"
