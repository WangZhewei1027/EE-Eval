  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Virtual Memory Interactive Simulator</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  input, button, select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  hr {\n    margin: 1em 0;\n  }\n  textarea {\n    font-family: monospace, monospace;\n    font-size: 0.9em;\n    width: 100%;\n    height: 12em;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n  #control-panel > div {\n    margin-bottom: 0.8em;\n  }\n</style>\n</head>\n<body>\n<h1>Virtual Memory Interactive Simulator</h1>\n\n<div id=\"description\">\n  <p>This simulator helps you explore virtual memory concepts by configuring system parameters,\n     loading programs, accessing memory addresses, and observing page tables, physical memory,\n     and page faults. You have full control over page size, virtual memory size, physical memory size,\n     number of processes, and can simulate many memory operations and scenarios.</p>\n</div>\n\n<hr />\n\n<div id=\"control-panel\">\n\n  <div>\n    <b>1. Configure System Parameters:</b><br />\n    <label>\n      Page Size (bytes, power of two, 16 - 1024):\n      <input type=\"number\" id=\"pageSizeInput\" value=\"64\" min=\"16\" max=\"1024\" step=\"16\" />\n    </label>\n    <label>\n      Virtual Address Space Size (KB, 4 - 64):\n      <input type=\"number\" id=\"virtualMemKBInput\" value=\"16\" min=\"4\" max=\"64\" step=\"4\" />\n    </label>\n    <label>\n      Physical Memory Size (KB, 1 - 32):\n      <input type=\"number\" id=\"physicalMemKBInput\" value=\"8\" min=\"1\" max=\"32\" step=\"1\" />\n    </label>\n    <label>\n      Number of Processes (1 - 5):\n      <input type=\"number\" id=\"processCountInput\" value=\"2\" min=\"1\" max=\"5\" step=\"1\" />\n    </label>\n    <button id=\"applyConfigBtn\">Apply Configuration and Initialize</button>\n  </div>\n\n  <hr />\n\n  <div id=\"process-management\" style=\"display:none;\">\n    <b>2. Process Management:</b><br />\n    <label>\n      Select Process:\n      <select id=\"processSelector\"></select>\n    </label>\n    <button id=\"addProcessBtn\">Add New Process</button>\n    <button id=\"removeProcessBtn\">Remove Selected Process</button>\n    <button id=\"resetAllProcessesBtn\">Reset All Processes (Clear Pages/Memory)</button>\n  </div>\n\n  <hr />\n\n  <div id=\"program-management\" style=\"display:none;\">\n    <b>3. Load/Unload Programs into Process Virtual Memory:</b><br />\n    <label>\n      Program Name:\n      <input type=\"text\" id=\"programNameInput\" placeholder=\"e.g. progA\" />\n    </label>\n    <label>\n      Program Size (bytes):\n      <input type=\"number\" id=\"programSizeInput\" min=\"1\" value=\"256\" />\n    </label>\n    <button id=\"loadProgramBtn\">Load Program into Selected Process</button>\n    <button id=\"unloadProgramBtn\">Unload Program from Selected Process</button>\n    <div><small>Programs are mapped to continuous virtual pages starting at 0 (for simplicity)</small></div>\n  </div>\n\n  <hr />\n\n  <div id=\"memory-access\" style=\"display:none;\">\n    <b>4. Memory Access Simulation:</b><br />\n    <label>\n      Access Virtual Address (decimal):\n      <input type=\"number\" id=\"accessAddressInput\" min=\"0\" />\n    </label>\n    <button id=\"accessMemoryBtn\">Access Memory (Read)</button>\n    <label>\n      Access Mode:\n      <select id=\"accessModeSelect\">\n        <option value=\"read\">Read</option>\n        <option value=\"write\">Write</option>\n      </select>\n    </label>\n    <button id=\"showPageTableBtn\">Show Page Table of Selected Process</button>\n    <button id=\"showPhysicalMemoryBtn\">Show Physical Memory Frames</button>\n    <button id=\"showTLBBtn\">Show TLB Entries</button>\n    <div id=\"memoryAccessResult\" style=\"white-space: pre-wrap; border: 1px solid black; padding: 0.3em; margin-top: 0.5em; height: 8em; overflow-y: auto;\"></div>\n  </div>\n  \n  <hr />\n\n  <div id=\"tlb-controls\" style=\"display:none;\">\n    <b>5. TLB (Translation Lookaside Buffer) Controls:</b><br />\n    <label>\n      TLB Size (entries):\n      <input type=\"number\" id=\"tlbSizeInput\" min=\"1\" max=\"16\" value=\"4\" />\n    </label>\n    <button id=\"applyTLBSizeBtn\">Apply TLB Size</button>\n    <button id=\"clearTLBBtn\">Clear TLB</button>\n  </div>\n\n  <hr />\n\n  <div id=\"stats\" style=\"display:none;\">\n    <b>6. Statistics and Logs:</b><br />\n    <div id=\"statsContent\" style=\"white-space: pre-wrap; border: 1px solid black; padding: 0.4em; height: 10em; overflow-y: auto;\"></div>\n    <button id=\"resetStatsBtn\">Reset Statistics</button>\n  </div>\n\n</div>\n\n<hr />\n\n<div id=\"debug-output\" style=\"white-space: pre-wrap; border: 1px solid black; padding: 0.4em; height: 14em; overflow-y: auto; font-size: 0.85em;\"></div>\n\n<script>\n// Virtual Memory Simulator - Data and State\n\n(function(){\n  // Constants and State\n  let config = {\n    pageSize: 64,\n    virtualMemSizeBytes: 16*1024,\n    physicalMemSizeBytes: 8*1024,\n    processCount: 2,\n    tlbSize: 4,\n  };\n\n  let processes = []; // Array of process objects\n  let physicalMemory = {\n    frameCount: 0,\n    frames: [] // frames hold { processId, virtualPage, valid }\n  };\n\n  let tlb = []; // Array of { processId, virtualPage, frameIndex, lastUsedTime }\n\n  // Stats\n  let stats = {\n    memoryAccesses: 0,\n    tlbHits: 0,\n    tlbMisses: 0,\n    pageFaults: 0,\n  };\n\n  let currentProcessId = 0;\n\n  // Utils\n  function isPowerOfTwo(x) {\n    return (x & (x - 1)) === 0;\n  }\n\n  function logDebug(msg){\n    let dbg = document.getElementById('debug-output');\n    dbg.textContent = msg + \"\\n\\n\" + dbg.textContent;\n  }\n\n  // Classes and Structures\n\n  // Process structure:\n  // id, programs: [{name, size, pagesCount}], pageTable: array indexed by virtualPage,\n  // each entry: { valid (bool), frameIndex (number|null), referencedAt (timestamp), dirty (bool) }\n  // max pages = virtualMemSizeBytes / pageSize\n  function Process(id){\n    this.id = id;\n    this.programs = [];\n    this.pageTable = [];\n    this.maxPageCount = config.virtualMemSizeBytes / config.pageSize;\n\n    // Initialize page table entries: invalid (not loaded)\n    for(let i=0; i<this.maxPageCount; i++){\n      this.pageTable.push({valid:false, frameIndex:null, referencedAt:0, dirty:false});\n    }\n  }\n  Process.prototype.loadProgram = function(name, sizeBytes){\n    // Program mapped from virtual page 0 up to pages needed\n    let pagesNeeded = Math.ceil(sizeBytes/config.pageSize);\n    if(pagesNeeded > this.maxPageCount){\n      return {success:false, error:\"Program size exceeds virtual address space.\"};\n    }\n    // Check overlapping with existing programs -> for simplicity disallow loading if any page occupied\n    for(let i=0; i<pagesNeeded; i++){\n      if(this.pageTable[i].valid){\n        return {success:false, error:\"Virtual pages occupied by existing programs.\"};\n      }\n    }\n    // Mark pages occupied by this program\n    for(let i=0; i<pagesNeeded; i++){\n      this.pageTable[i].valid = false; // initially not loaded in frames - simulate demand paging\n    }\n    this.programs.push({name:name, size:sizeBytes, pagesCount:pagesNeeded});\n    return {success:true, pages:pagesNeeded};\n  };\n  Process.prototype.unloadProgram = function(name){\n    let idx = this.programs.findIndex(p => p.name === name);\n    if(idx === -1) return {success:false, error:\"Program not found in process.\"};\n    let p = this.programs[idx];\n    // Free virtual pages occupied by the program (assume starting at 0)\n    let pagesCount = p.pagesCount;\n    for(let i=0; i<pagesCount; i++){\n      // Before mark invalid, we must free potential frames\n      if(this.pageTable[i].frameIndex !== null){\n        freePhysicalFrame(this.pageTable[i].frameIndex);\n      }\n      this.pageTable[i] = {valid:false, frameIndex:null, referencedAt:0, dirty:false};\n    }\n    this.programs.splice(idx,1);\n    return {success:true};\n  };\n  Process.prototype.resetPages = function(){\n    for(let i=0; i<this.pageTable.length; i++){\n      if(this.pageTable[i].frameIndex !== null){\n        freePhysicalFrame(this.pageTable[i].frameIndex);\n      }\n      this.pageTable[i] = {valid:false, frameIndex:null, referencedAt:0, dirty:false};\n    }\n    this.programs = [];\n  };\n  Process.prototype.virtualPagesOccupied = function(){\n    let cnt = 0;\n    this.programs.forEach(p => cnt += p.pagesCount);\n    return cnt;\n  };\n\n  // Physical memory management\n  function initPhysicalMemory(){\n    physicalMemory.frameCount = config.physicalMemSizeBytes / config.pageSize;\n    physicalMemory.frames = [];\n    for(let i=0; i<physicalMemory.frameCount; i++){\n      physicalMemory.frames.push({processId:null, virtualPage:null, valid:false, loadedAt:0});\n    }\n  }\n  function freePhysicalFrame(frameIndex){\n    if(frameIndex<0 || frameIndex>=physicalMemory.frameCount) return;\n    let frame = physicalMemory.frames[frameIndex];\n    if(frame.processId !== null){\n      // Remove from TLB\n      tlb = tlb.filter(e => !(e.processId===frame.processId && e.virtualPage===frame.virtualPage));\n      // Remove page table mapping from owning process for safety but process page table should be updated separately\n    }\n    frame.processId = null;\n    frame.virtualPage = null;\n    frame.valid = false;\n    frame.loadedAt = 0;\n  }\n  function findFreeFrame(){\n    for(let i=0; i<physicalMemory.frameCount; i++){\n      if(!physicalMemory.frames[i].valid){\n        return i;\n      }\n    }\n    return null;\n  }\n\n  // Replacement Policy: Least Recently Used (LRU) in physical frames\n  function selectVictimFrame(){\n    // Find frame with oldest loadedAt timestamp\n    let oldestTime = Infinity;\n    let victimIndex = null;\n    for(let i=0; i<physicalMemory.frames.length; i++){\n      if(physicalMemory.frames[i].valid && physicalMemory.frames[i].loadedAt < oldestTime){\n        oldestTime = physicalMemory.frames[i].loadedAt;\n        victimIndex = i;\n      }\n    }\n    return victimIndex;\n  }\n\n  // TLB Management - fully associative, LRU replacement\n  function tlbLookup(processId, virtualPage){\n    let now = Date.now();\n    for(let i=0; i<tlb.length; i++){\n      let entry = tlb[i];\n      if(entry.processId === processId && entry.virtualPage === virtualPage){\n        entry.lastUsedTime = now;\n        return entry.frameIndex;\n      }\n    }\n    return null;\n  }\n  function tlbAddEntry(processId, virtualPage, frameIndex){\n    let now = Date.now();\n    // If already in TLB, update usage\n    for(let i=0; i<tlb.length; i++){\n      let entry = tlb[i];\n      if(entry.processId === processId && entry.virtualPage === virtualPage){\n        entry.lastUsedTime = now;\n        return;\n      }\n    }\n    // Add new entry\n    if(tlb.length >= config.tlbSize){\n      // Evict least recently used\n      let lruTime = Infinity;\n      let lruIndex = -1;\n      for(let i=0; i<tlb.length; i++){\n        if(tlb[i].lastUsedTime < lruTime){\n          lruTime = tlb[i].lastUsedTime;\n          lruIndex = i;\n        }\n      }\n      if(lruIndex !== -1){\n        tlb.splice(lruIndex,1);\n      }\n    }\n    tlb.push({processId:processId, virtualPage:virtualPage, frameIndex:frameIndex, lastUsedTime: now});\n  }\n  function tlbClear(){\n    tlb = [];\n  }\n\n  // Memory Access Simulation\n  // Returns: { success, message, physicalAddress, pageFault }\n  function accessMemory(process, virtualAddress, accessMode){\n    stats.memoryAccesses++;\n    let pageSize = config.pageSize;\n    let pageNumber = Math.floor(virtualAddress / pageSize);\n    let offset = virtualAddress % pageSize;\n\n    if(pageNumber < 0 || pageNumber >= process.maxPageCount){\n      return {success:false, message:\"Virtual address out of range.\"};\n    }\n\n    // Check if page is part of loaded program(s)\n    let occupiedPages = process.virtualPagesOccupied();\n    if(pageNumber >= occupiedPages){\n      return {success:false, message:\"Address refers to unused virtual memory (no program loaded here).\"};\n    }\n\n    // Check TLB first\n    let frameIndex = tlbLookup(process.id, pageNumber);\n    if(frameIndex !== null){\n      stats.tlbHits++;\n      // Update page table last referenced:\n      process.pageTable[pageNumber].referencedAt = Date.now();\n      if(accessMode === \"write\") process.pageTable[pageNumber].dirty = true;\n      return {\n        success:true,\n        message:\"TLB hit. Physical frame \" + frameIndex + \", offset \" + offset + \".\",\n        physicalAddress: frameIndex*pageSize + offset,\n        pageFault:false\n      };\n    }\n    stats.tlbMisses++;\n\n    // Check page table\n    let pageEntry = process.pageTable[pageNumber];\n    if(!pageEntry.valid){\n      // Page fault\n      stats.pageFaults++;\n      // Try to load page into physical memory\n      let freeFrame = findFreeFrame();\n      let frameToUse;\n      if(freeFrame !== null){\n        frameToUse = freeFrame;\n      } else {\n        // Need to evict a victim frame\n        let victimFrame = selectVictimFrame();\n        if(victimFrame === null){\n          return {success:false, message:\"No frame available and no victim found. Memory full.\"};\n        }\n        // Remove victim frame from owning process page table and anywhere else\n        let victim = physicalMemory.frames[victimFrame];\n        if(victim.processId !== null){\n          let victimProcess = processes.find(p => p.id === victim.processId);\n          if(victimProcess) {\n            if(victimProcess.pageTable[victim.virtualPage]) {\n              victimProcess.pageTable[victim.virtualPage].valid = false;\n              victimProcess.pageTable[victim.virtualPage].frameIndex = null;\n            }\n          }\n          // Remove from TLB\n          tlb = tlb.filter(e => !(e.processId===victim.processId && e.virtualPage===victim.virtualPage));\n        }\n        frameToUse = victimFrame;\n      }\n      // Load the page into frame\n      physicalMemory.frames[frameToUse].processId = process.id;\n      physicalMemory.frames[frameToUse].virtualPage = pageNumber;\n      physicalMemory.frames[frameToUse].valid = true;\n      physicalMemory.frames[frameToUse].loadedAt = Date.now();\n\n      pageEntry.valid = true;\n      pageEntry.frameIndex = frameToUse;\n      pageEntry.referencedAt = Date.now();\n      pageEntry.dirty = (accessMode === \"write\");\n\n      // Add to TLB\n      tlbAddEntry(process.id, pageNumber, frameToUse);\n\n      return {\n        success:true,\n        message:\"Page fault. Loaded virtual page \" + pageNumber + \" into frame \" + frameToUse + \".\",\n        physicalAddress: frameToUse*pageSize + offset,\n        pageFault:true\n      };\n    } else {\n      // Page is valid in physical memory\n      pageEntry.referencedAt = Date.now();\n      if(accessMode === \"write\") pageEntry.dirty = true;\n      frameIndex = pageEntry.frameIndex;\n      // Add to TLB\n      tlbAddEntry(process.id, pageNumber, frameIndex);\n      return {\n        success:true,\n        message:\"Page found in page table. Physical frame \" + frameIndex + \", offset \" + offset + \".\",\n        physicalAddress: frameIndex*pageSize + offset,\n        pageFault:false\n      };\n    }\n  }\n\n  // UI Elements\n  const pageSizeInput = document.getElementById('pageSizeInput');\n  const virtualMemKBInput = document.getElementById('virtualMemKBInput');\n  const physicalMemKBInput = document.getElementById('physicalMemKBInput');\n  const processCountInput = document.getElementById('processCountInput');\n  const applyConfigBtn = document.getElementById('applyConfigBtn');\n\n  const processSelector = document.getElementById('processSelector');\n  const addProcessBtn = document.getElementById('addProcessBtn');\n  const removeProcessBtn = document.getElementById('removeProcessBtn');\n  const resetAllProcessesBtn = document.getElementById('resetAllProcessesBtn');\n\n  const programNameInput = document.getElementById('programNameInput');\n  const programSizeInput = document.getElementById('programSizeInput');\n  const loadProgramBtn = document.getElementById('loadProgramBtn');\n  const unloadProgramBtn = document.getElementById('unloadProgramBtn');\n\n  const accessAddressInput = document.getElementById('accessAddressInput');\n  const accessMemoryBtn = document.getElementById('accessMemoryBtn');\n  const accessModeSelect = document.getElementById('accessModeSelect');\n\n  const showPageTableBtn = document.getElementById('showPageTableBtn');\n  const showPhysicalMemoryBtn = document.getElementById('showPhysicalMemoryBtn');\n  const showTLBBtn = document.getElementById('showTLBBtn');\n\n  const memoryAccessResult = document.getElementById('memoryAccessResult');\n\n  const tlbSizeInput = document.getElementById('tlbSizeInput');\n  const applyTLBSizeBtn = document.getElementById('applyTLBSizeBtn');\n  const clearTLBBtn = document.getElementById('clearTLBBtn');\n\n  const processManagementDiv = document.getElementById('process-management');\n  const programManagementDiv = document.getElementById('program-management');\n  const memoryAccessDiv = document.getElementById('memory-access');\n  const tlbControlsDiv = document.getElementById('tlb-controls');\n  const statsDiv = document.getElementById('stats');\n  const statsContent = document.getElementById('statsContent');\n  const resetStatsBtn = document.getElementById('resetStatsBtn');\n\n  // Functions for UI Refresh\n  function refreshProcessSelector(){\n    processSelector.innerHTML = '';\n    processes.forEach(p => {\n      let option = document.createElement('option');\n      option.textContent = 'Process ' + p.id + ' (Loaded progs: ' + p.programs.length + ')';\n      option.value = p.id;\n      processSelector.appendChild(option);\n    });\n    if(processes.length > 0){\n      currentProcessId = parseInt(processSelector.value) || processes[0].id;\n      processSelector.value = currentProcessId;\n    } else {\n      currentProcessId = null;\n    }\n  }\n\n  function getCurrentProcess(){\n    if(currentProcessId === null) return null;\n    return processes.find(p => p.id === currentProcessId);\n  }\n\n  function appendStatsLog(msg){\n    statsContent.textContent = msg + \"\\n\" + statsContent.textContent;\n  }\n\n  // Update statistics display\n  function refreshStats(){\n    let lines = [];\n    lines.push(\"Total Memory Accesses: \" + stats.memoryAccesses);\n    lines.push(\"TLB Hits: \" + stats.tlbHits);\n    lines.push(\"TLB Misses: \" + stats.tlbMisses);\n    lines.push(\"Page Faults: \" + stats.pageFaults);\n    lines.push(\"\");\n    let hitRatio = (stats.memoryAccesses>0)?(stats.tlbHits/stats.memoryAccesses*100).toFixed(2) : \"N/A\";\n    lines.push(\"TLB Hit Ratio: \" + hitRatio + \"%\");\n    statsContent.textContent = lines.join('\\n');\n  }\n\n  function checkConfigValidity(){\n    let pSize = parseInt(pageSizeInput.value,10);\n    if(!isPowerOfTwo(pSize) || pSize < 16 || pSize > 1024){\n      alert(\"Page size must be a power of two between 16 and 1024.\");\n      return false;\n    }\n    let vMemKB = parseInt(virtualMemKBInput.value,10);\n    if(vMemKB <4 || vMemKB > 64){\n      alert(\"Virtual memory size must be between 4 KB and 64 KB.\");\n      return false;\n    }\n    let pMemKB = parseInt(physicalMemKBInput.value,10);\n    if(pMemKB <1 || pMemKB > 32){\n      alert(\"Physical memory size must be between 1 KB and 32 KB.\");\n      return false;\n    }\n    let pCount = parseInt(processCountInput.value,10);\n    if(pCount <1 || pCount >5){\n      alert(\"Process count must be between 1 and 5.\");\n      return false;\n    }\n    if(pMemKB >= vMemKB){\n      // Warn but allow\n      if(!confirm(\"Physical memory size is greater or equal to virtual memory size. Do you want to proceed?\")){\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // Initialize system\n  applyConfigBtn.addEventListener('click', function(){\n    if(!checkConfigValidity()) return;\n    config.pageSize = parseInt(pageSizeInput.value,10);\n    config.virtualMemSizeBytes = parseInt(virtualMemKBInput.value,10)*1024;\n    config.physicalMemSizeBytes = parseInt(physicalMemKBInput.value,10)*1024;\n    config.processCount = parseInt(processCountInput.value,10);\n\n    // Reset all state\n    processes = [];\n    for(let i=0; i<config.processCount; i++){\n      processes.push(new Process(i));\n    }\n    initPhysicalMemory();\n    tlbClear();\n    stats = {\n      memoryAccesses: 0,\n      tlbHits: 0,\n      tlbMisses: 0,\n      pageFaults: 0,\n    };\n    currentProcessId = 0;\n\n    refreshProcessSelector();\n\n    // Enable all controls\n    processManagementDiv.style.display = 'block';\n    programManagementDiv.style.display = 'block';\n    memoryAccessDiv.style.display = 'block';\n    tlbControlsDiv.style.display = 'block';\n    statsDiv.style.display = 'block';\n\n    memoryAccessResult.textContent = '';\n    appendStatsLog(\"Initialized system with configuration:\\n\" +\n      \"Page size: \" + config.pageSize + \" bytes\\n\" +\n      \"Virtual memory: \" + (config.virtualMemSizeBytes/1024) + \" KB\\n\" +\n      \"Physical memory: \" + (config.physicalMemSizeBytes/1024) + \" KB\\n\" +\n      \"Processes: \" + config.processCount + \"\\n\" +\n      \"TLB size: \" + config.tlbSize);\n\n    refreshStats();\n    logDebug(\"System initialized.\");\n  });\n\n  processSelector.addEventListener('change', function(){\n    currentProcessId = parseInt(processSelector.value,10);\n  });\n\n  addProcessBtn.addEventListener('click', function(){\n    if(processes.length >= 5){\n      alert(\"Maximum number of processes reached (5).\");\n      return;\n    }\n    let newId = 0;\n    while(processes.find(p => p.id === newId)){\n      newId++;\n    }\n    let newProc = new Process(newId);\n    processes.push(newProc);\n    refreshProcessSelector();\n    appendStatsLog(\"Added process ID \" + newId + \".\");\n  });\n\n  removeProcessBtn.addEventListener('click', function(){\n    if(processes.length <= 1){\n      alert(\"At least one process must remain.\");\n      return;\n    }\n    let proc = getCurrentProcess();\n    if(!proc){\n      alert(\"No process selected.\");\n      return;\n    }\n    // Free physical frames used by this process\n    proc.pageTable.forEach(entry => {\n      if(entry.frameIndex !== null){\n        freePhysicalFrame(entry.frameIndex);\n      }\n    });\n    // Remove from TLB\n    tlb = tlb.filter(e => e.processId !== proc.id);\n    // Remove process\n    processes = processes.filter(p => p.id !== proc.id);\n    // Change current process to first available\n    if(processes.length > 0) currentProcessId = processes[0].id;\n    else currentProcessId = null;\n    refreshProcessSelector();\n    appendStatsLog(\"Removed selected process ID \" + proc.id + \" and freed its pages.\");\n  });\n\n  resetAllProcessesBtn.addEventListener('click', function(){\n    if(!confirm(\"This will clear all programs and memory pages of ALL processes. Continue?\")) return;\n    processes.forEach(proc => {\n      proc.resetPages();\n    });\n    initPhysicalMemory();\n    tlbClear();\n    appendStatsLog(\"Reset all processes and cleared physical memory and TLB.\");\n  });\n\n  loadProgramBtn.addEventListener('click', function(){\n    let proc = getCurrentProcess();\n    if(!proc){\n      alert(\"No process selected.\");\n      return;\n    }\n    let name = programNameInput.value.trim();\n    if(!name){\n      alert(\"Please enter a program name.\");\n      return;\n    }\n    let size = parseInt(programSizeInput.value,10);\n    if(isNaN(size) || size<1){\n      alert(\"Please enter a valid program size (bytes).\");\n      return;\n    }\n    let result = proc.loadProgram(name, size);\n    if(result.success){\n      appendStatsLog(\"Loaded program '\" + name + \"' (\" + size + \" bytes, \" + result.pages + \" pages) into process \" + proc.id + \".\");\n    } else {\n      alert(\"Failed to load program: \"+result.error);\n    }\n  });\n\n  unloadProgramBtn.addEventListener('click', function(){\n    let proc = getCurrentProcess();\n    if(!proc){\n      alert(\"No process selected.\");\n      return;\n    }\n    let name = programNameInput.value.trim();\n    if(!name){\n      alert(\"Please enter a program name to unload.\");\n      return;\n    }\n    let result = proc.unloadProgram(name);\n    if(result.success){\n      appendStatsLog(\"Unloaded program '\" + name + \"' from process \" + proc.id + \".\");\n    } else {\n      alert(\"Failed to unload program: \"+result.error);\n    }\n  });\n\n  accessMemoryBtn.addEventListener('click', function(){\n    let proc = getCurrentProcess();\n    if(!proc){\n      alert(\"No process selected.\");\n      return;\n    }\n    let vAddr = parseInt(accessAddressInput.value,10);\n    if(isNaN(vAddr) || vAddr < 0){\n      alert(\"Please enter a valid virtual address (non-negative integer).\");\n      return;\n    }\n    if(vAddr >= config.virtualMemSizeBytes){\n      alert(\"Virtual address exceeds process virtual memory size (\"+config.virtualMemSizeBytes+\" bytes).\");\n      return;\n    }\n    let accessMode = accessModeSelect.value;\n    let res = accessMemory(proc, vAddr, accessMode);\n    if(res.success){\n      let info = \"Success: \" + res.message + \"\\n\";\n      info += \"Virtual Address = \" + vAddr + \"\\n\";\n      info += \"Physical Address = \" + res.physicalAddress + \"\\n\";\n      info += \"Page Fault = \" + (res.pageFault ? \"Yes\" : \"No\");\n      memoryAccessResult.textContent = info;\n      appendStatsLog(\"Process \"+proc.id+\" memory access at VA \"+vAddr+\" (\"+accessMode+\") - \" + (res.pageFault ? \"PAGE FAULT\" : \"No page fault.\"));\n      refreshStats();\n    } else {\n      memoryAccessResult.textContent = \"Error: \" + res.message;\n    }\n  });\n\n  showPageTableBtn.addEventListener('click', function(){\n    let proc = getCurrentProcess();\n    if(!proc){\n      alert(\"No process selected.\");\n      return;\n    }\n    let lines = [];\n    lines.push(\"Page Table of Process \" + proc.id + \":\");\n    lines.push(\"Page | Valid | Frame | Referenced At (timestamp) | Dirty | Program Content\");\n    for(let i=0; i<proc.pageTable.length; i++){\n      let e = proc.pageTable[i];\n      if(proc.programs.length>0) {\n        // Show only pages used by any program to reduce flood\n        let usedPages = proc.virtualPagesOccupied();\n        if(i >= usedPages) continue;\n      }\n      let dt = e.referencedAt ? new Date(e.referencedAt).toLocaleTimeString() : \"-\";\n      // Program content: check which program contains this page\n      let progName = '-';\n      let pageStart = 0;\n      for(let pgm of proc.programs){\n        let pageEnd = pageStart + pgm.pagesCount;\n        if(i >= pageStart && i < pageEnd){\n          progName = pgm.name;\n          break;\n        }\n        pageStart = pageEnd;\n      }\n      lines.push(i.toString().padEnd(4) + \" | \" + (e.valid?\"Y\":\"N\") + \"     | \" +\n        (e.frameIndex!==null?e.frameIndex:\"-\") + \"     | \" + dt.padEnd(23) + \" | \" + (e.dirty?\"Y\":\"N\") + \"     | \" + progName);\n    }\n    memoryAccessResult.textContent = lines.join('\\n');\n  });\n\n  showPhysicalMemoryBtn.addEventListener('click', function(){\n    let lines = [];\n    lines.push(\"Physical Memory Frames (\"+physicalMemory.frameCount+\" frames):\");\n    lines.push(\"Frame | Valid | Process ID | Virtual Page | Loaded At\");\n    physicalMemory.frames.forEach((f,i) => {\n      let loadedTime = f.loadedAt ? new Date(f.loadedAt).toLocaleTimeString() : \"-\";\n      lines.push(i.toString().padEnd(5) + \" | \" + (f.valid?\"Y\":\"N\") + \"     | \" + (f.processId!==null?f.processId:\"-\") + \"          | \" + (f.virtualPage!==null?f.virtualPage:\"-\")+\"           | \" + loadedTime);\n    });\n    memoryAccessResult.textContent = lines.join('\\n');\n  });\n\n  showTLBBtn.addEventListener('click', function(){\n    let lines = [];\n    lines.push(\"TLB Entries (\"+tlb.length+\"/\"+config.tlbSize+\"): \");\n    lines.push(\"Index | Process ID | Virtual Page | Frame | Last Used\");\n    tlb.forEach((e,i) => {\n      let usedTime = e.lastUsedTime ? new Date(e.lastUsedTime).toLocaleTimeString() : \"-\";\n      lines.push(i.toString().padEnd(5) + \" | \" + e.processId + \"          | \" + e.virtualPage + \"           | \" + e.frameIndex + \"     | \" + usedTime);\n    });\n    if(tlb.length === 0) lines.push(\"(empty)\");\n    memoryAccessResult.textContent = lines.join('\\n');\n  });\n\n  applyTLBSizeBtn.addEventListener('click', function(){\n    let sz = parseInt(tlbSizeInput.value,10);\n    if(isNaN(sz) || sz < 1 || sz>16){\n      alert(\"TLB size must be between 1 and 16.\");\n      return;\n    }\n    config.tlbSize = sz;\n    // Trim TLB if current size is bigger\n    if(tlb.length > sz){\n      tlb.sort((a,b) => b.lastUsedTime - a.lastUsedTime); // keep most recently used first\n      tlb = tlb.slice(0, sz);\n    }\n    appendStatsLog(\"Applied TLB size: \" + sz);\n    refreshStats();\n  });\n\n  clearTLBBtn.addEventListener('click', function(){\n    tlbClear();\n    appendStatsLog(\"TLB cleared.\");\n  });\n\n  resetStatsBtn.addEventListener('click', function(){\n    stats.memoryAccesses = 0;\n    stats.tlbHits = 0;\n    stats.tlbMisses = 0;\n    stats.pageFaults = 0;\n    appendStatsLog(\"Statistics reset.\");\n    refreshStats();\n  });\n\n  // Initialization: disable all except config initially\n  processManagementDiv.style.display = 'none';\n  programManagementDiv.style.display = 'none';\n  memoryAccessDiv.style.display = 'none';\n  tlbControlsDiv.style.display = 'none';\n  statsDiv.style.display = 'none';\n\n  logDebug(\"Welcome to the Virtual Memory Interactive Simulator.\\n\" +\n           \"Start by configuring the system above.\");\n\n})();\n</script>\n\n</body>\n</html>"
