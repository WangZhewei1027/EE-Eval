    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Load Balancing Interactive Simulator</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    /* Minimal visual styling only to ensure readability; otherwise plain */\n    body { font-family: sans-serif; color: black; background: white; margin: 12px; }\n    h1 { font-size: 18px; margin: 6px 0; }\n    .row { display: flex; gap: 12px; flex-wrap: wrap; }\n    .col { flex: 1 1 320px; min-width: 240px; }\n    label { display: block; margin-top: 6px; }\n    input[type=\"number\"], input[type=\"text\"], select, textarea { width: 100%; box-sizing: border-box; }\n    button { margin: 4px 2px; }\n    table { border-collapse: collapse; width: 100%; }\n    table, td, th { border: 1px solid #ddd; }\n    th, td { padding: 6px; text-align: left; font-size: 13px; }\n    textarea { height: 160px; font-family: monospace; font-size: 12px; }\n    .small { font-size: 12px; }\n    .tiny { font-size: 11px; }\n    details { margin-top: 6px; }\n    pre { white-space: pre-wrap; font-family: monospace; font-size: 12px; }\n    /* visual minimalism: no colors, no fancy styling */\n  </style>\n</head>\n<body>\n  <h1>Load Balancing Interactive Simulator</h1>\n\n  <div class=\"row\">\n    <div class=\"col\">\n      <h2>Controller</h2>\n      <label>Algorithm\n        <select id=\"algo\">\n          <option value=\"round-robin\">Round Robin</option>\n          <option value=\"weighted-round-robin\">Weighted Round Robin</option>\n          <option value=\"least-connections\">Least Connections</option>\n          <option value=\"random\">Random</option>\n          <option value=\"ip-hash\">IP Hash (Session Affinity)</option>\n        </select>\n      </label>\n\n      <label>Session affinity\n        <select id=\"affinity\">\n          <option value=\"none\">None</option>\n          <option value=\"ip\">Client IP</option>\n          <option value=\"cookie\">Cookie (simulated)</option>\n        </select>\n      </label>\n\n      <label>Request arrival rate (requests / sec)\n        <input id=\"rate\" type=\"range\" min=\"0\" max=\"200\" step=\"1\" value=\"10\">\n        <div class=\"tiny\"><span id=\"rateVal\">10</span> req/s</div>\n      </label>\n\n      <label>Per-request timeout (ms)\n        <input id=\"timeout\" type=\"number\" value=\"5000\" min=\"100\" step=\"100\">\n      </label>\n\n      <label>Max retries\n        <input id=\"retries\" type=\"number\" value=\"1\" min=\"0\" step=\"1\">\n      </label>\n\n      <label>Queue policy\n        <select id=\"queuePolicy\">\n          <option value=\"global\">Global queue (shared)</option>\n          <option value=\"per-server\">Per-server queue</option>\n          <option value=\"drop-tail\">Drop (tail) when full</option>\n          <option value=\"drop-oldest\">Drop oldest when full</option>\n        </select>\n      </label>\n\n      <label>Global queue size (0 = unlimited)\n        <input id=\"globalQueueSize\" type=\"number\" value=\"50\" min=\"0\" step=\"1\">\n      </label>\n\n      <label>Auto-start\n        <input id=\"autostart\" type=\"checkbox\" checked>\n      </label>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"startBtn\">Start</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"resetBtn\">Reset</button>\n        <button id=\"drainAllBtn\">Drain All Servers</button>\n      </div>\n\n      <details open>\n        <summary>Advanced controls</summary>\n\n        <label>Simulated time resolution (ms per tick)\n          <input id=\"tickMs\" type=\"number\" value=\"200\" min=\"10\" step=\"10\">\n        </label>\n\n        <label>Retry backoff base (ms)\n          <input id=\"backoffBase\" type=\"number\" value=\"200\" min=\"0\" step=\"50\">\n        </label>\n\n        <label>Health check interval (ticks)\n          <input id=\"healthInterval\" type=\"number\" value=\"10\" min=\"1\" step=\"1\">\n        </label>\n\n        <label>Enable automated health checks\n          <input id=\"healthChecksEnabled\" type=\"checkbox\" checked>\n        </label>\n\n        <label>Log verbosity\n          <select id=\"logVerbosity\">\n            <option value=\"debug\">Debug (all)</option>\n            <option value=\"info\" selected>Info</option>\n            <option value=\"warn\">Warn+Error</option>\n            <option value=\"error\">Error only</option>\n          </select>\n        </label>\n\n        <div style=\"margin-top:6px;\">\n          <button id=\"exportBtn\">Export configuration</button>\n          <button id=\"importBtn\">Import configuration</button>\n          <input id=\"importArea\" type=\"file\" style=\"display:none\">\n        </div>\n      </details>\n\n    </div>\n\n    <div class=\"col\">\n      <h2>Servers</h2>\n      <div>\n        <button id=\"addServerBtn\">Add Server</button>\n        <button id=\"resetServersBtn\">Reset Servers</button>\n      </div>\n\n      <table id=\"serversTable\">\n        <thead>\n          <tr>\n            <th>ID</th><th>Up?</th><th>Draining?</th><th>Weight</th><th>Capacity</th><th>Base ms</th><th>Jitter ms</th><th>Fail %</th><th>Queue size</th><th>Actions</th>\n          </tr>\n        </thead>\n        <tbody>\n        </tbody>\n      </table>\n\n      <details>\n        <summary>Preset server topologies</summary>\n        <button id=\"presetSimple\">3 identical servers</button>\n        <button id=\"presetWeighted\">2 small + 1 large (weights)</button>\n        <button id=\"presetHetero\">Heterogeneous latencies</button>\n      </details>\n    </div>\n\n    <div class=\"col\">\n      <h2>Generation & Clients</h2>\n\n      <label>Client IP pool size\n        <input id=\"clientPool\" type=\"number\" value=\"20\" min=\"1\" step=\"1\">\n      </label>\n\n      <label>Payload size (simulated ms)\n        <input id=\"payloadMs\" type=\"number\" value=\"0\" min=\"0\" step=\"10\">\n      </label>\n\n      <label>Burst generator: count\n        <input id=\"burstCount\" type=\"number\" value=\"10\" min=\"1\" step=\"1\">\n      </label>\n\n      <div style=\"margin-top:6px;\">\n        <button id=\"sendOneBtn\">Send 1 Request</button>\n        <button id=\"sendBurstBtn\">Send Burst</button>\n        <button id=\"clearQueueBtn\">Clear Queues</button>\n      </div>\n\n      <details>\n        <summary>Client behavior</summary>\n        <label>Sticky cookie TTL (ticks)\n          <input id=\"cookieTTL\" type=\"number\" value=\"50\" min=\"0\" step=\"1\">\n        </label>\n\n        <label>Client retry behavior (ms)\n          <input id=\"clientRetryAfter\" type=\"number\" value=\"1000\" min=\"0\" step=\"100\">\n        </label>\n\n      </details>\n    </div>\n  </div>\n\n  <hr>\n\n  <div class=\"row\">\n    <div class=\"col\">\n      <h2>Statistics</h2>\n      <div id=\"stats\">\n        <div>Total requests sent: <span id=\"statSent\">0</span></div>\n        <div>Completed: <span id=\"statCompleted\">0</span></div>\n        <div>Errors: <span id=\"statErrors\">0</span></div>\n        <div>Avg latency ms: <span id=\"statAvg\">0</span></div>\n        <div>Throughput req/s (window): <span id=\"statThroughput\">0</span></div>\n        <div>Queue length (global): <span id=\"statQueue\">0</span></div>\n      </div>\n\n      <details open>\n        <summary>Per-server summary</summary>\n        <div id=\"serverSummary\" class=\"small\"></div>\n      </details>\n    </div>\n\n    <div class=\"col\">\n      <h2>Live Log</h2>\n      <div>\n        <label>Filter by request id / server id / text\n          <input id=\"logFilter\" type=\"text\">\n        </label>\n        <label>Auto-scroll\n          <input id=\"autoScroll\" type=\"checkbox\" checked>\n        </label>\n      </div>\n      <textarea id=\"log\" readonly></textarea>\n      <div style=\"margin-top:6px;\">\n        <button id=\"clearLog\">Clear Log</button>\n        <button id=\"exportLog\">Export Log</button>\n      </div>\n    </div>\n\n    <div class=\"col\">\n      <h2>Inspect Requests</h2>\n      <label>Find request id\n        <input id=\"findReq\" type=\"text\">\n      </label>\n      <button id=\"findReqBtn\">Find</button>\n      <pre id=\"reqDetail\">Select a request from the log to inspect details. You can also find by id.</pre>\n    </div>\n  </div>\n\n  <script>\n    // Load Balancer Simulator - Plain, interactive, feature rich\n    (function(){\n      // Utility\n      function uid(prefix) {\n        return (prefix || 'id') + '-' + Math.random().toString(36).slice(2,9);\n      }\n      function nowMs() { return Date.now(); }\n\n      // State\n      let state = {\n        servers: [],\n        nextServerId: 1,\n        running: false,\n        tickInterval: null,\n        tickMs: 200,\n        time: 0,\n        requestCounter: 0,\n        requests: {}, // id -> req object\n        completed: 0,\n        errors: 0,\n        totalLatency: 0,\n        arrivalAccumulator: 0,\n        algoState: { rrIndex: 0, wrrCounters: [] },\n        affinityMap: {}, // key -> serverId, with expiry ticks if cookie\n        logs: [],\n        logLimit: 2000,\n        globalQueue: [],\n      };\n\n      // DOM refs\n      const algoEl = document.getElementById('algo');\n      const affinityEl = document.getElementById('affinity');\n      const rateEl = document.getElementById('rate');\n      const rateValEl = document.getElementById('rateVal');\n      const startBtn = document.getElementById('startBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const serversTableBody = document.querySelector('#serversTable tbody');\n      const addServerBtn = document.getElementById('addServerBtn');\n      const resetServersBtn = document.getElementById('resetServersBtn');\n      const presetSimple = document.getElementById('presetSimple');\n      const presetWeighted = document.getElementById('presetWeighted');\n      const presetHetero = document.getElementById('presetHetero');\n      const startAutostart = document.getElementById('autostart');\n      const tickMsEl = document.getElementById('tickMs');\n      const timeoutEl = document.getElementById('timeout');\n      const retriesEl = document.getElementById('retries');\n      const queuePolicyEl = document.getElementById('queuePolicy');\n      const globalQueueSizeEl = document.getElementById('globalQueueSize');\n      const sendOneBtn = document.getElementById('sendOneBtn');\n      const sendBurstBtn = document.getElementById('sendBurstBtn');\n      const burstCountEl = document.getElementById('burstCount');\n      const clientPoolEl = document.getElementById('clientPool');\n      const payloadMsEl = document.getElementById('payloadMs');\n      const clearQueueBtn = document.getElementById('clearQueueBtn');\n      const rateSlider = rateEl;\n      const statSentEl = document.getElementById('statSent');\n      const statCompletedEl = document.getElementById('statCompleted');\n      const statErrorsEl = document.getElementById('statErrors');\n      const statAvgEl = document.getElementById('statAvg');\n      const statThroughputEl = document.getElementById('statThroughput');\n      const statQueueEl = document.getElementById('statQueue');\n      const serverSummaryEl = document.getElementById('serverSummary');\n      const logArea = document.getElementById('log');\n      const clearLogBtn = document.getElementById('clearLog');\n      const exportLogBtn = document.getElementById('exportLog');\n      const logFilterEl = document.getElementById('logFilter');\n      const autoScrollEl = document.getElementById('autoScroll');\n      const findReqEl = document.getElementById('findReq');\n      const findReqBtn = document.getElementById('findReqBtn');\n      const reqDetailPre = document.getElementById('reqDetail');\n      const healthChecksEnabledEl = document.getElementById('healthChecksEnabled');\n      const healthIntervalEl = document.getElementById('healthInterval');\n      const backoffBaseEl = document.getElementById('backoffBase');\n      const cookieTTLEl = document.getElementById('cookieTTL');\n      const clientRetryAfterEl = document.getElementById('clientRetryAfter');\n      const importBtn = document.getElementById('importBtn');\n      const importArea = document.getElementById('importArea');\n      const exportBtn = document.getElementById('exportBtn');\n      const drainAllBtn = document.getElementById('drainAllBtn');\n      const clearLogTextBtn = clearLogBtn;\n\n      // Logging\n      const verbosityLevels = { debug:1, info:2, warn:3, error:4 };\n      function log(level, text, meta) {\n        const verbosity = document.getElementById('logVerbosity').value;\n        if (verbosityLevels[level] < verbosityLevels[verbosity]) return;\n        const ts = '[' + Math.floor(state.time) + 't]';\n        const entry = ts + ' ' + level.toUpperCase() + ': ' + text + (meta? (' | ' + JSON.stringify(meta)) : '');\n        state.logs.push({ time: state.time, level, text, meta, raw: entry });\n        if (state.logs.length > state.logLimit) state.logs.shift();\n        renderLogs();\n      }\n\n      function renderLogs() {\n        const filter = (logFilterEl.value || '').trim();\n        let text = '';\n        for (let e of state.logs) {\n          if (!filter || e.raw.indexOf(filter) !== -1 || JSON.stringify(e.meta || '').indexOf(filter) !== -1) {\n            text += e.raw + \"\\n\";\n          }\n        }\n        logArea.value = text;\n        if (autoScrollEl.checked) logArea.scrollTop = logArea.scrollHeight;\n      }\n\n      // Servers management\n      function addServer(config) {\n        const id = state.nextServerId++;\n        const server = {\n          id: id,\n          name: 'srv' + id,\n          up: true,\n          draining: false,\n          weight: config && config.weight || 1,\n          capacity: config && config.capacity || 5, // max concurrent\n          baseMs: config && config.baseMs || 100, // base processing time\n          jitterMs: config && config.jitterMs || 50, // added random\n          failRate: config && config.failRate || 0, // percent\n          queueSize: config && config.queueSize || 10, // per-server queue size\n          current: 0, // current running\n          processed: 0,\n          errors: 0,\n          totalTime: 0,\n          queue: [], // per-server queue if used\n        };\n        state.servers.push(server);\n        log('info', 'Added server ' + server.name, server);\n        rebuildServerTable();\n      }\n\n      function removeServer(id) {\n        const idx = state.servers.findIndex(s=>s.id===id);\n        if (idx>=0) {\n          const srv = state.servers.splice(idx,1)[0];\n          log('info','Removed server '+srv.name, srv);\n          rebuildServerTable();\n        }\n      }\n\n      function resetServers() {\n        state.servers = [];\n        state.nextServerId = 1;\n        state.globalQueue = [];\n        state.requests = {};\n        state.requestCounter = 0;\n        state.aggCompleted = 0;\n        rebuildServerTable();\n        log('info','Reset all servers');\n      }\n\n      // Build server table UI\n      function rebuildServerTable() {\n        serversTableBody.innerHTML = '';\n        for (let s of state.servers) {\n          const tr = document.createElement('tr');\n\n          const idCell = document.createElement('td'); idCell.textContent = s.name; tr.appendChild(idCell);\n\n          const upCell = document.createElement('td'); \n          const upChk = document.createElement('input'); upChk.type='checkbox'; upChk.checked = s.up;\n          upChk.onchange = function(){ s.up = upChk.checked; log('info','Server '+s.name+' set up='+(s.up)); renderSummary(); };\n          upCell.appendChild(upChk); tr.appendChild(upCell);\n\n          const drainCell = document.createElement('td');\n          const drainChk = document.createElement('input'); drainChk.type='checkbox'; drainChk.checked = s.draining;\n          drainChk.onchange = function(){ s.draining = drainChk.checked; log('info','Server '+s.name+' draining='+(s.draining)); renderSummary(); };\n          drainCell.appendChild(drainChk); tr.appendChild(drainCell);\n\n          const weightCell = document.createElement('td');\n          const weightInput = document.createElement('input'); weightInput.type='number'; weightInput.value = s.weight; weightInput.min = 1; weightInput.onchange = function(){ s.weight = Math.max(1, parseInt(weightInput.value)||1); log('info','Server '+s.name+' weight set to '+s.weight); };\n          weightCell.appendChild(weightInput); tr.appendChild(weightCell);\n\n          const capCell = document.createElement('td');\n          const capInput = document.createElement('input'); capInput.type='number'; capInput.value = s.capacity; capInput.min = 1; capInput.onchange = function(){ s.capacity = Math.max(1, parseInt(capInput.value)||1); log('info','Server '+s.name+' capacity set to '+s.capacity); };\n          capCell.appendChild(capInput); tr.appendChild(capCell);\n\n          const baseCell = document.createElement('td');\n          const baseInput = document.createElement('input'); baseInput.type='number'; baseInput.value = s.baseMs; baseInput.min = 0; baseInput.onchange = function(){ s.baseMs = Math.max(0, parseInt(baseInput.value)||0); };\n          baseCell.appendChild(baseInput); tr.appendChild(baseCell);\n\n          const jitterCell = document.createElement('td');\n          const jitterInput = document.createElement('input'); jitterInput.type='number'; jitterInput.value = s.jitterMs; jitterInput.min = 0; jitterInput.onchange = function(){ s.jitterMs = Math.max(0, parseInt(jitterInput.value)||0); };\n          jitterCell.appendChild(jitterInput); tr.appendChild(jitterCell);\n\n          const failCell = document.createElement('td');\n          const failInput = document.createElement('input'); failInput.type='number'; failInput.value = s.failRate; failInput.min = 0; failInput.max = 100; failInput.onchange = function(){ s.failRate = Math.min(100, Math.max(0, parseFloat(failInput.value)||0)); };\n          failCell.appendChild(failInput); tr.appendChild(failCell);\n\n          const qCell = document.createElement('td');\n          const qInput = document.createElement('input'); qInput.type='number'; qInput.value = s.queueSize; qInput.min = 0; qInput.onchange = function(){ s.queueSize = Math.max(0, parseInt(qInput.value)||0); };\n          qCell.appendChild(qInput); tr.appendChild(qCell);\n\n          const actionCell = document.createElement('td');\n          const remBtn = document.createElement('button'); remBtn.textContent = 'Remove';\n          remBtn.onclick = function(){ removeServer(s.id); };\n          const toxBtn = document.createElement('button'); toxBtn.textContent = 'Toggle Fail';\n          toxBtn.onclick = function(){ s.up = !s.up; rebuildServerTable(); log('warn','Toggled server '+s.name+' up=' + s.up); };\n          const drainBtn = document.createElement('button'); drainBtn.textContent = 'Drain';\n          drainBtn.onclick = function(){ s.draining = true; rebuildServerTable(); log('info','Server '+s.name+' set to draining'); };\n          actionCell.appendChild(remBtn); actionCell.appendChild(toxBtn); actionCell.appendChild(drainBtn); tr.appendChild(actionCell);\n\n          serversTableBody.appendChild(tr);\n        }\n        renderSummary();\n      }\n\n      // Preset topologies\n      presetSimple.onclick = function(){ resetServers(); addServer({weight:1,capacity:5,baseMs:100,jitterMs:40}); addServer({weight:1,capacity:5,baseMs:100,jitterMs:40}); addServer({weight:1,capacity:5,baseMs:100,jitterMs:40}); };\n      presetWeighted.onclick = function(){ resetServers(); addServer({weight:1,capacity:3,baseMs:120,jitterMs:50}); addServer({weight:1,capacity:3,baseMs:120,jitterMs:50}); addServer({weight:4,capacity:12,baseMs:80,jitterMs:30}); };\n      presetHetero.onclick = function(){ resetServers(); addServer({weight:1,capacity:4,baseMs:60,jitterMs:20}); addServer({weight:1,capacity:4,baseMs:150,jitterMs:100}); addServer({weight:2,capacity:6,baseMs:90,jitterMs:60}); };\n\n      // Core: Request lifecycle\n      function makeClientIP() {\n        const pool = Math.max(1, parseInt(clientPoolEl.value)||1);\n        const n = Math.floor(Math.random()*pool)+1;\n        return '10.0.0.'+n;\n      }\n\n      function enqueueToServerQueue(server, req) {\n        if (server.queueSize>0 && server.queue.length >= server.queueSize) {\n          const policy = queuePolicyEl.value;\n          if (policy === 'drop-tail') {\n            // drop this req\n            log('warn','Server '+server.name+' queue full - drop tail -> request dropped', req.id);\n            return false;\n          } else if (policy === 'drop-oldest') {\n            // drop oldest\n            const removed = server.queue.shift();\n            log('warn','Dropped oldest from '+server.name+' queue', removed.id);\n            server.queue.push(req);\n            return true;\n          } else {\n            // default: reject\n            log('warn','Server '+server.name+' queue full - reject', req.id);\n            return false;\n          }\n        } else {\n          server.queue.push(req);\n          return true;\n        }\n      }\n\n      function enqueueGlobal(req) {\n        const qsz = parseInt(globalQueueSizeEl.value)||0;\n        const policy = queuePolicyEl.value;\n        if (qsz>0 && state.globalQueue.length >= qsz) {\n          if (policy === 'drop-tail') {\n            log('warn','Global queue full - drop tail for req '+req.id);\n            return false;\n          } else if (policy === 'drop-oldest') {\n            const removed = state.globalQueue.shift();\n            log('warn','Dropped oldest from global queue: '+removed.id);\n            state.globalQueue.push(req);\n            return true;\n          } else {\n            log('warn','Global queue full - reject req '+req.id);\n            return false;\n          }\n        } else {\n          state.globalQueue.push(req);\n          return true;\n        }\n      }\n\n      function selectServer(req) {\n        // selection depends on algorithm and server state\n        const algo = algoEl.value;\n        const affinity = affinityEl.value;\n        // session affinity check\n        if (affinity !== 'none') {\n          let key;\n          if (affinity === 'ip') key = req.clientIP;\n          else if (affinity === 'cookie') key = req.cookie || req.clientIP; // cookie simulated\n          if (key && state.affinityMap[key]) {\n            const mapped = state.affinityMap[key];\n            // check if mapping expired (cookie TTL)\n            if (!mapped.expiry || mapped.expiry > state.time) {\n              const server = state.servers.find(s => s.id === mapped.serverId && s.up);\n              if (server) {\n                return {server, reason: 'affinity'};\n              }\n            } else {\n              delete state.affinityMap[key];\n            }\n          }\n        }\n\n        // create candidate list of up & non-draining servers (draining can finish but shouldn't accept new)\n        const candidates = state.servers.filter(s => s.up && !s.draining);\n        if (candidates.length === 0) {\n          // maybe allow draining servers if no other choice\n          const drainCandidates = state.servers.filter(s => s.up);\n          if (drainCandidates.length === 0) return null;\n          candidates.push(...drainCandidates);\n        }\n\n        if (algo === 'round-robin') {\n          let i = state.algoState.rrIndex % candidates.length;\n          state.algoState.rrIndex = (state.algoState.rrIndex + 1) % candidates.length;\n          return {server: candidates[i], reason:'rr'};\n        }\n\n        if (algo === 'weighted-round-robin') {\n          // simple implementation: expand weighted list\n          const pool = [];\n          for (let s of candidates) {\n            const w = Math.max(1, Math.floor(s.weight));\n            for (let i=0;i<w;i++) pool.push(s);\n          }\n          if (pool.length === 0) return null;\n          state.algoState.wrrCounters = pool; // store for debugging\n          const pick = pool[Math.floor(Math.random()*pool.length)];\n          return {server: pick, reason:'wrr'};\n        }\n\n        if (algo === 'least-connections') {\n          let best = null;\n          for (let s of candidates) {\n            if (!best || s.current < best.current) best = s;\n          }\n          return {server: best, reason:'leastconn'};\n        }\n\n        if (algo === 'random') {\n          const pick = candidates[Math.floor(Math.random()*candidates.length)];\n          return {server: pick, reason:'random'};\n        }\n\n        if (algo === 'ip-hash') {\n          // simple hash by IP string\n          const ip = req.clientIP || ('client'+Math.floor(Math.random()*100000));\n          let h = 0;\n          for (let i=0;i<ip.length;i++) h = ((h<<5)-h) + ip.charCodeAt(i);\n          h = Math.abs(h);\n          const idx = h % candidates.length;\n          return {server: candidates[idx], reason:'ip-hash'};\n        }\n\n        return null;\n      }\n\n      function assignRequest(req) {\n        const sel = selectServer(req);\n        if (!sel) {\n          log('warn','No available server for request '+req.id, req);\n          // enqueue globally or fail\n          if (queuePolicyEl.value === 'global' || queuePolicyEl.value === 'drop-tail' || queuePolicyEl.value === 'drop-oldest') {\n            if (enqueueGlobal(req)) {\n              log('debug','Request '+req.id+' enqueued globally');\n              return true;\n            } else {\n              failRequest(req, 'No server and queue rejected');\n              return false;\n            }\n          } else {\n            failRequest(req, 'No server available');\n            return false;\n          }\n        }\n\n        const server = sel.server;\n        // if server at capacity -> queue on server or global\n        if (server.current >= server.capacity) {\n          if (queuePolicyEl.value === 'per-server') {\n            if (enqueueToServerQueue(server, req)) {\n              log('debug','Request '+req.id+' queued on server '+server.name);\n              return true;\n            } else {\n              failRequest(req, 'Server queue rejected');\n              return false;\n            }\n          } else if (queuePolicyEl.value === 'global') {\n            if (enqueueGlobal(req)) {\n              log('debug','Request '+req.id+' enqueued globally');\n              return true;\n            } else {\n              failRequest(req, 'Global queue rejected');\n              return false;\n            }\n          } else {\n            // drop or reject\n            if (enqueueGlobal(req)) {\n              return true;\n            } else {\n              failRequest(req, 'All queues full');\n              return false;\n            }\n          }\n        }\n\n        // Accept on server\n        server.current += 1;\n        server.processed += 1;\n        req.assignedTo = server.id;\n        req.attempts += 1;\n        req.assignTime = state.time;\n        req.started = true;\n        // determine processing time\n        const base = server.baseMs + (parseInt(payloadMsEl.value)||0);\n        const jitter = Math.floor(Math.random()*(server.jitterMs+1));\n        const procMs = base + jitter;\n        // store remaining ticks\n        req.remainingMs = procMs;\n        req.deadline = state.time + (parseInt(timeoutEl.value)||5000)/state.tickMs; // in ticks\n        req.serverName = server.name;\n        // set affinity mapping if configured\n        const aff = affinityEl.value;\n        if (aff === 'cookie' || aff === 'ip') {\n          const key = aff === 'cookie' ? (req.cookie || req.clientIP) : req.clientIP;\n          if (key) {\n            const ttl = parseInt(cookieTTLEl.value) || 0;\n            state.affinityMap[key] = { serverId: server.id, expiry: ttl>0 ? state.time + ttl : null };\n          }\n        }\n        log('info','Assigned request '+req.id+' to '+server.name+' ('+sel.reason+')', {reqId:req.id, server:server.name, procMs});\n        return true;\n      }\n\n      function failRequest(req, reason) {\n        req.failed = true;\n        req.failReason = reason;\n        state.errors += 1;\n        log('error','Request '+req.id+' failed: '+reason, req);\n        delete state.requests[req.id];\n      }\n\n      function completeRequest(req, success, server) {\n        state.completed += 1;\n        server.current = Math.max(0, server.current - 1);\n        server.totalTime += (req.originalMs || req.remainingMsActual || 0);\n        if (!success) server.errors += 1;\n        if (success) {\n          state.totalLatency += req.originalMs || req.remainingMsActual || 0;\n        }\n        // mark request finished\n        req.finished = true;\n        req.finishTime = state.time;\n        if (success) log('info','Completed req '+req.id+' on '+server.name+' in '+(req.originalMs||req.remainingMsActual)+'ms', req);\n        else log('warn','Request '+req.id+' failed on '+server.name, req);\n        delete state.requests[req.id];\n\n        // If per-server queue has waiting requests, pop next\n        if (server.queue && server.queue.length>0) {\n          const next = server.queue.shift();\n          assignRequest(next);\n        }\n      }\n\n      // Tick: simulation step\n      function tick() {\n        state.time += 1;\n        // health checks\n        if (healthChecksEnabledEl.checked && state.time % Math.max(1, parseInt(healthIntervalEl.value)||1) === 0) {\n          for (let s of state.servers) {\n            // small probabilistic recovery / fail changes according to failRate\n            if (!s.up) {\n              // random chance to recover\n              if (Math.random() < 0.05) { s.up = true; log('info','Health check: '+s.name+' recovered'); }\n            } else {\n              // if server has failRate > 0 then possibly fail\n              if (s.failRate > 0 && Math.random() < (s.failRate/100) * 0.02) {\n                s.up = false;\n                log('warn','Health check: '+s.name+' became unhealthy (simulated)'); \n              }\n            }\n          }\n        }\n\n        // generate arrivals according to Poisson process approximation\n        const rate = parseFloat(rateEl.value) || 0;\n        const dtSec = (parseInt(tickMsEl.value)||200)/1000;\n        const expected = rate * dtSec;\n        // sample Poisson via approximation: number ~ floor(expected) + Bernoulli(prob)\n        let arrivals = Math.floor(expected);\n        if (Math.random() < (expected - arrivals)) arrivals += 1;\n        for (let i=0;i<arrivals;i++) {\n          spawnRequest();\n        }\n\n        // process global queue if using\n        if (state.globalQueue.length>0) {\n          // attempt to assign some number up to available capacity\n          for (let i=state.globalQueue.length-1;i>=0;i--) {\n            const req = state.globalQueue[i];\n            const ok = assignRequest(req);\n            if (ok) {\n              // remove from global queue if assigned or accepted\n              const ind = state.globalQueue.indexOf(req);\n              if (ind>=0) state.globalQueue.splice(ind,1);\n            }\n            // limit how many we try this tick to avoid thrashing\n            if (i < state.globalQueue.length - 20) break;\n          }\n        }\n\n        // progress running requests\n        for (let id in state.requests) {\n          const req = state.requests[id];\n          if (!req.started) continue;\n          if (req.finished) continue;\n          // if assignment timed out before starting\n          if (state.time > (req.deadline || Infinity)) {\n            // timed out\n            log('warn','Request '+req.id+' timed out before completion');\n            // free server slot if assigned\n            if (req.assignedTo) {\n              const srv = state.servers.find(s=>s.id===req.assignedTo);\n              if (srv) srv.current = Math.max(0, srv.current-1);\n            }\n            // trigger retry if allowed\n            if ((req.attempts || 0) <= parseInt(retriesEl.value || 0)) {\n              // schedule retry with backoff\n              req.attempts = (req.attempts||0) + 1;\n              req.started = false;\n              req.assignedTo = null;\n              const backoff = parseInt(backoffBaseEl.value||200);\n              req.nextAttemptTick = state.time + Math.ceil(backoff / (parseInt(tickMsEl.value)||200));\n              // put back in global queue so it will be attempted later\n              state.globalQueue.push(req);\n              log('debug','Scheduling retry for '+req.id+' after backoff');\n            } else {\n              failRequest(req, 'timeout');\n            }\n            continue;\n          }\n\n          // decrement remainingMs\n          if (!req.remainingMsActual) {\n            // convert remainingMs (ms) to ticks\n            // remainingMs stored as ms at assignment; convert per tick\n            req.remainingMsActual = req.remainingMs;\n          }\n          // decrement by tickMs\n          req.remainingMsActual -= (parseInt(tickMsEl.value)||200);\n          if (req.remainingMsActual <= 0) {\n            // processing finished\n            // pick the assigned server\n            const srv = state.servers.find(s=>s.id===req.assignedTo);\n            // simulate server failure at completion if failRate triggers\n            const failureProb = (srv && srv.failRate) ? (srv.failRate/100) : 0;\n            const actuallyFailed = Math.random() < failureProb;\n            completeRequest(req, !actuallyFailed, srv || {name:'<unknown>'});\n          }\n        }\n\n        // attempt to drain global queue into servers if capacity opened\n        if (state.globalQueue.length>0) {\n          for (let i=state.globalQueue.length-1;i>=0;i--) {\n            const req = state.globalQueue[i];\n            // if req has nextAttemptTick and hasn't reached it, skip\n            if (req.nextAttemptTick && state.time < req.nextAttemptTick) continue;\n            const ok = assignRequest(req);\n            if (ok) {\n              const idx = state.globalQueue.indexOf(req);\n              if (idx>=0) state.globalQueue.splice(idx,1);\n            }\n          }\n        }\n\n        // update UI\n        renderSummary();\n        renderLogs();\n        updateStats();\n      }\n\n      // Request creation\n      function spawnRequest(custom) {\n        const id = ++state.requestCounter;\n        const req = {\n          id: 'r' + id,\n          clientIP: makeClientIP(),\n          arrivalTime: state.time,\n          attempts: 0,\n          started: false,\n          finished: false,\n          failed: false,\n          originalMs: null,\n          cookie: 'ck-' + (Math.floor(Math.random()*1000000)),\n        };\n        if (custom) Object.assign(req, custom);\n        state.requests[req.id] = req;\n        log('debug','Spawned request '+req.id+' from '+req.clientIP);\n        // immediate assign attempt\n        const assigned = assignRequest(req);\n        if (!assigned) {\n          // if assignment failed and queue policy rejects, it's already failed and removed\n        } else {\n          // track stats\n          statInc('sent');\n        }\n      }\n\n      // Controls event handlers\n      startBtn.onclick = function() {\n        startSim();\n      };\n      pauseBtn.onclick = function() {\n        stopSim();\n      };\n      stepBtn.onclick = function() {\n        // one tick\n        applyConfigToState();\n        tick();\n      };\n      resetBtn.onclick = function() {\n        stopSim();\n        // clear state but keep servers\n        state.time = 0;\n        state.requestCounter = 0;\n        state.requests = {};\n        state.completed = 0;\n        state.errors = 0;\n        state.totalLatency = 0;\n        state.globalQueue = [];\n        state.affinityMap = {};\n        state.logs = [];\n        log('info','Simulator reset (kept servers)');\n        renderLogs();\n        renderSummary();\n        updateStats();\n      };\n\n      addServerBtn.onclick = function() { addServer(); };\n      resetServersBtn.onclick = function() { resetServers(); };\n\n      sendOneBtn.onclick = function() { spawnRequest(); };\n      sendBurstBtn.onclick = function() {\n        const count = Math.max(1, parseInt(burstCountEl.value)||1);\n        for (let i=0;i<count;i++) spawnRequest();\n      };\n      clearQueueBtn.onclick = function() {\n        state.globalQueue = [];\n        for (let s of state.servers) s.queue = [];\n        log('info','Cleared all queues');\n        renderSummary();\n      };\n\n      clearLogBtn.onclick = function(){ state.logs=[]; renderLogs(); };\n      exportLogBtn.onclick = function(){\n        const data = state.logs.map(e=>e.raw).join('\\n');\n        const blob = new Blob([data], { type: 'text/plain' });\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url;\n        a.download = 'lb-log.txt';\n        a.click();\n        URL.revokeObjectURL(url);\n      };\n\n      findReqBtn.onclick = function() {\n        const id = findReqEl.value.trim();\n        if (!id) return;\n        const r = state.requests[id];\n        if (r) {\n          reqDetailPre.textContent = JSON.stringify(r, null, 2);\n          return;\n        }\n        // search logs for ID\n        for (let e of state.logs) {\n          if (e.raw.indexOf(id)!==-1) {\n            reqDetailPre.textContent = e.raw + \"\\n\\nmeta: \" + JSON.stringify(e.meta || {}, null, 2);\n            return;\n          }\n        }\n        reqDetailPre.textContent = 'Request ' + id + ' not found';\n      };\n\n      importBtn.onclick = function() { importArea.click(); };\n      importArea.onchange = function(e) {\n        const f = importArea.files[0];\n        if (!f) return;\n        const reader = new FileReader();\n        reader.onload = function(ev) {\n          try {\n            const obj = JSON.parse(ev.target.result);\n            if (obj.servers) {\n              resetServers();\n              for (let s of obj.servers) {\n                addServer(s);\n              }\n              log('info','Imported configuration with '+obj.servers.length+' servers');\n            }\n          } catch(err) { log('error','Import failed: '+err.message); }\n        };\n        reader.readAsText(f);\n      };\n\n      exportBtn.onclick = function() {\n        const cfg = { servers: state.servers.map(s=>{\n          return { weight: s.weight, capacity: s.capacity, baseMs: s.baseMs, jitterMs: s.jitterMs, failRate: s.failRate, queueSize: s.queueSize };\n        })};\n        const blob = new Blob([JSON.stringify(cfg, null, 2)], {type:'application/json'});\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a'); a.href = url; a.download = 'lb-config.json'; a.click(); URL.revokeObjectURL(url);\n      };\n\n      drainAllBtn.onclick = function() {\n        for (let s of state.servers) s.draining = true;\n        log('info','All servers set to draining');\n        rebuildServerTable();\n      };\n\n      // Stats helpers\n      const statWindow = { ticks: [], windowSize: 20 };\n      function statInc(kind) {\n        if (kind === 'sent') {\n          statSentEl.textContent = parseInt(statSentEl.textContent || 0) + 1;\n          // track throughput\n          statWindow.ticks.push({ time: state.time, sent:1 });\n          while (statWindow.ticks.length > statWindow.windowSize) statWindow.ticks.shift();\n        }\n      }\n\n      function updateStats() {\n        document.getElementById('rateVal').textContent = rateEl.value;\n        statCompletedEl.textContent = state.completed;\n        statErrorsEl.textContent = state.errors;\n        statQueueEl.textContent = state.globalQueue.length;\n        statSentEl.textContent = state.requestCounter;\n        const avg = state.completed ? Math.round(state.totalLatency / Math.max(1,state.completed)) : 0;\n        statAvgEl.textContent = avg;\n        // throughput compute over last N ticks\n        const now = state.time;\n        const tw = 10; // last 10 ticks\n        let recent = 0;\n        for (let i=now - tw; i<=now; i++) {\n          // approximate by counting completions in logs\n        }\n        // compute throughput approximate as completed / seconds\n        const tickMs = parseInt(tickMsEl.value)||200;\n        const seconds = (statWindow.windowSize * tickMs)/1000 || 1;\n        const completedNow = state.completed;\n        // no persistent window for completed, so best-effort: show completed / seconds since start or last reset\n        const throughput = seconds>0 ? (state.completed / ((state.time* tickMs)/1000 || 1)) : 0;\n        statThroughputEl.textContent = throughput.toFixed(2);\n      }\n\n      function renderSummary() {\n        // server summary lines\n        let out = '';\n        for (let s of state.servers) {\n          const util = s.capacity > 0 ? Math.round((s.current / s.capacity)*100) : 0;\n          out += s.name + ' | up=' + s.up + ' | draining=' + s.draining + ' | cur=' + s.current + '/' + s.capacity + ' | q=' + (s.queue? s.queue.length:0) + ' | processed=' + s.processed + ' | errors=' + s.errors + ' | util%=' + util + '\\n';\n        }\n        serverSummaryEl.textContent = out;\n      }\n\n      // start/stop\n      function applyConfigToState() {\n        state.tickMs = Math.max(10, parseInt(tickMsEl.value)||200);\n      }\n\n      function startSim() {\n        if (state.running) return;\n        applyConfigToState();\n        state.running = true;\n        // if autostart to begin spawn or resume\n        state.tickInterval = setInterval(tick, state.tickMs);\n        log('info','Simulation started (tickMs='+state.tickMs+')');\n      }\n      function stopSim() {\n        if (!state.running) return;\n        clearInterval(state.tickInterval);\n        state.tickInterval = null;\n        state.running = false;\n        log('info','Simulation paused');\n      }\n\n      // Startup defaults\n      function boot() {\n        // add default servers for demo\n        presetSimple.click();\n        // start if autostart\n        if (startAutostart.checked) startSim();\n        renderLogs();\n        renderSummary();\n      }\n\n      // click handler to view details on log click - not possible in textarea, offer select from raw logs\n      // Provide ability to click log lines by double click -> inspect\n      logArea.ondblclick = function() {\n        const sel = logArea.value.substring(logArea.selectionStart, logArea.selectionEnd).trim();\n        if (!sel) return;\n        // try to parse id r<number> from selection\n        const match = sel.match(/r\\d+/);\n        const id = match ? match[0] : sel.split(/\\s+/)[0];\n        if (id) {\n          const r = state.requests[id];\n          if (r) {\n            reqDetailPre.textContent = JSON.stringify(r, null, 2);\n            return;\n          } else {\n            reqDetailPre.textContent = 'Request ' + id + ' not found in active requests. Searching logs...\\n';\n            for (let e of state.logs) {\n              if (e.raw.indexOf(id)!==-1) {\n                reqDetailPre.textContent += e.raw + \"\\n\\nmeta: \" + JSON.stringify(e.meta || {}, null, 2);\n                return;\n              }\n            }\n            reqDetailPre.textContent += 'No match';\n          }\n        }\n      };\n\n      // UI bindings\n      rateEl.oninput = function(){ rateValEl.textContent = rateEl.value; };\n      tickMsEl.onchange = function(){ /* apply on start */ };\n      // keyboard shortcuts minimal\n      document.addEventListener('keydown', function(e){\n        if (e.key === ' ') { e.preventDefault(); if (state.running) stopSim(); else startSim(); }\n      });\n\n      // Final boot\n      boot();\n\n      // Expose some state for debugging in console\n      window.LBSim = {\n        state,\n        addServer,\n        resetServers,\n        spawnRequest,\n        startSim,\n        stopSim,\n        tick,\n      };\n    })();\n  </script>\n</body>\n</html>"
