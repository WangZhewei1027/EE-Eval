    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sliding Window Aesthetics</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa, #c3cfe2);\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n        }\n\n        .container {\n            position: relative;\n            width: 60%;\n            height: 50%;\n            border-radius: 15px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n            border: 1px solid rgba(255, 255, 255, 0.6);\n        }\n\n        .slide {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            opacity: 0;\n            transition: opacity 0.5s ease-in-out;\n        }\n\n        .slide.active {\n            opacity: 1;\n        }\n\n        .content {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 2em;\n            color: #333;\n            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);\n            background: rgba(255, 255, 255, 0.8);\n            border-radius: 10px;\n            padding: 20px;\n            box-shadow: 0 2px 15px rgba(0, 0, 0, 0.2);\n        }\n\n        .buttons {\n            position: absolute;\n            bottom: 20px;\n            width: 100%;\n            display: flex;\n            justify-content: center;\n        }\n\n        .button {\n            background: #6c63ff;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            font-size: 1em;\n            cursor: pointer;\n            transition: background 0.3s ease;\n            margin: 0 10px;\n        }\n\n        .button:hover {\n            background: #5a52e0;\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n            }\n\n            to {\n                opacity: 1;\n            }\n        }\n\n        @keyframes fadeOut {\n            from {\n                opacity: 1;\n            }\n\n            to {\n                opacity: 0;\n            }\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <div class=\"slide active\">\n            <div class=\"content\">Welcome to the Sliding Window</div>\n        </div>\n        <div class=\"slide\">\n            <div class=\"content\">Visualize Concepts with Clarity</div>\n        </div>\n        <div class=\"slide\">\n            <div class=\"content\">Experience Smooth Transitions</div>\n        </div>\n    </div>\n    <div class=\"buttons\">\n        <button class=\"button\" id=\"nextBtn\">Next</button>\n        <button class=\"button\" id=\"prevBtn\">Previous</button>\n    </div>\n\n    <script>\n        const slides = document.querySelectorAll('.slide');\n        let currentIndex = 0;\n\n        function showSlide(index) {\n            slides.forEach((slide, i) => {\n                slide.classList.remove('active');\n                if (i === index) {\n                    slide.classList.add('active');\n                }\n            });\n        }\n\n        document.getElementById('nextBtn').addEventListener('click', () => {\n            currentIndex = (currentIndex + 1) % slides.length;\n            showSlide(currentIndex);\n        });\n\n        document.getElementById('prevBtn').addEventListener('click', () => {\n            currentIndex = (currentIndex - 1 + slides.length) % slides.length;\n            showSlide(currentIndex);\n        });\n    </script>\n</body>\n\n</html>"
