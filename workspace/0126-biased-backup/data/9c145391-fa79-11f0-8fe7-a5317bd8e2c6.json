    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Breadth-First Search (BFS) Interactive Explorer</title>\n<style>\n  /* Extremely minimal styling only for layout (black text on white background). */\n  html,body { height:100%; margin:0; font-family:Arial, sans-serif; color:#000; background:#fff; }\n  #app { display:flex; height:100vh; gap:8px; padding:8px; box-sizing:border-box; }\n  #controls { width:380px; overflow:auto; padding:6px; border:1px solid #000; }\n  #canvasWrap { flex:1; padding:6px; border:1px solid #000; display:flex; flex-direction:column; }\n  fieldset { margin-bottom:8px; padding:8px; }\n  label { display:block; margin:4px 0; font-size:13px; }\n  input, select, button, textarea { margin-right:6px; margin-top:4px; }\n  button { margin-bottom:6px; }\n  svg { width:100%; height:100%; border:1px solid #000; background:#fff; }\n  .small { font-size:12px; }\n  #log { width:100%; height:120px; }\n  #queueList, #historyIndex { width:100%; }\n  .controls-row { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }\n  .muted { font-size:12px; opacity:0.9; }\n  .tiny { font-size:11px; }\n</style>\n</head>\n<body>\n<div id=\"app\">\n  <div id=\"controls\">\n    <h3>Breadth-First Search (BFS) Explorer</h3>\n    <fieldset>\n      <legend>Graph Mode & Quick Generators</legend>\n      <div class=\"controls-row\">\n        <label><input type=\"radio\" name=\"mode\" value=\"grid\" checked> Grid mode</label>\n        <label><input type=\"radio\" name=\"mode\" value=\"free\"> Free node mode</label>\n      </div>\n      <div>\n        <label>Grid rows: <input type=\"number\" id=\"gridRows\" value=\"8\" min=\"1\" style=\"width:60px;\"></label>\n        <label>cols: <input type=\"number\" id=\"gridCols\" value=\"12\" min=\"1\" style=\"width:60px;\"></label>\n        <button id=\"genGrid\">Generate Grid</button>\n      </div>\n      <div>\n        <label>Obstacle density (0-1): <input id=\"obstDensity\" type=\"number\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.15\" style=\"width:80px;\"></label>\n        <button id=\"randomObstacles\">Randomize Obstacles</button>\n      </div>\n      <div>\n        <button id=\"presetMaze\">Preset: Simple Maze</button>\n        <button id=\"presetDisconnected\">Preset: Disconnected</button>\n      </div>\n      <div style=\"margin-top:6px;\">\n        <label><input type=\"checkbox\" id=\"directedGraph\"> Directed edges</label>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Edit Tools (click elements in canvas)</legend>\n      <div class=\"controls-row\">\n        <label><input type=\"radio\" name=\"tool\" value=\"select\" checked> Select / Move</label>\n        <label><input type=\"radio\" name=\"tool\" value=\"addnode\"> Add Node</label>\n        <label><input type=\"radio\" name=\"tool\" value=\"addedge\"> Add Edge (click source then target)</label>\n        <label><input type=\"radio\" name=\"tool\" value=\"toggleObstacle\"> Toggle Obstacle</label>\n        <label><input type=\"radio\" name=\"tool\" value=\"setStart\"> Set Start</label>\n        <label><input type=\"radio\" name=\"tool\" value=\"toggleGoal\"> Toggle Goal</label>\n      </div>\n      <div style=\"margin-top:6px;\">\n        <button id=\"deleteSelected\">Delete Selected</button>\n        <button id=\"clearGraph\">Clear Graph</button>\n        <button id=\"autoConnect\">Auto-connect nearest</button>\n      </div>\n      <div class=\"muted tiny\">Edge creation in free mode: choose \"Add Edge\", click source then click target. Double-click node to delete (works too).</div>\n    </fieldset>\n\n    <fieldset>\n      <legend>BFS Controls</legend>\n      <div>\n        <label>Start nodes (comma ids): <input id=\"startNodesInput\" type=\"text\" class=\"small\" placeholder=\"e.g. 0,1 or r0c0\"> </label>\n      </div>\n      <div>\n        <label>Stop policy:\n          <select id=\"stopPolicy\">\n            <option value=\"first\">Stop at first goal found</option>\n            <option value=\"all\">Explore all reachable nodes</option>\n            <option value=\"k\">Stop after K goals found</option>\n          </select>\n        </label>\n        <label id=\"kLabel\" style=\"display:none\">K: <input id=\"kValue\" type=\"number\" value=\"1\" min=\"1\" style=\"width:60px;\"></label>\n      </div>\n      <div>\n        <label>Neighbor order:\n          <select id=\"neighborOrder\">\n            <option value=\"id_asc\">By id ascending</option>\n            <option value=\"id_desc\">By id descending</option>\n            <option value=\"degree_asc\">By degree ascending</option>\n            <option value=\"degree_desc\">By degree descending</option>\n            <option value=\"random\">Random</option>\n            <option value=\"custom\">Custom order (csv below)</option>\n          </select>\n        </label>\n      </div>\n      <div>\n        <label>Custom neighbor preference (csv of node ids):</label>\n        <input id=\"customPreference\" type=\"text\" placeholder=\"id1,id2,...\" style=\"width:100%;\">\n      </div>\n\n      <div style=\"margin-top:6px;\">\n        <button id=\"bfsReset\">Reset BFS state</button>\n        <button id=\"bfsInit\">Initialize BFS (load start nodes)</button>\n      </div>\n\n      <div style=\"margin-top:6px;\" class=\"controls-row\">\n        <button id=\"stepBtn\">Step (space)</button>\n        <button id=\"runBtn\">Run / Pause (r)</button>\n        <button id=\"fastForward\">Run to completion</button>\n        <button id=\"stopBtn\">Stop & Clear BFS</button>\n      </div>\n\n      <div>\n        <label>Speed (ms per step): <input type=\"range\" id=\"speedSlider\" min=\"50\" max=\"2000\" value=\"400\"></label>\n      </div>\n\n      <div style=\"margin-top:6px;\">\n        <button id=\"undoBtn\">Undo (u)</button>\n        <button id=\"redoBtn\">Redo (y)</button>\n      </div>\n\n      <div style=\"margin-top:6px;\">\n        <label>History step: <input id=\"historyIndex\" type=\"range\" min=\"0\" max=\"0\" value=\"0\"></label>\n        <div class=\"muted tiny\">Drag to jump to any saved step.</div>\n      </div>\n\n      <div style=\"margin-top:6px;\">\n        <label><input id=\"showQueue\" type=\"checkbox\" checked> Show queue contents</label>\n        <label><input id=\"showPath\" type=\"checkbox\" checked> Show shortest path to last goal</label>\n        <label><input id=\"showParents\" type=\"checkbox\" checked> Show parent edges</label>\n        <label><input id=\"showDistances\" type=\"checkbox\" checked> Show distances</label>\n        <label><input id=\"showLayers\" type=\"checkbox\"> Show layer numbers</label>\n        <label><input id=\"visitOrder\" type=\"checkbox\"> Show visit order numbers</label>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Graph Import / Export</legend>\n      <div>\n        <button id=\"exportJson\">Export JSON</button>\n        <button id=\"importJsonBtn\">Import JSON</button>\n      </div>\n      <textarea id=\"jsonArea\" placeholder='{\"nodes\":[...],\"edges\":[...],\"directed\":false}' style=\"width:100%;height:80px;\"></textarea>\n      <div style=\"margin-top:6px;\">\n        <button id=\"randomGraph\">Random free-mode graph</button>\n        <label>nodes: <input id=\"randNodes\" value=\"12\" type=\"number\" min=\"1\" style=\"width:60px;\"></label>\n        <label>edge prob: <input id=\"randEdgeProb\" value=\"0.12\" type=\"number\" step=\"0.01\" min=\"0\" max=\"1\" style=\"width:80px;\"></label>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Diagnostics & Live Info</legend>\n      <div>Visited count: <span id=\"visitedCount\">0</span></div>\n      <div>Frontier (queue) size: <span id=\"frontierCount\">0</span></div>\n      <div>Current node: <span id=\"currentNode\">-</span></div>\n      <div>Found goals: <span id=\"foundGoals\">0</span></div>\n      <div style=\"margin-top:6px;\">\n        <label>Queue contents:</label>\n        <textarea id=\"queueList\" readonly></textarea>\n      </div>\n      <div style=\"margin-top:6px;\">\n        <label>Log / Timeline:</label>\n        <textarea id=\"log\" readonly></textarea>\n      </div>\n    </fieldset>\n\n    <div style=\"font-size:12px;\">\n      Keyboard: Space=Step, R=Run/Pause, F=FastForward, S=Reset, U=Undo, Y=Redo.\n    </div>\n  </div>\n\n  <div id=\"canvasWrap\">\n    <div style=\"margin-bottom:6px;\">\n      <button id=\"zoomIn\">Zoom In</button>\n      <button id=\"zoomOut\">Zoom Out</button>\n      <button id=\"fitView\">Fit View</button>\n      <span class=\"muted tiny\">Click canvas to add nodes in free mode. Drag nodes to move.</span>\n    </div>\n    <svg id=\"svgCanvas\" viewBox=\"0 0 1200 800\"></svg>\n  </div>\n</div>\n\n<script>\n/*\n  BFS Interactive Explorer\n  - Minimal visual style (black on white).\n  - Rich interactivity: grid/free mode, many controls, step/run, undo/redo, import/export, dynamic edits.\n*/\n\n/* -----------------------------\n   Data structures and state\n   ----------------------------- */\n\nlet state = {\n  graph: { nodes: {}, edges: [] , directed:false },\n  mode: 'grid', // 'grid' or 'free'\n  tool: 'select', // edit tool\n  svgScale: 1,\n  bfs: {\n    initialized: false,\n    queue: [],\n    inQueue: new Set(),\n    visited: new Set(),\n    parents: {}, // child -> parent\n    distance: {}, // node -> dist\n    visitOrder: {},\n    stepCount: 0,\n    current: null,\n    goalsFound: new Set()\n  },\n  ui: {\n    running: false,\n    timer: null,\n    speed: 400,\n  },\n  history: [], // snapshots for undo/redo and time-travel\n  historyPos: -1,\n  nextNodeId: 0,\n  selection: null,\n  edgeTempSource: null\n};\n\n/* Basic helpers */\nfunction deepCopy(obj){\n  return JSON.parse(JSON.stringify(obj));\n}\nfunction nodeIdNum(id){\n  // try to parse numeric core id for random sort consistency\n  let n = parseFloat(id);\n  if(!isNaN(n)) return n;\n  return id;\n}\n\n/* -----------------------------\n   SVG drawing utilities\n   ----------------------------- */\n\nconst svg = document.getElementById('svgCanvas');\nconst NS = \"http://www.w3.org/2000/svg\";\n\nfunction clearSVG(){\n  while(svg.firstChild) svg.removeChild(svg.firstChild);\n}\n\nfunction drawGraph(){\n  clearSVG();\n  const g = state.graph;\n  // draw edges\n  for(let e of g.edges){\n    const a = g.nodes[e.from];\n    const b = g.nodes[e.to];\n    if(!a || !b) continue;\n    let line = document.createElementNS(NS,'line');\n    line.setAttribute('x1', a.x);\n    line.setAttribute('y1', a.y);\n    line.setAttribute('x2', b.x);\n    line.setAttribute('y2', b.y);\n    line.setAttribute('stroke', '#000');\n    line.setAttribute('stroke-width', 1.2);\n    line.setAttribute('data-from', e.from);\n    line.setAttribute('data-to', e.to);\n    if(state.bfs.parents[b.id] === a.id || state.bfs.parents[a.id] === b.id){\n      // highlight parent edges when showParents\n      if(document.getElementById('showParents').checked) line.setAttribute('stroke-width', 2.2);\n    }\n    svg.appendChild(line);\n    if(g.directed){\n      // draw a small arrow head\n      let dx = b.x - a.x, dy = b.y - a.y;\n      let len = Math.hypot(dx,dy) || 1;\n      let ux = dx/len, uy = dy/len;\n      let arrowSize = 8;\n      let hx = b.x - ux*14, hy = b.y - uy*14;\n      let p1x = hx - uy*(arrowSize/2), p1y = hy + ux*(arrowSize/2);\n      let p2x = hx + uy*(arrowSize/2), p2y = hy - ux*(arrowSize/2);\n      let poly = document.createElementNS(NS,'polygon');\n      poly.setAttribute('points', `${b.x},${b.y} ${p1x},${p1y} ${p2x},${p2y}`);\n      poly.setAttribute('fill','#fff');\n      poly.setAttribute('stroke','#000');\n      poly.setAttribute('stroke-width','1');\n      svg.appendChild(poly);\n    }\n  }\n\n  // draw nodes\n  for(let id in g.nodes){\n    let n = g.nodes[id];\n    let group = document.createElementNS(NS,'g');\n    group.setAttribute('class','node');\n    group.setAttribute('data-id', id);\n    group.setAttribute('transform', `translate(${n.x},${n.y})`);\n    // circle\n    let r = 16;\n    let circ = document.createElementNS(NS,'circle');\n    circ.setAttribute('r', r);\n    circ.setAttribute('cx', 0);\n    circ.setAttribute('cy', 0);\n    circ.setAttribute('stroke', '#000');\n    circ.setAttribute('fill', n.obstacle ? '#fff' : '#fff'); // white fill; obstacle indicated by cross\n    circ.setAttribute('stroke-width', 1.2);\n    group.appendChild(circ);\n    // if obstacle draw X lines\n    if(n.obstacle){\n      let lx1 = document.createElementNS(NS,'line');\n      lx1.setAttribute('x1', -10); lx1.setAttribute('y1', -10);\n      lx1.setAttribute('x2', 10); lx1.setAttribute('y2', 10);\n      lx1.setAttribute('stroke','#000'); lx1.setAttribute('stroke-width',1.2);\n      group.appendChild(lx1);\n      let lx2 = document.createElementNS(NS,'line');\n      lx2.setAttribute('x1', -10); lx2.setAttribute('y1', 10);\n      lx2.setAttribute('x2', 10); lx2.setAttribute('y2', -10);\n      lx2.setAttribute('stroke','#000'); lx2.setAttribute('stroke-width',1.2);\n      group.appendChild(lx2);\n    }\n    // labels\n    let txt = document.createElementNS(NS,'text');\n    txt.setAttribute('x', 0); txt.setAttribute('y', 4);\n    txt.setAttribute('text-anchor','middle');\n    txt.setAttribute('font-size','11');\n    txt.setAttribute('font-family','Arial, sans-serif');\n    txt.textContent = id;\n    group.appendChild(txt);\n\n    // distance text\n    if(document.getElementById('showDistances').checked && state.bfs.distance[id] !== undefined){\n      let d = document.createElementNS(NS,'text');\n      d.setAttribute('x', 18); d.setAttribute('y', -18);\n      d.setAttribute('font-size','10');\n      d.setAttribute('font-family','Arial, sans-serif');\n      d.textContent = state.bfs.distance[id];\n      group.appendChild(d);\n    }\n    // visit order\n    if(document.getElementById('visitOrder').checked && state.bfs.visitOrder[id] !== undefined){\n      let v = document.createElementNS(NS,'text');\n      v.setAttribute('x', -18); v.setAttribute('y', -18);\n      v.setAttribute('font-size','10');\n      v.setAttribute('font-family','Arial, sans-serif');\n      v.textContent = state.bfs.visitOrder[id];\n      group.appendChild(v);\n    }\n    // layer number\n    if(document.getElementById('showLayers').checked && state.bfs.distance[id] !== undefined){\n      let l = document.createElementNS(NS,'text');\n      l.setAttribute('x', -18); l.setAttribute('y', 18);\n      l.setAttribute('font-size','10');\n      l.setAttribute('font-family','Arial, sans-serif');\n      l.textContent = 'L' + state.bfs.distance[id];\n      group.appendChild(l);\n    }\n    // marking start/goal/current\n    if(n.start){\n      let mark = document.createElementNS(NS,'text');\n      mark.setAttribute('x', 0); mark.setAttribute('y', -28);\n      mark.setAttribute('font-size','10');\n      mark.setAttribute('text-anchor','middle');\n      mark.textContent = 'START';\n      group.appendChild(mark);\n    }\n    if(n.goal){\n      let mark = document.createElementNS(NS,'text');\n      mark.setAttribute('x', 0); mark.setAttribute('y', 28);\n      mark.setAttribute('font-size','10');\n      mark.setAttribute('text-anchor','middle');\n      mark.textContent = 'GOAL';\n      group.appendChild(mark);\n    }\n    if(state.bfs.current === id){\n      let mark = document.createElementNS(NS,'text');\n      mark.setAttribute('x', 0); mark.setAttribute('y', -40);\n      mark.setAttribute('font-size','10');\n      mark.setAttribute('text-anchor','middle');\n      mark.textContent = 'CURRENT';\n      group.appendChild(mark);\n    }\n\n    // apply selection visual (simple: stroke-width larger)\n    if(state.selection === id){\n      circ.setAttribute('stroke-width', 2.4);\n    }\n\n    // clickable handlers via event delegation later\n    svg.appendChild(group);\n  }\n}\n\n/* -----------------------------\n   Graph operations\n   ----------------------------- */\n\nfunction addNode(x,y,id=null,opts={}){\n  if(id === null) id = generateNodeId();\n  let node = { id: id, x: x, y: y, obstacle: !!opts.obstacle, start: !!opts.start, goal: !!opts.goal };\n  state.graph.nodes[id] = node;\n  return id;\n}\n\nfunction generateNodeId(){\n  // uses incremental numeric id by default: 0,1,2... but keeps custom ids possible (grid r0c0)\n  let id = String(state.nextNodeId++);\n  while(state.graph.nodes[id]) id = String(state.nextNodeId++);\n  return id;\n}\n\nfunction removeNode(id){\n  delete state.graph.nodes[id];\n  state.graph.edges = state.graph.edges.filter(e => e.from !== id && e.to !== id);\n  // if BFS references this node, remove\n  if(state.bfs.inQueue.has(id)) state.bfs.inQueue.delete(id);\n  if(state.bfs.visited.has(id)) state.bfs.visited.delete(id);\n  delete state.bfs.parents[id];\n  delete state.bfs.distance[id];\n  delete state.bfs.visitOrder[id];\n  state.selection = null;\n}\n\nfunction addEdge(a,b){\n  if(!state.graph.nodes[a] || !state.graph.nodes[b]) return;\n  // prevent duplicate\n  if(state.graph.edges.some(e => e.from===a && e.to===b)) return;\n  state.graph.edges.push({from:a,to:b});\n  if(!state.graph.directed){\n    if(!state.graph.edges.some(e => e.from===b && e.to===a)) state.graph.edges.push({from:b,to:a});\n  }\n}\n\nfunction removeEdge(a,b){\n  state.graph.edges = state.graph.edges.filter(e => !(e.from===a && e.to===b));\n  if(!state.graph.directed) state.graph.edges = state.graph.edges.filter(e => !(e.from===b && e.to===a));\n}\n\nfunction neighborsOf(id){\n  let ns = [];\n  for(let e of state.graph.edges){\n    if(e.from === id){\n      // skip neighbor if node is obstacle?\n      let target = state.graph.nodes[e.to];\n      if(target && target.obstacle) continue;\n      ns.push(e.to);\n    }\n  }\n  return ns;\n}\n\n/* -----------------------------\n   Grid helpers\n   ----------------------------- */\n\nfunction generateGrid(rows, cols, spacing=60, startIdPrefix='r'){\n  state.graph = { nodes: {}, edges: [], directed: state.graph.directed };\n  state.nextNodeId = 0;\n  for(let r=0;r<rows;r++){\n    for(let c=0;c<cols;c++){\n      let id = 'r'+r+'c'+c;\n      addNode(60 + c*spacing, 60 + r*spacing, id, {obstacle:false});\n    }\n  }\n  // connect 4-neighbors\n  for(let r=0;r<rows;r++){\n    for(let c=0;c<cols;c++){\n      let id = 'r'+r+'c'+c;\n      let d = [[1,0],[-1,0],[0,1],[0,-1]];\n      for(let [dr,dc] of d){\n        let rr=r+dr, cc=c+dc;\n        if(rr>=0 && rr<rows && cc>=0 && cc<cols){\n          let id2 = 'r'+rr+'c'+cc;\n          if(state.graph.directed) state.graph.edges.push({from:id,to:id2});\n          else {\n            // ensure pair added once\n            if(!state.graph.edges.some(e=>e.from===id && e.to===id2)) {\n              state.graph.edges.push({from:id,to:id2});\n              state.graph.edges.push({from:id2,to:id});\n            }\n          }\n        }\n      }\n    }\n  }\n  state.mode = 'grid';\n  // update nextNodeId to avoid conflicts with numeric ids\n  state.nextNodeId = Object.keys(state.graph.nodes).length + 1000;\n}\n\n/* -----------------------------\n   BFS algorithm / stepping\n   ----------------------------- */\n\nfunction bfsInitFromUI(){\n  // clear BFS state but keep graph, set start nodes from input or nodes marked\n  state.bfs = {\n    initialized: true,\n    queue: [],\n    inQueue: new Set(),\n    visited: new Set(),\n    parents: {},\n    distance: {},\n    visitOrder: {},\n    stepCount: 0,\n    current: null,\n    goalsFound: new Set()\n  };\n  let startText = document.getElementById('startNodesInput').value.trim();\n  let starts = [];\n  if(startText){\n    startText.split(',').map(s=>s.trim()).filter(Boolean).forEach(token=>{\n      if(state.graph.nodes[token]) starts.push(token);\n    });\n  }\n  // also include nodes explicitly marked as start\n  for(let id in state.graph.nodes) if(state.graph.nodes[id].start) starts.push(id);\n  // unique\n  starts = Array.from(new Set(starts));\n  if(starts.length === 0){\n    // take first node as default if any\n    let keys = Object.keys(state.graph.nodes);\n    if(keys.length) starts.push(keys[0]);\n  }\n  for(let s of starts){\n    enqueueIfNot(s, 0, null);\n  }\n  saveSnapshot('BFS initialized');\n  updateUI();\n}\n\nfunction enqueueIfNot(node, dist, parent){\n  if(!state.graph.nodes[node]) return;\n  if(state.graph.nodes[node].obstacle) return;\n  if(state.bfs.visited.has(node)) return;\n  if(state.bfs.inQueue.has(node)) return;\n  state.bfs.queue.push(node);\n  state.bfs.inQueue.add(node);\n  state.bfs.parents[node] = parent;\n  if(parent === null) state.bfs.distance[node] = 0;\n  else state.bfs.distance[node] = (state.bfs.distance[parent] || 0) + 1;\n}\n\nfunction getStopPolicy(){\n  return document.getElementById('stopPolicy').value;\n}\n\nfunction stepBFS(){\n  if(!state.bfs.initialized){\n    log('BFS not initialized; press \"Initialize BFS\" first.');\n    return;\n  }\n  if(state.bfs.queue.length === 0){\n    log('Queue empty. BFS finished.');\n    state.ui.running = false;\n    stopTimer();\n    updateUI();\n    saveSnapshot('Finished');\n    return;\n  }\n  // Dequeue\n  let current = state.bfs.queue.shift();\n  state.bfs.inQueue.delete(current);\n  state.bfs.current = current;\n  state.bfs.stepCount++;\n  state.bfs.visited.add(current);\n  state.bfs.visitOrder[current] = state.bfs.stepCount;\n  // check goals\n  if(state.graph.nodes[current] && state.graph.nodes[current].goal){\n    state.bfs.goalsFound.add(current);\n    log(`Goal found at ${current}`);\n    if(getStopPolicy() === 'first'){\n      // record then halt\n      saveSnapshot(`Found goal ${current}`);\n      state.ui.running = false;\n      stopTimer();\n      updateUI();\n      return;\n    } else if(getStopPolicy() === 'k'){\n      let k = parseInt(document.getElementById('kValue').value) || 1;\n      if(state.bfs.goalsFound.size >= k){\n        saveSnapshot(`Found ${k} goals`);\n        state.ui.running = false;\n        stopTimer();\n        updateUI();\n        return;\n      }\n    }\n  }\n\n  // Get neighbors and enqueue according to neighbor order\n  let neigh = neighborsOf(current);\n  neigh = applyNeighborOrder(neigh);\n  for(let nb of neigh){\n    if(state.bfs.visited.has(nb)) continue;\n    if(state.bfs.inQueue.has(nb)) continue;\n    enqueueIfNot(nb, state.bfs.distance[current]+1, current);\n  }\n\n  // logging\n  log(`Expanded ${current}; enqueued ${neigh.filter(n=>!state.bfs.visited.has(n) && !state.bfs.inQueue.has(n)).join(', ')}`);\n  saveSnapshot(`Step ${state.bfs.stepCount} expand ${current}`);\n  updateUI();\n}\n\nfunction applyNeighborOrder(list){\n  let method = document.getElementById('neighborOrder').value;\n  let l = Array.from(list);\n  if(method === 'id_asc') l.sort((a,b)=>(String(a)>String(b)?1:-1));\n  else if(method === 'id_desc') l.sort((a,b)=>(String(a)<String(b)?1:-1));\n  else if(method === 'degree_asc') l.sort((a,b)=>getDegree(a)-getDegree(b));\n  else if(method === 'degree_desc') l.sort((a,b)=>getDegree(b)-getDegree(a));\n  else if(method === 'random') for(let i=l.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[l[i],l[j]]=[l[j],l[i]];}\n  else if(method === 'custom'){\n    let pref = document.getElementById('customPreference').value.split(',').map(s=>s.trim()).filter(Boolean);\n    l.sort((a,b)=>{\n      let ai = pref.indexOf(a), bi = pref.indexOf(b);\n      if(ai === -1 && bi === -1) return String(a)>String(b)?1:-1;\n      if(ai === -1) return 1;\n      if(bi === -1) return -1;\n      return ai-bi;\n    });\n  }\n  return l;\n}\n\nfunction getDegree(nodeId){\n  let deg = 0;\n  for(let e of state.graph.edges){\n    if(e.from === nodeId) deg++;\n  }\n  return deg;\n}\n\n/* -----------------------------\n   Timer / run control\n   ----------------------------- */\n\nfunction startTimer(){\n  if(state.ui.timer) clearInterval(state.ui.timer);\n  state.ui.timer = setInterval(()=> {\n    stepBFS();\n    if(state.bfs.queue.length === 0) stopTimer();\n  }, state.ui.speed);\n}\n\nfunction stopTimer(){\n  if(state.ui.timer) clearInterval(state.ui.timer);\n  state.ui.timer = null;\n  state.ui.running = false;\n  document.getElementById('runBtn').textContent = 'Run / Pause (r)';\n}\n\n/* -----------------------------\n   Snapshot history for undo/redo and time travel\n   ----------------------------- */\n\nfunction saveSnapshot(note=''){\n  // deep copy relevant pieces: graph, bfs, selection\n  const snap = {\n    time: Date.now(),\n    note: note,\n    graph: deepCopy(state.graph),\n    bfs: deepCopy({\n      initialized: state.bfs.initialized,\n      queue: state.bfs.queue.slice(),\n      inQueue: Array.from(state.bfs.inQueue),\n      visited: Array.from(state.bfs.visited),\n      parents: state.bfs.parents,\n      distance: state.bfs.distance,\n      visitOrder: state.bfs.visitOrder,\n      stepCount: state.bfs.stepCount,\n      current: state.bfs.current,\n      goalsFound: Array.from(state.bfs.goalsFound)\n    }),\n    selection: state.selection\n  };\n  // truncate future if we are not at latest\n  if(state.historyPos < state.history.length-1){\n    state.history = state.history.slice(0, state.historyPos+1);\n  }\n  state.history.push(snap);\n  state.historyPos = state.history.length-1;\n  updateHistorySlider();\n}\n\nfunction restoreSnapshot(pos){\n  if(pos<0 || pos>=state.history.length) return;\n  let snap = state.history[pos];\n  state.graph = deepCopy(snap.graph);\n  // restore BFS structure\n  state.bfs.initialized = snap.bfs.initialized;\n  state.bfs.queue = snap.bfs.queue.slice();\n  state.bfs.inQueue = new Set(snap.bfs.inQueue);\n  state.bfs.visited = new Set(snap.bfs.visited);\n  state.bfs.parents = deepCopy(snap.bfs.parents);\n  state.bfs.distance = deepCopy(snap.bfs.distance);\n  state.bfs.visitOrder = deepCopy(snap.bfs.visitOrder);\n  state.bfs.stepCount = snap.bfs.stepCount;\n  state.bfs.current = snap.bfs.current;\n  state.bfs.goalsFound = new Set(snap.bfs.goalsFound);\n  state.selection = snap.selection;\n  state.historyPos = pos;\n  updateHistorySlider();\n  updateUI();\n}\n\nfunction updateHistorySlider(){\n  let s = document.getElementById('historyIndex');\n  s.max = Math.max(0, state.history.length-1);\n  s.value = state.historyPos;\n}\n\n/* -----------------------------\n   UI updates, logging\n   ----------------------------- */\n\nfunction updateUI(){\n  document.getElementById('visitedCount').textContent = state.bfs.visited.size;\n  document.getElementById('frontierCount').textContent = state.bfs.queue.length;\n  document.getElementById('currentNode').textContent = state.bfs.current || '-';\n  document.getElementById('foundGoals').textContent = state.bfs.goalsFound.size;\n  document.getElementById('queueList').value = state.bfs.queue.join(', ');\n  document.getElementById('speedSlider').value = state.ui.speed;\n  // draw graph with overlays\n  drawGraph();\n}\n\nfunction log(text){\n  let ta = document.getElementById('log');\n  let t = new Date().toLocaleTimeString() + ' - ' + text;\n  ta.value = t + '\\n' + ta.value;\n}\n\n/* -----------------------------\n   Event handlers for UI controls\n   ----------------------------- */\n\ndocument.getElementById('genGrid').addEventListener('click', ()=>{\n  let r = parseInt(document.getElementById('gridRows').value) || 6;\n  let c = parseInt(document.getElementById('gridCols').value) || 8;\n  generateGrid(r,c,60);\n  saveSnapshot('Generated grid');\n  drawGraph();\n});\n\ndocument.getElementById('randomObstacles').addEventListener('click', ()=>{\n  let density = parseFloat(document.getElementById('obstDensity').value) || 0.15;\n  for(let id in state.graph.nodes){\n    state.graph.nodes[id].obstacle = Math.random() < density;\n  }\n  saveSnapshot('Randomized obstacles');\n  drawGraph();\n});\n\ndocument.getElementById('presetMaze').addEventListener('click', ()=>{\n  generateGrid(8,12,60);\n  // carve simple corridors\n  for(let id in state.graph.nodes){\n    state.graph.nodes[id].obstacle = false;\n    if(id.includes('r1') || id.includes('r3') || id.includes('r5')) {\n      // remove some nodes to create walls\n      if(Math.random() < 0.25) state.graph.nodes[id].obstacle = true;\n    }\n  }\n  saveSnapshot('Preset maze');\n  drawGraph();\n});\n\ndocument.getElementById('presetDisconnected').addEventListener('click', ()=>{\n  state.graph = { nodes: {}, edges: [], directed: false };\n  state.nextNodeId = 0;\n  for(let i=0;i<6;i++) addNode(120 + i*60, 120, null);\n  for(let i=0;i<6;i++) addNode(120 + i*60, 300, null);\n  // connect first row fully\n  let keys = Object.keys(state.graph.nodes);\n  for(let i=0;i<4;i++) addEdge(keys[i], keys[i+1]);\n  // connect second row only partly\n  addEdge(keys[6], keys[7]); addEdge(keys[7], keys[8]);\n  saveSnapshot('Preset disconnected');\n  drawGraph();\n});\n\ndocument.getElementsByName('mode').forEach(el=>{\n  el.addEventListener('change', ()=>{\n    state.mode = document.querySelector('input[name=\"mode\"]:checked').value;\n    log('Mode: ' + state.mode);\n  });\n});\n\ndocument.getElementsByName('tool').forEach(el=>{\n  el.addEventListener('change', ()=>{\n    state.tool = document.querySelector('input[name=\"tool\"]:checked').value;\n    state.edgeTempSource = null;\n    log('Tool: ' + state.tool);\n  });\n});\n\ndocument.getElementById('directedGraph').addEventListener('change', (e)=>{\n  state.graph.directed = e.target.checked;\n  saveSnapshot('Toggled directed = ' + state.graph.directed);\n  drawGraph();\n});\n\ndocument.getElementById('autoConnect').addEventListener('click', ()=>{\n  // connect nearest neighbors in free mode\n  let ids = Object.keys(state.graph.nodes);\n  for(let i=0;i<ids.length;i++){\n    for(let j=i+1;j<ids.length;j++){\n      let a = state.graph.nodes[ids[i]], b = state.graph.nodes[ids[j]];\n      let d = Math.hypot(a.x-b.x,a.y-b.y);\n      if(d < 120) addEdge(a.id, b.id);\n    }\n  }\n  saveSnapshot('Auto-connected nearest');\n  drawGraph();\n});\n\ndocument.getElementById('clearGraph').addEventListener('click', ()=>{\n  state.graph = { nodes: {}, edges: [], directed: state.graph.directed };\n  state.nextNodeId = 0;\n  saveSnapshot('Cleared graph');\n  drawGraph();\n});\n\ndocument.getElementById('deleteSelected').addEventListener('click', ()=>{\n  if(state.selection) removeNode(state.selection);\n  state.selection = null;\n  saveSnapshot('Deleted selected');\n  drawGraph();\n});\n\ndocument.getElementById('bfsInit').addEventListener('click', ()=> bfsInitFromUI());\ndocument.getElementById('bfsReset').addEventListener('click', ()=>{\n  state.bfs = {\n    initialized: false,\n    queue: [],\n    inQueue: new Set(),\n    visited: new Set(),\n    parents: {},\n    distance: {},\n    visitOrder: {},\n    stepCount: 0,\n    current: null,\n    goalsFound: new Set()\n  };\n  saveSnapshot('BFS reset');\n  updateUI();\n});\n\ndocument.getElementById('stepBtn').addEventListener('click', ()=> {\n  stepBFS();\n});\n\ndocument.getElementById('runBtn').addEventListener('click', ()=> {\n  if(state.ui.running){\n    state.ui.running = false;\n    stopTimer();\n  } else {\n    if(!state.bfs.initialized) bfsInitFromUI();\n    state.ui.running = true;\n    state.ui.speed = parseInt(document.getElementById('speedSlider').value) || state.ui.speed;\n    startTimer();\n    document.getElementById('runBtn').textContent = 'Pause (r)';\n  }\n});\n\ndocument.getElementById('fastForward').addEventListener('click', ()=>{\n  if(!state.bfs.initialized) bfsInitFromUI();\n  // run to completion quickly (without long delay)\n  while(state.bfs.queue.length > 0){\n    stepBFS();\n    // guard to avoid infinite loops\n    if(state.bfs.stepCount > 20000) { log('Aborting fast-forward: too many steps'); break; }\n  }\n});\n\ndocument.getElementById('stopBtn').addEventListener('click', ()=>{\n  state.ui.running = false;\n  stopTimer();\n  state.bfs.initialized = false;\n  saveSnapshot('Stopped BFS');\n});\n\ndocument.getElementById('speedSlider').addEventListener('input', (e)=>{\n  state.ui.speed = parseInt(e.target.value);\n  if(state.ui.running) startTimer();\n});\n\ndocument.getElementById('neighborOrder').addEventListener('change', ()=>{\n  document.getElementById('customPreference').disabled = document.getElementById('neighborOrder').value !== 'custom';\n});\n\ndocument.getElementById('stopPolicy').addEventListener('change', ()=>{\n  let v = document.getElementById('stopPolicy').value;\n  document.getElementById('kLabel').style.display = (v==='k') ? 'inline-block' : 'none';\n});\n\ndocument.getElementById('undoBtn').addEventListener('click', ()=>{\n  if(state.historyPos > 0) restoreSnapshot(state.historyPos - 1);\n});\ndocument.getElementById('redoBtn').addEventListener('click', ()=>{\n  if(state.historyPos < state.history.length - 1) restoreSnapshot(state.historyPos + 1);\n});\n\ndocument.getElementById('historyIndex').addEventListener('input', (e)=>{\n  let v = parseInt(e.target.value) || 0;\n  restoreSnapshot(v);\n});\n\n/* Import/Export */\ndocument.getElementById('exportJson').addEventListener('click', ()=>{\n  document.getElementById('jsonArea').value = JSON.stringify(state.graph, null, 2);\n});\ndocument.getElementById('importJsonBtn').addEventListener('click', ()=>{\n  try{\n    let g = JSON.parse(document.getElementById('jsonArea').value);\n    // basic validation\n    if(!g.nodes || !g.edges) throw new Error('Invalid graph JSON');\n    state.graph = g;\n    // build nodes keyed by id if array provided\n    if(Array.isArray(g.nodes)){\n      let nodesObj = {};\n      for(let n of g.nodes) nodesObj[n.id] = n;\n      state.graph.nodes = nodesObj;\n    }\n    saveSnapshot('Imported graph JSON');\n    drawGraph();\n  }catch(err){\n    log('Import failed: ' + err.message);\n  }\n});\n\n/* Random free-mode graph */\ndocument.getElementById('randomGraph').addEventListener('click', ()=>{\n  let n = parseInt(document.getElementById('randNodes').value) || 12;\n  let p = parseFloat(document.getElementById('randEdgeProb').value) || 0.12;\n  state.graph = { nodes: {}, edges: [], directed: state.graph.directed };\n  state.nextNodeId = 0;\n  // pack nodes in grid-ish positions\n  for(let i=0;i<n;i++){\n    addNode(80 + (i%6)*120, 80 + Math.floor(i/6)*100);\n  }\n  let keys = Object.keys(state.graph.nodes);\n  for(let i=0;i<keys.length;i++){\n    for(let j=i+1;j<keys.length;j++){\n      if(Math.random() < p) addEdge(keys[i], keys[j]);\n    }\n  }\n  saveSnapshot('Random graph');\n  drawGraph();\n});\n\n/* Zoom / view */\ndocument.getElementById('zoomIn').addEventListener('click', ()=>{ state.svgScale *= 1.2; svg.setAttribute('viewBox', `0 0 ${1200/state.svgScale} ${800/state.svgScale}`); });\ndocument.getElementById('zoomOut').addEventListener('click', ()=>{ state.svgScale /= 1.2; svg.setAttribute('viewBox', `0 0 ${1200/state.svgScale} ${800/state.svgScale}`); });\ndocument.getElementById('fitView').addEventListener('click', ()=>{ state.svgScale = 1; svg.setAttribute('viewBox','0 0 1200 800'); });\n\n/* Keyboard shortcuts */\ndocument.addEventListener('keydown', (e)=>{\n  if(e.code === 'Space'){ e.preventDefault(); stepBFS(); }\n  else if(e.key.toLowerCase() === 'r'){ e.preventDefault(); document.getElementById('runBtn').click(); }\n  else if(e.key.toLowerCase() === 'f'){ e.preventDefault(); document.getElementById('fastForward').click(); }\n  else if(e.key.toLowerCase() === 's'){ e.preventDefault(); document.getElementById('bfsReset').click(); }\n  else if(e.key.toLowerCase() === 'u'){ document.getElementById('undoBtn').click(); }\n  else if(e.key.toLowerCase() === 'y'){ document.getElementById('redoBtn').click(); }\n});\n\n/* -----------------------------\n   SVG interaction (node creation, selection, drag, edges)\n   ----------------------------- */\n\nsvg.addEventListener('dblclick', (ev)=>{\n  // double click on empty area: add node in free mode\n  if(state.mode !== 'free') return;\n  const pt = svgPoint(ev);\n  let id = addNode(pt.x, pt.y);\n  saveSnapshot('Added node ' + id);\n  drawGraph();\n});\n\nsvg.addEventListener('click', (ev)=>{\n  const target = ev.target;\n  const tool = state.tool;\n  const pt = svgPoint(ev);\n  // find clicked node by traversing up to <g> with data-id\n  let el = target;\n  while(el && el !== svg && !el.dataset.id) el = el.parentNode;\n  if(el && el.dataset && el.dataset.id){\n    let id = el.dataset.id;\n    if(tool === 'select'){\n      state.selection = id;\n      log('Selected ' + id);\n      drawGraph();\n    } else if(tool === 'addnode'){\n      // clicking node does nothing in add node tool\n      // but we can add a node near clicked to place precisely\n      let newId = addNode(pt.x+30, pt.y+30);\n      saveSnapshot('Added node ' + newId);\n      drawGraph();\n    } else if(tool === 'addedge'){\n      // two-click creation\n      if(!state.edgeTempSource){\n        state.edgeTempSource = id;\n        log('Edge source selected: ' + id + ' - now click target');\n      } else {\n        addEdge(state.edgeTempSource, id);\n        log('Added edge ' + state.edgeTempSource + ' -> ' + id);\n        state.edgeTempSource = null;\n        saveSnapshot('Added edge');\n        drawGraph();\n      }\n    } else if(tool === 'toggleObstacle'){\n      state.graph.nodes[id].obstacle = !state.graph.nodes[id].obstacle;\n      saveSnapshot('Toggled obstacle ' + id);\n      drawGraph();\n    } else if(tool === 'setStart'){\n      // clear other starts unless SHIFT held\n      if(!ev.shiftKey){\n        for(let nid in state.graph.nodes) state.graph.nodes[nid].start = false;\n      }\n      state.graph.nodes[id].start = true;\n      document.getElementById('startNodesInput').value = id;\n      saveSnapshot('Set start ' + id);\n      drawGraph();\n    } else if(tool === 'toggleGoal'){\n      state.graph.nodes[id].goal = !state.graph.nodes[id].goal;\n      saveSnapshot('Toggled goal ' + id);\n      drawGraph();\n    }\n    return;\n  } else {\n    // click on empty canvas\n    if(state.mode === 'free' && tool === 'addnode'){\n      let id = addNode(pt.x, pt.y);\n      saveSnapshot('Added node ' + id);\n      drawGraph();\n    }\n    // clear selection if clicked empty\n    state.selection = null;\n    state.edgeTempSource = null;\n    drawGraph();\n  }\n});\n\n/* drag nodes for move */\nlet dragInfo = null;\nsvg.addEventListener('mousedown', (ev)=>{\n  const pt = svgPoint(ev);\n  let el = ev.target;\n  while(el && el !== svg && !el.dataset.id) el = el.parentNode;\n  if(el && el.dataset && el.dataset.id){\n    let id = el.dataset.id;\n    if(state.tool === 'select'){\n      dragInfo = { id:id, startX:pt.x, startY:pt.y, origX: state.graph.nodes[id].x, origY: state.graph.nodes[id].y };\n    }\n  }\n});\nsvg.addEventListener('mousemove', (ev)=>{\n  if(!dragInfo) return;\n  const pt = svgPoint(ev);\n  let dx = pt.x - dragInfo.startX;\n  let dy = pt.y - dragInfo.startY;\n  state.graph.nodes[dragInfo.id].x = dragInfo.origX + dx;\n  state.graph.nodes[dragInfo.id].y = dragInfo.origY + dy;\n  drawGraph();\n});\nsvg.addEventListener('mouseup', (ev)=>{\n  if(dragInfo){\n    saveSnapshot('Moved node ' + dragInfo.id);\n    dragInfo = null;\n  }\n});\n\n/* helper: convert event coords to SVG coords */\nfunction svgPoint(evt){\n  const pt = svg.createSVGPoint();\n  pt.x = evt.clientX;\n  pt.y = evt.clientY;\n  const ctm = svg.getScreenCTM().inverse();\n  const svgP = pt.matrixTransform(ctm);\n  return {x: svgP.x, y: svgP.y};\n}\n\n/* double click on node to delete */\nsvg.addEventListener('dblclick', (e)=> {\n  let el = e.target;\n  while(el && el !== svg && !el.dataset.id) el = el.parentNode;\n  if(el && el.dataset && el.dataset.id){\n    let id = el.dataset.id;\n    removeNode(id);\n    saveSnapshot('Double-click deleted ' + id);\n    drawGraph();\n  }\n});\n\n/* allow removing edges by right-click context menu on edge */\nsvg.addEventListener('contextmenu', (e)=>{\n  e.preventDefault();\n  let el = e.target;\n  if(el && el.tagName === 'line'){\n    let from = el.getAttribute('data-from');\n    let to = el.getAttribute('data-to');\n    removeEdge(from,to);\n    saveSnapshot('Removed edge ' + from + ' -> ' + to);\n    drawGraph();\n  }\n});\n\n/* -----------------------------\n   Additional features: path reconstruction, dynamic continuation\n   ----------------------------- */\n\nfunction reconstructPathTo(goal){\n  if(!state.bfs.parents || !state.bfs.parents) return [];\n  let path = [];\n  let cur = goal;\n  while(cur !== null && cur !== undefined){\n    path.push(cur);\n    cur = state.bfs.parents[cur];\n  }\n  return path.reverse();\n}\n\n/* Helper to highlight shortest path to last found goal if enabled */\nfunction showPathOverlay(){\n  if(!document.getElementById('showPath').checked) return;\n  if(state.bfs.goalsFound.size === 0) return;\n  // pick last found goal\n  let last = Array.from(state.bfs.goalsFound).pop();\n  let path = reconstructPathTo(last);\n  // draw edges overlay for path: draw thick lines\n  for(let i=0;i<path.length-1;i++){\n    let a = state.graph.nodes[path[i]];\n    let b = state.graph.nodes[path[i+1]];\n    if(!a || !b) continue;\n    let line = document.createElementNS(NS,'line');\n    line.setAttribute('x1', a.x);\n    line.setAttribute('y1', a.y);\n    line.setAttribute('x2', b.x);\n    line.setAttribute('y2', b.y);\n    line.setAttribute('stroke', '#000');\n    line.setAttribute('stroke-width', 3);\n    svg.appendChild(line);\n  }\n}\n\n/* wrap drawGraph to include path overlay and parent edge emphasis */\nconst origDrawGraph = drawGraph;\ndrawGraph = function(){\n  clearSVG();\n  const g = state.graph;\n  // edges first\n  for(let e of g.edges){\n    const a = g.nodes[e.from];\n    const b = g.nodes[e.to];\n    if(!a || !b) continue;\n    let line = document.createElementNS(NS,'line');\n    line.setAttribute('x1', a.x);\n    line.setAttribute('y1', a.y);\n    line.setAttribute('x2', b.x);\n    line.setAttribute('y2', b.y);\n    line.setAttribute('stroke', '#000');\n    line.setAttribute('stroke-width', 1.2);\n    line.setAttribute('data-from', e.from);\n    line.setAttribute('data-to', e.to);\n    // emphasize parent edges if requested\n    if(document.getElementById('showParents').checked){\n      if(state.bfs.parents && state.bfs.parents[b.id] === a.id) line.setAttribute('stroke-width', 2.2);\n    }\n    svg.appendChild(line);\n    if(g.directed){\n      let dx = b.x - a.x, dy = b.y - a.y;\n      let len = Math.hypot(dx,dy) || 1;\n      let ux = dx/len, uy = dy/len;\n      let hx = b.x - ux*14, hy = b.y - uy*14;\n      let arrowSize = 8;\n      let p1x = hx - uy*(arrowSize/2), p1y = hy + ux*(arrowSize/2);\n      let p2x = hx + uy*(arrowSize/2), p2y = hy - ux*(arrowSize/2);\n      let poly = document.createElementNS(NS,'polygon');\n      poly.setAttribute('points', `${b.x},${b.y} ${p1x},${p1y} ${p2x},${p2y}`);\n      poly.setAttribute('fill','#fff');\n      poly.setAttribute('stroke','#000');\n      poly.setAttribute('stroke-width','1');\n      svg.appendChild(poly);\n    }\n  }\n  // nodes\n  for(let id in g.nodes){\n    let n = g.nodes[id];\n    let group = document.createElementNS(NS,'g');\n    group.setAttribute('class','node');\n    group.setAttribute('data-id', id);\n    group.setAttribute('transform', `translate(${n.x},${n.y})`);\n    let r = 16;\n    let circ = document.createElementNS(NS,'circle');\n    circ.setAttribute('r', r);\n    circ.setAttribute('cx', 0);\n    circ.setAttribute('cy', 0);\n    circ.setAttribute('stroke', '#000');\n    circ.setAttribute('fill', '#fff');\n    circ.setAttribute('stroke-width', 1.2);\n    group.appendChild(circ);\n    if(n.obstacle){\n      let lx1 = document.createElementNS(NS,'line');\n      lx1.setAttribute('x1', -10); lx1.setAttribute('y1', -10);\n      lx1.setAttribute('x2', 10); lx1.setAttribute('y2', 10);\n      lx1.setAttribute('stroke','#000'); lx1.setAttribute('stroke-width',1.2);\n      group.appendChild(lx1);\n      let lx2 = document.createElementNS(NS,'line');\n      lx2.setAttribute('x1', -10); lx2.setAttribute('y1', 10);\n      lx2.setAttribute('x2', 10); lx2.setAttribute('y2', -10);\n      lx2.setAttribute('stroke','#000'); lx2.setAttribute('stroke-width',1.2);\n      group.appendChild(lx2);\n    }\n    let txt = document.createElementNS(NS,'text');\n    txt.setAttribute('x', 0); txt.setAttribute('y', 4);\n    txt.setAttribute('text-anchor','middle');\n    txt.setAttribute('font-size','11');\n    txt.textContent = id;\n    group.appendChild(txt);\n    if(document.getElementById('showDistances').checked && state.bfs.distance[id] !== undefined){\n      let d = document.createElementNS(NS,'text');\n      d.setAttribute('x', 18); d.setAttribute('y', -18);\n      d.setAttribute('font-size','10');\n      d.textContent = state.bfs.distance[id];\n      group.appendChild(d);\n    }\n    if(document.getElementById('visitOrder').checked && state.bfs.visitOrder[id] !== undefined){\n      let v = document.createElementNS(NS,'text');\n      v.setAttribute('x', -18); v.setAttribute('y', -18);\n      v.setAttribute('font-size','10');\n      v.textContent = state.bfs.visitOrder[id];\n      group.appendChild(v);\n    }\n    if(document.getElementById('showLayers').checked && state.bfs.distance[id] !== undefined){\n      let l = document.createElementNS(NS,'text');\n      l.setAttribute('x', -18); l.setAttribute('y', 18);\n      l.setAttribute('font-size','10');\n      l.textContent = 'L' + state.bfs.distance[id];\n      group.appendChild(l);\n    }\n    if(n.start){\n      let mark = document.createElementNS(NS,'text');\n      mark.setAttribute('x', 0); mark.setAttribute('y', -28);\n      mark.setAttribute('font-size','10');\n      mark.setAttribute('text-anchor','middle');\n      mark.textContent = 'START';\n      group.appendChild(mark);\n    }\n    if(n.goal){\n      let mark = document.createElementNS(NS,'text');\n      mark.setAttribute('x', 0); mark.setAttribute('y', 28);\n      mark.setAttribute('font-size','10');\n      mark.setAttribute('text-anchor','middle');\n      mark.textContent = 'GOAL';\n      group.appendChild(mark);\n    }\n    if(state.bfs.current === id){\n      let mark = document.createElementNS(NS,'text');\n      mark.setAttribute('x', 0); mark.setAttribute('y', -40);\n      mark.setAttribute('font-size','10');\n      mark.setAttribute('text-anchor','middle');\n      mark.textContent = 'CURRENT';\n      group.appendChild(mark);\n    }\n    if(state.selection === id){\n      circ.setAttribute('stroke-width', 2.4);\n    }\n    svg.appendChild(group);\n  }\n\n  // overlay path\n  showPathOverlay();\n\n  // optionally overlay queue text in corner\n  if(document.getElementById('showQueue').checked){\n    let txt = document.createElementNS(NS,'text');\n    txt.setAttribute('x', 10); txt.setAttribute('y', 20);\n    txt.setAttribute('font-size','12');\n    txt.textContent = 'Queue: ' + state.bfs.queue.join(', ');\n    svg.appendChild(txt);\n  }\n};\n\n/* initialize with a starter grid */\ngenerateGrid(6,9,80);\nsaveSnapshot('Initial grid');\ndrawGraph();\nupdateUI();\n\n</script>\n</body>\n</html>"
