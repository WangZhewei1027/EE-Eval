    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ACID Properties Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <h1>ACID Properties Interactive Demonstration</h1>\n    \n    <h2>ACID Definitions</h2>\n    <p>Atomicity, Consistency, Isolation, Durability.</p>\n    \n    <h2>Current State</h2>\n    <div>\n        <p id=\"currentState\">No transactions yet</p>\n    </div>\n    \n    <h2>Begin Transaction</h2>\n    <button id=\"beginTransaction\">Start Transaction</button>\n\n    <h2>Actions</h2>\n    <button id=\"commit\" class=\"hidden\">Commit Transaction</button>\n    <button id=\"rollback\" class=\"hidden\">Rollback Transaction</button>\n\n    <h2>Input Data</h2>\n    <div>\n        <input type=\"text\" id=\"dataInput\" placeholder=\"Enter some data\">\n        <button id=\"addData\" class=\"hidden\">Add Data</button>\n    </div>\n\n    <h2>Data Entries</h2>\n    <div>\n        <ul id=\"dataList\"></ul>\n    </div>\n\n    <h2>Transaction History</h2>\n    <div>\n        <ul id=\"transactionHistory\"></ul>\n    </div>\n\n    <script>\n        let isTransactionActive = false;\n        let dataEntries = [];\n        let transactionHistory = [];\n        \n        document.getElementById('beginTransaction').onclick = function () {\n            isTransactionActive = true;\n            document.getElementById('currentState').innerText = \"Transaction in progress...\";\n            document.getElementById('commit').classList.remove('hidden');\n            document.getElementById('rollback').classList.remove('hidden');\n            document.getElementById('addData').classList.remove('hidden');\n        };\n\n        document.getElementById('commit').onclick = function () {\n            if (!isTransactionActive) return;\n            let data = document.getElementById('dataInput').value;\n            if (data) {\n                dataEntries.push(data);\n                transactionHistory.push(\"Committed: \" + data);\n                document.getElementById('dataInput').value = '';\n            }\n            updateDataList();\n            updateTransactionHistory();\n            finalizeTransaction(\"committed\");\n        };\n\n        document.getElementById('rollback').onclick = function () {\n            if (!isTransactionActive) return;\n            finalizeTransaction(\"rolled back\");\n        };\n\n        document.getElementById('addData').onclick = function () {\n            if (!isTransactionActive) return;\n            let data = document.getElementById('dataInput').value;\n            if (data) {\n                dataEntries.push(data);\n                transactionHistory.push(\"Added: \" + data);\n                document.getElementById('dataInput').value = '';\n                updateDataList();\n                updateTransactionHistory();\n            }\n        };\n\n        function finalizeTransaction(action) {\n            isTransactionActive = false;\n            document.getElementById('currentState').innerText = \"Transaction \" + action + \".\";\n            document.getElementById('commit').classList.add('hidden');\n            document.getElementById('rollback').classList.add('hidden');\n            document.getElementById('addData').classList.add('hidden');\n        }\n\n        function updateDataList() {\n            const list = document.getElementById('dataList');\n            list.innerHTML = '';\n            dataEntries.forEach(entry => {\n                const listItem = document.createElement('li');\n                listItem.innerText = entry;\n                list.appendChild(listItem);\n            });\n        }\n\n        function updateTransactionHistory() {\n            const history = document.getElementById('transactionHistory');\n            history.innerHTML = '';\n            transactionHistory.forEach(entry => {\n                const historyItem = document.createElement('li');\n                historyItem.innerText = entry;\n                history.appendChild(historyItem);\n            });\n        }\n    </script>\n</body>\n</html>"
