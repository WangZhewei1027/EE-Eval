    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Query Optimization — Visualization</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Space+Grotesk:wght@300;400;600&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #071021;\n      --bg-2: #0b1830;\n      --glass: rgba(255,255,255,0.04);\n      --accent: #6EE7B7;\n      --accent-2: #6CC0FF;\n      --muted: rgba(255,255,255,0.55);\n      --danger: #FF6B6B;\n      --card: rgba(255,255,255,0.03);\n      --glass-2: rgba(255,255,255,0.02);\n      --gold: #FFD166;\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%;margin:0;font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n    body{\n      background: radial-gradient(800px 400px at 10% 15%, rgba(108,192,255,0.06), transparent 6%),\n                  radial-gradient(700px 500px at 90% 80%, rgba(110,231,183,0.04), transparent 8%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color: #E6F0FF;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    .stage{\n      height:100vh;\n      display:flex;\n      gap:28px;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n      position:relative;\n    }\n\n    /* Top-left badge */\n    .badge{\n      position:absolute;\n      left:48px;\n      top:36px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));\n      border-radius:14px;\n      padding:10px 14px;\n      box-shadow: 0 6px 30px rgba(2,6,23,0.6);\n      backdrop-filter: blur(8px);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n    .logo{\n      height:40px;\n      width:40px;\n      border-radius:10px;\n      background: linear-gradient(135deg,var(--accent),var(--accent-2));\n      display:flex;align-items:center;justify-content:center;\n      font-weight:800;color:#04202B;font-family:Space Grotesk;\n      box-shadow: 0 6px 20px rgba(102,204,255,0.08), inset 0 -6px 10px rgba(255,255,255,0.08);\n    }\n    .badge h4{margin:0;font-weight:700;font-family:Space Grotesk;font-size:14px}\n    .badge p{margin:0;font-size:12px;color:var(--muted)}\n\n    /* Control buttons */\n    .controls{\n      position:absolute;\n      right:48px;\n      top:36px;\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n    .btn{\n      appearance:none;\n      border:0;\n      padding:10px 16px;\n      border-radius:12px;\n      font-weight:600;\n      cursor:pointer;\n      box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n      transition:transform .18s ease, box-shadow .18s ease, opacity .18s;\n      color: #04202B;\n      font-family:Space Grotesk;\n      letter-spacing:0.4px;\n      font-size:13px;\n    }\n    .btn:active{transform:translateY(1px)}\n    .btn:disabled{opacity:.5;cursor:default;transform:none}\n    .btn-primary{\n      background: linear-gradient(90deg,var(--accent),var(--accent-2));\n      border: 1px solid rgba(255,255,255,0.06);\n      box-shadow: 0 10px 30px rgba(108,192,255,0.12);\n    }\n    .btn-ghost{\n      background:transparent;\n      color:var(--muted);\n      border: 1px solid rgba(255,255,255,0.04);\n      padding:10px 14px;\n      font-weight:600;\n    }\n\n    /* Left card: title & query */\n    .left{\n      width:360px;\n      min-width:320px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      padding:28px;\n      box-shadow: 0 18px 60px rgba(3,10,25,0.6);\n      border:1px solid rgba(255,255,255,0.03);\n      backdrop-filter: blur(8px);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-self:stretch;\n    }\n    .title{\n      display:flex;flex-direction:column;gap:6px;\n    }\n    .title h1{\n      margin:0;font-family:Space Grotesk;font-weight:700;font-size:20px;\n      letter-spacing:-0.4px;\n    }\n    .title p{margin:0;color:var(--muted);font-size:13px}\n\n    .sqlcard{\n      margin-top:6px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border-radius:12px;\n      padding:14px;\n      font-family:JetBrains Mono, monospace;\n      color:#D8F7FF;\n      font-size:13px;\n      line-height:1.45;\n      border: 1px solid rgba(255,255,255,0.02);\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n    .sqlcard .muted{color:rgba(255,255,255,0.36); font-weight:500;}\n    .meta{\n      display:flex;gap:10px;align-items:center;margin-top:10px;\n      color:var(--muted);font-size:13px;\n    }\n\n    .stat{\n      margin-top:auto;\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:12px;border-radius:12px;border:1px solid rgba(255,255,255,0.02);\n      display:flex;align-items:center;justify-content:space-between;\n    }\n    .stat .cost{\n      font-weight:700;font-size:20px;font-family:Space Grotesk;color:var(--gold);\n    }\n    .stat .desc{font-size:13px;color:var(--muted)}\n\n    /* Visualization area */\n    .vis{\n      flex:1;\n      height:78vh;\n      min-height:540px;\n      border-radius:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      box-shadow: 0 28px 80px rgba(3,10,25,0.6);\n      border:1px solid rgba(255,255,255,0.03);\n      padding:28px;\n      position:relative;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      overflow:hidden;\n    }\n\n    /* SVG canvas */\n    svg{\n      width:100%;\n      height:100%;\n      overflow:visible;\n    }\n\n    .node{\n      filter: drop-shadow(0 8px 30px rgba(0,0,0,0.55));\n      transition:transform .7s cubic-bezier(.22,.9,.12,1), opacity .5s;\n    }\n\n    .card-node{\n      fill: url(#nodeGrad);\n      stroke: rgba(255,255,255,0.05);\n      stroke-width:1;\n      rx:12;\n    }\n    .small{\n      font-size:12px;fill:#E9F8FF;font-family:JetBrains Mono;font-weight:600;\n    }\n    .label{\n      font-family:Space Grotesk;font-weight:700;fill:#04202B;font-size:12px;\n    }\n\n    .op{\n      fill: linear-gradient(180deg,#fff,#fff);\n    }\n\n    .link{\n      stroke:rgba(255,255,255,0.08);\n      stroke-width:2.2;\n      fill:none;\n      transition:stroke-width .4s ease, stroke .4s ease, opacity .4s ease;\n    }\n\n    .cost-bubble{\n      font-family:JetBrains Mono;font-size:12px;font-weight:700;\n      fill:#04202B;\n    }\n\n    /* small floating badges */\n    .badge-floating{\n      position:absolute;\n      right:48px;\n      bottom:48px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .mini{\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;padding:8px 12px;border:1px solid rgba(255,255,255,0.03);\n      color:var(--muted);font-weight:600;font-size:13px;\n      display:flex;gap:10px;align-items:center;\n      box-shadow: 0 12px 30px rgba(2,6,23,0.5);\n    }\n\n    /* subtle animated sparkles */\n    .sparkle{\n      position:absolute;\n      pointer-events:none;\n      filter: blur(6px);\n      opacity:0.0;\n      transition:opacity .6s ease;\n    }\n\n    /* responsive tweak */\n    @media (max-width:1000px){\n      .left{display:none}\n      .stage{padding:28px}\n      .badge{left:18px;top:18px}\n      .controls{right:18px;top:18px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\">\n    <div class=\"badge\" aria-hidden>\n      <div class=\"logo\">Q</div>\n      <div>\n        <h4>Query Optimization</h4>\n        <p>Execution plan refinement • Cost-based tuning</p>\n      </div>\n    </div>\n\n    <div class=\"controls\" role=\"region\" aria-label=\"Controls\">\n      <button id=\"optimizeBtn\" class=\"btn btn-primary\">Optimize</button>\n      <button id=\"resetBtn\" class=\"btn btn-ghost\">Reset</button>\n    </div>\n\n    <div class=\"left\" aria-hidden>\n      <div class=\"title\">\n        <h1>Optimizing a JOIN-heavy query</h1>\n        <p>Observe how the optimizer rewrites the plan, reorders joins, and uses indexes to reduce cost.</p>\n      </div>\n\n      <div class=\"sqlcard\" aria-hidden>\n        <div><span class=\"muted\">-- Original SQL</span></div>\n        <div style=\"margin-top:8px;color:#E3F8FF\">\n          SELECT o.order_id, c.customer_name, SUM(i.amount) total\n        </div>\n        <div style=\"margin-top:6px;color:#BFEFFF\">FROM orders o</div>\n        <div style=\"margin-top:3px;color:#BFEFFF\">JOIN customers c ON o.customer_id = c.id</div>\n        <div style=\"margin-top:3px;color:#BFEFFF\">JOIN items i ON i.order_id = o.order_id</div>\n        <div style=\"margin-top:6px;color:#9EE7FF\">WHERE o.created_at &gt; '2025-01-01'</div>\n        <div style=\"margin-top:6px;color:#D6EEFF\">GROUP BY o.order_id, c.customer_name</div>\n      </div>\n\n      <div class=\"meta\">\n        <div style=\"display:flex;flex-direction:column\">\n          <div style=\"font-weight:700\">Cost before</div>\n          <div style=\"color:var(--muted);font-size:13px\">High I/O & CPU</div>\n        </div>\n        <div style=\"width:8px;height:8px;border-radius:50%;background:var(--danger);margin-left:auto\"></div>\n      </div>\n\n      <div class=\"stat\" aria-hidden>\n        <div>\n          <div class=\"desc\">Estimated Cost</div>\n          <div class=\"cost\" id=\"costValue\">213.74</div>\n        </div>\n        <div style=\"text-align:right\">\n          <div class=\"desc\">Plan Complexity</div>\n          <div style=\"font-weight:700;font-family:Space Grotesk;color:var(--accent)\">4 nodes</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"vis\" role=\"img\" aria-label=\"Query plan visualization\">\n      <!-- Decorative sparkles -->\n      <svg class=\"sparkle\" width=\"220\" height=\"220\" style=\"right:32px;top:20px;opacity:.45\" viewBox=\"0 0 220 220\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <radialGradient id=\"g1\"><stop offset=\"0%\" stop-color=\"#6EE7B7\"/><stop offset=\"100%\" stop-color=\"#6CC0FF\" stop-opacity=\"0\"/></radialGradient>\n        </defs>\n        <circle cx=\"40\" cy=\"40\" r=\"6\" fill=\"url(#g1)\" />\n        <circle cx=\"120\" cy=\"70\" r=\"10\" fill=\"url(#g1)\" />\n        <circle cx=\"190\" cy=\"30\" r=\"5\" fill=\"url(#g1)\" />\n      </svg>\n\n      <!-- Main SVG Canvas -->\n      <svg id=\"canvas\" viewBox=\"0 0 1100 700\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"nodeGrad\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#0EA5A4\" stop-opacity=\"0.90\"/>\n            <stop offset=\"100%\" stop-color=\"#6CC0FF\" stop-opacity=\"0.95\"/>\n          </linearGradient>\n          <linearGradient id=\"bgGlow\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#6EE7B7\" stop-opacity=\"0.18\"/>\n            <stop offset=\"100%\" stop-color=\"#6CC0FF\" stop-opacity=\"0.12\"/>\n          </linearGradient>\n          <filter id=\"softGlow\">\n            <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n            <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n        </defs>\n\n        <!-- Background soft shapes -->\n        <rect x=\"0\" y=\"0\" width=\"1100\" height=\"700\" rx=\"18\" fill=\"url(#bgGlow)\" opacity=\"0.06\" />\n\n        <!-- Tables on left -->\n        <g id=\"tables\">\n          <g id=\"table_orders\" class=\"node\" transform=\"translate(70,120)\">\n            <rect class=\"card-node\" width=\"160\" height=\"60\" rx=\"10\"></rect>\n            <text x=\"18\" y=\"28\" class=\"small\" fill=\"#04202B\">orders</text>\n            <text x=\"18\" y=\"46\" class=\"small\" fill=\"#08324A\" style=\"font-size:11px;opacity:0.85\">rows: 1.2M • pk: order_id</text>\n          </g>\n\n          <g id=\"table_customers\" class=\"node\" transform=\"translate(70,260)\">\n            <rect class=\"card-node\" width=\"160\" height=\"60\" rx=\"10\"></rect>\n            <text x=\"18\" y=\"28\" class=\"small\" fill=\"#04202B\">customers</text>\n            <text x=\"18\" y=\"46\" class=\"small\" fill=\"#08324A\" style=\"font-size:11px;opacity:0.85\">rows: 120k • pk: id</text>\n          </g>\n\n          <g id=\"table_items\" class=\"node\" transform=\"translate(70,400)\">\n            <rect class=\"card-node\" width=\"160\" height=\"60\" rx=\"10\"></rect>\n            <text x=\"18\" y=\"28\" class=\"small\" fill=\"#04202B\">items</text>\n            <text x=\"18\" y=\"46\" class=\"small\" fill=\"#08324A\" style=\"font-size:11px;opacity:0.85\">rows: 3.8M • idx: order_id</text>\n          </g>\n        </g>\n\n        <!-- Initial messy plan group (right center) -->\n        <g id=\"planGroup\">\n          <!-- links (initial) -->\n          <path id=\"link_o_i\" class=\"link\" d=\"M230,420 C360,420 470,360 530,360\" stroke=\"#FF8A6B\" stroke-linecap=\"round\" opacity=\"1\"></path>\n          <path id=\"link_o_c\" class=\"link\" d=\"M230,220 C360,220 470,260 530,260\" stroke=\"#FF8A6B\" stroke-linecap=\"round\" opacity=\"1\"></path>\n\n          <!-- Nodes -->\n          <g id=\"op_items\" class=\"node\" transform=\"translate(540,340)\">\n            <circle r=\"34\" fill=\"#FFB4A2\" opacity=\"0.98\"></circle>\n            <text x=\"-22\" y=\"6\" class=\"label\" fill=\"#4A0C05\">SCAN</text>\n            <text x=\"-22\" y=\"22\" class=\"small\" fill=\"#4A0C05\" style=\"font-size:11px\">items</text>\n            <rect x=\"-30\" y=\"-38\" width=\"60\" height=\"10\" rx=\"4\" fill=\"#FF6B6B\" opacity=\"0.12\"></rect>\n          </g>\n\n          <g id=\"op_customers\" class=\"node\" transform=\"translate(540,240)\">\n            <circle r=\"34\" fill=\"#FFB4A2\"></circle>\n            <text x=\"-28\" y=\"6\" class=\"label\" fill=\"#4A0C05\">SEQ</text>\n            <text x=\"-28\" y=\"22\" class=\"small\" fill=\"#4A0C05\" style=\"font-size:11px\">customers</text>\n          </g>\n\n          <g id=\"joinA\" class=\"node\" transform=\"translate(700,300)\">\n            <rect width=\"140\" height=\"64\" x=\"-70\" y=\"-32\" rx=\"12\" fill=\"#FFD7C4\" stroke=\"rgba(255,255,255,0.04)\"></rect>\n            <text x=\"-50\" y=\"-2\" class=\"label\" style=\"font-size:14px\" fill=\"#3C1C07\">HASH JOIN</text>\n            <text x=\"-50\" y=\"18\" class=\"small\" style=\"fill:#7A3A2B;font-size:12px\">Cost: 143.4</text>\n          </g>\n\n          <g id=\"joinB\" class=\"node\" transform=\"translate(880,300)\">\n            <rect width=\"160\" height=\"72\" x=\"-80\" y=\"-36\" rx=\"14\" fill=\"#FFD1D1\" stroke=\"rgba(255,255,255,0.04)\"></rect>\n            <text x=\"-58\" y=\"-2\" class=\"label\" style=\"font-size:14px\" fill=\"#4E0E0E\">MERGE JOIN</text>\n            <text x=\"-58\" y=\"20\" class=\"small\" style=\"fill:#8E2F2F;font-size:12px\">Cost: 70.3</text>\n          </g>\n\n          <!-- final root -->\n          <g id=\"root\" class=\"node\" transform=\"translate(920,430)\">\n            <rect width=\"220\" height=\"80\" x=\"-110\" y=\"-40\" rx=\"16\" fill=\"#FFF3C4\" stroke=\"rgba(255,255,255,0.04)\"></rect>\n            <text x=\"-88\" y=\"-2\" class=\"label\" style=\"font-size:16px;color:#4A2B00\">AGGREGATE (GROUP)</text>\n            <text id=\"rootCost\" x=\"-88\" y=\"18\" class=\"small\" style=\"fill:#6B4F00;font-size:12px\">Total Cost: 213.74</text>\n          </g>\n        </g>\n\n        <!-- Optimized nodes (hidden initially) -->\n        <g id=\"optGroup\" opacity=\"0\">\n          <!-- links (optimized) -->\n          <path id=\"op_link_items\" class=\"link\" d=\"M240,420 C360,420 480,460 640,460\" stroke=\"#6EE7B7\" stroke-linecap=\"round\" opacity=\"0.0\"></path>\n          <path id=\"op_link_customers\" class=\"link\" d=\"M240,260 C360,260 480,300 640,300\" stroke=\"#6EE7B7\" stroke-linecap=\"round\" opacity=\"0.0\"></path>\n\n          <!-- Index seek nodes -->\n          <g id=\"op_items_seek\" class=\"node\" transform=\"translate(640,460)\">\n            <circle r=\"34\" fill=\"#7EE7C1\"></circle>\n            <text x=\"-28\" y=\"6\" class=\"label\" fill=\"#032427\">IDX</text>\n            <text x=\"-28\" y=\"22\" class=\"small\" fill=\"#032427\" style=\"font-size:11px\">items.order_id</text>\n            <g transform=\"translate(-8,-28)\"><rect x=\"-18\" y=\"-6\" width=\"36\" height=\"12\" rx=\"6\" fill=\"#04202B\" opacity=\"0.06\"></rect></g>\n          </g>\n\n          <g id=\"op_customers_seek\" class=\"node\" transform=\"translate(640,300)\">\n            <circle r=\"34\" fill=\"#7EE7C1\"></circle>\n            <text x=\"-34\" y=\"6\" class=\"label\" fill=\"#032427\">IDX</text>\n            <text x=\"-34\" y=\"22\" class=\"small\" fill=\"#032427\" style=\"font-size:11px\">customers.id</text>\n          </g>\n\n          <g id=\"joinOptA\" class=\"node\" transform=\"translate(800,380)\">\n            <rect width=\"160\" height=\"64\" x=\"-80\" y=\"-32\" rx=\"12\" fill=\"#DDF7EE\" stroke=\"rgba(255,255,255,0.04)\"></rect>\n            <text x=\"-60\" y=\"-2\" class=\"label\" style=\"font-size:14px;color:#014036\">INDEX MERGE</text>\n            <text x=\"-60\" y=\"18\" class=\"small\" style=\"fill:#0D3F33;font-size:12px\">Cost: 35.6</text>\n          </g>\n\n          <g id=\"rootOpt\" class=\"node\" transform=\"translate(900,470)\">\n            <rect width=\"200\" height=\"72\" x=\"-100\" y=\"-36\" rx=\"16\" fill=\"#E6FFF7\" stroke=\"rgba(255,255,255,0.04)\"></rect>\n            <text x=\"-82\" y=\"-2\" class=\"label\" style=\"font-size:16px;color:#022B24\">AGGREGATE (GROUP)</text>\n            <text id=\"rootOptCost\" x=\"-82\" y=\"18\" class=\"small\" style=\"fill:#0B3C33;font-size:12px\">Total Cost: 42.13</text>\n          </g>\n        </g>\n\n        <!-- animated cost ribbon -->\n        <g id=\"ribbon\" transform=\"translate(200,30)\">\n          <rect x=\"-12\" y=\"-8\" width=\"360\" height=\"56\" rx=\"12\" fill=\"rgba(255,255,255,0.02)\"></rect>\n          <text x=\"8\" y=\"18\" class=\"small\" style=\"fill:#BFEFFF;font-size:12px\">Optimizer actions:</text>\n          <text id=\"actionText\" x=\"8\" y=\"38\" class=\"label\" style=\"font-size:14px;fill:#A8F3E0\">Analyzing statistics • Rewriting joins</text>\n        </g>\n      </svg>\n\n      <div class=\"badge-floating\" aria-hidden>\n        <div class=\"mini\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" style=\"margin-right:6px\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"#6EE7B7\" /></svg>Cost ↓</div>\n        <div class=\"mini\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" style=\"margin-right:6px\"><rect x=\"3\" y=\"6\" width=\"18\" height=\"12\" rx=\"2\" fill=\"#6CC0FF\"/></svg>Index usage ↑</div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Extremely limited interactivity: Optimize and Reset buttons control a single animation sequence.\n    (function(){\n      const optimizeBtn = document.getElementById('optimizeBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const optGroup = document.getElementById('optGroup');\n      const planGroup = document.getElementById('planGroup');\n      const rootCost = document.getElementById('rootCost');\n      const rootOptCost = document.getElementById('rootOptCost');\n      const actionText = document.getElementById('actionText');\n      const costValue = document.getElementById('costValue');\n\n      let animating = false;\n\n      function setInitial() {\n        // show initial\n        planGroup.style.opacity = 1;\n        planGroup.style.transform = 'translateX(0)';\n        optGroup.style.opacity = 0;\n        optGroup.style.transform = 'translateX(0)';\n        // reset nodes visible styles\n        document.getElementById('link_o_i').style.stroke = '#FF8A6B';\n        document.getElementById('link_o_c').style.stroke = '#FF8A6B';\n        document.getElementById('link_o_i').style.opacity = 1;\n        document.getElementById('link_o_c').style.opacity = 1;\n        document.getElementById('op_items').style.opacity = 1;\n        document.getElementById('op_customers').style.opacity = 1;\n        document.getElementById('joinA').style.opacity = 1;\n        document.getElementById('joinB').style.opacity = 1;\n        document.getElementById('root').style.opacity = 1;\n\n        // hide optimized\n        optGroup.querySelectorAll('.node, .link').forEach(n=>n.style.opacity=0);\n        optGroup.style.pointerEvents = 'none';\n\n        // set cost values\n        rootCost.textContent = 'Total Cost: 213.74';\n        rootOptCost.textContent = 'Total Cost: 42.13';\n        costValue.textContent = '213.74';\n        actionText.textContent = 'Analyzing statistics • Rewriting joins';\n      }\n\n      function easeOut(t){ return 1 - Math.pow(1 - t, 3); }\n      function lerp(a,b,t){ return a + (b-a)*t; }\n\n      // Simple timeline steps using setTimeout for clarity (keeps interactions extremely limited).\n      function runOptimization() {\n        if (animating) return;\n        animating = true;\n        optimizeBtn.disabled = true;\n        resetBtn.disabled = true;\n        let timeline = [];\n\n        // Step 1: Analyze statistics\n        timeline.push({delay: 0, func: ()=> {\n          actionText.textContent = 'Analyzing statistics • Estimating cardinalities';\n          // gentle glow on ribbon\n          document.getElementById('ribbon').animate([{opacity:0.8},{opacity:1}],{duration:900,iterations:2,direction:'alternate'});\n        }});\n\n        // Step 2: Highlight expensive scan\n        timeline.push({delay: 900, func: ()=> {\n          actionText.textContent = 'Identified heavy SEQ SCAN on items';\n          const n = document.getElementById('op_items');\n          n.animate([{transform:'scale(1)'},{transform:'scale(1.06)'}],{duration:700,fill:'forwards',easing:'ease-out'});\n          // pulse link color\n          document.getElementById('link_o_i').animate([{stroke:'#FF8A6B'},{stroke:'#FFD1B4'}],{duration:700,iterations:2,direction:'alternate'});\n        }});\n\n        // Step 3: Probe indexes suggestion\n        timeline.push({delay: 1800, func: ()=> {\n          actionText.textContent = 'Suggest using index on items.order_id';\n          // reveal optGroup nodes gradually\n          optGroup.style.opacity = 1;\n          const seq = [\n            {selector:'#op_items_seek', delay:0},\n            {selector:'#op_customers_seek', delay:200},\n            {selector:'#joinOptA', delay:420},\n            {selector:'#rootOpt', delay:620}\n          ];\n          seq.forEach(s =>{\n            setTimeout(()=> {\n              const el = document.querySelector(s.selector);\n              if (el) {\n                el.style.opacity = 1;\n                el.animate([{transform:'translateY(8px) scale(.96)', opacity:0},{transform:'translateY(0px) scale(1)', opacity:1}],{duration:640,easing:'cubic-bezier(.22,.9,.12,1)',fill:'forwards'});\n              }\n            }, s.delay);\n          });\n          // fade initial problematic links\n          document.getElementById('link_o_i').animate([{opacity:1},{opacity:0.08}],{duration:700,fill:'forwards'});\n          document.getElementById('link_o_c').animate([{opacity:1},{opacity:0.08}],{duration:700,fill:'forwards'});\n        }});\n\n        // Step 4: Replace plan visuals -> animate join reorder\n        timeline.push({delay: 2600, func: ()=> {\n          actionText.textContent = 'Rewriting joins • Reordering for selective index seeks';\n          // fade out old join nodes\n          ['joinA','joinB','op_items','op_customers','root'].forEach(id=>{\n            const el = document.getElementById(id);\n            if (el) {\n              el.animate([{opacity:1, transform:'translateY(0px)'},{opacity:0, transform:'translateY(-12px)'}],{duration:700,easing:'ease-out',fill:'forwards'});\n              setTimeout(()=> el.style.opacity = 0, 700);\n            }\n          });\n          // bring optimized links alive\n          const l1 = document.getElementById('op_link_items');\n          const l2 = document.getElementById('op_link_customers');\n          [l1,l2].forEach(l=>{\n            l.style.opacity = 1;\n            l.animate([{opacity:0},{opacity:1}],{duration:800,fill:'forwards'});\n          });\n        }});\n\n        // Step 5: Cost descent animation\n        timeline.push({delay: 3400, func: ()=> {\n          actionText.textContent = 'Estimating new cost • Applying plan';\n          animateCost(213.74, 42.13, 1400);\n        }});\n\n        // Step 6: Celebration sparkle & final message\n        timeline.push({delay: 5000, func: ()=> {\n          actionText.textContent = 'Optimized • Lower I/O and CPU usage';\n          showSparkles();\n          optimizeBtn.disabled = false;\n          resetBtn.disabled = false;\n          animating = false;\n        }});\n\n        // execute timeline\n        let t = 0;\n        timeline.forEach(step => {\n          t += step.delay;\n          setTimeout(step.func, t);\n        });\n      }\n\n      function animateCost(from, to, duration) {\n        const start = performance.now();\n        function frame(now){\n          const elapsed = now - start;\n          const t = Math.min(1, elapsed / duration);\n          const v = lerp(from, to, easeOut(t));\n          costValue.textContent = v.toFixed(2);\n          // subtle animate rootOpt label numeric fill\n          rootCost.style.opacity = 0.2 + (1 - t) * 0.8;\n          rootOptCost.style.opacity = 0.2 + t * 0.8;\n          if (t < 1) requestAnimationFrame(frame);\n          else {\n            costValue.textContent = to.toFixed(2);\n            // finalize visuals: hide old plan and show optimized group\n            planGroup.style.opacity = 0;\n            optGroup.style.opacity = 1;\n            document.getElementById('op_items_seek').style.opacity = 1;\n          }\n        }\n        requestAnimationFrame(frame);\n      }\n\n      function showSparkles(){\n        // simple DOM-level sparkle: create floating circles that fade\n        const cnt = 8;\n        for (let i=0;i<cnt;i++){\n          const s = document.createElement('div');\n          Object.assign(s.style,{\n            position:'absolute',width:'8px',height:'8px',borderRadius:'50%',\n            background: i%2? 'rgba(110,231,183,0.9)':'rgba(108,192,255,0.9)',\n            right: (40 + Math.random()*220)+'px',\n            top: (40 + Math.random()*200)+'px',\n            opacity:0, pointerEvents:'none', transform:'translateY(0px) scale(.6)'\n          });\n          document.querySelector('.vis').appendChild(s);\n          setTimeout(()=> {\n            s.style.transition = 'transform 900ms cubic-bezier(.22,.9,.12,1), opacity 900ms ease';\n            s.style.opacity = 1;\n            s.style.transform = 'translateY(-26px) scale(1.3)';\n          }, 40 + i*80);\n          setTimeout(()=> {\n            s.style.opacity = 0;\n            s.style.transform = 'translateY(-60px) scale(.2)';\n          }, 900 + i*90);\n          setTimeout(()=> s.remove(), 1800 + i*90);\n        }\n      }\n\n      // Wire up buttons\n      optimizeBtn.addEventListener('click', runOptimization);\n      resetBtn.addEventListener('click', ()=>{\n        if (animating) return;\n        setInitial();\n      });\n\n      // initial state\n      setInitial();\n    })();\n  </script>\n</body>\n</html>"
  },
