    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>P vs NP</title>\n    <style>\n        body {\n            background-color: #fff;\n            font-family: Arial, sans-serif;\n        }\n        #controls {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"text\"], input[type=\"number\"] {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ccc;\n        }\n        button {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n        #complex {\n            display: none;\n        }\n        #simple {\n            display: block;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"controls\">\n        <h2>P vs NP</h2>\n        <label>Problem:</label>\n        <input type=\"text\" id=\"problem\" placeholder=\"Enter problem name\">\n        <button id=\"solve-btn\">Solve</button>\n        <label>Solution:</label>\n        <input type=\"text\" id=\"solution\" placeholder=\"Enter solution name\">\n        <button id=\"view-btn\">View</button>\n        <button id=\"complex-btn\">Complex</button>\n        <button id=\"simple-btn\">Simple</button>\n        <div id=\"complex\" class=\"hidden\"></div>\n        <div id=\"simple\" class=\"hidden\"></div>\n    </div>\n\n    <script>\n        let problem = \"Traveling Salesman Problem\";\n        let solution = \" brute-force\";\n        let solutionText = document.getElementById(\"solution\");\n        let complexDiv = document.getElementById(\"complex\");\n        let simpleDiv = document.getElementById(\"simple\");\n\n        // Solve button click handler\n        document.getElementById(\"solve-btn\").addEventListener(\"click\", () => {\n            // Get input values\n            const problemName = document.getElementById(\"problem\").value.trim();\n            const solutionName = document.getElementById(\"solution\").value.trim();\n\n            // Check if input values are correct\n            if (problemName === \"\" || solutionName === \"\") {\n                alert(\"Please enter a problem name and a solution name.\");\n                return;\n            }\n\n            // Display solution\n            solutionText.textContent = solution;\n            solutionText.style.display = \"block\";\n\n            // Display complex solution\n            complexDiv.style.display = \"block\";\n            complexDiv.innerHTML = `<h2>Complex Solution:</h2><p>${problemName} is a ${problem} problem. The solution is a brute-force algorithm.</p>`;\n        });\n\n        // View button click handler\n        document.getElementById(\"view-btn\").addEventListener(\"click\", () => {\n            // Display solution\n            solutionText.textContent = solution;\n            solutionText.style.display = \"block\";\n\n            // Display simple solution\n            simpleDiv.style.display = \"block\";\n            simpleDiv.innerHTML = `<h2>Simple Solution:</h2><p>${problemName} is a ${problem} problem. The simple solution is ${solution}.`;\n        });\n\n        // Complex button click handler\n        document.getElementById(\"complex-btn\").addEventListener(\"click\", () => {\n            // Display complex solution\n            complexDiv.style.display = \"block\";\n            complexDiv.innerHTML = `<h2>Complex Solution:</h2><p>${problemName} is a ${problem} problem. The complex solution is a brute-force algorithm.</p>`;\n        });\n\n        // Simple button click handler\n        document.getElementById(\"simple-btn\").addEventListener(\"click\", () => {\n            // Display simple solution\n            simpleDiv.style.display = \"block\";\n            simpleDiv.innerHTML = `<h2>Simple Solution:</h2><p>${problemName} is a ${problem} problem. The simple solution is ${solution}.`;\n        });\n    </script>\n</body>\n</html>"
