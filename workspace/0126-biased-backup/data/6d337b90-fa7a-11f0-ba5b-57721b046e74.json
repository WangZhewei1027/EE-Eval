    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Asymmetric Cryptography Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .section {\n            margin-bottom: 30px;\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        .control-group {\n            margin: 10px 0;\n        }\n        button, select, input {\n            margin: 5px;\n            padding: 5px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n            font-family: monospace;\n        }\n        .key-display {\n            font-family: monospace;\n            word-break: break-all;\n            background-color: #f5f5f5;\n            padding: 10px;\n            margin: 1px 0;\n        }\n        .hidden {\n            display: none;\n        }\n        .step {\n            margin-bottom: 15px;\n        }\n        .status {\n            font-weight: bold;\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Asymmetric Cryptography Interactive Demo</h1>\n    \n    <div class=\"section\">\n        <h2>1. Key Generation</h2>\n        <div class=\"control-group\">\n            <label>Algorithm:</label>\n            <select id=\"algorithm\">\n                <option value=\"RSA\">RSA (2048-bit)</option>\n                <option value=\"ECC\">ECC (P-256)</option>\n            </select>\n            <button id=\"generateKeys\">Generate Key Pair</button>\n        </div>\n        \n        <div id=\"keyPairSection\" class=\"hidden\">\n            <div class=\"step\">\n                <h3>Public Key</h3>\n                <div id=\"publicKey\" class=\"key-display\"></div>\n                <button id=\"copyPublicKey\">Copy Public Key</button>\n            </div>\n            \n            <div class=\"step\">\n                <h3>Private Key</h3>\n                <div id=\"privateKey\" class=\"key-display\"></div>\n                <button id=\"copyPrivateKey\">Copy Private Key</button>\n                <button id=\"showPrivateKey\">Show Private Key</button>\n                <button id=\"hidePrivateKey\" class=\"hidden\">Hide Private Key</button>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>2. Encryption</h2>\n        <div class=\"control-group\">\n            <label>Message to encrypt:</label>\n            <textarea id=\"messageToEncrypt\"></textarea>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Use key:</label>\n            <select id=\"encryptKeyType\">\n                <option value=\"public\">Public Key (for encryption)</option>\n                <option value=\"private\">Private Key (for signing)</option>\n            </select>\n            <button id=\"encryptButton\">Encrypt/Sign</button>\n        </div>\n        \n        <div id=\"encryptedResultSection\" class=\"hidden\">\n            <h3>Encrypted/Signed Result</h3>\n            <div id=\"encryptedResult\" class=\"key-display\"></div>\n            <button id=\"copyEncrypted\">Copy Result</button>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>3. Decryption/Verification</h2>\n        <div class=\"control-group\">\n            <label>Encrypted message or signature:</label>\n            <textarea id=\"messageToDecrypt\"></textarea>\n        </div>\n        \n        <div class=\"control-group\">\n            <label>Use key:</label>\n            <select id=\"decryptKeyType\">\n                <option value=\"private\">Private Key (for decryption)</option>\n                <option value=\"public\">Public Key (for verification)</option>\n            </select>\n            <button id=\"decryptButton\">Decrypt/Verify</button>\n        </div>\n        \n        <div id=\"decryptedResultSection\" class=\"hidden\">\n            <h3>Decrypted/Verified Result</h3>\n            <div id=\"decryptedResult\" class=\"key-display\"></div>\n            <div id=\"verificationStatus\" class=\"status\"></div>\n            <button id=\"copyDecrypted\">Copy Result</button>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>4. Key Exchange Simulation</h2>\n        <div class=\"control-group\">\n            <button id=\"setupKeyExchange\">Setup Key Exchange (Alice and Bob)</button>\n        </div>\n        \n        <div id=\"keyExchangeSection\" class=\"hidden\">\n            <div class=\"step\">\n                <h3>Alice's Keys</h3>\n                <div>Public Key: <span id=\"alicePublicKey\" class=\"key-display\"></span></div>\n                <div>Private Key: <span id=\"alicePrivateKey\" class=\"key-display hidden\"></span></div>\n            </div>\n            \n            <div class=\"step\">\n                <h3>Bob's Keys</h3>\n                <div>Public Key: <span id=\"bobPublicKey\" class=\"key-display\"></span></div>\n                <div>Private Key: <span id=\"bobPrivateKey\" class=\"key-display hidden\"></span></div>\n            </div>\n            \n            <div class=\"step\">\n                <h3>Shared Secret Generation</h3>\n                <button id=\"aliceComputeShared\">Alice Compute Shared Secret</button>\n                <button id=\"bobComputeShared\">Bob Compute Shared Secret</button>\n                <div id=\"aliceSharedSecret\" class=\"key-display hidden\"></div>\n                <div id=\"bobSharedSecret\" class=\"key-display hidden\"></div>\n                <div id=\"sharedSecretMatch\" class=\"status\"></div>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"section\">\n        <h2>5. Digital Signature Workflow</h2>\n        <div class=\"control-group\">\n            <label>Document to sign:</label>\n            <textarea id=\"documentToSign\"></textarea>\n            <button id=\"signDocument\">Sign Document</button>\n        </div>\n        \n        <div id=\"signatureSection\" class=\"hidden\">\n            <h3>Signature</h3>\n            <div id=\"documentSignature\" class=\"key-display\"></div>\n            \n            <div class=\"control-group\">\n                <label>Verify signature for:</label>\n                <textarea id=\"documentToVerify\"></textarea>\n                <button id=\"verifyDocument\">Verify Signature</button>\n                <div id=\"verificationResult\" class=\"status\"></div>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        // Global variables\n        let keyPair = null;\n        let aliceKeyPair = null;\n        let bobKeyPair = null;\n        let aliceSharedSecret = null;\n        let bobSharedSecret = null;\n        \n        // DOM elements\n        const elements = {\n            algorithm: document.getElementById('algorithm'),\n            generateKeys: document.getElementById('generateKeys'),\n            keyPairSection: document.getElementById('keyPairSection'),\n            publicKey: document.getElementById('publicKey'),\n            privateKey: document.getElementById('privateKey'),\n            copyPublicKey: document.getElementById('copyPublicKey'),\n            copyPrivateKey: document.getElementById('copyPrivateKey'),\n            showPrivateKey: document.getElementById('showPrivateKey'),\n            hidePrivateKey: document.getElementById('hidePrivateKey'),\n            messageToEncrypt: document.getElementById('messageToEncrypt'),\n            encryptKeyType: document.getElementById('encryptKeyType'),\n            encryptButton: document.getElementById('encryptButton'),\n            encryptedResultSection: document.getElementById('encryptedResultSection'),\n            encryptedResult: document.getElementById('encryptedResult'),\n            copyEncrypted: document.getElementById('copyEncrypted'),\n            messageToDecrypt: document.getElementById('messageToDecrypt'),\n            decryptKeyType: document.getElementById('decryptKeyType'),\n            decryptButton: document.getElementById('decryptButton'),\n            decryptedResultSection: document.getElementById('decryptedResultSection'),\n            decryptedResult: document.getElementById('decryptedResult'),\n            verificationStatus: document.getElementById('verificationStatus'),\n            copyDecrypted: document.getElementById('copyDecrypted'),\n            setupKeyExchange: document.getElementById('setupKeyExchange'),\n            keyExchangeSection: document.getElementById('keyExchangeSection'),\n            alicePublicKey: document.getElementById('alicePublicKey'),\n            alicePrivateKey: document.getElementById('alicePrivateKey'),\n            bobPublicKey: document.getElementById('bobPublicKey'),\n            bobPrivateKey: document.getElementById('bobPrivateKey'),\n            aliceComputeShared: document.getElementById('aliceComputeShared'),\n            bobComputeShared: document.getElementById('bobComputeShared'),\n            aliceSharedSecret: document.getElementById('aliceSharedSecret'),\n            bobSharedSecret: document.getElementById('bobSharedSecret'),\n            sharedSecretMatch: document.getElementById('sharedSecretMatch'),\n            documentToSign: document.getElementById('documentToSign'),\n            signDocument: document.getElementById('signDocument'),\n            signatureSection: document.getElementById('signatureSection'),\n            documentSignature: document.getElementById('documentSignature'),\n            documentToVerify: document.getElementById('documentToVerify'),\n            verifyDocument: document.getElementById('verifyDocument'),\n            verificationResult: document.getElementById('verificationResult')\n        };\n        \n        // Event listeners\n        elements.generateKeys.addEventListener('click', generateKeyPair);\n        elements.copyPublicKey.addEventListener('click', () => copyToClipboard(elements.publicKey.textContent));\n        elements.copyPrivateKey.addEventListener('click', () => copyToClipboard(elements.privateKey.textContent));\n        elements.showPrivateKey.addEventListener('click', showPrivateKey);\n        elements.hidePrivateKey.addEventListener('click', hidePrivateKey);\n        elements.encryptButton.addEventListener('click', encryptMessage);\n        elements.copyEncrypted.addEventListener('click', () => copyToClipboard(elements.encryptedResult.textContent));\n        elements.decryptButton.addEventListener('click', decryptMessage);\n        elements.copyDecrypted.addEventListener('click', () => copyToClipboard(elements.decryptedResult.textContent));\n        elements.setupKeyExchange.addEventListener('click', setupKeyExchange);\n        elements.aliceComputeShared.addEventListener('click', () => computeSharedSecret('alice'));\n        elements.bobComputeShared.addEventListener('click', () => computeSharedSecret('bob'));\n        elements.signDocument.addEventListener('click', signDocument);\n        elements.verifyDocument.addEventListener('click', verifyDocument);\n        \n        // Helper functions\n        function copyToClipboard(text) {\n            navigator.clipboard.writeText(text).then(() => {\n                alert('Copied to clipboard!');\n            });\n        }\n        \n        function showPrivateKey() {\n            elements.privateKey.classList.remove('hidden');\n            elements.showPrivateKey.classList.add('hidden');\n            elements.hidePrivateKey.classList.remove('hidden');\n        }\n        \n        function hidePrivateKey() {\n            elements.privateKey.classList.add('hidden');\n            elements.showPrivateKey.classList.remove('hidden');\n            elements.hidePrivateKey.classList.add('hidden');\n        }\n        \n        function generateRandomString(length) {\n            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\n            let result = '';\n            for (let i = 0; i < length; i++) {\n                result += chars.charAt(Math.floor(Math.random() * chars.length));\n            }\n            return result;\n        }\n        \n        function simulateKeyGeneration(algorithm) {\n            // Simulate key generation (in a real app, use Web Crypto API)\n            if (algorithm === 'RSA') {\n                return {\n                    publicKey: `-----BEGIN RSA PUBLIC KEY-----\\n${generateRandomString(200)}\\n-----END RSA PUBLIC KEY-----`,\n                    privateKey: `-----BEGIN RSA PRIVATE KEY-----\\n${generateRandomString(1000)}\\n-----END RSA PRIVATE KEY-----`\n                };\n            } else { // ECC\n                return {\n                    publicKey: `-----BEGIN EC PUBLIC KEY-----\\n${generateRandomString(100)}\\n-----END EC PUBLIC KEY-----`,\n                    privateKey: `-----BEGIN EC PRIVATE KEY-----\\n${generateRandomString(200)}\\n-----END EC PRIVATE KEY-----`\n                };\n            }\n        }\n        \n        function simulateEncryption(message, key, isPublic) {\n            // Simulate encryption (in a real app, use Web Crypto API)\n            if (isPublic) {\n                return `-----BEGIN ENCRYPTED MESSAGE-----\\nUsing public key\\n${btoa(message)}\\n-----END ENCRYPTED MESSAGE-----`;\n            } else {\n                return `-----BEGIN SIGNATURE-----\\nUsing private key\\n${btoa(message)}\\n-----END SIGNATURE-----`;\n            }\n        }\n        \n        function simulateDecryption(encrypted, key, isPublic) {\n            // Simulate decryption (in a real app, use Web Crypto API)\n            const parts = encrypted.split('\\n');\n            if (parts.length < 3) return \"Invalid format\";\n            \n            if (isPublic) {\n                // Verification\n                if (encrypted.includes('SIGNATURE')) {\n                    const message = atob(parts[2]);\n                    return { success: true, message: message };\n                } else {\n                    return { success: false, message: \"Verification failed - not a signature\" };\n                }\n            } else {\n                // Decryption\n                if (encrypted.includes('ENCRYPTED MESSAGE')) {\n                    return { success: true, message: atob(parts[2]) };\n                } else {\n                    return { success: false, message: \"Decryption failed - not an encrypted message\" };\n                }\n            }\n        }\n        \n        function simulateKeyExchange(algorithm) {\n            // Simulate key exchange (in a real app, use Web Crypto API)\n            if (algorithm === 'RSA') {\n                return {\n                    alice: {\n                        publicKey: `-----BEGIN RSA PUBLIC KEY-----\\n${generateRandomString(200)}\\n-----END RSA PUBLIC KEY-----`,\n                        privateKey: `-----BEGIN RSA PRIVATE KEY-----\\n${generateRandomString(1000)}\\n-----END RSA PRIVATE KEY-----`\n                    },\n                    bob: {\n                        publicKey: `-----BEGIN RSA PUBLIC KEY-----\\n${generateRandomString(200)}\\n-----END RSA PUBLIC KEY-----`,\n                        privateKey: `-----BEGIN RSA PRIVATE KEY-----\\n${generateRandomString(1000)}\\n-----END RSA PRIVATE KEY-----`\n                    }\n                };\n            } else { // ECC\n                return {\n                    alice: {\n                        publicKey: `-----BEGIN EC PUBLIC KEY-----\\n${generateRandomString(100)}\\n-----END EC PUBLIC KEY-----`,\n                        privateKey: `-----BEGIN EC PRIVATE KEY-----\\n${generateRandomString(200)}\\n-----END EC PRIVATE KEY-----`\n                    },\n                    bob: {\n                        publicKey: `-----BEGIN EC PUBLIC KEY-----\\n${generateRandomString(100)}\\n-----END EC PUBLIC KEY-----`,\n                        privateKey: `-----BEGIN EC PRIVATE KEY-----\\n${generateRandomString(200)}\\n-----END EC PRIVATE KEY-----`\n                    }\n                };\n            }\n        }\n        \n        function simulateSharedSecretComputation(privateKey, otherPublicKey) {\n            // Simulate shared secret computation (in a real app, use Web Crypto API)\n            return `SharedSecret:${generateRandomString(32)}`;\n        }\n        \n        function simulateDocumentSigning(document, privateKey) {\n            // Simulate document signing (in a real app, use Web Crypto API)\n            return `-----BEGIN SIGNATURE-----\\nDocument: ${document}\\nSignature: ${generateRandomString(64)}\\n-----END SIGNATURE-----`;\n        }\n        \n        function simulateSignatureVerification(document, signature, publicKey) {\n            // Simulate signature verification (in a real app, use Web Crypto API)\n            const sigParts = signature.split('\\n');\n            if (sigParts.length < 3) return false;\n            \n            const sigDoc = sigParts[1].replace('Document: ', '');\n            return sigDoc === document;\n        }\n        \n        // Main functions\n        function generateKeyPair() {\n            const algorithm = elements.algorithm.value;\n            keyPair = simulateKeyGeneration(algorithm);\n            \n            elements.publicKey.textContent = keyPair.publicKey;\n            elements.privateKey.textContent = keyPair.privateKey;\n            elements.keyPairSection.classList.remove('hidden');\n            hidePrivateKey();\n            \n            alert(`${algorithm} key pair generated successfully!`);\n        }\n        \n        function encryptMessage() {\n            if (!keyPair) {\n                alert('Please generate a key pair first');\n                return;\n            }\n            \n            const message = elements.messageToEncrypt.value;\n            if (!message) {\n                alert('Please enter a message to encrypt');\n                return;\n            }\n            \n            const usePublicKey = elements.encryptKeyType.value === 'public';\n            const key = usePublicKey ? keyPair.publicKey : keyPair.privateKey;\n            \n            const result = simulateEncryption(message, key, usePublicKey);\n            elements.encryptedResult.textContent = result;\n            elements.encryptedResultSection.classList.remove('hidden');\n            \n            alert(usePublicKey ? 'Message encrypted with public key!' : 'Message signed with private key!');\n        }\n        \n        function decryptMessage() {\n            if (!keyPair) {\n                alert('Please generate a key pair first');\n                return;\n            }\n            \n            const encrypted = elements.messageToDecrypt.value;\n            if (!encrypted) {\n                alert('Please enter an encrypted message or signature');\n                return;\n            }\n            \n            const usePublicKey = elements.decryptKeyType.value === 'public';\n            const key = usePublicKey ? keyPair.publicKey : keyPair.privateKey;\n            \n            const result = simulateDecryption(encrypted, key, usePublicKey);\n            \n            if (result.success) {\n                elements.decryptedResult.textContent = result.message;\n                if (usePublicKey) {\n                    elements.verificationStatus.textContent = \"Signature verified successfully!\";\n                    elements.verificationStatus.style.color = \"green\";\n                }\n            } else {\n                elements.decryptedResult.textContent = result.message;\n                if (usePublicKey) {\n                    elements.verificationStatus.textContent = \"Signature verification failed!\";\n                    elements.verificationStatus.style.color = \"red\";\n                }\n            }\n            \n            elements.decryptedResultSection.classList.remove('hidden');\n        }\n        \n        function setupKeyExchange() {\n            const algorithm = elements.algorithm.value;\n            const keyPairs = simulateKeyExchange(algorithm);\n            \n            aliceKeyPair = keyPairs.alice;\n            bobKeyPair = keyPairs.bob;\n            \n            elements.alicePublicKey.textContent = aliceKeyPair.publicKey;\n            elements.alicePrivateKey.textContent = aliceKeyPair.privateKey;\n            elements.bobPublicKey.textContent = bobKeyPair.publicKey;\n            elements.bobPrivateKey.textContent = bobKeyPair.privateKey;\n            \n            elements.keyExchangeSection.classList.remove('hidden');\n            elements.aliceSharedSecret.classList.add('hidden');\n            elements.bobSharedSecret.classList.add('hidden');\n            elements.sharedSecretMatch.textContent = '';\n            \n            alert(`Key exchange setup complete for ${algorithm}! Alice and Bob have generated their key pairs.`);\n        }\n        \n        function computeSharedSecret(who) {\n            if (!aliceKeyPair || !bobKeyPair) {\n                alert('Please setup key exchange first');\n                return;\n            }\n            \n            if (who === 'alice') {\n                aliceSharedSecret = simulateSharedSecretComputation(\n                    aliceKeyPair.privateKey,\n                    bobKeyPair.publicKey\n                );\n                elements.aliceSharedSecret.textContent = aliceSharedSecret;\n                elements.aliceSharedSecret.classList.remove('hidden');\n            } else {\n                bobSharedSecret = simulateSharedSecretComputation(\n                    bobKeyPair.privateKey,\n                    aliceKeyPair.publicKey\n                );\n                elements.bobSharedSecret.textContent = bobSharedSecret;\n                elements.bobSharedSecret.classList.remove('hidden');\n            }\n            \n            if (aliceSharedSecret && bobSharedSecret) {\n                if (aliceSharedSecret === bobSharedSecret) {\n                    elements.sharedSecretMatch.textContent = \"Shared secrets match! Key exchange successful.\";\n                    elements.sharedSecretMatch.style.color = \"green\";\n                } else {\n                    elements.sharedSecretMatch.textContent = \"Shared secrets don't match!\";\n                    elements.sharedSecretMatch.style.color = \"red\";\n                }\n            }\n        }\n        \n        function signDocument() {\n            if (!keyPair) {\n                alert('Please generate a key pair first');\n                return;\n            }\n            \n            const document = elements.documentToSign.value;\n            if (!document) {\n                alert('Please enter a document to sign');\n                return;\n            }\n            \n            const signature = simulateDocumentSigning(document, keyPair.privateKey);\n            elements.documentSignature.textContent = signature;\n            elements.signatureSection.classList.remove('hidden');\n            \n            alert('Document signed successfully!');\n        }\n        \n        function verifyDocument() {\n            if (!keyPair) {\n                alert('Please generate a key pair first');\n                return;\n            }\n            \n            const document = elements.documentToVerify.value;\n            if (!document) {\n                alert('Please enter a document to verify');\n                return;\n            }\n            \n            const signature = elements.documentSignature.textContent;\n            if (!signature) {\n                alert('Please sign a document first');\n                return;\n            }\n            \n            const isValid = simulateSignatureVerification(document, signature, keyPair.publicKey);\n            \n            if (isValid) {\n                elements.verificationResult.textContent = \"Signature is valid!\";\n                elements.verificationResult.style.color = \"green\";\n            } else {\n                elements.verificationResult.textContent = \"Signature is invalid!\";\n                elements.verificationResult.style.color = \"red\";\n            }\n        }\n    </script>\n</body>\n</html>"
