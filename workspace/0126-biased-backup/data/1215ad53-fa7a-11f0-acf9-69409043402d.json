  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Interactive Paging Demonstration</title>\n<style>\n  /* Minimal styling: none except box-sizing for layout */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    padding: 0;\n    background: white;\n    color: black;\n  }\n  button, input[type=number], input[type=text], select {\n    font: inherit;\n  }\n</style>\n</head>\n<body>\n<h1>Paging Demonstration (Minimal UI)</h1>\n<p>\n  This demo allows you to browse through pages of data with rich controls.<br />\n  You can control page size, total items, jump to pages, navigate stepwise, filter items, and explore advanced paging options.\n</p>\n\n<div>\n  <label for=\"totalItemsInput\">Total Items: </label>\n  <input type=\"number\" id=\"totalItemsInput\" min=\"1\" max=\"10000\" step=\"1\" value=\"123\" />\n  <button id=\"setTotalItemsBtn\">Set Total Items</button>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <label for=\"pageSizeInput\">Page Size (items per page): </label>\n  <input type=\"number\" id=\"pageSizeInput\" min=\"1\" max=\"1000\" step=\"1\" value=\"10\" />\n  <button id=\"setPageSizeBtn\">Set Page Size</button>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <label for=\"filterInput\">Filter (substring match on item text): </label>\n  <input type=\"text\" id=\"filterInput\" placeholder=\"Filter text\" />\n  <button id=\"applyFilterBtn\">Apply Filter</button>\n  <button id=\"clearFilterBtn\">Clear Filter</button>\n</div>\n\n<hr/>\n\n<div>\n  <button id=\"firstPageBtn\" title=\"Go to first page\">|&lt;</button>\n  <button id=\"prevPageBtn\" title=\"Go to previous page\">&lt; Prev</button>\n  <label for=\"currentPageInput\">Page: </label>\n  <input type=\"number\" id=\"currentPageInput\" min=\"1\" value=\"1\" style=\"width:50px;\" />\n  <button id=\"goPageBtn\">Go</button>\n  <button id=\"nextPageBtn\" title=\"Go to next page\">Next &gt;</button>\n  <button id=\"lastPageBtn\" title=\"Go to last page\">&gt;|</button>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <label for=\"visiblePagesRange\">Visible Page Buttons: </label>\n  <input type=\"range\" id=\"visiblePagesRange\" min=\"3\" max=\"21\" step=\"2\" value=\"7\" />\n  <span id=\"visiblePagesLabel\">7</span>\n</div>\n\n<div style=\"margin-top:10px;\" id=\"pageButtonsContainer\" aria-label=\"Page navigation buttons\" role=\"navigation\" tabindex=\"0\">\n  <!-- Page number buttons will be inserted here -->\n</div>\n\n<hr/>\n\n<div>\n  <label>Items on current page:</label>\n  <ul id=\"itemsList\" style=\"margin-top:5px; max-height:200px; overflow-y:auto;\"></ul>\n</div>\n\n<hr/>\n\n<div>\n  <label for=\"jumpStepInput\">Jump pages by step:</label>\n  <input type=\"number\" id=\"jumpStepInput\" min=\"1\" max=\"1000\" value=\"5\" style=\"width: 60px;\" />\n  <button id=\"jumpForwardBtn\">Jump Forward</button>\n  <button id=\"jumpBackwardBtn\">Jump Backward</button>\n</div>\n\n<hr/>\n\n<div>\n  <label for=\"customPageInput\">Add Custom Page Bookmark (page number):</label>\n  <input type=\"number\" id=\"customPageInput\" min=\"1\" value=\"1\" style=\"width: 60px;\" />\n  <button id=\"addBookmarkBtn\">Add Bookmark</button>\n</div>\n<div style=\"margin-top:5px;\">\n  <label>Bookmarks: </label>\n  <ul id=\"bookmarksList\" style=\"list-style: decimal; padding-left:20px;\"></ul>\n</div>\n\n<hr/>\n\n<div>\n  <button id=\"toggleAdvancedBtn\">Show Advanced Paging Options</button>\n</div>\n\n<div id=\"advancedOptions\" style=\"display:none; margin-top:10px;\">\n  <fieldset>\n    <legend>Advanced Paging Controls</legend>\n    <div>\n      <input type=\"checkbox\" id=\"enableLoopPaging\" />\n      <label for=\"enableLoopPaging\">Enable Loop Paging (wrap navigation)</label>\n    </div>\n    <div style=\"margin-top:10px;\">\n      <label for=\"fastJumpMultiplier\">Fast Jump Multiplier:</label>\n      <input type=\"number\" id=\"fastJumpMultiplier\" min=\"1\" max=\"100\" value=\"10\" />\n      <button id=\"fastJumpForwardBtn\">Fast Jump Forward</button>\n      <button id=\"fastJumpBackwardBtn\">Fast Jump Backward</button>\n    </div>\n    <div style=\"margin-top:10px;\">\n      <label for=\"pageRangeInput\">Display Page Range (start,end):</label>\n      <input type=\"text\" id=\"pageRangeInput\" placeholder=\"e.g. 3,15\" style=\"width:80px;\" />\n      <button id=\"setPageRangeBtn\">Set Range</button>\n      <button id=\"clearPageRangeBtn\">Clear Range</button>\n    </div>\n  </fieldset>\n</div>\n\n<script>\n(function(){\n  // Data and State\n  let totalItems = 123;\n  let pageSize = 10;\n  let currentPage = 1;\n  let filterText = \"\";\n  let filteredItems = [];\n  let allItems = [];\n  let bookmarks = [];\n  let visiblePageButtonsCount = 7;\n  let loopPaging = false;\n  let pageRangeFilter = null; // {start: X, end: Y}\n\n  // Generate mock data (simple text items)\n  function generateItems(n) {\n    let arr = [];\n    for(let i=1; i<=n; i++){\n      arr.push(\"Item #\" + i);\n    }\n    return arr;\n  }\n\n  // Initialize items\n  function refreshAllItems(){\n    allItems = generateItems(totalItems);\n    applyFilterAndRange();\n  }\n\n  // Apply filtering and page range filter\n  function applyFilterAndRange(){\n    filteredItems = allItems.filter(function(item){\n      if(filterText && !item.toLowerCase().includes(filterText.toLowerCase())){\n        return false;\n      }\n      return true;\n    });\n    if(pageRangeFilter){\n      filteredItems = filteredItems.filter(function(item){\n        let num = +item.match(/\\d+$/)[0];\n        return num >= pageRangeFilter.start && num <= pageRangeFilter.end;\n      });\n    }\n    // If current page > max page, reset to max page\n    let maxP = maxPage();\n    if(currentPage > maxP) currentPage = maxP > 0 ? maxP : 1;\n  }\n\n  // Calculate max pages\n  function maxPage() {\n    return Math.max(1, Math.ceil(filteredItems.length / pageSize));\n  }\n\n  // Update visible pages label\n  function updateVisiblePagesLabel(){\n    let el = document.getElementById('visiblePagesLabel');\n    el.textContent = visiblePageButtonsCount;\n  }\n\n  // Render page buttons in container with ellipsis if needed\n  function renderPageButtons(){\n    let container = document.getElementById('pageButtonsContainer');\n    container.innerHTML = \"\";\n    let maxP = maxPage();\n    let btnCount = Math.min(visiblePageButtonsCount, maxP);\n    if(btnCount < 3) btnCount = Math.min(3, maxP);\n\n    // Determine range of pages to show around current page\n    // The range is centered on currentPage whenever possible\n    let half = Math.floor(btnCount/2);\n    let startPage = currentPage - half;\n    let endPage = currentPage + half;\n\n    if(startPage < 1){\n      endPage += 1 - startPage;\n      startPage = 1;\n    }\n    if(endPage > maxP){\n      startPage -= (endPage - maxP);\n      endPage = maxP;\n    }\n    if(startPage < 1) startPage = 1;\n\n    // Helper to create a button\n    function createPageBtn(pageNum) {\n      let btn = document.createElement('button');\n      btn.textContent = pageNum;\n      btn.disabled = (pageNum === currentPage);\n      btn.setAttribute('aria-current', pageNum === currentPage ? 'page' : null);\n      btn.addEventListener('click', function(){\n        currentPage = pageNum;\n        updateEverything();\n        currentPageInput.value = currentPage;\n        focusPageButtonsContainer();\n      });\n      return btn;\n    }\n\n    // If startPage > 1, show first page and ellipsis (if gap >1)\n    if(startPage > 1){\n      container.appendChild(createPageBtn(1));\n      if(startPage > 2){\n        let ellipsis = document.createElement('span');\n        ellipsis.textContent = ' ... ';\n        ellipsis.style.userSelect = \"none\";\n        container.appendChild(ellipsis);\n      }\n    }\n\n    for(let p=startPage; p<=endPage; p++){\n      container.appendChild(createPageBtn(p));\n    }\n\n    // If endPage < maxP, show ellipsis and last page\n    if(endPage < maxP){\n      if(endPage < maxP - 1){\n        let ellipsis = document.createElement('span');\n        ellipsis.textContent = ' ... ';\n        ellipsis.style.userSelect = \"none\";\n        container.appendChild(ellipsis);\n      }\n      container.appendChild(createPageBtn(maxP));\n    }\n  }\n\n  // Render items on current page\n  function renderItems(){\n    let ul = document.getElementById('itemsList');\n    ul.innerHTML = \"\";\n    if(filteredItems.length === 0){\n      let li = document.createElement('li');\n      li.textContent = \"(No items to display)\";\n      ul.appendChild(li);\n      return;\n    }\n    let startIndex = (currentPage - 1) * pageSize;\n    let endIndex = Math.min(startIndex + pageSize, filteredItems.length);\n    for(let i = startIndex; i < endIndex; i++){\n      let li = document.createElement('li');\n      li.textContent = filteredItems[i];\n      ul.appendChild(li);\n    }\n  }\n\n  // Update buttons enabled state for prev/next etc\n  function updateNavigationButtons(){\n    let maxP = maxPage();\n    firstPageBtn.disabled = (currentPage === 1);\n    prevPageBtn.disabled = (currentPage === 1);\n    nextPageBtn.disabled = (currentPage === maxP);\n    lastPageBtn.disabled = (currentPage === maxP);\n  }\n\n  // Focus page buttons container for accessibility\n  function focusPageButtonsContainer(){\n    let c = document.getElementById('pageButtonsContainer');\n    c.focus();\n  }\n\n  // Update bookmark list UI\n  function updateBookmarksUI(){\n    let ul = document.getElementById('bookmarksList');\n    ul.innerHTML = \"\";\n    if(bookmarks.length === 0){\n      let li = document.createElement('li');\n      li.textContent = \"(No bookmarks)\";\n      ul.appendChild(li);\n      return;\n    }\n    bookmarks.forEach(function(p,i){\n      let li = document.createElement('li');\n      let btn = document.createElement('button');\n      btn.textContent = \"Go to page \" + p;\n      btn.addEventListener('click', function(){\n        if(p >= 1 && p <= maxPage()){\n          currentPage = p;\n          currentPageInput.value = currentPage;\n          updateEverything();\n        }\n      });\n      li.appendChild(btn);\n      let delBtn = document.createElement('button');\n      delBtn.textContent = \"Remove\";\n      delBtn.style.marginLeft = \"5px\";\n      delBtn.addEventListener('click', function(){\n        bookmarks.splice(i,1);\n        updateBookmarksUI();\n      });\n      li.appendChild(delBtn);\n      ul.appendChild(li);\n    });\n  }\n\n  // Go to a given page, clamped to available pages\n  function goToPage(page){\n    let maxP = maxPage();\n    if(page < 1) page = 1;\n    else if(page > maxP) page = maxP;\n    currentPage = page;\n    currentPageInput.value = currentPage;\n    updateEverything();\n  }\n\n  // Update all UI parts and data displays\n  function updateEverything(){\n    applyFilterAndRange();\n    updateVisiblePagesLabel();\n    renderPageButtons();\n    renderItems();\n    updateNavigationButtons();\n    updateBookmarksUI();\n  }\n\n  // Initialization and event handlers\n  let totalItemsInput = document.getElementById('totalItemsInput');\n  let setTotalItemsBtn = document.getElementById('setTotalItemsBtn');\n  let pageSizeInput = document.getElementById('pageSizeInput');\n  let setPageSizeBtn = document.getElementById('setPageSizeBtn');\n  let filterInput = document.getElementById('filterInput');\n  let applyFilterBtn = document.getElementById('applyFilterBtn');\n  let clearFilterBtn = document.getElementById('clearFilterBtn');\n\n  let firstPageBtn = document.getElementById('firstPageBtn');\n  let prevPageBtn = document.getElementById('prevPageBtn');\n  let currentPageInput = document.getElementById('currentPageInput');\n  let goPageBtn = document.getElementById('goPageBtn');\n  let nextPageBtn = document.getElementById('nextPageBtn');\n  let lastPageBtn = document.getElementById('lastPageBtn');\n\n  let visiblePagesRange = document.getElementById('visiblePagesRange');\n\n  let jumpStepInput = document.getElementById('jumpStepInput');\n  let jumpForwardBtn = document.getElementById('jumpForwardBtn');\n  let jumpBackwardBtn = document.getElementById('jumpBackwardBtn');\n\n  let customPageInput = document.getElementById('customPageInput');\n  let addBookmarkBtn = document.getElementById('addBookmarkBtn');\n  let bookmarksList = document.getElementById('bookmarksList');\n\n  let toggleAdvancedBtn = document.getElementById('toggleAdvancedBtn');\n  let advancedOptions = document.getElementById('advancedOptions');\n  let enableLoopPagingChk = document.getElementById('enableLoopPaging');\n\n  let fastJumpMultiplierInput = document.getElementById('fastJumpMultiplier');\n  let fastJumpForwardBtn = document.getElementById('fastJumpForwardBtn');\n  let fastJumpBackwardBtn = document.getElementById('fastJumpBackwardBtn');\n\n  let pageRangeInput = document.getElementById('pageRangeInput');\n  let setPageRangeBtn = document.getElementById('setPageRangeBtn');\n  let clearPageRangeBtn = document.getElementById('clearPageRangeBtn');\n\n  setTotalItemsBtn.addEventListener('click', function(){\n    let val = parseInt(totalItemsInput.value);\n    if(isNaN(val) || val < 1){\n      alert(\"Total items must be a positive integer\");\n      return;\n    }\n    totalItems = val;\n    refreshAllItems();\n    if(currentPage > maxPage()) currentPage = maxPage();\n    currentPageInput.value = currentPage;\n    updateEverything();\n  });\n\n  setPageSizeBtn.addEventListener('click', function(){\n    let val = parseInt(pageSizeInput.value);\n    if(isNaN(val) || val < 1){\n      alert(\"Page size must be a positive integer\");\n      return;\n    }\n    pageSize = val;\n    if(currentPage > maxPage()) currentPage = maxPage();\n    currentPageInput.value = currentPage;\n    updateEverything();\n  });\n\n  applyFilterBtn.addEventListener('click', function(){\n    filterText = filterInput.value.trim();\n    currentPage = 1;\n    currentPageInput.value = currentPage;\n    updateEverything();\n  });\n\n  clearFilterBtn.addEventListener('click', function(){\n    filterText = \"\";\n    filterInput.value = \"\";\n    currentPage = 1;\n    currentPageInput.value = currentPage;\n    updateEverything();\n  });\n\n  firstPageBtn.addEventListener('click', function(){\n    currentPage = 1;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  prevPageBtn.addEventListener('click', function(){\n    let newPage = currentPage - 1;\n    if(newPage < 1){\n      if(loopPaging){\n        newPage = maxPage();\n      } else {\n        newPage = 1;\n      }\n    }\n    currentPage = newPage;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  nextPageBtn.addEventListener('click', function(){\n    let newPage = currentPage + 1;\n    if(newPage > maxPage()){\n      if(loopPaging){\n        newPage = 1;\n      } else {\n        newPage = maxPage();\n      }\n    }\n    currentPage = newPage;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  lastPageBtn.addEventListener('click', function(){\n    currentPage = maxPage();\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  goPageBtn.addEventListener('click', function(){\n    let val = parseInt(currentPageInput.value);\n    if(isNaN(val)){\n      alert(\"Please enter a valid page number\");\n      currentPageInput.value = currentPage;\n      return;\n    }\n    goToPage(val);\n    focusPageButtonsContainer();\n  });\n\n  currentPageInput.addEventListener('keydown', function(e){\n    if(e.key === \"Enter\"){\n      goPageBtn.click();\n    }\n  });\n\n  visiblePagesRange.addEventListener('input', function(){\n    visiblePageButtonsCount = parseInt(this.value);\n    updateEverything();\n  });\n\n  jumpForwardBtn.addEventListener('click', function(){\n    let step = parseInt(jumpStepInput.value);\n    if(isNaN(step) || step < 1) step = 1;\n    let newPage = currentPage + step;\n    if(newPage > maxPage()){\n      if(loopPaging){\n        newPage = ((newPage - 1) % maxPage()) + 1;\n      } else {\n        newPage = maxPage();\n      }\n    }\n    currentPage = newPage;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  jumpBackwardBtn.addEventListener('click', function(){\n    let step = parseInt(jumpStepInput.value);\n    if(isNaN(step) || step < 1) step = 1;\n    let newPage = currentPage - step;\n    if(newPage < 1){\n      if(loopPaging){\n        newPage = maxPage() - ((-newPage) % maxPage());\n        if(newPage < 1) newPage = maxPage();\n      } else {\n        newPage = 1;\n      }\n    }\n    currentPage = newPage;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  addBookmarkBtn.addEventListener('click', function(){\n    let val = parseInt(customPageInput.value);\n    if(isNaN(val) || val < 1 || val > maxPage()){\n      alert(\"Bookmark page must be a valid page number within range.\");\n      return;\n    }\n    if(!bookmarks.includes(val)){\n      bookmarks.push(val);\n      bookmarks.sort((a,b)=>a-b);\n      updateBookmarksUI();\n    }\n  });\n\n  toggleAdvancedBtn.addEventListener('click', function(){\n    if(advancedOptions.style.display === \"none\" || advancedOptions.style.display === \"\"){\n      advancedOptions.style.display = \"block\";\n      toggleAdvancedBtn.textContent = \"Hide Advanced Paging Options\";\n    } else {\n      advancedOptions.style.display = \"none\";\n      toggleAdvancedBtn.textContent = \"Show Advanced Paging Options\";\n    }\n  });\n\n  enableLoopPagingChk.addEventListener('change', function(){\n    loopPaging = this.checked;\n  });\n\n  fastJumpForwardBtn.addEventListener('click', function(){\n    let mult = parseInt(fastJumpMultiplierInput.value);\n    if(isNaN(mult) || mult < 1) mult = 10;\n    let newPage = currentPage + pageSize * mult;\n    if(newPage > maxPage()){\n      if(loopPaging){\n        newPage = ((newPage - 1) % maxPage()) + 1;\n      } else {\n        newPage = maxPage();\n      }\n    }\n    currentPage = newPage;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  fastJumpBackwardBtn.addEventListener('click', function(){\n    let mult = parseInt(fastJumpMultiplierInput.value);\n    if(isNaN(mult) || mult < 1) mult = 10;\n    let newPage = currentPage - pageSize * mult;\n    if(newPage < 1){\n      if(loopPaging){\n        newPage = maxPage() - ((-newPage) % maxPage());\n        if(newPage < 1) newPage = maxPage();\n      } else {\n        newPage = 1;\n      }\n    }\n    currentPage = newPage;\n    currentPageInput.value = currentPage;\n    updateEverything();\n    focusPageButtonsContainer();\n  });\n\n  setPageRangeBtn.addEventListener('click', function(){\n    let val = pageRangeInput.value.trim();\n    if(!val) {\n      alert(\"Please enter a page range in format: start,end\");\n      return;\n    }\n    let parts = val.split(',');\n    if(parts.length !== 2){\n      alert(\"Invalid format. Use start,end (e.g., 10,50)\");\n      return;\n    }\n    let s = parseInt(parts[0]);\n    let e = parseInt(parts[1]);\n    if(isNaN(s) || isNaN(e) || s < 1 || e < s || e > totalItems){\n      alert(\"Invalid range numbers or out of bounds\");\n      return;\n    }\n    pageRangeFilter = {start: s, end: e};\n    currentPage = 1;\n    currentPageInput.value = currentPage;\n    updateEverything();\n  });\n\n  clearPageRangeBtn.addEventListener('click', function(){\n    pageRangeFilter = null;\n    pageRangeInput.value = \"\";\n    currentPage = 1;\n    currentPageInput.value = currentPage;\n    updateEverything();\n  });\n\n  // Initialize data and UI\n  refreshAllItems();\n  updateEverything();\n\n  // Accessibility: keyboard page buttons navigation support\n  let pageButtonsContainer = document.getElementById('pageButtonsContainer');\n\n  pageButtonsContainer.addEventListener('keydown', function(e){\n    let focusElem = document.activeElement;\n    if(focusElem.tagName !== 'BUTTON') return;\n    let buttons = Array.from(pageButtonsContainer.querySelectorAll('button'));\n    let idx = buttons.indexOf(focusElem);\n    if(idx === -1) return;\n\n    if(e.key === 'ArrowRight' || e.key === 'ArrowDown'){\n      e.preventDefault();\n      let next = (idx + 1) % buttons.length;\n      buttons[next].focus();\n    } else if(e.key === 'ArrowLeft' || e.key === 'ArrowUp'){\n      e.preventDefault();\n      let prev = (idx -1 + buttons.length) % buttons.length;\n      buttons[prev].focus();\n    } else if(e.key === 'Home'){\n      e.preventDefault();\n      buttons[0].focus();\n    } else if(e.key === 'End'){\n      e.preventDefault();\n      buttons[buttons.length - 1].focus();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
