    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Greedy Algorithms — Visual Symphony</title>\n\n  <!-- Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #061224;\n      --accent-1: #7ee7c7;\n      --accent-2: #68a6ff;\n      --muted: rgba(255,255,255,0.12);\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.03);\n      --card: rgba(255,255,255,0.03);\n      --text: rgba(255,255,255,0.95);\n      --soft: rgba(255,255,255,0.8);\n      --shadow: 0 10px 30px rgba(6,12,34,0.6);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 700px at 10% 10%, rgba(104,166,255,0.08), transparent 10%),\n                  radial-gradient(1000px 600px at 90% 90%, rgba(126,231,199,0.04), transparent 15%),\n                  linear-gradient(180deg,var(--bg-1), var(--bg-2));\n      color:var(--text);\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Subtle floating pattern */\n    .canvas-wrap{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n    }\n\n    .container{\n      position:relative;\n      z-index:2;\n      max-width:1200px;\n      margin:48px auto;\n      padding:36px;\n    }\n\n    header{\n      display:flex;\n      align-items:flex-start;\n      gap:28px;\n      margin-bottom:28px;\n    }\n\n    .title{\n      flex:1 1 0;\n      display:flex;\n      gap:18px;\n      align-items:center;\n    }\n\n    .brand{\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n    }\n\n    .brand h1{\n      margin:0;\n      font-family:\"Playfair Display\", serif;\n      font-size:46px;\n      letter-spacing:-0.6px;\n      color:linear-gradient(90deg,#fff,#fff);\n      background:linear-gradient(90deg,var(--accent-2),var(--accent-1));\n      -webkit-background-clip:text;\n      background-clip:text;\n      color:transparent;\n      text-shadow:0 6px 20px rgba(6,12,34,0.6);\n    }\n\n    .brand p{\n      margin:0;\n      color:var(--soft);\n      font-size:14px;\n      max-width:720px;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-left:auto;\n    }\n\n    .btn{\n      background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      color:var(--text);\n      border:1px solid rgba(255,255,255,0.06);\n      padding:12px 18px;\n      border-radius:12px;\n      font-weight:600;\n      cursor:pointer;\n      box-shadow:var(--shadow);\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n      backdrop-filter: blur(6px) saturate(120%);\n      transition:transform .22s cubic-bezier(.2,.9,.2,1), box-shadow .22s;\n      user-select:none;\n    }\n    .btn:active{transform:translateY(2px)}\n    .btn:disabled{opacity:.5; cursor:default; transform:none}\n\n    .btn.play{\n      background: linear-gradient(90deg, rgba(104,166,255,0.14), rgba(126,231,199,0.08));\n      border: 1px solid rgba(120,170,250,0.12);\n      color: #eaf8ff;\n      box-shadow: 0 8px 30px rgba(41,78,126,0.3), 0 2px 8px rgba(126,231,199,0.06);\n    }\n\n    .btn.reset{\n      background:transparent;\n      border: 1px dashed rgba(255,255,255,0.04);\n      color:var(--soft);\n    }\n\n    /* Main panel */\n    .main{\n      display:grid;\n      grid-template-columns: 1fr 360px;\n      gap:28px;\n      align-items:stretch;\n    }\n\n    .stage{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      padding:28px;\n      box-shadow:var(--shadow);\n      min-height:520px;\n      position:relative;\n      overflow:hidden;\n    }\n\n    /* left visual area */\n    .visual-top{\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      gap:16px;\n      margin-bottom:18px;\n    }\n    .amount-card{\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n      padding:12px 16px;\n      border-radius:12px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      width:220px;\n    }\n    .amount-card .label{\n      font-size:13px;\n      color:var(--soft);\n    }\n    .amount-card .value{\n      font-family:\"Playfair Display\", serif;\n      font-size:28px;\n      color:var(--accent-1);\n      letter-spacing:1px;\n    }\n    .hint{\n      font-size:13px;\n      color:var(--soft);\n    }\n\n    .rack{\n      display:flex;\n      gap:14px;\n      align-items:center;\n    }\n\n    .pile{\n      width:96px;\n      height:96px;\n      border-radius:22px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      align-items:center;\n      justify-content:center;\n      gap:6px;\n      padding:10px;\n      position:relative;\n      overflow:visible;\n      transition:transform .36s cubic-bezier(.2,.9,.2,1), box-shadow .36s;\n    }\n    .pile .denom{\n      font-weight:700;\n      color:var(--soft);\n      font-size:18px;\n    }\n    .pile .meta{\n      font-size:12px;\n      color:rgba(255,255,255,0.5);\n    }\n    .pile:hover{transform:translateY(-6px); box-shadow: 0 12px 30px rgba(6,12,34,0.5)}\n    .pile.active{\n      transform:translateY(-12px) scale(1.02);\n      box-shadow: 0 20px 40px rgba(81,133,200,0.18);\n      outline: 2px solid rgba(104,166,255,0.14);\n    }\n\n    /* coin appearance */\n    .coin{\n      width:56px;\n      height:56px;\n      border-radius:50%;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:700;\n      color:#071024;\n      box-shadow: 0 6px 18px rgba(6,12,34,0.45), inset 0 -6px 12px rgba(255,255,255,0.06);\n      background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.75));\n      transform-origin:center;\n      user-select:none;\n    }\n\n    .coin.copper{\n      background: linear-gradient(180deg,#edc288,#cf8b4e);\n      color:#071024;\n    }\n    .coin.silver{\n      background: linear-gradient(180deg,#e8eef8,#b9c9e6);\n      color:#081229;\n    }\n    .coin.gold{\n      background: linear-gradient(180deg,#fff5c8,#ffd36a);\n      color:#071224;\n    }\n    .coin.teal{\n      background: linear-gradient(180deg,#a8fff0,#7fe7c4);\n      color:#042028;\n    }\n\n    /* solution area */\n    .solution{\n      position:absolute;\n      right:28px;\n      bottom:28px;\n      width:320px;\n      min-height:120px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:14px;\n      padding:16px;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 12px 40px rgba(6,12,34,0.55);\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n      align-items:flex-start;\n    }\n    .solution .title{\n      font-size:13px;\n      color:var(--soft);\n    }\n    .solution .stack{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    .solution .total{\n      margin-left:auto;\n      font-weight:700;\n      color:var(--accent-2);\n      font-size:16px;\n      padding-left:10px;\n    }\n\n    /* pseudo-code card */\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      padding:18px;\n      height:100%;\n      box-shadow:var(--shadow);\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n      overflow:hidden;\n    }\n    .card h3{\n      margin:0;\n      font-size:16px;\n      color:var(--soft);\n      letter-spacing:0.2px;\n    }\n\n    .code{\n      font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Noto Mono\", monospace;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n      border-radius:10px;\n      padding:12px;\n      color: #dbeafe;\n      font-size:13px;\n      line-height:1.6;\n      border:1px solid rgba(255,255,255,0.02);\n      overflow:auto;\n    }\n\n    .line{\n      padding:6px 8px;\n      border-radius:8px;\n      transition:background .28s, transform .28s;\n    }\n    .line.highlight{\n      background: linear-gradient(90deg, rgba(104,166,255,0.09), rgba(126,231,199,0.06));\n      transform:translateX(6px);\n      box-shadow: inset 0 -6px 20px rgba(6,12,34,0.14);\n    }\n\n    .meta{\n      color:var(--soft);\n      font-size:13px;\n      margin-top:auto;\n    }\n\n    /* small footer note */\n    .footer-note{\n      margin-top:18px;\n      color:var(--soft);\n      font-size:13px;\n    }\n\n    /* micro animations */\n    .spark{\n      position:absolute;\n      width:8px;\n      height:8px;\n      border-radius:50%;\n      background:var(--accent-1);\n      box-shadow: 0 0 14px rgba(126,231,199,0.9);\n      pointer-events:none;\n      opacity:0;\n      transform:scale(.2);\n      transition:opacity .18s, transform .36s;\n    }\n\n    /* subtle glass text block */\n    .obs{\n      font-size:13px;\n      color:var(--soft);\n      max-width:760px;\n    }\n\n    /* responsive */\n    @media (max-width:980px){\n      .main{grid-template-columns:1fr}\n      .solution{position:static; width:100%}\n      .card{height:auto}\n      header{flex-direction:column; gap:12px}\n      .controls{margin-left:0}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"canvas-wrap\"><canvas id=\"bgCanvas\"></canvas></div>\n\n  <div class=\"container\">\n    <header>\n      <div class=\"title\">\n        <div class=\"brand\">\n          <h1>Greedy Algorithms</h1>\n          <p class=\"obs\">A refined, visual demonstration of greedy selection: always choose the best short-term option. Watch how the algorithm composes a solution by repeatedly picking the largest useful coin for a target amount.</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"playBtn\" class=\"btn play\" title=\"Play the greedy selection animation\">\n          ▶ Play Animation\n        </button>\n        <button id=\"resetBtn\" class=\"btn reset\" title=\"Reset the visualization\">\n          ⟲ Reset\n        </button>\n      </div>\n    </header>\n\n    <main class=\"main\" role=\"main\">\n      <section class=\"stage\" aria-label=\"Visualization stage\">\n        <div class=\"visual-top\">\n          <div class=\"amount-card\" aria-hidden=\"true\">\n            <div class=\"label\">Target Amount</div>\n            <div class=\"value\" id=\"targetValue\">63¢</div>\n            <div class=\"hint\">Greedy strategy: pick the largest coin not exceeding the remaining amount.</div>\n          </div>\n\n          <div class=\"rack\" aria-hidden=\"true\">\n            <div class=\"pile\" data-value=\"25\" id=\"pile25\">\n              <div class=\"coin gold\">25¢</div>\n              <div class=\"denom\">Quarter</div>\n              <div class=\"meta\">x ∞</div>\n            </div>\n\n            <div class=\"pile\" data-value=\"10\" id=\"pile10\">\n              <div class=\"coin silver\">10¢</div>\n              <div class=\"denom\">Dime</div>\n              <div class=\"meta\">x ∞</div>\n            </div>\n\n            <div class=\"pile\" data-value=\"5\" id=\"pile5\">\n              <div class=\"coin copper\">5¢</div>\n              <div class=\"denom\">Nickel</div>\n              <div class=\"meta\">x ∞</div>\n            </div>\n\n            <div class=\"pile\" data-value=\"1\" id=\"pile1\">\n              <div class=\"coin teal\">1¢</div>\n              <div class=\"denom\">Penny</div>\n              <div class=\"meta\">x ∞</div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"height:18px\"></div>\n\n        <div style=\"position:relative; padding:8px 8px 120px 8px;\">\n          <div style=\"color:var(--soft); line-height:1.6; font-size:14px; max-width:720px;\">\n            Visual flow:\n            <ul style=\"margin:8px 0 0 18px; color:rgba(255,255,255,0.75)\">\n              <li>Greedy picks the largest coin not exceeding remaining amount.</li>\n              <li>Watch coins animate from their piles into the solution collection.</li>\n              <li>Pseudo-code highlights show the algorithmic step-by-step decision.</li>\n            </ul>\n          </div>\n\n          <!-- floating spark container -->\n          <div id=\"sparkContainer\"></div>\n\n          <!-- solution card -->\n          <div class=\"solution\" id=\"solutionCard\" aria-live=\"polite\">\n            <div style=\"display:flex; width:100%; align-items:center;\">\n              <div class=\"title\">Solution (selected coins)</div>\n              <div class=\"total\" id=\"solutionTotal\">0¢</div>\n            </div>\n            <div class=\"stack\" id=\"solutionStack\" aria-hidden=\"true\">\n              <!-- coins will be appended here -->\n            </div>\n\n            <div style=\"display:flex; gap:8px; margin-top:6px;\">\n              <div style=\"font-size:12px; color:var(--soft)\">Steps:</div>\n              <div id=\"stepList\" style=\"font-size:12px; color:var(--accent-1); font-weight:700\">0</div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <aside class=\"card\" aria-label=\"Algorithm pseudo-code\">\n        <h3>Greedy Coin-Change (Pseudo-code)</h3>\n        <div class=\"code\" id=\"codeBlock\">\n          <div class=\"line\" data-line=\"1\">1. function greedyChange(amount, coins):</div>\n          <div class=\"line\" data-line=\"2\">2. &nbsp;&nbsp;sort coins descending</div>\n          <div class=\"line\" data-line=\"3\">3. &nbsp;&nbsp;result ← []</div>\n          <div class=\"line\" data-line=\"4\">4. &nbsp;&nbsp;for each coin in coins:</div>\n          <div class=\"line\" data-line=\"5\">5. &nbsp;&nbsp;&nbsp;&nbsp;while amount ≥ coin:</div>\n          <div class=\"line\" data-line=\"6\">6. &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;amount ← amount − coin</div>\n          <div class=\"line\" data-line=\"7\">7. &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;append coin to result</div>\n          <div class=\"line\" data-line=\"8\">8. &nbsp;&nbsp;return result</div>\n        </div>\n\n        <div class=\"meta\">Denominations: 25¢ (quarter), 10¢ (dime), 5¢ (nickel), 1¢ (penny). Amount: 63¢. Greedy chooses largest feasible coin each iteration.</div>\n\n        <div class=\"footer-note\">Aesthetics-first: subtle motion and rich gradients help emphasize algorithmic rhythm — observe, don't fiddle.</div>\n      </aside>\n    </main>\n  </div>\n\n  <script>\n    // Small, elegant interactive animation demonstrating greedy coin selection.\n    (function(){\n      // Config\n      const TARGET = 63;\n      const COINS = [25, 10, 5, 1];\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const solutionStack = document.getElementById('solutionStack');\n      const solutionTotal = document.getElementById('solutionTotal');\n      const stepList = document.getElementById('stepList');\n      const codeLines = Array.from(document.querySelectorAll('.line'));\n      const piles = {\n        25: document.getElementById('pile25'),\n        10: document.getElementById('pile10'),\n        5:  document.getElementById('pile5'),\n        1:  document.getElementById('pile1')\n      };\n      const stage = document.querySelector('.stage');\n      const sparkContainer = document.getElementById('sparkContainer');\n      let animating = false;\n      let chosen = [];\n      let remaining = TARGET;\n\n      // Initialize display\n      document.getElementById('targetValue').textContent = TARGET + '¢';\n      solutionTotal.textContent = '0¢';\n      stepList.textContent = '0';\n\n      // Helper: compute greedy sequence\n      function computeGreedySequence(amount, coins){\n        const seq = [];\n        let a = amount;\n        const sorted = coins.slice().sort((a,b)=>b-a);\n        for(let coin of sorted){\n          while(a >= coin){\n            seq.push(coin);\n            a -= coin;\n          }\n        }\n        return seq;\n      }\n\n      // Helper: create a floating coin element\n      function createFloatingCoin(value){\n        const el = document.createElement('div');\n        el.className = 'coin float coin-clone';\n        // Choose style based on value\n        if(value === 25) el.classList.add('gold');\n        else if(value === 10) el.classList.add('silver');\n        else if(value === 5) el.classList.add('copper');\n        else el.classList.add('teal');\n        el.textContent = value + '¢';\n        el.style.position = 'absolute';\n        el.style.zIndex = 40;\n        el.style.width = '56px';\n        el.style.height = '56px';\n        el.style.display = 'flex';\n        el.style.alignItems = 'center';\n        el.style.justifyContent = 'center';\n        el.style.transition = 'transform .78s cubic-bezier(.2,.9,.2,1), opacity .38s ease';\n        return el;\n      }\n\n      // Animate one pick: highlight pile, clone coin, animate to solution\n      function animatePick(value, index, totalSeq){\n        return new Promise(resolve => {\n          const pile = piles[value];\n          // highlight pile\n          pile.classList.add('active');\n          highlightCode(5); // while loop line\n          setTimeout(()=>highlightCode(6), 420); // subtract step\n          setTimeout(()=>highlightCode(7), 740); // append to result\n\n          const startRect = pile.getBoundingClientRect();\n          const targetRect = solutionStack.getBoundingClientRect();\n\n          // Create coin clone at pile position\n          const coin = createFloatingCoin(value);\n          document.body.appendChild(coin);\n          // position\n          coin.style.left = (startRect.left + startRect.width/2 - 28) + 'px';\n          coin.style.top = (startRect.top + startRect.height/2 - 28) + 'px';\n          coin.style.opacity = '0';\n          // small pop-in\n          requestAnimationFrame(()=>{\n            coin.style.opacity = '1';\n            coin.style.transform = 'scale(1.12)';\n          });\n\n          // Calculate destination: arrange coins in solutionStack in grid\n          const destX = targetRect.left + 12 + ((chosen.length % 6) * 44);\n          const destY = targetRect.top + 36 + Math.floor(chosen.length / 6) * 44;\n          // animate to dest\n          setTimeout(()=>{\n            coin.style.transform = 'translate(' + (destX - (startRect.left + startRect.width/2 - 28)) + 'px,' + (destY - (startRect.top + startRect.height/2 - 28)) + 'px) scale(1)';\n          }, 90);\n\n          // spark effect upon arrival\n          setTimeout(()=>{\n            spawnSpark(destX + 20, destY + 20);\n          }, 760);\n\n          // finalize: move coin from body into solutionStack DOM for layout\n          setTimeout(()=>{\n            // remove floating coin and add a small static in stack\n            coin.remove();\n            const coinNode = document.createElement('div');\n            coinNode.className = 'coin ' + (value===25?'gold':value===10?'silver':value===5?'copper':'teal');\n            coinNode.style.width = '36px';\n            coinNode.style.height = '36px';\n            coinNode.style.fontSize = '12px';\n            coinNode.textContent = value + '¢';\n            coinNode.style.boxShadow = '0 6px 16px rgba(6,12,34,0.36)';\n            solutionStack.appendChild(coinNode);\n\n            // update stats\n            chosen.push(value);\n            const sum = chosen.reduce((a,b)=>a+b,0);\n            solutionTotal.textContent = sum + '¢';\n            stepList.textContent = chosen.length;\n\n            // unhighlight pile\n            pile.classList.remove('active');\n            highlightCode(null);\n            resolve();\n          }, 920);\n        });\n      }\n\n      // Pseudo-code highlight helper\n      function highlightCode(lineNumber){\n        codeLines.forEach(line=>{\n          if(lineNumber && Number(line.dataset.line) === lineNumber){\n            line.classList.add('highlight');\n          } else {\n            line.classList.remove('highlight');\n          }\n        });\n      }\n\n      // Spark generator\n      function spawnSpark(x,y){\n        const s = document.createElement('div');\n        s.className = 'spark';\n        s.style.left = x + 'px';\n        s.style.top = y + 'px';\n        const hue = Math.random()*40 + 160;\n        s.style.background = 'radial-gradient(circle, rgba(126,231,199,1) 0%, rgba(104,166,255,0.7) 60%)';\n        sparkContainer.appendChild(s);\n        requestAnimationFrame(()=>{\n          s.style.opacity = '1';\n          s.style.transform = 'scale(1)';\n        });\n        setTimeout(()=>{ s.style.opacity='0'; s.style.transform='scale(.3)'; }, 260);\n        setTimeout(()=>s.remove(), 620);\n      }\n\n      // Main play sequence\n      async function play(){\n        if(animating) return;\n        animating = true;\n        playBtn.disabled = true;\n        resetBtn.disabled = true;\n        chosen = [];\n        remaining = TARGET;\n        solutionStack.innerHTML = '';\n        solutionTotal.textContent = '0¢';\n        stepList.textContent = '0';\n        highlightCode(1);\n        await new Promise(r=>setTimeout(r, 420));\n        highlightCode(2);\n        await new Promise(r=>setTimeout(r, 420));\n        highlightCode(3);\n        await new Promise(r=>setTimeout(r, 420));\n        // compute seq\n        const seq = computeGreedySequence(TARGET, COINS);\n        highlightCode(4);\n        await new Promise(r=>setTimeout(r, 400));\n\n        // animate each pick\n        for(let i=0;i<seq.length;i++){\n          await animatePick(seq[i], i, seq.length);\n          // small pause\n          await new Promise(r=>setTimeout(r, 160));\n        }\n\n        // final highlight and small glow\n        highlightCode(8);\n        await new Promise(r=>setTimeout(r, 520));\n        highlightCode(null);\n        animating = false;\n        playBtn.disabled = false;\n        resetBtn.disabled = false;\n      }\n\n      function reset(){\n        if(animating) return;\n        chosen = [];\n        remaining = TARGET;\n        solutionStack.innerHTML = '';\n        solutionTotal.textContent = '0¢';\n        stepList.textContent = '0';\n        highlightCode(null);\n      }\n\n      // Attach handlers\n      playBtn.addEventListener('click', play);\n      resetBtn.addEventListener('click', reset);\n\n      // Tiny background particle canvas for atmosphere\n      const canvas = document.getElementById('bgCanvas');\n      const ctx = canvas.getContext('2d');\n      let w=0,h=0;\n      function resize(){\n        w = canvas.width = innerWidth;\n        h = canvas.height = innerHeight;\n      }\n      window.addEventListener('resize', resize);\n      resize();\n\n      // create particles\n      const P = [];\n      const NP = Math.max(18, Math.floor((w*h)/90000));\n      for(let i=0;i<NP;i++){\n        P.push({\n          x: Math.random()*w,\n          y: Math.random()*h,\n          r: 6 + Math.random()*22,\n          vx: (Math.random()-0.5)*0.12,\n          vy: (Math.random()-0.5)*0.12,\n          hue: 180 + Math.random()*60,\n          alpha: 0.02 + Math.random()*0.04\n        });\n      }\n\n      function frame(){\n        ctx.clearRect(0,0,w,h);\n        // soft vignette\n        const grad = ctx.createLinearGradient(0,0,w,h);\n        grad.addColorStop(0, 'rgba(10,18,36,0.12)');\n        grad.addColorStop(1, 'rgba(9,14,22,0.28)');\n        ctx.fillStyle = grad;\n        ctx.fillRect(0,0,w,h);\n\n        for(let p of P){\n          p.x += p.vx;\n          p.y += p.vy;\n          if(p.x < -p.r) p.x = w + p.r;\n          if(p.x > w + p.r) p.x = -p.r;\n          if(p.y < -p.r) p.y = h + p.r;\n          if(p.y > h + p.r) p.y = -p.r;\n          const g = ctx.createRadialGradient(p.x,p.y,p.r*0.02,p.x,p.y,p.r);\n          g.addColorStop(0, `hsla(${p.hue},80%,70%,${p.alpha})`);\n          g.addColorStop(1, `hsla(${p.hue},60%,24%,0)`);\n          ctx.fillStyle = g;\n          ctx.beginPath();\n          ctx.arc(p.x,p.y,p.r,0,Math.PI*2);\n          ctx.fill();\n        }\n\n        requestAnimationFrame(frame);\n      }\n      requestAnimationFrame(frame);\n\n      // minimal accessible hint: keyboard activates play with Space\n      window.addEventListener('keydown', (e)=>{\n        if(e.code === 'Space'){\n          e.preventDefault();\n          if(!animating) play();\n        }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
