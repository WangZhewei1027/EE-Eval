    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Undirected Graph</title>\n    <style>\n        /* Minimal CSS: no styling for visual appeal */\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #graph {\n            margin-top: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interactive Undirected Graph</h1>\n\n    <div>\n        <label for=\"nodeInput\">Add Node:</label>\n        <input type=\"text\" id=\"nodeInput\" placeholder=\"Node Name\">\n        <button id=\"addNodeBtn\">Add Node</button>\n        <button id=\"clearGraphBtn\">Clear Graph</button>\n    </div>\n\n    <div>\n        <label for=\"edgeInputStart\">From:</label>\n        <input type=\"text\" id=\"edgeInputStart\" placeholder=\"Start Node\">\n        <label for=\"edgeInputEnd\">To:</label>\n        <input type=\"text\" id=\"edgeInputEnd\" placeholder=\"End Node\">\n        <button id=\"addEdgeBtn\">Add Edge</button>\n    </div>\n\n    <div id=\"graph\"></div>\n\n    <script>\n        class Graph {\n            constructor() {\n                this.adjacencyList = {};\n            }\n\n            addNode(node) {\n                if (!this.adjacencyList[node]) {\n                    this.adjacencyList[node] = [];\n                }\n            }\n\n            addEdge(node1, node2) {\n                if (!this.adjacencyList[node1]) {\n                    this.addNode(node1);\n                }\n                if (!this.adjacencyList[node2]) {\n                    this.addNode(node2);\n                }\n                this.adjacencyList[node1].push(node2);\n                this.adjacencyList[node2].push(node1);\n            }\n\n            clear() {\n                this.adjacencyList = {};\n            }\n\n            display() {\n                const graphDiv = document.getElementById('graph');\n                graphDiv.innerHTML = '';\n                for (const node in this.adjacencyList) {\n                    graphDiv.innerHTML += `${node}: ${this.adjacencyList[node].join(', ')}<br>`;\n                }\n            }\n        }\n\n        const graph = new Graph();\n\n        document.getElementById('addNodeBtn').addEventListener('click', () => {\n            const nodeName = document.getElementById('nodeInput').value;\n            if (nodeName) {\n                graph.addNode(nodeName);\n                document.getElementById('nodeInput').value = '';\n                graph.display();\n            }\n        });\n\n        document.getElementById('addEdgeBtn').addEventListener('click', () => {\n            const startNode = document.getElementById('edgeInputStart').value;\n            const endNode = document.getElementById('edgeInputEnd').value;\n            if (startNode && endNode) {\n                graph.addEdge(startNode, endNode);\n                document.getElementById('edgeInputStart').value = '';\n                document.getElementById('edgeInputEnd').value = '';\n                graph.display();\n            }\n        });\n\n        document.getElementById('clearGraphBtn').addEventListener('click', () => {\n            graph.clear();\n            document.getElementById('graph').innerHTML = '';\n        });\n    </script>\n</body>\n</html>"
