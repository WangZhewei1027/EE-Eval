    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Depth-First Search (DFS)</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n            font-family: monospace;\n        }\n        #graph {\n            width: 800px;\n            height: 600px;\n            border: 1px solid #000;\n            margin: 40px auto;\n        }\n        .node {\n            border: 1px solid #000;\n            padding: 5px;\n            font-size: 12px;\n            cursor: pointer;\n        }\n        .edge {\n            border: 1px solid #000;\n            padding: 2px;\n            cursor: pointer;\n        }\n        .visited {\n            background-color: #ccc;\n        }\n        .current {\n            background-color: #999;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"graph\"></div>\n    <script>\n        class Node {\n            constructor(x, y) {\n                this.x = x;\n                this.y = y;\n                this.children = [];\n                this.visited = false;\n                this.current = false;\n            }\n        }\n\n        class Edge {\n            constructor(from, to) {\n                this.from = from;\n                this.to = to;\n            }\n        }\n\n        function createGraph(width, height) {\n            let graph = document.getElementById('graph');\n            graph.style.width = width + 'px';\n            graph.style.height = height + 'px';\n            graph.innerHTML = '';\n\n            let nodes = [];\n            let edges = [];\n\n            for (let i = 0; i < height; i++) {\n                let row = '';\n                for (let j = 0; j < width; j++) {\n                    row += '<div class=\"node\" id=\"' + i + ',' + j + '\">';\n\n                    if (i === 0 || i === height - 1 || j === 0 || j === width - 1) {\n                        row += '<div class=\"edge\" id=\"' + i + ',' + j + '\">';\n\n                        for (let k = 0; k < 10; k++) {\n                            let edge = new Edge(i, j);\n                            edge.from = i;\n                            edge.to = j;\n                            edge.children.push(edge);\n                            nodes.push(edge);\n                        }\n\n                        row += '</div>';\n                    } else {\n                        row += '<div class=\"edge\" id=\"' + i + ',' + j + '\">';\n\n                        for (let k = 0; k < 10; k++) {\n                            let edge = new Edge(i, j);\n                            edge.from = i;\n                            edge.to = j;\n                            edge.children.push(edge);\n                            nodes.push(edge);\n                        }\n\n                        row += '</div>';\n                    }\n\n                    row += '</div>';\n                }\n\n                graph.innerHTML += row;\n            }\n\n            function dfs(node) {\n                node.current = true;\n                for (let child of node.children) {\n                    if (child.current) {\n                        dfs(child);\n                    }\n                }\n\n                node.current = false;\n                let visited = false;\n                for (let edge of nodes) {\n                    if (edge.to === node.x && edge.to === node.y && !edge.visited) {\n                        edge.visited = true;\n                        dfs(edge);\n                    }\n                }\n            }\n\n            for (let node of nodes) {\n                if (node.current) {\n                    dfs(node);\n                }\n            }\n        }\n\n        let width = 800;\n        let height = 600;\n        createGraph(width, height);\n    </script>\n</body>\n</html>"
