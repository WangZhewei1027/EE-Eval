    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Doubly Linked List Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1s ease-out;\n        }\n        \n        .header h1 {\n            font-size: 2.8rem;\n            font-weight: 700;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 0.5rem;\n        }\n        \n        .header p {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n        }\n        \n        .visualization-container {\n            width: 100%;\n            max-width: 900px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            margin-bottom: 2rem;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .visualization-container::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 10px;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n        }\n        \n        .linked-list {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 300px;\n            position: relative;\n            padding: 2rem 0;\n        }\n        \n        .node {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            background: white;\n            border: 3px solid var(--primary);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: 600;\n            font-size: 1.5rem;\n            color: var(--primary);\n            position: relative;\n            z-index: 2;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            transition: all 0.3s ease;\n            animation: popIn 0.5s ease-out forwards;\n            opacity: 0;\n        }\n        \n        .node.active {\n            transform: scale(1.1);\n            box-shadow: 0 0 0 5px rgba(108, 92, 231, 0.3);\n        }\n        \n        .node::before, .node::after {\n            content: '';\n            position: absolute;\n            width: 60px;\n            height: 4px;\n            background: var(--secondary);\n            z-index: 1;\n        }\n        \n        .node::before {\n            right: -60px;\n            top: 50%;\n            transform: translateY(-50%);\n        }\n        \n        .node::after {\n            left: -60px;\n            top: 50%;\n            transform: translateY(-50%);\n        }\n        \n        .node:first-child::after, .node:last-child::before {\n            display: none;\n        }\n        \n        .arrow {\n            position: absolute;\n            width: 20px;\n            height: 20px;\n            border-top: 4px solid var(--primary);\n            border-right: 4px solid var(--primary);\n            z-index: 3;\n        }\n        \n        .arrow.next {\n            transform: rotate(45deg);\n            right: -30px;\n            top: 50%;\n            margin-top: -10px;\n        }\n        \n        .arrow.prev {\n            transform: rotate(-135deg);\n            left: -30px;\n            top: 50%;\n            margin-top: -10px;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n        \n        button.primary {\n            background: var(--primary);\n            color: white;\n        }\n        \n        button.primary:hover {\n            background: #5649c7;\n            transform: translateY(-2px);\n            box-shadow: 0 7px 20px rgba(108, 92, 231, 0.3);\n        }\n        \n        button.secondary {\n            background: white;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n        }\n        \n        button.secondary:hover {\n            background: #f5f6fa;\n            transform: translateY(-2px);\n        }\n        \n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n            flex-wrap: wrap;\n        }\n        \n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n        \n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n        \n        .legend-next {\n            background: var(--primary);\n        }\n        \n        .legend-prev {\n            background: var(--accent);\n        }\n        \n        .legend-node {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n            border: 2px solid var(--primary);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(-20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes popIn {\n            0% { opacity: 0; transform: scale(0.5); }\n            70% { opacity: 1; transform: scale(1.1); }\n            100% { opacity: 1; transform: scale(1); }\n        }\n        \n        @keyframes highlight {\n            0% { box-shadow: 0 0 0 0 rgba(108, 92, 231, 0.4); }\n            70% { box-shadow: 0 0 0 15px rgba(108, 92, 231, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(108, 92, 231, 0); }\n        }\n        \n        .highlight {\n            animation: highlight 1.5s ease-out;\n        }\n        \n        .footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Doubly Linked List</h1>\n        <p>A visual representation of a doubly linked list where each node contains a reference to both the next and previous nodes, enabling bidirectional traversal.</p>\n    </div>\n    \n    <div class=\"visualization-container\">\n        <div class=\"linked-list\" id=\"linkedList\">\n            <!-- Nodes will be inserted here by JavaScript -->\n        </div>\n    </div>\n    \n    <div class=\"controls\">\n        <button class=\"primary\" id=\"traverseNext\">Traverse Next</button>\n        <button class=\"secondary\" id=\"traversePrev\">Traverse Previous</button>\n    </div>\n    \n    <div class=\"legend\">\n        <div class=\"legend-item\">\n            <div class=\"legend-node\"></div>\n            <span>Node</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color legend-next\"></div>\n            <span>Next pointer</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color legend-prev\"></div>\n            <span>Previous pointer</span>\n        </div>\n    </div>\n    \n    <div class=\"footer\">\n        <p>Visualization of a fundamental data structure in computer science</p>\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const linkedList = document.getElementById('linkedList');\n            const traverseNextBtn = document.getElementById('traverseNext');\n            const traversePrevBtn = document.getElementById('traversePrev');\n            \n            // Create nodes\n            const nodes = [];\n            const values = ['A', 'B', 'C', 'D', 'E'];\n            \n            values.forEach((value, index) => {\n                const node = document.createElement('div');\n                node.className = 'node';\n                node.textContent = value;\n                node.dataset.index = index;\n                node.style.animationDelay = `${index * 0.2}s`;\n                \n                // Add arrows for next and previous (except first and last)\n                if (index < values.length - 1) {\n                    const nextArrow = document.createElement('div');\n                    nextArrow.className = 'arrow next';\n                    node.appendChild(nextArrow);\n                }\n                \n                if (index > 0) {\n                    const prevArrow = document.createElement('div');\n                    prevArrow.className = 'arrow prev';\n                    node.appendChild(prevArrow);\n                }\n                \n                linkedList.appendChild(node);\n                nodes.push(node);\n            });\n            \n            let currentIndex = 0;\n            nodes[currentIndex].classList.add('active');\n            \n            // Traverse next\n            traverseNextBtn.addEventListener('click', function() {\n                nodes[currentIndex].classList.remove('active');\n                currentIndex = (currentIndex + 1) % nodes.length;\n                nodes[currentIndex].classList.add('active');\n                nodes[currentIndex].classList.add('highlight');\n                \n                setTimeout(() => {\n                    nodes[currentIndex].classList.remove('highlight');\n                }, 1500);\n            });\n            \n            // Traverse previous\n            traversePrevBtn.addEventListener('click', function() {\n                nodes[currentIndex].classList.remove('active');\n                currentIndex = (currentIndex - 1 + nodes.length) % nodes.length;\n                nodes[currentIndex].classList.add('active');\n                nodes[currentIndex].classList.add('highlight');\n                \n                setTimeout(() => {\n                    nodes[currentIndex].classList.remove('highlight');\n                }, 1500);\n            });\n            \n            // Auto-traverse demonstration\n            setTimeout(() => {\n                const autoTraverse = setInterval(() => {\n                    traverseNextBtn.click();\n                }, 2000);\n                \n                // Stop after one full cycle\n                setTimeout(() => {\n                    clearInterval(autoTraverse);\n                }, values.length * 2000 + 1000);\n            }, 3000);\n        });\n    </script>\n</body>\n</html>"
  },
