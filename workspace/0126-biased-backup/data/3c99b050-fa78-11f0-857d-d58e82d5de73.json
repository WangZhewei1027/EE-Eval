    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>B-Tree Index - Visual Concept</title>\n<style>\n  /* Import a beautiful serif font for headings and a clean sans-serif for body */\n  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,600;1,600&family=Inter:wght@400;700&display=swap');\n\n  :root {\n    --color-bg: #0f172a;\n    --color-primary: #4ade80; /* Emerald green */\n    --color-secondary: #818cf8; /* Soft indigo */\n    --color-accent: #facc15; /* Amber */\n    --color-light: #e0e7ff;\n    --color-mid: #a5b4fc;\n    --color-dark: #0f172a;\n    --color-node-bg: #1e293b;\n    --color-node-border: #4ade80;\n    --color-key-bg: #22c55e;\n    --color-key-bg-alt: #16a34a;\n    --color-shadow: rgba(34, 197, 94, 0.35);\n    --ease: cubic-bezier(0.4, 0, 0.2, 1);\n    --transition: 0.4s var(--ease);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f172a 0%, #050a1f 100%);\n    font-family: 'Inter', sans-serif;\n    color: var(--color-light);\n    user-select: none;\n    overflow-x: hidden;\n  }\n\n  header {\n    padding: 3rem 2rem 1rem;\n    text-align: center;\n  }\n\n  header h1 {\n    font-family: 'Lora', serif;\n    font-weight: 600;\n    font-size: 3.25rem;\n    color: var(--color-primary);\n    letter-spacing: 0.05em;\n    text-shadow:\n      0 0 6px var(--color-primary),\n      0 0 12px var(--color-primary);\n    margin: 0 0 0.25em;\n  }\n  header h2 {\n    font-weight: 400;\n    font-size: 1.2rem;\n    color: var(--color-mid);\n    letter-spacing: 0.1em;\n    font-style: italic;\n    margin-top: 0;\n  }\n\n  main {\n    padding: 2rem;\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  /* Container for the B-Tree visualization */\n  .tree-container {\n    position: relative;\n    width: 100%;\n    height: 540px;\n    margin: 4rem auto;\n    perspective: 1600px;\n    user-select: none;\n  }\n\n  /* The tree root node container - preserve 3D */\n  .tree-root {\n    position: absolute;\n    top: 50px;\n    left: 50%;\n    transform-style: preserve-3d;\n    transform-origin: center top;\n    transform: translateX(-50%);\n    filter: drop-shadow(0 0 16px var(--color-primary));\n  }\n\n  /* Levels container aligned horizontally with spacing */\n  .tree-level {\n    display: flex;\n    justify-content: center;\n    gap: 2.6rem;\n    margin-top: 72px;\n    perspective: 1600px;\n  }\n\n  /* Node container */\n  .node {\n    background: var(--color-node-bg);\n    border: 3.5px solid var(--color-node-border);\n    border-radius: 20px;\n    box-shadow:\n      0 0 10px var(--color-shadow),\n      inset 0 0 8px #22c55e40;\n    padding: 0.375rem 1.4rem;\n    display: flex;\n    gap: 10px;\n    min-width: 130px;\n    justify-content: center;\n    align-items: center;\n    filter: drop-shadow(0 0 6px #22c55e88);\n    user-select: none;\n    transform-style: preserve-3d;\n  }\n\n  /* Each key in node */\n  .key {\n    background: linear-gradient(180deg, var(--color-key-bg) 0%, var(--color-key-bg-alt) 100%);\n    border-radius: 8px;\n    padding: 0.38rem 0.9rem;\n    font-weight: 700;\n    font-family: 'Lora', serif;\n    font-size: 1.2rem;\n    color: white;\n    text-shadow:\n      0 0 2px #166534cc,\n      0 2px 4px #134e30cc;\n    box-shadow:\n      0 0 6px #22c55e88,\n      inset 0 -2px 3px rgba(255 255 255 / 0.25);\n    user-select: none;\n    filter: drop-shadow(0 1px 2px #166534cc);\n    transition: background-color 0.3s ease;\n    cursor: default;\n  }\n\n  /* Lines connecting nodes */\n  svg.connector {\n    position: absolute;\n    top: 0;\n    left: 0;\n    overflow: visible;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Polished buttons container */\n  .controls {\n    display: flex;\n    justify-content: center;\n    margin-top: 1.5rem;\n    gap: 1.6rem;\n  }\n\n  button {\n    background: transparent;\n    border: 2.6px solid var(--color-secondary);\n    color: var(--color-secondary);\n    font-weight: 600;\n    font-family: 'Inter', sans-serif;\n    font-size: 1rem;\n    padding: 0.5em 1.4em;\n    border-radius: 10px;\n    cursor: pointer;\n    transition: background-color 0.35s var(--ease), border-color 0.35s var(--ease), color 0.35s var(--ease);\n    user-select: none;\n  }\n\n  button:hover,\n  button:focus {\n    background-color: var(--color-secondary);\n    color: var(--color-dark);\n    outline: none;\n    box-shadow:\n      0 0 8px var(--color-secondary),\n      0 0 16px var(--color-secondary);\n  }\n\n  /* Explanation text */\n  .explanation {\n    max-width: 720px;\n    margin: 1.5rem auto 2.6rem;\n    font-size: 1.1rem;\n    color: var(--color-mid);\n    line-height: 1.6;\n    font-family: 'Inter', sans-serif;\n    user-select: none;\n    max-width: 720px;\n  }\n\n  /* Legend styling */\n  .legend {\n    max-width: 360px;\n    margin: 2rem auto 5rem;\n    padding: 1rem 1.4rem;\n    border: 2.5px solid var(--color-primary);\n    border-radius: 14px;\n    font-family: 'Inter', sans-serif;\n    color: var(--color-light);\n    background: rgba(34, 197, 94, 0.1);\n    box-shadow:\n      0 0 18px #22c55e55,\n      inset 0 0 6px #22c55e55;\n    user-select: none;\n  }\n  .legend h3 {\n    font-family: 'Lora', serif;\n    font-weight: 600;\n    font-size: 1.4rem;\n    margin-top: 0;\n    margin-bottom: 0.7rem;\n    color: var(--color-primary);\n    text-shadow: 0 0 6px #4ade80dd;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 0.8rem;\n  }\n  .legend-node {\n    width: 28px;\n    height: 26px;\n    border-radius: 16px;\n    background: var(--color-node-bg);\n    border: 3.5px solid var(--color-node-border);\n    box-shadow: 0 0 10px var(--color-shadow);\n  }\n  .legend-key {\n    width: 24px;\n    height: 22px;\n    border-radius: 8px;\n    background: linear-gradient(180deg, var(--color-key-bg) 0%, var(--color-key-bg-alt) 100%);\n    box-shadow: 0 0 8px #22c55e88;\n  }\n  .legend-text {\n    font-size: 1rem;\n    color: var(--color-mid);\n  }\n\n  /* Animate the B-tree fadeIn on page load */\n  @keyframes fadeInUp {\n    0% {\n      opacity: 0; \n      transform: translateY(24px);\n    }\n    100% {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  /* Subtle fade and slide for nodes */\n  .node {\n    animation: fadeInUp 0.8s var(--ease) forwards;\n  }\n\n  /* Stagger animation delays for nodes */\n  .level0 .node { animation-delay: 0.15s; }\n  .level1 .node:nth-child(1) { animation-delay: 0.35s; }\n  .level1 .node:nth-child(2) { animation-delay: 0.45s; }\n  .level1 .node:nth-child(3) { animation-delay: 0.55s; }\n  .level2 .node:nth-child(1) { animation-delay: 0.75s; }\n  .level2 .node:nth-child(2) { animation-delay: 0.85s; }\n  .level2 .node:nth-child(3) { animation-delay: 0.95s; }\n  .level2 .node:nth-child(4) { animation-delay: 1.05s; }\n  .level2 .node:nth-child(5) { animation-delay: 1.15s; }\n  .level2 .node:nth-child(6) { animation-delay: 1.25s; }\n  .level2 .node:nth-child(7) { animation-delay: 1.35s; }\n\n  /* Smooth scaling for buttons on click */\n  button:active {\n    transform: scale(0.93);\n    transition: transform 0.12s ease;\n  }\n\n  /* Custom tooltip for keys */\n  .key[data-tooltip] {\n    position: relative;\n  }\n  .key[data-tooltip]:hover::after {\n    content: attr(data-tooltip);\n    position: absolute;\n    bottom: 130%;\n    left: 50%;\n    transform: translateX(-50%);\n    background: var(--color-secondary);\n    color: var(--color-dark);\n    padding: 4px 10px;\n    border-radius: 8px;\n    font-size: 0.85rem;\n    white-space: nowrap;\n    opacity: 0.9;\n    pointer-events: none;\n    transition: opacity 0.3s ease;\n  }\n</style>\n</head>\n<body>\n<header role=\"banner\">\n  <h1>B-Tree Index</h1>\n  <h2>Visual Concept &amp; Structure</h2>\n</header>\n\n<main>\n  <p class=\"explanation\" aria-live=\"polite\">\n    The B-Tree index is a balanced tree data structure widely used in databases to efficiently store and retrieve sorted data. It maintains sorted keys within nodes,\n    allowing logarithmic search, insertion, and deletion. This visualization depicts a classic order-3 B-Tree (max 2 keys per node, 3 children), illustrating the hierarchy and balanced nature of the index.\n  </p>\n\n  <div class=\"tree-container\" aria-label=\"B-Tree index visualization\" role=\"img\" aria-describedby=\"legend-desc\">\n    <div id=\"connectors\"></div>\n    <div class=\"tree-root\" aria-hidden=\"true\">\n      <!-- Level 0 (Root) -->\n      <div class=\"tree-level level0\" aria-hidden=\"true\">\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 50\">50</span>\n        </div>\n      </div>\n      <!-- Level 1 -->\n      <div class=\"tree-level level1\" aria-hidden=\"true\">\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Keys 20, 30\">20</span><span class=\"key\" data-tooltip=\"Keys 20, 30\">30</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 70\">70</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Keys 90, 95\">90</span><span class=\"key\" data-tooltip=\"Keys 90, 95\">95</span>\n        </div>\n      </div>\n      <!-- Level 2 -->\n      <div class=\"tree-level level2\" aria-hidden=\"true\">\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 10\">10</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 25\">25</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 35\">35</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 55\">55</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 65\">65</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 85\">85</span>\n        </div>\n        <div class=\"node\" tabindex=\"-1\" aria-hidden=\"true\">\n          <span class=\"key\" data-tooltip=\"Key 100\">100</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"legend\" id=\"legend-desc\">\n    <h3>Legend</h3>\n    <div class=\"legend-item\">\n      <div class=\"legend-node\" aria-hidden=\"true\"></div>\n      <div class=\"legend-text\">Node: Contains up to 2 keys and child pointers</div>\n    </div>\n    <div class=\"legend-item\">\n      <div class=\"legend-key\" aria-hidden=\"true\"></div>\n      <div class=\"legend-text\">Key: Sorted value stored within a node </div>\n    </div>\n  </div>\n\n  <div class=\"controls\" role=\"group\" aria-label=\"B-tree visualization controls\">\n    <button id=\"resetBtn\" aria-live=\"polite\" aria-label=\"Reset highlight\">Reset Highlight</button>\n    <button id=\"highlightBtn\" aria-live=\"polite\" aria-label=\"Highlight search path\">Highlight Search Path</button>\n  </div>\n</main>\n\n<script>\n  /* Purpose: Draw SVG connecting lines between B-tree nodes elegantly */\n\n  // Configuration for the tree layout nodes\n  const treeContainer = document.querySelector('.tree-container');\n  const rootDiv = document.querySelector('.tree-root');\n  const connectorsContainer = document.createElementNS(\"http://www.w3.org/2000/svg\", \"svg\");\n  connectorsContainer.classList.add('connector');\n  treeContainer.appendChild(connectorsContainer);\n\n  // Nodes arranged by level\n  const levels = [\n    document.querySelectorAll('.level0 > .node'),\n    document.querySelectorAll('.level1 > .node'),\n    document.querySelectorAll('.level2 > .node')\n  ];\n\n  connectorsContainer.setAttribute('width', treeContainer.offsetWidth);\n  connectorsContainer.setAttribute('height', treeContainer.offsetHeight);\n  connectorsContainer.style.width = treeContainer.offsetWidth + 'px';\n  connectorsContainer.style.height = treeContainer.offsetHeight + 'px';\n\n  const NS = \"http://www.w3.org/2000/svg\";\n\n  // Clear all children in SVG\n  function clearSVG(){\n    while(connectorsContainer.firstChild){\n      connectorsContainer.removeChild(connectorsContainer.firstChild);\n    }\n  }\n\n  // Given two DOM nodes, get their center bottom (parent) and center top (child) points relative to SVG viewport\n  function getConnectionPoints(parentNode, childNode){\n    const parentRect = parentNode.getBoundingClientRect();\n    const childRect = childNode.getBoundingClientRect();\n    const containerRect = treeContainer.getBoundingClientRect();\n\n    const startX = parentRect.left + parentRect.width / 2 - containerRect.left;\n    const startY = parentRect.top + parentRect.height - containerRect.top;\n\n    const endX = childRect.left + childRect.width / 2 - containerRect.left;\n    const endY = childRect.top - containerRect.top;\n\n    return {startX, startY, endX, endY};\n  }\n\n  // Cubic Bezier curve path between parent and child for a smooth connection\n  function createPath({startX, startY, endX, endY}){\n    const dx = endX - startX;\n    const dy = endY - startY;\n    // Control points for smooth curve\n    const controlX1 = startX;\n    const controlY1 = startY + dy * 0.4;\n    const controlX2 = endX;\n    const controlY2 = endY - dy * 0.4;\n\n    return `M${startX},${startY} C${controlX1},${controlY1} ${controlX2},${controlY2} ${endX},${endY}`;\n  }\n\n  // The B-tree links structure according to node indexing\n  // Level0 node => children: Level1 nodes 0,1,2\n  // Level1 nodes => children: Level2 nodes respective slices\n  const edges = [\n    // From root to level 1 nodes\n    {from: {level: 0, index: 0}, to: {level:1, index:0}},\n    {from: {level: 0, index: 0}, to: {level:1, index:1}},\n    {from: {level: 0, index: 0}, to: {level:1, index:2}},\n\n    // Level 1 nodes to level 2 nodes\n    {from: {level: 1, index: 0}, to: {level:2, index:0}},\n    {from: {level: 1, index: 0}, to: {level:2, index:1}},\n    {from: {level: 1, index: 0}, to: {level:2, index:2}},\n\n    {from: {level: 1, index: 1}, to: {level:2, index:3}},\n    {from: {level: 1, index: 1}, to: {level:2, index:4}},\n\n    {from: {level: 1, index: 2}, to: {level:2, index:5}},\n    {from: {level: 1, index: 2}, to: {level:2, index:6}},\n  ];\n\n  // Draw all connectors\n  function drawConnections(){\n    clearSVG();\n    edges.forEach(edge => {\n      const parentNode = levels[edge.from.level][edge.from.index];\n      const childNode = levels[edge.to.level][edge.to.index];\n      if (!parentNode || !childNode) return;\n      const points = getConnectionPoints(parentNode, childNode);\n      const pathData = createPath(points);\n\n      const path = document.createElementNS(NS, 'path');\n      path.setAttribute('d', pathData);\n      path.setAttribute('stroke', 'var(--color-primary)');\n      path.setAttribute('stroke-width', '2.8');\n      path.setAttribute('fill', 'none');\n      path.setAttribute('stroke-linejoin', 'round');\n      path.setAttribute('stroke-linecap', 'round');\n      path.style.filter = 'drop-shadow(0 0 5px var(--color-primary))';\n      connectorsContainer.appendChild(path);\n    });\n  }\n\n  // Redraw connections on resize\n  window.addEventListener('resize', () => {\n    connectorsContainer.setAttribute('width', treeContainer.offsetWidth);\n    connectorsContainer.setAttribute('height', treeContainer.offsetHeight);\n    connectorsContainer.style.width = treeContainer.offsetWidth + 'px';\n    connectorsContainer.style.height = treeContainer.offsetHeight + 'px';\n    drawConnections();\n  });\n\n  // Highlight path on a simple search from root to a target leaf following keys 70 > 65\n  // Chosen path nodes to highlight, by DOM references:\n  const highlightPathNodes = [\n    levels[0][0], // Root\n    levels[1][1], // Node with key 70\n    levels[2][4]  // Node with key 65\n  ];\n\n  // For visual highlight: green glow and scale keys gently\n  function highlightPath(){\n    clearHighlight();\n    highlightPathNodes.forEach(node => {\n      node.style.borderColor = 'var(--color-accent)';\n      node.style.boxShadow = `0 0 16px var(--color-accent), inset 0 0 12px #f59e0baa`;\n      const keys = node.querySelectorAll('.key');\n      keys.forEach(k => {\n        // Highlight keys in path with amber\n        k.style.background = 'linear-gradient(180deg, var(--color-accent) 0%, #b45309 100%)';\n        k.style.boxShadow = '0 0 12px var(--color-accent), inset 0 -2px 5px #b4530933';\n        k.style.transform = 'scale(1.1)';\n      });\n    });\n  }\n  function clearHighlight(){\n    // Reset all nodes to defaults\n    levels.flat().forEach(node => {\n      node.style.borderColor = 'var(--color-node-border)';\n      node.style.boxShadow = '0 0 10px var(--color-shadow), inset 0 0 8px #22c55e40';\n      const keys = node.querySelectorAll('.key');\n      keys.forEach(k => {\n        k.style.background = '';\n        k.style.boxShadow = '';\n        k.style.transform = '';\n      });\n    });\n  }\n\n  // Initialize drawing\n  drawConnections();\n\n  // Buttons logic\n  const resetBtn = document.getElementById('resetBtn');\n  const highlightBtn = document.getElementById('highlightBtn');\n\n  resetBtn.addEventListener('click', () => {\n    clearHighlight();\n  });\n\n  highlightBtn.addEventListener('click', () => {\n    highlightPath();\n  });\n\n  // Accessibility: Keyboard support for buttons\n  resetBtn.tabIndex = 0;\n  highlightBtn.tabIndex = 0;\n\n  // On load: no highlight\n  clearHighlight();\n\n</script>\n</body>\n</html>"
  },
