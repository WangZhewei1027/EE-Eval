    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>HTTP Interactive Model</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #response { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive HTTP Model</h1>\n\n<div>\n    <h2>Request Configuration</h2>\n    <label for=\"method\">Method:</label>\n    <select id=\"method\">\n        <option value=\"GET\">GET</option>\n        <option value=\"POST\">POST</option>\n        <option value=\"PUT\">PUT</option>\n        <option value=\"DELETE\">DELETE</option>\n    </select>\n    \n    <label for=\"url\">URL:</label>\n    <input type=\"text\" id=\"url\" placeholder=\"Enter URL\" />\n\n    <label for=\"header\">Header:</label>\n    <input type=\"text\" id=\"header\" placeholder=\"Enter Header\" />\n\n    <label for=\"body\">Body:</label>\n    <textarea id=\"body\" rows=\"4\" placeholder=\"Enter request body...\"></textarea>\n\n    <button id=\"sendRequest\">Send Request</button>\n</div>\n\n<div id=\"response\">\n    <h3>Response</h3>\n    <pre id=\"responseDisplay\"></pre>\n</div>\n\n<div>\n    <h2>Custom State Management</h2>\n    <label for=\"stateInput\">State Input:</label>\n    <input type=\"text\" id=\"stateInput\" placeholder=\"Enter state value\" />\n    <button id=\"updateState\">Update State</button>\n    <button id=\"resetState\">Reset State</button>\n    <h3>Current State Value:</h3>\n    <div id=\"currentState\">N/A</div>\n</div>\n\n<div>\n    <h2>Simulated Environment</h2>\n    <label for=\"envInput\">Environment Variable:</label>\n    <input type=\"text\" id=\"envInput\" placeholder=\"Set environment variable\" />\n    <button id=\"setEnv\">Set Env</button>\n    <div id=\"envDisplay\"></div>\n</div>\n\n<script>\n    document.getElementById('sendRequest').addEventListener('click', function() {\n        const method = document.getElementById('method').value;\n        const url = document.getElementById('url').value;\n        const header = document.getElementById('header').value;\n        const body = document.getElementById('body').value;\n\n        // Simulate a basic HTTP response\n        const response = {\n            method: method,\n            url: url,\n            header: header,\n            body: body,\n            status: 200,\n            message: \"Success\"\n        };\n\n        document.getElementById('responseDisplay').innerText = JSON.stringify(response, null, 2);\n    });\n\n    let currentState = 'Initial State';\n    document.getElementById('updateState').addEventListener('click', function() {\n        currentState = document.getElementById('stateInput').value;\n        document.getElementById('currentState').innerText = currentState;\n    });\n\n    document.getElementById('resetState').addEventListener('click', function() {\n        currentState = 'Initial State';\n        document.getElementById('currentState').innerText = currentState;\n    });\n\n    let envVar = '';\n    document.getElementById('setEnv').addEventListener('click', function() {\n        envVar = document.getElementById('envInput').value;\n        document.getElementById('envDisplay').innerText = \"Environment Variable Set: \" + envVar;\n    });\n</script>\n\n</body>\n</html>"
