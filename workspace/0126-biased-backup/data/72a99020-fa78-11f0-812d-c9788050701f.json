    const toY = toRect.top - graphRect.top + toRect.height/2;\n                \n                // Calculate edge length and angle\n                const length = Math.sqrt(Math.pow(toX - fromX, 2) + Math.pow(toY - fromY, 2));\n                const angle = Math.atan2(toY - fromY, toX - fromX) * 180 / Math.PI;\n                \n                // Create edge line\n                const edgeElement = document.createElement('div');\n                edgeElement.className = 'edge';\n                edgeElement.style.width = `${length}px`;\n                edgeElement.style.left = `${fromX}px`;\n                edgeElement.style.top = `${fromY}px`;\n                edgeElement.style.transform = `rotate(${angle}deg)`;\n                \n                // Create arrow at the end\n                const arrow = document.createElement('div');\n                arrow.className = 'arrow';\n                arrow.style.left = `${length - 10}px`;\n                arrow.style.top = `-4px`;\n                arrow.style.transform = `rotate(${angle}deg)`;\n                \n                edgeElement.appendChild(arrow);\n                graphContainer.appendChild(edgeElement);\n                edgeElements.push(edgeElement);\n            });\n            \n            // Animation function\n            function animateFlow() {\n                // Reset all nodes\n                Object.values(nodeElements).forEach(node => {\n                    node.style.backgroundColor = 'var(--primary)';\n                    node.classList.remove('pulse');\n                });\n                \n                // Animate the flow through edges\n                const flowPath = ['A', 'B', 'D', 'E', 'A', 'C', 'D', 'E'];\n                \n                flowPath.forEach((nodeId, i) => {\n                    setTimeout(() => {\n                        const node = nodeElements[nodeId];\n                        node.style.backgroundColor = 'var(--accent)';\n                        node.classList.a