;\n            position: relative;\n        }\n\n        /* P vs NP Visualization */\n        .complexity-visualization {\n            width: 100%;\n            max-width: 900px;\n            height: 400px;\n            position: relative;\n            margin: 0 auto;\n            padding: 2rem;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 16px;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n        }\n\n        .problem-path {\n            position: absolute;\n            height: 2px;\n            background: linear-gradient(90deg, rgba(138, 43, 226, 0), #8a2be2);\n            left: 50px;\n            right: 50px;\n            top: 50%;\n            transform: translateY(-50%);\n            z-index: 1;\n        }\n\n        .p-point, .np-point {\n            position: absolute;\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            z-index: 2;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);\n            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .p-point {\n            left: 150px;\n            top: 50%;\n            transform: translateY(-50%);\n            background: linear-gradient(135deg, #00b09b, #96c93d);\n            animation: float 4s ease-in-out infinite;\n        }\n\n        .np-point {\n            right: 150px;\n            top: 50%;\n            transform: translateY(-50%);\n            background: linear-gradient(135deg, #ff758c, #ff7eb3);\n            animation: float 4s ease-in-out 0.5s infinite;\n        }\n\n        .particles {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        .particle {\n            position: absolute;\n            background: rgba(255, 255, 255, 0.5);\n            border-radius: 50%;\n            animation: float 8s linear infinite;\n        }\n\n        /* Animation */\n        @keyframes float {\n            0%, 100% {\n                transform: translateY(-50%) translateX(0);\n            }\n            50% {\n                transform: translateY(-50%) translateX(0) translateY(-15px);\n            }\n        }\n\n        @keyframes sparkle {\n            0% {\n                opacity: 0;\n            }\n            50% {\n                opacity: 1;\n            }\n            100% {\n                opacity: 0;\n            }\n        }\n\n        /* Toggle Button */\n        .toggle-container {\n            display: flex;\n            justify-content: center;\n            margin: 3rem 0;\n        }\n\n        .toggle-btn {\n            background: rgba(255, 255, 255, 0.1);\n            color: white;\n            border: none;\n            padding: 1rem 2rem;\n            font-size: 1rem;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(5px);\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .toggle-btn:hover {\n            background: rgba(255, 255, 255, 0.2);\n            transform: translateY(-2px);\n        }\n\n        .toggle-btn:active {\n            transform: translateY(1px);\n        }\n\n        .toggle-btn::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n            transform: translateX(-100%);\n            transition: transform 0.6s ease;\n        }\n\n        .toggle-btn:hover::after {\n            transform: translateX(100%);\n        }\n\n        /* Connection line animation */\n        .connection-line {\n            position: absolute;\n            height: 2px;\n            background: white;\n            top: 50%;\n            left: 270px;\n            right: 270px;\n            transform: translateY(-50%);\n            z-index: 1;\n            opacity: 0;\n            transition: opacity 1s ease;\n        }\n\n        .connection-line.visible {\n            opacity: 0.5;\n        }\n\n        /* Footer */\n        footer {\n            text-align: center;\n            padding: 3rem 0;\n            font-size: 0.9rem;\n            color: rgba(255, 255, 255, 0.6);\n        }\n\n        /* Responsive */\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n\n            h2 {\n                font-size: 1.5rem;\n            }\n\n            .p-point, .np-point {\n                width: 80px;\n                height: 80px;\n                font-size: 1rem;\n            }\n\n            .p-point {\n                left: 50px;\n            }\n\n            .np-point {\n                right: 50px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <section class=\"hero\">\n            <h1>P vs NP</h1>\n            <h2>The Most Important Problem in Computer Science</h2>\n        </section>\n\n        <section class=\"content-section\" id=\"intro\">\n            <p>\n                The P vs NP problem is a fundamental question in computer science that asks whether every problem whose solution can be quickly verified by a computer can also be quickly solved by a computer.\n            </p>\n        </section>\n\n        <div class=\"toggle-container\">\n            <button class=\"toggle-btn\" id=\"solveToggle\">Show Possible Connection</button>\n        </div>\n\n        <div class=\"visualization-container\">\n            <div class=\"complexity-visualization\">\n                <div class=\"particles\" id=\"particles\"></div>\n                <div class=\"problem-path\"></div>\n                <div class=\"p-point\">P Problems<br><span style=\"font-size: 0.8rem; font-weight: normal;\">(Quick to solve)</span></div>\n                <div class=\"np-point\">NP Problems<br><span style=\"font-size: 0.8rem; font-weight: normal;\">(Quick to verify)</span></div>\n                <div class=\"connection-line\" id=\"connectionLine\"></div>\n            </div>\n        </div>\n\n        <section class=\"content-section\" id=\"explanation\">\n            <h2>The Essence of P vs NP</h2>\n            <p>\n                <strong>P problems</strong> are those that can be solved in polynomial time by a deterministic Turing machine. Examples include sorting a list or finding the shortest path between two points.\n            </p>\n            <p>\n                <strong>NP problems</strong> are those for which a proposed solution can be verified in polynomial time, but finding the solution may be much harder. The traveling salesman problem is a classic NP problem.\n            </p>\n            <p>\n                The million-dollar question: <strong>Is P = NP?</strong> If true, it would mean that problems we currently think are hard to solve actually have efficient solutions we just haven't discovered yet.\n            </p>\n        </section>\n\n        <section class=\"content-section\" id=\"implications\">\n            <h2>Potential Implications</h2>\n            <p>\n                A proof that P = NP would have profound consequences, revolutionizing fields from cryptography to medicine to artificial intelligence. Many experts believe P ≠ NP, but no one has been able to prove it.\n            </p>\n        </section>\n    </div>\n\n    <footer>\n        A visual exploration of one of the seven Millennium Prize Problems\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            const particlesContainer = document.getElementById('particles');\n            for (let i = 0; i < 50; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                particle.style.width = `${Math.random() * 8 + 2}px`;\n                particle.style.height = particle.style.width;\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.opacity = Math.random() * 0.4;\n                particle.style.animationDuration = `${Math.random() * 10 + 5}s`;\n                particle.style.animationDelay = `${Math.random() * 5}s`;\n                particlesContainer.appendChild(particle);\n            }\n\n            // Intersection Observer for scroll animations\n            const observer = new IntersectionObserver((entries) => {\n                entries.forEach(entry => {\n                    if (entry.isIntersecting) {\n                        entry.target.classList.add('visible');\n                    }\n                });\n            }, {\n                threshold: 0.1\n            });\n\n            document.querySelectorAll('.content-section').forEach(section => {\n                observer.observe(section);\n            });\n\n            // Toggle button functionality\n            const toggleBtn = document.getElementById('solveToggle');\n            const connectionLine = document.getElementById('connectionLine');\n            \n            toggleBtn.addEventListener('click', function() {\n                connectionLine.classList.toggle('visible');\n                \n                if (connectionLine.classList.contains('visible')) {\n                    toggleBtn.textContent = 'Hide Connection';\n                } else {\n                    toggleBtn.textContent = 'Show Possible Connection';\n                }\n            });\n\n            // Initial animations\n            setTimeout(() => {\n                document.getElementById('intro').classList.add('visible');\n            }, 300);\n        });\n    </script>\n</body>\n</html>"
