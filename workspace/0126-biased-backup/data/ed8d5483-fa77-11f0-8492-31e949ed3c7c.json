    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Merge Sort Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #282c34;\n            color: #ffffff;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 20px;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);\n        }\n\n        #visualization {\n            display: flex;\n            margin-bottom: 30px;\n            transition: all 0.5s ease;\n        }\n\n        .bar {\n            width: 30px;\n            margin: 0 2px;\n            background-color: #61dafb;\n            border-radius: 5px;\n            transition: height 0.5s ease, background-color 0.5s ease;\n        }\n\n        .merging {\n            background-color: #ff6f61;\n        }\n\n        .sorted {\n            background-color: #28a745;\n        }\n\n        .button {\n            padding: 10px 20px;\n            font-size: 1em;\n            color: #ffffff;\n            background-color: #007bff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n\n        .button:hover {\n            background-color: #0056b3;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Merge Sort Visualization</h1>\n    <div id=\"visualization\"></div>\n    <button class=\"button\" onclick=\"startSort()\">Start Merge Sort</button>\n\n    <script>\n        const visualization = document.getElementById('visualization');\n        const data = [60, 10, 40, 70, 20, 50, 30];\n\n        function drawBars(arr, highlight = null) {\n            visualization.innerHTML = '';\n            arr.forEach((value, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = value * 4 + 'px';\n                if (highlight === index) {\n                    bar.classList.add('merging');\n                }\n                visualization.appendChild(bar);\n            });\n        }\n\n        async function mergeSort(arr) {\n            if (arr.length <= 1) return arr;\n\n            let mid = Math.floor(arr.length / 2);\n            const left = await mergeSort(arr.slice(0, mid));\n            const right = await mergeSort(arr.slice(mid));\n\n            return merge(left, right);\n        }\n\n        async function merge(left, right) {\n            const sorted = [];\n            let i = 0, j = 0;\n\n            while (i < left.length && j < right.length) {\n                drawBars([...left, ...right], i + j);\n                await new Promise(resolve => setTimeout(resolve, 500));\n\n                if (left[i] <= right[j]) {\n                    sorted.push(left[i++]);\n                } else {\n                    sorted.push(right[j++]);\n                }\n            }\n\n            while (i < left.length) {\n                sorted.push(left[i++]);\n            }\n\n            while (j < right.length) {\n                sorted.push(right[j++]);\n            }\n\n            drawBars(sorted.concat(Array.from({length: right.length + left.length - sorted.length}, \n                () => 0)));\n\n            await new Promise(resolve => setTimeout(resolve, 500));\n            return sorted;\n        }\n\n        async function startSort() {\n            await mergeSort(data);\n            drawBars(data);\n            for (let i = 0; i < data.length; i++) {\n                const bar = document.querySelectorAll('.bar')[i];\n                bar.classList.add('sorted');\n            }\n        }\n\n        drawBars(data);\n    </script>\n</body>\n</html>"
