  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linear Search Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  input[type=\"number\"] {\n    width: 4em;\n  }\n  input[type=\"text\"] {\n    max-width: 10em;\n  }\n  button {\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  #arrayDisplay {\n    white-space: pre-wrap;\n  }\n  #log {\n    max-height: 12em;\n    overflow-y: scroll;\n    border: 1px solid black;\n    padding: 0.3em;\n    margin-top: 0.5em;\n    font-size: 0.85em;\n  }\n  label {\n    user-select: none;\n  }\n  .selected {\n    font-weight: bold;\n    text-decoration: underline;\n  }\n</style>\n</head>\n<body>\n\n<h1>Linear Search Interactive Demo</h1>\n\n<p>This demonstration allows you to create your own array, customize search targets, step through linear search manually or automatically, explore alternate workflows, and understand every detail of linear search. Use the controls below to experiment.</p>\n\n<hr />\n\n<section aria-label=\"Array Construction\">\n  <h2>1. Construct Array</h2>\n  <p>Enter up to 20 integers (positive or negative) separated by commas or spaces:</p>\n  <textarea id=\"arrayInput\" rows=\"3\" cols=\"60\" aria-label=\"Input array elements\"></textarea><br />\n  <button id=\"btnLoadArray\">Load Array</button>\n  <button id=\"btnRandomArray\">Generate Random Array</button>\n  <label for=\"randomSize\">Size:</label>\n  <input type=\"number\" id=\"randomSize\" min=\"1\" max=\"20\" value=\"10\" aria-label=\"Random array size\" />\n  <label for=\"randomMin\">Min:</label>\n  <input type=\"number\" id=\"randomMin\" min=\"-1000\" max=\"1000\" value=\"-50\" aria-label=\"Minimum random value\" />\n  <label for=\"randomMax\">Max:</label>\n  <input type=\"number\" id=\"randomMax\" min=\"-1000\" max=\"1000\" value=\"50\" aria-label=\"Maximum random value\" />\n  <p id=\"arrayError\" style=\"color:red; user-select:none;\"></p>\n</section>\n\n<hr />\n\n<section aria-label=\"Array Display and Index Controls\">\n  <h2>2. Current Array and Controls</h2>\n  <p><b>Array:</b> <span id=\"arrayDisplay\">[ ]</span></p>\n  <p>\n    Current index: <span id=\"currentIndexDisplay\">-</span> /\n    <span id=\"maxIndexDisplay\">-</span>\n  </p>\n  <p>\n    <button id=\"btnResetSearch\" disabled>Reset Search</button>\n    <button id=\"btnStepForward\" disabled>Step Forward</button>\n    <button id=\"btnStepBackward\" disabled>Step Backward</button>\n    <button id=\"btnAutoSearch\" disabled>Start Auto Search</button>\n    <button id=\"btnStopAuto\" disabled>Stop Auto Search</button>\n  </p>\n  <p>\n    Jump to index:\n    <input type=\"number\" id=\"jumpIndex\" min=\"0\" aria-label=\"Jump to index\" />\n    <button id=\"btnJumpIndex\" disabled>Go</button>\n    <button id=\"btnGoToNextMatch\" disabled>Next Match</button>\n    <button id=\"btnGoToPrevMatch\" disabled>Prev Match</button>\n  </p>\n  <p>\n    <button id=\"btnHighlightAllMatches\" disabled>Highlight All Matches</button>\n    <button id=\"btnClearHighlights\" disabled>Clear Highlights</button>\n  </p>\n</section>\n\n<hr />\n\n<section aria-label=\"Search Target and Options\">\n  <h2>3. Search Target and Options</h2>\n  <label for=\"targetValue\">Target value to find:</label>\n  <input type=\"text\" id=\"targetValue\" aria-label=\"Search target value\" />\n  <button id=\"btnSetTarget\" disabled>Set Target</button>\n  <p>\n    Find: \n    <label><input type=\"radio\" name=\"searchMode\" value=\"first\" checked disabled /> First occurrence</label>\n    <label><input type=\"radio\" name=\"searchMode\" value=\"all\" disabled /> All occurrences</label>\n  </p>\n  <p>\n    <label><input type=\"checkbox\" id=\"caseSensitive\" disabled /> Case/Symbol Sensitive (for text search)</label>\n  </p>\n  <p>\n    Search mode:\n    <select id=\"searchModeSelect\" disabled>\n      <option value=\"num\" selected>Numeric search</option>\n      <option value=\"text\">Text search</option>\n    </select>\n  </p>\n  <p><button id=\"btnToggleWorkflow\">Switch to Advanced Workflow</button></p>\n</section>\n\n<hr />\n\n<section aria-label=\"Search Result & Logs\">\n  <h2>4. Search Result</h2>\n  <p><b>Status:</b> <span id=\"searchStatus\">No search started.</span></p>\n  <p><b>Matches found:</b> <span id=\"matchCount\">0</span></p>\n  <div id=\"log\" aria-live=\"polite\" aria-atomic=\"false\" aria-relevant=\"additions\"></div>\n</section>\n\n<hr />\n\n<section aria-label=\"Advanced Workflow (Optional)\">\n  <h2>5. Advanced Workflow</h2>\n  <p>\n    <button id=\"btnLinearSearchExplain\">Explain Linear Search Algorithm</button>\n    <button id=\"btnCompareSearches\" disabled>Compare Linear Search to Other Searches</button>\n  </p>\n  <p>\n    <label for=\"compareSearchSelect\">Choose Search to Compare:</label>\n    <select id=\"compareSearchSelect\" disabled>\n      <option value=\"\" disabled selected>Select</option>\n      <option value=\"binary\">Binary Search (Sorted Arrays)</option>\n      <option value=\"jump\">Jump Search</option>\n      <option value=\"interpolation\">Interpolation Search</option>\n    </select>\n  </p>\n  <p>\n    <button id=\"btnRunCompare\" disabled>Run Comparison</button>\n  </p>\n  <pre id=\"compareOutput\" style=\"white-space: pre-wrap; max-height: 10em; overflow-y: auto; border: 1px solid black; padding: 0.3em;\"></pre>\n</section>\n\n<script>\n(() => {\n  // State variables\n  let array = [];\n  let searchTarget = null;\n  let searchTargetRaw = \"\";\n  let isTextSearch = false;\n  let isCaseSensitive = false;\n  let searchMode = \"first\"; // 'first' or 'all'\n  let currentIndex = -1;\n  let matches = []; // indices of found matches\n  let highlightsActive = false;\n  let autoIntervalId = null;\n  let advancedMode = false;\n  const maxArrayLength = 20;\n\n  // DOM Elements\n  const arrayInput = document.getElementById(\"arrayInput\");\n  const btnLoadArray = document.getElementById(\"btnLoadArray\");\n  const btnRandomArray = document.getElementById(\"btnRandomArray\");\n  const randomSize = document.getElementById(\"randomSize\");\n  const randomMin = document.getElementById(\"randomMin\");\n  const randomMax = document.getElementById(\"randomMax\");\n  const arrayDisplay = document.getElementById(\"arrayDisplay\");\n  const arrayError = document.getElementById(\"arrayError\");\n  const currentIndexDisplay = document.getElementById(\"currentIndexDisplay\");\n  const maxIndexDisplay = document.getElementById(\"maxIndexDisplay\");\n  const btnResetSearch = document.getElementById(\"btnResetSearch\");\n  const btnStepForward = document.getElementById(\"btnStepForward\");\n  const btnStepBackward = document.getElementById(\"btnStepBackward\");\n  const btnAutoSearch = document.getElementById(\"btnAutoSearch\");\n  const btnStopAuto = document.getElementById(\"btnStopAuto\");\n  const jumpIndex = document.getElementById(\"jumpIndex\");\n  const btnJumpIndex = document.getElementById(\"btnJumpIndex\");\n  const btnGoToNextMatch = document.getElementById(\"btnGoToNextMatch\");\n  const btnGoToPrevMatch = document.getElementById(\"btnGoToPrevMatch\");\n  const btnHighlightAllMatches = document.getElementById(\"btnHighlightAllMatches\");\n  const btnClearHighlights = document.getElementById(\"btnClearHighlights\");\n  const targetValueInput = document.getElementById(\"targetValue\");\n  const btnSetTarget = document.getElementById(\"btnSetTarget\");\n  const searchModeRadios = document.getElementsByName(\"searchMode\");\n  const caseSensitiveCheckbox = document.getElementById(\"caseSensitive\");\n  const searchModeSelect = document.getElementById(\"searchModeSelect\");\n  const searchStatus = document.getElementById(\"searchStatus\");\n  const matchCountDisplay = document.getElementById(\"matchCount\");\n  const log = document.getElementById(\"log\");\n  const btnToggleWorkflow = document.getElementById(\"btnToggleWorkflow\");\n  const advancedSection = document.querySelector(\"section[aria-label='Advanced Workflow (Optional)']\");\n  const btnLinearSearchExplain = document.getElementById(\"btnLinearSearchExplain\");\n  const btnCompareSearches = document.getElementById(\"btnCompareSearches\");\n  const compareSearchSelect = document.getElementById(\"compareSearchSelect\");\n  const btnRunCompare = document.getElementById(\"btnRunCompare\");\n  const compareOutput = document.getElementById(\"compareOutput\");\n\n  // Helpers & Utilities\n\n  // Parse user input array text into array of strings/nums\n  function parseInputArray(input) {\n    if (!input) return [];\n    // Split by commas or whitespace\n    const parts = input.trim().split(/[\\s,]+/);\n    return parts;\n  }\n\n  // Validate and normalize array for current search mode\n  function validateAndNormalizeArray(arr) {\n    if (arr.length > maxArrayLength) {\n      throw new Error(\"Array too long (max \" + maxArrayLength + \")\");\n    }\n    if (isTextSearch) {\n      // For text search, accept ANY string, including empty\n      // If case insensitive, convert all to lowercase\n      if (!isCaseSensitive) {\n        return arr.map(s => s.toLowerCase());\n      }\n      return arr.slice();\n    } else {\n      // Numeric search: All elements must parse as numbers (integers)\n      const numArr = arr.map((v, i) => {\n        let n = Number(v);\n        if (Number.isNaN(n)) {\n          throw new Error(\n            \"Invalid number at position \" + (i + 1) + \": '\" + v + \"'\"\n          );\n        }\n        if (!Number.isInteger(n)) {\n          // Accept floats, but warn? No, just accept.\n          return n;\n        }\n        return n;\n      });\n      return numArr;\n    }\n  }\n\n  // Validate and normalize search target\n  function validateAndNormalizeTarget(rawTarget) {\n    if (isTextSearch) {\n      if (!rawTarget) throw new Error(\"Target cannot be empty for text search\");\n      return isCaseSensitive ? rawTarget : rawTarget.toLowerCase();\n    } else {\n      let num = Number(rawTarget);\n      if (Number.isNaN(num)) {\n        throw new Error(\"Target must be a number\");\n      }\n      return num;\n    }\n  }\n\n  // Display array with highlighting for current index and matches\n  // Highlights implemented by wrapping in [ ] or <b> for current and * for match\n  function displayArray() {\n    if (array.length === 0) {\n      arrayDisplay.textContent = \"[ ]\";\n      currentIndexDisplay.textContent = \"-\";\n      maxIndexDisplay.textContent = \"-\";\n      return;\n    }\n    let pieces = [];\n    for (let i = 0; i < array.length; i++) {\n      let el = array[i];\n      let repr = \"\" + el;\n      const isCurrent = i === currentIndex;\n      const isMatch = matches.includes(i);\n      if (highlightsActive && isMatch) {\n        repr = \"*\" + repr + \"*\";\n      }\n      if (isCurrent) {\n        repr = \"[\" + repr + \"]\";\n      }\n      pieces.push(repr);\n    }\n    arrayDisplay.textContent = \"[ \" + pieces.join(\", \") + \" ]\";\n    currentIndexDisplay.textContent = currentIndex >= 0 ? currentIndex : \"-\";\n    maxIndexDisplay.textContent = array.length - 1;\n  }\n\n  // Log messages to the log box\n  function logMessage(msg) {\n    const time = new Date().toLocaleTimeString();\n    log.textContent += \"[\" + time + \"] \" + msg + \"\\n\";\n    log.scrollTop = log.scrollHeight;\n  }\n\n  // Clear log\n  function clearLog() {\n    log.textContent = \"\";\n  }\n\n  // Search Functions\n\n  // Reset search state\n  function resetSearch() {\n    currentIndex = -1;\n    matches = [];\n    highlightsActive = false;\n    searchStatus.textContent = \"Search reset, ready to start.\";\n    matchCountDisplay.textContent = \"0\";\n    updateNavButtons();\n    displayArray();\n    clearLog();\n  }\n\n  // Perform one search step forward, return status string\n  // Returns:\n  //   \"found\" if target found at current index,\n  //   \"notfound\" if target does not match current,\n  //   \"end\" if reached end of array with no match (for first occurrence),\n  //   \"continue\" if continuing (all mode)\n  function stepForward() {\n    if (array.length === 0) return \"noarray\";\n    if (currentIndex === array.length - 1) {\n      return \"end\";\n    }\n    currentIndex++;\n    const currentVal = array[currentIndex];\n\n    // Check equality with target differently for text/numeric\n    let matchHere = false;\n    if (isTextSearch) {\n      // We did lowercasing during normalization already\n      if (currentVal === searchTarget) matchHere = true;\n    } else {\n      if (currentVal === searchTarget) matchHere = true;\n    }\n\n    if (matchHere) {\n      matches.push(currentIndex);\n      displayArray();\n      matchCountDisplay.textContent = matches.length;\n      if (searchMode === \"first\") {\n        searchStatus.textContent = \"Target found at index \" + currentIndex + \". Search completed.\";\n        updateNavButtons(true);\n        return \"found\";\n      } else {\n        // all occurrences mode\n        searchStatus.textContent = \"Found occurrence at index \" + currentIndex + \". Continuing search...\";\n        updateNavButtons();\n        displayArray();\n        return \"continue\";\n      }\n    } else {\n      displayArray();\n      searchStatus.textContent = \"No match at index \" + currentIndex + \".\";\n      return \"notfound\";\n    }\n  }\n\n  // Step backward in search index (undo step)\n  function stepBackward() {\n    if (array.length === 0) return;\n    if (currentIndex <= 0) {\n      currentIndex = -1;\n      searchStatus.textContent = \"Reset to before start.\";\n      displayArray();\n      return;\n    }\n    // Remove any match at currentIndex since we're undoing\n    const idx = matches.indexOf(currentIndex);\n    if (idx !== -1) {\n      matches.splice(idx, 1);\n      matchCountDisplay.textContent = matches.length;\n    }\n    currentIndex--;\n    displayArray();\n    searchStatus.textContent = \"Stepped backward to index \" + (currentIndex >= 0 ? currentIndex : \"before start\") + \".\";\n    updateNavButtons();\n  }\n\n  // Auto search with interval of steps with delay\n  function startAutoSearch() {\n    if (autoIntervalId !== null) return;\n    btnAutoSearch.disabled = true;\n    btnStopAuto.disabled = false;\n    btnStepForward.disabled = true;\n    btnStepBackward.disabled = true;\n    btnJumpIndex.disabled = true;\n    btnResetSearch.disabled = true;\n\n    autoIntervalId = setInterval(() => {\n      const res = stepForward();\n      if (res === \"found\" || res === \"end\") {\n        stopAutoSearch();\n      }\n    }, 700);\n  }\n\n  function stopAutoSearch() {\n    if (autoIntervalId !== null) {\n      clearInterval(autoIntervalId);\n      autoIntervalId = null;\n    }\n    btnAutoSearch.disabled = false;\n    btnStopAuto.disabled = true;\n    btnStepForward.disabled = false;\n    btnStepBackward.disabled = false;\n    btnJumpIndex.disabled = false;\n    btnResetSearch.disabled = false;\n  }\n\n  // Jump to arbitrary index and report status\n  function jumpToIndex(idx) {\n    if (array.length === 0) {\n      searchStatus.textContent = \"No array loaded.\";\n      return false;\n    }\n    if (idx < 0 || idx >= array.length) {\n      searchStatus.textContent = \"Index out of bounds.\";\n      return false;\n    }\n    currentIndex = idx;\n    // Check if this index is a match\n    const isMatch = matches.includes(currentIndex);\n    searchStatus.textContent = \"Jumped to index \" + currentIndex + (isMatch ? \" (match)\" : \"\");\n    displayArray();\n    updateNavButtons();\n    return true;\n  }\n\n  // Navigate to next match from currentIndex\n  function goToNextMatch() {\n    if (matches.length === 0) {\n      searchStatus.textContent = \"No matches found yet.\";\n      return;\n    }\n    if (currentIndex === -1) {\n      currentIndex = matches[0];\n      searchStatus.textContent = \"Jumped to first match at index \" + currentIndex;\n      displayArray();\n      updateNavButtons();\n      return;\n    }\n    // Find next match after currentIndex\n    for (let m of matches) {\n      if (m > currentIndex) {\n        currentIndex = m;\n        searchStatus.textContent = \"Jumped to next match at index \" + currentIndex;\n        displayArray();\n        updateNavButtons();\n        return;\n      }\n    }\n    // Wrap around to first match\n    currentIndex = matches[0];\n    searchStatus.textContent = \"Wrapped to first match at index \" + currentIndex;\n    displayArray();\n    updateNavButtons();\n  }\n\n  // Navigate to previous match from currentIndex\n  function goToPrevMatch() {\n    if (matches.length === 0) {\n      searchStatus.textContent = \"No matches found yet.\";\n      return;\n    }\n    if (currentIndex === -1) {\n      currentIndex = matches[matches.length - 1];\n      searchStatus.textContent = \"Jumped to last match at index \" + currentIndex;\n      displayArray();\n      updateNavButtons();\n      return;\n    }\n    // Find prev match before currentIndex\n    for (let i = matches.length - 1; i >= 0; i--) {\n      if (matches[i] < currentIndex) {\n        currentIndex = matches[i];\n        searchStatus.textContent = \"Jumped to previous match at index \" + currentIndex;\n        displayArray();\n        updateNavButtons();\n        return;\n      }\n    }\n    // Wrap around to last match\n    currentIndex = matches[matches.length - 1];\n    searchStatus.textContent = \"Wrapped to last match at index \" + currentIndex;\n    displayArray();\n    updateNavButtons();\n  }\n\n  // Highlight all matches by activating highlightsActive\n  function highlightAllMatches() {\n    if (matches.length === 0) {\n      searchStatus.textContent = \"No matches to highlight.\";\n      return;\n    }\n    highlightsActive = true;\n    displayArray();\n    searchStatus.textContent = \"Highlighted all matches (\" + matches.length + \").\";\n    btnClearHighlights.disabled = false;\n    btnHighlightAllMatches.disabled = true;\n  }\n\n  // Clear highlights\n  function clearHighlights() {\n    highlightsActive = false;\n    displayArray();\n    searchStatus.textContent = \"Cleared all highlights.\";\n    btnClearHighlights.disabled = true;\n    btnHighlightAllMatches.disabled = matches.length === 0;\n  }\n\n  // Event and Update logic\n\n  // Enable or disable controls based on state\n  function updateNavButtons(searchCompleted = false) {\n    btnStepForward.disabled = array.length === 0 || searchCompleted || currentIndex >= array.length - 1;\n    btnStepBackward.disabled = array.length === 0 || currentIndex <= -1;\n    btnResetSearch.disabled = array.length === 0 || currentIndex === -1;\n    btnAutoSearch.disabled = array.length === 0 || searchCompleted || currentIndex >= array.length - 1;\n    btnJumpIndex.disabled = array.length === 0;\n    btnGoToNextMatch.disabled = matches.length === 0;\n    btnGoToPrevMatch.disabled = matches.length === 0;\n    btnHighlightAllMatches.disabled = matches.length === 0 || highlightsActive;\n    btnClearHighlights.disabled = !highlightsActive;\n  }\n\n  // Enable or disable search-related controls based on array and target\n  function updateSearchSetupControls() {\n    const arrayReady = array.length > 0;\n    btnSetTarget.disabled = !arrayReady || !targetValueInput.value.trim();\n    for (const r of searchModeRadios) r.disabled = !arrayReady;\n    caseSensitiveCheckbox.disabled = !arrayReady || !isTextSearch;\n    searchModeSelect.disabled = !arrayReady;\n  }\n\n  // Load array from input\n  btnLoadArray.addEventListener(\"click\", () => {\n    try {\n      const raw = arrayInput.value;\n      const parsed = parseInputArray(raw);\n      if (parsed.length === 0) throw new Error(\"Input array empty.\");\n      const norm = validateAndNormalizeArray(parsed);\n      array = norm;\n      arrayInput.value = array.toString();\n      clearLog();\n      logMessage(\"Array loaded with length \" + array.length + \".\");\n      resetSearch();\n      updateSearchSetupControls();\n    } catch (ex) {\n      arrayError.textContent = ex.message;\n      setTimeout(() => (arrayError.textContent = \"\"), 3000);\n    }\n  });\n\n  // Generate random array\n  btnRandomArray.addEventListener(\"click\", () => {\n    try {\n      let size = Number(randomSize.value);\n      let minVal = Number(randomMin.value);\n      let maxVal = Number(randomMax.value);\n      if (!Number.isInteger(size) || size < 1 || size > maxArrayLength) {\n        throw new Error(\"Size must be integer between 1 and \" + maxArrayLength);\n      }\n      if (!Number.isInteger(minVal) || !Number.isInteger(maxVal) || minVal > maxVal) {\n        throw new Error(\"Min and Max must be integers, min <= max.\");\n      }\n      let newArr = [];\n      for (let i = 0; i < size; i++) {\n        newArr.push(Math.floor(Math.random() * (maxVal - minVal + 1)) + minVal);\n      }\n      array = newArr;\n      arrayInput.value = array.toString();\n      clearLog();\n      logMessage(\"Random array generated: length=\" + size);\n      resetSearch();\n      updateSearchSetupControls();\n    } catch (ex) {\n      arrayError.textContent = ex.message;\n      setTimeout(() => (arrayError.textContent = \"\"), 3000);\n    }\n  });\n\n  // On search mode select change (numeric/text)\n  searchModeSelect.addEventListener(\"change\", () => {\n    isTextSearch = searchModeSelect.value === \"text\";\n    caseSensitiveCheckbox.disabled = !isTextSearch;\n    if (!isTextSearch) {\n      caseSensitiveCheckbox.checked = false;\n      isCaseSensitive = false;\n    }\n    updateSearchSetupControls();\n  });\n\n  // Case sensitive checkbox change\n  caseSensitiveCheckbox.addEventListener(\"change\", () => {\n    isCaseSensitive = caseSensitiveCheckbox.checked;\n  });\n\n  // Search mode (first/all) radios change\n  for (const r of searchModeRadios) {\n    r.addEventListener(\"change\", () => {\n      searchMode = r.value;\n    });\n  }\n\n  // Set search target button\n  btnSetTarget.addEventListener(\"click\", () => {\n    try {\n      if (array.length === 0) throw new Error(\"No array loaded.\");\n      const rawTarget = targetValueInput.value.trim();\n      if (!rawTarget) throw new Error(\"Target empty.\");\n      searchTarget = validateAndNormalizeTarget(rawTarget);\n      searchTargetRaw = rawTarget;\n      // Reset search state too\n      resetSearch();\n      logMessage(\"Search target set to '\" + searchTargetRaw + \"'\");\n      searchStatus.textContent = \"Target set: '\" + searchTargetRaw + \"'. Ready to start search.\";\n      updateNavButtons();\n    } catch (ex) {\n      alert(\"Error setting target: \" + ex.message);\n    }\n  });\n\n  // Step forward button\n  btnStepForward.addEventListener(\"click\", () => {\n    if (array.length === 0) return;\n    if (searchTarget === null) {\n      alert(\"Set the search target first.\");\n      return;\n    }\n    const res = stepForward();\n    if (res === \"found\" || res === \"end\") {\n      updateNavButtons(true);\n      stopAutoSearch();\n    }\n  });\n\n  // Step backward button\n  btnStepBackward.addEventListener(\"click\", () => {\n    stepBackward();\n  });\n\n  // Reset search button\n  btnResetSearch.addEventListener(\"click\", () => {\n    resetSearch();\n  });\n\n  // Auto search button\n  btnAutoSearch.addEventListener(\"click\", () => {\n    if (searchTarget === null) {\n      alert(\"Set the search target first.\");\n      return;\n    }\n    startAutoSearch();\n  });\n\n  // Stop auto search button\n  btnStopAuto.addEventListener(\"click\", () => {\n    stopAutoSearch();\n  });\n\n  // Jump to index button\n  btnJumpIndex.addEventListener(\"click\", () => {\n    let idx = Number(jumpIndex.value);\n    if (Number.isInteger(idx)) {\n      jumpToIndex(idx);\n    } else {\n      alert(\"Enter a valid integer index.\");\n    }\n  });\n\n  // Next match button\n  btnGoToNextMatch.addEventListener(\"click\", () => {\n    goToNextMatch();\n  });\n\n  // Prev match button\n  btnGoToPrevMatch.addEventListener(\"click\", () => {\n    goToPrevMatch();\n  });\n\n  // Highlight all matches button\n  btnHighlightAllMatches.addEventListener(\"click\", () => {\n    highlightAllMatches();\n  });\n\n  // Clear highlights button\n  btnClearHighlights.addEventListener(\"click\", () => {\n    clearHighlights();\n  });\n\n  // Toggle between simple and advanced workflows\n  btnToggleWorkflow.addEventListener(\"click\", () => {\n    advancedMode = !advancedMode;\n    advancedSection.style.display = advancedMode ? \"\" : \"none\";\n    btnToggleWorkflow.textContent = advancedMode ? \"Switch to Simple Workflow\" : \"Switch to Advanced Workflow\";\n  });\n\n  // Explain linear search (detailed textual explanation)\n  btnLinearSearchExplain.addEventListener(\"click\", () => {\n    let explanation = \"\";\n    explanation += \"Linear Search Algorithm Explanation:\\n\\n\";\n    explanation +=\n      \"Linear search is a sequential search algorithm that checks every element in the array or list until the desired target is found or the array ends.\\n\\n\";\n    explanation += \"Step-by-step procedure:\\n\";\n    explanation +=\n      \"1. Start at the first element of the array (index 0).\\n2. Compare the current element with the target value.\\n3. If it matches, stop and return this index (or record the match).\\n4. If not, move to the next element.\\n5. Repeat steps 2-4 until the end of the array is reached.\\n\\n\";\n    explanation +=\n      \"Linear search works on any list, sorted or unsorted, but has a worst-case time of O(n).\\nIt's simple but not efficient for large lists compared to other algorithms like binary search.\\n\";\n    alert(explanation);\n  });\n\n  function searchComparisonText(searchName) {\n    let res = \"\";\n    switch (searchName) {\n      case \"binary\":\n        res += \"Binary Search:\\n\";\n        res +=\n          \"- Requires a sorted array.\\n- Repeatedly divides the search interval in half.\\n- Compares the target to the middle element.\\n- If target equals middle, found.\\n- Else if target less, search left subarray; else right subarray.\\n- Time complexity: O(log n).\\n- Much faster than linear search on sorted arrays.\\n\";\n        break;\n      case \"jump\":\n        res += \"Jump Search:\\n\";\n        res +=\n          \"- Requires sorted array.\\n- Jump ahead fixed steps (√n) to find block where target may be.\\n- Then linear search within that block.\\n- Time complexity: O(√n).\\n\";\n        break;\n      case \"interpolation\":\n        res += \"Interpolation Search:\\n\";\n        res +=\n          \"- Requires sorted, uniformly distributed data.\\n- Uses value of target to estimate likely position.\\n- Probes position proportional to value difference.\\n- Expected time: O(log log n), worst O(n).\\n- More efficient than binary search for uniform data.\\n\";\n        break;\n      default:\n        res += \"No information available.\";\n    }\n    return res;\n  }\n\n  // Compare searches select field\n  compareSearchSelect.addEventListener(\"change\", () => {\n    btnRunCompare.disabled = compareSearchSelect.value === \"\";\n  });\n\n  // Run comparison button\n  btnRunCompare.addEventListener(\"click\", () => {\n    const val = compareSearchSelect.value;\n    compareOutput.textContent = searchComparisonText(val);\n  });\n\n  // Initialization\n  arrayDisplay.textContent = \"[ ]\";\n  currentIndexDisplay.textContent = \"-\";\n  maxIndexDisplay.textContent = \"-\";\n  btnStopAuto.disabled = true;\n  advancedSection.style.display = \"none\";\n\n  updateSearchSetupControls();\n  updateNavButtons();\n\n  // Keyboard support for stepping: Space = step forward, Shift+Space = step backward, R = Reset\n  document.body.addEventListener(\"keydown\", e => {\n    if (e.target.tagName === \"INPUT\" || e.target.tagName === \"TEXTAREA\") return;\n    if (e.code === \"Space\" && !e.shiftKey) {\n      e.preventDefault();\n      if (!btnStepForward.disabled) btnStepForward.click();\n    } else if (e.code === \"Space\" && e.shiftKey) {\n      e.preventDefault();\n      if (!btnStepBackward.disabled) btnStepBackward.click();\n    } else if (e.code === \"KeyR\") {\n      e.preventDefault();\n      if (!btnResetSearch.disabled) btnResetSearch.click();\n    }\n  });\n\n})();\n</script>\n\n</body>\n</html>"
