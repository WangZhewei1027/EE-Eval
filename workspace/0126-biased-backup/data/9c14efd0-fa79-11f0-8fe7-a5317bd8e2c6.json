  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Two Pointers Explorer</title>\n  <style>\n    /* Extremely minimal visual styling only for basic layout; otherwise default browser styles preserved */\n    body { font-family: Arial, sans-serif; color: black; background: white; margin: 12px; }\n    .container { display: flex; gap: 12px; }\n    .col { flex: 1; min-width: 260px; }\n    textarea, input[type=\"text\"], input[type=\"number\"], select { width: 100%; box-sizing: border-box; }\n    pre { white-space: pre-wrap; word-wrap: break-word; background: inherit; border: 1px solid #0000001a; padding: 6px; }\n    table { border-collapse: collapse; }\n    td, th { padding: 6px; border: 1px solid #000; text-align: center; }\n    button { margin: 2px 0; }\n    .array-row { display: flex; gap: 6px; flex-wrap: wrap; }\n    .cell { padding: 6px; border: 1px solid #000; min-width: 28px; }\n    .pointers { margin-top: 6px; font-family: monospace; }\n    .log { height: 160px; overflow: auto; border: 1px solid #000; padding: 6px; }\n    .branches { max-height: 120px; overflow: auto; border: 1px solid #000; padding: 6px; }\n    label { display: block; margin-top: 6px; }\n    .small { font-size: 12px; }\n  </style>\n</head>\n<body>\n  <h2>Two Pointers Explorer</h2>\n  <p class=\"small\">An interactive sandbox to explore many two-pointer algorithm variants. Minimal visual design; primary focus on interactivity. Use controls to step, run, branch, and experiment.</p>\n\n  <div class=\"container\">\n    <div class=\"col\" id=\"controls-col\">\n      <label>Algorithm\n        <select id=\"algo-select\">\n          <option value=\"pair-sum\">Pair Sum (sorted)</option>\n          <option value=\"remove-duplicates\">Remove Duplicates (sorted)</option>\n          <option value=\"partition-pivot\">Dutch Partition (pivot)</option>\n          <option value=\"reverse-subarray\">Reverse Subarray</option>\n          <option value=\"slow-fast\">Cycle Detect (slow-fast)</option>\n          <option value=\"custom-rule\">Custom Rule (user-defined)</option>\n        </select>\n      </label>\n\n      <label>Array (comma-separated)\n        <input type=\"text\" id=\"array-input\" value=\"1,2,3,4,5,6,7\" />\n      </label>\n\n      <div id=\"array-gen\">\n        <label>Generate random array size\n          <input type=\"range\" id=\"size-slider\" min=\"1\" max=\"20\" value=\"7\" />\n          <span id=\"size-display\">7</span>\n        </label>\n        <label>Min\n          <input type=\"number\" id=\"rand-min\" value=\"0\" />\n        </label>\n        <label>Max\n          <input type=\"number\" id=\"rand-max\" value=\"9\" />\n        </label>\n        <label><input type=\"checkbox\" id=\"gen-sort\" /> Sort generated array</label>\n        <button id=\"gen-random\">Generate Random Array</button>\n        <button id=\"shuffle-array\">Shuffle Current Array</button>\n      </div>\n\n      <div id=\"algo-params\">\n        <label id=\"target-label\">Target (for Pair Sum)\n          <input type=\"number\" id=\"target-input\" value=\"8\" />\n        </label>\n\n        <label id=\"pivot-label\" style=\"display:none\">Pivot value\n          <input type=\"number\" id=\"pivot-input\" value=\"1\" />\n        </label>\n\n        <label id=\"linked-list-note\" style=\"display:none\">For Cycle Detect, enter next indices in array (use -1 for null). Example: 1,2,0</label>\n      </div>\n\n      <label>Pointer initial indices (optional, blank for defaults)\n        i: <input type=\"number\" id=\"init-i\" style=\"width:60px\" /> j: <input type=\"number\" id=\"init-j\" style=\"width:60px\" />\n        <button id=\"apply-init\">Apply</button>\n      </label>\n\n      <label>Speed (ms per step)\n        <input type=\"range\" id=\"speed-slider\" min=\"50\" max=\"2000\" value=\"400\" />\n        <span id=\"speed-display\">400</span>\n      </label>\n\n      <label>Execution Controls</label>\n      <button id=\"step-btn\">Step</button>\n      <button id=\"step-back-btn\">Step Back</button>\n      <button id=\"run-btn\">Run</button>\n      <button id=\"pause-btn\" disabled>Pause</button>\n      <button id=\"reset-btn\">Reset</button>\n      <button id=\"stop-and-reset-log\">Stop & Clear Log</button>\n\n      <label>Options</label>\n      <label><input type=\"checkbox\" id=\"stop-on-first\" /> Stop on first match (Pair Sum)</label>\n      <label><input type=\"checkbox\" id=\"auto-apply-swap\" checked /> Auto-apply swaps (for partition/reverse)</label>\n\n      <label>Breakpoint condition (JS expression; variables: arr, i, j, low, mid, high, slow, fast, target, pivot, matches, step)\n        <input type=\"text\" id=\"breakpoint-input\" placeholder=\"e.g., arr[i] + arr[j] === target\" />\n      </label>\n      <button id=\"set-breakpoint\">Set Breakpoint</button>\n      <button id=\"clear-breakpoint\">Clear Breakpoint</button>\n\n      <label>Custom Rule (for Custom Rule mode)</label>\n      <textarea id=\"custom-rule\" rows=\"6\">// Return an action object, example:\n  // return { moveI:1, moveJ:-1, swap:false, recordMatch: false, stop:false };\n  // Allowed variables: arr, i, j, target, pivot, matches, step\n  if (i >= j) return { stop: true };\n  if (arr[i] + arr[j] === target) return { recordMatch: true, moveI:1, moveJ:-1 };\n  if (arr[i] + arr[j] < target) return { moveI:1 };\n  return { moveJ:-1 };</textarea>\n\n      <label>Manual Pointer Controls</label>\n      <input type=\"number\" id=\"manual-i\" style=\"width:80px\" placeholder=\"i\" /> \n      <input type=\"number\" id=\"manual-j\" style=\"width:80px\" placeholder=\"j\" />\n      <button id=\"set-manual-pointers\">Set Pointers</button>\n\n      <label>Create Branch / Branch Management</label>\n      <button id=\"create-branch\">Create Branch Here</button>\n      <div class=\"branches\" id=\"branches-list\"></div>\n      <small class=\"small\">Branches let you clone the current state and explore different continuations. Click a branch to switch to it.</small>\n    </div>\n\n    <div class=\"col\" id=\"visual-col\">\n      <label>Array visualization</label>\n      <div id=\"array-visual\" class=\"array-row\"></div>\n      <div class=\"pointers\" id=\"pointers-visual\"></div>\n\n      <label>Pseudo-code / Algorithm steps</label>\n      <pre id=\"pseudo-code\" style=\"min-height:80px\"></pre>\n\n      <label>Matches / Results</label>\n      <pre id=\"matches-area\">[]</pre>\n\n      <label>State snapshot</label>\n      <pre id=\"state-area\"></pre>\n    </div>\n\n    <div class=\"col\" id=\"right-col\">\n      <label>Execution Log</label>\n      <div class=\"log\" id=\"log-area\"></div>\n\n      <label>History (click to jump back to that step)</label>\n      <div class=\"log\" id=\"history-area\"></div>\n\n      <label>Quick Presets</label>\n      <button class=\"preset\" data-val=\"1,2,3,4,5,6,7\">Sorted 1..7</button>\n      <button class=\"preset\" data-val=\"1,1,2,2,3,3\">Sorted duplicates</button>\n      <button class=\"preset\" data-val=\"3,5,2,8,1,4,7\">Unsorted sample</button>\n      <button class=\"preset\" data-val=\"0,1,2,3,4\">Linked list indices</button>\n\n      <label>Export / Import state (JSON)</label>\n      <button id=\"export-state\">Export State</button>\n      <button id=\"import-state\">Import State</button>\n      <textarea id=\"export-area\" rows=\"6\" placeholder=\"Exported JSON appears here\"></textarea>\n    </div>\n  </div>\n\n  <script>\n(function(){\n  // Core state and engine for Two Pointers Explorer\n  let state = null;\n  let history = [];\n  let running = false;\n  let runTimer = null;\n  let branches = {}; // id -> {state, history}\n  let branchCounter = 1;\n  let currentBranchId = null;\n  let breakpointExpr = null;\n\n  // DOM elements\n  const algoSelect = document.getElementById('algo-select');\n  const arrayInput = document.getElementById('array-input');\n  const genRandomBtn = document.getElementById('gen-random');\n  const shuffleBtn = document.getElementById('shuffle-array');\n  const sizeSlider = document.getElementById('size-slider');\n  const sizeDisplay = document.getElementById('size-display');\n  const randMin = document.getElementById('rand-min');\n  const randMax = document.getElementById('rand-max');\n  const genSort = document.getElementById('gen-sort');\n  const targetInput = document.getElementById('target-input');\n  const pivotInput = document.getElementById('pivot-input');\n  const pivotLabel = document.getElementById('pivot-label');\n  const linkedListNote = document.getElementById('linked-list-note');\n  const speedSlider = document.getElementById('speed-slider');\n  const speedDisplay = document.getElementById('speed-display');\n  const stepBtn = document.getElementById('step-btn');\n  const stepBackBtn = document.getElementById('step-back-btn');\n  const runBtn = document.getElementById('run-btn');\n  const pauseBtn = document.getElementById('pause-btn');\n  const resetBtn = document.getElementById('reset-btn');\n  const stopResetLogBtn = document.getElementById('stop-and-reset-log');\n  const arrayVisual = document.getElementById('array-visual');\n  const pointersVisual = document.getElementById('pointers-visual');\n  const pseudoCode = document.getElementById('pseudo-code');\n  const matchesArea = document.getElementById('matches-area');\n  const stateArea = document.getElementById('state-area');\n  const logArea = document.getElementById('log-area');\n  const historyArea = document.getElementById('history-area');\n  const createBranchBtn = document.getElementById('create-branch');\n  const branchesList = document.getElementById('branches-list');\n  const initI = document.getElementById('init-i');\n  const initJ = document.getElementById('init-j');\n  const applyInitBtn = document.getElementById('apply-init');\n  const setManualPointersBtn = document.getElementById('set-manual-pointers');\n  const manualI = document.getElementById('manual-i');\n  const manualJ = document.getElementById('manual-j');\n  const stopOnFirstChk = document.getElementById('stop-on-first');\n  const autoApplySwapChk = document.getElementById('auto-apply-swap');\n  const breakpointInput = document.getElementById('breakpoint-input');\n  const setBreakpointBtn = document.getElementById('set-breakpoint');\n  const clearBreakpointBtn = document.getElementById('clear-breakpoint');\n  const customRuleArea = document.getElementById('custom-rule');\n  const exportBtn = document.getElementById('export-state');\n  const importBtn = document.getElementById('import-state');\n  const exportArea = document.getElementById('export-area');\n  const stopClearLogBtn = document.getElementById('stop-and-reset-log');\n\n  // Preset buttons\n  document.querySelectorAll('.preset').forEach(btn => {\n    btn.addEventListener('click', () => {\n      arrayInput.value = btn.getAttribute('data-val');\n      buildNewStateFromInputs();\n    });\n  });\n\n  // Helpers\n  function parseArrayInput() {\n    const raw = arrayInput.value.trim();\n    if (!raw) return [];\n    return raw.split(',').map(s => {\n      const t = s.trim();\n      // Allow empty as NaN? We'll parse to number if possible otherwise keep string\n      if (t === '') return null;\n      const n = Number(t);\n      return isNaN(n) ? t : n;\n    });\n  }\n  function copyArr(a) { return a.map(v => (Array.isArray(v) ? copyArr(v) : v)); }\n  function deepCopy(s) {\n    return JSON.parse(JSON.stringify(s));\n  }\n  function clamp(n, lo, hi) { return Math.max(lo, Math.min(hi, n)); }\n\n  // Initialize state\n  function defaultStateFromInputs() {\n    const arr = parseArrayInput();\n    const n = arr.length;\n    const algo = algoSelect.value;\n    const s = {\n      algo,\n      arr: arr.slice(),\n      n,\n      step: 0,\n      log: [],\n      matches: [],\n      // generic pointers\n      i: 0,\n      j: n - 1,\n      // for other algos\n      low: 0, mid: 0, high: Math.max(0, n - 1),\n      slow: null, fast: null,\n      // algorithm specific flags\n      finished: false,\n      config: {\n        stopOnFirst: stopOnFirstChk.checked,\n        autoApplySwap: autoApplySwapChk.checked\n      }\n    };\n    // initial pointers per algorithm\n    if (algo === 'remove-duplicates') {\n      s.i = 0; s.j = 1;\n    } else if (algo === 'partition-pivot') {\n      s.low = 0; s.mid = 0; s.high = Math.max(0, n - 1); // pivot in pivotInput\n    } else if (algo === 'reverse-subarray') {\n      s.i = 0; s.j = Math.max(0, n - 1);\n    } else if (algo === 'slow-fast') {\n      // arr is next indices: set slow and fast\n      s.slow = arr.length > 0 ? arr[0] : null;\n      s.fast = (arr.length>0 && Number.isInteger(arr[0]) && arr[0]>=0 && arr[0] < arr.length) ? arr[arr[0]] : null;\n    } else {\n      s.i = 0; s.j = Math.max(0, n - 1);\n    }\n    // apply user-specified initial indices if present\n    const userI = parseInt(initI.value); const userJ = parseInt(initJ.value);\n    if (!Number.isNaN(userI)) s.i = clamp(userI, 0, Math.max(0, n-1));\n    if (!Number.isNaN(userJ)) s.j = clamp(userJ, 0, Math.max(0, n-1));\n    return s;\n  }\n\n  function buildNewStateFromInputs() {\n    state = defaultStateFromInputs();\n    history = [deepCopy(state)];\n    branches = {};\n    currentBranchId = null;\n    branchCounter = 1;\n    updateAllDisplays();\n    log(\"Reset state.\");\n    refreshBranchesUI();\n  }\n\n  // UI updates\n  function updateArrayVisual() {\n    arrayVisual.innerHTML = '';\n    const arr = state.arr;\n    for (let idx = 0; idx < arr.length; idx++) {\n      const cell = document.createElement('div');\n      cell.className = 'cell';\n      cell.textContent = String(arr[idx]);\n      arrayVisual.appendChild(cell);\n    }\n    // pointers\n    const pointerLines = [];\n    if (state.algo === 'partition-pivot') {\n      pointerLines.push(`low=${state.low}  mid=${state.mid}  high=${state.high}`);\n    } else if (state.algo === 'slow-fast') {\n      pointerLines.push(`slow=${state.slow}  fast=${state.fast}`);\n    } else {\n      pointerLines.push(`i=${state.i}  j=${state.j}`);\n    }\n    pointersVisual.textContent = pointerLines.join('   ');\n  }\n\n  function updatePseudoCode() {\n    const algo = state.algo;\n    const lines = [];\n    if (algo === 'pair-sum') {\n      lines.push('i = 0, j = n-1');\n      lines.push('while i < j:');\n      lines.push('  sum = arr[i] + arr[j]');\n      lines.push('  if sum == target: record pair; (optionally move both or stop)');\n      lines.push('  else if sum < target: i++');\n      lines.push('  else: j--');\n    } else if (algo === 'remove-duplicates') {\n      lines.push('i = 0 (slow), j = 1 (fast)');\n      lines.push('while j < n:');\n      lines.push('  if arr[i] == arr[j]: j++');\n      lines.push('  else: i++; arr[i] = arr[j]; j++');\n      lines.push('Result length = i+1');\n    } else if (algo === 'partition-pivot') {\n      lines.push('low = 0, mid = 0, high = n-1');\n      lines.push('while mid <= high:');\n      lines.push('  if arr[mid] < pivot: swap(arr[low],arr[mid]); low++; mid++;');\n      lines.push('  else if arr[mid] == pivot: mid++');\n      lines.push('  else: swap(arr[mid],arr[high]); high--;');\n    } else if (algo === 'reverse-subarray') {\n      lines.push('i = start, j = end');\n      lines.push('while i < j: swap(arr[i], arr[j]); i++; j--;');\n    } else if (algo === 'slow-fast') {\n      lines.push('slow = head; fast = head');\n      lines.push('while fast and fast.next: slow = slow.next; fast = fast.next.next');\n      lines.push('if slow == fast -> cycle detected');\n      lines.push('Array form: arr[k] points to next index, -1 for null');\n    } else if (algo === 'custom-rule') {\n      lines.push('User defines a JS expression returning an action object.');\n      lines.push('Variables available: arr, i, j, target, pivot, matches, step');\n      lines.push('Action shape example: { moveI:1, moveJ:-1, swap:true, recordMatch:true, stop:false }');\n    }\n    pseudoCode.textContent = lines.join('\\\\n');\n  }\n\n  function updateMatchesArea() {\n    matchesArea.textContent = JSON.stringify(state.matches, null, 2);\n  }\n\n  function updateStateArea() {\n    const s = {\n      algo: state.algo,\n      i: state.i, j: state.j, low: state.low, mid: state.mid, high: state.high,\n      slow: state.slow, fast: state.fast, step: state.step, finished: state.finished\n    };\n    stateArea.textContent = JSON.stringify(s, null, 2);\n  }\n\n  function updateHistoryUI() {\n    historyArea.innerHTML = '';\n    const list = document.createElement('div');\n    history.forEach((h, idx) => {\n      const b = document.createElement('button');\n      b.textContent = `#${idx} s:${h.step}`;\n      b.style.display = 'block';\n      b.addEventListener('click', () => {\n        jumpToHistory(idx);\n      });\n      historyArea.appendChild(b);\n    });\n  }\n\n  function refreshBranchesUI() {\n    branchesList.innerHTML = '';\n    const root = document.createElement('div');\n    if (Object.keys(branches).length === 0) {\n      branchesList.textContent = '(no branches)';\n      return;\n    }\n    for (const id in branches) {\n      const b = branches[id];\n      const btn = document.createElement('button');\n      btn.textContent = `Branch ${id} (step ${b.state.step})`;\n      btn.style.display = 'block';\n      btn.addEventListener('click', () => {\n        switchToBranch(id);\n      });\n      const del = document.createElement('button');\n      del.textContent = 'Delete';\n      del.addEventListener('click', (e) => {\n        e.stopPropagation();\n        delete branches[id];\n        if (currentBranchId === id) currentBranchId = null;\n        refreshBranchesUI();\n      });\n      branchesList.appendChild(btn);\n      branchesList.appendChild(del);\n    }\n  }\n\n  function updateAllDisplays() {\n    updateArrayVisual();\n    updatePseudoCode();\n    updateMatchesArea();\n    updateStateArea();\n    updateHistoryUI();\n  }\n\n  function log(msg) {\n    const t = new Date().toLocaleTimeString();\n    state.log.push(`${t}: ${msg}`);\n    const line = document.createElement('div');\n    line.textContent = `${t}: ${msg}`;\n    logArea.appendChild(line);\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  function jumpToHistory(idx) {\n    if (idx < 0 || idx >= history.length) return;\n    state = deepCopy(history[idx]);\n    history = history.slice(0, idx + 1);\n    updateAllDisplays();\n    log(`Jumped to history #${idx}`);\n  }\n\n  // Branching\n  function createBranch() {\n    const id = String(branchCounter++);\n    branches[id] = { state: deepCopy(state), history: deepCopy(history) };\n    currentBranchId = id;\n    refreshBranchesUI();\n    log(`Created branch ${id}`);\n  }\n  function switchToBranch(id) {\n    if (!branches[id]) return;\n    state = deepCopy(branches[id].state);\n    history = deepCopy(branches[id].history);\n    currentBranchId = id;\n    updateAllDisplays();\n    log(`Switched to branch ${id}`);\n  }\n\n  // Step execution per algorithm\n  function evaluateBreakpoint() {\n    if (!breakpointExpr) return false;\n    try {\n      const arr = state.arr;\n      const i = state.i; const j = state.j;\n      const low = state.low; const mid = state.mid; const high = state.high;\n      const slow = state.slow; const fast = state.fast;\n      const target = Number(targetInput.value);\n      const pivot = Number(pivotInput.value);\n      const matches = state.matches;\n      const step = state.step;\n      const res = (new Function('arr','i','j','low','mid','high','slow','fast','target','pivot','matches','step','return (' + breakpointExpr + ')')).call(null, arr,i,j,low,mid,high,slow,fast,target,pivot,matches,step);\n      return !!res;\n    } catch (e) {\n      log('Breakpoint evaluation error: ' + e.message);\n      breakpointExpr = null;\n      breakpointInput.value = '';\n      return false;\n    }\n  }\n\n  function stepEngine() {\n    if (!state || state.finished) {\n      running = false;\n      clearInterval(runTimer);\n      runTimer = null;\n      runBtn.disabled = false;\n      pauseBtn.disabled = true;\n      return;\n    }\n    // Check breakpoint BEFORE executing step (so we can pause at this state)\n    if (evaluateBreakpoint()) {\n      running = false;\n      clearInterval(runTimer);\n      runTimer = null;\n      runBtn.disabled = false;\n      pauseBtn.disabled = true;\n      log('Paused at breakpoint condition.');\n      return;\n    }\n\n    const algo = state.algo;\n    let action = null;\n    try {\n      if (algo === 'pair-sum') action = alg_pair_sum_step();\n      else if (algo === 'remove-duplicates') action = alg_remove_duplicates_step();\n      else if (algo === 'partition-pivot') action = alg_partition_step();\n      else if (algo === 'reverse-subarray') action = alg_reverse_step();\n      else if (algo === 'slow-fast') action = alg_slow_fast_step();\n      else if (algo === 'custom-rule') action = alg_custom_rule_step();\n      else action = { stop: true };\n    } catch (e) {\n      log('Error during step: ' + e.message);\n      action = { stop: true };\n    }\n    state.step++;\n    // After computing action, apply it\n    applyAction(action);\n    // record to history\n    history.push(deepCopy(state));\n    updateAllDisplays();\n    // If finished, stop running\n    if (state.finished) {\n      running = false;\n      clearInterval(runTimer);\n      runTimer = null;\n      runBtn.disabled = false;\n      pauseBtn.disabled = true;\n      log('Algorithm finished.');\n    }\n  }\n\n  // Apply generic action\n  function applyAction(action) {\n    if (!action) return;\n    // swap\n    if (action.swap) {\n      const a = action.swapA !== undefined ? action.swapA : state.i;\n      const b = action.swapB !== undefined ? action.swapB : state.j;\n      const tmp = state.arr[a];\n      state.arr[a] = state.arr[b];\n      state.arr[b] = tmp;\n      log(`Swapped indices ${a} and ${b}.`);\n    }\n    // record match\n    if (action.recordMatch) {\n      state.matches.push(action.recordMatch === true ? [state.i, state.j] : action.recordMatch);\n      log('Recorded match: ' + JSON.stringify(state.matches[state.matches.length-1]));\n      if (state.config.stopOnFirst) {\n        state.finished = true;\n        return;\n      }\n    }\n    // pointer moves\n    if (action.setI !== undefined) state.i = clamp(action.setI, 0, Math.max(0, state.arr.length-1));\n    if (action.setJ !== undefined) state.j = clamp(action.setJ, 0, Math.max(0, state.arr.length-1));\n    if (action.moveI) state.i = clamp(state.i + action.moveI, 0, Math.max(0, state.arr.length-1));\n    if (action.moveJ) state.j = clamp(state.j + action.moveJ, 0, Math.max(0, state.arr.length-1));\n    if (action.setLow !== undefined) state.low = clamp(action.setLow, 0, Math.max(0, state.arr.length-1));\n    if (action.setMid !== undefined) state.mid = clamp(action.setMid, 0, Math.max(0, state.arr.length-1));\n    if (action.setHigh !== undefined) state.high = clamp(action.setHigh, 0, Math.max(0, state.arr.length-1));\n    if (action.moveLow) state.low = clamp(state.low + action.moveLow, 0, Math.max(0, state.arr.length-1));\n    if (action.moveMid) state.mid = clamp(state.mid + action.moveMid, 0, Math.max(0, state.arr.length-1));\n    if (action.moveHigh) state.high = clamp(state.high + action.moveHigh, 0, Math.max(0, state.arr.length-1));\n    if (action.setSlow !== undefined) state.slow = action.setSlow;\n    if (action.setFast !== undefined) state.fast = action.setFast;\n    if (action.moveSlow) state.slow = action.moveSlow;\n    if (action.moveFast) state.fast = action.moveFast;\n    // stop flag\n    if (action.stop) state.finished = true;\n  }\n\n  // Algorithm step implementations\n  function alg_pair_sum_step() {\n    const arr = state.arr;\n    const i = state.i; const j = state.j;\n    const target = Number(targetInput.value);\n    if (i >= j) {\n      return { stop: true };\n    }\n    const sum = Number(arr[i]) + Number(arr[j]);\n    log(`Checking i=${i} (${arr[i]}) + j=${j} (${arr[j]}) => ${sum}`);\n    if (sum === target) {\n      // record and decide movement\n      if (state.config.stopOnFirst) {\n        return { recordMatch: [i,j], stop: true };\n      } else {\n        // record but continue: default move both\n        return { recordMatch: [i,j], moveI: 1, moveJ: -1 };\n      }\n    } else if (sum < target) {\n      return { moveI: 1 };\n    } else {\n      return { moveJ: -1 };\n    }\n  }\n\n  function alg_remove_duplicates_step() {\n    const n = state.arr.length;\n    let i = state.i; let j = state.j;\n    if (j >= n) {\n      log('Remove duplicates finished; result length = ' + (i+1));\n      return { stop: true };\n    }\n    log(`Comparing i=${i} (${state.arr[i]}) and j=${j} (${state.arr[j]})`);\n    if (state.arr[i] === state.arr[j]) {\n      // duplicate\n      return { moveJ: 1 };\n    } else {\n      // move i and copy arr[j] to arr[i+1]\n      state.arr[i+1] = state.arr[j];\n      log(`Moved arr[${j}] -> arr[${i+1}]`);\n      return { moveI: 1, moveJ: 1 };\n    }\n  }\n\n  function alg_partition_step() {\n    const pivot = Number(pivotInput.value);\n    const low = state.low; const mid = state.mid; const high = state.high;\n    if (mid > high) {\n      log('Partition finished.');\n      return { stop: true };\n    }\n    const val = state.arr[mid];\n    log(`Inspecting mid=${mid} val=${val} pivot=${pivot}`);\n    if (val < pivot) {\n      if (state.config.autoApplySwap) {\n        return { swap: true, swapA: low, swapB: mid, moveLow: 1, moveMid: 1 };\n      } else {\n        // offer to swap? here just swap if user chooses autoApplySwap; otherwise only move pointers without swap\n        log('Auto-swap disabled; moving low and mid without swapping values (simulated).');\n        return { moveLow: 1, moveMid: 1 };\n      }\n    } else if (val === pivot) {\n      return { moveMid: 1 };\n    } else {\n      if (state.config.autoApplySwap) {\n        return { swap: true, swapA: mid, swapB: high, moveHigh: -1 };\n      } else {\n        log('Auto-swap disabled; moving high without swapping (simulated).');\n        return { moveHigh: -1 };\n      }\n    }\n  }\n\n  function alg_reverse_step() {\n    if (state.i >= state.j) {\n      log('Reverse finished.');\n      return { stop: true };\n    }\n    log(`Swapping i=${state.i} (${state.arr[state.i]}) and j=${state.j} (${state.arr[state.j]})`);\n    return { swap: true, swapA: state.i, swapB: state.j, moveI: 1, moveJ: -1 };\n  }\n\n  function alg_slow_fast_step() {\n    // arr contains next indices or -1 for null\n    if (state.slow === null || state.fast === null) {\n      log('No cycle: pointers are null');\n      return { stop: true };\n    }\n    log(`Moving slow from ${state.slow} to next; fast from ${state.fast} to next.next`);\n    const arr = state.arr;\n    const nextSlow = (typeof arr[state.slow] === 'number') ? arr[state.slow] : null;\n    const nextFast = getNextIndex(arr, state.fast);\n    const nextFast2 = getNextIndex(arr, nextFast);\n    state.slow = nextSlow;\n    state.fast = nextFast2;\n    if (state.slow === null || state.fast === null) {\n      log('Reached null - no cycle');\n      return { stop: true, setSlow: state.slow, setFast: state.fast };\n    }\n    if (state.slow === state.fast) {\n      log('Cycle detected; slow == fast = ' + state.slow);\n      return { stop: true };\n    }\n    return { setSlow: state.slow, setFast: state.fast };\n    function getNextIndex(arr, idx) {\n      if (idx === null || idx === undefined) return null;\n      if (idx < 0 || idx >= arr.length) return null;\n      const nxt = arr[idx];\n      if (nxt === -1 || nxt === null || nxt === undefined) return null;\n      return Number.isFinite(nxt) ? nxt : null;\n    }\n  }\n\n  function alg_custom_rule_step() {\n    // evaluate user-provided JS that returns an action object\n    const code = customRuleArea.value || '';\n    const arr = state.arr;\n    const i = state.i; const j = state.j;\n    const target = Number(targetInput.value);\n    const pivot = Number(pivotInput.value);\n    const matches = state.matches;\n    const stepNum = state.step;\n    try {\n      const func = new Function('arr','i','j','target','pivot','matches','step','return (' + code + ')');\n      const action = func(arr,i,j,target,pivot,matches,stepNum);\n      log('Custom rule produced action: ' + JSON.stringify(action));\n      if (!action) return { stop: true };\n      return action;\n    } catch (e) {\n      log('Custom rule error: ' + e.message);\n      return { stop: true };\n    }\n  }\n\n  // Button handlers\n  genRandomBtn.addEventListener('click', () => {\n    const size = Number(sizeSlider.value);\n    const lo = Number(randMin.value); const hi = Number(randMax.value);\n    const arr = [];\n    for (let k=0;k<size;k++) arr.push(Math.floor(Math.random()*(hi-lo+1))+lo);\n    if (genSort.checked) arr.sort((a,b)=>a-b);\n    arrayInput.value = arr.join(',');\n    buildNewStateFromInputs();\n  });\n  shuffleBtn.addEventListener('click', () => {\n    const arr = parseArrayInput();\n    for (let k=arr.length-1;k>0;k--) {\n      const r = Math.floor(Math.random()*(k+1));\n      const tmp = arr[k]; arr[k]=arr[r]; arr[r]=tmp;\n    }\n    arrayInput.value = arr.join(',');\n    buildNewStateFromInputs();\n  });\n\n  sizeSlider.addEventListener('input', () => sizeDisplay.textContent = sizeSlider.value);\n  speedSlider.addEventListener('input', () => speedDisplay.textContent = speedSlider.value);\n\n  algoSelect.addEventListener('change', () => {\n    const v = algoSelect.value;\n    // Show/hide controls\n    document.getElementById('target-label').style.display = (v === 'pair-sum' || v === 'custom-rule') ? '' : 'none';\n    pivotLabel.style.display = (v === 'partition-pivot' || v === 'custom-rule') ? '' : 'none';\n    linkedListNote.style.display = (v === 'slow-fast') ? '' : 'none';\n    if (v === 'custom-rule') {\n      // show custom rule\n    }\n    buildNewStateFromInputs();\n  });\n\n  stepBtn.addEventListener('click', () => {\n    // Single step\n    if (!state || state.finished) return;\n    stepEngine();\n    updateAllDisplays();\n  });\n  stepBackBtn.addEventListener('click', () => {\n    if (history.length <= 1) {\n      log('No step back available.');\n      return;\n    }\n    history.pop(); // current\n    const prev = history[history.length-1];\n    state = deepCopy(prev);\n    updateAllDisplays();\n    log('Stepped back.');\n  });\n\n  runBtn.addEventListener('click', () => {\n    if (running) return;\n    running = true;\n    runBtn.disabled = true;\n    pauseBtn.disabled = false;\n    const interval = Number(speedSlider.value);\n    runTimer = setInterval(() => {\n      if (!state || state.finished) {\n        running = false;\n        clearInterval(runTimer);\n        runTimer = null;\n        runBtn.disabled = false;\n        pauseBtn.disabled = true;\n        return;\n      }\n      stepEngine();\n    }, interval);\n    log('Started running.');\n  });\n\n  pauseBtn.addEventListener('click', () => {\n    running = false;\n    clearInterval(runTimer);\n    runTimer = null;\n    runBtn.disabled = false;\n    pauseBtn.disabled = true;\n    log('Paused.');\n  });\n\n  resetBtn.addEventListener('click', () => {\n    buildNewStateFromInputs();\n    log('User reset state.');\n  });\n\n  stopResetLogBtn.addEventListener('click', () => {\n    running = false;\n    clearInterval(runTimer);\n    runTimer = null;\n    runBtn.disabled = false;\n    pauseBtn.disabled = true;\n    logArea.innerHTML = '';\n    if (state) state.log = [];\n    log('Stopped and cleared logs.');\n  });\n\n  createBranchBtn.addEventListener('click', () => createBranch());\n  applyInitBtn.addEventListener('click', () => {\n    const s = parseInt(initI.value); const t = parseInt(initJ.value);\n    if (!Number.isNaN(s)) state.i = clamp(s,0,Math.max(0,state.arr.length-1));\n    if (!Number.isNaN(t)) state.j = clamp(t,0,Math.max(0,state.arr.length-1));\n    history.push(deepCopy(state));\n    updateAllDisplays();\n    log('Applied initial indices.');\n  });\n\n  setManualPointersBtn.addEventListener('click', () => {\n    const si = parseInt(manualI.value); const sj = parseInt(manualJ.value);\n    if (!Number.isNaN(si)) state.i = clamp(si,0,Math.max(0,state.arr.length-1));\n    if (!Number.isNaN(sj)) state.j = clamp(sj,0,Math.max(0,state.arr.length-1));\n    history.push(deepCopy(state));\n    updateAllDisplays();\n    log('Manually set pointers.');\n  });\n\n  setBreakpointBtn.addEventListener('click', () => {\n    const t = breakpointInput.value.trim();\n    if (!t) {\n      breakpointExpr = null;\n      log('Cleared breakpoint.');\n    } else {\n      breakpointExpr = t;\n      log('Set breakpoint expression: ' + t);\n    }\n  });\n  clearBreakpointBtn.addEventListener('click', () => {\n    breakpointExpr = null; breakpointInput.value = '';\n    log('Cleared breakpoint.');\n  });\n\n  exportBtn.addEventListener('click', () => {\n    exportArea.value = JSON.stringify({ state, history, branches }, null, 2);\n    log('Exported state to text area.');\n  });\n  importBtn.addEventListener('click', () => {\n    try {\n      const obj = JSON.parse(exportArea.value);\n      if (obj.state) state = obj.state;\n      if (obj.history) history = obj.history;\n      if (obj.branches) branches = obj.branches;\n      updateAllDisplays();\n      refreshBranchesUI();\n      log('Imported state.');\n    } catch (e) {\n      log('Import error: ' + e.message);\n    }\n  });\n\n  // Option toggles update config\n  stopOnFirstChk.addEventListener('change', () => { if (state) state.config.stopOnFirst = stopOnFirstChk.checked; });\n  autoApplySwapChk.addEventListener('change', () => { if (state) state.config.autoApplySwap = autoApplySwapChk.checked; });\n\n  // Keyboard shortcuts\n  document.addEventListener('keydown', (e) => {\n    if (e.key === ' ') { e.preventDefault(); stepBtn.click(); }\n    if (e.key === 'r') { runBtn.click(); }\n    if (e.key === 'p') { pauseBtn.click(); }\n  });\n\n  // Initial build\n  buildNewStateFromInputs();\n\n  // Expose some helpers to console for power users\n  window.TwoPointersExplorer = {\n    state: () => state,\n    history: () => history,\n    step: () => stepBtn.click(),\n    run: () => runBtn.click(),\n    pause: () => pauseBtn.click(),\n    createBranch\n  };\n\n  // Misc utility: shuffle array\n  function shuffleArray(a) {\n    for (let i=a.length-1;i>0;i--) {\n      const r = Math.floor(Math.random()*(i+1));\n      const tmp = a[i]; a[i]=a[r]; a[r]=tmp;\n    }\n  }\n\n  // Keep UI in sync if user edits array input manually\n  arrayInput.addEventListener('change', () => buildNewStateFromInputs());\n  targetInput.addEventListener('change', () => { if (state) state.config.target = Number(targetInput.value); });\n  pivotInput.addEventListener('change', () => { if (state) state.config.pivot = Number(pivotInput.value); });\n\n})();\n  </script>\n</body>\n</html>"
