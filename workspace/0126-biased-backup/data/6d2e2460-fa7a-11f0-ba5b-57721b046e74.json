    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Tim Sort Interactive Demo</title>\n    <style>\n        body { font-family: monospace; margin: 20px; line-height: 1.6; }\n        .container { max-width: 1000px; margin: 0 auto; }\n        .controls { margin: 20px 0; padding: 10px; border: 1px solid #ccc; }\n        .control-group { margin-bottom: 10px; }\n        button, input, select { margin-right: 10px; }\n        .array-container { margin: 20px 0; }\n        .array-element { display: inline-block; padding: 5px; margin: 2px; border: 1px solid #000; }\n        .run { background-color: #f0f0f0; }\n        .current { background-color: #d0d0d0; }\n        .min-run { border: 1px dashed #000; }\n        .merged { border: 1px solid #f00; }\n        .log { height: 200px; overflow-y: scroll; border: 1px solid #000; padding: 10px; margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Tim Sort Interactive Demo</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <label>Array Size: <input type=\"range\" id=\"arraySize\" min=\"10\" max=\"100\" value=\"30\"></label>\n                <span id=\"arraySizeValue\">30</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <label>Initial Order:\n                    <select id=\"initialOrder\">\n                        <option value=\"random\">Random</option>\n                        <option value=\"sorted\">Sorted</option>\n                        <option value=\"reverse\">Reverse Sorted</option>\n                        <option value=\"partially\">Partially Sorted</option>\n                    </select>\n                </label>\n            </div>\n            \n            <div class=\"control-group\">\n                <label>Min Run Size: <input type=\"range\" id=\"minRunSize\" min=\"4\" max=\"32\" value=\"16\"></label>\n                <span id=\"minRunSizeValue\">16</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <button id=\"generateArray\">Generate New Array</button>\n                <button id=\"stepForward\">Step Forward</button>\n                <button id=\"runToEnd\">Run to Completion</button>\n                <button id=\"reset\">Reset</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <label>Speed: <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\"></label>\n                <span id=\"speedValue\">500ms</span>\n            </div>\n        </div>\n        \n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n        \n        <div class=\"log\" id=\"log\"></div>\n        \n        <div class=\"info\">\n            <h3>Tim Sort Information</h3>\n            <p>Current State: <span id=\"currentState\">Initial</span></p>\n            <p>Current Step: <span id=\"currentStep\">0</span></p>\n            <p>Runs Identified: <span id=\"runsCount\">0</span></p>\n            <p>Merges Performed: <span id=\"mergesCount\">0</span></p>\n            <p>Comparisons: <span id=\"comparisonsCount\">0</span></p>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let array = [];\n        let originalArray = [];\n        let runs = [];\n        let currentRunIndex = 0;\n        let mergeStack = [];\n        let currentStep = 0;\n        let isRunning = false;\n        let runInterval = null;\n        let comparisons = 0;\n        let merges = 0;\n        \n        // DOM elements\n        const arrayContainer = document.getElementById('arrayContainer');\n        const logElement = document.getElementById('log');\n        const arraySizeInput = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const minRunSizeInput = document.getElementById('minRunSize');\n        const minRunSizeValue = document.getElementById('minRunSizeValue');\n        const speedInput = document.getElementById('speed');\n        const speedValue = document.getElementById('speedValue');\n        const currentStateElement = document.getElementById('currentState');\n        const currentStepElement = document.getElementById('currentStep');\n        const runsCountElement = document.getElementById('runsCount');\n        const mergesCountElement = document.getElementById('mergesCount');\n        const comparisonsCountElement = document.getElementById('comparisonsCount');\n        \n        // Event listeners\n        document.getElementById('generateArray').addEventListener('click', generateArray);\n        document.getElementById('stepForward').addEventListener('click', stepForward);\n        document.getElementById('runToEnd').addEventListener('click', runToEnd);\n        document.getElementById('reset').addEventListener('click', reset);\n        arraySizeInput.addEventListener('input', updateArraySizeValue);\n        minRunSizeInput.addEventListener('input', updateMinRunSizeValue);\n        speedInput.addEventListener('input', updateSpeedValue);\n        \n        // Initialize\n        generateArray();\n        \n        // Helper functions\n        function updateArraySizeValue() {\n            arraySizeValue.textContent = arraySizeInput.value;\n        }\n        \n        function updateMinRunSizeValue() {\n            minRunSizeValue.textContent = minRunSizeInput.value;\n        }\n        \n        function updateSpeedValue() {\n            speedValue.textContent = speedInput.value + 'ms';\n        }\n        \n        function log(message) {\n            logElement.innerHTML += message> ' + message + '<br>';\n            logElement.scrollTop = logElement.scrollHeight;\n        }\n        \n        function updateStats() {\n            currentStepElement.textContent = currentStep;\n            runsCountElement.textContent = runs.length;\n            mergesCountElement.textContent = merges;\n            comparisonsCountElement.textContent = comparisons;\n        }\n        \n        function generateArray() {\n            const size = parseInt(arraySizeInput.value);\n            const order = document.getElementById('initialOrder').value;\n            \n            array = [];\n            originalArray = [];\n            \n            // Generate base array\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * 100) + 1);\n            }\n            \n            // Apply ordering\n            if (order === 'sorted') {\n                array.sort((a, b) => a - b);\n            } else if (order === 'reverse') {\n                array.sort((a, b) => b - a);\n            } else if (order === 'partially') {\n                array.sort((a, b) => a - b);\n                // Randomly swap some elements\n                for (let i = 0; i < size / 4; i++) {\n                    const idx1 = Math.floor(Math.random() * size);\n                    const idx2 = Math.floor(Math.random() * size);\n                    [array[idx1], array[idx2]] = [array[idx2], array[idx1]];\n                }\n            }\n            \n            originalArray = [...array];\n            reset();\n            renderArray();\n            log('Generated new array with ' + size + ' elements (' + order + ' order)');\n        }\n        \n        function reset() {\n            array = [...originalArray];\n            runs = [];\n            currentRunIndex = 0;\n            mergeStack = [];\n            currentStep = 0;\n            comparisons = 0;\n            merges = 0;\n            isRunning = false;\n            clearInterval(runInterval);\n            currentStateElement.textContent = 'Initial';\n            updateStats();\n            renderArray();\n            log('Reset to initial state');\n        }\n        \n        function renderArray() {\n            arrayContainer.innerHTML = '';\n            \n            for (let i = 0; i < array.length; i++) {\n                const element = document.createElement('div');\n                element.className = 'array-element';\n                element.textContent = array[i];\n                \n                // Highlight runs\n                for (const run of runs) {\n                    if (i >= run.start && i <= run.end) {\n                        element.classList.add('run');\n                        break;\n                    }\n                }\n                \n                // Highlight current run\n                if (runs[currentRunIndex] && i >= runs[currentRunIndex].start && i <= runs[currentRunIndex].end) {\n                    element.classList.add('current');\n                }\n                \n                // Highlight min runs\n                const minRunSize = parseInt(minRunSizeInput.value);\n                for (const run of runs) {\n                    if (run.artificial && i >= run.start && i <= run.end) {\n                        element.classList.add('min-run');\n                        break;\n                    }\n                }\n                \n                arrayContainer.appendChild(element);\n            }\n        }\n        \n        function stepForward() {\n            if (currentStep === 0) {\n                findRuns();\n                currentStateElement.textContent = 'Finding Runs';\n                log('Starting Tim Sort - finding runs');\n            } else if (currentRunIndex < runs.length - 1) {\n                // Check if we need to merge\n                const run1 = runs[currentRunIndex];\n                const run2 = runs[currentRunIndex + 1];\n                \n                if (shouldMerge(run1, run2)) {\n                    mergeRuns(currentRunIndex, currentRunIndex + 1);\n                    currentStateElement.textContent = 'Merging Runs';\n                    log('Merging runs ' + currentRunIndex + ' and ' + (currentRunIndex + 1));\n                    merges++;\n                } else {\n                    currentRunIndex++;\n                    currentStateElement.textContent = 'Checking Next Run';\n                    log('Moving to next run: ' + (currentRunIndex + 1));\n                }\n            } else if (mergeStack.length > 1) {\n                // Merge remaining runs in stack\n                const run1 = mergeStack[mergeStack.length - 2];\n                const run2 = mergeStack[mergeStack.length - 1];\n                mergeRunsInStack();\n                currentStateElement.textContent = 'Merging Stack';\n                log('Merging runs in stack');\n                merges++;\n            } else if (runs.length === 1 && mergeStack.length === 0) {\n                currentStateElement.textContent = 'Completed';\n                log('Sorting finished!');\n                return;\n            } else {\n                // Push remaining runs to stack\n                while (currentRunIndex < runs.length) {\n                    mergeStack.push(runs[currentRunIndex]);\n                    log('Pushing run ' + currentRunIndex + ' to stack');\n                    currentRunIndex++;\n                }\n            }\n            \n            currentStep++;\n            updateStats();\n            renderArray();\n        }\n        \n        function runToEnd() {\n            if (isRunning) {\n                clearInterval(runInterval);\n                isRunning = false;\n                document.getElementById('runToEnd').textContent = 'Run to Completion';\n                return;\n            }\n            \n            isRunning = true;\n            document.getElementById('runToEnd').textContent = 'Stop';\n            \n            runInterval = setInterval(() => {\n                stepForward();\n                \n                if (currentStateElement.textContent === 'Completed') {\n                    clearInterval(runInterval);\n                    isRunning = false;\n                    document.getElementById('runToEnd').textContent = 'Run to Completion';\n                }\n            }, parseInt(speedInput.value));\n        }\n        \n        function findRuns() {\n            const minRun = parseInt(minRunSizeInput.value);\n            let i = 0;\n            const n = array.length;\n            \n            while (i < n) {\n                let j = i;\n                \n                // Find natural run\n                if (i < n - 1) {\n                    if (array[i] <= array[i + 1]) {\n                        while (j < n - 1 && array[j] <= array[j + 1]) {\n                            j++;\n                            comparisons++;\n                        }\n                    } else {\n                        while (j < n - 1 && array[j] > array[j + 1]) {\n                            j++;\n                            comparisons++;\n                        }\n                        // Reverse descending run\n                        reverse(i, j);\n                    }\n                }\n                \n                // If run is too short, extend it\n                if (j - i + 1 < minRun) {\n                    const end = Math.min(i + minRun - 1, n - 1);\n                    insertionSort(i, end);\n                    j = end;\n                }\n                \n                runs.push({\n                    start: i,\n                    end: j,\n                    artificial: (j - i + 1) >= minRun ? false : true\n                });\n                \n                i = j + 1;\n            }\n            \n            log('Found ' + runs.length + ' runs');\n        }\n        \n        function reverse(start, end) {\n            while (start < end) {\n                [array[start], array[end]] = [array[end], array[start]];\n                start++;\n                end--;\n            }\n        }\n        \n        function insertionSort(start, end) {\n            for (let i = start + 1; i <= end; i++) {\n                const key = array[i];\n                let j = i - 1;\n                \n                while (j >= start && array[j] > key) {\n                    array[j + 1] = array[j];\n                    j--;\n                    comparisons++;\n                }\n                \n                array[j + 1] = key;\n                comparisons++;\n            }\n        }\n        \n        function shouldMerge(run1, run2) {\n            // Check if run2 can be merged with run1\n            if (mergeStack.length >= 2) {\n                const stackRun1 = mergeStack[mergeStack.length - 2];\n                const stackRun2 = mergeStack[mergeStack.length - 1];\n                \n                if (stackRun1.end - stackRun1.start + 1 <= stackRun2.end - stackRun2.start + 1 + run2.end - run2.start + 1) {\n                    return true;\n                }\n            }\n            \n            if (mergeStack.length >= 1) {\n                const stackRun = mergeStack[mergeStack.length - 1];\n                if (stackRun.end - stackRun.start + 1 <= run2.end - run2.start + 1) {\n                    return true;\n                }\n            }\n            \n            return false;\n        }\n        \n        function mergeRuns(runIndex1, runIndex2) {\n            const run1 = runs[runIndex1];\n            const run2 = runs[runIndex2];\n            \n            const merged = array.slice(run1.start, run2.end + 1).sort((a, b) => a - b);\n            comparisons += Math.floor(Math.log2(merged.length)) * merged.length;\n            \n            // Copy merged array back\n            for (let i = 0; i < merged.length; i++) {\n                array[run1.start + i] = merged[i];\n            }\n            \n            // Update runs\n            runs.splice(runIndex1, 2, {\n                start: run1.start,\n                end: run2.end,\n                artificial: false\n            });\n            \n            currentRunIndex = Math.max(0, runIndex1 - 1);\n        }\n        \n        function mergeRunsInStack() {\n            if (mergeStack.length < 2) return;\n            \n            const run1 = mergeStack[mergeStack.length - 2];\n            const run2 = mergeStack[mergeStack.length - 1];\n            \n            const merged = array.slice(run1.start, run2.end + 1).sort((a, b) => a - b);\n            comparisons += Math.floor(Math.log2(merged.length)) * merged.length;\n            \n            // Copy merged array back\n            for (let i = 0; i < merged.length; i++) {\n                array[run1.start + i] = merged[i];\n            }\n            \n            // Update stack\n            mergeStack.splice(mergeStack.length - 2, 2, {\n                start: run1.start,\n                end: run2.end,\n                artificial: false\n            });\n        }\n    </script>\n</body>\n</html>"
  },
