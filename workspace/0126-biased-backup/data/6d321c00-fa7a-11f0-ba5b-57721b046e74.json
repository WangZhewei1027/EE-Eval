  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Design Patterns Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            margin-bottom: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        .pattern-controls {\n            margin-top: 10px;\n            padding: 10px;\n            background: #f5f5f5;\n        }\n        .output {\n            margin-top: 10px;\n            padding: 10px;\n            border: 1px dashed #999;\n            min-height: 50px;\n        }\n        button, select {\n            margin: 5px;\n        }\n        input[type=\"range\"] {\n            width: 200px;\n        }\n        .hidden {\n            display: none;\n        }\n        .tab {\n            cursor: pointer;\n            padding: 5px 10px;\n            border: 1px solid #ccc;\n            background: #eee;\n            display: inline-block;\n        }\n        .active-tab {\n            background: #fff;\n            border-bottom: 1px solid #fff;\n        }\n        .tab-content {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-top: -1px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Design Patterns Explorer</h1>\n    <div class=\"pattern-selector\">\n        <h3>Select Pattern Category:</h3>\n        <select id=\"patternCategory\">\n            <option value=\"creational\">Creational Patterns</option>\n            <option value=\"structural\">Structural Patterns</option>\n            <option value=\"behavioral\">Behavioral Patterns</option>\n        </select>\n        <button id=\"loadPatterns\">Load Patterns</button>\n    </div>\n\n    <div id=\"patternsContainer\" class=\"container\"></div>\n\n    <div id=\"patternDetails\" class=\"container hidden\">\n        <h2 id=\"currentPatternName\"></h2>\n        <div id=\"patternTabs\">\n            <div class=\"tab active-tab\" data-tab=\"description\">Description</div>\n            <div class=\"tab\" data-tab=\"example\">Example</div>\n            <div class=\"tab\" data-tab=\"interactive\">Interactive</div>\n        </div>\n        <div id=\"tabContents\">\n            <div id=\"description\" class=\"tab-content\">\n                <p id=\"patternDescription\"></p>\n            </div>\n            <div id=\"example\" class=\"tab-content hidden\">\n                <pre id=\"codeExample\"></pre>\n            </div>\n            <div id=\"interactive\" class=\"tab-content hidden\">\n                <div id=\"interactiveControls\"></div>\n                <div id=\"interactiveOutput\" class=\"output\"></div>\n            </div>\n        </div>\n    </div>\n\n    <div id=\"stateTracker\" class=\"container\">\n        <h3>State History</h3>\n        <div id=\"stateHistory\" class=\"output\"></div>\n        <button id=\"undoAction\">Undo</button>\n        <button id=\"redoAction\">Redo</button>\n        <button id=\"resetAll\">Reset All</button>\n    </div>\n\n    <script>\n        // Pattern data\n        const patterns = {\n            creational: [\n                {\n                    name: \"Singleton\",\n                    description: \"Ensures a class has only one instance and provides a global point of access to it.\",\n                    example: \"class Singleton {\\n  constructor() {}\\n  static getInstance() {\\n    if (!Singleton.instance) {\\n      Singleton.instance = new Singleton();\\n    }\\n    return Singleton.instance;\\n  }\\n}\",\n                    interactive: {\n                        controls: '<button id=\"getInstance\">Get Instance</button>',\n                        init: function() {\n                            document.getElementById('getInstance').addEventListener('click', () => {\n                                const instance = Singleton.getInstance();\n                                document.getElementById('interactiveOutput').textContent = \n                                    `Singleton instance created at: ${instance.createdAt}`;\n                            });\n                        }\n                    }\n                },\n                {\n                    name: \"Factory Method\",\n                    description: \"Defines an interface for creating an object, but lets subclasses decide which class to instantiate.\",\n                    example: \"class ProductFactory {\\n  createProduct(type) {\\n    switch(type) {\\n      case 'A': return new ProductA();\\n      case 'B': return new ProductB();\\n      default: throw new Error('Unknown product type');\\n    }\\n  }\\n}\",\n                    interactive: {\n                        controls: '<select id=\"productType\"><option value=\"A\">Product A</option><option value=\"B\">Product B</option></select><button id=\"createProduct\">Create Product</button>',\n                        init: function() {\n                            document.getElementById('createProduct').addEventListener('click', () => {\n                                const type = document.getElementById('productType').value;\n                                const factory = new ProductFactory();\n                                const product = factory.createProduct(type);\n                                document.getElementById('interactiveOutput').textContent = \n                                    `Created ${product.getName()} with price $${product.getPrice()}`;\n                            });\n                        }\n                    }\n                },\n                {\n                    name: \"Builder\",\n                    description: \"Separates the construction of a complex object from its representation.\",\n                    example: \"class CarBuilder {\\n  constructor() { this.car = new Car(); }\\n  setEngine(engine) { this.car.engine = engine; return this; }\\n  setWheels(wheels) { this.car.wheels = wheels; return this; }\\n  build() { return this.car; }\\n}\",\n                    interactive: {\n                        controls: '<div><label>Engine: <input type=\"text\" id=\"engineType\" value=\"V6\"></label></div>' +\n                                  '<div><label>Wheels: <input type=\"range\" id=\"wheelCount\" min=\"2\" max=\"6\" value=\"4\"></label><span id=\"wheelValue\">4</span></div>' +\n                                  '<button id=\"buildCar\">Build Car</button>',\n                        init: function() {\n                            document.getElementById('wheelCount').addEventListener('input', (e) => {\n                                document.getElementById('wheelValue').textContent = e.target.value;\n                            });\n                            \n                            document.getElementById('buildCar').addEventListener('click', () => {\n                                const builder = new CarBuilder();\n                                const engine = document.getElementById('engineType').value;\n                                const wheels = document.getElementById('wheelCount').value;\n                                \n                                const car = builder\n                                    .setEngine(engine)\n                                    .setWheels(wheels)\n                                    .build();\n                                \n                                document.getElementById('interactiveOutput').textContent = \n                                    `Built car with ${car.engine} engine and ${car.wheels} wheels`;\n                            });\n                        }\n                    }\n                }\n            ],\n            structural: [\n                {\n                    name: \"Adapter\",\n                    description: \"Allows incompatible interfaces to work together by wrapping an adaptee class with a compatible interface.\",\n                    example: \"class OldSystem {\\n  specificRequest() { return 'Old system response'; }\\n}\\n\\nclass Adapter {\\n  constructor(oldSystem) { this.oldSystem = oldSystem; }\\n  request() { return this.oldSystem.specificRequest(); }\\n}\",\n                    interactive: {\n                        controls: '<button id=\"useOldSystem\">Use Old System Directly</button>' +\n                                  '<button id=\"useAdapter\">Use Adapter</button>',\n                        init: function() {\n                            document.getElementById('useOldSystem').addEventListener('click', () => {\n                                const oldSystem = new OldSystem();\n                                try {\n                                    oldSystem.request(); // This will fail\n                                } catch (e) {\n                                    document.getElementById('interactiveOutput').textContent = \n                                        `Error: ${e.message}`;\n                                }\n                            });\n                            \n                            document.getElementById('useAdapter').addEventListener('click', () => {\n                                const oldSystem = new OldSystem();\n                                const adapter = new Adapter(oldSystem);\n                                document.getElementById('interactiveOutput').textContent = \n                                    `Adapter response: ${adapter.request()}`;\n                            });\n                        }\n                    }\n                },\n                {\n                    name: \"Composite\",\n                    description: \"Composes objects into tree structures to represent part-whole hierarchies.\",\n                    example: \"class Component {\\n  operation() {}\\n}\\n\\nclass Leaf extends Component {\\n  operation() { return 'Leaf'; }\\n}\\n\\nclass Composite extends Component {\\n  constructor() { super(); this.children = []; }\\n  add(c) { this.children.push(c); }\\n  operation() { return this.children.map(c => c.operation()).join(', '); }\\n}\",\n                    interactive: {\n                        controls: '<button id=\"addLeaf\">Add Leaf</button>' +\n                                  '<button id=\"addComposite\">Add Composite</button>' +\n                                  '<button id=\"executeOperation\">Execute Operation</button>' +\n                                  '<button id=\"resetComposite\">Reset</button>',\n                        init: function() {\n                            let root = new Composite();\n                            \n                            document.getElementById('addLeaf').addEventListener('click', () => {\n                                root.add(new Leaf());\n                                updateCompositeState();\n                            });\n                            \n                            document.getElementById('addComposite').addEventListener('click', () => {\n                                const newComposite = new Composite();\n                                root.add(newComposite);\n                                updateCompositeState();\n                            });\n                            \n                            document.getElementById('executeOperation').addEventListener('click', () => {\n                                document.getElementById('interactiveOutput').textContent = \n                                    `Composite operation result: ${root.operation()}`;\n                            });\n                            \n                            document.getElementById('resetComposite').addEventListener('click', () => {\n                                root = new Composite();\n                                updateCompositeState();\n                                document.getElementById('interactiveOutput').textContent = '';\n                            });\n                            \n                            function updateCompositeState() {\n                                document.getElementById('interactiveOutput').textContent = \n                                    `Current structure has ${root.children.length} components`;\n                            }\n                        }\n                    }\n                },\n                {\n                    name: \"Proxy\",\n                    description: \"Provides a surrogate or placeholder for another object to control access to it.\",\n                    example: \"class RealSubject {\\n  request() { return 'RealSubject: Handling request.'; }\\n}\\n\\nclass Proxy {\\n  constructor(realSubject) { this.realSubject = realSubject; }\\n  request() {\\n    if (this.checkAccess()) {\\n      return this.realSubject.request();\\n    }\\n    return 'Proxy: Access denied';\\n  }\\n  checkAccess() { return Math.random() > 0.5; }\\n}\",\n                    interactive: {\n                        controls: '<button id=\"directAccess\">Access Directly</button>' +\n                                  '<button id=\"proxyAccess\">Access Through Proxy</button>',\n                        init: function() {\n                            const realSubject = new RealSubject();\n                            \n                            document.getElementById('directAccess').addEventListener('click', () => {\n                                document.getElementById('interactiveOutput').textContent = \n                                    realSubject.request();\n                            });\n                            \n                            document.getElementById('proxyAccess').addEventListener('click', () => {\n                                const proxy = new Proxy(realSubject);\n                                document.getElementById('interactiveOutput').textContent = \n                                    proxy.request();\n                            });\n                        }\n                    }\n                }\n            ],\n            behavioral: [\n                {\n                    name: \"Observer\",\n                    description: \"Defines a one-to-many dependency between objects so that when one object changes state, all its dependents are notified and updated automatically.\",\n                    example: \"class Subject {\\n  constructor() { this.observers = []; }\\n  addObserver(o) { this.observers.push(o); }\\n  notify(data) { this.observers.forEach(o => o.update(data)); }\\n}\\n\\nclass Observer {\\n  update(data) { console.log('Received:', data); }\\n}\",\n                    interactive: {\n                        controls: '<button id=\"addObserver\">Add Observer</button>' +\n                                  '<input type=\"text\" id=\"notificationData\" placeholder=\"Notification data\">' +\n                                  '<button id=\"notifyObservers\">Notify Observers</button>' +\n                                  '<button id=\"clearObservers\">Clear Observers</button>',\n                        init: function() {\n                            const subject = new Subject();\n                            let observerCount = 0;\n                            \n                            document.getElementById('addObserver').addEventListener('click', () => {\n                                observerCount++;\n                                const observer = new Observer();\n                                observer.update = (data) => {\n                                    const output = document.getElementById('interactiveOutput');\n                                    output.textContent += `Observer ${observerCount} received: ${data}\\n`;\n                                };\n                                subject.addObserver(observer);\n                                document.getElementById('interactiveOutput').textContent += \n                                    `Added observer ${observerCount}\\n`;\n                            });\n                            \n                            document.getElementById('notifyObservers').addEventListener('click', () => {\n                                const data = document.getElementById('notificationData').value || 'default notification';\n                                subject.notify(data);\n                            });\n                            \n                            document.getElementById('clearObservers').addEventListener('click', () => {\n                                subject.observers = [];\n                                document.getElementById('interactiveOutput').textContent = \n                                    'All observers cleared\\n';\n                            });\n                        }\n                    }\n                },\n                {\n                    name: \"Strategy\",\n                    description: \"Defines a family of algorithms, encapsulates each one, and makes them interchangeable.\",\n                    example: \"class Context {\\n  constructor(strategy) { this.strategy = strategy; }\\n  executeStrategy() { return this.strategy.execute(); }\\n}\\n\\nclass ConcreteStrategyA {\\n  execute() { return 'Strategy A'; }\\n}\\n\\nclass ConcreteStrategyB {\\n  execute() { return 'Strategy B'; }\\n}\",\n                    interactive: {\n                        controls: '<select id=\"strategyType\">' +\n                                    '<option value=\"A\">Strategy A</option>' +\n                                    '<option value=\"B\">Strategy B</option>' +\n                                    '<option value=\"C\">Strategy C</option>' +\n                                  '</select>' +\n                                  '<button id=\"executeStrategy\">Execute Strategy</button>',\n                        init: function() {\n                            document.getElementById('executeStrategy').addEventListener('click', () => {\n                                const type = document.getElementById('strategyType').value;\n                                let strategy;\n                                \n                                switch(type) {\n                                    case 'A': strategy = new ConcreteStrategyA(); break;\n                                    case 'B': strategy = new ConcreteStrategyB(); break;\n                                    case 'C': strategy = new ConcreteStrategyC(); break;\n                                }\n                                \n                                const context = new Context(strategy);\n                                document.getElementById('interactiveOutput').textContent = \n                                    context.executeStrategy();\n                            });\n                        }\n                    }\n                },\n                {\n                    name: \"State\",\n                    description: \"Allows an object to alter its behavior when its internal state changes.\",\n                    example: \"class Context {\\n  constructor(state) { this.state = state; }\\n  request() { this.state.handle(this); }\\n}\\n\\nclass State {\\n  handle(context) {}\\n}\\n\\nclass ConcreteStateA extends State {\\n  handle(context) { context.state = new ConcreteStateB(); }\\n}\\n\\nclass ConcreteStateB extends State {\\n  handle(context) { context.state = new ConcreteStateA(); }\\n}\",\n                    interactive: {\n                        controls: '<button id=\"stateRequest\">Make Request</button>' +\n                                  '<button id=\"resetState\">Reset State</button>',\n                        init: function() {\n                            const context = new Context(new ConcreteStateA());\n                            \n                            document.getElementById('stateRequest').addEventListener('click', () => {\n                                const beforeState = context.state.constructor.name;\n                                context.request();\n                                const afterState = context.state.constructor.name;\n                                document.getElementById('interactiveOutput').textContent = \n                                    `State changed from ${beforeState} to ${afterState}`;\n                            });\n                            \n                            document.getElementById('resetState').addEventListener('click', () => {\n                                context.state = new ConcreteStateA();\n                                document.getElementById('interactiveOutput').textContent = \n                                    'State reset to ConcreteStateA';\n                            });\n                        }\n                    }\n                }\n            ]\n        };\n\n        // Implementations of pattern classes\n        class Singleton {\n            constructor() {\n                this.createdAt = new Date().toLocaleTimeString();\n            }\n            \n            static getInstance() {\n                if (!Singleton.instance) {\n                    Singleton.instance = new Singleton();\n                }\n                return Singleton.instance;\n            }\n        }\n\n        class ProductA {\n            getName() { return \"Product A\"; }\n            getPrice() { return 100; }\n        }\n\n        class ProductB {\n            getName() { return \"Product B\"; }\n            getPrice() { return 200; }\n        }\n\n        class ProductC {\n            getName() { return \"Product C\"; }\n            getPrice() { return 300; }\n        }\n\n        class ProductFactory {\n            createProduct(type) {\n                switch(type) {\n                    case 'A': return new ProductA();\n                    case 'B': return new ProductB();\n                    case 'C': return new ProductC();\n                    default: throw new Error('Unknown product type');\n                }\n            }\n        }\n\n        class Car {\n            constructor() {\n                this.engine = '';\n                this.wheels = 0;\n            }\n        }\n\n        class CarBuilder {\n            constructor() {\n                this.car = new Car();\n            }\n            \n            setEngine(engine) {\n                this.car.engine = engine;\n                return this;\n            }\n            \n            setWheels(wheels) {\n                this.car.wheels = wheels;\n                return this;\n            }\n            \n            build() {\n                return this.car;\n            }\n        }\n\n        class OldSystem {\n            specificRequest() {\n                return 'Old system response';\n            }\n        }\n\n        class Adapter {\n            constructor(oldSystem) {\n                this.oldSystem = oldSystem;\n            }\n            \n            request() {\n                return this.oldSystem.specificRequest();\n            }\n        }\n\n        class Component {\n            operation() {}\n        }\n\n        class Leaf extends Component {\n            operation() {\n                return 'Leaf';\n            }\n        }\n\n        class Composite extends Component {\n            constructor() {\n                super();\n                this.children = [];\n            }\n            \n            add(c) {\n                this.children.push(c);\n            }\n            \n            operation() {\n                return this.children.map(c => c.operation()).join(', ');\n            }\n        }\n\n        class RealSubject {\n            request() {\n                return 'RealSubject: Handling request.';\n            }\n        }\n\n        class Proxy {\n            constructor(realSubject) {\n                this.realSubject = realSubject;\n            }\n            \n            request() {\n                if (this.checkAccess()) {\n                    return this.realSubject.request();\n                }\n                return 'Proxy: Access denied';\n            }\n            \n            checkAccess() {\n                return Math.random() > 0.5;\n            }\n        }\n\n        class Subject {\n            constructor() {\n                this.observers = [];\n            }\n            \n            addObserver(o) {\n                this.observers.push(o);\n            }\n            \n            notify(data) {\n                this.observers.forEach(o => o.update(data));\n            }\n        }\n\n        class Observer {\n            update(data) {}\n        }\n\n        class ConcreteStrategyA {\n            execute() {\n                return 'Strategy A: Simple algorithm';\n            }\n        }\n\n        class ConcreteStrategyB {\n            execute() {\n                return 'Strategy B: Complex algorithm';\n            }\n        }\n\n        class ConcreteStrategyC {\n            execute() {\n                return 'Strategy C: Optimized algorithm';\n            }\n        }\n\n        class Context {\n            constructor(strategy) {\n                this.strategy = strategy;\n            }\n            \n            executeStrategy() {\n                return this.strategy.execute();\n            }\n        }\n\n        class State {\n            handle(context) {}\n        }\n\n        class ConcreteStateA extends State {\n            handle(context) {\n                context.state = new ConcreteStateB();\n                return 'Handled by State A, switching to State B';\n            }\n        }\n\n        class ConcreteStateB extends State {\n            handle(context) {\n                context.state = new ConcreteStateA();\n                return 'Handled by State B, switching to State A';\n            }\n        }\n\n        // State management\n        const stateHistory = [];\n        let currentStateIndex = -1;\n\n        function saveState() {\n            // Truncate any future states if we're not at the end\n            if (currentStateIndex < stateHistory.length - 1) {\n                stateHistory.length = currentStateIndex + 1;\n            }\n            \n            const state = {\n                patternCategory: document.getElementById('patternCategory').value,\n                selectedPattern: document.getElementById('currentPatternName')?.textContent || '',\n                activeTab: document.querySelector('.tab.active-tab')?.dataset.tab || 'description'\n            };\n            \n            stateHistory.push(state);\n            currentStateIndex = stateHistory.length - 1;\n            updateStateHistory();\n        }\n\n        function updateStateHistory() {\n            const historyElement = document.getElementById('stateHistory');\n            historyElement.innerHTML = '';\n            \n            stateHistory.forEach((state, index) => {\n                const div = document.createElement('div');\n                div.textContent = `${index + 1}. ${state.patternCategory} > ${state.selectedPattern || 'No pattern'} [${state.activeTab}]`;\n                if (index === currentStateIndex) {\n                    div.style.fontWeight = 'bold';\n                }\n                historyElement.appendChild(div);\n            });\n        }\n\n        function loadState(index) {\n            if (index < 0 || index >= stateHistory.length) return;\n            \n            const state = stateHistory[index];\n            document.getElementById('patternCategory').value = state.patternCategory;\n            \n            if (state.selectedPattern) {\n                loadPatternList(state.patternCategory);\n                \n                // Small delay to allow pattern list to load\n                setTimeout(() => {\n                    const patterns = document.querySelectorAll('.pattern-item');\n                    for (let p of patterns) {\n                        if (p.textContent === state.selectedPattern) {\n                            p.click();\n                            break;\n                        }\n                    }\n                    \n                    // Another small delay to allow pattern to load\n                    setTimeout(() => {\n                        const tab = document.querySelector(`.tab[data-tab=\"${state.activeTab}\"]`);\n                        if (tab) tab.click();\n                    }, 100);\n                }, 100);\n            }\n            \n            currentStateIndex = index;\n            updateStateHistory();\n        }\n\n        // UI Event Handlers\n        document.getElementById('loadPatterns').addEventListener('click', () => {\n            const category = document.getElementById('patternCategory').value;\n            loadPatternList(category);\n            saveState();\n        });\n\n        function loadPatternList(category) {\n            const container = document.getElementById('patternsContainer');\n            container.innerHTML = `<h3>${category.charAt(0).toUpperCase() + category.slice(1)} Patterns</h3>`;\n            \n            patterns[category].forEach(pattern => {\n                const div = document.createElement('div');\n                div.className = 'pattern-item';\n                div.textContent = pattern.name;\n                div.style.cursor = 'pointer';\n                div.style.margin = '5px 0';\n                div.style.padding = '5px';\n                div.style.border = '1px solid #ddd';\n                \n                div.addEventListener('click', () => {\n                    showPatternDetails(pattern, category);\n                    saveState();\n                });\n                \n                container.appendChild(div);\n            });\n        }\n\n        function showPatternDetails(pattern, category) {\n            document.getElementById('patternDetails').classList.remove('hidden');\n            document.getElementById('currentPatternName').textContent = pattern.name;\n            document.getElementById('patternDescription').textContent = pattern.description;\n            document.getElementById('codeExample').textContent = pattern.example;\n            \n            // Setup interactive controls\n            const interactiveControls = document.getElementById('interactiveControls');\n            interactiveControls.innerHTML = pattern.interactive.controls;\n            \n            // Clear previous output\n            document.getElementById('interactiveOutput').textContent = '';\n            \n            // Initialize interactive functionality\n            pattern.interactive.init();\n            \n            // Show description tab by default\n            document.querySelectorAll('.tab').forEach(tab => {\n                tab.classList.remove('active-tab');\n                if (tab.dataset.tab === 'description') {\n                    tab.classList.add('active-tab');\n                }\n            });\n            \n            document.querySelectorAll('.tab-content').forEach(content => {\n                content.classList.add('hidden');\n                if (content.id === 'description') {\n                    content.classList.remove('hidden');\n                }\n            });\n        }\n\n        // Tab switching\n        document.querySelectorAll('.tab').forEach(tab => {\n            tab.addEventListener('click', () => {\n                document.querySelectorAll('.tab').forEach(t => t.classList.remove('active-tab'));\n                tab.classList.add('active-tab');\n                \n                document.querySelectorAll('.tab-content').forEach(content => {\n                    content.classList.add('hidden');\n                });\n                \n                document.getElementById(tab.dataset.tab).classList.remove('hidden');\n                saveState();\n            });\n        });\n\n        // State management controls\n        document.getElementById('undoAction').addEventListener('click', () => {\n            if (currentStateIndex > 0) {\n                loadState(currentStateIndex - 1);\n            }\n        });\n\n        document.getElementById('redoAction').addEventListener('click', () => {\n            if (currentStateIndex < stateHistory.length - 1) {\n                loadState(currentStateIndex + 1);\n            }\n        });\n\n        document.getElementById('resetAll').addEventListener('click', () => {\n            document.getElementById('patternsContainer').innerHTML = '';\n            document.getElementById('patternDetails').classList.add('hidden');\n            stateHistory.length = 0;\n            currentStateIndex = -1;\n            updateStateHistory();\n        });\n\n        // Initialize with Creational patterns\n        loadPatternList('creational');\n    </script>\n</body>\n</html>"
  },
