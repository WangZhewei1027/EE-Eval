    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Array Aesthetics</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Helvetica Neue', Arial, sans-serif;\n            background: linear-gradient(135deg, #e6f7ff, #ccf2ff);\n            color: #333;\n            overflow: hidden;\n        }\n\n        h1 {\n            text-align: center;\n            font-size: 3rem;\n            margin-top: 50px;\n            color: #006699;\n            text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.2);\n        }\n\n        .container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 80vh;\n            flex-wrap: wrap;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .array-item {\n            width: 120px;\n            height: 120px;\n            margin: 15px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background: #4dd0e1;\n            border-radius: 15px;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n            font-size: 2rem;\n            transition: transform 0.3s, box-shadow 0.3s;\n        }\n\n        .array-item:hover {\n            transform: scale(1.1);\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\n        }\n\n        .footer {\n            text-align: center;\n            margin: 30px 0;\n            font-size: 1.2rem;\n            color: #4d4d4d;\n            opacity: 0.7;\n        }\n\n        button {\n            background-color: #006699;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n\n        button:hover {\n            background-color: #005f7f;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Visualizing an Array</h1>\n    <div class=\"container\" id=\"arrayContainer\">\n        <!-- Array Items will be dynamically generated here -->\n    </div>\n\n    <div class=\"footer\">\n        <button id=\"shuffleButton\">Shuffle Array</button>\n        <p>Click to rearrange the items visually.</p>\n    </div>\n\n    <script>\n        const arrayContainer = document.getElementById(\"arrayContainer\");\n        const shuffleButton = document.getElementById(\"shuffleButton\");\n        let arrayItems = [1, 2, 3, 4, 5, 6, 7, 8, 9];\n\n        function renderArray() {\n            arrayContainer.innerHTML = '';\n            arrayItems.forEach(item => {\n                const div = document.createElement(\"div\");\n                div.classList.add(\"array-item\");\n                div.textContent = item;\n                arrayContainer.appendChild(div);\n            });\n        }\n\n        function shuffleArray() {\n            for (let i = arrayItems.length - 1; i > 0; i--) {\n                const j = Math.floor(Math.random() * (i + 1));\n                [arrayItems[i], arrayItems[j]] = [arrayItems[j], arrayItems[i]];\n            }\n            renderArray();\n        }\n\n        shuffleButton.addEventListener(\"click\", shuffleArray);\n\n        // Initial render\n        renderArray();\n    </script>\n\n</body>\n</html>"
