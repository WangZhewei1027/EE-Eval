  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Load Balancing Interactive Simulator</title>\n</head>\n<body>\n<h1>Load Balancing Simulator</h1>\n\n<p>\nThis simulator lets you create servers, add tasks with customizable loads, and explore how different load balancing algorithms distribute the workload.\n</p>\n\n<section>\n<h2>Servers Setup</h2>\n<label>New Server Name: <input type=\"text\" id=\"newServerName\" /></label>\n<button id=\"addServerBtn\">Add Server</button>\n<button id=\"removeServerBtn\">Remove Selected Server</button>\n<br /><br />\n<label>Servers:</label>\n<select id=\"serversList\" size=\"5\" style=\"width: 200px;\"></select>\n<p>\n<span><b>Server Details:</b></span><br />\nID: <span id=\"serverId\">-</span><br />\nName: <span id=\"serverName\">-</span><br />\nCapacity (Max Load): <input type=\"number\" id=\"serverCapacity\" min=\"1\" value=\"10\" style=\"width: 60px;\" />\n<button id=\"updateServerCapacity\">Update Capacity</button><br />\nCurrent Load: <span id=\"serverLoad\">0</span><br />\nNumber of Tasks: <span id=\"serverTasksCount\">0</span><br />\n<button id=\"clearServerTasksBtn\">Clear Tasks on Server</button>\n</p>\n<hr />\n</section>\n\n<section>\n<h2>Tasks Setup</h2>\n<label>Task Name: <input type=\"text\" id=\"newTaskName\" /></label>\n<label>Load (Integer >0): <input type=\"number\" id=\"newTaskLoad\" min=\"1\" value=\"1\" style=\"width: 60px;\" /></label>\n<button id=\"addTaskBtn\">Add Task</button>\n<button id=\"removeTaskBtn\">Remove Selected Task</button>\n<br /><br />\n<label>Tasks:</label>\n<select id=\"tasksList\" size=\"5\" style=\"width: 200px;\"></select>\n<p>\n<span><b>Task Details:</b></span><br />\nID: <span id=\"taskId\">-</span><br />\nName: <span id=\"taskName\">-</span><br />\nLoad: <span id=\"taskLoad\">-</span><br />\nAssigned Server: <span id=\"taskAssignedServer\">-</span><br />\n<button id=\"assignTaskToServerBtn\">Assign to Selected Server</button>\n<button id=\"unassignTaskBtn\">Unassign Task</button>\n</p>\n<hr />\n</section>\n\n<section>\n<h2>Load Balancing Algorithms</h2>\n<label><input type=\"radio\" name=\"algorithm\" value=\"roundrobin\" checked /> Round Robin</label><br />\n<label><input type=\"radio\" name=\"algorithm\" value=\"leastconn\" /> Least Connections (Least Load)</label><br />\n<label><input type=\"radio\" name=\"algorithm\" value=\"random\" /> Random</label><br />\n<label><input type=\"radio\" name=\"algorithm\" value=\"custom\" /> Custom Weights</label><br />\n<div id=\"customWeightsContainer\" style=\"display:none; max-height:100px; overflow:auto; border:1px solid black; margin-top:4px; padding:4px;\">\n<p>Enter server weights (positive integers). Leave blank for default weight 1.</p>\n<div id=\"weightsInputs\"></div>\n<button id=\"updateWeightsBtn\">Update Weights</button>\n</div>\n<button id=\"autoBalanceBtn\">Auto Balance Tasks Using Selected Algorithm</button>\n</section>\n\n<hr />\n\n<section>\n<h2>Current State Overview</h2>\n<button id=\"showSummaryBtn\">Show Summary Report</button>\n<pre id=\"summaryReport\" style=\"white-space: pre-wrap; border:1px solid black; padding:5px; max-height:300px; overflow:auto;\"></pre>\n</section>\n\n<hr />\n\n<section>\n<h2>Manual Load Balancing Controls</h2>\n<label>Select Task: <select id=\"manualTaskSelector\" style=\"width: 220px;\"></select></label>\n<label>Select Server: <select id=\"manualServerSelector\" style=\"width: 220px;\"></select></label>\n<button id=\"manualAssignBtn\">Assign Task to Server</button>\n<button id=\"manualUnassignBtn\">Unassign Task</button>\n<p>\n<span><b>Manual Assignment Feedback:</b></span><br />\n<span id=\"manualAssignFeedback\">-</span>\n</p>\n</section>\n\n<hr />\n\n<section>\n<h2>Simulation Controls</h2>\n<label>Simulate Incoming Tasks (count): <input type=\"number\" id=\"simTaskCount\" min=\"1\" value=\"5\" style=\"width: 60px;\" /></label>\n<label>Min Load: <input type=\"number\" id=\"simTaskMinLoad\" min=\"1\" value=\"1\" style=\"width: 60px;\" /></label>\n<label>Max Load: <input type=\"number\" id=\"simTaskMaxLoad\" min=\"1\" value=\"5\" style=\"width: 60px;\" /></label>\n<button id=\"simulateTasksBtn\">Simulate & Auto Balance</button>\n</section>\n\n<hr />\n\n<section>\n<h2>Reset Controls</h2>\n<button id=\"resetAllBtn\">Reset All (Servers & Tasks)</button>\n<button id=\"clearTaskAssignmentsBtn\">Clear All Task Assignments</button>\n</section>\n\n<script>\n(() => {\n  // Data structures\n  let servers = [];\n  let tasks = [];\n  \n  // To assign unique IDs\n  let serverIdCounter = 1;\n  let taskIdCounter = 1;\n\n  // For Round Robin\n  let roundRobinIndex = 0;\n\n  // Current algorithm\n  let currentAlgorithm = 'roundrobin';\n  \n  // Custom weights map: serverId -> weight\n  let customWeights = {};\n\n  // Utility\n  function $(id) { return document.getElementById(id); }\n\n  // Server functions\n  function addServer(name, capacity) {\n    if(!name.trim()) {\n      alert('Server name cannot be empty.');\n      return false;\n    }\n    if(servers.some(s=>s.name===name)) {\n      alert('Server name must be unique.');\n      return false;\n    }\n    const server = {\n      id: serverIdCounter++,\n      name: name.trim(),\n      capacity: capacity || 10,\n      tasks: []\n    };\n    servers.push(server);\n    updateServersList();\n    updateWeightsInputs();\n    return true;\n  }\n\n  function removeServer(serverId) {\n    const idx = servers.findIndex(s=>s.id===serverId);\n    if(idx === -1) return false;\n    const server = servers[idx];\n    if(server.tasks.length > 0){\n      if(!confirm(\"Server has assigned tasks. Removing will unassign all these tasks. Proceed?\")){\n        return false;\n      }\n      // unassign tasks assigned to this server\n      server.tasks.forEach(tid => {\n        let t = tasks.find(tsk => tsk.id === tid);\n        if(t) t.assignedServer = null;\n      });\n    }\n    servers.splice(idx,1);\n    updateServersList();\n    updateWeightsInputs();\n    return true;\n  }\n\n  function updateServersList() {\n    const sel = $('serversList');\n    const manualServerSel = $('manualServerSelector');\n    const weightsDiv = $('weightsInputs');\n    sel.innerHTML = '';\n    manualServerSel.innerHTML = '';\n    servers.forEach(s => {\n      let opt = document.createElement('option');\n      opt.value = s.id;\n      opt.textContent = s.name + ' (Cap:' + s.capacity + ')';\n      sel.appendChild(opt);\n      // Manual selector\n      let opt2 = document.createElement('option');\n      opt2.value = s.id;\n      opt2.textContent = s.name;\n      manualServerSel.appendChild(opt2);\n    });\n    // If something selected previously, keep selection or select first\n    if(servers.length > 0) {\n      if(!sel.value || !servers.find(s=>s.id==sel.value)) sel.value = servers[0].id;\n      if(!manualServerSel.value || !servers.find(s=>s.id==manualServerSel.value)) manualServerSel.value = servers[0].id;\n    }\n    updateServerDetails();\n    updateWeightsInputs();\n  }\n\n  function updateServerDetails() {\n    const sel = $('serversList');\n    const idSpan = $('serverId');\n    const nameSpan = $('serverName');\n    const capacityInput = $('serverCapacity');\n    const loadSpan = $('serverLoad');\n    const tasksCountSpan = $('serverTasksCount');\n\n    if(!sel.value) {\n      idSpan.textContent = '-';\n      nameSpan.textContent = '-';\n      capacityInput.value = 10;\n      loadSpan.textContent = '0';\n      tasksCountSpan.textContent = '0';\n      return;\n    }\n    const server = servers.find(s=> s.id == sel.value);\n    if(!server) return;\n    idSpan.textContent = server.id;\n    nameSpan.textContent = server.name;\n    capacityInput.value = server.capacity;\n    let load = server.tasks.reduce((acc, tid) => {\n      const tsk = tasks.find(t => t.id === tid);\n      return acc + (tsk ? tsk.load : 0);\n    },0);\n    loadSpan.textContent = load;\n    tasksCountSpan.textContent = server.tasks.length;\n  }\n\n  function updateServerCapacity(serverId, capacity) {\n    const server = servers.find(s=>s.id==serverId);\n    if(!server) return false;\n    if(capacity<1) return false;\n    server.capacity = capacity;\n    updateServersList();\n    return true;\n  }\n\n  function clearTasksOnServer(serverId) {\n    const server = servers.find(s=>s.id==serverId);\n    if(!server) return false;\n    server.tasks.forEach(tid => {\n      const t = tasks.find(task => task.id === tid);\n      if(t) t.assignedServer = null;\n    });\n    server.tasks = [];\n    updateServersList();\n    updateTasksList();\n    return true;\n  }\n\n  // Task functions\n  function addTask(name, load) {\n    if(!name.trim()) {\n      alert('Task name cannot be empty.');\n      return false;\n    }\n    if(tasks.some(t=>t.name===name)) {\n      alert('Task name must be unique.');\n      return false;\n    }\n    if(!Number.isInteger(load) || load < 1) {\n      alert('Task load must be an integer >= 1.');\n      return false;\n    }\n    const task = {\n      id: taskIdCounter++,\n      name: name.trim(),\n      load: load,\n      assignedServer: null\n    };\n    tasks.push(task);\n    updateTasksList();\n    return true;\n  }\n\n  function removeTask(taskId) {\n    const idx = tasks.findIndex(t=>t.id === taskId);\n    if(idx === -1) return false;\n    const task = tasks[idx];\n    if(task.assignedServer !== null) {\n      const server = servers.find(s=>s.id===task.assignedServer);\n      if(server){\n        server.tasks = server.tasks.filter(tid => tid !== task.id);\n      }\n    }\n    tasks.splice(idx,1);\n    updateTasksList();\n    return true;\n  }\n\n  function updateTasksList() {\n    const sel = $('tasksList');\n    const manualTaskSel = $('manualTaskSelector');\n    sel.innerHTML = '';\n    manualTaskSel.innerHTML = '';\n    tasks.forEach(t => {\n      let opt = document.createElement('option');\n      opt.value = t.id;\n      let assignedName = t.assignedServer ? servers.find(s=>s.id===t.assignedServer)?.name || '?' : 'Unassigned';\n      opt.textContent = `${t.name} (Load:${t.load}) [${assignedName}]`;\n      sel.appendChild(opt);\n      // manual selector\n      let opt2 = document.createElement('option');\n      opt2.value = t.id;\n      opt2.textContent = t.name + ' (Load:' + t.load + ')';\n      manualTaskSel.appendChild(opt2);\n    });\n    // Maintain selection when possible:\n    if(tasks.length > 0){\n      if(!sel.value || !tasks.find(t=>t.id==sel.value)) sel.value = tasks[0].id;\n      if(!manualTaskSel.value || !tasks.find(t=>t.id==manualTaskSel.value)) manualTaskSel.value = tasks[0].id;\n    }\n    updateTaskDetails();\n  }\n\n  function updateTaskDetails() {\n    const sel = $('tasksList');\n    const idSpan = $('taskId');\n    const nameSpan = $('taskName');\n    const loadSpan = $('taskLoad');\n    const assignedSpan = $('taskAssignedServer');\n    if(!sel.value) {\n      idSpan.textContent = '-';\n      nameSpan.textContent = '-';\n      loadSpan.textContent = '-';\n      assignedSpan.textContent = '-';\n      return;\n    }\n    const task = tasks.find(t=>t.id == sel.value);\n    if(!task) return;\n    idSpan.textContent = task.id;\n    nameSpan.textContent = task.name;\n    loadSpan.textContent = task.load;\n    assignedSpan.textContent = task.assignedServer ? (servers.find(s=>s.id===task.assignedServer)?.name || '?') : 'Unassigned';\n  }\n\n  function assignTaskToServer(taskId, serverId) {\n    const task = tasks.find(t=>t.id==taskId);\n    const server = servers.find(s=>s.id==serverId);\n    if(!task || !server) return false;\n    // Check capacity\n    const currentLoad = server.tasks.reduce((acc, tid) => {\n      const tsk = tasks.find(t => t.id === tid);\n      return acc + (tsk ? tsk.load : 0);\n    },0);\n    if(currentLoad + task.load > server.capacity) {\n      return { success:false, message:\"Server capacity exceeded! Task cannot be assigned.\"};\n    }\n    // Remove task from previous server's tasks if assigned\n    if(task.assignedServer !== null) {\n      const oldServer = servers.find(s=>s.id===task.assignedServer);\n      if(oldServer) {\n        oldServer.tasks = oldServer.tasks.filter(tid => tid !== task.id);\n      }\n    }\n    // Assign\n    task.assignedServer = server.id;\n    server.tasks.push(task.id);\n    updateTasksList();\n    updateServersList();\n    return {success:true};\n  }\n\n  function unassignTask(taskId) {\n    const task = tasks.find(t=>t.id==taskId);\n    if(!task || task.assignedServer === null) return false;\n    const server = servers.find(s=>s.id===task.assignedServer);\n    if(server) {\n      server.tasks = server.tasks.filter(tid => tid !== task.id);\n    }\n    task.assignedServer = null;\n    updateTasksList();\n    updateServersList();\n    return true;\n  }\n\n  // Load Balancing Algorithms\n\n  // Round Robin: assign tasks one by one cycling through servers in order\n  function lbRoundRobin(tasksToAssign) {\n    if(servers.length === 0) {\n      alert(\"No servers available.\");\n      return;\n    }\n    let idx = roundRobinIndex % servers.length;\n    tasksToAssign.forEach(task => {\n      // Try assign with wrap around if capacity exceeded\n      let assigned = false;\n      for(let i = 0; i < servers.length; i++){\n        const server = servers[(idx + i) % servers.length];\n        const currentLoad = server.tasks.reduce((acc, tid) => {\n          const tsk = tasks.find(t => t.id === tid);\n          return acc + (tsk ? tsk.load : 0);\n        },0);\n        if(currentLoad + task.load <= server.capacity){\n          assignTaskToServer(task.id, server.id);\n          assigned = true;\n          idx = ((idx + i) + 1) % servers.length;\n          break;\n        }\n      }\n      if(!assigned){\n        // cannot assign task because no servers have capacity\n        // remain unassigned\n      }\n    });\n    roundRobinIndex = idx;\n  }\n\n  // Least Connections (Least Load): assign task to server with least total load (that can take it)\n  function lbLeastConnections(tasksToAssign) {\n    if(servers.length === 0) {\n      alert(\"No servers available.\");\n      return;\n    }\n    tasksToAssign.forEach(task=>{\n      // candidates: servers with capacity\n      let candidates = servers.filter(server => {\n        let load = server.tasks.reduce((acc, tid) => {\n          const tsk = tasks.find(t => t.id === tid);\n          return acc + (tsk ? tsk.load : 0);\n        },0);\n        return load + task.load <= server.capacity;\n      });\n      if(candidates.length === 0) {\n        // cannot assign task\n        return;\n      }\n      // Find least load server\n      candidates.sort((a,b) => {\n        let loadA = a.tasks.reduce((acc, tid) => {\n          const tsk = tasks.find(t => t.id === tid);\n          return acc + (tsk ? tsk.load : 0);\n        },0);\n        let loadB = b.tasks.reduce((acc, tid) => {\n          const tsk = tasks.find(t => t.id === tid);\n          return acc + (tsk ? tsk.load : 0);\n        },0);\n        return loadA - loadB;\n      });\n      assignTaskToServer(task.id, candidates[0].id);\n    });\n  }\n\n  // Random: assign task to random server that has capacity\n  function lbRandom(tasksToAssign) {\n    if(servers.length === 0) {\n      alert(\"No servers available.\");\n      return;\n    }\n    tasksToAssign.forEach(task => {\n      const candidates = servers.filter(server => {\n        let load = server.tasks.reduce((acc, tid) => {\n          const tsk = tasks.find(t => t.id === tid);\n          return acc + (tsk ? tsk.load : 0);\n        },0);\n        return load + task.load <= server.capacity;\n      });\n      if(candidates.length === 0) {\n        return;\n      }\n      const chosen = candidates[Math.floor(Math.random() * candidates.length)];\n      assignTaskToServer(task.id, chosen.id);\n    });\n  }\n\n  // Custom Weights: assign task to server randomly weighted by user-defined weights (if any), considering capacity\n  // If no weights, default 1 each\n  function lbCustomWeights(tasksToAssign) {\n    if(servers.length === 0) {\n      alert(\"No servers available.\");\n      return;\n    }\n    // Build weighted list of servers repeated by their weight\n    tasksToAssign.forEach(task => {\n      // filter servers that can accept task\n      let candidates = servers.filter(server => {\n        let load = server.tasks.reduce((acc, tid) => {\n          const tsk = tasks.find(t => t.id === tid);\n          return acc + (tsk ? tsk.load : 0);\n        },0);\n        return load + task.load <= server.capacity;\n      });\n      if(candidates.length === 0) return;\n      let weightedServers = [];\n      candidates.forEach(s => {\n        let w = customWeights[s.id];\n        w = (w && w > 0) ? w : 1;\n        for(let i=0;i<w;i++){\n          weightedServers.push(s);\n        }\n      });\n      if(weightedServers.length === 0) return;\n      let chosen = weightedServers[Math.floor(Math.random() * weightedServers.length)];\n      assignTaskToServer(task.id, chosen.id);\n    });\n  }\n\n  function autoBalance() {\n    if(tasks.length === 0) {\n      alert(\"No tasks to assign.\");\n      return;\n    }\n    if(servers.length === 0) {\n      alert(\"No servers available.\");\n      return;\n    }\n    // First unassign all tasks\n    clearAllTaskAssignments(false);\n\n    // Get all tasks\n    let tasksToAssign = tasks.slice();\n\n    switch(currentAlgorithm) {\n      case 'roundrobin':\n        lbRoundRobin(tasksToAssign);\n        break;\n      case 'leastconn':\n        lbLeastConnections(tasksToAssign);\n        break;\n      case 'random':\n        lbRandom(tasksToAssign);\n        break;\n      case 'custom':\n        lbCustomWeights(tasksToAssign);\n        break;\n      default:\n        alert(\"Unknown algorithm.\");\n    }\n    updateTasksList();\n    updateServersList();\n  }\n\n  function clearAllTaskAssignments(updateUI=true) {\n    tasks.forEach(task => task.assignedServer = null);\n    servers.forEach(server => server.tasks = []);\n    if(updateUI) {\n      updateServersList();\n      updateTasksList();\n    }\n  }\n\n  // Handling inputs for custom weights\n  function updateWeightsInputs() {\n    const container = $('weightsInputs');\n    container.innerHTML = '';\n    if(currentAlgorithm !== 'custom') {\n      container.style.display = 'none';\n      return;\n    }\n    container.style.display = 'block';\n    servers.forEach(s => {\n      let id = 'weight_' + s.id;\n      let label = document.createElement('label');\n      label.htmlFor = id;\n      label.textContent = s.name + ': ';\n      let input = document.createElement('input');\n      input.type = 'number';\n      input.min = '1';\n      input.value = customWeights[s.id] || 1;\n      input.id = id;\n      input.style.width = '60px';\n      label.appendChild(input);\n      container.appendChild(label);\n      container.appendChild(document.createElement('br'));\n    });\n  }\n\n  function handleAlgorithmChange() {\n    const radios = document.querySelectorAll('input[name=\"algorithm\"]');\n    radios.forEach(r => {\n      if(r.checked) currentAlgorithm = r.value;\n    });\n    updateWeightsInputs();\n  }\n\n  // Summary report\n  function showSummaryReport() {\n    const area = $('summaryReport');\n    let report = '';\n    report += 'Servers Summary:\\n';\n    servers.forEach(server => {\n      let load = server.tasks.reduce((acc, tid) => {\n        const tsk = tasks.find(t => t.id === tid);\n        return acc + (tsk ? tsk.load : 0);\n      },0);\n      report += `ID: ${server.id} | Name: ${server.name} | Capacity: ${server.capacity} | Current Load: ${load} | Tasks: ${server.tasks.length}\\n`;\n    });\n    report += '\\nTasks Summary:\\n';\n    tasks.forEach(task => {\n      let srvName = task.assignedServer ? (servers.find(s=>s.id === task.assignedServer)?.name || '?') : 'Unassigned';\n      report += `ID: ${task.id} | Name: ${task.name} | Load: ${task.load} | Assigned Server: ${srvName}\\n`;\n    });\n    area.textContent = report;\n  }\n\n  // Simulation: create random tasks and auto balance\n  function simulateIncomingTasks(count, minLoad, maxLoad) {\n    if(servers.length === 0){\n      alert(\"No servers available.\");\n      return;\n    }\n    if(count < 1) {\n      alert(\"Task count must be >= 1.\");\n      return;\n    }\n    if(minLoad > maxLoad) {\n      alert(\"Min Load cannot be greater than Max Load.\");\n      return;\n    }\n    for(let i=0; i<count; i++){\n      let load = Math.floor(Math.random()*(maxLoad - minLoad +1)) + minLoad;\n      let name;\n      // Make sure name is unique\n      do {\n        name = 'SimTask' + (taskIdCounter);\n      } while(tasks.some(t=>t.name === name));\n      addTask(name, load);\n    }\n    autoBalance();\n  }\n\n  // Event handlers\n\n  // Servers add/remove/update\n  $('addServerBtn').addEventListener('click', () => {\n    const name = $('newServerName').value;\n    const capacity = parseInt($('serverCapacity').value) || 10;\n    if(addServer(name, capacity)) {\n      $('newServerName').value = '';\n      // reset capacity input for new server to default 10\n      $('serverCapacity').value = 10;\n    }\n  });\n\n  $('removeServerBtn').addEventListener('click', () => {\n    const sel = $('serversList');\n    if(!sel.value) {\n      alert('Select a server to remove.');\n      return;\n    }\n    if(removeServer(parseInt(sel.value))) {\n      updateServerDetails();\n    }\n  });\n\n  $('serversList').addEventListener('change', updateServerDetails);\n\n  $('updateServerCapacity').addEventListener('click', () => {\n    const sel = $('serversList');\n    if(!sel.value) {\n      alert('Select a server first.');\n      return;\n    }\n    const val = parseInt($('serverCapacity').value);\n    if(isNaN(val) || val < 1) {\n      alert('Capacity must be an integer >= 1.');\n      return;\n    }\n    updateServerCapacity(parseInt(sel.value), val);\n  });\n\n  $('clearServerTasksBtn').addEventListener('click', () => {\n    const sel = $('serversList');\n    if(!sel.value) {\n      alert('Select a server first.');\n      return;\n    }\n    clearTasksOnServer(parseInt(sel.value));\n  });\n\n  // Tasks add/remove/update\n  $('addTaskBtn').addEventListener('click', () => {\n    const name = $('newTaskName').value;\n    const load = parseInt($('newTaskLoad').value);\n    if(addTask(name, load)) {\n      $('newTaskName').value = '';\n      $('newTaskLoad').value = 1;\n    }\n  });\n\n  $('removeTaskBtn').addEventListener('click', () => {\n    const sel = $('tasksList');\n    if(!sel.value) {\n      alert('Select a task to remove.');\n      return;\n    }\n    removeTask(parseInt(sel.value));\n  });\n\n  $('tasksList').addEventListener('change', updateTaskDetails);\n\n  // Assign task to selected server (from task details)\n  $('assignTaskToServerBtn').addEventListener('click', () => {\n    const taskSel = $('tasksList');\n    const serverSel = $('serversList');\n    if(!taskSel.value) {\n      alert('Select a task first.');\n      return;\n    }\n    if(!serverSel.value) {\n      alert('Select a server first.');\n      return;\n    }\n    const result = assignTaskToServer(parseInt(taskSel.value), parseInt(serverSel.value));\n    if(result.success === false) {\n      alert(result.message);\n    }\n  });\n\n  $('unassignTaskBtn').addEventListener('click', () => {\n    const taskSel = $('tasksList');\n    if(!taskSel.value) {\n      alert('Select a task first.');\n      return;\n    }\n    unassignTask(parseInt(taskSel.value));\n  });\n\n  // Algorithm selection\n  const algRadios = document.querySelectorAll('input[name=\"algorithm\"]');\n  algRadios.forEach(r => {\n    r.addEventListener('change', handleAlgorithmChange);\n  });\n\n  // Update weights button\n  $('updateWeightsBtn').addEventListener('click', () => {\n    // gather weights\n    let newWeights = {};\n    let valid = true;\n    servers.forEach(server => {\n      let val = parseInt($('weight_' + server.id).value);\n      if(isNaN(val) || val < 1) {\n        alert(`Invalid weight for server '${server.name}'. Must be >=1.`);\n        valid = false;\n      } else {\n        newWeights[server.id] = val;\n      }\n    });\n    if(valid) {\n      customWeights = newWeights;\n      alert(\"Custom weights updated.\");\n    }\n  });\n\n  // Auto Balance button\n  $('autoBalanceBtn').addEventListener('click', () => {\n    autoBalance();\n  });\n\n  // Show summary\n  $('showSummaryBtn').addEventListener('click', () => {\n    showSummaryReport();\n  });\n\n  // Manual load balancing controls\n  $('manualAssignBtn').addEventListener('click', () => {\n    const taskSel = $('manualTaskSelector');\n    const serverSel = $('manualServerSelector');\n    const feedback = $('manualAssignFeedback');\n\n    if(!taskSel.value || !serverSel.value) {\n      feedback.textContent = 'Select both task and server.';\n      return;\n    }\n    const result = assignTaskToServer(parseInt(taskSel.value), parseInt(serverSel.value));\n    if(result.success) {\n      feedback.textContent = `Task assigned to server successfully.`;\n    } else {\n      feedback.textContent = result.message || 'Failed to assign the task.';\n    }\n  });\n\n  $('manualUnassignBtn').addEventListener('click', () => {\n    const taskSel = $('manualTaskSelector');\n    const feedback = $('manualAssignFeedback');\n    if(!taskSel.value) {\n      feedback.textContent = 'Select a task.';\n      return;\n    }\n    if(unassignTask(parseInt(taskSel.value))) {\n      feedback.textContent = 'Task unassigned successfully.';\n    } else {\n      feedback.textContent = 'Task was not assigned to any server.';\n    }\n  });\n\n  // Simulation\n  $('simulateTasksBtn').addEventListener('click', () => {\n    const count = parseInt($('simTaskCount').value);\n    const minLoad = parseInt($('simTaskMinLoad').value);\n    const maxLoad = parseInt($('simTaskMaxLoad').value);\n    simulateIncomingTasks(count, minLoad, maxLoad);\n  });\n\n  // Reset buttons\n  $('resetAllBtn').addEventListener('click', () => {\n    if(!confirm(\"This will delete all servers and tasks. Proceed?\")) return;\n    servers = [];\n    tasks = [];\n    serverIdCounter = 1;\n    taskIdCounter = 1;\n    roundRobinIndex = 0;\n    customWeights = {};\n    updateServersList();\n    updateTasksList();\n    $('summaryReport').textContent = '';\n    $('manualAssignFeedback').textContent = '-';\n  });\n\n  $('clearTaskAssignmentsBtn').addEventListener('click', () => {\n    clearAllTaskAssignments();\n    $('manualAssignFeedback').textContent = '-';\n  });\n\n  // Update details when servers/tasks list change\n  $('serversList').addEventListener('change', () => {\n    updateServerDetails();\n    updateWeightsInputs();\n  });\n  $('tasksList').addEventListener('change', updateTaskDetails);\n\n  // Initialize\n  updateServersList();\n  updateTasksList();\n  handleAlgorithmChange();\n\n  // Add some defaults for initial exploration\n  addServer('ServerA', 10);\n  addServer('ServerB', 15);\n  addServer('ServerC', 20);\n\n  addTask('Task1', 4);\n  addTask('Task2', 3);\n  addTask('Task3', 7);\n  addTask('Task4', 6);\n  addTask('Task5', 2);\n})();\n</script>\n</body>\n</html>"
