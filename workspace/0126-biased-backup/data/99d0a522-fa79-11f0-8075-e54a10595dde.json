    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Software Development Life Cycle</title>\n    <style>\n        /* Minimal CSS */\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .section {\n            margin-bottom: 20px;\n        }\n        .button, .input-field, .slider {\n            margin-top: 10px;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Software Development Life Cycle (SDLC)</h1>\n\n    <div class=\"section\" id=\"planning-section\">\n        <h2>1. Planning</h2>\n        <textarea id=\"plan-input\" class=\"input-field\" rows=\"4\" placeholder=\"Enter project goals...\"></textarea>\n        <button class=\"button\" onclick=\"savePlanning()\">Save Planning</button>\n        <div id=\"planning-output\"></div>\n    </div>\n\n    <div class=\"section\" id=\"analysis-section\">\n        <h2>2. Analysis</h2>\n        <button class=\"button\" onclick=\"startAnalysis()\">Start Analysis</button>\n        <div id=\"analysis-output\"></div>\n    </div>\n\n    <div class=\"section\" id=\"design-section\">\n        <h2>3. Design</h2>\n        <input type=\"text\" id=\"design-input\" class=\"input-field\" placeholder=\"Enter design specifications...\" />\n        <button class=\"button\" onclick=\"saveDesign()\">Save Design</button>\n        <div id=\"design-output\"></div>\n    </div>\n\n    <div class=\"section\" id=\"development-section\">\n        <h2>4. Development</h2>\n        <label>Development Progress:</label>\n        <input type=\"range\" id=\"development-slider\" class=\"slider\" min=\"0\" max=\"100\" onchange=\"updateProgress()\"/>\n        <div id=\"development-output\"></div>\n    </div>\n\n    <div class=\"section\" id=\"testing-section\">\n        <h2>5. Testing</h2>\n        <button class=\"button\" onclick=\"startTesting()\">Start Testing</button>\n        <div id=\"testing-output\"></div>\n    </div>\n\n    <div class=\"section\" id=\"deployment-section\">\n        <h2>6. Deployment</h2>\n        <button class=\"button\" onclick=\"deployProject()\">Deploy Project</button>\n        <div id=\"deployment-output\"></div>\n    </div>\n\n    <script>\n        // JavaScript functionality\n\n        let planningOutput = \"\";\n        let analysisDone = false;\n        let designOutput = \"\";\n        let developmentProgress = 0;\n\n        function savePlanning() {\n            const planningInput = document.getElementById('plan-input').value;\n            planningOutput = planningInput;\n            document.getElementById('planning-output').innerText = \"Planning saved: \" + planningOutput;\n        }\n\n        function startAnalysis() {\n            if (planningOutput) {\n                analysisDone = true;\n                document.getElementById('analysis-output').innerText = \"Analysis started based on: \" + planningOutput;\n            } else {\n                alert(\"Please save planning first.\");\n            }\n        }\n\n        function saveDesign() {\n            const designInput = document.getElementById('design-input').value;\n            designOutput = designInput;\n            document.getElementById('design-output').innerText = \"Design saved: \" + designOutput;\n        }\n\n        function updateProgress() {\n            developmentProgress = document.getElementById('development-slider').value;\n            document.getElementById('development-output').innerText = \"Development progress: \" + developmentProgress + \"%\";\n        }\n\n        function startTesting() {\n            if (developmentProgress == 100) {\n                document.getElementById('testing-output').innerText = \"Testing started on completed development.\";\n            } else {\n                alert(\"Development must be 100% complete before testing.\");\n            }\n        }\n\n        function deployProject() {\n            if (analysisDone && designOutput && developmentProgress == 100) {\n                document.getElementById('deployment-output').innerText = \"Project deployed successfully!\";\n            } else {\n                alert(\"Ensure all prior phases are completed correctly.\");\n            }\n        }\n    </script>\n\n</body>\n</html>"
