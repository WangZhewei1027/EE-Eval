  "question": "Process",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Process Simulator — Interactive</title>\n<style>\n/* Extremely minimal layout */\nhtml,body{height:100%;margin:8px;font-family:system-ui,Segoe UI,Arial;}\n.container{display:flex;gap:8px;align-items:flex-start;}\n.panel{flex:1;min-width:260px;max-width:50%;padding:6px;border:1px solid #000;}\n.panel h3{margin:6px 0 8px 0;font-size:14px;}\n.small{font-size:12px}\n.row{display:flex;gap:6px;align-items:center;margin-bottom:6px}\n.col{display:flex;flex-direction:column;gap:6px}\ntextarea,input,select,button{font:12px/1.2 monospace;padding:4px}\ntextarea{width:100%;height:80px}\n.list{max-height:200px;overflow:auto;border:1px solid #000;padding:4px}\npre{white-space:pre-wrap;font-family:monospace;font-size:12px}\nbutton{cursor:pointer}\nfieldset{padding:6px}\n</style>\n</head>\n<body>\n<h2>Process Simulator — \"Process\"</h2>\n<div class=\"container\">\n  <div class=\"panel\" id=\"designer\">\n    <h3>Process Designer</h3>\n    <div class=\"row\">\n      <input id=\"procName\" placeholder=\"Process name\" value=\"Example Process\">\n      <button id=\"newProc\">New</button>\n      <button id=\"loadSample\">Load Sample</button>\n      <button id=\"exportProc\">Export JSON</button>\n      <button id=\"importProc\">Import JSON</button>\n    </div>\n\n    <fieldset>\n      <legend>Add / Manage Steps</legend>\n      <div class=\"row\">\n        <input id=\"stepName\" placeholder=\"Step name\">\n        <select id=\"stepType\">\n          <option value=\"task\">task</option>\n          <option value=\"decision\">decision</option>\n          <option value=\"manual\">manual (approval)</option>\n          <option value=\"timer\">timer</option>\n          <option value=\"parallel-start\">parallel-start</option>\n          <option value=\"parallel-end\">parallel-end</option>\n        </select>\n        <button id=\"addStep\">Add Step</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Steps:</label>\n        <select id=\"stepsList\" size=\"6\" style=\"flex:1\"></select>\n      </div>\n\n      <div id=\"stepEditor\" style=\"display:none\">\n        <div class=\"row\">\n          <label>ID:</label><input id=\"editId\" readonly>\n          <label>Name:</label><input id=\"editName\">\n        </div>\n        <div class=\"row\">\n          <label>Type:</label>\n          <select id=\"editType\">\n            <option value=\"task\">task</option>\n            <option value=\"decision\">decision</option>\n            <option value=\"manual\">manual</option>\n            <option value=\"timer\">timer</option>\n            <option value=\"parallel-start\">parallel-start</option>\n            <option value=\"parallel-end\">parallel-end</option>\n          </select>\n          <label>Duration(ms):</label><input id=\"editDuration\" type=\"number\" min=\"0\" value=\"500\" style=\"width:85px\">\n        </div>\n        <div class=\"row\">\n          <label>Success prob (0-1):</label><input id=\"editProb\" type=\"number\" min=\"0\" max=\"1\" step=\"0.01\" value=\"1\" style=\"width:80px\">\n          <label>Condition (for decision):</label><input id=\"editCondition\" placeholder=\"e.g., vars.x>10 || true\" style=\"flex:1\">\n        </div>\n        <div class=\"row\">\n          <label>Action script (JS):</label>\n          <button id=\"insertScriptExample\">Insert example</button>\n        </div>\n        <textarea id=\"editScript\" placeholder=\"// function run(vars,meta){ return {vars:{x:vars.x+1}} }\"></textarea>\n        <div class=\"row\">\n          <label>Parallel group ID:</label><input id=\"editParallelGroup\" placeholder=\"group1\" style=\"width:100px\">\n          <label><input type=\"checkbox\" id=\"editBreakpoint\"> Breakpoint</label>\n          <button id=\"saveStep\">Save</button>\n          <button id=\"deleteStep\">Delete</button>\n          <button id=\"duplicateStep\">Duplicate</button>\n        </div>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Transitions</legend>\n      <div class=\"row\">\n        <select id=\"transFrom\"></select>\n        <select id=\"transTo\"></select>\n        <input id=\"transCond\" placeholder=\"Condition (optional)\">\n        <button id=\"addTrans\">Add</button>\n      </div>\n      <div class=\"list\" id=\"transList\"></div>\n    </fieldset>\n  </div>\n\n  <div class=\"panel\" id=\"runner\">\n    <h3>Runner & Control</h3>\n    <div class=\"row\">\n      <button id=\"startRun\">Start Run</button>\n      <button id=\"startMultiple\">Start N</button>\n      <input id=\"startCount\" type=\"number\" value=\"1\" min=\"1\" style=\"width:60px\">\n      <label>Mode:</label>\n      <select id=\"runMode\"><option>auto</option><option>step</option></select>\n      <label>Speed:</label><input id=\"speed\" type=\"range\" min=\"10\" max=\"2000\" value=\"500\">\n      <span id=\"speedVal\">500ms</span>\n    </div>\n\n    <div class=\"row\">\n      <label><input type=\"checkbox\" id=\"useGlobalVars\"> Use global variables</label>\n      <label><input type=\"checkbox\" id=\"logVerbose\" checked> Verbose logs</label>\n      <button id=\"pauseAll\">Pause</button>\n      <button id=\"resumeAll\">Resume</button>\n      <button id=\"abortAll\">Abort</button>\n    </div>\n\n    <fieldset>\n      <legend>Active Runs</legend>\n      <div id=\"runsList\" class=\"list\"></div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Selected Run Controls</legend>\n      <div class=\"row\">\n        <label>Selected Run ID:</label><input id=\"selectedRunId\" readonly style=\"width:100px\">\n        <button id=\"stepForward\">Step Forward</button>\n        <button id=\"stepBack\">Step Back</button>\n        <button id=\"approveManual\">Approve</button>\n        <button id=\"rejectManual\">Reject</button>\n        <button id=\"showSnapshot\">Snapshot</button>\n      </div>\n      <div class=\"row\">\n        <label>Jump to step ID:</label>\n        <input id=\"jumpStepId\" style=\"width:80px\">\n        <button id=\"jumpToStep\">Jump</button>\n        <button id=\"toggleBreakpoint\">Toggle Breakpoint for Step</button>\n      </div>\n    </fieldset>\n\n    <fieldset>\n      <legend>Run History / Controls</legend>\n      <div class=\"row\">\n        <button id=\"exportRun\">Export Run</button>\n        <button id=\"replayRun\">Replay</button>\n        <button id=\"clearCompleted\">Clear Completed</button>\n      </div>\n    </fieldset>\n  </div>\n\n  <div class=\"panel\" id=\"inspector\">\n    <h3>Variables & Logs</h3>\n\n    <fieldset>\n      <legend>Global Variables</legend>\n      <div class=\"row\">\n        <input id=\"varKey\" placeholder=\"key\">\n        <input id=\"varVal\" placeholder=\"value\">\n        <button id=\"setVar\">Set</button>\n        <button id=\"delVar\">Delete</button>\n        <button id=\"clearVars\">Clear All</button>\n      </div>\n      <pre id=\"varsView\">{}</pre>\n    </fieldset>\n\n    <fieldset>\n      <legend>Watches & Eval</legend>\n      <div class=\"row\">\n        <input id=\"watchExpr\" placeholder=\"expression using vars\">\n        <button id=\"addWatch\">Add</button>\n      </div>\n      <div class=\"list\" id=\"watches\"></div>\n      <div class=\"row\">\n        <label>Eval:</label>\n        <input id=\"evalExpr\" placeholder=\"vars.x+1\">\n        <button id=\"evalBtn\">Eval</button>\n      </div>\n      <pre id=\"evalResult\"></pre>\n    </fieldset>\n\n    <fieldset>\n      <legend>Logs</legend>\n      <div class=\"row\">\n        <input id=\"logFilter\" placeholder=\"filter\">\n        <button id=\"clearLogs\">Clear</button>\n        <button id=\"exportLogs\">Export</button>\n      </div>\n      <div class=\"list\" id=\"logs\"></div>\n    </fieldset>\n\n  </div>\n</div>\n\n<script>\n/*\nProcess Simulator\n- Minimal UI, many interactive controls.\n- Steps, transitions, runs, variables, actions, breakpoints, manual approvals, parallel flows.\n*/\n\n(function(){\n  // Utilities\n  const $ = id=>document.getElementById(id);\n  const now = ()=>new Date().toISOString();\n  function log(msg,meta){ addLog({time:now(),msg,meta}); }\n  function addLog(obj){ logs.unshift(obj); renderLogs(); }\n  function deepClone(obj){ return JSON.parse(JSON.stringify(obj)); }\n\n  // Model\n  let processDef = { id:1, name:'Example Process', steps:[], transitions:[] };\n  let nextStepId = 1;\n  let logs = [];\n  let globalVars = {};\n  let watches = [];\n  let runs = []; // active and completed runs\n  let replaying = false;\n\n  // UI references\n  const stepsList = $('stepsList');\n  const transFrom = $('transFrom');\n  const transTo = $('transTo');\n  const transList = $('transList');\n  const runsList = $('runsList');\n  const varsView = $('varsView');\n  const logsDiv = $('logs');\n  const watchesDiv = $('watches');\n  const watchesInput = $('watchExpr');\n\n  // Init\n  function resetProcess(){\n    processDef = { id:1, name:$('procName').value||'Process', steps:[], transitions:[] };\n    nextStepId = 1;\n    logs = [];\n    globalVars = {};\n    runs = [];\n    renderAll();\n    addLog({time:now(),msg:'Created new process'});\n  }\n\n  function loadSample(){\n    resetProcess();\n    processDef.name = 'Sample Order Process';\n    const s1 = makeStep('Start','task',{duration:200,prob:1,script:'// set initial\\nreturn {vars:{count:0}}'});\n    const s2 = makeStep('Check inventory','task',{duration:300,prob:1});\n    const s3 = makeStep('Decision: in stock?','decision',{condition:'vars.count>0',duration:50});\n    const s4 = makeStep('Pickup & Ship','task',{duration:400,prob:0.9});\n    const s5 = makeStep('Notify customer','manual',{duration:0});\n    const s6 = makeStep('Wait timer','timer',{duration:1000});\n    const s7 = makeStep('Parallel start','parallel-start',{});\n    const s8 = makeStep('Task A','task',{duration:300});\n    const s9 = makeStep('Task B','task',{duration:500});\n    const s10 = makeStep('Parallel end','parallel-end',{});\n    processDef.steps.push(s1,s2,s3,s4,s5,s6,s7,s8,s9,s10);\n    processDef.transitions.push(\n      {from:s1.id,to:s2.id,cond:''},\n      {from:s2.id,to:s3.id,cond:''},\n      {from:s3.id,to:s4.id,cond:'vars.count>0'},\n      {from:s3.id,to:s6.id,cond:'!(vars.count>0)'},\n      {from:s4.id,to:s7.id,cond:''},\n      {from:s7.id,to:s8.id,cond:''},\n      {from:s7.id,to:s9.id,cond:''},\n      {from:s8.id,to:s10.id,cond:''},\n      {from:s9.id,to:s10.id,cond:''},\n      {from:s10.id,to:s5.id,cond:''},\n      {from:s6.id,to:s5.id,cond:''}\n    );\n    nextStepId = processDef.steps.reduce((m,s)=>Math.max(m,s.id),0)+1;\n    addLog({time:now(),msg:'Loaded sample process'});\n    renderAll();\n  }\n\n  function makeStep(name,type,opts){\n    return {\n      id: nextStepId++,\n      name: name||('Step '+(nextStepId)),\n      type: type||'task',\n      duration: opts.duration||500,\n      prob: opts.prob==null?1:opts.prob,\n      condition: opts.condition||'',\n      script: opts.script||'',\n      parallelGroup: opts.parallelGroup||'',\n      breakpoint: opts.breakpoint||false\n    };\n  }\n\n  // Render functions\n  function renderSteps(){\n    stepsList.innerHTML = '';\n    transFrom.innerHTML = '';\n    transTo.innerHTML = '';\n    processDef.steps.forEach(s=>{\n      const opt = document.createElement('option');\n      opt.value = s.id;\n      opt.textContent = `[${s.id}] ${s.name} (${s.type})`;\n      stepsList.appendChild(opt);\n      const opt2 = opt.cloneNode(true);\n      transFrom.appendChild(opt2);\n      transTo.appendChild(opt.cloneNode(true));\n    });\n  }\n  function renderTransitions(){\n    transList.innerHTML = '';\n    processDef.transitions.forEach((t,i)=>{\n      const from = findStep(t.from), to = findStep(t.to);\n      const div = document.createElement('div');\n      div.textContent = `${i}: [${t.from}] ${from?from.name:'<missing>'} -> [${t.to}] ${to?to.name:'<missing>'}  cond: \"${t.cond||t.condition||''}\"`;\n      const btn = document.createElement('button'); btn.textContent='Delete'; btn.onclick=()=>{ processDef.transitions.splice(i,1); renderTransitions(); addLog({time:now(), msg:'Deleted transition '+i}); };\n      div.appendChild(btn);\n      transList.appendChild(div);\n    });\n  }\n  function renderAll(){\n    $('procName').value = processDef.name;\n    renderSteps();\n    renderTransitions();\n    renderVars();\n    renderLogs();\n    renderRuns();\n    renderWatches();\n  }\n\n  function findStep(id){ return processDef.steps.find(s=>s.id==id) }\n  function findStepIndex(id){ return processDef.steps.findIndex(s=>s.id==id) }\n\n  // Designer events\n  $('addStep').onclick = ()=>{\n    const name = $('stepName').value || ('Step '+nextStepId);\n    const type = $('stepType').value;\n    const step = makeStep(name,type,{duration:500,prob:1,condition:''});\n    processDef.steps.push(step);\n    renderAll();\n    addLog({time:now(),msg:`Added step [${step.id}] ${step.name} (${step.type})`});\n  };\n\n  $('stepsList').addEventListener('change',()=>{\n    const id = +stepsList.value;\n    if(!id){ $('stepEditor').style.display='none'; return; }\n    const s = findStep(id);\n    if(!s) return;\n    $('stepEditor').style.display='block';\n    $('editId').value = s.id;\n    $('editName').value = s.name;\n    $('editType').value = s.type;\n    $('editDuration').value = s.duration||0;\n    $('editProb').value = s.prob==null?1:s.prob;\n    $('editCondition').value = s.condition||s.cond||'';\n    $('editScript').value = s.script||'';\n    $('editParallelGroup').value = s.parallelGroup||'';\n    $('editBreakpoint').checked = !!s.breakpoint;\n  });\n\n  $('saveStep').onclick = ()=>{\n    const id = +$('editId').value;\n    const s = findStep(id);\n    if(!s) return;\n    s.name = $('editName').value;\n    s.type = $('editType').value;\n    s.duration = +$('editDuration').value||0;\n    s.prob = Number($('editProb').value) || 0;\n    s.condition = $('editCondition').value;\n    s.script = $('editScript').value;\n    s.parallelGroup = $('editParallelGroup').value;\n    s.breakpoint = $('editBreakpoint').checked;\n    renderAll();\n    addLog({time:now(),msg:`Saved step [${s.id}] ${s.name}`});\n  };\n\n  $('deleteStep').onclick = ()=>{\n    const id = +$('editId').value;\n    const idx = findStepIndex(id);\n    if(idx>=0){\n      processDef.steps.splice(idx,1);\n      processDef.transitions = processDef.transitions.filter(t=>t.from!==id && t.to!==id);\n      renderAll();\n      addLog({time:now(),msg:`Deleted step [${id}]`});\n    }\n  };\n\n  $('duplicateStep').onclick = ()=>{\n    const id = +$('editId').value;\n    const s = findStep(id);\n    if(!s) return;\n    const clone = deepClone(s);\n    clone.id = nextStepId++;\n    clone.name = s.name + ' (copy)';\n    processDef.steps.push(clone);\n    renderAll();\n    addLog({time:now(),msg:`Duplicated step [${id}] -> [${clone.id}]`});\n  };\n\n  $('addTrans').onclick = ()=>{\n    const from = Number(transFrom.value);\n    const to = Number(transTo.value);\n    const cond = $('transCond').value || '';\n    if(!from || !to){ alert('Select from and to'); return; }\n    processDef.transitions.push({from,to,cond});\n    renderTransitions();\n    addLog({time:now(),msg:`Added transition [${from}] -> [${to}] cond:${cond}`});\n  };\n\n  $('insertScriptExample').onclick = ()=>{\n    $('editScript').value = \"// Example: modify vars, meta contains runId and stepId\\nfunction run(vars,meta){ vars.count = (vars.count||0)+1; return {vars:vars, note:'incremented'} }\\n// Return object: {vars: {...}}\";\n  };\n\n  // Export / Import\n  $('exportProc').onclick = ()=>{\n    const data = JSON.stringify(processDef,null,2);\n    const blob = new Blob([data],{type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a'); a.href = url; a.download = (processDef.name||'process')+'.json'; a.click();\n    URL.revokeObjectURL(url);\n  };\n  $('importProc').onclick = ()=>{\n    const txt = prompt('Paste process JSON');\n    if(!txt) return;\n    try{\n      const obj = JSON.parse(txt);\n      processDef = obj;\n      nextStepId = processDef.steps.reduce((m,s)=>Math.max(m,s.id),0)+1;\n      renderAll();\n      addLog({time:now(),msg:'Imported process JSON'});\n    }catch(e){ alert('Invalid JSON: '+e.message) }\n  };\n\n  $('newProc').onclick = resetProcess;\n  $('loadSample').onclick = loadSample;\n\n  // Variables\n  function renderVars(){\n    varsView.textContent = JSON.stringify(globalVars,null,2);\n  }\n  $('setVar').onclick = ()=>{\n    const k = $('varKey').value.trim();\n    const v = $('varVal').value;\n    if(!k) return alert('Enter key');\n    try{\n      globalVars[k] = JSON.parse(v);\n    }catch(e){\n      globalVars[k] = v;\n    }\n    renderVars();\n    addLog({time:now(),msg:`Set variable ${k}`});\n  };\n  $('delVar').onclick = ()=>{\n    const k = $('varKey').value.trim();\n    delete globalVars[k];\n    renderVars();\n    addLog({time:now(),msg:`Deleted variable ${k}`});\n  };\n  $('clearVars').onclick = ()=>{\n    globalVars = {};\n    renderVars();\n    addLog({time:now(),msg:'Cleared globals'});\n  };\n\n  // Watches & eval\n  function renderWatches(){\n    watchesDiv.innerHTML = '';\n    watches.forEach((w,i)=>{\n      const d = document.createElement('div');\n      const span = document.createElement('span');\n      let val = '';\n      try{ val = JSON.stringify(evalInContext(w.expr, currentVarsForEval() ),null,2); }catch(e){ val = 'ERR: '+e.message; }\n      span.textContent = `${i}: ${w.expr} => ${val}`;\n      const del = document.createElement('button'); del.textContent='X'; del.onclick=()=>{ watches.splice(i,1); renderWatches(); };\n      d.appendChild(span); d.appendChild(del);\n      watchesDiv.appendChild(d);\n    });\n  }\n  $('addWatch').onclick = ()=>{\n    const e = watchesInput.value.trim();\n    if(!e) return;\n    watches.push({expr:e});\n    watchesInput.value='';\n    renderWatches();\n  };\n  $('evalBtn').onclick = ()=>{\n    const expr = $('evalExpr').value;\n    try{\n      const res = evalInContext(expr, currentVarsForEval());\n      $('evalResult').textContent = '=> ' + JSON.stringify(res,null,2);\n    }catch(e){\n      $('evalResult').textContent = 'Error: '+e.message;\n    }\n  };\n\n  function currentVarsForEval(){\n    // use selected run variables if any, else global\n    const runId = $('selectedRunId').value;\n    if(runId){\n      const r = runs.find(x=>x.id==runId);\n      if(r) return deepClone(r.vars);\n    }\n    return deepClone(globalVars);\n  }\n\n  function evalInContext(expr, vars){\n    // Provide 'vars' as available\n    const fn = new Function('vars','meta','return ('+expr+')');\n    return fn(vars, {});\n  }\n\n  // Logs\n  function renderLogs(){\n    logsDiv.innerHTML = '';\n    const filter = $('logFilter').value.trim().toLowerCase();\n    for(let i=0;i<logs.length;i++){\n      const l = logs[i];\n      const s = document.createElement('div');\n      const text = `${l.time} - ${l.msg}${l.meta?(' '+JSON.stringify(l.meta)):''}`;\n      if(filter && text.toLowerCase().indexOf(filter)===-1) continue;\n      s.textContent = text;\n      logsDiv.appendChild(s);\n    }\n  }\n  $('clearLogs').onclick = ()=>{ logs = []; renderLogs(); };\n  $('exportLogs').onclick = ()=>{\n    const data = JSON.stringify(logs,null,2);\n    const blob = new Blob([data],{type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a'); a.href = url; a.download = 'logs.json'; a.click();\n    URL.revokeObjectURL(url);\n  };\n\n  // Runner core\n  let runCounter = 1;\n  function createRun(useGlobal){\n    const r = {\n      id: 'run-'+(runCounter++),\n      procName: processDef.name,\n      vars: useGlobal ? globalVars : deepClone(globalVars),\n      tokens: [], // active tokens, each token has current stepId or null for not started\n      stepStates: {}, // stepId -> {status:'pending'|'running'|'completed'|'failed'}\n      history: [], // snapshots\n      createdAt: now(),\n      status: 'ready', // running/paused/completed/aborted\n      paused: false,\n      waitingManual: [], // tokens waiting for manual approval {tokenId, stepId}\n    };\n    // initialize states\n    processDef.steps.forEach(s=> r.stepStates[s.id] = {status:'pending'});\n    // create initial token(s): find start steps (no inbound transitions)\n    const inbound = new Set(processDef.transitions.map(t=>t.to));\n    const startSteps = processDef.steps.filter(s=>!inbound.has(s.id));\n    if(startSteps.length===0 && processDef.steps.length>0) startSteps.push(processDef.steps[0]);\n    startSteps.forEach(s=> r.tokens.push({id:Math.random().toString(36).slice(2), stepId:s.id}));\n    runs.push(r);\n    renderRuns();\n    addLog({time:now(),msg:`Created run ${r.id}`,meta:{startSteps:startSteps.map(s=>s.id)}});\n    return r;\n  }\n\n  async function executeRun(r){\n    r.status = 'running';\n    r.startTime = Date.now();\n    saveSnapshot(r);\n    renderRuns();\n    while(true){\n      if(r.status==='aborted'){ addLog({time:now(),msg:`Run ${r.id} aborted`}); break; }\n      if(r.paused){ await sleep(200); continue; }\n      if(r.tokens.length===0){\n        r.status = 'completed';\n        addLog({time:now(),msg:`Run ${r.id} completed`});\n        renderRuns();\n        break;\n      }\n      // pick next token\n      const token = r.tokens.shift();\n      const step = findStep(token.stepId);\n      if(!step){\n        addLog({time:now(),msg:`Run ${r.id} token reached missing step ${token.stepId}`});\n        continue;\n      }\n      // Breakpoint check\n      if(step.breakpoint){\n        r.paused = true;\n        addLog({time:now(),msg:`Run ${r.id} paused at breakpoint step [${step.id}] ${step.name}`});\n        r.currentToken = token;\n        renderRuns();\n        continue;\n      }\n      try{\n        await runStepForToken(r,token,step);\n      }catch(e){\n        addLog({time:now(),msg:`Run ${r.id} error executing step ${step.id}: ${e.message}`});\n      }\n      saveSnapshot(r);\n      renderRuns();\n      // If step mode, pause after each step\n      if($('runMode').value === 'step'){ r.paused = true; renderRuns(); await sleep(50); continue; }\n    }\n  }\n\n  function saveSnapshot(r){\n    const snap = {\n      time: now(),\n      vars: deepClone(r.vars),\n      stepStates: deepClone(r.stepStates),\n      tokens: deepClone(r.tokens),\n    };\n    r.history.push(snap);\n    if(r.history.length>100) r.history.shift();\n  }\n\n  async function runStepForToken(r, token, step){\n    r.stepStates[step.id] = {status:'running',started:now()};\n    addLog({time:now(),msg:`Run ${r.id} running step [${step.id}] ${step.name}`});\n    renderRuns();\n    // Execute action\n    if(step.type==='task' || step.type==='parallel-start' || step.type==='parallel-end'){\n      await delayWithSpeed(parseInt(step.duration||0));\n      // script execution optionally modifies vars\n      if(step.script && step.script.trim()){\n        try{\n          const res = runUserScript(step.script, r.vars, {runId:r.id,stepId:step.id});\n          if(res && res.vars) Object.assign(r.vars, res.vars);\n        }catch(e){\n          addLog({time:now(),msg:`Script error at step ${step.id}: ${e.message}`});\n        }\n      }\n      // simulate success/failure by prob\n      const p = (step.prob==null?1:step.prob);\n      const ok = Math.random()<=p;\n      if(!ok){ r.stepStates[step.id] = {status:'failed',finished:now()}; addLog({time:now(),msg:`Step [${step.id}] failed on run ${r.id}`}); return; }\n      r.stepStates[step.id] = {status:'completed',finished:now()};\n      // Transitions:\n      if(step.type==='parallel-start'){\n        // start all outgoing transitions as separate tokens\n        const outs = outgoing(step.id).map(t=>t.to);\n        outs.forEach(toId=> r.tokens.push({id:Math.random().toString(36).slice(2), stepId:toId}));\n      }else if(step.type==='parallel-end'){\n        // move to outgoing transitions only if all incoming in that parallel group are completed\n        const outs = outgoing(step.id).map(t=>t.to);\n        outs.forEach(toId=> r.tokens.push({id:Math.random().toString(36).slice(2), stepId:toId}));\n      }else{\n        // normal: pick eligible transitions by evaluating conditions\n        const outs = outgoing(step.id);\n        let pushed=false;\n        for(const t of outs){\n          const cond = t.cond || t.condition || '';\n          if(!cond){ r.tokens.push({id:Math.random().toString(36).slice(2), stepId:t.to}); pushed=true; continue; }\n          try{\n            const ok = (new Function('vars','meta','return ('+cond+')'))(r.vars, {runId:r.id,stepId:step.id});\n            if(ok){ r.tokens.push({id:Math.random().toString(36).slice(2), stepId:t.to}); pushed=true; }\n          }catch(e){ addLog({time:now(),msg:`Condition eval error: ${e.message}`}); }\n        }\n        // no outgoing: token ends\n        if(!pushed && outs.length===0){ /* token finished */ }\n      }\n    }else if(step.type==='decision'){\n      // evaluate condition and follow matching transition(s)\n      await delayWithSpeed(parseInt(step.duration||0));\n      let matched=false;\n      const outs = outgoing(step.id);\n      for(const t of outs){\n        const cond = t.cond || t.condition || '';\n        try{\n          const ok = cond ? (new Function('vars','meta','return ('+cond+')'))(r.vars,{runId:r.id,stepId:step.id}) : false;\n          if(ok){ r.tokens.push({id:Math.random().toString(36).slice(2), stepId:t.to}); matched=true; }\n        }catch(e){ addLog({time:now(),msg:`Decision eval error: ${e.message}`}); }\n      }\n      if(!matched){\n        // if none matched and there's a default (no cond) push them\n        outs.filter(t=>!(t.cond||t.condition)).forEach(t=> r.tokens.push({id:Math.random().toString(36).slice(2), stepId:t.to}));\n      }\n      r.stepStates[step.id] = {status:'completed',finished:now()};\n    }else if(step.type==='timer'){\n      // wait for configured delay; can be aborted via pause/abort\n      await delayWithSpeed(parseInt(step.duration||0));\n      r.stepStates[step.id] = {status:'completed',finished:now()};\n      outgoing(step.id).forEach(t=> r.tokens.push({id:Math.random().toString(36).slice(2), stepId:t.to}));\n    }else if(step.type==='manual'){\n      // wait until user approves/rejects this token: add to waitingManual and pause run loop until resolved\n      r.waitingManual.push({token,step});\n      r.paused = true;\n      addLog({time:now(),msg:`Run ${r.id} awaiting manual approval at step [${step.id}]`});\n      renderRuns();\n      // Wait until manual resolves (approval triggers resume and pushes next tokens)\n      return;\n    }else{\n      // unknown type: mark completed\n      r.stepStates[step.id] = {status:'completed',finished:now()};\n    }\n  }\n\n  function outgoing(stepId){\n    return processDef.transitions.filter(t=>t.from===stepId);\n  }\n\n  function runUserScript(script, vars, meta){\n    // Expected to return object with vars\n    // Provide basic sandbox: provide vars and meta\n    const fnBody = script.trim().startsWith('function') ? '('+script+')' : script;\n    try{\n      const fn = new Function('vars','meta','return (('+fnBody+')(vars,meta))');\n      return fn(deepClone(vars), meta) || {};\n    }catch(e){\n      // try to evaluate as code returning an object\n      const wrapper = new Function('vars','meta', script);\n      return wrapper(deepClone(vars), meta) || {};\n    }\n  }\n\n  // Controls to start runs\n  $('startRun').onclick = ()=>{\n    const useGlobal = $('useGlobalVars').checked;\n    const r = createRun(useGlobal);\n    executeRun(r).catch(e=>addLog({time:now(),msg:'Run error: '+e.message}));\n    renderRuns();\n  };\n  $('startMultiple').onclick = ()=>{\n    const n = Math.max(1,parseInt($('startCount').value)||1);\n    for(let i=0;i<n;i++){\n      const r = createRun($('useGlobalVars').checked);\n      executeRun(r).catch(e=>addLog({time:now(),msg:'Run error: '+e.message}));\n    }\n  };\n\n  // pause/resume/abort global\n  $('pauseAll').onclick = ()=>{ runs.forEach(r=> r.paused = true); renderRuns(); addLog({time:now(),msg:'Paused all runs'}); };\n  $('resumeAll').onclick = ()=>{ runs.forEach(r=> r.paused = false); renderRuns(); addLog({time:now(),msg:'Resumed all runs'}); };\n  $('abortAll').onclick = ()=>{ runs.forEach(r=> r.status='aborted'); renderRuns(); addLog({time:now(),msg:'Aborted all runs'}); };\n\n  // per-run UI render\n  function renderRuns(){\n    runsList.innerHTML = '';\n    runs.forEach(r=>{\n      const d = document.createElement('div');\n      d.style.borderTop = '1px solid #000'; d.style.paddingTop='4px'; d.style.marginTop='4px';\n      const title = document.createElement('div');\n      title.textContent = `${r.id} - ${r.status} - tokens:${r.tokens.length} paused:${r.paused}`;\n      d.appendChild(title);\n      const info = document.createElement('pre');\n      info.textContent = `vars: ${JSON.stringify(r.vars)}\\nstates: ${JSON.stringify(simpleStates(r.stepStates))}\\nwaitingManual:${r.waitingManual.length}`;\n      d.appendChild(info);\n      const selBtn = document.createElement('button'); selBtn.textContent='Select'; selBtn.onclick=()=>{ $('selectedRunId').value=r.id; renderRuns(); };\n      d.appendChild(selBtn);\n      const pause = document.createElement('button'); pause.textContent='Pause'; pause.onclick=()=>{ r.paused=true; renderRuns(); };\n      const resume = document.createElement('button'); resume.textContent='Resume'; resume.onclick=()=>{ r.paused=false; renderRuns(); };\n      const abort = document.createElement('button'); abort.textContent='Abort'; abort.onclick=()=>{ r.status='aborted'; renderRuns(); };\n      const exportBtn = document.createElement('button'); exportBtn.textContent='Export'; exportBtn.onclick=()=>{ const data=JSON.stringify(r,null,2); const blob=new Blob([data],{type:'application/json'}); const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download=r.id+'.json'; a.click(); URL.revokeObjectURL(url); };\n      d.appendChild(pause); d.appendChild(resume); d.appendChild(abort); d.appendChild(exportBtn);\n      // manual approvals control per run\n      if(r.waitingManual.length){\n        r.waitingManual.forEach((w,i)=>{\n          const mdiv = document.createElement('div');\n          mdiv.textContent = `Manual #${i} at step [${w.step.id}] ${w.step.name}`;\n          const apro = document.createElement('button'); apro.textContent='Approve'; apro.onclick=()=>{ handleManualDecision(r,w,true); };\n          const rej = document.createElement('button'); rej.textContent='Reject'; rej.onclick=()=>{ handleManualDecision(r,w,false); };\n          mdiv.appendChild(apro); mdiv.appendChild(rej);\n          d.appendChild(mdiv);\n        });\n      }\n      runsList.appendChild(d);\n    });\n    renderVars(); renderLogs(); renderWatches();\n  }\n\n  function simpleStates(ss){\n    const o={};\n    for(const k in ss) o[k]=ss[k].status;\n    return o;\n  }\n\n  // Manual approval handling\n  function handleManualDecision(r,w,approved){\n    // Remove waitingManual entry\n    const idx = r.waitingManual.indexOf(w);\n    if(idx>=0) r.waitingManual.splice(idx,1);\n    r.stepStates[w.step.id] = {status: approved ? 'completed' : 'failed', finished: now()};\n    addLog({time:now(),msg:`Run ${r.id} manual ${approved?'approved':'rejected'} at step [${w.step.id}]`});\n    if(approved){\n      // push outgoing tokens\n      outgoing(w.step.id).forEach(t=> r.tokens.push({id:Math.random().toString(36).slice(2), stepId:t.to}));\n    }\n    r.paused = false;\n    renderRuns();\n  }\n\n  // Selected run controls (step forward/back etc)\n  $('stepForward').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return alert('Select a run');\n    // resume run to process one token\n    r.paused = false;\n    // if paused at breakpoint and currentToken exists, process it\n    if(r.currentToken){ const t = r.currentToken; r.currentToken=null; runStepForToken(r,t,findStep(t.stepId)).then(()=>{ saveSnapshot(r); renderRuns(); }); return; }\n    // if tokens exist, unpause and allow loop to proceed; create a minimal tick by running executeRun if not active\n    if(r.status==='ready' || r.status==='running') { r.paused=false; renderRuns(); } else { executeRun(r); }\n  };\n  $('stepBack').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    if(r.history.length<2) return alert('No previous snapshot');\n    // pop last snapshot and restore previous\n    r.history.pop();\n    const snap = deepClone(r.history[r.history.length-1]);\n    r.vars = snap.vars; r.tokens = snap.tokens; r.stepStates = snap.stepStates;\n    renderRuns();\n    addLog({time:now(),msg:`Rewound run ${r.id} one step`});\n  };\n\n  $('approveManual').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    if(r.waitingManual.length===0) return alert('No manual waiting');\n    handleManualDecision(r,r.waitingManual[0],true);\n  };\n  $('rejectManual').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    if(r.waitingManual.length===0) return alert('No manual waiting');\n    handleManualDecision(r,r.waitingManual[0],false);\n  };\n\n  $('showSnapshot').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    alert(JSON.stringify(r.history[r.history.length-1]||{},null,2));\n  };\n\n  $('jumpToStep').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    const id = Number($('jumpStepId').value);\n    if(!id) return alert('Enter step id');\n    r.tokens.push({id:Math.random().toString(36).slice(2), stepId:id});\n    r.paused=false;\n    renderRuns();\n    addLog({time:now(),msg:`Jumped run ${r.id} to step ${id}`});\n  };\n\n  $('toggleBreakpoint').onclick = ()=>{\n    const id = Number($('jumpStepId').value);\n    if(!id) return alert('Enter step id');\n    const s = findStep(id);\n    if(!s) return alert('Step not found');\n    s.breakpoint = !s.breakpoint;\n    renderAll();\n    addLog({time:now(),msg:`Toggled breakpoint on step ${id} => ${s.breakpoint}`});\n  };\n\n  $('exportRun').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    const data = JSON.stringify(r,null,2);\n    const blob = new Blob([data],{type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a'); a.href = url; a.download = r.id+'.json'; a.click();\n    URL.revokeObjectURL(url);\n  };\n\n  $('replayRun').onclick = ()=>{\n    const r = getSelectedRun(); if(!r) return;\n    if(!r.history || r.history.length===0) return alert('No history to replay');\n    // Replay through history snapshots\n    (async ()=>{\n      replaying = true;\n      for(const snap of r.history){\n        if(!replaying) break;\n        $('selectedRunId').value = r.id;\n        // show snapshot\n        alert('Replay snapshot:\\n'+JSON.stringify(snap,null,2).slice(0,2000));\n        await sleep(300);\n      }\n      replaying = false;\n    })();\n  };\n\n  $('clearCompleted').onclick = ()=>{\n    runs = runs.filter(r=> r.status !== 'completed' && r.status!=='aborted');\n    renderRuns();\n    addLog({time:now(),msg:'Cleared completed runs'});\n  };\n\n  function getSelectedRun(){ const id = $('selectedRunId').value; return runs.find(r=>r.id===id); }\n\n  // Manual approve via UI for waiting manual tokens is handled in per-run render.\n\n  // Step helper functions\n  function delayWithSpeed(ms){\n    const speed = Number($('speed').value) || 500;\n    const multiplier = Math.max(1, 500 / speed); // inverse mapping: higher speed -> smaller wait\n    const actual = Math.max(0, Math.round(ms * multiplier));\n    return sleep(actual);\n  }\n  function sleep(ms){ return new Promise(res=>setTimeout(res, ms)); }\n\n  // Logs array functions\n  function addLogEntry(msg,meta){ logs.unshift({time:now(),msg,meta}); renderLogs(); }\n\n  // Script runner util\n  // Provide secure-ish sandbox? Running user code via Function. Acceptable for this demo.\n\n  // Speed slider\n  $('speed').oninput = ()=>{ $('speedVal').textContent = $('speed').value+'ms'; };\n  $('logFilter').oninput = renderLogs;\n\n  // Misc UI binding\n  $('importProc').addEventListener('click', ()=>{ /* handled above */ });\n\n  // Initialize\n  resetProcess();\n\n  // Helpers for testing and advanced control\n  window.__processSimulator = {\n    getProcess: ()=>processDef,\n    getRuns: ()=>runs,\n    getLogs: ()=>logs,\n    setGlobalVars: v=>{ globalVars=v; renderVars(); },\n    addLog: (m)=>addLog({time:now(),msg:m}),\n  };\n\n  // Utilities for safe evaluation\n  function runFunctionSource(src,vars,meta){\n    const fn = new Function('vars','meta','return ('+src+')');\n    return fn(vars,meta);\n  }\n\n  // Simple UI-driven import prompt for process JSON in sidebar\n  // The \"Import JSON\" button above uses prompt.\n\n  // Render initial\n  renderAll();\n\n  // Add keyboard shortcuts: N new proc, S start, P pause, R resume\n  document.addEventListener('keydown',(e)=>{\n    if(e.ctrlKey && e.key==='n'){ resetProcess(); e.preventDefault(); }\n    if(e.ctrlKey && e.key==='s'){ $('startRun').click(); e.preventDefault(); }\n    if(e.ctrlKey && e.key==='p'){ $('pauseAll').click(); e.preventDefault(); }\n    if(e.ctrlKey && e.key==='r'){ $('resumeAll').click(); e.preventDefault(); }\n  });\n\n  // Expose some UI functions for debugging\n  window.psim = {\n    addStep: ()=>$('addStep').click(),\n    start: ()=>$('startRun').click(),\n    runs: ()=>runs,\n    proc: ()=>processDef,\n    logs: ()=>logs\n  };\n\n})();\n</script>\n</body>\n</html>"
