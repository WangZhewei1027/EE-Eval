    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Branch and Bound Interactive Example</title>\n</head>\n<body>\n    <h1>Branch and Bound Example</h1>\n    <p>Use the controls below to explore the Branch and Bound algorithm for solving optimization problems.</p>\n\n    <div>\n        <label for=\"items\">Enter Number of Items (2-10): </label>\n        <input type=\"number\" id=\"items\" min=\"2\" max=\"10\" value=\"5\">\n        <button onclick=\"generateItems()\">Generate Items</button>\n    </div>\n\n    <div>\n        <h2>Items:</h2>\n        <ul id=\"itemList\"></ul>\n    </div>\n\n    <div>\n        <label for=\"capacity\">Enter Capacity: </label>\n        <input type=\"number\" id=\"capacity\" value=\"15\">\n    </div>\n\n    <button onclick=\"startBranchAndBound()\">Start Branch and Bound</button>\n\n    <h2>Results:</h2>\n    <div id=\"results\"></div>\n\n    <script>\n        let items = [];\n        let weights = [];\n        let values = [];\n\n        function generateItems() {\n            const numItems = document.getElementById('items').value;\n            items = [];\n            for (let i = 0; i < numItems; i++) {\n                const weight = Math.floor(Math.random() * 10) + 1;\n                const value = Math.floor(Math.random() * 20) + 1;\n                items.push({ weight, value });\n                weights.push(weight);\n                values.push(value);\n            }\n            displayItems();\n        }\n\n        function displayItems() {\n            const itemList = document.getElementById('itemList');\n            itemList.innerHTML = '';\n            items.forEach((item, index) => {\n                itemList.innerHTML += `<li>Item ${index + 1}: Weight - ${item.weight}, Value - ${item.value}</li>`;\n            });\n        }\n\n        function startBranchAndBound() {\n            const capacity = document.getElementById('capacity').value;\n            const result = branchAndBound(capacity);\n            displayResults(result);\n        }\n\n        function branchAndBound(capacity) {\n            const n = items.length;\n            let maxValue = 0;\n            let bestItems = [];\n\n            function traverse(node, level, totalWeight, totalValue) {\n                if (level === n) {\n                    if (totalValue > maxValue && totalWeight <= capacity) {\n                        maxValue = totalValue;\n                        bestItems = [...node];\n                    }\n                    return;\n                }\n\n                // Include the current item\n                traverse([...node, level], level + 1, totalWeight + weights[level], totalValue + values[level]);\n\n                // Exclude the current item\n                traverse(node, level + 1, totalWeight, totalValue);\n            }\n\n            traverse([], 0, 0, 0);\n            return { maxValue, bestItems };\n        }\n\n        function displayResults(result) {\n            const resultsDiv = document.getElementById('results');\n            resultsDiv.innerHTML = `Maximum Value: ${result.maxValue}<br>Items Included: ${result.bestItems.map(i => `Item ${i + 1}`).join(', ')}`;\n        }\n    </script>\n</body>\n</html>"
