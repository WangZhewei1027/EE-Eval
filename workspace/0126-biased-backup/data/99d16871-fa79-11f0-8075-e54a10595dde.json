    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Symmetric Cryptography Demo</title>\n    <script>\n        let secretKey = '';\n        let plaintext = '';\n        let ciphertext = '';\n\n        function setKey() {\n            secretKey = document.getElementById('keyInput').value;\n            document.getElementById('keyStatus').innerText = 'Key Set: ' + secretKey;\n        }\n\n        function setPlaintext() {\n            plaintext = document.getElementById('plaintextInput').value;\n            document.getElementById('plaintextStatus').innerText = 'Plaintext Set: ' + plaintext;\n        }\n\n        function encrypt() {\n            if (!secretKey || !plaintext) {\n                alert('Please set both the key and plaintext');\n                return;\n            }\n            ciphertext = btoa(plaintext + secretKey); // Simple reversible transformation for demonstration\n            document.getElementById('ciphertextStatus').innerText = 'Ciphertext: ' + ciphertext;\n        }\n\n        function decrypt() {\n            try {\n                if (!secretKey || !ciphertext) {\n                    alert('Please encrypt text first');\n                    return;\n                }\n                const decrypted = atob(ciphertext);\n                const originalText = decrypted.replace(secretKey, '');\n                document.getElementById('decryptedStatus').innerText = 'Decrypted Text: ' + originalText;\n            } catch (e) {\n                alert('Error during decryption');\n            }\n        }\n\n        function reset() {\n            secretKey = '';\n            plaintext = '';\n            ciphertext = '';\n            document.getElementById('keyInput').value = '';\n            document.getElementById('plaintextInput').value = '';\n            document.getElementById('ciphertextStatus').innerText = 'Ciphertext: ';\n            document.getElementById('decryptedStatus').innerText = 'Decrypted Text: ';\n            document.getElementById('keyStatus').innerText = 'Key Set: ';\n            document.getElementById('plaintextStatus').innerText = 'Plaintext Set: ';\n        }\n    </script>\n</head>\n<body>\n    <h1>Symmetric Cryptography Demo</h1>\n    \n    <div>\n        <h2>Set Key</h2>\n        <input type=\"text\" id=\"keyInput\" placeholder=\"Enter a secret key\">\n        <button onclick=\"setKey()\">Set Key</button>\n        <p id=\"keyStatus\">Key Set: </p>\n    </div>\n    \n    <div>\n        <h2>Set Plaintext</h2>\n        <input type=\"text\" id=\"plaintextInput\" placeholder=\"Enter text to encrypt\">\n        <button onclick=\"setPlaintext()\">Set Plaintext</button>\n        <p id=\"plaintextStatus\">Plaintext Set: </p>\n    </div>\n    \n    <div>\n        <h2>Encrypt</h2>\n        <button onclick=\"encrypt()\">Encrypt</button>\n        <p id=\"ciphertextStatus\">Ciphertext: </p>\n    </div>\n    \n    <div>\n        <h2>Decrypt</h2>\n        <button onclick=\"decrypt()\">Decrypt</button>\n        <p id=\"decryptedStatus\">Decrypted Text: </p>\n    </div>\n    \n    <div>\n        <h2>Reset</h2>\n        <button onclick=\"reset()\">Reset</button>\n    </div>\n</body>\n</html>"
