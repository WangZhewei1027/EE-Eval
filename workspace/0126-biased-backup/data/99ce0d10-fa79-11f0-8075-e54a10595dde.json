    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Queue Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        input, button {\n            margin: 5px;\n        }\n        #queueContainer {\n            margin-top: 20px;\n        }\n        .item {\n            margin: 2px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Queue Demonstration</h1>\n    <label for=\"itemInput\">Enter an item: </label>\n    <input type=\"text\" id=\"itemInput\" />\n    <button onclick=\"enqueue()\">Enqueue</button>\n    <button onclick=\"dequeue()\">Dequeue</button>\n    <button onclick=\"peek()\">Peek</button>\n    <button onclick=\"clearQueue()\">Clear Queue</button>\n    \n    <h2>Queue State</h2>\n    <div id=\"queueContainer\"></div>\n    <div>\n        <label for=\"capacityInput\">Set Maximum Capacity: </label>\n        <input type=\"number\" id=\"capacityInput\" value=\"5\" min=\"1\" onchange=\"setCapacity()\" />\n    </div>\n    <div>\n        <button onclick=\"printQueue()\">Print Queue</button>\n    </div>\n\n    <script>\n        let queue = [];\n        let maxCapacity = 5;\n\n        function enqueue() {\n            const itemInput = document.getElementById('itemInput');\n            const item = itemInput.value;\n            if (item !== '' && queue.length < maxCapacity) {\n                queue.push(item);\n                itemInput.value = '';\n                renderQueue();\n            } else if (queue.length >= maxCapacity) {\n                alert('Queue is full! Cannot enqueue.');\n            }\n        }\n\n        function dequeue() {\n            if (queue.length > 0) {\n                queue.shift();\n                renderQueue();\n            } else {\n                alert('Queue is empty! Cannot dequeue.');\n            }\n        }\n\n        function peek() {\n            if (queue.length > 0) {\n                alert('Front item: ' + queue[0]);\n            } else {\n                alert('Queue is empty!');\n            }\n        }\n\n        function clearQueue() {\n            queue = [];\n            renderQueue();\n        }\n\n        function setCapacity() {\n            const capacityInput = document.getElementById('capacityInput');\n            maxCapacity = parseInt(capacityInput.value);\n            if (queue.length > maxCapacity) {\n                alert('Current queue exceeds new capacity! Please dequeue items.');\n            }\n        }\n\n        function printQueue() {\n            console.log(queue);\n            alert('Check the console for the current queue.');\n        }\n\n        function renderQueue() {\n            const queueContainer = document.getElementById('queueContainer');\n            queueContainer.innerHTML = '';\n            for (let item of queue) {\n                const div = document.createElement('div');\n                div.className = 'item';\n                div.textContent = item;\n                queueContainer.appendChild(div);\n            }\n        }\n    </script>\n</body>\n</html>"
