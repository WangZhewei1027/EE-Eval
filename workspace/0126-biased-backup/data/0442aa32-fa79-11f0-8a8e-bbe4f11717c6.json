    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bellman-Ford Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f2f2f2;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .button {\n            width: 200px;\n            height: 50px;\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n        .graph {\n            width: 100%;\n            height: 500px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            overflow: hidden;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Bellman-Ford Algorithm</h1>\n        <p>Find the shortest path from a source to all other nodes in a graph.</p>\n        <button id=\"start-button\">Start</button>\n        <button id=\"stop-button\" disabled>Stop</button>\n        <div class=\"graph\"></div>\n    </div>\n\n    <script>\n        let graph = {\n            'source': {\n                'nodes': ['A', 'B', 'C', 'D', 'E'],\n                'edges': [\n                    ['A', 'B', 1],\n                    ['A', 'C', 4],\n                    ['B', 'C', 2],\n                    ['B', 'D', 5],\n                    ['C', 'D', 1],\n                    ['C', 'E', 3],\n                    ['D', 'E', 4]\n                ]\n            },\n            'distances': {\n                'A': 0,\n                'B': 1,\n                'C': 4,\n                'D': 5,\n                'E': 7\n            }\n        };\n\n        let queue = ['A'];\n        let distances = { 'A': 0 };\n\n        while (queue.length > 0) {\n            let currentVertex = queue.shift();\n            for (let neighbor in graph[currentVertex]['edges']) {\n                let distance = graph[currentVertex]['edges'][neighbor][0] + graph[currentVertex]['edges'][neighbor][1];\n                if (distances[neighbor] === undefined || distances[neighbor] > distance) {\n                    distances[neighbor] = distance;\n                    queue.push(neighbor);\n                }\n            }\n        }\n\n        let result = '';\n        for (let vertex in distances) {\n            result += `Vertex: ${vertex}, Distance: ${distances[vertex]}\\n`;\n        }\n        document.getElementById('result').innerHTML = result;\n    </script>\n</body>\n</html>"
