    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Interpreter — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Space+Grotesk:wght@400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg1: #071028;\n      --bg2: #0b1530;\n      --glass: rgba(255,255,255,0.04);\n      --accent: #7ae7ff;\n      --accent-2: #8c6cff;\n      --muted: rgba(255,255,255,0.12);\n      --card: rgba(255,255,255,0.03);\n      --success: #7be495;\n      --shadow: 0 10px 30px rgba(2,6,23,0.6);\n      --glass-border: linear-gradient(120deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n      --mono: 'Space Grotesk', monospace;\n      --ui: 'Inter', sans-serif;\n    }\n\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:var(--ui);\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(115,66,255,0.12), transparent 8%),\n                  radial-gradient(900px 400px at 90% 90%, rgba(122,231,255,0.06), transparent 8%),\n                  linear-gradient(180deg, var(--bg1), var(--bg2));\n      color: #e9f3ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Page layout */\n    .stage{\n      width:100%;\n      height:100vh;\n      display:grid;\n      grid-template-columns: 420px 1fr 420px;\n      align-items:center;\n      gap:32px;\n      padding:48px;\n      position:relative;\n    }\n\n    header.appbar{\n      position:absolute;\n      top:28px;\n      left:48px;\n      right:48px;\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      pointer-events:none;\n    }\n    .brand{\n      display:flex;\n      gap:18px;\n      align-items:center;\n      pointer-events:auto;\n    }\n    .logo{\n      width:56px;height:56px;border-radius:14px;\n      background:linear-gradient(135deg,var(--accent),var(--accent-2));\n      box-shadow: 0 6px 30px rgba(99,79,255,0.16), inset 0 -6px 30px rgba(255,255,255,0.06);\n      display:flex;align-items:center;justify-content:center;font-weight:800;\n      color:#021025;font-size:20px;font-family:var(--mono);\n      transform:rotate(-15deg);\n      border:1px solid rgba(255,255,255,0.06);\n    }\n    .title{\n      pointer-events:auto;\n    }\n    .title h1{margin:0;font-size:18px;letter-spacing:-0.4px}\n    .title p{margin:0;font-size:12px;color:var(--muted);margin-top:4px}\n\n    .controls{\n      pointer-events:auto;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      -webkit-tap-highlight-color:transparent;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.06);\n      color:var(--accent);\n      padding:10px 16px;\n      border-radius:10px;\n      font-weight:600;\n      letter-spacing:0.2px;\n      cursor:pointer;\n      backdrop-filter: blur(6px) saturate(120%);\n      box-shadow: var(--shadow);\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      transition:transform .18s ease, opacity .18s ease, box-shadow .18s ease;\n      font-family:var(--ui);\n    }\n    .btn:active{transform:translateY(1px) scale(.998)}\n    .btn.secondary{\n      color: #dfefff;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 6px 20px rgba(3,9,25,0.5);\n    }\n\n    /* Cards */\n    .card{\n      border-radius:20px;\n      padding:24px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: var(--shadow);\n      border:1px solid rgba(255,255,255,0.03);\n      min-height:420px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      position:relative;\n      overflow:visible;\n    }\n\n    /* Left code display */\n    .codeCard{padding:28px 22px}\n    .sectionTitle{\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      gap:12px;\n    }\n    .sectionTitle h2{margin:0;font-size:13px;font-weight:700}\n    .sectionTitle .hint{font-size:12px;color:var(--muted)}\n\n    .codeWindow{\n      margin-top:10px;\n      background: linear-gradient(180deg, rgba(12,24,48,0.46), rgba(6,12,22,0.36));\n      border-radius:14px;\n      padding:18px;\n      font-family:var(--mono);\n      color:#dff9ff;\n      font-size:13px;\n      line-height:1.5;\n      position:relative;\n      min-height:250px;\n      box-shadow: inset 0 -10px 40px rgba(0,0,0,0.35);\n      border:1px solid rgba(255,255,255,0.03);\n    }\n\n    .line{\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n      padding:6px 8px;\n      border-radius:8px;\n      transition:background .18s ease, transform .18s ease;\n    }\n\n    .ln{\n      width:28px;\n      text-align:right;\n      color:rgba(255,255,255,0.2);\n      font-size:12px;\n      padding-right:6px;\n      user-select:none;\n    }\n    .code{\n      flex:1;\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n      align-items:center;\n      min-height:18px;\n    }\n\n    .tok{\n      padding:6px 10px;\n      border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.016), rgba(255,255,255,0.006));\n      border:1px solid rgba(255,255,255,0.03);\n      font-size:13px;\n      color:#e6fbff;\n      box-shadow: 0 2px 8px rgba(6,10,20,0.5);\n    }\n    .tok.keyword{background:linear-gradient(180deg, rgba(140,108,255,0.12), rgba(140,108,255,0.04)); color: #efe6ff; border:1px solid rgba(140,108,255,0.18)}\n    .tok.func{background:linear-gradient(180deg, rgba(122,231,255,0.08), rgba(122,231,255,0.03)); color: #e6fbff; border:1px solid rgba(122,231,255,0.18)}\n    .tok.num{background:linear-gradient(180deg, rgba(123,228,149,0.08), rgba(123,228,149,0.02)); color: #dfffe9; border:1px solid rgba(123,228,149,0.14)}\n    .tok.op{color:#d7e7ff; opacity:0.92}\n\n    /* Pipeline center art */\n    .pipeline{\n      display:flex;\n      justify-content:center;\n      align-items:center;\n      position:relative;\n      min-height:520px;\n      overflow:visible;\n    }\n\n    .space{\n      width:100%;\n      height:520px;\n      position:relative;\n      border-radius:28px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      pointer-events:none;\n    }\n\n    .stageNode{\n      width:140px;\n      height:140px;\n      border-radius:18px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      flex-direction:column;\n      gap:8px;\n      text-align:center;\n      position:relative;\n      box-shadow: 0 20px 60px rgba(3,8,20,0.5);\n      backdrop-filter: blur(6px) saturate(120%);\n    }\n    .stageNode .label{font-size:12px;color:var(--muted);font-weight:600}\n    .stageNode .big{font-weight:800;font-size:22px;color:var(--accent)}\n\n    .node-lexer{left: 28%; position:absolute; top: 30%;}\n    .node-parser{left: 50%; position:absolute; top: 14%;}\n    .node-ast{left: 65%; position:absolute; top: 45%;}\n    .node-eval{left: 44%; position:absolute; top: 66%;}\n\n    .glowRing{\n      position:absolute;\n      inset:0;\n      border-radius:inherit;\n      pointer-events:none;\n      mix-blend-mode:screen;\n      opacity:0.7;\n      filter: blur(24px);\n      transform:scale(.98);\n      background: radial-gradient(closest-side, rgba(138,108,255,0.12), transparent 60%),\n                  radial-gradient(closest-side, rgba(122,231,255,0.08), transparent 40%);\n      z-index:0;\n    }\n\n    /* token movers (absolute) */\n    .floatingToken{\n      position:absolute;\n      padding:8px 12px;\n      border-radius:999px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      color:#e6fbff;\n      font-family:var(--mono);\n      font-size:13px;\n      box-shadow: 0 8px 30px rgba(6,10,20,0.6);\n      transform:translate(-50%,-50%) scale(1);\n      transition:transform .34s cubic-bezier(.2,.9,.27,1), opacity .28s linear;\n      will-change:transform, opacity;\n      z-index:60;\n      pointer-events:none;\n    }\n\n    .floatingToken.kind-key{background:linear-gradient(180deg, rgba(140,108,255,0.14), rgba(140,108,255,0.04)); border:1px solid rgba(140,108,255,0.22)}\n    .floatingToken.kind-fn{background:linear-gradient(180deg, rgba(122,231,255,0.1), rgba(122,231,255,0.03)); border:1px solid rgba(122,231,255,0.14)}\n    .floatingToken.kind-num{background:linear-gradient(180deg, rgba(123,228,149,0.1), rgba(123,228,149,0.02)); border:1px solid rgba(123,228,149,0.12)}\n    .floatingToken.kind-op{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.03)}\n\n    /* AST display */\n    .ast{\n      position:absolute;\n      left:61%;\n      top:36%;\n      width:260px;\n      height:200px;\n      pointer-events:none;\n      z-index:40;\n    }\n    .astNode{\n      position:absolute;\n      width:86px;height:44px;border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      display:flex;align-items:center;justify-content:center;\n      font-weight:700;font-size:13px;\n      color:#eff8ff;\n      transform:scale(.2) translateY(20px);\n      opacity:0;\n      box-shadow: 0 8px 30px rgba(4,8,18,0.6);\n    }\n    .astNode.root{left:86px; top:12px}\n    .astNode.left{left:8px; top:88px}\n    .astNode.right{left:164px; top:88px}\n\n    .connector{\n      position:absolute;\n      width:260px;height:200px;left:0;top:0;\n      pointer-events:none;\n      z-index:30;\n      opacity:0;\n      transition:opacity .28s linear;\n    }\n\n    /* evaluator orbs */\n    .orb{\n      position:absolute;\n      width:18px;height:18px;border-radius:50%;\n      background: radial-gradient(circle at 30% 30%, #ffffff, var(--accent));\n      box-shadow:0 8px 26px rgba(122,231,255,0.18), 0 2px 10px rgba(0,0,0,0.6);\n      transform:translate(-50%,-50%) scale(.9);\n      opacity:0;\n      pointer-events:none;\n      z-index:55;\n    }\n\n    /* Output console */\n    .outputCard{\n      padding:28px 22px;\n      display:flex;\n      flex-direction:column;\n      justify-content:space-between;\n    }\n    .console{\n      background: linear-gradient(180deg, rgba(12,18,34,0.6), rgba(6,10,18,0.35));\n      border-radius:14px;\n      padding:20px;\n      min-height:300px;\n      font-family:var(--mono);\n      color:#c8f2ff;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: inset 0 -10px 40px rgba(0,0,0,0.35);\n      position:relative;\n      overflow:hidden;\n    }\n    .console .result{\n      font-size:24px;font-weight:800;color:var(--success);\n      display:flex;align-items:center;gap:12px;\n      opacity:0; transform:translateY(8px);\n      transition:opacity .28s ease, transform .28s ease;\n    }\n\n    .console .meta{\n      font-size:12px;color:var(--muted);margin-top:12px;\n    }\n\n    /* subtle animated background shapes */\n    .ambient{\n      position:absolute;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n      filter: blur(40px) saturate(120%);\n      opacity:0.6;\n    }\n    .blob{\n      position:absolute;\n      width:420px;height:420px;border-radius:40%;\n      transform:rotate(28deg);\n      background:linear-gradient(135deg, rgba(140,108,255,0.09), rgba(122,231,255,0.06));\n      left:-80px;top:-60px;\n      mix-blend-mode:screen;\n    }\n    .blob.two{width:260px;height:260px;right:-40px;bottom:-40px;left:auto;top:auto;background:linear-gradient(135deg, rgba(123,228,149,0.05), rgba(122,231,255,0.05));opacity:0.9}\n\n    /* animation classes triggered by JS */\n    .active .floatingToken{opacity:1}\n    .move-to-lexer{transform:translate(var(--dx) , var(--dy)) scale(1.02); transition:transform .9s cubic-bezier(.2,.9,.27,1), opacity .28s}\n    .move-to-parser{transform:translate(var(--dx) , var(--dy)) scale(1.02); transition:transform .9s cubic-bezier(.28,.88,.24,1) .18s, opacity .28s}\n    .move-to-ast{transform:translate(var(--dx) , var(--dy)) scale(.98); transition:transform .9s cubic-bezier(.3,.86,.32,1) .36s, opacity .28s}\n    .move-to-eval{transform:translate(var(--dx) , var(--dy)) scale(.96); transition:transform .9s cubic-bezier(.32,.8,.34,1) .54s, opacity .28s}\n    .fade-away{opacity:0; transform:translate(var(--dx), var(--dy)) scale(.6); transition:transform .7s ease .9s, opacity .5s ease .9s}\n\n    .astNode.show{opacity:1; transform:scale(1) translateY(0); transition: transform .42s cubic-bezier(.2,.9,.27,1), opacity .36s ease}\n    .connector.show{opacity:1}\n\n    .orb.fly{opacity:1; transform:translate(var(--ox), var(--oy)) scale(1); transition: transform .9s cubic-bezier(.2,.9,.27,1) .6s, opacity .3s linear .6s}\n\n    .console .result.show{opacity:1; transform:translateY(0)}\n\n    /* tiny hover micro-interaction */\n    .card:hover .glowRing{filter: blur(26px) saturate(130%); transform:scale(1.02)}\n    .hintTag{\n      padding:8px 12px;border-radius:999px;font-size:12px;background:rgba(255,255,255,0.02); color:var(--muted); border:1px solid rgba(255,255,255,0.02)\n    }\n\n    footer.attribution{\n      position:absolute;bottom:22px;left:48px;right:48px;text-align:center;font-size:12px;color:rgba(255,255,255,0.06);\n      pointer-events:none;\n    }\n\n    @media (max-width:1100px){\n      .stage{grid-template-columns: 1fr; grid-auto-rows: auto; padding:28px; gap:16px}\n      header.appbar{left:20px;right:20px}\n      footer.attribution{left:20px;right:20px}\n      .node-lexer,.node-parser,.node-ast,.node-eval{position:static; transform:translateY(0); margin:12px}\n      .pipeline{min-height:420px}\n      .space{flex-direction:column}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\">\n    <header class=\"appbar\">\n      <div class=\"brand\">\n        <div class=\"logo\">I</div>\n        <div class=\"title\">\n          <h1>Interpreter</h1>\n          <p>Translating code into behavior — an elegant visualization</p>\n        </div>\n      </div>\n\n      <div class=\"controls\">\n        <button class=\"btn\" id=\"runBtn\" title=\"Animate the interpretation\">Animate</button>\n        <button class=\"btn secondary\" id=\"resetBtn\" title=\"Reset visualization\">Reset</button>\n      </div>\n    </header>\n\n    <!-- Left: Code -->\n    <section class=\"card codeCard\">\n      <div class=\"sectionTitle\">\n        <h2>Source</h2>\n        <div class=\"hint\">Readable, human-oriented</div>\n      </div>\n      <div class=\"codeWindow\" id=\"codeWindow\" aria-hidden=\"false\">\n        <div class=\"line\"><div class=\"ln\">1</div><div class=\"code\"><div class=\"tok keyword\">let</div><div class=\"tok func\">square</div><div class=\"tok op\">=</div><div class=\"tok\">x</div><div class=\"tok op\">=&gt;</div><div class=\"tok op\">x</div><div class=\"tok op\">*</div><div class=\"tok op\">x</div></div></div>\n        <div class=\"line\"><div class=\"ln\">2</div><div class=\"code\"><div class=\"tok keyword\">const</div><div class=\"tok\">a</div><div class=\"tok op\">=</div><div class=\"tok num\">6</div></div></div>\n        <div class=\"line\"><div class=\"ln\">3</div><div class=\"code\"><div class=\"tok\">square</div><div class=\"tok op\">(</div><div class=\"tok num\">a</div><div class=\"tok op\">)</div></div></div>\n        <div style=\"position:absolute;right:14px;bottom:12px;font-size:11px;color:var(--muted)\">ES6-like</div>\n      </div>\n\n      <div style=\"display:flex;gap:12px;align-items:center;justify-content:space-between;margin-top:10px\">\n        <div class=\"hintTag\">Interpretive pipeline</div>\n        <div style=\"font-size:12px;color:var(--muted)\">Observe how tokens flow → AST → result</div>\n      </div>\n    </section>\n\n    <!-- Center: Pipeline visualization -->\n    <main class=\"pipeline\" aria-hidden=\"false\">\n      <div class=\"space card\" id=\"centralSpace\" style=\"min-height:520px;align-items:flex-start;overflow:visible\">\n        <div class=\"glowRing\"></div>\n\n        <div class=\"stageNode node-lexer\" id=\"nodeLexer\" aria-hidden=\"true\">\n          <div class=\"big\">LEXER</div>\n          <div class=\"label\">tokenize</div>\n        </div>\n\n        <div class=\"stageNode node-parser\" id=\"nodeParser\" aria-hidden=\"true\">\n          <div class=\"big\">PARSER</div>\n          <div class=\"label\">build AST</div>\n        </div>\n\n        <div class=\"stageNode node-ast\" id=\"nodeAst\" aria-hidden=\"true\">\n          <div class=\"big\">AST</div>\n          <div class=\"label\">structured tree</div>\n        </div>\n\n        <div class=\"stageNode node-eval\" id=\"nodeEval\" aria-hidden=\"true\">\n          <div class=\"big\">EVALUATOR</div>\n          <div class=\"label\">compute</div>\n        </div>\n\n        <!-- AST visual area -->\n        <div class=\"ast\" id=\"ast\">\n          <svg class=\"connector\" viewBox=\"0 0 260 200\" id=\"connectorSvg\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7ae7ff\" stop-opacity=\"0.8\" />\n                <stop offset=\"1\" stop-color=\"#8c6cff\" stop-opacity=\"0.85\" />\n              </linearGradient>\n            </defs>\n            <path d=\"M130 36 C110 64, 54 90, 30 110\" stroke=\"url(#g1)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.9\"/>\n            <path d=\"M130 36 C150 64, 206 90, 230 110\" stroke=\"url(#g1)\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.9\"/>\n          </svg>\n\n          <div class=\"astNode root\" id=\"astRoot\">CALL</div>\n          <div class=\"astNode left\" id=\"astLeft\">square</div>\n          <div class=\"astNode right\" id=\"astRight\">36</div>\n        </div>\n\n        <!-- floating tokens will be injected here -->\n        <div id=\"movingLayer\" style=\"position:absolute;left:0;top:0;right:0;bottom:0;pointer-events:none\"></div>\n\n        <!-- evaluator orbs -->\n        <div class=\"orb\" id=\"orb1\"></div>\n        <div class=\"orb\" id=\"orb2\"></div>\n      </div>\n    </main>\n\n    <!-- Right: Output / Console -->\n    <aside class=\"card outputCard\">\n      <div class=\"sectionTitle\">\n        <h2>Output</h2>\n        <div class=\"hint\">Interpreter result</div>\n      </div>\n\n      <div class=\"console\" id=\"console\">\n        <div style=\"display:flex;align-items:center;gap:12px;justify-content:space-between\">\n          <div>\n            <div style=\"font-size:13px;color:var(--muted)\">Console</div>\n            <div style=\"font-size:11px;color:rgba(255,255,255,0.06);margin-top:8px\">Purely visual — no side effects</div>\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center\">\n            <div style=\"width:12px;height:12px;border-radius:50%;background:var(--success);box-shadow:0 6px 28px rgba(123,228,149,0.12)\"></div>\n            <div style=\"width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 6px 28px rgba(122,231,255,0.08)\"></div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:26px\">\n          <div class=\"hintTag\" style=\"display:inline-flex\">evaluator</div>\n          <div class=\"result\" id=\"resultText\" style=\"margin-top:22px\">Result: <span style=\"font-family:var(--mono);margin-left:8px\">42</span></div>\n          <div class=\"meta\">Notes: function square(6) → 36</div>\n        </div>\n      </div>\n\n      <div style=\"display:flex;justify-content:flex-end;margin-top:12px;color:var(--muted);font-size:12px\">Deterministic · Stepwise</div>\n    </aside>\n\n    <div class=\"ambient\" aria-hidden=\"true\">\n      <div class=\"blob\"></div>\n      <div class=\"blob two\"></div>\n    </div>\n\n    <footer class=\"attribution\">An evocative concept: observing how an interpreter breathes life into code</footer>\n  </div>\n\n  <script>\n    (function(){\n      const runBtn = document.getElementById('runBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const movingLayer = document.getElementById('movingLayer');\n      const codeWindow = document.getElementById('codeWindow');\n      const centralSpace = document.getElementById('centralSpace');\n      const astRoot = document.getElementById('astRoot');\n      const astLeft = document.getElementById('astLeft');\n      const astRight = document.getElementById('astRight');\n      const connectorSvg = document.getElementById('connectorSvg');\n      const orb1 = document.getElementById('orb1');\n      const orb2 = document.getElementById('orb2');\n      const resultText = document.getElementById('resultText');\n\n      // Predefined tokens with types and text and approximate element positions (line, order)\n      const tokens = [\n        {text:'let', kind:'key', line:1},\n        {text:'square', kind:'fn', line:1},\n        {text:'=', kind:'op', line:1},\n        {text:'x', kind:'op', line:1},\n        {text:'=>', kind:'op', line:1},\n        {text:'x', kind:'op', line:1},\n        {text:'*', kind:'op', line:1},\n        {text:'x', kind:'op', line:1},\n\n        {text:'const', kind:'key', line:2},\n        {text:'a', kind:'op', line:2},\n        {text:'=', kind:'op', line:2},\n        {text:'6', kind:'num', line:2},\n\n        {text:'square', kind:'fn', line:3},\n        {text:'(', kind:'op', line:3},\n        {text:'a', kind:'op', line:3},\n        {text:')', kind:'op', line:3},\n      ];\n\n      let activeTokens = [];\n      let animating = false;\n\n      // utility to find position of the token element in the codeWindow\n      function getTokenPositions(){\n        const lines = Array.from(codeWindow.querySelectorAll('.line'));\n        const pos = [];\n        lines.forEach((lnEl, li) => {\n          const codeEl = lnEl.querySelector('.code');\n          const kids = Array.from(codeEl.children);\n          kids.forEach((k, idx) => {\n            const rect = k.getBoundingClientRect();\n            pos.push({\n              el: k,\n              rect: rect,\n              line: li+1,\n              text: k.textContent,\n              idx\n            });\n          });\n        });\n        return pos;\n      }\n\n      function normalize(v){ return Math.round(v); }\n\n      function createFloatingToken(text, kind){\n        const el = document.createElement('div');\n        el.className = 'floatingToken kind-' + (kind || 'op');\n        el.textContent = text;\n        movingLayer.appendChild(el);\n        return el;\n      }\n\n      function globalToLocalRect(rect, host){\n        const hostRect = host.getBoundingClientRect();\n        return {\n          left: rect.left - hostRect.left,\n          top: rect.top - hostRect.top,\n          width: rect.width,\n          height: rect.height\n        };\n      }\n\n      function positionAt(el, x, y){\n        el.style.left = x + 'px';\n        el.style.top = y + 'px';\n      }\n\n      function clearAnimation(){\n        animating = false;\n        activeTokens.forEach(t => {\n          try{ t.el.remove(); }catch(e){}\n        });\n        activeTokens = [];\n        // reset ast\n        astRoot.classList.remove('show');\n        astLeft.classList.remove('show');\n        astRight.classList.remove('show');\n        connectorSvg.classList.remove('show');\n        orb1.style.opacity = 0;\n        orb2.style.opacity = 0;\n        resultText.classList.remove('show');\n      }\n\n      function animatePipeline(){\n        if(animating) return;\n        animating = true;\n        clearAnimation();\n\n        const pos = getTokenPositions();\n\n        // map tokens order to pos mapping by text and line (best effort)\n        const assignment = [];\n        let pIndex = 0;\n        for(let i=0;i<tokens.length;i++){\n          const t = tokens[i];\n          // find next matching pos on that line\n          const match = pos.find((p, idx) => !assignment.some(a=>a.pIndex===idx) && p.line===t.line && p.text.trim()===t.text);\n          let pidx = match ? pos.indexOf(match) : (pIndex < pos.length ? pIndex : 0);\n          assignment.push({token: t, pIndex: pidx});\n          pIndex++;\n        }\n\n        // compute some anchor points: lexer center, parser center, ast center, eval center, output console\n        const lexerRect = document.getElementById('nodeLexer').getBoundingClientRect();\n        const parserRect = document.getElementById('nodeParser').getBoundingClientRect();\n        const astRect = document.getElementById('ast').getBoundingClientRect();\n        const evalRect = document.getElementById('nodeEval').getBoundingClientRect();\n        const consoleRect = document.getElementById('console').getBoundingClientRect();\n        const spaceRect = centralSpace.getBoundingClientRect();\n        const layerRect = movingLayer.getBoundingClientRect();\n\n        // offsets relative to movingLayer\n        const lexerCenter = { x: lexerRect.left - layerRect.left + lexerRect.width/2, y: lexerRect.top - layerRect.top + lexerRect.height/2 };\n        const parserCenter = { x: parserRect.left - layerRect.left + parserRect.width/2, y: parserRect.top - layerRect.top + parserRect.height/2 };\n        const astCenter = { x: astRect.left - layerRect.left + astRect.width/2, y: astRect.top - layerRect.top + astRect.height/2 };\n        const evalCenter = { x: evalRect.left - layerRect.left + evalRect.width/2, y: evalRect.top - layerRect.top + evalRect.height/2 };\n        const consoleCenter = { x: consoleRect.left + consoleRect.width/2, y: consoleRect.top + consoleRect.height/2 };\n\n        // Start creating floating tokens at positions of their source tokens\n        assignment.forEach((a, i) => {\n          const sourcePos = pos[a.pIndex] ? pos[a.pIndex].rect : null;\n          const f = createFloatingToken(a.token.text, a.token.kind);\n          activeTokens.push({el: f, token: a.token});\n\n          if (sourcePos){\n            const local = globalToLocalRect(sourcePos, movingLayer);\n            // place on same spot\n            positionAt(f, local.left + local.width/2, local.top + local.height/2);\n          } else {\n            // fallback: left side near code window\n            const cwRect = codeWindow.getBoundingClientRect();\n            const layer = movingLayer.getBoundingClientRect();\n            positionAt(f, cwRect.left - layer.left + 40 + (i*6), cwRect.top - layer.top + 40 + ((i%6)*6));\n          }\n        });\n\n        // reveal nodes with soft delays\n        setTimeout(()=> {\n          document.getElementById('nodeLexer').classList.add('pulse');\n        }, 80);\n\n        // Move tokens in stagger to lexer\n        activeTokens.forEach((t, i) => {\n          setTimeout(()=> {\n            const el = t.el;\n            // compute dx/dy relative to initial position\n            const curRect = el.getBoundingClientRect();\n            const layer = movingLayer.getBoundingClientRect();\n            const curCenter = {x: curRect.left - layer.left + curRect.width/2, y: curRect.top - layer.top + curRect.height/2};\n            const dx = (lexerCenter.x - curCenter.x);\n            const dy = (lexerCenter.y - curCenter.y);\n            el.style.setProperty('--dx', dx + 'px');\n            el.style.setProperty('--dy', dy + 'px');\n            el.classList.add('move-to-lexer');\n          }, 60 + i*80);\n        });\n\n        // After reaching lexer, small pause then to parser\n        setTimeout(()=> {\n          // subtle highlight\n          document.getElementById('nodeLexer').animate([\n            { boxShadow: '0 20px 60px rgba(3,8,20,0.5)' },\n            { boxShadow: '0 30px 90px rgba(122,231,255,0.14)' }\n          ], { duration: 520, easing:'cubic-bezier(.2,.9,.27,1)'});\n        }, 700);\n\n        setTimeout(()=> {\n          activeTokens.forEach((t, i) => {\n            const el = t.el;\n            const curRect = el.getBoundingClientRect();\n            const layer = movingLayer.getBoundingClientRect();\n            const curCenter = {x: curRect.left - layer.left + curRect.width/2, y: curRect.top - layer.top + curRect.height/2};\n            const dx = (parserCenter.x - curCenter.x);\n            const dy = (parserCenter.y - curCenter.y);\n            el.style.setProperty('--dx', dx + 'px');\n            el.style.setProperty('--dy', dy + 'px');\n            el.classList.remove('move-to-lexer');\n            el.classList.add('move-to-parser');\n          });\n        }, 900);\n\n        // When tokens arrive at parser reveal AST nodes with choreography\n        setTimeout(()=> {\n          astRoot.classList.add('show');\n          setTimeout(()=> astLeft.classList.add('show'), 220);\n          setTimeout(()=> astRight.classList.add('show'), 340);\n          setTimeout(()=> connectorSvg.classList.add('show'), 300);\n        }, 1600);\n\n        // tokens move to AST positions (spread) - some fade to represent absorption\n        setTimeout(()=> {\n          activeTokens.forEach((t, i) => {\n            const el = t.el;\n            const curRect = el.getBoundingClientRect();\n            const layer = movingLayer.getBoundingClientRect();\n            const curCenter = {x: curRect.left - layer.left + curRect.width/2, y: curRect.top - layer.top + curRect.height/2};\n            // move in the general direction of AST, with slight offset to left or right\n            const side = (i % 2 === 0) ? -1 : 1;\n            const targetX = astCenter.x + side * (30 + (i%3)*12);\n            const targetY = astCenter.y + (20 + (Math.floor(i/3)*8));\n            const dx = (targetX - curCenter.x);\n            const dy = (targetY - curCenter.y);\n            el.style.setProperty('--dx', dx + 'px');\n            el.style.setProperty('--dy', dy + 'px');\n            el.classList.remove('move-to-parser');\n            el.classList.add('move-to-ast');\n            // schedule fade-away to simulate token consumption\n            setTimeout(()=> {\n              el.classList.add('fade-away');\n              setTimeout(()=> {\n                try{ el.remove(); }catch(e){}\n              }, 800);\n            }, 600 + (i*80));\n          });\n        }, 1950);\n\n        // evaluator orbs — fly from AST to evaluator to console\n        setTimeout(()=> {\n          // position orbs at AST center\n          orb1.style.left = (astCenter.x - 8) + 'px';\n          orb1.style.top = (astCenter.y - 8) + 'px';\n          orb2.style.left = (astCenter.x + 12) + 'px';\n          orb2.style.top = (astCenter.y + 10) + 'px';\n\n          // first hop: AST -> Evaluator\n          setTimeout(()=> {\n            orb1.style.setProperty('--ox', (evalCenter.x + 8) + 'px');\n            orb1.style.setProperty('--oy', (evalCenter.y + 8) + 'px');\n            orb1.classList.add('fly');\n          }, 80);\n\n          setTimeout(()=> {\n            orb2.style.setProperty('--ox', (evalCenter.x - 6) + 'px');\n            orb2.style.setProperty('--oy', (evalCenter.y - 6) + 'px');\n            orb2.classList.add('fly');\n          }, 200);\n\n          // second hop: Evaluator -> Console (screen coordinates)\n          setTimeout(()=> {\n            const layer = movingLayer.getBoundingClientRect();\n            const targetX = consoleCenter.x - layer.left + 20;\n            const targetY = consoleCenter.y - layer.top;\n            orb1.style.setProperty('--ox', targetX + 'px');\n            orb1.style.setProperty('--oy', targetY + 'px');\n            orb2.style.setProperty('--ox', (targetX + 12) + 'px');\n            orb2.style.setProperty('--oy', (targetY + 18) + 'px');\n          }, 1250);\n\n          // final: make console show result\n          setTimeout(()=> {\n            resultText.classList.add('show');\n          }, 1800);\n        }, 2500);\n\n        // clean up after animation finishes\n        setTimeout(()=> {\n          animating = false;\n        }, 3600);\n      }\n\n      runBtn.addEventListener('click', animatePipeline);\n      resetBtn.addEventListener('click', clearAnimation);\n\n      // tiny polish: show initial subtle entrance animation\n      window.addEventListener('load', ()=> {\n        document.body.animate([\n          { filter: 'brightness(.92) contrast(0.98)'},\n          { filter: 'brightness(1) contrast(1)'}\n        ], { duration:900, easing:'cubic-bezier(.2,.9,.27,1)'});\n      });\n\n      // focus accessible\n      runBtn.addEventListener('keydown', (e)=> {\n        if(e.key === 'Enter' || e.key === ' ') { e.preventDefault(); animatePipeline(); }\n      });\n      resetBtn.addEventListener('keydown', (e)=> {\n        if(e.key === 'Enter' || e.key === ' ') { e.preventDefault(); clearAnimation(); }\n      });\n\n      // initialize\n      clearAnimation();\n      // reveal subtle starter AST nodes with low opacity to invite observation\n      setTimeout(()=> {\n        astRoot.style.opacity = 0.65;\n        astLeft.style.opacity = 0.65;\n        astRight.style.opacity = 0.65;\n        astRoot.style.transform = 'scale(.94)';\n        astLeft.style.transform = 'scale(.94)';\n        astRight.style.transform = 'scale(.94)';\n      }, 600);\n\n    })();\n  </script>\n</body>\n</html>"
  },
