    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Binary Search — Visualized</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Playfair+Display:wght@600;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#071026;\n    --bg-2:#0f1530;\n    --accent-1:#6EE7C3;\n    --accent-2:#8B5CF6;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.65);\n    --soft: rgba(255,255,255,0.03);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(139,92,246,0.12), transparent 6%),\n                radial-gradient(900px 400px at 90% 90%, rgba(110,231,195,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg-1) 0%, var(--bg-2) 100%);\n    color: #eaf6ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:40px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Main card */\n  .stage{\n    width:100%;\n    max-width:1100px;\n    border-radius:18px;\n    padding:36px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    box-shadow:\n      0 8px 30px rgba(2,6,23,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Decorative animated blobs */\n  .stage::before, .stage::after{\n    content:\"\";\n    position:absolute;\n    border-radius:50%;\n    filter:blur(36px);\n    opacity:0.12;\n    pointer-events:none;\n  }\n  .stage::before{\n    width:520px;height:520px;\n    left:-10%;\n    top:-20%;\n    background: radial-gradient(circle at 30% 30%, rgba(139,92,246,0.9), transparent 35%);\n    animation: floatA 12s ease-in-out infinite;\n  }\n  .stage::after{\n    width:420px;height:420px;\n    right:-10%;\n    bottom:-20%;\n    background: radial-gradient(circle at 70% 70%, rgba(110,231,195,0.9), transparent 35%);\n    animation: floatB 10s ease-in-out infinite;\n  }\n  @keyframes floatA{0%{transform:translateY(0)rotate(0deg)}50%{transform:translateY(18px)rotate(6deg)}100%{transform:translateY(0)rotate(0deg)}}\n  @keyframes floatB{0%{transform:translateY(0)rotate(0deg)}50%{transform:translateY(-14px)rotate(-6deg)}100%{transform:translateY(0)rotate(0deg)}}\n\n  .header{\n    display:flex;\n    gap:24px;\n    align-items:center;\n    margin-bottom:18px;\n  }\n  .title{\n    flex:1;\n  }\n  .title h1{\n    margin:0;\n    font-family: 'Playfair Display', serif;\n    font-size:28px;\n    letter-spacing:0.4px;\n    color: #ffffff;\n    text-shadow: 0 6px 18px rgba(139,92,246,0.12);\n  }\n  .title p{\n    margin:6px 0 0 0;\n    color:var(--muted);\n    font-size:13px;\n    line-height:1.25;\n  }\n\n  .controls{\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n\n  .btn{\n    -webkit-tap-highlight-color: transparent;\n    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.06);\n    color: white;\n    padding:10px 16px;\n    border-radius:12px;\n    cursor:pointer;\n    font-weight:600;\n    font-size:13px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition: transform .18s cubic-bezier(.2,.9,.3,1), box-shadow .18s;\n    box-shadow: 0 6px 18px rgba(3,6,23,0.45);\n  }\n  .btn:active{transform:translateY(1px)}\n  .btn .dot{\n    width:10px;height:10px;border-radius:50%;\n    background:linear-gradient(180deg,var(--accent-1),var(--accent-2));\n    box-shadow:0 6px 18px rgba(139,92,246,0.18), 0 1px 0 rgba(255,255,255,0.05) inset;\n  }\n\n  /* Layout */\n  .content{\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:28px;\n    align-items:start;\n  }\n\n  .visual{\n    padding:26px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    border:1px solid rgba(255,255,255,0.02);\n    position:relative;\n    min-height:320px;\n  }\n\n  /* array row */\n  .array-wrap{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:22px 16px;\n    gap:18px;\n    transform-style:preserve-3d;\n    perspective:800px;\n    margin-top:16px;\n  }\n\n  .node{\n    width:72px;height:72px;\n    border-radius:16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-size:18px;\n    font-weight:700;\n    color:#eaf6ff;\n    position:relative;\n    transition: transform .65s cubic-bezier(.2,.9,.3,1), opacity .6s ease, filter .6s ease, box-shadow .6s;\n    box-shadow: 0 8px 20px rgba(2,6,23,0.55);\n    border: 1px solid rgba(255,255,255,0.03);\n    user-select:none;\n  }\n  .node::before{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    border-radius:inherit;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), transparent);\n    pointer-events:none;\n  }\n\n  .node.mark{\n    transform: translateY(-10px) scale(1.06);\n    box-shadow: 0 18px 40px rgba(139,92,246,0.16), 0 4px 10px rgba(0,0,0,0.5);\n    border: 1px solid rgba(139,92,246,0.5);\n  }\n\n  .node.dim{\n    opacity:0.18;\n    transform: scale(.96);\n    filter: blur(.6px) saturate(.8);\n    box-shadow:none;\n  }\n\n  .node.target{\n    border: 1px solid rgba(110,231,195,0.8);\n    background: linear-gradient(180deg, rgba(110,231,195,0.06), rgba(139,92,246,0.02));\n    color:#defcf0;\n    box-shadow: 0 12px 30px rgba(110,231,195,0.08), 0 2px 10px rgba(139,92,246,0.06);\n  }\n\n  /* mid halo */\n  .halo{\n    position:absolute;\n    height:46px;width:46px;border-radius:50%;\n    left:50%;transform:translateX(-50%);\n    top:40%;\n    pointer-events:none;\n    opacity:0;\n  }\n  .halo.show{\n    opacity:1;\n    animation: pulseHalo 1100ms ease-in-out both;\n  }\n  @keyframes pulseHalo{\n    0%{transform:translateX(-50%) scale(.88); box-shadow:0 0 0 0 rgba(139,92,246,0.28)}\n    40%{transform:translateX(-50%) scale(1.06); box-shadow:0 0 0 26px rgba(139,92,246,0.03)}\n    100%{transform:translateX(-50%) scale(1); box-shadow:0 0 0 0 rgba(139,92,246,0)}\n  }\n\n  /* overlay range band */\n  .band{\n    position:absolute;\n    left:10%;\n    right:10%;\n    top:48%;\n    height:110px;\n    transform:translateY(-50%);\n    pointer-events:none;\n    border-radius:16px;\n    transition: left .7s cubic-bezier(.2,.9,.3,1), right .7s cubic-bezier(.2,.9,.3,1);\n    background: linear-gradient(90deg, rgba(139,92,246,0.06), rgba(110,231,195,0.03));\n    mix-blend-mode: overlay;\n    opacity:0.85;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  /* right panel */\n  .panel{\n    padding:22px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    min-height:320px;\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n  }\n  .panel h3{\n    margin:0;\n    font-size:14px;\n    color:#fff;\n    font-weight:700;\n  }\n  .panel .meta{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .log{\n    flex:1;\n    background: linear-gradient(180deg, rgba(255,255,255,0.008), rgba(255,255,255,0.006));\n    border-radius:12px;\n    padding:14px;\n    overflow:auto;\n    font-size:13px;\n    color:var(--muted);\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n  .log p{\n    margin:0 0 8px 0;\n    line-height:1.35;\n  }\n\n  .stat{\n    display:flex;\n    gap:10px;\n    justify-content:space-between;\n    align-items:center;\n    padding:10px 14px;\n    border-radius:12px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.02);\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* footer micro */\n  .foot{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    margin-top:14px;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* small responsive */\n  @media (max-width:980px){\n    .content{grid-template-columns:1fr}\n    .panel{order:2}\n  }\n\n  /* subtle flourish for found */\n  .found-glow{\n    position:absolute;\n    left:0;right:0;top:0;bottom:0;\n    pointer-events:none;\n    border-radius:inherit;\n    background: radial-gradient(800px 200px at 50% 30%, rgba(110,231,195,0.08), transparent 10%);\n    opacity:0;\n    transition: opacity .8s ease;\n  }\n  .found-glow.show{opacity:1}\n</style>\n</head>\n<body>\n  <div class=\"stage\" role=\"main\" aria-label=\"Binary Search Visualization\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <h1>Binary Search</h1>\n        <p>Efficiently find a target in a sorted array — visualized with elegant motion and clarity. Observe how the search interval halves each step.</p>\n      </div>\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"runBtn\" class=\"btn\" title=\"Run animation\">\n          <span class=\"dot\" aria-hidden=\"true\"></span>\n          <span id=\"btnLabel\">Animate</span>\n        </button>\n      </div>\n    </div>\n\n    <div class=\"content\">\n      <div class=\"visual\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between\">\n          <div style=\"display:flex;flex-direction:column;gap:6px;\">\n            <div style=\"font-size:12px;color:var(--muted)\">Array</div>\n            <div style=\"font-weight:700;font-size:14px;color:#fff\">Sorted ascending</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div style=\"font-size:12px;color:var(--muted)\">Target</div>\n            <div id=\"targetBadge\" style=\"display:inline-block;margin-top:6px;padding:8px 12px;border-radius:12px;background:linear-gradient(90deg, rgba(110,231,195,0.08), rgba(139,92,246,0.03));font-weight:700;color:#eaf6ff;border:1px solid rgba(255,255,255,0.02)\">—</div>\n          </div>\n        </div>\n\n        <div style=\"position:relative;margin-top:12px;\">\n          <div class=\"band\" id=\"band\"></div>\n          <div class=\"array-wrap\" id=\"arrayWrap\" aria-hidden=\"false\"></div>\n          <div class=\"halo\" id=\"halo\"></div>\n          <div class=\"found-glow\" id=\"foundGlow\"></div>\n        </div>\n\n        <div style=\"margin-top:18px;display:flex;gap:18px;align-items:center;justify-content:center\">\n          <div style=\"font-size:13px;color:var(--muted)\">Iterations</div>\n          <div id=\"iterBadge\" style=\"min-width:42px;text-align:center;padding:8px 12px;border-radius:12px;background:linear-gradient(90deg, rgba(255,255,255,0.014), rgba(255,255,255,0.008));border:1px solid rgba(255,255,255,0.02);font-weight:700\">0</div>\n        </div>\n      </div>\n\n      <aside class=\"panel\" aria-label=\"Details\">\n        <h3>What happens</h3>\n        <div class=\"meta\">\n          <div style=\"display:flex;gap:8px;align-items:center\">\n            <div style=\"width:10px;height:10px;border-radius:50%;background:linear-gradient(180deg,var(--accent-1),var(--accent-2));\"></div>\n            <div style=\"font-size:13px;color:var(--muted)\">Halve the search range each comparison</div>\n          </div>\n          <div style=\"font-size:13px;color:var(--muted)\">Time Complexity: <strong style=\"color:#fff;margin-left:6px\">O(log n)</strong></div>\n        </div>\n\n        <div class=\"log\" id=\"log\" tabindex=\"0\" aria-live=\"polite\">\n          <p>Press Animate to watch a binary search locate the target. The middle element is compared and the irrelevant half fades away.</p>\n        </div>\n\n        <div class=\"stat\" aria-hidden=\"true\">\n          <div>Array size</div>\n          <div id=\"nStat\">15</div>\n        </div>\n\n        <div class=\"foot\">\n          <div style=\"color:var(--muted)\">Visual demo • Minimal controls</div>\n          <div style=\"color:var(--muted)\">Made with care</div>\n        </div>\n      </aside>\n    </div>\n  </div>\n\n<script>\n(() => {\n  const runBtn = document.getElementById('runBtn');\n  const btnLabel = document.getElementById('btnLabel');\n  const arrayWrap = document.getElementById('arrayWrap');\n  const logEl = document.getElementById('log');\n  const targetBadge = document.getElementById('targetBadge');\n  const iterBadge = document.getElementById('iterBadge');\n  const nStat = document.getElementById('nStat');\n  const band = document.getElementById('band');\n  const halo = document.getElementById('halo');\n  const foundGlow = document.getElementById('foundGlow');\n\n  // Config\n  const arr = [3,7,12,16,22,27,31,36,41,47,52,58,63,69,75]; // sorted\n  const N = arr.length;\n  nStat.textContent = N;\n  let timeouts = [];\n  let running = false;\n  let lastTarget = null;\n\n  function clearTimeouts(){\n    timeouts.forEach(t => clearTimeout(t));\n    timeouts = [];\n  }\n\n  // Create node elements\n  function renderArray(){\n    arrayWrap.innerHTML = '';\n    arr.forEach((v, idx) => {\n      const node = document.createElement('div');\n      node.className = 'node';\n      node.dataset.index = idx;\n      node.dataset.value = v;\n      node.innerHTML = '<div style=\"text-align:center\"><div style=\"font-size:11px;color:var(--muted);font-weight:600;margin-bottom:6px\">i=' + idx + '</div><div style=\"font-size:18px\">' + v + '</div></div>';\n      arrayWrap.appendChild(node);\n    });\n    // initial band left/right to include full array\n    updateBand(0, N-1);\n  }\n\n  function log(msg, mute){\n    const p = document.createElement('p');\n    p.textContent = msg;\n    logEl.appendChild(p);\n    if (!mute) logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // Update band position to cover indices l..r visually\n  function updateBand(l, r){\n    const children = Array.from(arrayWrap.children);\n    if (children.length === 0) return;\n    const leftNode = children[l];\n    const rightNode = children[r];\n    const wrapRect = arrayWrap.getBoundingClientRect();\n    const leftRect = leftNode.getBoundingClientRect();\n    const rightRect = rightNode.getBoundingClientRect();\n    const leftPos = leftRect.left - wrapRect.left;\n    const rightPos = rightRect.right - wrapRect.left;\n    // set band left/right as percentage relative to arrayWrap\n    const pad = 8;\n    const leftPct = Math.max(0, (leftPos - pad) / wrapRect.width) * 100;\n    const rightPct = Math.min(100, 100 - (wrapRect.width - rightPos - pad) / wrapRect.width * 100);\n    band.style.left = leftPct + '%';\n    band.style.right = (100 - rightPct) + '%';\n  }\n\n  // Determine target randomly but different from last\n  function chooseTarget(){\n    let t = arr[Math.floor(Math.random()*arr.length)];\n    if (t === lastTarget){\n      // pick neighbor if same - ensure change\n      const idx = arr.indexOf(t);\n      t = arr[(idx + 3) % arr.length];\n    }\n    lastTarget = t;\n    return t;\n  }\n\n  // Animation: sequence of steps using real binary search operations\n  function animateSearch(){\n    clearTimeouts();\n    running = true;\n    runBtn.disabled = true;\n    runBtn.style.opacity = 0.92;\n    btnLabel.textContent = 'Running...';\n\n    // reset visuals\n    const nodes = Array.from(arrayWrap.children);\n    nodes.forEach(n => {\n      n.classList.remove('dim','mark','target');\n      n.style.transitionDelay = '0ms';\n    });\n    foundGlow.classList.remove('show');\n    halo.classList.remove('show');\n    iterBadge.textContent = '0';\n\n    const target = chooseTarget();\n    targetBadge.textContent = target;\n\n    logEl.innerHTML = '';\n    log('Start binary search for target ' + target + '.');\n    let l = 0, r = N - 1;\n    let iter = 0;\n\n    // Visual update initial band\n    updateBand(l, r);\n\n    // Steps array for deterministic scheduling\n    const steps = [];\n    while (l <= r){\n      const mid = Math.floor((l + r) / 2);\n      steps.push({l, r, mid});\n      if (arr[mid] === target){ break; }\n      if (arr[mid] < target){ l = mid + 1; } else { r = mid - 1; }\n    }\n\n    // If target absent (shouldn't here) we still animate until l>r. But target is in arr.\n    // Schedule display\n    let time = 200; // initial delay\n    const stepDelay = 1100;\n\n    steps.forEach((s, k) => {\n      const t1 = setTimeout(() => {\n        const {l, r, mid} = s;\n        iter = k + 1;\n        iterBadge.textContent = String(iter);\n        log('Iteration ' + iter + ': examine mid index ' + mid + ' (value ' + arr[mid] + ').');\n        // dim irrelevant nodes\n        const nodesAll = Array.from(arrayWrap.children);\n        nodesAll.forEach((n, idx) => {\n          n.classList.remove('mark');\n          n.classList.remove('target');\n          if (idx < l || idx > r){\n            n.classList.add('dim');\n          } else {\n            n.classList.remove('dim');\n          }\n        });\n        // mark mid\n        const midNode = nodesAll[mid];\n        midNode.classList.add('mark');\n        // halo position over mid\n        const wrapRect = arrayWrap.getBoundingClientRect();\n        const midRect = midNode.getBoundingClientRect();\n        const left = (midRect.left + midRect.right)/2 - wrapRect.left;\n        halo.style.left = left + 'px';\n        halo.classList.remove('show');\n        // trigger reflow then show\n        void halo.offsetWidth;\n        halo.classList.add('show');\n      }, time);\n      timeouts.push(t1);\n      time += 420;\n\n      const comparison = arr[s.mid] === target ? 'equal' : (arr[s.mid] < target ? 'less' : 'greater');\n\n      const t2 = setTimeout(() => {\n        if (comparison === 'equal'){\n          log('Found target at index ' + s.mid + ' after ' + iter + ' iterations.');\n          // highlight found node and reveal final glow\n          const nodesAll = Array.from(arrayWrap.children);\n          nodesAll.forEach((n, idx) => {\n            if (idx === s.mid){\n              n.classList.add('target');\n              n.classList.remove('dim');\n            } else {\n              n.classList.add('dim');\n            }\n            n.classList.remove('mark');\n          });\n          updateBand(s.mid, s.mid);\n          foundGlow.classList.add('show');\n        } else if (comparison === 'less'){\n          log('Target is less than mid value — discard right half.');\n          // dim right half (mid+1..r)\n          const nodesAll = Array.from(arrayWrap.children);\n          nodesAll.forEach((n, idx) => {\n            if (idx > s.mid && idx <= s.r){\n              n.classList.add('dim');\n            } else if (idx >= s.l && idx <= s.mid){\n              n.classList.remove('dim');\n            }\n            n.classList.remove('mark');\n          });\n          // update band to new right bound = mid\n          updateBand(s.l, s.mid);\n        } else {\n          log('Target is greater than mid value — discard left half.');\n          // dim left half (l..mid-1)\n          const nodesAll = Array.from(arrayWrap.children);\n          nodesAll.forEach((n, idx) => {\n            if (idx < s.mid && idx >= s.l){\n              n.classList.add('dim');\n            } else if (idx <= s.r && idx >= s.mid){\n              n.classList.remove('dim');\n            }\n            n.classList.remove('mark');\n          });\n          // update band to new left bound = mid\n          updateBand(s.mid, s.r);\n        }\n      }, time);\n      timeouts.push(t2);\n      time += stepDelay - 420;\n    });\n\n    // finish sequence: re-enable button\n    const tEnd = setTimeout(() => {\n      running = false;\n      runBtn.disabled = false;\n      btnLabel.textContent = 'Replay';\n      log('Animation complete.');\n    }, time + 320);\n    timeouts.push(tEnd);\n  }\n\n  // Setup initial\n  renderArray();\n  log('Ready. Press Animate to begin a clear demonstration of binary search (one control).');\n\n  // Button action: single button toggles between animate/replay but just animates each click.\n  runBtn.addEventListener('click', () => {\n    if (running) return;\n    // Reset visual state slightly\n    const nodes = Array.from(arrayWrap.children);\n    nodes.forEach(n => {\n      n.classList.remove('dim','mark','target');\n      n.style.transitionDelay = '';\n    });\n    band.style.left = '0%';\n    band.style.right = '0%';\n    foundGlow.classList.remove('show');\n    halo.classList.remove('show');\n    animateSearch();\n  });\n\n  // Recompute band on resize\n  window.addEventListener('resize', () => {\n    // Find current visible bounds — compute from first non-dim to last non-dim\n    const nodes = Array.from(arrayWrap.children);\n    let first = 0, last = nodes.length -1;\n    for (let i=0;i<nodes.length;i++){\n      if (!nodes[i].classList.contains('dim')){ first = i; break;}\n    }\n    for (let i=nodes.length-1;i>=0;i--){\n      if (!nodes[i].classList.contains('dim')){ last = i; break;}\n    }\n    updateBand(first,last);\n  });\n\n  // Small polish: animate the dot in the button slightly to indicate interactivity\n  const dot = runBtn.querySelector('.dot');\n  if(dot){\n    dot.style.boxShadow = '0 6px 18px rgba(139,92,246,0.15)';\n  }\n\n})();\n</script>\n</body>\n</html>"
  },
