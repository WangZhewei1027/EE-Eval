    "content": "<html>\n<head>\n    <title>Set</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: white;\n        }\n        input {\n            width: 50px;\n            height: 20px;\n            padding: 5px;\n            margin-bottom: 10px;\n            border: 1px solid black;\n        }\n        button {\n            width: 100px;\n            height: 30px;\n            padding: 5px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: white;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n        #state {\n            width: 50px;\n            height: 20px;\n            padding: 5px;\n            margin-bottom: 10px;\n            border: 1px solid black;\n            display: inline-block;\n        }\n        #state span {\n            display: block;\n            font-size: 12px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Set</h1>\n    <div id=\"state\"></div>\n    <div>\n        <label for=\"value1\">Value 1:</label>\n        <input type=\"number\" id=\"value1\" value=\"0\">\n    </div>\n    <div>\n        <label for=\"value2\">Value 2:</label>\n        <input type=\"number\" id=\"value2\" value=\"0\">\n    </div>\n    <button id=\"add\">+</button>\n    <button id=\"subtract\">-</button>\n    <button id=\"multiply\">x</button>\n    <button id=\"divide\">/</button>\n    <button id=\"reset\">Reset</button>\n    <button id=\"save\">Save</button>\n    <div id=\"output\"></div>\n\n    <script>\n        let state = {\n            value1: 0,\n            value2: 0\n        };\n\n        const add = document.getElementById('add');\n        const subtract = document.getElementById('subtract');\n        const multiply = document.getElementById('multiply');\n        const divide = document.getElementById('divide');\n        const reset = document.getElementById('reset');\n        const save = document.getElementById('save');\n        const output = document.getElementById('output');\n\n        add.addEventListener('click', () => {\n            state.value1 += 1;\n            updateOutput();\n        });\n\n        subtract.addEventListener('click', () => {\n            if (state.value1 > 0) {\n                state.value1 -= 1;\n                updateOutput();\n            }\n        });\n\n        multiply.addEventListener('click', () => {\n            if (state.value1 > 0 && state.value2 > 0) {\n                state.value1 *= state.value2;\n                updateOutput();\n            }\n        });\n\n        divide.addEventListener('click', () => {\n            if (state.value1 > 0 && state.value2 > 0) {\n                if (state.value2 !== 0) {\n                    state.value1 /= state.value2;\n                    updateOutput();\n                }\n            }\n        });\n\n        reset.addEventListener('click', () => {\n            state.value1 = 0;\n            state.value2 = 0;\n            updateOutput();\n        });\n\n        save.addEventListener('click', () => {\n            const outputText = `Value 1: ${state.value1}, Value 2: ${state.value2}`;\n            localStorage.setItem('set', outputText);\n            alert(`Set saved as ${outputText}`);\n        });\n\n        function updateOutput() {\n            const outputText = `Value 1: ${state.value1}, Value 2: ${state.value2}`;\n            output.textContent = outputText;\n        }\n    </script>\n</body>\n</html>"
