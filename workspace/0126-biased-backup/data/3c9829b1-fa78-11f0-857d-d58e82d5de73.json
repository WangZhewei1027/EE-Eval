    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>PageRank Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Petrona:wght@600&family=Manrope:wght@400;700&display=swap');\n\n  :root {\n    --bg-gradient-start: #0f2027;\n    --bg-gradient-end: #203a43;\n    --node-color: #3aa0d8;\n    --node-highlight: #f5a425;\n    --link-color: #6eb8e1;\n    --link-highlight: #f5a425;\n    --text-primary: #f0f6fc;\n    --text-secondary: #9db7cf;\n    --shadow-glow: rgba(245, 164, 37, 0.6);\n    --shadow-dark: rgba(15, 32, 39, 0.8);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));\n    font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,\n      Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;\n    color: var(--text-primary);\n    overflow: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  main {\n    width: 90vw;\n    max-width: 960px;\n    padding: 2rem 0 3rem;\n  }\n\n  h1 {\n    font-family: 'Petrona', serif;\n    font-weight: 600;\n    font-size: 3.4rem;\n    text-align: center;\n    letter-spacing: 0.08em;\n    color: #f5a425;\n    margin-bottom: 0.15em;\n    user-select: none;\n    text-shadow:\n      0 0 6px #f5a425aa,\n      0 0 12px #f5a425cc;\n  }\n\n  h2 {\n    color: var(--text-secondary);\n    text-align: center;\n    font-weight: 600;\n    font-size: 1.3rem;\n    letter-spacing: 0.06em;\n    margin-bottom: 2rem;\n    user-select: none;\n  }\n\n  #graph-container {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    position: relative;\n    filter: drop-shadow(0 0 10px var(--shadow-glow));\n    border-radius: 1.5rem;\n    background: radial-gradient(ellipse 100% 120% at center, #142c42 35%, #0f1e2a 90%);\n    box-shadow:\n      inset 0 0 45px #0e3c67,\n      0 0 35px var(--shadow-glow);\n    user-select: none;\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n    display: block;\n    overflow: visible;\n  }\n\n  /* Node circles */\n  circle.node {\n    fill: var(--node-color);\n    filter: drop-shadow(0 0 6px #2490dc44);\n    transition: fill 0.6s ease, r 0.6s ease, filter 0.6s ease;\n    cursor: default;\n  }\n\n  circle.node.highlighted {\n    fill: var(--node-highlight);\n    filter: drop-shadow(0 0 14px var(--shadow-glow));\n  }\n\n  /* Link lines */\n  line.link {\n    stroke: var(--link-color);\n    stroke-width: 2px;\n    stroke-linecap: round;\n    opacity: 0.5;\n    transition: stroke 0.6s ease, stroke-width 0.6s ease, opacity 0.6s ease;\n  }\n\n  line.link.highlighted {\n    stroke: var(--link-highlight);\n    stroke-width: 3.5px;\n    opacity: 1;\n  }\n\n  /* Node label text */\n  text.node-label {\n    fill: var(--text-primary);\n    pointer-events: none;\n    font-weight: 700;\n    font-size: 1rem;\n    user-select: none;\n    filter: drop-shadow(0 0 2px #0f2027bb);\n    transition: fill 0.6s ease;\n  }\n\n  /* PageRank value inside nodes */\n  text.pagerank {\n    font-family: 'Manrope', monospace;\n    font-weight: 800;\n    font-size: 0.9rem;\n    fill: white;\n    user-select: none;\n    pointer-events: none;\n    filter: drop-shadow(0 0 4px #0f2027cc);\n    letter-spacing: 0.05em;\n    text-anchor: middle;\n  }\n\n  /* Control panel */\n  #control-panel {\n    margin-top: 2.5rem;\n    text-align: center;\n    user-select: none;\n  }\n\n  button {\n    background: linear-gradient(145deg, #f5a425 0%, #c97e07 100%);\n    border: none;\n    border-radius: 36px;\n    padding: 0.9rem 2.4rem;\n    font-size: 1.05rem;\n    font-weight: 700;\n    color: #142c42;\n    cursor: pointer;\n    box-shadow:\n      0 0 15px #f5a425cc,\n      inset 0 2px 5px #e0a723cc;\n    transition:\n      box-shadow 0.4s ease,\n      background 0.4s ease,\n      color 0.4s ease;\n    user-select: none;\n    letter-spacing: 0.06em;\n  }\n\n  button:hover,\n  button:focus {\n    outline: none;\n    background: linear-gradient(145deg, #f5c04f 0%, #d1990a 100%);\n    box-shadow:\n      0 0 25px #f5c04fcc,\n      inset 0 3px 6px #f7c13fcc;\n    color: #0f1e2a;\n  }\n\n  button:active {\n    transform: scale(0.96);\n    box-shadow:\n      0 0 15px #f5a425cc,\n      inset 0 1px 3px #c37e07cc;\n  }\n\n  /* Footer text */\n  footer {\n    margin-top: 4rem;\n    text-align: center;\n    font-size: 0.86rem;\n    color: var(--text-secondary);\n    user-select: none;\n    font-style: italic;\n    letter-spacing: 0.07em;\n  }\n\n  /* Responsive adjustments */\n  @media (max-width: 600px) {\n    h1 {\n      font-size: 2.4rem;\n    }\n    h2 {\n      font-size: 1rem;\n    }\n    button {\n      font-size: 0.95rem;\n      padding: 0.75rem 2rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <main>\n    <h1>PageRank</h1>\n    <h2>Visualizing the Power of Link Importance</h2>\n    <section id=\"graph-container\" aria-label=\"PageRank visualization graph\">\n      <svg viewBox=\"0 0 800 800\" role=\"img\" aria-describedby=\"desc\" preserveAspectRatio=\"xMidYMid meet\">\n        <desc id=\"desc\">Graph representation of nodes and their PageRank values, with directed edges.</desc>\n\n        <!-- Links -->\n        <line class=\"link\" data-from=\"0\" data-to=\"1\" />\n        <line class=\"link\" data-from=\"0\" data-to=\"2\" />\n        <line class=\"link\" data-from=\"1\" data-to=\"2\" />\n        <line class=\"link\" data-from=\"2\" data-to=\"0\" />\n        <line class=\"link\" data-from=\"2\" data-to=\"3\" />\n        <line class=\"link\" data-from=\"3\" data-to=\"4\" />\n        <line class=\"link\" data-from=\"4\" data-to=\"2\" />\n        <line class=\"link\" data-from=\"4\" data-to=\"5\" />\n        <line class=\"link\" data-from=\"5\" data-to=\"3\" />\n        <line class=\"link\" data-from=\"5\" data-to=\"6\" />\n        <line class=\"link\" data-from=\"6\" data-to=\"4\" />\n\n        <!-- Nodes -->\n        <g class=\"node\" id=\"node-0\" data-index=\"0\" aria-label=\"Page A\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"400\" cy=\"120\" r=\"42\" />\n          <text class=\"node-label\" x=\"400\" y=\"115\" text-anchor=\"middle\">A</text>\n          <text class=\"pagerank\" x=\"400\" y=\"155\" text-anchor=\"middle\">0.15</text>\n        </g>\n\n        <g class=\"node\" id=\"node-1\" data-index=\"1\" aria-label=\"Page B\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"250\" cy=\"280\" r=\"36\" />\n          <text class=\"node-label\" x=\"250\" y=\"275\" text-anchor=\"middle\">B</text>\n          <text class=\"pagerank\" x=\"250\" y=\"310\" text-anchor=\"middle\">0.07</text>\n        </g>\n\n        <g class=\"node\" id=\"node-2\" data-index=\"2\" aria-label=\"Page C\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"520\" cy=\"290\" r=\"48\" />\n          <text class=\"node-label\" x=\"520\" y=\"285\" text-anchor=\"middle\">C</text>\n          <text class=\"pagerank\" x=\"520\" y=\"320\" text-anchor=\"middle\">0.22</text>\n        </g>\n\n        <g class=\"node\" id=\"node-3\" data-index=\"3\" aria-label=\"Page D\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"660\" cy=\"460\" r=\"33\" />\n          <text class=\"node-label\" x=\"660\" y=\"455\" text-anchor=\"middle\">D</text>\n          <text class=\"pagerank\" x=\"660\" y=\"485\" text-anchor=\"middle\">0.06</text>\n        </g>\n\n        <g class=\"node\" id=\"node-4\" data-index=\"4\" aria-label=\"Page E\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"380\" cy=\"520\" r=\"40\" />\n          <text class=\"node-label\" x=\"380\" y=\"515\" text-anchor=\"middle\">E</text>\n          <text class=\"pagerank\" x=\"380\" y=\"550\" text-anchor=\"middle\">0.18</text>\n        </g>\n\n        <g class=\"node\" id=\"node-5\" data-index=\"5\" aria-label=\"Page F\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"230\" cy=\"480\" r=\"29\" />\n          <text class=\"node-label\" x=\"230\" y=\"475\" text-anchor=\"middle\">F</text>\n          <text class=\"pagerank\" x=\"230\" y=\"505\" text-anchor=\"middle\">0.05</text>\n        </g>\n\n        <g class=\"node\" id=\"node-6\" data-index=\"6\" aria-label=\"Page G\" role=\"listitem\" tabindex=\"0\">\n          <circle class=\"node\" cx=\"130\" cy=\"350\" r=\"32\" />\n          <text class=\"node-label\" x=\"130\" y=\"345\" text-anchor=\"middle\">G</text>\n          <text class=\"pagerank\" x=\"130\" y=\"375\" text-anchor=\"middle\">0.07</text>\n        </g>\n      </svg>\n    </section>\n\n    <div id=\"control-panel\" aria-label=\"PageRank control panel\">\n      <button id=\"animate-btn\" aria-pressed=\"false\" aria-label=\"Animate PageRank iterations\">Animate Iterations</button>\n    </div>\n  </main>\n  <footer>\n    &copy; 2024 &mdash; PageRank Visualization Demo\n  </footer>\n\n<script>\n(() => {\n  // Graph data structure\n  const nodes = [\n    { id: \"A\", index: 0, links: [1, 2] },\n    { id: \"B\", index: 1, links: [2] },\n    { id: \"C\", index: 2, links: [0, 3] },\n    { id: \"D\", index: 3, links: [4] },\n    { id: \"E\", index: 4, links: [2, 5] },\n    { id: \"F\", index: 5, links: [3, 6] },\n    { id: \"G\", index: 6, links: [4] }\n  ];\n\n  const numNodes = nodes.length;\n  const damping = 0.85;\n  const tolerance = 0.0001;\n  const maxIterations = 30;\n\n  // SVG Elements references\n  const svg = document.querySelector('svg');\n  const animateBtn = document.getElementById('animate-btn');\n\n  // Store circle and pagerank text references for quick access\n  const nodeCircles = [];\n  const nodeRankTexts = [];\n\n  for (let i = 0; i < numNodes; i++) {\n    nodeCircles[i] = svg.querySelector(`#node-${i} circle.node`);\n    nodeRankTexts[i] = svg.querySelector(`#node-${i} text.pagerank`);\n  }\n\n  // Compute adjacency matrix (stochastic)\n  // We represent the graph as an adjacency matrix M where M[j][i] = 1/outboundLinks(j) if there's a link j->i\n  // PageRank vector p is column vector, satisfying p = damping * M * p + (1-damping) * teleportation\n\n  // Build matrix M as 2D array (size numNodes x numNodes)\n  const M = Array.from({ length: numNodes }, () => Array(numNodes).fill(0));\n\n  for (let j = 0; j < numNodes; j++) {\n    const outLinks = nodes[j].links;\n    const outDegree = outLinks.length;\n    if (outDegree === 0) {\n      // Dangling node distributes uniformly\n      for (let i = 0; i < numNodes; i++) {\n        M[i][j] = 1 / numNodes;\n      }\n    } else {\n      for (const dest of outLinks) {\n        M[dest][j] = 1 / outDegree;\n      }\n    }\n  }\n\n  // Initialize PageRank vector with uniform probability\n  let p = Array(numNodes).fill(1 / numNodes);\n\n  // States for animation\n  let isAnimating = false;\n  let currentIter = 0;\n  let intervalId = null;\n\n  // Utility: format pagerank to 2 decimals as string\n  function formatPR(value) {\n    return value.toFixed(3);\n  }\n\n  // Update node visuals for PageRank values and size\n  function updateVisuals(rankVector) {\n    const maxPR = Math.max(...rankVector);\n    const minPR = Math.min(...rankVector);\n\n    // Map PageRank to radius range 29 to 48 (original radii)\n    const minRadius = 29;\n    const maxRadius = 48;\n    const rangePR = maxPR - minPR || 1;\n\n    for (let i = 0; i < numNodes; i++) {\n      const normValue = (rankVector[i] - minPR) / rangePR;\n      const radius = minRadius + normValue * (maxRadius - minRadius);\n      nodeCircles[i].setAttribute('r', radius.toFixed(1));\n\n      // Animate color glow intensity by ranking\n      const glowStrength = 0.4 + 0.6 * normValue;\n      nodeCircles[i].style.filter = `drop-shadow(0 0 ${6 + 14 * glowStrength}px rgb(245,164,37,${glowStrength}))`;\n\n      // Update text (PageRank value)\n      nodeRankTexts[i].textContent = formatPR(rankVector[i]);\n    }\n  }\n\n  // Ease function for animation steps\n  function lerp(a, b, t) {\n    return a + (b - a) * t;\n  }\n\n  // Smooth animate a tick between two rank vectors\n  function animateTick(fromPR, toPR, duration = 1200) {\n    return new Promise((resolve) => {\n      const startMs = performance.now();\n\n      function step(time) {\n        const elapsed = time - startMs;\n        const t = Math.min(elapsed / duration, 1);\n        const interp = fromPR.map((v,i) => lerp(v, toPR[i], t));\n\n        updateVisuals(interp);\n\n        if (t < 1) {\n          requestAnimationFrame(step);\n        } else {\n          resolve();\n        }\n      }\n      requestAnimationFrame(step);\n    });\n  }\n\n  // Single iteration of PageRank\n  function pageRankIteration(prVec) {\n    const newPR = new Array(numNodes).fill(0);\n    for (let i = 0; i < numNodes; i++) {\n      let sum = 0;\n      for (let j = 0; j < numNodes; j++) {\n        sum += M[i][j] * prVec[j];\n      }\n      newPR[i] = damping * sum + (1 - damping) / numNodes;\n    }\n    return newPR;\n  }\n\n  // Animate full iterations\n  async function animateIterations() {\n    if (isAnimating) return;\n    isAnimating = true;\n    animateBtn.setAttribute('aria-pressed', 'true');\n    animateBtn.textContent = 'Animating…';\n\n    let prevPR = p;\n    for (currentIter = 1; currentIter <= maxIterations; currentIter++) {\n      const nextPR = pageRankIteration(prevPR);\n      await animateTick(prevPR, nextPR);\n\n      // Check convergence (L1 norm)\n      const diff = nextPR.reduce((acc, val, i) => acc + Math.abs(val - prevPR[i]), 0);\n      prevPR = nextPR;\n\n      if (diff < tolerance) break;\n    }\n    p = prevPR;\n\n    animateBtn.textContent = 'Animate Iterations';\n    animateBtn.setAttribute('aria-pressed', 'false');\n    isAnimating = false;\n  }\n\n  // Initialize visuals on page load\n  updateVisuals(p);\n\n  // Event listener for button\n  animateBtn.addEventListener('click', () => {\n    if (!isAnimating) {\n      animateIterations();\n    }\n  });\n\n  // Draw arrow markers on links\n  function setupArrowMarkers() {\n    const ns = \"http://www.w3.org/2000/svg\";\n\n    // Create defs if not exist\n    let defs = svg.querySelector('defs');\n    if (!defs) {\n      defs = document.createElementNS(ns, 'defs');\n      svg.insertBefore(defs, svg.firstChild);\n    }\n\n    // Marker for arrowhead\n    let marker = defs.querySelector('#arrowhead');\n    if (!marker) {\n      marker = document.createElementNS(ns, 'marker');\n      marker.setAttribute('id', 'arrowhead');\n      marker.setAttribute('markerWidth', '7');\n      marker.setAttribute('markerHeight', '7');\n      marker.setAttribute('refX', '5');\n      marker.setAttribute('refY', '3.5');\n      marker.setAttribute('orient', 'auto');\n      marker.setAttribute('markerUnits', 'strokeWidth');\n\n      const path = document.createElementNS(ns, 'path');\n      path.setAttribute('d', 'M0,0 L7,3.5 L0,7 Z');\n      path.setAttribute('fill', 'var(--link-color)');\n      marker.appendChild(path);\n      defs.appendChild(marker);\n    }\n\n    // Apply marker-end to all links\n    const lines = svg.querySelectorAll('line.link');\n    lines.forEach(line => {\n      line.setAttribute('marker-end', 'url(#arrowhead)');\n    });\n  }\n\n  // Position links properly and shorten lines so arrows don't overlap nodes\n  function adjustLinkPositions() {\n    const padding = 4; // small padding away from node edge\n    for (const line of svg.querySelectorAll('line.link')) {\n      const fromIndex = +line.dataset.from;\n      const toIndex = +line.dataset.to;\n      const fromNode = svg.querySelector(`#node-${fromIndex} circle.node`);\n      const toNode = svg.querySelector(`#node-${toIndex} circle.node`);\n\n      if (!fromNode || !toNode) continue;\n\n      const x1 = +fromNode.getAttribute('cx');\n      const y1 = +fromNode.getAttribute('cy');\n      const r1 = +fromNode.getAttribute('r');\n\n      const x2 = +toNode.getAttribute('cx');\n      const y2 = +toNode.getAttribute('cy');\n      const r2 = +toNode.getAttribute('r');\n\n      const dx = x2 - x1;\n      const dy = y2 - y1;\n      const dist = Math.hypot(dx, dy);\n\n      if (dist === 0) {\n        line.setAttribute('x1', x1);\n        line.setAttribute('y1', y1);\n        line.setAttribute('x2', x2);\n        line.setAttribute('y2', y2);\n        continue;\n      }\n\n      // shorten line start and end by radius + padding\n      const ratioStart = (r1 + padding) / dist;\n      const ratioEnd = (r2 + padding + 6) / dist; // +6 for arrow size approx\n\n      const newX1 = x1 + dx * ratioStart;\n      const newY1 = y1 + dy * ratioStart;\n      const newX2 = x2 - dx * ratioEnd;\n      const newY2 = y2 - dy * ratioEnd;\n\n      line.setAttribute('x1', newX1.toFixed(1));\n      line.setAttribute('y1', newY1.toFixed(1));\n      line.setAttribute('x2', newX2.toFixed(1));\n      line.setAttribute('y2', newY2.toFixed(1));\n    }\n  }\n\n  setupArrowMarkers();\n  adjustLinkPositions();\n\n  // Accessibility note: focus outlines for nodes\n  const nodeGroups = svg.querySelectorAll('g.node');\n  nodeGroups.forEach(g => {\n    g.addEventListener('focus', () => {\n      const circle = g.querySelector('circle.node');\n      if (circle) {\n        circle.classList.add('highlighted');\n      }\n    });\n    g.addEventListener('blur', () => {\n      const circle = g.querySelector('circle.node');\n      if (circle) {\n        circle.classList.remove('highlighted');\n      }\n    });\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
