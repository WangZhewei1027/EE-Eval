    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Agile Methodology - Visual Experience</title>\n<style>\n  /* Import fonts */\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Playfair+Display:wght@700&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);\n    font-family: 'Poppins', sans-serif;\n    color: #f3f4f6;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  #app {\n    max-width: 1100px;\n    width: 90vw;\n    background: rgba(255 255 255 / 0.06);\n    border-radius: 32px;\n    box-shadow:\n      0 10px 30px rgb(255 255 255 / 0.12),\n      inset 0 0 120px 30px rgb(255 255 255 / 0.05);\n    backdrop-filter: saturate(180%) blur(18px);\n    -webkit-backdrop-filter: saturate(180%) blur(18px);\n    padding: 40px 48px 56px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 48px;\n    align-items: center;\n  }\n\n  /* Title Section */\n  .title-section {\n    grid-column: 1 / 3;\n    text-align: center;\n    margin-bottom: 16px;\n  }\n  .title-section h1 {\n    font-family: 'Playfair Display', serif;\n    font-size: 3.6rem;\n    font-weight: 700;\n    letter-spacing: 0.02em;\n    margin: 0;\n    color: #ffeda6;\n    text-shadow:\n      0 0 5px #ffd66bcc,\n      0 0 20px #ecb542cc;\n    user-select: none;\n  }\n  .title-section p {\n    font-weight: 300;\n    font-size: 1.2rem;\n    color: #cfd3de;\n    max-width: 580px;\n    margin: 8px auto 0;\n    line-height: 1.5;\n    font-style: italic;\n    text-shadow: 0 0 3px #174375aa;\n  }\n\n  /* Graphic / animation area */\n  .graphic {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    perspective: 1200px;\n  }\n\n  /* Agile Cycle Wheels */\n  .wheel {\n    position: absolute;\n    inset: 0;\n    margin: auto;\n    width: 280px;\n    height: 280px;\n    border-radius: 50%;\n    border: 6px solid rgba(255 237 166 / 0.6);\n    box-shadow:\n      0 0 25px 4px #ffeda6aa,\n      inset 0 0 20px 6px #ffeda666;\n    animation: wheel-rotate 40s linear infinite;\n    filter: drop-shadow(0 0 6px #ffd66b88);\n    background:\n      radial-gradient(circle at center, rgba(255 237 166 / 0.26) 30%, transparent 70%);\n    z-index: 100;\n  }\n  .wheel.reverse {\n    border-color: #ecb542cc;\n    animation-direction: reverse;\n    filter: drop-shadow(0 0 8px #ecb542cc);\n    background:\n      radial-gradient(circle at center, rgba(236,181,66,0.3) 30%, transparent 70%);\n  }\n\n  /* Inner icons ring */\n  .icons-ring {\n    position: absolute;\n    top: 50%; left: 50%;\n    width: 220px;\n    height: 220px;\n    margin: -110px 0 0 -110px;\n    pointer-events: none;\n  }\n\n  .icons-ring svg {\n    position: absolute;\n    width: 48px;\n    height: 48px;\n    fill: #ffeda6dd;\n    filter: drop-shadow(0 0 3px #ffd66bcc);\n    transition: transform 0.3s ease;\n  }\n\n  /* Positions of icons around the ring */\n  .icons-ring svg:nth-child(1) { top: 8px; left: 50%; transform: translateX(-50%); }\n  .icons-ring svg:nth-child(2) { top: 45px; right: 14px; }\n  .icons-ring svg:nth-child(3) { top: 110px; right: 8px; }\n  .icons-ring svg:nth-child(4) { bottom: 50px; right: 35px; }\n  .icons-ring svg:nth-child(5) { bottom: 8px; left: 50%; transform: translateX(-50%); }\n  .icons-ring svg:nth-child(6) { bottom: 50px; left: 35px; }\n  .icons-ring svg:nth-child(7) { top: 110px; left: 8px; }\n  .icons-ring svg:nth-child(8) { top: 45px; left: 14px; }\n\n  /* Labels next to icons */\n  .labels {\n    position: absolute;\n    width: 100%;\n    height: 100%;\n    pointer-events: none;\n  }\n  .labels span {\n    position: absolute;\n    color: #ffd66bcc;\n    font-weight: 600;\n    font-size: 1.05rem;\n    text-shadow: 0 0 5px #ecb542cc;\n    white-space: nowrap;\n    font-family: 'Poppins', sans-serif;\n  }\n  /* Label positions */\n  .labels span:nth-child(1) { top: 0; left: 50%; transform: translate(-50%, -100%); }\n  .labels span:nth-child(2) { top: 25%; right: 0; transform: translate(150%, 0); }\n  .labels span:nth-child(3) { top: 50%; right: 0; transform: translate(150%, -50%); }\n  .labels span:nth-child(4) { bottom: 25%; right: 0; transform: translate(150%, 0); }\n  .labels span:nth-child(5) { bottom: 0; left: 50%; transform: translate(-50%, 100%); }\n  .labels span:nth-child(6) { bottom: 25%; left: 0; transform: translate(-150%, 0); }\n  .labels span:nth-child(7) { top: 50%; left: 0; transform: translate(-150%, -50%); }\n  .labels span:nth-child(8) { top: 25%; left: 0; transform: translate(-150%, 0); }\n\n  /* Agile Pillars (center) */\n  .center-circle {\n    position: relative;\n    width: 140px;\n    height: 140px;\n    border-radius: 50%;\n    background: radial-gradient(circle at center, #ffd66b 70%, #ecb542 100%);\n    box-shadow:\n      0 0 20px 6px #ffeda6cc,\n      inset 0 0 18px #ffd66bcc;\n    text-align: center;\n    padding: 12px;\n    user-select: none;\n    filter: drop-shadow(0 0 6px #ecb542cc);\n    cursor: default;\n  }\n\n  .center-circle h2 {\n    margin: 0;\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 1.4rem;\n    color: #3b2f0d;\n    text-shadow: 0 0 4px #6a5816cc;\n  }\n\n  .center-list {\n    margin-top: 8px;\n    font-weight: 600;\n    font-size: 0.9rem;\n    color: #412f08;\n    line-height: 1.3;\n    user-select: none;\n  }\n\n  /* Description Text area */\n  .description {\n    background: rgba(255 237 166 / 0.1);\n    border-radius: 24px;\n    padding: 32px 32px 40px;\n    box-shadow:\n      inset 0 0 40px 4px #ffeda680,\n      0 10px 30px rgb(0 0 0 / 0.1);\n    font-size: 1.12rem;\n    line-height: 1.6;\n    color: #fff9db;\n    font-weight: 300;\n    user-select: none;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n  .description h3 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 2rem;\n    color: #ffdf7a;\n    margin-bottom: 12px;\n    text-shadow: 0 0 6px #ecb542cc;\n  }\n  .description p {\n    margin: 0 0 24px;\n    text-shadow: 0 0 5px #1b3055bb;\n  }\n\n  /* Button */\n  .btn-container {\n    text-align: center;\n    margin-top: auto;\n  }\n  button {\n    background: #ecb542;\n    border: none;\n    outline: none;\n    border-radius: 30px;\n    padding: 12px 38px;\n    font-weight: 600;\n    font-family: 'Poppins', sans-serif;\n    font-size: 1.1rem;\n    cursor: pointer;\n    color: #3b2f0d;\n    box-shadow:\n      0 0 12px #ecb542cc,\n      inset 0 0 10px #ffd66bcc;\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.4s ease,\n      color 0.3s ease,\n      transform 0.3s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: #ffdf7a;\n    box-shadow:\n      0 0 24px #ffeda6cc,\n      inset 0 0 12px #ffd66bcc;\n    color: #614b04;\n    transform: scale(1.07);\n    outline-offset: 3px;\n  }\n\n  /* Animations */\n  @keyframes wheel-rotate {\n    0% { transform: rotate(0turn); }\n    100% { transform: rotate(1turn); }\n  }\n\n  /* Info text transitions */\n  .desc-fade {\n    opacity: 0;\n    transform: translateY(20px);\n    transition: opacity 0.8s ease, transform 0.8s ease;\n    will-change: opacity, transform;\n  }\n  .desc-fade.visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  /* Responsive */\n  @media (max-width: 900px) {\n    #app {\n      grid-template-columns: 1fr;\n      padding: 32px;\n      gap: 40px;\n    }\n    .title-section {\n      grid-column: auto;\n    }\n    .graphic {\n      margin: 0 auto;\n      width: 320px;\n      aspect-ratio: 1/1;\n    }\n    .description {\n      padding: 24px 24px 32px;\n      font-size: 1rem;\n    }\n  }\n  @media (max-width: 480px) {\n    .title-section h1 {\n      font-size: 2.8rem;\n    }\n    .labels span {\n      font-size: 0.9rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <main id=\"app\" role=\"main\" aria-label=\"Agile methodology visual demonstration\">\n    <section class=\"title-section\" aria-live=\"polite\">\n      <h1>Agile Methodology</h1>\n      <p><em>\"Delivering value through iterative collaboration and continuous improvement.\"</em></p>\n    </section>\n\n    <div class=\"graphic\" aria-hidden=\"true\">\n      <div class=\"wheel\" aria-hidden=\"true\"></div>\n      <div class=\"wheel reverse\" aria-hidden=\"true\"></div>\n\n      <div class=\"icons-ring\" aria-hidden=\"true\">\n        <!-- Eight icons representing main Agile phases -->\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Concept\">\n          <path d=\"M12 2a10 10 0 1 0 8.66 5.14l-1.41 1.41A8 8 0 1 1 4 12h2l3-4 3 4h2a8 8 0 0 0-1.14-5.14l-1.41 1.41A6 6 0 1 1 12 6z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Planning\">\n          <path d=\"M3 13h2v-2H3v2zm0 4h2v-2H3v2zM7 7h11v2H7V7zm-4 8h2v-2H3v2zm4 0h11v2H7v-2z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Design\">\n          <path d=\"M19.07 4.93a10 10 0 1 0 1.41 1.41l-6.36 6.36-3-3 6.36-6.36zM7 10h2v10H7z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Development\">\n          <path d=\"M3 12h18v2H3zM7 6h10v2H7zM7 18h10v2H7z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Testing\">\n          <path d=\"M9 16l-4-4 1.41-1.41L9 13.17l7.59-7.59L18 7l-9 9z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Deployment\">\n          <path d=\"M5 20h14v-2H5v2zm7-14v8l5-4-5-4z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Review\">\n          <path d=\"M3 6l3 6-3 6h15v-2H7.97l1.8-4-3-6H3z\"/>\n        </svg>\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\" title=\"Retrospective\">\n          <path d=\"M12 4a8 8 0 1 0 8 8h-2a6 6 0 1 1-6-6v4l5-5-5-5v4z\"/>\n        </svg>\n      </div>\n      <div class=\"labels\" aria-hidden=\"true\">\n        <span>Concept</span>\n        <span>Planning</span>\n        <span>Design</span>\n        <span>Development</span>\n        <span>Testing</span>\n        <span>Deployment</span>\n        <span>Review</span>\n        <span>Retrospective</span>\n      </div>\n      <div class=\"center-circle\" aria-label=\"Core Agile values and pillars\">\n        <h2>Core Values</h2>\n        <div class=\"center-list\" aria-hidden=\"true\">\n          <div>• Individuals & interactions</div>\n          <div>• Working software</div>\n          <div>• Customer collaboration</div>\n          <div>• Responding to change</div>\n        </div>\n      </div>\n    </div>\n\n    <article class=\"description\" aria-live=\"polite\">\n      <h3>About Agile</h3>\n      <p id=\"desc-text\">Agile Methodology emphasizes flexible, iterative development — delivering small, incremental improvements quickly to maximize customer value and adapt to change efficiently.</p>\n      <div class=\"btn-container\">\n        <button id=\"btn-more\" aria-controls=\"desc-text\" aria-expanded=\"false\" aria-label=\"Read more about Agile\">Learn More</button>\n      </div>\n    </article>\n  </main>\n\n<script>\n  (function(){\n    const btn = document.getElementById('btn-more');\n    const desc = document.getElementById('desc-text');\n\n    const texts = [\n      \"Agile Methodology emphasizes flexible, iterative development — delivering small, incremental improvements quickly to maximize customer value and adapt to change efficiently.\",\n      \"It is built on the principles of collaboration, continuous feedback, and adaptive planning, fostering highly responsive teams that prioritize working software and customer satisfaction above all.\",\n      \"The Agile process involves repeated cycles of planning, design, development, testing, deployment, and retrospective analysis to continuously improve and deliver value with each iteration.\"\n    ];\n\n    let currentIndex = 0;\n\n    btn.addEventListener('click', () => {\n      currentIndex = (currentIndex + 1) % texts.length;\n      btn.setAttribute('aria-expanded', currentIndex !== 0);\n      desc.classList.remove('visible');\n      setTimeout(() => {\n        desc.textContent = texts[currentIndex];\n        desc.classList.add('visible');\n      }, 300);\n      // Change button label for toggle effect\n      btn.textContent = (currentIndex === 0) ? \"Learn More\" : \"Show Less\";\n    });\n\n    // Initial fade in\n    desc.classList.add('visible');\n  })();\n</script>\n</body>\n</html>"
