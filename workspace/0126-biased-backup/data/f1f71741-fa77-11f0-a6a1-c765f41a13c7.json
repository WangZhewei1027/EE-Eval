    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Big-Omega (Ω) Notation — Visual Demonstration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@700;900&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071122;\n    --accent-1:#7ee7c7;\n    --accent-2:#7aa2ff;\n    --muted:#9aa7b2;\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.03);\n    --card-shadow: 0 8px 30px rgba(2,6,23,0.7);\n    --glass-border: rgba(255,255,255,0.06);\n    --success:#6ef08a;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(122,162,255,0.08), transparent 10%),\n                radial-gradient(900px 500px at 90% 90%, rgba(126,231,199,0.06), transparent 12%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color:#e6f0f3;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Layout */\n  .wrap{\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap:28px;\n    align-items:center;\n    height:100vh;\n    padding:48px;\n    position:relative;\n  }\n\n  /* Left panel — explanation */\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:30px;\n    box-shadow:var(--card-shadow);\n    border:1px solid var(--glass-border);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:hidden;\n  }\n  .logo{\n    display:flex;\n    gap:16px;\n    align-items:center;\n  }\n  .omega{\n    width:86px;height:86px;\n    display:grid;place-items:center;\n    background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    border-radius:18px;\n    box-shadow: 0 8px 30px rgba(122,162,255,0.08), inset 0 -6px 18px rgba(0,0,0,0.12);\n    transform:rotate(-12deg);\n    flex-shrink:0;\n  }\n  .omega svg{filter:drop-shadow(0 6px 20px rgba(122,162,255,0.12));}\n  .title{\n    display:block;\n  }\n  .title h1{\n    margin:0;\n    font-family:\"Playfair Display\", serif;\n    font-weight:900;\n    letter-spacing:-1px;\n    font-size:22px;\n    color:linear-gradient;\n    line-height:1;\n  }\n  .title p{\n    margin:6px 0 0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .definition{\n    margin-top:22px;\n    font-size:14px;\n    line-height:1.55;\n    color:rgba(230,240,243,0.95);\n  }\n\n  .math-card{\n    margin-top:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border-radius:14px;\n    padding:14px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n  }\n  .expression{\n    display:flex;\n    gap:16px;\n    align-items:center;\n    justify-content:space-between;\n  }\n  .expr-left{\n    font-family: \"Playfair Display\", serif;\n    font-weight:700;\n    font-size:20px;\n    color:#fff;\n  }\n  .expr-right{\n    text-align:right;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .example{\n    margin-top:12px;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  .hint{\n    margin-top:18px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .pill{\n    background:rgba(255,255,255,0.02);\n    padding:8px 12px;\n    border-radius:999px;\n    font-size:13px;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Right panel — visual graph */\n  .vis{\n    position:relative;\n    height:calc(100vh - 96px);\n    min-height:520px;\n    border-radius:22px;\n    overflow:hidden;\n    padding:26px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), transparent 30%);\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow:var(--card-shadow);\n  }\n\n  .vis-header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:10px;\n    margin-bottom:12px;\n  }\n  .vis-header .label{\n    font-weight:600;\n    letter-spacing:0.2px;\n    color:#eaf7f2;\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .vis-header .sub{\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .canvas-wrap{\n    height:calc(100% - 56px);\n    display:flex;\n    align-items:stretch;\n  }\n\n  .graph{\n    flex:1;\n    border-radius:16px;\n    background:\n      linear-gradient(0deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005)),\n      repeating-linear-gradient(90deg, rgba(255,255,255,0.01) 0 1px, transparent 1px 40px);\n    margin-right:18px;\n    padding:18px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Controls area */\n  .controls{\n    width:260px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    padding:12px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .btn{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    gap:10px;\n    padding:10px 14px;\n    border-radius:10px;\n    border:0;\n    cursor:pointer;\n    background:linear-gradient(90deg,var(--accent-2),var(--accent-1));\n    color:#05202a;\n    font-weight:600;\n    box-shadow:0 10px 30px rgba(122,162,255,0.12);\n    transition:transform .18s ease, box-shadow .18s ease, opacity .18s;\n  }\n  .btn:active{transform:translateY(2px)}\n  .btn.ghost{\n    background:transparent;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow:none;\n  }\n  .meta{\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* Graph elements */\n  svg{width:100%; height:100%}\n  .axis{\n    stroke:rgba(255,255,255,0.06);\n    stroke-width:1;\n  }\n  .grid-line{\n    stroke:rgba(255,255,255,0.02);\n    stroke-width:1;\n  }\n  .curve-f{\n    stroke: url(#gradF);\n    stroke-width:3.4;\n    fill:none;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    filter: drop-shadow(0 6px 20px rgba(126,231,199,0.08));\n  }\n  .curve-g{\n    stroke: url(#gradG);\n    stroke-width:3.2;\n    stroke-dasharray:6 8;\n    fill:none;\n    stroke-linecap:round;\n    filter: drop-shadow(0 6px 16px rgba(122,162,255,0.06));\n  }\n  .curve-cg{\n    stroke: rgba(255,255,255,0.12);\n    stroke-width:2.2;\n    stroke-dasharray:3 6;\n    fill:none;\n  }\n  .area-pass{\n    fill: rgba(126,231,199,0.045);\n    transition:opacity .6s ease;\n  }\n  .n0-line{\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1.6;\n    stroke-dasharray:4 6;\n  }\n  .n0-label{\n    font-family:Inter, sans-serif;\n    font-size:12px;\n    fill:var(--muted);\n  }\n  .status-pill{\n    position:absolute;\n    right:40px;\n    top:44px;\n    padding:8px 12px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    font-weight:600;\n    font-size:13px;\n    display:flex;\n    gap:8px;\n    align-items:center;\n  }\n\n  /* Info overlay */\n  .overlay{\n    position:absolute;\n    inset:36px;\n    border-radius:18px;\n    pointer-events:none;\n    display:flex;\n    align-items:flex-end;\n    justify-content:flex-start;\n    padding:34px;\n  }\n  .card-tip{\n    pointer-events:auto;\n    background: linear-gradient(180deg, rgba(8,14,20,0.6), rgba(5,8,10,0.3));\n    border:1px solid rgba(255,255,255,0.04);\n    padding:18px;\n    border-radius:12px;\n    max-width:420px;\n    color:var(--muted);\n    font-size:13px;\n    box-shadow:0 8px 30px rgba(2,6,23,0.6);\n    transform:translateY(12px);\n    opacity:0;\n    transition:opacity .28s ease, transform .28s ease;\n  }\n  .card-tip.show{\n    opacity:1;\n    transform:translateY(0);\n  }\n\n  /* Footer mini */\n  .mini{\n    position:absolute;\n    left:48px;\n    bottom:32px;\n    color:rgba(255,255,255,0.06);\n    font-size:12px;\n    letter-spacing:2px;\n    text-transform:uppercase;\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .wrap{grid-template-columns: 1fr; padding:22px; gap:16px}\n    .graph{margin-right:0}\n    .controls{width:100%}\n    .mini{left:22px}\n  }\n\n  /* subtle animation on omega */\n  @keyframes floaty {\n    0% { transform: rotate(-12deg) translateY(0px) }\n    50% { transform: rotate(-12deg) translateY(-6px) }\n    100% { transform: rotate(-12deg) translateY(0px) }\n  }\n  .omega{animation:floaty 6s ease-in-out infinite}\n\n  /* particle sparkles */\n  .spark{\n    position:absolute;\n    width:6px;height:6px;\n    border-radius:50%;\n    background:linear-gradient(180deg,var(--accent-1),var(--accent-2));\n    opacity:0.12;\n    filter:blur(2px);\n    transform:translate(-50%,-50%) scale(1);\n  }\n\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"panel\" aria-hidden=\"false\">\n    <div class=\"logo\">\n      <div class=\"omega\" title=\"Omega\">\n        <svg viewBox=\"0 0 120 120\" width=\"56\" height=\"56\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"oGrad\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7ee7c7\"/>\n              <stop offset=\"1\" stop-color=\"#7aa2ff\"/>\n            </linearGradient>\n            <filter id=\"g\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"b\"/>\n            </filter>\n          </defs>\n          <g filter=\"url(#g)\">\n            <text x=\"50%\" y=\"58%\" text-anchor=\"middle\" font-family=\"Playfair Display, serif\" font-weight=\"900\"\n              font-size=\"70\" fill=\"url(#oGrad)\">Ω</text>\n          </g>\n        </svg>\n      </div>\n      <div class=\"title\">\n        <h1>Big-Omega Notation</h1>\n        <p>Lower-bound growth: showing how f(n) grows at least as quickly as a multiple of g(n).</p>\n      </div>\n    </div>\n\n    <div class=\"definition\" id=\"def\">\n      Big-Omega (Ω) is used to express a lower bound on the growth of a function. Formally:\n      <div style=\"margin-top:12px;padding:14px;border-radius:12px;background:var(--glass);border:1px solid var(--glass-border)\">\n        There exist positive constants c and n0 such that for all n ≥ n0: f(n) ≥ c · g(n).\n      </div>\n      <div style=\"margin-top:12px;color:var(--muted);font-size:13px;\">\n        This visualization demonstrates the idea: find a constant factor c and a threshold n0 so that f dominates c·g beyond that threshold.\n      </div>\n    </div>\n\n    <div class=\"math-card\" aria-hidden=\"false\">\n      <div class=\"expression\">\n        <div class=\"expr-left\">f(n) = n² + 10n</div>\n        <div class=\"expr-right\">g(n) = n²</div>\n      </div>\n      <div class=\"example\">\n        Example claim: f(n) = Ω(n²). We pick a constant c (visualized on the right). The shaded region shows where f(n) ≥ c·g(n).\n      </div>\n      <div class=\"hint\" style=\"margin-top:12px\">\n        <div class=\"pill\">Constants: c = 0.5</div>\n        <div class=\"pill\">Threshold: n₀ → animated</div>\n      </div>\n    </div>\n\n    <div style=\"margin-top:18px;display:flex;gap:12px\">\n      <button class=\"btn\" id=\"toggleBtn\" aria-pressed=\"false\" title=\"Play / Pause animation\">Pause</button>\n      <button class=\"btn ghost\" id=\"infoBtn\" title=\"Show definition overlay\">Definition</button>\n    </div>\n\n    <div style=\"height:8px\"></div>\n    <div class=\"mini\">MATHEMATICAL VISUALIZATION</div>\n  </div>\n\n  <div class=\"vis\">\n    <div class=\"vis-header\">\n      <div>\n        <div class=\"label\">Graphical Illustration — Big-Omega (Ω)</div>\n        <div class=\"sub\">f(n) (solid) vs. g(n) (dashed) and c·g(n) (thin)</div>\n      </div>\n      <div class=\"status-pill\" id=\"status\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"#f5c26b\"></circle></svg>\n        checking...\n      </div>\n    </div>\n\n    <div class=\"canvas-wrap\">\n      <div class=\"graph\" id=\"graphWrap\">\n        <svg id=\"graph\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"none\" role=\"img\" aria-label=\"Function graph\">\n          <defs>\n            <linearGradient id=\"gradF\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7ee7c7\"/><stop offset=\"1\" stop-color=\"#3bb28f\"/></linearGradient>\n            <linearGradient id=\"gradG\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#a6bfff\"/><stop offset=\"1\" stop-color=\"#7aa2ff\"/></linearGradient>\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n              <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n            </filter>\n            <clipPath id=\"clipArea\"><rect x=\"80\" y=\"40\" width=\"860\" height=\"560\" rx=\"10\"/></clipPath>\n          </defs>\n\n          <!-- faint grid -->\n          <g clip-path=\"url(#clipArea)\">\n            <rect x=\"80\" y=\"40\" width=\"860\" height=\"560\" fill=\"transparent\"></rect>\n            <!-- vertical thin -->\n            <g id=\"grid\">\n              <!-- dynamic grid lines drawn by JS -->\n            </g>\n\n            <!-- curves -->\n            <path id=\"curveF\" class=\"curve-f\"></path>\n            <path id=\"curveG\" class=\"curve-g\"></path>\n            <path id=\"curveCg\" class=\"curve-cg\"></path>\n\n            <!-- shaded area where f >= c*g beyond n0 -->\n            <path id=\"areaPass\" class=\"area-pass\" opacity=\"0\"></path>\n\n            <!-- n0 vertical -->\n            <line id=\"n0line\" class=\"n0-line\" x1=\"0\" x2=\"0\" y1=\"40\" y2=\"600\"></line>\n            <text id=\"n0lbl\" class=\"n0-label\" x=\"0\" y=\"36\">n₀ = 0</text>\n          </g>\n\n          <!-- axes labels outside clip -->\n          <g>\n            <text x=\"70\" y=\"60\" fill=\"#8aa3b2\" font-size=\"12\" font-family=\"Inter\">Y</text>\n            <text x=\"960\" y=\"610\" fill=\"#8aa3b2\" font-size=\"12\" font-family=\"Inter\">n →</text>\n          </g>\n        </svg>\n\n        <!-- overlay tip -->\n        <div class=\"overlay\">\n          <div class=\"card-tip\" id=\"cardTip\">\n            Big-Omega captures a lower bound: there should exist constants c > 0 and n₀ such that for every n ≥ n₀,\n            f(n) ≥ c · g(n). In this animation you can observe the vertical threshold n₀ slide until every point to the right\n            satisfies the inequality — when the check is satisfied the status will turn green.\n          </div>\n        </div>\n\n        <!-- decorative sparkles -->\n        <div id=\"spark1\" class=\"spark\" style=\"left:18%;top:16%;opacity:0.08\"></div>\n        <div id=\"spark2\" class=\"spark\" style=\"left:86%;top:28%;opacity:0.09\"></div>\n        <div id=\"spark3\" class=\"spark\" style=\"left:72%;top:72%;opacity:0.07\"></div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <div class=\"meta\">Animation Controls</div>\n        <div style=\"display:flex;gap:8px\">\n          <button class=\"btn\" id=\"playPause\">Pause</button>\n          <button class=\"btn ghost\" id=\"jumpBtn\">Reset</button>\n        </div>\n        <div style=\"margin-top:10px\" class=\"meta\">Constants</div>\n        <div style=\"display:flex;flex-direction:column;gap:8px;margin-top:6px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div style=\"color:var(--muted);font-size:13px\">Function f(n)</div>\n            <div style=\"font-weight:700\">n² + 10n</div>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div style=\"color:var(--muted);font-size:13px\">g(n)</div>\n            <div style=\"font-weight:700\">n²</div>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div style=\"color:var(--muted);font-size:13px\">chosen c</div>\n            <div style=\"font-weight:700\">0.50</div>\n          </div>\n        </div>\n\n        <div style=\"height:8px\"></div>\n        <div style=\"display:flex;gap:10px;align-items:center\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:linear-gradient(90deg,#7ee7c7,#3bb28f);box-shadow:0 6px 18px rgba(59,178,143,0.12)\"></div>\n          <div style=\"color:var(--muted);font-size:12px\">Shaded area: where f(n) ≥ c·g(n) (to the right of n₀)</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  Visual demonstration script.\n  - Draws f(n) = n^2 + 10n and g(n) = n^2 across a domain\n  - Shows c * g(n) where c = 0.5\n  - Animates a moving threshold n0 that scans left-to-right until \"all\" points to the right satisfy f >= c*g\n  - Minimal interactivity: play/pause and reset\n*/\n\n(function(){\n  // DOM\n  const svg = document.getElementById('graph');\n  const curveF = document.getElementById('curveF');\n  const curveG = document.getElementById('curveG');\n  const curveCg = document.getElementById('curveCg');\n  const areaPass = document.getElementById('areaPass');\n  const n0line = document.getElementById('n0line');\n  const n0lbl = document.getElementById('n0lbl');\n  const status = document.getElementById('status');\n  const cardTip = document.getElementById('cardTip');\n  const infoBtn = document.getElementById('infoBtn');\n  const toggleBtn = document.getElementById('toggleBtn');\n  const playPause = document.getElementById('playPause');\n  const jumpBtn = document.getElementById('jumpBtn');\n  const tipVisibleClass = 'show';\n  const graphWrap = document.getElementById('graphWrap');\n\n  // parameters\n  const width = 860; // px width for plotting (clipped area)\n  const height = 560;\n  const offsetX = 80;\n  const offsetY = 40;\n  const maxN = 100; // domain [0,maxN]\n  const samples = 240; // resolution of curve\n  const c = 0.5; // chosen constant\n  let running = true;\n  let t = 0; // animation normalized 0..1 for n0 position\n  let speed = 0.006; // speed per frame\n  let n0 = 0; // current threshold\n  let satisfied = false;\n\n  // functions\n  function f(n){ return n*n + 10*n; }\n  function g(n){ return n*n; }\n  function cg(n){ return c * g(n); }\n\n  // map n value to svg x\n  function xOf(n){\n    return offsetX + (n / maxN) * width;\n  }\n  // map y value to svg y (invert)\n  // We need to compute dynamic ymax to scale visually\n  let yScaleMax = 1;\n  function yOf(y){\n    // invert: larger y => smaller px\n    return offsetY + height - (y / yScaleMax) * height;\n  }\n\n  // Precompute values for g and f across points and find max\n  const points = [];\n  function computePoints(){\n    points.length = 0;\n    let maxVal = -Infinity;\n    for(let i=0;i<=samples;i++){\n      const n = (i / samples) * maxN;\n      const valF = f(n);\n      const valG = g(n);\n      const valCg = cg(n);\n      maxVal = Math.max(maxVal, valF, valG, valCg);\n      points.push({n, valF, valG, valCg});\n    }\n    yScaleMax = maxVal * 1.12 + 10;\n  }\n\n  // draw grid lines and ticks\n  function drawGrid(){\n    const gnode = svg.querySelector('#grid');\n    gnode.innerHTML = '';\n    // vertical ticks for n\n    const stepN = 10;\n    for(let n=0;n<=maxN;n+=stepN){\n      const x = xOf(n);\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1',x);\n      line.setAttribute('x2',x);\n      line.setAttribute('y1',offsetY);\n      line.setAttribute('y2',offsetY+height);\n      line.setAttribute('class','grid-line');\n      line.setAttribute('opacity', n%20 === 0 ? 0.09 : 0.03);\n      gnode.appendChild(line);\n\n      const lbl = document.createElementNS('http://www.w3.org/2000/svg','text');\n      lbl.setAttribute('x', x);\n      lbl.setAttribute('y', offsetY + height + 22);\n      lbl.setAttribute('fill', '#8aa3b2');\n      lbl.setAttribute('font-size','11');\n      lbl.setAttribute('text-anchor','middle');\n      lbl.setAttribute('font-family','Inter, sans-serif');\n      lbl.textContent = String(n);\n      gnode.appendChild(lbl);\n    }\n    // horizontal faint lines for y (nice few)\n    const niceY = 5;\n    for(let i=0;i<=niceY;i++){\n      const y = offsetY + (i / niceY) * height;\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1',offsetX);\n      line.setAttribute('x2',offsetX+width);\n      line.setAttribute('y1',y);\n      line.setAttribute('y2',y);\n      line.setAttribute('class','grid-line');\n      line.setAttribute('opacity',0.02 + i*0.01);\n      gnode.appendChild(line);\n    }\n  }\n\n  function makePathFromValues(arr, valueKey){\n    let d = '';\n    for(let i=0;i<arr.length;i++){\n      const p = arr[i];\n      const x = xOf(p.n);\n      const y = yOf(p[valueKey]);\n      d += (i===0 ? 'M' : 'L') + x + ' ' + y + ' ';\n    }\n    return d;\n  }\n\n  function makeAreaPath(thresholdIndex){\n    // area to the right of threshold where f >= cg\n    // we will construct polygon following f curve from thresholdIndex to end,\n    // then back along cg curve from end to thresholdIndex, and close.\n    const arr = points;\n    const start = Math.max(0, thresholdIndex);\n    if(start >= arr.length-1) return '';\n    let d = '';\n    // move to first f point\n    d += 'M ' + xOf(arr[start].n) + ' ' + yOf(arr[start].valF) + ' ';\n    // along f\n    for(let i=start+1;i<arr.length;i++){\n      d += 'L ' + xOf(arr[i].n) + ' ' + yOf(arr[i].valF) + ' ';\n    }\n    // back along cg\n    for(let i=arr.length-1;i>=start;i--){\n      d += 'L ' + xOf(arr[i].n) + ' ' + yOf(arr[i].valCg) + ' ';\n    }\n    d += 'Z';\n    return d;\n  }\n\n  // check whether for all n >= n0, f(n) >= c*g(n) holds (within the samples)\n  function checkSatisfied(thresholdIndex){\n    // For a robust check, require that on the tail the minimum (f - c*g) >= -tiny\n    let minDiff = Infinity;\n    for(let i=thresholdIndex;i<points.length;i++){\n      const diff = points[i].valF - points[i].valCg;\n      if(diff < minDiff) minDiff = diff;\n    }\n    return {ok: minDiff >= -1e-6, minDiff};\n  }\n\n  // update visual paths\n  function updateGraphics(){\n    // recompute curves\n    curveF.setAttribute('d', makePathFromValues(points, 'valF'));\n    curveG.setAttribute('d', makePathFromValues(points, 'valG'));\n    curveCg.setAttribute('d', makePathFromValues(points, 'valCg'));\n\n    // position n0 line\n    const idx = Math.round((n0 / maxN) * samples);\n    const x = xOf(n0);\n    n0line.setAttribute('x1', x);\n    n0line.setAttribute('x2', x);\n    n0line.setAttribute('y1', offsetY);\n    n0line.setAttribute('y2', offsetY + height);\n    n0lbl.setAttribute('x', Math.min(x+8, offsetX+width-54));\n    n0lbl.textContent = 'n₀ = ' + n0.toFixed(1);\n\n    // compute area shading path\n    const thresholdIndex = idx;\n    const okRes = checkSatisfied(thresholdIndex);\n    if(okRes.ok){\n      areaPass.setAttribute('d', makeAreaPath(thresholdIndex));\n      areaPass.setAttribute('opacity', '0.96');\n    } else {\n      // if not satisfied, still show partial area where f >= cg on the right of n0\n      // We'll compute index points where f >= cg and make small segments (but keep simple)\n      // For simplicity fade area out\n      areaPass.setAttribute('d', makeAreaPath(thresholdIndex));\n      areaPass.setAttribute('opacity', '0.32');\n    }\n\n    // update status\n    if(okRes.ok && !satisfied){\n      satisfied = true;\n      status.style.borderRadius = '999px';\n      status.innerHTML = '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"'+getComputedStyle(document.documentElement).getPropertyValue('--success')+'\"></circle></svg> Verified';\n      status.style.color = '#cff5dd';\n    } else if(!okRes.ok && satisfied){\n      satisfied = false;\n      status.innerHTML = '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"#f5c26b\"></circle></svg> checking...';\n      status.style.color = 'var(--muted)';\n    } else if(!okRes.ok){\n      status.innerHTML = '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><circle cx=\"12\" cy=\"12\" r=\"10\" fill=\"#f5c26b\"></circle></svg> scanning...';\n    }\n\n    // small glow effect on the curves using stroke dashoffset to animate slightly\n    curveF.style.strokeDasharray = '0';\n    curveG.style.strokeDasharray = '6 8';\n  }\n\n  // animation loop\n  function tick(){\n    if(running){\n      t += speed;\n      if(t > 1) t = 1; // clamp\n      // map t to n0 nonlinearly to create expressive motion (ease)\n      const eased = easeInOutCubic(t);\n      n0 = eased * (maxN * 0.85); // stop a bit before end to show margin\n      updateGraphics();\n      if(t >= 1){\n        // We reached the end; if satisfied still false, do a pass-check by scanning n0 downwards to find minimal n0\n        if(!satisfied){\n          // find minimal index where condition becomes true\n          let found = points.length - 1;\n          for(let i=0;i<points.length;i++){\n            const res = checkSatisfied(i);\n            if(res.ok){\n              found = i;\n              break;\n            }\n          }\n          n0 = (found / samples) * maxN;\n          updateGraphics();\n          running = false;\n          playPause.textContent = 'Play';\n          toggleBtn.textContent = 'Play';\n        } else {\n          running = false;\n          playPause.textContent = 'Play';\n          toggleBtn.textContent = 'Play';\n        }\n      }\n    }\n    requestAnimationFrame(tick);\n  }\n\n  function easeInOutCubic(x){\n    return x < 0.5 ? 4 * x * x * x : 1 - Math.pow(-2 * x + 2, 3) / 2;\n  }\n\n  // Initialization\n  computePoints();\n  drawGrid();\n  updateGraphics();\n  requestAnimationFrame(tick);\n\n  // UI interactions\n  playPause.addEventListener('click', ()=>{\n    running = !running;\n    playPause.textContent = running ? 'Pause' : 'Play';\n    toggleBtn.textContent = running ? 'Pause' : 'Play';\n  });\n  toggleBtn.addEventListener('click', ()=>{\n    running = !running;\n    playPause.textContent = running ? 'Pause' : 'Play';\n    toggleBtn.textContent = running ? 'Pause' : 'Play';\n  });\n\n  jumpBtn.addEventListener('click', ()=>{\n    // reset animation to start\n    t = 0;\n    n0 = 0;\n    running = true;\n    satisfied = false;\n    playPause.textContent = 'Pause';\n    toggleBtn.textContent = 'Pause';\n    updateGraphics();\n  });\n\n  infoBtn.addEventListener('click', ()=>{\n    if(cardTip.classList.contains(tipVisibleClass)){\n      cardTip.classList.remove(tipVisibleClass);\n    } else {\n      cardTip.classList.add(tipVisibleClass);\n      // auto-hide after 7 seconds\n      setTimeout(()=>cardTip.classList.remove(tipVisibleClass), 7000);\n    }\n  });\n\n  // Decorative subtle sparkle movements\n  const sparkEls = [document.getElementById('spark1'), document.getElementById('spark2'), document.getElementById('spark3')];\n  sparkEls.forEach((el, idx)=>{\n    const baseLeft = parseFloat(el.style.left);\n    const baseTop = parseFloat(el.style.top);\n    (function animateSpark(el, bx, by, i){\n      let s = 0;\n      function loop(){\n        s += 0.003 + i*0.0012;\n        const dx = Math.sin(s*2.1 + i*1.2) * 2.2;\n        const dy = Math.cos(s*1.6 + i*0.9) * 3;\n        el.style.left = (bx + dx) + '%';\n        el.style.top = (by + dy) + '%';\n        requestAnimationFrame(loop);\n      }\n      loop();\n    })(el, baseLeft, baseTop, idx);\n  });\n\n  // small entrance animation\n  document.querySelectorAll('.panel, .vis').forEach((el,i)=>{\n    el.style.opacity = 0;\n    el.style.transform = 'translateY(6px)';\n    setTimeout(()=>{ el.style.transition = 'opacity .6s ease, transform .6s ease'; el.style.opacity = 1; el.style.transform = 'translateY(0)'; }, 120 + i*120);\n  });\n\n  // ensure recompute on resize to keep scaling tight\n  window.addEventListener('resize', ()=>{\n    computePoints();\n    drawGrid();\n    updateGraphics();\n  });\n\n})();\n</script>\n</body>\n</html>"
