    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Heap Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #output {\n            font-size: 12px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Heap Sort</h1>\n    <button id=\"sort-button\">Heap Sort</button>\n    <input id=\"data-input\" type=\"text\" placeholder=\"Enter numbers separated by spaces\">\n    <button id=\"sort-button-2\">Heap Sort (2nd pass)</button>\n    <button id=\"sort-button-3\">Heap Sort (3rd pass)</button>\n    <button id=\"sort-button-4\">Heap Sort (4th pass)</button>\n    <button id=\"sort-button-5\">Heap Sort (5th pass)</button>\n    <div id=\"output\"></div>\n    <script>\n        let data = [];\n        let sortButton = document.getElementById('sort-button');\n        let dataInput = document.getElementById('data-input');\n        let sortButton2 = document.getElementById('sort-button-2');\n        let sortButton3 = document.getElementById('sort-button-3');\n        let sortButton4 = document.getElementById('sort-button-4');\n        let sortButton5 = document.getElementById('sort-button-5');\n        let outputDiv = document.getElementById('output');\n\n        sortButton.addEventListener('click', sortHeap);\n        dataInput.addEventListener('input', updateData);\n\n        function sortHeap() {\n            data = dataInput.value.split(' ').map(Number);\n            outputDiv.innerHTML = '';\n\n            for (let i = 0; i < data.length; i++) {\n                outputDiv.innerHTML += `${data[i]} `;\n            }\n\n            heapify(data, 0);\n            heapSort(data, 0, data.length - 1);\n        }\n\n        function heapify(data, n, i) {\n            let largest = i;\n            let left = 2 * i + 1;\n            let right = 2 * i + 2;\n\n            if (left < n && data[i] < data[left]) {\n                largest = left;\n            }\n\n            if (right < n && data[largest] < data[right]) {\n                largest = right;\n            }\n\n            if (largest !== i) {\n                swap(data, i, largest);\n                heapify(data, n, largest);\n            }\n        }\n\n        function heapSort(data, n, k) {\n            if (k < 0 || n === 0) return;\n\n            for (let i = n - 1; i > k; i--) {\n                swap(data, i, i - 1);\n                heapify(data, i, i - 1);\n            }\n        }\n\n        function swap(data, i, j) {\n            let temp = data[i];\n            data[i] = data[j];\n            data[j] = temp;\n        }\n\n        function updateData() {\n            dataInput.value = data.map(x => x.toString());\n        }\n    </script>\n</body>\n</html>"
