    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Congestion Control Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #4a6fa5;\n            --secondary: #166088;\n            --accent: #4fc3f7;\n            --background: #0a192f;\n            --card-bg: rgba(16, 42, 67, 0.8);\n            --text: #e6f1ff;\n            --success: #4caf50;\n            --warning: #ff9800;\n            --danger: #f44336;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--background);\n            color: var(--text);\n            overflow-x: hidden;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n        \n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(90deg, var(--accent), var(--primary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            font-weight: 300;\n            opacity: 0.8;\n        }\n        \n        .visualization-container {\n            width: 100%;\n            max-width: 1200px;\n            height: 500px;\n            background-color: var(--card-bg);\n            border-radius: 20px;\n            padding: 2rem;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);\n            position: relative;\n            overflow: hidden;\n            margin-bottom: 3rem;\n            animation: slideUp 1s ease-out;\n            backdrop-filter: blur(5px);\n        }\n        \n        .network-path {\n            position: absolute;\n            bottom: 100px;\n            left: 50px;\n            right: 50px;\n            height: 3px;\n            background-color: rgba(255, 255, 255, 0.1);\n            border-radius: 3px;\n            overflow: visible;\n        }\n        \n        .network-node {\n            position: absolute;\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n            background-color: var(--accent);\n            box-shadow: 0 0 15px var(--accent);\n            top: 50%;\n            transform: translateY(-50%);\n            animation: pulse 2s infinite;\n        }\n        \n        .network-node:nth-child(1) { left: 0; animation-delay: 0s; }\n        .network-node:nth-child(2) { left: 25%; animation-delay: 0.5s; }\n        .network-node:nth-child(3) { left: 50%; animation-delay: 1s; }\n        .network-node:nth-child(4) { left: 75%; animation-delay: 1.5s; }\n        .network-node:nth-child(5) { left: 100%; animation-delay: 2s; }\n        \n        .data-packet {\n            position: absolute;\n            width: 30px;\n            height: 20px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            border-radius: 4px;\n            bottom: 100px;\n            left: 50px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-size: 10px;\n            font-weight: bold;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);\n            transform-origin: center;\n            transform: translateY(50%);\n            opacity: 0;\n        }\n        \n        .congestion-indicator {\n            position: absolute;\n            width: 100%;\n            height: 50px;\n            bottom: 150px;\n            left: 0;\n            background-color: rgba(244, 67, 54, 0.1);\n            border-radius: 0 0 20px 20px;\n            transition: all 0.5s ease;\n            opacity: 0;\n        }\n        \n        .congestion-warning {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            color: var(--danger);\n            font-weight: bold;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            opacity: 0;\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n        \n        button {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .info-cards {\n            display: flex;\n            gap: 2rem;\n            width: 100%;\n            max-width: 1200px;\n            margin-top: 2rem;\n        }\n        \n        .card {\n            flex: 1;\n            background-color: var(--card-bg);\n            border-radius: 15px;\n            padding: 1.5rem;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n            transition: transform 0.3s ease;\n            backdrop-filter: blur(5px);\n        }\n        \n        .card:hover {\n            transform: translateY(-5px);\n        }\n        \n        .card h3 {\n            color: var(--accent);\n            margin-bottom: 1rem;\n            font-size: 1.3rem;\n        }\n        \n        .card p {\n            font-size: 0.9rem;\n            line-height: 1.6;\n            opacity: 0.9;\n        }\n        \n        .throughput-meter {\n            width: 100%;\n            height: 10px;\n            background-color: rgba(255, 255, 255, 0.1);\n            border-radius: 5px;\n            margin-top: 1rem;\n            overflow: hidden;\n        }\n        \n        .throughput-fill {\n            height: 100%;\n            width: 70%;\n            background: linear-gradient(90deg, var(--success), #8bc34a);\n            border-radius: 5px;\n            transition: width 0.5s ease;\n        }\n        \n        .animation-layer {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n        \n        .particle {\n            position: absolute;\n            width: 2px;\n            height: 2px;\n            background-color: var(--accent);\n            border-radius: 50%;\n            opacity: 0.5;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulse {\n            0% { transform: translateY(-50%) scale(1); }\n            50% { transform: translateY(-50%) scale(1.2); }\n            100% { transform: translateY(-50%) scale(1); }\n        }\n        \n        @keyframes movePacket {\n            0% { \n                left: 50px;\n                opacity: 0;\n                transform: translateY(50%) scale(0.8);\n            }\n            10% { \n                opacity: 1;\n                transform: translateY(50%) scale(1);\n            }\n            90% { \n                opacity: 1;\n                transform: translateY(50%) scale(1);\n            }\n            100% { \n                left: calc(100% - 80px);\n                opacity: 0;\n                transform: translateY(50%) scale(0.8);\n            }\n        }\n        \n        @keyframes congestionPulse {\n            0% { opacity: 0; }\n            50% { opacity: 0.3; }\n            100% { opacity: 0; }\n        }\n        \n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            font-size: 0.8rem;\n            opacity: 0.6;\n            animation: fadeIn 2s ease-out;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Congestion Control</h1>\n        <p class=\"subtitle\">Maintaining network efficiency through intelligent traffic management</p>\n    </header>\n    \n    <div class=\"controls\">\n        <button id=\"startBtn\">Start Simulation</button>\n        <button id=\"congestionBtn\">Induce Congestion</button>\n    </div>\n    \n    <div class=\"visualization-container\">\n        <div class=\"animation-layer\" id=\"particleLayer\"></div>\n        \n        <div class=\"network-path\">\n            <div class=\"network-node\"></div>\n            <div class=\"network-node\"></div>\n            <div class=\"network-node\"></div>\n            <div class=\"network-node\"></div>\n            <div class=\"network-node\"></div>\n        </div>\n        \n        <div class=\"congestion-indicator\" id=\"congestionIndicator\">\n            <div class=\"congestion-warning\">Congestion Detected</div>\n        </div>\n    </div>\n    \n    <div class=\"info-cards\">\n        <div class=\"card\">\n            <h3>Slow Start</h3>\n            <p>TCP begins with a conservative window size and exponentially increases it until congestion is detected or a threshold is reached.</p>\n            <div class=\"throughput-meter\">\n                <div class=\"throughput-fill\" id=\"slowStartMeter\"></div>\n            </div>\n        </div>\n        \n        <div class=\"card\">\n            <h3>Avoidance Phase</h3>\n            <p>After reaching the threshold, TCP switches to additive increase, growing the window size linearly to maximize throughput without causing congestion.</p>\n            <div class=\"throughput-meter\">\n                <div class=\"throughput-fill\" id=\"avoidanceMeter\"></div>\n            </div>\n        </div>\n        \n        <div class=\"card\">\n            <h3>Congestion Response</h3>\n            <p>When packet loss is detected, TCP dramatically reduces its window size and begins building back up, creating the characteristic sawtooth pattern.</p>\n            <div class=\"throughput-meter\">\n                <div class=\"throughput-fill\" id=\"responseMeter\"></div>\n            </div>\n        </div>\n    </div>\n    \n    <footer>\n        <p>Visualization of TCP Congestion Control Algorithms | Network Performance Optimization</p>\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const startBtn = document.getElementById('startBtn');\n            const congestionBtn = document.getElementById('congestionBtn');\n            const congestionIndicator = document.getElementById('congestionIndicator');\n            const particleLayer = document.getElementById('particleLayer');\n            \n            let isSimulating = false;\n            let packetInterval;\n            let congestionActive = false;\n            let slowStartMeter = document.getElementById('slowStartMeter');\n            let avoidanceMeter = document.getElementById('avoidanceMeter');\n            let responseMeter = document.getElementById('responseMeter');\n            \n            // Create background particles\n            for (let i = 0; i < 50; i++) {\n                createParticle();\n            }\n            \n            function createParticle() {\n                const particle = document.createElement('div');\n                particle.className = 'particle';\n                \n                const size = Math.random() * 3 + 1;\n                const posX = Math.random() * 100;\n                const posY = Math.random() * 100;\n                const duration = Math.random() * 20 + 10;\n                const delay = Math.random() * 10;\n                const opacity = Math.random() * 0.3 + 0.1;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.top = `${posY}%`;\n                particle.style.opacity = opacity;\n                particle.style.animation = `float ${duration}s linear ${delay}s infinite`;\n                \n                particleLayer.appendChild(particle);\n            }\n            \n            function createPacket() {\n                if (!isSimulating) return;\n                \n                const packet = document.createElement('div');\n                packet.className = 'data-packet';\n                \n                // Random packet size indicator\n                const packetSize = Math.floor(Math.random() * 5) + 1;\n                packet.style.width = `${20 + packetSize * 5}px`;\n                packet.style.height = `${15 + packetSize * 2}px`;\n                packet.textContent = packetSize + 'KB';\n                \n                // Position at start\n                packet.style.left = '50px';\n                document.querySelector('.visualization-container').appendChild(packet);\n                \n                // Random delay to simulate network variability\n                const delay = congestionActive ? Math.random() * 2000 : Math.random() * 500;\n                \n                setTimeout(() => {\n                    packet.style.animation = `movePacket ${congestionActive ? '3s' : '1.5s'} linear forwards`;\n                    \n                    // Remove packet after animation\n                    setTimeout(() => {\n                        packet.remove();\n                    }, congestionActive ? 3000 : 1500);\n                }, delay);\n            }\n            \n            function updateMeters() {\n                if (!isSimulating) return;\n                \n                // Simulate the sawtooth pattern of congestion control\n                const time = Date.now() / 1000;\n                \n                // Slow Start meter - exponential growth\n                const slowStartValue = Math.min(100, Math.pow(1.1, time % 5) * 10);\n                slowStartMeter.style.width = `${slowStartValue}%`;\n                \n                // Avoidance meter - linear growth with occasional drops\n                let avoidanceValue = (time * 5) % 100;\n                if (Math.sin(time * 0.5) > 0.9) avoidanceValue *= 0.7;\n                avoidanceMeter.style.width = `${avoidanceValue}%`;\n                \n                // Response meter - dramatic drops and recovery\n                let responseValue = 70 + Math.sin(time * 0.3) * 30;\n                if (congestionActive) {\n                    responseValue = 30 + Math.sin(time * 1.5) * 15;\n                }\n                responseMeter.style.width = `${responseValue}%`;\n                \n                requestAnimationFrame(updateMeters);\n            }\n            \n            startBtn.addEventListener('click', function() {\n                if (isSimulating) {\n                    // Stop simulation\n                    isSimulating = false;\n                    clearInterval(packetInterval);\n                    startBtn.textContent = 'Start Simulation';\n                    slowStartMeter.style.width = '0%';\n                    avoidanceMeter.style.width = '0%';\n                    responseMeter.style.width = '0%';\n                } else {\n                    // Start simulation\n                    isSimulating = true;\n                    startBtn.textContent = 'Stop Simulation';\n                    packetInterval = setInterval(createPacket, 300);\n                    updateMeters();\n                }\n            });\n            \n            congestionBtn.addEventListener('click', function() {\n                congestionActive = !congestionActive;\n                \n                if (congestionActive) {\n                    congestionBtn.textContent = 'Clear Congestion';\n                    congestionIndicator.style.opacity = '1';\n                    congestionIndicator.querySelector('.congestion-warning').style.opacity = '1';\n                    \n                    // Add more particles to show congestion\n                    for (let i = 0; i < 20; i++) {\n                        createParticle();\n                    }\n                } else {\n                    congestionBtn.textContent = 'Induce Congestion';\n                    congestionIndicator.style.opacity = '0';\n                    congestionIndicator.querySelector('.congestion-warning').style.opacity = '0';\n                }\n            });\n            \n            // Add floating animation to particles\n            const style = document.createElement('style');\n            style.textContent = `\n                @keyframes float {\n                    0% { transform: translate(0, 0); }\n                    25% { transform: translate(${Math.random() * 20 - 10}px, ${Math.random() * 20 - 10}px); }\n                    50% { transform: translate(${Math.random() * 40 - 20}px, ${Math.random() * 40 - 20}px); }\n                    75% { transform: translate(${Math.random() * 20 - 10}px, ${Math.random() * 20 - 10}px); }\n                    100% { transform: translate(0, 0); }\n                }\n            `;\n            document.head.appendChild(style);\n        });\n    </script>\n</body>\n</html>"
