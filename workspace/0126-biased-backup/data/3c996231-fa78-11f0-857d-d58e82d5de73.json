    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Virtual Memory Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Lexend+Deca&family=Space+Grotesk:wght@400;700&display=swap');\n  /* BASE RESET & SETUP */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1a1f38, #0f111a);\n    font-family: 'Lexend Deca', sans-serif;\n    color: #e0e6f0;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1rem 4rem;\n  }\n  h1 {\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    font-size: 3.2rem;\n    margin-bottom: 0.2em;\n    background: linear-gradient(90deg, #7fffd4, #00c6ff, #00ff94);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    user-select:none;\n  }\n  h2 {\n    font-weight: 400;\n    font-size: 1.25rem;\n    color: #9bbcf7;\n    font-style: italic;\n    margin-bottom: 3.5rem;\n    user-select:none;\n  }\n\n  /* MAIN CONTAINER */\n  #container {\n    display: flex;\n    gap: 2rem;\n    max-width: 1100px;\n    width: 100%;\n    user-select:none;\n  }\n\n  /* MEMORY BLOCK BASE */\n  .memory-block {\n    background: rgba(255 255 255 / 0.06);\n    border-radius: 1.25rem;\n    box-shadow:\n      inset 0 0 10px 1px rgba(255 255 255 / 0.06),\n      0 10px 40px rgba(0 255 212 / 0.18);\n    padding: 2rem 2.5rem 3rem;\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    position: relative;\n    overflow: hidden;\n    transition: box-shadow 0.8s ease;\n  }\n  .memory-block::before {\n    content: '';\n    position: absolute;\n    border-radius: 50%;\n    top: -60%;\n    left: 70%;\n    width: 220%;\n    height: 220%;\n    background: radial-gradient(circle closest-side, rgba(0,255,212,0.3) 0%, transparent 80%);\n    filter: blur(70px);\n    z-index: 0;\n    transition: opacity 1s ease;\n    opacity: 0.15;\n  }\n  .memory-block:hover::before {\n    opacity: 0.3;\n  }\n  .memory-block strong {\n    font-weight: 700;\n    font-size: 1.6rem;\n    letter-spacing: 0.1em;\n    margin-bottom: 1rem;\n    color: #00f4a1;\n    z-index: 10;\n  }\n  .memory-block p {\n    font-size: 0.95rem;\n    line-height: 1.5;\n    color: #acb8d9cc;\n    user-select:none;\n    z-index: 10;\n    flex-grow: 1;\n  }\n\n  /* MEMORY CHIPS CONTAINER */\n  .chip-container {\n    margin-top: 1.5rem;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 1rem;\n    z-index: 10;\n  }\n\n  /* SINGLE CHIP */\n  .chip {\n    background: linear-gradient(145deg, #003330, #004c3d);\n    border: 2px solid #00ffd3;\n    border-radius: 0.5rem;\n    box-shadow:\n      0 0 8px #00fcb1,\n      inset 0 0 12px #00d8a0;\n    color: #00fcd4;\n    font-family: 'Space Grotesk', monospace;\n    font-weight: 600;\n    font-size: 0.75rem;\n    text-align: center;\n    line-height: 1.2;\n    padding: 0.35rem 0.7rem;\n    user-select:none;\n    cursor: default;\n    position: relative;\n    min-width: 72px;\n    border-radius: 0.5rem;\n    transition:\n      transform 0.4s ease,\n      box-shadow 0.4s ease;\n  }\n  .chip::after {\n    content: '';\n    position: absolute;\n    bottom: 5px;\n    right: 7px;\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n    background: #00ffd3;\n    box-shadow: 0 0 6px #00ffd3;\n  }\n  .chip:hover {\n    transform: scale(1.15);\n    box-shadow:\n      0 0 18px #00ffdb,\n      inset 0 0 20px #00ffdb;\n  }\n\n  /* ARROWS */\n  svg.arrow {\n    width: 24px;\n    height: 24px;\n    fill: none;\n    stroke: #00f5ba;\n    stroke-width: 3;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    margin: 0 1.2rem;\n    flex-shrink: 0;\n    user-select:none;\n    animation: pulseStroke 2.5s infinite alternate ease-in-out;\n    align-self: center;\n  }\n\n  @keyframes pulseStroke {\n    0% {\n      stroke-opacity: 0.6;\n    }\n    100% {\n      stroke-opacity: 1;\n    }\n  }\n\n  /* VISUALIZER */\n  #visualizer {\n    margin-top: 3rem;\n    background: rgba(0, 255, 212, 0.05);\n    border-radius: 1.7rem;\n    width: 100%;\n    max-width: 1120px;\n    height: 320px;\n    overflow: visible;\n    position: relative;\n    box-shadow:\n      inset 0 0 30px 2px rgba(0,255,212,0.13),\n      0 0 90px 6px rgba(0,255,212,0.18);\n  }\n  svg#vm-svg {\n    width: 100%;\n    height: 100%;\n    user-select:none;\n  }\n\n  /* CONTROLS */\n  #controls {\n    margin-top: 2rem;\n    display: flex;\n    justify-content: center;\n    gap: 18px;\n    user-select:none;\n  }\n  button {\n    background: linear-gradient(145deg, #004c3f, #007e68);\n    border: none;\n    border-radius: 1.2rem;\n    padding: 0.86rem 2.3rem;\n    font-family: 'Lexend Deca', sans-serif;\n    font-weight: 600;\n    font-size: 1.05rem;\n    color: #a6fff3;\n    letter-spacing: 0.05em;\n    box-shadow:\n      0 0 15px #00ffd3,\n      inset 0 0 12px #00b185b2;\n    cursor: pointer;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.3s cubic-bezier(0.4,0,0.2,1);\n    user-select:none;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #00e5af, #00d8a1);\n    box-shadow:\n      0 0 24px #00ffd3,\n      inset 0 0 18px #00ffd3;\n    transform: scale(1.07);\n  }\n  button:active {\n    transform: scale(0.96);\n  }\n\n  /* TEXT INFO BOX */\n  #info-text {\n    margin-top: 1.3rem;\n    max-width: 960px;\n    color: #88d8c0cc;\n    font-size: 1.07rem;\n    line-height: 1.4;\n    font-style: italic;\n    font-weight: 500;\n    text-align: center;\n    filter: drop-shadow(0 0 4px #00e9c2aa);\n    user-select:none;\n  }\n\n  /* FOOTER */\n  footer {\n    margin-top: 4rem;\n    font-size: 0.8rem;\n    color: #3ef5d19d;\n    user-select:none;\n  }\n\n  /* RESPONSIVE */\n  @media (max-width: 860px) {\n    #container {\n      flex-direction: column;\n      gap: 2rem;\n    }\n    #visualizer {\n      height: 280px;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>Virtual Memory</h1>\n  <h2>Visualizing how Memory is Organized & Mapped</h2>\n  <div id=\"container\" aria-label=\"Main conceptual blocks\">\n    <section class=\"memory-block\" aria-labelledby=\"block1-title\" role=\"region\" tabindex=\"0\" aria-describedby=\"block1-desc\">\n      <strong id=\"block1-title\">Virtual Address Space</strong>\n      <p id=\"block1-desc\">Every process has its own virtual memory, subdivided into pages. The CPU's MMU translates virtual addresses to physical addresses using page tables.</p>\n      <div class=\"chip-container\" aria-label=\"Virtual pages\">\n        <div class=\"chip\" title=\"Virtual Page 0x01\">0x01</div>\n        <div class=\"chip\" title=\"Virtual Page 0x02\">0x02</div>\n        <div class=\"chip\" title=\"Virtual Page 0x03\">0x03</div>\n        <div class=\"chip\" title=\"Virtual Page 0x04\">0x04</div>\n        <div class=\"chip\" title=\"Virtual Page 0x05\">0x05</div>\n        <div class=\"chip\" title=\"Virtual Page 0x06\">0x06</div>\n      </div>\n    </section>\n\n    <svg class=\"arrow\" aria-hidden=\"true\" viewBox=\"0 0 24 24\">\n      <path d=\"M5 12h14M13 6l6 6-6 6\"/>\n    </svg>\n\n    <section class=\"memory-block\" aria-labelledby=\"block2-title\" role=\"region\" tabindex=\"0\" aria-describedby=\"block2-desc\">\n      <strong id=\"block2-title\">Page Table</strong>\n      <p id=\"block2-desc\">The page table maps virtual pages to physical frames. It contains flags such as Present, Read/Write and Validity to control access.</p>\n      <div class=\"chip-container\" aria-label=\"Page Table Entries\">\n        <div class=\"chip\" title=\"Page Table Entry PTE 0x01\">PTE 0x01</div>\n        <div class=\"chip\" title=\"Page Table Entry PTE 0x02\">PTE 0x02</div>\n        <div class=\"chip\" title=\"Page Table Entry PTE 0x03\">PTE 0x03</div>\n        <div class=\"chip\" title=\"Page Table Entry PTE 0x04\">PTE 0x04</div>\n        <div class=\"chip\" title=\"Page Table Entry PTE 0x05\">PTE 0x05</div>\n        <div class=\"chip\" title=\"Page Table Entry PTE 0x06\">PTE 0x06</div>\n      </div>\n    </section>\n\n    <svg class=\"arrow\" aria-hidden=\"true\" viewBox=\"0 0 24 24\">\n      <path d=\"M5 12h14M13 6l6 6-6 6\"/>\n    </svg>\n\n    <section class=\"memory-block\" aria-labelledby=\"block3-title\" role=\"region\" tabindex=\"0\" aria-describedby=\"block3-desc\">\n      <strong id=\"block3-title\">Physical Memory</strong>\n      <p id=\"block3-desc\">Physical frames in RAM where the contents of pages reside. Frames can be swapped in and out to disk based on usage.</p>\n      <div class=\"chip-container\" aria-label=\"Physical frames\">\n        <div class=\"chip\" title=\"Physical Frame 0x11\">0x11</div>\n        <div class=\"chip\" title=\"Physical Frame 0x22\">0x22</div>\n        <div class=\"chip\" title=\"Physical Frame 0x33\">0x33</div>\n        <div class=\"chip\" title=\"Physical Frame 0x44\">0x44</div>\n        <div class=\"chip\" title=\"Physical Frame 0x55\">0x55</div>\n        <div class=\"chip\" title=\"Physical Frame 0x66\">0x66</div>\n      </div>\n    </section>\n  </div>\n\n  <div id=\"visualizer\" aria-label=\"Virtual Memory address translation illustration\" role=\"img\" tabindex=\"0\">\n    <svg id=\"vm-svg\" viewBox=\"0 0 1100 320\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"true\" focusable=\"false\">\n      <!-- Gradients -->\n      <defs>\n        <linearGradient id=\"gradVA\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#00ffba\"/>\n          <stop offset=\"100%\" stop-color=\"#007f56\"/>\n        </linearGradient>\n        <linearGradient id=\"gradPT\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#5a9fff\"/>\n          <stop offset=\"100%\" stop-color=\"#004eae\"/>\n        </linearGradient>\n        <linearGradient id=\"gradPM\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#ff7ee7\"/>\n          <stop offset=\"100%\" stop-color=\"#ac008f\"/>\n        </linearGradient>\n        <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\" color-interpolation-filters=\"sRGB\">\n          <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"3\" flood-color=\"#00ffc8\" flood-opacity=\"0.7\"/>\n          <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"6\" flood-color=\"#00ffc8\" flood-opacity=\"0.4\"/>\n        </filter>\n        <filter id=\"pulseShadow\" x=\"-30%\" y=\"-30%\" width=\"160%\" height=\"160%\" color-interpolation-filters=\"sRGB\">\n          <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"2\" flood-color=\"#00ffe0\" flood-opacity=\"0.8\"/>\n        </filter>\n      </defs>\n\n      <!-- Virtual Address Space Block -->\n      <rect x=\"20\" y=\"30\" width=\"300\" height=\"260\" rx=\"30\" ry=\"30\" fill=\"url(#gradVA)\" filter=\"url(#glow)\" />\n      <text x=\"170\" y=\"75\" fill=\"#d0ffe4\" font-family=\"Space Grotesk, sans-serif\" font-weight=\"700\" font-size=\"22\" text-anchor=\"middle\" pointer-events=\"none\">Virtual Address Space</text>\n\n      <!-- Virtual pages rectangles -->\n      <g id=\"va-pages\" transform=\"translate(50,105)\">\n        <rect width=\"50\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#00ffbb\" opacity=\"0.7\" filter=\"url(#pulseShadow)\"/>\n        <rect x=\"60\" width=\"50\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#00ffbb\" opacity=\"0.55\" />\n        <rect x=\"120\" width=\"50\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#00ffbb\" opacity=\"0.4\" />\n        <rect x=\"180\" width=\"50\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#00ffbb\" opacity=\"0.6\" />\n        <rect x=\"240\" width=\"50\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#00ffbb\" opacity=\"0.5\" />\n      </g>\n\n      <!-- Arrow VA->PT -->\n      <path d=\"M320 150 L380 150\" stroke=\"#00fcca\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n      <polygon points=\"380 140 395 150 380 160\" fill=\"#00fcca\" />\n\n      <!-- Page Table Block -->\n      <rect x=\"400\" y=\"30\" width=\"280\" height=\"260\" rx=\"30\" ry=\"30\" fill=\"url(#gradPT)\" filter=\"url(#glow)\" />\n      <text x=\"540\" y=\"75\" fill=\"#c7d9ff\" font-family=\"Space Grotesk, sans-serif\" font-weight=\"700\" font-size=\"22\" text-anchor=\"middle\" pointer-events=\"none\">Page Table</text>\n\n      <!-- Page table entries -->\n      <g id=\"pt-entries\" transform=\"translate(430, 105)\">\n        <rect width=\"45\" height=\"40\" rx=\"8\" ry=\"8\" fill=\"#5fc4ff\" opacity=\"0.7\" filter=\"url(#pulseShadow)\"/>\n        <rect x=\"55\" width=\"45\" height=\"40\" rx=\"8\" ry=\"8\" fill=\"#5fc4ff\" opacity=\"0.5\" />\n        <rect x=\"110\" width=\"45\" height=\"40\" rx=\"8\" ry=\"8\" fill=\"#5fc4ff\" opacity=\"0.6\" />\n        <rect x=\"165\" width=\"45\" height=\"40\" rx=\"8\" ry=\"8\" fill=\"#5fc4ff\" opacity=\"0.4\" />\n        <rect x=\"220\" width=\"45\" height=\"40\" rx=\"8\" ry=\"8\" fill=\"#5fc4ff\" opacity=\"0.55\" />\n      </g>\n\n      <!-- Arrow PT->PM -->\n      <path d=\"M690 150 L750 150\" stroke=\"#6b51f9\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n      <polygon points=\"750 140 765 150 750 160\" fill=\"#6b51f9\" />\n\n      <!-- Physical Memory Block -->\n      <rect x=\"780\" y=\"30\" width=\"300\" height=\"260\" rx=\"30\" ry=\"30\" fill=\"url(#gradPM)\" filter=\"url(#glow)\" />\n      <text x=\"930\" y=\"75\" fill=\"#f7a9f5\" font-family=\"Space Grotesk, sans-serif\" font-weight=\"700\" font-size=\"22\" text-anchor=\"middle\" pointer-events=\"none\">Physical Memory</text>\n\n      <!-- Physical frames rectangles -->\n      <g id=\"pm-frames\" transform=\"translate(810, 105)\">\n        <rect width=\"48\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#ff53dc\" opacity=\"0.6\" filter=\"url(#pulseShadow)\"/>\n        <rect x=\"58\" width=\"48\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#ff53dc\" opacity=\"0.5\" />\n        <rect x=\"118\" width=\"48\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#ff53dc\" opacity=\"0.7\" />\n        <rect x=\"178\" width=\"48\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#ff53dc\" opacity=\"0.55\" />\n        <rect x=\"238\" width=\"48\" height=\"40\" rx=\"10\" ry=\"10\" fill=\"#ff53dc\" opacity=\"0.4\" />\n      </g>\n\n      <!-- Animating connection lines -->\n      <path id=\"map-line-1\" d=\"M100 145 L435 145 L790 145\" stroke=\"#00ffd1\" stroke-width=\"4\" stroke-linejoin=\"round\" fill=\"none\" stroke-dasharray=\"690\" stroke-dashoffset=\"690\" />\n      <circle id=\"map-dot-1\" cx=\"100\" cy=\"145\" r=\"8\" fill=\"#00ffb3\" filter=\"url(#glow)\" />\n    </svg>\n  </div>\n\n  <div id=\"info-text\" aria-live=\"polite\" role=\"region\" tabindex=\"0\">\n    <em>Observe the flow of address translation from Virtual Address Space through Page Table into Physical Memory frames.</em>\n  </div>\n\n  <div id=\"controls\">\n    <button id=\"playBtn\" aria-pressed=\"false\" aria-label=\"Play the address translation animation\">Play Animation</button>\n    <button id=\"resetBtn\" aria-label=\"Reset the animation to initial state\">Reset</button>\n  </div>\n\n<script>\n  (() => {\n    const line = document.getElementById('map-line-1');\n    const dot = document.getElementById('map-dot-1');\n    const playBtn = document.getElementById('playBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const infoText = document.getElementById('info-text');\n\n    const length = line.getTotalLength();\n    let animationId = null;\n    let startTime = null;\n    let duration = 5200; // ms\n    let running = false;\n\n    line.style.strokeDasharray = length;\n    line.style.strokeDashoffset = length;\n\n    // Dot movement along the path - basic linear normalized progress\n    function animate(timestamp) {\n      if (!startTime) startTime = timestamp;\n      let elapsed = timestamp - startTime;\n      if (elapsed > duration) elapsed = duration;\n\n      const progress = elapsed / duration;\n      line.style.strokeDashoffset = length - length * progress;\n\n      // Calculate dot position on the path\n      const point = line.getPointAtLength(length * progress);\n      dot.setAttribute('cx', point.x);\n      dot.setAttribute('cy', point.y);\n\n      if (elapsed < duration) {\n        animationId = requestAnimationFrame(animate);\n      } else {\n        running = false;\n        playBtn.textContent = 'Play Animation';\n        playBtn.setAttribute('aria-pressed', 'false');\n        infoText.textContent = 'Animation completed! The virtual address is fully mapped to physical memory.';\n      }\n    }\n\n    function playAnimation() {\n      if (running) return;\n      running = true;\n      startTime = null;\n      infoText.textContent = 'Translating virtual address through the page table...';\n      playBtn.textContent = 'Playing...';\n      playBtn.setAttribute('aria-pressed', 'true');\n      animationId = requestAnimationFrame(animate);\n    }\n\n    function resetAnimation() {\n      if (animationId) cancelAnimationFrame(animationId);\n      running = false;\n      line.style.strokeDashoffset = length;\n      dot.setAttribute('cx', 100);\n      dot.setAttribute('cy', 145);\n      playBtn.textContent = 'Play Animation';\n      playBtn.setAttribute('aria-pressed', 'false');\n      infoText.textContent = 'Observe the flow of address translation from Virtual Address Space through Page Table into Physical Memory frames.';\n    }\n\n    playBtn.addEventListener('click', playAnimation);\n    resetBtn.addEventListener('click', resetAnimation);\n\n    // Initialize physical dot position\n    resetAnimation();\n  })();\n</script>\n<footer>&#x2022; Concept &amp; Design by ChatGPT &copy; 2024 &#x2022;</footer>\n</body>\n</html>"
  },
