    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Red-Black Tree</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        #tree {\n            border: 1px solid black;\n            padding: 10px;\n            border-radius: 5px;\n            width: 800px;\n            height: 600px;\n            margin: 20px auto;\n            background-color: #fff;\n            border: 1px solid black;\n        }\n        #controls {\n            margin-bottom: 10px;\n        }\n        #controls button {\n            padding: 5px 10px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #controls input {\n            padding: 5px 10px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tree\"></div>\n    <div id=\"controls\">\n        <button id=\"insert-btn\">Insert</button>\n        <button id=\"delete-btn\">Delete</button>\n        <input id=\"value-input\" type=\"number\" placeholder=\"Enter value\">\n        <button id=\"search-btn\">Search</button>\n        <button id=\"print-btn\">Print</button>\n    </div>\n\n    <script>\n        class Node {\n            constructor(key, color = 'red') {\n                this.key = key;\n                this.color = color;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class RedBlackTree {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(key) {\n                let node = new Node(key, 'black');\n                if (this.root === null) {\n                    this.root = node;\n                } else {\n                    this._insert(this.root, node);\n                }\n            }\n\n            _insert(node, newNode) {\n                if (newNode.key < node.key) {\n                    if (node.left === null) {\n                        node.left = newNode;\n                    } else {\n                        this._insert(node.left, newNode);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = newNode;\n                    } else {\n                        this._insert(node.right, newNode);\n                    }\n                }\n            }\n\n            search(key) {\n                return this._search(this.root, key);\n            }\n\n            _search(node, key) {\n                if (node === null) {\n                    return null;\n                }\n                if (key < node.key) {\n                    return this._search(node.left, key);\n                } else if (key > node.key) {\n                    return this._search(node.right, key);\n                } else {\n                    return node;\n                }\n            }\n\n            print() {\n                this._print(this.root);\n            }\n\n            _print(node) {\n                if (node !== null) {\n                    this._print(node.left);\n                    process.stdout.write(node.key + ' ');\n                    this._print(node.right);\n                }\n            }\n        }\n\n        let tree = new RedBlackTree();\n\n        function insert(key) {\n            tree.insert(key);\n        }\n\n        function delete(key) {\n            tree.root = tree.delete(key);\n        }\n\n        function search(key) {\n            return tree.search(key);\n        }\n\n        function print() {\n            tree.print();\n        }\n\n        function _insert(node, newNode) {\n            if (newNode.key < node.key) {\n                if (node.left === null) {\n                    node.left = newNode;\n                } else {\n                    this._insert(node.left, newNode);\n                }\n            } else {\n                if (node.right === null) {\n                    node.right = newNode;\n                } else {\n                    this._insert(node.right, newNode);\n                }\n            }\n        }\n\n        function _search(node, key) {\n            if (node === null) {\n                return null;\n            }\n            if (key < node.key) {\n                return this._search(node.left, key);\n            } else if (key > node.key) {\n                return this._search(node.right, key);\n            } else {\n                return node;\n            }\n        }\n\n        function _print(node) {\n            if (node !== null) {\n                this._print(node.left);\n                process.stdout.write(node.key + ' ');\n                this._print(node.right);\n            }\n        }\n\n        document.getElementById('insert-btn').addEventListener('click', () => {\n            insert(Number(document.getElementById('value-input').value));\n        });\n\n        document.getElementById('delete-btn').addEventListener('click', () => {\n            delete(Number(document.getElementById('value-input').value));\n        });\n\n        document.getElementById('search-btn').addEventListener('click', () => {\n            let found = search(Number(document.getElementById('value-input').value));\n            if (found !== null) {\n                console.log(found.key);\n            } else {\n                console.log('Not found');\n            }\n        });\n\n        document.getElementById('print-btn').addEventListener('click', () => {\n            print();\n        });\n    </script>\n    <script src=\"script.js\"></script>\n</body>\n</html>"
