  "question": "Graph (Undirected)",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Undirected Graph</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        canvas { border: 1px solid black; margin: 10px 0; }\n        .control-panel { margin: 10px 0; padding: 10px; border: 1px solid #ccc; }\n        .control-group { margin: 10px 0; }\n        button, input, select { margin: 5px; }\n        table { border-collapse: collapse; margin: 10px 0; }\n        td, th { border: 1px solid #ccc; padding: 5px; }\n    </style>\n</head>\n<body>\n    <h1>Undirected Graph Explorer</h1>\n    \n    <div class=\"control-panel\">\n        <div class=\"control-group\">\n            <button id=\"addNode\">Add Node</button>\n            <button id=\"nodeName\" value=\"Node\">Node Label</button>\n            <button id=\"removeNode\">Remove Node</button>\n            <button id=\"clearGraph\">Clear Graph</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <button id=\"addEdge\">Add Edge</button>\n            <button id=\"removeEdge\">Remove Edge</button>\n            <span>Weight: <input type=\"number\" id=\"edgeWeight\" value=\"1\" min=\"1\" max=\"100\"></span>\n        </div>\n        \n        <div class=\"control-group\">\n            <button id=\"randomGraph\">Generate Random Graph</button>\n            Nodes: <input type=\"number\" id=\"randomNodes\" value=\"5\" min=\"2\" max=\"20\">\n            Edges: <input type=\"number\" id=\"randomEdges\" value=\"7\" min=\"1\" max=\"50\">\n        </div>\n        \n        <div class=\"control-group\">\n            <button id=\"findPath\">Find Path</button>\n            From: <select id=\"pathFrom\"></select>\n            To: <select id=\"pathTo\"></select>\n            Algorithm: \n            <select id=\"pathAlgorithm\">\n                <option value=\"bfs\">Breadth-First</option>\n                <option value=\"dfs\">Depth-First</option>\n                <option value=\"dijkstra\">Dijkstra's</option>\n            </select>\n        </div>\n        \n        <div class=\"control-group\">\n            <button id=\"detectCycle\">Detect Cycle</button>\n            <button id=\"findConnected\">Find Connected Components</button>\n            <button id=\"findMST\">Find Minimum Spanning Tree</button>\n        </div>\n    </div>\n    \n    <canvas id=\"graphCanvas\" width=\"800\" height=\"500\"></canvas>\n    \n    <div class=\"control-panel\">\n        <h3>Graph Information</h3>\n        <div id=\"graphInfo\">\n            Nodes: 0, Edges: 0, Connected: No, Cyclic: No\n        </div>\n        \n        <h3>Adjacency List</h3>\n        <table id=\"adjacencyList\">\n            <thead>\n                <tr><th>Node</th><th>Connections</th></tr>\n            </thead>\n            <tbody></tbody>\n        </table>\n    </div>\n    \n    <div id=\"status\"></div>\n    \n    <script>\n        // Graph data structure\n        const graph = {\n            nodes: [],\n            edges: [],\n            nextId: 1,\n            \n            addNode: function(label) {\n                const node = {\n                    id: this.nextId++,\n                    label: label || `Node ${this.nextId-1}`,\n                    x: Math.random() * 700 + 50,\n                    y: Math.random() * 400 + 50\n                };\n                this.nodes.push(node);\n                return node;\n            },\n            \n            removeNode: function(nodeId) {\n                this.nodes = this.nodes.filter(n => n.id !== nodeId);\n                this.edges = this.edges.filter(e => e.from !== nodeId && e.to !== nodeId);\n            },\n            \n            addEdge: function(from, to, weight) {\n                if (from === to) return null; // no self-loops\n                \n                // Check if edge already exists\n                const exists = this.edges.some(e => \n                    (e.from === from && e.to === to) || (e.from === to && e.to === from));\n                if (exists) return null;\n                \n                const edge = { from, to, weight: weight || 1 };\n                this.edges.push(edge);\n                return edge;\n            },\n            \n            removeEdge: function(from, to) {\n                this.edges = this.edges.filter(e => \n                    !((e.from === from && e.to === to) || (e.from === to && e.to === from)));\n            },\n            \n            getNode: function(id) {\n                return this.nodes.find(n => n.id === id);\n            },\n            \n            getNeighbors: function(nodeId) {\n                return this.edges\n                    .filter(e => e.from === nodeId || e.to === nodeId)\n                    .map(e => e.from === nodeId ? e.to : e.from);\n            },\n            \n            isConnected: function() {\n                if (this.nodes.length === 0) return false;\n                const visited = new Set();\n                const queue = [this.nodes[0].id];\n                \n                while (queue.length > 0) {\n                    const current = queue.shift();\n                    visited.add(current);\n                    \n                    for (const neighbor of this.getNeighbors(current)) {\n                        if (!visited.has(neighbor)) {\n                            queue.push(neighbor);\n                        }\n                    }\n                }\n                \n                return visited.size === this.nodes.length;\n            },\n            \n            hasCycle: function() {\n                const visited = new Set();\n                \n                for (const node of this.nodes) {\n                    if (!visited.has(node.id) && this.hasCycleDFS(node.id, -1, visited)) {\n                        return true;\n                    }\n                }\n                return false;\n            },\n            \n            hasCycleDFS: function(nodeId, parentId, visited) {\n                visited.add(nodeId);\n                \n                for (const neighbor of this.getNeighbors(nodeId)) {\n                    if (!visited.has(neighbor)) {\n                        if (this.hasCycleDFS(neighbor, nodeId, visited)) {\n                            return true;\n                        }\n                    } else if (neighbor !== parentId) {\n                        return true;\n                    }\n                }\n                return false;\n            },\n            \n            findPath: function(from, to, algorithm) {\n                if (from === to) return [from];\n                \n                if (algorithm === 'bfs') {\n                    return this.bfs(from, to);\n                } else if (algorithm === 'dfs') {\n                    return this.dfs(from, to);\n                } else if (algorithm === 'dijkstra') {\n                    return this.dijkstra(from, to);\n                }\n                return [];\n            },\n            \n            bfs: function(start, end) {\n                const queue = [[start]];\n                const visited = new Set([start]);\n                \n                while (queue.length > 0) {\n                    const path = queue.shift();\n                    const node = path[path.length - 1];\n                    \n                    if (node === end) return path;\n                    \n                    for (const neighbor of this.getNeighbors(node)) {\n                        if (!visited.has(neighbor)) {\n                            visited.add(neighbor);\n                            queue.push([...path, neighbor]);\n                        }\n                    }\n                }\n                return [];\n            },\n            \n            dfs: function(start, end, visited = new Set(), path = []) {\n                visited.add(start);\n                path.push(start);\n                \n                if (start === end) return path;\n                \n                for (const neighbor of this.getNeighbors(start)) {\n                    if (!visited.has(neighbor)) {\n                        const result = this.dfs(neighbor, end, visited, path);\n                        if (result.length > 0) return result;\n                        path.pop();\n                    }\n                }\n                return [];\n            },\n            \n            dijkstra: function(start, end) {\n                const distances = {};\n                const previous = {};\n                const nodes = new Set(this.nodes.map(n => n.id));\n                const path = [];\n                \n                for (const node of nodes) {\n                    distances[node] = Infinity;\n                    previous[node] = null;\n                }\n                distances[start] = 0;\n                \n                while (nodes.size > 0) {\n                    let smallest = null;\n                    for (const node of nodes) {\n                        if (smallest === null || distances[node] < distances[smallest]) {\n                            smallest = node;\n                        }\n                    }\n                    \n                    if (smallest === end) {\n                        while (previous[smallest]) {\n                            path.push(smallest);\n                            smallest = previous[smallest];\n                        }\n                        path.push(start);\n                        return path.reverse();\n                    }\n                    \n                    nodes.delete(smallest);\n                    \n                    for (const neighbor of this.getNeighbors(smallest)) {\n                        const edge = this.edges.find(e => \n                            (e.from === smallest && e.to === neighbor) || \n                            (e.from === neighbor && e.to === smallest));\n                        const alt = distances[smallest] + (edge ? edge.weight : 1);\n                        \n                        if (alt < distances[neighbor]) {\n                            distances[neighbor] = alt;\n                            previous[neighbor] = smallest;\n                        }\n                    }\n                }\n                return [];\n            },\n            \n            findConnectedComponents: function() {\n                const visited = new Set();\n                const components = [];\n                \n                for (const node of this.nodes) {\n                    if (!visited.has(node.id)) {\n                        const component = [];\n                        const queue = [node.id];\n                        \n                        while (queue.length > 0) {\n                            const current = queue.shift();\n                            if (visited.has(current)) continue;\n                            \n                            visited.add(current);\n                            component.push(current);\n                            \n                            for (const neighbor of this.getNeighbors(current)) {\n                                if (!visited.has(neighbor)) {\n                                    queue.push(neighbor);\n                                }\n                            }\n                        }\n                        components.push(component);\n                    }\n                }\n                return components;\n            },\n            \n            findMST: function() {\n                // Kruskal's algorithm\n                if (this.nodes.length === 0) return [];\n                \n                const mst = [];\n                const parent = {};\n                const rank = {};\n                \n                // Initialize each node as its own parent\n                for (const node of this.nodes) {\n                    parent[node.id] = node.id;\n                    rank[node.id] = 0;\n                }\n                \n                // Sort edges by weight\n                const sortedEdges = [...this.edges].sort((a, b) => a.weight - b.weight);\n                \n                for (const edge of sortedEdges) {\n                    const root1 = this.find(edge.from, parent);\n                    const root2 = this.find(edge.to, parent);\n                    \n                    if (root1 !== root2) {\n                        mst.push(edge);\n                        this.union(root1, root2, parent, rank);\n                    }\n                }\n                \n                return mst;\n            },\n            \n            find: function(node, parent) {\n                if (parent[node] !== node) {\n                    parent[node] = this.find(parent[node], parent);\n                }\n                return parent[node];\n            },\n            \n            union: function(a, b, parent, rank) {\n                const rootA = this.find(a, parent);\n                const rootB = this.find(b, parent);\n                \n                if (rootA === rootB) return;\n                \n                if (rank[rootA] < rank[rootB]) {\n                    parent[rootA] = rootB;\n                } else if (rank[rootA] > rank[rootB]) {\n                    parent[rootB] = rootA;\n                } else {\n                    parent[rootB] = rootA;\n                    rank[rootA]++;\n                }\n            }\n        };\n        \n        // UI State\n        const state = {\n            selectedNode: null,\n            selectedEdge: null,\n            mode: 'select', // 'select', 'addNode', 'addEdge', 'removeNode', 'removeEdge'\n            highlightedPath: [],\n            highlightedEdges: [],\n            mst: [],\n            connectedComponents: []\n        };\n        \n        // Canvas setup\n        const canvas = document.getElementById('graphCanvas');\n        const ctx = canvas.getContext('2d');\n        \n        // UI Elements\n        const statusDiv = document.getElementById('status');\n        const graphInfoDiv = document.getElementById('graphInfo');\n        const adjacencyList = document.getElementById('adjacencyList').querySelector('tbody');\n        \n        // Event Listeners\n        document.getElementById('addNode').addEventListener('click', () => {\n            state.mode = 'addNode';\n            updateStatus('Click on canvas to add a new node');\n        });\n        \n        document.getElementById('nodeName').addEventListener('click', () => {\n            const newName = prompt('Enter new default node name:', document.getElementById('nodeName').value);\n            if (newName !== null) {\n                document.getElementById('nodeName').value = newName;\n            }\n        });\n        \n        document.getElementById('removeNode').addEventListener('click', () => {\n            state.mode = 'removeNode';\n            updateStatus('Click on a node to remove it');\n        });\n        \n        document.getElementById('clearGraph').addEventListener('click', () => {\n            if (confirm('Are you sure you want to clear the graph?')) {\n                graph.nodes = [];\n                graph.edges = [];\n                state.highlightedPath = [];\n                state.highlightedEdges = [];\n                state.mst = [];\n                state.connectedComponents = [];\n                updateGraph();\n            }\n        });\n        \n        document.getElementById('addEdge').addEventListener('click', () => {\n            state.mode = 'addEdge';\n            state.selectedNode = null;\n            updateStatus('Click on first node, then second node to add edge');\n        });\n        \n        document.getElementById('removeEdge').addEventListener('click', () => {\n            state.mode = 'removeEdge';\n            updateStatus('Click on an edge to remove it');\n        });\n        \n        document.getElementById('randomGraph').addEventListener('click', () => {\n            const nodeCount = parseInt(document.getElementById('randomNodes').value);\n            const edgeCount = parseInt(document.getElementById('randomEdges').value);\n            \n            if (nodeCount < 2 || edgeCount < 1) {\n                alert('Invalid parameters for random graph');\n                return;\n            }\n            \n            if (edgeCount > nodeCount * (nodeCount - 1) / 2) {\n                alert('Too many edges for the number of nodes');\n                return;\n            }\n            \n            // Clear existing graph\n            graph.nodes = [];\n            graph.edges = [];\n            graph.nextId = 1;\n            \n            // Add nodes\n            for (let i = 0; i < nodeCount; i++) {\n                graph.addNode(`Node ${i+1}`);\n            }\n            \n            // Add edges\n            const possibleEdges = [];\n            for (let i = 0; i < nodeCount; i++) {\n                for (let j = i + 1; j < nodeCount; j++) {\n                    possibleEdges.push([i+1, j+1]);\n                }\n            }\n            \n            // Shuffle possible edges\n            for (let i = possibleEdges.length - 1; i > 0; i--) {\n                const j = Math.floor(Math.random() * (i + 1));\n                [possibleEdges[i], possibleEdges[j]] = [possibleEdges[j], possibleEdges[i]];\n            }\n            \n            // Take the required number of edges\n            for (let i = 0; i < edgeCount; i < possibleEdges.length; i++) {\n                const [from, to] = possibleEdges[i];\n                graph.addEdge(from, to, Math.floor(Math.random() * 10) + 1);\n            }\n            \n            updateGraph();\n            updateStatus(`Generated random graph with ${nodeCount} nodes and ${edgeCount} edges`);\n        });\n        \n        document.getElementById('findPath').addEventListener('click', () => {\n            const from = parseInt(document.getElementById('pathFrom').value);\n            const to = parseInt(document.getElementById('pathTo').value);\n            const algorithm = document.getElementById('pathAlgorithm').value;\n            \n            if (!from || !to) {\n                alert('Please select both source and destination nodes');\n                return;\n            }\n            \n            const path = graph.findPath(from, to, algorithm);\n            \n            if (path.length === 0) {\n                updateStatus(`No path found from ${graph.getNode(from).label} to ${graph.getNode(to).label}`);\n                state.highlightedPath = [];\n            } else {\n                state.highlightedPath = path;\n                \n                // Highlight edges in the path\n                state.highlightedEdges = [];\n                for (let i = 0; i < path.length - 1; i++) {\n                    const edge = graph.edges.find(e => \n                        (e.from === path[i] && e.to === path[i+1]) || \n                        (e.from === path[i+1] && e.to === path[i]));\n                    if (edge) state.highlightedEdges.push(edge);\n                }\n                \n                updateStatus(`Path found (${algorithm}): ${path.map(id => graph.getNode(id).label).join(' → ')}`);\n            }\n            \n            drawGraph();\n        });\n        \n        document.getElementById('detectCycle').addEventListener('click', () => {\n            const hasCycle = graph.hasCycle();\n            if (hasCycle) {\n                updateStatus('Graph contains at least one cycle');\n            } else {\n                updateStatus('Graph is acyclic (no cycles)');\n            }\n        });\n        \n        document.getElementById('findConnected').addEventListener('click', () => {\n            state.connectedComponents = graph.findConnectedComponents();\n            \n            if (state.connectedComponents.length === 1) {\n                updateStatus('Graph is fully connected');\n            } else {\n                updateStatus(`Graph has ${state.connectedComponents.length} connected components`);\n            }\n            \n            drawGraph();\n        });\n        \n        document.getElementById('findMST').addEventListener('click', () => {\n            if (!graph.isConnected()) {\n                alert('Graph must be connected to find MST');\n                return;\n            }\n            \n            state.mst = graph.findMST();\n            updateStatus(`Found Minimum Spanning Tree with ${state.mst.length} edges`);\n            drawGraph();\n        });\n        \n        canvas.addEventListener('click', (e) => {\n            const rect = canvas.getBoundingClientRect();\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            \n            if (state.mode === 'addNode') {\n                const label = document.getElementById('nodeName').value || `Node ${graph.nextId}`;\n                graph.addNode(label);\n                updateGraph();\n                updateStatus(`Added node ${label}`);\n            } \n            else if (state.mode === 'removeNode') {\n                const node = findNodeAt(x, y);\n                if (node) {\n                    graph.removeNode(node.id);\n                    updateGraph();\n                    updateStatus(`Removed node ${node.label}`);\n                }\n            }\n            else if (state.mode === 'addEdge') {\n                const node = findNodeAt(x, y);\n                if (node) {\n                    if (!state.selectedNode) {\n                        state.selectedNode = node;\n                        updateStatus(`Selected ${node.label}, now click destination node`);\n                    } else if (state.selectedNode.id !== node.id) {\n                        const weight = parseInt(document.getElementById('edgeWeight').value) || 1;\n                        const edge = graph.addEdge(state.selectedNode.id, node.id, weight);\n                        if (edge) {\n                            updateStatus(`Added edge between ${state.selectedNode.label} and ${node.label} (weight: ${weight})`);\n                        } else {\n                            updateStatus('Edge already exists');\n                        }\n                        state.selectedNode = null;\n                        updateGraph();\n                    }\n                }\n            }\n            else if (state.mode === 'removeEdge') {\n                const edge = findEdgeAt(x, y);\n                if (edge) {\n                    const fromNode = graph.getNode(edge.from);\n                    const toNode = graph.getNode(edge.to);\n                    graph.removeEdge(edge.from, edge.to);\n                    updateGraph();\n                    updateStatus(`Removed edge between ${fromNode.label} and ${toNode.label}`);\n                }\n            }\n            else { // select mode\n                const node = findNodeAt(x, y);\n                if (node) {\n                    updateStatus(`Selected node ${node.label}`);\n                }\n            }\n        });\n        \n        canvas.addEventListener('mousemove', (e) => {\n            if (state.mode === 'select') {\n                const rect = canvas.getBoundingClientRect();\n                const x = e.clientX - rect.left;\n                const y = e.clientY - rect.top;\n                \n                const node = findNodeAt(x, y);\n                if (node) {\n                    canvas.style.cursor = 'pointer';\n                } else {\n                    const edge = findEdgeAt(x, y);\n                    canvas.style.cursor = edge ? 'pointer' : 'default';\n                }\n            } else {\n                canvas.style.cursor = 'crosshair';\n            }\n        });\n        \n        // Helper functions\n        function findNodeAt(x, y) {\n            for (let i = graph.nodes.length - 1; i >= 0; i--) {\n                const node = graph.nodes[i];\n                const dx = node.x - x;\n                const dy = node.y - y;\n                const distance = Math.sqrt(dx * dx + dy * dy);\n                if (distance <= 20) {\n                    return node;\n                }\n            }\n            return null;\n        }\n        \n        function findEdgeAt(x, y) {\n            for (const edge of graph.edges) {\n                const fromNode = graph.getNode(edge.from);\n                const toNode = graph.getNode(edge.to);\n                \n                if (!fromNode || !toNode) continue;\n                \n                // Simple line-to-point distance check\n                const A = { x: fromNode.x, y: fromNode.y };\n                const B = { x: toNode.x, y: toNode.y };\n                const P = { x, y };\n                \n                const AB = Math.sqrt((B.x-A.x)*(B.x-A.x) + (B.y-A.y)*(B.y-A.y));\n                const AP = (P.x-A.x)*(B.x-A.x) + (P.y-A.y)*(B.y-A.y);\n                const t = AP / (AB*AB);\n                \n                if (t < 0 || t > 1) continue;\n                \n                const projection = {\n                    x: A.x + t*(B.x-A.x),\n                    y: A.y + t*(B.y-A.y)\n                };\n                \n                const distance = Math.sqrt((P.x-projection.x)*(P.x-projection.x) + (P.y-projection.y)*(P.y-projection.y));\n                \n                if (distance <= 5) {\n                    return edge;\n                }\n            }\n            return null;\n        }\n        \n        function updateStatus(message) {\n            statusDiv.textContent = message;\n        }\n        \n        function updateGraph() {\n            // Update node lists in path finder\n            const pathFrom = document.getElementById('pathFrom');\n            const pathTo = document.getElementById('pathTo');\n            \n            pathFrom.innerHTML = '';\n            pathTo.innerHTML = '';\n            \n            graph.nodes.forEach(node => {\n                const option = document.createElement('option');\n                option.value = node.id;\n                option.textContent = node.label;\n                pathFrom.appendChild(option.cloneNode(true));\n                pathTo.appendChild(option);\n            });\n            \n            // Update graph info\n            const isConnected = graph.isConnected();\n            const hasCycle = graph.hasCycle();\n            graphInfoDiv.textContent = `Nodes: ${graph.nodes.length}, Edges: ${graph.edges.length}, Connected: ${isConnected ? 'Yes' : 'No'}, Cyclic: ${hasCycle ? 'Yes' : 'No'}`;\n            \n            // Update adjacency list\n            adjacencyList.innerHTML = '';\n            graph.nodes.forEach(node => {\n                const row = document.createElement('tr');\n                const cell1 = document.createElement('td');\n                const cell2 = document.createElement('td');\n                \n                cell1.textContent = node.label;\n                \n                const neighbors = graph.getNeighbors(node.id);\n                if (neighbors.length > 0) {\n                    cell2.textContent = neighbors.map(id => {\n                        const neighbor = graph.getNode(id);\n                        const edge = graph.edges.find(e => \n                            (e.from === node.id && e.to === id) || \n                            (e.from === id && e.to === node.id));\n                        return `${neighbor.label} (${edge ? edge.weight : '1'})`;\n                    }).join(', ');\n                } else {\n                    cell2.textContent = 'None';\n                }\n                \n                row.appendChild(cell1);\n                row.appendChild(cell2);\n                adjacencyList.appendChild(row);\n            });\n            \n            drawGraph();\n        }\n        \n        function drawGraph() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            // Draw edges\n            for (const edge of graph.edges) {\n                const fromNode = graph.getNode(edge.from);\n                const toNode = graph.getNode(edge.to);\n                \n                if (!fromNode || !toNode) continue;\n                \n                // Highlight path edges\n                const isPathEdge = state.highlightedEdges.some(e => \n                    (e.from === edge.from && e.to === edge.to) || \n                    (e.from === edge.to && e.to === edge.from));\n                \n                // Highlight MST edges\n                const isMSTEdge = state.mst.some(e => \n                    (e.from === edge.from && e.to === edge.to) || \n                    (e.from === edge.to && e.to === edge.from));\n                \n                // Highlight connected component edges\n                let isComponentEdge = false;\n                for (const component of state.connectedComponents) {\n                    if (component.includes(edge.from) && component.includes(edge.to)) {\n                        isComponentEdge = true;\n                        break;\n                    }\n                }\n                \n                ctx.beginPath();\n                ctx.moveTo(fromNode.x, fromNode.y);\n                ctx.lineTo(toNode.x, toNode.y);\n                \n                if (isPathEdge) {\n                    ctx.strokeStyle = 'red';\n                    ctx.lineWidth = 3;\n                } else if (isMSTEdge) {\n                    ctx.strokeStyle = 'green';\n                    ctx.lineWidth = 3;\n                } else if (isComponentEdge && state.connectedComponents.length > 0) {\n                    ctx.strokeStyle = 'blue';\n                    ctx.lineWidth = 2;\n                } else {\n                    ctx.strokeStyle = 'black';\n                    ctx.lineWidth = 1;\n                }\n                \n                ctx.stroke();\n                \n                // Draw edge weight\n                if (edge.weight !== 1) {\n                    const midX = (fromNode.x + toNode.x) / 2;\n                    const midY = (fromNode.y + toNode.y) / 2;\n                    \n                    ctx.fillStyle = 'white';\n                    ctx.fillRect(midX - 10, midY - 10, 20, 20);\n                    \n                    ctx.fillStyle = 'black';\n                    ctx.textAlign = 'center';\n                    ctx.textBaseline = 'middle';\n                    ctx.fillText(edge.weight.toString(), midX, midY);\n                }\n            }\n            \n            // Draw nodes\n            for (const node of graph.nodes) {\n                ctx.beginPath();\n                ctx.arc(node.x, node.y, 20, 0, Math.PI * 2);\n                \n                // Highlight path nodes\n                const isPathNode = state.highlightedPath.includes(node.id);\n                \n                // Highlight connected component nodes\n                let isComponentNode = false;\n                for (const component of state.connectedComponents) {\n                    if (component.includes(node.id)) {\n                        isComponentNode = true;\n                        break;\n                    }\n                }\n                \n                if (isPathNode) {\n                    ctx.fillStyle = 'red';\n                } else if (isComponentNode && state.connectedComponents.length > 0) {\n                    ctx.fillStyle = 'blue';\n                } else {\n                    ctx.fillStyle = 'lightgray';\n                }\n                \n                ctx.fill();\n                ctx.strokeStyle = 'black';\n                ctx.lineWidth = 1;\n                ctx.stroke();\n                \n                // Draw node label\n                ctx.fillStyle = 'black';\n                ctx.textAlign = 'center';\n                ctx.textBaseline = 'middle';\n                ctx.fillText(node.label, node.x, node.y);\n            }\n        }\n        \n        // Initialize\n        updateGraph();\n    </script>\n</body>\n</html>"
  },
