    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Red-Black Tree — A Visual, Aesthetic Demonstration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Merriweather:wght@300;400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071022;\n    --card-glass: rgba(255,255,255,0.04);\n    --accent: #8be9fd;\n    --soft: #b7c3d6;\n    --muted: rgba(255,255,255,0.06);\n    --glass-border: rgba(255,255,255,0.06);\n    --red: #ff5c7c;\n    --black-node: #1b2b3a;\n    --black-stroke: #0b1320;\n    --glow: rgba(139,233,253,0.12);\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: 'Poppins', system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 700px at 10% 20%, rgba(8,24,38,0.6), transparent),\n                radial-gradient(900px 500px at 90% 80%, rgba(8,12,38,0.5), transparent),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #e6eef6;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Subtle animated background sheen */\n  .sheen {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    mix-blend-mode:overlay;\n    opacity:0.9;\n    background:\n      radial-gradient(800px 500px at 15% 10%, rgba(139,233,253,0.06), transparent 8%),\n      radial-gradient(600px 300px at 85% 90%, rgba(255,95,150,0.03), transparent 6%);\n    animation: float 14s ease-in-out infinite;\n    filter: blur(20px);\n  }\n  @keyframes float {\n    0% {transform: translateY(0px) translateX(0px) rotate(-2deg);}\n    50%{transform: translateY(-12px) translateX(8px) rotate(2deg);}\n    100%{transform: translateY(0px) translateX(0px) rotate(-2deg);}\n  }\n\n  .container {\n    max-width:1100px;\n    margin:48px auto;\n    padding:36px;\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap:28px;\n  }\n\n  .panel {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid var(--glass-border);\n    border-radius: 18px;\n    padding:26px;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6);\n    backdrop-filter: blur(8px) saturate(140%);\n    position:relative;\n    overflow:hidden;\n  }\n\n  .title {\n    display:flex;\n    align-items:center;\n    gap:14px;\n    margin-bottom:10px;\n  }\n  .logo {\n    width:60px;height:60px;border-radius:12px;\n    display:grid;place-items:center;\n    background:linear-gradient(135deg,#0ea5a4,#7c3aed);\n    box-shadow: 0 6px 20px rgba(124,58,237,0.18), inset 0 -6px 20px rgba(0,0,0,0.18);\n    font-weight:700;color:white;font-size:20px;font-family:'Merriweather',serif;\n  }\n  h1 {\n    margin:0;\n    font-size:20px;\n    letter-spacing:0.2px;\n    font-weight:700;\n    color: #f6fbff;\n  }\n  p.lead {\n    margin:6px 0 18px 0;\n    color:var(--soft);\n    font-size:13px;\n    line-height:1.45;\n  }\n\n  .controls {\n    display:flex;\n    gap:12px;\n    margin-top:12px;\n  }\n\n  .btn {\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--accent);\n    cursor:pointer;\n    font-weight:600;\n    font-size:13px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    box-shadow: 0 6px 18px rgba(11,19,30,0.45);\n    transition:transform .18s ease, box-shadow .18s ease, opacity .12s ease;\n    border:1px solid rgba(139,233,253,0.08);\n  }\n  .btn:active{ transform: translateY(1px) }\n  .btn.primary {\n    background: linear-gradient(135deg,#7c3aed,#06b6d4);\n    color:white;\n    box-shadow: 0 10px 30px rgba(99,102,241,0.18), 0 2px 8px rgba(6,6,24,0.6);\n    border: none;\n  }\n  .btn.ghost {\n    color: var(--soft);\n    border: 1px dashed rgba(255,255,255,0.04);\n    background:transparent;\n  }\n\n  .legend {\n    margin-top:18px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--soft);\n    font-size:13px;\n  }\n  .swatch {\n    width:36px;height:36px;border-radius:10px;display:grid;place-items:center;\n    color:white;font-weight:700;font-size:13px;\n    box-shadow: 0 6px 18px rgba(0,0,0,0.5), inset 0 -6px 14px rgba(255,255,255,0.02);\n  }\n  .swatch.red { background: linear-gradient(180deg,#ff7b96,#ff476a); }\n  .swatch.black { background: linear-gradient(180deg,#0b1220,#202b3a); color:#cfe8ff; }\n\n  /* RHS: showcase */\n  .showcase {\n    position:relative; overflow:hidden;\n    min-height:520px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .board {\n    width:100%;\n    height:520px;\n    border-radius:16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 30px 60px rgba(2,6,23,0.6);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* operation badge */\n  .op {\n    position:absolute;\n    left:48px; top:26px;\n    padding:10px 14px;\n    border-radius:12px;\n    background:linear-gradient(90deg, rgba(12,18,30,0.8), rgba(8,12,20,0.5));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--accent);\n    font-weight:600;\n    font-size:13px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    box-shadow: 0 8px 26px rgba(3,8,18,0.6);\n    backdrop-filter: blur(6px);\n  }\n\n  .op .dot {\n    width:10px;height:10px;border-radius:50%;\n    background:var(--accent);\n    box-shadow:0 6px 18px rgba(8,150,200,0.18);\n  }\n\n  /* timeline */\n  .timeline {\n    position:absolute;\n    right:28px; bottom:18px;\n    display:flex;\n    gap:8px;\n    align-items:center;\n    color:var(--soft);\n    font-size:13px;\n  }\n  .ticks {\n    display:flex;gap:6px;align-items:center;\n    padding:8px;border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .tick {\n    width:12px;height:12px;border-radius:4px;background:rgba(255,255,255,0.03);\n    transition:all .36s cubic-bezier(.2,.9,.2,1);\n    box-shadow: inset 0 -2px 4px rgba(0,0,0,0.5);\n  }\n  .tick.active{ background:linear-gradient(135deg,#06b6d4,#7c3aed); transform:scale(1.22); box-shadow:0 8px 22px rgba(99,102,241,0.12) }\n\n  /* SVG nodes */\n  svg { width:100%; height:100%; display:block; }\n  .node {\n    cursor:default;\n    transition: transform 800ms cubic-bezier(.2,.9,.2,1), opacity 420ms ease, filter 420ms ease;\n  }\n\n  .node .circle {\n    stroke: rgba(0,0,0,0.6);\n    stroke-width:2;\n    filter: drop-shadow(0 8px 18px rgba(3,8,18,0.5));\n    transition: fill 420ms ease, stroke 420ms ease;\n  }\n\n  .node .label {\n    font-family:'Merriweather', serif;\n    font-weight:700;\n    font-size:14px;\n    fill: white;\n    pointer-events:none;\n    text-anchor:middle;\n    dominant-baseline:central;\n    transition: fill 420ms ease;\n    text-shadow: 0 2px 6px rgba(0,0,0,0.6);\n  }\n\n  .node.red .circle {\n    fill: url(#redGrad);\n  }\n  .node.red .label { fill: #fff7f8; }\n\n  .node.black .circle {\n    fill: url(#blackGrad);\n  }\n  .node.black .label { fill: #dbeefc; }\n\n  /* subtle highlight on hover (non-interactive emphasis) */\n  .node:hover { transform: scale(1.06); }\n\n  /* edges */\n  .edge {\n    stroke:linear-gradient(90deg,#7c3aed,#06b6d4);\n    stroke-width:3;\n    fill:none;\n    stroke-linecap:round;\n    opacity:1;\n    transition: opacity 420ms ease;\n  }\n\n  /* footer microtext */\n  .micro {\n    margin-top:18px;color:var(--soft);font-size:12px;\n  }\n\n  /* small responsive */\n  @media (max-width:1060px){\n    .container { grid-template-columns: 1fr; padding:20px; gap:18px; }\n    .showcase { order: -1; }\n  }\n</style>\n</head>\n<body>\n<div class=\"sheen\" aria-hidden=\"true\"></div>\n\n<div class=\"container\">\n  <div class=\"panel\" style=\"min-height:520px;\">\n    <div class=\"title\">\n      <div class=\"logo\">RB</div>\n      <div style=\"flex:1\">\n        <h1>Red-Black Tree — Elegant Visual Demonstration</h1>\n        <p class=\"lead\">A refined, animated illustration of the Red-Black Tree concept. Observe insertion, recoloring, and rotation operations as the tree evolves. Interactivity is intentionally minimal — press Play to watch the curated animation.</p>\n      </div>\n    </div>\n\n    <div style=\"display:flex;flex-direction:column;gap:12px\">\n      <div style=\"display:flex;flex-direction:column;gap:8px\">\n        <div style=\"display:flex;gap:12px;align-items:center;\">\n          <button id=\"playBtn\" class=\"btn primary\" title=\"Play animation\">\n            ▶ Play Animation\n          </button>\n          <button id=\"resetBtn\" class=\"btn ghost\" title=\"Reset to empty\">\n            ⟲ Reset\n          </button>\n        </div>\n        <div class=\"micro\" style=\"max-width:360px;\">\n          Tip: This demonstration walks through a short insertion sequence that includes a rotation and recoloring to preserve Red-Black Tree properties. The focus is on clarity and aesthetic presentation rather than interactive editing.\n        </div>\n      </div>\n\n      <div class=\"legend\">\n        <div class=\"swatch red\">R</div>\n        <div style=\"line-height:1.05\">\n          <div style=\"font-weight:700;color:#ffdfe6\">Red Node</div>\n          <div style=\"color:var(--soft);font-size:13px\">May not have a red child</div>\n        </div>\n\n        <div style=\"width:18px\"></div>\n\n        <div class=\"swatch black\">B</div>\n        <div style=\"line-height:1.05\">\n          <div style=\"font-weight:700;color:#d8eefe\">Black Node</div>\n          <div style=\"color:var(--soft);font-size:13px\">Root is always black</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:8px;color:var(--soft);font-size:13px;\">\n        Curated insertion sequence: 10 → 20 → 30 → 15 → 25 → 5 → 35\n      </div>\n    </div>\n  </div>\n\n  <div class=\"panel showcase\" aria-hidden=\"false\">\n    <div class=\"board\" id=\"board\">\n      <div class=\"op\" id=\"opBadge\"><div class=\"dot\"></div><div id=\"opText\">Idle • Awaiting</div></div>\n\n      <svg id=\"svgroot\" viewBox=\"0 0 900 520\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"false\">\n        <defs>\n          <linearGradient id=\"redGrad\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ff8aa1\"/>\n            <stop offset=\"1\" stop-color=\"#ff4b6a\"/>\n          </linearGradient>\n          <linearGradient id=\"blackGrad\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#1b2733\"/>\n            <stop offset=\"1\" stop-color=\"#111827\"/>\n          </linearGradient>\n\n          <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"8\" result=\"b\"/>\n            <feMerge>\n              <feMergeNode in=\"b\" />\n              <feMergeNode in=\"SourceGraphic\" />\n            </feMerge>\n          </filter>\n        </defs>\n\n        <!-- edges container -->\n        <g id=\"edges\"></g>\n\n        <!-- nodes container -->\n        <g id=\"nodes\"></g>\n\n      </svg>\n\n      <div class=\"timeline\" style=\"right:18px;\">\n        <div style=\"color:var(--soft);font-size:13px;margin-right:8px\">Step</div>\n        <div class=\"ticks\" id=\"ticks\"></div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n  // Minimal, curated animation sequence for aesthetic demonstration.\n  // Nodes: 10,20,30,15,25,5,35 with predetermined positions per step.\n  (function(){\n    const steps = [\n      // Step 0: empty\n      { op: 'Idle • Awaiting', nodes: [], edges: [] },\n\n      // Step 1: Insert 10 -> root (black)\n      { op: 'Insert 10 → root (black)', nodes: [\n        {id: '10', label:'10', x:450, y:120, color:'black', show:true},\n      ], edges: [] },\n\n      // Step 2: Insert 20 -> red right child of 10\n      { op: 'Insert 20 (red child)', nodes: [\n        {id:'10', label:'10', x:450, y:120, color:'black', show:true},\n        {id:'20', label:'20', x:650, y:240, color:'red', show:true},\n      ], edges: [ ['10','20'] ] },\n\n      // Step 3: Insert 30 -> triggers left rotation around 10 => 20 becomes root\n      // We'll animate nodes moving to new positions\n      { op: 'Insert 30 → rotation (left)', nodes: [\n        {id:'20', label:'20', x:450, y:120, color:'black', show:true},\n        {id:'10', label:'10', x:270, y:240, color:'red', show:true},\n        {id:'30', label:'30', x:630, y:240, color:'red', show:true},\n      ], edges: [ ['20','10'], ['20','30'] ] },\n\n      // Step 4: Insert 15 -> recolor (10 & 30 -> black), root stays black\n      { op: 'Insert 15 → recolor', nodes: [\n        {id:'20', label:'20', x:450, y:120, color:'black', show:true},\n        {id:'10', label:'10', x:270, y:240, color:'black', show:true},\n        {id:'30', label:'30', x:630, y:240, color:'black', show:true},\n        {id:'15', label:'15', x:340, y:360, color:'red', show:true},\n      ], edges: [ ['20','10'], ['20','30'], ['10','15'] ] },\n\n      // Step 5: Insert 25 -> simple insertion under 30\n      { op: 'Insert 25 (no rotation)', nodes: [\n        {id:'20', label:'20', x:450, y:120, color:'black', show:true},\n        {id:'10', label:'10', x:270, y:240, color:'black', show:true},\n        {id:'30', label:'30', x:630, y:240, color:'black', show:true},\n        {id:'15', label:'15', x:340, y:360, color:'red', show:true},\n        {id:'25', label:'25', x:560, y:360, color:'red', show:true},\n      ], edges: [ ['20','10'], ['20','30'], ['10','15'], ['30','25'] ] },\n\n      // Step 6: Insert 5 -> left child of 10\n      { op: 'Insert 5 (leaf)', nodes: [\n        {id:'20', label:'20', x:450, y:120, color:'black', show:true},\n        {id:'10', label:'10', x:270, y:240, color:'black', show:true},\n        {id:'30', label:'30', x:630, y:240, color:'black', show:true},\n        {id:'15', label:'15', x:340, y:360, color:'red', show:true},\n        {id:'25', label:'25', x:560, y:360, color:'red', show:true},\n        {id:'5', label:'5', x:200, y:360, color:'red', show:true},\n      ], edges: [ ['20','10'], ['20','30'], ['10','15'], ['30','25'], ['10','5'] ] },\n\n      // Step 7: Insert 35 -> final tree with node 35\n      { op: 'Insert 35 → balanced', nodes: [\n        {id:'20', label:'20', x:450, y:120, color:'black', show:true},\n        {id:'10', label:'10', x:270, y:240, color:'black', show:true},\n        {id:'30', label:'30', x:630, y:240, color:'black', show:true},\n        {id:'15', label:'15', x:340, y:360, color:'red', show:true},\n        {id:'25', label:'25', x:560, y:360, color:'red', show:true},\n        {id:'5', label:'5', x:200, y:360, color:'red', show:true},\n        {id:'35', label:'35', x:700, y:360, color:'red', show:true},\n      ], edges: [\n        ['20','10'], ['20','30'], ['10','15'], ['30','25'], ['10','5'], ['30','35']\n      ] },\n    ];\n\n    // DOM references\n    const svg = document.getElementById('svgroot');\n    const nodesLayer = document.getElementById('nodes');\n    const edgesLayer = document.getElementById('edges');\n    const opText = document.getElementById('opText');\n    const playBtn = document.getElementById('playBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const ticksEl = document.getElementById('ticks');\n\n    // Create tick indicators\n    for (let i=0; i<steps.length; i++){\n      const t = document.createElement('div');\n      t.className = 'tick' + (i===0 ? ' active' : '');\n      ticksEl.appendChild(t);\n    }\n\n    // Maintain a map of node elements by id\n    const nodeElems = new Map();\n\n    // Helper to create node SVG group\n    function createNode(id,label){\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('class','node');\n      g.setAttribute('data-id',id);\n      g.style.transition = 'transform 700ms cubic-bezier(.2,.9,.2,1), opacity 420ms ease';\n      // build circle and label\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('class','circle');\n      circle.setAttribute('cx',0); circle.setAttribute('cy',0); circle.setAttribute('r',28);\n      circle.setAttribute('stroke-width',2);\n      circle.style.transition = 'fill 420ms ease, stroke 420ms ease';\n      circle.style.filter = 'drop-shadow(0 10px 20px rgba(3,8,18,0.5))';\n      const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('class','label');\n      text.setAttribute('x',0); text.setAttribute('y',0);\n      text.textContent = label;\n\n      g.appendChild(circle);\n      g.appendChild(text);\n      nodesLayer.appendChild(g);\n      nodeElems.set(id, {g,circle,text,visible:true});\n      // initial off-screen\n      g.style.opacity = 0;\n      g.style.transform = `translate(${450}px, ${520}px) scale(0.9)`;\n      return nodeElems.get(id);\n    }\n\n    // Helper to draw edges as paths (curved)\n    function edgeKey(a,b){ return a+'-'+b; }\n    const edgeElems = new Map();\n\n    function createEdge(aId,bId){\n      const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n      path.setAttribute('class','edge');\n      path.setAttribute('stroke','#84f1ff'); // fallback\n      path.setAttribute('stroke-width',3);\n      path.setAttribute('fill','none');\n      path.style.transition = 'opacity 360ms ease';\n      edgesLayer.appendChild(path);\n      edgeElems.set(edgeKey(aId,bId), {path,aId,bId});\n      return path;\n    }\n\n    // Update step visuals\n    let currentStepIndex = 0;\n    let playing = false;\n    let playTimer = null;\n\n    function goToStep(index){\n      if (index < 0) index = 0;\n      if (index >= steps.length) index = steps.length-1;\n      currentStepIndex = index;\n\n      const step = steps[index];\n      opText.textContent = step.op;\n\n      // Update ticks\n      Array.from(ticksEl.children).forEach((el,i)=> el.classList.toggle('active', i===index) );\n\n      // Fade edges while repositioning (for masking abrupt path d changes)\n      edgesLayer.style.transition = 'opacity 220ms ease';\n      edgesLayer.style.opacity = 0.12;\n\n      // Ensure nodes exist\n      const idsNow = new Set(step.nodes.map(n=>n.id));\n      step.nodes.forEach(n=>{\n        if (!nodeElems.has(n.id)) createNode(n.id, n.label);\n        const e = nodeElems.get(n.id);\n        // set label in case\n        e.text.textContent = n.label;\n        // make visible\n        e.g.style.opacity = 1;\n        e.visible = true;\n        // color classes\n        e.g.classList.toggle('red', n.color==='red');\n        e.g.classList.toggle('black', n.color==='black');\n        // position: use CSS transform translate\n        e.g.style.transform = `translate(${n.x}px, ${n.y}px) scale(1)`;\n        // set circle fill instantly (will transition)\n        if (n.color === 'red'){\n          e.circle.setAttribute('fill','url(#redGrad)');\n        } else {\n          e.circle.setAttribute('fill','url(#blackGrad)');\n        }\n      });\n\n      // Hide nodes not in this step\n      nodeElems.forEach((val,id)=>{\n        if (!idsNow.has(id)){\n          // fade out\n          val.g.style.opacity = 0;\n          val.g.style.transform = `translate(450px,520px) scale(0.88)`;\n          val.visible = false;\n          // remove after a delay\n          setTimeout(()=>{\n            try{\n              if (!val.visible){\n                nodesLayer.removeChild(val.g);\n                nodeElems.delete(id);\n              }\n            }catch(e){}\n          }, 700);\n        }\n      });\n\n      // Update edges: create any missing, remove absent\n      const edgeSetNow = new Set(step.edges.map(e=>edgeKey(e[0],e[1])));\n      // create new edges\n      step.edges.forEach(e=>{\n        const k = edgeKey(e[0],e[1]);\n        if (!edgeElems.has(k)){\n          createEdge(e[0],e[1]);\n        }\n      });\n      // remove edges no longer present\n      Array.from(edgeElems.keys()).forEach(k=>{\n        if (!edgeSetNow.has(k)){\n          const ob = edgeElems.get(k);\n          try{ edgesLayer.removeChild(ob.path); }catch(e){}\n          edgeElems.delete(k);\n        }\n      });\n\n      // After slight delay, update path positions and fade edges in\n      setTimeout(()=> {\n        // Recompute paths\n        edgeElems.forEach((obj,k)=>{\n          const a = nodeElems.get(obj.aId);\n          const b = nodeElems.get(obj.bId);\n          if (!a || !b) { obj.path.setAttribute('d',''); return; }\n          // get computed transform to derive x,y\n          // transforms are like translate(xpx, ypx)\n          const ax = parseFloat(a.g.style.transform.split('translate(')[1]) || 0;\n          // extract numbers more robustly:\n          function getXY(g){\n            const t = g.style.transform;\n            const m = t.match(/translate\\(([-0-9.]+)px,\\s*([-0-9.]+)px\\)/);\n            if (m) return [parseFloat(m[1]), parseFloat(m[2])];\n            const m2 = t.match(/translate\\(([-0-9.]+)px\\)/);\n            if (m2) return [parseFloat(m2[1]), 0];\n            return [0,0];\n          }\n          const [x1,y1] = getXY(a.g);\n          const [x2,y2] = getXY(b.g);\n          // create a smooth cubic curve\n          const dx = Math.abs(x2-x1);\n          const cx1 = x1 + dx*0.25;\n          const cx2 = x2 - dx*0.25;\n          const d = `M ${x1} ${y1} C ${cx1} ${y1+28} ${cx2} ${y2-28} ${x2} ${y2}`;\n          obj.path.setAttribute('d', d);\n          // subtle stroke color gradient via stroke-linecap\n          obj.path.setAttribute('stroke', 'url(#edgeGrad)');\n          // Draw animation: stroke-dash trick\n          obj.path.style.strokeDasharray = obj.path.getTotalLength ? obj.path.getTotalLength() : 500;\n          obj.path.style.strokeDashoffset = obj.path.style.strokeDasharray;\n          obj.path.getBoundingClientRect(); // force layout\n          obj.path.style.transition = 'stroke-dashoffset 680ms cubic-bezier(.2,.9,.2,1), opacity 420ms ease';\n          obj.path.style.strokeDashoffset = '0';\n          obj.path.style.opacity = 1.0;\n        });\n\n        // fade edges in\n        edgesLayer.style.opacity = 1.0;\n      }, 80);\n\n      // subtle op badge glow based on step\n      const badge = document.getElementById('opBadge');\n      badge.animate([\n        { boxShadow: '0 8px 20px rgba(6,11,20,0.6), 0 0 0 0 rgba(12,60,80,0)' },\n        { boxShadow: '0 18px 44px rgba(6,11,20,0.8), 0 0 40px rgba(12,60,80,0.06)' },\n        { boxShadow: '0 8px 20px rgba(6,11,20,0.6), 0 0 0 0 rgba(12,60,80,0)' }\n      ], { duration: 1800, easing:'cubic-bezier(.2,.8,.2,1)' });\n    }\n\n    // initialize: start at step 0 (Idle)\n    goToStep(0);\n\n    // Play routine: step through each step with timed intervals\n    function playSequence(){\n      if (playing) return;\n      playing = true;\n      playBtn.textContent = '⏸ Playing...';\n      playBtn.disabled = true;\n      let i = 1; // start from step 1 (skip idle)\n      function next(){\n        goToStep(i);\n        i++;\n        if (i < steps.length){\n          playTimer = setTimeout(next, 1200 + (i===3? 300:0)); // slightly longer around rotation step\n        } else {\n          // final show for a while then enable replay\n          setTimeout(()=> {\n            playBtn.textContent = 'Replay';\n            playBtn.disabled = false;\n            playing = false;\n          }, 1000);\n        }\n      }\n      // small delay to begin\n      setTimeout(next, 300);\n    }\n\n    playBtn.addEventListener('click', ()=>{\n      // if currently idle or finished, start/replay\n      playSequence();\n    });\n\n    resetBtn.addEventListener('click', ()=>{\n      // stop any playing\n      if (playTimer) clearTimeout(playTimer);\n      playing = false;\n      playBtn.textContent = 'Play Animation';\n      playBtn.disabled = false;\n      // clear nodes and edges gracefully\n      nodeElems.forEach((val,id)=>{\n        val.g.style.opacity = 0;\n        val.g.style.transform = `translate(450px,520px) scale(0.88)`;\n      });\n      edgeElems.forEach((val,k)=>{\n        try{ val.path.style.opacity = 0; }catch(e){}\n      });\n      setTimeout(()=> {\n        // purge DOM children of nodes and edges\n        nodeElems.forEach((val,id)=>{\n          try{ nodesLayer.removeChild(val.g); }catch(e){}\n        });\n        nodeElems.clear();\n        edgeElems.forEach((val,k)=>{\n          try{ edgesLayer.removeChild(val.path); }catch(e){}\n        });\n        edgeElems.clear();\n        goToStep(0);\n      }, 520);\n    });\n\n    // Accessibility: allow space/enter to play\n    playBtn.addEventListener('keydown', (e)=> {\n      if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); playSequence(); }\n    });\n\n    // Precreate an SVG linear gradient for edges (subtle)\n    const defs = svg.querySelector('defs');\n    if (defs){\n      const g = document.createElementNS('http://www.w3.org/2000/svg','linearGradient');\n      g.setAttribute('id','edgeGrad');\n      g.setAttribute('x1','0'); g.setAttribute('x2','1');\n      const s1 = document.createElementNS('http://www.w3.org/2000/svg','stop');\n      s1.setAttribute('offset','0'); s1.setAttribute('stop-color','#7c3aed'); s1.setAttribute('stop-opacity','1');\n      const s2 = document.createElementNS('http://www.w3.org/2000/svg','stop');\n      s2.setAttribute('offset','1'); s2.setAttribute('stop-color','#06b6d4'); s2.setAttribute('stop-opacity','1');\n      g.appendChild(s1); g.appendChild(s2);\n      defs.appendChild(g);\n    }\n\n    // small ambient animation to gently float the board's elements for life\n    const nodesAnimate = setInterval(()=> {\n      // apply tiny, non-intrusive jiggle to visible nodes\n      nodeElems.forEach((val,id)=>{\n        if (!val.visible) return;\n        const r = (Math.sin(Date.now()/1000 + id.charCodeAt(0)))*1.2;\n        val.g.style.transform += ` translateY(${r}px)`;\n        // remove after tiny delay so transforms don't accumulate\n        setTimeout(()=> {\n          // revert to original transform by resetting to computed layout from attribute\n          // However this is purely cosmetic; we allow natural transitions to settle\n          // We'll not revert programmatically to keep code simple and aesthetic.\n        }, 1600);\n      });\n    }, 2200);\n\n  })();\n</script>\n</body>\n</html>"
