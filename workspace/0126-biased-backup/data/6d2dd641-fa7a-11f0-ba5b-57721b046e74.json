    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Quick Sort Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 1000px;\n            margin: 0 auto;\n        }\n        .array-container {\n            display: flex;\n            margin: 20px 0;\n            height: 100px;\n            align-items: flex-end;\n        }\n        .array-element {\n            flex: 30px;\n            margin: 0 2px;\n            background-color: #ddd;\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            padding-bottom: 5px;\n            position: relative;\n        }\n        .pivot {\n            background-color: #aaa;\n        }\n        .partition {\n            background-color: #ccc;\n        }\n        .sorted {\n            background-color: #888;\n        }\n        .comparing {\n            background-color: #666;\n            color: white;\n        }\n        .controls {\n            margin: 20px 0;\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n        }\n        .control-group {\n            margin-right: 20px;\n            margin-bottom: 10px;\n        }\n        .explanation {\n            margin: 20px 0;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        .log {\n            height: 100px;\n            overflow-y: auto;\n            border: 1px solid #ccc;\n            padding: 5px;\n            font-family: monospace;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Quick Sort Interactive Demo</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <label for=\"arraySize\">Array Size:</label>\n                <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"30\" value=\"10\">\n                <span id=\"arraySizeValue\">10</span>\n                <button id=\"generateArray\">Generate New Array</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <button id=\"startSort\">Start Quick Sort</button>\n                <button id=\"stepForward\">Step Forward</button>\n                <button id=\"pauseSort\">Pause</button>\n                <button id=\"resetSort\">Reset</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"speed\">Speed:</label>\n                <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\" step=\"100\">\n                <span id=\"speedValue\">500ms</span>\n            </div>\n            \n            <div class=\"control-group\">\n                <label>\n                    <input type=\"checkbox\" id=\"showPartitions\"> Show Partitions\n                </label>\n                <label>\n                    <input type=\"checkbox\" id=\"showPivot\" checked> Show Pivot\n                </label>\n            </div>\n            \n            <div class=\"control-group\">\n                <label for=\"pivotStrategy\">Pivot Strategy:</label>\n                <select id=\"pivotStrategy\">\n                    <option value=\"first\">First Element</option>\n                    <option value=\"last\">Last Element</option>\n                    <option value=\"middle\">Middle Element</option>\n                    <option value=\"random\">Random</option>\n                </select>\n            </div>\n        </div>\n        \n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n        \n        <div class=\"explanation\" id=\"explanation\">\n            <h3>Current Step Explanation</h3>\n            <p id=\"stepExplanation\">Click \"Start Quick Sort\" to begin.</p>\n        </div>\n        \n        <div class=\"log\" id=\"log\">\n            <p>Log messages will appear here...</p>\n        </div>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Manual Partitioning</h3>\n                <label for=\"partitionStart\">Start Index:</label>\n                <input type=\"number\" id=\"partitionStart\" min=\"0\" max=\"9\" value=\"0\">\n                <label for=\"partitionEnd\">End Index:</label>\n                <input type=\"number\" id=\"partitionEnd\" min=\"0\" max=\"9\" value=\"9\">\n                <button id=\"manualPartition\">Partition This Range</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let array = [];\n        let originalArray = [];\n        let animationSpeed = 500;\n        let isSorting = false;\n        let isPaused = false;\n        let sortSteps = [];\n        let currentStep = 0;\n        let sortInterval = null;\n        let callStack = [];\n        \n        // DOM elements\n        const arrayContainer = document.getElementById('arrayContainer');\n        const arraySizeInput = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const generateArrayBtn = document.getElementById('generateArray');\n        const startSortBtn = document.getElementById('startSort');\n        const stepForwardBtn = document.getElementById('stepForward');\n        const pauseSortBtn = document.getElementById('pauseSort');\n        const resetSortBtn = document.getElementById('resetSort');\n        const speedInput = document.getElementById('speed');\n        const speedValue = document.getElementById('speedValue');\n        const showPartitionsCheckbox = document.getElementById('showPartitions');\n        const showPivotCheckbox = document.getElementById('showPivot');\n        const pivotStrategySelect = document.getElementById('pivotStrategy');\n        const stepExplanation = document.getElementById('stepExplanation');\n        const logElement = document.getElementById('log');\n        const partitionStartInput = document.getElementById('partitionStart');\n        const partitionEndInput = document.getElementById('partitionEnd');\n        const manualPartitionBtn = document.getElementById('manualPartition');\n        \n        // Initialize\n        function init() {\n            generateArray();\n            setupEventListeners();\n        }\n        \n        function setupEventListeners() {\n            arraySizeInput.addEventListener('input', updateArraySizeValue);\n            generateArrayBtn.addEventListener('click', generateArray);\n            startSortBtn.addEventListener('click', startQuickSort);\n            stepForwardBtn.addEventListener('click', stepForward);\n            pauseSortBtn.addEventListener('click', togglePause);\n            resetSortBtn.addEventListener('click', resetSort);\n            speedInput.addEventListener('input', updateSpeed);\n            manualPartitionBtn.addEventListener('click', manualPartition);\n        }\n        \n        function updateArraySizeValue() {\n            const size = arraySizeInput.value;\n            arraySizeValue.textContent = size;\n            partitionEndInput.max = size - 1;\n            partitionEndInput.value = size - 1;\n        }\n        \n        function updateSpeed() {\n            animationSpeed = speedInput.value;\n            speedValue.textContent = `${animationSpeed}ms`;\n            \n            if (isSorting && !isPaused) {\n                clearInterval(sortInterval);\n                sortInterval = setInterval(stepForward, animationSpeed);\n            }\n        }\n        \n        function generateArray() {\n            const size = parseInt(arraySizeInput.value);\n            array = [];\n            for (let i = 0; i < size; i++) {\n                array.push(Math.floor(Math.random() * 90) + 10);\n            }\n            originalArray = [...array];\n            renderArray();\n            resetSortState();\n            logMessage(`Generated new array: ${array.join(', ')}`);\n        }\n        \n        function renderArray(highlight = [], pivotIndex = -1, partitions = []) {\n            arrayContainer.innerHTML = '';\n            const maxValue = Math.max(...array, 10);\n            \n            array.forEach((value, index) => {\n                const element = document.createElement('div');\n                element.className = 'array-element';\n                element.style.height = `${(value / maxValue) * 90}px`;\n                element.textContent = value;\n                \n                if (partitions.length > 0 && showPartitionsCheckbox.checked) {\n                    const [partStart, partEnd] = partitions[partitions.length - 1];\n                    if (index >= partStart && index <= partEnd) {\n                        element.classList.add('partition');\n                    }\n                }\n                \n                if (highlight.includes(index)) {\n                    element.classList.add('comparing');\n                }\n                \n                if (index === pivotIndex && showPivotCheckbox.checked) {\n                    element.classList.add('pivot');\n                }\n                \n                // Mark sorted positions\n                if (callStack.some(call => call.sorted && index >= call.low && index <= call.high)) {\n                    element.classList.add('sorted');\n                }\n                \n                arrayContainer.appendChild(element);\n            });\n        }\n        \n        function logMessage(message) {\n            const logEntry = document.createElement('p');\n            logEntry.textContent = message;\n            logElement.appendChild(logEntry);\n            logElement.scrollTop = logElement.scrollHeight;\n        }\n        \n        function resetSortState() {\n            clearInterval(sortInterval);\n            isSorting = false;\n            isPaused = false;\n            sortSteps = [];\n            currentStep = 0;\n            callStack = [];\n            stepExplanation.textContent = 'Click \"Start Quick Sort\" to begin.';\n            logMessage('Sorting state reset.');\n        }\n        \n        function resetSort() {\n            array = [...originalArray];\n            renderArray();\n            resetSortState();\n            logMessage('Array reset to original state.');\n        }\n        \n        function togglePause() {\n            if (!isSorting) return;\n            \n            isPaused = !isPaused;\n            pauseSortBtn.textContent = isPaused ? 'Resume' : 'Pause';\n            \n            if (isPaused) {\n                clearInterval(sortInterval);\n                logMessage('Sorting paused.');\n            } else {\n                sortInterval = setInterval(stepForward, animationSpeed);\n                logMessage('Sorting resumed.');\n            }\n        }\n        \n        function startQuickSort() {\n            if (isSorting) return;\n            \n            resetSortState();\n            isSorting = true;\n            callStack.push({ low: 0, high: array.length - 1, pivot: -1, state: 'start' });\n            logMessage('Starting Quick Sort...');\n            \n            // Generate all steps for visualization\n            quickSortSteps(0, array.length - 1);\n            \n            if (sortSteps.length > 0) {\n                sortInterval = setInterval(stepForward, animationSpeed);\n            }\n        }\n        \n        function quickSortSteps(low, high) {\n            if (low < high) {\n                const pivotIndex = partitionSteps(low, high);\n                \n                // Push left partition to call stack\n                callStack.push({ low, high: pivotIndex - 1, pivot: 'left', state: 'partition' });\n                quickSortSteps(low, pivotIndex - 1);\n                \n                // Push right partition to call stack\n                callStack.push({ low: pivotIndex + 1, high, pivot: 'right', state: 'partition' });\n                quickSortSteps(pivotIndex + 1, high);\n                \n                // Mark this range as sorted\n                callStack.push({ low, high, pivot: -1, state: 'sorted', sorted: true });\n                sortSteps.push({ type: 'sorted', low, high });\n            }\n        }\n        \n        function partitionSteps(low, high) {\n            let pivotIndex = choosePivot:\n            const strategy = pivotStrategySelect.value;\n            let pivotIndex;\n            \n            switch(strategy) {\n                case 'first':\n                    pivotIndex = low;\n                    break;\n                case 'last':\n                    pivotIndex = high;\n                    break;\n                case 'middle':\n                    pivotIndex = Math.floor((low + high) / 2);\n                    break;\n                case 'random':\n                    pivotIndex = Math.floor(Math.random() * (high - low + 1)) + low;\n                    break;\n            }\n            \n            // Record pivot selection\n            sortSteps.push({ \n                type: 'pivot', \n                pivotIndex,\n                low,\n                high,\n                message: `Choosing pivot (${strategy} element): ${array[pivotIndex]} at index ${pivotIndex}`\n            });\n            \n            // Swap pivot with last element\n            if (pivotIndex !== high) {\n                sortSteps.push({\n                    type: 'swap',\n                    indices: [pivotIndex, high],\n                    message: `Moving pivot ${array[pivotIndex]} to end of partition (index ${high})`\n                });\n                [array[pivotIndex], array[high]] = [array[high], array[pivotIndex]];\n                pivotIndex = high;\n            }\n            \n            const pivotValue = array[pivotIndex];\n            let i = low - 1;\n            \n            sortSteps.push({\n                type: 'partition_start',\n                pivotIndex,\n                pivotValue,\n                low,\n                high,\n                message: `Partitioning from ${low} to ${high} with pivot ${pivotValue}`\n            });\n            \n            for (let j = low; j < high; j++) {\n                sortSteps.push({\n                    type: 'compare',\n                    indices: [j, pivotIndex],\n                    message: `Comparing ${array[j]} with pivot ${pivotValue}`\n                });\n                \n                if (array[j] < pivotValue) {\n                    i++;\n                    if (i !== j) {\n                        sortSteps.push({\n                            type: 'swap',\n                            indices: [i, j],\n                            message: `Swapping ${array[i]} and ${array[j]} (both < ${pivotValue})`\n                        });\n                        [array[i], array[j]] = [array[j], array[i]];\n                    }\n                }\n            }\n            \n            // Swap pivot into correct position\n            if (i + 1 !== pivotIndex) {\n                sortSteps.push({\n                    type: 'final_swap',\n                    indices: [i + 1, pivotIndex],\n                    message: `Moving pivot ${pivotValue} to final position at index ${i + 1}`\n                });\n                [array[i + 1], array[pivotIndex]] = [array[pivotIndex], array[i + 1]];\n                pivotIndex = i + 1;\n            }\n            \n            sortSteps.push({\n                type: 'partition_end',\n                pivotIndex,\n                message: `Partition complete. Pivot ${pivotValue} now at index ${pivotIndex}`\n            });\n            \n            return pivotIndex;\n        }\n        \n        function stepForward() {\n            if (currentStep >= sortSteps.length) {\n                clearInterval(sortInterval);\n                isSorting = false;\n                stepExplanation.textContent = 'Sorting complete!';\n                logMessage('Quick Sort completed successfully!');\n                return;\n            }\n            \n            const step = sortSteps[currentStep];\n            let highlight = [];\n            let pivotIndex = -1;\n            let partitions = [];\n            \n            switch(step.type) {\n                case 'pivot':\n                    pivotIndex = step.pivotIndex;\n                    stepExplanation.textContent = step.message;\n                    break;\n                    \n                case 'swap':\n                case 'final_swap':\n                    [array[step.indices[0]], array[step.indices[1]]] = \n                        [array[step.indices[1]], array[step.indices[0]]];\n                    highlight = step.indices;\n                    stepExplanation.textContent = step.message;\n                    break;\n                    \n                case 'compare':\n                    highlight = step.indices;\n                    stepExplanation.textContent = step.message;\n                    break;\n                    \n                case 'partition_start':\n                    pivotIndex = step.pivotIndex;\n                    partitions = [[step.low, step.high]];\n                    stepExplanation.textContent = step.message;\n                    break;\n                    \n                case 'partition_end':\n                    pivotIndex = step.pivotIndex;\n                    stepExplanation.textContent = step.message;\n                    break;\n                    \n                case 'sorted':\n                    stepExplanation.textContent = `Elements from index ${step.low} to ${step.high} are now in their final positions.`;\n                    break;\n            }\n            \n            renderArray(highlight, pivotIndex, partitions);\n            if (step.message) logMessage(step.message);\n            currentStep++;\n        }\n        \n        function manualPartition() {\n            if (isSorting) {\n                logMessage('Cannot manually partition while sorting is in progress.');\n                return;\n            }\n            \n            const start = parseInt(partitionStartInput.value);\n            const end = parseInt(partitionEndInput.value);\n            \n            if (start < 0 || end >= array.length || start >= end) {\n                logMessage('Invalid partition range.');\n                return;\n            }\n            \n            logMessage(`Manually partitioning from index ${start} to ${end}...`);\n            \n            // Choose pivot based on current strategy\n            const strategy = pivotStrategySelect.value;\n            let pivotIndex;\n            \n            switch(strategy) {\n                case 'first':\n                    pivotIndex = start;\n                    break;\n                case 'last':\n                    pivotIndex = end;\n                    break;\n                case 'middle':\n                    pivotIndex = Math.floor((start + end) / 2);\n                    break;\n                case 'random':\n                    pivotIndex = Math.floor(Math.random() * (end - start + 1)) + start;\n                    break;\n            }\n            \n            // Move pivot to end\n            [array[pivotIndex], array[end]] = [array[end], array[pivotIndex]];\n            pivotIndex = end;\n            const pivotValue = array[pivotIndex];\n            \n            let i = start - 1;\n            for (let j = start; j < end; j++) {\n                if (array[j] < pivotValue) {\n                    i++;\n                    [array[i], array[j]] = [array[j], array[i]];\n                }\n            }\n            \n            // Move pivot to final position\n            [array[i + 1], array[pivotIndex]] = [array[pivotIndex], array[i + 1]];\n            pivotIndex = i + 1;\n            \n            renderArray([], pivotIndex, [[start, end]]);\n            logMessage(`Manual partition complete. Pivot ${pivotValue} now at index ${pivotIndex}`);\n            stepExplanation.textContent = `Manual partition from ${start} to ${end} complete. Pivot is at index ${pivotIndex}.`;\n        }\n        \n        // Initialize the app\n        init();\n    </script>\n</body>\n</html>"
  },
