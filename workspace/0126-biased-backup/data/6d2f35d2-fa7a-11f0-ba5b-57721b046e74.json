  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Dynamic Programming Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .section {\n            border: 1px solid #ccc;\n            padding: 15px;\n            margin-bottom: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 15px;\n        }\n        button, select, input {\n            padding: 5px 10px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin-bottom: 15px;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: center;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        .memo-table {\n            display: grid;\n            gap: 2px;\n        }\n        .memo-cell {\n            border: 1px solid #ddd;\n            padding: 5px;\n            text-align: center;\n            min-width: 30px;\n        }\n        .highlight {\n            background-color: #e6f7ff;\n        }\n        .explanation {\n            margin-top: 15px;\n            padding: 10px;\n            border: 1px solid #eee;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Dynamic Programming Explorer</h1>\n        \n        <div class=\"section\">\n            <h2>Fibonacci Sequence</h2>\n            <div class=\"controls\">\n                <input type=\"number\" id=\"fib-input\" min=\"0\" max=\"20\" value=\"5\">\n                <button onclick=\"calculateFibonacci()\">Calculate</button>\n                <select id=\"fib-method\" onchange=\"updateFibonacciExplanation()\">\n                    <option value=\"recursive\">Recursive</option>\n                    <option value=\"memoization\">Memoization</option>\n                    <option value=\"dp\">Dynamic Programming</option>\n                </select>\n                <button onclick=\"stepThroughFibonacci()\">Step Through</button>\n                <button onclick=\"resetFibonacci()\">Reset</button>\n            </div>\n            <div id=\"fib-result\"></div>\n            <div id=\"fib-steps\"></div>\n            <div id=\"fib-explanation\" class=\"explanation\"></div>\n            <div id=\"fib-memo-table\" class=\"memo-table\" style=\"display: none;\"></div>\n        </div>\n        \n        <div class=\"section\">\n            <h2>Knapsack Problem</h2>\n            <div class=\"controls\">\n                <input type=\"number\" id=\"knapsack-capacity\" min=\"1\" max=\"20\" value=\"5\">\n                <button onclick=\"generateKnapsackItems()\">Generate Items</button>\n                <button onclick=\"solveKnapsack()\">Solve</button>\n                <button onclick=\"stepThroughKnapsack()\">Step Through</button>\n                <button onclick=\"resetKnapsack()\">Reset</button>\n            </div>\n            <div id=\"knapsack-items\"></div>\n            <div id=\"knapsack-result\"></div>\n            <div id=\"knapsack-steps\"></div>\n            <div id=\"knapsack-explanation\" class=\"explanation\"></div>\n            <div id=\"knapsack-dp-table\" style=\"overflow-x: auto;\"></div>\n        </div>\n        \n        <div class=\"section\">\n            <h2>Longest Common Subsequence</h2>\n            <div class=\"controls\">\n                <input type=\"text\" id=\"lcs-str1\" value=\"ABCDGH\">\n                <input type=\"text\" id=\"lcs-str2\" value=\"AEDFHR\">\n                <button onclick=\"calculateLCS()\">Calculate</button>\n                <button onclick=\"stepThroughLCS()\">Step Through</button>\n                <button onclick=\"resetLCS()\">Reset</button>\n            </div>\n            <div id=\"lcs-result\"></div>\n            <div id=\"lcs-steps\"></div>\n            <div id=\"lcs-explanation\" class=\"explanation\"></div>\n            <div id=\"lcs-dp-table\" style=\"overflow-x: auto;\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Fibonacci Sequence\n        let fibSteps = [];\n        let currentFibStep = 0;\n        let fibMemo = {};\n        \n        function calculateFibonacci() {\n            const n = parseInt(document.getElementById('fib-input').value);\n            const method = document.getElementById('fib-method').value;\n            let result;\n            \n            if (method === 'recursive') {\n                result = fibRecursive(n);\n                document.getElementById('fib-result').innerHTML = `Fibonacci(${n}) = ${result} (Recursive)`;\n            } else if (method === 'memoization') {\n                fibMemo = {};\n                result = fibMemoization(n);\n                document.getElementById('fib-result').innerHTML = `Fibonacci(${n}) = ${result} (Memoization)`;\n                displayFibMemoTable(n);\n            } else {\n                result = fibDP(n);\n                document.getElementById('fib-result').innerHTML = `Fibonacci(${n}) = ${result} (DP)`;\n                displayFibDPTable(n);\n            }\n            \n            updateFibonacciExplanation();\n        }\n        \n        function fibRecursive(n) {\n            if (n <= 1) return n;\n            return fibRecursive(n-1) + fibRecursive(n-2);\n        }\n        \n        function fibMemoization(n) {\n            if (n in fibMemo) return fibMemo[n];\n            if (n <= 1) return n;\n            fibMemo[n] = fibMemoization(n-1) + fibMemoization(n-2);\n            return fibMemo[n];\n        }\n        \n        function fibDP(n) {\n            if (n <= 1) return n;\n            let dp = [0, 1];\n            for (let i = 2; i <= n; i++) {\n                dp[i] = dp[i-1] + dp[i-2];\n            }\n            return dp[n];\n        }\n        \n        function displayFibMemoTable(n) {\n            const tableDiv = document.getElementById('fib-memo-table');\n            tableDiv.style.display = 'block';\n            tableDiv.innerHTML = '<h3>Memoization Table</h3>';\n            \n            const table = document.createElement('div');\n            table.className = 'memo-table';\n            table.style.gridTemplateColumns = `repeat(${n+1}, 1fr)`;\n            \n            for (let i = 0; i <= n; i++) {\n                const cell = document.createElement('div');\n                cell.className = 'memo-cell';\n                cell.textContent = i in fibMemo ? fibMemo[i] : '';\n                cell.id = `fib-memo-${i}`;\n                table.appendChild(cell);\n            }\n            \n            tableDiv.appendChild(table);\n        }\n        \n        function displayFibDPTable(n) {\n            const tableDiv = document.getElementById('fib-memo-table');\n            tableDiv.style.display = 'block';\n            tableDiv.innerHTML = '<h3>DP Array</h3>';\n            \n            const table = document.createElement('div');\n            table.className = 'memo-table';\n            table.style.gridTemplateColumns = `repeat(${n+1}, 1fr)`;\n            \n            let dp = [0, 1];\n            for (let i = 2; i <= n; i++) {\n                dp[i] = dp[i-1] + dp[i-2];\n            }\n            \n            for (let i = 0; i <= n; i++) {\n                const cell = document.createElement('div');\n                cell.className = 'memo-cell';\n                cell.textContent = dp[i];\n                cell.id = `fib-dp-${i}`;\n                table.appendChild(cell);\n            }\n            \n            tableDiv.appendChild(table);\n        }\n        \n        function stepThroughFibonacci() {\n            const n = parseInt(document.getElementById('fib-input').value);\n            const method = document.getElementById('fib-method').value;\n            \n            if (fibSteps.length === 0) {\n                if (method === 'recursive') {\n                    generateFibRecursiveSteps(n);\n                } else if (method === 'memoization') {\n                    generateFibMemoSteps(n);\n                } else {\n                    generateFibDPSteps(n);\n                }\n                currentFibStep = 0;\n            }\n            \n            if (currentFibStep < fibSteps.length) {\n                document.getElementById('fib-steps').innerHTML = fibSteps[currentFibStep].message;\n                \n                if (fibSteps[currentFibStep].highlight) {\n                    const cells = document.querySelectorAll('.memo-cell');\n                    cells.forEach(cell => cell.classList.remove('highlight'));\n                    \n                    fibSteps[currentFibStep].highlight.forEach(id => {\n                        const cell = document.getElementById(`fib-${id}`);\n                        if (cell) cell.classList.add('highlight');\n                    });\n                }\n                \n                currentFibStep++;\n            } else {\n                document.getElementById('fib-steps').innerHTML = \"All steps completed!\";\n            }\n        }\n        \n        function generateFibRecursiveSteps(n) {\n            fibSteps = [];\n            fibSteps.push({\n                message: `Calculating Fibonacci(${n}) recursively...`,\n                highlight: []\n            });\n            // More steps would be added in a real implementation\n        }\n        \n        function generateFibMemoSteps(n) {\n            fibSteps = [];\n            fibMemo = {};\n            fibSteps.push({\n                message: `Initializing memoization table for Fibonacci(${n})...`,\n                highlight: []\n            });\n            // More steps would be added in a real implementation\n        }\n        \n        function generateFibDPSteps(n) {\n            fibSteps = [];\n            fibSteps.push({\n                message: `Initializing DP array with Fibonacci(0) = 0 and Fibonacci(1) = 1...`,\n                highlight: ['dp-0', 'dp-1']\n            });\n            // More steps would be added in a real implementation\n        }\n        \n        function resetFibonacci() {\n            fibSteps = [];\n            currentFibStep = 0;\n            document.getElementById('fib-steps').innerHTML = '';\n            document.getElementById('fib-result').innerHTML = '';\n            document.getElementById('fib-memo-table').innerHTML = '';\n            document.getElementById('fib-memo-table').style.display = 'none';\n            const cells = document.querySelectorAll('.memo-cell');\n            cells.forEach(cell => cell.classList.remove('highlight'));\n        }\n        \n        function updateFibonacciExplanation() {\n            const method = document.getElementById('fib-method').value;\n            let explanation = '';\n            \n            if (method === 'recursive') {\n                explanation = `\n                    <h3>Recursive Approach</h3>\n                    <p>This is the naive recursive solution that directly implements the mathematical definition:</p>\n                    <p>fib(n) = fib(n-1) + fib(n-2)</p>\n                    <p>Time complexity: O(2^n) (exponential)</p>\n                    <p>Space complexity: O(n) (call stack)</p>\n                `;\n            } else if (method === 'memoization') {\n                explanation = `\n                    <h3>Memoization (Top-Down DP)</h3>\n                    <p>This approach stores the results of subproblems to avoid redundant calculations.</p>\n                    <p>Time complexity: O(n)</p>\n                    <p>Space complexity: O(n)</p>\n                `;\n            } else {\n                explanation = `\n                    <h3>Dynamic Programming (Bottom-Up)</h3>\n                    <p>This approach solves subproblems in order and stores results in a table.</p>\n                    <p>Time complexity: O(n)</p>\n                    <p>Space complexity: O(n) (can be optimized to O(1))</p>\n                `;\n            }\n            \n            document.getElementById('fib-explanation').innerHTML = explanation;\n        }\n        \n        // Knapsack Problem\n        let knapsackItems = [];\n        let knapsackSteps = [];\n        let currentKnapsackStep = 0;\n        \n        function generateKnapsackItems() {\n            const capacity = parseInt(document.getElementById('knapsack-capacity').value);\n            const count = Math.min(5, Math.max(3, Math.floor(capacity / 2)));\n            \n            knapsackItems = [];\n            for (let i = 0; i < count; i++) {\n                knapsackItems.push({\n                    weight: Math.floor(Math.random() * capacity / 2) + 1,\n                    value: Math.floor(Math.random() * 20) + 5\n                });\n            }\n            \n            displayKnapsackItems();\n        }\n        \n        function displayKnapsackItems() {\n            let html = '<h3>Items</h3><table><tr><th>Item</th><th>Weight</th><th>Value</th></tr>';\n            knapsackItems.forEach((item, index) => {\n                html += `<tr><td>${index+1}</td><td>${item.weight}</td><td>${item.value}</td></tr>`;\n            });\n            html += '</table>';\n            document.getElementById('knapsack-items').innerHTML = html;\n        }\n        \n        function solveKnapsack() {\n            const capacity = parseInt(document.getElementById('knapsack-capacity').value);\n            const n = knapsackItems.length;\n            \n            // Initialize DP table\n            let dp = Array(n + 1).fill().map(() => Array(capacity + 1).fill(0));\n            \n            for (let i = 1; i <= n; i++) {\n                for (let w = 1; w <= capacity; w++) {\n                    if (knapsackItems[i-1].weight <= w) {\n                        dp[i][w] = Math.max(\n                            knapsackItems[i-1].value + dp[i-1][w - knapsackItems[i-1].weight],\n                            dp[i-1][w]\n                        );\n                    } else {\n                        dp[i][w] = dp[i-1][w];\n                    }\n                }\n            }\n            \n            // Find selected items\n            let selectedItems = [];\n            let w = capacity;\n            for (let i = n; i > 0; i--) {\n                if (dp[i][w] !== dp[i-1][w]) {\n                    selectedItems.push(i-1);\n                    w -= knapsackItems[i-1].weight;\n                }\n            }\n            \n            // Display result\n            const totalValue = dp[n][capacity];\n            const totalWeight = selectedItems.reduce((sum, idx) => sum + knapsackItems[idx].weight, 0);\n            let itemsList = selectedItems.map(idx => `Item ${idx+1} (w:${knapsackItems[idx].weight}, v:${knapsackItems[idx].value})`).join(', ');\n            \n            document.getElementById('knapsack-result').innerHTML = `\n                <p>Maximum value: ${totalValue}</p>\n                <p>Total weight: ${totalWeight}/${capacity}</p>\n                <p>Selected items: ${itemsList}</p>\n            `;\n            \n            // Display DP table\n            displayKnapsackDPTable(dp, capacity);\n        }\n        \n        function displayKnapsackDPTable(dp, capacity) {\n            const n = knapsackItems.length;\n            let html = '<h3>DP Table</h3><table><tr><th>Item \\ Weight</th>';\n            \n            // Header row (weights)\n            for (let w = 0; w <= capacity; w++) {\n                html += `<th>${w}</th>`;\n            }\n            html += '</tr>';\n            \n            // Data rows\n            for (let i = 0; i <= n; i++) {\n                html += `<tr><th>${i > 0 ? i : ''}</th>`;\n                for (let w = 0; w <= capacity; w++) {\n                    html += `<td id=\"knapsack-cell-${i}-${w}\">${dp[i][w]}</td>`;\n                }\n                html += '</tr>';\n            }\n            html += '</table>';\n            \n            document.getElementById('knapsack-dp-table').innerHTML = html;\n        }\n        \n        function stepThroughKnapsack() {\n            // Implementation would be similar to Fibonacci stepping\n            document.getElementById('knapsack-steps').innerHTML = \"Step-by-step execution would be implemented here...\";\n        }\n        \n        function resetKnapsack() {\n            knapsackSteps = [];\n            currentKnapsackStep = 0;\n            document.getElementById('knapsack-steps').innerHTML = '';\n            document.getElementById('knapsack-result').innerHTML = '';\n            document.getElementById('knapsack-dp-table').innerHTML = '';\n        }\n        \n        // Longest Common Subsequence\n        let lcsSteps = [];\n        let currentLcsStep = 0;\n        \n        function calculateLCS() {\n            const str1 = document.getElementById('lcs-str1').value;\n            const str2 = document.getElementById('lcs-str2').value;\n            \n            const m = str1.length;\n            const n = str2.length;\n            \n            // Create DP table\n            let dp = Array(m + 1).fill().map(() => Array(n + 1).fill(0));\n            \n            for (let i = 1; i <= m; i++) {\n                for (let j = 1; j <= n; j++) {\n                    if (str1[i-1] === str2[j-1]) {\n                        dp[i][j] = dp[i-1][j-1] + 1;\n                    } else {\n                        dp[i][j] = Math.max(dp[i-1][j], dp[i][j-1]);\n                    }\n                }\n            }\n            \n            // Find the LCS string\n            let lcs = '';\n            let i = m, j = n;\n            while (i > 0 && j > 0) {\n                if (str1[i-1] === str2[j-1]) {\n                    lcs = str1[i-1] + lcs;\n                    i--;\n                    j--;\n                } else if (dp[i-1][j] > dp[i][j-1]) {\n                    i--;\n                } else {\n                    j--;\n                }\n            }\n            \n            document.getElementById('lcs-result').innerHTML = `\n                <p>LCS Length: ${dp[m][n]}</p>\n                <p>LCS String: ${lcs}</p>\n            `;\n            \n            displayLcsDPTable(dp, str1, str2);\n        }\n        \n        function displayLcsDPTable(dp, str1, str2) {\n            const m = str1.length;\n            const n = str2.length;\n            \n            let html = '<h3>DP Table</h3><table><tr><th></th><th></th>';\n            \n            // Header row (str2)\n            for (let j = 0; j < n; j++) {\n                html += `<th>${str2[j]}</th>`;\n            }\n            html += '</tr>';\n            \n            // Data row 0 (empty string)\n            html += '<tr><th></th><th>0</th>';\n            for (let j = 0; j <= n; j++) {\n                html += `<td>${dp[0][j]}</td>`;\n            }\n            html += '</tr>';\n            \n            // Data rows\n            for (let i = 1; i <= m; i++) {\n                html += `<tr><th>${str1[i-1]}</th><th>${i}</th>`;\n                for (let j = 0; j <= n; j++) {\n                    html += `<td id=\"lcs-cell-${i}-${j}\">${dp[i][j]}</td>`;\n                }\n                html += '</tr>';\n            }\n            html += '</table>';\n            \n            document.getElementById('lcs-dp-table').innerHTML = html;\n        }\n        \n        function stepThroughLCS() {\n            // Implementation would be similar to Fibonacci stepping\n            document.getElementById('lcs-steps').innerHTML = \"Step-by-step execution would be implemented here...\";\n        }\n        \n        function resetLCS() {\n            lcsSteps = [];\n            currentLcsStep = 0;\n            document.getElementById('lcs-steps').innerHTML = '';\n            document.getElementById('lcs-result').innerHTML = '';\n            document.getElementById('lcs-dp-table').innerHTML = '';\n        }\n        \n        // Initialize\n        updateFibonacciExplanation();\n        generateKnapsackItems();\n    </script>\n</body>\n</html>"
  },
