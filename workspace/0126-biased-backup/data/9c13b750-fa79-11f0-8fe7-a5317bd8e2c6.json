Insert generalized suffix at \" + start;\n    let cur = rootId;\n    let i = start;\n    while(i < S.length){\n      const c = S[i];\n      const node = tree.nodes[cur];\n      if(!node.edges[c]){\n        const leafId = nodeId();\n        tree.nodes[leafId] = {edges:{}, suffixLink:null, leafIndices:new Set([start])};\n        node.edges[c] = {start: i, end: Infinity, dest: leafId};\n        tree.ownerOfSuffix[start] = (start < n1) ? 1 : 2;\n        makeSnapshotFromTree(tree, \"Inserted new generalized leaf for suffix \" + start + \" at char '\" + c + \"'\");\n        break;\n      } else {\n        const e = node.edges[c];\n        let j = e.start;\n        while(j <= (e.end === Infinity ? S.length-1 : e.end) && i < S.length && S[j] === S[i]){\n          j++; i++;\n        }\n        if(j <= (e.end === Infinity ? S.length-1 : e.end) && i < S.length && S[j] !== S[i]){\n          const splitId = nodeId();\n          tree.nodes[splitId] = {edges:{}, suffixLink:null, leafIndices:new Set()};\n          const oldDest = e.dest;\n          const oldStart = e.start;\n          const oldEnd = e.end;\n          node.edges[c] = {start: oldStart, end: j-1, dest: splitId};\n          tree.nodes[splitId].edges[S[j]] = {start: j, end: oldEnd, dest: oldDest};\n          const leafId = nodeId();\n          tree.nodes[leafId] = {edges:{}, suffixLink:null, leafIndices:new Set([start])};\n          tree.nodes[splitId].edges[S[i]] = {start: i, end: Infinity, dest: leafId};\n          tree.ownerOfSuffix[start] = (start < n1) ? 1 : 2;\n          makeSnapshotFromTree(tree, \"Split and inserted generalized leaf during naive insertion of suffix \" + start);\n          break;\n        } else {\n          cur = e.dest;\n          continue;\n        }\n      }\n    }\n    updateLeafIndices(tree);\n    makeSnapshotFromTree(tree, \"Finished inserting generalized suffix \" + start);\n  }\n  makeSnapshotFromTree(tree, \"Final generalized naive-built tree\");\n  log('Generalized naive build generated ' + snapshots.length + ' snapshots for S+T \"' + S + '\"');\n  currentSnapshotIndex = 0;\n}\n\n// Helper: update leafIndices and ownerOfSuffix mapping for tree readability\nfunction updateLeafIndices(tree){\n  // reset\n  for(const nid in tree.nodes){\n    tree.nodes[nid].leafIndices = new Set();\n  }\n  const S = tree.S;\n  // DFS from root to collect leaves\n  function dfs(nodeId, pathStart){\n    const n = tree.nodes[nodeId];\n    let isLeaf = Object.keys(n.edges).length === 0;\n    if(isLeaf){\n      // fallback: find position by scanning edges? We assume leaves were created with a single start index that may not be stored\n      // We'll find leaves by checking for no children and attempt to find a start index by looking at parent edges in parent relationships\n      // To simplify: we will populate leafIndices by scanning all suffix starts and checking if path exists from root\n      return;\n    }\n    for(const key in n.edges){\n      const e = n.edges[key];\n      dfs(e.dest, e.start);\n    }\n  }\n  // Instead of DFS leaf detection, for clarity compute leafIndices per node by checking all suffixes\n  for(let start=0; start<tree.S.length; start++){\n    let cur = tree.root;\n    let i = start;\n    while(i < tree.S.length){\n      const c = tree.S[i];\n      const n = tree.nodes[cur];\n      if(!n) break;\n      const e = n.edges[c];\n      if(!e) break;\n      let j = e.start;\n      while(j <= (e.end === Infinity ? tree.S.length-1 : e.end) && i < tree.S.length && tree.S[j] === tree.S[i]){\n        j++; i++;\n      }\n      // assign leafIndices to nodes along the path\n      tree.nodes[cur].leafIndices.add(start);\n      if(j > (e.end === Infinity ? tree.S.length-1 : e.end)){\n        cur = e.dest;\n      } else {\n        // ended in middle of edge -> then leaf not under current node, but split would have been needed; still assign\n        tree.nodes[cur].leafIndices.add(start);\n        break;\n      }\n    }\n    // assign leaf to final node if ended