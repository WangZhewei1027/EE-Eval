  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Suffix Tree Interactive Explorer</title>\n</head>\n<body>\n\n<h1>Suffix Tree Interactive Explorer</h1>\n\n<!-- Controls: Input and algorithm selection -->\n<div>\n  <label>Mode:\n    <select id=\"modeSelect\">\n      <option value=\"single\">Single String</option>\n      <option value=\"generalized\">Generalized (two strings)</option>\n    </select>\n  </label>\n</div>\n\n<div>\n  <label>String (S):\n    <input type=\"text\" id=\"inputString\" value=\"banana\" size=\"40\">\n  </label>\n</div>\n\n<div id=\"secondStringRow\" style=\"display:none;\">\n  <label>String 2 (T):\n    <input type=\"text\" id=\"inputString2\" value=\"panama\" size=\"40\">\n  </label>\n</div>\n\n<div>\n  <label>Algorithm:\n    <select id=\"algoSelect\">\n      <option value=\"ukkonen\">Ukkonen (online, step-by-step)</option>\n      <option value=\"naive\">Naive insert-all-suffixes (step-by-step)</option>\n    </select>\n  </label>\n</div>\n\n<div>\n  <label>Terminator for S:\n    <input type=\"text\" id=\"termS\" value=\"#\" size=\"1\">\n  </label>\n  <label id=\"termTLabel\" style=\"display:none;\">Terminator for T:\n    <input type=\"text\" id=\"termT\" value=\"$\" size=\"1\">\n  </label>\n</div>\n\n<div>\n  <button id=\"buildBtn\">Build (generate steps)</button>\n  <button id=\"resetBtn\">Reset</button>\n  <button id=\"randomBtn\">Randomize S</button>\n  <label>Random length:\n    <input type=\"range\" id=\"randLen\" min=\"3\" max=\"16\" value=\"6\">\n    <span id=\"randLenVal\">6</span>\n  </label>\n</div>\n\n<hr>\n\n<!-- Playback controls -->\n<div>\n  <button id=\"stepBackBtn\">Step Back</button>\n  <button id=\"stepForwardBtn\">Step Forward</button>\n  <button id=\"playPauseBtn\">Play</button>\n  <label>Speed:\n    <input type=\"range\" id=\"speedSlider\" min=\"100\" max=\"2000\" value=\"600\">\n    <span id=\"speedVal\">600ms</span>\n  </label>\n  <label>Auto-step amount:\n    <input type=\"number\" id=\"autoStepAmount\" value=\"1\" min=\"1\" max=\"10\" style=\"width:60px;\">\n  </label>\n  <button id=\"jumpStartBtn\">Jump to Start</button>\n  <button id=\"jumpEndBtn\">Jump to End</button>\n</div>\n\n<hr>\n\n<!-- Tree visualization and options -->\n<div>\n  <label><input type=\"checkbox\" id=\"showSuffixLinks\" checked> Show suffix links</label>\n  <label><input type=\"checkbox\" id=\"showEdgeIndexes\" checked> Show edge indexes (start,end)</label>\n  <label><input type=\"checkbox\" id=\"showEdgeSubstrings\" checked> Show edge substring</label>\n  <label><input type=\"checkbox\" id=\"collapseLeaves\" > Collapse leaf listings</label>\n</div>\n\n<div>\n  <button id=\"exportBtn\">Export Tree JSON</button>\n  <button id=\"importBtn\">Import JSON</button>\n  <input type=\"file\" id=\"importFile\" style=\"display:none;\">\n</div>\n\n<hr>\n\n<!-- Pattern search -->\n<div>\n  <label>Pattern search:\n    <input type=\"text\" id=\"patternInput\" size=\"30\">\n  </label>\n  <button id=\"searchAllBtn\">Find All (fast)</button>\n  <button id=\"searchStepBtn\">Step Search</button>\n  <button id=\"searchResetBtn\">Reset Search</button>\n  <label>Match result max:\n    <input type=\"number\" id=\"maxMatches\" value=\"50\" style=\"width:60px;\">\n  </label>\n</div>\n\n<hr>\n\n<!-- Advanced queries -->\n<div>\n  <button id=\"computeSA\">Compute Suffix Array & LCP</button>\n  <button id=\"computeLRS\">Longest Repeated Substring</button>\n  <button id=\"computeLCS\">Longest Common Substring (generalized)</button>\n  <button id=\"countDistinct\">Count Distinct Substrings</button>\n</div>\n\n<hr>\n\n<!-- Visualization areas -->\n<div>\n  <h3>Current Phase / Step Info</h3>\n  <div id=\"stepInfo\" style=\"white-space:pre-wrap; font-family:monospace;\"></div>\n</div>\n\n<div>\n  <h3>Tree View (text)</h3>\n  <div id=\"treeView\" style=\"white-space:pre-wrap; font-family:monospace; max-height:400px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n</div>\n\n<div>\n  <h3>Suffix Array / LCP View</h3>\n  <div id=\"saView\" style=\"white-space:pre-wrap; font-family:monospace; max-height:180px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n</div>\n\n<div>\n  <h3>Search / Query Results</h3>\n  <div id=\"queryView\" style=\"white-space:pre-wrap; font-family:monospace; max-height:180px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n</div>\n\n<div>\n  <h3>Operation Log</h3>\n  <label>Filter:\n    <input type=\"text\" id=\"logFilter\" placeholder=\"filter text\">\n  </label>\n  <button id=\"clearLogBtn\">Clear Log</button>\n  <div id=\"opLog\" style=\"white-space:pre-wrap; font-family:monospace; max-height:260px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n</div>\n\n<script>\n// Minimal visual styling intentionally omitted. Focus on functionality.\n\n// Data structures for tree builder and step snapshots\n(function(){\n\n// Utility functions\nfunction deepClone(obj){\n  return JSON.parse(JSON.stringify(obj));\n}\nfunction idGen(prefix){\n  let i=0;\n  return function(){ return prefix + (++i); };\n}\n\n// DOM elements\nconst modeSelect = document.getElementById('modeSelect');\nconst inputString = document.getElementById('inputString');\nconst inputString2 = document.getElementById('inputString2');\nconst secondStringRow = document.getElementById('secondStringRow');\nconst algoSelect = document.getElementById('algoSelect');\nconst termS = document.getElementById('termS');\nconst termT = document.getElementById('termT');\nconst termTLabel = document.getElementById('termTLabel');\n\nconst buildBtn = document.getElementById('buildBtn');\nconst resetBtn = document.getElementById('resetBtn');\nconst randomBtn = document.getElementById('randomBtn');\nconst randLen = document.getElementById('randLen');\nconst randLenVal = document.getElementById('randLenVal');\n\nconst stepBackBtn = document.getElementById('stepBackBtn');\nconst stepForwardBtn = document.getElementById('stepForwardBtn');\nconst playPauseBtn = document.getElementById('playPauseBtn');\nconst speedSlider = document.getElementById('speedSlider');\nconst speedVal = document.getElementById('speedVal');\nconst autoStepAmount = document.getElementById('autoStepAmount');\nconst jumpStartBtn = document.getElementById('jumpStartBtn');\nconst jumpEndBtn = document.getElementById('jumpEndBtn');\n\nconst showSuffixLinks = document.getElementById('showSuffixLinks');\nconst showEdgeIndexes = document.getElementById('showEdgeIndexes');\nconst showEdgeSubstrings = document.getElementById('showEdgeSubstrings');\nconst collapseLeaves = document.getElementById('collapseLeaves');\n\nconst exportBtn = document.getElementById('exportBtn');\nconst importBtn = document.getElementById('importBtn');\nconst importFile = document.getElementById('importFile');\n\nconst patternInput = document.getElementById('patternInput');\nconst searchAllBtn = document.getElementById('searchAllBtn');\nconst searchStepBtn = document.getElementById('searchStepBtn');\nconst searchResetBtn = document.getElementById('searchResetBtn');\nconst maxMatches = document.getElementById('maxMatches');\n\nconst computeSA = document.getElementById('computeSA');\nconst computeLRS = document.getElementById('computeLRS');\nconst computeLCSBtn = document.getElementById('computeLCS');\nconst countDistinct = document.getElementById('countDistinct');\n\nconst stepInfo = document.getElementById('stepInfo');\nconst treeView = document.getElementById('treeView');\nconst saView = document.getElementById('saView');\nconst queryView = document.getElementById('queryView');\nconst opLog = document.getElementById('opLog');\nconst logFilter = document.getElementById('logFilter');\nconst clearLogBtn = document.getElementById('clearLogBtn');\n\n// State\nlet snapshots = []; // array of snapshots representing states\nlet currentSnapshotIndex = 0;\nlet playing = false;\nlet playTimer = null;\n\nlet logEntries = [];\nfunction log(msg){\n  const entry = {ts: (new Date()).toISOString(), msg};\n  logEntries.push(entry);\n  renderLog();\n}\nfunction renderLog(){\n  const f = logFilter.value.trim().toLowerCase();\n  opLog.innerText = logEntries.filter(e=> !f || e.msg.toLowerCase().includes(f)).map(e=> e.ts + \" | \" + e.msg).join(\"\\n\");\n}\n\nrandLen.addEventListener('input', ()=> { randLenVal.innerText = randLen.value; });\n\nmodeSelect.addEventListener('change', ()=> {\n  if(modeSelect.value === 'generalized'){\n    secondStringRow.style.display = '';\n    termTLabel.style.display = '';\n  } else {\n    secondStringRow.style.display = 'none';\n    termTLabel.style.display = 'none';\n  }\n});\n\nimportBtn.addEventListener('click', ()=> importFile.click());\nimportFile.addEventListener('change', (ev)=> {\n  const f = ev.target.files[0];\n  if(!f) return;\n  const reader = new FileReader();\n  reader.onload = function(e){\n    try{\n      const data = JSON.parse(e.target.result);\n      // Expect an exported snapshot set\n      if(data && data.snapshots){\n        snapshots = data.snapshots;\n        currentSnapshotIndex = Math.max(0, Math.min(snapshots.length-1, data.currentIndex || 0));\n        log('Imported snapshots JSON. ' + snapshots.length + ' snapshots loaded.');\n        renderSnapshot();\n      } else {\n        alert('JSON did not contain snapshots[]');\n      }\n    } catch(err){\n      alert('Invalid JSON: ' + err);\n    }\n  };\n  reader.readAsText(f);\n});\n\n// Export\nexportBtn.addEventListener('click', ()=>{\n  const payload = {snapshots, currentIndex: currentSnapshotIndex};\n  const dataStr = \"data:text/json;charset=utf-8,\" + encodeURIComponent(JSON.stringify(payload));\n  const a = document.createElement('a');\n  a.href = dataStr;\n  a.download = 'suffix_tree_snapshots.json';\n  a.click();\n  log('Exported snapshots JSON.');\n});\n\n// Reset\nresetBtn.addEventListener('click', ()=>{\n  snapshots = [];\n  currentSnapshotIndex = 0;\n  playing = false;\n  clearInterval(playTimer);\n  renderSnapshot();\n  log('Reset explorer state.');\n});\n\n// Randomize string\nrandomBtn.addEventListener('click', ()=>{\n  const len = parseInt(randLen.value,10);\n  // Basic alphabet letters\n  const alpha = \"abcdefghijklmnopqrstuvwxyz\";\n  let s = \"\";\n  for(let i=0;i<len;i++) s += alpha[Math.floor(Math.random()*alpha.length)];\n  inputString.value = s;\n  log('Randomized input string: ' + s);\n});\n\n// Play controls\nspeedSlider.addEventListener('input', ()=> { speedVal.innerText = speedSlider.value + \"ms\"; });\n\nstepBackBtn.addEventListener('click', ()=> { step(-1); });\nstepForwardBtn.addEventListener('click', ()=> { step(1); });\njumpStartBtn.addEventListener('click', ()=> { goTo(0); });\njumpEndBtn.addEventListener('click', ()=> { goTo(snapshots.length - 1); });\n\nplayPauseBtn.addEventListener('click', ()=> {\n  if(playing){ stopPlay(); } else { startPlay(); }\n});\n\nfunction startPlay(){\n  if(!snapshots || snapshots.length===0) return;\n  playing = true;\n  playPauseBtn.innerText = 'Pause';\n  const delay = parseInt(speedSlider.value,10);\n  const amt = Math.max(1, parseInt(autoStepAmount.value,10));\n  playTimer = setInterval(()=> {\n    step(amt);\n  }, delay);\n  log('Play started.');\n}\nfunction stopPlay(){\n  playing = false;\n  playPauseBtn.innerText = 'Play';\n  clearInterval(playTimer);\n  playTimer = null;\n  log('Play paused.');\n}\n\n// Core operations: generate snapshots by algorithms\nbuildBtn.addEventListener('click', ()=> {\n  stopPlay();\n  snapshots = [];\n  currentSnapshotIndex = 0;\n  saView.innerText = \"\";\n  queryView.innerText = \"\";\n  opLog.innerText = \"\";\n  logEntries = [];\n  log('Build started: algo=' + algoSelect.value + ' mode=' + modeSelect.value);\n  if(modeSelect.value === 'generalized'){\n    const S = inputString.value + termS.value;\n    const T = inputString2.value + termT.value;\n    // Ensure terminators are unique\n    if(termS.value === termT.value){\n      alert('Terminators for the two strings must differ. Change one.');\n      log('Build aborted: identical terminators.');\n      return;\n    }\n    if(algoSelect.value === 'ukkonen'){\n      buildGeneralizedUkkonenSteps(inputString.value, inputString2.value, termS.value, termT.value);\n    } else {\n      buildGeneralizedNaiveSteps(inputString.value, inputString2.value, termS.value, termT.value);\n    }\n  } else {\n    const S = inputString.value + termS.value;\n    if(algoSelect.value === 'ukkonen'){\n      buildUkkonenSteps(inputString.value, termS.value);\n    } else {\n      buildNaiveSteps(inputString.value, termS.value);\n    }\n  }\n  renderSnapshot();\n});\n\n// Snapshot rendering\nfunction renderSnapshot(){\n  if(!snapshots || snapshots.length===0){\n    treeView.innerText = \"(no snapshots)\";\n    stepInfo.innerText = \"\";\n    saView.innerText = \"\";\n    queryView.innerText = \"\";\n    return;\n  }\n  const snap = snapshots[currentSnapshotIndex];\n  // Step info\n  let info = \"Step \" + (currentSnapshotIndex+1) + \" / \" + snapshots.length + \"\\n\";\n  if(snap.phase) info += \"Phase: \" + snap.phase + \"\\n\";\n  if(snap.message) info += \"Note: \" + snap.message + \"\\n\";\n  if(snap.meta) info += \"Meta: \" + JSON.stringify(snap.meta) + \"\\n\";\n  stepInfo.innerText = info;\n  // Tree view\n  treeView.innerText = renderTreeText(snap);\n  // SA view might be in snapshot\n  saView.innerText = snap.saText || \"\";\n  queryView.innerText = snap.queryText || \"\";\n  renderLog();\n}\n\n// Tree text rendering\nfunction renderTreeText(snap){\n  if(!snap.root) return \"(empty snapshot)\";\n  const lines = [];\n  const s = snap.fullString || \"\";\n  lines.push(\"Full string: \\\"\" + s + \"\\\"\");\n  lines.push(\"Nodes: \" + snap.nodes.length + \"   Edges: \" + snap.edges.length);\n  lines.push(\"\");\n  function nodeLine(n){\n    const parts = [\"[\" + n.id + \"]\"];\n    if(showSuffixLinks.checked && n.suffixLink) parts.push(\"->sl:\" + n.suffixLink);\n    if(n.leafIndices && n.leafIndices.length){\n      if(collapseLeaves.checked){\n        parts.push(\"leaves:\" + n.leafIndices.length);\n      } else {\n        parts.push(\"leaves:\" + JSON.stringify(n.leafIndices));\n      }\n    }\n    return parts.join(\" \");\n  }\n  function edgeLine(e){\n    const parts = [];\n    if(showEdgeIndexes.checked) parts.push(\"(\" + e.start + \",\" + e.endDisplay + \")\");\n    if(showEdgeSubstrings.checked) parts.push('\"' + e.substr + '\"');\n    parts.push(\" -> \" + e.dest);\n    return parts.join(\" \");\n  }\n  function dfs(nodeId, indent){\n    const n = snap.nodeMap[nodeId];\n    lines.push(indent + nodeLine(n));\n    for(const e of n.edges){\n      lines.push(indent + \"  - \" + edgeLine(e));\n      dfs(e.dest, indent + \"    \");\n    }\n  }\n  dfs(\"n1\", \"\");\n  return lines.join(\"\\n\");\n}\n\n// Step navigation\nfunction step(delta){\n  if(!snapshots || snapshots.length===0) return;\n  let newIndex = currentSnapshotIndex + delta;\n  if(newIndex < 0) newIndex = 0;\n  if(newIndex >= snapshots.length) newIndex = snapshots.length - 1;\n  currentSnapshotIndex = newIndex;\n  renderSnapshot();\n}\n\nfunction goTo(idx){\n  if(!snapshots || snapshots.length===0) return;\n  currentSnapshotIndex = Math.max(0, Math.min(snapshots.length - 1, idx));\n  renderSnapshot();\n}\n\n// Operation log controls\nclearLogBtn.addEventListener('click', ()=> { logEntries = []; renderLog(); });\n\n// Searches\nlet searchStepper = null;\nsearchAllBtn.addEventListener('click', ()=> {\n  if(!snapshots || snapshots.length===0) return;\n  const pattern = patternInput.value;\n  if(!pattern) { alert('Enter a pattern to search'); return; }\n  const snap = snapshots[currentSnapshotIndex];\n  const s = snap.fullString || \"\";\n  // naive SA search: compute all occurrences\n  const res = [];\n  for(let i=0;i+pattern.length<=s.length;i++){\n    if(s.substr(i, pattern.length) === pattern) res.push(i);\n    if(res.length >= parseInt(maxMatches.value,10)) break;\n  }\n  queryView.innerText = \"Pattern: \\\"\" + pattern + \"\\\"\\nOccurrences: \" + res.length + \"\\nPositions: \" + JSON.stringify(res);\n  log('Pattern search all: \"' + pattern + '\" found ' + res.length + ' occurrences.');\n});\n\nlet searchSteps = [];\nlet searchStepIndex = 0;\nsearchStepBtn.addEventListener('click', ()=> {\n  if(!snapshots || snapshots.length===0) return;\n  const pattern = patternInput.value;\n  if(!pattern) { alert('Enter pattern'); return; }\n  // Build a sequence of step messages that mimic traversing the tree per character\n  const snap = snapshots[currentSnapshotIndex];\n  const steps = [];\n  let nodeId = \"n1\"; // start at root\n  let i = 0;\n  steps.push({msg: \"Start at root\", nodeId});\n  while(i < pattern.length){\n    const c = pattern[i];\n    const node = snap.nodeMap[nodeId];\n    // find edge starting with c among edges\n    let edge = null;\n    for(const e of node.edges){\n      if(e.substr[0] === c){ edge = e; break; }\n    }\n    if(!edge){\n      steps.push({msg: \"No edge starting with '\" + c + \"' from node \" + nodeId + \". Pattern not found.\"});\n      break;\n    }\n    // traverse along edge\n    let j = 0;\n    while(j < edge.substr.length && i < pattern.length){\n      steps.push({msg: \"Match char segment: edge \" + edge.start + \"-\" + edge.endDisplay + \" substr '\" + edge.substr + \"', comparing pattern[\" + i + \"] = '\" + pattern[i] + \"' with edge[\" + j + \"] = '\" + edge.substr[j] + \"'\"});\n      if(pattern[i] !== edge.substr[j]){\n        steps.push({msg: \"Mismatch at pattern pos \" + i + \" -> pattern not found.\"});\n        i = pattern.length; // end\n        break;\n      }\n      i++; j++;\n    }\n    if(i >= pattern.length){\n      steps.push({msg: \"Pattern completely matched. Occurrences are leaves under node \" + edge.dest});\n      break;\n    }\n    if(j === edge.substr.length){\n      // continue at dest node\n      nodeId = edge.dest;\n      steps.push({msg: \"Reached node \" + nodeId + \" after consuming edge. Continue.\"});\n    } else {\n      // mismatch already handled above\n      break;\n    }\n  }\n  searchSteps = steps;\n  searchStepIndex = 0;\n  // Show first step\n  if(searchSteps.length>0){\n    queryView.innerText = \"Search stepping (\" + searchSteps.length + \" steps):\\n\" + searchSteps[0].msg;\n    log('Pattern search stepping started for \"' + pattern + '\"');\n  } else {\n    queryView.innerText = \"No steps generated.\";\n  }\n  // wire step forward/back with existing step controls: map them when active\n});\n\nsearchResetBtn.addEventListener('click', ()=> {\n  searchSteps = [];\n  searchStepIndex = 0;\n  queryView.innerText = \"\";\n  log('Search steps reset.');\n});\n\n// Use step forward/back to traverse search steps if available\nconst originalStep = stepForwardBtn.onclick;\nstepForwardBtn.addEventListener('click', ()=> {\n  if(searchSteps && searchSteps.length > 0){\n    searchStepIndex = Math.min(searchSteps.length-1, searchStepIndex + 1);\n    queryView.innerText = \"Search stepping (\" + searchSteps.length + \" steps):\\n\" + searchSteps[searchStepIndex].msg;\n  }\n});\nstepBackBtn.addEventListener('click', ()=> {\n  if(searchSteps && searchSteps.length > 0){\n    searchStepIndex = Math.max(0, searchStepIndex - 1);\n    queryView.innerText = \"Search stepping (\" + searchSteps.length + \" steps):\\n\" + searchSteps[searchStepIndex].msg;\n  }\n});\n\nfunction ensureSnapshotExists(){\n  if(!snapshots || snapshots.length===0) return false;\n  return true;\n}\n\n// Compute SA and LCP from final string directly (fast) or from tree\ncomputeSA.addEventListener('click', ()=> {\n  if(!ensureSnapshotExists()) return;\n  const snap = snapshots[currentSnapshotIndex];\n  const s = snap.fullString || \"\";\n  const SA = [];\n  for(let i=0;i<s.length;i++) SA.push(i);\n  SA.sort((a,b)=> {\n    if(a===b) return 0;\n    return s.substring(a) < s.substring(b) ? -1 : 1;\n  });\n  const LCP = [];\n  for(let i=1;i<SA.length;i++){\n    const a = SA[i-1], b = SA[i];\n    let l=0;\n    while(a+l < s.length && b+l < s.length && s[a+l]===s[b+l]) l++;\n    LCP.push(l);\n  }\n  let text = \"Suffix Array (indices):\\n[\" + SA.join(\",\") + \"]\\n\\nLCP between adjacent:\\n[\" + LCP.join(\",\") + \"]\";\n  saView.innerText = text;\n  // Attach to snapshot for display when navigating\n  snapshots[currentSnapshotIndex].saText = text;\n  log('Computed SA and LCP for current snapshot.');\n});\n\n// Longest repeated substring (LRS)\ncomputeLRS.addEventListener('click', ()=> {\n  if(!ensureSnapshotExists()) return;\n  // Use SA & LCP above approach for simplicity\n  const snap = snapshots[currentSnapshotIndex];\n  const s = snap.fullString || \"\";\n  const SA = [];\n  for(let i=0;i<s.length;i++) SA.push(i);\n  SA.sort((a,b)=> s.substring(a) < s.substring(b) ? -1 : 1);\n  let bestLen = 0;\n  let bestPos = 0;\n  for(let i=1;i<SA.length;i++){\n    let l=0;\n    const a = SA[i-1], b = SA[i];\n    while(a+l < s.length && b+l < s.length && s[a+l]===s[b+l]) l++;\n    if(l > bestLen){ bestLen=l; bestPos = a; }\n  }\n  if(bestLen === 0){\n    queryView.innerText = \"No repeated substring (other than terminator).\";\n    log('LRS computed: none.');\n  } else {\n    queryView.innerText = \"Longest repeated substring: \\\"\" + s.substr(bestPos, bestLen) + \"\\\" length=\" + bestLen + \" at pos \" + bestPos;\n    log('LRS computed: \"' + s.substr(bestPos,bestLen) + '\"');\n  }\n});\n\n// Count distinct substrings using formula n*(n+1)/2 - sum LCP\ncountDistinct.addEventListener('click', ()=> {\n  if(!ensureSnapshotExists()) return;\n  const snap = snapshots[currentSnapshotIndex];\n  const s = snap.fullString || \"\";\n  const SA = [];\n  for(let i=0;i<s.length;i++) SA.push(i);\n  SA.sort((a,b)=> s.substring(a) < s.substring(b) ? -1 : 1);\n  const LCP = [];\n  for(let i=1;i<SA.length;i++){\n    let l=0;\n    const a = SA[i-1], b = SA[i];\n    while(a+l < s.length && b+l < s.length && s[a+l]===s[b+l]) l++;\n    LCP.push(l);\n  }\n  const n = s.length;\n  const total = n*(n+1)/2 - LCP.reduce((a,b)=>a+b,0);\n  queryView.innerText = \"Distinct substrings count: \" + total;\n  log('Distinct substrings counted: ' + total);\n});\n\n// Generalized LCS\ncomputeLCSBtn.addEventListener('click', ()=> {\n  if(modeSelect.value !== 'generalized'){\n    alert('Switch to generalized mode with two strings to compute LCS.');\n    return;\n  }\n  if(!ensureSnapshotExists()) return;\n  const snap = snapshots[currentSnapshotIndex];\n  // We'll find deepest internal node with leaves from both strings\n  let best = {len:0, substr:\"\", nodeId:null};\n  function dfs(nodeId, curDepth){\n    const node = snap.nodeMap[nodeId];\n    let ownerSet = new Set(node.leafOwners || []);\n    if(ownerSet.size >= 2 && curDepth > best.len){\n      best.len = curDepth;\n      // Build substring by walking up parent edges (we store edges with parent info in snapshot)\n      best.substr = buildSubstringFromNode(snap, nodeId);\n      best.nodeId = nodeId;\n    }\n    for(const e of node.edges){\n      dfs(e.dest, curDepth + e.substr.length);\n    }\n  }\n  dfs(\"n1\", 0);\n  if(best.len === 0){\n    queryView.innerText = \"No common substring found.\";\n    log('LCS: none.');\n  } else {\n    queryView.innerText = \"LCS length \" + best.len + \" substring: \\\"\" + best.substr + \"\\\" (node \" + best.nodeId + \")\";\n    log('LCS found: \"' + best.substr + '\" length ' + best.len);\n  }\n});\n\nfunction buildSubstringFromNode(snap, nodeId){\n  // Walk backwards from node to root using parent pointers included in snapshot (we will maintain parent in snapshots)\n  const node = snap.nodeMap[nodeId];\n  const parts = [];\n  let cur = nodeId;\n  while(cur && cur !== \"n1\"){\n    const edge = snap.parentEdge[cur];\n    if(!edge) break;\n    parts.push(edge.substr);\n    cur = snap.parentNode[cur];\n  }\n  return parts.reverse().join(\"\");\n}\n\n// ---------- Building algorithms (generate snapshots) ----------\n\n// Snapshot building helper: create an exported representation of current tree\nfunction makeSnapshotFromTree(tree, metaMessage){\n  // tree: {fullString, nodes map, edges ...}\n  // We'll produce nodes array and edges with substrings computed up to tree.pos\n  const s = tree.S;\n  const pos = tree.pos;\n  const nodeList = [];\n  const edgeList = [];\n  const nodeMapExport = {};\n  // We'll ensure each node has unique id \"nX\"\n  for(const nid in tree.nodes){\n    const n = tree.nodes[nid];\n    nodeList.push({id: nid, suffixLink: n.suffixLink || null, leafIndices: Array.from(n.leafIndices || [])});\n  }\n  // For edges, gather from parent\n  const parentEdge = {}; // map child->edge\n  const parentNode = {};\n  for(const pid in tree.nodes){\n    const n = tree.nodes[pid];\n    for(const ekey in n.edges){\n      const e = n.edges[ekey];\n      // compute substring display until pos\n      const endIdx = (e.end === Infinity) ? pos : e.end;\n      const substr = s.substring(e.start, Math.min(endIdx+1, s.length));\n      const eobj = {start: e.start, endDisplay: (e.end===Infinity ? ('..' + pos) : e.end), substr: substr, dest: e.dest};\n      edgeList.push(eobj);\n      if(!nodeMapExport[pid]) nodeMapExport[pid] = {id: pid, edges: [], suffixLink: tree.nodes[pid].suffixLink || null, leafIndices: Array.from(tree.nodes[pid].leafIndices || [])};\n      nodeMapExport[pid].edges.push({start:e.start, endDisplay:eobj.endDisplay, substr:substr, dest:e.dest});\n      parentEdge[e.dest] = {start:e.start, endDisplay:eobj.endDisplay, substr:substr, dest:e.dest};\n      parentNode[e.dest] = pid;\n    }\n  }\n  const nodesArray = Object.values(nodeMapExport);\n  // Also compute owner info for generalized tree leaves\n  const nodeOwners = {};\n  for(const nid in tree.nodes){\n    nodeOwners[nid] = new Set();\n    const li = tree.nodes[nid].leafIndices || new Set();\n    for(const posi of li){\n      if(tree.ownerOfSuffix && tree.ownerOfSuffix[posi]) nodeOwners[nid].add(tree.ownerOfSuffix[posi]);\n    }\n  }\n  // Transform sets to arrays\n  for(const nid in nodeOwners){\n    nodeOwners[nid] = Array.from(nodeOwners[nid]);\n  }\n  // Export snapshot object\n  const snap = {\n    phase: tree.phase || null,\n    message: metaMessage || null,\n    meta: {pos: tree.pos},\n    fullString: s,\n    nodes: nodesArray,\n    edges: edgeList,\n    nodeMap: nodeMapExport,\n    parentEdge: parentEdge,\n    parentNode: parentNode,\n    ownerInfo: nodeOwners\n  };\n  // attach leafOwners to node map\n  for(const nid in snap.nodeMap){\n    snap.nodeMap[nid].leafOwners = nodeOwners[nid] || [];\n  }\n  // compute and attach leafIndices for convenience (already in nodeMap)\n  for(const nid in snap.nodeMap){\n    snap.nodeMap[nid].leafIndices = snap.nodeMap[nid].leafIndices || [];\n  }\n  // Also make quick lookup map for recursion earlier\n  snapshots.push(snap);\n}\n\n// ---------- Ukkonen algorithm (single string) ----------\nfunction buildUkkonenSteps(baseString, terminator){\n  const S = baseString + terminator;\n  // Node structure: nodes map with edges keyed by first char; edges: {start,end,dest}\n  const nodes = {};\n  const nodeId = idGen('n');\n  // Create root\n  const rootId = nodeId();\n  nodes[rootId] = {edges: {}, suffixLink: null, leafIndices: new Set()};\n  const tree = {S: S, pos: -1, nodes: nodes, phase: null, ownerOfSuffix: {}};\n  tree.root = rootId;\n  tree.nextNodeId = nodeId;\n  // Add snapshot of empty root\n  tree.pos = -1;\n  makeSnapshotFromTree(tree, \"Initial empty tree\");\n\n  let activeNode = rootId;\n  let activeEdge = -1;\n  let activeLength = 0;\n  let remainder = 0;\n  let lastNewNode = null;\n\n  for(let i=0;i<S.length;i++){\n    tree.pos = i;\n    tree.phase = \"phase \" + i + \" (adding '\" + S[i] + \"')\";\n    const ch = S[i];\n    remainder++;\n    lastNewNode = null;\n    makeSnapshotFromTree(tree, \"Start phase \" + i + \", remainder now \" + remainder);\n\n    while(remainder > 0){\n      if(activeLength === 0) activeEdge = i;\n      const activeEdgeChar = S[activeEdge];\n      const activeNodeObj = tree.nodes[activeNode];\n      let edge = activeNodeObj.edges[activeEdgeChar];\n      if(!edge){\n        // Rule 2: create a new leaf edge\n        const leafId = nodeId();\n        tree.nodes[leafId] = {edges:{}, suffixLink: null, leafIndices: new Set([i - (S.length - 1 - i) /* dummy */])};\n        // In our representation, we'll keep leafIndices updated via a DFS after each crucial change for readability\n        activeNodeObj.edges[activeEdgeChar] = {start: i, end: Infinity, dest: leafId};\n        // assign ownerOfSuffix: suffix begins at i\n        tree.ownerOfSuffix[i] = 1;\n        makeSnapshotFromTree(tree, \"Created new leaf for char '\" + ch + \"' at pos \" + i);\n        if(lastNewNode){\n          tree.nodes[lastNewNode].suffixLink = activeNode;\n          makeSnapshotFromTree(tree, \"Set suffix link of lastNewNode \" + lastNewNode + \" -> \" + activeNode);\n          lastNewNode = null;\n        }\n        remainder--;\n      } else {\n        // Walk down if necessary\n        const edgeSpan = (edge.end === Infinity ? (i - edge.start + 1) : (edge.end - edge.start + 1));\n        if(activeLength >= edgeSpan){\n          activeEdge += edgeSpan;\n          activeLength -= edgeSpan;\n          activeNode = edge.dest;\n          continue;\n        }\n        // Check next character on edge\n        const nextChar = S[edge.start + activeLength];\n        if(nextChar === ch){\n          // Rule 3: no insertion, increment activeLength\n          activeLength++;\n          makeSnapshotFromTree(tree, \"Character already on edge, increment activeLength to \" + activeLength);\n          if(lastNewNode){\n            tree.nodes[lastNewNode].suffixLink = activeNode;\n            makeSnapshotFromTree(tree, \"Set suffix link of lastNewNode \" + lastNewNode + \" -> \" + activeNode);\n            lastNewNode = null;\n          }\n          break;\n        } else {\n          // Rule 2 + split edge: create internal node\n          const splitId = nodeId();\n          tree.nodes[splitId] = {edges:{}, suffixLink: null, leafIndices: new Set()};\n          // Old edge becomes child of split\n          const oldDest = edge.dest;\n          const oldStart = edge.start;\n          const oldEnd = edge.end;\n          // New edge from activeNode to split\n          activeNodeObj.edges[activeEdgeChar] = {start: oldStart, end: oldStart + activeLength - 1, dest: splitId};\n          // Edge from split to oldDest with adjusted start\n          tree.nodes[splitId].edges[S[oldStart + activeLength]] = {start: oldStart + activeLength, end: oldEnd, dest: oldDest};\n          // New leaf from split\n          const leafId = nodeId();\n          tree.nodes[leafId] = {edges:{}, suffixLink: null, leafIndices: new Set([i])};\n          tree.nodes[splitId].edges[ch] = {start: i, end: Infinity, dest: leafId};\n\n          makeSnapshotFromTree(tree, \"Split edge and created internal node \" + splitId + \" and leaf \" + leafId);\n\n          // manage suffix link\n          if(lastNewNode){\n            tree.nodes[lastNewNode].suffixLink = splitId;\n            makeSnapshotFromTree(tree, \"Set suffix link of lastNewNode \" + lastNewNode + \" -> \" + splitId);\n          }\n          lastNewNode = splitId;\n\n          remainder--;\n          if(activeNode === rootId && activeLength > 0){\n            activeLength--;\n            activeEdge = i - remainder + 1;\n          } else {\n            activeNode = tree.nodes[activeNode].suffixLink || rootId;\n          }\n        }\n      }\n    } // end while remainder\n    // After phase, update a readable mapping of leafIndices by performing a DFS to collect leaf positions\n    updateLeafIndices(tree);\n    makeSnapshotFromTree(tree, \"End phase \" + i);\n  } // end for each char\n\n  // Final snapshot marking completion\n  tree.pos = S.length - 1;\n  makeSnapshotFromTree(tree, \"Final tree built (Ukkonen).\");\n  log('Ukkonen build generated ' + snapshots.length + ' snapshots for string \"' + S + '\"');\n  currentSnapshotIndex = 0;\n}\n\n// ---------- Naive builder for single string ----------\nfunction buildNaiveSteps(baseString, terminator){\n  const S = baseString + terminator;\n  const nodes = {};\n  const nodeId = idGen('n');\n  const rootId = nodeId();\n  nodes[rootId] = {edges:{}, suffixLink:null, leafIndices:new Set()};\n  const tree = {S: S, pos: -1, nodes: nodes, phase: null, ownerOfSuffix:{}};\n  tree.root = rootId;\n  tree.nextNodeId = nodeId;\n  tree.pos = -1;\n  makeSnapshotFromTree(tree, \"Initial empty tree (naive)\");\n\n  // Insert each suffix\n  for(let start=0; start<S.length; start++){\n    tree.pos = start;\n    tree.phase = \"Insert suffix starting at \" + start;\n    let cur = rootId;\n    let i = start;\n    while(i < S.length){\n      const c = S[i];\n      const node = tree.nodes[cur];\n      if(!node.edges[c]){\n        // create leaf\n        const leafId = nodeId();\n        tree.nodes[leafId] = {edges:{}, suffixLink:null, leafIndices:new Set([start])};\n        node.edges[c] = {start: i, end: Infinity, dest: leafId};\n        tree.ownerOfSuffix[start] = 1;\n        makeSnapshotFromTree(tree, \"Inserted new leaf for suffix starting \" + start + \" at char '\" + c + \"'\");\n        break;\n      } else {\n        const e = node.edges[c];\n        // match along edge\n        let j = e.start;\n        while(j <= (e.end === Infinity ? S.length-1 : e.end) && i < S.length && S[j] === S[i]){\n          j++; i++;\n        }\n        if(j <= (e.end === Infinity ? S.length-1 : e.end) && i < S.length && S[j] !== S[i]){\n          // split\n          const splitId = nodeId();\n          tree.nodes[splitId] = {edges:{}, suffixLink:null, leafIndices:new Set()};\n          // existing child becomes child of split\n          const oldDest = e.dest;\n          const oldStart = e.start;\n          const oldEnd = e.end;\n          node.edges[c] = {start: oldStart, end: j-1, dest: splitId};\n          tree.nodes[splitId].edges[S[j]] = {start: j, end: oldEnd, dest: oldDest};\n          // new leaf\n          const leafId = nodeId();\n          tree.nodes[leafId] = {edges:{}, suffixLink:null, leafIndices:new Set([start])};\n          tree.nodes[splitId].edges[S[i]] = {start: i, end: Infinity, dest: leafId};\n          makeSnapshotFromTree(tree, \"Split and inserted for mismatch during insertion of suffix \" + start);\n          break;\n        } else {\n          // moved past edge\n          cur = e.dest;\n          continue;\n        }\n      }\n    }\n    updateLeafIndices(tree);\n    makeSnapshotFromTree(tree, \"Finished inserting suffix \" + start);\n  }\n  makeSnapshotFromTree(tree, \"Final naive-built tree\");\n  log('Naive build generated ' + snapshots.length + ' snapshots for string \"' + S + '\"');\n  currentSnapshotIndex = 0;\n}\n\n// ---------- Generalized versions (two strings) ----------\nfunction buildGeneralizedUkkonenSteps(s1, s2, term1, term2){\n  // We'll build a generalized suffix tree by concatenating with distinct terminators and tracking ownerOfSuffix by start pos\n  const S = s1 + term1 + s2 + term2;\n  const n1 = s1.length + 1; // including term1\n  // Build similar to single Ukkonen but track ownerOfSuffix: if suffix start < n1 => owner 1 else owner 2\n  const nodes = {};\n  const nodeId = idGen('n');\n  const rootId = nodeId();\n  nodes[rootId] = {edges:{}, suffixLink:null, leafIndices:new Set()};\n  const tree = {S: S, pos: -1, nodes: nodes, phase: null, ownerOfSuffix: {}};\n  tree.root = rootId;\n  tree.nextNodeId = nodeId;\n  tree.pos = -1;\n  makeSnapshotFromTree(tree, \"Initial empty generalized tree\");\n\n  let activeNode = rootId;\n  let activeEdge = -1;\n  let activeLength = 0;\n  let remainder = 0;\n  let lastNewNode = null;\n\n  for(let i=0;i<S.length;i++){\n    tree.pos = i;\n    tree.phase = \"phase \" + i + \" (adding '\" + S[i] + \"')\";\n    remainder++;\n    lastNewNode = null;\n    makeSnapshotFromTree(tree, \"Start phase \" + i + \", remainder now \" + remainder);\n\n    while(remainder > 0){\n      if(activeLength === 0) activeEdge = i;\n      const activeEdgeChar = S[activeEdge];\n      const activeNodeObj = tree.nodes[activeNode];\n      let edge = activeNodeObj.edges[activeEdgeChar];\n      if(!edge){\n        // create leaf\n        const leafId = nodeId();\n        tree.nodes[leafId] = {edges:{}, suffixLink:null, leafIndices:new Set([i])};\n        activeNodeObj.edges[activeEdgeChar] = {start: i, end: Infinity, dest: leafId};\n        tree.ownerOfSuffix[i] = (i < n1) ? 1 : 2;\n        makeSnapshotFromTree(tree, \"Created new generalized leaf for char '\" + S[i] + \"' at pos \" + i);\n        if(lastNewNode){\n          tree.nodes[lastNewNode].suffixLink = activeNode;\n          makeSnapshotFromTree(tree, \"Set suffix link of lastNewNode \" + lastNewNode + \" -> \" + activeNode);\n          lastNewNode = null;\n        }\n        remainder--;\n      } else {\n        const edgeSpan = (edge.end === Infinity ? (i - edge.start + 1) : (edge.end - edge.start + 1));\n        if(activeLength >= edgeSpan){\n          activeEdge += edgeSpan;\n          activeLength -= edgeSpan;\n          activeNode = edge.dest;\n          continue;\n        }\n        const nextChar = S[edge.start + activeLength];\n        if(nextChar === S[i]){\n          activeLength++;\n          makeSnapshotFromTree(tree, \"Character already on edge, increment activeLength to \" + activeLength);\n          if(lastNewNode){\n            tree.nodes[lastNewNode].suffixLink = activeNode;\n            makeSnapshotFromTree(tree, \"Set suffix link of lastNewNode \" + lastNewNode + \" -> \" + activeNode);\n            lastNewNode = null;\n          }\n          break;\n        } else {\n          // split\n          const splitId = nodeId();\n          tree.nodes[splitId] = {edges:{}, suffixLink:null, leafIndices:new Set()};\n          const oldDest = edge.dest;\n          const oldStart = edge.start;\n          const oldEnd = edge.end;\n          activeNodeObj.edges[activeEdgeChar] = {start: oldStart,