  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Relational Database — Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Roboto+Slab:wght@700&display=swap');\n  :root {\n    --color-bg: #121622;\n    --color-primary: #4ecdc4;\n    --color-secondary: #f7fff7;\n    --color-accent: #f25f5c;\n    --color-shadow: rgba(14, 17, 23, 0.7);\n    --font-heading: 'Roboto Slab', serif;\n    --font-body: 'Poppins', sans-serif;\n    --radius: 18px;\n    --transition: all 0.5s cubic-bezier(0.65, 0, 0.35, 1);\n    --elevation: 0 10px 25px var(--color-shadow);\n  }\n\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  body {\n    background: linear-gradient(135deg, #121622 20%, #1f2a44 80%);\n    font-family: var(--font-body);\n    color: var(--color-secondary);\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 2rem 5rem;\n    overflow-x: hidden;\n  }\n\n  header {\n    font-family: var(--font-heading);\n    font-weight: 700;\n    font-size: 3.6rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: var(--color-primary);\n    text-shadow: 0 0 12px var(--color-primary);\n    user-select: none;\n    margin-bottom: 2rem;\n  }\n\n  main {\n    position: relative;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 4rem;\n    max-width: 1200px;\n    width: 100%;\n  }\n\n  /* THE TABLE CARDS */\n  .table-card {\n    background: linear-gradient(145deg, #223350, #1b2b46);\n    border-radius: var(--radius);\n    box-shadow: var(--elevation);\n    width: 280px;\n    padding: 1.8rem 2rem 2.8rem;\n    display: flex;\n    flex-direction: column;\n    transition: var(--transition);\n    position: relative;\n  }\n  .table-card:hover {\n    transform: translateY(-8px);\n    box-shadow: 0 20px 40px rgba(78, 205, 196, 0.5);\n  }\n\n  .table-title {\n    font-family: var(--font-heading);\n    font-size: 1.9rem;\n    margin-bottom: 1rem;\n    color: var(--color-accent);\n    letter-spacing: 0.08em;\n    text-shadow: 0 0 8px var(--color-accent);\n  }\n\n  .columns-list {\n    list-style: none;\n    flex-grow: 1;\n  }\n  .column-item {\n    font-weight: 600;\n    font-size: 1.1rem;\n    margin-bottom: 0.9rem;\n    position: relative;\n    letter-spacing: 0.02em;\n    color: var(--color-secondary);\n  }\n\n  /* Highlight PK and FK (visual) */\n  .pk {\n    color: #ffcb6b;\n    font-weight: 700;\n    text-shadow: 0 0 6px #ffcb6b99;\n  }\n  .fk {\n    color: #82aaff;\n    font-style: italic;\n    text-shadow: 0 0 5px #82aaffcc;\n  }\n\n  /* Connecting lines SVG container */\n  #connections {\n    position: absolute;\n    top: 0; left: 0;\n    width: 100%;\n    height: 100%;\n    pointer-events: none;\n    z-index: 1;\n  }\n\n  /* Caption below tables */\n  .caption {\n    margin-top: 4rem;\n    font-size: 1.1rem;\n    max-width: 600px;\n    line-height: 1.5;\n    color: #adb7c7aa;\n    user-select: none;\n    text-align: center;\n  }\n\n  /* Buttons container */\n  .controls {\n    margin-top: 3rem;\n    display: flex;\n    gap: 2rem;\n  }\n\n  button {\n    background: var(--color-primary);\n    border: none;\n    padding: 0.9rem 2rem;\n    font-weight: 600;\n    font-size: 1rem;\n    border-radius: var(--radius);\n    color: var(--color-bg);\n    cursor: pointer;\n    box-shadow: 0 4px 12px rgba(78, 205, 196, 0.4);\n    transition: var(--transition);\n    user-select: none;\n  }\n  button:hover {\n    background: var(--color-accent);\n    box-shadow: 0 6px 16px rgba(242, 95, 92, 0.6);\n    color: var(--color-secondary);\n  }\n  button:active {\n    transform: translateY(1px);\n  }\n\n  /* Subtle animated background shape */\n  #bg-shape {\n    position: fixed;\n    top: -20vh;\n    left: 50%;\n    width: 110vw;\n    height: 110vw;\n    max-width: 700px;\n    max-height: 700px;\n    background: radial-gradient(circle at center, #4ecdc4bb 0%, transparent 70%);\n    filter: blur(165px);\n    transform: translateX(-50%);\n    animation: pulseGlow 8s ease-in-out infinite;\n    z-index: 0;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      transform: translateX(-50%) scale(1);\n      opacity: 0.42;\n      filter: blur(160px);\n    }\n    50% {\n      transform: translateX(-50%) scale(1.08);\n      opacity: 0.6;\n      filter: blur(175px);\n    }\n  }\n</style>\n</head>\n<body>\n  <div id=\"bg-shape\" aria-hidden=\"true\"></div>\n  <header>Relational Database</header>\n  <main aria-label=\"Visual representation of relational database schema\">\n    <article id=\"tbl-customers\" class=\"table-card\" tabindex=\"0\" aria-describedby=\"desc-customers\">\n      <h2 class=\"table-title\">Customers</h2>\n      <ul class=\"columns-list\">\n        <li class=\"column-item pk\" title=\"Primary Key\">CustomerID</li>\n        <li class=\"column-item\">Name</li>\n        <li class=\"column-item\">Email</li>\n        <li class=\"column-item\">Phone</li>\n      </ul>\n      <p id=\"desc-customers\" class=\"visually-hidden\">Table Customers with primary key CustomerID</p>\n    </article>\n\n    <article id=\"tbl-orders\" class=\"table-card\" tabindex=\"0\" aria-describedby=\"desc-orders\">\n      <h2 class=\"table-title\">Orders</h2>\n      <ul class=\"columns-list\">\n        <li class=\"column-item pk\" title=\"Primary Key\">OrderID</li>\n        <li class=\"column-item fk\" title=\"Foreign Key\">CustomerID</li>\n        <li class=\"column-item\">OrderDate</li>\n        <li class=\"column-item\">TotalAmount</li>\n      </ul>\n      <p id=\"desc-orders\" class=\"visually-hidden\">Table Orders with primary key OrderID and foreign key CustomerID references Customers</p>\n    </article>\n\n    <article id=\"tbl-products\" class=\"table-card\" tabindex=\"0\" aria-describedby=\"desc-products\">\n      <h2 class=\"table-title\">Products</h2>\n      <ul class=\"columns-list\">\n        <li class=\"column-item pk\" title=\"Primary Key\">ProductID</li>\n        <li class=\"column-item\">Name</li>\n        <li class=\"column-item\">Category</li>\n        <li class=\"column-item\">Price</li>\n      </ul>\n      <p id=\"desc-products\" class=\"visually-hidden\">Table Products with primary key ProductID</p>\n    </article>\n\n    <article id=\"tbl-orderdetails\" class=\"table-card\" tabindex=\"0\" aria-describedby=\"desc-orderdetails\">\n      <h2 class=\"table-title\">OrderDetails</h2>\n      <ul class=\"columns-list\">\n        <li class=\"column-item pk\" title=\"Primary Key\">OrderDetailID</li>\n        <li class=\"column-item fk\" title=\"Foreign Key\">OrderID</li>\n        <li class=\"column-item fk\" title=\"Foreign Key\">ProductID</li>\n        <li class=\"column-item\">Quantity</li>\n      </ul>\n      <p id=\"desc-orderdetails\" class=\"visually-hidden\">Table OrderDetails with primary key OrderDetailID and foreign keys OrderID references Orders and ProductID references Products</p>\n    </article>\n\n    <svg id=\"connections\" aria-hidden=\"true\" width=\"100%\" height=\"100%\"></svg>\n  </main>\n\n  <div class=\"controls\" role=\"region\" aria-label=\"Controls for layout\">\n    <button id=\"btn-toggle-layout\" aria-pressed=\"false\" title=\"Toggle layout orientation\">Toggle Vertical Layout</button>\n  </div>\n\n  <p class=\"caption\">\n    This visualization illustrates a relational database schema. Tables are represented as cards showing their columns. \n    Primary keys (PK) are highlighted in gold, foreign keys (FK) in light blue. Lines connect foreign keys to their referenced primary keys, showcasing referential relationships.\n  </p>\n\n  <script>\n    (function(){\n      const svg = document.getElementById('connections');\n      const tables = {\n        customers: document.getElementById('tbl-customers'),\n        orders: document.getElementById('tbl-orders'),\n        products: document.getElementById('tbl-products'),\n        orderdetails: document.getElementById('tbl-orderdetails')\n      };\n\n      // Relationships to visualize:\n      // Orders.CustomerID (FK) -> Customers.CustomerID (PK)\n      // OrderDetails.OrderID (FK) -> Orders.OrderID (PK)\n      // OrderDetails.ProductID (FK) -> Products.ProductID (PK)\n\n      // We need to find position of FK columns and PK columns in their tables,\n      // then draw smooth lines (cubic curves) connecting them.\n\n      // To get positions, find offset of table, then offset of row inside.\n\n      // Helpers:\n      function getColumnCenter(tableElem, colText) {\n        const items = [...tableElem.querySelectorAll('.column-item')];\n        for (let item of items) {\n          if (item.textContent.trim() === colText.trim()) {\n            const rect = item.getBoundingClientRect();\n            return {\n              x: rect.right, // attach from right side for FK (usually right edge)\n              y: rect.top + rect.height / 2\n            };\n          }\n        }\n        return null;\n      }\n      function getPKCenter(tableElem, colText) {\n        // For PK slightly attach from left side\n        const items = [...tableElem.querySelectorAll('.column-item')];\n        for (let item of items) {\n          if (item.textContent.trim() === colText.trim()) {\n            const rect = item.getBoundingClientRect();\n            return {\n              x: rect.left, // attach from left side for PK (left edge)\n              y: rect.top + rect.height / 2\n            };\n          }\n        }\n        return null;\n      }\n\n      // Maintain layout mode (horizontal or vertical)\n      let verticalLayout = false;\n\n      const btnToggle = document.getElementById('btn-toggle-layout');\n      btnToggle.addEventListener('click', () => {\n        verticalLayout = !verticalLayout;\n        btnToggle.setAttribute('aria-pressed', verticalLayout);\n        if(verticalLayout) {\n          document.querySelector('main').style.flexDirection = 'column';\n          btnToggle.textContent = 'Toggle Horizontal Layout';\n        } else {\n          document.querySelector('main').style.flexDirection = 'row';\n          btnToggle.textContent = 'Toggle Vertical Layout';\n        }\n        drawConnections();\n      });\n\n      // Draw lines between two points in SVG with a cubic bezier curve\n      function createCurvePath(x1, y1, x2, y2) {\n        // Horizontal or vertical curve depending on layout\n        if(verticalLayout) {\n          // vertical layout: tables stack column-wise,\n          // so draw curve mostly vertical\n          const dx = x2 - x1;\n          const dy = y2 - y1;\n          const cx1 = x1;\n          const cy1 = y1 + dy/3;\n          const cx2 = x2;\n          const cy2 = y2 - dy/3;\n          return `M ${x1} ${y1} C ${cx1} ${cy1} ${cx2} ${cy2} ${x2} ${y2}`;\n        } else {\n          // horizontal layout: tables side-by-side,\n          // curve mostly horizontal with horizontal control points\n          const dx = x2 - x1;\n          const dy = y2 - y1;\n          const cx1 = x1 + dx / 3;\n          const cy1 = y1;\n          const cx2 = x2 - dx / 3;\n          const cy2 = y2;\n          return `M ${x1} ${y1} C ${cx1} ${cy1} ${cx2} ${cy2} ${x2} ${y2}`;\n        }\n      }\n\n      function clearConnections() {\n        while(svg.firstChild){\n          svg.removeChild(svg.firstChild);\n        }\n      }\n\n      function drawConnections() {\n        clearConnections();\n        // Get bounding rect of SVG container for coordinate adjustment\n        const svgRect = svg.getBoundingClientRect();\n\n        // Helper: translate viewport coords to SVG coords\n        function toSvgCoords(clientX, clientY){\n          return {\n            x: clientX - svgRect.left,\n            y: clientY - svgRect.top\n          };\n        }\n\n        // Link orders.CustomerID -> customers.CustomerID\n        let start = getColumnCenter(tables.orders, 'CustomerID');\n        let end = getPKCenter(tables.customers, 'CustomerID');\n        if(start && end){\n          start = toSvgCoords(start.x, start.y);\n          end = toSvgCoords(end.x, end.y);\n          const pathData = createCurvePath(start.x, start.y, end.x, end.y);\n          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n          path.setAttribute('d', pathData);\n          path.setAttribute('stroke', '#82aaff');\n          path.setAttribute('stroke-width', '3');\n          path.setAttribute('fill', 'none');\n          path.setAttribute('opacity', '0.7');\n          path.setAttribute('class', 'connection');\n          path.style.filter = 'drop-shadow(0 0 4px #82aaffcc)';\n          svg.appendChild(path);\n        }\n\n        // Link orderdetails.OrderID -> orders.OrderID\n        start = getColumnCenter(tables.orderdetails, 'OrderID');\n        end = getPKCenter(tables.orders, 'OrderID');\n        if(start && end){\n          start = toSvgCoords(start.x, start.y);\n          end = toSvgCoords(end.x, end.y);\n          const pathData = createCurvePath(start.x, start.y, end.x, end.y);\n          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n          path.setAttribute('d', pathData);\n          path.setAttribute('stroke', '#82aaff');\n          path.setAttribute('stroke-width', '3');\n          path.setAttribute('fill', 'none');\n          path.setAttribute('opacity', '0.7');\n          path.style.filter = 'drop-shadow(0 0 4px #82aaffcc)';\n          svg.appendChild(path);\n        }\n\n        // Link orderdetails.ProductID -> products.ProductID\n        start = getColumnCenter(tables.orderdetails, 'ProductID');\n        end = getPKCenter(tables.products, 'ProductID');\n        if(start && end){\n          start = toSvgCoords(start.x, start.y);\n          end = toSvgCoords(end.x, end.y);\n          const pathData = createCurvePath(start.x, start.y, end.x, end.y);\n          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n          path.setAttribute('d', pathData);\n          path.setAttribute('stroke', '#82aaff');\n          path.setAttribute('stroke-width', '3');\n          path.setAttribute('fill', 'none');\n          path.setAttribute('opacity', '0.7');\n          path.style.filter = 'drop-shadow(0 0 4px #82aaffcc)';\n          svg.appendChild(path);\n        }\n      }\n\n      window.addEventListener('resize', drawConnections);\n      window.addEventListener('load', drawConnections);\n    })();\n\n  </script>\n\n  <style>\n    /* Visually hidden for accessibility */\n    .visually-hidden {\n      position: absolute !important;\n      height: 1px; width: 1px;\n      overflow: hidden;\n      clip: rect(1px, 1px, 1px, 1px);\n      clip-path: inset(50%);\n      white-space: nowrap;\n      border: 0;\n      padding: 0;\n      margin: -1px;\n    }\n  </style>\n</body>\n</html>"
  },
