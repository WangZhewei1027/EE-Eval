  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Insertion Sort Interactive Explorer</title>\n<style>\n  /* Minimal styling for layout only */\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n  }\n  #arrayInput, #stepControls, #autoControls, #info, #customStep {\n    margin-top: 10px;\n  }\n  button, input[type=number], input[type=text], select {\n    margin-right: 5px;\n    margin-bottom: 5px;\n    font-size: 1em;\n  }\n  #arrayDisplay {\n    white-space: pre;\n    font-size: 1.1em;\n  }\n  #log {\n    max-height: 150px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 5px;\n    font-size: 0.9em;\n  }\n  #statesList {\n    max-height: 120px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 3px;\n    font-size: 0.9em;\n  }\n  label {\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n\n<h2>Insertion Sort Interactive Explorer</h2>\n\n<div id=\"arrayInput\">\n  <label for=\"inputArray\">Enter array (comma/space separated):</label><br/>\n  <input type=\"text\" id=\"inputArray\" size=\"50\" aria-label=\"Input array\" value=\"5 3 8 6 2 9 1\" />\n  <button id=\"loadArrayBtn\">Load Array</button>\n</div>\n\n<div id=\"arrayDisplay\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<div id=\"stepControls\" aria-label=\"Step Controls\" role=\"group\">\n  <button id=\"prevStep\" disabled>&lt; Prev Step</button>\n  <button id=\"nextStep\" disabled>Next Step &gt;</button>\n  <button id=\"firstStep\" disabled>|&lt; First</button>\n  <button id=\"lastStep\" disabled>&gt;| Last</button>\n</div>\n\n<div id=\"autoControls\" aria-label=\"Automatic Controls\" role=\"group\">\n  <label for=\"autoSpeed\">Auto speed (ms per step):</label>\n  <input type=\"number\" id=\"autoSpeed\" value=\"1000\" min=\"100\" max=\"5000\" step=\"100\" aria-describedby=\"autoSpeedDesc\" />\n  <span id=\"autoSpeedDesc\">(100 to 5000)</span>\n  <button id=\"startAuto\" disabled>Start Auto</button>\n  <button id=\"stopAuto\" disabled>Stop Auto</button>\n</div>\n\n<div id=\"customStep\" aria-label=\"Custom Step Navigation\" role=\"group\">\n  <label for=\"goToStepInput\">Go to step (#):</label>\n  <input type=\"number\" id=\"goToStepInput\" value=\"0\" min=\"0\" aria-describedby=\"stepCountDesc\"/>\n  <button id=\"goToStepBtn\" disabled>Go</button>\n  <span id=\"stepCountDesc\">(0 based, max 0)</span>\n</div>\n\n<div id=\"info\" aria-live=\"polite\" aria-atomic=\"true\" style=\"white-space: pre-wrap; margin-top:10px;\">\n</div>\n\n<h3>State Timeline (Click step to jump)</h3>\n<div id=\"statesList\" role=\"listbox\" tabindex=\"0\" aria-label=\"List of algorithm states\">\n</div>\n\n<h3>Operation Log</h3>\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"false\" tabindex=\"0\"></div>\n\n<h3>Explore More</h3>\n<div id=\"exploreControls\" aria-label=\"Exploration Controls\" role=\"group\">\n  <label for=\"insertValue\">Insert value:</label>\n  <input type=\"number\" id=\"insertValue\" aria-describedby=\"insertValueDesc\" />\n  <button id=\"insertBtn\" disabled>Insert</button>\n  <span id=\"insertValueDesc\">Insert a number into the sorted part at current step</span>\n  <button id=\"removeBtn\" disabled>Remove selected index</button>\n  <label for=\"removeIndex\">Index:</label>\n  <input type=\"number\" id=\"removeIndex\" min=\"0\" />\n  <br/>\n  <label for=\"replaceIndex\">Replace at index:</label>\n  <input type=\"number\" id=\"replaceIndex\" min=\"0\" />\n  <label for=\"replaceValue\">With value:</label>\n  <input type=\"number\" id=\"replaceValue\" />\n  <button id=\"replaceBtn\" disabled>Replace</button>\n  <br/>\n  <button id=\"resetBtn\">Reset to loaded array</button>\n</div>\n\n<script>\n(function(){\n  // Core data structures\n  // Each state records:\n  // - array snapshot (array of numbers)\n  // - current i (insertion index in the main algorithm)\n  // - j index (pointer moving backward)\n  // - description string for this step\n  // We'll generate these states by simulating insertion sort with fine-grained steps.\n\n  // For maximum interactivity, states can be explored and even modified.\n  // User can jump to any state, step forward/backward.\n  // Users can insert or remove elements at the current state to explore.\n\n  // Globals:\n  let states = []; // array of states\n  let currentStep = 0;\n\n  // State structure example:\n  // {\n  //   array: [...],\n  //   i: number|null,\n  //   j: number|null,\n  //   phase: string, // \"start\", \"compare\", \"shift\", \"insert\", \"done\" etc.\n  //   description: string\n  // }\n\n  // DOM elements\n  const inputArrayEl = document.getElementById('inputArray');\n  const loadArrayBtn = document.getElementById('loadArrayBtn');\n  const arrayDisplayEl = document.getElementById('arrayDisplay');\n  const prevStepBtn = document.getElementById('prevStep');\n  const nextStepBtn = document.getElementById('nextStep');\n  const firstStepBtn = document.getElementById('firstStep');\n  const lastStepBtn = document.getElementById('lastStep');\n  const autoSpeedInput = document.getElementById('autoSpeed');\n  const startAutoBtn = document.getElementById('startAuto');\n  const stopAutoBtn = document.getElementById('stopAuto');\n  const goToStepInput = document.getElementById('goToStepInput');\n  const goToStepBtn = document.getElementById('goToStepBtn');\n  const stepCountDescSpan = document.getElementById('stepCountDesc');\n  const infoEl = document.getElementById('info');\n  const statesListEl = document.getElementById('statesList');\n  const logEl = document.getElementById('log');\n  const insertValueInput = document.getElementById('insertValue');\n  const insertBtn = document.getElementById('insertBtn');\n  const removeBtn = document.getElementById('removeBtn');\n  const removeIndexInput = document.getElementById('removeIndex');\n  const replaceIndexInput = document.getElementById('replaceIndex');\n  const replaceValueInput = document.getElementById('replaceValue');\n  const replaceBtn = document.getElementById('replaceBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // For auto play\n  let autoIntervalID = null;\n\n  function parseInputArray(str) {\n    // Parse by splitting on comma or space, filter out empty and NaN\n    let rawItems = str.split(/[\\s,]+/);\n    let arr = [];\n    for(let item of rawItems) {\n      if(item.trim() === '') continue;\n      let n = Number(item);\n      if(!Number.isNaN(n)) arr.push(n);\n    }\n    return arr;\n  }\n\n  // Clear all states and reset\n  function resetStates() {\n    states = [];\n    currentStep = 0;\n    updateStepControls();\n    updateGoToControls();\n    renderState();\n    renderStatesList();\n    clearLog();\n    stopAuto();\n    insertBtn.disabled = true;\n    removeBtn.disabled = true;\n    replaceBtn.disabled = true;\n  }\n\n  // Generate detailed insertion sort states for given array\n  // States show very fine-grained steps: start of iteration, comparisons, shifts, insertion of key\n  function generateInsertionSortStates(arr) {\n    let s = [];\n    let array = arr.slice();\n    // Initial state\n    s.push({\n      array: array.slice(),\n      i: null,\n      j: null,\n      phase: \"start\",\n      description: \"Initial array before sorting\"\n    });\n\n    let n = array.length;\n\n    for(let i=1; i<n; i++) {\n      let key = array[i];\n      let j = i-1;\n      // State: Start iteration with key at i\n      s.push({\n        array: array.slice(),\n        i: i,\n        j: null,\n        phase: \"iteration_start\",\n        description: `Start iteration with i=${i}, key=${key}`\n      });\n\n      // Compare and shift elements greater than key\n      while(j>=0 && array[j] > key) {\n        // State before compare\n        s.push({\n          array: array.slice(),\n          i: i,\n          j: j,\n          phase: \"compare\",\n          description: `Compare key=${key} with array[${j}]=${array[j]} (key < array[j]) - shift needed`\n        });\n        // Shift element right\n        array[j+1] = array[j];\n        s.push({\n          array: array.slice(),\n          i: i,\n          j: j,\n          phase: \"shift\",\n          description: `Shift array[${j}]=${array[j]} to position ${j+1}`\n        });\n        j--;\n      }\n      if(j>=0) {\n        s.push({\n          array: array.slice(),\n          i: i,\n          j: j,\n          phase: \"compare\",\n          description: `Compare key=${key} with array[${j}]=${array[j]} (key >= array[j]) - no shift`\n        });\n      } else {\n        s.push({\n          array: array.slice(),\n          i: i,\n          j: j,\n          phase: \"compare\",\n          description: `Compare key=${key} with array[${j}]=undefined (start of array) - stop shifting`\n        });\n      }\n      array[j+1] = key;\n      s.push({\n        array: array.slice(),\n        i: i,\n        j: j,\n        phase: \"insert\",\n        description: `Insert key=${key} at position ${j+1}`\n      });\n    }\n\n    s.push({\n      array: array.slice(),\n      i: null,\n      j: null,\n      phase: \"done\",\n      description: \"Array is fully sorted\"\n    });\n\n    return s;\n  }\n\n  // Render the current state information and array\n  function renderState() {\n    if(states.length===0) {\n      arrayDisplayEl.textContent = \"No array loaded.\";\n      infoEl.textContent = \"\";\n      return;\n    }\n    let state = states[currentStep];\n    let arr = state.array;\n    \n    // Show array with markers\n    // Mark i and j indexes visually with ^ in line below numbers\n    // We'll print indexes on top, then array values, then marker line with i/j indicators\n\n    let indexesLine = \"\";\n    for(let idx=0; idx<arr.length; idx++) {\n      let sidx = String(idx);\n      while(sidx.length<3) sidx += \" \";\n      if(idx < arr.length-1) sidx += \" \";\n      indexesLine += sidx;\n    }\n    let valuesLine = \"\";\n    for(let val of arr) {\n      let sval = String(val);\n      while(sval.length<3) sval += \" \";\n      sval += \" \";\n      valuesLine += sval;\n    }\n    let markerLine = \"\";\n    for(let idx=0; idx<arr.length; idx++) {\n      if(state.j===idx && state.i===idx) {\n        markerLine += \"ij \".padEnd(4,\" \");\n      } else if(state.i === idx) {\n        markerLine += \" i \".padEnd(4,\" \");\n      } else if(state.j === idx) {\n        markerLine += \" j \".padEnd(4,\" \");\n      } else {\n        markerLine += \"   \".padEnd(4,\" \");\n      }\n    }\n\n    arrayDisplayEl.textContent = indexesLine.trimEnd() + \"\\n\" + valuesLine.trimEnd() + \"\\n\" + markerLine.trimEnd();\n\n    infoEl.textContent = \"Step \"+currentStep+\"/\"+(states.length-1)+\" - \" + state.phase.toUpperCase() + \"\\n\" + state.description;\n\n    goToStepInput.max = states.length - 1;\n    stepCountDescSpan.textContent = `(0 to ${states.length -1})`;\n\n    // Enable or disable navigation buttons\n    updateStepControls();\n\n    // Update go to step controls\n    updateGoToControls();\n\n    // Highlight current step in statesList\n    highlightCurrentStateInList();\n\n    // Enable explore controls except insert/remove/replace only if state not done\n    if(state.phase === \"done\" || states.length===0) {\n      insertBtn.disabled = true;\n      removeBtn.disabled = true;\n      replaceBtn.disabled = true;\n    } else {\n      insertBtn.disabled = false;\n      removeBtn.disabled = false;\n      replaceBtn.disabled = false;\n    }\n  }\n\n  // Update the Next/Prev/First/Last buttons states\n  function updateStepControls() {\n    prevStepBtn.disabled = (currentStep <= 0);\n    firstStepBtn.disabled = (currentStep <= 0);\n    nextStepBtn.disabled = (currentStep >= states.length-1);\n    lastStepBtn.disabled = (currentStep >= states.length-1);\n    startAutoBtn.disabled = (states.length === 0 || currentStep === states.length -1);\n    stopAutoBtn.disabled = true;\n    goToStepBtn.disabled = (states.length === 0);\n  }\n\n  // Update Go To step button disabled or not & max input\n  function updateGoToControls() {\n    goToStepInput.max = (states.length > 0) ? states.length - 1 : 0;\n    let val = Number(goToStepInput.value);\n    if(Number.isNaN(val) || val < 0) goToStepInput.value = 0;\n    if(val > goToStepInput.max) goToStepInput.value = goToStepInput.max;\n    goToStepBtn.disabled = (states.length === 0);\n  }\n\n  // Navigation button handlers\n  prevStepBtn.addEventListener('click', () => {\n    if(currentStep > 0) {\n      currentStep--;\n      renderState();\n    }\n  });\n  \n  nextStepBtn.addEventListener('click', () => {\n    if(currentStep < states.length - 1) {\n      currentStep++;\n      renderState();\n    }\n  });\n\n  firstStepBtn.addEventListener('click', () => {\n    currentStep = 0;\n    renderState();\n  });\n\n  lastStepBtn.addEventListener('click', () => {\n    currentStep = states.length - 1;\n    renderState();\n  });\n\n  // Auto play setup\n  startAutoBtn.addEventListener('click', () => {\n    if(autoIntervalID !== null) return;\n    startAutoBtn.disabled = true;\n    stopAutoBtn.disabled = false;\n\n    let speed = Number(autoSpeedInput.value);\n    if(Number.isNaN(speed) || speed < 100) speed = 100;\n    if(speed > 5000) speed = 5000;\n    autoSpeedInput.value = speed;\n\n    autoIntervalID = setInterval(() => {\n      if(currentStep < states.length - 1) {\n        currentStep++;\n        renderState();\n      } else {\n        stopAuto();\n      }\n    }, speed);\n  });\n\n  stopAutoBtn.addEventListener('click', () => {\n    stopAuto();\n  });\n\n  function stopAuto() {\n    if(autoIntervalID !== null) {\n      clearInterval(autoIntervalID);\n      autoIntervalID = null;\n    }\n    startAutoBtn.disabled = (states.length === 0 || currentStep === states.length - 1);\n    stopAutoBtn.disabled = true;\n  }\n\n  // Go to step button\n  goToStepBtn.addEventListener('click', () => {\n    let val = Number(goToStepInput.value);\n    if(!Number.isInteger(val) || val < 0) val = 0;\n    if(val > states.length - 1) val = states.length - 1;\n    currentStep = val;\n    renderState();\n  });\n\n  // Load array button - parse input and create states\n  loadArrayBtn.addEventListener('click', () => {\n    let arr = parseInputArray(inputArrayEl.value);\n    if(arr.length === 0) {\n      alert(\"Please enter a valid array with numbers separated by commas or spaces.\");\n      return;\n    }\n    states = generateInsertionSortStates(arr);\n    currentStep = 0;\n    renderState();\n    renderStatesList();\n    clearLog();\n    log(\"Loaded new array: [\" + arr.join(\", \") + \"]\");\n  });\n\n  // Log helper\n  function log(msg) {\n    let now = new Date();\n    let timestamp = now.toLocaleTimeString();\n    let line = `[${timestamp}] ${msg}\\n`;\n    logEl.textContent += line;\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  function clearLog() {\n    logEl.textContent = \"\";\n  }\n\n  // States list rendering\n  function renderStatesList() {\n    statesListEl.innerHTML = \"\";\n    if(states.length === 0) {\n      let emptyMsg = document.createElement('div');\n      emptyMsg.textContent = \"No states to display.\";\n      statesListEl.appendChild(emptyMsg);\n      return;\n    }\n    for(let i=0; i<states.length; i++) {\n      let div = document.createElement('div');\n      div.setAttribute('role', 'option');\n      div.tabIndex = 0;\n      div.dataset.step = i;\n      div.textContent = `${i}: ${states[i].phase} - ${states[i].description}`;\n      div.style.cursor = \"pointer\";\n\n      // Keyboard accessible: Enter or Space selects step\n      div.addEventListener('keydown', (e) => {\n        if(e.key === \"Enter\" || e.key === \" \"){\n          e.preventDefault();\n          jumpToStepFromList(i);\n        }\n      });\n\n      div.addEventListener('click', () => {\n        jumpToStepFromList(i);\n      });\n\n      statesListEl.appendChild(div);\n    }\n    highlightCurrentStateInList();\n  }\n\n  // Highlight the current step in the states list\n  function highlightCurrentStateInList() {\n    let children = statesListEl.children;\n    for(let i = 0; i < children.length; i++) {\n      if(children[i].dataset.step == currentStep) {\n        children[i].style.backgroundColor = \"#ddd\";\n        children[i].setAttribute('aria-selected', 'true');\n        children[i].scrollIntoView({block:\"nearest\", inline:\"nearest\"});\n      } else {\n        children[i].style.backgroundColor = \"\";\n        children[i].setAttribute('aria-selected', 'false');\n      }\n    }\n  }\n\n  function jumpToStepFromList(step) {\n    if(step >= 0 && step < states.length) {\n      currentStep = step;\n      renderState();\n    }\n  }\n\n  // Exploration features: insert/remove/replace elements dynamically at current state\n  // These manipulations create a new branch/fork of states from this step,\n  // re-running insertion sort from this modified array starting from step 0.\n\n  insertValueInput.addEventListener('input', () => {\n    // Enable insert button only if valid number\n    let val = insertValueInput.value.trim();\n    insertBtn.disabled = val === \"\" || Number.isNaN(Number(val)) || states.length === 0;\n  });\n  insertBtn.addEventListener('click', () => {\n    if(states.length === 0) return;\n    let val = Number(insertValueInput.value);\n    if(Number.isNaN(val)) return;\n\n    let state = states[currentStep];\n    let arr = state.array.slice();\n\n    // For maximum exploration, insert at the sorted portion (0..i)\n    // Current i indicates sorted portion end; if i null, set to zero (start)\n    let insertIndex = state.i !== null ? state.i : 0;\n\n    arr.splice(insertIndex, 0, val);\n    states = generateInsertionSortStates(arr);\n    currentStep = 0;\n    renderState();\n    renderStatesList();\n    clearLog();\n    log(`Inserted value ${val} at sorted region index ${insertIndex} and reset states.`);\n  });\n\n  removeIndexInput.addEventListener('input', () => {\n    removeBtn.disabled = states.length === 0 || removeIndexInput.value === \"\" || Number.isNaN(Number(removeIndexInput.value));\n  });\n  removeBtn.addEventListener('click', () => {\n    if(states.length === 0) return;\n    let idx = Number(removeIndexInput.value);\n    let state = states[currentStep];\n    let arr = state.array.slice();\n    if (idx < 0 || idx >= arr.length) {\n      alert(\"Remove index out of range.\");\n      return;\n    }\n    let val = arr[idx];\n    arr.splice(idx,1);\n    states = generateInsertionSortStates(arr);\n    currentStep = 0;\n    renderState();\n    renderStatesList();\n    clearLog();\n    log(`Removed element at index ${idx} (value=${val}) and reset states.`);\n  });\n\n  replaceIndexInput.addEventListener('input', () => {\n    checkReplaceBtnEnabled();\n  });\n  replaceValueInput.addEventListener('input', () => {\n    checkReplaceBtnEnabled();\n  });\n\n  function checkReplaceBtnEnabled() {\n    let idxVal = replaceIndexInput.value.trim();\n    let newVal = replaceValueInput.value.trim();\n    replaceBtn.disabled = (\n      states.length === 0 ||\n      idxVal === \"\" || newVal === \"\" ||\n      Number.isNaN(Number(idxVal)) ||\n      Number.isNaN(Number(newVal))\n    );\n  }\n\n  replaceBtn.addEventListener('click', () => {\n    if(states.length === 0) return;\n    let idx = Number(replaceIndexInput.value);\n    let val = Number(replaceValueInput.value);\n    let state = states[currentStep];\n    let arr = state.array.slice();\n    if (idx < 0 || idx >= arr.length) {\n      alert(\"Replace index out of range.\");\n      return;\n    }\n    let oldVal = arr[idx];\n    arr[idx] = val;\n    states = generateInsertionSortStates(arr);\n    currentStep = 0;\n    renderState();\n    renderStatesList();\n    clearLog();\n    log(`Replaced element at index ${idx} from ${oldVal} to ${val} and reset states.`);\n  });\n\n  // Reset button resets to loaded array (initial input)\n  resetBtn.addEventListener('click', () => {\n    loadArrayBtn.click();\n    log(\"Reset to loaded array.\");\n  });\n\n  // On page load, load default input array and generate states\n  loadArrayBtn.click();\n\n  // Accessibility note:\n  // - statesList is keyboard focusable and each step clickable/selectable\n  // - buttons and inputs have labels and aria attributes for screen readers\n\n})();\n</script>\n\n</body>\n</html>"
  },
