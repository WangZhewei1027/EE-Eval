    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Bellman-Ford — Visual Elegance</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1:#030417;\n      --bg-2:#071032;\n      --card: rgba(255,255,255,0.04);\n      --glass: rgba(255,255,255,0.03);\n      --accent-1: #7cf7e4;\n      --accent-2: #8b6bff;\n      --accent-3: #ff80bf;\n      --muted: rgba(255,255,255,0.5);\n      --glass-border: rgba(255,255,255,0.06);\n      --success: #26de81;\n      --danger: #ff6b6b;\n      --shadow: 0 8px 30px rgba(2,6,23,0.6);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      background:\n        radial-gradient(1200px 600px at 10% 10%, rgba(139,107,255,0.12), transparent 6%),\n        radial-gradient(900px 400px at 90% 90%, rgba(124,247,228,0.06), transparent 6%),\n        linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color:#eaf3ff;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:36px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    .stage{\n      width:1100px;\n      max-width:95vw;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid var(--glass-border);\n      border-radius:18px;\n      padding:26px;\n      box-shadow: var(--shadow);\n      display:grid;\n      grid-template-columns: 1fr 380px;\n      gap:20px;\n      position:relative;\n      overflow:hidden;\n    }\n\n    /* Header */\n    .header{\n      grid-column: 1 / -1;\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:18px;\n      margin-bottom:6px;\n    }\n    .title{\n      display:flex;\n      align-items:center;\n      gap:16px;\n    }\n    .brand{\n      width:68px;\n      height:68px;\n      border-radius:12px;\n      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:800;\n      color:#02101a;\n      box-shadow:0 6px 20px rgba(139,107,255,0.18), inset 0 -6px 30px rgba(255,255,255,0.06);\n      transform:translateZ(0);\n    }\n    .brand .b{\n      font-size:20px;\n      letter-spacing:-1px;\n    }\n    h1{\n      margin:0;\n      font-size:20px;\n      letter-spacing:-0.3px;\n      font-weight:700;\n      color: #f8fbff;\n    }\n    p.lead{\n      margin:0;\n      font-size:13px;\n      color:var(--muted);\n      max-width:760px;\n    }\n\n    /* Canvas / Graph area */\n    .canvas{\n      position:relative;\n      background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n      border-radius:12px;\n      padding:18px;\n      min-height:560px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      overflow:hidden;\n    }\n\n    /* Decorative grid */\n    .canvas:before{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      background-image:\n        linear-gradient(transparent 92%, rgba(255,255,255,0.01) 92%),\n        linear-gradient(90deg, transparent 92%, rgba(255,255,255,0.01) 92%);\n      opacity:0.8;\n      mix-blend-mode:overlay;\n      pointer-events:none;\n    }\n\n    svg.graph{\n      width:100%;\n      height:100%;\n      overflow:visible;\n    }\n\n    /* Nodes */\n    .node{\n      cursor:default;\n      transition:transform 420ms cubic-bezier(.2,.9,.2,1), filter 420ms;\n      transform-origin:center;\n      filter:drop-shadow(0 8px 20px rgba(2,6,23,0.6));\n    }\n    .node circle{\n      transition: r 320ms, fill 320ms, stroke 320ms;\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1;\n    }\n    .node .label{\n      font-size:13px;\n      font-weight:700;\n      fill: #04131a;\n      letter-spacing:0.6px;\n    }\n    .node .dist{\n      font-size:12px;\n      fill:var(--muted);\n      font-weight:600;\n    }\n\n    /* Active / updated states */\n    .node.active circle{\n      r:28;\n      fill: url(#gradNodeActive);\n      stroke: rgba(255,255,255,0.08);\n    }\n    .node.updated circle{\n      r:30;\n      fill: linear-gradient(90deg, var(--accent-2), var(--accent-3));\n      stroke: rgba(255,255,255,0.1);\n    }\n    .node.inactive circle{\n      r:22;\n      fill: rgba(255,255,255,0.02);\n    }\n\n    /* Edge styles */\n    .edge{\n      fill:none;\n      stroke: rgba(255,255,255,0.08);\n      stroke-width:2;\n      transition: stroke 260ms, stroke-width 260ms, opacity 260ms;\n    }\n    .edge.highlight{\n      stroke: url(#edgeGlow);\n      stroke-width:3.8;\n      filter: drop-shadow(0 10px 24px rgba(139,107,255,0.14));\n    }\n    .weight{\n      font-size:12px;\n      fill:rgba(255,255,255,0.9);\n      font-weight:700;\n      background:transparent;\n      transition: fill 240ms;\n    }\n    .weight.glow{\n      fill: #02101a;\n      filter: drop-shadow(0 8px 22px rgba(124,247,228,0.18));\n    }\n\n    /* Sidebar */\n    .info{\n      padding:18px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      height:100%;\n      display:flex;\n      flex-direction:column;\n      gap:14px;\n    }\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      appearance:none;\n      border:0;\n      padding:10px 14px;\n      border-radius:10px;\n      color: #02101a;\n      font-weight:700;\n      background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n      box-shadow: 0 8px 28px rgba(124,247,228,0.06), inset 0 -6px 20px rgba(255,255,255,0.04);\n      cursor:pointer;\n      transition: transform 180ms ease, box-shadow 180ms;\n      user-select:none;\n      font-size:14px;\n    }\n    .btn:active{ transform: translateY(1px) }\n    .btn.ghost{\n      background: transparent;\n      color:var(--muted);\n      border: 1px solid rgba(255,255,255,0.04);\n      box-shadow:none;\n    }\n    .meta{\n      color:var(--muted);\n      font-size:13px;\n    }\n    .explain{\n      background:linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.006));\n      padding:12px;\n      border-radius:10px;\n      font-size:13px;\n      color:var(--muted);\n      line-height:1.45;\n      flex:1;\n      overflow:auto;\n    }\n    .footer-note{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      color:var(--muted);\n      font-size:12px;\n      justify-content:space-between;\n    }\n    .status{\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n    }\n    .indicator{\n      width:10px;\n      height:10px;\n      border-radius:50%;\n      background: rgba(255,255,255,0.06);\n      box-shadow:0 6px 16px rgba(2,6,23,0.6);\n    }\n    .indicator.ok{ background: linear-gradient(90deg,var(--success), #86e2a7); box-shadow:none; }\n    .indicator.warn{ background: linear-gradient(90deg, var(--accent-3), var(--accent-2)); box-shadow:none; }\n    .small{\n      font-size:12px;\n      color:var(--muted);\n    }\n\n    /* subtle animations */\n    @keyframes floaty {\n      0%{ transform: translateY(0px) }\n      50%{ transform: translateY(-6px) }\n      100%{ transform: translateY(0px) }\n    }\n    .brand{ animation: floaty 6s ease-in-out infinite }\n\n    /* responsive */\n    @media (max-width:980px){\n      .stage{ grid-template-columns: 1fr; padding:18px }\n      .info{ height:auto }\n      .canvas{ min-height:420px }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\" aria-live=\"polite\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <div class=\"brand\" aria-hidden=\"true\"><span class=\"b\">BF</span></div>\n        <div>\n          <h1>Bellman–Ford Algorithm — Elegant Visualization</h1>\n          <p class=\"lead\">Observe relaxation across iterations. Distances update from a chosen source; negative-cycle detection is performed at the end.</p>\n        </div>\n      </div>\n      <div class=\"meta small\">Nodes: 6 · Iterations: 5</div>\n    </div>\n\n    <div class=\"canvas\" role=\"img\" aria-label=\"Bellman-Ford algorithm graph visualization\">\n      <svg class=\"graph\" viewBox=\"0 0 1000 620\" preserveAspectRatio=\"xMidYMid meet\">\n        <!-- Gradients and defs -->\n        <defs>\n          <linearGradient id=\"gradNodeActive\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#8b6bff\"/>\n            <stop offset=\"1\" stop-color=\"#7cf7e4\"/>\n          </linearGradient>\n          <linearGradient id=\"edgeGlow\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7cf7e4\"/>\n            <stop offset=\"1\" stop-color=\"#8b6bff\"/>\n          </linearGradient>\n          <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n            <feMerge>\n              <feMergeNode in=\"coloredBlur\"/>\n              <feMergeNode in=\"SourceGraphic\"/>\n            </feMerge>\n          </filter>\n        </defs>\n\n        <!-- Edges: We'll draw with quadratic bezier curves and markers -->\n        <!-- Define marker arrow -->\n        <defs>\n          <marker id=\"arrow\" markerWidth=\"10\" markerHeight=\"10\" refX=\"9\" refY=\"5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n            <path d=\"M0,0 L10,5 L0,10 z\" fill=\"#02101a\" opacity=\"0.95\"/>\n          </marker>\n        </defs>\n\n        <!-- Edges Group -->\n        <g id=\"edges\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></g>\n\n        <!-- Nodes Group -->\n        <g id=\"nodes\"></g>\n\n        <!-- Floating captions -->\n        <g transform=\"translate(30,560)\">\n          <text x=\"0\" y=\"0\" fill=\"rgba(255,255,255,0.06)\" font-size=\"12\">Animated relaxation — iterations 1..N-1</text>\n        </g>\n      </svg>\n\n      <!-- Decorative overlay: subtle translucent particles -->\n      <canvas id=\"dots\" style=\"position:absolute; inset:0; pointer-events:none\"></canvas>\n    </div>\n\n    <aside class=\"info\" aria-hidden=\"false\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center\">\n        <div>\n          <div class=\"small\" style=\"color:var(--muted)\">Source</div>\n          <div style=\"font-weight:800;font-size:20px\">A (Node 0)</div>\n        </div>\n        <div class=\"controls\">\n          <button id=\"playBtn\" class=\"btn\" title=\"Play animation\">Play</button>\n          <button id=\"resetBtn\" class=\"btn ghost\" title=\"Reset to initial\">Reset</button>\n        </div>\n      </div>\n\n      <div class=\"explain\" id=\"explain\">\n        <strong style=\"color:var(--accent-1);display:block;margin-bottom:8px\">How to read this visualization</strong>\n        <p>Each node shows its current shortest-known distance from the source (A). The system performs N-1 relaxation passes across all directed edges in sequence. When an edge is highlighted, the algorithm attempts to relax it: if dist[u] + w < dist[v], the distance of v updates and it pulses.</p>\n        <p style=\"margin-top:6px\">At the end, the algorithm checks for negative cycles. If any distance can still be improved, that indicates the presence of a negative-weight cycle reachable from the source.</p>\n        <div style=\"margin-top:10px;padding:10px;border-radius:8px;background:linear-gradient(90deg,rgba(139,107,255,0.06),transparent);font-size:13px\">\n          <strong>Graph details</strong>\n          <ul style=\"margin:8px 0 0 18px;padding:0;color:var(--muted);\">\n            <li>Nodes: A, B, C, D, E, F</li>\n            <li>Source: A</li>\n            <li>Edges include some negative weights, but no negative cycles</li>\n          </ul>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:12px;align-items:center;justify-content:space-between\">\n        <div>\n          <div class=\"small\">Status</div>\n          <div class=\"status\" id=\"status\">\n            <span class=\"indicator\" id=\"statusDot\"></span>\n            <div id=\"statusText\" style=\"font-weight:700;color:var(--muted)\">Idle</div>\n          </div>\n        </div>\n        <div style=\"text-align:right\">\n          <div class=\"small\">Iterations</div>\n          <div style=\"font-weight:800\" id=\"iterCount\">0 / 5</div>\n        </div>\n      </div>\n    </aside>\n  </div>\n\n  <script>\n    // Minimal, polished bellman-ford animation with limited controls: Play / Reset.\n    (function(){\n      const svg = document.querySelector('svg.graph');\n      const edgesGroup = svg.querySelector('#edges');\n      const nodesGroup = svg.querySelector('#nodes');\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const statusDot = document.getElementById('statusDot');\n      const statusText = document.getElementById('statusText');\n      const iterCount = document.getElementById('iterCount');\n      const explain = document.getElementById('explain');\n\n      // Graph data: positions and directed edges with weights\n      const positions = [\n        {id:0,label:'A', x:150, y:120},\n        {id:1,label:'B', x:420, y:70},\n        {id:2,label:'C', x:760, y:120},\n        {id:3,label:'D', x:320, y:330},\n        {id:4,label:'E', x:600, y:300},\n        {id:5,label:'F', x:460, y:500}\n      ];\n\n      // Edge list: u -> v with weight\n      const edges = [\n        {u:0,v:1,w:6},\n        {u:0,v:3,w:7},\n        {u:1,v:2,w:5},\n        {u:1,v:3,w:8},\n        {u:1,v:4,w:-4},\n        {u:2,v:4,w: -3},\n        {u:3,v:1,w:-2},\n        {u:4,v:5,w:9},\n        {u:5,v:2,w:7},\n        {u:3,v:4,w:9}\n      ];\n\n      // Controls and state\n      const N = positions.length;\n      let distances = new Array(N).fill(Infinity);\n      const source = 0;\n      let iteration = 0;\n      const maxIter = N - 1;\n      let running = false;\n      let currentEdgeIndex = 0;\n      let timer = null;\n      let scheduled = [];\n\n      // Create visuals: nodes and edges\n      function buildGraph(){\n        edgesGroup.innerHTML = '';\n        nodesGroup.innerHTML = '';\n\n        // Draw edges\n        edges.forEach((e, i) => {\n          const p = positions[e.u];\n          const q = positions[e.v];\n          const dx = q.x - p.x;\n          const dy = q.y - p.y;\n          const mx = (p.x + q.x) / 2 + (dy * 0.08);\n          const my = (p.y + q.y) / 2 - (dx * 0.06);\n          const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n          path.setAttribute('d', `M${p.x},${p.y} Q${mx},${my} ${q.x},${q.y}`);\n          path.setAttribute('class','edge');\n          path.setAttribute('id','edge-'+i);\n          path.setAttribute('data-index',i);\n          path.setAttribute('marker-end','url(#arrow)');\n          path.style.opacity = 0.98;\n          edgesGroup.appendChild(path);\n\n          // weight label\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.setAttribute('x', mx );\n          text.setAttribute('y', my );\n          text.setAttribute('class','weight');\n          text.setAttribute('text-anchor','middle');\n          text.setAttribute('dy','-8');\n          text.textContent = e.w;\n          text.setAttribute('id','w-'+i);\n          edgesGroup.appendChild(text);\n        });\n\n        // Draw nodes\n        positions.forEach(n => {\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('class','node inactive');\n          g.setAttribute('transform', `translate(${n.x},${n.y})`);\n          g.setAttribute('id','node-'+n.id);\n\n          const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          circle.setAttribute('r',22);\n          circle.setAttribute('cx',0);\n          circle.setAttribute('cy',0);\n          circle.setAttribute('fill','rgba(255,255,255,0.02)');\n          g.appendChild(circle);\n\n          const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n          label.setAttribute('class','label');\n          label.setAttribute('x',0);\n          label.setAttribute('y',6);\n          label.setAttribute('text-anchor','middle');\n          label.textContent = n.label;\n          g.appendChild(label);\n\n          const dist = document.createElementNS('http://www.w3.org/2000/svg','text');\n          dist.setAttribute('class','dist');\n          dist.setAttribute('x',0);\n          dist.setAttribute('y',36);\n          dist.setAttribute('text-anchor','middle');\n          dist.setAttribute('id','dist-'+n.id);\n          dist.textContent = '∞';\n          g.appendChild(dist);\n\n          nodesGroup.appendChild(g);\n        });\n      }\n\n      function updateNodeVisual(i, options = {}){\n        const g = document.getElementById('node-'+i);\n        if(!g) return;\n        g.classList.remove('active','updated','inactive');\n        if(options.updated) g.classList.add('updated');\n        else if(options.active) g.classList.add('active');\n        else if(options.inactive) g.classList.add('inactive');\n\n        // update distance label\n        const dElem = document.getElementById('dist-'+i);\n        const val = distances[i];\n        dElem.textContent = (val === Infinity) ? '∞' : val.toString();\n        dElem.style.fill = options.updated ? '#d8fff6' : 'var(--muted)';\n        // subtle scale for updated\n        g.style.transition = 'transform 420ms cubic-bezier(.2,.9,.2,1)';\n        g.style.transform = options.updated ? 'scale(1.08)' : 'scale(1)';\n        setTimeout(()=>{ if(g) g.style.transform = ''; },420);\n      }\n\n      function resetState(){\n        running = false;\n        iteration = 0;\n        currentEdgeIndex = 0;\n        distances = new Array(N).fill(Infinity);\n        distances[source] = 0;\n        iterCount.textContent = `${0} / ${maxIter}`;\n        statusText.textContent = 'Idle';\n        statusDot.className = 'indicator';\n        playBtn.textContent = 'Play';\n        playBtn.disabled = false;\n        // reset visuals\n        buildGraph();\n        positions.forEach((_,i)=> updateNodeVisual(i, {inactive:true}));\n        updateNodeVisual(source, {active:true});\n        // show initial distance\n        updateNodeVisual(source,{updated:false});\n      }\n\n      // Animation control\n      function setStatus(text, ok){\n        statusText.textContent = text;\n        statusDot.className = 'indicator ' + (ok ? 'ok' : 'warn');\n      }\n\n      // Relax one edge (u->v)\n      function relaxEdge(index){\n        const e = edges[index];\n        const u = e.u, v = e.v, w = e.w;\n        return new Promise(resolve=>{\n          // highlight edge\n          const edgePath = document.getElementById('edge-'+index);\n          const weightText = document.getElementById('w-'+index);\n          edgePath.classList.add('highlight');\n          weightText.classList.add('glow');\n\n          // highlight nodes\n          updateNodeVisual(u, {active:true});\n          updateNodeVisual(v, {active:true});\n\n          setTimeout(()=>{\n\n            const canRelax = distances[u] !== Infinity && (distances[u] + w < distances[v]);\n            if(canRelax){\n              distances[v] = distances[u] + w;\n              // animate update\n              updateNodeVisual(v, {updated:true});\n            } else {\n              // a subtle pulse to show attempt\n              const gv = document.getElementById('node-'+v);\n              if(gv){\n                gv.style.transition = 'transform 260ms';\n                gv.style.transform = 'scale(1.03)';\n                setTimeout(()=>{ gv.style.transform = ''; },260);\n              }\n              updateNodeVisual(v, {inactive:true});\n            }\n\n            // unhighlight\n            setTimeout(()=> {\n              if(edgePath) edgePath.classList.remove('highlight');\n              if(weightText) weightText.classList.remove('glow');\n              updateNodeVisual(u, {inactive:true});\n              // brief delay then resolve\n              setTimeout(resolve, 220);\n            }, 700);\n\n          }, 420);\n        });\n      }\n\n      // Perform a single full iteration over edges\n      async function doIteration(){\n        iteration++;\n        iterCount.textContent = `${iteration} / ${maxIter}`;\n        setStatus(`Iteration ${iteration}`, false);\n        for(let i=0;i<edges.length;i++){\n          currentEdgeIndex = i;\n          // step through each edge\n          await relaxEdge(i);\n          // if paused, break\n          if(!running) return;\n        }\n      }\n\n      // Negative cycle check\n      async function checkNegativeCycle(){\n        setStatus('Checking for negative cycles...', false);\n        // highlight all edges one by one checking if any can relax further\n        for(let i=0;i<edges.length;i++){\n          const e = edges[i];\n          const edgePath = document.getElementById('edge-'+i);\n          const weightText = document.getElementById('w-'+i);\n          edgePath.classList.add('highlight');\n          weightText.classList.add('glow');\n\n          await new Promise(r => setTimeout(r,520));\n\n          if(distances[e.u] !== Infinity && distances[e.u] + e.w < distances[e.v]){\n            // negative cycle detected\n            edgePath.classList.add('highlight');\n            weightText.classList.add('glow');\n            setStatus('Negative cycle detected!', false);\n            explain.innerHTML += `<div style=\"margin-top:12px;color:var(--accent-3);font-weight:700\">Detected a negative-weight cycle reachable from the source.</div>`;\n            return true;\n          }\n\n          edgePath.classList.remove('highlight');\n          weightText.classList.remove('glow');\n        }\n\n        setStatus('No negative cycles detected', true);\n        return false;\n      }\n\n      async function animate(){\n        if(running) return;\n        running = true;\n        playBtn.textContent = 'Pause';\n        setStatus('Running', false);\n        // iterate N-1 times\n        while(running && iteration < maxIter){\n          await doIteration();\n          if(!running) break;\n        }\n        if(!running){\n          setStatus('Paused', false);\n          return;\n        }\n\n        // final check for negative cycle\n        const hasNeg = await checkNegativeCycle();\n        running = false;\n        playBtn.textContent = 'Play';\n        if(!hasNeg) {\n          setStatus('Completed', true);\n        } else {\n          setStatus('Found negative cycle', false);\n        }\n      }\n\n      // Minimal canvas background particles for aesthetics\n      (function particles(){\n        const canvas = document.getElementById('dots');\n        const ctx = canvas.getContext('2d');\n        function resize(){\n          canvas.width = canvas.clientWidth * devicePixelRatio;\n          canvas.height = canvas.clientHeight * devicePixelRatio;\n          ctx.scale(devicePixelRatio, devicePixelRatio);\n        }\n        resize();\n        window.addEventListener('resize', resize);\n        const particles = [];\n        const count = Math.max(18, Math.floor((canvas.clientWidth * canvas.clientHeight) / 90000));\n        for(let i=0;i<count;i++){\n          particles.push({\n            x: Math.random()*canvas.clientWidth,\n            y: Math.random()*canvas.clientHeight,\n            r: Math.random()*2.8 + 0.6,\n            a: Math.random()*0.6 + 0.08,\n            vx: (Math.random()-0.5)*0.2,\n            vy: (Math.random()-0.5)*0.2,\n            hue: 180 + Math.random()*160\n          });\n        }\n        function frame(){\n          ctx.clearRect(0,0,canvas.clientWidth,canvas.clientHeight);\n          particles.forEach(p=>{\n            p.x += p.vx;\n            p.y += p.vy;\n            if(p.x < -10) p.x = canvas.clientWidth + 10;\n            if(p.x > canvas.clientWidth + 10) p.x = -10;\n            if(p.y < -10) p.y = canvas.clientHeight + 10;\n            if(p.y > canvas.clientHeight + 10) p.y = -10;\n            ctx.beginPath();\n            const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r*6);\n            g.addColorStop(0, `rgba(124,247,228,${p.a})`);\n            g.addColorStop(1, `rgba(124,247,228,0)`);\n            ctx.fillStyle = g;\n            ctx.fillRect(p.x - p.r*6, p.y - p.r*6, p.r*12, p.r*12);\n          });\n          requestAnimationFrame(frame);\n        }\n        requestAnimationFrame(frame);\n      })();\n\n      // Initialize\n      buildGraph();\n      resetState();\n\n      // Hook up buttons\n      playBtn.addEventListener('click', () => {\n        if(running){\n          running = false;\n          playBtn.textContent = 'Play';\n          setStatus('Paused', false);\n        } else {\n          // Start or resume\n          animate();\n        }\n      });\n      resetBtn.addEventListener('click', () => {\n        running = false;\n        playBtn.textContent = 'Play';\n        explain.innerHTML = `<strong style=\"color:var(--accent-1);display:block;margin-bottom:8px\">How to read this visualization</strong>\n        <p>Each node shows its current shortest-known distance from the source (A). The system performs N-1 relaxation passes across all directed edges in sequence. When an edge is highlighted, the algorithm attempts to relax it: if dist[u] + w < dist[v], the distance of v updates and it pulses.</p>\n        <p style=\"margin-top:6px\">At the end, the algorithm checks for negative cycles. If any distance can still be improved, that indicates the presence of a negative-weight cycle reachable from the source.</p>`;\n        resetState();\n      });\n\n      // small accessibility: allow space to toggle play/pause\n      window.addEventListener('keydown', (e)=>{\n        if(e.code === 'Space'){ e.preventDefault(); playBtn.click(); }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
