   </div>\n\n    <script>\n        let d = {\n            graph: {},\n            start: {},\n            path: {},\n            heap: {},\n            minHeapSize: 10,\n            maxHeapSize: 100,\n            numStartingPoints: 10,\n            numEdges: 100,\n            showPath: false\n        };\n\n        function createGraph() {\n            for (let i = 0; i < d.numStartingPoints; i++) {\n                d.graph[i] = {};\n                for (let j = 0; j < d.numStartingPoints; j++) {\n                    d.graph[i][j] = 0;\n                }\n            }\n        }\n\n        function addEdge(start, end, weight) {\n            d.graph[start][end] = weight;\n        }\n\n        function dijkstra(start, end) {\n            d.start[start] = 0;\n            d.path[start] = null;\n            d.heap = [];\n\n            let current = start;\n            while (d.heap.length > 0) {\n                let min = Infinity;\n                let minIndex = -1;\n                for (let i = 0; i < d.heap.length; i++) {\n                    if (d.heap[i][0] < min) {\n                        min = d.heap[i][0];\n                        minIndex = i;\n                    }\n                }\n                let next = minIndex;\n                let minWeight = d.heap[next][0];\n                d.heap.splice(next, 1);\n                if (d.path[current] !== null) {\n                    d.path[current] = end;\n                }\n                d.path[current] = minWeight;\n                if (d.path[current] === Infinity) {\n                    break;\n                }\n                d.heap.push([d.path[current], current]);\n                current = next;\n            }\n\n            if (d.path[end] !== null) {\n                console.log(\"Shortest path:\", d.path[end]);\n            } else {\n                console.log(\"No path found\");\n            }\n        }\n\n        function start() {\n            createGraph();\n            dijkstra(0, d.numStartingPoints);\n            if (d.showPath) {\n                for (let i = 0; i < d.numStartingPoints; i++) {\n                    console.log(`Path from point ${i} to ${d.numStartingPoints}: ${d.path[i]}`);\n                }\n            }\n            d.minHeapSize = 10;\n            d.maxHeapSize = 100;\n            d.numStartingPoints = 10;\n            d.numEdges = 100;\n            d.showPath = false;\n            d.minHeapSize = 10;\n            d.maxHeapSize = 100;\n            d.numStartingPoints = 10;\n            d.numEdges = 100;\n            d.showPath = false;\n        }\n\n        function reset() {\n            d = {\n                graph: {},\n                start: {},\n                path: {},\n                heap: {},\n                minHeapSize: 10,\n                maxHeapSize: 100,\n                numStartingPoints: 10,\n                numEdges: 100,\n                showPath: false\n            };\n            createGraph();\n            dijkstra(0, d.numStartingPoints);\n        }\n\n        let startButton = document.getElementById(\"start-btn\");\n        let minHeapSizeInput = document.getElementById(\"min-heap-size\");\n        let maxHeapSizeInput = document.getElementById(\"max-heap-size\");\n        let numStartingPointsInput = document.getElementById(\"num-starting-points\");\n        let numEdgesInput = document.getElementById(\"num-edges\");\n        let resetButton = document.getElementById(\"reset-btn\");\n        let showPathCheckbox = document.getElementById(\"show-path\");\n\n        startButton.addEventListener(\"click\", start);\n        minHeapSizeInput.addEventListener(\"input\", start);\n        maxHeapSizeInput.addEventListener(\"input\", start);\n        numStartingPointsInput.addEventListener(\"input\", start);\n        numEdgesInput.addEventListener(\"input\", start);\n        resetButton.addEventListener(\"click\", reset);\n        showPathCheckbox.addEventListener(\"change\", start);\n    </script>\n</body>\n</ht