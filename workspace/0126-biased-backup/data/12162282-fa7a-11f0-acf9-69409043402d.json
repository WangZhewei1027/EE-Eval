  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>OSI Model Interactive Exploration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  #header {\n    margin-bottom: 1em;\n  }\n  #controls > * {\n    margin: 0.3em 0.5em 0.3em 0;\n  }\n  #output {\n    margin-top: 1em;\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 0.5em;\n    max-height: 30em;\n    overflow-y: auto;\n  }\n  fieldset {\n    margin-top: 0.5em;\n    border: 1px solid black;\n    padding: 0.5em;\n  }\n  label {\n    cursor: pointer;\n  }\n</style>\n</head>\n<body>\n<h1 id=\"header\">OSI Model Interactive Exploration</h1>\n\n<div id=\"controls\" aria-label=\"OSI Model controls\">\n\n  <fieldset>\n    <legend>Current Layer Selection</legend>\n    <select id=\"layer-select\" aria-label=\"Select OSI Layer\">\n      <option value=\"7\">7 - Application</option>\n      <option value=\"6\">6 - Presentation</option>\n      <option value=\"5\">5 - Session</option>\n      <option value=\"4\">4 - Transport</option>\n      <option value=\"3\">3 - Network</option>\n      <option value=\"2\">2 - Data Link</option>\n      <option value=\"1\">1 - Physical</option>\n    </select>\n    <button id=\"describe-layer\" aria-label=\"Describe selected OSI layer\">Describe Layer</button>\n    <button id=\"show-functions\" aria-label=\"Show common functions of layer\">Show Functions</button>\n    <button id=\"examples-btn\" aria-label=\"Show real world examples at this layer\">Show Examples</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Packet / Data Simulation Controls</legend>\n    <label for=\"message-input\">Input Message (Text): </label>\n    <input type=\"text\" id=\"message-input\" aria-label=\"Input message text\" value=\"Hello OSI Model\" size=\"30\" />\n    <br />\n    <label for=\"start-layer\">Start Layer: </label>\n    <select id=\"start-layer\" aria-label=\"Select starting layer\">\n      <option value=\"7\">7 - Application</option>\n      <option value=\"6\">6 - Presentation</option>\n      <option value=\"5\">5 - Session</option>\n      <option value=\"4\">4 - Transport</option>\n      <option value=\"3\">3 - Network</option>\n      <option value=\"2\">2 - Data Link</option>\n      <option value=\"1\">1 - Physical</option>\n    </select>\n    <label for=\"end-layer\">End Layer: </label>\n    <select id=\"end-layer\" aria-label=\"Select ending layer\">\n      <option value=\"1\">1 - Physical</option>\n      <option value=\"2\">2 - Data Link</option>\n      <option value=\"3\">3 - Network</option>\n      <option value=\"4\">4 - Transport</option>\n      <option value=\"5\">5 - Session</option>\n      <option value=\"6\">6 - Presentation</option>\n      <option value=\"7\">7 - Application</option>\n    </select>\n    <br />\n    <button id=\"simulate-down\" aria-label=\"Simulate encapsulation from start to end layer\">Simulate Encapsulation</button>\n    <button id=\"simulate-up\" aria-label=\"Simulate decapsulation from start to end layer\">Simulate Decapsulation</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Layer Parameter Controls</legend>\n    <div>\n      <label for=\"mtu-slider\">MTU (bytes) at Network Layer (3): </label>\n      <input type=\"range\" id=\"mtu-slider\" min=\"500\" max=\"2000\" step=\"10\" value=\"1500\" aria-label=\"MTU slider\" />\n      <span id=\"mtu-value\">1500</span>\n    </div>\n    <div>\n      <label for=\"window-size-input\">Transport Layer (4) Window Size (segments): </label>\n      <input type=\"number\" id=\"window-size-input\" min=\"1\" max=\"100\" value=\"5\" aria-label=\"Window size input\" />\n    </div>\n    <div>\n      <label for=\"encryption-checkbox\">Presentation Layer (6) Encryption Enabled: </label>\n      <input type=\"checkbox\" id=\"encryption-checkbox\" aria-label=\"Encryption toggle\" />\n    </div>\n    <div>\n      <label for=\"compression-checkbox\">Presentation Layer (6) Compression Enabled: </label>\n      <input type=\"checkbox\" id=\"compression-checkbox\" aria-label=\"Compression toggle\" />\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>User-Defined Protocol Message</legend>\n    <textarea id=\"custom-message\" aria-label=\"Custom protocol message\" rows=\"4\" cols=\"50\" placeholder=\"Define a custom protocol message in JSON or structured format here...\"></textarea>\n    <br />\n    <button id=\"parse-protocol\" aria-label=\"Parse and analyze custom protocol message\">Parse Protocol</button>\n  </fieldset>\n</div>\n\n<div id=\"output\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions\" tabindex=\"0\" role=\"region\" aria-label=\"Output log and descriptions\">\n</div>\n\n<script>\n(() => {\n  'use strict';\n\n  const layers = {\n    7: {\n      name: \"Application\",\n      description:\n        \"The top OSI layer that interfaces directly with user applications. Responsible for network services to applications and protocol representation.\",\n      functions: [\n        \"Identifying communication partners\",\n        \"Determining resource availability\",\n        \"Synchronizing communication\",\n        \"High-level APIs and services (HTTP, FTP, SMTP, DNS, etc.)\",\n      ],\n      examples: [\n        \"HTTP, FTP, SMTP, DNS, Telnet, SSH\",\n        \"Email clients, Web browsers\",\n      ],\n    },\n    6: {\n      name: \"Presentation\",\n      description:\n        \"Layer responsible for data translation, encryption and compression. Ensures that data is in a usable format for the application layer.\",\n      functions: [\n        \"Data format translation (e.g., character encoding)\",\n        \"Encryption and decryption\",\n        \"Compression and decompression\",\n      ],\n      examples: [\n        \"SSL/TLS encryption\",\n        \"JPEG, GIF, MPEG format translation\",\n      ],\n    },\n    5: {\n      name: \"Session\",\n      description:\n        \"Manages sessions between applications. Establishes, manages and terminates connections between local and remote applications.\",\n      functions: [\n        \"Dialog control (half/full duplex)\",\n        \"Synchronization with checkpoints and recovery\",\n        \"Session establishment, maintenance, termination\",\n      ],\n      examples: [\n        \"NetBIOS, SAP, RPC\",\n        \"Session management in video conferencing\",\n      ],\n    },\n    4: {\n      name: \"Transport\",\n      description:\n        \"Provides reliable data transfer services to upper layers. Responsible for flow control, error control and segmentation.\",\n      functions: [\n        \"Segmentation and reassembly\",\n        \"Connection control (connection-oriented/connectionless)\",\n        \"Flow control and error correction\",\n      ],\n      examples: [\n        \"TCP (connection-oriented)\",\n        \"UDP (connectionless)\",\n      ],\n    },\n    3: {\n      name: \"Network\",\n      description:\n        \"Controls the operation of the subnet, routing packets to their destination across multiple networks.\",\n      functions: [\n        \"Logical addressing (IP addressing)\",\n        \"Routing and forwarding\",\n        \"Packet sequencing and traffic control\",\n      ],\n      examples: [\n        \"IP, ICMP, IPSec, IGMP\",\n        \"Routers operate at this layer\",\n      ],\n    },\n    2: {\n      name: \"Data Link\",\n      description:\n        \"Provides node-to-node data transfer, framing, error detection/correction and manages physical addressing (MAC).\",\n      functions: [\n        \"Framing of packets\",\n        \"Error detection and correction\",\n        \"Physical addressing via MAC addresses\",\n        \"Controls access to physical medium\",\n      ],\n      examples: [\n        \"Ethernet, PPP, Switches\",\n        \"MAC addresses, ARP\",\n      ],\n    },\n    1: {\n      name: \"Physical\",\n      description:\n        \"Transmits raw bits over physical medium. Defines mechanical, electrical, and timing characteristics.\",\n      functions: [\n        \"Transmission and reception of raw bit streams\",\n        \"Physical connections (cables, connectors)\",\n        \"Modulation and signal encoding\",\n      ],\n      examples: [\n        \"Cables, fiber optics, radio signals\",\n        \"USB, Ethernet physical layer, RS-232\",\n      ],\n    },\n  };\n\n  // Output handling\n  const outputEl = document.getElementById('output');\n\n  function outln(text = '') {\n    outputEl.textContent += text + '\\n';\n    outputEl.scrollTop = outputEl.scrollHeight;\n  }\n  function clearOutput() {\n    outputEl.textContent = '';\n  }\n\n  // Layer selection controls\n  const layerSelect = document.getElementById(\"layer-select\");\n  const describeLayerBtn = document.getElementById(\"describe-layer\");\n  const showFunctionsBtn = document.getElementById(\"show-functions\");\n  const examplesBtn = document.getElementById(\"examples-btn\");\n\n  describeLayerBtn.addEventListener('click', () => {\n    clearOutput();\n    let v = parseInt(layerSelect.value, 10);\n    let layer = layers[v];\n    outln(`Layer ${v} - ${layer.name}\\n`);\n    outln(layer.description);\n  });\n\n  showFunctionsBtn.addEventListener('click', () => {\n    clearOutput();\n    let v = parseInt(layerSelect.value, 10);\n    let layer = layers[v];\n    outln(`Common Functions of Layer ${v} - ${layer.name}:\\n`);\n    layer.functions.forEach((fn, i) => outln(`${i + 1}. ${fn}`));\n  });\n\n  examplesBtn.addEventListener('click', () => {\n    clearOutput();\n    let v = parseInt(layerSelect.value, 10);\n    let layer = layers[v];\n    outln(`Real World Examples at Layer ${v} - ${layer.name}:\\n`);\n    layer.examples.forEach((ex, i) => outln(`${i + 1}. ${ex}`));\n  });\n\n  // Simulation Controls\n  const messageInput = document.getElementById(\"message-input\");\n  const startLayerSelectDown = document.getElementById(\"start-layer\");\n  const endLayerSelectDown = document.getElementById(\"end-layer\");\n  const simulateDownBtn = document.getElementById(\"simulate-down\");\n  const simulateUpBtn = document.getElementById(\"simulate-up\");\n\n  // Parameters\n  const mtuSlider = document.getElementById(\"mtu-slider\");\n  const mtuValue = document.getElementById(\"mtu-value\");\n  const windowSizeInput = document.getElementById(\"window-size-input\");\n  const encryptionCheckbox = document.getElementById(\"encryption-checkbox\");\n  const compressionCheckbox = document.getElementById(\"compression-checkbox\");\n\n  mtuSlider.addEventListener('input', () => {\n    mtuValue.textContent = mtuSlider.value;\n  });\n\n  /*\n   Simulate Encapsulation & Decapsulation:\n   We'll fake a layered packet structure.\n   Encapsulation direction: from startLayer (default = 7) down to endLayer (default = 1)\n   Decapsulation direction: from startLayer (default = 1) up to endLayer (default = 7)\n   \n   At each layer, some specific process is \"applied\"\n   We'll maintain a \"data\" object with fields:\n   - payload: raw message or encapsulated data\n   - headers: Array of added headers (layer, details)\n   - footers: Array of added footers (rfc822 style not required but just for realism)\n\n   For realism, include effect of parameters:\n   - MTU at layer 3 (limits packet size, fragment if too large)\n   - Window size at layer 4 affects segmentation output\n   - Encryption/compression at layer 6 modifies payload\n\n  */\n\n  // Simple utility functions\n\n  // Simple compression simulation\n  function compress(data) {\n    // Naive compression: remove vowels (simulate compression ratio ~70%)\n    return data.replace(/[aeiouAEIOU]/g, '');\n  }\n  // Simple decompression simulation (cannot truly restore without data)\n  function decompress(data) {\n    // Can't restore exactly, so say \"Decompressed data\"\n    return `[Decompressed] ${data}`;\n  }\n  // Simple encryption simulation\n  function encrypt(data) {\n    // Caesar cipher +3 letters for demo\n    return data.replace(/[a-z]/gi, (c) => {\n      const base = c <= 'Z' ? 65 : 97;\n      let code = c.charCodeAt(0) - base;\n      code = (code + 3) % 26;\n      return String.fromCharCode(code + base);\n    });\n  }\n  // Simple decryption simulation (-3 letters)\n  function decrypt(data) {\n    return data.replace(/[a-z]/gi, (c) => {\n      const base = c <= 'Z' ? 65 : 97;\n      let code = c.charCodeAt(0) - base;\n      code = (code - 3 + 26) % 26;\n      return String.fromCharCode(code + base);\n    });\n  }\n\n  // Fragment function for layer 3 (Network)\n  function fragmentPacket(payload, mtu) {\n    // Simple fragmentation: split payload into chunks of mtu size (assume 1 char = 1 byte for simulation)\n    let fragments = [];\n    let i = 0;\n    while (i < payload.length) {\n      fragments.push(payload.slice(i, i + mtu));\n      i += mtu;\n    }\n    return fragments;\n  }\n\n  // Encapsulation step function by layer\n  function encapsulateLayer(layerNum, packet, params) {\n    // Packet: { payload, headers: [], footers: [] }\n    const layer = layers[layerNum];\n    switch (layerNum) {\n      case 7: // Application\n        // No header added for simulation, assume raw message input at this point\n        packet.headers.push({ layer: layerNum, info: \"Application Layer Data\" });\n        break;\n      case 6: // Presentation\n        // Apply compression/encryption optionally\n        let data = packet.payload;\n        if (params.compression) {\n          data = compress(data);\n          packet.headers.push({ layer: layerNum, info: \"Compressed\" });\n        }\n        if (params.encryption) {\n          data = encrypt(data);\n          packet.headers.push({ layer: layerNum, info: \"Encrypted\" });\n        }\n        packet.payload = data;\n        break;\n      case 5: // Session\n        // Add a session header (session ID simulated)\n        packet.headers.push({ layer: layerNum, info: \"Session ID: 1234\" });\n        break;\n      case 4: // Transport\n        // Segment the data by window size\n        const ws = params.windowSize;\n        let segments = [];\n        let segmentSize = Math.ceil(packet.payload.length / ws);\n        for (let i = 0; i < ws; i++) {\n          let segPayload = packet.payload.slice(i * segmentSize, (i + 1) * segmentSize);\n          if (segPayload.length === 0) continue;\n          segments.push({\n            headers: [{ layer: 4, info: `Segment #${i + 1} (Window size=${ws})` }],\n            payload: segPayload,\n            footers: [],\n          });\n        }\n        if (segments.length > 1) {\n          // Overwrite packet as multiple segments (simulate)\n          packet.segments = segments;\n          packet.payload = null; // no single payload when segmented\n          packet.headers.push({ layer: 4, info: `Segmented into ${segments.length} segments` });\n        } else {\n          // Add a simple header\n          packet.headers.push({ layer: layerNum, info: \"Single transport segment\" });\n        }\n        break;\n      case 3: // Network\n        // Fragment packet if payload (or segment payloads) > MTU\n        if (packet.segments) {\n          // Fragment each segment if needed\n          let fragSegments = [];\n          packet.segments.forEach((seg) => {\n            let frags = fragmentPacket(seg.payload, params.mtu);\n            if (frags.length > 1) {\n              frags.forEach((fragPayload, i) => {\n                fragSegments.push({\n                  headers: seg.headers.concat([{ layer: 3, info: `Fragment #${i + 1}/${frags.length}` }]),\n                  payload: fragPayload,\n                  footers: [],\n                });\n              });\n            } else {\n              fragSegments.push({\n                headers: seg.headers.concat([{ layer: 3, info: \"No Fragment Required\" }]),\n                payload: seg.payload,\n                footers: [],\n              });\n            }\n          });\n          packet.segments = fragSegments;\n          packet.headers.push({ layer: 3, info: `Fragmented into ${fragSegments.length} packets due to MTU=${params.mtu}` });\n        } else {\n          let payloadData = packet.payload;\n          if (payloadData.length > params.mtu) {\n            let frags = fragmentPacket(payloadData, params.mtu);\n            if (frags.length > 1) {\n              let fragPackets = frags.map((fragPayload, i) => ({\n                headers: [{ layer: 3, info: `Fragment #${i + 1}/${frags.length}` }],\n                payload: fragPayload,\n                footers: [],\n              }));\n              packet.segments = fragPackets;\n              packet.payload = null;\n              packet.headers.push({ layer: 3, info: `Fragmented into ${frags.length} packets due to MTU=${params.mtu}` });\n            }\n          } else {\n            packet.headers.push({ layer: 3, info: \"Packet fits MTU, no fragmentation\" });\n          }\n        }\n        break;\n      case 2: // Data Link\n        // Add MAC addresses in header (simulate source/dest MAC)\n        packet.headers.push({ layer: 2, info: \"Src MAC: AA:BB:CC:DD:EE:FF, Dest MAC: 11:22:33:44:55:66\" });\n        break;\n      case 1: // Physical\n        // Add physical layer \"bitstream\" info - simulate conversion to bits\n        if (packet.segments) {\n          packet.segments.forEach((seg) => {\n            seg.headers.push({ layer: 1, info: `Physical encoding of ${seg.payload.length} bytes` });\n          });\n        } else {\n          packet.headers.push({ layer: 1, info: `Physical encoding of ${packet.payload.length} bytes` });\n        }\n        break;\n      default:\n        // Unknown layer\n        packet.headers.push({ layer: layerNum, info: \"(Unknown Layer Action)\" });\n        break;\n    }\n  }\n\n  // Decapsulation step function by layer\n  function decapsulateLayer(layerNum, packet, params) {\n    // Reverse the encapsulation per layer\n    switch (layerNum) {\n      case 1: // Physical\n        // Remove physical encoding header\n        if (packet.segments) {\n          packet.segments.forEach((seg) => {\n            seg.headers = seg.headers.filter(h => h.layer !== 1);\n          });\n        } else {\n          packet.headers = packet.headers.filter(h => h.layer !== 1);\n        }\n        break;\n      case 2: // Data Link\n        packet.headers = packet.headers.filter(h => h.layer !== 2);\n        break;\n      case 3: // Network\n        // Reassemble fragments if any\n        if (packet.segments) {\n          // Check if segments have fragment info\n          let fragSegments = packet.segments.filter(s => s.headers.some(h => h.info.includes(\"Fragment\")));\n          if (fragSegments.length > 0) {\n            // Sort fragments\n            let fragments = fragSegments.slice();\n            fragments.sort((a, b) => {\n              let aFrag = a.headers.find(h => h.layer === 3 && h.info.includes(\"Fragment\"));\n              let bFrag = b.headers.find(h => h.layer === 3 && h.info.includes(\"Fragment\"));\n              let aNum = parseInt(aFrag.info.match(/Fragment #(\\d+)/)[1], 10);\n              let bNum = parseInt(bFrag.info.match(/Fragment #(\\d+)/)[1], 10);\n              return aNum - bNum;\n            });\n            // Reassemble payload\n            let reassembled = fragments.map(f => f.payload).join('');\n            packet.payload = reassembled;\n            packet.segments = null;\n            packet.headers = packet.headers.filter(h => h.layer !== 3);\n            packet.headers.push({ layer: 3, info: \"Reassembled fragments\" });\n          } else {\n            // No fragments\n            packet.headers = packet.headers.filter(h => h.layer !== 3);\n          }\n        } else {\n          packet.headers = packet.headers.filter(h => h.layer !== 3);\n        }\n        break;\n      case 4: // Transport\n        // Reassemble segments if any\n        if (packet.segments) {\n          // Sort segments by segment number in header\n          let segs = packet.segments.filter(s => s.headers.some(h => h.layer === 4 && h.info.includes(\"Segment\")));\n          if (segs.length > 0) {\n            segs.sort((a, b) => {\n              let aSeg = a.headers.find(h => h.layer === 4 && h.info.match(/Segment #(\\d+)/));\n              let bSeg = b.headers.find(h => h.layer === 4 && h.info.match(/Segment #(\\d+)/));\n              let aNum = parseInt(aSeg.info.match(/Segment #(\\d+)/)[1], 10);\n              let bNum = parseInt(bSeg.info.match(/Segment #(\\d+)/)[1], 10);\n              return aNum - bNum;\n            });\n            let reassembled = segs.map(s => s.payload).join('');\n            packet.payload = reassembled;\n            packet.segments = null;\n            packet.headers = packet.headers.filter(h => h.layer !== 4);\n            packet.headers.push({ layer: 4, info: \"Reassembled segments\" });\n          } else {\n            packet.headers = packet.headers.filter(h => h.layer !== 4);\n          }\n        } else {\n          packet.headers = packet.headers.filter(h => h.layer !== 4);\n        }\n        break;\n      case 5: // Session\n        packet.headers = packet.headers.filter(h => h.layer !== 5);\n        break;\n      case 6: // Presentation\n        // Remove compression/encryption headers and revert payload\n        let compressed = packet.headers.some(h => h.info === \"Compressed\");\n        let encrypted = packet.headers.some(h => h.info === \"Encrypted\");\n        if (encrypted) {\n          packet.payload = decrypt(packet.payload);\n        }\n        if (compressed) {\n          packet.payload = decompress(packet.payload);\n        }\n        packet.headers = packet.headers.filter(h => h.layer !== 6);\n        break;\n      case 7: // Application\n        packet.headers = packet.headers.filter(h => h.layer !== 7);\n        break;\n      default:\n        // Unknown layer\n        break;\n    }\n  }\n\n  // Display packet simulation result:\n  // We have a packet object {payload, headers[], segments?}\n  // We will print a detailed traversal showing headers and payload at each step\n  function displayPacket(packet, direction) {\n    // direction is \"Encapsulation\" or \"Decapsulation\"\n    let lines = [];\n    function describeSegment(seg, idx = null) {\n      let prefix = idx !== null ? `  Segment ${idx + 1}:\\n` : \"\";\n      let str = prefix;\n      if (seg.headers.length > 0) {\n        str += \"    Headers:\\n\";\n        seg.headers.forEach(h => {\n          str += `      - Layer ${h.layer} (${layers[h.layer].name}): ${h.info}\\n`;\n        });\n      }\n      str += `    Payload (${seg.payload.length} bytes):\\n`;\n      let pl = seg.payload.length > 60 ? seg.payload.slice(0, 60) + \"...\" : seg.payload;\n      str += `      \"${pl}\"\\n`;\n      return str;\n    }\n    lines.push(`--- Packet ${direction} Result ---\\n`);\n\n    if (packet.segments) {\n      lines.push(`Packet contains ${packet.segments.length} segment(s)/fragment(s):\\n`);\n      packet.segments.forEach((seg, i) => {\n        lines.push(describeSegment(seg, i));\n      });\n    } else {\n      lines.push(`Packet Headers:`);\n      packet.headers.forEach(h => {\n        lines.push(`  - Layer ${h.layer} (${layers[h.layer].name}): ${h.info}`);\n      });\n      lines.push(`Payload (${packet.payload.length} bytes):`);\n      let pl = packet.payload.length > 100 ? packet.payload.slice(0, 100) + \"...\" : packet.payload;\n      lines.push(`  \"${pl}\"`);\n    }\n\n    return lines.join('\\n');\n  }\n\n  // Main simulation functions\n  simulateDownBtn.addEventListener('click', () => {\n    clearOutput();\n    let start = parseInt(startLayerSelectDown.value, 10);\n    let end = parseInt(endLayerSelectDown.value, 10);\n\n    if (start < end) {\n      outln(\"Error: Start layer must be >= end layer for encapsulation (top-down).\");\n      return;\n    }\n\n    let message = messageInput.value.trim();\n    if (message.length === 0) {\n      outln(\"Error: Message cannot be empty.\");\n      return;\n    }\n\n    // Initialize packet\n    let packet = {\n      payload: message,\n      headers: [],\n      footers: [],\n    };\n\n    // Prepare parameters\n    let params = {\n      mtu: parseInt(mtuSlider.value, 10),\n      windowSize: parseInt(windowSizeInput.value, 10),\n      encryption: encryptionCheckbox.checked,\n      compression: compressionCheckbox.checked,\n    };\n\n    outln(`Encapsulating message from Layer ${start} to Layer ${end}...`);\n    for (let layerNum = start; layerNum >= end; layerNum--) {\n      outln(`\\nEncapsulating at Layer ${layerNum} (${layers[layerNum].name}):`);\n      encapsulateLayer(layerNum, packet, params);\n      // Show incremental packet info if possible\n      if (packet.segments) {\n        outln(`  Packet segmented into ${packet.segments.length} parts.`);\n      } else {\n        outln(`  Current payload size: ${packet.payload.length} bytes.`);\n      }\n    }\n\n    let result = displayPacket(packet, \"Encapsulation\");\n    outln('\\n' + result);\n  });\n\n  simulateUpBtn.addEventListener('click', () => {\n    clearOutput();\n    let start = parseInt(startLayerSelectDown.value, 10);\n    let end = parseInt(endLayerSelectDown.value, 10);\n\n    if (start > end) {\n      outln(\"Error: Start layer must be <= end layer for decapsulation (bottom-up).\");\n      return;\n    }\n\n    let message = messageInput.value.trim();\n    if (message.length === 0) {\n      outln(\"Error: Message cannot be empty.\");\n      return;\n    }\n\n    // Initialize packet - simulate a packet encapsulated from layer end up to layer start\n    // As we don't have prior encapsulation data for up simulation, assume direct\n    let packet = {\n      payload: message,\n      headers: [],\n      footers: [],\n    };\n\n    // We need a simulated packet suitable for decapsulation:\n    // We'll simulate by generating a fully encapsulated packet from layer end up to start,\n    // but reversing the direction: So we do a quick encapsulation first, then decapsulate.\n\n    // But if start < end, error displayed above.\n\n    // Prepare parameters\n    let params = {\n      mtu: parseInt(mtuSlider.value, 10),\n      windowSize: parseInt(windowSizeInput.value, 10),\n      encryption: encryptionCheckbox.checked,\n      compression: compressionCheckbox.checked,\n    };\n\n    // Build a packet encapsulated from end layer to start layer (reverse order)\n    let simulatedPacket = {\n      payload: message,\n      headers: [],\n      footers: [],\n    };\n    for (let layerNum = end; layerNum <= start; layerNum++) {\n      encapsulateLayer(layerNum, simulatedPacket, params);\n    }\n\n    // Now start decapsulation\n    outln(`Decapsulating message from Layer ${start} to Layer ${end}...`);\n    for (let layerNum = start; layerNum >= end; layerNum--) {\n      outln(`\\nDecapsulating at Layer ${layerNum} (${layers[layerNum].name}):`);\n      decapsulateLayer(layerNum, simulatedPacket, params);\n      if (simulatedPacket.segments) {\n        outln(`  Packet segmented into ${simulatedPacket.segments.length} parts.`);\n      } else if (simulatedPacket.payload) {\n        outln(`  Current payload size: ${simulatedPacket.payload.length} bytes.`);\n      }\n    }\n\n    let result = displayPacket(simulatedPacket, \"Decapsulation\");\n    outln('\\n' + result);\n  });\n\n  // User protocol message parsing feature: Accept JSON structure and describe\n  const customMessageArea = document.getElementById('custom-message');\n  const parseProtocolBtn = document.getElementById('parse-protocol');\n\n  parseProtocolBtn.addEventListener('click', () => {\n    clearOutput();\n    let text = customMessageArea.value.trim();\n    if (!text) {\n      outln(\"Error: Protocol message is empty.\");\n      return;\n    }\n    try {\n      let obj = JSON.parse(text);\n      outln(\"Parsed protocol message JSON:\\n\");\n      parseProtocolObject