    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Exponential Search - Visual Demonstration</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Fraunces:wght@700&display=swap');\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #141e30, #243b55);\n    color: #e7edef;\n    font-family: 'Space Grotesk', sans-serif;\n    overflow-x: hidden;\n    user-select: none;\n  }\n  h1 {\n    font-family: 'Fraunces', serif;\n    font-weight: 900;\n    text-align: center;\n    font-size: 3.5rem;\n    margin: 2rem 1rem 0.2rem;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: #f0f4f8;\n    text-shadow:\n      0 0 8px #a5f3fc88,\n      0 0 15px #14b8a688,\n      0 0 20px #14b8a6;\n  }\n  h2 {\n    text-align: center;\n    font-weight: 700;\n    font-size: 1.25rem;\n    margin-top: 0;\n    margin-bottom: 2rem;\n    color: #a0c7c7cc;\n    letter-spacing: 0.05em;\n    font-style: italic;\n  }\n  main {\n    max-width: 960px;\n    margin: 0 auto 4rem;\n    padding: 0 1rem;\n  }\n  /* Search container & array */\n  .array-container {\n    background: rgba(20, 55, 70, 0.7);\n    border-radius: 18px;\n    padding: 1.5rem 2rem 2.5rem 2rem;\n    box-shadow:\n      inset 0 0 18px #1fc3c9aa,\n      0 6px 30px #0b263833;\n    user-select: none;\n  }\n  .array-title {\n    font-weight: 600;\n    font-size: 1.2rem;\n    margin-bottom: 1rem;\n    color: #7efff5cc;\n    text-align: center;\n    letter-spacing: 0.05em;\n    font-family: 'Fraunces', serif;\n    text-shadow: 0 0 6px #14b899cc;\n  }\n  .array {\n    display: flex;\n    justify-content: center;\n    flex-wrap: nowrap;\n    gap: 0.45rem;\n    overflow-x: auto;\n    padding-bottom: 8px;\n  }\n  /* Scrollbar styling */\n  .array::-webkit-scrollbar {\n    height: 8px;\n  }\n  .array::-webkit-scrollbar-track {\n    background: rgba(255 255 255 / 0.05);\n    border-radius: 20px;\n  }\n  .array::-webkit-scrollbar-thumb {\n    background: #3dd9d9cc;\n    border-radius: 20px;\n  }\n  .element {\n    flex: 0 0 54px;\n    height: 54px;\n    background: linear-gradient(145deg, #18afb4, #12a7ad);\n    border-radius: 12px;\n    color: #e1f7f7;\n    font-weight: 700;\n    font-size: 1.45rem;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow:\n      0 3px 8px #147d7e88,\n      inset 0 2px 4px #8ff7f7bb;\n    position: relative;\n    user-select: none;\n    transition:\n      background 0.45s cubic-bezier(0.19, 1, 0.22, 1),\n      color 0.45s cubic-bezier(0.19, 1, 0.22, 1),\n      box-shadow 0.45s cubic-bezier(0.19, 1, 0.22, 1);\n  }\n  .element.highlight {\n    background: #3af4f4;\n    color: #003b3b;\n    box-shadow:\n      0 0 22px 4px #3af4f4cc,\n      inset 0 0 18px #00f0f0ff;\n  }\n  .element.checked {\n    background: #f4a261;\n    color: #3d1f00;\n    box-shadow:\n      0 0 20px #f4a261cc,\n      inset 0 0 18px #f48a117f;\n  }\n  .element.found {\n    background: #90be6d;\n    color: #1b3a00;\n    box-shadow:\n      0 0 26px #90be6dcc,\n      inset 0 0 20px #6a9748ff;\n  }\n  /* Indicators */\n  .indicator {\n    position: absolute;\n    top: -28px;\n    width: 100%;\n    font-size: 0.875rem;\n    font-weight: 600;\n    letter-spacing: 0.04em;\n    text-transform: uppercase;\n    text-align: center;\n    user-select: none;\n    color: #b2fff3cc;\n    text-shadow: 0 0 8px #2ee6e0cc;\n  }\n  .indicator.left {\n    top: unset;\n    bottom: -28px;\n    color: #a0ffccbb;\n    text-shadow: 0 0 8px #24ccacbb;\n  }\n  /* Animation line */\n  .line-container {\n    position: relative;\n    height: 130px;\n    margin-top: 3rem;\n  }\n  svg.line-path {\n    width: 100%;\n    height: 130px;\n    overflow-visible: visible;\n  }\n  /* Markers circle */\n  circle.marker {\n    fill: #14c1becc;\n    stroke: #0d6b6a;\n    stroke-width: 2px;\n    filter: drop-shadow(0 0 4px #14c1becc);\n    transition: fill 0.35s ease;\n  }\n  circle.marker.checked {\n    fill: #f4a260cc;\n    filter: drop-shadow(0 0 7px #f4a260cc);\n  }\n  circle.marker.found {\n    fill: #90be6dcc;\n    filter: drop-shadow(0 0 10px #90be6dcc);\n  }\n  /* Buttons & controls */\n  .controls {\n    text-align: center;\n    margin-top: 2rem;\n  }\n  button {\n    cursor: pointer;\n    background: #18afb4;\n    border: none;\n    padding: 0.85rem 2rem;\n    border-radius: 50px;\n    font-size: 1.1rem;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    color: #e0fcfc;\n    box-shadow:\n      0 4px 12px #18afb480,\n      0 0 15px #18afb480;\n    user-select: none;\n    transition:\n      background 0.35s ease,\n      box-shadow 0.35s ease;\n    font-family: 'Space Grotesk', sans-serif;\n  }\n  button:hover,\n  button:focus {\n    background: #1fe6e9;\n    box-shadow:\n      0 8px 24px #1fe6e980,\n      0 0 20px #1fe6e980;\n    outline: none;\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    color: #4f8d8dbc;\n    font-size: 0.85rem;\n    letter-spacing: 0.05em;\n    margin-bottom: 3rem;\n    font-style: italic;\n  }\n\n  /* Tooltip styling for legend */\n  .legend {\n    max-width: 480px;\n    margin: 1.5rem auto 3rem;\n    font-size: 0.9rem;\n    line-height: 1.5;\n    color: #a9e3e3dd;\n    font-family: 'Space Grotesk', sans-serif;\n    text-align: center;\n    letter-spacing: 0.03em;\n    user-select: none;\n  }\n  .legend b {\n    color: #79f8f7dd;\n  }\n  .legend span {\n    display: inline-block;\n    min-width: 88px;\n    padding: 0.15rem 0.6rem;\n    border-radius: 12px;\n    font-weight: 700;\n    margin: 0 0.15rem;\n    user-select: none;\n  }\n  .legend .highlight {\n    background: #07f0f7cc;\n    color: #003838;\n    text-shadow: none;\n  }\n  .legend .checked {\n    background: #f4a261cc;\n    color: #3d1f00;\n  }\n  .legend .found {\n    background: #90be6dcc;\n    color: #1b3a00;\n  }\n\n  /* Responsive: smaller screens */\n  @media (max-width: 580px) {\n    .element {\n      flex: 0 0 44px;\n      height: 44px;\n      font-size: 1.1rem;\n      border-radius: 10px;\n    }\n    h1 {\n      font-size: 2.8rem;\n    }\n    .array-title {\n      font-size: 1rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>Exponential Search</h1>\n  <h2>An Elegant Visual Demonstration</h2>\n  <main role=\"main\" aria-label=\"Exponential Search Visualization\">\n    <section class=\"array-container\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <div class=\"array-title\">Sorted Array</div>\n      <div class=\"array\" id=\"array\" aria-label=\"Array of numbers\">\n        <!-- Elements inserted by JS -->\n      </div>\n    </section>\n\n    <div class=\"line-container\" aria-hidden=\"true\">\n      <svg class=\"line-path\" viewBox=\"0 0 960 130\" preserveAspectRatio=\"none\" role=\"presentation\" aria-hidden=\"true\">\n        <!-- Lines and markers inserted by JS -->\n      </svg>\n    </div>\n\n    <div class=\"legend\" aria-label=\"Legend explaining color coding\">\n      <span class=\"highlight\" tabindex=\"0\">Highlight</span> &mdash; Potential boundary in exponential steps&nbsp;&nbsp;\n      <span class=\"checked\" tabindex=\"0\">Checked</span> &mdash; Elements currently examined during binary search&nbsp;&nbsp;\n      <span class=\"found\" tabindex=\"0\">Found</span> &mdash; Target element located\n    </div>\n\n    <div class=\"controls\">\n      <button id=\"btnStart\" aria-label=\"Start the Exponential Search animation\">Start Search</button>\n      <button id=\"btnReset\" aria-label=\"Reset the visualization\" disabled>Reset</button>\n    </div>\n  </main>\n  <footer>© 2024 Visual Algorithms — Crafted with care &amp; finesse</footer>\n\n<script>\n(() => {\n  // Sorted array for demonstration (length 32, nice powers of 2)\n  const arrayValues = [2,3,5,7,10,14,18,19,23,25,29,31,35,38,42,46,48,52,57,61,65,67,70,73,77,80,84,88,91,94,97,99];\n  // Target value for searching example\n  const targetValue = 73;\n\n  // Elements container & SVG\n  const arrayContainer = document.getElementById('array');\n  const svg = document.querySelector('svg.line-path');\n  const btnStart = document.getElementById('btnStart');\n  const btnReset = document.getElementById('btnReset');\n\n  // Constants for layout\n  const elemCount = arrayValues.length;\n  const elemWidth = 54; // must match CSS flex-basis and height\n  const gap = 0.45 * 16; // 0.45rem gap in px (assuming 16px base font size)\n  const totalWidth = elemCount * elemWidth + (elemCount - 1) * gap;\n  svg.setAttribute('width', totalWidth);\n\n  // Create array elements DOM once\n  const elems = [];\n  for(let i = 0; i < elemCount; i++) {\n    const el = document.createElement('div');\n    el.className = 'element';\n    el.textContent = arrayValues[i];\n    el.setAttribute('data-index', i);\n    el.setAttribute('aria-label', `Element ${i}, value ${arrayValues[i]}`);\n    arrayContainer.appendChild(el);\n    elems.push(el);\n  }\n\n  // Helper: Convert index to horizontal x center coordinate within the SVG\n  // Place markers above array elements by calculating their center.\n  function indexToX(i) {\n    return elemWidth/2 + i*(elemWidth + gap);\n  }\n\n  // Remove all highlights & markers\n  function clearHighlights() {\n    elems.forEach(e => {\n      e.classList.remove('highlight', 'checked', 'found');\n      const ind = e.querySelector('.indicator');\n      if(ind) ind.remove();\n    });\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  // Create an indicator label on top/bottom of an element\n  function setIndicator(index, text, position='top') {\n    const el = elems[index];\n    let label = el.querySelector('.indicator');\n    if(!label) {\n      label = document.createElement('div');\n      label.className = `indicator ${position === 'bottom' ? 'left' : ''}`;\n      el.appendChild(label);\n    }\n    label.textContent = text;\n  }\n\n  // Draw an arrow line with a glowing marker circle in SVG between two elements indices (inclusive x positions)\n  // type: 'highlight', 'checked', or 'found' affects color\n  // From fromIndex to toIndex horizontally\n  function drawLine(fromIndex, toIndex, type='highlight') {\n    const startX = indexToX(fromIndex);\n    const endX = indexToX(toIndex);\n    const y = 60;\n\n    // Draw a curved line\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    let color;\n    switch(type) {\n      case 'checked': color = '#f4a260'; break;\n      case 'found': color = '#90be6d'; break;\n      default: color = '#14c1be'; break;\n    }\n\n    const cp1x = startX + (endX - startX)/4;\n    const cp2x = startX + 3*(endX - startX)/4;\n    const cp1y = y - 42;\n    const cp2y = y - 42;\n\n    const d = `M ${startX} ${y} C ${cp1x} ${cp1y}, ${cp2x} ${cp2y}, ${endX} ${y}`;\n    path.setAttribute('d', d);\n    path.setAttribute('fill', 'none');\n    path.setAttribute('stroke', color);\n    path.setAttribute('stroke-width', '3.5');\n    path.setAttribute('stroke-linecap', 'round');\n    path.setAttribute('filter', `drop-shadow(0 0 8px ${color}aa)`);\n\n    // Animate stroke dash\n    path.style.strokeDasharray = 250;\n    path.style.strokeDashoffset = 250;\n    path.style.animation = 'drawPath 1.1s ease forwards';\n\n    svg.appendChild(path);\n\n    // Draw circles for start and end markers \n    [fromIndex, toIndex].forEach((idx) => {\n      const cir = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      cir.classList.add('marker', type);\n      cir.setAttribute('r', 10);\n      cir.setAttribute('cx', indexToX(idx));\n      cir.setAttribute('cy', y);\n      svg.appendChild(cir);\n    });\n  }\n  \n  // Animation keyframes injection for path drawing\n  const styleSheet = document.createElement('style');\n  styleSheet.textContent = `\n    @keyframes drawPath {\n      to { stroke-dashoffset: 0; }\n    }\n  `;\n  document.head.appendChild(styleSheet);\n\n  /*\n    Exponential Search Animation Logic:\n    1) Start from index 0, check if target == arr[0]. If yes done.\n    2) Increase index exponentially: 1, 2, 4, 8, 16... until arr[i] >= target or i > array.length\n    3) Use binary search between previous bound and current bound.\n  */\n\n  // Steps state for animation timeline\n  const STEPS = [];\n\n  // Prepare exponential steps\n  function prepareExponentialSteps(arr, target) {\n    let step = 0;\n    STEPS.length = 0;\n    // Step 0: start at 0\n    STEPS.push({type:'check', indices:[0], desc: `Check element at index 0 (value ${arr[0]})`});\n    if(arr[0] === target) {\n      STEPS.push({type:'found', index:0, desc: `Target ${target} found immediately at index 0`});\n      return;\n    }\n    let bound = 1;\n    while(bound < arr.length && arr[bound] < target) {\n      STEPS.push({type:'highlight', indices:[bound], desc: `Exponential step: checking index ${bound} (value ${arr[bound]})`});\n      bound *= 2;\n    }\n    const high = Math.min(bound, arr.length -1);\n    const low = bound/2;\n    STEPS.push({type:'range', low:low, high:high, desc: `Found range for binary search: indices [${low}..${high}]`});\n    binarySearchSteps(arr, target, low, high);\n  }\n\n  // Prepare binary search steps\n  function binarySearchSteps(arr, target, left, right) {\n    // Iterative binary search, recording steps\n    while(left <= right) {\n      const mid = Math.floor((left + right) / 2);\n      STEPS.push({type:'check', indices:[mid], desc: `Checking middle element at index ${mid} (value ${arr[mid]})`});\n      if(arr[mid] === target) {\n        STEPS.push({type:'found', index: mid, desc: `Target ${target} found at index ${mid}`});\n        return;\n      }\n      else if(arr[mid] < target) {\n        STEPS.push({type:'binary-update', low: mid + 1, high:right, desc: `Target > value at ${mid}, new search range [${mid+1}..${right}]`});\n        left = mid + 1;\n      }\n      else {\n        STEPS.push({type:'binary-update', low: left, high: mid - 1, desc: `Target < value at ${mid}, new search range [${left}..${mid-1}]`});\n        right = mid - 1;\n      }\n    }\n    STEPS.push({type:'notfound', desc:`Target ${target} not found in the array.`});\n  }\n\n  // Reset visual states\n  function resetVisual() {\n    clearHighlights();\n    svg.style.opacity = '1';\n  }\n\n  // Scroll to element nicely for user visibility (centered horizontally)\n  function scrollToElement(index) {\n    const el = elems[index];\n    if(!el) return;\n    const rect = el.getBoundingClientRect();\n    const containerRect = arrayContainer.getBoundingClientRect();\n    const scrollParent = arrayContainer.parentElement;\n\n    // Calculate center offset to scroll\n    const targetScrollLeft = el.offsetLeft - (scrollParent.clientWidth/2) + (el.clientWidth/2);\n    scrollParent.scroll({\n      left: targetScrollLeft,\n      behavior: 'smooth'\n    });\n  }\n\n  // Animate step-by-step\n  let stepIndex = 0;\n  let animationInProgress = false;\n\n  function runStep(index) {\n    if(index >= STEPS.length) {\n      animationInProgress = false;\n      btnStart.disabled = true;\n      btnReset.disabled = false;\n      return;\n    }\n    animationInProgress = true;\n    const step = STEPS[index];\n    resetVisual();\n\n    switch(step.type) {\n      case 'check':\n        step.indices.forEach(i => {\n          elems[i].classList.add('checked');\n          setIndicator(i, 'Checking', 'top');\n          scrollToElement(i);\n          drawLine(i, i, 'checked');\n        });\n        break;\n      case 'highlight':\n        step.indices.forEach(i => {\n          elems[i].classList.add('highlight');\n          setIndicator(i, 'Exponential Check', 'top');\n          scrollToElement(i);\n          drawLine(i, i, 'highlight');\n        });\n        break;\n      case 'range':\n        // Highlight the range bounded for binary search\n        const { low, high } = step;\n        for(let i = low; i <= high; i++) {\n          elems[i].classList.add('highlight');\n        }\n        setIndicator(low, 'Low', 'bottom');\n        setIndicator(high, 'High', 'top');\n        drawLine(low, high, 'highlight');\n        scrollToElement(low);\n        break;\n      case 'binary-update':\n        // Clear previous checked, highlight current range\n        const { low: l, high: h } = step;\n        for(let i = l; i <= h; i++) {\n          elems[i].classList.add('highlight');\n        }\n        setIndicator(l, 'Low', 'bottom');\n        setIndicator(h, 'High', 'top');\n        drawLine(l, h, 'highlight');\n        scrollToElement(l);\n        break;\n      case 'found':\n        elems[step.index].classList.add('found');\n        setIndicator(step.index, 'FOUND!', 'top');\n        drawLine(step.index, step.index, 'found');\n        scrollToElement(step.index);\n        break;\n      case 'notfound':\n        // Display a subtle message in footer (through live region)\n        alert(step.desc);\n        break;\n    }\n\n    // Display description in aria-live region (optional: for screen reader)\n    arrayContainer.setAttribute('aria-label', `Exponential Search step: ${step.desc}`);\n\n    // Proceed to next step after delay\n    setTimeout(() => {\n      runStep(index + 1);\n    }, step.type === 'check' ? 1900 : 2500);\n  }\n\n  // Button event handlers\n  btnStart.addEventListener('click', () => {\n    btnStart.disabled = true;\n    btnReset.disabled = true;\n    prepareExponentialSteps(arrayValues, targetValue);\n    runStep(0);\n    btnReset.disabled = false;\n  });\n\n  btnReset.addEventListener('click', () => {\n    stepIndex = 0;\n    animationInProgress = false;\n    resetVisual();\n    btnStart.disabled = false;\n    btnReset.disabled = true;\n    arrayContainer.setAttribute('aria-label', 'Sorted array content');\n    arrayContainer.parentElement.scroll({\n      left: 0,\n      behavior: 'smooth'\n    });\n  });\n\n  // Initialize disabled state\n  btnReset.disabled = true;\n\n})();\n</script>\n</body>\n</html>"
  },
