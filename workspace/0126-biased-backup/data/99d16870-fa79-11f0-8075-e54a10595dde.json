    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Encryption Interface</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .hidden { display: none; }\n    </style>\n</head>\n<body>\n\n<h1>Simple Encryption Tool</h1>\n\n<h2>Input Text</h2>\n<textarea id=\"inputText\" rows=\"4\" cols=\"50\"></textarea><br/>\n\n<h2>Encryption Method</h2>\n<select id=\"encryptionMethod\" onchange=\"updateEncryptionMethod()\">\n    <option value=\"caesar\">Caesar Cipher</option>\n    <option value=\"xor\">XOR Cipher</option>\n</select>\n\n<h2>Caesar Cipher Settings</h2>\n<div id=\"caesarSettings\" class=\"hidden\">\n    <label for=\"shift\">Shift:</label>\n    <input type=\"number\" id=\"shift\" value=\"3\" min=\"1\" max=\"25\"/><br/>\n</div>\n\n<h2>XOR Cipher Settings</h2>\n<div id=\"xorSettings\" class=\"hidden\">\n    <label for=\"xorKey\">XOR Key:</label>\n    <input type=\"text\" id=\"xorKey\" value=\"mykey\"/><br/>\n</div>\n\n<h2>Output</h2>\n<textarea id=\"outputText\" rows=\"4\" cols=\"50\" readonly></textarea><br/>\n\n<h2>Actions</h2>\n<button onclick=\"encryptText()\">Encrypt</button>\n<button onclick=\"decryptText()\">Decrypt</button>\n<button onclick=\"clearFields()\">Clear</button>\n\n<script>\n    function updateEncryptionMethod() {\n        const method = document.getElementById(\"encryptionMethod\").value;\n        document.getElementById(\"caesarSettings\").classList.toggle('hidden', method !== 'caesar');\n        document.getElementById(\"xorSettings\").classList.toggle('hidden', method !== 'xor');\n    }\n\n    function encryptText() {\n        const method = document.getElementById(\"encryptionMethod\").value;\n        const input = document.getElementById(\"inputText\").value;\n        let output;\n\n        if (method === \"caesar\") {\n            const shift = parseInt(document.getElementById(\"shift\").value);\n            output = caesarCipher(input, shift);\n        } else if (method === \"xor\") {\n            const key = document.getElementById(\"xorKey\").value;\n            output = xorCipher(input, key);\n        }\n\n        document.getElementById(\"outputText\").value = output;\n    }\n\n    function decryptText() {\n        const method = document.getElementById(\"encryptionMethod\").value;\n        const input = document.getElementById(\"outputText\").value;\n        let output;\n\n        if (method === \"caesar\") {\n            const shift = parseInt(document.getElementById(\"shift\").value);\n            output = caesarCipher(input, -shift);\n        } else if (method === \"xor\") {\n            const key = document.getElementById(\"xorKey\").value;\n            output = xorCipher(input, key);\n        }\n\n        document.getElementById(\"outputText\").value = output;\n    }\n\n    function caesarCipher(text, shift) {\n        return text.split('').map(char => {\n            if (!char.match(/[a-zA-Z]/)) return char; // Non-alphabet characters untouched\n            const base = char.charCodeAt(0) >= 65 && char.charCodeAt(0) <= 90 ? 65 : 97; // A or a\n            return String.fromCharCode((char.charCodeAt(0) - base + shift + 26) % 26 + base);\n        }).join('');\n    }\n\n    function xorCipher(text, key) {\n        let output = '';\n        for (let i = 0; i < text.length; i++) {\n            output += String.fromCharCode(text.charCodeAt(i) ^ key.charCodeAt(i % key.length));\n        }\n        return output;\n    }\n\n    function clearFields() {\n        document.getElementById(\"inputText\").value = '';\n        document.getElementById(\"outputText\").value = '';\n        document.getElementById(\"xorKey\").value = 'mykey';\n        document.getElementById(\"shift\").value = 3;\n    }\n</script>\n\n</body>\n</html>"
