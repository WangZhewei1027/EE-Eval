    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Logistic Regression Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Logistic Regression Interactive Demo</h1>\n    \n    <div>\n        <label for=\"coef0\">Coefficient 0 (Intercept):</label>\n        <input type=\"number\" id=\"coef0\" value=\"0\" step=\"0.1\">\n    </div>\n    \n    <div>\n        <label for=\"coef1\">Coefficient 1:</label>\n        <input type=\"number\" id=\"coef1\" value=\"1\" step=\"0.1\">\n    </div>\n    \n    <div>\n        <label for=\"coef2\">Coefficient 2:</label>\n        <input type=\"number\" id=\"coef2\" value=\"1\" step=\"0.1\">\n    </div>\n\n    <div>\n        <button id=\"updateButton\">Update Model</button>\n    </div>\n\n    <h2>Input Value for Prediction</h2>\n    <div>\n        <label for=\"inputValue\">Value:</label>\n        <input type=\"number\" id=\"inputValue\" value=\"0\" step=\"0.1\">\n    </div>\n    \n    <div>\n        <button id=\"predictButton\">Predict</button>\n    </div>\n    \n    <h2>Output</h2>\n    <div id=\"output\"></div>\n    \n    <script>\n        let coef0 = parseFloat(document.getElementById(\"coef0\").value);\n        let coef1 = parseFloat(document.getElementById(\"coef1\").value);\n        let coef2 = parseFloat(document.getElementById(\"coef2\").value);\n        \n        document.getElementById(\"updateButton\").addEventListener(\"click\", function() {\n            coef0 = parseFloat(document.getElementById(\"coef0\").value);\n            coef1 = parseFloat(document.getElementById(\"coef1\").value);\n            coef2 = parseFloat(document.getElementById(\"coef2\").value);\n            alert(\"Model Updated!\");\n        });\n        \n        document.getElementById(\"predictButton\").addEventListener(\"click\", function() {\n            const inputValue = parseFloat(document.getElementById(\"inputValue\").value);\n            const z = coef0 + coef1 * inputValue + coef2 * Math.pow(inputValue, 2);\n            const prediction = 1 / (1 + Math.exp(-z));\n            document.getElementById(\"output\").innerText = `Predicted Probability: ${prediction}`;\n        });\n    </script>\n</body>\n</html>"
