    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Priority Queue Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(to right, #6A82FB, #FC5C7D);\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n        .container {\n            text-align: center;\n            width: 500px;\n        }\n        h1 {\n            font-size: 2.5rem;\n            margin-bottom: 20px;\n        }\n        .queue {\n            position: relative;\n            width: 100%;\n            height: 300px;\n            border: 2px solid #FFF;\n            border-radius: 10px;\n            overflow: hidden;\n            box-shadow: 0 0 15px rgba(0,0,0,0.5);\n            background: rgba(255, 255, 255, 0.1);\n        }\n        .element {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.2rem;\n            transition: transform 0.3s ease;\n            opacity: 0.85;\n        }\n        .element.high {\n            background-color: #FF3B30;\n        }\n        .element.medium {\n            background-color: #FFCC00;\n        }\n        .element.low {\n            background-color: #4CD964;\n        }\n        .button {\n            background-color: #FFF;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            margin-top: 20px;\n            color: #333;\n            font-weight: bold;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n            outline: none;\n        }\n        .button:hover {\n            background-color: #e0e0e0;\n        }\n        .button:active {\n            transform: scale(0.95);\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1>Priority Queue Visualization</h1>\n    <div class=\"queue\" id=\"queue\"></div>\n    <button class=\"button\" onclick=\"startAnimation()\">Watch Queue</button>\n</div>\n\n<script>\n    const queueContainer = document.getElementById('queue');\n    const priorities = [\n        { value: 'A', priority: 'high' },\n        { value: 'B', priority: 'medium' },\n        { value: 'C', priority: 'low' },\n        { value: 'D', priority: 'medium' },\n        { value: 'E', priority: 'high' },\n    ];\n    \n    function createElement(value, priority, index) {\n        const element = document.createElement('div');\n        element.className = `element ${priority}`;\n        element.innerText = value;\n        element.style.bottom = `${index * 60}px`;  // stack elements vertically\n        return element;\n    }\n\n    function addElementsToQueue() {\n        queueContainer.innerHTML = \"\"; // Clear queue\n        priorities.forEach((item, index) => {\n            const el = createElement(item.value, item.priority, index);\n            queueContainer.appendChild(el);\n        });\n    }\n\n    function startAnimation() {\n        addElementsToQueue();\n        const elements = document.querySelectorAll('.element');\n\n        elements.forEach((el, index) => {\n            el.style.transform = `translateY(${Math.random() * 50}px)`;\n            setTimeout(() => {\n                el.style.transform = 'translateY(0)';\n                el.style.opacity = '1';\n            }, index * 200);\n        });\n    }\n    \n    startAnimation(); // Automatically start the animation when the page loads\n</script>\n\n</body>\n</html>"
