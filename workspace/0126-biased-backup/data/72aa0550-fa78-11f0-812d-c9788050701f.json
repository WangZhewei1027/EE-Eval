    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tim Sort Visualization</title>\n    <style>\n        :root {\n            --primary: #4a6fa5;\n            --secondary: #166088;\n            --accent: #4fc3f7;\n            --background: #0a192f;\n            --text: #e6f1ff;\n            --highlight: #64ffda;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Avenir', 'Helvetica Neue', sans-serif;\n        }\n\n        body {\n            background-color: var(--background);\n            color: var(--text);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 2rem;\n            width: 100%;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 600;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(45deg, var(--accent), var(--highlight));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            opacity: 0.8;\n            margin-bottom: 1.5rem;\n        }\n\n        .visualization-container {\n            width: 90%;\n            max-width: 1200px;\n            height: 500px;\n            background: rgba(10, 25, 47, 0.7);\n            border-radius: 16px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n            backdrop-filter: blur(4px);\n            -webkit-backdrop-filter: blur(4px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            margin-bottom: 2rem;\n        }\n\n        .array-container {\n            display: flex;\n            align-items: flex-end;\n            height: 80%;\n            gap: 2px;\n            padding-top: 1rem;\n            position: relative;\n        }\n\n        .array-bar {\n            flex: 1;\n            background: linear-gradient(to top, var(--primary), var(--secondary));\n            border-radius: 4px 4px 0 0;\n            transition: height 0.3s ease, background 0.3s ease;\n            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);\n            position: relative;\n        }\n\n        .array-bar.active {\n            background: linear-gradient(to top, var(--highlight), #64ffda);\n            box-shadow: 0 0 15px var(--highlight);\n        }\n\n        .array-bar.merged {\n            background: linear-gradient(to top, #ff6b6b, #f368e0);\n        }\n\n        .array-bar.sorted {\n            background: linear-gradient(to top, #1dd1a1, #10ac84);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n\n        button {\n            background: linear-gradient(45deg, var(--secondary), var(--primary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.8rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, var(--accent), var(--highlight));\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        button:hover::after {\n            opacity: 0.3;\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-bottom: 2rem;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .info-panel {\n            width: 90%;\n            max-width: 800px;\n            background: rgba(10, 25, 47, 0.7);\n            border-radius: 16px;\n            padding: 1.5rem;\n            margin-top: 1rem;\n            line-height: 1.6;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .info-panel h2 {\n            color: var(--accent);\n            margin-bottom: 1rem;\n            font-size: 1.5rem;\n        }\n\n        .info-panel p {\n            margin-bottom: 1rem;\n            opacity: 0.9;\n        }\n\n        .highlight {\n            color: var(--highlight);\n            font-weight: 600;\n        }\n\n        .stars {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n        }\n\n        .star {\n            position: absolute;\n            background-color: white;\n            border-radius: 50%;\n            opacity: 0.8;\n            animation: twinkle 3s infinite alternate;\n        }\n\n        @keyframes twinkle {\n            0% { opacity: 0.3; }\n            100% { opacity: 0.8; }\n        }\n\n        .tim-sort-steps {\n            width: 90%;\n            max-width: 800px;\n            margin-top: 2rem;\n        }\n\n        .step {\n            background: rgba(10, 25, 47, 0.7);\n            border-radius: 8px;\n            padding: 1rem;\n            margin-bottom: 1rem;\n            border-left: 4px solid var(--accent);\n            transition: all 0.3s ease;\n        }\n\n        .step:hover {\n            transform: translateX(5px);\n            border-left-color: var(--highlight);\n        }\n\n        .step h3 {\n            color: var(--accent);\n            margin-bottom: 0.5rem;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"stars\" id=\"stars\"></div>\n\n    <header>\n        <h1>Tim Sort</h1>\n        <div class=\"subtitle\">A hybrid stable sorting algorithm derived from merge sort and insertion sort</div>\n    </header>\n\n    <div class=\"legend\">\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: linear-gradient(to top, var(--primary), var(--secondary));\"></div>\n            <span>Normal</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: linear-gradient(to top, var(--highlight), #64ffda);\"></div>\n            <span>Active</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: linear-gradient(to top, #ff6b6b, #f368e0);\"></div>\n            <span>Merging</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: linear-gradient(to top, #1dd1a1, #10ac84);\"></div>\n            <span>Sorted</span>\n        </div>\n    </div>\n\n    <div class=\"controls\">\n        <button id=\"startBtn\">Start Visualization</button>\n        <button id=\"resetBtn\">Reset Array</button>\n    </div>\n\n    <div class=\"visualization-container\">\n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n    </div>\n\n    <div class=\"info-panel\">\n        <h2>About Tim Sort</h2>\n        <p>Tim Sort is a hybrid sorting algorithm derived from <span class=\"highlight\">merge sort</span> and <span class=\"highlight\">insertion sort</span>, designed to perform well on many kinds of real-world data. It was implemented by Tim Peters in 2002 for use in the Python programming language.</p>\n        <p>The algorithm finds subsequences of the data that are already ordered (runs) and uses them to sort the remainder more efficiently. This is done by merging runs until certain conditions are met.</p>\n    </div>\n\n    <div class=\"tim-sort-steps\">\n        <h2 style=\"color: var(--accent); margin-bottom: 1rem; text-align: center;\">How Tim Sort Works</h2>\n        \n        <div class=\"step\">\n            <h3>1. Run Identification</h3>\n            <p>The array is divided into small segments called \"runs\". These can be either strictly non-increasing or strictly non-decreasing sequences.</p>\n        </div>\n        \n        <div class=\"step\">\n            <h3>2. Insertion Sort on Small Runs</h3>\n            <p>Runs smaller than a minimum run size (typically 32-64) are extended using insertion sort until they reach the minimum size.</p>\n        </div>\n        \n        <div class=\"step\">\n            <h3>3. Merge Adjacent Runs</h3>\n            <p>The algorithm merges adjacent runs in a stable way until only one run remains - the sorted array.</p>\n        </div>\n        \n        <div class=\"step\">\n            <h3>4. Galloping Mode</h3>\n            <p>For optimal performance, Tim Sort uses a \"galloping\" mode during merging when one run is consistently smaller than the other.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create stars background\n            createStars();\n            \n            const arrayContainer = document.getElementById('arrayContainer');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let array = [];\n            const arraySize = 50;\n            const minValue = 10;\n            const maxValue = 400;\n            \n            // Initialize array\n            resetArray();\n            \n            // Event listeners\n            startBtn.addEventListener('click', startTimSort);\n            resetBtn.addEventListener('click', resetArray);\n            \n            function createStars() {\n                const starsContainer = document.getElementById('stars');\n                const starCount = 100;\n                \n                for (let i = 0; i < starCount; i++) {\n                    const star = document.createElement('div');\n                    star.classList.add('star');\n                    \n                    // Random position\n                    const x = Math.random() * 100;\n                    const y = Math.random() * 100;\n                    \n                    // Random size (0.5px to 2px)\n                    const size = Math.random() * 1.5 + 0.5;\n                    \n                    // Random animation delay\n                    const delay = Math.random() * 3;\n                    \n                    star.style.left = `${x}%`;\n                    star.style.top = `${y}%`;\n                    star.style.width = `${size}px`;\n                    star.style.height = `${size}px`;\n                    star.style.animationDelay = `${delay}s`;\n                    \n                    starsContainer.appendChild(star);\n                }\n            }\n            \n            function resetArray() {\n                array = [];\n                arrayContainer.innerHTML = '';\n                \n                for (let i = 0; i < arraySize; i++) {\n                    array.push(Math.floor(Math.random() * (maxValue - minValue + 1)) + minValue);\n                }\n                \n                renderArray();\n            }\n            \n            function renderArray(activeIndices = [], mergingIndices = [], sortedIndices = []) {\n                arrayContainer.innerHTML = '';\n                \n                for (let i = 0; i < array.length; i++) {\n                    const bar = document.createElement('div');\n                    bar.classList.add('array-bar');\n                    bar.style.height = `${array[i]}px`;\n                    \n                    if (activeIndices.includes(i)) {\n                        bar.classList.add('active');\n                    }\n                    \n                    if (mergingIndices.includes(i)) {\n                        bar.classList.add('merged');\n                    }\n                    \n                    if (sortedIndices.includes(i)) {\n                        bar.classList.add('sorted');\n                    }\n                    \n                    arrayContainer.appendChild(bar);\n                }\n            }\n            \n            async function startTimSort() {\n                startBtn.disabled = true;\n                resetBtn.disabled = true;\n                \n                // Find runs in the array\n                const runs = findRuns();\n                \n                // Sort each run with insertion sort\n                for (let run of runs) {\n                    await insertionSort(run.start, run.end);\n                    await new Promise(resolve => setTimeout(resolve, 50));\n                }\n                \n                // Merge runs\n                await mergeRuns(runs);\n                \n                // Mark entire array as sorted\n                renderArray([], [], Array.from({length: array.length}, (_, i) => i));\n                \n                startBtn.disabled = false;\n                resetBtn.disabled = false;\n            }\n            \n            function findRuns() {\n                const runs = [];\n                const minRun = 32; // Minimum run size\n                \n                let start = 0;\n                let end = 0;\n                \n                while (start < array.length) {\n                    end = Math.min(start + minRun, array.length);\n                    runs.push({start, end});\n                    start = end;\n                }\n                \n                return runs;\n            }\n            \n            async function insertionSort(start, end) {\n                for (let i = start + 1; i < end; i++) {\n                    let key = array[i];\n                    let j = i - 1;\n                    \n                    // Highlight current elements being compared\n                    renderArray([i, j], []);\n                    \n                    await new Promise(resolve => setTimeout(resolve, 20));\n                    \n                    while (j >= start && array[j] > key) {\n                        array[j + 1] = array[j];\n                        j = j - 1;\n                        \n                        renderArray([j + 1, j], []);\n                        await new Promise(resolve => setTimeout(resolve, 20));\n                    }\n                    \n                    array[j + 1] = key;\n                    \n                    renderArray([], []);\n                    await new Promise(resolve => setTimeout(resolve, 10));\n                }\n            }\n            \n            async function mergeRuns(runs) {\n                while (runs.length > 1) {\n                    const newRuns = [];\n                    \n                    for (let i = 0; i < runs.length; i += 2) {\n                        if (i + 1 >= runs.length) {\n                            newRuns.push(runs[i]);\n                            continue;\n                        }\n                        \n                        const run1 = runs[i];\n                        const run2 = runs[i + 1];\n                        \n                        // Highlight the runs being merged\n                        const mergingIndices = [];\n                        for (let j = run1.start; j < run2.end; j++) {\n                            mergingIndices.push(j);\n                        }\n                        \n                        renderArray([], mergingIndices);\n                        await new Promise(resolve => setTimeout(resolve, 200));\n                        \n                        await merge(run1.start, run1.end, run2.end);\n                        \n                        newRuns.push({start: run1.start, end: run2.end});\n                    }\n                    \n                    runs = newRuns;\n                }\n            }\n            \n            async function merge(start, mid, end) {\n                const left = array.slice(start, mid);\n                const right = array.slice(mid, end);\n                \n                let i = 0, j = 0, k = start;\n                \n                while (i < left.length && j < right.length) {\n                    if (left[i] <= right[j]) {\n                        array[k] = left[i];\n                        i++;\n                    } else {\n                        array[k] = right[j];\n                        j++;\n                    }\n                    \n                    renderArray([k], []);\n                    await new Promise(resolve => setTimeout(resolve, 20));\n                    k++;\n                }\n                \n                while (i < left.length) {\n                    array[k] = left[i];\n                    i++;\n                    k++;\n                    \n                    renderArray([k - 1], []);\n                    await new Promise(resolve => setTimeout(resolve, 20));\n                }\n                \n                while (j < right.length) {\n                    array[k] = right[j];\n                    j++;\n                    k++;\n                    \n                    renderArray([k - 1], []);\n                    await new Promise(resolve => setTimeout(resolve, 20));\n                }\n            }\n        });\n    </script>\n</body>\n</html>"
