    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Breadth-First Search (BFS) Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    overflow-x: hidden;\n  }\n\n  header {\n    margin: 2rem 0 1rem 0;\n    text-align: center;\n    max-width: 720px;\n    padding: 0 1rem;\n  }\n  header h1 {\n    font-weight: 600;\n    font-size: 3.25rem;\n    letter-spacing: 0.05em;\n    background: linear-gradient(90deg, #49a09d, #5f2c82);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    margin: 0 0 0.25rem 0;\n    text-shadow:\n      1px 1px 4px rgba(79, 79, 135, 0.6),\n      0 0 10px rgba(79, 79, 135, 0.15);\n  }\n  header p {\n    font-weight: 300;\n    font-size: 1.15rem;\n    line-height: 1.5;\n    color: #c0c7d6;\n    max-width: 600px;\n    margin: 0 auto;\n    letter-spacing: 0.03em;\n  }\n\n  main {\n    position: relative;\n    flex-grow: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    max-width: 960px;\n    padding: 1rem;\n  }\n\n  /* Graph container */\n  #graph-container {\n    position: relative;\n    background: #142d4c;\n    border-radius: 24px;\n    box-shadow:\n      inset 0 0 30px #35648a66,\n      0 8px 24px rgba(20, 45, 76, 0.7);\n    width: 720px;\n    height: 520px;\n    user-select: none;\n  }\n\n  /* Nodes and edges in SVG */\n  svg {\n    width: 100%;\n    height: 100%;\n    display: block;\n  }\n\n  /* Edges style */\n  line.edge {\n    stroke: #6085a3;\n    stroke-width: 2;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 1.5px #88aad9aa);\n    transition: stroke 0.4s ease;\n    opacity: 0.7;\n  }\n  line.edge.visited {\n    stroke: #f9a826;\n    stroke-width: 3.2;\n    opacity: 1;\n    filter: drop-shadow(0 0 8px #f9a826);\n  }\n\n  /* Directed edge arrow (marker) */\n  marker#arrowhead {\n    fill: #6085a3;\n    filter: drop-shadow(0 0 1.5px #88aad9d9);\n    transition: fill 0.4s ease;\n  }\n  line.edge.visited ~ marker#arrowhead {\n    fill: #f9a826;\n    filter: drop-shadow(0 0 8px #f9a826);\n  }\n\n  /* Nodes */\n  g.node circle {\n    fill: #1c3966;\n    stroke: #35648a;\n    stroke-width: 3;\n    filter:\n      drop-shadow(0 0 10px #37649488);\n    transition:\n      fill 0.6s ease,\n      stroke 0.5s ease,\n      filter 0.5s ease;\n    cursor: default;\n  }\n  g.node.visited circle {\n    fill: #f9a826;\n    stroke: #f1c40f;\n    filter:\n      drop-shadow(0 0 12px #f9a826);\n  }\n  g.node.start circle {\n    fill: #38b6ff;\n    stroke: #27a1e5;\n    filter: drop-shadow(0 0 17px #38b6ff);\n  }\n  g.node.end circle {\n    fill: #d85151;\n    stroke: #b53636;\n    filter: drop-shadow(0 0 14px #d85151);\n  }\n\n  /* Node labels */\n  g.node text {\n    fill: #cfd9e8;\n    font-weight: 600;\n    font-size: 20px;\n    font-family: 'Poppins', sans-serif;\n    user-select: none;\n    pointer-events: none;\n    text-shadow:\n      0 0 2px rgba(0,0,0,0.5);\n    transition: fill 0.5s ease;\n  }\n  g.node.visited text {\n    fill: #2b2b00;\n    font-weight: 700;\n  }\n  g.node.start text {\n    fill: #d2f2ff;\n    font-weight: 700;\n  }\n  g.node.end text {\n    fill: #ffd7d7;\n    font-weight: 700;\n  }\n\n  /* Controls */\n  #controls {\n    margin-top: 1.5rem;\n    display: flex;\n    gap: 1.4rem;\n  }\n  button {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    padding: 0.75rem 1.6rem;\n    border: none;\n    border-radius: 20px;\n    cursor: pointer;\n    background: linear-gradient(135deg, #49a09d, #5f2c82);\n    color: #e0e6f0;\n    box-shadow: 0 6px 12px rgba(79, 79, 135, 0.5);\n    transition:\n      background 0.4s ease,\n      box-shadow 0.3s ease,\n      transform 0.2s ease;\n  }\n  button:hover:not(:disabled) {\n    background: linear-gradient(135deg, #5f2c82, #49a09d);\n    box-shadow: 0 10px 22px rgba(101, 97, 138, 0.8);\n    transform: translateY(-3px);\n  }\n  button:disabled {\n    cursor: default;\n    background: #415462;\n    box-shadow: none;\n    color: #8791a1;\n  }\n\n  /* Footer */\n  footer {\n    margin: 2rem 0 2.5rem 0;\n    font-weight: 300;\n    font-size: 0.9rem;\n    letter-spacing: 0.04em;\n    color: #7a8ba6cc;\n  }\n\n</style>\n</head>\n<body>\n<header>\n  <h1>Breadth-First Search</h1>\n  <p>An elegant, step-by-step visualization of the Breadth-First Search algorithm traversing a directed graph. Observe the spreading wave of discovery from the start node, illuminating the shortest paths layer-by-layer.</p>\n</header>\n\n<main>\n  <div id=\"graph-container\" aria-label=\"Breadth-First Search graph visualization\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 720 520\" role=\"img\" aria-labelledby=\"svgTitle\">\n      <title id=\"svgTitle\">Directed graph for BFS traversal</title>\n      <!-- Edges -->\n      <defs>\n        <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" \n                refX=\"18\" refY=\"3\" orient=\"auto\" markerUnits=\"strokeWidth\">\n          <path d=\"M0,0 L8,3 L0,6\" />\n        </marker>\n      </defs>\n\n      <!-- Edges lines will be generated by JS -->\n\n      <!-- Nodes will be generated by JS -->\n\n    </svg>\n  </div>\n</main>\n\n<div id=\"controls\" aria-label=\"Controls to run BFS visualization\">\n  <button id=\"start-btn\" aria-controls=\"graph-container\" aria-label=\"Start Breadth-First Search Visualization\">Start BFS</button>\n  <button id=\"reset-btn\" aria-controls=\"graph-container\" aria-label=\"Reset Visualization\" disabled>Reset</button>\n</div>\n\n<footer aria-hidden=\"true\">\n  © 2024 BFS Visualization &mdash; Designed for clarity and aesthetic beauty.\n</footer>\n\n<script>\n(() => {\n  'use strict';\n\n  // Graph definition - Directed graph with adjacency list\n  // Nodes and their positions in SVG coordinates (x,y)\n  const nodes = [\n    { id: \"A\", x: 90,  y: 250 },  // Start node\n    { id: \"B\", x: 230, y: 110 },\n    { id: \"C\", x: 230, y: 390 },\n    { id: \"D\", x: 370, y: 250 },\n    { id: \"E\", x: 510, y: 100 },\n    { id: \"F\", x: 510, y: 400 },\n    { id: \"G\", x: 650, y: 250 }   // End node\n  ];\n\n  // Directed edges: from -> to\n  const edges = [\n    [\"A\", \"B\"],\n    [\"A\", \"C\"],\n    [\"B\", \"D\"],\n    [\"C\", \"D\"],\n    [\"D\", \"E\"],\n    [\"D\", \"F\"],\n    [\"E\", \"G\"],\n    [\"F\", \"G\"]\n  ];\n\n  // SVG root element\n  const svg = document.querySelector('svg');\n\n  // State variables\n  let visitedNodes = new Set();\n  let visitedEdges = new Set();\n  let queue = [];\n  let animationStep = 0;\n  let animationInterval = null;\n\n  // Parameters for animation timing\n  const stepDuration = 1400; // ms delay between node visits\n\n  // Elements holders for easy updates\n  const nodeElements = new Map(); // id -> <g>\n  const edgeElements = []; // [{line, from, to}]\n\n  // Special nodes\n  const startNodeId = \"A\";\n  const endNodeId = \"G\";\n\n  // Initialize the graph rendering\n  function createGraph() {\n    // Clear SVG content except defs\n    while(svg.lastChild && svg.lastChild.nodeName !== 'defs') {\n      svg.removeChild(svg.lastChild);\n    }\n\n    // Create edges first (so nodes appear on top)\n    edges.forEach(([from, to]) => {\n      const fromNode = nodes.find(n => n.id === from);\n      const toNode = nodes.find(n => n.id === to);\n\n      // Calculate line endpoints shifted slightly so arrow doesn't overlap node circles\n      const deltaX = toNode.x - fromNode.x;\n      const deltaY = toNode.y - fromNode.y;\n      const dist = Math.hypot(deltaX, deltaY);\n      const r = 28; // radius of node circle + some margin\n\n      // Start (from) coordinates moved by r toward to\n      const startX = fromNode.x + (deltaX * r / dist);\n      const startY = fromNode.y + (deltaY * r / dist);\n\n      // End (to) coordinates moved by r away from to\n      const endX = toNode.x - (deltaX * r / dist);\n      const endY = toNode.y - (deltaY * r / dist);\n\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n      line.setAttribute(\"x1\", startX);\n      line.setAttribute(\"y1\", startY);\n      line.setAttribute(\"x2\", endX);\n      line.setAttribute(\"y2\", endY);\n      line.setAttribute(\"class\", \"edge\");\n      line.setAttribute(\"marker-end\", \"url(#arrowhead)\");\n      line.dataset.from = from;\n      line.dataset.to = to;\n\n      svg.appendChild(line);\n      edgeElements.push({line, from, to});\n    });\n\n    // Create node groups\n    nodes.forEach(node => {\n      const g = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n      g.setAttribute(\"class\", \"node\");\n      g.setAttribute(\"tabindex\", \"-1\");\n      g.setAttribute(\"aria-label\", `Node ${node.id}`);\n      g.style.transformOrigin = `${node.x}px ${node.y}px`;\n      g.dataset.id = node.id;\n\n      // Circle\n      const circle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n      circle.setAttribute(\"cx\", node.x);\n      circle.setAttribute(\"cy\", node.y);\n      circle.setAttribute(\"r\", 24);\n      g.appendChild(circle);\n\n      // Text label\n      const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n      text.setAttribute(\"x\", node.x);\n      text.setAttribute(\"y\", node.y + 7);\n      text.setAttribute(\"text-anchor\", \"middle\");\n      text.textContent = node.id;\n      g.appendChild(text);\n\n      if(node.id === startNodeId) {\n        g.classList.add(\"start\");\n      }\n      if(node.id === endNodeId) {\n        g.classList.add(\"end\");\n      }\n\n      svg.appendChild(g);\n      nodeElements.set(node.id, g);\n    });\n  }\n\n  // BFS animation logic\n  function bfsStep() {\n    if(queue.length === 0) {\n      // Animation finished\n      clearInterval(animationInterval);\n      animationInterval = null;\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      return;\n    }\n\n    const currentId = queue.shift();\n\n    // Mark current node visited if not already\n    if(!visitedNodes.has(currentId)) {\n      visitedNodes.add(currentId);\n      const nodeEl = nodeElements.get(currentId);\n      nodeEl.classList.add(\"visited\");\n\n      // Pulse animation: scale up then back\n      nodeEl.animate([\n        { transform: \"scale(1)\" },\n        { transform: \"scale(1.18)\" },\n        { transform: \"scale(1)\" }\n      ], {\n        duration: 550,\n        easing: \"cubic-bezier(0.4, 0, 0.2, 1)\"\n      });\n    }\n\n    // Enqueue neighbors and highlight edges\n    const neighbors = edges.filter(e => e[0] === currentId).map(e => e[1]);\n    neighbors.forEach(neighborId => {\n      if(!visitedNodes.has(neighborId) && !queue.includes(neighborId)) {\n        queue.push(neighborId);\n\n        // Highlight edge current->neighbor\n        const edgeObj = edgeElements.find(e => e.from === currentId && e.to === neighborId);\n        if(edgeObj && !visitedEdges.has(currentId+neighborId)) {\n          visitedEdges.add(currentId+neighborId);\n          edgeObj.line.classList.add(\"visited\");\n          // Edge glow pulse\n          edgeObj.line.animate([\n            { strokeWidth: '3.2', opacity: 1, filter: 'drop-shadow(0 0 8px #f9a826)' },\n            { strokeWidth: '2.8', opacity: 0.9, filter: 'drop-shadow(0 0 5px #f9a826a0)' },\n            { strokeWidth: '3.2', opacity: 1, filter: 'drop-shadow(0 0 8px #f9a826)' }\n          ], {\n            duration: 1400,\n            easing: \"ease-in-out\"\n          });\n        }\n      }\n    });\n  }\n\n  // Start BFS animation sequence\n  function startBFS() {\n    if(animationInterval) return;\n\n    visitedNodes.clear();\n    visitedEdges.clear();\n\n    // Reset classes (in case reset wasn't pressed)\n    nodeElements.forEach(g => {\n      g.classList.remove(\"visited\");\n    });\n    edgeElements.forEach(({line}) => {\n      line.classList.remove(\"visited\");\n    });\n\n    queue = [startNodeId];\n\n    bfsStep(); // Start immediately first step\n\n    animationInterval = setInterval(bfsStep, stepDuration);\n\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n  }\n\n  // Reset visualization to initial state\n  function resetVisualization() {\n    if(animationInterval) {\n      clearInterval(animationInterval);\n      animationInterval = null;\n    }\n    visitedNodes.clear();\n    visitedEdges.clear();\n    queue = [];\n\n    nodeElements.forEach(g => {\n      g.classList.remove(\"visited\");\n    });\n    edgeElements.forEach(({line}) => {\n      line.classList.remove(\"visited\");\n    });\n\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Initialize all\n  function init() {\n    createGraph();\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Button references\n  const startBtn = document.getElementById(\"start-btn\");\n  const resetBtn = document.getElementById(\"reset-btn\");\n\n  startBtn.addEventListener(\"click\", startBFS);\n  resetBtn.addEventListener(\"click\", resetVisualization);\n\n  // Start with graph rendered\n  init();\n\n  // Accessibility: Focus outline visible only on keyboard tab\n  // (Handled by default browser behavior)\n})();\n</script>\n</body>\n</html>"
  },
