    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Priority Queue Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        table {\n            margin-top: 20px;\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid black;\n            padding: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h2>Interactive Priority Queue</h2>\n    <label for=\"value\">Enter value:</label>\n    <input type=\"number\" id=\"value\" placeholder=\"Value\">\n    \n    <label for=\"priority\">Enter priority:</label>\n    <input type=\"number\" id=\"priority\" placeholder=\"Priority\">\n\n    <button onclick=\"enqueue()\">Enqueue</button>\n    <button onclick=\"dequeue()\">Dequeue</button>\n    <button onclick=\"viewQueue()\">View Queue</button>\n    \n    <h3>Queue:</h3>\n    <table id=\"queueTable\">\n        <tr>\n            <th>Value</th>\n            <th>Priority</th>\n        </tr>\n    </table>\n\n    <script>\n        class PriorityQueue {\n            constructor() {\n                this.queue = [];\n            }\n\n            enqueue(value, priority) {\n                const newNode = { value, priority };\n                let added = false;\n                for(let i = 0; i < this.queue.length; i++) {\n                    if(newNode.priority > this.queue[i].priority) {\n                        this.queue.splice(i, 0, newNode);\n                        added = true;\n                        break;\n                    }\n                }\n                if(!added) {\n                    this.queue.push(newNode);\n                }\n            }\n\n            dequeue() {\n                return this.queue.shift();\n            }\n\n            getQueue() {\n                return this.queue;\n            }\n        }\n\n        const priorityQueue = new PriorityQueue();\n\n        function enqueue() {\n            const value = document.getElementById('value').value;\n            const priority = document.getElementById('priority').value;\n\n            if (value === '' || priority === '') {\n                alert('Please enter both value and priority.');\n                return;\n            }\n\n            priorityQueue.enqueue(Number(value), Number(priority));\n            document.getElementById('value').value = '';\n            document.getElementById('priority').value = '';\n            viewQueue();\n        }\n\n        function dequeue() {\n            const removed = priorityQueue.dequeue();\n            if (removed) {\n                alert(`Dequeued: Value ${removed.value}, Priority ${removed.priority}`);\n            } else {\n                alert('Queue is empty.');\n            }\n            viewQueue();\n        }\n\n        function viewQueue() {\n            const table = document.getElementById('queueTable');\n            while (table.rows.length > 1) {\n                table.deleteRow(1);\n            }\n            const queue = priorityQueue.getQueue();\n            queue.forEach(item => {\n                const row = table.insertRow();\n                const cellValue = row.insertCell(0);\n                const cellPriority = row.insertCell(1);\n                cellValue.textContent = item.value;\n                cellPriority.textContent = item.priority;\n            });\n        }\n    </script>\n</body>\n</html>"
