  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>NP-Completeness Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .panel {\n            border: 1px solid #000;\n            padding: 10px;\n            margin-bottom: 15px;\n        }\n        button, select, input {\n            margin: 5px;\n        }\n        .problem-instance {\n            font-family: monospace;\n            white-space: pre;\n        }\n        .hidden {\n            display: none;\n        }\n        table {\n            border-collapse: collapse;\n            margin: 10px 0;\n        }\n        td, th {\n            border: 1px solid #000;\n            padding: 5px;\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <h1>NP-Completeness Interactive Explorer</h1>\n    \n    <div class=\"panel\">\n        <h2>1. Problem Selection</h2>\n        <select id=\"problemSelect\">\n            <option value=\"sat\">Boolean Satisfiability (SAT)</option>\n            <option value=\"vc\">Vertex Cover</option>\n            <option value=\"tsp\">Traveling Salesman</option>\n            <option value=\"clique\">Clique</option>\n            <option value=\"is\">Independent Set</option>\n        </select>\n        <button onclick=\"generateProblem()\">Generate Problem Instance</button>\n        <button onclick=\"showReduction()\">Show Reduction</button>\n    </div>\n    \n    <div class=\"panel\" id=\"problemPanel\">\n        <h2>2. Problem Instance</h2>\n        <div id=\"problemInstance\" class=\"problem-instance\"></div>\n        <div id=\"problemControls\"></div>\n    </div>\n    \n    <div class=\"panel hidden\" id=\"solutionPanel\">\n        <h2>3. Solution Attempt</h2>\n        <div id=\"solutionArea\"></div>\n        <div id=\"verificationResult\"></div>\n    </div>\n    \n    <div class=\"panel hidden\" id=\"reductionPanel\">\n        <h2>4. Reduction Explorer</h2>\n        <div id=\"reductionSteps\"></div>\n        <button onclick=\"nextReductionStep()\">Next Step</button>\n        <div id=\"reductionVisualization\"></div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>5. Complexity Analysis</h2>\n        <div>\n            <label>Problem Size (n): <input type=\"range\" id=\"problemSize\" min=\"3\" max=\"20\" value=\"5\"></label>\n            <span id=\"sizeValue\">5</span>\n        </div>\n        <div>\n            <button onclick=\"runBruteForce()\">Run Brute Force Algorithm</button>\n            <button onclick=\"runHeuristic()\">Run Heuristic Algorithm</button>\n        </div>\n        <div id=\"runtimeResults\">\n            <table>\n                <tr>\n                    <th>Algorithm</th>\n                    <th>Steps</th>\n                    <th>Time Complexity</th>\n                </tr>\n                <tr>\n                    <td>Brute Force</td>\n                    <td id=\"bfSteps\">-</td>\n                    <td id=\"bfComplexity\">-</td>\n                </tr>\n                <tr>\n                    <td>Heuristic</td>\n                    <td id=\"heuristicSteps\">-</td>\n                    <td id=\"heuristicComplexity\">-</td>\n                </tr>\n            </table>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>6. NP-Completeness Proof</h2>\n        <div>\n            <input type=\"checkbox\" id=\"showProofSteps\"> Show detailed proof steps\n        </div>\n        <div id=\"proofSteps\" class=\"hidden\">\n            <ol>\n                <li>Show problem is in NP (verifiable in polynomial time)</li>\n                <li>Select known NP-complete problem to reduce from</li>\n                <li>Construct polynomial-time reduction</li>\n                <li>Prove reduction preserves answers</li>\n                <li>Conclude NP-completeness</li>\n            </ol>\n        </div>\n        <button onclick=\"constructProof()\">Construct Proof for Selected Problem</button>\n        <div id=\"proofConstruction\"></div>\n    </div>\n    \n    <script>\n        let currentProblem = null;\n        let currentSolution = null;\n        let reductionStep = 0;\n        let problemSize = 5;\n        \n        document.getElementById('problemSize').addEventListener('input', function() {\n            problemSize = this.value;\n            document.getElementById('sizeValue').textContent = problemSize;\n        });\n        \n        document.getElementById('showProofSteps').addEventListener('change', function() {\n            document.getElementById('proofSteps').classList.toggle('hidden', !this.checked);\n        });\n        \n        function generateProblem() {\n            const problemType = document.getElementById('problemSelect').value;\n            currentProblem = generateProblemInstance(problemType, problemSize);\n            document.getElementById('problemInstance').textContent = currentProblem.display;\n            document.getElementById('problemPanel').classList.remove('hidden');\n            document.getElementById('solutionPanel').classList.add('hidden');\n            \n            // Generate appropriate controls\n            const controlsDiv = document.getElementById('problemControls');\n            controlsDiv.innerHTML = '';\n            \n            if (problemType === 'sat') {\n                controlsDiv.innerHTML = `\n                    <p>Try assigning values to variables:</p>\n                    ${currentProblem.variables.map(v => `\n                        <label>${v}: \n                            <select id=\"var_${v}\">\n                                <option value=\"unset\">Unset</option>\n                                <option value=\"true\">True</option>\n                                <option value=\"false\">False</option>\n                            </select>\n                        </label>\n                    `).join('')}\n                    <button onclick=\"checkSATSolution()\">Check Solution</button>\n                `;\n            } else if (problemType === 'vc') {\n                controlsDiv.innerHTML = `\n                    <p>Select vertices for your cover (size ≤ ${currentProblem.k}):</p>\n                    ${currentProblem.vertices.map(v => `\n                        <input type=\"checkbox\" id=\"vc_${v}\"> ${v}\n                    `).join('')}\n                    <button onclick=\"checkVCSolution()\">Check Solution</button>\n                `;\n            } else if (problemType === 'tsp') {\n                controlsDiv.innerHTML = `\n                    <p>Construct a tour (click cities in order):</p>\n                    <div id=\"tspCities\"></div>\n                    <div id=\"tspTour\"></div>\n                    <button onclick=\"checkTSPSolution()\">Check Solution</button>\n                `;\n                // Render TSP cities (simplified)\n                document.getElementById('tspCities').innerHTML = currentProblem.cities.map(c => \n                    `<button onclick=\"addToTour('${c}')\">${c}</button>`\n                ).join(' ');\n            }\n        }\n        \n        function generateProblemInstance(type, size) {\n            if (type === 'sat') {\n                const variables = [];\n                for (let i = 0; i < size; i++) {\n                    variables.push(`x${i}`);\n                }\n                \n                const clauses = [];\n                for (let i = 0; i < size; i++) {\n                    const clause = [];\n                    for (let j = 0; j < 3; j++) {\n                        const varIndex = Math.floor(Math.random() * size);\n                        const negated = Math.random() > 0.5;\n                        clause.push(negated ? `¬${variables[varIndex]}` : variables[varIndex]);\n                    }\n                    clauses.push(`(${clause.join(' ∨ ')})`);\n                }\n                \n                return {\n                    type: 'sat',\n                    variables: variables,\n                    clauses: clauses,\n                    display: `Variables: ${variables.join(', ')}\\nClauses:\\n${clauses.join(' ∧\\n')}`\n                };\n            } else if (type === 'vc') {\n                const vertices = [];\n                for (let i = 0; i < size; i++) {\n                    vertices.push(`v${i}`);\n                }\n                \n                const edges = [];\n                for (let i = 0; i < size * 1.5; i++) {\n                    const v1 = Math.floor(Math.random() * size);\n                    let v2 = Math.floor(Math.random() * size);\n                    while (v2 === v1) v2 = Math.floor(Math.random() * size);\n                    edges.push(`${vertices[v1]}—${vertices[v2]}`);\n                }\n                \n                return {\n                    type: 'vc',\n                    vertices: vertices,\n                    edges: edges,\n                    k: Math.floor(size / 2) + 1,\n                    display: `Vertices: ${vertices.join(', ')}\\nEdges: ${edges.join(', ')}\\nFind vertex cover of size ≤ ${Math.floor(size / 2) + 1}`\n                };\n            } else if (type === 'tsp') {\n                const cities = [];\n                for (let i = 0; i < size; i++) {\n                    cities.push(`City ${i}`);\n                }\n                \n                // Generate random distances\n                const distances = {};\n                for (let i = 0; i < size; i++) {\n                    for (let j = i + 1; j < size; j++) {\n                        const dist = Math.floor(Math.random() * 100) + 1;\n                        distances[`${cities[i]}-${cities[j]}`] = dist;\n                        distances[`${cities[j]}-${cities[i]}`] = dist;\n                    }\n                }\n                \n                return {\n                    type: 'tsp',\n                    cities: cities,\n                    distances: distances,\n                    display: `Cities: ${cities.join(', ')}\\nFind tour visiting all cities with minimal total distance`\n                };\n            }\n        }\n        \n        function checkSATSolution() {\n            const problemType = document.getElementById('problemSelect').value;\n            if (problemType !== 'sat') return;\n            \n            const assignment = {};\n            let allAssigned = true;\n            \n            currentProblem.variables.forEach(v => {\n                const val = document.getElementById(`var_${v}`).value;\n                if (val === 'unset') {\n                    allAssigned = false;\n                } else {\n                    assignment[v] = val === 'true';\n                }\n            });\n            \n            if (!allAssigned) {\n                document.getElementById('verificationResult').innerHTML = \n                    '<p style=\"color:red\">Please assign all variables</p>';\n                return;\n            }\n            \n            let allClausesSatisfied = true;\n            currentProblem.clauses.forEach(clause => {\n                // Simple check - in real implementation would parse the clause properly\n                const vars = clause.match(/[x¬x]\\d+/g);\n                let clauseSatisfied = false;\n                \n                vars.forEach(v => {\n                    const negated = v.startsWith('¬');\n                    const varName = negated ? v.substring(1) : v;\n                    if ((assignment[varName] && !negated) || (!assignment[varName] && negated)) {\n                        clauseSatisfied = true;\n                    }\n                });\n                \n                if (!clauseSatisfied) {\n                    allClausesSatisfied = false;\n                }\n            });\n            \n            document.getElementById('solutionPanel').classList.remove('hidden');\n            document.getElementById('verificationResult').innerHTML = allClausesSatisfied ?\n                '<p style=\"color:green\">All clauses satisfied! This is a valid solution.</p>' :\n                '<p style=\"color:red\">Not all clauses are satisfied. Try different assignments.</p>';\n        }\n        \n        function checkVCSolution() {\n            const selectedVertices = [];\n            currentProblem.vertices.forEach(v => {\n                if (document.getElementById(`vc_${v}`).checked) {\n                    selectedVertices.push(v);\n                }\n            });\n            \n            if (selectedVertices.length > currentProblem.k) {\n                document.getElementById('verificationResult').innerHTML = \n                    `<p style=\"color:red\">Too many vertices selected (${selectedVertices.length} > ${currentProblem.k})</p>`;\n                return;\n            }\n            \n            let allEdgesCovered = true;\n            currentProblem.edges.forEach(edge => {\n                const [v1, v2] = edge.split('—');\n                if (!selectedVertices.includes(v1) && !selectedVertices.includes(v2)) {\n                    allEdgesCovered = false;\n                }\n            });\n            \n            document.getElementById('solutionPanel').classList.remove('hidden');\n            document.getElementById('verificationResult').innerHTML = allEdgesCovered ?\n                `<p style=\"color:green\">All edges covered with ${selectedVertices.length} vertices! Valid solution.</p>` :\n                '<p style=\"color:red\">Not all edges are covered. Try different vertex selection.</p>';\n        }\n        \n        let tspTour = [];\n        function addToTour(city) {\n            if (!tspTour.includes(city)) {\n                tspTour.push(city);\n                document.getElementById('tspTour').textContent = `Current tour: ${tspTour.join(' → ')}`;\n            }\n        }\n        \n        function checkTSPSolution() {\n            if (tspTour.length !== currentProblem.cities.length) {\n                document.getElementById('verificationResult').innerHTML = \n                    '<p style=\"color:red\">Tour must visit all cities exactly once</p>';\n                return;\n            }\n            \n            // Calculate total distance\n            let totalDistance = 0;\n            for (let i = 0; i < tspTour.length; i++) {\n                const next = (i + 1) % tspTour.length;\n                const key = `${tspTour[i]}-${tspTour[next]}`;\n                totalDistance += currentProblem.distances[key];\n            }\n            \n            document.getElementById('solutionPanel').classList.remove('hidden');\n            document.getElementById('verificationResult').innerHTML = \n                `<p>Tour distance: ${totalDistance}</p><p>Can you find a shorter tour?</p>`;\n        }\n        \n        function showReduction() {\n            const problemType = document.getElementById('problemSelect').value;\n            reductionStep = 0;\n            document.getElementById('reductionPanel').classList.remove('hidden');\n            document.getElementById('reductionSteps').innerHTML = \n                `<p>Reduction from ${getReductionSource(problemType)} to ${problemType.toUpperCase()}</p>`;\n            nextReductionStep();\n        }\n        \n        function getReductionSource(problemType) {\n            const reductions = {\n                'sat': '3SAT',\n                'vc': '3SAT',\n                'tsp': 'Hamiltonian Cycle',\n                'clique': '3SAT',\n                'is': 'Clique'\n            };\n            return reductions[problemType] || '3SAT';\n        }\n        \n        function nextReductionStep() {\n            const problemType = document.getElementById('problemSelect').value;\n            reductionStep++;\n            \n            let stepContent = '';\n            if (problemType === 'sat') {\n                stepContent = getSATReductionStep(reductionStep);\n            } else if (problemType === 'vc') {\n                stepContent = getVCReductionStep(reductionStep);\n            } else if (problemType === 'tsp') {\n                stepContent = getTSPReductionStep(reductionStep);\n            }\n            \n            document.getElementById('reductionSteps').innerHTML += stepContent;\n        }\n        \n        function getSATReductionStep(step) {\n            switch(step) {\n                case 1:\n                    return `<p>Step 1: Start with 3SAT problem instance</p>`;\n                case 2:\n                    return `<p>Step 2: For each variable x, create two vertices (x and ¬x) connected by an edge</p>`;\n                case 3:\n                    return `<p>Step 3: For each clause (l1 ∨ l2 ∨ l3), create a triangle connecting the literals</p>`;\n                case 4:\n                    return `<p>Step 4: Set k = number of variables + 2 * number of clauses</p>`;\n                case 5:\n                    return `<p>Step 5: Prove that satisfying assignment corresponds to vertex cover and vice versa</p>`;\n                default:\n                    return `<p>Reduction complete. We've shown how to convert any 3SAT problem to Vertex Cover.</p>`;\n            }\n        }\n        \n        function getVCReductionStep(step) {\n            switch(step) {\n                case 1:\n                    return `<p>Step 1: Start with 3SAT problem instance</p>`;\n                case 2:\n                    return `<p>Step 2: For each variable x, create two vertices (x and ¬x) connected by an edge</p>`;\n                case 3:\n                    return `<p>Step 3: For each clause (l1 ∨ l2 ∨ l3), create a triangle connecting the literals</p>`;\n                case 4:\n                    return `<p>Step 4: Set k = number of variables + 2 * number of clauses</p>`;\n                case 5:\n                    return `<p>Step 5: Prove that satisfying assignment corresponds to vertex cover and vice versa</p>`;\n                default:\n                    return `<p>Reduction complete. We've shown how to convert any 3SAT problem to Vertex Cover.</p>`;\n            }\n        }\n        \n        function getTSPReductionStep(step) {\n            switch(step) {\n                case 1:\n                    return `<p>Step 1: Start with Hamiltonian Cycle problem instance (graph G)</p>`;\n                case 2:\n                    return `<p>Step 2: Create TSP instance with same set of vertices as cities</p>`;\n                case 3:\n                    return `<p>Step 3: Set distance between cities u and v to 1 if edge exists in G, 2 otherwise</p>`;\n                case 4:\n                    return `<p>Step 4: Set target tour length to number of vertices</p>`;\n                case 5:\n                    return `<p>Step 5: Prove Hamiltonian cycle exists iff TSP tour of length n exists</p>`;\n                default:\n                    return `<p>Reduction complete. We've shown how to convert any Hamiltonian Cycle problem to TSP.</p>`;\n            }\n        }\n        \n        function runBruteForce() {\n            const problemType = document.getElementById('problemSelect').value;\n            let steps = 1;\n            let complexity = '';\n            \n            if (problemType === 'sat') {\n                steps = Math.pow(2, problemSize);\n                complexity = 'O(2ⁿ)';\n            } else if (problemType === 'vc') {\n                steps = combinationCount(currentProblem.vertices.length, currentProblem.k);\n                complexity = 'O(nᵏ)';\n            } else if (problemType === 'tsp') {\n                steps = factorial(problemSize - 1) / 2;\n                complexity = 'O(n!)';\n            }\n            \n            document.getElementById('bfSteps').textContent = steps.toLocaleString();\n            document.getElementById('bfComplexity').textContent = complexity;\n        }\n        \n        function runHeuristic() {\n            const problemType = document.getElementById('problemSelect').value;\n            let steps = 0;\n            let complexity = '';\n            \n            if (problemType === 'sat') {\n                steps = problemSize * 3; // Very simplified\n                complexity = 'O(n) approximation';\n            } else if (problemType === 'vc') {\n                steps = currentProblem.edges.length * 2;\n                complexity = 'O(log n) approximation';\n            } else if (problemType === 'tsp') {\n                steps = problemSize * problemSize;\n                complexity = 'O(n²) approximation';\n            }\n            \n            document.getElementById('heuristicSteps').textContent = steps.toLocaleString();\n            document.getElementById('heuristicComplexity').textContent = complexity;\n        }\n        \n        function combinationCount(n, k) {\n            let result = 1;\n            for (let i = 1; i <= k; i++) {\n                result *= (n - k + i) / i;\n            }\n            return Math.round(result);\n        }\n        \n        function factorial(n) {\n            let result = 1;\n            for (let i = 2; i <= n; i++) {\n                result *= i;\n            }\n            return result;\n        }\n        \n        function constructProof() {\n            const problemType = document.getElementById('problemSelect').value;\n            let proof = '';\n            \n            if (problemType === 'sat') {\n                proof = `\n                    <h3>Proof that SAT is NP-Complete</h3>\n                    <ol>\n                        <li><strong>SAT is in NP:</strong> Given a proposed assignment, we can verify it in polynomial time by evaluating each clause.</li>\n                        <li><strong>Reduction from Circuit-SAT:</strong> Any boolean circuit can be converted to an equivalent SAT formula in polynomial time.</li>\n                        <li><strong>Completeness:</strong> Since Circuit-SAT is NP-hard and we can reduce it to SAT, SAT is NP-hard.</li>\n                        <li><strong>Conclusion:</strong> SAT is in NP and is NP-hard, therefore it is NP-complete.</li>\n                    </ol>\n                `;\n            } else if (problemType === 'vc') {\n                proof = `\n                    <h3>Proof that Vertex Cover is NP-Complete</h3>\n                    <ol>\n                        <li><strong>Vertex Cover is in NP:</strong> Given a set of vertices, we can verify in polynomial time if it covers all edges.</li>\n                        <li><strong>Reduction from 3SAT:</strong> We can convert any 3SAT problem to a Vertex Cover problem as shown in the reduction steps.</li>\n                        <li><strong>Completeness:</strong> The reduction preserves the answer and runs in polynomial time.</li>\n                        <li><strong>Conclusion:</strong> Vertex Cover is in NP and is NP-hard, therefore it is NP-complete.</li>\n                    </ol>\n                `;\n            } else if (problemType === 'tsp') {\n                proof = `\n                    <h3>Proof that TSP is NP-Complete</h3>\n                    <ol>\n                        <li><strong>TSP is in NP:</strong> Given a tour, we can verify its length in polynomial time.</li>\n                        <li><strong>Reduction from Hamiltonian Cycle:</strong> We can convert any Hamiltonian Cycle problem to TSP as shown in the reduction steps.</li>\n                        <li><strong>Completeness:</strong> The reduction preserves the answer and runs in polynomial time.</li>\n                        <li><strong>Conclusion:</strong> TSP is in NP and is NP-hard, therefore it is NP-complete.</li>\n                    </ol>\n                `;\n            }\n            \n            document.getElementById('proofConstruction').innerHTML = proof;\n        }\n    </script>\n</body>\n</html>"
