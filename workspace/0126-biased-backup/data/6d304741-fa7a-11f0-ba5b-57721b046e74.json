    "content": "<html>\n<head>\n    <title>Mutex Interactive Demonstration</title>\n    <script>\n        let sharedResource = {\n            value: 0,\n            locked: false,\n            owner: null,\n            waitingThreads: []\n        };\n\n        let threads = [];\n        let currentThreadId = 0;\n        let speed = 500;\n        let running = false;\n        let intervalId = null;\n\n        function Thread(id) {\n            this.id = id;\n            this.state = 'ready';\n            this.operations = [];\n            this.currentOp = 0;\n            this.log = [];\n            \n            this.addOperation = function(op) {\n                this.operations.push(op);\n            };\n            \n            this.executeNext = function() {\n                if (this.currentOp >= this.operations.length) {\n                    this.state = 'finished';\n                    return false;\n                }\n                \n                const op = this.operations[this.currentOp];\n                this.log.push(`Executing: ${op}`);\n                \n                if (op === 'lock') {\n                    if (sharedResource.locked && sharedResource.owner !== this.id) {\n                        this.state = 'waiting';\n                        sharedResource.waitingThreads.push(this.id);\n                        this.log.push(`Waiting for mutex (owned by Thread ${sharedResource.owner})`);\n                        return false;\n                    } else {\n                        sharedResource.locked = true;\n                        sharedResource.owner = this.id;\n                        this.log.push(`Acquired mutex`);\n                    }\n                } else if (op === 'unlock') {\n                    if (sharedResource.owner === this.id) {\n                        sharedResource.locked = false;\n                        this.log.push(`Released mutex`);\n                        \n                        if (sharedResource.waitingThreads.length > 0) {\n                            const nextThread = sharedResource.waitingThreads.shift();\n                            sharedResource.owner = nextThread;\n                            sharedResource.locked = true;\n                            threads.find(t => t.id === nextThread).state = 'ready';\n                            this.log.push(`Passed mutex to Thread ${nextThread}`);\n                        } else {\n                            sharedResource.owner = null;\n                        }\n                    }\n                } else if (op === 'read') {\n                    this.log.push(`Read value: ${sharedResource.value}`);\n                } else if (op === 'increment') {\n                    if (sharedResource.owner === this.id) {\n                        sharedResource.value++;\n                        this.log.push(`Incremented value to ${sharedResource.value}`);\n                    } else {\n                        this.log.push(`Failed to increment - don't own mutex`);\n                    }\n                } else if (op === 'decrement') {\n                    if (sharedResource.owner === this.id) {\n                        sharedResource.value--;\n                        this.log.push(`Decremented value to ${sharedResource.value}`);\n                    } else {\n                        this.log.push(`Failed to decrement - don't own mutex`);\n                    }\n                }\n                \n                this.currentOp++;\n                return true;\n            };\n        }\n\n        function addThread() {\n            const thread = new Thread(++currentThreadId);\n            threads.push(thread);\n            updateUI();\n        }\n\n        function removeThread() {\n            if (threads.length > 0) {\n                const thread = threads.pop();\n                if (sharedResource.owner === thread.id) {\n                    sharedResource.locked = false;\n                    sharedResource.owner = null;\n                }\n                updateUI();\n            }\n        }\n\n        function addOperation(threadId, op) {\n            const thread = threads.find(t => t.id === threadId);\n            if (thread) {\n                thread.addOperation(op);\n                updateUI();\n            }\n        }\n\n        function clearThreadOperations(threadId) {\n            const thread = threads.find(t => t.id === threadId);\n            if (thread) {\n                thread.operations = [];\n                thread.currentOp = 0;\n                thread.state = 'ready';\n                updateUI();\n            }\n        }\n\n        function step() {\n            let anyExecuted = false;\n            \n            threads.forEach(thread => {\n                if (thread.state === 'ready') {\n                    if (thread.executeNext()) {\n                        anyExecuted = true;\n                    }\n                }\n            });\n            \n            if (!anyExecuted) {\n                // Check if all threads are finished\n                if (threads.every(t => t.state === 'finished' || \n                    threads.every(t => t.state === 'waiting' && t.currentOp >= t.operations.length)) {\n                    stopExecution();\n                }\n            }\n            \n            updateUI();\n            return anyExecuted;\n        }\n\n        function startExecution() {\n            if (!running) {\n                running = true;\n                intervalId = setInterval(step, speed);\n                document.getElementById('startBtn').disabled = true;\n                document.getElementById('stopBtn').disabled = false;\n                document.getElementById('stepBtn').disabled = true;\n            }\n        }\n\n        function stopExecution() {\n            if (running) {\n                clearInterval(intervalId);\n                running = false;\n                document.getElementById('startBtn').disabled = false;\n                document.getElementById('stopBtn').disabled = true;\n                document.getElementById('stepBtn').disabled = false;\n            }\n        }\n\n        function setSpeed(newSpeed) {\n            speed = 1100 - newSpeed;\n            if (running) {\n                stopExecution();\n                startExecution();\n            }\n        }\n\n        function updateUI() {\n            // Update shared resource display\n            const resourceDiv = document.getElementById('sharedResource');\n            resourceDiv.innerHTML = `\n                <h3>Shared Resource</h3>\n                <p>Value: ${sharedResource.value}</p>\n                <p>Locked: ${sharedResource.locked ? 'Yes (Thread ' + sharedResource.owner + ')' : 'No'}</p>\n                <p>Waiting Threads: ${sharedResource.waitingThreads.join(', ') || 'None'}</p>\n            `;\n            \n            // Update threads display\n            const threadsDiv = document.getElementById('threads');\n            threadsDiv.innerHTML = '<h3>Threads</h3>';\n            \n            threads.forEach(thread => {\n                const threadDiv = document.createElement('div');\n                threadDiv.style.border = '1px solid black';\n                threadDiv.style.margin = '5px';\n                threadDiv.style.padding = '5px';\n                \n                let operationsHtml = thread.operations.map((op, idx) => \n                    `<span style=\"${idx === thread.currentOp && thread.state !== 'finished' ? 'font-weight:bold;' : ''}\">${op}</span>`\n                ).join(' | ');\n                \n                threadDiv.innerHTML = `\n                    <h4>Thread ${thread.id} (${thread.state})</h4>\n                    <p>Operations: ${operationsHtml}</p>\n                    <div>\n                        <button onclick=\"addOperation(${thread.id}, 'lock')\">Add Lock</button>\n                        <button onclick=\"addOperation(${thread.id}, 'unlock')\">Add Unlock</button>\n                        <button onclick=\"addOperation(${thread.id}, 'read')\">Add Read</button>\n                        <button onclick=\"addOperation(${thread.id}, 'increment')\">Add Increment</button>\n                        <button onclick=\"addOperation(${thread.id}, 'decrement')\">Add Decrement</button>\n                        <button onclick=\"clearThreadOperations(${thread.id})\">Clear Operations</button>\n                    </div>\n                    <div style=\"max-height: 100px; overflow-y: auto; border: 1px solid #ccc; padding: 5px;\">\n                        ${thread.log.map(log => `<div>${log}</div>`).reverse().join('')}\n                    </div>\n                `;\n                \n                threadsDiv.appendChild(threadDiv);\n            });\n        }\n    </script>\n</head>\n<body>\n    <h1>Mutex Interactive Demonstration</h1>\n    \n    <div>\n        <button onclick=\"addThread()\">Add Thread</button>\n        <button onclick=\"removeThread()\">Remove Thread</button>\n        <button id=\"startBtn\" onclick=\"startExecution()\">Start Execution</button>\n        <button id=\"stopBtn\" onclick=\"stopExecution()\" disabled>Stop Execution</button>\n        <button id=\"stepBtn\" onclick=\"step()\">Step</button>\n        <div>\n            <label>Speed: </label>\n            <input type=\"range\" min=\"100\" max=\"1000\" value=\"500\" oninput=\"setSpeed(this.value)\">\n        </div>\n    </div>\n    \n    <div id=\"sharedResource\"></div>\n    <div id=\"threads\"></div>\n    \n    <div>\n        <h3>Instructions</h3>\n        <ol>\n            <li>Add one or more threads</li>\n            <li>Add operations to each thread (lock/unlock to control access to shared resource)</li>\n            <li>Run the simulation to see how mutex controls access</li>\n            <li>Watch for deadlocks when threads wait indefinitely</li>\n        </ol>\n        \n        <h3>Key Concepts</h3>\n        <ul>\n            <li><strong>Mutex</strong>: Mutual exclusion lock that prevents simultaneous access</li>\n            <li><strong>Lock</strong>: Thread acquires exclusive access to shared resource</li>\n            <li><strong>Unlock</strong>: Thread releases access to shared resource</li>\n            <li><strong>Deadlock</strong>: When threads wait indefinitely for each other</li>\n        </ul>\n    </div>\n    \n    <script>\n        // Initialize with two threads\n        addThread();\n        addThread();\n        updateUI();\n    </script>\n</body>\n</html>"
