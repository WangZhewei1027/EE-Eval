    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Nearest Neighbors Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    padding: 10px;\n    user-select: none;\n  }\n  #canvas {\n    border: 1px solid black;\n    cursor: crosshair;\n  }\n  label, div {\n    margin-top: 8px;\n    margin-bottom: 4px;\n    display: block;\n  }\n  button, input[type=number], select {\n    font-family: monospace, monospace;\n  }\n  #pointsList {\n    height: 100px;\n    overflow-y: scroll;\n    border: 1px solid black;\n    padding: 4px;\n  }\n  #log {\n    height: 150px;\n    overflow-y: auto;\n    border: 1px solid black;\n    white-space: pre-wrap;\n    font-size: 12px;\n    padding: 4px;\n    margin-top: 8px;\n  }\n</style>\n</head>\n<body>\n\n<h1>K-Nearest Neighbors Interactive Demo</h1>\n\n<div>\n  <label>Mode (how to add points):\n    <select id=\"modeSelect\" title=\"Select adding mode\">\n      <option value=\"classA\">Add Class A Point</option>\n      <option value=\"classB\">Add Class B Point</option>\n      <option value=\"classC\">Add Class C Point</option>\n      <option value=\"query\">Add Query Point</option>\n      <option value=\"remove\">Remove Points (click to remove nearest point)</option>\n      <option value=\"move\">Move Points (drag)</option>\n      <option value=\"none\">No Add/Remove/Move (View Only)</option>\n    </select>\n  </label>\n</div>\n\n<div>\n<label for=\"kInput\">Number of neighbors K:\n  <input type=\"number\" id=\"kInput\" value=\"3\" min=\"1\" max=\"20\" style=\"width: 40px\" title=\"Choose k neighbors\"/>\n</label>\n<button id=\"classifyButton\" title=\"Classify query points based on current points and k\">Classify Query</button>\n<button id=\"clearQueriesButton\" title=\"Remove all query points\">Clear Query Points</button>\n<button id=\"clearAllButton\" title=\"Remove all points\">Clear All Points</button>\n<button id=\"resetButton\" title=\"Reset everything including logs\">Reset All</button>\n</div>\n\n<div>\n<label for=\"distanceMetric\">Distance Metric:\n  <select id=\"distanceMetric\" title=\"Choose distance metric\">\n    <option value=\"euclidean\">Euclidean</option>\n    <option value=\"manhattan\">Manhattan</option>\n    <option value=\"chebyshev\">Chebyshev</option>\n  </select>\n</label>\n</div>\n\n<div>\n<label for=\"weighting\">Weighting Scheme:\n  <select id=\"weighting\" title=\"Choose weighting scheme\">\n    <option value=\"uniform\">Uniform (majority vote)</option>\n    <option value=\"distance\">Distance weighted</option>\n  </select>\n</label>\n</div>\n\n<div>\n  <label>Distance threshold (for weighting scheme):\n    <input type=\"number\" id=\"thresholdInput\" value=\"\" min=\"0\" step=\"0.1\" style=\"width: 60px\" \n    placeholder=\"unlimited\" title=\"Max distance to consider neighbors (empty = no limit)\"/>\n  </label>\n</div>\n\n<canvas id=\"canvas\" width=\"600\" height=\"400\" tabindex=\"0\"\n  aria-label=\"Graph area to add and manipulate points for K-Nearest Neighbors\"></canvas>\n\n<div>\n  <label>Points List (click point ID to remove):\n    <div id=\"pointsList\" tabindex=\"0\" aria-live=\"polite\" aria-relevant=\"additions removals\"></div>\n  </label>\n</div>\n\n<div>\n  <label>Logs and Details:</label>\n  <div id=\"log\" tabindex=\"0\" aria-live=\"polite\" aria-relevant=\"additions\"></div>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n\n  const modeSelect = document.getElementById('modeSelect');\n  const kInput = document.getElementById('kInput');\n  const classifyButton = document.getElementById('classifyButton');\n  const clearQueriesButton = document.getElementById('clearQueriesButton');\n  const clearAllButton = document.getElementById('clearAllButton');\n  const resetButton = document.getElementById('resetButton');\n  const pointsListDiv = document.getElementById('pointsList');\n  const logDiv = document.getElementById('log');\n  const distanceMetricSel = document.getElementById('distanceMetric');\n  const weightingSel = document.getElementById('weighting');\n  const thresholdInput = document.getElementById('thresholdInput');\n\n  // Data structures\n  // Points: array of {id, x, y, classLabel, isQuery, classifiedLabel}\n  // id is unique integer\n  let points = [];\n  let nextPointId = 1;\n\n  // State for drag move mode\n  let dragInfo = null; // {point, offsetX, offsetY} or null\n\n  // Constants for different class labels and colors (colors are just for visualization on canvas)\n  const classColors = {\n    classA: 'black', // we won't use colors but distinguish by shape\n    classB: 'black',\n    classC: 'black',\n    query: 'black',\n  };\n\n  // Shape mapping:\n  // classA: circle\n  // classB: square\n  // classC: triangle\n  // query: diamond\n  // classifiedQuery: same shape as query, but with label drawn next to it\n\n  // Util functions:\n\n  function log(msg) {\n    const time = new Date().toLocaleTimeString();\n    logDiv.textContent += `[${time}] ${msg}\\n`;\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  // Distance functions\n\n  function getDistance(p1, p2, metric) {\n    const dx = p1.x - p2.x;\n    const dy = p1.y - p2.y;\n    switch(metric) {\n      case 'euclidean': return Math.sqrt(dx*dx + dy*dy);\n      case 'manhattan': return Math.abs(dx) + Math.abs(dy);\n      case 'chebyshev': return Math.max(Math.abs(dx), Math.abs(dy));\n      default: return Math.sqrt(dx*dx + dy*dy);\n    }\n  }\n\n  // Draw functions\n\n  function clearCanvas() {\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n  }\n\n  function drawPoint(pt, highlight=false) {\n    const size = 6;\n    ctx.lineWidth = 1;\n    ctx.strokeStyle = 'black';\n    ctx.fillStyle = 'black';\n    const x = pt.x;\n    const y = pt.y;\n\n    // Choose shape by class\n    switch(pt.classLabel) {\n      case 'classA':\n        // circle\n        ctx.beginPath();\n        ctx.arc(x,y,size,0,Math.PI*2);\n        ctx.stroke();\n        if (highlight) {\n          ctx.beginPath();\n          ctx.arc(x,y,size-2,0,Math.PI*2);\n          ctx.fill();\n        }\n        break;\n      case 'classB':\n        // square\n        ctx.beginPath();\n        ctx.rect(x - size, y - size, size*2, size*2);\n        ctx.stroke();\n        if (highlight) {\n          ctx.fillRect(x - size +2, y - size +2, size*2 - 4, size*2 -4);\n        }\n        break;\n      case 'classC':\n        // triangle upward\n        ctx.beginPath();\n        ctx.moveTo(x, y - size);\n        ctx.lineTo(x - size, y + size);\n        ctx.lineTo(x + size, y + size);\n        ctx.closePath();\n        ctx.stroke();\n        if (highlight) {\n          ctx.beginPath();\n          ctx.moveTo(x, y - size +2);\n          ctx.lineTo(x - size +2, y + size -2);\n          ctx.lineTo(x + size -2, y + size -2);\n          ctx.closePath();\n          ctx.fill();\n        }\n        break;\n      case 'query':\n        // diamond rotated square\n        ctx.beginPath();\n        ctx.moveTo(x, y - size);\n        ctx.lineTo(x - size, y);\n        ctx.lineTo(x, y + size);\n        ctx.lineTo(x + size, y);\n        ctx.closePath();\n        ctx.stroke();\n        if (highlight) {\n          ctx.beginPath();\n          ctx.moveTo(x, y - size +2);\n          ctx.lineTo(x - size +2, y);\n          ctx.lineTo(x, y + size -2);\n          ctx.lineTo(x + size -2, y);\n          ctx.closePath();\n          ctx.fill();\n        }\n        break;\n      default:\n        // fallback circle\n        ctx.beginPath();\n        ctx.arc(x,y,size,0,Math.PI*2);\n        ctx.stroke();\n        break;\n    }\n\n    // For query points, if classifiedLabel exists, print label next to point\n    if (pt.isQuery && pt.classifiedLabel) {\n      ctx.font = '12px monospace';\n      ctx.textBaseline = 'middle';\n      ctx.fillText(pt.classifiedLabel, x + size + 4, y);\n    }\n  }\n\n  // Draw points and optionally highlight query points or nearest neighbors\n\n  function drawAllPoints(highlightIds=[]) {\n    clearCanvas();\n    // Draw all normal points first (non-query)\n    for (const pt of points) {\n      if (!pt.isQuery) {\n        drawPoint(pt, highlightIds.includes(pt.id));\n      }\n    }\n    // Then draw query points on top\n    for (const pt of points) {\n      if (pt.isQuery) {\n        drawPoint(pt, highlightIds.includes(pt.id));\n      }\n    }\n  }\n\n  // Find nearest neighbors for one query point\n\n  function findNeighbors(queryPt, k, metric, threshold=null) {\n    // Return array of {point, distance}\n    // Filter points to only non query points\n    const nonQueryPts = points.filter(p => !p.isQuery);\n    if (nonQueryPts.length === 0) {\n      return [];\n    }\n    let dists = nonQueryPts\n      .map(p => ({point: p, distance: getDistance(queryPt, p, metric)}))\n      .filter(d => (threshold === null || d.distance <= threshold));\n    dists.sort((a,b) => a.distance - b.distance);\n    return dists.slice(0,k);\n  }\n\n  // Classify one query point\n\n  function classifyPoint(queryPt, k, metric, weighting, threshold) {\n    // neighbors is list of {point, distance}\n    const neighbors = findNeighbors(queryPt, k, metric, threshold);\n\n    if (neighbors.length === 0) {\n      return null;\n    }\n\n    // Tally votes\n    const voteCounts = {}; // classLabel -> score\n    for (const neighbor of neighbors) {\n      const cls = neighbor.point.classLabel;\n      if (!(cls in voteCounts)) voteCounts[cls] = 0;\n      if (weighting === 'distance') {\n        // weight = 1 / (distance + epsilon), closer stronger\n        // but if distance=0, means identical point, assign large weight\n        const w = neighbor.distance === 0 ? 1e9 : 1 / neighbor.distance;\n        voteCounts[cls] += w;\n      } else {\n        // uniform vote\n        voteCounts[cls] += 1;\n      }\n    }\n    // Find max vote score(s)\n    let maxScore = -Infinity;\n    let winners = [];\n    for (const [cls,v] of Object.entries(voteCounts)) {\n      if (v > maxScore) {\n        maxScore = v;\n        winners = [cls];\n      } else if (v === maxScore) {\n        winners.push(cls);\n      }\n    }\n    if (winners.length === 1) {\n      return winners[0];\n    } else {\n      // Tie -> pick one alphabetically stable\n      winners.sort();\n      return winners[0];\n    }\n  }\n\n  // Update points list display\n\n  function updatePointsList() {\n    pointsListDiv.innerHTML = '';\n    if(points.length === 0) {\n      pointsListDiv.textContent = 'No points in dataset.';\n      return;\n    }\n    for (const pt of points) {\n      const span = document.createElement('span');\n      span.textContent = `[${pt.id}] `;\n      span.style.cursor = 'pointer';\n      span.title = `Remove this point (ID: ${pt.id}, class: ${pt.classLabel}${pt.isQuery ? ', query' : ''})`;\n      // Add color-coded label representation in text (no color but show shape)\n      let shapeDesc = \"\";\n      switch(pt.classLabel) {\n        case 'classA': shapeDesc = \"Circle\"; break;\n        case 'classB': shapeDesc = \"Square\"; break;\n        case 'classC': shapeDesc = \"Triangle\"; break;\n        case 'query': shapeDesc = \"Diamond\"; break;\n      }\n      span.textContent += `${shapeDesc} (${pt.isQuery ? 'Query' : pt.classLabel}) @ (${pt.x.toFixed(1)},${pt.y.toFixed(1)})`;\n      span.style.userSelect = \"none\";\n\n      // Remove on click\n      span.addEventListener('click', () => {\n        const confirmed = confirm(`Remove point ID ${pt.id}?`);\n        if(confirmed) {\n          points = points.filter(p => p.id !== pt.id);\n          log(`Point ID ${pt.id} removed.`);\n          classifyQueriesIfAny(false);\n          updatePointsList();\n          drawAllPoints();\n        }\n      });\n      pointsListDiv.appendChild(span);\n      pointsListDiv.appendChild(document.createElement('br'));\n    }\n  }\n\n  // Classify query points and update display\n\n  function classifyQueriesIfAny(reportLog=true) {\n    const k = parseInt(kInput.value);\n    if (isNaN(k) || k < 1) {\n      if (reportLog) log(\"Invalid k. Please enter a positive integer.\");\n      return;\n    }\n\n    const thresholdVal = thresholdInput.value.trim();\n    let threshold = null;\n    if (thresholdVal !== \"\") {\n      const n = parseFloat(thresholdVal);\n      if (!isNaN(n) && n >= 0) {\n        threshold = n;\n      } else {\n        if (reportLog) log('Invalid threshold: Must be a number >= 0 or empty.');\n        return;\n      }\n    }\n    const metric = distanceMetricSel.value;\n    const weighting = weightingSel.value;\n\n    const queryPoints = points.filter(p => p.isQuery);\n    if(queryPoints.length === 0) {\n      if(reportLog) log('No query points to classify.');\n      return;\n    }\n    if(points.filter(p=>!p.isQuery).length === 0) {\n      if(reportLog) log('No base points in dataset. Add some class points first.');\n      return;\n    }\n    for (const qp of queryPoints) {\n      const assignedLabel = classifyPoint(qp, k, metric, weighting, threshold);\n      qp.classifiedLabel = assignedLabel ? assignedLabel : \"Unclassified\";\n      if(reportLog) {\n        const neighbors = findNeighbors(qp, k, metric, threshold);\n        log(`Query ID ${qp.id} classified as: ${qp.classifiedLabel}. Near neighbors: ${neighbors.map(n => n.point.id + \"(\" + n.point.classLabel + \") dist:\" + n.distance.toFixed(1)).join(\", \")}`);\n      }\n    }\n    drawAllPoints(queryPoints.map(p=>p.id));\n    updatePointsList();\n  }\n\n  // Handle canvas events\n\n  canvas.addEventListener('mousedown', e => {\n    const rect = canvas.getBoundingClientRect();\n    const mouseX = e.clientX - rect.left;\n    const mouseY = e.clientY - rect.top;\n    const mode = modeSelect.value;\n\n    if (mode === 'move') {\n      // Attempt to start dragging nearest point if close\n      const pt = findNearestPoint(mouseX, mouseY, 10);\n      if (pt) {\n        dragInfo = {\n          point: pt,\n          offsetX: pt.x - mouseX,\n          offsetY: pt.y - mouseY\n        };\n      }\n    } else if (mode === 'remove') {\n      // Remove nearest point if close\n      const pt = findNearestPoint(mouseX, mouseY, 10);\n      if (pt) {\n        const confirmed = confirm(`Remove point ID ${pt.id}?`);\n        if(confirmed) {\n          points = points.filter(p => p.id !== pt.id);\n          log(`Point ID ${pt.id} removed.`);\n          classifyQueriesIfAny(false);\n          updatePointsList();\n          drawAllPoints();\n        }\n      } else {\n        log('No point near click to remove.');\n      }\n    } else if (mode === 'none') {\n      // Do nothing\n      return;\n    } else {\n      // Add point of selected class or query at click position\n      const classLabel = mode;\n      if(!['classA','classB','classC','query'].includes(classLabel)) return;\n      // For query, clear classifiedLabel if added anew\n      const newPoint = {\n        id: nextPointId++,\n        x: mouseX,\n        y: mouseY,\n        classLabel,\n        isQuery: (classLabel === 'query'),\n        classifiedLabel: null\n      };\n      points.push(newPoint);\n      log(`Added ${classLabel}${newPoint.isQuery ? ' (query)' : ''} point ID ${newPoint.id} at (${mouseX.toFixed(1)},${mouseY.toFixed(1)}).`);\n      classifyQueriesIfAny(false);\n      updatePointsList();\n      drawAllPoints();\n    }\n  });\n\n  canvas.addEventListener('mousemove', e => {\n    if(!dragInfo) return;\n    const rect = canvas.getBoundingClientRect();\n    const mouseX = e.clientX - rect.left;\n    const mouseY = e.clientY - rect.top;\n    const pt = dragInfo.point;\n    pt.x = mouseX + dragInfo.offsetX;\n    if(pt.x < 0) pt.x = 0;\n    if(pt.x > canvas.width) pt.x = canvas.width;\n    pt.y = mouseY + dragInfo.offsetY;\n    if(pt.y < 0) pt.y = 0;\n    if(pt.y > canvas.height) pt.y = canvas.height;\n    classifyQueriesIfAny(false);\n    updatePointsList();\n    drawAllPoints();\n  });\n\n  canvas.addEventListener('mouseup', e => {\n    if(dragInfo) {\n      log(`Moved point ID ${dragInfo.point.id} to (${dragInfo.point.x.toFixed(1)},${dragInfo.point.y.toFixed(1)}).`);\n    }\n    dragInfo = null;\n  });\n\n  canvas.addEventListener('mouseleave', e => {\n    dragInfo = null;\n  });\n\n  // Near point finder: returns point within maxDist or null\n\n  function findNearestPoint(x,y,maxDist) {\n    if(points.length===0) return null;\n    let nearest = null;\n    let nearestDist = maxDist+1;\n    for(const pt of points) {\n      const dist = Math.hypot(pt.x - x, pt.y - y);\n      if(dist<=maxDist && dist < nearestDist) {\n        nearest = pt;\n        nearestDist = dist;\n      }\n    }\n    return nearest;\n  }\n\n  // Button handlers\n\n  classifyButton.addEventListener('click', () => {\n    classifyQueriesIfAny(true);\n  });\n\n  clearQueriesButton.addEventListener('click', () => {\n    let removedCount = 0;\n    points = points.filter(p => {\n      if(p.isQuery) {\n        removedCount++;\n        return false;\n      }\n      return true;\n    });\n    log(`Removed ${removedCount} query point(s).`);\n    updatePointsList();\n    drawAllPoints();\n  });\n\n  clearAllButton.addEventListener('click', () => {\n    const conf = confirm('Remove ALL points from the dataset?');\n    if(conf) {\n      points = [];\n      log('All points removed.');\n      updatePointsList();\n      drawAllPoints();\n    }\n  });\n\n  resetButton.addEventListener('click', () => {\n    const conf = confirm('Reset everything including logs, points, and settings?');\n    if(conf) {\n      points = [];\n      nextPointId = 1;\n      logDiv.textContent = '';\n      modeSelect.value = 'classA';\n      kInput.value = '3';\n      distanceMetricSel.value = 'euclidean';\n      weightingSel.value = 'uniform';\n      thresholdInput.value = '';\n      updatePointsList();\n      drawAllPoints();\n      log('System reset.');\n    }\n  });\n\n  // Input change handlers to reclassify queries when relevant\n\n  kInput.addEventListener('input', () => {\n    classifyQueriesIfAny(false);\n  });\n\n  distanceMetricSel.addEventListener('change', () => {\n    classifyQueriesIfAny(false);\n  });\n\n  weightingSel.addEventListener('change', () => {\n    classifyQueriesIfAny(false);\n  });\n\n  thresholdInput.addEventListener('input', () => {\n    classifyQueriesIfAny(false);\n  });\n\n  // Initialization\n\n  function initExampleData() {\n    points = [\n      // Class A points (circles)\n      {id: nextPointId++, x: 100, y: 80, classLabel: 'classA', isQuery:false, classifiedLabel:null},\n      {id: nextPointId++, x: 130, y: 120, classLabel: 'classA', isQuery:false, classifiedLabel:null},\n      {id: nextPointId++, x: 90, y: 150, classLabel: 'classA', isQuery:false, classifiedLabel:null},\n\n      // Class B points (squares)\n      {id: nextPointId++, x: 300, y: 100, classLabel: 'classB', isQuery:false, classifiedLabel:null},\n      {id: nextPointId++, x: 320, y: 140, classLabel: 'classB', isQuery:false, classifiedLabel:null},\n      {id: nextPointId++, x: 270, y: 130, classLabel: 'classB', isQuery:false, classifiedLabel:null},\n\n      // Class C points (triangles)\n      {id: nextPointId++, x: 200, y: 300, classLabel: 'classC', isQuery:false, classifiedLabel:null},\n      {id: nextPointId++, x: 230, y: 350, classLabel: 'classC', isQuery:false, classifiedLabel:null},\n      {id: nextPointId++, x: 180, y: 360, classLabel: 'classC', isQuery:false, classifiedLabel:null},\n\n      // Query points (diamonds)\n      {id: nextPointId++, x: 150, y: 150, classLabel: 'query', isQuery:true, classifiedLabel: null},\n      {id: nextPointId++, x: 280, y: 125, classLabel: 'query', isQuery:true, classifiedLabel: null},\n      {id: nextPointId++, x: 210, y: 330, classLabel: 'query', isQuery:true, classifiedLabel: null},\n    ];\n  }\n\n  // Setup on load\n\n  function setup() {\n    initExampleData();\n    updatePointsList();\n    classifyQueriesIfAny(false);\n    drawAllPoints();\n    log('Initialized with example data.');\n  }\n\n  setup();\n\n})();\n</script>\n\n</body>\n</html>"
  },
