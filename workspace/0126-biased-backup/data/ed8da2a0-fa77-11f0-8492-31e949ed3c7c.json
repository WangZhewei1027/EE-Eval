    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Search Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #1e1e2f;\n            color: #ffffff;\n            margin: 0;\n            padding: 20px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n\n        .container {\n            text-align: center;\n            max-width: 800px;\n            background-color: #2b2b3d;\n            border-radius: 15px;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);\n            padding: 40px;\n            overflow: hidden;\n            position: relative;\n        }\n\n        h1 {\n            font-size: 3em;\n            margin-bottom: 20px;\n            color: #66fcf1;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);\n        }\n\n        .search-container {\n            display: flex;\n            justify-content: center;\n            margin: 20px 0;\n        }\n\n        .number {\n            width: 50px;\n            height: 50px;\n            background-color: #f9a69b;\n            color: #1e1e2f;\n            border-radius: 10px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 1.5em;\n            margin: 0 5px;\n            transition: transform 0.3s, background-color 0.3s;\n        }\n\n        .highlight {\n            background-color: #66fcf1;\n            transform: scale(1.2);\n        }\n\n        .button {\n            background-color: #66fcf1;\n            color: #1e1e2f;\n            border: none;\n            padding: 15px 30px;\n            border-radius: 5px;\n            font-size: 1.2em;\n            cursor: pointer;\n            transition: background-color 0.3s, transform 0.3s;\n        }\n\n        .button:hover {\n            background-color: #5fb8b8;\n            transform: scale(1.05);\n        }\n\n        .button:disabled {\n            background-color: #555;\n            cursor: not-allowed;\n        }\n\n        .visual {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <h1>Linear Search Visualization</h1>\n        <div class=\"search-container\">\n            <div class=\"number\" id=\"num0\">3</div>\n            <div class=\"number\" id=\"num1\">8</div>\n            <div class=\"number\" id=\"num2\">1</div>\n            <div class=\"number\" id=\"num3\">7</div>\n            <div class=\"number\" id=\"num4\">4</div>\n            <div class=\"number\" id=\"num5\">5</div>\n        </div>\n        <button class=\"button\" id=\"startButton\">Start Search</button>\n    </div>\n\n    <script>\n        const numbers = document.querySelectorAll('.number');\n        const target = 7; // Target we are searching for\n        let index = 0;\n\n        document.getElementById('startButton').addEventListener('click', function () {\n            this.disabled = true; // Disable the button during the search\n            linearSearch();\n        });\n\n        function linearSearch() {\n            if (index < numbers.length) {\n                const currentNumber = numbers[index];\n                currentNumber.classList.add('highlight');\n\n                setTimeout(() => {\n                    if (parseInt(currentNumber.textContent) === target) {\n                        alert(`Found ${target} at index ${index}!`);\n                    } else {\n                        currentNumber.classList.remove('highlight');\n                        index++;\n                        linearSearch(); // Move to the next number\n                    }\n                }, 1000);\n            } else {\n                alert(`${target} not found in the array.`);\n                document.getElementById('startButton').disabled = false; // Enable button again\n                index = 0; // Reset index for next search\n            }\n        }\n    </script>\n</body>\n\n</html>"
