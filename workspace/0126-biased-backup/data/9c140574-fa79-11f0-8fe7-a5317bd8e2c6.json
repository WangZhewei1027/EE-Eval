running && !confirm(\"Stop running to jump to index?\")) return;\n    stopRunning();\n    snapshot();\n    state.index = idx;\n    log(\"Jumped to index \" + idx + \" for trace.\");\n    updateAll();\n  });\n\n  highlightRange.addEventListener('click', ()=>{\n    const a = Number(startIndex.value) || 0;\n    const b = Number(endIndex.value) || 0;\n    alert(\"Range to highlight: [\" + a + \",\" + b + \"]. (Cells in this demo are plain; use visual inspection.)\");\n  });\n\n  // Utility: initialize with default array\n  function initDefaults(){\n    state.array = [];\n    const n = Number(sizeNumber.value) || 10;\n    for(let i=0;i<n;i++) state.array.push(i*1);\n    state.start = 0;\n    state.end = Math.max(0, state.array.length-1);\n    state.index = state.start;\n    state.targets = parseTargets();\n    updateAll();\n  }\n\n  // When target input changes, reflect immediate parse (but do not reinitialize)\n  targetInput.addEventListener('change', ()=> {\n    state.targets = parseTargets();\n    log(\"Targets set to: [\" + state.targets.join(', ') + \"]\");\n    renderState();\n  });\n\n  modeSelect.addEventListener('change', ()=> { state.mode = modeSelect.value; renderState(); });\n  directionSelect.addEventListener('change', ()=> { state.direction = directionSelect.value; renderState(); });\n\n  // Keep a fallback handler for window unload to stop timers\n  window.addEventListener('beforeunload', ()=> { if(runInterval) clearInterval(runInterval); });\n\n  // Initialize\n  initDefaults();\n  log(\"Demo ready. Click 'Generate random array' or edit array and set a target, then Run or Step.\");\n})();\n</script>\n\n</body>\n</html>"
