  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Linear Search — Interactive Demonstration</title>\n<style>\n  /* Minimal plain styling: keep everything black on white, basic layout only */\n  html,body { margin:10px; padding:10px; font-family:monospace; color:black; background:white;}\n  button,input,select,textarea { font:inherit; }\n  .row { margin:6px 0; }\n  .label { display:inline-block; width:140px; }\n  #arrayDisplay { white-space:nowrap; margin:8px 0; }\n  .cell { display:inline-block; min-width:36px; padding:6px; margin:2px; border:1px solid #000; text-align:center; cursor:pointer; }\n  .cell.current { outline:3px solid; }\n  .cell.found { font-weight:bold; text-decoration:underline; }\n  #log { width:100%; height:160px; }\n  textarea { width:100%; height:80px; }\n  fieldset { margin:8px 0; padding:8px; }\n  .small { font-size:12px; }\n</style>\n</head>\n<body>\n\n<h2>Linear Search — Interactive Demonstration</h2>\n\n<div class=\"row\">\n  <span class=\"label\">Array size</span>\n  <input type=\"range\" id=\"sizeSlider\" min=\"0\" max=\"50\" value=\"10\">\n  <input id=\"sizeNumber\" type=\"number\" min=\"0\" max=\"50\" value=\"10\" style=\"width:60px\">\n  <button id=\"applySize\">Apply size</button>\n</div>\n\n<div class=\"row\">\n  <span class=\"label\">Value range (min/max)</span>\n  <input id=\"minValue\" type=\"number\" style=\"width:70px\" value=\"0\">\n  <input id=\"maxValue\" type=\"number\" style=\"width:70px\" value=\"99\">\n  <button id=\"generate\">Generate random array</button>\n  <button id=\"shuffle\">Shuffle</button>\n  <button id=\"presetWorst\">Preset: Worst-case</button>\n  <button id=\"presetBest\">Preset: Best-case</button>\n</div>\n\n<fieldset>\n<legend>Array (click cell to edit; double-click to set empty)</legend>\n<div id=\"arrayDisplay\"></div>\n<div class=\"row\">\n  <span class=\"label\">Quick edit (CSV)</span>\n  <textarea id=\"arrayText\"></textarea>\n  <div class=\"row\">\n    <button id=\"applyText\">Apply CSV to array</button>\n    <button id=\"exportJSON\">Export JSON</button>\n    <button id=\"importJSON\">Import JSON</button>\n    <button id=\"clearArray\">Clear</button>\n  </div>\n</div>\n</fieldset>\n\n<fieldset>\n<legend>Search Target & Mode</legend>\n<div class=\"row\">\n  <span class=\"label\">Target value(s)</span>\n  <input id=\"targetInput\" type=\"text\" value=\"42\" style=\"width:240px\">\n  <span class=\"small\"> (comma-separated values allowed)</span>\n</div>\n<div class=\"row\">\n  <span class=\"label\">Mode</span>\n  <select id=\"modeSelect\">\n    <option value=\"first\">First match (stop when found)</option>\n    <option value=\"all\">All matches</option>\n    <option value=\"count\">Count only (returns number)</option>\n    <option value=\"exists\">Exists? (boolean)</option>\n  </select>\n  <span style=\"margin-left:12px;\" class=\"small\">Direction</span>\n  <select id=\"directionSelect\">\n    <option value=\"ltr\">Left → Right (index 0 → n-1)</option>\n    <option value=\"rtl\">Right → Left (n-1 → 0)</option>\n  </select>\n</div>\n<div class=\"row\">\n  <span class=\"label\">Search range (inclusive)</span>\n  <input id=\"startIndex\" type=\"number\" style=\"width:60px\" value=\"0\">\n  <input id=\"endIndex\" type=\"number\" style=\"width:60px\" value=\"9\">\n  <button id=\"autoRange\">Auto-range to array</button>\n</div>\n</fieldset>\n\n<fieldset>\n<legend>Execution Controls</legend>\n<div class=\"row\">\n  <button id=\"reset\">Reset</button>\n  <button id=\"stepBack\">Step ←</button>\n  <button id=\"stepForward\">Step →</button>\n  <button id=\"runToggle\">Run</button>\n  <button id=\"runToNext\">Run to next match</button>\n  <button id=\"runToFound\">Run to first found</button>\n  <button id=\"abort\">Abort</button>\n</div>\n<div class=\"row\">\n  <span class=\"label\">Speed (ms per step)</span>\n  <input id=\"speed\" type=\"range\" min=\"20\" max=\"2000\" value=\"400\">\n  <input id=\"speedNumber\" type=\"number\" style=\"width:70px\" min=\"20\" max=\"2000\" value=\"400\">\n</div>\n<div class=\"row\">\n  <span class=\"label\">Step size</span>\n  <input id=\"stepSize\" type=\"number\" style=\"width:70px\" min=\"1\" value=\"1\">\n  <span class=\"small\"> (how many indices to advance per step)</span>\n</div>\n<div class=\"row\">\n  <span class=\"label\">Controls</span>\n  <button id=\"undo\">Undo last step</button>\n  <button id=\"clearLog\">Clear log</button>\n  <button id=\"copyArray\">Copy array to clipboard</button>\n</div>\n</fieldset>\n\n<fieldset>\n<legend>State & Metrics</legend>\n<div class=\"row\"><span class=\"label\">State</span><span id=\"stateDisplay\">idle</span></div>\n<div class=\"row\"><span class=\"label\">Current index</span><span id=\"currentIndex\">-</span></div>\n<div class=\"row\"><span class=\"label\">Comparisons</span><span id=\"comparisons\">0</span></div>\n<div class=\"row\"><span class=\"label\">Matches found</span><span id=\"matchesFound\">0</span></div>\n<div class=\"row\"><span class=\"label\">Found indices</span><span id=\"foundList\">[]</span></div>\n<div class=\"row\"><span class=\"label\">Steps taken</span><span id=\"stepsTaken\">0</span></div>\n</fieldset>\n\n<fieldset>\n<legend>Execution Log (chronological)</legend>\n<div class=\"row\">\n  <textarea id=\"log\" readonly></textarea>\n</div>\n</fieldset>\n\n<fieldset>\n<legend>Interactive Exploration Tools</legend>\n<div class=\"row\">\n  <button id=\"simulateBest\">Simulate Best-case</button>\n  <button id=\"simulateWorst\">Simulate Worst-case</button>\n  <button id=\"simulateAverage\">Simulate Random (average)</button>\n  <button id=\"explainStep\">Explain current step</button>\n</div>\n<div class=\"row\">\n  <span class=\"label\">Search trace</span>\n  <input id=\"traceIndex\" type=\"number\" style=\"width:70px\" value=\"0\">\n  <button id=\"goToIndex\">Go to index (for trace)</button>\n  <button id=\"highlightRange\">Highlight range</button>\n</div>\n</fieldset>\n\n<script>\n(function(){\n  // State\n  const state = {\n    array: [],\n    index: -1,\n    comparisons: 0,\n    matches: [],\n    steps: 0,\n    running: false,\n    paused: false,\n    mode: 'first',\n    direction: 'ltr',\n    speed: 400,\n    stepSize: 1,\n    start: 0,\n    end: -1,\n    targets: [],\n    history: [], // snapshots for undo/history stepping\n    log: [],\n    autoAbortOnEdit: true\n  };\n\n  // UI elements\n  const el = id => document.getElementById(id);\n  const sizeSlider = el('sizeSlider'), sizeNumber = el('sizeNumber'), applySize = el('applySize');\n  const minValue = el('minValue'), maxValue = el('maxValue'), generateBtn = el('generate'), shuffleBtn = el('shuffle');\n  const presetWorst = el('presetWorst'), presetBest = el('presetBest');\n  const arrayDisplay = el('arrayDisplay'), arrayText = el('arrayText'), applyText = el('applyText');\n  const exportJSON = el('exportJSON'), importJSON = el('importJSON'), clearArray = el('clearArray');\n  const targetInput = el('targetInput'), modeSelect = el('modeSelect'), directionSelect = el('directionSelect');\n  const startIndex = el('startIndex'), endIndex = el('endIndex'), autoRange = el('autoRange');\n  const resetBtn = el('reset'), stepBack = el('stepBack'), stepForward = el('stepForward'), runToggle = el('runToggle');\n  const runToNext = el('runToNext'), runToFound = el('runToFound'), abortBtn = el('abort');\n  const speed = el('speed'), speedNumber = el('speedNumber'), stepSizeEl = el('stepSize');\n  const undoBtn = el('undo'), clearLog = el('clearLog'), copyArray = el('copyArray');\n  const stateDisplay = el('stateDisplay'), currentIndexEl = el('currentIndex');\n  const comparisonsEl = el('comparisons'), matchesFoundEl = el('matchesFound'), foundListEl = el('foundList'), stepsTakenEl = el('stepsTaken');\n  const logEl = el('log');\n  const simulateBest = el('simulateBest'), simulateWorst = el('simulateWorst'), simulateAverage = el('simulateAverage'), explainStep = el('explainStep');\n  const traceIndex = el('traceIndex'), goToIndex = el('goToIndex'), highlightRange = el('highlightRange');\n\n  // Helpers\n  function log(message){\n    const t = new Date().toISOString().slice(11,23);\n    state.log.push(`${t} - ${message}`);\n    renderLog();\n  }\n  function renderLog(){\n    logEl.value = state.log.join(\"\\n\");\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n  function snapshot(){\n    // Push a deep snapshot for undo\n    state.history.push({\n      array: state.array.slice(),\n      index: state.index,\n      comparisons: state.comparisons,\n      matches: state.matches.slice(),\n      steps: state.steps,\n      mode: state.mode,\n      direction: state.direction,\n      start: state.start,\n      end: state.end,\n      targets: state.targets.slice()\n    });\n    if(state.history.length > 200) state.history.shift();\n  }\n  function applySnapshot(snap){\n    state.array = snap.array.slice();\n    state.index = snap.index;\n    state.comparisons = snap.comparisons;\n    state.matches = snap.matches.slice();\n    state.steps = snap.steps;\n    state.mode = snap.mode;\n    state.direction = snap.direction;\n    state.start = snap.start;\n    state.end = snap.end;\n    state.targets = snap.targets.slice();\n    state.running = false;\n    state.paused = false;\n    updateAll();\n  }\n  function undo(){\n    if(state.history.length === 0) { log(\"Nothing to undo.\"); return; }\n    const s = state.history.pop();\n    applySnapshot(s);\n    log(\"Undid last change.\");\n  }\n\n  function updateAll(){\n    renderArray();\n    renderState();\n    renderLog();\n  }\n\n  function renderArray(){\n    arrayDisplay.innerHTML = '';\n    const n = state.array.length;\n    for(let i=0;i<n;i++){\n      const v = state.array[i];\n      const div = document.createElement('div');\n      div.className = 'cell';\n      if(i === state.index) div.className += ' current';\n      if(state.matches.indexOf(i) !== -1) div.className += ' found';\n      div.dataset.index = i;\n      div.textContent = (v === undefined || v === null || v === '') ? '·' : String(v);\n      div.title = 'Index ' + i;\n      div.addEventListener('click', onCellClick);\n      div.addEventListener('dblclick', onCellDblClick);\n      arrayDisplay.appendChild(div);\n    }\n    // Update auto-range inputs limits\n    startIndex.min = 0;\n    startIndex.max = Math.max(0,n-1);\n    endIndex.min = 0;\n    endIndex.max = Math.max(0,n-1);\n    if(state.end === -1) state.end = Math.max(0,n-1);\n  }\n\n  function onCellClick(e){\n    const idx = Number(e.currentTarget.dataset.index);\n    // If running, ask to stop or queue edit\n    if(state.running){\n      const ok = confirm(\"Search is running. Stop and edit the array? (Cancel to skip)\");\n      if(!ok) return;\n      stopRunning();\n    }\n    const newVal = prompt(\"Enter new integer value for index \" + idx + \" (leave blank for empty):\", String(state.array[idx]));\n    if(newVal === null) return;\n    snapshot();\n    if(newVal.trim() === '') {\n      state.array[idx] = '';\n    } else {\n      const parsed = Number(newVal.trim());\n      if(Number.isNaN(parsed)) {\n        alert(\"Invalid number. Edit cancelled.\");\n        return;\n      }\n      state.array[idx] = parsed;\n    }\n    log(\"Edited index \" + idx + \" -> \" + state.array[idx]);\n    updateAll();\n  }\n\n  function onCellDblClick(e){\n    const idx = Number(e.currentTarget.dataset.index);\n    snapshot();\n    state.array[idx] = '';\n    log(\"Cleared index \" + idx);\n    updateAll();\n  }\n\n  function renderState(){\n    stateDisplay.textContent = state.running ? (state.paused ? 'paused' : 'running') : 'idle';\n    currentIndexEl.textContent = state.index >=0 ? state.index : '-';\n    comparisonsEl.textContent = state.comparisons;\n    matchesFoundEl.textContent = state.matches.length;\n    foundListEl.textContent = '[' + state.matches.join(', ') + ']';\n    stepsTakenEl.textContent = state.steps;\n    sizeSlider.value = state.array.length;\n    sizeNumber.value = state.array.length;\n    speed.value = state.speed;\n    speedNumber.value = state.speed;\n    stepSizeEl.value = state.stepSize;\n    modeSelect.value = state.mode;\n    directionSelect.value = state.direction;\n    startIndex.value = state.start;\n    endIndex.value = state.end;\n    targetInput.value = state.targets.join(', ');\n  }\n\n  function parseTargets(){\n    const txt = targetInput.value;\n    if(txt.trim() === '') return [];\n    return txt.split(',').map(s => {\n      const t = s.trim();\n      if(t === '') return '';\n      const num = Number(t);\n      return Number.isNaN(num) ? t : num;\n    });\n  }\n\n  // Algorithm step logic\n  function initializeSearch(pushHistory=true){\n    if(pushHistory) snapshot();\n    state.targets = parseTargets();\n    state.mode = modeSelect.value;\n    state.direction = directionSelect.value;\n    state.speed = Number(speed.value);\n    state.stepSize = Math.max(1, Number(stepSizeEl.value) || 1);\n    state.start = clamp(Number(startIndex.value) || 0, 0, Math.max(0, state.array.length-1));\n    state.end = clamp(Number(endIndex.value) || 0, 0, Math.max(0, state.array.length-1));\n    // Normalize start/end according to direction: we still allow search on arbitrary range\n    // Set index to start side depending on direction:\n    state.index = (state.direction === 'ltr') ? state.start : state.end;\n    state.comparisons = 0;\n    state.matches = [];\n    state.steps = 0;\n    state.running = false;\n    state.paused = false;\n    updateAll();\n    log(`Initialized search. Mode=${state.mode}, Direction=${state.direction}, Targets=[${state.targets.join(', ')}], Range=[${state.start},${state.end}]`);\n  }\n\n  function clamp(v,a,b){ return Math.max(a, Math.min(b, v)); }\n\n  function stepForwardOnce(){\n    // One atomic step: compare current index to all targets, update matches and counters\n    if(!inRange(state.index)) {\n      // Out of range: finish\n      state.running = false;\n      state.paused = false;\n      log(\"Index out of range. Search finished.\");\n      updateAll();\n      return false;\n    }\n    snapshot();\n    state.steps++;\n    const currentValue = state.array[state.index];\n    let matched = false;\n    for(const t of state.targets){\n      state.comparisons++;\n      if(currentValue === t){\n        matched = true;\n        if(state.matches.indexOf(state.index) === -1) state.matches.push(state.index);\n        log(`Compare index ${state.index}: ${currentValue} == ${t} → match`);\n        if(state.mode === 'first' || state.mode === 'exists'){\n          // For 'first' and 'exists' we stop on first match found\n          updateAll();\n          return true; // indicate match found and possibly stop handling by caller\n        }\n      } else {\n        log(`Compare index ${state.index}: ${currentValue} != ${t}`);\n      }\n    }\n    if(!matched) {\n      log(`Index ${state.index} checked: no target matched.`);\n    }\n    updateAll();\n    // Advance index by stepSize in chosen direction\n    advanceIndex();\n    // If we just went out of range, finish\n    if(!inRange(state.index)) {\n      log(\"Reached end of range. Search finished.\");\n      updateAll();\n      state.running = false;\n      state.paused = false;\n    }\n    return matched;\n  }\n\n  function advanceIndex(){\n    if(state.direction === 'ltr') state.index += Math.abs(state.stepSize);\n    else state.index -= Math.abs(state.stepSize);\n  }\n\n  function inRange(idx){\n    if(state.direction === 'ltr') return idx <= state.end && idx >= state.start && idx < state.array.length;\n    else return idx >= state.start && idx <= state.end && idx >= 0;\n  }\n\n  let runInterval = null;\n\n  function runLoop(conditionCallback){\n    if(state.running) return;\n    state.running = true;\n    state.paused = false;\n    renderState();\n    log(\"Run started.\");\n    function loopStep(){\n      if(!state.running) { clearInterval(runInterval); runInterval = null; return; }\n      if(!inRange(state.index)){\n        state.running = false;\n        state.paused = false;\n        log(\"Run reached end of range.\");\n        renderState();\n        clearInterval(runInterval);\n        runInterval = null;\n        return;\n      }\n      const matched = stepForwardOnce();\n      // Decide whether to stop based on mode or external condition\n      if(conditionCallback && conditionCallback({matched, index: state.index, state: state})){\n        state.running = false;\n        state.paused = false;\n        log(\"Run stopped due to condition.\");\n        renderState();\n        clearInterval(runInterval);\n        runInterval = null;\n        return;\n      }\n      if(state.mode === 'first' && matched){\n        // We already returned earlier in stepForwardOnce before advancing index when first-found - but if not, ensure stop.\n        state.running = false;\n        state.paused = false;\n        log(\"First match found. Run stopped.\");\n        renderState();\n        clearInterval(runInterval);\n        runInterval = null;\n        return;\n      }\n    }\n    runInterval = setInterval(loopStep, Math.max(20, state.speed || 200));\n  }\n\n  function stopRunning(){\n    state.running = false;\n    state.paused = false;\n    if(runInterval){ clearInterval(runInterval); runInterval = null; }\n    renderState();\n    log(\"Run aborted by user.\");\n  }\n\n  // Buttons and event wiring\n  sizeSlider.addEventListener('input', ()=> { sizeNumber.value = sizeSlider.value; });\n  sizeNumber.addEventListener('change', ()=> { sizeSlider.value = sizeNumber.value; });\n\n  applySize.addEventListener('click', ()=>{\n    const n = clamp(Number(sizeNumber.value)||0, 0, 200);\n    if(state.running){\n      if(!confirm(\"Search is running. Stop and change size?\")) return;\n      stopRunning();\n    }\n    snapshot();\n    const old = state.array.slice();\n    if(n > state.array.length){\n      for(let i=state.array.length;i<n;i++) state.array.push(Math.floor((Number(minValue.value)||0) + Math.random() * ((Number(maxValue.value)||0) - (Number(minValue.value)||0) + 1)));\n    } else {\n      state.array = state.array.slice(0,n);\n    }\n    if(n === 0) state.end = -1;\n    log(\"Array resized from \" + old.length + \" to \" + n);\n    updateAll();\n  });\n\n  generateBtn.addEventListener('click', ()=>{\n    if(state.running){\n      if(!confirm(\"Search is running. Stop and generate new array?\")) return;\n      stopRunning();\n    }\n    snapshot();\n    const n = Number(sizeNumber.value) || 0;\n    const min = Number(minValue.value) || 0;\n    const max = Number(maxValue.value) || 0;\n    state.array = [];\n    for(let i=0;i<n;i++){\n      const v = Math.floor(min + Math.random() * (max - min + 1));\n      state.array.push(v);\n    }\n    state.end = Math.max(0, state.array.length-1);\n    log(\"Generated random array of size \" + n);\n    updateAll();\n  });\n\n  shuffleBtn.addEventListener('click', ()=>{\n    if(state.running){\n      if(!confirm(\"Search is running. Stop and shuffle?\")) return;\n      stopRunning();\n    }\n    snapshot();\n    for(let i=state.array.length-1;i>0;i--){\n      const j = Math.floor(Math.random()*(i+1));\n      const t = state.array[i]; state.array[i] = state.array[j]; state.array[j] = t;\n    }\n    log(\"Array shuffled.\");\n    updateAll();\n  });\n\n  presetWorst.addEventListener('click', ()=>{\n    // Place target at end so worst-case for typical target\n    if(state.running && !confirm(\"Stop running to apply preset?\")) return;\n    stopRunning();\n    snapshot();\n    const n = Number(sizeNumber.value) || 10;\n    state.array = [];\n    for(let i=0;i<n;i++) state.array.push(i);\n    // default target: a value not in array so it's worst-case (search entire array)\n    targetInput.value = String(n+1);\n    state.end = Math.max(0, state.array.length-1);\n    log(\"Preset worst-case applied.\");\n    updateAll();\n  });\n\n  presetBest.addEventListener('click', ()=>{\n    if(state.running && !confirm(\"Stop running to apply preset?\")) return;\n    stopRunning();\n    snapshot();\n    const n = Number(sizeNumber.value) || 10;\n    state.array = [];\n    for(let i=0;i<n;i++) state.array.push(i);\n    // Put target at first index\n    targetInput.value = String(0);\n    state.start = 0; state.end = Math.max(0, n-1);\n    state.index = state.start;\n    log(\"Preset best-case applied.\");\n    updateAll();\n  });\n\n  applyText.addEventListener('click', ()=>{\n    if(state.running && !confirm(\"Stop running to apply CSV?\")) return;\n    stopRunning();\n    snapshot();\n    const txt = arrayText.value.trim();\n    if(txt === '') {\n      state.array = [];\n      log(\"Applied empty CSV -> cleared array.\");\n      updateAll();\n      return;\n    }\n    const parts = txt.split(/[,;\\s]+/).filter(x=>x!=='');\n    const arr = parts.map(p => {\n      const n = Number(p);\n      return Number.isNaN(n) ? p : n;\n    });\n    state.array = arr;\n    state.end = Math.max(0, state.array.length-1);\n    log(\"Applied CSV to array. Length=\" + state.array.length);\n    updateAll();\n  });\n\n  exportJSON.addEventListener('click', ()=>{\n    const js = JSON.stringify(state.array);\n    prompt(\"Copy JSON array:\", js);\n  });\n\n  importJSON.addEventListener('click', ()=>{\n    if(state.running && !confirm(\"Stop running to import JSON?\")) return;\n    stopRunning();\n    const txt = prompt(\"Paste JSON array (e.g. [1,2,3]):\",\"\");\n    if(!txt) return;\n    try{\n      const arr = JSON.parse(txt);\n      if(!Array.isArray(arr)) throw new Error(\"Not array\");\n      snapshot();\n      state.array = arr.map(x => (typeof x === 'number') ? x : x);\n      state.end = Math.max(0, state.array.length-1);\n      log(\"Imported JSON array. Length=\" + state.array.length);\n      updateAll();\n    } catch(err){\n      alert(\"Invalid JSON: \" + err.message);\n    }\n  });\n\n  clearArray.addEventListener('click', ()=>{\n    if(state.running && !confirm(\"Stop running to clear array?\")) return;\n    stopRunning();\n    snapshot();\n    state.array = [];\n    state.index = -1;\n    state.matches = [];\n    state.comparisons = 0;\n    log(\"Array cleared.\");\n    updateAll();\n  });\n\n  autoRange.addEventListener('click', ()=>{\n    state.start = 0;\n    state.end = Math.max(0, state.array.length-1);\n    startIndex.value = state.start;\n    endIndex.value = state.end;\n    log(\"Auto-range set to full array.\");\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    if(state.running && !confirm(\"Stop running and reset search?\")) return;\n    stopRunning();\n    initializeSearch();\n  });\n\n  stepForward.addEventListener('click', ()=>{\n    if(!state.array.length){ alert(\"Array is empty.\"); return; }\n    if(!inRange(state.index)) {\n      // initialize\n      initializeSearch();\n    }\n    if(state.running){\n      alert(\"Cannot step while running. Pause or abort first.\");\n      return;\n    }\n    state.running = false;\n    state.paused = false;\n    const matched = stepForwardOnce();\n    // For 'first' mode: if matched we should stop (already handled)\n  });\n\n  stepBack.addEventListener('click', ()=>{\n    undo();\n  });\n\n  runToggle.addEventListener('click', ()=>{\n    if(state.running){\n      stopRunning();\n      return;\n    }\n    if(!state.array.length){ alert(\"Array is empty.\"); return; }\n    if(!inRange(state.index)) initializeSearch();\n    state.mode = modeSelect.value;\n    state.direction = directionSelect.value;\n    state.targets = parseTargets();\n    state.speed = Number(speed.value);\n    state.stepSize = Math.max(1, Number(stepSizeEl.value) || 1);\n    // Normal run: stop on complete or first match if mode 'first' or exists\n    runLoop(({matched}) => {\n      if(state.mode === 'first' && matched) return true;\n      if(state.mode === 'exists' && matched) return true;\n      return false;\n    });\n  });\n\n  runToNext.addEventListener('click', ()=>{\n    if(state.running){ alert(\"Already running.\"); return; }\n    if(!state.array.length){ alert(\"Array is empty.\"); return; }\n    if(!inRange(state.index)) initializeSearch();\n    // Stop when the next match is found (skip if current index already matched)\n    runLoop(({matched, index}) => {\n      // If current index already in matches and matched==false, continue until find new one\n      if(matched) return true;\n      return false;\n    });\n  });\n\n  runToFound.addEventListener('click', ()=>{\n    if(state.running){ alert(\"Already running.\"); return; }\n    if(!state.array.length){ alert(\"Array is empty.\"); return; }\n    if(!inRange(state.index)) initializeSearch();\n    runLoop(({matched}) => {\n      if(matched) return true;\n      return false;\n    });\n  });\n\n  abortBtn.addEventListener('click', ()=>{\n    if(!state.running){ log(\"Abort pressed but not running.\"); return; }\n    stopRunning();\n  });\n\n  speed.addEventListener('input', ()=> { speedNumber.value = speed.value; state.speed = Number(speed.value); });\n  speedNumber.addEventListener('change', ()=> { speed.value = speedNumber.value; state.speed = Number(speedNumber.value); });\n\n  stepSizeEl.addEventListener('change', ()=> { state.stepSize = Math.max(1, Number(stepSizeEl.value)||1); });\n\n  undoBtn.addEventListener('click', ()=> { undo(); });\n\n  clearLog.addEventListener('click', ()=> { state.log = []; renderLog(); });\n\n  copyArray.addEventListener('click', ()=>{\n    try{\n      const text = state.array.join(',');\n      navigator.clipboard.writeText(text).then(()=> log(\"Array copied to clipboard.\"), ()=> prompt(\"Copy this array:\", text));\n    } catch(e){\n      prompt(\"Copy this array:\", state.array.join(','));\n    }\n  });\n\n  simulateBest.addEventListener('click', ()=>{\n    if(state.running && !confirm(\"Stop running to simulate?\")) return;\n    stopRunning();\n    snapshot();\n    // Put target at current start\n    if(state.array.length === 0){\n      alert(\"Array empty.\");\n      return;\n    }\n    const start = 0;\n    state.array[0] =