    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Type System — Visual Concept</title>\n\n  <!-- Elegant fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071025;\n      --accent-1: #6be2ff;\n      --accent-2: #8a6bff;\n      --muted: rgba(255,255,255,0.6);\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.02);\n      --panel: rgba(255,255,255,0.03);\n      --radius: 18px;\n      --shadow-lg: 0 30px 60px rgba(2,6,23,0.7);\n      --shadow-soft: 0 10px 30px rgba(2,6,23,0.6);\n      --mono: 'Inter', system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      --serif: 'Playfair Display', Georgia, serif;\n    }\n\n    *{box-sizing:border-box; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale}\n    html,body{height:100%}\n    body{\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 20%, rgba(134,101,255,0.12), transparent 8%),\n                  radial-gradient(900px 500px at 90% 80%, rgba(19,179,255,0.08), transparent 10%),\n                  linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n      font-family: var(--mono);\n      color: #ffffff;\n      overflow:hidden;\n      -webkit-user-select:none;\n      user-select:none;\n    }\n\n    /* Subtle grain overlay via SVG dataURI to feel tactile */\n    .grain{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      mix-blend-mode:overlay;\n      opacity:0.06;\n      background-image:\n        radial-gradient(transparent 20%, rgba(255,255,255,0.02) 20%, rgba(255,255,255,0.02) 21%, transparent 21%),\n        radial-gradient(transparent 20%, rgba(255,255,255,0.01) 20%, rgba(255,255,255,0.01) 21%, transparent 21%);\n      background-size: 3px 3px, 7px 7px;\n    }\n\n    .stage{\n      position:relative;\n      height:100vh;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n      gap:28px;\n    }\n\n    .card {\n      width:1100px;\n      max-width:calc(100% - 96px);\n      border-radius:var(--radius);\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: var(--shadow-lg);\n      overflow:visible;\n      position:relative;\n      padding:48px 56px;\n      display:flex;\n      gap:36px;\n      align-items:center;\n      transform:translateY(0);\n      transition:transform 0.9s cubic-bezier(.2,.9,.3,1), box-shadow 0.6s;\n      backdrop-filter: blur(8px) saturate(120%);\n    }\n\n    .card:hover{ transform:translateY(-8px); box-shadow: 0 48px 80px rgba(2,6,23,0.8); }\n\n    /* Left side: large typographic art */\n    .hero{\n      flex:1;\n      min-width:360px;\n      position:relative;\n      display:flex;\n      align-items:center;\n      gap:18px;\n      padding:12px;\n      height:420px;\n    }\n\n    /* Big layered type using SVG for precision and crispness */\n    .type-hero{\n      position:relative;\n      width:100%;\n      height:100%;\n      display:block;\n    }\n\n    /* Right side: compact tokens / description */\n    .panel{\n      width:380px;\n      min-width:260px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-self:stretch;\n      justify-content:flex-start;\n    }\n\n    .titleRow{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n\n    .brand{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n\n    .logo{\n      width:46px;\n      height:46px;\n      border-radius:10px;\n      background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:800;\n      color:#02111a;\n      box-shadow: 0 6px 18px rgba(106,95,255,0.18), inset 0 -6px 18px rgba(255,255,255,0.08);\n      font-family:var(--serif);\n      transform:rotate(-8deg);\n      letter-spacing: -0.02em;\n    }\n\n    .meta{\n      display:flex;\n      flex-direction:column;\n      line-height:1;\n    }\n\n    .meta .name{\n      font-family:var(--serif);\n      font-weight:700;\n      font-size:14px;\n      color: #fff;\n      opacity:0.98;\n    }\n\n    .meta .sub{\n      font-size:12px;\n      color:var(--muted);\n      margin-top:2px;\n    }\n\n    .desc{\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n      margin-top:6px;\n    }\n\n    /* Token chips gentle */\n    .tokens{\n      margin-top:18px;\n      display:grid;\n      grid-template-columns:repeat(2,1fr);\n      gap:12px;\n    }\n\n    .chip{\n      border-radius:12px;\n      padding:12px 14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 8px 20px rgba(4,12,30,0.5);\n      backdrop-filter: blur(6px);\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n      transition: transform 0.6s cubic-bezier(.2,.9,.3,1), box-shadow 0.3s;\n    }\n    .chip:hover{ transform:translateY(-6px); box-shadow: 0 16px 40px rgba(4,12,30,0.6); }\n    .chip .k{ font-size:12px; color:var(--muted); }\n    .chip .v{ font-family:var(--serif); font-weight:700; font-size:16px; color:#fff; }\n\n    /* Toggle button */\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n\n    .btn{\n      -webkit-tap-highlight-color: transparent;\n      border: none;\n      outline:none;\n      cursor:pointer;\n      padding:10px 14px;\n      border-radius:12px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      color:var(--muted);\n      font-size:13px;\n      border:1px solid rgba(255,255,255,0.04);\n      transition: transform 0.18s ease, box-shadow 0.2s, background 0.2s, color 0.2s;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      justify-content:center;\n    }\n    .btn:active{ transform: translateY(1px) scale(0.998); }\n    .btn.primary{\n      background: linear-gradient(90deg, var(--accent-1), var(--accent-2));\n      color: #031426;\n      font-weight:600;\n      box-shadow: 0 10px 28px rgba(106,95,255,0.22);\n      border: none;\n    }\n\n    /* Hidden details sheet */\n    .details{\n      position:fixed;\n      right:44px;\n      bottom:44px;\n      width:480px;\n      max-width:calc(100% - 44px);\n      height:62vh;\n      max-height:720px;\n      border-radius:16px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n      box-shadow: 0 40px 90px rgba(2,8,30,0.7);\n      padding:22px;\n      overflow:auto;\n      transform: translateY(30px) scale(0.98);\n      opacity:0;\n      pointer-events:none;\n      transition: transform 0.6s cubic-bezier(.2,.9,.3,1), opacity 0.42s, box-shadow 0.3s;\n    }\n    .details.show{\n      transform: translateY(0) scale(1);\n      opacity:1;\n      pointer-events:auto;\n    }\n\n    .details h3{\n      font-family:var(--serif);\n      margin:0 0 10px 0;\n      font-size:20px;\n      color:#fff;\n    }\n\n    .details p{ color:var(--muted); margin:0 0 16px 0; font-size:13px; line-height:1.6; }\n\n    .scale-grid{\n      display:grid;\n      grid-template-columns:repeat(3,1fr);\n      gap:12px;\n      margin-top:8px;\n    }\n\n    .scale-item{\n      padding:10px;\n      border-radius:10px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n      align-items:flex-start;\n    }\n    .scale-item .label{ font-size:12px; color:var(--muted); }\n    .scale-item .sample{ font-family:var(--serif); color:#fff; font-weight:700; font-size:18px; }\n\n    /* Background ornament (waves + letter fragments) */\n    .bg-svg{\n      position:absolute;\n      inset:0;\n      z-index:0;\n      pointer-events:none;\n      opacity:0.18;\n      filter: blur(12px) saturate(120%);\n      mix-blend-mode: soft-light;\n    }\n\n    /* Floating decorative tokens over the hero */\n    .floaters{\n      position:absolute;\n      inset:0;\n      display:block;\n      pointer-events:none;\n    }\n\n    .floater{\n      position:absolute;\n      border-radius:12px;\n      padding:8px 12px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      color:var(--muted);\n      font-size:13px;\n      box-shadow: 0 12px 30px rgba(2,10,30,0.45);\n      transform: translateZ(0);\n      animation: floaty 6s ease-in-out infinite;\n    }\n    .floater.alt{ animation-duration:8s; animation-delay:1s; }\n    .floater.big{ font-family:var(--serif); font-weight:700; color:#fff; font-size:18px; padding:14px 18px; }\n\n    @keyframes floaty{\n      0%{ transform: translateY(0) translateX(0) rotate(-1deg); opacity:0.96; }\n      50%{ transform: translateY(-12px) translateX(8px) rotate(2deg); opacity:1; }\n      100%{ transform: translateY(0) translateX(0) rotate(-1deg); opacity:0.96; }\n    }\n\n    /* Typographic hero animations */\n    .layered-text{\n      position:absolute;\n      left:20px;\n      top:28px;\n      width:620px;\n      height:260px;\n      overflow:visible;\n    }\n\n    /* SVG defs ensure crisp gradients and stroke effects */\n    .stagger-in{\n      opacity:0;\n      transform: translateY(24px) scale(0.98);\n      animation: reveal 0.9s cubic-bezier(.2,.9,.3,1) forwards;\n    }\n    .stagger-in.delay-1{ animation-delay:0.08s; }\n    .stagger-in.delay-2{ animation-delay:0.16s; }\n    .stagger-in.delay-3{ animation-delay:0.24s; }\n\n    @keyframes reveal{\n      to{ opacity:1; transform: translateY(0) scale(1); }\n    }\n\n    /* Responsive */\n    @media (max-width:960px){\n      .card{ padding:28px; flex-direction:column; align-items:stretch; gap:20px; height:auto; }\n      .hero{ height:320px; }\n      .panel{ width:100%; }\n      .details{ right:22px; bottom:22px; width:calc(100% - 44px); height:56vh; }\n    }\n\n    footer{\n      position:fixed;\n      left:44px;\n      bottom:28px;\n      color:var(--muted);\n      font-size:12px;\n      display:flex;\n      gap:8px;\n      align-items:center;\n      opacity:0.9;\n      pointer-events:none;\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"grain\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\">\n    <div class=\"card\" role=\"region\" aria-label=\"Type System concept card\">\n      <div class=\"hero\">\n        <!-- Decorative SVG background shapes -->\n        <svg class=\"bg-svg\" viewBox=\"0 0 1200 520\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#6be2ff\" stop-opacity=\"0.45\"/>\n              <stop offset=\"100%\" stop-color=\"#8a6bff\" stop-opacity=\"0.35\"/>\n            </linearGradient>\n            <filter id=\"softBl\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"40\" />\n            </filter>\n          </defs>\n          <g filter=\"url(#softBl)\">\n            <path d=\"M80,340 C180,160 420,50 640,80 C860,110 1020,220 1120,340 L1120,520 L0,520 Z\" fill=\"url(#g1)\" opacity=\"0.24\"></path>\n            <path d=\"M120,380 C240,200 500,100 740,140 C980,180 1040,300 1120,380 L1120,520 L0,520 Z\" fill=\"#ffffff\" opacity=\"0.03\"></path>\n          </g>\n          <!-- subtle letter silhouettes -->\n          <g opacity=\"0.04\" fill=\"#ffffff\">\n            <path d=\"M260 120c-18-7-36-10-54-10-38 0-64 16-80 46-6 11-9 23-9 35 0 20 7 36 21 48 14 12 36 18 66 18 20 0 40-4 60-12 20-8 43-20 71-36l-5-12c-24 12-46 22-66 30-18 8-36 11-56 11-20 0-35-4-45-13-10-9-15-20-15-33 0-11 3-22 10-34 3-5 6-9 10-13 14-14 36-22 64-22 13 0 28 2 44 6l2-12z\"/>\n            <path d=\"M480 76h-40v-12h-24v12h-8v20h8v120h56V96h8V76z\"/>\n            <path d=\"M720 80c-26 0-46 8-60 24-14 16-22 36-22 60 0 24 8 44 22 60 14 16 34 24 60 24s46-8 60-24c14-16 22-36 22-60 0-24-8-44-22-60-14-16-34-24-60-24zm0 28c10 0 20 4 28 12 8 8 12 18 12 30 0 12-4 22-12 30-8 8-18 12-28 12s-20-4-28-12c-8-8-12-18-12-30 0-12 4-22 12-30 8-8 18-12 28-12z\"/>\n          </g>\n        </svg>\n\n        <!-- Layered type as SVG for crispness and control -->\n        <svg class=\"type-hero\" viewBox=\"0 0 760 420\" preserveAspectRatio=\"xMinYMid meet\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"stroke\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#6be2ff\"/>\n              <stop offset=\"100%\" stop-color=\"#8a6bff\"/>\n            </linearGradient>\n            <filter id=\"drop\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feDropShadow dx=\"0\" dy=\"10\" stdDeviation=\"24\" flood-color=\"#000\" flood-opacity=\"0.35\"/>\n            </filter>\n            <linearGradient id=\"fillG\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.08\"/>\n              <stop offset=\"100%\" stop-color=\"#ffffff\" stop-opacity=\"0.02\"/>\n            </linearGradient>\n            <filter id=\"emboss\">\n              <feGaussianBlur in=\"SourceAlpha\" stdDeviation=\"3\" result=\"blur\"/>\n              <feOffset in=\"blur\" dx=\"0\" dy=\"2\" result=\"off\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"off\" mode=\"normal\"/>\n            </filter>\n          </defs>\n\n          <!-- Backdrop large strokes -->\n          <g transform=\"translate(10,12)\">\n            <text x=\"8\" y=\"160\" font-family=\"Playfair Display, Georgia, serif\" font-weight=\"700\" font-size=\"140\" fill=\"none\" stroke=\"url(#stroke)\" stroke-width=\"4\" stroke-linejoin=\"round\" stroke-linecap=\"round\" opacity=\"0.95\" style=\"filter:url(#drop); mix-blend-mode:screen;\">\n              TYPE\n            </text>\n\n            <text x=\"8\" y=\"310\" font-family=\"Inter, system-ui\" font-weight=\"800\" font-size=\"42\" fill=\"url(#fillG)\" opacity=\"0.95\" style=\"letter-spacing:4px;\">\n              SYSTEM\n            </text>\n\n            <!-- soft white fill overlay for depth -->\n            <text x=\"18\" y=\"150\" font-family=\"Playfair Display, Georgia, serif\" font-weight=\"700\" font-size=\"140\" fill=\"rgba(255,255,255,0.03)\" style=\"mix-blend-mode:soft-light;\">\n              TYPE\n            </text>\n\n            <!-- accent line -->\n            <rect x=\"340\" y=\"130\" width=\"320\" height=\"6\" rx=\"3\" fill=\"url(#stroke)\" opacity=\"0.95\" transform=\"rotate(-2 500 132)\"></rect>\n\n            <!-- small descriptive label -->\n            <text x=\"350\" y=\"90\" font-family=\"Inter\" font-weight=\"600\" font-size=\"12\" fill=\"#ffffff\" opacity=\"0.9\">A SYSTEM OF TOKENS — SCALE • WEIGHT • SPACE • COLOR</text>\n          </g>\n        </svg>\n\n        <!-- Floating chips -->\n        <div class=\"floaters\" aria-hidden=\"true\">\n          <div class=\"floater\" style=\"left:24px; top:28px; transform-origin:center;\" aria-hidden=\"true\">Scale: 8px→64px</div>\n          <div class=\"floater alt big\" style=\"left:440px; top:42px; animation-delay:0.6s;\" aria-hidden=\"true\">72 / 56 / 40</div>\n          <div class=\"floater\" style=\"left:520px; top:220px; animation-delay:1.1s;\" aria-hidden=\"true\">Weight: Light → Bold</div>\n          <div class=\"floater\" style=\"left:120px; top:220px; animation-delay:0.9s;\" aria-hidden=\"true\">Leading: 1.2 ↔ 1.6</div>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <div class=\"titleRow\">\n          <div class=\"brand\">\n            <div class=\"logo\">TS</div>\n            <div class=\"meta\">\n              <div class=\"name\">Type System</div>\n              <div class=\"sub\">Design tokens & typographic architecture</div>\n            </div>\n          </div>\n\n          <div class=\"controls\">\n            <button id=\"revealBtn\" class=\"btn primary\" aria-expanded=\"false\" title=\"Reveal type details\">Reveal Details</button>\n          </div>\n        </div>\n\n        <div class=\"desc stagger-in delay-1\">\n          A refined typographic system organizes scale, weight, rhythm and color into predictable tokens. This concept demonstrates how type behaves when treated as a structured system — deliberate, scalable, and harmonious.\n        </div>\n\n        <div class=\"tokens stagger-in delay-2\" role=\"list\">\n          <div class=\"chip\" role=\"listitem\">\n            <div class=\"k\">Scale</div>\n            <div class=\"v\">XXS · XS · S · M · L · XL</div>\n          </div>\n\n          <div class=\"chip\" role=\"listitem\">\n            <div class=\"k\">Weights</div>\n            <div class=\"v\">300 · 400 · 600 · 800</div>\n          </div>\n\n          <div class=\"chip\" role=\"listitem\">\n            <div class=\"k\">Leading</div>\n            <div class=\"v\">1.1 · 1.25 · 1.5</div>\n          </div>\n\n          <div class=\"chip\" role=\"listitem\">\n            <div class=\"k\">Color</div>\n            <div class=\"v\">Primary · Muted · Accent</div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:auto; display:flex; gap:12px; align-items:center;\">\n          <div style=\"flex:1; color:var(--muted); font-size:12px;\">Observe the hierarchy, spacing and rhythm — minimal controls, maximum clarity.</div>\n          <!-- Subtle non-primary button for aesthetic balance (not necessary, but counts as up to 2 controls) -->\n          <button id=\"pulseBtn\" class=\"btn\" title=\"Pulse the system\">Pulse</button>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Hidden details sheet -->\n  <div id=\"details\" class=\"details\" role=\"dialog\" aria-hidden=\"true\" aria-label=\"Detailed type tokens\">\n    <h3>Type Tokens — Reference</h3>\n    <p>Tokens are atomic values that compose typography across components. Here are the essential sets that form the backbone of a robust type system.</p>\n\n    <div style=\"display:flex; gap:12px; align-items:center; margin-bottom:14px;\">\n      <div style=\"width:12px; height:12px; border-radius:4px; background:linear-gradient(90deg,var(--accent-1),var(--accent-2)); box-shadow:0 6px 18px rgba(106,95,255,0.18)\"></div>\n      <div style=\"color:var(--muted); font-size:13px;\">Consistent scale, intentional rhythm, and clear weights.</div>\n    </div>\n\n    <div style=\"display:flex; gap:12px;\">\n      <div style=\"flex:1\">\n        <div class=\"scale-grid\">\n          <div class=\"scale-item\">\n            <div class=\"label\">XXS</div>\n            <div class=\"sample\">10px</div>\n          </div>\n          <div class=\"scale-item\">\n            <div class=\"label\">XS</div>\n            <div class=\"sample\">12px</div>\n          </div>\n          <div class=\"scale-item\">\n            <div class=\"label\">S</div>\n            <div class=\"sample\">14px</div>\n          </div>\n          <div class=\"scale-item\">\n            <div class=\"label\">M</div>\n            <div class=\"sample\">18px</div>\n          </div>\n          <div class=\"scale-item\">\n            <div class=\"label\">L</div>\n            <div class=\"sample\">24px</div>\n          </div>\n          <div class=\"scale-item\">\n            <div class=\"label\">XL</div>\n            <div class=\"sample\">40px</div>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"width:160px; display:flex; flex-direction:column; gap:8px;\">\n        <div style=\"background:var(--panel); padding:12px; border-radius:10px; border:1px solid rgba(255,255,255,0.03);\">\n          <div class=\"label\" style=\"font-size:12px; color:var(--muted)\">Weights</div>\n          <div style=\"font-family:var(--serif); font-weight:700; font-size:18px; color:#fff\">300 · 400 · 600 · 800</div>\n        </div>\n\n        <div style=\"background:var(--panel); padding:12px; border-radius:10px; border:1px solid rgba(255,255,255,0.03);\">\n          <div class=\"label\" style=\"font-size:12px; color:var(--muted)\">Leading</div>\n          <div style=\"font-family:var(--mono); font-weight:600; font-size:14px; color:#fff\">1.1 / 1.25 / 1.5</div>\n        </div>\n      </div>\n    </div>\n\n    <p style=\"margin-top:18px; color:var(--muted); font-size:13px;\">This details panel is minimal by design — meant as a quick reference, not a configurator. The system is about predictable, reusable choices that scale harmoniously across interfaces.</p>\n  </div>\n\n  <footer aria-hidden=\"true\">\n    <div style=\"width:10px; height:10px; border-radius:3px; background:linear-gradient(90deg,var(--accent-1),var(--accent-2)); box-shadow: 0 6px 16px rgba(106,95,255,0.2)\"></div>\n    <div>Type System • Visual Concept</div>\n  </footer>\n\n  <script>\n    // Minimal interactivity: Reveal details and Pulse animation\n    (function(){\n      const revealBtn = document.getElementById('revealBtn');\n      const details = document.getElementById('details');\n      const pulseBtn = document.getElementById('pulseBtn');\n      let shown = false;\n\n      revealBtn.addEventListener('click', function(){\n        shown = !shown;\n        details.classList.toggle('show', shown);\n        revealBtn.setAttribute('aria-expanded', String(shown));\n        revealBtn.textContent = shown ? 'Hide Details' : 'Reveal Details';\n      });\n\n      // Pulse: a modest, temporary nudge of the main card to communicate system pulse\n      pulseBtn.addEventListener('click', function(){\n        const card = document.querySelector('.card');\n        if(!card) return;\n        card.animate([\n          { transform: 'translateY(0) scale(1)' },\n          { transform: 'translateY(-6px) scale(1.01)' },\n          { transform: 'translateY(0) scale(1)' }\n        ], { duration: 540, easing: 'cubic-bezier(.2,.9,.3,1)'});\n      });\n\n      // Keyboard: Escape hides details if open (small accessibility improvement)\n      window.addEventListener('keydown', function(e){\n        if(e.key === 'Escape' && shown){\n          shown = false;\n          details.classList.remove('show');\n          revealBtn.setAttribute('aria-expanded','false');\n          revealBtn.textContent = 'Reveal Details';\n        }\n      });\n\n      // Stagger reveal initial content gently\n      window.addEventListener('load', function(){\n        document.querySelectorAll('.stagger-in').forEach((el, i) => {\n          el.style.animationDelay = (i * 0.06) + 's';\n        });\n      });\n    })();\n  </script>\n</body>\n</html>"
  },
