    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Prim's Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            background-color: #2C3E50;\n            color: #ECF0F1;\n            overflow: hidden;\n        }\n        h1 {\n            text-align: center;\n            margin-top: 20px;\n            font-size: 2.5em;\n        }\n        #canvas {\n            display: block;\n            margin: 40px auto;\n            border: 2px solid #2980B9;\n            border-radius: 10px;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);\n        }\n        .controls {\n            text-align: center;\n            margin: 20px 0;\n        }\n        button {\n            background: #2980B9;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            font-size: 1.2em;\n            cursor: pointer;\n            transition: background 0.3s;\n        }\n        button:hover {\n            background: #3498DB;\n        }\n    </style>\n</head>\n<body>\n    <h1>Visualizing Prim's Algorithm</h1>\n    <canvas id=\"canvas\" width=\"800\" height=\"600\"></canvas>\n    <div class=\"controls\">\n        <button id=\"startButton\">Start Animation</button>\n    </div>\n    <script>\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n\n        const vertices = [\n            { x: 100, y: 100 },\n            { x: 700, y: 100 },\n            { x: 700, y: 500 },\n            { x: 100, y: 500 },\n            { x: 400, y: 300 },\n        ];\n\n        const edges = [\n            { from: 0, to: 1, weight: 1 },\n            { from: 1, to: 2, weight: 5 },\n            { from: 2, to: 3, weight: 3 },\n            { from: 3, to: 0, weight: 4 },\n            { from: 0, to: 4, weight: 2 },\n            { from: 1, to: 4, weight: 3 },\n            { from: 2, to: 4, weight: 2 },\n        ];\n\n        let mstEdges = [];\n        let visited = new Array(vertices.length).fill(false);\n        let currentEdgeIndex = 0;\n\n        function drawVertices() {\n            vertices.forEach((vertex, idx) => {\n                ctx.fillStyle = visited[idx] ? '#27AE60' : '#E74C3C';\n                ctx.beginPath();\n                ctx.arc(vertex.x, vertex.y, 10, 0, Math.PI * 2);\n                ctx.fill();\n                ctx.strokeStyle = '#ECF0F1';\n                ctx.stroke();\n                ctx.font = '14px Arial';\n                ctx.fillStyle = '#ECF0F1';\n                ctx.fillText(idx, vertex.x - 5, vertex.y - 15);\n            });\n        }\n\n        function drawEdges() {\n            ctx.strokeStyle = '#BDC3C7';\n            edges.forEach(edge => {\n                ctx.beginPath();\n                ctx.moveTo(vertices[edge.from].x, vertices[edge.from].y);\n                ctx.lineTo(vertices[edge.to].x, vertices[edge.to].y);\n                ctx.stroke();\n            });\n\n            ctx.strokeStyle = '#F39C12';\n            mstEdges.forEach(edge => {\n                ctx.beginPath();\n                ctx.moveTo(vertices[edge.from].x, vertices[edge.from].y);\n                ctx.lineTo(vertices[edge.to].x, vertices[edge.to].y);\n                ctx.stroke();\n            });\n        }\n\n        function primAlgorithm() {\n            let startVertex = 0;\n            visited[startVertex] = true;\n\n            const addEdges = () => {\n                const availableEdges = edges.filter(edge => visited[edge.from] !== visited[edge.to]);\n                availableEdges.sort((a, b) => a.weight - b.weight);\n                if (availableEdges.length) {\n                    const nextEdge = availableEdges[0];\n                    if (!visited[nextEdge.to]) {\n                        visited[nextEdge.to] = true;\n                        mstEdges.push(nextEdge);\n                    }\n                }\n            };\n\n            const animationLoop = () => {\n                if (mstEdges.length < vertices.length - 1) {\n                    addEdges();\n                    drawCanvas();\n                    setTimeout(animationLoop, 1000); \n                }\n            };\n            \n            animationLoop();\n        }\n\n        function drawCanvas() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            drawEdges();\n            drawVertices();\n        }\n\n        document.getElementById('startButton').onclick = () => {\n            if (mstEdges.length === 0) {\n                primAlgorithm();\n            }\n        };\n\n        drawCanvas(); // Initial draw\n    </script>\n</body>\n</html>"
