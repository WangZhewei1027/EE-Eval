  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Time Complexity Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 1000px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            margin-bottom: 20px;\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        .control-panel {\n            margin-bottom: 15px;\n        }\n        button, select, input {\n            margin: 5px;\n            padding: 5px;\n        }\n        .results {\n            margin-top: 15px;\n            padding: 10px;\n            border: 1px solid #eee;\n            min-height: 50px;\n        }\n        .visualization {\n            height: 300px;\n            border: 1px solid #ddd;\n            margin-top: 20px;\n            overflow: auto;\n            white-space: nowrap;\n        }\n        .complexity-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n        .complexity-table th, .complexity-table td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        .code-sample {\n            font-family: monospace;\n            background-color: #f5f5f5;\n            padding: 10px;\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Time Complexity Explorer</h1>\n    \n    <div class=\"container\">\n        <h2>Algorithm Simulator</h2>\n        <div class=\"control-panel\">\n            <select id=\"algorithm-select\">\n                <option value=\"linear\">Linear Search</option>\n                <option value=\"binary\">Binary Search</option>\n                <option value=\"bubble\">Bubble Sort</option>\n                <option value=\"merge\">Merge Sort</option>\n                <option value=\"fibonacci\">Fibonacci (Recursive)</option>\n                <option value=\"factorial\">Factorial</option>\n            </select>\n            <input type=\"number\" id=\"input-size\" min=\"1\" max=\"1000\" value=\"10\">\n            <button id=\"run-algorithm\">Run Algorithm</button>\n            <button id=\"step-algorithm\">Step Through</button>\n            <button id=\"reset-algorithm\">Reset</button>\n        </div>\n        <div class=\"results\" id=\"algorithm-results\">\n            Select an algorithm and input size to begin.\n        </div>\n        <div class=\"visualization\" id=\"algorithm-visualization\"></div>\n    </div>\n    \n    <div class=\"container\">\n        <h2>Complexity Comparison</h2>\n        <div class=\"control-panel\">\n            <label>Input Size Range: </label>\n            <input type=\"range\" id=\"size-range\" min=\"1\" max=\"1000\" value=\"100\">\n            <span id=\"size-value\">100</span>\n            <button id=\"compare-button\">Compare Complexities</button>\n        </div>\n        <div class=\"results\" id=\"comparison-results\"></div>\n        <canvas id=\"complexity-chart\" width=\"800\" height=\"400\"></canvas>\n    </div>\n    \n    <div class=\"container\">\n        <h2>Big-O Notation Reference</h2>\n        <table class=\"complexity-table\">\n            <tr>\n                <th>Notation</th>\n                <th>Name</th>\n                <th>Example</th>\n                <th>Performance</th>\n            </tr>\n            <tr>\n                <td>O(1)</td>\n                <td>Constant</td>\n                <td>Array access</td>\n                <td>Excellent</td>\n            </tr>\n            <tr>\n                <td>O(log n)</td>\n                <td>Logarithmic</td>\n                <td>Binary search</td>\n                <td>Good</td>\n            </tr>\n            <tr>\n                <td>O(n)</td>\n                <td>Linear</td>\n                <td>Linear search</td>\n                <td>Fair</td>\n            </tr>\n            <tr>\n                <td>O(n log n)</td>\n                <td>Linearithmic</td>\n                <td>Merge sort</td>\n                <td>Okay</td>\n            </tr>\n            <tr>\n                <td>O(n²)</td>\n                <td>Quadratic</td>\n                <td>Bubble sort</td>\n                <td>Poor</td>\n            </tr>\n            <tr>\n                <td>O(2ⁿ)</td>\n                <td>Exponential</td>\n                <td>Recursive Fibonacci</td>\n                <td>Terrible</td>\n            </tr>\n        </table>\n        \n        <div class=\"control-panel\">\n            <button id=\"show-examples\">Show Code Examples</button>\n        </div>\n        <div id=\"code-examples\" style=\"display: none;\">\n            <h3>O(1) - Constant Time</h3>\n            <div class=\"code-sample\">\n                function getFirstElement(arr) {<br>\n                &nbsp;&nbsp;return arr[0];<br>\n                }\n            </div>\n            \n            <h3>O(n) - Linear Time</h3>\n            <div class=\"code-sample\">\n                function linearSearch(arr, target) {<br>\n                &nbsp;&nbsp;for (let i = 0; i < arr.length; i++) {<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;if (arr[i] === target) return i;<br>\n                &nbsp;&nbsp;}<br>\n                &nbsp;&nbsp;return -1;<br>\n                }\n            </div>\n            \n            <h3>O(n²) - Quadratic Time</h3>\n            <div class=\"code-sample\">\n                function bubbleSort(arr) {<br>\n                &nbsp;&nbsp;for (let i = 0; i < arr.length; i++) {<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;for (let j = 0; j < arr.length - i - 1; j++) {<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;if (arr[j] > arr[j + 1]) {<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;// Swap elements<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;let temp = arr[j];<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;arr[j] = arr[j + 1];<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;arr[j + 1] = temp;<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;}<br>\n                &nbsp;&nbsp;&nbsp;&nbsp;}<br>\n                &nbsp;&nbsp;}<br>\n                }\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"container\">\n        <h2>Complexity Calculator</h2>\n        <div class=\"control-panel\">\n            <label>Enter your algorithm's complexity: </label>\n            <select id=\"complexity-type\">\n                <option value=\"1\">O(1)</option>\n                <option value=\"logn\">O(log n)</option>\n                <option value=\"n\">O(n)</option>\n                <option value=\"nlogn\">O(n log n)</option>\n                <option value=\"n2\">O(n²)</option>\n                <option value=\"2n\">O(2ⁿ)</option>\n                <option value=\"nfact\">O(n!)</option>\n            </select>\n            <input type=\"number\" id=\"calc-input-size\" min=\"1\" max=\"1000000\" value=\"100\">\n            <button id=\"calculate-button\">Calculate Operations</button>\n        </div>\n        <div class=\"results\" id=\"calculation-results\"></div>\n    </div>\n    \n    <script>\n        // Algorithm Simulator\n        const algorithmSelect = document.getElementById('algorithm-select');\n        const inputSize = document.getElementById('input-size');\n        const runAlgorithm = document.getElementById('run-algorithm');\n        const stepAlgorithm = document.getElementById('step-algorithm');\n        const resetAlgorithm = document.getElementById('reset-algorithm');\n        const algorithmResults = document.getElementById('algorithm-results');\n        const algorithmVisualization = document.getElementById('algorithm-visualization');\n        \n        let currentStep = 0;\n        let steps = [];\n        let currentAlgorithm = '';\n        \n        runAlgorithm.addEventListener('click', function() {\n            const algorithm = algorithmSelect.value;\n            const size = parseInt(inputSize.value);\n            currentAlgorithm = algorithm;\n            currentStep = 0;\n            \n            // Simulate algorithm steps\n            steps = simulateAlgorithm(algorithm, size);\n            \n            // Display final result\n            algorithmResults.innerHTML = `Algorithm: ${getAlgorithmName(algorithm)}<br>\n                                         Input Size: ${size}<br>\n                                         Operations: ${steps.length}<br>\n                                         Time Complexity: ${getComplexity(algorithm)}`;\n            \n            // Visualize final state\n            visualizeAlgorithm(steps[steps.length - 1], algorithmVisualization);\n        });\n        \n        stepAlgorithm.addEventListener('click', function() {\n            if (steps.length === 0) {\n                const algorithm = algorithmSelect.value;\n                const size = parseInt(inputSize.value);\n                currentAlgorithm = 0;\n                steps = simulateAlgorithm(algorithm, size);\n            }\n            \n            if (currentStep < steps.length) {\n                visualizeAlgorithm(steps[currentStep], algorithmVisualization);\n                algorithmResults.innerHTML = `Step ${currentStep + 1} of ${steps.length}<br>\n                                             Current operation: ${steps[currentStep].operation || 'Processing'}`;\n                currentStep++;\n            } else {\n                algorithmResults.innerHTML = 'Algorithm completed!';\n            }\n        });\n        \n        resetAlgorithm.addEventListener('click', function() {\n            currentStep = 0;\n            steps = [];\n            algorithmResults.innerHTML = 'Algorithm reset.';\n            algorithmVisualization.innerHTML = '';\n        });\n        \n        // Complexity Comparison\n        const sizeRange = document.getElementById('size-range');\n        const sizeValue = document.getElementById('size-value');\n        const compareButton = document.getElementById('compare-button');\n        const comparisonResults = document.getElementById('comparison-results');\n        const complexityChart = document.getElementById('complexity-chart');\n        \n        sizeRange.addEventListener('input', function() {\n            sizeValue.textContent = sizeRange.value;\n        });\n        \n        compareButton.addEventListener('click', function() {\n            const maxSize = parseInt(sizeRange.value);\n            comparisonResults.innerHTML = `Comparing time complexities up to input size ${maxSize}`;\n            drawComplexityChart(maxSize);\n        });\n        \n        // Code Examples\n        const showExamples = document.getElementById('show-examples');\n        const codeExamples = document.getElementById('code-examples');\n        \n        showExamples.addEventListener('click', function() {\n            if (codeExamples.style.display === 'none') {\n                codeExamples.style.display = 'block';\n                showExamples.textContent = 'Hide Code Examples';\n            } else {\n                codeExamples.style.display = 'none';\n                showExamples.textContent = 'Show Code Examples';\n            }\n        });\n        \n        // Complexity Calculator\n        const complexityType = document.getElementById('complexity-type');\n        const calcInputSize = document.getElementById('calc-input-size');\n        const calculateButton = document.getElementById('calculate-button');\n        const calculationResults = document.getElementById('calculation-results');\n        \n        calculateButton.addEventListener('click', function() {\n            const type = complexityType.value;\n            const size = parseInt(calcInputSize.value);\n            let operations;\n            \n            switch(type) {\n                case '1':\n                    operations = 1;\n                    break;\n                case 'logn':\n                    operations = Math.log2(size);\n                    break;\n                case 'n':\n                    operations = size;\n                    break;\n                case 'nlogn':\n                    operations = size * Math.log2(size);\n                    break;\n                case 'n2':\n                    operations = size * size;\n                    break;\n                case '2n':\n                    operations = Math.pow(2, size);\n                    break;\n                case 'nfact':\n                    operations = factorial(size);\n                    break;\n            }\n            \n            calculationResults.innerHTML = `For input size ${size}:<br>\n                                           Complexity: ${getComplexityByType(type)}<br>\n                                           Estimated operations: ${operations.toFixed(2)}`;\n        });\n        \n        // Helper functions\n        function getAlgorithmName(algo) {\n            const names = {\n                'linear': 'Linear Search',\n                'binary': 'Binary Search',\n                'bubble': 'Bubble Sort',\n                'merge': 'Merge Sort',\n                'fibonacci': 'Fibonacci (Recursive)',\n                'factorial': 'Factorial'\n            };\n            return names[algo] || algo;\n        }\n        \n        function getComplexity(algo) {\n            const complexities = {\n                'linear': 'O(n)',\n                'binary': 'O(log n)',\n                'bubble': 'O(n²)',\n                'merge': 'O(n log n)',\n                'fibonacci': 'O(2ⁿ)',\n                'factorial': 'O(n!)'\n            };\n            return complexities[algo] || 'Unknown';\n        }\n        \n        function getComplexityByType(type) {\n            const types = {\n                '1': 'O(1)',\n                'logn': 'O(log n)',\n                'n': 'O(n)',\n                'nlogn': 'O(n log n)',\n                'n2': 'O(n²)',\n                '2n': 'O(2ⁿ)',\n                'nfact': 'O(n!)'\n            };\n            return types[type] || 'Unknown';\n        }\n        \n        function factorial(n) {\n            if (n <= 1) return 1;\n            return n * factorial(n - 1);\n        }\n        \n        function simulateAlgorithm(algorithm, size) {\n            let steps = [];\n            \n            switch(algorithm) {\n                case 'linear':\n                    // Simulate linear search\n                    const target = Math.floor(size / 2);\n                    for (let i = 0; i < size; i++) {\n                        steps.push({\n                            data: Array(size).fill(0).map((_, idx) => ({\n                                value: idx,\n                                state: idx < i ? 'searched' : idx === i ? 'current' : 'unsearched',\n                                found: idx === target\n                            })),\n                            operation: `Checking index ${i} for value ${target}`\n                        });\n                    }\n                    break;\n                    \n                case 'binary':\n                    // Simulate binary search\n                    let low = 0, high = size - 1;\n                    const target = Math.floor(size / 2);\n                    while (low <= high) {\n                        const mid = Math.floor((low + high) / 2);\n                        steps.push({\n                            data: Array(size).fill(0).map((_, idx) => ({\n                                value: idx,\n                                state: idx >= low && idx <= high ? 'active' : 'inactive',\n                                current: idx === mid,\n                                found: idx === target\n                            })),\n                            operation: `Checking middle element at index ${mid}`\n                        });\n                        \n                        if (mid === target) break;\n                        else if (target < mid) high = mid - 1;\n                        else low = mid + 1;\n                    }\n                    break;\n                    \n                case 'bubble':\n                    // Simulate bubble sort\n                    let arr = Array(size).fill(0).map((_, i) => Math.floor(Math.random() * 100));\n                    for (let i = 0; i < size; i++) {\n                        for (let j = 0; j < size - i - 1; j++) {\n                            steps.push({\n                                data: arr.map((val, idx) => ({\n                                    value: val,\n                                    state: idx === j || idx === j + 1 ? 'comparing' : \n                                           idx >= size - i ? 'sorted' : 'unsorted'\n                                })),\n                                operation: `Comparing elements at ${j} and ${j + 1}`\n                            });\n                            \n                            if (arr[j] > arr[j + 1]) {\n                                [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];\n                                steps.push({\n                                    data: arr.map((val, idx) => ({\n                                        value: val,\n                                        state: idx === j || idx === j + 1 ? 'swapping' : \n                                               idx >= size - i ? 'sorted' : 'unsorted'\n                                    })),\n                                    operation: `Swapping elements at ${j} and ${j + 1}`\n                                });\n                            }\n                        }\n                    }\n                    break;\n                    \n                case 'fibonacci':\n                    // Simulate recursive Fibonacci\n                    function fib(n, depth = 0, steps) {\n                        steps.push({\n                            operation: `Calculating fib(${n})`,\n                            depth: depth,\n                            current: n\n                        });\n                        \n                        if (n <= 1) return n;\n                        return fib(n - 1, depth + 1, steps) + fib(n - 2, depth + 1, steps);\n                    }\n                    \n                    fib(size, 0, steps);\n                    break;\n                    \n                case 'factorial':\n                    // Simulate factorial\n                    function fact(n, steps) {\n                        steps.push({\n                            operation: `Calculating ${n}!`,\n                            current: n\n                        });\n                        \n                        if (n <= 1) return 1;\n                        return n * fact(n - 1, steps);\n                    }\n                    \n                    fact(size, steps);\n                    break;\n            }\n            \n            return steps;\n        }\n        \n        function visualizeAlgorithm(step, container) {\n            container.innerHTML = '';\n            \n            if (!step.data) {\n                container.innerHTML = step.operation;\n                return;\n            }\n            \n            const data = step.data;\n            const width = Math.max(20, 800 / data.length);\n            \n            data.forEach(item => {\n                const element = document.createElement('div');\n                element.style.display = 'inline-block';\n                element.style.width = `${width}px`;\n                element.style.height = `${item.value * 3}px`;\n                element.style.margin = '2px';\n                element.style.backgroundColor = item.state === 'current' ? '#ddd' : \n                                               item.state === 'searched' ? '#aaa' : \n                                               item.found ? '#888' : '#eee';\n                element.style.border = '1px solid #999';\n                element.style.textAlign = 'center';\n                element.style.verticalAlign = 'bottom';\n                element.textContent = item.value;\n                \n                container.appendChild(element);\n            });\n            \n            if (step.operation) {\n                const opText = document.createElement('div');\n                opText.textContent = step.operation;\n                container.appendChild(opText);\n            }\n        }\n        \n        function drawComplexityChart(maxSize) {\n            const ctx = complexityChart.getContext('2d');\n            ctx.clearRect(0, 0, complexityChart.width, complexityChart.height);\n            \n            // Draw axes\n            ctx.beginPath();\n            ctx.moveTo(50, 350);\n            ctx.lineTo(750, 350);\n            ctx.moveTo(50, 350);\n            ctx.lineTo(50, 50);\n            ctx.stroke();\n            \n            // Axis labels\n            ctx.fillText(\"Input Size (n)\", 400, 380);\n            ctx.save();\n            ctx.translate(30, 200);\n            ctx.rotate(-Math.PI/2);\n            ctx.fillText(\"Operations\", 0, 0);\n            ctx.restore();\n            \n            // Draw complexity curves\n            const complexities = [\n                { type: '1', color: 'green', name: 'O(1)' },\n                { type: 'logn', color: 'blue', name: 'O(log n)' },\n                { type: 'n', color: 'orange', name: 'O(n)' },\n                { type: 'nlogn', color: 'purple', name: 'O(n log n)' },\n                { type: 'n2', color: 'red', name: 'O(n²)' },\n                { type: '2n', color: 'black', name: 'O(2ⁿ)' }\n            ];\n            \n            const step = maxSize / 100;\n            const xScale = 700 / maxSize;\n            const yScale = 300 / calculateMaxOperations(maxSize);\n            \n            complexities.forEach(comp => {\n                ctx.beginPath();\n                ctx.strokeStyle = comp.color;\n                \n                for (let n = 1; n <= maxSize; n += step) {\n                    let ops;\n                    \n                    switch(comp.type) {\n                        case '1': ops = 1; break;\n                        case 'logn': ops = Math.log2(n); break;\n                        case 'n': ops = n; break;\n                        case 'nlogn': ops = n * Math.log2(n); break;\n                        case 'n2': ops = n * n; break;\n                        case '2n': ops = Math.pow(2, n); break;\n                    }\n                    \n                    const x = 50 + n * xScale;\n                    const y = 350 - ops * yScale;\n                    \n                    if (n === 1) {\n                        ctx.moveTo(x, y);\n                    } else {\n                        ctx.lineTo(x, y);\n                    }\n                }\n                \n                ctx.stroke();\n                ctx.fillStyle = comp.color;\n                ctx.fillText(comp.name, 600, 100 + complexities.indexOf(comp) * 20);\n            });\n        }\n        \n        function calculateMaxOperations(maxSize) {\n            return Math.max(\n                1,\n                Math.log2(maxSize),\n                maxSize,\n                maxSize * Math.log2(maxSize),\n                maxSize * maxSize,\n                Math.pow(2, Math.min(maxSize, 10)) // Cap exponential growth for visibility\n            );\n        }\n    </script>\n</body>\n</html>"
  },
