    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive SQL Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        textarea, input, select {\n            width: 100%;\n            padding: 8px;\n            margin: 5px 0;\n            box-sizing: border-box;\n        }\n        button {\n            padding: 8px 12px;\n            margin: 5px 5px 5px 0;\n            cursor: pointer;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 10px;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        .hidden {\n            display: none;\n        }\n        .tabs {\n            display: flex;\n            margin-bottom: -1px;\n        }\n        .tab {\n            padding: 10px 15px;\n            cursor: 1px solid #ccc;\n            background: #f1f1f1;\n            margin-right: 5px;\n            border: 1px solid #ccc;\n            border-bottom: none;\n        }\n        .tab.active {\n            background: white;\n            border-bottom: 1px solid white;\n        }\n        .tab-content {\n            display: none;\n        }\n        .tab-content.active {\n            display: block;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive SQL Explorer</h1>\n        \n        <div class=\"panel\">\n            <div class=\"tabs\">\n                <div class=\"tab active\" onclick=\"switchTab('query')\">Query Builder</div>\n                <div class=\"tab\" onclick=\"switchTab('schema')\">Database Schema</div>\n                <div class=\"tab\" onclick=\"switchTab('tutorial')\">Tutorial</div>\n            </div>\n            \n            <div id=\"query\" class=\"tab-content active\">\n                <h3>SQL Query</h3>\n                <textarea id=\"sqlQuery\" rows=\"5\">SELECT * FROM employees;</textarea>\n                <div>\n                    <button onclick=\"executeQuery()\">Execute</button>\n                    <button onclick=\"explainQuery()\">Explain</button>\n                    <button onclick=\"saveQuery()\">Save Query</button>\n                    <button onclick=\"loadQuery()\">Load Query</button>\n                    <button onclick=\"clearQuery()\">Clear</button>\n                </div>\n                \n                <div>\n                    <label>Query Type:</label>\n                    <select id=\"queryType\" onchange=\"updateQueryTemplate()\">\n                        <option value=\"select\">SELECT</option>\n                        <option value=\"insert\">INSERT</option>\n                        <option value=\"update\">UPDATE</option>\n                        <option value=\"delete\">DELETE</option>\n                        <option value=\"join\">JOIN</option>\n                        <option value=\"subquery\">Subquery</option>\n                    </select>\n                </div>\n                \n                <div id=\"queryOptions\" class=\"hidden\">\n                    <div id=\"selectOptions\">\n                        <label>Table:</label>\n                        <select id=\"selectTable\" onchange=\"updateSelectColumns()\">\n                            <option value=\"employees\">employees</option>\n                            <option value=\"departments\">departments</option>\n                            <option value=\"projects\">projects</option>\n                        </select>\n                        \n                        <label>Columns:</label>\n                        <div id=\"selectColumns\"></div>\n                        \n                        <label>Conditions:</label>\n                        <input type=\"text\" id=\"selectWhere\" placeholder=\"e.g., salary > 50000\">\n                        \n                        <label>Order By:</label>\n                        <input type=\"text\" id=\"selectOrder\" placeholder=\"e.g., last_name ASC\">\n                    </div>\n                </div>\n            </div>\n            \n            <div id=\"schema\" class=\"tab-content\">\n                <h3>Database Schema</h3>\n                <div>\n                    <select id=\"schemaTable\" onchange=\"showTableSchema()\">\n                        <option value=\"employees\">employees</option>\n                        <option value=\"departments\">departments</option>\n                        <option value=\"projects\">projects</option>\n                    </select>\n                </div>\n                <div id=\"tableSchema\"></div>\n            </div>\n            \n            <div id=\"tutorial\" class=\"tab-content\">\n                <h3>SQL Tutorial</h3>\n                <div>\n                    <select id=\"tutorialTopic\" onchange=\"showTutorial()\">\n                        <option value=\"basics\">SQL Basics</option>\n                        <option value=\"select\">SELECT Statements</option>\n                        <option value=\"joins\">JOIN Operations</option>\n                        <option value=\"subqueries\">Subqueries</option>\n                        <option value=\"functions\">SQL Functions</option>\n                    </select>\n                </div>\n                <div id=\"tutorialContent\"></div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h3>Query Results</h3>\n            <div id=\"queryResults\"></div>\n            <div id=\"queryStats\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h3>Query History</h3>\n            <div id=\"queryHistory\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Sample database\n        const database = {\n            employees: [\n                { id: 1, first_name: 'John', last_name: 'Doe', email: 'john@example.com', salary: 60000, department_id: 1 },\n                { id: 2, first_name: 'Jane', last_name: 'Smith', email: 'jane@example.com', salary: 75000, department_id: 2 },\n                { id: 3, first_name: 'Bob', last_name: 'Johnson', email: 'bob@example.com', salary: 55000, department_id: 1 },\n                { id: 4, first_name: 'Alice', last_name: 'Williams', email: 'alice@example.com', salary: 80000, department_id: 3 }\n            ],\n            departments: [\n                { id: 1, name: 'Engineering', manager: 'John Doe', budget: 500000 },\n                { id: 2, name: 'Marketing', manager: 'Jane Smith', budget: 300000 },\n                { id: 3, name: 'Sales', manager: 'Alice Williams', budget: 400000 }\n            ],\n            projects: [\n                { id: 1, name: 'Website Redesign', department_id: 2, budget: 50000, status: 'active' },\n                { id: 2, name: 'Database Migration', department_id: 1, budget: 75000, status: 'completed' },\n                { id: 3, name: 'Product Launch', department_id: 3, budget: 100000, status: 'planning' }\n            ]\n        };\n\n        // Schema information\n        const schema = {\n            employees: [\n                { name: 'id', type: 'INTEGER', description: 'Primary key' },\n                { name: 'first_name', type: 'VARCHAR(50)', description: 'Employee first name' },\n                { name: 'last_name', type: 'VARCHAR(50)', description: 'Employee last name' },\n                { name: 'email', type: 'VARCHAR(100)', description: 'Employee email' },\n                { name: 'salary', type: 'DECIMAL(10,2)', description: 'Annual salary' },\n                { name: 'department_id', type: 'INTEGER', description: 'Foreign key to departments' }\n            ],\n            departments: [\n                { name: 'id', type: 'INTEGER', description: 'Primary key' },\n                { name: 'name', type: 'VARCHAR(50)', description: 'Department name' },\n                { name: 'manager', type: 'VARCHAR(100)', description: 'Department manager' },\n                { name: 'budget', type: 'DECIMAL(12,2)', description: 'Annual budget' }\n            ],\n            projects: [\n                { name: 'id', type: 'INTEGER', description: 'Primary key' },\n                { name: 'name', type: 'VARCHAR(100)', description: 'Project name' },\n                { name: 'department_id', type: 'INTEGER', description: 'Owning department' },\n                { name: 'budget', type: 'DECIMAL(10,2)', description: 'Project budget' },\n                { name: 'status', type: 'VARCHAR(20)', description: 'Project status' }\n            ]\n        };\n\n        // Tutorial content\n        const tutorials = {\n            basics: `\n                <h4>SQL Basics</h4>\n                <p>SQL (Structured Query Language) is used to manage relational databases.</p>\n                <p>Basic SQL commands:</p>\n                <ul>\n                    <li>SELECT - retrieve data</li>\n                    <li>INSERT - add new records</li>\n                    <li>UPDATE - modify records</li>\n                    <li>DELETE - remove records</li>\n                </ul>\n            `,\n            select: `\n                <h4>SELECT Statements</h4>\n                <p>The SELECT statement retrieves data from one or more tables.</p>\n                <p>Basic syntax:</p>\n                <pre>SELECT column1, column2 FROM table_name WHERE condition;</pre>\n                <p>Examples:</p>\n                <pre>SELECT * FROM employees;</pre>\n                <pre>SELECT first_name, last_name FROM employees WHERE salary > 50000;</pre>\n            `,\n            joins: `\n                <h4>JOIN Operations</h4>\n                <p>JOINs combine rows from two or more tables based on related columns.</p>\n                <p>Types of JOINs:</p>\n                <ul>\n                    <li>INNER JOIN - returns matching rows</li>\n                    <li>LEFT JOIN - returns all rows from left table</li>\n                    <li>RIGHT JOIN - returns all rows from right table</li>\n                    <li>FULL JOIN - returns all rows when there's a match</li>\n                </ul>\n                <p>Example:</p>\n                <pre>SELECT e.first_name, e.last_name, d.name \nFROM employees e \nJOIN departments d ON e.department_id = d.id;</pre>\n            `,\n            subqueries: `\n                <h4>Subqueries</h4>\n                <p>A subquery is a query nested inside another query.</p>\n                <p>Example:</p>\n                <pre>SELECT first_name, last_name \nFROM employees \nWHERE department_id IN (SELECT id FROM departments WHERE name = 'Engineering');</pre>\n            `,\n            functions: `\n                <h4>SQL Functions</h4>\n                <p>Common SQL functions:</p>\n                <ul>\n                    <li>COUNT() - count rows</li>\n                    <li>SUM() - calculate sum</li>\n                    <li>AVG() - calculate average</li>\n                    <li>MAX()/MIN() - find maximum/minimum</li>\n                    <li>CONCAT() - combine strings</li>\n                </ul>\n                <p>Example:</p>\n                <pre>SELECT COUNT(*) FROM employees;</pre>\n                <pre>SELECT AVG(salary) FROM employees WHERE department_id = 1;</pre>\n            `\n        };\n\n        // Query history\n        let queryHistory = [];\n\n        // Initialize the app\n        function init() {\n            updateSelectColumns();\n            showTableSchema();\n            showTutorial();\n        }\n\n        // Tab switching\n        function switchTab(tabId) {\n            document.querySelectorAll('.tab').forEach(tab => {\n                tab.classList.remove('active');\n            });\n            document.querySelectorAll('.tab-content').forEach(content => {\n                content.classList.remove('active');\n            });\n            \n            document.querySelector(`.tab[onclick=\"switchTab('${tabId}')\"]`).classList.add('active');\n            document.getElementById(tabId).classList.add('active');\n        }\n\n        // Execute SQL query\n        function executeQuery() {\n            const query = document.getElementById('sqlQuery').value.trim();\n            if (!query) return;\n            \n            try {\n                const result = parseAndExecuteQuery(query);\n                displayResults(result);\n                addToHistory(query, result);\n            } catch (error) {\n                displayError(error.message);\n            }\n        }\n\n        // Parse and execute query (simplified)\n        function parseAndExecuteQuery(query) {\n            query = query.toLowerCase();\n            \n            if (query.startsWith('select')) {\n                return handleSelectQuery(query);\n            } else if (query.startsWith('insert')) {\n                return handleInsertQuery(query);\n            } else if (query.startsWith('update')) {\n                return handleUpdateQuery(query);\n            } else if (query.startsWith('delete')) {\n                return handleDeleteQuery(query);\n            } else {\n                throw new Error('Unsupported query type');\n            }\n        }\n\n        // Handle SELECT queries\n        function handleSelectQuery(query) {\n            // Very simplified parser - just for demonstration\n            const fromIndex = query.indexOf('from');\n            if (fromIndex === -1) throw new Error('Invalid SELECT query');\n            \n            const tableName = query.substring(fromIndex + 5).split(' ')[0].trim();\n            if (!database[tableName]) throw new Error(`Table ${tableName} not found`);\n            \n            // Get all columns or specified columns\n            let columns = [];\n            const selectPart = query.substring(6, fromIndex).trim();\n            \n            if (selectPart === '*') {\n                columns = Object.keys(database[tableName][0]);\n            } else {\n                columns = selectPart.split(',').map(col => col.trim());\n            }\n            \n            // Get the data\n            const results = database[tableName].map(row => {\n                const resultRow = {};\n                columns.forEach(col => {\n                    if (row[col] === undefined) throw new Error(`Column ${col} not found`);\n                    resultRow[col] = row[col];\n                });\n                return resultRow;\n            });\n            \n            return {\n                type: 'SELECT',\n                table: tableName,\n                columns: columns,\n                rows: results,\n                count: results.length\n            };\n        }\n\n        // Handle INSERT queries (simplified)\n        function handleInsertQuery(query) {\n            const intoIndex = query.indexOf('into');\n            const valuesIndex = query.indexOf('values');\n            \n            if (intoIndex === -1 || valuesIndex === -1) throw new Error('Invalid INSERT query');\n            \n            const tableName = query.substring(intoIndex + 5, valuesIndex).trim().split(' ')[0];\n            if (!database[tableName]) throw new Error(`Table ${tableName} not found`);\n            \n            // Very simplified - just for demo\n            const valuesPart = query.substring(valuesIndex + 7).trim();\n            const values = valuesPart.replace(/[()]/g, '').split(',').map(v => v.trim().replace(/'/g, ''));\n            \n            // Create new row (simplified - assumes order matches)\n            const newRow = {};\n            const columns = Object.keys(database[tableName][0]);\n            \n            columns.forEach((col, i) => {\n                newRow[col] = values[i];\n            });\n            \n            database[tableName].push(newRow);\n            \n            return {\n                type: 'INSERT',\n                table: tableName,\n                affectedRows: 1\n            };\n        }\n\n        // Handle UPDATE queries (simplified)\n        function handleUpdateQuery(query) {\n            const tableIndex = query.indexOf('update') + 7;\n            const setIndex = query.indexOf('set');\n            const whereIndex = query.indexOf('where');\n            \n            if (setIndex === -1) throw new Error('Invalid UPDATE query');\n            \n            const tableName = query.substring(tableIndex, setIndex).trim();\n            if (!database[tableName]) throw new Error(`Table ${tableName} not found`);\n            \n            // Very simplified - just for demo\n            let count = 0;\n            database[tableName].forEach(row => {\n                // In a real implementation, we would parse the WHERE clause\n                // and only update matching rows\n                row.salary = parseInt(row.salary) + 5000; // Simple demo update\n                count++;\n            });\n            \n            return {\n                type: 'UPDATE',\n                table: tableName,\n                affectedRows: count\n            };\n        }\n\n        // Handle DELETE queries (simplified)\n        function handleDeleteQuery(query) {\n            const fromIndex = query.indexOf('from');\n            const whereIndex = query.indexOf('where');\n            \n            if (fromIndex === -1) throw new Error('Invalid DELETE query');\n            \n            const tableName = query.substring(fromIndex + 5, whereIndex !== -1 ? whereIndex : undefined).trim();\n            if (!database[tableName]) throw new Error(`Table ${tableName} not found`);\n            \n            // Very simplified - just for demo\n            const originalCount = database[tableName].length;\n            database[tableName] = database[tableName].slice(0, -1); // Remove last item for demo\n            const newCount = database[tableName].length;\n            \n            return {\n                type: 'DELETE',\n                table: tableName,\n                affectedRows: originalCount - newCount\n            };\n        }\n\n        // Display query results\n        function displayResults(result) {\n            const resultsDiv = document.getElementById('queryResults');\n            const statsDiv = document.getElementById('queryStats');\n            \n            resultsDiv.innerHTML = '';\n            statsDiv.innerHTML = '';\n            \n            if (result.type === 'SELECT') {\n                if (result.rows.length === 0) {\n                    resultsDiv.innerHTML = '<p>No results found</p>';\n                } else {\n                    const table = document.createElement('table');\n                    \n                    // Create header\n                    const thead = document.createElement('thead');\n                    const headerRow = document.createElement('tr');\n                    result.columns.forEach(col => {\n                        const th = document.createElement('th');\n                        th.textContent = col;\n                        headerRow.appendChild(th);\n                    });\n                    thead.appendChild(headerRow);\n                    table.appendChild(thead);\n                    \n                    // Create rows\n                    const tbody = document.createElement('tbody');\n                    result.rows.forEach(row => {\n                        const tr = document.createElement('tr');\n                        result.columns.forEach(col => {\n                            const td = document.createElement('td');\n                            td.textContent = row[col];\n                            tr.appendChild(td);\n                        });\n                        tbody.appendChild(tr);\n                    });\n                    table.appendChild(tbody);\n                    \n                    resultsDiv.appendChild(table);\n                }\n                \n                statsDiv.innerHTML = `<p>Returned ${result.count} rows from table ${result.table}</p>`;\n            } else {\n                resultsDiv.innerHTML = `<p>${result.type} operation completed successfully</p>`;\n                statsDiv.innerHTML = `<p>Affected ${result.affectedRows} rows in table ${result.table}</p>`;\n            }\n        }\n\n        // Display error\n        function displayError(message) {\n            const resultsDiv = document.getElementById('queryResults');\n            resultsDiv.innerHTML = `<p style=\"color:red\">Error: ${message}</p>`;\n        }\n\n        // Add query to history\n        function addToHistory(query, result) {\n            queryHistory.unshift({\n                query: query,\n                timestamp: new Date(),\n                result: result\n            });\n            \n            updateHistoryDisplay();\n        }\n\n        // Update history display\n        function updateHistoryDisplay() {\n            const historyDiv = document.getElementById('queryHistory');\n            historyDiv.innerHTML = '';\n            \n            queryHistory.slice(0, 5).forEach(item => {\n                const div = document.createElement('div');\n                div.style.marginBottom = '10px';\n                div.style.padding = '5px';\n                div.style.borderBottom = '1px solid #eee';\n                \n                const queryText = document.createElement('div');\n                queryText.textContent = item.query;\n                queryText.style.fontFamily = 'monospace';\n                \n                const meta = document.createElement('div');\n                meta.style.fontSize = '0.8em';\n                meta.style.color = '#666';\n                meta.textContent = `${item.timestamp.toLocaleTimeString()} - ${item.result.type} (${item.result.affectedRows || item.result.count} rows)`;\n                \n                div.appendChild(queryText);\n                div.appendChild(meta);\n                historyDiv.appendChild(div);\n            });\n        }\n\n        // Explain query\n        function explainQuery() {\n            const query = document.getElementById('sqlQuery').value.trim();\n            if (!query) return;\n            \n            const resultsDiv = document.getElementById('queryResults');\n            resultsDiv.innerHTML = `\n                <h4>Query Explanation</h4>\n                <p>This is a simplified explanation of what the query does:</p>\n                <ul>\n                    <li>Query type: ${query.split(' ')[0].toUpperCase()}</li>\n                    <li>Tables accessed: ${query.includes('FROM') ? query.split('FROM')[1].split(' ')[1] : 'N/A'}</li>\n                    <li>Conditions: ${query.includes('WHERE') ? query.split('WHERE')[1] : 'None'}</li>\n                </ul>\n                <p>Note: This is a simulation. A real database would provide more detailed execution plans.</p>\n            `;\n        }\n\n        // Save query\n        function saveQuery() {\n            const query = document.getElementById('sqlQuery').value.trim();\n            if (!query) return;\n            \n            localStorage.setItem('savedQuery', query);\n            alert('Query saved to browser storage');\n        }\n\n        // Load query\n        function loadQuery() {\n            const savedQuery = localStorage.getItem('savedQuery');\n            if (savedQuery) {\n                document.getElementById('sqlQuery').value = savedQuery;\n            } else {\n                alert('No saved query found');\n            }\n        }\n\n        // Clear query\n        function clearQuery() {\n            document.getElementById('sqlQuery').value = '';\n        }\n\n        // Update query template based on type\n        function updateQueryTemplate() {\n            const queryType = document.getElementById('queryType').value;\n            const queryOptions = document.getElementById('queryOptions');\n            \n            queryOptions.classList.remove('hidden');\n            \n            switch(queryType) {\n                case 'select':\n                    document.getElementById('sqlQuery').value = 'SELECT * FROM employees;';\n                    document.getElementById('selectOptions').style.display = 'block';\n                    break;\n                case 'insert':\n                    document.getElementById('sqlQuery').value = 'INSERT INTO employees (id, first_name, last_name, email, salary, department_id) VALUES (5, \"New\", \"Employee\", \"new@example.com\", 50000, 1);';\n                    break;\n                case 'update':\n                    document.getElementById('sqlQuery').value = 'UPDATE employees SET salary = 65000 WHERE id = 1;';\n                    break;\n                case 'delete':\n                    document.getElementById('sqlQuery').value = 'DELETE FROM employees WHERE id = 1;';\n                    break;\n                case 'join':\n                    document.getElementById('sqlQuery').value = 'SELECT e.first_name, e.last_name, d.name FROM employees e JOIN departments d ON e.department_id = d.id;';\n                    break;\n                case 'subquery':\n                    document.getElementById('sqlQuery').value = 'SELECT first_name, last_name FROM employees WHERE department_id IN (SELECT id FROM departments WHERE name = \"Engineering\");';\n                    break;\n            }\n        }\n\n        // Update select columns when table changes\n        function updateSelectColumns() {\n            const tableName = document.getElementById('selectTable').value;\n            const columnsDiv = document.getElementById('selectColumns');\n            \n            columnsDiv.innerHTML = '';\n            \n            if (database[tableName]) {\n                Object.keys(database[tableName][0]).forEach(col => {\n                    const checkbox = document.createElement('input');\n                    checkbox.type = 'checkbox';\n                    checkbox.id = `col_${col}`;\n                    checkbox.value = col;\n                    checkbox.checked = true;\n                    \n                    const label = document.createElement('label');\n                    label.htmlFor = `col_${col}`;\n                    label.textContent = col;\n                    \n                    const div = document.createElement('div');\n                    div.appendChild(checkbox);\n                    div.appendChild(label);\n                    \n                    columnsDiv.appendChild(div);\n                });\n            }\n        }\n\n        // Show table schema\n        function showTableSchema() {\n            const tableName = document.getElementById('schemaTable').value;\n            const schemaDiv = document.getElementById('tableSchema');\n            \n            if (schema[tableName]) {\n                const table = document.createElement('table');\n                \n                // Header\n                const thead = document.createElement('thead');\n                const headerRow = document.createElement('tr');\n                ['Column', 'Type', 'Description'].forEach(text => {\n                    const th = document.createElement('th');\n                    th.textContent = text;\n                    headerRow.appendChild(th);\n                });\n                thead.appendChild(headerRow);\n                table.appendChild(thead);\n                \n                // Rows\n                const tbody = document.createElement('tbody');\n                schema[tableName].forEach(col => {\n                    const tr = document.createElement('tr');\n                    \n                    const tdName = document.createElement('td');\n                    tdName.textContent = col.name;\n                    tr.appendChild(tdName);\n                    \n                    const tdType = document.createElement('td');\n                    tdType.textContent = col.type;\n                    tr.appendChild(tdType);\n                    \n                    const tdDesc = document.createElement('td');\n                    tdDesc.textContent = col.description;\n                    tr.appendChild(tdDesc);\n                    \n                    tbody.appendChild(tr);\n                });\n                table.appendChild(tbody);\n                \n                schemaDiv.innerHTML = '';\n                schemaDiv.appendChild(table);\n            }\n        }\n\n        // Show tutorial\n        function showTutorial() {\n            const topic = document.getElementById('tutorialTopic').value;\n            const tutorialDiv = document.getElementById('tutorialContent');\n            \n            if (tutorials[topic]) {\n                tutorialDiv.innerHTML = tutorials[topic];\n            }\n        }\n\n        // Initialize the app\n        window.onload = init;\n    </script>\n</body>\n</html>"
  },
