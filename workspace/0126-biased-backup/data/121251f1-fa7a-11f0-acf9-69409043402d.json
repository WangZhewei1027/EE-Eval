    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Interactive Linked List Explorer</title>\n<style>\n  /* extremely minimal: just to keep monospace for clarity */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  input[type=number], input[type=text] {\n    width: 6em;\n    font-family: monospace;\n  }\n  button {\n    font-family: monospace;\n  }\n  textarea {\n    font-family: monospace;\n    width: 100%;\n    height: 4em;\n  }\n  .section {\n    margin-bottom: 1.5em;\n  }\n  label {\n    display: inline-block;\n    min-width: 8em;\n  }\n</style>\n</head>\n<body>\n<h1>Linked List Interactive Explorer</h1>\n\n<div class=\"section\" id=\"controls-insert\">\n  <h2>Insert Node</h2>\n  <label for=\"insert-value\">Value (text):</label>\n  <input type=\"text\" id=\"insert-value\" autocomplete=\"off\" />\n  <br /><br />\n  <label for=\"insert-pos\">Position (0 = head):</label>\n  <input type=\"number\" id=\"insert-pos\" min=\"0\" value=\"0\" />\n  <button id=\"insert-head\">Insert at Head</button>\n  <button id=\"insert-tail\">Insert at Tail</button>\n  <button id=\"insert-pos-btn\">Insert at Position</button>\n  <div>\n    <small>Position must be between 0 and current list length.</small>\n  </div>\n</div>\n\n<div class=\"section\" id=\"controls-delete\">\n  <h2>Delete Node</h2>\n  <label for=\"delete-pos\">Position (0 = head):</label>\n  <input type=\"number\" id=\"delete-pos\" min=\"0\" value=\"0\" />\n  <button id=\"delete-pos-btn\">Delete at Position</button>\n  <button id=\"delete-head\">Delete Head</button>\n  <button id=\"delete-tail\">Delete Tail</button>\n  <div>\n    <small>Position must be within list bounds.</small>\n  </div>\n</div>\n\n<div class=\"section\" id=\"controls-update\">\n  <h2>Update Node</h2>\n  <label for=\"update-pos\">Position (0 = head):</label>\n  <input type=\"number\" id=\"update-pos\" min=\"0\" value=\"0\" />\n  <br /><br />\n  <label for=\"update-value\">New Value (text):</label>\n  <input type=\"text\" id=\"update-value\" autocomplete=\"off\" />\n  <button id=\"update-pos-btn\">Update Node Value</button>\n</div>\n\n<div class=\"section\" id=\"controls-search\">\n  <h2>Search</h2>\n  <label for=\"search-value\">Search Value:</label>\n  <input type=\"text\" id=\"search-value\" autocomplete=\"off\" />\n  <button id=\"search-btn\">Find All Positions</button>\n  <div id=\"search-result\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n</div>\n\n<div class=\"section\" id=\"controls-traverse\">\n  <h2>Traverse List</h2>\n  <button id=\"traverse-head-next\">Start at Head → Next</button>\n  <button id=\"traverse-head\">Jump to Head</button>\n  <button id=\"traverse-tail-prev\">Start at Tail ← Prev</button>\n  <button id=\"traverse-tail\">Jump to Tail</button>\n  <button id=\"traverse-reset\">Reset Traversal</button>\n  <div style=\"margin-top:0.5em;\">\n    <label>Current Traversal Position:</label>\n    <span id=\"traverse-pos\">-</span>\n    <label style=\"margin-left:1em;\">Value:</label>\n    <span id=\"traverse-val\">-</span>\n  </div>\n</div>\n\n<div class=\"section\" id=\"controls-reverse\">\n  <h2>List Operations</h2>\n  <button id=\"reverse-list\">Reverse Entire List</button>\n  <button id=\"clear-list\">Clear Entire List</button>\n  <button id=\"sort-list\">Sort List (lexicographically)</button>\n  <button id=\"remove-duplicates\">Remove Duplicate Values</button>\n</div>\n\n<div class=\"section\" id=\"controls-debug\">\n  <h2>Debug & Export / Import</h2>\n  <button id=\"export-json-btn\">Export List JSON</button>\n  <button id=\"import-json-btn\">Import List JSON</button>\n  <br />\n  <textarea id=\"json-textarea\" placeholder=\"Paste JSON here to import or see export output\" spellcheck=\"false\"></textarea>\n  <div id=\"json-message\" style=\"margin-top:0.5em;white-space:pre-wrap;\"></div>\n</div>\n\n<div class=\"section\" id=\"list-visualization\">\n  <h2>Current List (Index : Value)</h2>\n  <div id=\"list-display\" style=\"white-space: pre-wrap; font-weight: normal; min-height: 3em; border: 1px solid #000; padding: 0.5em; font-family: monospace;\"></div>\n</div>\n\n<script>\n(function(){\n  // Linked List Node class\n  class Node {\n    constructor(value) {\n      this.value = value;\n      this.next = null;\n      this.prev = null; // for doubly linked list support\n    }\n  }\n\n  // Doubly Linked List with rich functionality\n  class LinkedList {\n    constructor() {\n      this.head = null;\n      this.tail = null;\n      this.length = 0;\n    }\n\n    insertAtHead(value) {\n      const node = new Node(value);\n      if (!this.head) {\n        this.head = node;\n        this.tail = node;\n      } else {\n        node.next = this.head;\n        this.head.prev = node;\n        this.head = node;\n      }\n      this.length++;\n    }\n\n    insertAtTail(value) {\n      const node = new Node(value);\n      if (!this.tail) {\n        this.head = node;\n        this.tail = node;\n      } else {\n        node.prev = this.tail;\n        this.tail.next = node;\n        this.tail = node;\n      }\n      this.length++;\n    }\n\n    insertAtPosition(value, pos) {\n      if (pos < 0 || pos > this.length) {\n        throw new RangeError('Position out of bounds');\n      }\n      if (pos === 0) {\n        this.insertAtHead(value);\n        return;\n      }\n      if (pos === this.length) {\n        this.insertAtTail(value);\n        return;\n      }\n      // insert in middle\n      const node = new Node(value);\n      let current = this.head;\n      for (let i = 0; i < pos; i++) {\n        current = current.next;\n      }\n      const prev = current.prev;\n      prev.next = node;\n      node.prev = prev;\n      node.next = current;\n      current.prev = node;\n      this.length++;\n    }\n\n    deleteAtHead() {\n      if (!this.head) {\n        throw new RangeError('List empty');\n      }\n      const val = this.head.value;\n      if (this.head === this.tail) { \n        this.head = null;\n        this.tail = null;\n      } else {\n        this.head = this.head.next;\n        this.head.prev = null;\n      }\n      this.length--;\n      return val;\n    }\n\n    deleteAtTail() {\n      if (!this.tail) {\n        throw new RangeError('List empty');\n      }\n      const val = this.tail.value;\n      if (this.head === this.tail) {\n        this.head = null;\n        this.tail = null;\n      } else {\n        this.tail = this.tail.prev;\n        this.tail.next = null;\n      }\n      this.length--;\n      return val;\n    }\n\n    deleteAtPosition(pos) {\n      if (pos < 0 || pos >= this.length) {\n        throw new RangeError('Position out of bounds');\n      }\n      if (pos === 0) {\n        return this.deleteAtHead();\n      }\n      if (pos === this.length - 1) {\n        return this.deleteAtTail();\n      }\n      let current = this.head;\n      for (let i = 0; i < pos; i++) {\n        current = current.next;\n      }\n      const val = current.value;\n      const before = current.prev;\n      const after = current.next;\n      before.next = after;\n      after.prev = before;\n      this.length--;\n      return val;\n    }\n\n    updateAtPosition(pos, newValue) {\n      if (pos < 0 || pos >= this.length) {\n        throw new RangeError('Position out of bounds');\n      }\n      let current = this.head;\n      for (let i = 0; i < pos; i++) {\n        current = current.next;\n      }\n      current.value = newValue;\n    }\n\n    findAllPositions(value) {\n      const positions = [];\n      let idx = 0;\n      let current = this.head;\n      while (current) {\n        if (current.value === value) {\n          positions.push(idx);\n        }\n        current = current.next;\n        idx++;\n      }\n      return positions;\n    }\n\n    toArray() {\n      const arr = [];\n      let current = this.head;\n      while (current) {\n        arr.push(current.value);\n        current = current.next;\n      }\n      return arr;\n    }\n\n    fromArray(arr) {\n      this.clear();\n      for (const v of arr) {\n        this.insertAtTail(v);\n      }\n    }\n\n    clear() {\n      this.head = null;\n      this.tail = null;\n      this.length = 0;\n    }\n\n    reverse() {\n      let current = this.head;\n      let tmp = null;\n      while (current) {\n        tmp = current.next;\n        current.next = current.prev;\n        current.prev = tmp;\n        current = tmp;\n      }\n      tmp = this.head;\n      this.head = this.tail;\n      this.tail = tmp;\n    }\n\n    sortLex() {\n      // sort linked list values lex, rebuild list with sorted array\n      const arr = this.toArray();\n      arr.sort((a,b)=>String(a).localeCompare(b));\n      this.fromArray(arr);\n    }\n\n    removeDuplicates() {\n      const seen = new Set();\n      let current = this.head;\n      let pos = 0;\n      while (current) {\n        if (seen.has(current.value)) {\n          const nextNode = current.next;\n          // delete current at pos\n          this.deleteAtPosition(pos);\n          current = nextNode;\n        } else {\n          seen.add(current.value);\n          current = current.next;\n          pos++;\n        }\n      }\n    }\n  }\n\n  // Traversal controller to move through the list step-wise\n  class Traversal {\n    constructor(list) {\n      this.list = list;\n      this.current = null;\n      this.currentPos = -1;\n    }\n    jumpToHead() {\n      this.current = this.list.head;\n      this.currentPos = this.current ? 0 : -1;\n    }\n    jumpToTail() {\n      this.current = this.list.tail;\n      this.currentPos = this.current ? this.list.length - 1 : -1;\n    }\n    reset() {\n      this.current = null;\n      this.currentPos = -1;\n    }\n    next() {\n      if (!this.current) {\n        this.jumpToHead();\n        return;\n      }\n      if (this.current.next) {\n        this.current = this.current.next;\n        this.currentPos++;\n      } else {\n        // At tail already, do not move\n      }\n    }\n    prev() {\n      if (!this.current) {\n        this.jumpToTail();\n        return;\n      }\n      if (this.current.prev) {\n        this.current = this.current.prev;\n        this.currentPos--;\n      } else {\n        // At head already, do not move\n      }\n    }\n    getCurrent() {\n      if (!this.current) return {pos:-1,value:null};\n      return {pos:this.currentPos, value:this.current.value};\n    }\n  }\n\n  // App state\n  const list = new LinkedList();\n  const traversal = new Traversal(list);\n\n  // UI elements\n  const insertValueElem = document.getElementById('insert-value');\n  const insertPosElem = document.getElementById('insert-pos');\n  const insertHeadBtn = document.getElementById('insert-head');\n  const insertTailBtn = document.getElementById('insert-tail');\n  const insertPosBtn = document.getElementById('insert-pos-btn');\n\n  const deletePosElem = document.getElementById('delete-pos');\n  const deletePosBtn = document.getElementById('delete-pos-btn');\n  const deleteHeadBtn = document.getElementById('delete-head');\n  const deleteTailBtn = document.getElementById('delete-tail');\n\n  const updatePosElem = document.getElementById('update-pos');\n  const updateValueElem = document.getElementById('update-value');\n  const updatePosBtn = document.getElementById('update-pos-btn');\n\n  const searchValueElem = document.getElementById('search-value');\n  const searchBtn = document.getElementById('search-btn');\n  const searchResultDiv = document.getElementById('search-result');\n\n  const traverseHeadNextBtn = document.getElementById('traverse-head-next');\n  const traverseHeadBtn = document.getElementById('traverse-head');\n  const traverseTailPrevBtn = document.getElementById('traverse-tail-prev');\n  const traverseTailBtn = document.getElementById('traverse-tail');\n  const traverseResetBtn = document.getElementById('traverse-reset');\n  const traversePosSpan = document.getElementById('traverse-pos');\n  const traverseValSpan = document.getElementById('traverse-val');\n\n  const reverseListBtn = document.getElementById('reverse-list');\n  const clearListBtn = document.getElementById('clear-list');\n  const sortListBtn = document.getElementById('sort-list');\n  const removeDuplicatesBtn = document.getElementById('remove-duplicates');\n\n  const exportJSONBtn = document.getElementById('export-json-btn');\n  const importJSONBtn = document.getElementById('import-json-btn');\n  const jsonTextarea = document.getElementById('json-textarea');\n  const jsonMessageDiv = document.getElementById('json-message');\n\n  const listDisplayDiv = document.getElementById('list-display');\n\n  // Helper to refresh display\n  function refreshListDisplay() {\n    if (list.length === 0) {\n      listDisplayDiv.textContent = \"(empty)\";\n    } else {\n      const arr = list.toArray();\n      const displayLines = arr.map((v,i)=> i + ' : ' + v);\n      listDisplayDiv.textContent = displayLines.join('\\n');\n    }\n  }\n\n  // Helper for traversal display update\n  function refreshTraversalDisplay() {\n    const current = traversal.getCurrent();\n    if (current.pos === -1) {\n      traversePosSpan.textContent = '-';\n      traverseValSpan.textContent = '-';\n    } else {\n      traversePosSpan.textContent = current.pos;\n      traverseValSpan.textContent = current.value;\n    }\n  }\n\n  // Helper: validate position input relative to list length\n  function validatePositionInput(inputElem, allowEqualLength) {\n    let val = inputElem.value.trim();\n    if (val === '') {\n      return {valid:false, reason:'Empty input'};\n    }\n    let n = Number(val);\n    if (!Number.isInteger(n) || n < 0) {\n      return {valid:false, reason:'Not a valid non-negative integer'};\n    }\n    if (allowEqualLength) {\n      if (n > list.length) {\n        return {valid:false, reason:`Position > list length (${list.length})`};\n      }\n    } else {\n      if (n >= list.length) {\n        return {valid:false, reason:`Position out of bounds, max index ${list.length-1}`};\n      }\n    }\n    return {valid:true, pos:n};\n  }\n\n  // Insert Handlers\n  insertHeadBtn.addEventListener('click', () => {\n    const val = insertValueElem.value.trim();\n    if (val === '') {\n      alert('Please enter a value to insert.');\n      insertValueElem.focus();\n      return;\n    }\n    try {\n      list.insertAtHead(val);\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch(e) {\n      alert('Insert failed: ' + e.message);\n    }\n  });\n\n  insertTailBtn.addEventListener('click', () => {\n    const val = insertValueElem.value.trim();\n    if (val === '') {\n      alert('Please enter a value to insert.');\n      insertValueElem.focus();\n      return;\n    }\n    try {\n      list.insertAtTail(val);\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch(e) {\n      alert('Insert failed: ' + e.message);\n    }\n  });\n\n  insertPosBtn.addEventListener('click', () => {\n    const val = insertValueElem.value.trim();\n    if (val === '') {\n      alert('Please enter a value to insert.');\n      insertValueElem.focus();\n      return;\n    }\n    const posV = validatePositionInput(insertPosElem, true);\n    if (!posV.valid) {\n      alert('Position error: ' + posV.reason);\n      insertPosElem.focus();\n      return;\n    }\n    try {\n      list.insertAtPosition(val, posV.pos);\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch (e) {\n      alert('Insert failed: ' + e.message);\n    }\n  });\n\n  // Delete Handlers\n  deleteHeadBtn.addEventListener('click', () => {\n    if (list.length === 0) {\n      alert('List already empty');\n      return;\n    }\n    try {\n      list.deleteAtHead();\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch (e) {\n      alert('Delete failed: ' + e.message);\n    }\n  });\n\n  deleteTailBtn.addEventListener('click', () => {\n    if (list.length === 0) {\n      alert('List already empty');\n      return;\n    }\n    try {\n      list.deleteAtTail();\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch (e) {\n      alert('Delete failed: ' + e.message);\n    }\n  });\n\n  deletePosBtn.addEventListener('click', () => {\n    if (list.length === 0) {\n      alert('List is empty');\n      return;\n    }\n    const posV = validatePositionInput(deletePosElem, false);\n    if (!posV.valid) {\n      alert('Position error: ' + posV.reason);\n      deletePosElem.focus();\n      return;\n    }\n    try {\n      list.deleteAtPosition(posV.pos);\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch(e) {\n      alert('Delete failed: ' + e.message);\n    }\n  });\n\n  // Update Handlers\n  updatePosBtn.addEventListener('click', () => {\n    if (list.length === 0) {\n      alert('List is empty');\n      return;\n    }\n    const posV = validatePositionInput(updatePosElem, false);\n    if (!posV.valid) {\n      alert('Position error: ' + posV.reason);\n      updatePosElem.focus();\n      return;\n    }\n    const newVal = updateValueElem.value.trim();\n    if (newVal === '') {\n      alert('Please enter a new value to update.');\n      updateValueElem.focus();\n      return;\n    }\n    try {\n      list.updateAtPosition(posV.pos, newVal);\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n    } catch(e) {\n      alert('Update failed: ' + e.message);\n    }\n  });\n\n  // Search Handlers\n  searchBtn.addEventListener('click', () => {\n    const term = searchValueElem.value;\n    searchResultDiv.textContent = '';\n    if (term === '') {\n      alert('Please enter a search value.');\n      searchValueElem.focus();\n      return;\n    }\n    const positions = list.findAllPositions(term);\n    if (positions.length === 0) {\n      searchResultDiv.textContent = 'Value not found in list.';\n    } else {\n      searchResultDiv.textContent = 'Value found at positions: ' + positions.join(', ');\n    }\n  });\n\n  // Traversal Handlers\n  traverseHeadNextBtn.addEventListener('click', () => {\n    traversal.next();\n    refreshTraversalDisplay();\n  });\n\n  traverseHeadBtn.addEventListener('click', () => {\n    traversal.jumpToHead();\n    refreshTraversalDisplay();\n  });\n\n  traverseTailPrevBtn.addEventListener('click', () => {\n    traversal.prev();\n    refreshTraversalDisplay();\n  });\n\n  traverseTailBtn.addEventListener('click', () => {\n    traversal.jumpToTail();\n    refreshTraversalDisplay();\n  });\n\n  traverseResetBtn.addEventListener('click', () => {\n    traversal.reset();\n    refreshTraversalDisplay();\n  });\n\n  // List operations handlers\n  reverseListBtn.addEventListener('click', () => {\n    if (list.length < 2) {\n      alert('List must have 2 or more elements to reverse.');\n      return;\n    }\n    list.reverse();\n    refreshListDisplay();\n    resetTraversalIfInvalid();\n  });\n\n  clearListBtn.addEventListener('click', () => {\n    if (list.length === 0) {\n      alert('List is already empty.');\n      return;\n    }\n    if (!confirm('Are you sure you want to clear the entire list?')) return;\n    list.clear();\n    refreshListDisplay();\n    traversal.reset();\n    refreshTraversalDisplay();\n  });\n\n  sortListBtn.addEventListener('click', () => {\n    if (list.length < 2) {\n      alert('List must have 2 or more elements to sort.');\n      return;\n    }\n    list.sortLex();\n    refreshListDisplay();\n    resetTraversalIfInvalid();\n  });\n\n  removeDuplicatesBtn.addEventListener('click', () => {\n    if (list.length < 2) {\n      alert('List must have 2 or more elements to remove duplicates.');\n      return;\n    }\n    list.removeDuplicates();\n    refreshListDisplay();\n    resetTraversalIfInvalid();\n  });\n\n  // Debug, Export/Import\n  exportJSONBtn.addEventListener('click', () => {\n    const arr = list.toArray();\n    try {\n      const json = JSON.stringify(arr, null, 2);\n      jsonTextarea.value = json;\n      jsonMessageDiv.textContent = 'Export successful. JSON copied to textarea.';\n    } catch (e) {\n      jsonMessageDiv.textContent = 'Export failed: ' + e.message;\n    }\n  });\n\n  importJSONBtn.addEventListener('click', () => {\n    const text = jsonTextarea.value.trim();\n    if (text === '') {\n      jsonMessageDiv.textContent = 'No JSON input to import.';\n      jsonTextarea.focus();\n      return;\n    }\n    try {\n      const arr = JSON.parse(text);\n      if (!Array.isArray(arr)) {\n        jsonMessageDiv.textContent = 'JSON is not an array.';\n        return;\n      }\n      list.fromArray(arr.map(String));\n      refreshListDisplay();\n      resetTraversalIfInvalid();\n      jsonMessageDiv.textContent = `Import successful. List length: ${list.length}`;\n    } catch (e) {\n      jsonMessageDiv.textContent = 'Import failed: ' + e.message;\n    }\n  });\n\n  // If current traversal points to invalid position (e.g. after deletion), reset\n  function resetTraversalIfInvalid() {\n    const current = traversal.getCurrent();\n    if (current.pos === -1) {\n      traversal.reset();\n    } else if (current.pos >= list.length) {\n      traversal.reset();\n    }\n    refreshTraversalDisplay();\n  }\n\n  // Initialize\n  refreshListDisplay();\n  refreshTraversalDisplay();\n\n})();\n</script>\n\n</body>\n</html>"
