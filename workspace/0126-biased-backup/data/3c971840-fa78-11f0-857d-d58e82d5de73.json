    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Radix Sort Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Space Grotesk', sans-serif;\n    color: #e0e6f0;\n    overflow-x: hidden;\n    user-select: none;\n  }\n  h1 {\n    margin: 1.2rem 0 0.4rem;\n    font-weight: 700;\n    font-size: 2.8rem;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: #85d7ff;\n    text-shadow: 0 0 6px #32bfffaa;\n  }\n\n  h2 {\n    margin: 0 0 1.5rem 0;\n    font-weight: 500;\n    font-size: 1.2rem;\n    color: #a8c6ffcc;\n    letter-spacing: 0.06em;\n  }\n\n  /* Container */\n  .container {\n    max-width: 900px;\n    margin: 2rem auto 5rem;\n    background: rgba(30, 50, 70, 0.72);\n    border-radius: 1.4rem;\n    padding: 2.8rem 3rem 3.2rem;\n    box-shadow:\n      0 0 12px 3px #1da1f2bb,\n      inset 0 0 15px 2px #32bfff55;\n  }\n\n  /* Buttons */\n  .btn-group {\n    display: flex;\n    justify-content: center;\n    gap: 1.6rem;\n    margin: 1.8rem 0 3rem;\n  }\n\n  button {\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 700;\n    font-size: 1.1rem;\n    padding: 0.9rem 2rem;\n    border-radius: 12px;\n    border: none;\n    cursor: pointer;\n    background: linear-gradient(145deg, #1d8cf3, #0d6cbc);\n    color: #e0e6f0;\n    box-shadow:\n      0 4px 15px #0f4e8faa,\n      inset 0 -1px 4px #143d69;\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.18s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #47a7ff, #1d8cf3);\n    box-shadow:\n      0 6px 20px #1d8cf3cc,\n      inset 0 -1px 6px #1661a4;\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(1px);\n    box-shadow:\n      0 2px 9px #0f4e8fbb,\n      inset 0 -1px 4px #0b3e6e;\n  }\n  button:disabled {\n    background: #0b2c4fdd;\n    cursor: default;\n    box-shadow: none;\n    color: #779bb3aa;\n  }\n\n  /* Visualization area */\n  #visualizer {\n    position: relative;\n    height: 290px;\n    background: linear-gradient(135deg, #122437, #274264);\n    border-radius: 1rem;\n    overflow: visible;\n    box-shadow:\n      0 0 15px 3px #2a70f8bb,\n      inset 0 0 20px 2px #32bfff55;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    padding: 1rem 1rem 1.8rem 1rem;\n  }\n\n  /* Bars container */\n  .bars {\n    display: flex;\n    gap: 1rem;\n    align-items: flex-end;\n    justify-content: center;\n    flex-wrap: nowrap;\n  }\n\n  /* Individual bar */\n  .bar {\n    position: relative;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    width: 36px;\n    border-radius: 0.35rem;\n    box-shadow:\n      0 3px 13px #0f71ffcc,\n      inset 0 -3px 12px #145effee;\n    transition:\n      background-color 0.5s ease,\n      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    cursor: default;\n    user-select: none;\n  }\n  .bar[data-highlight=\"digit\"] {\n    background: #59f0ffcc;\n    box-shadow:\n      0 0 20px 5px #59d9ffff,\n      inset 0 0 18px #47c1fff4;\n    transform: translateY(-8px);\n    z-index: 10;\n  }\n  .bar[data-highlight=\"bucket\"] {\n    background: #e26caccc;\n    box-shadow:\n      0 0 25px 6px #d1488aff,\n      inset 0 0 20px #b1397ee3;\n    transform: translateY(-10px);\n    z-index: 12;\n  }\n  .bar.sorted {\n    background: #71ffb5cc;\n    box-shadow:\n      0 0 18px 4px #4acf8ff5,\n      inset 0 0 20px #3db77ccc;\n    transform: translateY(0);\n  }\n\n  /* Bar height and label */\n  .bar .height-label {\n    position: absolute;\n    bottom: 100%;\n    margin-bottom: 8px;\n    color: #a5d8ffcc;\n    font-size: 0.9rem;\n    font-weight: 600;\n    letter-spacing: 0.05em;\n    text-shadow: 0 0 5px #47bfffdd;\n    user-select: none;\n  }\n  .bar .value-label {\n    color: #d0ebffdd;\n    font-weight: 700;\n    font-size: 1.12rem;\n    letter-spacing: 0.12em;\n    text-shadow:\n      0 0 5px #32bfffcc,\n      0 0 10px #9fddfff2;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Buckets container */\n  #buckets-area {\n    margin-top: 32px;\n    display: flex;\n    justify-content: center;\n    gap: 14px;\n    flex-wrap: nowrap;\n    user-select: none;\n  }\n\n  .bucket {\n    background: #112e4cbb;\n    border-radius: 0.85rem;\n    width: 46px;\n    min-height: 80px;\n    box-shadow:\n      inset 0 0 25px 10px #1e90ff33,\n      0 0 16px 3px #1e90ffcc;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 6px 4px 10px 4px;\n    transition:\n      box-shadow 0.35s ease,\n      transform 0.5s ease;\n    flex-wrap: nowrap;\n  }\n  .bucket[data-active=\"true\"] {\n    box-shadow:\n      inset 0 0 30px 14px #67f9ffff,\n      0 0 25px 6px #67f9ffcc;\n    transform: translateY(-6px);\n    z-index: 15;\n  }\n\n  .bucket-label {\n    font-weight: 700;\n    font-size: 1rem;\n    color: #4de2ffdd;\n    margin-bottom: 0.45rem;\n    text-shadow: 0 0 8px #4de2ffdd;\n    user-select: text;\n    letter-spacing: 0.14em;\n  }\n\n  .bucket-bars {\n    display: flex;\n    flex-direction: column-reverse;\n    gap: 6px;\n    align-items: center;\n    overflow-y: visible;\n    max-height: 120px;\n    min-height: 90px;\n    justify-content: flex-start;\n  }\n\n  .bucket-bars .bar {\n    width: 38px;\n    border-radius: 0.45rem;\n    font-size: 0.95rem;\n    letter-spacing: 0.06em;\n    box-shadow:\n      0 2px 10px #b1e7ffff,\n      inset 0 -2px 8px #89d6ffcc;\n    cursor: default;\n    transform: translateY(0);\n  }\n  .bucket-bars .bar .height-label {\n    display: none;\n  }\n  .bucket-bars .bar .value-label {\n    font-size: 1.1rem;\n    color: #bbffffee;\n    text-shadow:\n      0 0 7px #33ddffff,\n      0 0 14px #46eaffef;\n  }\n\n  /* Footer Text */\n  .footer-text {\n    text-align: center;\n    font-size: 0.85rem;\n    color: #83c6ff99;\n    padding: 16px 18px 40px;\n    user-select: none;\n  }\n\n  /* Scrollbar hidden on buckets area for neatness */\n  #buckets-area::-webkit-scrollbar {\n    display: none;\n  }\n\n  /* Smooth fade animation for bars appearing */\n  .fade-in {\n    animation: fadeInUp 1.2s ease forwards;\n    opacity: 0;\n    transform: translateY(12px);\n  }\n  @keyframes fadeInUp {\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"Radix Sort Visualization\">\n    <h1>Radix Sort</h1>\n    <h2>An elegant demonstration of sorting by digits with luminous animation</h2>\n\n    <div class=\"btn-group\" role=\"region\" aria-label=\"Controls\">\n      <button id=\"start-button\" aria-live=\"polite\" aria-label=\"Start Radix Sort Animation\">Start Animation</button>\n      <button id=\"reset-button\" aria-live=\"polite\" aria-label=\"Reset to initial state\" disabled>Reset</button>\n    </div>\n\n    <section id=\"visualizer\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <!-- Bars representing array elements -->\n      <div class=\"bars\" id=\"bars-container\" aria-label=\"Array bars representing numbers to be sorted\">\n        <!-- Bars dynamically generated -->\n      </div>\n    </section>\n\n    <section id=\"buckets-area\" aria-label=\"Buckets for digits 0 through 9\">\n      <!-- Buckets dynamically generated -->\n    </section>\n\n    <div class=\"footer-text\" aria-hidden=\"true\">\n      &copy; 2024 &bull; Visualization by AI &bull; Inspired by data structures &amp; algorithms\n    </div>\n  </main>\n\n<script>\n(() => {\n  'use strict';\n\n  const ARRAY_LENGTH = 14;\n  const MAX_NUMBER = 9999; // Up to 4 digits\n  const DIGIT_BASE = 10;\n  const ANIMATION_DELAY = 900; // ms between steps\n\n  const barsContainer = document.getElementById('bars-container');\n  const bucketsArea = document.getElementById('buckets-area');\n  const startBtn = document.getElementById('start-button');\n  const resetBtn = document.getElementById('reset-button');\n\n  // Generate distinct pastel-blue tinted colors, avoiding monotony\n  function generateBarColor(idx, total) {\n    const hue = 200 + (idx / total) * 60; // from blue-ish to cyan-ish\n    return `hsl(${hue}, 80%, 65%)`;\n  }\n\n  // Create bars representing array elements\n  function createBars(arr) {\n    barsContainer.innerHTML = '';\n    for (let i = 0; i < arr.length; i++) {\n      const val = arr[i];\n      const bar = document.createElement('div');\n      bar.className = 'bar fade-in';\n      bar.style.height = `${40 + (val / MAX_NUMBER) * 210}px`; // dynamic height 40-250 px\n\n      bar.style.backgroundColor = generateBarColor(i, arr.length);\n      bar.style.boxShadow = `\n        0 4px 12px hsla(200, 90%, 65%, 0.85),\n        inset 0 -6px 25px hsla(200, 80%, 55%, 0.85)\n      `;\n\n      bar.setAttribute('data-index', i);\n      bar.setAttribute('tabindex', '-1');\n\n      const heightLabel = document.createElement('div');\n      heightLabel.className = 'height-label';\n      heightLabel.textContent = val;\n\n      const valueLabel = document.createElement('div');\n      valueLabel.className = 'value-label';\n      valueLabel.textContent = val;\n\n      bar.appendChild(heightLabel);\n      bar.appendChild(valueLabel);\n      barsContainer.appendChild(bar);\n    }\n  }\n\n  // Create buckets 0-9\n  function createBuckets() {\n    bucketsArea.innerHTML = '';\n    for(let i=0; i<10; i++) {\n      const bucket = document.createElement('div');\n      bucket.className = 'bucket';\n      bucket.setAttribute('data-index', i);\n      bucket.setAttribute('tabindex', '-1');\n\n      const label = document.createElement('div');\n      label.className = 'bucket-label';\n      label.textContent = i;\n\n      const bucketBars = document.createElement('div');\n      bucketBars.className = 'bucket-bars';\n\n      bucket.appendChild(label);\n      bucket.appendChild(bucketBars);\n\n      bucketsArea.appendChild(bucket);\n    }\n  }\n\n  // Radix Sort utility: get digit at position pos (0 = least significant)\n  function digitAt(num, pos) {\n    return Math.floor(num / Math.pow(10, pos)) % 10;\n  }\n\n  // Sleep using async Promise\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Animation and visualization logic\n  async function animateRadixSort(arr) {\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n\n    const bars = [...barsContainer.children];\n\n    const maxVal = Math.max(...arr);\n    const maxDigits = maxVal.toString().length;\n\n    // For visual clarity, mark all bars as default\n    bars.forEach(bar => {\n      bar.classList.remove('sorted', 'bar-highlight');\n      bar.style.transform = 'translateY(0)';\n    });\n\n    for (let digitPos = 0; digitPos < maxDigits; digitPos++) {\n      // Highlight current digit position\n      updateMessage(`Sorting on digit position: ${digitPos + 1}`);\n\n      // Mark buckets active\n      highlightActiveBucket(null); // clear active buckets\n      clearBucketsBars();\n\n      // Highlight digit in bars & move bars up slightly\n      for (let i = 0; i < arr.length; i++) {\n        const bar = bars[i];\n        bar.dataset.highlight = 'digit';\n        // Show digit overlay or color effect?\n        // We'll rely on blue highlight and slight raise\n      }\n      await sleep(ANIMATION_DELAY / 2);\n\n      // Place each bar into corresponding bucket visually\n      let buckets = Array.from({ length: 10 }, () => []);\n      for (let i = 0; i < arr.length; i++) {\n        let digit = digitAt(arr[i], digitPos);\n        buckets[digit].push(arr[i]);\n      }\n\n      // Animate distributation\n      for (let b = 0; b < buckets.length; b++) {\n        highlightActiveBucket(b);\n        // Remove all \"digit\" highlight from bars before transfer\n        bars.forEach(bar => bar.removeAttribute('data-highlight'));\n        await sleep(ANIMATION_DELAY / 3);\n\n        // Remove bars from main display that move into this bucket\n        const barsToMove = [];\n        for (let i = 0; i < arr.length; i++) {\n          let d = digitAt(arr[i], digitPos);\n          if (d === b) {\n            barsToMove.push({\n              value: arr[i],\n              idx: i,\n              barElem: bars[i]\n            });\n          }\n        }\n\n        // Animate bars moving down from main container into bucket\n        for (let bmv of barsToMove) {\n          bmv.barElem.dataset.highlight = 'bucket';\n        }\n        await sleep(ANIMATION_DELAY / 2);\n\n        let bucketElem = bucketsArea.children[b];\n        let bucketBars = bucketElem.querySelector('.bucket-bars');\n\n        // Actually move bars DOM nodes into bucket for visual\n        for (let bmv of barsToMove) {\n          bucketBars.prepend(bmv.barElem);\n        }\n        await sleep(ANIMATION_DELAY / 2);\n      }\n\n      highlightActiveBucket(null);\n      clearBarsHighlight();\n\n      // Reassemble array from buckets visually and logically\n      let newArr = [];\n      let newBars = [];\n      for (let i = 0; i < buckets.length; i++) {\n        let bucketElem = bucketsArea.children[i];\n        let bucketBars = bucketElem.querySelectorAll('.bar');\n        for (let b of bucketBars) {\n          newArr.push(parseInt(b.querySelector('.value-label').textContent, 10));\n          newBars.push(b);\n        }\n      }\n\n      // Animate bars moving from bucket back to main container\n      barsContainer.style.justifyContent = 'center';\n\n      // Delay before moving back\n      await sleep(ANIMATION_DELAY / 2);\n\n      for(let b of newBars) {\n        barsContainer.appendChild(b);\n        b.dataset.highlight = 'digit'; // light highlight while moving back\n      }\n\n      // Force update bars array\n      bars.length = 0;\n      bars.push(...newBars);\n\n      await sleep(ANIMATION_DELAY / 2);\n      newBars.forEach(bar => bar.removeAttribute('data-highlight'));\n\n      // Update array reference\n      arr = newArr;\n\n      // Small delay before next digit round\n      await sleep(ANIMATION_DELAY * 0.7);\n    }\n\n    // Mark bars as sorted - luminous green\n    bars.forEach(bar => {\n      bar.classList.add('sorted');\n      bar.removeAttribute('data-highlight');\n    });\n\n    updateMessage(`Sorting complete! Array sorted in ascending order.`);\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n\n    return arr;\n  }\n\n  function updateMessage(msg) {\n    startBtn.setAttribute('aria-label', msg);\n  }\n\n  function highlightActiveBucket(bucketIndex) {\n    for (let i = 0; i < bucketsArea.children.length; i++) {\n      const bucket = bucketsArea.children[i];\n      if (i === bucketIndex) {\n        bucket.setAttribute('data-active', 'true');\n      } else {\n        bucket.removeAttribute('data-active');\n      }\n    }\n  }\n\n  function clearBucketsBars() {\n    for(let i=0; i<bucketsArea.children.length; i++) {\n      const bucketBars = bucketsArea.children[i].querySelector('.bucket-bars');\n      bucketBars.innerHTML = '';\n    }\n  }\n\n  function clearBarsHighlight() {\n    for(let bar of barsContainer.children) {\n      bar.removeAttribute('data-highlight');\n    }\n  }\n\n  // Initial array and visualization setup\n  let array = [];\n  function generateRandomArray() {\n    array = [];\n    const used = new Set();\n    while(array.length < ARRAY_LENGTH) {\n      let val = Math.floor( Math.random() * (MAX_NUMBER+1) );\n      // Enforce uniqueness for aesthetic clarity\n      if (!used.has(val)) {\n        used.add(val);\n        array.push(val);\n      }\n    }\n    return array;\n  }\n\n  // Reset visualization to initial state\n  function resetVisualization() {\n    array = generateRandomArray();\n    createBars(array);\n    createBuckets();\n    updateMessage('Ready to start Radix Sort animation.');\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Event handlers for buttons\n  startBtn.addEventListener('click', async () => {\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    await animateRadixSort(array);\n  });\n  resetBtn.addEventListener('click', () => {\n    resetVisualization();\n  });\n\n  // On load initialize\n  resetVisualization();\n\n})();\n</script>\n</body>\n</html>"
