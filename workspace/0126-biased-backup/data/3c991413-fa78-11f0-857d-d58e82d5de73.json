    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>CPU Scheduling — A Visual Symphony</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Open+Sans&display=swap');\n\n  /* Reset and base */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n  body {\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Open Sans', sans-serif;\n    color: #e9ecef;\n    height: 100vh;\n    overflow: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2.5rem 1rem 3rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 3.2rem;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    color: #e0e6f0;\n    margin-bottom: 0.5rem;\n    filter: drop-shadow(0 0 8px #64f0d4cc);\n  }\n  h2 {\n    font-weight: 700;\n    font-size: 1.15rem;\n    color: #89e6f3;\n    margin-bottom: 1.8rem;\n    letter-spacing: 0.07em;\n    text-transform: uppercase;\n    filter: drop-shadow(0 0 5px #65d9f14f);\n  }\n\n  /* Container for scheduler layout */\n  .container {\n    position: relative;\n    max-width: 1100px;\n    width: 100%;\n    background: rgba(255 255 255 / 0.06);\n    border-radius: 1.25rem;\n    padding: 2rem 3rem 3rem;\n    box-shadow:\n      inset 0 0 130px 11px #15d0c933,\n      0 0 30px 2px #01f1df44;\n  }\n\n  /* CPU graphic */\n  .cpu {\n    width: 160px;\n    height: 160px;\n    margin: 0 auto 3rem;\n    position: relative;\n    filter: drop-shadow(0 0 20px #4affffcc);\n    animation: gentlePulse 5s ease-in-out infinite alternate;\n  }\n\n  /* Central microchip */\n  .cpu-base {\n    width: 100%;\n    height: 100%;\n    border-radius: 32px;\n    background: linear-gradient(135deg, #0ff7f766 0%, #00d2ff99 70%);\n    box-shadow:\n      0 0 40px 2px #00d9ffcc,\n      inset 0 0 38px 10px #00aecc88,\n      inset 0 0 15px 5px #00fcffcc;\n    position: relative;\n    overflow: visible;\n  }\n\n  /* CPU pins around base */\n  .pin-row {\n    position: absolute;\n    display: flex;\n    gap: 8px;\n  }\n  .pin {\n    width: 15px;\n    height: 8px;\n    background: linear-gradient(90deg, #00e4ff, #44ffff);\n    border-radius: 5px 5px 3px 3px;\n    filter: drop-shadow(0 0 8px #2bd4e1cc);\n    animation: pinGlow 4s ease-in-out infinite alternate;\n  }\n\n  .pin-row.top {\n    top: -18px;\n    left: 18px;\n  }\n  .pin-row.bottom {\n    bottom: -18px;\n    left: 18px;\n  }\n  .pin-row.left {\n    top: 18px;\n    left: -24px;\n    flex-direction: column;\n    gap: 9px;\n  }\n  .pin-row.right {\n    top: 18px;\n    right: -24px;\n    flex-direction: column;\n    gap: 9px;\n  }\n\n  /* Scheduling queue container */\n  .queue-section {\n    margin-top: 1.8rem;\n  }\n\n  .queue-title {\n    font-weight: 700;\n    font-size: 1.15rem;\n    letter-spacing: 0.08em;\n    color: #7ef2e6;\n    margin-bottom: 0.75rem;\n    filter: drop-shadow(0 0 6px #22dfebbb);\n  }\n\n  /* Process queue bar */\n  .queue-bar {\n    display: flex;\n    gap: 0.28rem;\n    background: rgba(255 255 255 / 0.1);\n    border-radius: 20px;\n    padding: 0.35rem;\n    box-shadow: inset 0 0 40px #19cfd68c;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  /* Individual process block */\n  .process {\n    flex-grow: 1;\n    height: 42px;\n    border-radius: 15px;\n    position: relative;\n    filter: drop-shadow(0 0 6px #00f1ffcc);\n    cursor: default;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding-left: 12px;\n    font-weight: 700;\n    color: #ffffffcc;\n    text-shadow:\n      0 0 7px #00eac5aa,\n      0 0 15px #00e2ffc4;\n    font-family: 'Montserrat', sans-serif;\n    letter-spacing: 0.03em;\n    user-select: none;\n  }\n\n  /* Different colors for processes */\n  .process.p1 {\n    background: linear-gradient(135deg, #00ffc2cc 0%, #00dcc9dd 100%);\n    box-shadow: 0 0 12px 2px #00dabe;\n  }\n  .process.p2 {\n    background: linear-gradient(135deg, #ffe600cc 0%, #ffde0088 100%);\n    box-shadow: 0 0 12px 2px #f1d400;\n  }\n  .process.p3 {\n    background: linear-gradient(135deg, #ff6f91cc 0%, #ff4366ee 100%);\n    box-shadow: 0 0 12px 2px #fc4969;\n  }\n  .process.p4 {\n    background: linear-gradient(135deg, #8360c3cc 0%, #2ebf91cc 100%);\n    box-shadow: 0 0 12px 2px #4983f9;\n  }\n  .process.p5 {\n    background: linear-gradient(135deg, #00f2ffcc 0%, #0051d4bb 100%);\n    box-shadow: 0 0 14px 3px #00a6ff;\n  }\n\n  /* Process label overlay shimmer */\n  .process label {\n    font-size: 0.88rem;\n    pointer-events: none;\n  }\n\n  /* Timers bar inside each process for visual burst */\n  .burst-bar {\n    position: absolute;\n    top: 0;\n    left: 0;\n    height: 5px;\n    background: #ffffffbb;\n    border-radius: 3px 3px 0 0;\n    filter: drop-shadow(0 0 10px #fff8);\n    transition: width 0.8s ease;\n  }\n\n  /* Legend container */\n  .legend {\n    font-size: 0.85rem;\n    color: #a4b0be;\n    margin-top: 2rem;\n    max-width: 600px;\n    line-height: 1.45;\n    user-select: none;\n  }\n\n  /* Buttons row */\n  .btn-row {\n    margin-top: 2.6rem;\n    display: flex;\n    gap: 18px;\n    justify-content: center;\n  }\n\n  button {\n    border: none;\n    background: linear-gradient(135deg, #0ffeded0, #03c8cbcc);\n    color: #003a42;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1.05rem;\n    letter-spacing: 0.07em;\n    padding: 0.75rem 2.7rem;\n    border-radius: 30px;\n    box-shadow:\n      0 0 16px 4px #1af0e5cc,\n      inset 0 -3px 7px #01adb6b3;\n    cursor: pointer;\n    transition:\n      background 0.3s ease,\n      box-shadow 0.3s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(135deg, #00ffffdd, #00d6dccc);\n    box-shadow:\n      0 0 22px 8px #0ff6f3ee,\n      inset 0 -3px 8px #01adb6e3;\n  }\n  button:active {\n    transform: scale(0.96);\n    box-shadow:\n      0 0 15px 4px #00c9d0cc,\n      inset 0 -3px 6px #0199a6b3;\n  }\n\n  /* Timeline and advanced grid line */\n  .timeline {\n    position: relative;\n    margin-top: 0.75rem;\n    height: 6px;\n    width: 100%;\n    background: rgba(255 255 255 / 0.12);\n    border-radius: 10px;\n    box-shadow:\n      inset 0 0 10px 1px #00d6d699,\n      0 0 6px 0 #00e9ff44;\n    overflow: hidden;\n  }\n\n  .tick {\n    position: absolute;\n    bottom: 0;\n    width: 1.4px;\n    height: 6px;\n    background: #00f1ffff;\n    filter: drop-shadow(0 0 8px #03efffcc);\n    opacity: 0.45;\n    transition: opacity 0.3s ease;\n  }\n  .tick-label {\n    position: absolute;\n    bottom: -22px;\n    color: #73f6ffcc;\n    font-weight: 600;\n    font-size: 0.78rem;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n    text-shadow: 0 0 4px #45e9ffcc;\n  }\n\n  /* Animations */\n\n  @keyframes pinGlow {\n    0%, 100% {\n      box-shadow: 0 0 6px #00fafb88;\n      filter: drop-shadow(0 0 8px #00e0ffcc);\n      background: linear-gradient(90deg, #00e4ff, #44ffff);\n    }\n    50% {\n      box-shadow: 0 0 15px #13fff8cc;\n      filter: drop-shadow(0 0 14px #00d9ffc8);\n      background: linear-gradient(90deg, #80f9ffcc, #c9ffffcc);\n    }\n  }\n  @keyframes gentlePulse {\n    0% {\n      filter: drop-shadow(0 0 20px #4affffcc);\n      transform: translateZ(0) rotate(0deg) scale(1);\n    }\n    50% {\n      filter: drop-shadow(0 0 26px #64fff6cc);\n      transform: translateZ(0) rotate(2deg) scale(1.02);\n    }\n    100% {\n      filter: drop-shadow(0 0 20px #4affffcc);\n      transform: translateZ(0) rotate(0deg) scale(1);\n    }\n  }\n\n  /* Loading swirl background */\n  .loading-swirl {\n    pointer-events: none;\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    background:\n      radial-gradient(circle at center, transparent 48%, rgba(0,255,255,.08) 70%),\n      conic-gradient(from 260deg at 50% 50%, #00ffff40 0% 20%, transparent 35% 100%);\n    animation: swirlSpin 22s linear infinite;\n    filter: blur(4px) brightness(1.12);\n    z-index: 1;\n  }\n  @keyframes swirlSpin {\n    0% { transform: rotate(0deg);}\n    100% { transform: rotate(360deg);}\n  }\n\n  /* Tooltip on processes */\n  .tooltip {\n    position: absolute;\n    bottom: calc(100% + 10px);\n    left: 50%;\n    transform: translateX(-50%);\n    background: rgba(0 255 255 / 0.85);\n    padding: 7px 12px;\n    border-radius: 24px;\n    color: #003a42;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 0.9rem;\n    white-space: nowrap;\n    box-shadow: 0 0 12px 3px #00e8ffcc;\n    pointer-events: none;\n    opacity: 0;\n    transition: opacity 0.25s ease;\n    user-select: none;\n    z-index: 999;\n  }\n  .process:hover .tooltip {\n    opacity: 1;\n  }\n\n  /* Responsive adjustments */\n  @media (max-width: 650px) {\n    .container {\n      padding: 1.5rem 1.75rem 2rem;\n    }\n    h1 {\n      font-size: 2.1rem;\n    }\n    h2 {\n      font-size: 0.9rem;\n    }\n    .cpu {\n      width: 130px;\n      height: 130px;\n      margin-bottom: 2rem;\n    }\n    .pin-row.top,\n    .pin-row.bottom {\n      left: 12px;\n    }\n    .queue-bar {\n      height: 32px;\n    }\n    .process {\n      font-size: 0.77rem;\n      height: 32px;\n      border-radius: 10px;\n      padding-left: 10px;\n    }\n    .legend {\n      font-size: 0.78rem;\n      max-width: 90vw;\n    }\n  }\n</style>\n</head>\n<body>\n  <div class=\"loading-swirl\" aria-hidden=\"true\"></div>\n\n  <h1>CPU Scheduling</h1>\n  <h2>A Visual Symphony of Process Management</h2>\n\n  <div class=\"container\" role=\"main\" aria-label=\"CPU Scheduling Visualization\">\n    <!-- CPU graphic -->\n    <div class=\"cpu\" aria-hidden=\"true\">\n      <div class=\"cpu-base\"></div>\n      <div class=\"pin-row top\" style=\"--pins:8;\">\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n      </div>\n      <div class=\"pin-row bottom\" style=\"--pins:8;\">\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n      </div>\n      <div class=\"pin-row left\" style=\"--pins:6;\">\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n      </div>\n      <div class=\"pin-row right\" style=\"--pins:6;\">\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n        <div class=\"pin\"></div>\n      </div>\n    </div>\n\n    <!-- Process queue display -->\n    <section class=\"queue-section\" aria-label=\"Ready Queue of Processes\">\n      <div class=\"queue-title\">Ready Queue</div>\n      <div class=\"queue-bar\" id=\"readyQueue\" aria-live=\"polite\" aria-atomic=\"true\">\n        <!-- dynamic processes added here -->\n      </div>\n      <div class=\"timeline\" aria-hidden=\"true\" aria-label=\"Process burst timeline\" role=\"presentation\"></div>\n    </section>\n\n    <!-- Buttons limited -->\n    <div class=\"btn-row\">\n      <button id=\"btnStep\" aria-controls=\"readyQueue\" aria-label=\"Advance CPU Scheduling Animation\">Step</button>\n      <button id=\"btnReset\" aria-label=\"Reset CPU Scheduling Animation\">Reset</button>\n    </div>\n\n    <!-- Legend/explanation text -->\n    <div class=\"legend\" aria-live=\"polite\" aria-atomic=\"true\">\n      <p><strong>Concept:</strong> Scheduling is how the CPU decides which process to execute next.</p>\n      <p><strong>Ready Queue:</strong> Simulates multiple processes waiting for CPU time with various burst durations.</p>\n      <p><strong>Pulse:</strong> The highlighted process is currently running and will complete its burst before next scheduling.</p>\n      <p><em>Press \"Step\" to advance scheduling through processes sequentially, or \"Reset\" to start over.</em></p>\n    </div>\n  </div>\n\n<script>\n  (function() {\n    const readyQueue = document.getElementById('readyQueue');\n    const btnStep = document.getElementById('btnStep');\n    const btnReset = document.getElementById('btnReset');\n\n    // Processes data: id, label, burst (total), color class, remaining burst\n    const processesData = [\n      {id: 'P1', label: 'Process 1', burst: 7, color: 'p1'},\n      {id: 'P2', label: 'Process 2', burst: 4, color: 'p2'},\n      {id: 'P3', label: 'Process 3', burst: 5, color: 'p3'},\n      {id: 'P4', label: 'Process 4', burst: 3, color: 'p4'},\n      {id: 'P5', label: 'Process 5', burst: 6, color: 'p5'}\n    ];\n\n    // State\n    let processes = [];\n    let currentIndex = 0;\n\n    // Initialize processes elements\n    function initProcesses() {\n      processes = processesData.map(p => ({\n        ...p,\n        remaining: p.burst,\n        element: null,\n        burstBar: null\n      }));\n      currentIndex = 0;\n      readyQueue.innerHTML = '';\n      // Create each process block\n      processes.forEach(p => {\n        const procEl = document.createElement('div');\n        procEl.classList.add('process', p.color);\n        procEl.style.flexBasis = p.burst * 20 + '%'; // scale with burst time\n        procEl.setAttribute('aria-label', `${p.label} burst time: ${p.burst}`);\n        procEl.setAttribute('tabindex', '-1');\n\n        // label inside\n        const label = document.createElement('label');\n        label.textContent = `${p.id} (${p.burst})`;\n        procEl.appendChild(label);\n\n        // burst bar\n        const burstBar = document.createElement('div');\n        burstBar.classList.add('burst-bar');\n        burstBar.style.width = '100%';\n        procEl.appendChild(burstBar);\n\n        // tooltip for remaining burst\n        const tooltip = document.createElement('div');\n        tooltip.className = 'tooltip';\n        tooltip.textContent = `Remaining Burst: ${p.burst}`;\n        procEl.appendChild(tooltip);\n\n        readyQueue.appendChild(procEl);\n\n        p.element = procEl;\n        p.burstBar = burstBar;\n        updateVisual(p);\n      });\n    }\n\n    // Animate scheduling step\n    function stepScheduling() {\n      if (processes.length === 0) return;\n\n      // Reset all highlights\n      processes.forEach(p => {\n        p.element.style.filter = 'none';\n        p.burstBar.style.transition = 'width 0.8s ease';\n      });\n\n      const currentProcess = processes[currentIndex];\n\n      if (currentProcess.remaining <= 0) {\n        // Move to next process\n        do {\n          currentIndex = (currentIndex + 1) % processes.length;\n        } while (processes[currentIndex].remaining <= 0);\n      }\n\n      const proc = processes[currentIndex];\n\n      // Highlight current running process with scaling glow\n      proc.element.style.filter =\n        'drop-shadow(0 0 16px #00ffffcc) drop-shadow(0 0 28px #00e8f7dd) saturate(1.18)';\n      \n      // Simulate burst running - deduct a quantum (full burst here)\n      let runBurst = proc.remaining;\n\n      // Animate the burst bar shrinking from 100% to 0\n      proc.burstBar.style.transition = 'width 0.9s ease';\n      proc.burstBar.style.width = '0%';\n\n      // Update remaining burst to 0\n      proc.remaining = 0;\n      updateVisual(proc);\n\n      // Move index to next process after animation (~950ms)\n      setTimeout(() => {\n        currentIndex = (currentIndex + 1) % processes.length;\n        \n        // If next selected has 0 remaining, find next available\n        let loopLimiter = 0;\n        while (processes[currentIndex].remaining === 0 && loopLimiter < processes.length) {\n          currentIndex = (currentIndex + 1) % processes.length;\n          loopLimiter++;\n        }\n\n        // If all are zero remaining, disable step and highlight reset\n        if (loopLimiter >= processes.length) {\n          btnStep.disabled = true;\n          btnStep.style.cursor = 'not-allowed';\n          btnStep.textContent = 'Complete ✓';\n        }\n      }, 950);\n    }\n\n    // Update visual representation of remaining burst\n    function updateVisual(proc) {\n      const ratio = proc.remaining / proc.burst;\n      proc.burstBar.style.width = (ratio * 100) + '%';\n      proc.element.querySelector('label').textContent = `${proc.id} (${proc.remaining})`;\n      proc.element.querySelector('.tooltip').textContent = `Remaining Burst: ${proc.remaining}`;\n      if (proc.remaining <= 0) {\n        proc.element.style.opacity = '0.48';\n        proc.element.style.filter = 'grayscale(0.8)';\n        proc.element.style.cursor = 'default';\n      } else {\n        proc.element.style.opacity = '1';\n        proc.element.style.filter = 'none';\n        proc.element.style.cursor = 'default';\n      }\n    }\n\n    // Reset animation and states\n    function resetScheduling() {\n      btnStep.disabled = false;\n      btnStep.style.cursor = 'pointer';\n      btnStep.textContent = 'Step';\n      initProcesses();\n    }\n\n    // Timeline tick marks below queue bar\n    const timeline = document.querySelector('.timeline');\n    function renderTimeline() {\n      timeline.innerHTML = '';\n      const total = processesData.reduce((a, c) => a + c.burst, 0);\n      let accum = 0;\n      processesData.forEach(p => {\n        accum += p.burst;\n        const tick = document.createElement('div');\n        tick.classList.add('tick');\n        const leftPercent = (accum / total) * 100;\n        tick.style.left = leftPercent + '%';\n\n        const label = document.createElement('div');\n        label.className = 'tick-label';\n        label.style.left = leftPercent + '%';\n        label.textContent = accum;\n\n        timeline.appendChild(tick);\n        timeline.appendChild(label);\n      });\n    }\n\n    // Initialize on load\n    resetScheduling();\n    renderTimeline();\n\n    // Button events\n    btnStep.addEventListener('click', () => stepScheduling());\n    btnReset.addEventListener('click', () => resetScheduling());\n  })();\n</script>\n</body>\n</html>"
