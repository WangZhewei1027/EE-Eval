    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Congestion Control Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 10px;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace;\n    margin-top: 5px;\n  }\n  input[type=number] {\n    width: 80px;\n  }\n  select {\n    font-family: monospace;\n  }\n  button {\n    font-family: monospace;\n  }\n  label {\n    display: block;\n    margin-top: 10px;\n  }\n  .panel {\n    border-top: 1px solid #000;\n    margin-top: 15px;\n    padding-top: 10px;\n  }\n  .log {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    height: 200px;\n    overflow-y: scroll;\n    font-size: 13px;\n  }\n  .inline {\n    display: inline-block;\n    margin-right: 10px;\n  }\n</style>\n</head>\n<body>\n<h1>Congestion Control Interactive Demo</h1>\n\n<p>\nThis demo models TCP-like congestion control (Additive Increase Multiplicative Decrease).\nYou can configure network parameters, manually send/send ACKs/loss events, and explore how congestion window and other state variables respond.\n</p>\n\n<div class=\"panel\" id=\"configPanel\">\n  <b>Network & Algorithm Configuration</b>\n  <label>Propagation Delay (ms):\n    <input type=\"number\" id=\"inputDelay\" min=\"1\" max=\"1000\" value=\"100\" />\n  </label>\n  <label>Link Capacity (pps: packets per second):\n    <input type=\"number\" id=\"inputCapacity\" min=\"10\" max=\"10000\" value=\"1000\" />\n  </label>\n  <label>Packet Loss Probability (0.0 - 1.0):\n    <input type=\"number\" id=\"inputLossProb\" step=\"0.01\" min=\"0\" max=\"1\" value=\"0.01\" />\n  </label>\n  <label>Maximum Segment Size (MSS in bytes):\n    <input type=\"number\" id=\"inputMSS\" min=\"1\" max=\"1460\" value=\"1460\" />\n  </label>\n  <label>Initial Congestion Window (cwnd in MSS):\n    <input type=\"number\" id=\"inputInitCwnd\" min=\"1\" max=\"100\" value=\"1\" />\n  </label>\n  <label>Slow Start Threshold (ssthresh in MSS):\n    <input type=\"number\" id=\"inputSsthresh\" min=\"1\" max=\"1000\" value=\"64\" />\n  </label>\n  <label>Algorithm:\n    <select id=\"selectAlgorithm\">\n      <option value=\"reno\" selected>TCP Reno</option>\n      <option value=\"cubic\">TCP Cubic (simplified)</option>\n      <option value=\"newreno\">TCP NewReno</option>\n      <option value=\"vegas\">TCP Vegas (simplified)</option>\n    </select>\n  </label>\n  <button id=\"btnApplyConfig\">Apply Configuration</button>\n</div>\n\n<div class=\"panel\" id=\"statePanel\">\n  <b>State Variables</b>\n  <div>CWND (congestion window in MSS): <span id=\"stateCwnd\">1</span></div>\n  <div>SSTHRESH (MSS): <span id=\"stateSsthresh\">64</span></div>\n  <div>Flight Size (in-flight packets): <span id=\"stateFlight\">0</span></div>\n  <div>Algorithm State: <span id=\"statePhase\">Slow Start</span></div>\n  <div>Current Round-Trip Time (RTT ms): <span id=\"stateRtt\">0</span></div>\n  <div>Packets Sent: <span id=\"statePacketsSent\">0</span></div>\n  <div>Packets Acked: <span id=\"statePacketsAcked\">0</span></div>\n  <div>Packets Lost: <span id=\"statePacketsLost\">0</span></div>\n  <div>Duplicate ACK count: <span id=\"stateDupAcks\">0</span></div>\n</div>\n\n<div class=\"panel\" id=\"manualControlPanel\">\n  <b>Manual Packet Operations</b>\n  <div>\n    <button id=\"btnSendPacket\">Send One Packet</button>\n    <button id=\"btnSendBurst\">Send Burst (send cwnd packets)</button>\n  </div>\n  <div>\n    <label>Receive ACK for Packet #:\n      <input type=\"number\" id=\"inputAckPacket\" min=\"1\" />\n      <button id=\"btnRecvAck\">Receive ACK</button>\n    </label>\n  </div>\n  <div>\n    <label>Report Packet Loss for Packet #:\n      <input type=\"number\" id=\"inputLossPacket\" min=\"1\" />\n      <button id=\"btnReportLoss\">Report Loss</button>\n    </label>\n  </div>\n  <div>\n    <button id=\"btnAutoRun\" title=\"Auto-simulate 100 packets sent with network loss\">Auto Run 100 Packets</button>\n    <button id=\"btnReset\">Reset State</button>\n  </div>\n</div>\n\n<div class=\"panel\" id=\"timePanel\">\n  <b>Timing Control (Simulated Time)</b>\n  <label>Time Per Packet Transmission (ms):\n    <input type=\"number\" id=\"inputPacketTime\" min=\"1\" max=\"1000\" value=\"10\" />\n  </label>\n  <label>Time Per ACK (ms):\n    <input type=\"number\" id=\"inputAckTime\" min=\"1\" max=\"1000\" value=\"10\" />\n  </label>\n  <label>Round Trip Time (RTT) Estimation Uses EWMA alpha:\n    <input type=\"number\" step=\"0.01\" min=\"0\" max=\"1\" id=\"inputRttAlpha\" value=\"0.125\" />\n  </label>\n</div>\n\n<div class=\"panel\" id=\"logsPanel\">\n  <b>Activity Log</b>\n  <div class=\"log\" id=\"logOutput\" tabindex=\"0\"></div>\n</div>\n\n<script>\n(() => {\n  // State variables and constants for TCP Reno (simple baseline)\n  const MSS_DEFAULT = 1460;\n\n  // Maintain simulation state\n  let state = {\n    cwnd: 1, // in MSS units\n    ssthresh: 64,\n    flight: 0,\n    packetsSent: 0,\n    packetsAcked: 0,\n    packetsLost: 0,\n    dupAcks: 0,\n    lastAck: 0,\n    phase: \"Slow Start\",\n    rtt: 100, // ms, initial estimate (propagation delay x2 for RTT?)\n    rttAlpha: 0.125,\n    rttVar: 0,\n    rto: 3000,\n    lastPacketSentTime: 0,\n    lastAckedPacketTime: 0,\n    sendTimes: {}, // packetNum: sendTime(ms)\n    ackedPackets: new Set(),\n    algo: \"reno\",\n    mss: MSS_DEFAULT,\n    delay: 100,\n    capacity: 1000,\n    lossProb: 0.01,\n    maxPacketNum: 0,\n    dupAckCountForPacket: 0,\n    cubicState: null,\n  };\n\n  // Cubic control (simplified)\n  class CubicState {\n    constructor() {\n      this.W_max = 0;\n      this.K = 0;\n      this.epochStart = null;\n      this.cwnd = 1;\n      this.lastUpdateTime = 0;\n      this.C = 0.4; // cubic scaling constant\n    }\n    updateCwnd(t) {\n      const K = this.K;\n      const C = this.C;\n      const tSec = (t - this.epochStart) / 1000;\n      const cubicWindow = C * Math.pow(tSec - K, 3) + this.W_max;\n      if (cubicWindow > 0) {\n        this.cwnd = cubicWindow;\n      }\n    }\n    onLoss(t) {\n      this.W_max = this.cwnd;\n      this.K = Math.cbrt(this.W_max / this.C);\n      this.epochStart = t;\n      this.cwnd *= 0.7; // multiplicative decrease\n      if (this.cwnd < 1) this.cwnd = 1;\n    }\n    onAck(t) {\n      if (!this.epochStart) this.epochStart = t;\n      this.updateCwnd(t);\n    }\n  }\n\n  // Vegas control (simplified)\n  class VegasState {\n    constructor() {\n      this.alpha = 1;\n      this.beta = 3;\n      this.baseRTT = null;\n      this.diff = 0;\n      this.phase = \"Slow Start\"; // or \"Cong Avoidance\"\n      this.cwnd = 1;\n    }\n    updateRTT(rtt) {\n      if (this.baseRTT === null || rtt < this.baseRTT) this.baseRTT = rtt;\n      this.diff = this.cwnd * (1 - this.baseRTT / rtt);\n      if (this.diff < this.alpha) {\n        // increase cwnd\n        this.cwnd += 1;\n        this.phase = \"Slow Start\";\n      } else if (this.diff > this.beta) {\n        // decrease cwnd\n        this.cwnd -= 1;\n        this.phase = \"Congestion Avoidance\";\n        if (this.cwnd < 1) this.cwnd = 1;\n      }\n    }\n  }\n\n  // DOM shortcuts\n  const el = {\n    inputDelay: document.getElementById(\"inputDelay\"),\n    inputCapacity: document.getElementById(\"inputCapacity\"),\n    inputLossProb: document.getElementById(\"inputLossProb\"),\n    inputMSS: document.getElementById(\"inputMSS\"),\n    inputInitCwnd: document.getElementById(\"inputInitCwnd\"),\n    inputSsthresh: document.getElementById(\"inputSsthresh\"),\n    selectAlgorithm: document.getElementById(\"selectAlgorithm\"),\n    btnApplyConfig: document.getElementById(\"btnApplyConfig\"),\n\n    stateCwnd: document.getElementById(\"stateCwnd\"),\n    stateSsthresh: document.getElementById(\"stateSsthresh\"),\n    stateFlight: document.getElementById(\"stateFlight\"),\n    statePhase: document.getElementById(\"statePhase\"),\n    stateRtt: document.getElementById(\"stateRtt\"),\n    statePacketsSent: document.getElementById(\"statePacketsSent\"),\n    statePacketsAcked: document.getElementById(\"statePacketsAcked\"),\n    statePacketsLost: document.getElementById(\"statePacketsLost\"),\n    stateDupAcks: document.getElementById(\"stateDupAcks\"),\n\n    btnSendPacket: document.getElementById(\"btnSendPacket\"),\n    btnSendBurst: document.getElementById(\"btnSendBurst\"),\n    inputAckPacket: document.getElementById(\"inputAckPacket\"),\n    btnRecvAck: document.getElementById(\"btnRecvAck\"),\n    inputLossPacket: document.getElementById(\"inputLossPacket\"),\n    btnReportLoss: document.getElementById(\"btnReportLoss\"),\n    btnAutoRun: document.getElementById(\"btnAutoRun\"),\n    btnReset: document.getElementById(\"btnReset\"),\n\n    inputPacketTime: document.getElementById(\"inputPacketTime\"),\n    inputAckTime: document.getElementById(\"inputAckTime\"),\n    inputRttAlpha: document.getElementById(\"inputRttAlpha\"),\n\n    logOutput: document.getElementById(\"logOutput\"),\n  };\n\n  // Utility: log output and keep scroll bottom\n  function log(msg) {\n    const now = new Date();\n    const t = now.toLocaleTimeString();\n    el.logOutput.textContent += `[${t}] ${msg}\\n`;\n    el.logOutput.scrollTop = el.logOutput.scrollHeight;\n  }\n\n  // Update displayed state values\n  function updateDisplay() {\n    el.stateCwnd.textContent = state.cwnd.toFixed(2);\n    el.stateSsthresh.textContent = state.ssthresh.toFixed(2);\n    el.stateFlight.textContent = state.flight;\n    el.statePhase.textContent = state.phase;\n    el.stateRtt.textContent = state.rtt.toFixed(1);\n    el.statePacketsSent.textContent = state.packetsSent;\n    el.statePacketsAcked.textContent = state.packetsAcked;\n    el.statePacketsLost.textContent = state.packetsLost;\n    el.stateDupAcks.textContent = state.dupAcks;\n  }\n\n  // RTT measurement & update with EWMA, update RTO (RFC stuff simplified)\n  function updateRTTEstimate(sampleRTT) {\n    if (!sampleRTT || sampleRTT <= 0) return;\n    const alpha = state.rttAlpha;\n    if (!state.rtt) {\n      state.rtt = sampleRTT;\n      state.rttVar = sampleRTT / 2;\n    } else {\n      state.rttVar = (1 - 0.25) * state.rttVar + 0.25 * Math.abs(state.rtt - sampleRTT);\n      state.rtt = (1 - alpha) * state.rtt + alpha * sampleRTT;\n    }\n    // Simplified RTO\n    state.rto = state.rtt + 4 * state.rttVar;\n  }\n\n  // Congestion window increase on ACK (by algorithm)\n  function onPacketAcked(packetNum, recvTime) {\n    log(`ACK received for Packet #${packetNum}`);\n\n    // Ensure packet was sent and is not duplicate ACK\n    if (!state.ackedPackets.has(packetNum)) {\n      state.ackedPackets.add(packetNum);\n      state.packetsAcked++;\n\n      // Flight size decrement: one packet acknowledged\n      if (state.flight > 0) state.flight--;\n\n      // Calculate sample RTT if possible\n      if (state.sendTimes[packetNum]) {\n        const sendTime = state.sendTimes[packetNum];\n        let sampleRTT = recvTime - sendTime;\n        if (sampleRTT < 0) sampleRTT = state.rtt; // fallback\n        updateRTTEstimate(sampleRTT);\n      }\n\n      state.dupAcks = 0;\n\n      // CWND update according to algorithm and phase\n\n      if (state.algo === \"reno\" || state.algo === \"newreno\") {\n        if (state.phase === \"Slow Start\") {\n          // cwnd doubles approx each RTT => cwnd increases by 1 MSS per ACK\n          state.cwnd += 1;\n          if (state.cwnd >= state.ssthresh) {\n            state.phase = \"Congestion Avoidance\";\n            log(\"Entered Congestion Avoidance phase\");\n          }\n        } else if (state.phase === \"Congestion Avoidance\") {\n          // Additive increase (increase cwnd by ~1 MSS per RTT)\n          state.cwnd += 1 / state.cwnd;\n        }\n      } else if (state.algo === \"cubic\") {\n        // Cubic increases cwnd following cubic curve\n        state.cubicState.onAck(recvTime);\n        state.cwnd = state.cubicState.cwnd;\n        if (state.cwnd >= state.ssthresh) {\n          state.phase = \"Congestion Avoidance\";\n        } else {\n          state.phase = \"Slow Start\";\n        }\n      } else if (state.algo === \"vegas\") {\n        // Vegas adjusts based on RTT samples\n        state.vegasState.updateRTT(state.rtt);\n        state.cwnd = state.vegasState.cwnd;\n        state.phase = state.vegasState.phase;\n      }\n\n      if (state.cwnd < 1) state.cwnd = 1;\n    } else {\n      // Duplicate ACK\n      state.dupAcks++;\n      log(`Duplicate ACK #${state.dupAcks} for Packet #${packetNum}`);\n      if (state.algo === \"reno\" || state.algo === \"newreno\") {\n        if (state.dupAcks === 3) {\n          log(\"Triple duplicate ACKs detected, fast retransmit and fast recovery\");\n          state.ssthresh = Math.max(state.cwnd / 2, 2);\n          state.cwnd = state.ssthresh + 3;\n          state.phase = \"Fast Recovery\";\n        } else if (state.dupAcks > 3) {\n          state.cwnd += 1; // inflate cwnd during fast recovery\n        }\n      }\n    }\n\n    updateDisplay();\n  }\n\n  // Packet loss triggers multiplicative decrease + ssthresh update\n  function onPacketLoss(packetNum) {\n    log(`Packet loss detected for Packet #${packetNum}`);\n    state.packetsLost++;\n    if (state.flight > 0) state.flight--;\n\n    // Reset duplicate ACK count on loss\n    state.dupAcks = 0;\n\n    if (state.algo === \"reno\" || state.algo === \"newreno\") {\n      state.ssthresh = Math.max(state.cwnd / 2, 2);\n      state.cwnd = 1;\n      state.phase = \"Slow Start\";\n      log(`Entered Slow Start phase with ssthresh=${state.ssthresh.toFixed(2)}`);\n    } else if (state.algo === \"cubic\") {\n      state.cubicState.onLoss(Date.now());\n      state.cwnd = state.cubicState.cwnd;\n      state.ssthresh = Math.max(state.cwnd / 2, 2);\n      state.phase = \"Slow Start\";\n    } else if (state.algo === \"vegas\") {\n      // Vegas decreases cwnd gently on loss\n      state.vegasState.cwnd = Math.max(state.vegasState.cwnd / 2, 1);\n      state.cwnd = state.vegasState.cwnd;\n      state.phase = \"Slow Start\";\n    }\n\n    updateDisplay();\n  }\n\n  // Send one packet: increase flight, assign packet number, log send time\n  function sendPacket() {\n    state.maxPacketNum++;\n    const pnum = state.maxPacketNum;\n    const now = Date.now();\n    state.sendTimes[pnum] = now;\n    state.flight++;\n    state.packetsSent++;\n    log(`Sent Packet #${pnum}`);\n    updateDisplay();\n    return pnum;\n  }\n\n  // Send burst of cwnd (rounded down) packets\n  function sendBurst() {\n    let count = Math.floor(state.cwnd);\n    if (count < 1) count = 1;\n    log(`Sending burst of ${count} packets (cwnd=${state.cwnd.toFixed(2)})`);\n    let packets = [];\n    for (let i=0; i<count; i++) {\n      packets.push(sendPacket());\n    }\n    return packets;\n  }\n\n  // Reset state to initial config\n  function resetState() {\n    state.cwnd = parseFloat(el.inputInitCwnd.value) || 1;\n    state.ssthresh = parseFloat(el.inputSsthresh.value) || 64;\n    state.flight = 0;\n    state.phase = \"Slow Start\";\n    state.packetsSent = 0;\n    state.packetsAcked = 0;\n    state.packetsLost = 0;\n    state.rtt = (el.inputDelay.value * 2) || 100;\n    state.rttAlpha = parseFloat(el.inputRttAlpha.value) || 0.125;\n    state.dupAcks = 0;\n    state.lastAck = 0;\n    state.maxPacketNum = 0;\n    state.sendTimes = {};\n    state.ackedPackets = new Set();\n    state.algo = el.selectAlgorithm.value;\n    state.mss = parseInt(el.inputMSS.value) || MSS_DEFAULT;\n    state.delay = parseInt(el.inputDelay.value) || 100;\n    state.capacity = parseInt(el.inputCapacity.value) || 1000;\n    state.lossProb = parseFloat(el.inputLossProb.value) || 0.01;\n\n    if (state.algo === \"cubic\") {\n      state.cubicState = new CubicState();\n      state.cubicState.cwnd = state.cwnd;\n    } else {\n      state.cubicState = null;\n    }\n    if (state.algo === \"vegas\") {\n      state.vegasState = new VegasState();\n      state.vegasState.cwnd = state.cwnd;\n      state.vegasState.baseRTT = state.rtt;\n    } else {\n      state.vegasState = null;\n    }\n\n    el.logOutput.textContent = \"\";\n    log(\"Simulation reset.\");\n    updateDisplay();\n  }\n\n  // Auto run simulation: repeatedly send packets and simulate ACKs or losses with configured lossProb\n  async function autoRunSimulation(count=100) {\n    log(`Starting auto-run simulation for ${count} packets...`);\n    for (let i = 0; i < count; i++) {\n      if (state.flight >= Math.floor(state.cwnd)) {\n        // Wait for ACK or loss processing to reduce flight\n        await delay(50);\n        i--;\n        continue;\n      }\n      let p = sendPacket();\n      // Schedule ACK or loss after RTT + random transmission delay\n      await delay(5);\n      let lossRoll = Math.random();\n      if (lossRoll < state.lossProb) {\n        log(`Simulating loss for Packet #${p}`);\n        // report loss after RTT delay\n        setTimeout(() => { onPacketLoss(p); }, state.rtt + Math.random()*20);\n      } else {\n        // ACK after RTT + random jitter\n        setTimeout(() => { onPacketAcked(p, Date.now()); }, state.rtt + Math.random()*20);\n      }\n      await delay(10);\n    }\n    log(\"Auto-run simulation complete.\");\n  }\n\n  function delay(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Bind event handlers\n  el.btnApplyConfig.addEventListener(\"click\", () => {\n    resetState();\n  });\n  el.btnReset.addEventListener(\"click\", () => {\n    resetState();\n  });\n  el.btnSendPacket.addEventListener(\"click\", () => {\n    sendPacket();\n  });\n  el.btnSendBurst.addEventListener(\"click\", () => {\n    sendBurst();\n  });\n  el.btnRecvAck.addEventListener(\"click\", () => {\n    let pnum = parseInt(el.inputAckPacket.value);\n    if (!pnum || pnum < 1 || pnum > state.maxPacketNum) {\n      log(\"Invalid Packet Number for ACK\");\n      return;\n    }\n    onPacketAcked(pnum, Date.now());\n  });\n  el.btnReportLoss.addEventListener(\"click\", () => {\n    let pnum = parseInt(el.inputLossPacket.value);\n    if (!pnum || pnum < 1 || pnum > state.maxPacketNum) {\n      log(\"Invalid Packet Number for Loss\");\n      return;\n    }\n    onPacketLoss(pnum);\n  });\n  el.btnAutoRun.addEventListener(\"click\", async () => {\n    el.btnAutoRun.disabled = true;\n    await autoRunSimulation(100);\n    el.btnAutoRun.disabled = false;\n  });\n\n  // Initialize\n  resetState();\n})();\n</script>\n\n</body>\n</html>"
  },
