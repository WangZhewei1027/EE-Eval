    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Artistic Selection Sort Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap');\n        \n        :root {\n            --primary: #5e35b1;\n            --secondary: #3949ab;\n            --accent: #ff7043;\n            --light: #f5f5f5;\n            --dark: #212121;\n            --highlight: #d1c4e9;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--light);\n            color: var(--dark);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .header {\n            text-align: center;\n            padding: 2rem 0;\n            width: 100%;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n            margin-bottom: 2rem;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 2.8rem;\n            margin: 0;\n            letter-spacing: 1px;\n        }\n        \n        .subtitle {\n            font-weight: 300;\n            font-size: 1.2rem;\n            opacity: 0.9;\n            margin-top: 0.5rem;\n        }\n        \n        .container {\n            width: 90%;\n            max-width: 1000px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        \n        .visualization {\n            width: 100%;\n            height: 400px;\n            position: relative;\n            margin: 2rem 0;\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            padding-bottom: 2rem;\n            border-radius: 8px;\n            background: white;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);\n            overflow: hidden;\n        }\n        \n        .array-bar {\n            width: 40px;\n            margin: 0 4px;\n            background: linear-gradient(to top, var(--primary), var(--secondary));\n            border-radius: 4px 4px 0 0;\n            position: relative;\n            transition: height 0.3s ease, transform 0.3s ease, background 0.3s ease;\n            box-shadow: 0 4px 12px rgba(94, 53, 177, 0.2);\n        }\n        \n        .array-bar::after {\n            content: attr(data-value);\n            position: absolute;\n            bottom: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 14px;\n            color: var(--dark);\n            font-weight: 600;\n        }\n        \n        .array-bar.minimum {\n            background: linear-gradient(to top, var(--accent), #ff8a65);\n            transform: scaleY(1.05);\n            box-shadow: 0 4px 16px rgba(255, 112, 67, 0.3);\n        }\n        \n        .array-bar.comparing {\n            background: var(--highlight);\n            transform: scaleY(1.03);\n        }\n        \n        .array-bar.sorted {\n            background: linear-gradient(to top, #66bb6a, #81c784);\n            box-shadow: 0 4px 12px rgba(102, 187, 106, 0.2);\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n        \n        button {\n            padding: 0.8rem 1.5rem;\n            font-family: 'Montserrat', sans-serif;\n            font-size: 1rem;\n            font-weight: 600;\n            border: none;\n            border-radius: 4px;\n            background: var(--primary);\n            color: white;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 8px rgba(94, 53, 177, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 12px rgba(94, 53, 177, 0.4);\n            background: var(--secondary);\n        }\n        \n        button:disabled {\n            background: #bdbdbd;\n            cursor: not-allowed;\n            transform: none;\n            box-shadow: none;\n        }\n        \n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin: 1rem 0;\n            flex-wrap: wrap;\n        }\n        \n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n        \n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n        \n        .explanation {\n            background: white;\n            padding: 2rem;\n            border-radius: 8px;\n            margin: 2rem 0;\n            width: 100%;\n            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);\n            line-height: 1.6;\n        }\n        \n        .explanation h2 {\n            font-family: 'Playfair Display', serif;\n            color: var(--primary);\n            margin-top: 0;\n        }\n        \n        .explanation p {\n            margin-bottom: 1.5rem;\n        }\n        \n        .footer {\n            text-align: center;\n            padding: 2rem;\n            width: 100%;\n            margin-top: auto;\n            background: var(--dark);\n            color: white;\n            font-weight: 300;\n            font-size: 0.9rem;\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2rem;\n            }\n            \n            .visualization {\n                height: 300px;\n            }\n            \n            .array-bar {\n                width: 30px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Selection Sort</h1>\n        <div class=\"subtitle\">An Elegant Visualization</div>\n    </div>\n    \n    <div class=\"container\">\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to bottom, var(--primary), var(--secondary));\"></div>\n                <span>Unsorted</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to bottom, var(--highlight), #e1d5f7);\"></div>\n                <span>Comparing</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to bottom, var(--accent), #ff8a65);\"></div>\n                <span>Current Minimum</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(to bottom, #66bb6a, #81c784);\"></div>\n                <span>Sorted</span>\n            </div>\n        </div>\n        \n        <div class=\"visualization\" id=\"visualization\"></div>\n        \n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Sorting</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>The Art of Selection Sort</h2>\n            <p>Selection sort is an elegant, in-place comparison-based algorithm that divides the input list into two parts: the sublist of items already sorted, which is built up from left to right, and the sublist of items remaining to be sorted.</p>\n            <p>The algorithm proceeds by finding the smallest (or largest, depending on sorting order) element in the unsorted sublist, exchanging it with the leftmost unsorted element, and moving the sublist boundaries one element to the right.</p>\n            <p>Though not the most efficient for large datasets, selection sort is valued for its simplicity and the minimal number of swaps it makes (O(n) swaps in the worst case).</p>\n        </div>\n    </div>\n    \n    <div class=\"footer\">\n        A Visual Exploration of Algorithmic Beauty\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const visualization = document.getElementById('visualization');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let array = [];\n            let isSorting = false;\n            let animationSpeed = 500; // ms\n            \n            function generateRandomArray() {\n                const size = 15;\n                array = [];\n                for (let i = 0; i < size; i++) {\n                    array.push(Math.floor(Math.random() * 90) + 10);\n                }\n                renderArray();\n            }\n            \n            function renderArray() {\n                visualization.innerHTML = '';\n                const maxValue = Math.max(...array);\n                \n                array.forEach((value, index) => {\n                    const bar = document.createElement('div');\n                    bar.className = 'array-bar';\n                    bar.style.height = `${(value / maxValue) * 80}%`;\n                    bar.setAttribute('data-value', value);\n                    visualization.appendChild(bar);\n                });\n            }\n            \n            function highlightElements(indices, className) {\n                const bars = visualization.querySelectorAll('.array-bar');\n                indices.forEach(i => {\n                    bars[i].classList.add(className);\n                });\n                \n                return new Promise(resolve => {\n                    setTimeout(() => {\n                        indices.forEach(i => {\n                            bars[i].classList.remove(className);\n                        });\n                        resolve();\n                    }, animationSpeed);\n                });\n            }\n            \n            async function selectionSort() {\n                if (isSorting) return;\n                isSorting = true;\n                startBtn.disabled = true;\n                resetBtn.disabled = true;\n                \n                const bars = visualization.querySelectorAll('.array-bar');\n                const n = array.length;\n                \n                for (let i = 0; i < n - 1; i++) {\n                    let minIndex = i;\n                    \n                    // Highlight the current minimum\n                    bars[minIndex].classList.add('minimum');\n                    \n                    for (let j = i + 1; j < n; j++) {\n                        // Highlight the current comparison\n                        bars[j].classList.add('comparing');\n                        \n                        await new Promise(resolve => setTimeout(resolve, animationSpeed / 2));\n                        \n                        if (array[j] < array[minIndex]) {\n                            // Remove highlight from previous minimum\n                            bars[minIndex].classList.remove('minimum');\n                            minIndex = j;\n                            // Highlight new minimum\n                            bars[minIndex].classList.add('minimum');\n                            await new Promise(resolve => setTimeout(resolve, animationSpeed / 2));\n                        }\n                        \n                        // Remove comparison highlight\n                        bars[j].classList.remove('comparing');\n                    }\n                    \n                    // Perform swap if needed\n                    if (minIndex !== i) {\n                        // Highlight elements being swapped\n                        await highlightElements([i, minIndex], 'comparing');\n                        \n                        // Swap the values\n                        [array[i], array[minIndex]] = [array[minIndex], array[i]];\n                        renderArray();\n                        \n                        // Get new bar references after re-render\n                        const newBars = visualization.querySelectorAll('.array-bar');\n                        newBars[i].classList.add('minimum');\n                        await new Promise(resolve => setTimeout(resolve, animationSpeed / 2));\n                    }\n                    \n                    // Mark as sorted\n                    bars[i].classList.remove('minimum');\n                    bars[i].classList.add('sorted');\n                    \n                    // If last element\n                    if (i === n - 2) {\n                        bars[n - 1].classList.add('sorted');\n                    }\n                }\n                \n                isSorting = false;\n                startBtn.disabled = false;\n                resetBtn.disabled = false;\n            }\n            \n            startBtn.addEventListener('click', selectionSort);\n            resetBtn.addEventListener('click', function() {\n                if (!isSorting) {\n                    generateRandomArray();\n                }\n            });\n            \n            // Initialize\n            generateRandomArray();\n        });\n    </script>\n</body>\n</html>"
