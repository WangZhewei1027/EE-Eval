  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Linked List</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { max-width: 800px; margin: 0 auto; }\n        .controls { margin-bottom: 20px; border: 1px solid #ccc; padding: 10px; }\n        .control-group { margin-bottom: 10px; }\n        button, input, select { margin-right: 5px; }\n        .list-display { border: 1px solid #ccc; padding: 15px; min-height: 100px; }\n        .node { display: inline-block; border: 1px solid #000; padding: 5px; margin: 5px; }\n        .pointer { display: inline-block; margin: 0 5px; }\n        .null { color: #999; }\n        .stats { margin-top: 20px; border-top: 1px solid #ccc; padding-top: 10px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Linked List</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Node Operations</h3>\n                <input type=\"text\" id=\"nodeValue\" placeholder=\"Enter value\">\n                <button onclick=\"addToHead()\">Add to Head</button>\n                <button onclick=\"addToTail()\">Add to Tail</button>\n                <button onclick=\"removeFromHead()\">Remove from Head</button>\n                <button onclick=\"removeFromTail()\">Remove from Tail</button>\n                <button onclick=\"clearList()\">Clear List</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Insert/Remove at Position</h3>\n                <input type=\"number\" id=\"insertPos\" placeholder=\"Position\" min=\"0\">\n                <input type=\"text\" id=\"insertValue\" placeholder=\"Value\">\n                <button onclick=\"insertAtPosition()\">Insert</button>\n                <input type=\"number\" id=\"removePos\" placeholder=\"Position\" min=\"0\">\n                <button onclick=\"removeAtPosition()\">Remove</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Search Operations</h3>\n                <input type=\"text\" id=\"searchValue\" placeholder=\"Value to find\">\n                <button onclick=\"findValue()\">Find Value</button>\n                <button onclick=\"findAllOccurrences()\">Find All Occurrences</button>\n                <button onclick=\"countOccurrences()\">Count Occurrences</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>List Manipulation</h3>\n                <button onclick=\"reverseList()\">Reverse List</button>\n                <button onclick=\"sortList()\">Sort List</button>\n                <button onclick=\"removeDuplicates()\">Remove Duplicates</button>\n                <button onclick=\"rotateList()\">Rotate List</button>\n                <input type=\"number\" id=\"rotateBy\" placeholder=\"Positions\" min=\"1\" value=\"1\">\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Traversal Control</h3>\n                <button onclick=\"startTraversal()\">Start Traversal</button>\n                <button onclick=\"stepForward()\">Step Forward</button>\n                <button onclick=\"stepBackward()\">Step Backward</button>\n                <button onclick=\"stopTraversal()\">Stop Traversal</button>\n                <span>Speed:</span>\n                <input type=\"range\" id=\"traversalSpeed\" min=\"100\" max=\"2000\" value=\"500\">\n            </div>\n        </div>\n        \n        <div class=\"list-display\" id=\"listDisplay\">\n            <p>List is empty</p>\n        </div>\n        \n        <div class=\"stats\">\n            <h3>List Statistics</h3>\n            <p>Length: <span id=\"listLength\">0</span></p>\n            <p>Head Value: <span id=\"headValue\">null</span></p>\n            <p>Tail Value: <span id=\"tailValue\">null</span></p>\n            <div id=\"searchResults\"></div>\n        </div>\n        \n        <div class=\"info\">\n            <h3>Current Operation Log</h3>\n            <div id=\"operationLog\"></div>\n        </div>\n    </div>\n\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.next = null;\n            }\n        }\n\n        class LinkedList {\n            constructor() {\n                this.head = null;\n                this.tail = null;\n                this.length = 0;\n                this.traversalNode = null;\n                this.traversalInterval = null;\n                this.traversalHistory = [];\n                this.traversalIndex = -1;\n            }\n\n            addToHead(value) {\n                const newNode = new Node(value);\n                if (!this.head) {\n                    this.head = newNode;\n                    this.tail = newNode;\n                } else {\n                    newNode.next = this.head;\n                    this.head = newNode;\n                }\n                this.length++;\n                return this;\n            }\n\n            addToTail(value) {\n                const newNode = new Node(value);\n                if (!this.head) {\n                    this.head = newNode;\n                    this.tail = newNode;\n                } else {\n                    this.tail.next = newNode;\n                    this.tail = newNode;\n                }\n                this.length++;\n                return this;\n            }\n\n            removeFromHead() {\n                if (!this.head) return null;\n                const removedValue = this.head.value;\n                this.head = this.head.next;\n                this.length--;\n                if (this.length === 0) {\n                    this.tail = null;\n                }\n                return removedValue;\n            }\n\n            removeFromTail() {\n                if (!this.head) return null;\n                if (this.length === 1) {\n                    return this.removeFromHead();\n                }\n                let current = this.head;\n                let newTail = current;\n                while (current.next) {\n                    newTail = current;\n                    current = current.next;\n                }\n                this.tail = newTail;\n                this.tail.next = null;\n                this.length--;\n                return current.value;\n            }\n\n            insertAt(position, value) {\n                if (position < 0 || position > this.length) return false;\n                if (position === 0) return !!this.addToHead(value);\n                if (position === this.length) return !!this.addToTail(value);\n\n                const newNode = new Node(value);\n                let prev = this.getNodeAt(position - 1);\n                newNode.next = prev.next;\n                prev.next = newNode;\n                this.length++;\n                return true;\n            }\n\n            removeAt(position) {\n                if (position < 0 || position >= this.length) return null;\n                if (position === 0) return this.removeFromHead();\n                if (position === this.length - 1) return this.removeFromTail();\n\n                let prev = this.getNodeAt(position - 1);\n                let removed = prev.next;\n                prev.next = removed.next;\n                this.length--;\n                return removed.value;\n            }\n\n            getNodeAt(position) {\n                if (position < 0 || position >= this.length) return null;\n                let current = this.head;\n                for (let i = 0; i < position; i++) {\n                    current = current.next;\n                }\n                return current;\n            }\n\n            find(value) {\n                let current = this.head;\n                let position = 0;\n                while (current) {\n                    if (current.value === value) {\n                        return position;\n                    }\n                    current = current.next;\n                    position++;\n                }\n                return -1;\n            }\n\n            findAll(value) {\n                let current = this.head;\n                let positions = [];\n                let index = 0;\n                while (current) {\n                    if (current.value === value) {\n                        positions.push(index);\n                    }\n                    current = current.next;\n                    index++;\n                }\n                return positions;\n            }\n\n            count(value) {\n                let current = this.head;\n                let count = 0;\n                while (current) {\n                    if (current.value === value) {\n                        count++;\n                    }\n                    current = current.next;\n                }\n                return count;\n            }\n\n            reverse() {\n                let node = null;\n                let current = this.head;\n                this.head = this.tail;\n                this.tail = current;\n                while (current) {\n                    let next = current.next;\n                    current.next = node;\n                    node = current;\n                    current = next;\n                }\n                return this;\n            }\n\n            sort() {\n                const values = [];\n                let current = this.head;\n                while (current) {\n                    values.push(current.value);\n                    current = current.next;\n                }\n                values.sort((a, b) => a - b);\n                this.clear();\n                values.forEach(val => this.addToTail(val));\n                return this;\n            }\n\n            removeDuplicates() {\n                const seen = new Set();\n                let current = this.head;\n                let prev = null;\n                while (current) {\n                    if (seen.has(current.value)) {\n                        prev.next = current.next;\n                        this.length--;\n                        if (!current.next) {\n                            this.tail = prev;\n                        }\n                    } else {\n                        seen.add(current.value);\n                        prev = current;\n                    }\n                    current = current.next;\n                }\n                return this;\n            }\n\n            rotate(k) {\n                if (this.length <= 1 || k % this.length === 0) return this;\n                k = k % this.length;\n                if (k < 0) k += this.length;\n\n                let newTailPos = this.length - k - 1;\n                let newTail = this.getNodeAt(newTailPos);\n                let newHead = newTail.next;\n\n                this.tail.next = this.head;\n                this.head = newHead;\n                this.tail = newTail;\n                this.tail.next = null;\n\n                return this;\n            }\n\n            clear() {\n                this.head = null;\n                this.tail = null;\n                this.length = 0;\n                return this;\n            }\n\n            startTraversal() {\n                this.traversalNode = this.head;\n                this.traversalHistory = [];\n                this.traversalIndex = -1;\n                this.recordTraversalState();\n                return this.traversalNode;\n            }\n\n            stepForward() {\n                if (!this.traversalNode) return null;\n                this.traversalNode = this.traversalNode.next;\n                this.recordTraversalState();\n                return this.traversalNode;\n            }\n\n            stepBackward() {\n                if (this.traversalIndex <= 0) return null;\n                this.traversalIndex--;\n                this.traversalNode = this.traversalHistory[this.traversalIndex].node;\n                return this.traversalNode;\n            }\n\n            recordTraversalState() {\n                this.traversalHistory = this.traversalHistory.slice(0, this.traversalIndex + 1);\n                this.traversalHistory.push({\n                    node: this.traversalNode,\n                    time: new Date()\n                });\n                this.traversalIndex++;\n            }\n\n            autoTraverse(speed) {\n                this.stopTraversal();\n                this.startTraversal();\n                this.traversalInterval = setInterval(() => {\n                    if (!this.stepForward()) {\n                        this.stopTraversal();\n                    }\n                    updateDisplay();\n                }, speed);\n            }\n\n            stopTraversal() {\n                if (this.traversalInterval) {\n                    clearInterval(this.traversalInterval);\n                    this.traversalInterval = null;\n                }\n            }\n        }\n\n        const list = new LinkedList();\n        let highlightedNode = null;\n\n        function updateDisplay() {\n            const display = document.getElementById('listDisplay');\n            const lengthDisplay = document.getElementById('listLength');\n            const headDisplay = document.getElementById('headValue');\n            const tailDisplay = document.getElementById('tailValue');\n            \n            display.innerHTML = '';\n            lengthDisplay.textContent = list.length;\n            headDisplay.textContent = list.head ? list.head.value : 'null';\n            tailDisplay.textContent = list.tail ? list.tail.value : 'null';\n\n            if (list.length === 0) {\n                display.innerHTML = '<p>List is empty</p>';\n                return;\n            }\n\n            let current = list.head;\n            let position = 0;\n            while (current) {\n                const nodeElement = document.createElement('span');\n                nodeElement.className = 'node';\n                nodeElement.textContent = current.value;\n                \n                if (current === highlightedNode) {\n                    nodeElement.style.backgroundColor = '#eee';\n                    nodeElement.style.border = '2px solid #000';\n                }\n                \n                if (current === list.traversalNode) {\n                    nodeElement.style.fontWeight = 'bold';\n                }\n                \n                display.appendChild(nodeElement);\n                \n                if (current.next) {\n                    const pointer = document.createElement('span');\n                    pointer.className = 'pointer';\n                    pointer.textContent = '→';\n                    display.appendChild(pointer);\n                } else {\n                    const nullPointer = document.createElement('span');\n                    nullPointer.className = 'pointer null';\n                    nullPointer.textContent = '→ null';\n                    display.appendChild(nullPointer);\n                }\n                \n                current = current.next;\n                position++;\n            }\n        }\n\n        function logOperation(operation) {\n            const log = document.getElementById('operationLog');\n            const entry = document.createElement('p');\n            entry.textContent = `[${new Date().toLocaleTimeString()}] ${operation}`;\n            log.prepend(entry);\n        }\n\n        function addToHead() {\n            const value = document.getElementById('nodeValue').value;\n            if (!value) return;\n            list.addToHead(value);\n            logOperation(`Added ${value} to head`);\n            updateDisplay();\n        }\n\n        function addToTail() {\n            const value = document.getElementById('nodeValue').value;\n            if (!value) return;\n            list.addToTail(value);\n            logOperation(`Added ${value} to tail`);\n            updateDisplay();\n        }\n\n        function removeFromHead() {\n            const value = list.removeFromHead();\n            if (value !== null) {\n                logOperation(`Removed ${value} from head`);\n            } else {\n                logOperation('Attempted to remove from empty list');\n            }\n            updateDisplay();\n        }\n\n        function removeFromTail() {\n            const value = list.removeFromTail();\n            if (value !== null) {\n                logOperation(`Removed ${value} from tail`);\n            } else {\n                logOperation('Attempted to remove from empty list');\n            }\n            updateDisplay();\n        }\n\n        function insertAtPosition() {\n            const position = parseInt(document.getElementById('insertPos').value);\n            const value = document.getElementById('insertValue').value;\n            if (isNaN(position) || !value) return;\n            \n            if (list.insertAt(position, value)) {\n                logOperation(`Inserted ${value} at position ${position}`);\n            } else {\n                logOperation(`Failed to insert at position ${position}`);\n            }\n            updateDisplay();\n        }\n\n        function removeAtPosition() {\n            const position = parseInt(document.getElementById('removePos').value);\n            if (isNaN(position)) return;\n            \n            const value = list.removeAt(position);\n            if (value !== null) {\n                logOperation(`Removed ${value} from position ${position}`);\n            } else {\n                logOperation(`Failed to remove from position ${position}`);\n            }\n            updateDisplay();\n        }\n\n        function findValue() {\n            const value = document.getElementById('searchValue').value;\n            if (!value) return;\n            \n            const position = list.find(value);\n            const results = document.getElementById('searchResults');\n            results.innerHTML = '';\n            \n            if (position >= 0) {\n                results.innerHTML = `<p>Value ${value} found at position ${position}</p>`;\n                highlightNode(list.getNodeAt(position));\n                logOperation(`Found ${value} at position ${position}`);\n            } else {\n                results.innerHTML = `<p>Value ${value} not found in list</p>`;\n                logOperation(`Value ${value} not found`);\n            }\n        }\n\n        function findAllOccurrences() {\n            const value = document.getElementById('searchValue').value;\n            if (!value) return;\n            \n            const positions = list.findAll(value);\n            const results = document.getElementById('searchResults');\n            results.innerHTML = '';\n            \n            if (positions.length > 0) {\n                results.innerHTML = `<p>Value ${value} found at positions: ${positions.join(', ')}</p>`;\n                logOperation(`Found ${value} at positions: ${positions.join(', ')}`);\n                \n                // Highlight all occurrences\n                positions.forEach(pos => {\n                    const node = list.getNodeAt(pos);\n                    if (node) {\n                        setTimeout(() => {\n                            highlightNode(node);\n                            updateDisplay();\n                        }, pos * 300);\n                    }\n                });\n            } else {\n                results.innerHTML = `<p>Value ${value} not found in list</p>`;\n                logOperation(`Value ${value} not found`);\n            }\n        }\n\n        function countOccurrences() {\n            const value = document.getElementById('searchValue').value;\n            if (!value) return;\n            \n            const count = list.count(value);\n            const results = document.getElementById('searchResults');\n            results.innerHTML = `<p>Value ${value} appears ${count} time(s) in the list</p>`;\n            logOperation(`Counted ${count} occurrences of ${value}`);\n        }\n\n        function highlightNode(node) {\n            highlightedNode = node;\n            updateDisplay();\n            setTimeout(() => {\n                highlightedNode = null;\n                updateDisplay();\n            }, 2000);\n        }\n\n        function reverseList() {\n            list.reverse();\n            logOperation('List reversed');\n            updateDisplay();\n        }\n\n        function sortList() {\n            list.sort();\n            logOperation('List sorted');\n            updateDisplay();\n        }\n\n        function removeDuplicates() {\n            list.removeDuplicates();\n            logOperation('Duplicates removed');\n            updateDisplay();\n        }\n\n        function rotateList() {\n            const k = parseInt(document.getElementById('rotateBy').value) || 1;\n            list.rotate(k);\n            logOperation(`List rotated by ${k} positions`);\n            updateDisplay();\n        }\n\n        function clearList() {\n            list.clear();\n            logOperation('List cleared');\n            updateDisplay();\n        }\n\n        function startTraversal() {\n            list.startTraversal();\n            logOperation('Started traversal');\n            updateDisplay();\n        }\n\n        function stepForward() {\n            list.stepForward();\n            logOperation('Traversal step forward');\n            updateDisplay();\n        }\n\n        function stepBackward() {\n            list.stepBackward();\n            logOperation('Traversal step backward');\n            updateDisplay();\n        }\n\n        function stopTraversal() {\n            list.stopTraversal();\n            logOperation('Stopped traversal');\n            updateDisplay();\n        }\n\n        function autoTraverse() {\n            const speed = document.getElementById('traversalSpeed').value;\n            list.autoTraverse(speed);\n            logOperation(`Started auto traversal (speed: ${speed}ms)`);\n        }\n\n        // Initialize\n        updateDisplay();\n    </script>\n</body>\n</html>"
