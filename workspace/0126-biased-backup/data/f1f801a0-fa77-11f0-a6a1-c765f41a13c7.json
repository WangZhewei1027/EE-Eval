;\n      left:50%;\n      transform:translateX(-50%);\n      font-size:12px;\n      padding:6px 10px;\n      border-radius:999px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      color:rgba(12,20,36,0.92);\n      box-shadow: 0 6px 18px rgba(6,10,20,0.36);\n      border:1px solid rgba(255,255,255,0.03);\n    }\n\n    /* progress ring */\n    .progress-ring{\n      position:absolute;\n      left:50%;\n      top:50%;\n      transform:translate(-50%,-50%);\n      width:118px;height:118px;pointer-events:none;\n      z-index:30;\n    }\n\n    /* stage steps */\n    .steps{\n      position:absolute;\n      bottom:18px;\n      left:50%;\n      transform:translateX(-50%);\n      background: rgba(7,14,28,0.36);\n      padding:10px 14px;\n      border-radius:999px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 6px 20px rgba(8,12,20,0.45);\n      z-index:50;\n    }\n    .step{\n      display:flex;flex-direction:column;align-items:center;gap:6px;\n      color:rgba(234,246,255,0.6); font-size:12px;\n    }\n    .step .dot{\n      width:12px;height:12px;border-radius:50%;\n      background: rgba(255,255,255,0.06);\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n    .step.active .dot{\n      background: linear-gradient(90deg, var(--accent-1), var(--accent-2));\n      box-shadow: 0 6px 18px rgba(96,165,250,0.18), 0 0 20px rgba(96,165,250,0.08);\n      transform: scale(1.18);\n    }\n    .status-badge{\n      position:absolute;\n      right:18px;\n      top:18px;\n      background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:8px 12px;\n      border-radius:12px;\n      font-size:12px;\n      color:rgba(234,246,255,0.86);\n      display:flex;gap:10px;align-items:center;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .status-dot{width:10px;height:10px;border-radius:50%;background:rgba(96,165,250,0.9);box-shadow:0 4px 14px rgba(96,165,250,0.18)}\n\n    /* Action area */\n    .actions{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      justify-content:flex-end;\n      margin-top:22px;\n    }\n    .btn{\n      appearance:none;border:0;padding:12px 18px;border-radius:12px;font-weight:700;\n      cursor:pointer;font-size:14px;\n      color:#04202f;\n      background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n      box-shadow: 0 10px 30px rgba(96,165,250,0.12), 0 2px 6px rgba(6,10,20,0.5);\n      transition: transform 240ms ease, box-shadow 240ms ease, opacity 200ms;\n      display:inline-flex;gap:10px;align-items:center;\n    }\n    .btn:active{transform:translateY(1px)}\n    .btn[disabled]{opacity:0.5; cursor:not-allowed; transform:none; box-shadow:none}\n\n    .ghost{\n      background: transparent;\n      color: rgba(234,246,255,0.86);\n      border:1px solid rgba(255,255,255,0.04);\n      box-shadow:none;\n    }\n\n    /* confetti */\n    .confetti-piece{\n      position:absolute;\n      width:10px;height:8px;\n      background: linear-gradient(90deg, var(--accent-3), var(--accent-2));\n      opacity:0;\n      transform-origin:center;\n      border-radius:2px;\n      will-change: transform, opacity;\n      z-index:60;\n    }\n\n    /* number microanimation */\n    .num-change{ transition: transform 420ms cubic-bezier(.2,.9,.2,1), color 360ms; display:inline-block;}\n    .num-decrease { color: rgba(255,255,255,0.7); transform: translateY(-6px) scale(0.98) }\n    .num-increase { color: var(--accent-1); transform: translateY(-6px) scale(1.02) }\n\n    /* subtle fly-in header */\n    .fade-in { opacity:0; transform: translateY(6px); animation: fadeIn 720ms cubic-bezier(.2,.9,.2,1) forwards; }\n    .fade-in.delay { animation-delay:120ms }\n    @keyframes fadeIn { to { opacity:1; transform:none } }\n\n    /* particle keyframes for confetti */\n    @keyframes confettiFly {\n      to { transform: translate(var(--tx