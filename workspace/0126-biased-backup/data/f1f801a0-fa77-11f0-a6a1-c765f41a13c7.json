83,0.12)\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n              <feMerge><feMergeNode in=\"coloredBlur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n            </filter>\n          </defs>\n\n          <!-- Soft curved path -->\n          <path id=\"transferPath\" d=\"M150 180 C 330 30, 670 30, 850 60\" stroke=\"url(#pathGrad)\" stroke-width=\"8\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.9\" filter=\"url(#glow)\"/>\n          <!-- subtle shadow path -->\n          <path d=\"M150 182 C 330 32, 670 32, 850 62\" stroke=\"rgba(2,6,20,0.24)\" stroke-width=\"16\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.06\"/>\n\n          <!-- left & right account indicators on svg (purely decorative) -->\n          <g id=\"left-node\" transform=\"translate(140,160)\">\n            <circle cx=\"0\" cy=\"0\" r=\"28\" fill=\"rgba(255,255,255,0.02)\" stroke=\"rgba(255,255,255,0.02)\" />\n            <rect x=\"-18\" y=\"-18\" width=\"36\" height=\"36\" rx=\"8\" fill=\"url(#nodeLeftGrad)\" opacity=\"0.04\"/>\n          </g>\n          <g id=\"right-node\" transform=\"translate(860,78)\">\n            <circle cx=\"0\" cy=\"0\" r=\"28\" fill=\"rgba(255,255,255,0.02)\" stroke=\"rgba(255,255,255,0.02)\"/>\n            <rect x=\"-18\" y=\"-18\" width=\"36\" height=\"36\" rx=\"8\" fill=\"url(#nodeRightGrad)\" opacity=\"0.04\"/>\n          </g>\n        </svg>\n\n        <!-- moving coin element (HTML overlay) -->\n        <div class=\"coin\" id=\"coin\" aria-hidden=\"true\" style=\"transform: translate(-50%,-50%);\">\n          <div style=\"display:flex;flex-direction:column;align-items:center;\">\n            <div class=\"symbol\">₿</div>\n            <div style=\"font-size:10px;color:rgba(8,32,51,0.82);margin-top:4px;\">TRANSFER</div>\n          </div>\n          <div class=\"value\" id=\"coin-value\">-$1,200</div>\n        </div>\n\n        <!-- progress ring SVG overlay -->\n        <svg class=\"progress-ring\" viewBox=\"0 0 120 120\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"ringGrad\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#6EE7B7\"/>\n              <stop offset=\"0.5\" stop-color=\"#60A5FA\"/>\n              <stop offset=\"1\" stop-color=\"#A78BFA\"/>\n            </linearGradient>\n          </defs>\n          <circle cx=\"60\" cy=\"60\" r=\"50\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"8\" fill=\"none\" />\n          <circle id=\"progress\" cx=\"60\" cy=\"60\" r=\"50\" stroke=\"url(#ringGrad)\" stroke-width=\"8\" fill=\"none\" stroke-linecap=\"round\" stroke-dasharray=\"314\" stroke-dashoffset=\"314\" transform=\"rotate(-90 60 60)\"/>\n        </svg>\n\n        <!-- steps -->\n        <div class=\"steps\" role=\"list\">\n          <div class=\"step\" id=\"step-1\"><div class=\"dot\"></div><div>Authorized</div></div>\n          <div class=\"step\" id=\"step-2\"><div class=\"dot\"></div><div>Cleared</div></div>\n          <div class=\"step\" id=\"step-3\"><div class=\"dot\"></div><div>Settled</div></div>\n        </div>\n\n        <!-- completed badge -->\n        <div class=\"complete\" id=\"complete-badge\" style=\"opacity:0; transform:translateY(6px); transition: all 420ms cubic-bezier(.2,.9,.2,1)\">Settled • TX 0xA3F…9B2</div>\n      </section>\n\n      <!-- Right Account -->\n      <section class=\"account-card fade-in\" style=\"--i:3\">\n        <div>\n          <div class=\"acct-top\">\n            <div class=\"avatar\" style=\"background:linear-gradient(135deg,#6ee7b7,#60a5fa); color:#04202f\">BL</div>\n            <div class=\"acct-meta\">\n              <div class=\"name\">Bob • Checking</div>\n              <div class=\"type\">Account • 1072</div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:8px\">\n            <div class=\"sub\">Available Balance</div>\n            <div class=\"balance\" id=\"right-balance\">$2,860.00</div>\n          </div>\n        </div>\n\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div style=\"display:flex;flex-direction:column\">\n            <div class=\"sub\">Trust level</div>\n            <div style=\"font-size:13px;color:rgba(234,246,255,0.6);font-weight:700;margin-top:6px\">Verified</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div class=\"sub\">Pending</div>\n            <div id=\"pending-amt\" style=\"font-weight:700;color:rgba(234,246,255,0.7);margin-top:6px\">—</div>\n          </div>\n        </div>\n      </section>\n    </div>\n\n    <div class=\"actions\">\n      <button class=\"btn ghost\" id=\"infoBtn\" title=\"Details\" aria-hidden=\"true\">Details</button>\n      <button class=\"btn\" id=\"startBtn\" aria-pressed=\"false\">Initiate Transaction</button>\n    </div>\n  </main>\n\n  <script>\n    // Minimal interactivity: single button controls the visual transaction animation.\n    (function(){\n      // Elements\n      const startBtn = document.getElementById('startBtn');\n      const coin = document.getElementById('coin');\n      const path = document.getElementById('transferPath');\n      const progress = document.getElementById('progress');\n      const step1 = document.getElementById('step-1');\n      const step2 = document.getElementById('step-2');\n      const step3 = document.getElementById('step-3');\n      const leftBalanceEl = document.getElementById('left-balance');\n      const rightBalanceEl = document.getElementById('right-balance');\n      const pendingAmt = document.getElementById('pending-amt');\n      const statusText = document.getElementById('status-text');\n      const statusDot = document.querySelector('.status-dot');\n      const completeBadge = document.getElementById('complete-badge');\n      const coinValue = document.getElementById('coin-value');\n      const svg = document.querySelector('.flow');\n\n      const initialLeft = 12480.00;\n      const initialRight = 2860.00;\n      const transferAmt = 1200.00;\n\n      // prepare path\n      const pathLength = path.getTotalLength();\n      let animating = false;\n\n      // utility: format currency\n      function formatCurrency(v){\n        return '$' + v.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});\n      }\n\n      // animate number with easing\n      function animateNumber(el, from, to, duration, onStep){\n        const start = performance.now();\n        const delta = to - from;\n        return new Promise(resolve=>{\n          function step(now){\n            const t = Math.min(1, (now-start)/duration);\n            const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic\n            const value = from + delta * eased;\n            el.textContent = formatCurrency(value);\n            if(onStep) onStep(value);\n            if(t < 1) requestAnimationFrame(step); else resolve();\n          }\n          requestAnimationFrame(step);\n        });\n      }\n\n      // move coin along path\n      function animateCoin(duration, onProgress){\n        const start = performance.now();\n        return new Promise(resolve=>{\n          function step(now){\n            const t = Math.min(1, (now - start) / duration);\n            const eased = t<0.5 ? 4*t*t*t : 1 - Math.pow(-2*t + 2, 3)/2; // easeInOutCubic\n            const len = pathLength * eased;\n            const pt = path.getPointAtLength(len);\n            // position coin (svg coordinates -> container coordinates)\n            // Get bounding rect of svg to map coordinates\n            const svgRect = svg.getBoundingClientRect();\n            // scale because viewBox is 1000x280; transform to screen coords\n            const viewBox = svg.viewBox.baseVal;\n            const scaleX = svgRect.width / viewBox.width;\n            const scaleY = svgRect.height / viewBox.height;\n            const x = svgRect.left + pt.x * scaleX;\n            const y = svgRect.top + pt.y * scaleY;\n            // position coin center\n            coin.style.left = x + 'px';\n            coin.style.top = y + 'px';\n            if(onProgress) onProgress(eased);\n            if(t < 1) requestAnimationFrame(step); else resolve();\n          }\n          requestAnimationFrame(step);\n        });\n      }\n\n      // animate progress ring\n      function animateRing(toPercent, duration){\n        const circum = 2 * Math.PI * 50;\n        const startOffset = parseFloat(progress.getAttribute('data-offset') || circum);\n        const targetOffset = circum * (1 - toPercent);\n        const startTime = performance.now();\n        return new Promise(resolve=>{\n          function step(now){\n            const t = Math.min(1, (now - startTime) / duration);\n            const eased = 1 - Math.pow(1 - t, 3);\n            const curOffset = startOffset + (targetOffset - startOffset) * eased;\n            progress.style.strokeDashoffset = curOffset;\n            progress.setAttribute('data-offset', curOffset);\n            if(t < 1) requestAnimationFrame(step); else resolve();\n          }\n          requestAnimationFrame(step);\n        });\n      }\n\n      // update stepper visual\n      function setActiveStep(n){\n        [step1,step2,step3].forEach((s,idx)=>{\n          s.classList.toggle('active', idx < n);\n        });\n      }\n\n      // confetti burst\n      function burst(x,y){\n        const colors = ['#6EE7B7','#60A5FA','#A78BFA','#FDE68A','#FFBFCD'];\n        for(let i=0;i<16;i++){\n          const el = document.createElement('div');\n          el.className = 'confetti-piece';\n          el.style.background = colors[i % colors.length];\n          el.style.left = x + 'px';\n          el.style.top = y + 'px';\n          el.style.opacity = 0;\n          const tx = (Math.random()*360 - 180) + 'px';\n          const ty = (Math.random()*160 - 40) + 'px';\n          const r = (Math.random()*720 - 360) + 'deg';\n          el.style.setProperty('--tx', tx);\n          el.style.setProperty('--ty', ty);\n          el.style.setProperty('--r', r);\n          document.body.appendChild(el);\n          // animate\n          requestAnimationFrame(()=> {\n            el.style.opacity = 1;\n            el.style.transition = 'transform 880ms cubic-bezier(.2,.9,.2,1), opacity 880ms';\n            el.style.transform = `translate(${tx}, ${ty}) rotate(${r})`;\n          });\n          setTimeout(()=>{ el.style.opacity = 0; setTimeout(()=>el.remove(), 900) }, 880);\n        }\n      }\n\n      // small particle ripple\n      function ripple(x,y){\n        const el = document.createElement('div');\n        el.style.position='absolute'; el.style.left=x+'px'; el.style.top=y+'px';\n        el.style.width='12px'; el.style.height='12px'; el.style.borderRadius='50%';\n        el.style.background='radial-gradient(circle, rgba(96,165,250,0.9), rgba(96,165,250,0.3))';\n        el.style.opacity='0.9'; el.style.transform='translate(-50%,-50%) scale(0.2)';\n        el.style.transition='transform 420ms ease, opacity 420ms ease';\n        document.body.appendChild(el);\n        requestAnimationFrame(()=>{ el.style.transform='translate(-50%,-50%) scale(1.8)'; el.style.opacity='0'; });\n        setTimeout(()=>el.remove(), 460);\n      }\n\n      // entry animation to place coin near left account\n      function placeCoinAtStart(){\n        // find point at small length near the start of path\n        const pt = path.getPointAtLength(2);\n        const svgRect = svg.getBoundingClientRect();\n        const viewBox = svg.viewBox.baseVal;\n        const scaleX = svgRect.width / viewBox.width;\n        const scaleY = svgRect.height / viewBox.height;\n        const x = svgRect.left + pt.x * scaleX;\n        const y = svgRect.top + pt.y * scaleY;\n        coin.style.left = x + 'px';\n        coin.style.top = y + 'px';\n      }\n\n      // set initial UI\n      leftBalanceEl.textContent = formatCurrency(initialLeft);\n      rightBalanceEl.textContent = formatCurrency(initialRight);\n      coinValue.textContent = '-'+formatCurrency(transferAmt);\n      placeCoinAtStart();\n      // idle floating\n      coin.style.animation = 'floaty 3000ms ease-in-out infinite';\n      progress.style.strokeDashoffset = 2 * Math.PI * 50;\n      progress.setAttribute('data-offset', 2 * Math.PI * 50);\n\n      // orchestrate the transaction sequence\n      async function runTransaction(){\n        if(animating) return;\n        animating = true;\n        startBtn.disabled = true;\n        startBtn.textContent = 'Processing...';\n        startBtn.setAttribute('aria-pressed','true');\n        // reset UI\n        setActiveStep(0);\n        completeBadge.style.opacity = 0;\n        completeBadge.style.transform = 'translateY(6px)';\n        pendingAmt.textContent = formatCurrency(transferAmt);\n        statusText.textContent = 'Authorizing';\n        statusDot.style.background = 'linear-gradient(90deg,var(--accent-1),var(--accent-2))';\n        // coin is visible and has a value tag\n        coin.style.opacity = 1;\n        coin.style.transition = 'transform 240ms, left 0.1s, top 0.1s';\n        coin.style.animation = ''; // stop idle float during transit\n\n        // 1) authorize (small delay)\n        await animateRing(0.18, 480); // show small progress\n        setActiveStep(1);\n        await new Promise(r=>setTimeout(r, 640));\n\n        // 2) transit - coin moves along path while balances update and ring progresses\n        statusText.textContent = 'In transit';\n        // left decreases gradually during transit\n        const leftAnim = animateNumber(leftBalanceEl, initialLeft, initialLeft - transferAmt, 1600);\n        // right increases with a small lag\n        const rightAnim = (async ()=>{\n          await new Promise(r=>setTimeout(r, 900));\n          return animateNumber(rightBalanceEl, initialRight, initialRight + transferAmt, 1200);\n        })();\n\n        // animate coin movement and progress ring together\n        const coinTransit = animateCoin(1800, async (p)=>{\n          // update ring as p increases\n          progress.style.strokeDashoffset = 2 * Math.PI * 50 * (1 - (0.18 + p*0.6)); // from 18% to 78%\n          progress.setAttribute('data-offset', progress.style.strokeDashoffset);\n        });\n\n        // while coin moving, also pulse the coin and change status color\n        const pulseInt = setInterval(()=> {\n          coin.animate([{transform:'scale(1)'},{transform:'scale(1.06)'},{transform:'scale(1)'}],{duration:700, easing:'ease-in-out'});\n        }, 760);\n\n        await Promise.all([leftAnim, rightAnim, coinTransit]);\n        clearInterval(pulseInt);\n\n        // mark cleared\n        setActiveStep(2);\n        statusText.textContent = 'Cleared';\n        await animateRing(0.88, 520);\n        await new Promise(r=>setTimeout(r, 420));\n\n        // final settlement: small pause, confetti, ripple and finalize\n        statusText.textContent = 'Settling';\n        setActiveStep(3);\n        await animateRing(1.0, 520);\n\n        // locate coin final position to burst\n        const finalPt = path.getPointAtLength(pathLength - 1);\n        const svgRect = svg.getBoundingClientRect();\n        const viewBox = svg.viewBox.baseVal;\n        const scaleX = svgRect.width / viewBox.width;\n        const scaleY = svgRect.height / viewBox.height;\n        const fx = svgRect.left + finalPt.x * scaleX;\n        const fy = svgRect.top + finalPt.y * scaleY;\n\n        burst(fx, fy-30);\n        ripple(fx, fy-30);\n\n        // settle UI\n        pendingAmt.textContent = '—';\n        statusText.textContent = 'Confirmed';\n        statusDot.style.background = 'linear-gradient(90deg,#22c55e,#60a5fa)';\n        completeBadge.style.opacity = 1;\n        completeBadge.style.transform = 'translateY(0)';\n\n        // move coin to final and fade slightly\n        coin.style.left = fx + 'px';\n        coin.style.top = (fy-6) + 'px';\n        coin.style.transition = 'left 420ms cubic-bezier(.2,.9,.2,1), top 420ms cubic-bezier(.2,.9,.2,1), opacity 420ms';\n        coin.style.opacity = 0.98;\n        // small pop\n        coin.animate([{transform:'scale(1.12)'},{transform:'scale(1)'}], {duration:420, easing:'cubic-bezier(.2,.9,.2,1)'});\n\n        // finish\n        await new Promise(r=>setTimeout(r,700));\n        startBtn.disabled = false;\n        startBtn.textContent = 'Replay Transaction';\n        startBtn.setAttribute('aria-pressed','false');\n        animating = false;\n\n        // re-enable idle float for coin in final position\n        setTimeout(()=>{ coin.style.animation = 'floaty 3800ms ease-in-out infinite' }, 700);\n      }\n\n      // initial placement on resize\n      window.addEventListener('resize', ()=> {\n        placeCoinAtStart();\n      });\n\n      // bind button\n      startBtn.addEventListener('click', ()=> {\n        // toggle: if not started or finished, run\n        runTransaction();\n      });\n\n      // small aesthetic: make info btn subtle reveal (not interactive)\n      const infoBtn = document.getElementById('infoBtn');\n      infoBtn.addEventListener('click', (e)=> {\n        // Extremely limited: simply toggle subtle pulse, no extra UI\n        infoBtn.animate([{transform:'scale(1)'},{transform:'scale(0.98)'},{transform:'scale(1)'}], {duration:320});\n      });\n\n      // Initial micro-entrance of UI\n      setTimeout(()=> {\n        document.querySelectorAll('.fade-in').forEach((el,i)=> el.style.animationDelay = (i*70)+'ms');\n      }, 60);\n    })();\n  </script>\n</body>\n</html>"
  },
