    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hash Map</title>\n    <style>\n        body {\n            font-family: monospace;\n            font-size: 12px;\n            background-color: white;\n            padding: 0;\n            margin: 0;\n        }\n        .hash-map {\n            width: 800px;\n            height: 600px;\n            margin: 0 auto;\n            border: 1px solid black;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);\n        }\n        .hash-map input[type=\"text\"], .hash-map input[type=\"number\"] {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n        }\n        .hash-map button {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: white;\n            cursor: pointer;\n        }\n        .hash-map button:hover {\n            background-color: #3e8e41;\n        }\n        .hash-map input[type=\"submit\"] {\n            padding: 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: white;\n            cursor: pointer;\n        }\n        .hash-map input[type=\"submit\"]:hover {\n            background-color: #3e8e41;\n        }\n        .hash-map select {\n            padding: 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: white;\n            cursor: pointer;\n        }\n        .hash-map select:hover {\n            background-color: #3e8e41;\n        }\n        .hash-map input[type=\"checkbox\"] {\n            padding: 10px;\n            margin-bottom: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: white;\n            cursor: pointer;\n        }\n        .hash-map input[type=\"checkbox\"]:checked {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"hash-map\">\n        <input type=\"text\" id=\"input1\" placeholder=\"Enter key\" oninput=\"updateDisplay()\">\n        <input type=\"text\" id=\"input2\" placeholder=\"Enter value\" oninput=\"updateDisplay()\">\n        <button id=\"add-btn\">Add</button>\n        <button id=\"remove-btn\">Remove</button>\n        <select id=\"select1\" onchange=\"updateDisplay()\">\n            <option value=\"1\">Option 1</option>\n            <option value=\"2\">Option 2</option>\n            <option value=\"3\">Option 3</option>\n        </select>\n        <input type=\"checkbox\" id=\"checkbox1\">\n        <input type=\"checkbox\" id=\"checkbox2\">\n        <input type=\"checkbox\" id=\"checkbox3\">\n        <button id=\"clear-btn\">Clear</button>\n    </div>\n\n    <script>\n        let input1 = document.getElementById('input1');\n        let input2 = document.getElementById('input2');\n        let addBtn = document.getElementById('add-btn');\n        let removeBtn = document.getElementById('remove-btn');\n        let select1 = document.getElementById('select1');\n        let checkbox1 = document.getElementById('checkbox1');\n        let checkbox2 = document.getElementById('checkbox2');\n        let checkbox3 = document.getElementById('checkbox3');\n        let clearBtn = document.getElementById('clear-btn');\n        let display = document.getElementById('display');\n        let count = 0;\n\n        addBtn.addEventListener('click', () => {\n            if (count < 10) {\n                input1.value += 'a';\n                count++;\n            }\n        });\n\n        removeBtn.addEventListener('click', () => {\n            if (count > 0) {\n                input1.value = input1.value.slice(0, -1);\n                count--;\n            }\n        });\n\n        select1.addEventListener('change', () => {\n            display.innerText = `Select: ${select1.value}`;\n        });\n\n        checkbox1.addEventListener('change', () => {\n            if (checkbox1.checked) {\n                input2.value += 'b';\n            } else {\n                input2.value = input2.value.slice(0, -1);\n            }\n        });\n\n        checkbox2.addEventListener('change', () => {\n            if (checkbox2.checked) {\n                input2.value += 'c';\n            } else {\n                input2.value = input2.value.slice(0, -1);\n            }\n        });\n\n        checkbox3.addEventListener('change', () => {\n            if (checkbox3.checked) {\n                input2.value += 'd';\n            } else {\n                input2.value = input2.value.slice(0, -1);\n            }\n        });\n\n        clearBtn.addEventListener('click', () => {\n            input1.value = '';\n            input2.value = '';\n        });\n\n        updateDisplay() {\n            display.innerText = `Input 1: ${input1.value}, Input 2: ${input2.value}`;\n        }\n    </script>\n</body>\n</html>"
