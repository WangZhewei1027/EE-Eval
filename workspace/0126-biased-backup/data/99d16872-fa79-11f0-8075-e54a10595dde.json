    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Asymmetric Cryptography Demo</title>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jsencrypt/3.2.0/jsencrypt.min.js\"></script>\n    <script>\n        let publicKey;\n        let privateKey;\n        let encryptInstance = new JSEncrypt();\n        \n        function generateKeys() {\n            encryptInstance = new JSEncrypt();\n            publicKey = encryptInstance.getPublicKey();\n            privateKey = encryptInstance.getPrivateKey();\n            document.getElementById(\"publicKey\").innerText = publicKey;\n            document.getElementById(\"privateKey\").innerText = privateKey;\n            alert(\"Keys generated!\");\n        }\n\n        function encryptMessage() {\n            const message = document.getElementById(\"message\").value;\n            encryptInstance.setPublicKey(publicKey);\n            const encrypted = encryptInstance.encrypt(message);\n            document.getElementById(\"encryptedMessage\").innerText = encrypted ? encrypted : 'Encryption failed!';\n        }\n\n        function decryptMessage() {\n            const encryptedMessage = document.getElementById(\"encryptedMessageInput\").value;\n            encryptInstance.setPrivateKey(privateKey);\n            const decrypted = encryptInstance.decrypt(encryptedMessage);\n            document.getElementById(\"decryptedMessage\").innerText = decrypted ? decrypted : 'Decryption failed!';\n        }\n    </script>\n</head>\n<body>\n    <h1>Asymmetric Cryptography Demo</h1>\n    \n    <h2>1. Generate Keys</h2>\n    <button onclick=\"generateKeys()\">Generate Public/Private Keys</button>\n    <h3>Public Key:</h3>\n    <pre id=\"publicKey\"></pre>\n    <h3>Private Key:</h3>\n    <pre id=\"privateKey\"></pre>\n\n    <h2>2. Encrypt a Message</h2>\n    <input type=\"text\" id=\"message\" placeholder=\"Enter message to encrypt\">\n    <button onclick=\"encryptMessage()\">Encrypt Message</button>\n    <h3>Encrypted Message:</h3>\n    <pre id=\"encryptedMessage\"></pre>\n\n    <h2>3. Decrypt a Message</h2>\n    <input type=\"text\" id=\"encryptedMessageInput\" placeholder=\"Enter encrypted message\">\n    <button onclick=\"decryptMessage()\">Decrypt Message</button>\n    <h3>Decrypted Message:</h3>\n    <pre id=\"decryptedMessage\"></pre>\n</body>\n</html>"
