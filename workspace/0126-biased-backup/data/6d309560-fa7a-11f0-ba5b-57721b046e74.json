    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Virtual Memory Simulator</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #000; padding: 10px; }\n        .row { display: flex; gap: 20px; }\n        .memory-display { display: flex; flex-wrap: wrap; gap: 2px; }\n        .memory-cell { width: 50px; height: 50px; border: 1px solid #000; display: flex; flex-direction: column; justify-content: center; align-items: center; }\n        .page-table { display: grid; grid-template-columns: repeat(5, 1fr); gap: 5px; }\n        .page-table-entry { border: 1px solid #000; padding: 5px; }\n        .active { background-color: #f0f0f0; }\n        .controls { display: flex; flex-direction: column; gap: 10px; }\n        button { padding: 5px 10px; }\n        select, textarea { width: 100%; }\n        .highlight { background-color: #e0e0e0; }\n    </style>\n</head>\n<body>\n    <h1>Virtual Memory Simulator</h1>\n    \n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"panel\" style=\"flex: 2;\">\n                <h2>Physical Memory</h2>\n                <div class=\"memory-display\" id=\"physical-memory\"></div>\n                <div>\n                    <label>Memory Size: <input type=\"range\" id=\"mem-size\" min=\"4\" max=\"32\" value=\"16\"> <span id=\"mem-size-value\">16</span> frames</label>\n                </div>\n            </div>\n            \n            <div class=\"panel\" style=\"flex: 1;\">\n                <h2>Page Table</h2>\n                <div class=\"page-table\" id=\"page-table\"></div>\n                <div>\n                    <label>Page Replacement Algorithm:\n                        <select id=\"replacement-algo\">\n                            <option value=\"FIFO\">FIFO</option>\n                            <option value=\"LRU\">LRU</option>\n                            <option value=\"OPT\">OPT (Optimal)</option>\n                        </select>\n                    </label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"row\">\n            <div class=\"panel\" style=\"flex: 1;\">\n                <h2>Process Control</h2>\n                <div class=\"controls\">\n                    <div>\n                        <label>Process Size: <span id=\"process-size-value\">8</span> pages\n                            <input type=\"range\" id=\"process-size\" min=\"4\" max=\"32\" value=\"8\">\n                        </label>\n                    </div>\n                    <div>\n                        <button id=\"create-process\">Create Process</button>\n                        <button id=\"terminate-process\">Terminate Process</button>\n                    </div>\n                    <div>\n                        <label>Current Process: <span id=\"current-process\">None</span></label>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"panel\" style=\"flex: 1;\">\n                <h2>Memory Access</h2>\n                <div class=\"controls\">\n                    <div>\n                        <label>Access Address: <input type=\"number\" id=\"access-addr\" min=\"0\" value=\"0\"></label>\n                        <button id=\"access-memory\">Access</button>\n                    </div>\n                    <div>\n                        <label>Access Pattern:\n                            <select id=\"access-pattern\">\n                                <option value=\"sequential\">Sequential</option>\n                                <option value=\"random\">Random</option>\n                                <option value=\"looping\">Looping</option>\n                                <option value=\"custom\">Custom</option>\n                            </select>\n                        </label>\n                    </div>\n                    <div id=\"custom-pattern-control\" style=\"display: none;\">\n                        <label>Custom Pattern (comma-separated): <input type=\"text\" id=\"custom-pattern\" value=\"0,1,2,3,4,5,6,7\"></label>\n                    </div>\n                    <div>\n                        <button id=\"run-pattern\">Run Pattern</button>\n                        <button id=\"stop-pattern\">Stop</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Statistics</h2>\n            <div>\n                <p>Page Faults: <span id=\"page-faults\">0</span></p>\n                <p>Page Hits: <span id=\"page-hits\">0</span></p>\n                <p>Hit Ratio: <span id=\"hit-ratio\">0%</span></p>\n                <p>Current Frame Queue: <span id=\"frame-queue\"></span></p>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Event Log</h2>\n            <textarea id=\"event-log\" rows=\"6\" readonly style=\"width: 100%;\"></textarea>\n            <button id=\"clear-log\">Clear Log</button>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let physicalMemory = [];\n        let pageTable = [];\n        let currentProcess = null;\n        let pageFaults = 0;\n        let pageHits = 0;\n        let frameQueue = [];\n        let accessPatternInterval = null;\n        let lastAccessTime = {};\n        \n        // DOM elements\n        const physicalMemoryEl = document.getElementById('physical-memory');\n        const pageTableEl = document.getElementById('page-table');\n        const memSizeSlider = document.getElementById('mem-size');\n        const memSizeValue = document.getElementById('mem-size-value');\n        const processSizeSlider = document.getElementById('process-size');\n        const processSizeValue = document.getElementById('process-size-value');\n        const createProcessBtn = document.getElementById('create-process');\n        const terminateProcessBtn = document.getElementById('terminate-process');\n        const currentProcessEl = document.getElementById('current-process');\n        const accessAddrInput = document.getElementById('access-addr');\n        const accessMemoryBtn = document.getElementById('access-memory');\n        const accessPatternSelect = document.getElementById('access-pattern');\n        const customPatternControl = document.getElementById('custom-pattern-control');\n        const customPatternInput = document.getElementById('custom-pattern');\n        const runPatternBtn = document.getElementById('run-pattern');\n        const stopPatternBtn = document.getElementById('stop-pattern');\n        const pageFaultsEl = document.getElementById('page-faults');\n        const pageHitsEl = document.getElementById('page-hits');\n        const hitRatioEl = document.getElementById('hit-ratio');\n        const frameQueueEl = document.getElementById('frame-queue');\n        const eventLogEl = document.getElementById('event-log');\n        const clearLogBtn = document.getElementById('clear-log');\n        const replacementAlgoSelect = document.getElementById('replacement-algo');\n        \n        // Initialize\n        function init() {\n            updateMemorySize();\n            renderPageTable();\n            \n            // Event listeners\n            memSizeSlider.addEventListener('input', updateMemorySize);\n            processSizeSlider.addEventListener('input', () => {\n                processSizeValue.textContent = processSizeSlider.value;\n            });\n            \n            createProcessBtn.addEventListener('click', createProcess);\n            terminateProcessBtn.addEventListener('click', terminateProcess);\n            accessMemoryBtn.addEventListener('click', () => {\n                const addr = parseInt(accessAddrInput.value);\n                if (!isNaN(addr)) {\n                    accessMemory(addr);\n                }\n            });\n            \n            accessPatternSelect.addEventListener('change', () => {\n                if (accessPatternSelect.value === 'custom') {\n                    customPatternControl.style.display = 'block';\n                } else {\n                    customPatternControl.style.display = 'none';\n                }\n            });\n            \n            runPatternBtn.addEventListener('click', runAccessPattern);\n            stopPatternBtn.addEventListener('click', stopAccessPattern);\n            clearLogBtn.addEventListener('click', () => {\n                eventLogEl.value = '';\n            });\n        }\n        \n        // Update memory size based on slider\n        function updateMemorySize() {\n            const size = parseInt(memSizeSlider.value);\n            memSizeValue.textContent = size;\n            \n            physicalMemory = Array(size).fill(null);\n            frameQueue = [];\n            renderPhysicalMemory();\n        }\n        \n        // Create a new process\n        function createProcess() {\n            const processSize = parseInt(processSizeSlider.value);\n            currentProcess = {\n                id: Date.now(),\n                size: processSize,\n                pages: Array(processSize).fill(null).map((_, i) => ({\n                    pageNum: i,\n                    loaded: false,\n                    frame: null,\n                    referenced: false,\n                    modified: false\n                }))\n            };\n            \n            pageTable = [...currentProcess.pages];\n            currentProcessEl.textContent = `PID: ${currentProcess.id}`;\n            logEvent(`Process created with ${processSize} pages`);\n            renderPageTable();\n        }\n        \n        // Terminate current process\n        function terminateProcess() {\n            if (!currentProcess) return;\n            \n            // Free all frames\n            for (const page of pageTable) {\n                if (page.loaded) {\n                    physicalMemory[page.frame] = null;\n                }\n            }\n            \n            logEvent(`Process terminated, freed ${currentProcess.size} pages`);\n            currentProcess = null;\n            pageTable = [];\n            frameQueue = [];\n            currentProcessEl.textContent = 'None';\n            renderPhysicalMemory();\n            renderPageTable();\n        }\n        \n        // Access memory at virtual address\n        function accessMemory(virtualAddr) {\n            if (!currentProcess) {\n                logEvent('Error: No process created');\n                return;\n            }\n            \n            const pageNum = Math.floor(virtualAddr / 10); // Assuming 10 bytes per page\n            if (pageNum < 0 || pageNum >= currentProcess.size) {\n                logEvent(`Error: Invalid address ${virtualAddr} (page ${pageNum})`);\n                return;\n            }\n            \n            const page = pageTable[pageNum];\n            page.referenced = true;\n            lastAccessTime[pageNum] = Date.now();\n            \n            if (page.loaded) {\n                // Page hit\n                pageHits++;\n                pageHitsEl.textContent = pageHits;\n                updateHitRatio();\n                logEvent(`Access to address ${virtualAddr} (page ${pageNum}) - HIT in frame ${page.frame}`);\n                \n                // For LRU, move to end of queue\n                if (replacementAlgoSelect.value === 'LRU') {\n                    frameQueue = frameQueue.filter(f => f !== page.frame);\n                    frameQueue.push(page.frame);\n                    updateFrameQueueDisplay();\n                }\n            } else {\n                // Page fault\n                pageFaults++;\n                pageFaultsEl.textContent = pageFaults;\n                updateHitRatio();\n                logEvent(`Access to address ${virtualAddr} (page ${pageNum}) - FAULT`);\n                \n                handlePageFault(pageNum);\n            }\n            \n            renderPhysicalMemory();\n            renderPageTable();\n        }\n        \n        // Handle page fault\n        function handlePageFault(pageNum) {\n            const page = pageTable[pageNum];\n            let frameToUse = -1;\n            \n            // Find free frame\n            for (let i = 0; i < physicalMemory.length; i++) {\n                if (physicalMemory[i] === null) {\n                    frameToUse = i;\n                    break;\n                }\n            }\n            \n            // If no free frame, replace a page\n            if (frameToUse === -1) {\n                frameToUse = selectFrameToReplace();\n                const evictedPage = physicalMemory[frameToUse];\n                if (evictedPage) {\n                    evictedPage.loaded = false;\n                    evictedPage.frame = null;\n                    logEvent(`Evicted page ${evictedPage.pageNum} from frame ${frameToUse}`);\n                }\n            }\n            \n            // Load the page\n            page.loaded = true;\n            page.frame = frameToUse;\n            physicalMemory[frameToUse] = page;\n            frameQueue.push(frameToUse);\n            updateFrameQueueDisplay();\n            \n            logEvent(`Loaded page ${pageNum} into frame ${frameToUse}`);\n        }\n        \n        // Select frame to replace based on algorithm\n        function selectFrameToReplace() {\n            const algo = replacementAlgoSelect.value;\n            \n            if (algo === 'FIFO') {\n                return frameQueue[0];\n            } else if (algo === 'LRU') {\n                // Find frame with oldest access time\n                let oldestTime = Infinity;\n                let oldestFrame = frameQueue[0];\n                \n                for (const frame of frameQueue) {\n                    const page = physicalMemory[frame];\n                    if (lastAccessTime[page.pageNum] < oldestTime) {\n                        oldestTime = lastAccessTime[page.pageNum];\n                        oldestFrame = frame;\n                    }\n                }\n                \n                return oldestFrame;\n            } else if (algo === 'OPT') {\n                // Optimal - replace page that won't be used for longest time\n                // This is impractical in real systems but useful for simulation\n                let furthestUse = -1;\n                let selectedFrame = frameQueue[0];\n                \n                for (const frame of frameQueue) {\n                    const page = physicalMemory[frame];\n                    let nextUse = Infinity;\n                    \n                    // Check future accesses (limited to next 10 in our simulation)\n                    const nextAccesses = getNextAccesses(page.pageNum, 10);\n                    if (nextAccesses.length > 0) {\n                        nextUse = nextAccesses[0];\n                    }\n                    \n                    if (nextUse > furthestUse) {\n                        furthestUse = nextUse;\n                        selectedFrame = frame;\n                    }\n                }\n                \n                return selectedFrame;\n            }\n            \n            return frameQueue[0]; // Default to FIFO\n        }\n        \n        // Helper to get future accesses (simulated)\n        function getNextAccesses(pageNum, limit) {\n            const pattern = getCurrentPattern();\n            const currentAddr = parseInt(accessAddrInput.value);\n            let currentIndex = pattern.indexOf(currentAddr);\n            if (currentIndex === -1) currentIndex = 0;\n            \n            const accesses = [];\n            for (let i = currentIndex + 1; i < pattern.length && accesses.length < limit; i++) {\n                const addr = pattern[i];\n                const pn = Math.floor(addr / 10);\n                if (pn === pageNum) {\n                    accesses.push(i - currentIndex);\n                }\n            }\n            \n            return accesses;\n        }\n        \n        // Run access pattern\n        function runAccessPattern() {\n            stopAccessPattern();\n            \n            const pattern = getCurrentPattern();\n            let index = 0;\n            \n            accessPatternInterval = setInterval(() => {\n                if (index >= pattern.length) {\n                    index = 0;\n                }\n                \n                accessAddrInput.value = pattern[index];\n                accessMemory(pattern[index]);\n                index++;\n            }, 1000);\n        }\n        \n        // Stop access pattern\n        function stopAccessPattern() {\n            if (accessPatternInterval) {\n                clearInterval(accessPatternInterval);\n                accessPatternInterval = null;\n            }\n        }\n        \n        // Get current access pattern\n        function getCurrentPattern() {\n            const patternType = accessPatternSelect.value;\n            \n            if (patternType === 'custom') {\n                return customPatternInput.value.split(',').map(Number);\n            } else if (patternType === 'sequential') {\n                return Array.from({length: currentProcess ? currentProcess.size : 8}, (_, i) => i * 10);\n            } else if (patternType === 'random') {\n                return Array.from({length: 20}, () => Math.floor(Math.random() * (currentProcess ? currentProcess.size * 10 : 80)));\n            } else if (patternType === 'looping') {\n                return [0, 1, 2, 3, 4, 5, 6, 7, 6, 5, 4, 3, 2, 1, 0].map(x => x * 10);\n            }\n            \n            return [];\n        }\n        \n        // Update hit ratio display\n        function updateHitRatio() {\n            const total = pageHits + pageFaults;\n            const ratio = total > 0 ? Math.round((pageHits / total) * 100) : 0;\n            hitRatioEl.textContent = `${ratio}%`;\n        }\n        \n        // Update frame queue display\n        function updateFrameQueueDisplay() {\n            frameQueueEl.textContent = frameQueue.join(', ');\n        }\n        \n        // Log event to event log\n        function logEvent(message) {\n            eventLogEl.value += `[${new Date().toLocaleTimeString()}] ${message}\\n`;\n            eventLogEl.scrollTop = eventLogEl.scrollHeight;\n        }\n        \n        // Render physical memory\n        function renderPhysicalMemory() {\n            physicalMemoryEl.innerHTML = '';\n            \n            for (let i = 0; i < physicalMemory.length; i++) {\n                const cell = document.createElement('div');\n                cell.className = 'memory-cell';\n                \n                if (physicalMemory[i]) {\n                    const page = physicalMemory[i];\n                    cell.textContent = `P${page.pageNum}`;\n                    cell.title = `Page ${page.pageNum}\\nFrame ${i}`;\n                    \n                    if (page.referenced) {\n                        cell.classList.add('highlight');\n                    }\n                } else {\n                    cell.textContent = `F${i}`;\n                    cell.title = `Frame ${i} (free)`;\n                }\n                \n                physicalMemoryEl.appendChild(cell);\n            }\n        }\n        \n        // Render page table\n        function renderPageTable() {\n            pageTableEl.innerHTML = '';\n            \n            if (!currentProcess) {\n                pageTableEl.innerHTML = '<div>No process</div>';\n                return;\n            }\n            \n            // Header\n            const header = document.createElement('div');\n            header.className = 'page-table-entry';\n            header.style.fontWeight = 'bold';\n            header.innerHTML = 'Page#<br>Frame#<br>Status';\n            pageTableEl.appendChild(header);\n            \n            // Entries\n            for (const page of pageTable) {\n                const entry = document.createElement('div');\n                entry.className = 'page-table-entry';\n                \n                let status = page.loaded ? 'Loaded' : 'Not loaded';\n                if (page.referenced) status += ', Referenced';\n                if (page.modified) status += ', Modified';\n                \n                entry.innerHTML = `${page.pageNum}<br>${page.loaded ? page.frame : '-'}<br>${status}`;\n                \n                if (page.referenced) {\n                    entry.classList.add('highlight');\n                }\n                \n                pageTableEl.appendChild(entry);\n            }\n        }\n        \n        // Initialize the simulator\n        init();\n    </script>\n</body>\n</html>"
  },
