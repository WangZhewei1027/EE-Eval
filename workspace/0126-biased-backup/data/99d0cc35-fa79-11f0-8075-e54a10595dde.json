    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Abstract Syntax Tree Interactive Demo</title>\n    <script>\n        class ASTNode {\n            constructor(type, value) {\n                this.type = type;\n                this.value = value || null;\n                this.children = [];\n            }\n\n            addChild(node) {\n                this.children.push(node);\n            }\n        }\n\n        let rootNode = new ASTNode('Program', 'Root');\n        let currentNode = rootNode;\n\n        function renderAST() {\n            const astViewer = document.getElementById('astViewer');\n            astViewer.innerHTML = JSON.stringify(rootNode, null, 2);\n        }\n\n        function addNode() {\n            const nodeType = document.getElementById('nodeType').value;\n            const nodeValue = document.getElementById('nodeValue').value;\n            const newNode = new ASTNode(nodeType, nodeValue);\n            currentNode.addChild(newNode);\n            renderAST();\n        }\n\n        function changeNode() {\n            const nodeIndex = parseInt(document.getElementById('nodeIndex').value);\n            const newNodeType = document.getElementById('newNodeType').value;\n            const newNodeValue = document.getElementById('newNodeValue').value;\n\n            if (currentNode.children[nodeIndex]) {\n                currentNode.children[nodeIndex].type = newNodeType;\n                currentNode.children[nodeIndex].value = newNodeValue;\n                renderAST();\n            } else {\n                alert('Node index out of range');\n            }\n        }\n\n        function deleteNode() {\n            const nodeIndex = parseInt(document.getElementById('nodeIndex').value);\n\n            if (currentNode.children[nodeIndex]) {\n                currentNode.children.splice(nodeIndex, 1);\n                renderAST();\n            } else {\n                alert('Node index out of range');\n            }\n        }\n\n        function navigateToChild() {\n            const nodeIndex = parseInt(document.getElementById('nodeIndex').value);\n            if (currentNode.children[nodeIndex]) {\n                currentNode = currentNode.children[nodeIndex];\n                renderAST();\n            } else {\n                alert('Node index out of range');\n            }\n        }\n\n        function navigateToParent() {\n            if (currentNode !== rootNode) {\n                // Note: This approach assumes a simple tree without parent pointers. Therefore, manual management of parent nodes is necessary to navigate back.\n                alert('Navigating to parent is not implemented in this structure.');\n            }\n        }\n    </script>\n</head>\n<body>\n    <h1>Interactive Abstract Syntax Tree (AST) Demo</h1>\n    \n    <div>\n        <h2>Add Node</h2>\n        <label for=\"nodeType\">Node Type: </label>\n        <input type=\"text\" id=\"nodeType\">\n        <label for=\"nodeValue\">Node Value: </label>\n        <input type=\"text\" id=\"nodeValue\">\n        <button onclick=\"addNode()\">Add Node</button>\n    </div>\n\n    <div>\n        <h2>Change Node</h2>\n        <label for=\"nodeIndex\">Node Index: </label>\n        <input type=\"text\" id=\"nodeIndex\">\n        <label for=\"newNodeType\">New Node Type: </label>\n        <input type=\"text\" id=\"newNodeType\">\n        <label for=\"newNodeValue\">New Node Value: </label>\n        <input type=\"text\" id=\"newNodeValue\">\n        <button onclick=\"changeNode()\">Change Node</button>\n    </div>\n\n    <div>\n        <h2>Delete Node</h2>\n        <label for=\"nodeIndex\">Node Index: </label>\n        <input type=\"text\" id=\"nodeIndex\">\n        <button onclick=\"deleteNode()\">Delete Node</button>\n    </div>\n\n    <div>\n        <h2>Navigate</h2>\n        <button onclick=\"navigateToChild()\">Navigate to Child</button>\n        <button onclick=\"navigateToParent()\">Navigate to Parent</button>\n    </div>\n\n    <h2>AST Output</h2>\n    <pre id=\"astViewer\"></pre>\n\n    <script>\n        renderAST();\n    </script>\n</body>\n</html>"
