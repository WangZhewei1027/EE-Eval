  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Garbage Collection Simulator</title>\n<style>\n/* Extremely minimal styling to keep layout readable; plain black on white */\nbody { font-family: monospace; color: black; background: white; margin: 12px; }\nh1 { font-size: 18px; margin: 0 0 8px 0; }\nsection { margin-bottom: 12px; }\nlabel { margin-right: 6px; }\nbutton, input, select, textarea { font-family: monospace; margin: 2px 4px 2px 0; }\n#controls { display:block; }\n#heapView { width:100%; height:240px; }\n#log { width:100%; height:160px; }\n.small { font-size:12px; }\n.row { margin-bottom:6px; }\n.split { display:flex; gap:8px; }\n.col { flex:1; }\n</style>\n</head>\n<body>\n<h1>Garbage Collection Simulator (Plain Interface)</h1>\n\n<section id=\"controls\">\n <div class=\"row\">\n  <label>Algorithm:</label>\n  <select id=\"algo\">\n    <option value=\"markSweep\">Mark-and-Sweep (Full)</option>\n    <option value=\"minorMarkSweep\">Minor Mark-Sweep (Young)</option>\n    <option value=\"copying\">Copying (Semi-space)</option>\n    <option value=\"generational\">Generational (Minor+Major)</option>\n    <option value=\"refcount\">Reference Counting</option>\n    <option value=\"incremental\">Incremental Mark</option>\n  </select>\n\n  <label>Auto-run:</label>\n  <input type=\"checkbox\" id=\"autorun\">\n\n  <label>Speed (ms):</label>\n  <input type=\"range\" id=\"speed\" min=\"50\" max=\"2000\" value=\"400\">\n  <span id=\"speedLabel\">400</span> ms\n\n  <label>Allocation Pressure:</label>\n  <input type=\"range\" id=\"pressure\" min=\"0\" max=\"100\" value=\"30\">\n  <span id=\"pressureLabel\">30</span> %\n </div>\n\n <div class=\"row\">\n  <button id=\"allocOne\">Allocate Object</button>\n  <button id=\"allocMany\">Allocate Many</button>\n  <input type=\"number\" id=\"allocCount\" value=\"10\" min=\"1\" style=\"width:64px;\">\n  <label>Size range:</label>\n  <input type=\"number\" id=\"minSize\" value=\"1\" min=\"1\" style=\"width:48px;\">\n  <input type=\"number\" id=\"maxSize\" value=\"8\" min=\"1\" style=\"width:48px;\">\n  <label>Fields per object:</label>\n  <input type=\"number\" id=\"fields\" value=\"2\" min=\"0\" style=\"width:48px;\">\n  <label><input type=\"checkbox\" id=\"allowWeak\"> Allow weak fields</label>\n </div>\n\n <div class=\"row\">\n  <button id=\"createRoot\">Add Random Root</button>\n  <button id=\"removeRoot\">Remove Random Root</button>\n  <button id=\"toggleRootMode\">Root Mode: OFF</button>\n  <span class=\"small\">(Click an object in heap to toggle root when Root Mode ON)</span>\n </div>\n\n <div class=\"row\">\n  <button id=\"mutateOne\">Mutate One Reference</button>\n  <button id=\"mutateMany\">Mutate Many</button>\n  <input type=\"number\" id=\"mutateCount\" value=\"5\" min=\"1\" style=\"width:56px;\">\n  <button id=\"createCycle\">Create Cycle</button>\n  <button id=\"createChain\">Create Chain</button>\n  <input type=\"number\" id=\"chainLen\" value=\"6\" min=\"1\" style=\"width:48px;\">\n </div>\n\n <div class=\"row\">\n  <button id=\"stepGC\">Step GC</button>\n  <button id=\"runGC\">Run GC</button>\n  <button id=\"stopGC\">Stop GC</button>\n  <button id=\"compact\">Compact</button>\n  <button id=\"detectLeaks\">Detect Leaks</button>\n  <button id=\"exportHeap\">Export Heap</button>\n  <button id=\"importHeap\">Import Heap</button>\n  <input type=\"file\" id=\"importFile\" style=\"display:none;\">\n </div>\n\n <div class=\"row\">\n  <label>Heap size (slots):</label>\n  <input type=\"number\" id=\"heapSlots\" value=\"200\" min=\"10\" style=\"width:72px;\">\n  <label>Young size (slots):</label>\n  <input type=\"number\" id=\"youngSlots\" value=\"80\" min=\"5\" style=\"width:72px;\">\n  <label>Promotion age threshold:</label>\n  <input type=\"number\" id=\"promoteAge\" value=\"2\" min=\"0\" style=\"width:48px;\">\n  <label>Max roots:</label>\n  <input type=\"number\" id=\"maxRoots\" value=\"10\" min=\"1\" style=\"width:56px;\">\n </div>\n\n <div class=\"row\">\n  <button id=\"reset\">Reset Simulator</button>\n  <button id=\"clearLogs\">Clear Logs</button>\n  <select id=\"scenario\">\n    <option value=\"\">-- Load Scenario --</option>\n    <option value=\"leakyService\">Leaky Service (finalizers & cycles)</option>\n    <option value=\"interactiveDemo\">Interactive Demo (mix roots & cycles)</option>\n    <option value=\"stress\">Stress Test (many objects)</option>\n  </select>\n </div>\n</section>\n\n<section class=\"split\">\n <div class=\"col\">\n  <div><strong>Heap View (click object id to select for editing)</strong></div>\n  <pre id=\"heapView\"></pre>\n  <div class=\"row\">\n    <label>Selected object id:</label>\n    <input type=\"text\" id=\"selectedId\" style=\"width:140px;\">\n    <button id=\"selectRefresh\">Refresh Selection</button>\n    <button id=\"toggleRootSelected\">Toggle Root</button>\n    <button id=\"deleteSelected\">Delete Selected</button>\n    <label>Size:</label>\n    <input type=\"number\" id=\"editSize\" style=\"width:64px;\">\n    <button id=\"setSize\">Set Size</button>\n  </div>\n  <div class=\"row\">\n    <label>Fields (comma-separated target ids or null):</label>\n    <input type=\"text\" id=\"editFields\" style=\"width:420px;\">\n    <button id=\"setFields\">Set Fields</button>\n    <label><input type=\"checkbox\" id=\"editWeak\"> Mark fields as weak (applies to all)</label>\n  </div>\n </div>\n\n <div class=\"col\">\n  <div><strong>Inspector / Logs / Timeline</strong></div>\n  <div class=\"row\">\n    <label>Inspector:</label>\n    <pre id=\"inspector\" style=\"height:120px;\"></pre>\n  </div>\n  <div class=\"row\">\n    <label>Log:</label>\n    <textarea id=\"log\"></textarea>\n  </div>\n  <div class=\"row\">\n    <label>History (click to restore snapshot):</label>\n    <select id=\"history\" size=\"6\" style=\"width:100%;\"></select>\n    <div class=\"row\">\n      <button id=\"snapshot\">Save Snapshot</button>\n      <button id=\"restore\">Restore Selected</button>\n      <button id=\"deleteSnapshot\">Delete Snapshot</button>\n    </div>\n  </div>\n </div>\n</section>\n\n<script>\n/*\n Garbage Collection Simulator - Single File\n - Minimal visual design (plain text)\n - Maximum interactivity: many controls, complex state transitions\n*/\n\n/* Core simulator state */\n(function() {\n  'use strict';\n\n  // Utilities\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n  function now(){ return (new Date()).toISOString(); }\n  function clone(obj){ return JSON.parse(JSON.stringify(obj)); }\n\n  // DOM refs\n  const heapView = document.getElementById('heapView');\n  const logArea = document.getElementById('log');\n  const inspector = document.getElementById('inspector');\n  const historySel = document.getElementById('history');\n\n  const algoSel = document.getElementById('algo');\n  const autorunChk = document.getElementById('autorun');\n  const speedRange = document.getElementById('speed');\n  const speedLabel = document.getElementById('speedLabel');\n  const pressureRange = document.getElementById('pressure');\n  const pressureLabel = document.getElementById('pressureLabel');\n\n  const allocOneBtn = document.getElementById('allocOne');\n  const allocManyBtn = document.getElementById('allocMany');\n  const allocCountInput = document.getElementById('allocCount');\n  const minSizeInput = document.getElementById('minSize');\n  const maxSizeInput = document.getElementById('maxSize');\n  const fieldsInput = document.getElementById('fields');\n  const allowWeakChk = document.getElementById('allowWeak');\n\n  const createRootBtn = document.getElementById('createRoot');\n  const removeRootBtn = document.getElementById('removeRoot');\n  const toggleRootModeBtn = document.getElementById('toggleRootMode');\n  let rootMode = false;\n\n  const mutateOneBtn = document.getElementById('mutateOne');\n  const mutateManyBtn = document.getElementById('mutateMany');\n  const mutateCountInput = document.getElementById('mutateCount');\n  const createCycleBtn = document.getElementById('createCycle');\n  const createChainBtn = document.getElementById('createChain');\n  const chainLenInput = document.getElementById('chainLen');\n\n  const stepGCBtn = document.getElementById('stepGC');\n  const runGCBtn = document.getElementById('runGC');\n  const stopGCBtn = document.getElementById('stopGC');\n  const compactBtn = document.getElementById('compact');\n  const detectLeaksBtn = document.getElementById('detectLeaks');\n  const exportHeapBtn = document.getElementById('exportHeap');\n  const importHeapBtn = document.getElementById('importHeap');\n  const importFileInput = document.getElementById('importFile');\n\n  const heapSlotsInput = document.getElementById('heapSlots');\n  const youngSlotsInput = document.getElementById('youngSlots');\n  const promoteAgeInput = document.getElementById('promoteAge');\n  const maxRootsInput = document.getElementById('maxRoots');\n\n  const resetBtn = document.getElementById('reset');\n  const clearLogsBtn = document.getElementById('clearLogs');\n  const scenarioSel = document.getElementById('scenario');\n\n  const selectedIdInput = document.getElementById('selectedId');\n  const selectRefreshBtn = document.getElementById('selectRefresh');\n  const toggleRootSelectedBtn = document.getElementById('toggleRootSelected');\n  const deleteSelectedBtn = document.getElementById('deleteSelected');\n  const editSizeInput = document.getElementById('editSize');\n  const setSizeBtn = document.getElementById('setSize');\n  const editFieldsInput = document.getElementById('editFields');\n  const setFieldsBtn = document.getElementById('setFields');\n  const editWeakChk = document.getElementById('editWeak');\n\n  const snapshotBtn = document.getElementById('snapshot');\n  const restoreBtn = document.getElementById('restore');\n  const deleteSnapshotBtn = document.getElementById('deleteSnapshot');\n\n  // Simulation state\n  let nextId = 1;\n  let slotsUsed = 0;\n  let heapSlots = parseInt(heapSlotsInput.value,10);\n  let youngSlots = parseInt(youngSlotsInput.value,10);\n  let promoteAge = parseInt(promoteAgeInput.value,10);\n  let maxRoots = parseInt(maxRootsInput.value,10);\n\n  // Represent objects as:\n  // { id, addr, size, fields: [{target:null|id, weak:false}], age, generation: 'young'|'old',\n  //   marked:false, refcount:0, finalizer:false, pinned:false, forwarded:null, bornAt:number }\n  let objects = {}; // id -> object\n  let roots = new Set(); // set of ids\n  let freeAddr = 1; // simple address counter\n  let history = []; // snapshots\n  let autorunTimer = null;\n  let incrementalWorklist = [];\n  let incrementalState = null;\n\n  // Logging\n  function log(s){\n    const line = '['+now()+'] '+s;\n    logArea.value = line + '\\n' + logArea.value;\n  }\n  function clearLog(){ logArea.value = ''; }\n\n  // Helpers\n  function getObject(id){ return objects[id] || null; }\n  function allObjects(){ return Object.values(objects).sort((a,b)=>a.addr-b.addr); }\n\n  function allocateObject(opts){\n    opts = opts || {};\n    const size = opts.size || randInt(parseInt(minSizeInput.value,10), parseInt(maxSizeInput.value,10));\n    const fieldsCount = ('fields' in opts) ? opts.fields : parseInt(fieldsInput.value,10);\n    const allowWeak = allowWeakChk.checked;\n    // Check available slots (simple)\n    if (slotsUsed + size > heapSlots) {\n      log('Allocation failed: not enough heap slots. Consider running GC or increasing heap slots.');\n      return null;\n    }\n    const id = nextId++;\n    const obj = {\n      id:id,\n      addr: freeAddr,\n      size: size,\n      fields: [],\n      age: 0,\n      generation: 'young',\n      marked: false,\n      refcount: 0,\n      finalizer: !!opts.finalizer,\n      pinned: !!opts.pinned,\n      forwarded: null,\n      bornAt: Date.now()\n    };\n    for (let i=0;i<fieldsCount;i++){\n      const f = { target: null, weak: allowWeak && Math.random()<0.25 };\n      obj.fields.push(f);\n    }\n    objects[id]=obj;\n    slotsUsed += size;\n    freeAddr += size; // simplistic address assignment\n    // Update refcounts for any fields set on creation (none by default)\n    log('Allocated object id='+id+' size='+size+' fields='+obj.fields.length);\n    return obj;\n  }\n\n  function freeObject(id){\n    const obj = getObject(id);\n    if (!obj) return;\n    // Kick finalizer if present\n    if (obj.finalizer) {\n      log('Finalizer run for object '+id);\n    }\n    // Decrease refcounts for targets\n    for (const f of obj.fields){\n      if (f.target !== null){\n        decRef(f.target);\n      }\n    }\n    slotsUsed -= obj.size;\n    delete objects[id];\n    roots.delete(id);\n    log('Freed object '+id);\n  }\n\n  function incRef(id){\n    const o = getObject(id);\n    if (!o) return;\n    o.refcount++;\n  }\n  function decRef(id){\n    const o = getObject(id);\n    if (!o) return;\n    o.refcount--;\n  }\n\n  function setField(sourceId, fieldIndex, targetId, weak=false){\n    const source = getObject(sourceId);\n    if (!source) return false;\n    if (fieldIndex<0 || fieldIndex>=source.fields.length) return false;\n    const prev = source.fields[fieldIndex].target;\n    if (prev !== null) decRef(prev);\n    source.fields[fieldIndex].target = (targetId===null? null : targetId);\n    source.fields[fieldIndex].weak = !!weak;\n    if (targetId !== null) incRef(targetId);\n    return true;\n  }\n\n  function addRoot(id){\n    if (!getObject(id)) return false;\n    if (roots.size >= maxRoots) {\n      log('Cannot add root '+id+' — root set limit reached');\n      return false;\n    }\n    if (!roots.has(id)) {\n      roots.add(id);\n      log('Added root '+id);\n    }\n    return true;\n  }\n\n  function removeRoot(id){\n    if (roots.has(id)) {\n      roots.delete(id);\n      log('Removed root '+id);\n      return true;\n    }\n    return false;\n  }\n\n  // Rendering\n  function renderHeap(){\n    // Minimal plain representation\n    const lines = [];\n    lines.push('Heap slots used: '+slotsUsed+' / '+heapSlots+'  (young slots: '+youngSlots+')');\n    lines.push('Roots: ['+Array.from(roots).join(', ')+']');\n    lines.push('Objects (addr,size,age,gen,refcount,marked,finalizer,pinned):');\n    for (const o of allObjects()){\n      const fstrings = o.fields.map((f,i)=>('f'+i+':'+(f.target===null?'null':f.target)+(f.weak?'<weak>':'')));\n      lines.push('id='+o.id+' @'+o.addr+' size='+o.size+' age='+o.age+' gen='+o.generation\n           +' rc='+o.refcount+' mark='+o.marked+' fin='+(o.finalizer?'Y':'N')+' pin='+(o.pinned?'Y':'N')\n           +' fields={'+fstrings.join(', ')+'}');\n    }\n    lines.push('');\n    lines.push('Controls: Click an object id below to select it for editing.');\n    lines.push('');\n    lines.push('Object ids:');\n    // List object ids as clickable tokens (we will emulate clickable by linking)\n    let idsLine = '';\n    for (const o of allObjects()){\n      idsLine += '['+o.id+'] ';\n    }\n    lines.push(idsLine);\n    heapView.textContent = lines.join('\\n');\n  }\n\n  function inspect(id){\n    const o = getObject(parseInt(id,10));\n    if (!o){\n      inspector.textContent = 'No object with id '+id;\n      return;\n    }\n    const lines = [];\n    lines.push('Object id='+o.id);\n    lines.push('Address: '+o.addr);\n    lines.push('Size: '+o.size);\n    lines.push('Age: '+o.age);\n    lines.push('Generation: '+o.generation);\n    lines.push('Refcount: '+o.refcount);\n    lines.push('Marked: '+o.marked);\n    lines.push('Finalizer: '+o.finalizer);\n    lines.push('Pinned: '+o.pinned);\n    lines.push('Fields:');\n    o.fields.forEach((f,i)=>{\n      lines.push('  ['+i+'] -> '+(f.target===null?'null':f.target)+' (weak='+f.weak+')');\n    });\n    inspector.textContent = lines.join('\\n');\n    selectedIdInput.value = o.id;\n    editSizeInput.value = o.size;\n    editFieldsInput.value = o.fields.map(f=>f.target===null?'null':f.target).join(',');\n    editWeakChk.checked = o.fields.length>0 && o.fields.every(f=>f.weak);\n  }\n\n  // Click handling in heapView: detect id on click\n  heapView.addEventListener('click', function(e){\n    // Determine click position contents\n    // Simpler: open a prompt to enter id? But requirement: click object id in heap.\n    // We'll find nearest number under click by mapping coordinates -> line content.\n    // For simplicity, prompt for id if rootMode true.\n    if (rootMode){\n      const id = prompt('Enter object id to toggle root:');\n      if (id) {\n        const iid = parseInt(id,10);\n        if (!getObject(iid)) { alert('No such id'); return; }\n        if (roots.has(iid)) removeRoot(iid); else addRoot(iid);\n        renderAll();\n      }\n      return;\n    }\n    // Otherwise prompt for id to inspect\n    const id = prompt('Enter object id to inspect/edit:');\n    if (!id) return;\n    if (!getObject(parseInt(id,10))) { alert('No such id'); return; }\n    inspect(id);\n  });\n\n  // GC Algorithms\n\n  // Mark-and-Sweep (full)\n  function markAndSweepFull(){\n    log('Starting full mark-and-sweep');\n    // Clear marks\n    for (const o of Object.values(objects)) o.marked = false;\n    // Mark phase\n    const stack = [];\n    roots.forEach(r=>stack.push(r));\n    while (stack.length){\n      const id = stack.pop();\n      const o = getObject(id);\n      if (!o || o.marked) continue;\n      o.marked = true;\n      for (const f of o.fields){\n        if (f.target !== null && !f.weak){\n          stack.push(f.target);\n        }\n      }\n    }\n    // Sweep\n    const toFree = [];\n    for (const o of Object.values(objects)){\n      if (!o.marked){\n        toFree.push(o.id);\n      }\n    }\n    for (const id of toFree) freeObject(id);\n    log('Mark-and-sweep complete. Freed '+toFree.length+' objects.');\n    renderAll();\n  }\n\n  // Minor mark-sweep (young only)\n  function markAndSweepYoung(){\n    log('Starting minor mark-and-sweep (young generation)');\n    for (const o of Object.values(objects)) {\n      if (o.generation==='young') o.marked = false;\n    }\n    const stack = [];\n    roots.forEach(r=>stack.push(r));\n    while (stack.length){\n      const id = stack.pop();\n      const o = getObject(id);\n      if (!o) continue;\n      if (o.marked) continue;\n      o.marked = true;\n      for (const f of o.fields){\n        if (f.target !== null && !f.weak){\n          // Mark reachable objects but only propagate into young space for minor GC? We'll mark regardless but only sweep young.\n          stack.push(f.target);\n        }\n      }\n    }\n    const toFree = [];\n    for (const o of Object.values(objects)){\n      if (o.generation==='young' && !o.marked){\n        toFree.push(o.id);\n      }\n    }\n    for (const id of toFree) freeObject(id);\n    // Age increment for surviving young objects; possibly promote\n    for (const o of Object.values(objects)){\n      if (o.generation==='young' && o.marked){\n        o.age++;\n        if (o.age > promoteAgeInput.value) {\n          o.generation = 'old';\n          log('Promoted object '+o.id+' to old generation');\n        }\n      }\n    }\n    log('Minor mark-and-sweep complete. Freed '+toFree.length+' young objects.');\n    renderAll();\n  }\n\n  // Copying (semi-space) for young generation: allocate new objects in to-space and forward pointers\n  function copyingGC(){\n    log('Starting copying GC (semi-space) on young generation');\n    // create mapping from old id to new object (simulate new address)\n    const newMap = {};\n    const newObjects = {};\n    let newSlotsUsed = 0;\n    // Copy reachable young objects reachable from roots\n    const queue = [];\n    roots.forEach(r=>queue.push(r));\n    while (queue.length){\n      const id = queue.shift();\n      const o = getObject(id);\n      if (!o) continue;\n      for (const f of o.fields){\n        if (f.target !== null && !f.weak){\n          const t = getObject(f.target);\n          if (!t) continue;\n          if (t.generation === 'young' && !newMap[t.id]){\n            // copy\n            const copyId = nextId++;\n            const copyObj = clone(t);\n            copyObj.id = copyId;\n            copyObj.addr = freeAddr + newSlotsUsed;\n            copyObj.marked = false;\n            copyObj.forwarded = null;\n            copyObj.age = t.age+1;\n            // Note: copied objects are considered still young or promoted?\n            if (copyObj.age > promoteAgeInput.value) {\n              copyObj.generation = 'old';\n              log('Promotion during copying: original '+t.id+' -> copy '+copyId+' now old');\n            } else {\n              copyObj.generation = 'young';\n            }\n            newMap[t.id] = copyId;\n            newObjects[copyId] = copyObj;\n            newSlotsUsed += copyObj.size;\n            // Enqueue original's fields targets to be scanned later\n            // We'll handle pointers after we've created nodes\n            queue.push(t.id); // ensure transitive closure\n          }\n        }\n      }\n    }\n    // If nothing to copy, just return\n    const newIds = Object.keys(newObjects).map(x=>parseInt(x,10));\n    if (newIds.length===0) {\n      log('Copying GC: no young objects reachable, nothing copied.');\n      return;\n    }\n    // Build copies for each mapped original\n    for (const oldIdStr of Object.keys(newMap)){\n      const oldId = parseInt(oldIdStr,10);\n      const copyId = newMap[oldId];\n      const oldObj = getObject(oldId);\n      const copy = clone(oldObj);\n      copy.id = copyId;\n      copy.addr = freeAddr; freeAddr += copy.size;\n      copy.forwarded = null;\n      // Update fields: if target within young and copied, update to new id; otherwise keep target id\n      for (let i=0;i<copy.fields.length;i++){\n        const f = copy.fields[i];\n        if (f.target !== null && newMap[f.target]){\n          copy.fields[i].target = newMap[f.target];\n        }\n      }\n      newObjects[copyId] = copy;\n    }\n    // Insert copied objects to heap and remove originals that were copied\n    for (const newId of Object.keys(newObjects)){\n      const n = newObjects[newId];\n      objects[n.id] = n;\n      slotsUsed += n.size;\n    }\n    // Remove old young objects that were copied (simulate from-space clearing)\n    const removed = [];\n    for (const oldIdStr of Object.keys(newMap)){\n      const oldId = parseInt(oldIdStr,10);\n      const old = getObject(oldId);\n      if (old) {\n        slotsUsed -= old.size;\n        delete objects[oldId];\n        removed.push(oldId);\n      }\n    }\n    log('Copying GC copied '+newIds.length+' objects, removed '+removed.length+' originals.');\n    renderAll();\n  }\n\n  // Reference counting collector (simple): recompute refcounts from scratch, free zero-ref objects iteratively, then detect cycles\n  function referenceCountingPass(){\n    log('Starting reference counting pass');\n    // Reset refcounts\n    for (const o of Object.values(objects)) o.refcount = 0;\n    // Count references from roots and fields (only strong)\n    for (const r of roots) {\n      const o = getObject(r);\n      if (!o) continue;\n      o.refcount++;\n    }\n    for (const o of Object.values(objects)){\n      for (const f of o.fields){\n        if (f.target !== null && !f.weak){\n          const t = getObject(f.target);\n          if (t) t.refcount++;\n        }\n      }\n    }\n    // Free objects with zero refcount iteratively\n    const queue = [];\n    for (const o of Object.values(objects)) if (o.refcount<=0) queue.push(o.id);\n    const freed = [];\n    while (queue.length){\n      const id = queue.pop();\n      const o = getObject(id);\n      if (!o) continue;\n      // If any root reference exists, skip\n      if (roots.has(id)) continue;\n      // Free it\n      for (const f of o.fields){\n        if (f.target !== null){\n          const t = getObject(f.target);\n          if (!t) continue;\n          t.refcount--;\n          if (t.refcount<=0) queue.push(t.id);\n        }\n      }\n      freed.push(id);\n      slotsUsed -= o.size;\n      delete objects[id];\n    }\n    log('Reference counting freed '+freed.length+' objects (not including cycles).');\n    renderAll();\n  }\n\n  // Simple cycle detection: find SCCs of remaining objects not reachable from roots using graph traversal\n  function detectCycles(){\n    log('Detecting unreachable cycles');\n    // Build graph of strong references\n    const nodes = Object.keys(objects).map(x=>parseInt(x,10));\n    const nodeIndex = {};\n    nodes.forEach((n,i)=>nodeIndex[n]=i);\n    const adj = nodes.map(()=>[]);\n    for (const o of Object.values(objects)){\n      const u = nodeIndex[o.id];\n      for (const f of o.fields){\n        if (f.target !== null && !f.weak){\n          if (nodeIndex[f.target] !== undefined){\n            adj[u].push(nodeIndex[f.target]);\n          }\n        }\n      }\n    }\n    // Determine reachable from roots\n    const reachable = new Set();\n    const stack = [];\n    roots.forEach(r=>{\n      if (nodeIndex[r]!==undefined) stack.push(nodeIndex[r]);\n    });\n    while (stack.length){\n      const u = stack.pop();\n      if (reachable.has(u)) continue;\n      reachable.add(u);\n      for (const v of adj[u]) stack.push(v);\n    }\n    // Objects not reachable are candidates; find SCCs among them\n    const candidates = nodes.map((n,i)=>i).filter(i=>!reachable.has(i));\n    if (candidates.length===0){\n      log('No unreachable objects found.');\n      return [];\n    }\n    // Tarjan's SCC\n    let index = 0;\n    const indices = Array(nodes.length).fill(-1);\n    const lowlink = Array(nodes.length).fill(0);\n    const onstack = Array(nodes.length).fill(false);\n    const S = [];\n    const sccs = [];\n    function strongconnect(v){\n      indices[v] = index; lowlink[v] = index; index++;\n      S.push(v); onstack[v]=true;\n      for (const w of adj[v]){\n        if (indices[w]===-1){\n          strongconnect(w);\n          lowlink[v] = Math.min(lowlink[v], lowlink[w]);\n        } else if (onstack[w]){\n          lowlink[v] = Math.min(lowlink[v], indices[w]);\n        }\n      }\n      if (lowlink[v] === indices[v]){\n        const comp = [];\n        let w;\n        do {\n          w = S.pop();\n          onstack[w]=false;\n          comp.push(nodes[w]);\n        } while (w !== v);\n        sccs.push(comp);\n      }\n    }\n    for (const v of candidates) if (indices[v]===-1) strongconnect(v);\n    // Filter SCCs which are cycles (size>1 or self-loop)\n    const cycles = sccs.filter(comp=>{\n      if (comp.length>1) return true;\n      const single = comp[0];\n      const o = getObject(single);\n      if (!o) return false;\n      return o.fields.some(f=>f.target===single);\n    });\n    log('Detected '+cycles.length+' unreachable cycles / SCCs.');\n    // Optionally free them\n    const freed = [];\n    for (const comp of cycles){\n      for (const id of comp){\n        if (getObject(id)) { freed.push(id); delete objects[id]; slotsUsed -= 0; } // size accounted below\n      }\n    }\n    // Now adjust slotsUsed by adding sizes of freed objects\n    let removedSize = 0;\n    for (const id of freed){\n      // Freed earlier via delete but we didn't subtract sizes; compute from snapshot? We can't now; simpler: recompute slotsUsed\n    }\n    // recompute slotsUsed:\n    slotsUsed = 0;\n    for (const o of Object.values(objects)) slotsUsed += o.size;\n    log('Freed objects from cycles: '+freed.join(', '));\n    renderAll();\n    return cycles;\n  }\n\n  // Incremental marking: push some objects per step\n  function startIncremental(){\n    incrementalWorklist = [];\n    // Initialize with roots\n    for (const r of roots) incrementalWorklist.push(r);\n    incrementalState = { phase: 'marking' };\n    log('Started incremental marking. Use Step GC to process worklist.');\n  }\n\n  function stepIncremental(){\n    if (!incrementalState || incrementalState.phase!=='marking'){\n      startIncremental();\n    }\n    const batchSize = Math.max(1, Math.floor(10 * (100/pressureRange.value)));\n    let processed = 0;\n    while (processed < batchSize && incrementalWorklist.length){\n      const id = incrementalWorklist.shift();\n      const o = getObject(id);\n      if (!o || o.marked) continue;\n      o.marked = true;\n      for (const f of o.fields){\n        if (f.target !== null && !f.weak){\n          incrementalWorklist.push(f.target);\n        }\n      }\n      processed++;\n    }\n    log('Incremental step processed '+processed+' objects; remaining worklist='+incrementalWorklist.length);\n    if (incrementalWorklist.length===0){\n      // Do sweep for unmarked objects\n      const toFree = [];\n      for (const o of Object.values(objects)){\n        if (!o.marked) toFree.push(o.id);\n      }\n      for (const id of toFree) freeObject(id);\n      // Clear marks\n      for (const o of Object.values(objects)) o.marked = false;\n      incrementalState = null;\n      log('Incremental marking complete; swept '+toFree.length+' objects.');\n    }\n    renderAll();\n  }\n\n  // Compaction: move objects to eliminate gaps and update addresses\n  function compactHeap(){\n    log('Starting heap compaction');\n    const objs = allObjects();\n    let addr = 1;\n    for (const o of objs){\n      o.addr = addr;\n      addr += o.size;\n    }\n    freeAddr = addr;\n    log('Compaction complete; addresses reassigned.');\n    renderAll();\n  }\n\n  // Manual GC control\n  function stepGC(){\n    const algo = algoSel.value;\n    if (algo==='markSweep') markAndSweepFull();\n    else if (algo==='minorMarkSweep') markAndSweepYoung();\n    else if (algo==='copying') copyingGC();\n    else if (algo==='generational') {\n      // Minor GC on young; if pressure high or young full, trigger major\n      if (slotsUsed > heapSlots * 0.85 || pressureRange.value > 70) {\n        log('Generational: conditions met for major GC');\n        markAndSweepFull();\n      } else {\n        markAndSweepYoung();\n      }\n    } else if (algo==='refcount') {\n      referenceCountingPass();\n      // optionally detect cycles\n      detectCycles();\n    } else if (algo==='incremental') {\n      stepIncremental();\n    }\n  }\n\n  let running = false;\n  function runGC(){\n    if (running) return;\n    running = true;\n    log('Auto GC run started for algorithm: '+algoSel.value);\n    const loop = ()=>{\n      if (!running) return;\n      // allocate some objects based on pressure to simulate runtime\n      simulateAllocations();\n      stepGC();\n      if (autorunChk.checked){\n        autorunTimer = setTimeout(loop, parseInt(speedRange.value,10));\n      } else {\n        running = false;\n      }\n    };\n    if (autorunChk.checked){\n      loop();\n    } else {\n      // Single run once\n      stepGC();\n    }\n  }\n\n  function stopGC(){\n    running = false;\n    if (autorunTimer) { clearTimeout(autorunTimer); autorunTimer = null; }\n    log('Auto GC stopped.');\n  }\n\n  // Simulate allocations triggered by pressure\n  function simulateAllocations(){\n    const pressure = parseInt(pressureRange.value,10);\n    // With some probability, allocate objects\n    const p = pressure/100;\n    const r = Math.random();\n    if (r < p){\n      const n = Math.max(1, Math.floor(p * 5));\n      for (let i=0;i<n;i++){\n        const o = allocateObject();\n        // randomly assign some fields to existing objects\n        if (o){\n          const objs = Object.keys(objects).map(x=>parseInt(x,10));\n          for (let fi=0; fi<o.fields.length; fi++){\n            if (objs.length>1 && Math.random()<0.6){\n              const tgt = objs[randInt(0,objs.length-1)];\n              if (tgt!==o.id) setField(o.id, fi, tgt, Math.random()<0.1);\n            }\n          }\n          if (Math.random()<0.2) addRoot(o.id);\n        }\n      }\n    }\n  }\n\n  // UI actions\n  allocOneBtn.addEventListener('click', function(){\n    const o = allocateObject();\n    renderAll();\n    if (o) inspect(o.id);\n  });\n  allocManyBtn.addEventListener('click', function(){\n    const n = Math.max(1, parseInt(allocCountInput.value,10));\n    for (let i=0;i<n;i++){\n      const o = allocateObject();\n      if (o && Math.random()<0.1) addRoot(o.id);\n    }\n    renderAll();\n  });\n\n  createRootBtn.addEventListener('click', function(){\n    const ids = Object.keys(objects).map(x=>parseInt(x,10));\n    if (ids.length===0) { log('No objects to add as root'); return; }\n    const id = ids[randInt(0, ids.length-1)];\n    addRoot(id);\n    renderAll();\n  });\n  removeRootBtn.addEventListener('click', function(){\n    const ids = Array.from(roots);\n    if (ids.length===0) { log('No roots to remove'); return; }\n    const id = ids[randInt(0, ids.length-1)];\n    removeRoot(id);\n    renderAll();\n  });\n  toggleRootModeBtn.addEventListener('click', function(){\n    rootMode = !rootMode;\n    toggleRootModeBtn.textContent = 'Root Mode: '+(rootMode?'ON':'OFF');\n  });\n\n  mutateOneBtn.addEventListener('click', function(){\n    const ids = Object.keys(objects).map(x=>parseInt(x,10));\n    if (ids.length===0) { log('No objects to mutate'); return; }\n    const id = ids[randInt(0, ids.length-1)];\n    const o = getObject(id);\n    if (!o || o.fields.length===0) { log('Selected object has no fields'); return; }\n    const fi = randInt(0, o.fields.length-1);\n    const targetCandidates = ids.filter(x=>x!==id);\n    const tgt = (targetCandidates.length>0 && Math.random()<0.8) ? targetCandidates[randInt(0,targetCandidates.length-1)] : null;\n    setField(id, fi, tgt, allowWeakChk.checked && Math.random()<0.2);\n    log('Mutated object '+id+' field['+fi+'] -> '+(tgt===null?'null':tgt));\n    renderAll();\n  });\n\n  mutateManyBtn.addEventListener('click', function(){\n    const n = Math.max(1, parseInt(mutateCountInput.value,10));\n    for (let i=0;i<n;i++) mutateOneBtn.click();\n  });\n\n  createCycleBtn.addEventListener('click', function(){\n    // create a small cycle of new objects and no roots\n    const size = randInt(2,5);\n    const ids = [];\n    for (let i=0;i<size;i++){\n      const o = allocateObject({size:1, fields:1});\n      ids.push(o.id);\n    }\n    for (let i=0;i<size;i++){\n      setField(ids[i], 0, ids[(i+1)%size]);\n    }\n    log('Created cycle of ids: '+ids.join(', '));\n    renderAll();\n  });\n\n  createChainBtn.addEventListener('click', function(){\n    const len = Math.max(1, parseInt(chainLenInput.value,10));\n    const ids = [];\n    for (let i=0;i<len;i++){\n      const o = allocateObject({size:1, fields:1});\n      ids.push(o.id);\n    }\n    for (let i=0;i<len-1;i++){\n      setField(ids[i],0,ids[i+1]);\n    }\n    // optionally root the head\n    if (Math.random()<0.5) addRoot(ids[0]);\n    log('Created chain: '+ids.join(' -> '));\n    renderAll();\n  });\n\n  stepGCBtn.addEventListener('click', function(){ stepGC(); });\n  runGCBtn.addEventListener('click', function(){ autorunChk.checked = true; runGC(); });\n  stopGCBtn.addEventListener('click', function(){ autorunChk.checked = false; stopGC(); });\n\n  compactBtn.addEventListener('click', function(){ compactHeap(); });\n\n  detectLeaksBtn.addEventListener('click', function(){ detectCycles(); });\n\n  exportHeapBtn.addEventListener('click', function(){\n    const data = {\n      nextId, slotsUsed, freeAddr, objects, roots:Array.from(roots),\n      heapSlots: parseInt(heapSlotsInput.value,10), youngSlots: parseInt(youngSlotsInput.value,10)\n    };\n    const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a');\n    a.href = url;\n    a.download = 'heap.json';\n    a.click();\n  });\n\n  importHeapBtn.addEventListener('click', function(){ importFileInput.click(); });\n  importFileInput.addEventListener('change', function(e){\n    const f = e.target.files[0];\n    if (!f) return;\n    const r = new FileReader();\n    r.onload = function(ev){\n      try {\n        const data = JSON.parse(ev.target.result);\n        if (!data.objects) throw 'Invalid file';\n        objects = data.objects;\n        nextId = data.nextId || (Math.max(0, ...Object.keys(objects).map(x=>parseInt(x,10)))+1);\n        slotsUsed = 0;\n        for (const o of Object.values(objects)) slotsUsed += o.size;\n        freeAddr = data.freeAddr || 1;\n        roots = new Set(data.roots || []);\n        heapSlotsInput.value = data.heapSlots || heapSlotsInput.value;\n        youngSlotsInput.value = data.youngSlots || youngSlotsInput.value;\n        renderAll();\n        log('Imported heap from file');\n      } catch(e){\n        alert('Failed to import: '+e);\n      }\n    };\n    r.readAsText(f);\n  });\n\n  resetBtn.addEventListener('click', function(){\n    if (!confirm('Reset simulator? All objects will be cleared.')) return;\n    objects = {};\n    roots = new Set();\n    nextId = 1;\n    slotsUsed = 0;\n    freeAddr = 1;\n    history = [];\n    historySel.innerHTML = '';\n    clearLog();\n    renderAll();\n    log('Simulator reset');\n  });\n\n  clearLogsBtn.addEventListener('click', clearLog);\n\n  scenarioSel.addEventListener('change', function(){\n    const v = scenarioSel.value;\n    if (!v) return;\n    if (v==='leakyService'){\n      resetBtn.click();\n      // Create objects with finalizers and cycles and some roots missing\n      for (let i=0;i<10;i++){\n        const o = allocateObject({size:2, fields:2, finalizer:(i%3===0)});\n        if (i%4===0) addRoot(o.id);\n      }\n      // create cycles\n      createCycleBtn.click();\n      createCycleBtn.click();\n      log('Loaded scenario: leakyService');\n      renderAll();\n    } else if (v==='interactiveDemo'){\n      resetBtn.click();\n      for (let i=0;i<20;i++){\n        const o = allocateObject({size:1+randInt(0,3), fields:randInt(1,3)});\n        if (Math.random()<0.2) addRoot(o.id);\n      }\n      log('Loaded scenario: interactiveDemo');\n      renderAll();\n    } else if (v==='stress'){\n      resetBtn.click();\n      for (let i=0;i<120;i++){\n        allocateObject({size:1, fields:1});\n      }\n      // random references\n      const ids = Object.keys(objects).map(x=>parseInt(x,10));\n      for (const id of ids){\n        const o = getObject(id);\n        for (let fi=0;fi<o.fields.length;fi++){\n          const tgt = ids[randInt(0, ids.length-1)];\n          setField(o.id, fi, tgt, Math.random()<0.05);\n        }\n      }\n      log('Loaded scenario: stress');\n      renderAll();\n    }\n  });\n\n  // Selection and editing\n  selectRefreshBtn.addEventListener('click', function(){\n    const id = selectedIdInput.value;\n    if (!id) { alert('Enter id'); return; }\n    inspect(id);\n  });\n  toggleRootSelectedBtn.addEventListener('click', function(){\n    const id = parseInt(selectedIdInput.value,10);\n    if (!getObject(id)) { alert('No such object'); return; }\n    if (roots.has(id)) removeRoot(id); else addRoot(id);\n    renderAll();\n  });\n  deleteSelectedBtn.addEventListener('click', function(){\n    const id = parseInt(selectedIdInput.value,10);\n    if (!getObject(id)) { alert('No such object'); return; }\n    freeObject(id);\n    renderAll();\n  });\n  setSizeBtn.addEventListener('click', function(){\n    const id = parseInt(selectedIdInput.value,10);\n    const o = getObject(id);\n    if (!o) { alert('No such object'); return; }\n    const newSize = parseInt(editSizeInput.value,10);\n    if (newSize<=0) return;\n    slotsUsed += (newSize - o.size);\n    o.size = newSize;\n    renderAll();\n  });\n  setFieldsBtn.addEventListener('click', function(){\n    const id = parseInt(selectedIdInput.value,10);\n    const o = getObject(id);\n    if (!o) { alert('No such object'); return; }\n    const parts = editFieldsInput.value.split(',').map(s=>s.trim());\n    // ensure objects have fields to match or adjust length\n    while (o.fields.length < parts.length) o.fields.push({target:null,weak:false});\n    for (let i=0;i<o.fields.length;i++){\n      const p = parts[i];\n      const tgt = (p===undefined || p==='' || p.toLowerCase()==='null') ? null : parseInt(p,10);\n      setField(id, i, tgt, editWeakChk.checked);\n    }\n    renderAll();\n  });\n\n  // Snapshots\n  snapshotBtn.addEventListener('click', function(){\n    const snap = {\n      ts: now(),\n      state: { nextId, slotsUsed, freeAddr, objects: clone(objects), roots: Array.from(roots) }\n    };\n    history.push(snap);\n    const opt = document.createElement('option');\n    opt.text = snap.ts + ' ('+Object.keys(snap.state.objects).length+' objs)';\n    opt.value = history.length-1;\n    historySel.add(opt);\n    log('Saved snapshot '+snap.ts);\n  });\n  restoreBtn.addEventListener('click', function(){\n    const idx = historySel.value;\n    if (!idx) { alert('Select snapshot'); return; }\n    const snap = history[idx];\n    if (!snap) { alert('Invalid snapshot'); return; }\n    if (!confirm('Restore snapshot from '+snap.ts+'? This will overwrite current heap.')) return;\n    nextId = snap.state.nextId;\n    slotsUsed = snap.state.slotsUsed;\n    freeAddr = snap.state.freeAddr;\n    objects = clone(snap.state.objects);\n    roots = new Set(snap.state.roots);\n    renderAll();\n    log('Restored snapshot '+snap.ts);\n  });\n  deleteSnapshotBtn.addEventListener('click', function(){\n    const idx = historySel.value;\n    if (!idx) { alert('Select snapshot'); return; }\n    history.splice(idx,1);\n    historySel.remove(idx);\n    log('Deleted snapshot '+idx);\n  });\n\n  // Misc UI updates\n  speedRange.addEventListener('input', function(){ speedLabel.textContent = speedRange.value; });\n  pressureRange.addEventListener('input', function(){ pressureLabel.textContent = pressureRange.value; });\n\n  // Render all\n  function renderAll(){\n    heapSlots = Math.max(10, parseInt(heapSlotsInput.value,10));\n    youngSlots = Math.max(5, parseInt(youngSlotsInput.value,10));\n    promoteAge = Math.max(0, parseInt(promoteAgeInput.value,10));\n    maxRoots = Math.max(1, parseInt(maxRootsInput.value,10));\n    renderHeap();\n    const sel = selectedIdInput.value;\n    if (sel) {\n      const o = getObject(parseInt(sel,10));\n      if (o) inspect(sel); else inspector.textContent = 'Selected object not found';\n    }\n  }\n\n  // Initialize with a small demo\n  function initDemo(){\n    for (let i=0;i<8;i++){\n      const o = allocateObject({size:randInt(1,4), fields:randInt(0,3)});\n      if (i<2) addRoot(o.id);\n    }\n    // Link some\n    const ids = Object.keys(objects).map(x=>parseInt(x,10));\n    if (ids.length>=3){\n      setField(ids[0], 0, ids[1]);\n      setField(ids[1], 0, ids[2]);\n    }\n    renderAll();\n    log('Initialized demo heap with '+Object.keys(objects).length+' objects.');\n  }\n\n  // first render\n  initDemo();\n\n  // Global keyboard shortcuts\n  window.addEventListener('keydown', function(e){\n    if (e.key==='g') { stepGCBtn.click(); }\n    if (e.key==='r') { runGCBtn.click(); }\n    if (e.key==='s') { snapshotBtn.click(); }\n  });\n\n  // Expose simple API for console debugging\n  window.GCSim = {\n    allocateObject, freeObject, objects, roots, renderAll, log\n  };\n\n})();\n</script>\n</body>\n</html>"
