    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Dynamic Array — Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700&family=Playfair+Display&display=swap');\n\n  /* Reset/Normalize */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1f1f38 0%, #2e3a59 60%, #40607a 100%);\n    color: #e0e6f1;\n    font-family: 'Montserrat', sans-serif;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    overflow-x: hidden;\n    padding: 2rem;\n    user-select: none;\n  }\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.6rem;\n    margin-bottom: 0.2em;\n    letter-spacing: 0.05em;\n    text-align: center;\n    color: #e0ecff;\n    text-shadow:\n       0 0 6px #a0c1ff88,\n       0 0 15px #60a0ff99,\n       0 0 20px #5088ffcc;\n  }\n  h2 {\n    font-weight: 500;\n    font-size: 1.25rem;\n    margin-bottom: 3rem;\n    text-align: center;\n    color: #b0c5ffcc;\n    letter-spacing: 0.07em;\n  }\n\n  /* Container for the array visualization */\n  .array-container {\n    position: relative;\n    display: flex;\n    gap: 1.6rem;\n    perspective: 1200px;\n  }\n\n  /* Single dynamic array slot */\n  .slot {\n    width: 96px;\n    height: 120px;\n    border-radius: 1rem;\n    background:\n      linear-gradient(145deg,\n        #728dc9,\n        #5473c6);\n    box-shadow:\n      inset 2px 2px 8px #a6bdffcc,\n      inset -3px -3px 12px #325b9d,\n      0 10px 25px rgba(52, 101, 199, 0.35);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: #f0f4ff;\n    font-weight: 600;\n    font-size: 1.85rem;\n    letter-spacing: 0.21em;\n    text-shadow: 0 0 4px #4968bcbb;\n    transition:\n      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),\n      box-shadow 0.6s cubic-bezier(0.22, 1, 0.36, 1),\n      background-color 0.8s,\n      color 0.8s;\n    cursor: default;\n    user-select: none;\n    position: relative;\n  }\n  .slot::before {\n    content: attr(data-index);\n    position: absolute;\n    top: 10%;\n    right: 10%;\n    font-size: 0.8rem;\n    font-weight: 700;\n    color: #c3cdeacc;\n    text-shadow: 0 0 3px #28448a;\n    letter-spacing: 0.13em;\n  }\n  .slot[data-empty=\"true\"] {\n    filter: brightness(0.6);\n    color: #8ea8c9cc;\n    background:\n      linear-gradient(145deg,\n        #4a6ea4,\n        #365185);\n    box-shadow:\n      inset 2px 2px 5px #2a3e67cc,\n      inset -2px -2px 8px #3a5399,\n      0 12px 22px rgba(26, 37, 63, 0.15);\n  }\n\n  /* Glow highlight for active slot */\n  .slot.active {\n    animation: pulseGlow 2.8s ease-in-out infinite;\n    box-shadow:\n      0 0 12px #7ea9ffcc,\n      inset 1px 1px 8px #a5baffcc,\n      0 18px 45px #7ea9ff66;\n    color: #e9f0ff;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n        0 0 8px #7ea9ffbb,\n        inset 1px 1px 6px #a5baffbb,\n        0 16px 38px #7ea9ff44;\n    }\n    50% {\n      box-shadow:\n        0 0 20px #a6c2ffdd,\n        inset 3px 3px 12px #c3d0ffdd,\n        0 24px 58px #a6c2ff88;\n    }\n  }\n\n  /* Controls panel */\n  .controls {\n    margin-top: 4rem;\n    display: flex;\n    gap: 2.8rem;\n  }\n  button {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1rem;\n    background: linear-gradient(145deg, #3461a7, #2d599d);\n    color: #e1eafc;\n    border: none;\n    border-radius: 1rem;\n    padding: 0.75rem 2.4rem;\n    box-shadow:\n      0 3px 15px rgba(21, 58, 106, 0.6);\n    cursor: pointer;\n    transition:\n      background-color 0.25s ease,\n      box-shadow 0.3s ease,\n      filter 0.3s ease;\n    user-select: none;\n  }\n  button:hover, button:focus {\n    background: linear-gradient(145deg, #4174d0, #3b6fc8);\n    box-shadow:\n      0 6px 30px rgba(65, 116, 208, 0.9);\n    filter: brightness(1.05);\n    outline: none;\n  }\n  button:active {\n    background: linear-gradient(145deg, #2d599d, #265189);\n    box-shadow: none;\n    filter: brightness(0.9);\n  }\n\n  /* Footer note */\n  footer {\n    margin-top: 6rem;\n    font-size: 0.75rem;\n    font-style: italic;\n    color: #8ea8df88;\n    letter-spacing: 0.07em;\n    user-select: none;\n  }\n\n  /* Responsive scaling */\n  @media (max-width: 480px) {\n    .array-container {\n      gap: 1.1rem;\n    }\n    .slot {\n      width: 64px;\n      height: 80px;\n      font-size: 1.25rem;\n    }\n    button {\n      padding: 0.55rem 1.6rem;\n      font-size: 0.85rem;\n    }\n  }\n\n</style>\n</head>\n<body>\n  <h1>Dynamic Array</h1>\n  <h2>Visualizing Capacity & Growth</h2>\n\n  <main aria-label=\"Dynamic array visualization\" role=\"main\">\n    <div class=\"array-container\" aria-live=\"polite\" aria-atomic=\"true\">\n      <!-- Slots will be dynamically inserted here -->\n    </div>\n    <div class=\"controls\" role=\"group\" aria-label=\"Array controls\">\n      <button id=\"btn-add\" type=\"button\" aria-describedby=\"descAdd\">Add Element</button>\n      <button id=\"btn-reset\" type=\"button\" aria-describedby=\"descReset\">Reset Array</button>\n    </div>\n  </main>\n\n  <footer>\n    &copy; 2024 | Crafted as an elegant concept demonstration\n  </footer>\n\n<script>\n  // Dynamic Array conceptual demo:\n  // Starts empty with capacity 4.\n  // On each addition: inserts an element. If full, doubles capacity.\n  // Visual: filled slots show values, empty slots dimmed.\n  // Highlight the last inserted element briefly.\n\n  const container = document.querySelector('.array-container');\n  const btnAdd = document.getElementById('btn-add');\n  const btnReset = document.getElementById('btn-reset');\n\n  // Initial state\n  let capacity = 4;\n  let length = 0;\n  let arrayValues = []; // store numeric values\n\n  // Timing constants for animations\n  const highlightDuration = 1200;\n\n  // Initialize the array UI\n  function renderArray() {\n    container.innerHTML = '';\n    for (let i = 0; i < capacity; i++) {\n      const slot = document.createElement('div');\n      slot.classList.add('slot');\n      slot.setAttribute('data-index', i);\n      if (i < length) {\n        slot.textContent = arrayValues[i];\n        slot.setAttribute('data-empty', 'false');\n      } else {\n        slot.textContent = '';\n        slot.setAttribute('data-empty', 'true');\n      }\n      container.appendChild(slot);\n    }\n  }\n\n  // Animate new insertion highlight\n  function highlightSlot(index) {\n    if (index < 0 || index >= capacity) return;\n    const slots = container.querySelectorAll('.slot');\n    const slot = slots[index];\n    if (!slot) return;\n    slot.classList.add('active');\n    setTimeout(() => {\n      slot.classList.remove('active');\n    }, highlightDuration);\n  }\n\n  // Add element handler\n  btnAdd.addEventListener('click', () => {\n    if (length < capacity) {\n      // Insert new value\n      arrayValues.push(length * 10 + 7);\n      length++;\n      renderArray();\n      highlightSlot(length - 1);\n    } else {\n      // Double capacity\n      capacity *= 2;\n\n      // Flash doubling effect on container\n      container.style.transition = 'transform 0.6s ease';\n      container.style.transformOrigin = 'center center';\n      container.style.transform = 'scale(1.1)';\n      \n      setTimeout(() => {\n        // New capacity: fill additional empty slots with empty\n        renderArray();\n        container.style.transform = 'scale(1)';\n        \n        // Animate highlight on last inserted (previous one)\n        highlightSlot(length - 1);\n      }, 600);\n    }\n  });\n\n  // Reset array to initial state\n  btnReset.addEventListener('click', () => {\n    capacity = 4;\n    length = 0;\n    arrayValues = [];\n    renderArray();\n  });\n\n  // Initial render\n  renderArray();\n</script>\n</body>\n</html>"
