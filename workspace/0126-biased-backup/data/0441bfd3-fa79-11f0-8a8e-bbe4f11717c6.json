ick\", function() {\n            bt.generate();\n        });\n\n        function generate() {\n            bt.generateTree(0, 0, 0, 10);\n        }\n\n        function BTree(n) {\n            this.root = new Node(0, 0, n);\n        }\n\n        BTree.prototype.generateTree = function(start, end, left, right) {\n            if (start > end) {\n                return;\n            }\n\n            let mid = Math.floor((start + end) / 2);\n\n            let node = new Node(start, mid, right);\n            node.left = new Node(start, mid, left);\n            node.right = new Node(mid + 1, end, right);\n\n            bt.root = node;\n        }\n\n        class Node {\n            constructor(key, value, left, right) {\n                this.key = key;\n                this.value = value;\n                this.left = left;\n                this.right = right;\n            }\n        }\n    </script>\n</body>\n</html>"
