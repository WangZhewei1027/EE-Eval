    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Big-Theta Notation Interactive Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .control {\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Big-Theta Notation Explorer</h1>\n    <div class=\"control\">\n        <label for=\"inputFunction\">Input Function (n):</label>\n        <input type=\"number\" id=\"inputFunction\" value=\"1\" min=\"1\" onchange=\"updateGraph()\">\n    </div>\n    <div class=\"control\">\n        <label for=\"thetaFunction\">Theta Function:</label>\n        <select id=\"thetaFunction\" onchange=\"updateGraph()\">\n            <option value=\"n\">Θ(n)</option>\n            <option value=\"nLogN\">Θ(n log n)</option>\n            <option value=\"nSquared\">Θ(n²)</option>\n            <option value=\"logN\">Θ(log n)</option>\n            <option value=\"constant\">Θ(1)</option>\n        </select>\n    </div>\n    <div class=\"control\">\n        <label for=\"nValue\">Value of n:</label>\n        <input type=\"range\" id=\"nValue\" min=\"1\" max=\"100\" value=\"10\" onchange=\"updateGraph()\">\n        <span id=\"rangeValue\">10</span>\n    </div>\n    <button onclick=\"calculate()\">Calculate Big-Theta</button>\n    <div id=\"output\"></div>\n\n    <script>\n        function updateGraph() {\n            const nInput = document.getElementById('inputFunction').value;\n            const thetaFunc = document.getElementById('thetaFunction').value;\n            const nValue = document.getElementById('nValue').value;\n            document.getElementById('rangeValue').textContent = nValue;\n\n            document.getElementById('output').innerHTML = `\n                Current Input (n): ${nInput} <br>\n                Selected Theta Function: ${thetaFunc} <br>\n                Evaluated at n = ${nValue}: ${calculateTheta(thetaFunc, nValue)} <br>\n            `;\n        }\n\n        function calculateTheta(func, n) {\n            n = parseInt(n);\n            switch (func) {\n                case \"n\":\n                    return `${n}`;\n                case \"nLogN\":\n                    return `${n * Math.log(n).toFixed(2)}`;\n                case \"nSquared\":\n                    return `${n * n}`;\n                case \"logN\":\n                    return `${Math.log(n).toFixed(2)}`;\n                case \"constant\":\n                    return `1`;\n                default:\n                    return `Undefined`;\n            }\n        }\n\n        function calculate() {\n            updateGraph();\n        }\n    </script>\n</body>\n</html>"
