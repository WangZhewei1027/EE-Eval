    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Doubly Linked List</title>\n    <style>\n        body {\n            font-family: monospace;\n            font-size: 12px;\n            margin: 0;\n            padding: 0;\n            background-color: #f0f0f0;\n        }\n        #list {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n        #list li {\n            padding: 5px;\n            border-bottom: 1px solid #ccc;\n        }\n        #list li:last-child {\n            border-bottom: none;\n        }\n        #add {\n            width: 100%;\n            padding: 10px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        #remove {\n            width: 100%;\n            padding: 10px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        #prev, #next {\n            width: 100%;\n            padding: 10px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        #prev:hover, #next:hover {\n            background-color: #ccc;\n        }\n        #prev, #next, #add, #remove {\n            margin-bottom: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Doubly Linked List</h1>\n    <ul id=\"list\"></ul>\n    <div>\n        <input id=\"add\" type=\"text\" placeholder=\"Add node\">\n        <button id=\"add-btn\">Add</button>\n        <button id=\"remove-btn\">Remove</button>\n        <button id=\"prev-btn\">Previous</button>\n        <button id=\"next-btn\">Next</button>\n    </div>\n\n    <script>\n        let head = document.createElement('head');\n        document.body.appendChild(head);\n\n        let list = document.getElementById('list');\n        let add = document.getElementById('add');\n        let remove = document.getElementById('remove');\n        let prev = document.getElementById('prev');\n        let next = document.getElementById('next');\n        let addBtn = document.getElementById('add-btn');\n        let removeBtn = document.getElementById('remove-btn');\n\n        addBtn.addEventListener('click', addNode);\n        removeBtn.addEventListener('click', removeNode);\n        prev.addEventListener('click', movePrev);\n        next.addEventListener('click', moveNext);\n\n        let headNode = {\n            value: '',\n            prev: null,\n            next: null\n        };\n\n        let tailNode = {\n            value: '',\n            prev: null,\n            next: null\n        };\n\n        function addNode() {\n            let value = add.value.trim();\n            if (value !== '') {\n                let newNode = {\n                    value,\n                    prev: headNode,\n                    next: headNode.next\n                };\n                if (headNode === null) {\n                    headNode = newNode;\n                } else {\n                    tailNode.next = newNode;\n                    newNode.next.prev = tailNode;\n                }\n                list.innerHTML += `<li>${newNode.value}</li>`;\n                add.value = '';\n            }\n        }\n\n        function removeNode() {\n            list.innerHTML = '';\n            let value = remove.value.trim();\n            if (value !== '') {\n                let node = list.querySelector(`li[value=\"${value}\"]`);\n                if (node !== null) {\n                    if (node === headNode) {\n                        headNode = headNode.next;\n                    } else {\n                        node.next.prev = node.prev;\n                    }\n                    if (node.prev === null) {\n                        tailNode = node;\n                    } else {\n                        node.prev.next = node.next;\n                    }\n                    list.innerHTML = '';\n                    node.value = '';\n                }\n            }\n        }\n\n        function movePrev() {\n            let current = list.querySelector('li[value=\"'];\n            if (current !== null) {\n                let prevNode = current.prev;\n                if (prevNode !== null) {\n                    list.innerHTML = '';\n                    let value = prevNode.value;\n                    let newNode = {\n                        value,\n                        prev: headNode,\n                        next: headNode.next\n                    };\n                    if (headNode === null) {\n                        headNode = newNode;\n                    } else {\n                        tailNode.next = newNode;\n                        newNode.next.prev = tailNode;\n                    }\n                    list.innerHTML += `<li>${newNode.value}</li>`;\n                    prevNode.value = '';\n                    current.value = value;\n                    current.prev.value = '';\n                }\n            }\n        }\n\n        function moveNext() {\n            let current = list.querySelector('li[value=\"'];\n            if (current !== null) {\n                let nextNode = current.next;\n                if (nextNode !== null) {\n                    list.innerHTML = '';\n                    let value = nextNode.value;\n                    let newNode = {\n                        value,\n                        prev: headNode,\n                        next: headNode.next\n                    };\n                    if (headNode === null) {\n                        headNode = newNode;\n                    } else {\n                        tailNode.next = newNode;\n                        newNode.next.prev = tailNode;\n                    }\n                    list.innerHTML += `<li>${newNode.value}</li>`;\n                    nextNode.value = '';\n                    current.value = value;\n                    current.next.value = '';\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
