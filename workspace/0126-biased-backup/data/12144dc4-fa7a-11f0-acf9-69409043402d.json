    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Floyd-Warshall Algorithm Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    white-space: pre;\n  }\n  textarea, input, button, select {\n    font-family: monospace, monospace;\n    margin: 3px 0;\n  }\n  table {\n    border-collapse: collapse;\n  }\n  td, th {\n    border: 1px solid black;\n    text-align: center;\n    padding: 2px 5px;\n    min-width: 30px;\n  }\n  input[type=number] {\n    width: 40px;\n  }\n</style>\n</head>\n<body>\n\n<h2>Floyd-Warshall Algorithm Interactive Demo</h2>\n\n<div>\n  <label for=\"vertexCountInput\">Number of vertices (1 to 10): </label>\n  <input type=\"number\" id=\"vertexCountInput\" min=\"1\" max=\"10\" value=\"4\" />\n  <button id=\"createGraphBtn\">Create Graph Matrix</button>\n</div>\n\n<div id=\"graphInputSection\" style=\"margin-top:10px;\"></div>\n\n<div id=\"controls\" style=\"margin-top:10px; display:none;\">\n  <button id=\"stepForwardBtn\">Step Forward</button>\n  <button id=\"stepBackwardBtn\">Step Backward</button>\n  <button id=\"runToEndBtn\">Run to End</button>\n  <button id=\"resetBtn\">Reset</button>\n</div>\n\n<div id=\"statusSection\" style=\"margin-top:10px;\">\n  <div><b>Current Step:</b> <span id=\"currentStep\">-</span></div>\n  <div><b>Iteration Indices (k, i, j):</b> (<span id=\"indexK\">-</span>, <span id=\"indexI\">-</span>, <span id=\"indexJ\">-</span>)</div>\n  <div><b>Explanation:</b> <span id=\"explanation\">-</span></div>\n</div>\n\n<div id=\"matrixSection\" style=\"margin-top:10px;\"></div>\n\n<div style=\"margin-top:15px;\">\n  <h3>Additional Controls</h3>\n  <label for=\"edgeAddFrom\">Add/Modify Edge: from </label>\n  <input type=\"number\" id=\"edgeAddFrom\" min=\"0\" max=\"9\" value=\"0\" style=\"width:40px\"/>\n  <label for=\"edgeAddTo\">to </label>\n  <input type=\"number\" id=\"edgeAddTo\" min=\"0\" max=\"9\" value=\"1\" style=\"width:40px\"/>\n  <label for=\"edgeAddWeight\">weight </label>\n  <input type=\"number\" id=\"edgeAddWeight\" style=\"width:60px\" />\n  <button id=\"addEdgeButton\">Add / Update Edge</button>\n  <button id=\"removeEdgeButton\">Remove Edge</button>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <button id=\"exportGraph\">Export Graph (JSON)</button>\n  <button id=\"importGraph\">Import Graph (from JSON)</button>\n  <br/>\n  <textarea id=\"graphJSONInput\" rows=\"6\" cols=\"40\" placeholder='Paste JSON here for import'></textarea>\n</div>\n\n<div style=\"margin-top:10px;\">\n  <button id=\"showPathsBtn\">Show Shortest Paths Reconstruction</button>\n</div>\n\n<div id=\"pathsSection\" style=\"margin-top:10px; white-space: pre-wrap;\"></div>\n\n<script>\n(function() {\n  // Constants\n  const INF = Number.POSITIVE_INFINITY;\n  const MAX_VERTICES = 10;\n\n  // State\n  let vertexCount = 0;\n  let graphMatrix = []; // adjacency matrix: graphMatrix[i][j] = weight or INF if no edge\n  let distMatrix = []; // current dist matrix during FW\n  let nextMatrix = []; // matrix for path reconstruction\n  let steps = []; // each step: {k,i,j,updated:boolean, oldDist:number, oldNext:number|null}\n  let currentStepIndex = -1;\n\n  // Elements\n  const vertexCountInput = document.getElementById('vertexCountInput');\n  const createGraphBtn = document.getElementById('createGraphBtn');\n  const graphInputSection = document.getElementById('graphInputSection');\n  const controls = document.getElementById('controls');\n  const stepForwardBtn = document.getElementById('stepForwardBtn');\n  const stepBackwardBtn = document.getElementById('stepBackwardBtn');\n  const runToEndBtn = document.getElementById('runToEndBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const currentStepSpan = document.getElementById('currentStep');\n  const indexKSpan = document.getElementById('indexK');\n  const indexISpan = document.getElementById('indexI');\n  const indexJSpan = document.getElementById('indexJ');\n  const explanationSpan = document.getElementById('explanation');\n  const matrixSection = document.getElementById('matrixSection');\n  const edgeAddFrom = document.getElementById('edgeAddFrom');\n  const edgeAddTo = document.getElementById('edgeAddTo');\n  const edgeAddWeight = document.getElementById('edgeAddWeight');\n  const addEdgeButton = document.getElementById('addEdgeButton');\n  const removeEdgeButton = document.getElementById('removeEdgeButton');\n  const exportGraphBtn = document.getElementById('exportGraph');\n  const importGraphBtn = document.getElementById('importGraph');\n  const graphJSONInput = document.getElementById('graphJSONInput');\n  const showPathsBtn = document.getElementById('showPathsBtn');\n  const pathsSection = document.getElementById('pathsSection');\n\n  // Utility\n\n  function isValidVertex(v) {\n    return Number.isInteger(v) && v >= 0 && v < vertexCount;\n  }\n\n  function createEmptyMatrix(size, fillValue) {\n    const m = new Array(size);\n    for (let i = 0; i < size; i++) {\n      m[i] = new Array(size).fill(fillValue);\n    }\n    return m;\n  }\n\n  function deepCopyMatrix(m) {\n    return m.map(row => row.slice());\n  }\n\n  function weightToString(w) {\n    if (w === INF) return \"∞\";\n    return String(w);\n  }\n\n  // Build UI for graph input matrix (editable inputs)\n  function buildGraphInputMatrix() {\n    graphInputSection.innerHTML = '';\n    const table = document.createElement('table');\n    const headerRow = document.createElement('tr');\n    const emptyTH = document.createElement('th');\n    headerRow.appendChild(emptyTH);\n    for(let j = 0; j < vertexCount; j++) {\n      const th = document.createElement('th');\n      th.textContent = j;\n      headerRow.appendChild(th);\n    }\n    table.appendChild(headerRow);\n    for(let i = 0; i < vertexCount; i++) {\n      const tr = document.createElement('tr');\n      const th = document.createElement('th');\n      th.textContent = i;\n      tr.appendChild(th);\n      for(let j = 0; j < vertexCount; j++) {\n        const td = document.createElement('td');\n        const input = document.createElement('input');\n        input.type = 'text';\n        input.size = 5;\n        input.dataset.i = i;\n        input.dataset.j = j;\n        if(i === j) {\n          input.value = \"0\";\n          input.readOnly = true;\n          input.style.backgroundColor = \"#eee\";\n        } else if(graphMatrix[i][j] === INF) {\n          input.value = \"\";\n          input.placeholder = \"∞\";\n        } else {\n          input.value = String(graphMatrix[i][j]);\n        }\n        td.appendChild(input);\n        tr.appendChild(td);\n      }\n      table.appendChild(tr);\n    }\n    graphInputSection.appendChild(table);\n    // Add validation: only numbers or empty for infinity allowed\n  }\n\n  // Read graph matrix from inputs\n  function readGraphMatrixFromInputs() {\n    const inputs = graphInputSection.querySelectorAll('input[type=text]');\n    let newMatrix = createEmptyMatrix(vertexCount, INF);\n    for(let input of inputs) {\n      const i = parseInt(input.dataset.i);\n      const j = parseInt(input.dataset.j);\n      if(i === j) {\n        newMatrix[i][j] = 0;\n        continue;\n      }\n      let val = input.value.trim();\n      if(val === \"\" || val.toLowerCase() === \"inf\" || val === \"∞\" ) {\n        newMatrix[i][j] = INF;\n      } else {\n        let parsed = Number(val);\n        if(isNaN(parsed)) {\n          alert(`Invalid input at edge (${i} -> ${j}): \"${val}\". Please input a number or leave empty for no edge.`);\n          return null;\n        } else {\n          newMatrix[i][j] = parsed;\n        }\n      }\n    }\n    return newMatrix;\n  }\n\n  // Display current distMatrix as table with path highlight\n  function buildMatrixDisplay() {\n    matrixSection.innerHTML = '';\n    if(vertexCount === 0) return;\n    const table = document.createElement('table');\n    const headerRow = document.createElement('tr');\n    headerRow.appendChild(document.createElement('th')); // empty corner\n    for(let j = 0; j < vertexCount; j++) {\n      const th = document.createElement('th');\n      th.textContent = j;\n      headerRow.appendChild(th);\n    }\n    table.appendChild(headerRow);\n\n    for(let i=0; i<vertexCount; i++) {\n      const tr = document.createElement('tr');\n      const th = document.createElement('th');\n      th.textContent = i;\n      tr.appendChild(th);\n      for(let j=0; j<vertexCount; j++) {\n        const td = document.createElement('td');\n        let val = distMatrix[i][j];\n        if(val === INF) td.textContent = \"∞\";\n        else td.textContent = val;\n        // Highlight if this cell updated in current step\n        if(currentStepIndex >= 0) {\n          let step = steps[currentStepIndex];\n          if(step.updated && step.i === i && step.j === j) {\n            td.style.border = \"2px solid\";\n          }\n        }\n        tr.appendChild(td);\n      }\n      table.appendChild(tr);\n    }\n    matrixSection.appendChild(table);\n  }\n\n  // Build next matrix display - will be used for path reconstructions, optional\n  // -- omitted here, we show path reconstruction text separately\n\n  // Run Floyd-Warshall building steps\n  function buildSteps() {\n    steps = [];\n    distMatrix = createEmptyMatrix(vertexCount, INF);\n    nextMatrix = createEmptyMatrix(vertexCount, null);\n\n    // init dist and next matrix from graphMatrix\n    for(let i = 0; i<vertexCount; i++) {\n      for(let j = 0; j<vertexCount; j++) {\n        distMatrix[i][j] = graphMatrix[i][j];\n        if(graphMatrix[i][j] !== INF && i !== j) {\n          nextMatrix[i][j] = j;\n        }\n      }\n      distMatrix[i][i] = 0;\n      nextMatrix[i][i] = i;\n    }\n\n    // Copy matrices to restore each step or step update track\n    for(let k=0; k<vertexCount; k++) {\n      for(let i=0; i<vertexCount; i++) {\n        for(let j=0; j<vertexCount; j++) {\n          let updated = false;\n          let oldDist = distMatrix[i][j];\n          let oldNext = nextMatrix[i][j];\n          if(distMatrix[i][k] === INF || distMatrix[k][j] === INF) {\n            // no path through k\n            steps.push({k,i,j,updated:false,oldDist,oldNext});\n            continue;\n          }\n          if(distMatrix[i][k] + distMatrix[k][j] < distMatrix[i][j]) {\n            distMatrix[i][j] = distMatrix[i][k] + distMatrix[k][j];\n            nextMatrix[i][j] = nextMatrix[i][k];\n            updated = true;\n          }\n          steps.push({k,i,j,updated,oldDist,oldNext});\n        }\n      }\n    }\n  }\n\n  // Reset to initial state before steps\n  function resetStateBeforeSteps() {\n    distMatrix = createEmptyMatrix(vertexCount, INF);\n    for(let i = 0; i < vertexCount; i++) {\n      for(let j = 0; j < vertexCount; j++) {\n        distMatrix[i][j] = graphMatrix[i][j];\n      }\n    }\n  }\n\n  // Apply step N of FW\n  function applyStep(n) {\n    resetStateBeforeSteps();\n    // Reset next matrix\n    nextMatrix = createEmptyMatrix(vertexCount, null);\n    for(let i = 0; i < vertexCount; i++) {\n      for(let j = 0; j < vertexCount; j++) {\n        if(graphMatrix[i][j] !== INF && i !== j) {\n          nextMatrix[i][j] = j;\n        }\n        if(i === j) nextMatrix[i][j] = i;\n      }\n    }\n    for(let idx=0; idx <= n; idx++) {\n      const step = steps[idx];\n      const {k,i,j,updated} = step;\n      if(updated) {\n        distMatrix[i][j] = distMatrix[i][k] + distMatrix[k][j];\n        nextMatrix[i][j] = nextMatrix[i][k];\n      }\n    }\n  }\n\n  // Show current step info and matrix\n  function updateDisplay() {\n    if(currentStepIndex < 0) {\n      currentStepSpan.textContent = \"Before start\";\n      indexKSpan.textContent = \"-\";\n      indexISpan.textContent = \"-\";\n      indexJSpan.textContent = \"-\";\n      explanationSpan.textContent = \"Click 'Step Forward' or 'Run to End' to start the algorithm.\";\n      resetBtn.disabled = true;\n      stepBackwardBtn.disabled = true;\n      stepForwardBtn.disabled = false;\n      runToEndBtn.disabled = false;\n      buildMatrixDisplay();\n      return;\n    }\n    const step = steps[currentStepIndex];\n    currentStepSpan.textContent = currentStepIndex+1 + \" / \" + steps.length;\n    indexKSpan.textContent = step.k;\n    indexISpan.textContent = step.i;\n    indexJSpan.textContent = step.j;\n\n    if(step.updated) {\n      explanationSpan.textContent = `dist[${step.i}][${step.j}] updated. \\\nNew distance = dist[${step.i}][${step.k}] + dist[${step.k}][${step.j}] = ` +\n        `${distMatrix[step.i][step.j]}. Next vertex on path set to ${nextMatrix[step.i][step.j]}.`;\n    } else {\n      explanationSpan.textContent = `No update: dist[${step.i}][${step.j}] <= \\\ndist[${step.i}][${step.k}] + dist[${step.k}][${step.j}]`;\n    }\n\n    resetBtn.disabled = false;\n    stepBackwardBtn.disabled = currentStepIndex <= 0;\n    stepForwardBtn.disabled = currentStepIndex >= steps.length - 1;\n    runToEndBtn.disabled = currentStepIndex >= steps.length - 1;\n\n    buildMatrixDisplay();\n    pathsSection.textContent = \"\";\n  }\n\n  // Event handlers\n  createGraphBtn.addEventListener('click', () => {\n    let val = Number(vertexCountInput.value);\n    if(!Number.isInteger(val) || val < 1 || val > MAX_VERTICES) {\n      alert(`Number of vertices must be an integer between 1 and ${MAX_VERTICES}`);\n      return;\n    }\n    vertexCount = val;\n    // Initialize graphMatrix with INF except diagonal 0\n    graphMatrix = createEmptyMatrix(vertexCount, INF);\n    for(let i=0; i<vertexCount; i++) {\n      graphMatrix[i][i] = 0;\n    }\n    buildGraphInputMatrix();\n    controls.style.display = \"none\";\n    matrixSection.innerHTML = \"\";\n    currentStepSpan.textContent = \"-\";\n    indexKSpan.textContent = \"-\";\n    indexISpan.textContent = \"-\";\n    indexJSpan.textContent = \"-\";\n    explanationSpan.textContent = \"-\";\n    steps = [];\n    currentStepIndex = -1;\n    pathsSection.textContent = \"\";\n  });\n\n  // After the user edits the matrix and wants to start algorithm\n  function tryStartAlgorithm() {\n    let newGraph = readGraphMatrixFromInputs();\n    if(newGraph === null) {\n      return;\n    }\n    graphMatrix = newGraph;\n    buildSteps();\n    currentStepIndex = -1;\n    controls.style.display = \"inline-block\";\n    applyStep(currentStepIndex);\n    updateDisplay();\n  }\n\n  // Adding/Updating an edge via controls\n  function addOrUpdateEdge() {\n    let from = Number(edgeAddFrom.value);\n    let to = Number(edgeAddTo.value);\n    let weight = edgeAddWeight.value.trim();\n    if(!isValidVertex(from) || !isValidVertex(to)) {\n      alert(\"Vertex indices must be between 0 and \"+(vertexCount-1));\n      return;\n    }\n    if(from === to) {\n      alert(\"No self-loops allowed to edit manually (distance 0 fixed).\");\n      return;\n    }\n    if(weight === \"\" || weight.toLowerCase() === \"inf\" || weight === \"∞\") {\n      alert(\"Weight invalid for add/update. Use Remove Edge to clear edge.\");\n      return;\n    }\n    let w = Number(weight);\n    if(isNaN(w)) {\n      alert(\"Weight must be a valid number.\");\n      return;\n    }\n    graphMatrix[from][to] = w;\n    buildGraphInputMatrix();\n    tryStartAlgorithm();\n  }\n\n  function removeEdge() {\n    let from = Number(edgeAddFrom.value);\n    let to = Number(edgeAddTo.value);\n    if(!isValidVertex(from) || !isValidVertex(to)) {\n      alert(\"Vertex indices must be between 0 and \"+(vertexCount-1));\n      return;\n    }\n    if(from === to) {\n      alert(\"No self-loops allowed.\");\n      return;\n    }\n    graphMatrix[from][to] = INF;\n    buildGraphInputMatrix();\n    tryStartAlgorithm();\n  }\n\n  stepForwardBtn.addEventListener('click', () => {\n    if(steps.length === 0) return;\n    if(currentStepIndex < steps.length - 1) {\n      currentStepIndex++;\n      applyStep(currentStepIndex);\n      updateDisplay();\n    }\n  });\n  stepBackwardBtn.addEventListener('click', () => {\n    if(steps.length === 0) return;\n    if(currentStepIndex > -1) {\n      currentStepIndex--;\n      if(currentStepIndex === -1) {\n        resetStateBeforeSteps();\n        nextMatrix = createEmptyMatrix(vertexCount,null);\n        for(let i=0;i<vertexCount;i++){\n          for(let j=0;j<vertexCount;j++){\n            if(graphMatrix[i][j] !== INF && i !== j) nextMatrix[i][j] = j;\n            if(i===j) nextMatrix[i][j] = i;\n          }\n        }\n      } else {\n        applyStep(currentStepIndex);\n      }\n      updateDisplay();\n    }\n  });\n  runToEndBtn.addEventListener('click', () => {\n    if(steps.length === 0) return;\n    currentStepIndex = steps.length - 1;\n    applyStep(currentStepIndex);\n    updateDisplay();\n  });\n  resetBtn.addEventListener('click', () => {\n    currentStepIndex = -1;\n    resetStateBeforeSteps();\n    nextMatrix = createEmptyMatrix(vertexCount,null);\n    for(let i=0;i<vertexCount;i++){\n      for(let j=0;j<vertexCount;j++){\n        if(graphMatrix[i][j] !== INF && i !== j) nextMatrix[i][j] = j;\n        if(i===j) nextMatrix[i][j] = i;\n      }\n    }\n    updateDisplay();\n  });\n\n  addEdgeButton.addEventListener('click', addOrUpdateEdge);\n  removeEdgeButton.addEventListener('click', removeEdge);\n\n  exportGraphBtn.addEventListener('click', () => {\n    if(vertexCount === 0) {\n      alert(\"No graph to export.\");\n      return;\n    }\n    const exportData = {\n      vertexCount,\n      graphMatrix\n    };\n    const jsonStr = JSON.stringify(exportData, null, 2);\n    graphJSONInput.value = jsonStr;\n    alert(\"Graph exported to text area below. You can copy it.\");\n  });\n\n  importGraphBtn.addEventListener('click', () => {\n    let text = graphJSONInput.value.trim();\n    if(!text) {\n      alert(\"Please paste JSON graph data into the text area.\");\n      return;\n    }\n    try {\n      const obj = JSON.parse(text);\n      if(!obj.vertexCount || !obj.graphMatrix) {\n        alert(\"JSON malformed or missing required fields.\");\n        return;\n      }\n      if(!(Number.isInteger(obj.vertexCount) && obj.vertexCount >= 1 && obj.vertexCount<=MAX_VERTICES)) {\n        alert(`vertexCount must be integer between 1 and ${MAX_VERTICES}`);\n        return;\n      }\n      if(!Array.isArray(obj.graphMatrix) || obj.graphMatrix.length !== obj.vertexCount) {\n        alert(\"graphMatrix dimension mismatch.\");\n        return;\n      }\n      for(let i=0; i<obj.vertexCount; i++) {\n        if(!Array.isArray(obj.graphMatrix[i]) || obj.graphMatrix[i].length !== obj.vertexCount) {\n          alert(\"graphMatrix is not a square matrix.\");\n          return;\n        }\n        for(let j=0; j<obj.vertexCount; j++) {\n          let val = obj.graphMatrix[i][j];\n          if(val !== null && val !== undefined && val !== INF) {\n            if(typeof val !== \"number\") {\n              alert(\"graphMatrix entries must be numbers or null/INF.\");\n              return;\n            }\n          }\n        }\n      }\n      // OK\n      vertexCount = obj.vertexCount;\n      graphMatrix = obj.graphMatrix.map(row => row.map(v => (v===null ? INF : v)));\n      vertexCountInput.value = vertexCount;\n      buildGraphInputMatrix();\n      controls.style.display = \"inline-block\";\n      buildSteps();\n      currentStepIndex = -1;\n      resetStateBeforeSteps();\n      updateDisplay();\n      alert(\"Graph imported successfully.\");\n    } catch(e) {\n      alert(\"Invalid JSON format or parse error.\");\n    }\n  });\n\n  showPathsBtn.addEventListener('click', () => {\n    if(currentStepIndex < steps.length - 1) {\n      alert(\"Please run the algorithm to the end to reconstruct paths.\");\n      return;\n    }\n    // Build full nextMatrix state at end\n    let finalNext = createEmptyMatrix(vertexCount, null);\n    for(let i=0; i < vertexCount; i++) {\n      for(let j=0; j < vertexCount; j++) {\n        if(graphMatrix[i][j] !== INF && i !== j) finalNext[i][j] = j;\n        if(i === j) finalNext[i][j] = i;\n      }\n    }\n    for(let s = 0; s < steps.length; s++) {\n      let st = steps[s];\n      if(st.updated) {\n        finalNext[st.i][st.j] = finalNext[st.i][st.k];\n      }\n    }\n\n    // Build shortest path from i to j using finalNext\n    function reconstructPath(i, j) {\n      if(distMatrix[i][j] === INF) return null;\n      const path = [i];\n      while(i !== j) {\n        i = finalNext[i][j];\n        if(i === null) return null; // no path\n        path.push(i);\n      }\n      return path;\n    }\n\n    let result = \"\";\n    for(let start=0; start < vertexCount; start++) {\n      for(let end=0; end < vertexCount; end++) {\n        if(start === end) continue;\n        let p = reconstructPath(start, end);\n        if(p === null) {\n          result += `No path from ${start} to ${end}\\n`;\n        } else {\n          result += `Path from ${start} to ${end} (dist=${distMatrix[start][end]}): ${p.join(\" -> \")}\\n`;\n        }\n      }\n    }\n    pathsSection.textContent = result;\n  });\n\n  // On initial load, disable controls\n  controls.style.display = \"none\";\n  matrixSection.innerHTML = \"\";\n  graphInputSection.innerHTML = \"\";\n  currentStepSpan.textContent = \"-\";\n  indexKSpan.textContent = \"-\";\n  indexISpan.textContent = \"-\";\n  indexJSpan.textContent = \"-\";\n  explanationSpan.textContent = \"-\";\n\n  // Add instructions below the title for basic usage\n  const instructions = document.createElement('pre');\n  instructions.textContent = String.raw`\nInstructions:\n\n1) Enter the number of vertices (max 10) and press \"Create Graph Matrix\".\n2) Edit the matrix inputs to set edge weights. Leave empty for no edge (∞). Diagonals fixed at 0.\n3) After editing, click 'Step Forward' or 'Run to End' to start Floyd-Warshall algorithm.\n4) Use \"Step Forward\", \"Step Backward\", \"Run to End\" buttons to navigate through each update step.\n5) You can reset to initial state with \"Reset\" button.\n6) Add or remove edges using the fields below the controls and graph matrix will update automatically.\n7) Export current graph as JSON, or import from JSON pasted in the text box for complex graphs.\n8) After algorithm has run to completion, click \"Show Shortest Paths Reconstruction\" to show all shortest paths.\n9) All vertex indexes are zero-based.\n\nYou can explore how Floyd-Warshall updates shortest paths step-by-step with realtime data.\n\n`;\n  document.body.insertBefore(instructions, graphInputSection);\n\n})();\n</script>\n\n</body>\n</html>"
  },
