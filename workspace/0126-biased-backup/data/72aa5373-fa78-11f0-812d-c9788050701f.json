3rem auto;\n            perspective: 1000px;\n        }\n\n        .graph {\n            width: 100%;\n            height: 100%;\n            border-radius: 16px;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            -webkit-backdrop-filter: blur(10px);\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            padding: 20px;\n            transition: var(--transition);\n            transform-style: preserve-3d;\n        }\n\n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            background: linear-gradient(135deg, var(--primary), var(--accent));\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 1.2rem;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n            transform: translateZ(20px);\n            transition: var(--transition);\n            z-index: 2;\n        }\n\n        .edge {\n            position: absolute;\n            height: 3px;\n            background: rgba(255, 255, 255, 0.4);\n            transform-origin: 0 0;\n            z-index: 1;\n            transition: var(--transition);\n        }\n\n        .edge::after {\n            content: '';\n            position: absolute;\n            right: 0;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 12px;\n            height: 12px;\n            border-radius: 2px;\n            background: var(--secondary);\n            clip-path: polygon(100% 50%, 0 0, 0 100%);\n        }\n\n        .edge-weight {\n            position: absolute;\n            font-size: 0.9rem;\n            padding: 2px 8px;\n            border-radius: 20px;\n            background: rgba(0, 0, 0, 0.7);\n            color: white;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n            z-index: 10;\n        }\n\n        button {\n            padding: 0.8rem 1.8rem;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: var(--transition);\n            background: linear-gradient(45deg, var(--primary), #7a5af5);\n            color: white;\n            box-shadow: 0 4px 15px rgba(93, 55, 224, 0.4);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(93, 55, 224, 0.6);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            opacity: 0;\n            transition: var(--transition);\n            z-index: -1;\n        }\n\n        button:hover::after {\n            opacity: 1;\n        }\n\n        .matrix-container {\n            width: 100%;\n            max-width: 600px;\n            margin: 2rem auto;\n            overflow: hidden;\n            border-radius: 12px;\n            background: rgba(255, 255, 255, 0.05);\n            backdrop-filter: blur(10px);\n            -webkit-backdrop-filter: blur(10px);\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: var(--transition);\n        }\n\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            font-family: 'Courier New', monospace;\n        }\n\n        th, td {\n            padding: 0.8rem;\n            text-align: center;\n            transition: var(--transition);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n\n        th {\n            background: rgba(0, 0, 0, 0.3);\n            font-weight: 600;\n            color: var(--accent);\n        }\n\n        td {\n            position: relative;\n        }\n\n        td.highlight {\n            animation: highlight 1.5s ease;\n            background: rgba(255, 107, 107, 0.2);\n        }\n\n        td.path {\n            background: rgba(78, 205, 196, 0.3);\n        }\n\n        td.infinity {\n            color: rgba(255, 255, 255, 0.4);\n        }\n\n        @keyframes highlight {\n            0%, 100% { background-color: transparent; }\n            50% { background-color: rgba(255, 107, 107, 0.4); }\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin: 1.5rem 0;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .highlight-legend {\n            background: rgba(255, 107, 107, 0.4);\n        }\n\n        .path-legend {\n            background: rgba(78, 205, 196, 0.4);\n        }\n\n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            opacity: 0.08;\n        }\n\n        .status {\n            margin-top: 1.5rem;\n            font-size: 1.1rem;\n            font-weight: 500;\n            min-height: 24px;\n            color: var(--accent);\n            text-align: center;\n        }\n\n        footer {\n            text-align: center;\n            padding: 2rem;\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.2rem;\n            }\n            .graph-container {\n                width: 90%;\n                height: 300px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <header>\n        <h1>Floyd-Warshall Algorithm</h1>\n        <p class=\"subtitle\">\n            A visual demonstration of the dynamic programming algorithm for finding shortest paths in a weighted graph\n        </p>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"graph-container\">\n            <div class=\"graph\" id=\"graph\"></div>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color highlight-legend\"></div>\n                <span>Current Comparison</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color path-legend\"></div>\n                <span>Optimized Path</span>\n            </div>\n        </div>\n\n        <div class=\"status\" id=\"status\">Ready to begin</div>\n\n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Animation</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n\n        <div class=\"matrix-container\">\n            <table id=\"matrix\">\n                <thead>\n                    <tr>\n                        <th colspan=\"5\">Distance Matrix</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <!-- Filled by JavaScript -->\n                </tbody>\n            </table>\n        </div>\n    </div>\n\n    <footer>\n        Floyd-Warshall Algorithm Visualization | Shortest Path Finder\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            const particles = document.getElementById('particles');\n            for (let i = 0; i < 50; i++) {\n                const particle = document.createElement('div');\n                particle.style.position = 'absolute';\n                particle.style.width = `${Math.random() * 5 + 2}px`;\n                particle.style.height = particle.style.width;\n                particle.style.backgroundColor = 'white';\n                particle.style.borderRadius = '50%';\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.opacity = Math.random() * 0.3 + 0.1;\n                particle.style.transform = `translateZ(${Math.random() * 100}px)`;\n                particle.style.animation = `float ${Math.random() * 10 + 10}s infinite ease-in-out`;\n                particle.style.animationDelay = `${Math.random() * 5}s`;\n                particles.appendChild(particle);\n            }\n\n            // Graph definition\n            const graph = {\n                nodes: [\n                    { id: 'A', x: 100, y: 100 },\n                    { id: 'B', x: 450, y: 100 },\n                    { id: 'C', x: 450, y: 300 },\n                    { id: 'D', x: 100, y: 300 },\n                    { id: 'E', x: 275, y: 200 }\n                ],\n                edges: [\n                    { source: 0, target: 1, weight: 5 },\n                    { source: 0, target: 3, weight: 10 },\n                    { source: 1, target: 2, weight: 3 },\n                    { source: 1, target: 4, weight: 4 },\n                    { source: 2, target: 3, weight: 1 },\n                    { source: 3, target: 0, weight: 2 },\n                    { source: 4, target: 2, weight: 6 },\n                    { source: 4, target: 3, weight: 2 }\n                ]\n            };\n\n            // Initialize distance matrix\n            let dist = [];\n            const n = graph.nodes.length;\n            \n            // Create initial distance matrix with Infinity\n            for (let i = 0; i < n; i++) {\n                dist[i] = [];\n                for (let j = 0; j < n; j++) {\n                    if (i === j) {\n                        dist[i][j] = 0;\n                    } else {\n                        dist[i][j] = Infinity;\n                    }\n                }\n            }\n\n            // Set edges in distance matrix\n            graph.edges.forEach(edge => {\n                dist[edge.source][edge.target] = edge.weight;\n            });\n\n            // Draw the graph\n            function drawGraph() {\n                const container = document.getElementById('graph');\n                container.innerHTML = '';\n\n                // Draw edges\n                graph.edges.forEach((edge, index) => {\n                    const sourceNode = graph.nodes[edge.source];\n                    const targetNode = graph.nodes[edge.target];\n                    \n                    const edgeEl = document.createElement('div');\n                    edgeEl.className = 'edge';\n                    \n                    // Calculate edge position and angle\n                    const dx = targetNode.x - sourceNode.x;\n                    const dy = targetNode.y - sourceNode.y;\n                    const length = Math.sqrt(dx * dx + dy * dy);\n                    const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n                    \n                    edgeEl.style.width = `${length}px`;\n                    edgeEl.style.left = `${sourceNode.x}px`;\n                    edgeEl.style.top = `${sourceNode.y}px`;\n                    edgeEl.style.transform = `rotate(${angle}deg)`;\n                    \n                    // Add weight label\n                    const weightEl = document.createElement('span');\n                    weightEl.className = 'edge-weight';\n                    weightEl.textContent = edge.weight;\n                    \n                    // Position weight at center of edge\n                    const weightLeft = length / 2 - 15;\n                    const weightTop = angle > 90 || angle < -90 ? -30 : 10;\n                    \n                    weightEl.style.left = `${weightLeft}px`;\n                    weightEl.style.top = `${weightTop}px`;\n                    \n                    edgeEl.appendChild(weightEl);\n                    container.appendChild(edgeEl);\n                });\n\n                // Draw nodes\n                graph.nodes.forEach((node, index) => {\n                    const nodeEl = document.createElement('div');\n                    nodeEl.className = 'node';\n                    nodeEl.textContent = node.id;\n                    nodeEl.style.left = `${node.x - 30}px`;\n                    nodeEl.style.top = `${node.y - 30}px`;\n                    nodeEl.setAttribute('data-index', index);\n                    container.appendChild(nodeEl);\n                });\n            }\n\n            // Render the distance matrix\n            function renderMatrix() {\n                const matrixBody = document.querySelector('#matrix tbody');\n                matrixBody.innerHTML = '';\n                \n                // Add header row\n                const headerRow = document.createElement('tr');\n                headerRow.innerHTML = '<th></th>' + \n                    graph.nodes.map(node => `<th>${node.id}</th>`).join('');\n                matrixBody.appendChild(headerRow);\n                \n                // Add data rows\n                for (let i = 0; i < n; i++) {\n                    const row = document.createElement('tr');\n                    row.innerHTML = `<th>${graph.nodes[i].id}</th>` + \n                        Array(n).fill().map((_, j) => {\n                            const value = dist[i][j];\n                            const isInfinity = value === Infinity;\n                            const displayValue = isInfinity ? '∞' : value;\n                            return `<td class=\"${isInfinity ? 'infinity' : ''}\">${displayValue}</td>`;\n                        }).join('');\n                    matrixBody.appendChild(row);\n                }\n            }\n\n            // Floyd-Warshall algorithm implementation\n            let isRunning = false;\n            let currentStep = { k: -1, i: -1, j: -1 };\n            \n            async function floydWarshallStep() {\n                isRunning = true;\n                document.getElementById('startBtn').textContent = 'Running...';\n                \n                const n = dist.length;\n                const delay = 1000;\n                \n                for (let k = 0; k < n; k++) {\n                    currentStep.k = k;\n                    updateStatus();\n                    \n                    for (let i = 0; i < n; i++) {\n                        currentStep.i = i;\n                        \n                        for (let j = 0; j < n; j++) {\n                            currentStep.j = j;\n                            updateStatus();\n                            \n                            // Highlight the current comparison in matrix\n                            highlightMatrixCell(i, j);\n                            \n                            // Check if the path through k is shorter\n                            if (dist[i][k] + dist[k][j] < dist[i][j]) {\n                                // Update the matrix\n                                dist[i][j] = dist[i][k] + dist[k][j];\n                                \n                                // Highlight the new shorter path\n                                highlightPath(i, j, k);\n                                \n                                // Add small delay for visualization\n                                await new Promise(resolve => setTimeout(resolve, delay));\n                                \n                                // Update the matrix display\n                                renderMatrix();\n                            }\n                            \n                            await new Promise(resolve => setTimeout(resolve, delay / 2));\n                        }\n                    }\n                }\n                \n                isRunning = false;\n                document.getElementById('startBtn').textContent = 'Complete';\n                updateStatus({ text: 'Algorithm complete! Final shortest paths calculated.' });\n            }\n            \n            function highlightMatrixCell(i, j) {\n                // Clear previous highlights\n                document.querySelectorAll('#matrix td').forEach(td => {\n                    td.classList.remove('highlight', 'path');\n                });\n                \n                // Highlight current cells\n                const cell1 = document.querySelector(`#matrix tr:nth-child(${i + 2}) td:nth-child(${j + 2})`);\n                if (cell1) cell1.classList.add('highlight');\n                \n                // Add path class to cells being compared\n                if (currentStep.k >= 0) {\n                    const cell2 = document.querySelector(`#matrix tr:nth-child(${i + 2}) td:nth-child(${currentStep.k + 2})`);\n                    const cell3 = document.querySelector(`#matrix tr:nth-child(${currentStep.k + 2}) td:nth-child(${j + 2})`);\n                    \n                    if (cell2) cell2.classList.add('path');\n                    if (cell3) cell3.classList.add('path');\n                }\n            }\n            \n            function highlightPath(i, j, k) {\n                updateStatus({\n                    text: `Found shorter path from ${graph.nodes[i].id} → ${graph.nodes[j].id} (via ${graph.nodes[k].id})`,\n                    color: '#4ecdc4'\n                });\n                \n                // Here you could add visual path highlighting on the graph\n                // This would require tracking paths in a more complex way\n            }\n            \n            function updateStatus(options = {}) {\n                const statusEl = document.getElementById('status');\n                const { k, i, j } = currentStep;\n                \n                if (options.text) {\n                    statusEl.textContent = options.text;\n                    if (options.color) statusEl.style.color = options.color;\n                    return;\n                }\n                \n                if (k === -1) {\n                    statusEl.textContent = 'Ready to begin';\n                    statusEl.style.color = '#4ecdc4';\n                } else {\n                    let text = `Comparing path: ${graph.nodes[i].id} → ${graph.nodes[j].id}`;\n                    if (k >= 0) {\n                        text += ` (via ${graph.nodes[k].id})`;\n                    }\n                    statusEl.textContent = text;\n                    statusEl.style.color = '#ff6b6b';\n                }\n            }\n            \n            function reset() {\n                // Reset distance matrix\n                for (let i = 0; i < n; i++) {\n                    for (let j = 0; j < n; j++) {\n                        if (i === j) {\n                            dist[i][j] = 0;\n                        } else {\n                            dist[i][j] = Infinity;\n                        }\n                    }\n                }\n                \n                // Set edges in distance matrix\n                graph.edges.forEach(edge => {\n                    dist[edge.source][edge.target] = edge.weight;\n                });\n                \n                // Reset UI\n                currentStep = { k: -1, i: -1, j: -1 };\n                renderMatrix();\n                updateStatus();\n                document.getElementById('startBtn').textContent = 'Start Animation';\n                \n                // Clear highlights\n                document.querySelectorAll('#matrix td').forEach(td => {\n                    td.classList.remove('highlight', 'path');\n                });\n            }\n            \n            // Initialize\n            drawGraph();\n            renderMatrix();\n            \n            // Event listeners\n            document.getElementById('startBtn').addEventListener('click', function() {\n                if (!isRunning && this.textContent !== 'Complete') {\n                    floydWarshallStep();\n                }\n            });\n            \n            document.getElementById('resetBtn').addEventListener('click', reset);\n            \n            // Add animation for particles\n            const style = document.createElement('style');\n            style.textContent = `\n                @keyframes float {\n                    0%, 100% { transform: translateY(0) translateX(0) translateZ(0); }\n                    25% { transform: translateY(-50px) translateX(20px) translateZ(30px); }\n                    50% { transform: translateY(20px) translateX(-30px) translateZ(-20px); }\n                    75% { transform: translateY(-30px) translateX(-10px) translateZ(-10px); }\n                }\n            `;\n            document.head.appendChild(style);\n        });\n    </script>\n</body>\n</html>"
