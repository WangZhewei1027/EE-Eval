    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Support Vector Machine Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n  /* Root Variables */\n  :root {\n    --primary-color: #4b6cb7;\n    --secondary-color: #182848;\n    --accent-color: #88e0ef;\n    --svm-color-pos: #35d07f;\n    --svm-color-neg: #f25c6c;\n    --line-color: #ffffffbb;\n    --bg-gradient-start: #1f263d;\n    --bg-gradient-end: #283148;\n    --font-family: 'Montserrat', sans-serif;\n    --shadow-primary: rgba(107, 123, 193, 0.4);\n    --shadow-accent: rgba(136, 224, 239, 0.3);\n  }\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));\n    font-family: var(--font-family);\n    color: #f0f4fa;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  .container {\n    max-width: 960px;\n    margin: 2rem auto 4rem auto;\n    padding: 0 1.5rem;\n    display: flex;\n    flex-direction: column;\n    gap: 2rem;\n  }\n\n  /* Header with subtle gradient text */\n  header {\n    text-align: center;\n  }\n\n  header h1 {\n    font-weight: 700;\n    font-size: 3.4rem;\n    letter-spacing: 0.08em;\n    background: linear-gradient(90deg, #35d07f, #88e0ef);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    filter: drop-shadow(0 2px 4px var(--shadow-primary));\n    margin-bottom: 0.5rem;\n  }\n\n  header p {\n    font-size: 1.2rem;\n    color: #b2bbcc;\n    max-width: 540px;\n    margin: 0 auto;\n    line-height: 1.5;\n    font-weight: 400;\n  }\n\n  /* Canvas container: centered, subtle 3D card with glow */\n  .canvas-wrapper {\n    position: relative;\n    background: var(--secondary-color);\n    border-radius: 2rem;\n    box-shadow:\n      0 0 20px 5px var(--shadow-primary),\n      inset 0 0 30px 1px var(--shadow-accent);\n    padding: 1.5rem 2rem 2rem 2rem;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    aspect-ratio: 1 / 1;\n    max-width: 100%;\n    overflow: visible;\n  }\n\n  canvas {\n    border-radius: 1.4rem;\n    box-shadow:\n      0 12px 24px rgb(0 0 0 / 0.25);\n    background: linear-gradient(180deg, #283148, #1f263d);\n  }\n\n  /* Explanation Box */\n  .explanation {\n    max-width: 700px;\n    margin: 0 auto;\n    font-size: 1.05rem;\n    line-height: 1.6;\n    color: #d9e3f0;\n    text-align: center;\n    filter: drop-shadow(0 0 8px var(--shadow-primary));\n  }\n\n  /* Buttons */\n  .controls {\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n    margin-top: 1rem;\n  }\n\n  button {\n    background: linear-gradient(135deg, #35d07f, #88e0ef);\n    border: none;\n    padding: 0.65rem 1.4rem;\n    font-weight: 700;\n    font-size: 1.1rem;\n    border-radius: 1rem;\n    color: #1b1f27;\n    cursor: pointer;\n    box-shadow: 0 4px 12px var(--shadow-accent);\n    transition:\n      background-color 0.3s ease,\n      transform 0.2s ease,\n      box-shadow 0.3s ease;\n    user-select: none;\n  }\n\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, #4de993, #aaf1fc);\n    box-shadow:\n      0 6px 20px #88e0efcc,\n      0 0 8px #35d07fcc;\n    transform: scale(1.08);\n    outline: none;\n  }\n\n  button:active {\n    transform: scale(0.96);\n  }\n\n  /* Footer with subtle fade */\n  footer {\n    text-align: center;\n    font-size: 0.9rem;\n    color: #76829f88;\n    user-select: none;\n    margin-top: 3rem;\n  }\n\n  /* Subtle animated glowing dots legend */\n  .legend {\n    position: absolute;\n    bottom: 1rem;\n    right: 1.6rem;\n    background: rgba(40, 49, 72, 0.75);\n    border-radius: 1rem;\n    padding: 0.6rem 1rem;\n    font-size: 0.9rem;\n    user-select: none;\n    color: #a2b4d2cc;\n    box-shadow: 0 0 22px 1px var(--shadow-primary);\n    backdrop-filter: blur(10px);\n  }\n\n  .legend span {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.45rem;\n    margin-right: 1rem;\n  }\n\n  .legend .dot {\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    box-shadow: 0 0 8px 2px;\n  }\n\n  .pos-dot {\n    background: var(--svm-color-pos);\n    box-shadow: 0 0 16px 4px var(--svm-color-pos);\n    animation: glowPos 3s ease-in-out infinite alternate;\n  }\n\n  .neg-dot {\n    background: var(--svm-color-neg);\n    box-shadow: 0 0 16px 4px var(--svm-color-neg);\n    animation: glowNeg 3s ease-in-out infinite alternate;\n  }\n\n  @keyframes glowPos {\n    0%, 100% { box-shadow: 0 0 16px 4px var(--svm-color-pos); }\n    50% { box-shadow: 0 0 26px 8px var(--svm-color-pos); }\n  }\n\n  @keyframes glowNeg {\n    0%, 100% { box-shadow: 0 0 16px 4px var(--svm-color-neg); }\n    50% { box-shadow: 0 0 26px 8px var(--svm-color-neg); }\n  }\n  \n</style>\n</head>\n<body>\n\n<div class=\"container\" role=\"main\" aria-label=\"Support Vector Machine visualization\">\n  <header>\n    <h1>Support Vector Machine</h1>\n    <p>An aesthetic illustration depicting the classic SVM classifier, showcasing data points separated by the optimal hyperplane and the margin-defining support vectors.</p>\n  </header>\n\n  <div class=\"canvas-wrapper\" aria-label=\"Support Vector Machine plot visualization\">\n    <canvas id=\"svmCanvas\" width=\"700\" height=\"700\" role=\"img\" aria-describedby=\"explanationText\"></canvas>\n    <div class=\"legend\" aria-hidden=\"true\">\n      <span><div class=\"dot pos-dot\"></div> Positive Class (+1)</span>\n      <span><div class=\"dot neg-dot\"></div> Negative Class (-1)</span>\n      <span><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"7\" cy=\"7\" r=\"6\" stroke=\"#88e0ef\" stroke-width=\"2\" stroke-dasharray=\"4 3\"/></svg> Support Vectors</span>\n      <span><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><line x1=\"1\" y1=\"7\" x2=\"13\" y2=\"7\" stroke=\"#88e0ef\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg> Hyperplane</span>\n    </div>\n  </div>\n\n  <div class=\"controls\" role=\"region\" aria-label=\"Controls\">\n    <button id=\"toggleMarginBtn\" aria-pressed=\"true\" aria-controls=\"svmCanvas\">\n      Toggle Margin\n    </button>\n    <button id=\"regenBtn\" aria-controls=\"svmCanvas\">\n      Regenerate Data\n    </button>\n  </div>\n\n  <div class=\"explanation\" id=\"explanationText\">\n    <p>\n      The <strong>Support Vector Machine</strong> algorithm separates two classes of data points with a hyperplane that maximizes the margin – the distance between the closest points of each class, called <em>support vectors</em>. Here, green and red points represent two classes, and the glowing circles highlight those critical support vectors that define the boundary. The center line is the optimal hyperplane that splits the classes with the maximum margin.\n    </p>\n  </div>\n</div>\n\n<footer aria-hidden=\"true\">Visual design © 2024 | SVM concept demonstration</footer>\n\n<script>\n(() => {\n  const canvas = document.getElementById('svmCanvas');\n  const ctx = canvas.getContext('2d');\n  const width = canvas.width;\n  const height = canvas.height;\n\n  const toggleMarginBtn = document.getElementById('toggleMarginBtn');\n  const regenBtn = document.getElementById('regenBtn');\n\n  // Colors & styles from CSS variables (fallbacks)\n  const colors = {\n    positive: getComputedStyle(document.documentElement).getPropertyValue('--svm-color-pos').trim() || '#35d07f',\n    negative: getComputedStyle(document.documentElement).getPropertyValue('--svm-color-neg').trim() || '#f25c6c',\n    hyperplane: 'rgba(136, 224, 239, 0.85)',\n    marginLines: 'rgba(136, 224, 239, 0.45)',\n    supportVectorHighlight: 'rgba(136, 224, 239, 0.3)',\n    backgroundGradientStart: getComputedStyle(document.documentElement).getPropertyValue('--bg-gradient-start').trim() || '#1f263d',\n    backgroundGradientEnd: getComputedStyle(document.documentElement).getPropertyValue('--bg-gradient-end').trim() || '#283148',\n  }\n\n  // Data parameters\n  const POINT_RADIUS = 9;\n  const SUPPORT_RADIUS = 13;\n  const SV_GLOW_ALPHA = 0.3;\n  const SV_GLOW_MAX = 16;\n\n  // Model parameters (2D linear SVM)\n  // For this illustration, we'll synthesize:\n  // - two well separated classes of points\n  // - an optimal separating hyperplane with margin lines\n  // - highlight support vectors (closest points to the hyperplane)\n\n  // SVM hyperplane equation: w.x + b = 0\n  // We choose w and b arbitrarily for nice diagonal line: example: w = [1, -0.8], b = -0.2 \n\n  // Support vectors lie on lines w.x + b = ±1 (margin boundaries)\n\n  let showMargin = true;\n\n  // Generate synthetic data for classes: roughly Gaussian clouds on left/right sides separated by margin\n\n  let dataPoints = [];\n\n  // Utility helper: Linear algebra simple dot product\n  function dot(a,b) {\n    return a[0]*b[0] + a[1]*b[1];\n  }\n\n  // SVM Model\n  const w = [1, -0.8];\n  const b = -0.2;\n\n  // Normalize w for distances calculations\n  const wLength = Math.sqrt(w[0]*w[0] + w[1]*w[1]);\n  const wNorm = [w[0]/wLength, w[1]/wLength];\n\n  // Distance from point x to hyperplane = (w.x+b)/||w||\n  function pointDistance(x) {\n    return (dot(w,x) + b) / wLength;\n  }\n\n  // Canvas coordinate transformation: map from data space to canvas space and back\n  // Data space: x in [-4, 4], y in [-4,4]\n  // Canvas: 0 to width and height, leaving margin around edges\n\n  const margin = 70;\n  const dataRange = 8;\n  const dataMin = -4;\n  const dataMax = 4;\n\n  function dataToCanvas(xy) {\n    // xy = [x,y] in data coords\n    // map x from [-4,4] to [margin, width-margin]\n    // map y from [-4,4] to [height-margin, margin] (y flipped)\n    const [x,y] = xy;\n    const cx = margin + ((x - dataMin) / dataRange) * (width - 2*margin);\n    const cy = height - (margin + ((y - dataMin) / dataRange) * (height - 2*margin));\n    return [cx, cy];\n  }\n\n  function canvasToData(cx, cy) {\n    const x = dataMin + ((cx - margin) / (width - 2*margin)) * dataRange;\n    const y = dataMin + ((height - cy - margin) / (height - 2*margin)) * dataRange;\n    return [x, y];\n  }\n\n  // Generate data points randomly for two classes, near their margin lines with some noise\n  function generateData(num=30) {\n    let points = [];\n\n    // Positive class: w.x + b >= 1 roughly\n    // Negative class: w.x + b <= -1 roughly\n\n    // We'll scatter points around margin boundary lines + random offset along margin normals\n\n    // The margin boundaries are: w.x + b = ±1\n\n    function randomNormal() {\n      // Box-Muller transform for normal distribution\n      let u = 0, v = 0;\n      while(u === 0) u = Math.random();\n      while(v === 0) v = Math.random();\n      return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);\n    }\n\n    for(let i=0; i<num; i++) {\n      // Positive class\n      // choose random position on margin line w.x+b=1 and add Gaussian noise perpendicular to margin\n      let marginPos = 1;\n      let t = (Math.random()*8 - 4); // parameter to generate points along vector orthogonal to margin line\n      // We'll find a vector orthogonal to w, call it u = [-w[1], w[0]]\n      const u = [-w[1], w[0]];\n      // normalize u\n      const uLen = Math.sqrt(u[0]*u[0]+u[1]*u[1]);\n      const un = [u[0]/uLen, u[1]/uLen];\n\n      // Solve for x on margin line: w.x + b = marginPos\n      // Parametric form: x = x0 + t*un, we find x0 (a point on margin line)\n      // One point x0 satisfies: w.x0 + b = marginPos\n      // Let's pick x0 = [0, y0], solve for y0:\n      // w[0]*0 + w[1]*y0 + b = marginPos => y0 = (marginPos - b)/w[1]\n      let x0 = 0;\n      let y0 = (marginPos - b)/w[1];\n      // Base point on margin line:\n      let base = [x0, y0];\n      // Add t along un:\n      let pos = [base[0] + t*un[0], base[1] + t*un[1]];\n      // Add some noise perpendicular to margin line (along wNorm)\n      const noise = randomNormal()*0.3;\n      pos[0] += noise*wNorm[1]; // perpendicular direction to wNorm is rotated 90°\n      pos[1] -= noise*wNorm[0];\n\n      // Clamp points in data range\n      pos[0] = Math.min(Math.max(pos[0], dataMin + 0.2), dataMax - 0.2);\n      pos[1] = Math.min(Math.max(pos[1], dataMin + 0.2), dataMax - 0.2);\n\n      points.push({\n        pos,\n        label: +1,\n      });\n    }\n\n    for(let i=0; i<num; i++) {\n      // Negative class\n      let marginPos = -1;\n      let t = (Math.random()*8 - 4);\n      const u = [-w[1], w[0]];\n      const uLen = Math.sqrt(u[0]*u[0]+u[1]*u[1]);\n      const un = [u[0]/uLen, u[1]/uLen];\n\n      let x0 = 0;\n      let y0 = (marginPos - b)/w[1];\n      let base = [x0, y0];\n      let pos = [base[0] + t*un[0], base[1] + t*un[1]];\n      const noise = randomNormal()*0.3;\n      pos[0] += noise*wNorm[1];\n      pos[1] -= noise*wNorm[0];\n\n      pos[0] = Math.min(Math.max(pos[0], dataMin + 0.2), dataMax - 0.2);\n      pos[1] = Math.min(Math.max(pos[1], dataMin + 0.2), dataMax - 0.2);\n\n      points.push({\n        pos,\n        label: -1,\n      });\n    }\n\n    return points;\n  }\n\n  // Identify support vectors: closest points to hyperplane on either side with distance ~1/wLength\n  // Because support vectors lie exactly on margin boundary, distance is ±1/wLength\n  function findSupportVectors(points) {\n    // Find points with distance close (+/- thres) to margin boundaries\n    const threshold = 0.15;\n    let sv = [];\n    points.forEach(p => {\n      let d = pointDistance(p.pos);\n      if(p.label === 1 && Math.abs(d - 1/wLength) < threshold) {\n        sv.push(p);\n      } else if(p.label === -1 && Math.abs(d + 1/wLength) < threshold) {\n        sv.push(p);\n      }\n    });\n    return sv;\n  }\n\n  // Smooth animation helpers\n\n  let animationId;\n\n  // Animate glowing effect on support vectors\n  let glowPhase = 0;\n  const glowSpeed = 0.015; // radians/frame\n\n  // Draw the grid background softly\n\n  function drawGrid() {\n    const gridStep = 1;\n    const lightLine = 'rgba(255,255,255,0.07)';\n    const darkLine = 'rgba(255,255,255,0.12)';\n\n    ctx.save();\n    ctx.lineWidth = 1;\n\n    for(let x = dataMin; x <= dataMax; x += gridStep) {\n      let [cx, cy1] = dataToCanvas([x, dataMin]);\n      let [cx2, cy2] = dataToCanvas([x, dataMax]);\n      ctx.strokeStyle = (x%2===0) ? darkLine : lightLine;\n      ctx.beginPath();\n      ctx.moveTo(cx, cy1);\n      ctx.lineTo(cx2, cy2);\n      ctx.stroke();\n    }\n\n    for(let y = dataMin; y <= dataMax; y += gridStep) {\n      let [cx1, cy] = dataToCanvas([dataMin, y]);\n      let [cx2, cy2] = dataToCanvas([dataMax, y]);\n      ctx.strokeStyle = (y%2===0) ? darkLine : lightLine;\n      ctx.beginPath();\n      ctx.moveTo(cx1, cy);\n      ctx.lineTo(cx2, cy2);\n      ctx.stroke();\n    }\n\n    ctx.restore();\n  }\n\n  // Draw points and support vector highlights\n  function drawPoints(points, supportVectors) {\n    points.forEach(p => {\n      const [cx, cy] = dataToCanvas(p.pos);\n      const isSupport = supportVectors.includes(p);\n      const r = POINT_RADIUS;\n      ctx.save();\n\n      // Glow for support vectors\n      if(isSupport) {\n        // Pulsing glow ambient halo behind\n        const glowRadius = SUPPORT_RADIUS + 6 * Math.abs(Math.sin(glowPhase));\n        const gradient = ctx.createRadialGradient(cx, cy, SUPPORT_RADIUS*0.8, cx, cy, glowRadius);\n        gradient.addColorStop(0, colors.supportVectorHighlight);\n        gradient.addColorStop(1, 'rgba(136, 224, 239, 0)');\n        ctx.fillStyle = gradient;\n        ctx.shadowColor = colors.supportVectorHighlight;\n        ctx.shadowBlur = 18;\n        ctx.beginPath();\n        ctx.arc(cx, cy, glowRadius, 0, Math.PI*2);\n        ctx.fill();\n      }\n\n      // Point fill and border\n      ctx.beginPath();\n      ctx.arc(cx, cy, r, 0, Math.PI*2);\n      ctx.fillStyle = p.label === 1 ? colors.positive : colors.negative;\n      ctx.shadowColor = p.label === 1 ? colors.positive : colors.negative;\n      ctx.shadowBlur = isSupport ? 16 : 6;\n      ctx.fill();\n\n      // Crisp white border for support vectors\n      if(isSupport) {\n        ctx.lineWidth = 2.4;\n        ctx.strokeStyle = 'rgba(136, 224, 239, 0.85)';\n        ctx.shadowBlur = 14;\n        ctx.shadowColor = 'rgba(136, 224, 239, 0.85)';\n        ctx.stroke();\n      }\n\n      ctx.restore();\n    });\n  }\n\n  // Draw hyperplane and margin lines\n\n  function drawLines(showMarginLines) {\n    // We'll draw the line w.x + b = 0 (hyperplane)\n    // In canvas coordinates, this line spans the visible plot area\n\n    // The line equation: w.x + b = 0\n    // y = (-w0 * x - b)/w1\n\n    // Find intersection points with canvas edges in data space domain and convert to canvas\n\n    function yLine(x) {\n      return (-w[0]*x - b)/w[1];\n    }\n\n    // Clip the line segment to data box\n    // We'll find two points by intersecting line with left and right edges (x = dataMin, dataMax)\n    // and check if those y values are in range\n\n    let points = [];\n\n    // Left edge (x = dataMin)\n    let yl = yLine(dataMin);\n    if(yl >= dataMin && yl <= dataMax) points.push([dataMin, yl]);\n\n    // Right edge (x = dataMax)\n    let yr = yLine(dataMax);\n    if(yr >= dataMin && yr <= dataMax) points.push([dataMax, yr]);\n\n    // If less than 2 points found, try top and bottom edges:\n    if(points.length < 2) {\n      // Top edge (y = dataMax)\n      let xt = (-w[1]*dataMax - b) / w[0];\n      if(xt >= dataMin && xt <= dataMax) points.push([xt, dataMax]);\n      // Bottom edge (y = dataMin)\n      let xb = (-w[1]*dataMin - b) / w[0];\n      if(xb >= dataMin && xb <= dataMax) points.push([xb, dataMin]);\n    }\n\n    if(points.length !== 2) return;\n\n    // Convert data points to canvas points\n    const c1 = dataToCanvas(points[0]);\n    const c2 = dataToCanvas(points[1]);\n\n    // Draw hyperplane\n    ctx.save();\n    ctx.strokeStyle = colors.hyperplane;\n    ctx.lineWidth = 3;\n    ctx.shadowColor = colors.hyperplane;\n    ctx.shadowBlur = 10;\n    ctx.lineCap = 'round';\n    ctx.beginPath();\n    ctx.moveTo(c1[0], c1[1]);\n    ctx.lineTo(c2[0], c2[1]);\n    ctx.stroke();\n\n    ctx.restore();\n\n    if(!showMarginLines) return;\n\n    // Draw margin lines w.x + b = ±1\n\n    function yMargin(x, offset) {\n      return (-w[0]*x - b + offset)/w[1];\n    }\n\n    const offsets = [1, -1];\n    ctx.lineWidth = 2.2;\n    ctx.strokeStyle = colors.marginLines;\n    ctx.setLineDash([8, 10]);\n\n    offsets.forEach(offset => {\n      let mp = [];\n\n      // Left side\n      let yl = yMargin(dataMin, offset);\n      if(yl >= dataMin && yl <= dataMax) mp.push([dataMin, yl]);\n\n      // Right side\n      let yr = yMargin(dataMax, offset);\n      if(yr >= dataMin && yr <= dataMax) mp.push([dataMax, yr]);\n\n      // Top and bottom edges if needed\n      if(mp.length < 2) {\n        let xt = (-w[1]*dataMax - b + offset) / w[0];\n        if(xt >= dataMin && xt <= dataMax) mp.push([xt, dataMax]);\n\n        let xb = (-w[1]*dataMin - b + offset) / w[0];\n        if(xb >= dataMin && xb <= dataMax) mp.push([xb, dataMin]);\n      }\n\n      if(mp.length === 2) {\n        const c1 = dataToCanvas(mp[0]);\n        const c2 = dataToCanvas(mp[1]);\n        ctx.beginPath();\n        ctx.moveTo(c1[0], c1[1]);\n        ctx.lineTo(c2[0], c2[1]);\n        ctx.stroke();\n      }\n    });\n\n    ctx.setLineDash([]);\n    ctx.restore();\n  }\n\n  // Render all\n  function render() {\n    ctx.clearRect(0, 0, width, height);\n\n    // Background subtle gradient fill\n    let bgGradient = ctx.createLinearGradient(0, 0, 0, height);\n    bgGradient.addColorStop(0, colors.backgroundGradientStart);\n    bgGradient.addColorStop(1, colors.backgroundGradientEnd);\n    ctx.fillStyle = bgGradient;\n    ctx.fillRect(0, 0, width, height);\n\n    drawGrid();\n\n    // Draw lines\n    drawLines(showMargin);\n\n    // Draw data points & support vectors\n    const supportVectors = findSupportVectors(dataPoints);\n\n    drawPoints(dataPoints, supportVectors);\n\n    glowPhase += glowSpeed;\n    if(glowPhase > Math.PI*2) glowPhase -= Math.PI*2;\n  }\n\n  // Animation loop\n  function animate() {\n    render();\n    animationId = requestAnimationFrame(animate);\n  }\n\n  // Button handlers\n  toggleMarginBtn.addEventListener('click', () => {\n    showMargin = !showMargin;\n    toggleMarginBtn.setAttribute('aria-pressed', showMargin.toString());\n  });\n\n  regenBtn.addEventListener('click', () => {\n    dataPoints = generateData(30);\n  });\n\n  // Initialize data and start animation\n  dataPoints = generateData(30);\n\n  animate();\n\n})();\n</script>\n\n</body>\n</html>"
  },
