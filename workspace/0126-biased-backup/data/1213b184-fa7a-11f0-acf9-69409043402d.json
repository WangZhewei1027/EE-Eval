  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Quick Sort Interactive Explorer</title>\n<style>\n  /* Extremely minimal styling: just monospace font for clarity */\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    background: white;\n    color: black;\n  }\n  button, input[type=number], input[type=text], select {\n    font-family: monospace;\n    font-size: 14px;\n    margin: 2px 4px 2px 0;\n  }\n  label {\n    user-select: none;\n  }\n  pre {\n    white-space: pre-wrap;\n    word-break: break-word;\n    font-size: 14px;\n    margin-top: 6px;\n  }\n  hr {\n    margin: 10px 0;\n  }\n  fieldset {\n    margin-bottom: 12px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Quick Sort Interactive Explorer</h1>\n\n<fieldset>\n  <legend>Array Input and Controls</legend>\n\n  <label for=\"arrayInput\">Enter array (comma or space separated integers):</label><br />\n  <input type=\"text\" id=\"arrayInput\" size=\"50\" value=\"5,2,9,1,5,6\" />\n  <button id=\"loadArrayBtn\" title=\"Load array & prepare for sorting\">Load Array</button>\n  <button id=\"randomArrayBtn\" title=\"Generate random array\">Random Array</button>\n  <label for=\"randomSize\" title=\"Size for random array\">Size:</label>\n  <input type=\"number\" id=\"randomSize\" min=\"1\" max=\"100\" value=\"10\" style=\"width:50px;\" />\n  <label for=\"randomMax\" title=\"Max value for random array\">Max:</label>\n  <input type=\"number\" id=\"randomMax\" min=\"1\" max=\"1000\" value=\"50\" style=\"width:60px;\" />\n\n  <br /><br />\n  <label for=\"pivotStrategy\">Pivot Selection Strategy:</label>\n  <select id=\"pivotStrategy\" title=\"Choose pivot selection method\">\n    <option value=\"last\">Last element</option>\n    <option value=\"first\">First element</option>\n    <option value=\"middle\">Middle element</option>\n    <option value=\"random\">Random element</option>\n    <option value=\"medianOfThree\">Median of three</option>\n  </select>\n</fieldset>\n\n<fieldset>\n  <legend>Sorting Controls</legend>\n  <button id=\"stepBtn\" title=\"Perform one algorithm step\">Step</button>\n  <button id=\"autoRunBtn\" title=\"Automatic running\">Auto Run</button>\n  <button id=\"pauseBtn\" title=\"Pause Auto Run\">Pause</button>\n  <button id=\"resetBtn\" title=\"Reset to original array\">Reset</button>\n  <label for=\"speedRange\" title=\"Adjust auto-run speed (ms)\">Speed (ms):</label>\n  <input type=\"range\" id=\"speedRange\" min=\"50\" max=\"2000\" value=\"500\" step=\"10\" />\n  <span id=\"speedDisplay\">500</span>\n</fieldset>\n\n<fieldset>\n  <legend>Controls for Exploration</legend>\n  <button id=\"undoBtn\" title=\"Undo last step\">Undo</button>\n  <button id=\"redoBtn\" title=\"Redo last undone step\">Redo</button>\n  <label for=\"jumpToStepInput\" title=\"Jump directly to a step index\">Jump to step:</label>\n  <input type=\"number\" id=\"jumpToStepInput\" min=\"0\" value=\"0\" style=\"width: 60px;\" />\n  <button id=\"jumpToStepBtn\" title=\"Jump to selected step\">Go</button>\n  <button id=\"showCallStackBtn\" title=\"Toggle call stack display\">Toggle Call Stack</button>\n  <button id=\"showSubarraysBtn\" title=\"Toggle subarrays overview display\">Toggle Subarrays View</button>\n</fieldset>\n\n<hr />\n\n<div id=\"statusArea\" aria-live=\"polite\" style=\"font-weight:bold;\"></div>\n\n<h2>Array State</h2>\n<pre id=\"arrayState\">[]</pre>\n\n<h2>Algorithm Description</h2>\n<pre id=\"algorithmText\">\n// Will show explanation of current step\n</pre>\n\n<h2>Partition Pointers</h2>\n<pre id=\"pointersDisplay\">\n// Shows current pointers: low, high, pivot index, i, j, etc.\n</pre>\n\n<h2>Call Stack</h2>\n<pre id=\"callStackDisplay\" style=\"display:none; max-height:200px; overflow-y:auto;\"></pre>\n\n<h2>Subarrays Overview</h2>\n<pre id=\"subarraysDisplay\" style=\"display:none; max-height:200px; overflow-y:auto;\"></pre>\n\n<script>\n(() => {\n  // State of the Quick Sort algorithm for visualization\n  // Using stepwise, manual control\n\n  /*********************\n   * DATA STRUCTURES\n   *********************/\n  // The input array - original and working copies\n  let originalArray = [];\n  let workingArray = [];\n\n  // The stack of recursion frames for quicksort simulation\n  // Each frame: { left, right, stage: \"start\" | \"partition\" | \"done\", pivotIndex, i, j }\n  // stage indicates what sub-step the frame is currently at\n  // i and j are pointers used in partition\n\n  let callStack = [];\n\n  // History stack for undo/redo (stores { workingArray copy, callStack deep copy })\n  let history = [];\n  let historyIndex = -1;\n\n  // Auto run interval\n  let autoRunInterval = null;\n\n  // Pivot strategy function references\n  const pivotStrategies = {\n    last: function(arr, left, right) { return right; },\n    first: function(arr, left, right) { return left; },\n    middle: function(arr, left, right) { return Math.floor((left+right)/2); },\n    random: function(arr, left, right) { return left + Math.floor(Math.random()*(right-left+1)); },\n    medianOfThree: function(arr, left, right) {\n      let mid = Math.floor((left+right)/2); \n      let trio = [\n        {val: arr[left], idx:left},\n        {val: arr[mid], idx:mid},\n        {val: arr[right], idx:right}\n      ];\n      trio.sort((a,b) => a.val - b.val);\n      return trio[1].idx;\n    }\n  };\n\n  // Current pivot strategy key\n  let currentPivotStrategyKey = \"last\";\n\n  /***********************\n   * UTILITY FUNCTIONS\n   ***********************/\n  // Deep copy call stack frames (safe for primitives)\n  function deepCopyCallStack(cs) {\n    return cs.map(frame => Object.assign({}, frame));\n  }\n\n  // Deep copy entire state snapshot for history\n  function makeSnapshot() {\n    return {\n      workingArray: workingArray.slice(),\n      callStack: deepCopyCallStack(callStack)\n    };\n  }\n\n  // Restore from snapshot\n  function restoreSnapshot(snapshot) {\n    workingArray = snapshot.workingArray.slice();\n    callStack = deepCopyCallStack(snapshot.callStack);\n  }\n\n  // Push current state to history\n  function pushHistory() {\n    // Discard any redo history\n    if(historyIndex < history.length-1) {\n      history = history.slice(0, historyIndex+1);\n    }\n    history.push(makeSnapshot());\n    historyIndex++;\n    updateUndoRedoButtons();\n  }\n\n  // Update Undo/Redo buttons status\n  function updateUndoRedoButtons() {\n    undoBtn.disabled = (historyIndex <= 0);\n    redoBtn.disabled = (historyIndex >= history.length-1);\n  }\n\n  // Check if array is fully sorted (for status)\n  function isSorted(arr) {\n    for(let i=1; i<arr.length; i++) {\n      if(arr[i-1] > arr[i]) return false;\n    }\n    return true;\n  }\n\n  /***********************\n   * ALGORITHM IMPLEMENTATION\n   ***********************/\n\n  // Initialize quicksort call stack with full range\n  function initializeQuickSort() {\n    callStack = [];\n    if(workingArray.length > 1) {\n      callStack.push({left:0, right:workingArray.length-1, stage:\"start\", pivotIndex:-1, i:-1, j:-1});\n    }\n    // else no sorting needed\n  }\n\n  // Perform one step of quicksort visualization.\n  // Returns true if progressed, false if done.\n  function quickSortStep() {\n    if(callStack.length === 0) {\n      return false; // sorting done\n    }\n\n    let frame = callStack[callStack.length-1];\n\n    // stages: start, partition, done\n\n    if(frame.stage === \"start\") {\n      // Select pivot index by chosen strategy within [left,right]\n      frame.pivotIndex = pivotStrategies[currentPivotStrategyKey](workingArray, frame.left, frame.right);\n      // Swap pivot to right for partitioning (common approach)\n      swap(workingArray, frame.pivotIndex, frame.right);\n      frame.pivotIndex = frame.right;\n\n      frame.i = frame.left-1; // index of smaller element\n      frame.j = frame.left;\n\n      frame.stage = \"partition\";\n      return true;\n    }\n\n    if(frame.stage === \"partition\") {\n      if(frame.j < frame.right) {\n        // Compare current element with pivot\n\n        if(workingArray[frame.j] <= workingArray[frame.pivotIndex]) {\n          frame.i++;\n          swap(workingArray, frame.i, frame.j);\n        }\n        frame.j++;\n        return true;\n      } else {\n        // End partitioning: place pivot after last smaller element\n        frame.i++;\n        swap(workingArray, frame.i, frame.pivotIndex);\n        const pivotFinalPos = frame.i;\n\n        // Pop current frame from stack\n        callStack.pop();\n\n        // Push right side frame if needed\n        if(pivotFinalPos+1 < frame.right) {\n          callStack.push({\n            left: pivotFinalPos+1,\n            right: frame.right,\n            stage: \"start\",\n            pivotIndex: -1,\n            i:-1, j:-1\n          });\n        }\n        // Push left side frame if needed\n        if(frame.left < pivotFinalPos-1) {\n          callStack.push({\n            left: frame.left,\n            right: pivotFinalPos-1,\n            stage: \"start\",\n            pivotIndex: -1,\n            i:-1, j:-1\n          });\n        }\n\n        return true;\n      }\n    }\n\n    return false; // Should not reach here\n  }\n\n  function swap(arr, a, b) {\n    let tmp = arr[a];\n    arr[a] = arr[b];\n    arr[b] = tmp;\n  }\n\n  /******************************\n   * UI UPDATE FUNCTIONS\n   ******************************/\n\n  const arrayStatePre = document.getElementById(\"arrayState\");\n  const algorithmTextPre = document.getElementById(\"algorithmText\");\n  const pointersPre = document.getElementById(\"pointersDisplay\");\n  const callStackPre = document.getElementById(\"callStackDisplay\");\n  const subarraysPre = document.getElementById(\"subarraysDisplay\");\n  const statusArea = document.getElementById(\"statusArea\");\n\n  // Update the array display\n  function updateArrayDisplay() {\n    // Show array with indexes below, highlight pivot index if any active frame\n    let arr = workingArray.slice();\n    let pivots = new Set();\n    if(callStack.length > 0) {\n      let frame = callStack[callStack.length-1];\n      if(frame.pivotIndex >=0) pivots.add(frame.pivotIndex);\n    }\n    let line1 = arr.map(x => x.toString().padStart(2,\" \")).join(\" \");\n    let line2 = arr.map((_,i) => indicesHighlight(i, pivots.has(i))).join(\" \");\n\n    function indicesHighlight(i, isPivot) {\n      return (i).toString().padStart(2,\" \");\n    }\n\n    arrayStatePre.textContent = line1 + \"\\n\" + line2;\n  }\n\n  // Update algorithm explanation text depending on current frame and step\n  function updateAlgorithmDescription() {\n    if(callStack.length === 0) {\n      algorithmTextPre.textContent = \"// Sorting is complete!\\n\";\n      statusArea.textContent = \"Array is sorted. No frames on call stack.\";\n      return;\n    }\n\n    let frame = callStack[callStack.length-1];\n    let left = frame.left, right = frame.right;\n\n    let text = \"// Quick Sort: sorting subarray indices [\" + left + \" .. \" + right + \"]\\n\";\n    switch(frame.stage) {\n      case \"start\":\n        text +=\n`Select pivot element using strategy '${currentPivotStrategyKey}'.\\n` +\n`Swap chosen pivot to end of subarray.\\n` +\n`Initialize pointers:\\n` +\n` i (smaller element index) = ${frame.left - 1};\\n` +\n` j (current element index) = ${frame.left};`;\n        statusArea.textContent = \"Pivot is being selected and pointers initialized.\";\n        break;\n      case \"partition\":\n        if(frame.j < frame.right) {\n          text +=\n`Partitioning: comparing array[j] with pivot.\\n` +\n` j = ${frame.j}, i = ${frame.i}\\n` +\n`If array[j] <= pivot, increment i and swap elements at i and j.\\n` +\n`Current array[j] = ${workingArray[frame.j]}, pivot = ${workingArray[frame.pivotIndex]}`;\n          statusArea.textContent = \"Partitioning in progress...\";\n        } else {\n          text +=\n`Partition complete.\\n` +\n`Place pivot after the last smaller element.\\n` +\n`Then recursively quicksort the two subarrays.`;\n          statusArea.textContent = \"Partitioning done for current frame.\";\n        }\n        break;\n      case \"done\":\n        text += \"// Frame marked done (should not be visible).\";\n        statusArea.textContent = \"\";\n        break;\n      default:\n        text += \"// Unknown stage\";\n        statusArea.textContent = \"\";\n    }\n    algorithmTextPre.textContent = text;\n  }\n\n  // Update pointers display in partition step\n  function updatePointersDisplay() {\n    if(callStack.length === 0) {\n      pointersPre.textContent = \"// No active partition frame\";\n      return;\n    }\n    let frame = callStack[callStack.length-1];\n    let lines = [];\n    lines.push(\"left (start index): \" + frame.left);\n    lines.push(\"right (end index)  : \" + frame.right);\n    if(frame.pivotIndex >=0) lines.push(\"pivot index       : \" + frame.pivotIndex + \" (value: \" + workingArray[frame.pivotIndex] + \")\");\n    if(frame.stage === \"partition\") {\n      lines.push(\"i (smaller element pointer): \" + frame.i);\n      lines.push(\"j (current element pointer): \" + frame.j);\n    }\n    pointersPre.textContent = lines.join(\"\\n\");\n  }\n\n  // Update call stack display\n  function updateCallStackDisplay() {\n    if(callStackPre.style.display === \"none\") return;\n    if(callStack.length === 0) {\n      callStackPre.textContent = \"Call stack is empty.\";\n      return;\n    }\n    let lines = [];\n    let index = callStack.length-1;\n    for(let frame of callStack.slice().reverse()) {\n      lines.push(`Frame #${index--}: subarray [${frame.left} .. ${frame.right}], stage: ${frame.stage}`);\n    }\n    callStackPre.textContent = lines.join(\"\\n\");\n  }\n\n  // Update subarrays overview - shows all current frames and their subranges\n  function updateSubarraysDisplay() {\n    if(subarraysPre.style.display === \"none\") return;\n    if(callStack.length === 0) {\n      subarraysPre.textContent = \"No subarrays sorting - array sorted.\";\n      return;\n    }\n    let lines = [];\n    for(let frame of callStack) {\n      let partInfo = `Subarray [${frame.left} .. ${frame.right}]`;\n      if(frame.pivotIndex >=0) {\n        partInfo += `, pivot at ${frame.pivotIndex} (val ${workingArray[frame.pivotIndex]})`;\n      }\n      partInfo += `, stage: ${frame.stage}`;\n      lines.push(partInfo);\n    }\n    subarraysPre.textContent = lines.join(\"\\n\");\n  }\n\n  // Update the jumpToStepInput max & clear if needed (we track by history length)\n  function updateJumpToStepInputMax() {\n    jumpToStepInput.max = history.length-1;\n    if(+jumpToStepInput.value > history.length-1) jumpToStepInput.value = history.length-1;\n  }\n\n  // Repaint all on state changes\n  function repaintAll() {\n    updateArrayDisplay();\n    updateAlgorithmDescription();\n    updatePointersDisplay();\n    updateCallStackDisplay();\n    updateSubarraysDisplay();\n    updateUndoRedoButtons();\n    updateJumpToStepInputMax();\n  }\n\n  /*********************************\n   * EVENT HANDLERS AND UI BINDINGS\n   *********************************/\n\n  // Elements references\n  const arrayInput = document.getElementById(\"arrayInput\");\n  const loadArrayBtn = document.getElementById(\"loadArrayBtn\");\n  const randomArrayBtn = document.getElementById(\"randomArrayBtn\");\n  const randomSizeInput = document.getElementById(\"randomSize\");\n  const randomMaxInput = document.getElementById(\"randomMax\");\n  const pivotStrategySelect = document.getElementById(\"pivotStrategy\");\n\n  const stepBtn = document.getElementById(\"stepBtn\");\n  const autoRunBtn = document.getElementById(\"autoRunBtn\");\n  const pauseBtn = document.getElementById(\"pauseBtn\");\n  const resetBtn = document.getElementById(\"resetBtn\");\n  const speedRange = document.getElementById(\"speedRange\");\n  const speedDisplay = document.getElementById(\"speedDisplay\");\n\n  const undoBtn = document.getElementById(\"undoBtn\");\n  const redoBtn = document.getElementById(\"redoBtn\");\n  const jumpToStepInput = document.getElementById(\"jumpToStepInput\");\n  const jumpToStepBtn = document.getElementById(\"jumpToStepBtn\");\n  const showCallStackBtn = document.getElementById(\"showCallStackBtn\");\n  const showSubarraysBtn = document.getElementById(\"showSubarraysBtn\");\n\n  // Parse array from input string\n  function parseArrayInput(str) {\n    // split by comma or space, filter only integers\n    let parts = str.split(/[\\s,]+/).filter(x=>x.length>0);\n    let nums = [];\n    for(let p of parts) {\n      let n = parseInt(p,10);\n      if(isNaN(n)) return null;\n      nums.push(n);\n    }\n    return nums;\n  }\n\n  // Load array from input (reset state)\n  loadArrayBtn.addEventListener(\"click\", () => {\n    let arr = parseArrayInput(arrayInput.value);\n    if(arr === null) {\n      alert(\"Invalid input array. Only integers and separators (comma, space) allowed.\");\n      return;\n    }\n    if(arr.length > 1000) {\n      if(!confirm(\"Large array length (\" + arr.length + \") may slow down the UI. Continue?\")) return;\n    }\n    originalArray = arr.slice();\n    workingArray = arr.slice();\n    initializeQuickSort();\n    pushHistory();\n    repaintAll();\n    statusArea.textContent = \"Loaded array and ready to sort.\";\n    stopAutoRun();\n  });\n\n  // Generate random array\n  randomArrayBtn.addEventListener(\"click\", () => {\n    let size = parseInt(randomSizeInput.value,10);\n    let maxv = parseInt(randomMaxInput.value,10);\n    if(isNaN(size)||size < 1) size=10;\n    if(isNaN(maxv)||maxv<1) maxv=50;\n    if(size>1000) {\n      if(!confirm(\"Large array size (\" + size + \") may slow down the UI. Continue?\")) return;\n    }\n    let arr = [];\n    for(let i=0; i<size; i++) {\n      arr.push(Math.floor(Math.random()*maxv));\n    }\n    originalArray = arr;\n    workingArray = arr.slice();\n    arrayInput.value = arr.join(\", \");\n    initializeQuickSort();\n    pushHistory();\n    repaintAll();\n    statusArea.textContent = \"Random array generated and ready.\";\n    stopAutoRun();\n  });\n\n  // Pivot strategy selector\n  pivotStrategySelect.addEventListener(\"change\", () => {\n    currentPivotStrategyKey = pivotStrategySelect.value;\n    // Reset current sorting to apply new strategy\n    workingArray = originalArray.slice();\n    initializeQuickSort();\n    pushHistory();\n    repaintAll();\n    statusArea.textContent = \"Pivot strategy changed to '\"+currentPivotStrategyKey+\"'. Reset and ready.\";\n    stopAutoRun();\n  });\n\n  // Step one quicksort step\n  stepBtn.addEventListener(\"click\", () => {\n    stopAutoRun();\n    let prog = quickSortStep();\n    if(!prog) {\n      statusArea.textContent = \"Sorting complete.\";\n    } else {\n      statusArea.textContent = \"Step executed.\";\n    }\n    pushHistory();\n    repaintAll();\n  });\n\n  // Auto run logic\n  function startAutoRun() {\n    if(autoRunInterval !== null) return; // already running\n    autoRunInterval = setInterval(() => {\n      let prog = quickSortStep();\n      if(!prog) {\n        statusArea.textContent = \"Sorting complete (auto-run).\";\n        stopAutoRun();\n      } else {\n        pushHistory();\n      }\n      repaintAll();\n    }, +speedRange.value);\n    statusArea.textContent = \"Auto run started.\";\n  }\n  function stopAutoRun() {\n    if(autoRunInterval !== null) {\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n      statusArea.textContent = \"Auto run paused.\";\n    }\n  }\n\n  autoRunBtn.addEventListener(\"click\", () => {\n    startAutoRun();\n  });\n  pauseBtn.addEventListener(\"click\", () => {\n    stopAutoRun();\n  });\n\n  // Reset to original array and start new\n  resetBtn.addEventListener(\"click\", () => {\n    stopAutoRun();\n    workingArray = originalArray.slice();\n    initializeQuickSort();\n    pushHistory();\n    repaintAll();\n    statusArea.textContent = \"Reset to original array.\";\n  });\n\n  // Speed slider updates interval speed if auto run active\n  speedRange.addEventListener(\"input\", () => {\n    speedDisplay.textContent = speedRange.value;\n    if(autoRunInterval !== null) {\n      stopAutoRun();\n      startAutoRun();\n    }\n  });\n\n  // Undo/Redo handling\n  undoBtn.addEventListener(\"click\", () => {\n    if(historyIndex > 0) {\n      historyIndex--;\n      restoreSnapshot(history[historyIndex]);\n      repaintAll();\n      statusArea.textContent = \"Undo to step \" + historyIndex;\n      stopAutoRun();\n    }\n  });\n  redoBtn.addEventListener(\"click\", () => {\n    if(historyIndex < history.length-1) {\n      historyIndex++;\n      restoreSnapshot(history[historyIndex]);\n      repaintAll();\n      statusArea.textContent = \"Redo to step \" + historyIndex;\n      stopAutoRun();\n    }\n  });\n\n  // Jump to step\n  jumpToStepBtn.addEventListener(\"click\", () => {\n    let val = parseInt(jumpToStepInput.value,10);\n    if(isNaN(val) || val < 0 || val >= history.length) {\n      alert(\"Invalid step index\");\n      return;\n    }\n    historyIndex = val;\n    restoreSnapshot(history[historyIndex]);\n    repaintAll();\n    statusArea.textContent = \"Jumped to step \" + val;\n    stopAutoRun();\n  });\n\n  // Toggle call stack view\n  showCallStackBtn.addEventListener(\"click\", () => {\n    if(callStackPre.style.display === \"none\") {\n      callStackPre.style.display = \"block\";\n      showCallStackBtn.textContent = \"Hide Call Stack\";\n    } else {\n      callStackPre.style.display = \"none\";\n      showCallStackBtn.textContent = \"Show Call Stack\";\n    }\n    repaintAll();\n  });\n\n  // Toggle subarrays view\n  showSubarraysBtn.addEventListener(\"click\", () => {\n    if(subarraysPre.style.display === \"none\") {\n      subarraysPre.style.display = \"block\";\n      showSubarraysBtn.textContent = \"Hide Subarrays View\";\n    } else {\n      subarraysPre.style.display = \"none\";\n      showSubarraysBtn.textContent = \"Show Subarrays View\";\n    }\n    repaintAll();\n  });\n\n  // Initial load - initialize array from input field\n  function init() {\n    let arr = parseArrayInput(arrayInput.value);\n    if(arr === null || arr.length === 0) {\n      arr = [5,2,9,1,5,6];\n      arrayInput.value = arr.join(\", \");\n    }\n    originalArray = arr.slice();\n    workingArray = arr.slice();\n    initializeQuickSort();\n    pushHistory();\n    repaintAll();\n    statusArea.textContent = \"Ready to sort. Loaded initial array.\";\n  }\n\n  init();\n\n  // Keyboard shortcuts for power users\n  document.addEventListener(\"keydown\", (ev) => {\n    if(ev.target.tagName === \"INPUT\" || ev.target.tagName === \"SELECT\" || ev.target.isContentEditable) return;\n\n    if(ev.key === \"ArrowRight\") {\n      ev.preventDefault();\n      stepBtn.click();\n    } else if(ev.key === \" \") {\n      ev.preventDefault();\n      if(autoRunInterval) {\n        pauseBtn.click();\n      } else {\n        autoRunBtn.click();\n      }\n    } else if(ev.key === \"ArrowLeft\") {\n      ev.preventDefault();\n      undoBtn.click();\n    }\n  });\n\n})();\n</script>\n\n</body>\n</html>"
  },
