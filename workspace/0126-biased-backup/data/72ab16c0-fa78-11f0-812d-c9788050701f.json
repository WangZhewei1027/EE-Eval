  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);\n            margin-bottom: 3rem;\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n\n        .window {\n            position: absolute;\n            width: 200px;\n            height: 100%;\n            background: linear-gradient(45deg, rgba(116, 185, 255, 0.3), rgba(100, 200, 250, 0.5));\n            border: 1px solid rgba(116, 185, 255, 0.5);\n            backdrop-filter: blur(5px);\n            border-radius: 8px;\n            left: 0;\n            top: 0;\n            transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.3, 1);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-size: 1.5rem;\n            font-weight: 300;\n            user-select: none;\n        }\n\n        .data-stream {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: center;\n        }\n\n        .data-item {\n            background: rgba(255, 255, 255, 0.1);\n            width: 180px;\n            height: 180px;\n            margin: 0 10px;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 2rem;\n            color: var(--light);\n            font-weight: 300;\n            flex-shrink: 0;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        .data-item.highlight {\n            background: var(--accent);\n            transform: scale(1.05);\n            box-shadow: 0 10px 30px rgba(116, 185, 255, 0.5);\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 0.5s forwards;\n        }\n\n        button {\n            background: rgba(255, 255, 255, 0.1);\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            color: var(--light);\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            backdrop-filter: blur(5px);\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        button:hover {\n            background: rgba(255, 255, 255, 0.2);\n            transform: translateY(-2px);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .info-panel {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 12px;\n            padding: 2rem;\n            margin-top: 2rem;\n            max-width: 800px;\n            border: 1px solid rgba(255, 255, 255, 0.05);\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 1s forwards;\n        }\n\n        .info-panel h2 {\n            font-weight: 300;\n            margin-bottom: 1rem;\n            color: var(--accent);\n        }\n\n        .info-panel p {\n            line-height: 1.6;\n            margin-bottom: 1rem;\n            color: var(--secondary);\n        }\n\n        .visualization {\n            position: relative;\n            height: 300px;\n            width: 100%;\n            margin: 3rem 0;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 1.5s forwards;\n        }\n\n        .window-size-indicator {\n            position: absolute;\n            bottom: -30px;\n            left: 0;\n            height: 3px;\n            background: var(--accent);\n            width: 200px;\n            border-radius: 3px;\n            transition: all 0.8s cubic-bezier(0.2, 0.8, 0.3, 1);\n        }\n\n        .window-size-indicator::after {\n            content: 'Window Size';\n            position: absolute;\n            top: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 0.8rem;\n            color: var(--accent);\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes float {\n            0%, 100% {\n                transform: translateY(0);\n            }\n            50% {\n                transform: translateY(-10px);\n            }\n        }\n\n        .floating {\n            animation: float 4s ease-in-out infinite;\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n\n        @keyframes pulse {\n            0% {\n                box-shadow: 0 0 0 0 rgba(116, 185, 255, 0.4);\n            }\n            70% {\n                box-shadow: 0 0 0 15px rgba(116, 185, 255, 0);\n            }\n            100% {\n                box-shadow: 0 0 0 0 rgba(116, 185, 255, 0);\n            }\n        }\n\n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--secondary);\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1.5s ease-out 2s forwards;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Sliding Window</h1>\n            <div class=\"subtitle\">An elegant visualization of the algorithm pattern</div>\n        </header>\n\n        <div class=\"controls\">\n            <button id=\"prevBtn\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                    <polyline points=\"15 18 9 12 15 6\"></polyline>\n                </svg>\n                Previous\n            </button>\n            <button id=\"nextBtn\">\n                Next\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                    <polyline points=\"9 18 15 12 9 6\"></polyline>\n                </svg>\n            </button>\n        </div>\n\n        <div class=\"window-track\">\n            <div class=\"window floating\"></div>\n            <div class=\"data-stream\" id=\"dataStream\">\n                <!-- Data items will be inserted here by JS -->\n            </div>\n        </div>\n\n        <div class=\"window-size-indicator\"></div>\n\n        <div class=\"visualization\">\n            <div class=\"info-panel\">\n                <h2>About the Sliding Window Technique</h2>\n                <p>The sliding window technique is a method for efficiently processing arrays or lists by maintaining a subarray or subsequence that \"slides\" through the data structure.</p>\n                <p>This visualization shows how a fixed-size window moves through a sequence of elements, typically to calculate some function on each window (like sums, averages, or pattern matching).</p>\n                <p>The technique is particularly useful for problems involving contiguous subarrays or subsequences, often reducing time complexity from O(n²) to O(n).</p>\n            </div>\n        </div>\n    </div>\n\n    <footer>\n        Visual Algorithm Series | Sliding Window Pattern | Designed for Aesthetic Excellence\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Generate data items\n            const dataStream = document.getElementById('dataStream');\n            const items = [];\n            for (let i = 0; i < 20; i++) {\n                const item = document.createElement('div');\n                item.className = 'data-item';\n                item.textContent = Math.floor(Math.random() * 100);\n                dataStream.appendChild(item);\n                items.push(item);\n            }\n\n            // Position data items\n            let currentPosition = 0;\n            const windowElement = document.querySelector('.window');\n            const windowSize = 4;\n            let currentWindowStart = 0;\n\n            function updateWindow() {\n                // Highlight items in current window\n                items.forEach((item, index) => {\n                    item.classList.remove('highlight');\n                    if (index >= currentWindowStart && index < currentWindowStart + windowSize) {\n                        item.classList.add('highlight');\n                    }\n                });\n\n                // Move window indicator\n                const indicator = document.querySelector('.window-size-indicator');\n                indicator.style.left = `${currentWindowStart * 190}px`;\n\n                // Update window text\n                const windowSum = items.slice(currentWindowStart, currentWindowStart + windowSize)\n                    .reduce((sum, item) => sum + parseInt(item.textContent), 0);\n                windowElement.textContent = `Sum: ${windowSum}`;\n            }\n\n            function moveWindow(direction) {\n                if (direction === 'next' && currentWindowStart + windowSize < items.length) {\n                    currentWindowStart++;\n                } else if (direction === 'prev' && currentWindowStart > 0) {\n                    currentWindowStart--;\n                }\n                updateWindow();\n\n                // Animate window movement\n                windowElement.style.transform = `translateX(${currentWindowStart * 190}px)`;\n\n                // Pulse animation for visual feedback\n                windowElement.classList.add('pulse');\n                setTimeout(() => windowElement.classList.remove('pulse'), 2000);\n            }\n\n            // Initialize\n            updateWindow();\n\n            // Button event listeners\n            document.getElementById('nextBtn').addEventListener('click', () => moveWindow('next'));\n            document.getElementById('prevBtn').addEventListener('click', () => moveWindow('prev'));\n\n            // Auto-animate for initial demonstration\n            let autoInterval;\n            function startAutoAnimation() {\n                clearInterval(autoInterval);\n                autoInterval = setInterval(() => {\n                    if (currentWindowStart + windowSize >= items.length) {\n                        currentWindowStart = 0;\n                        windowElement.style.transition = 'none';\n                        windowElement.style.transform = `translateX(0)`;\n                        // Force reflow\n                        void windowElement.offsetWidth;\n                        windowElement.style.transition = 'transform 0.8s cubic-bezier(0.2, 0.8, 0.3, 1)';\n                    }\n                    moveWindow('next');\n                }, 1500);\n            }\n\n            // Start auto animation after initial delay\n            setTimeout(startAutoAnimation, 3000);\n\n            // Stop auto animation when user interacts\n            document.querySelectorAll('button').forEach(btn => {\n                btn.addEventListener('click', () => {\n                    clearInterval(autoInterval);\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
