  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>K-Nearest Neighbors Interactive Demo</title>\n<style>\n/* Minimal layout only to ensure readability; no colors, no animations */\nbody { font-family: sans-serif; margin: 8px; }\nsection { margin-bottom: 12px; }\nlabel { margin-right: 6px; }\ninput[type=\"number\"] { width: 70px; }\ninput[type=\"range\"] { vertical-align: middle; }\ncanvas { background: white; cursor: crosshair; }\ntextarea { width: 100%; height: 120px; }\nbutton { margin-right: 6px; margin-top: 4px; }\nselect { margin-right: 6px; }\n</style>\n</head>\n<body>\n\n<h2>K-Nearest Neighbors — Interactive Demo</h2>\n\n<section>\n<strong>Dataset controls</strong><br>\n<label>Classes: <input id=\"in-classes\" type=\"number\" value=\"3\" min=\"1\"></label>\n<label>Points/class: <input id=\"in-ppc\" type=\"number\" value=\"25\" min=\"1\"></label>\n<label>Dimensions: <input id=\"in-dims\" type=\"number\" value=\"2\" min=\"2\"></label>\n<label>Seed: <input id=\"in-seed\" type=\"number\" value=\"1\"></label>\n<label>Type:\n  <select id=\"in-type\">\n    <option value=\"classification\" selected>Classification</option>\n    <option value=\"regression\">Regression</option>\n  </select>\n</label>\n<button id=\"btn-generate\">Generate</button>\n<button id=\"btn-clear\">Clear</button>\n<button id=\"btn-default\">Load Default</button>\n<br>\n<input type=\"file\" id=\"file-load\" style=\"display:inline-block;\">\n<button id=\"btn-export-json\">Export JSON</button>\n<button id=\"btn-export-csv\">Export CSV</button>\n</section>\n\n<section>\n<strong>Mode (click canvas to act)</strong><br>\n<label><input type=\"radio\" name=\"mode\" value=\"view\" checked> View / Select</label>\n<label><input type=\"radio\" name=\"mode\" value=\"add\"> Add point</label>\n<label><input type=\"radio\" name=\"mode\" value=\"move\"> Move point</label>\n<label><input type=\"radio\" name=\"mode\" value=\"remove\"> Remove point</label>\n<label><input type=\"radio\" name=\"mode\" value=\"label\"> Set label/value</label>\n<br>\n<label>New point label/value: <input id=\"in-new-label\" type=\"text\" value=\"0\" style=\"width:60px\"></label>\n<button id=\"btn-toggle-truth\">Toggle test/train for selected</button>\n<button id=\"btn-undo\">Undo</button>\n<button id=\"btn-redo\">Redo</button>\n</section>\n\n<section>\n<strong>KNN settings</strong><br>\n<label>K: <input id=\"in-k\" type=\"range\" min=\"1\" max=\"50\" value=\"5\"><span id=\"out-k\">5</span></label>\n<label>Distance:\n  <select id=\"in-dist\">\n    <option value=\"euclidean\">Euclidean</option>\n    <option value=\"manhattan\">Manhattan</option>\n    <option value=\"chebyshev\">Chebyshev</option>\n    <option value=\"cosine\">Cosine</option>\n  </select>\n</label>\n<label>Weighting:\n  <select id=\"in-weight\">\n    <option value=\"uniform\">Uniform</option>\n    <option value=\"inverse\">Inverse distance</option>\n    <option value=\"gaussian\">Gaussian</option>\n  </select>\n</label>\n<label>Normalize:\n  <select id=\"in-norm\">\n    <option value=\"none\">None</option>\n    <option value=\"minmax\">Min-Max</option>\n    <option value=\"zscore\">Z-score</option>\n  </select>\n</label>\n<label>Tie break:\n  <select id=\"in-tie\">\n    <option value=\"lowest\">Lowest label</option>\n    <option value=\"closest\">Closest neighbor</option>\n    <option value=\"random\">Random</option>\n  </select>\n</label>\n<button id=\"btn-classify-selected\">Explain prediction for selected point</button>\n<button id=\"btn-predict-all\">Predict all unlabeled (assign)</button>\n</section>\n\n<section>\n<strong>Visualization / projection</strong><br>\n<label>Feature X:\n  <select id=\"sel-x\"></select>\n</label>\n<label>Feature Y:\n  <select id=\"sel-y\"></select>\n</label>\n<label>Grid resolution: <input id=\"in-res\" type=\"number\" value=\"30\" min=\"5\" max=\"100\"></label>\n<button id=\"btn-compute-grid\">Compute decision grid</button>\n<button id=\"btn-clear-grid\">Clear grid</button>\n<label><input id=\"chk-show-neighbors\" type=\"checkbox\"> Show neighbors when hovering</label>\n</section>\n\n<section>\n<strong>Data splitting & validation</strong><br>\n<label>Test fraction: <input id=\"in-testfrac\" type=\"range\" min=\"0\" max=\"0.9\" step=\"0.01\" value=\"0.3\"><span id=\"out-testfrac\">0.30</span></label>\n<button id=\"btn-split\">Split dataset</button>\n<label>CV folds: <input id=\"in-folds\" type=\"number\" min=\"2\" value=\"5\" style=\"width:60px\"></label>\n<button id=\"btn-cv\">Run Cross-Validation</button>\n<button id=\"btn-sweep\">Hyperparameter sweep (k)</button>\n<input id=\"in-sweep-max\" type=\"number\" value=\"25\" min=\"1\" style=\"width:70px\">\n</section>\n\n<section>\n<strong>Canvas (click to interact)</strong><br>\n<canvas id=\"canvas\" width=\"640\" height=\"480\"></canvas>\n<div>\n<button id=\"btn-center\">Center view</button>\n<button id=\"btn-scale\">Auto-scale to features</button>\n</div>\n</section>\n\n<section>\n<strong>Selected point / Details</strong>\n<div>\n<label>Selected ID: <span id=\"sel-id\">none</span></label><br>\n<textarea id=\"txt-details\" readonly></textarea>\n</div>\n</section>\n\n<section>\n<strong>Metrics and output</strong><br>\n<textarea id=\"txt-output\" readonly></textarea>\n</section>\n\n<script>\n/*\n  K-Nearest Neighbors interactive demo\n  - Many user controls and workflows\n  - Minimal visual design (black on white, simple elements)\n*/\n\n(function(){\n\n// Utilities\nfunction rand(seed) {\n  // simple LCG\n  seed = seed | 0;\n  return function() {\n    seed = (seed * 1664525 + 1013904223) >>> 0;\n    return seed / 4294967296;\n  }\n}\nfunction shuffle(a, rng) {\n  for (let i = a.length-1; i>0; i--) {\n    const j = Math.floor(rng()* (i+1));\n    [a[i], a[j]] = [a[j], a[i]];\n  }\n}\n\nfunction clone(obj){ return JSON.parse(JSON.stringify(obj)); }\nfunction uniqueId(){ return Math.floor(Math.random()*1e9).toString(36); }\n\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\n\nconst state = {\n  points: [], // {id, x:[], label (for classification), value (for regression), split: 'train'|'test'|'unlabeled'}\n  dims: 2,\n  type: 'classification',\n  selected: null,\n  mode: 'view',\n  grid: null, // {preds:[], res, xRange,yRange}\n  undoStack: [],\n  redoStack: [],\n  settings: {\n    k: 5,\n    dist: 'euclidean',\n    weight: 'uniform',\n    norm: 'none',\n    tie: 'lowest'\n  },\n  view: { padding: 0.06 } // for auto scaling\n};\n\n// DOM refs\nconst inClasses = document.getElementById('in-classes');\nconst inPpc = document.getElementById('in-ppc');\nconst inDims = document.getElementById('in-dims');\nconst inSeed = document.getElementById('in-seed');\nconst inType = document.getElementById('in-type');\nconst btnGenerate = document.getElementById('btn-generate');\nconst btnClear = document.getElementById('btn-clear');\nconst btnDefault = document.getElementById('btn-default');\nconst fileLoad = document.getElementById('file-load');\nconst btnExportJSON = document.getElementById('btn-export-json');\nconst btnExportCSV = document.getElementById('btn-export-csv');\n\nconst modes = document.getElementsByName('mode');\nconst inNewLabel = document.getElementById('in-new-label');\nconst btnToggleTruth = document.getElementById('btn-toggle-truth');\nconst btnUndo = document.getElementById('btn-undo');\nconst btnRedo = document.getElementById('btn-redo');\n\nconst inK = document.getElementById('in-k');\nconst outK = document.getElementById('out-k');\nconst inDist = document.getElementById('in-dist');\nconst inWeight = document.getElementById('in-weight');\nconst inNorm = document.getElementById('in-norm');\nconst inTie = document.getElementById('in-tie');\nconst btnExplain = document.getElementById('btn-classify-selected');\nconst btnPredictAll = document.getElementById('btn-predict-all');\n\nconst selX = document.getElementById('sel-x');\nconst selY = document.getElementById('sel-y');\nconst inRes = document.getElementById('in-res');\nconst btnComputeGrid = document.getElementById('btn-compute-grid');\nconst btnClearGrid = document.getElementById('btn-clear-grid');\nconst chkShowNeighbors = document.getElementById('chk-show-neighbors');\n\nconst inTestFrac = document.getElementById('in-testfrac');\nconst outTestFrac = document.getElementById('out-testfrac');\nconst btnSplit = document.getElementById('btn-split');\nconst inFolds = document.getElementById('in-folds');\nconst btnCV = document.getElementById('btn-cv');\nconst btnSweep = document.getElementById('btn-sweep');\nconst inSweepMax = document.getElementById('in-sweep-max');\n\nconst btnCenter = document.getElementById('btn-center');\nconst btnScale = document.getElementById('btn-scale');\n\nconst selId = document.getElementById('sel-id');\nconst txtDetails = document.getElementById('txt-details');\nconst txtOutput = document.getElementById('txt-output');\n\nconst fileReader = new FileReader();\n\n// Initialize UI components\nfunction initFeatureSelectors() {\n  selX.innerHTML = '';\n  selY.innerHTML = '';\n  for (let i=0;i<state.dims;i++) {\n    const optX = document.createElement('option');\n    optX.value = i; optX.text = 'f' + i;\n    const optY = optX.cloneNode(true);\n    selX.appendChild(optX);\n    selY.appendChild(optY);\n  }\n  selY.value = Math.min(1,state.dims-1);\n}\n\n// Undo/redo\nfunction pushUndo() {\n  state.undoStack.push(clone({points: state.points, settings: state.settings}));\n  if (state.undoStack.length>200) state.undoStack.shift();\n  state.redoStack = [];\n}\nfunction undo() {\n  if (!state.undoStack.length) return;\n  state.redoStack.push(clone({points: state.points, settings: state.settings}));\n  const prev = state.undoStack.pop();\n  state.points = clone(prev.points);\n  state.settings = prev.settings;\n  redraw();\n}\nfunction redo() {\n  if (!state.redoStack.length) return;\n  state.undoStack.push(clone({points: state.points, settings: state.settings}));\n  const nxt = state.redoStack.pop();\n  state.points = clone(nxt.points);\n  state.settings = nxt.settings;\n  redraw();\n}\n\n// Dataset generation\nfunction generateDataset() {\n  const classes = Math.max(1, parseInt(inClasses.value));\n  const ppc = Math.max(1, parseInt(inPpc.value));\n  const dims = Math.max(2, parseInt(inDims.value));\n  const seed = parseInt(inSeed.value) || 1;\n  const type = inType.value;\n  state.dims = dims;\n  state.type = type;\n  initFeatureSelectors();\n  pushUndo();\n  state.points = [];\n  const rng = rand(seed);\n  // create cluster centers spread on grid\n  const radius = 1.0;\n  for (let c=0;c<classes;c++){\n    const angle = (c/(classes))*Math.PI*2;\n    const center = [];\n    for (let d=0;d<dims;d++){\n      // mix periodic center to get spread\n      center.push(Math.sin(angle + d) * 3 + (d*0.5));\n    }\n    for (let i=0;i<ppc;i++){\n      const p = { id: uniqueId(), x: [], split: 'train' };\n      for (let d=0;d<dims;d++){\n        p.x.push(center[d] + (rng()-0.5)*radius*3 + (rng()-0.5));\n      }\n      if (type === 'classification') {\n        p.label = c;\n      } else {\n        // regression: value around class index with noise\n        p.value = c + (rng()-0.5)*1.5;\n      }\n      state.points.push(p);\n    }\n  }\n  // add some unlabeled points\n  for (let i=0;i<Math.floor(classes*ppc*0.05);i++){\n    const p = { id: uniqueId(), x: [], split: 'unlabeled' };\n    for (let d=0;d<dims;d++){\n      p.x.push((Math.random()-0.5)*6 + (d*0.5));\n    }\n    state.points.push(p);\n  }\n  state.grid = null;\n  redraw();\n  log('Generated dataset: classes=' + classes + ', points/class=' + ppc + ', dims=' + dims);\n}\n\n// Export / import\nfunction exportJSON() {\n  const data = {\n    points: state.points,\n    dims: state.dims,\n    type: state.type\n  };\n  const blob = new Blob([JSON.stringify(data)], {type: 'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'knn_dataset.json'; document.body.appendChild(a);\n  a.click(); a.remove();\n  URL.revokeObjectURL(url);\n}\nfunction exportCSV() {\n  if (!state.points.length) { log('No points to export'); return; }\n  let header = [];\n  for (let d=0;d<state.dims;d++) header.push('f'+d);\n  if (state.type === 'classification') header.push('label');\n  else header.push('value');\n  header.push('split');\n  const rows = [header.join(',')];\n  state.points.forEach(p=>{\n    const vals = p.x.map(v=>v.toString());\n    if (state.type==='classification') vals.push(('label' in p)?p.label:'');\n    else vals.push(('value' in p)?p.value:'');\n    vals.push(p.split||'');\n    rows.push(vals.join(','));\n  });\n  const blob = new Blob([rows.join('\\n')], {type:'text/csv'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'knn_dataset.csv'; document.body.appendChild(a);\n  a.click(); a.remove(); URL.revokeObjectURL(url);\n}\nfileLoad.addEventListener('change', (ev)=>{\n  const file = ev.target.files[0];\n  if (!file) return;\n  fileReader.onload = () => {\n    try {\n      const text = fileReader.result;\n      if (file.name.toLowerCase().endsWith('.json')) {\n        const obj = JSON.parse(text);\n        if (!obj.points) throw('Invalid file');\n        pushUndo();\n        state.points = obj.points;\n        state.dims = obj.dims || state.dims;\n        state.type = obj.type || state.type;\n        initFeatureSelectors();\n        redraw();\n        log('Loaded JSON dataset from file');\n      } else {\n        // treat as CSV\n        const lines = text.trim().split(/\\r?\\n/).map(s=>s.trim()).filter(Boolean);\n        const header = lines[0].split(',');\n        const dims = header.filter(h=>h.startsWith('f')).length;\n        const points = [];\n        for (let i=1;i<lines.length;i++){\n          const vals = lines[i].split(',');\n          const p = {id:uniqueId(), x: [], split: 'train'};\n          for (let d=0; d<dims; d++) p.x.push(parseFloat(vals[d]));\n          if (header.includes('label')) p.label = vals[header.indexOf('label')]===''?undefined:vals[header.indexOf('label')];\n          if (header.includes('value')) p.value = vals[header.indexOf('value')]===''?undefined:parseFloat(vals[header.indexOf('value')]);\n          if (header.includes('split')) p.split = vals[header.indexOf('split')] || 'train';\n          points.push(p);\n        }\n        pushUndo();\n        state.points = points;\n        state.dims = dims;\n        initFeatureSelectors();\n        redraw();\n        log('Loaded CSV dataset');\n      }\n    } catch (e) {\n      log('Load error: '+e);\n    }\n  };\n  fileReader.readAsText(file);\n});\n\n// Mode handling\nmodes.forEach(r=>r.addEventListener('change', ()=>{\n  state.mode = document.querySelector('input[name=\"mode\"]:checked').value;\n  log('Mode: ' + state.mode);\n}));\ninNewLabel.addEventListener('change', ()=>{ /* nothing */ });\nbtnToggleTruth.addEventListener('click', ()=>{\n  if (!state.selected) { log('Select a point first'); return; }\n  pushUndo();\n  const p = state.points.find(u=>u.id===state.selected);\n  if (!p) return;\n  p.split = (p.split==='train'?'test':'train');\n  redraw();\n  log('Toggled split for selected point: ' + p.split);\n});\nbtnUndo.addEventListener('click', undo);\nbtnRedo.addEventListener('click', redo);\n\n// K settings\ninK.addEventListener('input', ()=>{ state.settings.k = parseInt(inK.value); outK.textContent = inK.value; redraw(); });\ninDist.addEventListener('change', ()=>{ state.settings.dist = inDist.value; redraw(); });\ninWeight.addEventListener('change', ()=>{ state.settings.weight = inWeight.value; redraw(); });\ninNorm.addEventListener('change', ()=>{ state.settings.norm = inNorm.value; redraw(); });\ninTie.addEventListener('change', ()=>{ state.settings.tie = inTie.value; redraw(); });\n\n// Visualization selectors\nfunction getSelectedFeatures() {\n  const xi = parseInt(selX.value || 0);\n  const yi = parseInt(selY.value || Math.min(1,state.dims-1));\n  return [xi, yi];\n}\n\n// Canvas interactions\nlet dragging = null;\nlet dragOffset = null;\n\ncanvas.addEventListener('mousedown', (ev)=>{\n  const rect = canvas.getBoundingClientRect();\n  const mx = ev.clientX - rect.left;\n  const my = ev.clientY - rect.top;\n  const coords = canvasToData(mx,my);\n  if (state.mode === 'add') {\n    pushUndo();\n    const p = { id: uniqueId(), x: Array.from({length: state.dims}, ()=>0), split: 'train' };\n    const [xi,yi] = getSelectedFeatures();\n    p.x[xi] = coords[0];\n    p.x[yi] = coords[1];\n    // set other dims to mean\n    const means = featureMeans();\n    for (let d=0; d<state.dims; d++) if (d!==xi && d!==yi) p.x[d]=means[d];\n    if (state.type==='classification') {\n      const lab = inNewLabel.value;\n      p.label = isNaN(Number(lab)) ? lab : Number(lab);\n    } else {\n      const val = Number(inNewLabel.value);\n      p.value = isNaN(val) ? 0 : val;\n    }\n    state.points.push(p);\n    state.selected = p.id;\n    redraw();\n  } else if (state.mode === 'remove') {\n    const hit = hitTest(mx,my);\n    if (hit) {\n      pushUndo();\n      state.points = state.points.filter(pt=>pt.id!==hit.id);\n      state.selected = null;\n      redraw();\n    }\n  } else if (state.mode === 'move') {\n    const hit = hitTest(mx,my);\n    if (hit) {\n      dragging = hit;\n      dragOffset = {mx: mx, my: my};\n      state.selected = hit.id;\n    }\n  } else if (state.mode === 'label') {\n    const hit = hitTest(mx,my);\n    if (hit) {\n      pushUndo();\n      if (state.type==='classification') {\n        const lab = inNewLabel.value;\n        hit.label = isNaN(Number(lab)) ? lab : Number(lab);\n      } else {\n        const val = Number(inNewLabel.value);\n        hit.value = isNaN(val) ? 0 : val;\n      }\n      state.selected = hit.id;\n      redraw();\n    }\n  } else { // view/select\n    const hit = hitTest(mx,my);\n    if (hit) {\n      state.selected = hit.id;\n      if (chkShowNeighbors.checked) {\n        // nothing extra here; redraw will show neighbors when hovered\n      }\n      redraw();\n      showDetailsForSelected();\n    } else {\n      state.selected = null;\n      redraw();\n    }\n  }\n});\ncanvas.addEventListener('mousemove', (ev)=>{\n  if (!dragging) return;\n  const rect = canvas.getBoundingClientRect();\n  const mx = ev.clientX - rect.left;\n  const my = ev.clientY - rect.top;\n  const dx = mx - dragOffset.mx;\n  const dy = my - dragOffset.my;\n  dragOffset.mx = mx; dragOffset.my = my;\n  const [x,y] = canvasToData(mx,my);\n  // update dragging point coordinates for selected features; preserve others\n  const [xi, yi] = getSelectedFeatures();\n  pushUndo(); // one small push per drag step may be noisy but safe\n  dragging.x[xi] = x;\n  dragging.x[yi] = y;\n  redraw();\n});\ncanvas.addEventListener('mouseup', ()=>{ dragging = null; dragOffset = null; });\ncanvas.addEventListener('mouseleave', ()=>{ dragging = null; dragOffset = null; });\n\n// helper to pick point near mouse\nfunction hitTest(mx,my) {\n  const [xv,yv] = canvasToData(mx,my);\n  let closest = null;\n  let minDist = Infinity;\n  const [xi,yi] = getSelectedFeatures();\n  for (let p of state.points) {\n    const dx = (p.x[xi] - xv);\n    const dy = (p.x[yi] - yv);\n    const d2 = dx*dx + dy*dy;\n    if (d2 < minDist && d2 < 0.1) { // threshold relative to data units (rough)\n      minDist = d2; closest = p;\n    }\n  }\n  return closest;\n}\n\n// coordinate transforms between data and canvas (based on selected features)\nfunction computeRanges() {\n  const [xi, yi] = getSelectedFeatures();\n  let xmin=Infinity,xmax=-Infinity,ymin=Infinity,ymax=-Infinity;\n  if (!state.points.length) {\n    xmin = -5; xmax = 5; ymin = -5; ymax = 5;\n  } else {\n    for (let p of state.points) {\n      const x = p.x[xi], y = p.x[yi];\n      if (x < xmin) xmin = x; if (x > xmax) xmax = x;\n      if (y < ymin) ymin = y; if (y > ymax) ymax = y;\n    }\n    if (xmin===xmax) { xmin -= 1; xmax += 1; }\n    if (ymin===ymax) { ymin -= 1; ymax += 1; }\n  }\n  // padding\n  const px = (xmax - xmin) * state.view.padding;\n  const py = (ymax - ymin) * state.view.padding;\n  return {xmin: xmin - px, xmax: xmax + px, ymin: ymin - py, ymax: ymax + py};\n}\nfunction dataToCanvas(x,y) {\n  const r = computeRanges();\n  const sx = (x - r.xmin) / (r.xmax - r.xmin);\n  const sy = 1 - (y - r.ymin) / (r.ymax - r.ymin);\n  return [sx * canvas.width, sy * canvas.height];\n}\nfunction canvasToData(mx,my) {\n  const r = computeRanges();\n  const sx = mx / canvas.width;\n  const sy = 1 - (my / canvas.height);\n  const x = r.xmin + sx * (r.xmax - r.xmin);\n  const y = r.ymin + sy * (r.ymax - r.ymin);\n  return [x,y];\n}\n\n// drawing\nfunction redraw() {\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  // draw grid decision map if present (rendered as text)\n  if (state.grid && state.grid.preds) {\n    const res = state.grid.res;\n    const cellW = canvas.width / res;\n    const cellH = canvas.height / res;\n    const preds = state.grid.preds;\n    ctx.font = Math.max(8, Math.min(16, Math.floor(Math.min(cellW,cellH)*0.6))) + 'px sans-serif';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n    for (let j=0;j<res;j++){\n      for (let i=0;i<res;i++){\n        const val = preds[j*res + i];\n        const cx = i*cellW + cellW/2;\n        const cy = j*cellH + cellH/2;\n        ctx.fillStyle = 'black';\n        ctx.fillText(String(val), cx, cy);\n      }\n    }\n  }\n\n  // axes tick marks (draw simple labels)\n  ctx.font = '12px sans-serif';\n  ctx.textAlign = 'left';\n  ctx.textBaseline = 'top';\n  const r = computeRanges();\n  ctx.fillStyle = 'black';\n  ctx.fillText('x:' + r.xmin.toFixed(2) + ' .. ' + r.xmax.toFixed(2), 4, 4);\n  ctx.fillText('y:' + r.ymin.toFixed(2) + ' .. ' + r.ymax.toFixed(2), 4, 18);\n\n  // draw all points\n  for (let p of state.points) {\n    drawPoint(p);\n  }\n\n  // if selected and show neighbors, draw neighbor info\n  if (state.selected) {\n    const p = state.points.find(pt=>pt.id===state.selected);\n    if (p && chkShowNeighbors.checked) {\n      const neighbors = findNeighborsForPoint(p);\n      // draw lines to neighbors and mark neighbor indices\n      const [xi, yi] = getSelectedFeatures();\n      const [px,py] = dataToCanvas(p.x[xi], p.x[yi]);\n      ctx.strokeStyle = 'black';\n      ctx.lineWidth = 1;\n      for (let i=0;i<neighbors.length;i++){\n        const n = neighbors[i];\n        const [nx,ny] = dataToCanvas(n.x[xi], n.x[yi]);\n        ctx.beginPath();\n        ctx.moveTo(px,py); ctx.lineTo(nx,ny); ctx.stroke();\n        // draw small label for neighbor order\n        ctx.fillStyle = 'black';\n        ctx.fillRect(nx-6, ny-6, 12, 12);\n        ctx.fillStyle = 'white';\n        ctx.font = '10px sans-serif';\n        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';\n        ctx.fillText(String(i+1), nx, ny);\n      }\n    }\n  }\n}\n\nfunction drawPoint(p) {\n  const [xi, yi] = getSelectedFeatures();\n  const [cx,cy] = dataToCanvas(p.x[xi], p.x[yi]);\n  ctx.lineWidth = 1;\n  ctx.strokeStyle = 'black';\n  ctx.fillStyle = 'black';\n  // shape depends on label or index\n  if (state.type === 'classification') {\n    const lab = ('label' in p) ? p.label : '-';\n    // choose shape by hash of label\n    let shape = 0;\n    if (typeof lab === 'number') shape = Math.abs(lab) % 5;\n    else shape = (String(lab).length % 5);\n    // different shapes\n    if (shape === 0) { // circle filled\n      ctx.beginPath(); ctx.arc(cx,cy,6,0,Math.PI*2); ctx.fill();\n    } else if (shape === 1) { // cross\n      ctx.beginPath(); ctx.moveTo(cx-6,cy-6); ctx.lineTo(cx+6,cy+6); ctx.moveTo(cx-6,cy+6); ctx.lineTo(cx+6,cy-6); ctx.stroke();\n    } else if (shape === 2) { // square\n      ctx.strokeRect(cx-6, cy-6, 12, 12);\n    } else if (shape === 3) { // triangle\n      ctx.beginPath(); ctx.moveTo(cx,cy-7); ctx.lineTo(cx-7,cy+6); ctx.lineTo(cx+7,cy+6); ctx.closePath(); ctx.stroke();\n    } else { // text label\n      ctx.font = '10px sans-serif';\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillText(String(lab), cx, cy);\n    }\n  } else {\n    // regression: draw small dot and number\n    ctx.beginPath(); ctx.arc(cx,cy,4,0,Math.PI*2); ctx.fill();\n    ctx.font = '10px sans-serif';\n    ctx.textAlign = 'left';\n    ctx.textBaseline = 'top';\n    const v = ('value' in p) ? p.value : '';\n    ctx.fillText(v.toFixed? (p.value? p.value.toFixed(2): '') : String(v), cx+6, cy+6);\n  }\n  // mark test points with square marker\n  if (p.split === 'test') {\n    ctx.strokeRect(cx+8, cy-8, 8, 8);\n  }\n  // selection ring\n  if (state.selected === p.id) {\n    ctx.beginPath(); ctx.arc(cx,cy,10,0,Math.PI*2); ctx.stroke();\n    selId.textContent = p.id;\n  }\n}\n\n// compute feature means\nfunction featureMeans() {\n  const means = Array(state.dims).fill(0);\n  if (!state.points.length) return means;\n  for (let d=0; d<state.dims; d++) {\n    let s=0, count=0;\n    for (let p of state.points) { s += (p.x[d] || 0); count++; }\n    means[d] = s/count;\n  }\n  return means;\n}\n\n// KNN core\nfunction prepareDataForDistances() {\n  // returns array of normalized feature arrays depending on norm setting\n  const norm = state.settings.norm;\n  const Xtrain = state.points.map(p=>p.x.slice());\n  const dims = state.dims;\n  const res = {X: Xtrain, normParams: null};\n  if (norm === 'none') return res;\n  const params = {min: Array(dims), max: Array(dims), mean: Array(dims), std: Array(dims)};\n  for (let d=0; d<dims; d++){\n    const vals = Xtrain.map(r=>r[d]);\n    const mn = Math.min(...vals);\n    const mx = Math.max(...vals);\n    const mu = vals.reduce((a,b)=>a+b,0)/vals.length;\n    const sd = Math.sqrt(vals.reduce((s,v)=>s+(v-mu)*(v-mu),0)/vals.length);\n    params.min[d] = mn; params.max[d] = mx; params.mean[d] = mu; params.std[d] = sd || 1;\n    if (norm==='minmax') {\n      for (let i=0;i<Xtrain.length;i++) {\n        Xtrain[i][d] = (Xtrain[i][d] - mn) / (mx - mn || 1);\n      }\n    } else if (norm==='zscore') {\n      for (let i=0;i<Xtrain.length;i++) {\n        Xtrain[i][d] = (Xtrain[i][d] - mu) / (params.std[d] || 1);\n      }\n    }\n  }\n  res.X = Xtrain;\n  res.normParams = params;\n  return res;\n}\n\nfunction normalizePoint(x, params, method) {\n  if (!params || method==='none') return x.slice();\n  if (method==='minmax') {\n    return x.map((v,i)=> (v - params.min[i]) / (params.max[i] - params.min[i] || 1));\n  } else if (method==='zscore') {\n    return x.map((v,i)=> (v - params.mean[i]) / (params.std[i] || 1));\n  }\n  return x.slice();\n}\n\nfunction distance(a,b,method) {\n  if (!a || !b) return Infinity;\n  if (method==='euclidean') {\n    let s=0; for (let i=0;i<a.length;i++){ const d=a[i]-b[i]; s+=d*d;} return Math.sqrt(s);\n  } else if (method==='manhattan') {\n    let s=0; for (let i=0;i<a.length;i++){ s+=Math.abs(a[i]-b[i]); } return s;\n  } else if (method==='chebyshev') {\n    let m=0; for (let i=0;i<a.length;i++){ m = Math.max(m, Math.abs(a[i]-b[i])); } return m;\n  } else if (method==='cosine') {\n    let da=0, db=0, dot=0;\n    for (let i=0;i<a.length;i++){ dot += a[i]*b[i]; da+=a[i]*a[i]; db+=b[i]*b[i]; }\n    if (da===0 || db===0) return 1; return 1 - dot / (Math.sqrt(da)*Math.sqrt(db));\n  }\n  return Infinity;\n}\n\nfunction findNeighborsForPoint(p) {\n  // returns array of neighbor point objects (k nearest using current settings)\n  const k = Math.max(1, state.settings.k);\n  const all = state.points.filter(pt=>pt.id!==p.id && (pt.split === 'train' || pt.split === undefined || pt.split === 'train'));\n  if (!all.length) return [];\n  const prepared = prepareDataForDistances();\n  const params = prepared.normParams;\n  const method = state.settings.norm;\n  const px = normalizePoint(p.x, params, method);\n  const distMethod = state.settings.dist;\n  const dlist = all.map(pt=>{\n    const nx = normalizePoint(pt.x, params, method);\n    const d = distance(px, nx, distMethod);\n    return {pt: pt, d: d};\n  });\n  dlist.sort((a,b)=>a.d - b.d);\n  return dlist.slice(0,k).map(x=>x.pt);\n}\n\nfunction predictForPoint(p, options={explain:false}) {\n  // return predicted label or value and optionally explanation\n  const prepared = prepareDataForDistances();\n  const params = prepared.normParams;\n  const method = state.settings.norm;\n  const px = normalizePoint(p.x, params, method);\n  const candidates = [];\n  for (let pt of state.points) {\n    if (pt.id === p.id) continue;\n    if (pt.split !== 'train' && pt.split!=='train' && pt.split!=='') {\n      // only use train points as neighbors\n    }\n    if (pt.split !== 'train') continue;\n    const nx = normalizePoint(pt.x, params, method);\n    const d = distance(px, nx, state.settings.dist);\n    candidates.push({d: d, pt: pt});\n  }\n  candidates.sort((a,b)=>a.d - b.d);\n  const k = Math.max(1, state.settings.k);\n  const neighbors = candidates.slice(0,k);\n  // weighting\n  const weights = neighbors.map(n=>{\n    if (state.settings.weight === 'uniform') return 1;\n    if (state.settings.weight === 'inverse') return 1 / (n.d + 1e-6);\n    if (state.settings.weight === 'gaussian') return Math.exp(-(n.d*n.d)/(2*1.0));\n    return 1;\n  });\n  if (state.type === 'classification') {\n    // aggregate by label\n    const counts = {};\n    for (let i=0;i<neighbors.length;i++){\n      const lab = neighbors[i].pt.label;\n      const w = weights[i];\n      counts[lab] = (counts[lab]||0) + w;\n    }\n    // find max\n    let bestLabel = null;\n    let bestScore = -Infinity;\n    for (let klabel in counts) {\n      if (counts[klabel] > bestScore) { bestScore = counts[klabel]; bestLabel = klabel; }\n      else if (counts[klabel] === bestScore) {\n        // tie-break\n        if (state.settings.tie === 'lowest') {\n          if (klabel < bestLabel) bestLabel = klabel;\n        } else if (state.settings.tie === 'closest') {\n          // choose label of closest neighbor among those tied\n          for (let n of neighbors) { if (String(n.pt.label)===klabel) { bestLabel = klabel; break; } }\n        } else if (state.settings.tie === 'random') {\n          if (Math.random() < 0.5) bestLabel = klabel;\n        }\n      }\n    }\n    return {pred: bestLabel, neighbors: neighbors.map(n=>({id:n.pt.id,d:n.d,label:n.pt.label}))};\n  } else {\n    // regression: weighted average\n    let num=0, den=0;\n    for (let i=0;i<neighbors.length;i++){\n      const w = weights[i];\n      const val = neighbors[i].pt.value || 0;\n      num += w * val; den += w;\n    }\n    const pred = den? num/den : (neighbors.length? neighbors[0].pt.value : 0);\n    return {pred: pred, neighbors: neighbors.map(n=>({id:n.pt.id,d:n.d,value:n.pt.value}))};\n  }\n}\n\n// UI actions\nbtnGenerate.addEventListener('click', generateDataset);\nbtnClear.addEventListener('click', ()=>{\n  pushUndo();\n  state.points = [];\n  state.grid = null;\n  redraw();\n  log('Cleared dataset');\n});\nbtnDefault.addEventListener('click', ()=>{\n  inClasses.value = 3; inPpc.value = 25; inDims.value = 2; inSeed.value = 2; inType.value = 'classification';\n  generateDataset();\n});\n\nbtnExportJSON.addEventListener('click', exportJSON);\nbtnExportCSV.addEventListener('click', exportCSV);\n\n// classification explanation\nbtnExplain.addEventListener('click', ()=>{\n  if (!state.selected) { log('Select a point first'); return; }\n  const p = state.points.find(pt=>pt.id===state.selected);\n  if (!p) { log('Selected point not found'); return; }\n  const res = predictForPoint(p, {explain:true});\n  let out = 'Prediction for selected point (id='+p.id+'): \\n';\n  out += 'Predicted: ' + String(res.pred) + '\\n';\n  out += 'Neighbors:\\n';\n  res.neighbors.forEach((n,i)=>{\n    out += (i+1) + '. id=' + n.id + ', dist=' + n.d.toFixed(4);\n    if ('label' in n) out += ', label=' + n.label;\n    if ('value' in n) out += ', value=' + n.value;\n    out += '\\n';\n  });\n  txtDetails.value = out;\n  log('Explained prediction for selected point');\n});\n\n// predict all unlabeled or test set\nbtnPredictAll.addEventListener('click', ()=>{\n  if (!state.points.length) { log('No points'); return; }\n  pushUndo();\n  let count=0;\n  for (let p of state.points) {\n    if (state.type === 'classification') {\n      if (p.label === undefined || p.label === null) {\n        const res = predictForPoint(p);\n        p.label = res.pred;\n        count++;\n      }\n    } else {\n      if (p.value === undefined || p.value === null) {\n        const res = predictForPoint(p);\n        p.value = res.pred;\n        count++;\n      }\n    }\n  }\n  redraw();\n  log('Assigned predictions to ' + count + ' unlabeled points');\n});\n\n// grid decision map\nbtnComputeGrid.addEventListener('click', ()=>{\n  const res = Math.max(5, Math.min(100, parseInt(inRes.value)));\n  const [xi, yi] = getSelectedFeatures();\n  const ranges = computeRanges();\n  const preds = [];\n  pushUndo();\n  // for each grid cell, map to feature space point (other dims = mean)\n  const dims = state.dims;\n  const means = featureMeans();\n  for (let j=0;j<res;j++){\n    for (let i=0;i<res;i++){\n      const sx = (i + 0.5)/res;\n      const sy = 1 - (j + 0.5)/res;\n      const x = ranges.xmin + sx*(ranges.xmax - ranges.xmin);\n      const y = ranges.ymin + sy*(ranges.ymax - ranges.ymin);\n      const p = {id: 'grid_'+i+'_'+j, x: Array(dims).fill(0) };\n      for (let d=0; d<dims; d++) p.x[d] = means[d];\n      p.x[xi] = x; p.x[yi] = y;\n      const pred = predictForPoint(p);\n      preds.push(pred.pred);\n    }\n  }\n  state.grid = {preds: preds, res: res, xRange: [ranges.xmin, ranges.xmax], yRange: [ranges.ymin, ranges.ymax], features: [xi, yi]};\n  redraw();\n  log('Computed decision grid, resolution=' + res);\n});\nbtnClearGrid.addEventListener('click', ()=>{ state.grid = null; redraw(); });\n\n// split and CV\ninTestFrac.addEventListener('input', ()=>{ outTestFrac.textContent = parseFloat(inTestFrac.value).toFixed(2); });\nbtnSplit.addEventListener('click', ()=>{\n  if (!state.points.length) { log('No points to split'); return; }\n  pushUndo();\n  const frac = parseFloat(inTestFrac.value);\n  const rng = rand(Date.now() % 1000000);\n  const shuffled = state.points.slice();\n  shuffle(shuffled, rng);\n  const testCount = Math.floor(shuffled.length * frac);\n  for (let i=0;i<shuffled.length;i++){\n    shuffled[i].split = (i < testCount ? 'test' : 'train');\n  }\n  // copy back splits\n  for (let p of state.points) {\n    const sp = shuffled.find(s=>s.id===p.id);\n    if (sp) p.split = sp.split;\n  }\n  redraw();\n  log('Split dataset: test fraction=' + frac);\n});\n\nbtnCV.addEventListener('click', ()=>{\n  const folds = Math.max(2, parseInt(inFolds.value || 5));\n  if (!state.points.length) { log('No points'); return; }\n  // Only use labeled points for CV\n  const labeled = state.points.filter(p => (state.type==='classification' ? ('label' in p && p.label !== undefined) : ('value' in p && p.value !== undefined)));\n  if (labeled.length < folds) { log('Not enough labeled points for ' + folds + ' folds'); return; }\n  const rng = rand(1);\n  const idx = labeled.map((v,i)=>i);\n  shuffle(idx, rng);\n  const foldSize = Math.floor(labeled.length / folds);\n  const results = [];\n  pushUndo();\n  for (let f=0; f<folds; f++){\n    const testIdx = idx.slice(f*foldSize, (f+1)*foldSize);\n    const trainIdx = idx.filter(i=>!testIdx.includes(i));\n    // create temp train/test splits\n    const tmp = labeled.map((p,i)=>{\n      return {id: p.id, x: p.x.slice(), label: p.label, value: p.value, split: trainIdx.includes(i)?'train':'test'};\n    });\n    // compute metrics\n    const preds = [];\n    for (let iTest of testIdx) {\n      const pTest = tmp[iTest];\n      // build points array for predict function\n      // simulate global state by substituting state.points with tmp set\n      const originalPoints = state.points;\n      state.points = tmp;\n      const res = predictForPoint(pTest);\n      // restore\n      state.points = originalPoints;\n      preds.push({true: (state.type==='classification'? pTest.label: pTest.value), pred: res.pred});\n    }\n    // compute metric\n    if (state.type === 'classification') {\n      let correct = 0;\n      for (let el of preds) if (String(el.true) === String(el.pred)) correct++;\n      results.push({fold: f+1, accuracy: preds.length? correct / preds.length : 0, correct, total: preds.length});\n    } else {\n      let sse = 0;\n      for (let el of preds) sse += Math.pow(el.true - el.pred, 2);\n      results.push({fold: f+1, mse: preds.length? sse / preds.length : 0, total: preds.length});\n    }\n  }\n  // aggregate\n  let out = 'Cross-validation results:\\n';\n  if (state.type === 'classification') {\n    let sum=0, tot=0;\n    results.forEach(r=>{ out += 'Fold '+r.fold+': acc=' + (r.accuracy*100).toFixed(2)+'% ('+r.correct+'/'+r.total+')\\n'; sum += r.accuracy; tot++; });\n    out += 'Mean accuracy: ' + ((sum/tot)*100).toFixed(2) + '%\\n';\n  } else {\n    let sum=0, tot=0;\n    results.forEach(r=>{ out += 'Fold '+r.fold+': mse=' + r.mse.toFixed(4) + '\\n'; sum += r.mse; tot++; });\n    out += 'Mean MSE: ' + (sum/tot).toFixed(4) + '\\n';\n  }\n  txtOutput.value = out;\n  log('Ran cross-validation with ' + folds + ' folds');\n});\n\n// hyperparameter sweep\nbtnSweep.addEventListener('click', ()=>{\n  const maxk = Math.max(1, parseInt(inSweepMax.value));\n  if (!state.points.length) { log('No points'); return; }\n  const labeled = state.points.filter(p => (state.type==='classification' ? ('label' in p && p.label !== undefined) : ('value' in p && p.value !== undefined)));\n  if (!labeled.length) { log('No labeled points for sweep'); return; }\n  const rng = rand(2);\n  const idx = labeled.map((v,i)=>i);\n  shuffle(idx, rng);\n  const trainSize = Math.floor(labeled.length * 0.7) || Math.floor(labeled.length/2);\n  const trainIdx = idx.slice(0,trainSize);\n  const testIdx = idx.slice(trainSize);\n  if (!testIdx.length) { log('Not enough points to split for sweep'); return; }\n  const results = [];\n  pushUndo();\n  for (let k=1;k<=maxk;k++){\n    state.settings.k = k;\n    let correct=0, total=0, sse=0;\n    for (let ti of testIdx) {\n      const pTest = labeled[ti];\n      // temporarily set only training points\n      const trainPts = trainIdx.map(i => labeled[i]);\n      const originalPoints = state.points;\n      state.points = trainPts.concat([]);\n      const res = predictForPoint(pTest);\n      state.points = originalPoints;\n      if (state.type === 'classification') {\n        if (String(res.pred) === String(pTest.label)) correct++;\n        total++;\n      } else {\n        sse += Math.pow(pTest.value - res.pred, 2);\n        total++;\n      }\n    }\n    if (state.type === 'classification') results.push({k:k, acc: total? correct/total : 0});\n    else results.push({k:k, mse: total? sse/total : 0});\n  }\n  // display and allow clicking a k in output by text (user can copy)\n  let out = 'Hyperparameter sweep results:\\n';\n  if (state.type === 'classification') {\n    results.forEach(r=> out += 'k=' + r.k + ': acc=' + (r.acc*100).toFixed(2) + '%\\n');\n    // set k to best\n    const best = results.reduce((a,b)=> a.acc>=b.acc?a:b);\n    state.settings.k = best.k; inK.value = best.k; outK.textContent = best.k;\n    out += 'Best k (max accuracy): ' + best.k + '\\n';\n  } else {\n    results.forEach(r=> out += 'k=' + r.k + ': mse=' + r.mse.toFixed(4) + '\\n');\n    const best = results.reduce((a,b)=> a.mse<=b.mse?a:b);\n    state.settings.k = best.k; inK.value = best.k; outK.textContent = best.k;\n    out += 'Best k (min mse): ' + best.k + '\\n';\n  }\n  txtOutput.value = out;\n  redraw();\n  log('Completed hyperparameter sweep up to k=' + maxk);\n});\n\n// center and scale view\nbtnCenter.addEventListener('click', ()=>{\n  state.view.padding = 0.02;\n  redraw();\n});\nbtnScale.addEventListener('click', ()=>{\n  state.view.padding = 0.06;\n  redraw();\n});\n\n// details display\nfunction showDetailsForSelected() {\n  if (!state.selected) { txtDetails.value = ''; selId.textContent = 'none'; return; }\n  const p = state.points.find(pt=>pt.id===state.selected);\n  if (!p) { txtDetails.value = ''; selId.textContent = 'none'; return; }\n  let out = 'Point id: ' + p.id + '\\n';\n  out += 'Coordinates: ' + p.x.map(v=>v.toFixed(3)).join(', ') + '\\n';\n  if (state.type === 'classification') out += 'Label: ' + (('label' in p)? String(p.label) : 'none') + '\\n';\n  else out += 'Value: ' + (('value' in p)? String(p.value) : 'none') + '\\n';\n  out += 'Split: ' + p.split + '\\n';\n  txtDetails.value = out;\n}\n\n// logging\nfunction log(msg) {\n  const now = new Date();\n  txtOutput.value = '[' + now.toLocaleTimeString() + '] ' + msg + '\\n' + txtOutput.value;\n}\n\n// helper predict for grid hover\ncanvas.addEventListener('mousemove', (ev)=>{\n  if (!state.grid) return;\n  const rect = canvas.getBoundingClientRect();\n  const mx = ev.clientX - rect.left, my = ev.clientY - rect.top;\n  const res = state.grid.res;\n  const cellW = canvas.width / res;\n  const cellH = canvas.height / res;\n  const i = Math.floor(mx / cellW);\n  const j = Math.floor(my / cellH);\n  if (i<0||i>=res||j<0||j>=res) return;\n  const idx = j*res + i;\n  const val = state.grid.preds[idx];\n  // display in output area but keep previous messages: place at top\n  txtOutput.value = 'Grid hover: cell ['+i+','+j+'] -> pred=' + String(val) + '\\n' + txtOutput.value;\n  // optionally show neighbors for the generated grid point\n  if (chkShowNeighbors.checked) {\n    const dims = state.dims;\n    const p = { id:'tmp', x: Array(dims).fill(0) };\n    const xi = state.grid.features[0], yi = state.grid.features[1];\n    const ranges = {xmin: state.grid.xRange[0], xmax: state.grid.xRange[1], ymin: state.grid.yRange[0], ymax: state.grid.yRange[1]};\n    const sx = (i + 0.5)/res;\n    const sy = 1 - (j + 0.5)/res;\n    p.x[xi] = ranges.xmin + sx*(ranges.xmax - ranges.xmin);\n    p.x[yi] = ranges.ymin + sy*(ranges.ymax - ranges.ymin);\n    const means = featureMeans();\n    for (let d=0; d<dims; d++) if (d!==xi && d!==yi) p.x[d] = means[d];\n    const pred = predictForPoint(p);\n    // show details\n    let out = 'Grid cell prediction: ' + String(pred.pred) + '\\nNeighbors:\\n';\n    pred.neighbors.forEach((n,i)=> out += (i+1)+'. id='+n.id+', dist='+n.d.toFixed(4)+(n.label!==undefined? ', label='+n.label: (n.value!==undefined? ', value='+n.value: '')) + '\\n');\n    txtDetails.value = out;\n    // mark neighbors visually\n    // we will redraw after to show neighbors - but careful: do not disturb undo stack\n    redraw();\n    // draw neighbor marks\n    const neighbors = pred.neighbors.map(n=> state.points.find(pt=>pt.id===n.id)).filter(Boolean);\n    for (let iN=0;iN<neighbors.length;iN++){\n      const np = neighbors[iN];\n      ctx.beginPath();\n      const [nx,ny] = dataToCanvas(np.x[xi], np.x[yi]);\n      ctx.strokeRect(nx-9, ny-9, 18, 18);\n    }\n  }\n});\n\n// show details when clicking selected (also via button)\ncanvas.addEventListener('click', (ev)=>{ showDetailsForSelected(); });\n\n// keyboard shortcuts\nwindow.addEventListener('keydown', (ev)=>{\n  if (ev.key === 'a') document.querySelector('input[name=\"mode\"][value=\"add\"]').checked = true;\n  if (ev.key === 'm') document.querySelector('input[name=\"mode\"][value=\"move\"]').checked = true;\n  if (ev.key === 'r') document.querySelector('input[name=\"mode\"][value=\"remove\"]').checked = true;\n  state.mode = document.querySelector('input[name=\"mode\"]:checked').value;\n});\n\n// initial setup\nfunction setup() {\n  initFeatureSelectors();\n  state.points = [];\n  generateDataset();\n}\nsetup();\n\n})(); // end closure\n</script>\n\n</body>\n</html>"
