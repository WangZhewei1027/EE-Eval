    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Neural Networks — A Visual Journey</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Root and body style */\n  :root {\n    --primary-color: #4A90E2;\n    --secondary-color: #50E3C2;\n    --accent-color: #F5A623;\n    --bg-dark: #121212;\n    --bg-darker: #0D0D0D;\n    --text-light: #E0E0E0;\n    --shadow-glow: rgba(74, 144, 226, 0.6);\n  }\n  /* Reset */\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n  body {\n    background: linear-gradient(135deg, #121212 0%, #0D0D0D 100%);\n    font-family: 'Poppins', sans-serif;\n    color: var(--text-light);\n    overflow: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 2rem;\n  }\n  /* Title */\n  header {\n    text-align: center;\n    margin-bottom: 2rem;\n    z-index: 10;\n  }\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    background: linear-gradient(90deg, #50E3C2, #4A90E2);\n    background-clip: text;\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    filter: drop-shadow(0 0 8px var(--shadow-glow));\n    letter-spacing: 0.05em;\n    user-select: none;\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.2rem;\n    letter-spacing: 0.15em;\n    margin-top: 0.5em;\n    color: #7f8fa6;\n    user-select: none;\n    font-style: italic;\n  }\n\n  /* Container for visualization and controls */\n  main {\n    position: relative;\n    width: 90vw;\n    max-width: 960px;\n    aspect-ratio: 16 / 9;\n    background: #1B1B1B;\n    border-radius: 20px;\n    box-shadow:\n      inset 0 0 20px #222,\n      0 0 60px var(--shadow-glow);\n    overflow: hidden;\n    user-select: none;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* Visualization canvas */\n  #nn-canvas {\n    flex-grow: 1;\n    display: block;\n    border-radius: 20px 20px 0 0;\n    background: radial-gradient(circle at center, #111827, #0B0B0B 80%);\n    cursor: default;\n  }\n\n  /* Controls panel */\n  .controls {\n    background: #0E0E0E;\n    padding: 1rem 1.5rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.2rem;\n    border-radius: 0 0 20px 20px;\n  }\n\n  button {\n    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));\n    border: none;\n    border-radius: 50px;\n    padding: 0.6rem 2rem;\n    font-weight: 600;\n    font-size: 1rem;\n    color: white;\n    box-shadow: 0 8px 15px rgba(74,144,226,0.4);\n    cursor: pointer;\n    transition: all 0.3s ease;\n    user-select: none;\n  }\n\n  button:focus-visible {\n    outline: 2px solid var(--accent-color);\n    outline-offset: 4px;\n  }\n\n  button:hover {\n    transform: translateY(-3px);\n    box-shadow: 0 12px 30px rgba(74,144,226,0.65);\n  }\n  button:active {\n    transform: translateY(-1px);\n    box-shadow: 0 8px 15px rgba(74,144,226,0.5);\n  }\n\n  /* Tooltip for layer info */\n  #tooltip {\n    position: absolute;\n    pointer-events: none;\n    background: rgba(10, 10, 10, 0.85);\n    color: #a0cce7;\n    padding: 6px 12px;\n    border-radius: 10px;\n    font-size: 0.875rem;\n    font-weight: 500;\n    letter-spacing: 0.01em;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    user-select: none;\n    z-index: 15;\n    font-family: 'Poppins', sans-serif;\n    box-shadow: 0 0 15px var(--shadow-glow);\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>NEURAL NETWORKS</h1>\n  <h2>Visualizing the Intelligence Inside</h2>\n</header>\n\n<main>\n  <canvas id=\"nn-canvas\" width=\"900\" height=\"506\" aria-label=\"Neural network visualization\"></canvas>\n  <div class=\"controls\" role=\"region\" aria-label=\"Controls for visualization\">\n    <button id=\"toggleAnimation\" aria-pressed=\"true\" aria-label=\"Pause neural network animation\">Pause Animation</button>\n    <button id=\"shuffleWeights\" aria-label=\"Shuffle connections weights to random values\">Shuffle Weights</button>\n  </div>\n  <div id=\"tooltip\" role=\"tooltip\"></div>\n</main>\n\n<script>\n(() => {\n  'use strict';\n\n  const canvas = document.getElementById('nn-canvas');\n  const ctx = canvas.getContext('2d');\n  const tooltip = document.getElementById('tooltip');\n  const toggleBtn = document.getElementById('toggleAnimation');\n  const shuffleBtn = document.getElementById('shuffleWeights');\n\n  const dpr = window.devicePixelRatio || 1;\n  const width = canvas.width;\n  const height = canvas.height;\n\n  canvas.style.width = width + 'px';\n  canvas.style.height = height + 'px';\n\n  // Adjust canvas for retina\n  canvas.width = width * dpr;\n  canvas.height = height * dpr;\n  ctx.scale(dpr, dpr);\n\n  // Neural network configuration\n  const layersConfig = [6, 10, 8, 5, 2]; // Number of neurons per layer\n\n  // Colors for neurons based on their layer index\n  const neuronColors = [\n    '#4A90E2',\n    '#50E3C2',\n    '#F5A623',\n    '#E94E77',\n    '#9B59B6'\n  ];\n\n  // Neuron radius\n  const neuronRadius = 18;\n\n  // Animation control\n  let animationActive = true;\n  let time = 0;\n\n  // Store neurons with positions and properties\n  let neurons = [];\n  // Store connections with weight values and animation state\n  let connections = [];\n\n  // Initialize neurons positions and structure\n  function initNeurons() {\n    neurons = [];\n    const marginX = 80;\n    const marginY = 60;\n    const usableWidth = width - 2 * marginX;\n    const usableHeight = height - 2 * marginY;\n\n    layersConfig.forEach((count, layerIndex) => {\n      const layerX = marginX + (usableWidth / (layersConfig.length - 1)) * layerIndex;\n      const gapY = usableHeight / (count - 1 || 1);\n      for (let i = 0; i < count; i++) {\n        const y = marginY + (count === 1 ? usableHeight / 2 : gapY * i);\n        neurons.push({\n          id: `${layerIndex}-${i}`,\n          layer: layerIndex,\n          x: layerX,\n          y: y,\n          radius: neuronRadius,\n          color: neuronColors[layerIndex] || '#888',\n          activation: 0,\n        });\n      }\n    });\n  }\n\n  // Initialize connections between subsequent layers\n  function initConnections() {\n    connections = [];\n    for(let l = 0; l < layersConfig.length - 1; l++) {\n      const currentLayerCount = layersConfig[l];\n      const nextLayerCount = layersConfig[l + 1];\n      for(let i = 0; i < currentLayerCount; i++) {\n        const startNeuron = neurons.find(n => n.layer === l && n.id.endsWith(`-${i}`));\n        for(let j = 0; j < nextLayerCount; j++) {\n          const endNeuron = neurons.find(n => n.layer === l + 1 && n.id.endsWith(`-${j}`));\n          // Initialize weight with random -1 to 1\n          const weight = Math.random() * 2 - 1;\n          connections.push({\n            start: startNeuron,\n            end: endNeuron,\n            weight: weight,\n            animationPhase: Math.random() * 2 * Math.PI, // phase offset for animation\n          });\n        }\n      }\n    }\n  }\n\n  // Activation pulse animation for each neuron across layers\n  function updateActivations(t) {\n    neurons.forEach(neuron => {\n      // Pulse activations synced by layer but with different phase offset\n      const pulseSpeed = 1.3;\n      const basePhase = (neuron.layer * 1.2 + neuron.y / height * 2) * Math.PI * 1.3;\n      neuron.activation = 0.5 + 0.5 * Math.sin(t * pulseSpeed + basePhase);\n    });\n  }\n\n  // Draw neurons\n  function drawNeurons() {\n    neurons.forEach(n => {\n      const glow = n.activation * 0.6 + 0.3;\n      ctx.shadowColor = n.color;\n      ctx.shadowBlur = 20 * glow;\n      // Outer glow circle\n      ctx.beginPath();\n      ctx.fillStyle = `rgba(255 255 255 / ${0.05 + glow * 0.14})`;\n      ctx.arc(n.x, n.y, n.radius + 8 * glow, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.closePath();\n\n      // Main neuron circle\n      ctx.beginPath();\n      const gradient = ctx.createRadialGradient(n.x, n.y, n.radius/4, n.x, n.y, n.radius);\n      gradient.addColorStop(0, `rgba(255 255 255 / ${0.75 * n.activation})`);\n      gradient.addColorStop(1, n.color);\n\n      ctx.fillStyle = gradient;\n      ctx.arc(n.x, n.y, n.radius, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.closePath();\n\n      // Inner small bright spot for depth\n      ctx.beginPath();\n      ctx.fillStyle = `rgba(255 255 255 / ${0.6 * n.activation})`;\n      ctx.arc(n.x - n.radius/3, n.y - n.radius/3, n.radius/4, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.closePath();\n\n      ctx.shadowBlur = 0;\n    });\n  }\n\n  // Get color representing weight strength and sign\n  function weightToColor(weight) {\n    // Positive: turquoise-blueish, Negative: coral-redish\n    const p = Math.min(1, Math.abs(weight)); // clamp\n    if(weight >= 0) {\n      // interpolate light turquoise to blue\n      const r = Math.floor(80 + 105 * (1 - p));\n      const g = Math.floor(230 + 25 * (1 - p));\n      const b = Math.floor(194 + 61 * (1 - p));\n      return `rgb(${r},${g},${b})`; // approx turquoise shades\n    } else {\n      // interpolate light coral to red\n      const r = Math.floor(245 + 10 * (1 - p));\n      const g = Math.floor(166 - 120 * p);\n      const b = Math.floor(35 - 35 * p);\n      return `rgb(${r},${g > 0 ? g : 0},${b > 0 ? b : 0})`;\n    }\n  }\n\n  // Draw connections with animated pulse on weight strength\n  function drawConnections(t) {\n    connections.forEach(conn => {\n      const {start, end, weight, animationPhase} = conn;\n\n      // Animate alpha and width with sine wave\n      const alphaBase = 0.15;\n      const alphaPulse = 0.6 * Math.abs(Math.sin(t * 4 + animationPhase));\n      const alpha = Math.min(1, alphaBase + alphaPulse);\n      const widthBase = 0.6;\n      const widthPulse = 1.4 * Math.abs(Math.sin(t * 4 + animationPhase));\n      const width = widthBase + widthPulse;\n\n      // Stroke style based on weight\n      const color = weightToColor(weight);\n      ctx.strokeStyle = color;\n      ctx.lineWidth = width;\n      ctx.shadowColor = color;\n      ctx.shadowBlur = 8 * (alpha);\n\n      // Draw connection line with smooth bezier curve\n      ctx.beginPath();\n      const cp1x = start.x + (end.x - start.x) * 0.4;\n      const cp1y = start.y;\n      const cp2x = start.x + (end.x - start.x) * 0.6;\n      const cp2y = end.y;\n      ctx.moveTo(start.x, start.y);\n      ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, end.x, end.y);\n      ctx.stroke();\n      ctx.closePath();\n\n      ctx.shadowBlur = 0;\n    });\n  }\n\n  // Clear canvas\n  function clear() {\n    ctx.clearRect(0, 0, width, height);\n    // Subtle dark overlay for fading trails effect\n    ctx.fillStyle = 'rgba(18,18,18,0.2)';\n    ctx.fillRect(0, 0, width, height);\n  }\n\n  // Main draw loop\n  function drawLoop(timestamp = 0) {\n    if(animationActive) {\n      time = timestamp * 0.001;\n    }\n    clear();\n    updateActivations(time);\n    drawConnections(time);\n    drawNeurons();\n    if(animationActive) {\n      window.requestAnimationFrame(drawLoop);\n    }\n  }\n\n  // Button event handlers\n  toggleBtn.addEventListener('click', () => {\n    animationActive = !animationActive;\n    toggleBtn.textContent = animationActive ? 'Pause Animation' : 'Play Animation';\n    toggleBtn.setAttribute('aria-pressed', animationActive.toString());\n    if(animationActive) {\n      window.requestAnimationFrame(drawLoop);\n    }\n  });\n\n  shuffleBtn.addEventListener('click', () => {\n    // Randomize weights\n    connections.forEach(conn => {\n      conn.weight = Math.random() * 2 - 1;\n      conn.animationPhase = Math.random() * 2 * Math.PI;\n    });\n    // Visual feedback: flash background subtle color shift\n    flashBackground();\n  });\n\n  // Flash background on shuffle for nice effect\n  function flashBackground() {\n    const duration = 350;\n    let start = null;\n    function flash(ts) {\n      if(!start) start = ts;\n      const elapsed = ts - start;\n      const progress = Math.min(1, elapsed / duration);\n\n      const pulse = 0.15 * (1 - progress);\n      const color = `rgba(80, 227, 194, ${pulse})`;\n      canvas.style.boxShadow = `\n        inset 0 0 40px ${color},\n        0 0 120px ${color}\n      `;\n\n      if(progress < 1) {\n        requestAnimationFrame(flash);\n      } else {\n        canvas.style.boxShadow = '';\n      }\n    }\n    requestAnimationFrame(flash);\n  }\n\n  // Hover neuron highlighting & tooltip\n  function getNearestNeuron(mx, my) {\n    let minDist = Infinity;\n    let closest = null;\n    neurons.forEach(n => {\n      const dx = n.x - mx;\n      const dy = n.y - my;\n      const dist = dx*dx + dy*dy;\n      if(dist < minDist && dist < 30*30) {\n        minDist = dist;\n        closest = n;\n      }\n    });\n    return closest;\n  }\n\n  function onMouseMove(e) {\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n    const hoveredNeuron = getNearestNeuron(mx, my);\n\n    if(hoveredNeuron) {\n      tooltip.style.opacity = '1';\n      tooltip.style.left = (mx + 20) + 'px';\n      tooltip.style.top = (my + 20) + 'px';\n\n      tooltip.textContent = `Layer ${hoveredNeuron.layer + 1} | Neuron ${(hoveredNeuron.id.split('-')[1]) + 1}\\nActivation: ${(hoveredNeuron.activation * 100).toFixed(1)}%`;\n    } else {\n      tooltip.style.opacity = '0';\n      tooltip.textContent = '';\n    }\n  }\n  function onMouseLeave() {\n    tooltip.style.opacity = '0';\n    tooltip.textContent = '';\n  }\n\n  canvas.addEventListener('mousemove', onMouseMove);\n  canvas.addEventListener('mouseleave', onMouseLeave);\n\n  // Initialize and start animation\n  function init() {\n    initNeurons();\n    initConnections();\n    drawLoop();\n  }\n\n  init();\n\n  // Responsive resizing handling (optional)\n  window.addEventListener('resize', () => {\n    // We keep fixed size for crisp visuals and layout constraints\n  });\n})();\n</script>\n</body>\n</html>"
  },
