    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>B+ Tree Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1e3c72, #2a5298);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f3;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1rem;\n    user-select: none;\n    overflow-x: hidden;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    letter-spacing: 0.08em;\n    margin: 0 0 0.25rem 0;\n    color: #f2f7fe;\n    text-shadow:\n      2px 2px 6px rgba(42, 82, 152, 0.85),\n      0 0 8px rgba(255, 255, 255, 0.3);\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.25rem;\n    color: #c0cde8cc;\n    margin: 0 0 2rem 0;\n  }\n\n  /* Container */\n  #container {\n    background: linear-gradient(145deg, #2c4a82, #1d2e61);\n    border-radius: 1.25rem;\n    box-shadow: 0 0 20px #426cb040 inset, 0 10px 40px rgba(0, 0, 0, 0.8);\n    max-width: 1000px;\n    width: 100%;\n    padding: 2rem 3rem 4rem;\n    position: relative;\n  }\n\n  /* Controls area */\n  #controls {\n    text-align: center;\n    margin-bottom: 3rem;\n  }\n  button {\n    background: #5878b4;\n    border: none;\n    color: #d9e1ef;\n    font-weight: 600;\n    font-size: 1.05rem;\n    padding: 0.65rem 1.8rem;\n    margin: 0 10px;\n    border-radius: 9999px;\n    box-shadow:\n      0 4px 15px rgba(88, 120, 180, 0.6),\n      inset 0 -2px 8px rgba(255, 255, 255, 0.12);\n    cursor: pointer;\n    user-select: none;\n    transition: background 0.35s cubic-bezier(0.4, 0, 0.2, 1),\n                box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  button:hover, button:focus {\n    outline: none;\n    background: #7293d3;\n    box-shadow:\n      0 6px 26px rgba(114, 147, 211, 0.8),\n      inset 0 -3px 12px rgba(255, 255, 255, 0.15);\n  }\n  button:active {\n    transform: translateY(2px);\n    box-shadow:\n      0 2px 8px rgba(88, 120, 180, 0.4),\n      inset 0 0 10px rgba(255, 255, 255, 0.1);\n  }\n\n  /* SVG tree container */\n  #tree-svg {\n    display: block;\n    margin: 0 auto;\n    max-width: 100%;\n    height: 520px;\n  }\n\n  /* Node styling */\n  .node-group {\n    cursor: default;\n    filter: drop-shadow(0 6px 6px rgba(0, 8, 32, 0.15));\n    transition: transform 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55);\n  }\n\n  .node-rect {\n    fill: url(#nodeGradient);\n    stroke: #a3bddc;\n    stroke-width: 2;\n    rx: 14;\n    ry: 14;\n    filter: drop-shadow(0 2px 6px rgba(21, 44, 71, 0.3));\n    transition: fill 0.3s ease;\n  }\n\n  .node-rect.leaf {\n    fill: url(#leafGradient);\n    stroke: #8dd4c7;\n  }\n\n  .node-rect.focused {\n    stroke: #ffca3a;\n    stroke-width: 3.5;\n    filter:\n      drop-shadow(0 0 9px #ffc43acc)\n      drop-shadow(0 0 14px #ffdea3aa);\n  }\n\n  .node-text {\n    font-weight: 600;\n    fill: #eaf6ffdd;\n    font-size: 18px;\n    user-select: none;\n    pointer-events: none;\n    letter-spacing: 0.005em;\n    text-shadow:\n      0 1px 1px rgba(0,0,0,0.18);\n    transition: fill 0.3s ease;\n  }\n\n  /* Internal separator lines between keys */\n  .sep-line {\n    stroke: #718dbf99;\n    stroke-width: 2;\n  }\n\n  /* Pointer lines */\n  .pointer-line {\n    stroke: #8a9acbcc;\n    stroke-width: 3;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    transition: stroke 0.3s ease;\n  }\n  /* Pointer circles */\n  .pointer-circle {\n    fill: #8a9acbd9;\n    stroke: none;\n  }\n\n  /* Key highlight animations */\n  .key-highlight {\n    animation: pulseGlow 2.5s infinite forwards;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      fill: #ffca3a;\n      filter: drop-shadow(0 0 12px #ffc43a);\n    }\n    50% {\n      fill: #fff5cc;\n      filter: none;\n    }\n  }\n\n  /* Footer text */\n  footer {\n    margin-top: 4rem;\n    font-size: 0.9rem;\n    color: #aab6fb90;\n    user-select: none;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width: 600px) {\n    #container {\n      padding: 1.5rem 1.75rem 3rem;\n    }\n    h1 {\n      font-size: 2.4rem;\n    }\n    h2 {\n      font-size: 1rem;\n      margin-bottom: 1.25rem;\n    }\n    #tree-svg {\n      height: 350px;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>B+ Tree</h1>\n  <h2>Data Structure Visualization — Observe the layered elegance</h2>\n  <div id=\"container\" role=\"main\" aria-label=\"B Plus Tree Visualization\">\n    <div id=\"controls\" aria-label=\"Controls to highlight keys\">\n      <button id=\"highlightRoot\" aria-pressed=\"false\" aria-label=\"Highlight root keys\">Highlight Root Keys</button>\n      <button id=\"highlightLeaves\" aria-pressed=\"false\" aria-label=\"Highlight leaf keys\">Highlight Leaf Keys</button>\n    </div>\n    <svg id=\"tree-svg\" viewBox=\"0 0 1000 520\" aria-hidden=\"true\" role=\"img\" focusable=\"false\">\n      <defs>\n        <!-- Gradient for internal nodes -->\n        <linearGradient id=\"nodeGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#4070d5\"/>\n          <stop offset=\"100%\" stop-color=\"#2a3c79\"/>\n        </linearGradient>\n        <!-- Gradient for leaf nodes -->\n        <linearGradient id=\"leafGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#4ecdc4\"/>\n          <stop offset=\"100%\" stop-color=\"#379a99\"/>\n        </linearGradient>\n        <!-- Glow filter for emphasis -->\n        <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\" >\n          <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"5\" flood-color=\"#ffca3a\" flood-opacity=\"0.8\"/>\n        </filter>\n      </defs>\n      <!-- Tree structure -->\n\n      <!-- Root Node -->\n      <g class=\"node-group root\" transform=\"translate(400,80)\">\n        <rect class=\"node-rect\" width=\"200\" height=\"56\" />\n        <!-- Keys -->\n        <!-- 3 keys: 17 | 35 | 66 -->\n        <text class=\"node-text\" x=\"25\" y=\"36\">17</text>\n        <line class=\"sep-line\" x1=\"70\" y1=\"8\" x2=\"70\" y2=\"48\" />\n        <text class=\"node-text\" x=\"94\" y=\"36\">35</text>\n        <line class=\"sep-line\" x1=\"140\" y1=\"8\" x2=\"140\" y2=\"48\" />\n        <text class=\"node-text\" x=\"165\" y=\"36\">66</text>\n      </g>\n\n      <!-- Level 1 internal nodes -->\n      <!-- Left node -->\n      <g class=\"node-group internal\" transform=\"translate(145,190)\">\n        <rect class=\"node-rect\" width=\"160\" height=\"48\" />\n        <!-- Keys: 5 | 12 -->\n        <text class=\"node-text\" x=\"20\" y=\"30\">5</text>\n        <line class=\"sep-line\" x1=\"65\" y1=\"6\" x2=\"65\" y2=\"42\" />\n        <text class=\"node-text\" x=\"95\" y=\"30\">12</text>\n      </g>\n\n      <!-- Middle node -->\n      <g class=\"node-group internal\" transform=\"translate(400,190)\">\n        <rect class=\"node-rect\" width=\"140\" height=\"48\" />\n        <!-- Keys: 40 | 49 -->\n        <text class=\"node-text\" x=\"20\" y=\"30\">40</text>\n        <line class=\"sep-line\" x1=\"65\" y1=\"6\" x2=\"65\" y2=\"42\" />\n        <text class=\"node-text\" x=\"95\" y=\"30\">49</text>\n      </g>\n\n      <!-- Right node -->\n      <g class=\"node-group internal\" transform=\"translate(670,190)\">\n        <rect class=\"node-rect\" width=\"130\" height=\"48\" />\n        <!-- Keys: 72 | 93 -->\n        <text class=\"node-text\" x=\"20\" y=\"30\">72</text>\n        <line class=\"sep-line\" x1=\"65\" y1=\"6\" x2=\"65\" y2=\"42\" />\n        <text class=\"node-text\" x=\"95\" y=\"30\">93</text>\n      </g>\n\n      <!-- Level 2 leaf nodes -->\n      <!-- L1 leaf nodes on left -->\n      <g class=\"node-group leaf\" transform=\"translate(40,310)\">\n        <rect class=\"node-rect leaf\" width=\"160\" height=\"52\" />\n        <!-- Keys: 1 | 3 | 4 -->\n        <text class=\"node-text\" x=\"20\" y=\"34\">1</text>\n        <line class=\"sep-line\" x1=\"50\" y1=\"10\" x2=\"50\" y2=\"42\" />\n        <text class=\"node-text\" x=\"75\" y=\"34\">3</text>\n        <line class=\"sep-line\" x1=\"110\" y1=\"10\" x2=\"110\" y2=\"42\" />\n        <text class=\"node-text\" x=\"135\" y=\"34\">4</text>\n        <!-- Next leaf pointer circle right side -->\n        <circle class=\"pointer-circle\" cx=\"160\" cy=\"26\" r=\"7\" />\n      </g>\n\n      <g class=\"node-group leaf\" transform=\"translate(220,310)\">\n        <rect class=\"node-rect leaf\" width=\"160\" height=\"52\" />\n        <!-- Keys: 6 | 10 | 15 -->\n        <text class=\"node-text\" x=\"20\" y=\"34\">6</text>\n        <line class=\"sep-line\" x1=\"53\" y1=\"10\" x2=\"53\" y2=\"42\" />\n        <text class=\"node-text\" x=\"80\" y=\"34\">10</text>\n        <line class=\"sep-line\" x1=\"115\" y1=\"10\" x2=\"115\" y2=\"42\" />\n        <text class=\"node-text\" x=\"140\" y=\"34\">15</text>\n        <circle class=\"pointer-circle\" cx=\"160\" cy=\"26\" r=\"7\" />\n      </g>\n\n      <!-- Middle leaf nodes -->\n      <g class=\"node-group leaf\" transform=\"translate(365,310)\">\n        <rect class=\"node-rect leaf\" width=\"140\" height=\"52\" />\n        <!-- Keys: 36 | 38 -->\n        <text class=\"node-text\" x=\"20\" y=\"34\">36</text>\n        <line class=\"sep-line\" x1=\"65\" y1=\"10\" x2=\"65\" y2=\"42\" />\n        <text class=\"node-text\" x=\"95\" y=\"34\">38</text>\n        <circle class=\"pointer-circle\" cx=\"140\" cy=\"26\" r=\"7\" />\n      </g>\n\n      <g class=\"node-group leaf\" transform=\"translate(515,310)\">\n        <rect class=\"node-rect leaf\" width=\"150\" height=\"52\" />\n        <!-- Keys: 41 | 44 | 47 -->\n        <text class=\"node-text\" x=\"20\" y=\"34\">41</text>\n        <line class=\"sep-line\" x1=\"53\" y1=\"10\" x2=\"53\" y2=\"42\" />\n        <text class=\"node-text\" x=\"80\" y=\"34\">44</text>\n        <line class=\"sep-line\" x1=\"115\" y1=\"10\" x2=\"115\" y2=\"42\" />\n        <text class=\"node-text\" x=\"140\" y=\"34\">47</text>\n        <circle class=\"pointer-circle\" cx=\"150\" cy=\"26\" r=\"7\" />\n      </g>\n\n      <!-- Right leaf nodes -->\n      <g class=\"node-group leaf\" transform=\"translate(655,310)\">\n        <rect class=\"node-rect leaf\" width=\"130\" height=\"52\" />\n        <!-- Keys: 69 | 71 -->\n        <text class=\"node-text\" x=\"20\" y=\"34\">69</text>\n        <line class=\"sep-line\" x1=\"67\" y1=\"10\" x2=\"67\" y2=\"42\" />\n        <text class=\"node-text\" x=\"100\" y=\"34\">71</text>\n        <circle class=\"pointer-circle\" cx=\"130\" cy=\"26\" r=\"7\" />\n      </g>\n\n      <g class=\"node-group leaf\" transform=\"translate(800,310)\">\n        <rect class=\"node-rect leaf\" width=\"160\" height=\"52\" />\n        <!-- Keys: 75 | 88 | 90 | 95 -->\n        <text class=\"node-text\" x=\"20\" y=\"34\">75</text>\n        <line class=\"sep-line\" x1=\"48\" y1=\"10\" x2=\"48\" y2=\"42\" />\n        <text class=\"node-text\" x=\"70\" y=\"34\">88</text>\n        <line class=\"sep-line\" x1=\"100\" y1=\"10\" x2=\"100\" y2=\"42\" />\n        <text class=\"node-text\" x=\"125\" y=\"34\">90</text>\n        <line class=\"sep-line\" x1=\"145\" y1=\"10\" x2=\"145\" y2=\"42\" />\n        <text class=\"node-text\" x=\"155\" y=\"34\">95</text>\n        <circle class=\"pointer-circle\" cx=\"160\" cy=\"26\" r=\"7\" />\n      </g>\n\n      <!-- Pointer lines from root to level 1 -->\n      <line class=\"pointer-line\" x1=\"400\" y1=\"136\" x2=\"220\" y2=\"190\" />\n      <line class=\"pointer-line\" x1=\"460\" y1=\"136\" x2=\"470\" y2=\"190\" />\n      <line class=\"pointer-line\" x1=\"600\" y1=\"136\" x2=\"735\" y2=\"190\" />\n\n      <!-- Pointer lines from level 1 to leaf nodes -->\n      <line class=\"pointer-line\" x1=\"165\" y1=\"238\" x2=\"120\" y2=\"310\" />\n      <line class=\"pointer-line\" x1=\"250\" y1=\"238\" x2=\"300\" y2=\"310\" />\n\n      <line class=\"pointer-line\" x1=\"435\" y1=\"238\" x2=\"435\" y2=\"310\" />\n      <line class=\"pointer-line\" x1=\"490\" y1=\"238\" x2=\"575\" y2=\"310\" />\n\n      <line class=\"pointer-line\" x1=\"740\" y1=\"238\" x2=\"720\" y2=\"310\" />\n      <line class=\"pointer-line\" x1=\"785\" y1=\"238\" x2=\"875\" y2=\"310\" />\n    </svg>\n  </div>\n  <footer>Designed &amp; coded with elegance by AI — B+ Tree Concept Demonstration</footer>\n\n<script>\n  (() => {\n    const highlightRootBtn = document.getElementById('highlightRoot');\n    const highlightLeavesBtn = document.getElementById('highlightLeaves');\n\n    // Select root keys (texts inside root node)\n    const rootNode = document.querySelector('.node-group.root');\n    const rootKeys = rootNode ? rootNode.querySelectorAll('text.node-text') : [];\n\n    // Select leaf nodes (node-rect.leaf) and their keys\n    const leafNodes = document.querySelectorAll('.node-group.leaf');\n    const leafKeys = [];\n    leafNodes.forEach(leaf => {\n      leafKeys.push(...leaf.querySelectorAll('text.node-text'));\n    });\n\n    // Helpers\n    function toggleHighlight(elements, enabled) {\n      elements.forEach(el => {\n        if (enabled) {\n          el.classList.add('key-highlight');\n        } else {\n          el.classList.remove('key-highlight');\n        }\n      });\n    }\n\n    // States\n    let rootHighlighted = false;\n    let leavesHighlighted = false;\n\n    highlightRootBtn.addEventListener('click', () => {\n      rootHighlighted = !rootHighlighted;\n      highlightRootBtn.setAttribute('aria-pressed', rootHighlighted);\n      toggleHighlight(rootKeys, rootHighlighted);\n      if (rootHighlighted) {\n        // If root highlighted, dehighlight leaves for clarity\n        leavesHighlighted = false;\n        highlightLeavesBtn.setAttribute('aria-pressed', 'false');\n        toggleHighlight(leafKeys, false);\n      }\n    });\n\n    highlightLeavesBtn.addEventListener