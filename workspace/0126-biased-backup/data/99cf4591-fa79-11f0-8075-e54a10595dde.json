    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>A* Search Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #controls {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h2>A* Search Visualization</h2>\n<div id=\"controls\">\n    <label for=\"start\">Start Node:</label>\n    <input type=\"text\" id=\"start\" value=\"A\"><br>\n    <label for=\"goal\">Goal Node:</label>\n    <input type=\"text\" id=\"goal\" value=\"E\"><br>\n    <label for=\"heuristic\">Heuristic Weights (comma-separated):</label>\n    <input type=\"text\" id=\"heuristic\" value=\"1,2,3,1,0\"><br>\n    <button id=\"runAStar\">Run A* Search</button>\n    <button id=\"reset\">Reset</button>\n</div>\n\n<pre id=\"output\"></pre>\n\n<script>\n    const graph = {\n        A: { B: 1, C: 4 },\n        B: { A: 1, C: 2, D: 5 },\n        C: { A: 4, B: 2, D: 1, E: 3 },\n        D: { B: 5, C: 1, E: 1 },\n        E: { C: 3, D: 1 }\n    };\n\n    const runAStar = () => {\n        const start = document.getElementById('start').value;\n        const goal = document.getElementById('goal').value;\n        const heuristicInput = document.getElementById('heuristic').value.split(',').map(Number);\n        \n        const heuristic = {};\n        const nodes = Object.keys(graph);\n        \n        if (heuristicInput.length !== nodes.length) {\n            document.getElementById('output').innerText = \"Error: Heuristic weights must match number of nodes.\";\n            return;\n        }\n\n        for (let i = 0; i < nodes.length; i++) {\n            heuristic[nodes[i]] = heuristicInput[i];\n        }\n\n        const openSet = [start];\n        const cameFrom = {};\n        const gScore = {};\n        const fScore = {};\n        \n        for (const node of nodes) {\n            gScore[node] = Infinity;\n            fScore[node] = Infinity;\n        }\n\n        gScore[start] = 0;\n        fScore[start] = heuristic[start];\n\n        while (openSet.length > 0) {\n            const current = openSet.reduce((a, b) => fScore[a] < fScore[b] ? a : b);\n            if (current === goal) {\n                reconstructPath(cameFrom, current);\n                return;\n            }\n\n            openSet.splice(openSet.indexOf(current), 1);\n            for (const neighbor in graph[current]) {\n                const tentativeGScore = gScore[current] + graph[current][neighbor];\n                if (tentativeGScore < gScore[neighbor]) {\n                    cameFrom[neighbor] = current;\n                    gScore[neighbor] = tentativeGScore;\n                    fScore[neighbor] = gScore[neighbor] + heuristic[neighbor];\n                    if (!openSet.includes(neighbor)) {\n                        openSet.push(neighbor);\n                    }\n                }\n            }\n        }\n\n        document.getElementById('output').innerText = \"No path found.\";\n    };\n\n    const reconstructPath = (cameFrom, current) => {\n        const totalPath = [current];\n        while (current in cameFrom) {\n            current = cameFrom[current];\n            totalPath.push(current);\n        }\n        totalPath.reverse();\n        document.getElementById('output').innerText = \"Path found: \" + totalPath.join(\" -> \");\n    };\n\n    document.getElementById('runAStar').onclick = runAStar;\n    document.getElementById('reset').onclick = () => {\n        document.getElementById('start').value = 'A';\n        document.getElementById('goal').value = 'E';\n        document.getElementById('heuristic').value = '1,2,3,1,0';\n        document.getElementById('output').innerText = '';\n    };\n</script>\n\n</body>\n</html>"
