    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Congestion Control Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;600&display=swap');\n\n  :root {\n    --bg-light: #f5f7fa;\n    --bg-dark: #181c24;\n    --primary-start: #00d2ff;\n    --primary-end: #3a47d5;\n    --accent: #ff6a9e;\n    --text-light: #e0e6f2;\n    --text-dark: #202b46;\n    --gradient-glow: radial-gradient(circle at center, #3a47d5 0%, #0b0c13 80%);\n    --packet-green: #3cd070;\n    --packet-orange: #ffa94d;\n    --packet-red: #ff6a6a;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: var(--bg-light);\n    font-family: 'Manrope', sans-serif;\n    color: var(--text-dark);\n    overflow-x: hidden;\n  }\n\n  header {\n    text-align: center;\n    padding: 2rem 1rem 0 1rem;\n    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));\n    color: white;\n    box-shadow: 0 4px 15px rgba(58, 71, 213, 0.3);\n  }\n\n  header h1 {\n    margin: 0;\n    font-weight: 600;\n    font-size: 3rem;\n    letter-spacing: 0.05em;\n    text-shadow:\n      0 0 8px rgba(58, 71, 213, 0.7),\n      0 0 15px rgba(0, 210, 255, 0.75);\n  }\n\n  header p {\n    margin: 0.5rem 0 2rem;\n    font-weight: 300;\n    font-size: 1.25rem;\n    opacity: 0.85;\n    user-select: none;\n  }\n\n  main {\n    max-width: 900px;\n    margin: 0 auto 3rem auto;\n    background: white;\n    border-radius: 24px;\n    box-shadow:\n      0 10px 18px rgba(58, 71, 213, 0.15),\n      0 2px 6px rgba(0, 0, 0, 0.06);\n    padding: 3rem 3.5rem 4rem 3.5rem;\n    position: relative;\n  }\n\n  #visualizer {\n    width: 100%;\n    height: 380px;\n    background: #1e222e;\n    border-radius: 20px;\n    overflow: visible;\n    box-shadow:\n      0 0 40px 6px rgba(58, 71, 213, 0.25),\n      inset 0 0 20px 2px rgba(0, 210, 255, 0.3);\n    position: relative;\n  }\n\n  /* Link between sender and receiver */\n  .link {\n    stroke: url(#linkGradient);\n    stroke-width: 8;\n    fill: none;\n    filter: drop-shadow(0 0 8px rgba(58, 71, 213, 0.45));\n  }\n\n  /* Congestion bar */\n  #congestionBarContainer {\n    position: absolute;\n    bottom: 1.5rem;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 280px;\n    height: 28px;\n    background: #222533;\n    border-radius: 14px;\n    box-shadow: inset 0 0 8px rgba(0, 0, 0, 0.7);\n    overflow: hidden;\n  }\n\n  #congestionBar {\n    height: 28px;\n    width: 0%;\n    background: linear-gradient(90deg, var(--packet-green), var(--packet-orange), var(--packet-red));\n    border-radius: 14px;\n    box-shadow:\n      0 0 10px rgba(252, 119, 3, 0.7),\n      0 0 14px rgba(252, 119, 3, 0.6);\n    transition: width 1.2s ease-in-out;\n  }\n\n  #congestionLabel {\n    position: absolute;\n    width: 280px;\n    text-align: center;\n    line-height: 28px;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: var(--text-light);\n    text-shadow: 0 0 4px rgba(0,0,0,0.6);\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Sender and Receiver containers */\n  .node {\n    fill: #283040;\n    stroke: #3a47d5;\n    stroke-width: 3;\n    filter:\n      drop-shadow(0 0 4px rgba(58, 71, 213, 0.5));\n  }\n\n  .node-glow {\n    fill: none;\n    stroke: #00d2ff;\n    stroke-width: 7;\n    stroke-linecap: round;\n    filter:\n      drop-shadow(0 0 12px rgba(0, 210, 255, 0.85));\n    opacity: 0.35;\n    animation: pulseGlow 2.5s ease-in-out infinite;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {opacity: 0.3;}\n    50% {opacity: 0.7;}\n  }\n\n  .node-text {\n    fill: var(--text-light);\n    font-weight: 600;\n    font-size: 1.1rem;\n    user-select: none;\n    letter-spacing: 0.04em;\n  }\n\n  /* Packet Styles */\n  .packet {\n    fill: var(--packet-green);\n    stroke: #0a7159;\n    stroke-width: 1.5;\n    filter: drop-shadow(0 0 5px rgba(60, 208, 112, 0.7));\n    transform-origin: center;\n    animation-timing-function: linear;\n  }\n\n  .packet-warning {\n    fill: var(--packet-orange);\n    stroke: #a66d1a;\n    filter: drop-shadow(0 0 5px rgba(255, 164, 77, 0.7));\n  }\n\n  .packet-drop {\n    fill: var(--packet-red);\n    stroke: #912929;\n    filter: drop-shadow(0 0 8px rgba(255, 106, 106, 0.8));\n  }\n\n  /* Buttons */\n  #controls {\n    margin-top: 2.5rem;\n    text-align: center;\n  }\n\n  button {\n    background: linear-gradient(135deg, #3a47d5, #00d2ff);\n    border: none;\n    color: white;\n    font-weight: 600;\n    font-family: 'Manrope', sans-serif;\n    font-size: 1.15rem;\n    padding: 0.75rem 2.25rem;\n    border-radius: 34px;\n    cursor: pointer;\n    box-shadow:\n      0 6px 16px rgba(58, 71, 213, 0.6),\n      inset 0 1px 2px rgba(255, 255, 255, 0.2);\n    transition:\n      box-shadow 0.3s ease,\n      transform 0.3s ease;\n    user-select: none;\n  }\n\n  button:hover {\n    box-shadow:\n      0 12px 22px rgba(58, 71, 213, 0.9),\n      inset 0 2px 5px rgba(255, 255, 255, 0.3);\n    transform: scale(1.08);\n  }\n\n  button:active {\n    transform: scale(0.97);\n  }\n\n  /* Packet animation paths */\n\n  /* Helper for easing */\n  @keyframes packetMoveForward {\n    0% {\n      offset-distance: 0%;\n      opacity: 1;\n      transform: rotate(0deg);\n    }\n    100% {\n      offset-distance: 100%;\n      opacity: 1;\n      transform: rotate(0deg);\n    }\n  }\n\n  @keyframes packetDropFade {\n    0% {\n      opacity: 1;\n      transform: scale(1) rotate(0deg);\n    }\n    80% {\n      opacity: 1;\n      transform: scale(1.2) rotate(15deg);\n    }\n    100% {\n      opacity: 0;\n      transform: scale(0.5) rotate(30deg);\n    }\n  }\n\n  svg {\n    overflow: visible;\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Congestion Control</h1>\n  <p>An aesthetic and animated visualization of network congestion dynamics</p>\n</header>\n<main>\n  <svg id=\"visualizer\" viewBox=\"0 0 900 380\" aria-label=\"Congestion control network visualization\" role=\"img\" >\n    <defs>\n      <linearGradient id=\"linkGradient\" x1=\"0%\" y1=\"50%\" x2=\"100%\" y2=\"50%\">\n        <stop offset=\"0%\" stop-color=\"#00d2ff\" />\n        <stop offset=\"100%\" stop-color=\"#3a47d5\" />\n      </linearGradient>\n\n      <path id=\"pathLink\" d=\"M 150 190 Q 450 50 750 190\" />\n    </defs>\n\n    <!-- Nodes with glowing halo -->\n    <g id=\"sender\" transform=\"translate(150,190)\" aria-label=\"Sender Node\" role=\"img\">\n      <circle class=\"node\" r=\"44\" />\n      <circle class=\"node-glow\" r=\"60\" />\n      <text class=\"node-text\" x=\"0\" y=\"7\" text-anchor=\"middle\">Sender</text>\n    </g>\n\n    <g id=\"receiver\" transform=\"translate(750,190)\" aria-label=\"Receiver Node\" role=\"img\">\n      <circle class=\"node\" r=\"44\" />\n      <circle class=\"node-glow\" r=\"60\" />\n      <text class=\"node-text\" x=\"0\" y=\"7\" text-anchor=\"middle\">Receiver</text>\n    </g>\n\n    <!-- Link line -->\n    <path class=\"link\" d=\"M 150 190 Q 450 50 750 190\" />\n\n    <!-- Congestion window visual -->\n    <rect x=\"340\" y=\"150\" width=\"220\" height=\"35\" rx=\"8\" ry=\"8\" fill=\"url(#linkGradient)\" filter=\"url(#glow)\" opacity=\"0.2\"/>\n\n    <!-- Congestion window text -->\n    <text x=\"450\" y=\"178\" fill=\"#e0e6f2\" font-family=\"Manrope\" font-weight=\"600\" font-size=\"1rem\" text-anchor=\"middle\" opacity=\"0.7\" user-select=\"none\">Congestion Window</text>\n  </svg>\n\n  <div id=\"congestionBarContainer\" role=\"img\" aria-label=\"Congestion window utilization bar\">\n    <div id=\"congestionBar\"></div>\n    <div id=\"congestionLabel\">Congestion Window: 0%</div>\n  </div>\n\n  <div id=\"controls\" aria-label=\"Controls\">\n    <button id=\"startBtn\" aria-pressed=\"false\" aria-label=\"Start animation\">Start Animation</button>\n    <button id=\"resetBtn\" aria-pressed=\"false\" aria-label=\"Reset animation\" disabled>Reset</button>\n  </div>\n</main>\n\n<script>\n  (function(){\n    const SVG_NS = \"http://www.w3.org/2000/svg\";\n    const visualizer = document.getElementById('visualizer');\n    const pathLink = visualizer.querySelector('#pathLink');\n    const startBtn = document.getElementById('startBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const congestionBar = document.getElementById('congestionBar');\n    const congestionLabel = document.getElementById('congestionLabel');\n\n    // Path length for offsetDistance animations\n    const pathLength = pathLink.getTotalLength();\n\n    // State variables\n    let animationRunning = false;\n\n    // Packet prototype function: create a packet circle with classes and initial opacity 0\n    function createPacket(className = 'packet', radius = 10) {\n      const circle = document.createElementNS(SVG_NS, 'circle');\n      circle.setAttribute('r', radius);\n      circle.setAttribute('class', className);\n      circle.style.offsetPath = 'path(\"M 150 190 Q 450 50 750 190\")';\n      circle.style.offsetDistance = '0%';\n      circle.style.opacity = '0';\n      circle.style.position = 'absolute';\n      // Enable GPU layer for smooth animations\n      circle.style.willChange = 'offset-distance, transform, opacity';\n      visualizer.appendChild(circle);\n      return circle;\n    }\n\n    // Create and store packets for animation\n    const packets = [];\n    // Three packets traveling normally (green)\n    for(let i=0; i<8; i++){\n      packets.push({el: createPacket('packet'), delay: i * 1300});\n    }\n\n    // Warning packet (orange)\n    const warningPacket = createPacket('packet packet-warning');\n    warningPacket.style.offsetDistance = '0%';\n    warningPacket.style.opacity = '0';\n\n    // Dropped packet (red)\n    const droppedPacket = createPacket('packet packet-drop');\n    droppedPacket.style.opacity = '0';\n\n    // Congestion Bar increments: from 0 to 100% and back to 30% cyclically\n    const congStates = [\n      {percent: 20, duration: 1200},\n      {percent: 45, duration: 1300},\n      {percent: 75, duration: 1400},\n      {percent: 95, duration: 1600},\n      {percent: 55, duration: 1300},\n      {percent: 30, duration: 1200}\n    ];\n\n    // Returns a Promise that resolves after ms milliseconds\n    function delay(ms) {\n      return new Promise(r => setTimeout(r, ms));\n    }\n\n    // Animate single packet forward along path\n    function animatePacket(packet, duration = 3500, startDelay = 0) {\n      return new Promise(resolve => {\n        packet.style.transition = 'none';\n        packet.style.opacity = '0';\n        packet.style.offsetDistance = '0%';\n\n        // Trigger reflow for immediate style applying\n        // eslint-disable-next-line no-unused-expressions\n        packet.offsetWidth;\n\n        setTimeout(() => {\n          packet.style.transition = `offset-distance ${duration}ms linear, opacity 500ms ease-in-out`;\n          packet.style.opacity = '1';\n          packet.style.offsetDistance = '100%';\n\n          // At 70% of duration, reduce opacity for fade effect\n          setTimeout(() => {\n            packet.style.opacity = '0';\n          }, duration * 0.85);\n\n          setTimeout(() => {\n            resolve();\n          }, duration + 150);\n        }, startDelay);\n      });\n    }\n\n    // Animate warning packet: slows and pulses on path then fades out\n    async function animateWarningPacket() {\n      return new Promise(resolve => {\n        warningPacket.style.transition = 'none';\n        warningPacket.style.opacity = '0';\n        warningPacket.style.offsetDistance = '0%';\n\n        // Reflow\n        warningPacket.offsetWidth;\n\n        warningPacket.style.transition = 'offset-distance 4s ease-in-out, opacity 400ms ease-in-out';\n        warningPacket.style.opacity = '1';\n        warningPacket.style.offsetDistance = '80%';\n\n        let pulseCount = 0;\n\n        function pulse() {\n          warningPacket.animate([\n            { transform: 'scale(1) rotate(0deg)', offset: 0 },\n            { transform: 'scale(1.2) rotate(5deg)', offset: 0.5 },\n            { transform: 'scale(1) rotate(0deg)', offset: 1 }\n          ], {\n            duration: 1200,\n            iterations: 3,\n            easing: 'ease-in-out'\n          });\n\n          pulseCount++;\n        }\n\n        setTimeout(() => pulse(), 600);\n\n        setTimeout(() => {\n          warningPacket.style.opacity = '0';\n          setTimeout(() => resolve(), 800);\n        }, 4000);\n      });\n    }\n\n    // Animate dropped packet fading out near sender, simulating drop\n    async function animateDroppedPacket() {\n      return new Promise(resolve => {\n        droppedPacket.style.transition = 'none';\n        droppedPacket.style.opacity = '1';\n        droppedPacket.setAttribute('cx', '150');\n        droppedPacket.setAttribute('cy', '190');\n        droppedPacket.style.transformOrigin = 'center';\n        droppedPacket.style.transform = 'scale(1) rotate(0deg)';\n        droppedPacket.style.willChange = 'transform, opacity';\n\n        // Reflow\n        droppedPacket.offsetWidth;\n\n        droppedPacket.style.transition = 'opacity 1500ms ease-in, transform 1500ms ease-in';\n        droppedPacket.style.opacity = '0';\n        droppedPacket.style.transform = 'scale(0.3) rotate(30deg) translateY(22px)';\n\n        setTimeout(() => {\n          resolve();\n        }, 1600);\n      });\n    }\n\n    // Animate congestion bar with smooth linear interpolation between states\n    async function animateCongestionBar() {\n      for(let i=0; i<congStates.length; i++) {\n        const state = congStates[i];\n        congestionBar.style.transition = `width ${state.duration}ms ease-in-out`;\n        congestionBar.style.width = `${state.percent}%`;\n        congestionLabel.textContent = `Congestion Window: ${state.percent}%`;\n        await delay(state.duration + 100);\n      }\n    }\n\n    // Animate whole cycle\n    async function startAnimationCycle() {\n      if(animationRunning) return;\n      animationRunning = true;\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      startBtn.setAttribute('aria-pressed', 'true');\n      resetBtn.setAttribute('aria-pressed', 'false');\n\n      // Loop packets with staggered start times, for 3 iterations\n      for(let cycle=0; cycle < 3; cycle++) {\n        // Animate green packets moving forward\n        let packetPromises = [];\n        for(let i=0; i<packets.length; i++){\n          packetPromises.push(animatePacket(packets[i].el, 3800, packets[i].delay));\n        }\n\n        // Animate congestion bar increasing\n        const congestionPromise = animateCongestionBar();\n\n        // Wait until all packets finish\n        await Promise.all(packetPromises.concat(congestionPromise));\n\n        // Animate warning orange packet (congestion alert)\n        await animateWarningPacket();\n\n        // Animate congestion bar decrease partially\n        congestionBar.style.transition = 'width 1200ms ease-in-out';\n        congestionBar.style.width = '30%';\n        congestionLabel.textContent = 'Congestion Window: 30%';\n        await delay(1300);\n\n        // Animate dropped red packet near sender\n        await animateDroppedPacket();\n\n        // Reset packets opacity\n        packets.forEach(p => {\n          p.el.style.transition = 'none';\n          p.el.style.opacity = '0';\n          p.el.style.offsetDistance = '0%';\n        });\n        warningPacket.style.opacity = '0';\n        droppedPacket.style.opacity = '0';\n      }\n\n      startBtn.disabled = false;\n      resetBtn.disabled = true;\n      startBtn.setAttribute('aria-pressed', 'false');\n      animationRunning = false;\n    }\n\n    // Reset visual elements to initial states\n    function resetAnimation() {\n      if(animationRunning) return;\n      congestionBar.style.transition = 'width 800ms ease-in-out';\n      congestionBar.style.width = '0%';\n      congestionLabel.textContent = 'Congestion Window: 0%';\n\n      packets.forEach(p => {\n        p.el.style.transition = 'none';\n        p.el.style.opacity = '0';\n        p.el.style.offsetDistance = '0%';\n      });\n\n      warningPacket.style.opacity = '0';\n      droppedPacket.style.opacity = '0';\n\n      startBtn.disabled = false;\n      resetBtn.disabled = true;\n    }\n\n    startBtn.addEventListener('click', startAnimationCycle);\n    resetBtn.addEventListener('click', resetAnimation);\n\n    // Initial congestion bar zero width\n    resetAnimation();\n  })();\n</script>\n</body>\n</html>"
