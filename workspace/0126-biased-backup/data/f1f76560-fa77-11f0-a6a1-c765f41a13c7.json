    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Thread — Visual Concept</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071026;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.65);\n    --accent-1: #7ee7ff;\n    --accent-2: #9b8cff;\n    --accent-3: #ff9bd6;\n    --card-radius: 16px;\n    --focus: 0 8px 30px rgba(110,99,255,0.18);\n    --glass-border: rgba(255,255,255,0.06);\n    --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Segoe UI Mono\", monospace;\n    --ui: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(15,20,36,0.7), transparent 10%),\n                radial-gradient(900px 500px at 90% 90%, rgba(7,16,38,0.6), transparent 12%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: #fff;\n    font-family: var(--ui);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Container */\n  .stage{\n    position:relative;\n    height:100vh;\n    width:100vw;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap: 24px;\n    padding:48px;\n    box-sizing:border-box;\n  }\n\n  /* Canvas fills background area */\n  canvas#threadCanvas{\n    position:absolute;\n    inset:0;\n    width:100%;\n    height:100%;\n    display:block;\n    z-index:0;\n    transition: filter 400ms cubic-bezier(.2,.9,.3,1), opacity .4s;\n    will-change: transform, filter;\n  }\n\n  /* Faint decorative starfield */\n  .stars{\n    position:absolute;\n    inset:0;\n    z-index:0;\n    pointer-events:none;\n    mix-blend-mode: screen;\n  }\n\n  /* Central hero card */\n  .card{\n    position:relative;\n    z-index:3;\n    width:min(980px,92vw);\n    max-width:1200px;\n    padding:36px;\n    border-radius:var(--card-radius);\n    background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: var(--focus);\n    backdrop-filter: blur(10px) saturate(120%);\n    display:flex;\n    align-items:center;\n    gap:28px;\n    overflow:visible;\n  }\n\n  .hero{\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n    align-items:flex-start;\n    flex:0 1 60%;\n  }\n\n  h1{\n    margin:0;\n    font-size: clamp(34px, 6vw, 56px);\n    letter-spacing: -0.02em;\n    font-weight:700;\n    line-height:1;\n    color: #fff;\n    text-shadow: 0 6px 30px rgba(120,100,255,0.12);\n  }\n\n  h1 .accent{\n    background: linear-gradient(90deg,var(--accent-1),var(--accent-2),var(--accent-3));\n    -webkit-background-clip: text;\n    background-clip:text;\n    color:transparent;\n    font-weight:800;\n  }\n\n  p.lead{\n    margin:0;\n    font-size:16px;\n    color: var(--muted);\n    max-width:52ch;\n  }\n\n  .meta{\n    margin-top:8px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .pill{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    padding:6px 12px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    box-shadow: 0 6px 20px rgba(12,12,18,0.45);\n  }\n\n  .visual{\n    position:relative;\n    flex:0 0 40%;\n    min-width:240px;\n    max-width:420px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Decorative phantom frame */\n  .frame{\n    width:100%;\n    height:220px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 6px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    overflow:hidden;\n    position:relative;\n  }\n\n  .frame .mini{\n    position:absolute;\n    inset:0;\n    display:block;\n    pointer-events:none;\n  }\n\n  .frame .label{\n    position:absolute;\n    left:18px;\n    top:14px;\n    font-size:12px;\n    color:var(--muted);\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), transparent);\n    padding:6px 10px;\n    border-radius:999px;\n    border:1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(6px);\n  }\n\n  /* Single control button (only one) */\n  .control{\n    position:fixed;\n    right:28px;\n    bottom:28px;\n    z-index:6;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.06);\n    color:#fff;\n    padding:12px 16px;\n    border-radius:12px;\n    font-weight:600;\n    letter-spacing:0.02em;\n    box-shadow: 0 10px 30px rgba(3,10,30,0.6);\n    cursor:pointer;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition: transform .22s cubic-bezier(.2,.9,.3,1), box-shadow .22s;\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n  .control:active{ transform: translateY(1px) scale(.998); }\n  .control:hover{ transform: translateY(-3px); box-shadow:0 18px 50px rgba(3,10,30,0.7); }\n  .control .dot{\n    width:10px;height:10px;border-radius:50%;\n    box-shadow: 0 4px 14px rgba(126,231,255,0.12);\n    background: linear-gradient(180deg,var(--accent-1),var(--accent-2));\n    transition: transform .22s;\n  }\n  .control.paused .dot{\n    background: linear-gradient(180deg,#ff9ea8,#ff7aa2);\n    transform: scale(.9);\n  }\n\n  /* subtle footer label */\n  .credit{\n    position:fixed;\n    left:28px;\n    bottom:28px;\n    color:rgba(255,255,255,0.45);\n    font-size:13px;\n    z-index:6;\n    backdrop-filter: blur(6px);\n    padding:8px 12px;\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.03);\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), transparent);\n  }\n\n  /* Responsive adjustments */\n  @media (max-width:880px){\n    .card{ flex-direction:column; align-items:flex-start; gap:18px; padding:22px; }\n    .visual{ width:100%; }\n    .frame{ width:100%; height:200px; }\n  }\n\n  /* Small fade overlay when paused */\n  .paused-overlay{\n    position:absolute;\n    inset:0;\n    z-index:4;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n    opacity:0;\n    transition: opacity .3s;\n  }\n  .paused-overlay.show{\n    opacity:1;\n  }\n  .pause-badge{\n    background: linear-gradient(90deg, rgba(10,12,20,0.72), rgba(10,12,25,0.6));\n    border:1px solid rgba(255,255,255,0.04);\n    padding:12px 18px;\n    border-radius:999px;\n    color:var(--muted);\n    font-weight:700;\n    letter-spacing:0.06em;\n    backdrop-filter: blur(6px);\n  }\n</style>\n</head>\n<body>\n  <div class=\"stage\" aria-hidden=\"false\">\n    <canvas id=\"threadCanvas\"></canvas>\n\n    <!-- starfield created with SVG for crispness -->\n    <svg class=\"stars\" viewBox=\"0 0 800 600\" preserveAspectRatio=\"xMidYMid slice\" aria-hidden=\"true\">\n      <defs>\n        <filter id=\"glow\">\n          <feGaussianBlur stdDeviation=\"2.8\" result=\"coloredBlur\"/>\n          <feMerge>\n            <feMergeNode in=\"coloredBlur\"/>\n            <feMergeNode in=\"SourceGraphic\"/>\n          </feMerge>\n        </filter>\n      </defs>\n      <g fill=\"rgba(255,255,255,0.06)\" stroke=\"none\" filter=\"url(#glow)\">\n        <circle cx=\"56\" cy=\"44\" r=\"1.6\" opacity=\"0.9\"/>\n        <circle cx=\"142\" cy=\"22\" r=\"1.2\" opacity=\"0.6\"/>\n        <circle cx=\"232\" cy=\"180\" r=\"1.8\" opacity=\"0.85\"/>\n        <circle cx=\"592\" cy=\"120\" r=\"1.3\" opacity=\"0.7\"/>\n        <circle cx=\"680\" cy=\"48\" r=\"1.4\" opacity=\"0.6\"/>\n        <circle cx=\"740\" cy=\"420\" r=\"1.6\" opacity=\"0.5\"/>\n        <circle cx=\"420\" cy=\"96\" r=\"1.7\" opacity=\"0.8\"/>\n        <circle cx=\"300\" cy=\"280\" r=\"1.2\" opacity=\"0.65\"/>\n        <circle cx=\"520\" cy=\"380\" r=\"2.4\" opacity=\"0.85\"/>\n        <circle cx=\"80\" cy=\"520\" r=\"1.3\" opacity=\"0.5\"/>\n        <circle cx=\"700\" cy=\"520\" r=\"1.4\" opacity=\"0.45\"/>\n      </g>\n    </svg>\n\n    <div class=\"card\" role=\"region\" aria-label=\"Thread visualization\">\n      <div class=\"hero\">\n        <h1><span class=\"accent\">THREAD</span> — Weaving Motion</h1>\n        <p class=\"lead\">A minimalist visualization of threads: smooth, luminous strands that weave and connect, conveying continuity and subtle motion. Observe the interplay of color, light and flow.</p>\n        <div class=\"meta\">\n          <div class=\"pill\">Concept • Motion • Elegance</div>\n          <div style=\"opacity:.9;font-size:13px;padding:6px 12px;border-radius:10px;background:rgba(255,255,255,0.01);border:1px solid rgba(255,255,255,0.02);\">One control: Pause / Play</div>\n        </div>\n      </div>\n\n      <div class=\"visual\" aria-hidden=\"true\">\n        <div class=\"frame\">\n          <div class=\"label\">Threads • Live</div>\n          <svg class=\"mini\" viewBox=\"0 0 600 240\" preserveAspectRatio=\"none\">\n            <!-- subtle decorative arcs -->\n            <defs>\n              <linearGradient id=\"gA\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7ee7ff\" stop-opacity=\"0.18\"/>\n                <stop offset=\"1\" stop-color=\"#9b8cff\" stop-opacity=\"0.06\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M20 220 C120 40, 480 40, 580 220\" stroke=\"url(#gA)\" stroke-width=\"1.4\" fill=\"none\" opacity=\"0.8\" stroke-linecap=\"round\"/>\n            <path d=\"M40 200 C140 70, 460 70, 560 200\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"1.2\" fill=\"none\" stroke-dasharray=\"6 12\"/>\n          </svg>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"paused-overlay\" id=\"pausedOverlay\" aria-hidden=\"true\">\n      <div class=\"pause-badge\" id=\"pauseBadge\">PAUSED</div>\n    </div>\n\n    <button id=\"playPause\" class=\"control\" aria-pressed=\"false\" aria-label=\"Pause the thread animation\">\n      <span class=\"dot\" id=\"dot\"></span>\n      <span id=\"btnLabel\">Pause</span>\n    </button>\n\n    <div class=\"credit\">Visual concept • Threads</div>\n  </div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('threadCanvas');\n  const ctx = canvas.getContext('2d', { alpha: true });\n  const dpr = Math.max(1, window.devicePixelRatio || 1);\n\n  let w = 0, h = 0;\n  function resize(){\n    w = canvas.clientWidth;\n    h = canvas.clientHeight;\n    canvas.width = Math.floor(w * dpr);\n    canvas.height = Math.floor(h * dpr);\n    ctx.setTransform(dpr,0,0,dpr,0,0);\n  }\n  window.addEventListener('resize', resize);\n  resize();\n\n  // Configuration\n  const center = () => ({ x: w * 0.5, y: h * 0.52 });\n  const THREAD_COUNT = 7;\n  const POINTS = 7;\n  const baseRadius = Math.min(w,h) * 0.18;\n  const palettes = [\n    ['#7ee7ff','#9b8cff','#ff9bd6'],\n    ['#ffd98e','#ff9e9e','#ff8fe2'],\n    ['#8ee7b6','#6bd6ff','#9b8cff'],\n    ['#7ee7ff','#a4f0c1','#ffd98e']\n  ];\n\n  // create threads\n  const threads = [];\n  for(let i=0;i<THREAD_COUNT;i++){\n    const colorSet = palettes[i % palettes.length];\n    threads.push({\n      id: i,\n      phase: Math.random() * Math.PI * 2,\n      speed: 0.2 + Math.random()*0.45,\n      radius: baseRadius * (0.6 + i*0.12),\n      points: new Array(POINTS).fill(0).map((_,k)=>({\n        angle: (k / POINTS) * Math.PI * 2 + (i * 0.14),\n        offset: (Math.random()-.5) * 0.2,\n        wiggle: Math.random() * 0.9 + 0.2\n      })),\n      colors: colorSet\n    });\n  }\n\n  // subtle floating nodes\n  const nodes = [];\n  for(let i=0;i<12;i++){\n    nodes.push({\n      x: Math.random()*w,\n      y: Math.random()*h,\n      r: 2 + Math.random()*4,\n      phase: Math.random()*Math.PI*2,\n      vx: (Math.random()-.5)*0.12,\n      vy: (Math.random()-.5)*0.12\n    });\n  }\n\n  let t0 = performance.now();\n  let running = true;\n  const overlay = document.getElementById('pausedOverlay');\n  const btn = document.getElementById('playPause');\n  const btnLabel = document.getElementById('btnLabel');\n  const btnDot = document.getElementById('dot');\n\n  btn.addEventListener('click', ()=>{\n    running = !running;\n    btn.setAttribute('aria-pressed', String(!running));\n    btn.classList.toggle('paused', !running);\n    btnLabel.textContent = running ? 'Pause' : 'Play';\n    btn.setAttribute('aria-label', running ? 'Pause the thread animation' : 'Play the thread animation');\n    overlay.classList.toggle('show', !running);\n  });\n\n  // draw function\n  function draw(now){\n    if(!running) {\n      requestAnimationFrame(draw);\n      return;\n    }\n    const t = (now - t0) / 1000;\n    ctx.clearRect(0,0,w,h);\n\n    // subtle layered vignette\n    const gV = ctx.createLinearGradient(0,0,0,h);\n    gV.addColorStop(0, 'rgba(255,255,255,0.02)');\n    gV.addColorStop(1, 'rgba(0,0,0,0.25)');\n    ctx.fillStyle = gV;\n    // ctx.fillRect(0,0,w,h); // optional\n\n    // ambient soft light\n    ctx.globalCompositeOperation = 'lighter';\n    for(let i=0;i<3;i++){\n      const cx = center().x + Math.cos(t*0.25 + i*2.1) * (w*0.22);\n      const cy = center().y + Math.sin(t*0.25 + i*1.3) * (h*0.08);\n      const rg = ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(w,h)*0.8);\n      const c = i===0 ? 'rgba(126,231,255,' : i===1 ? 'rgba(155,140,255,' : 'rgba(255,155,200,';\n      rg.addColorStop(0, c + '0.06)');\n      rg.addColorStop(0.45, c + '0.03)');\n      rg.addColorStop(1, 'rgba(0,0,0,0)');\n      ctx.fillStyle = rg;\n      ctx.fillRect(0,0,w,h);\n    }\n\n    // update nodes (slow drift)\n    ctx.globalCompositeOperation = 'screen';\n    nodes.forEach(n=>{\n      n.x += Math.sin(t*0.4 + n.phase)*0.06 + n.vx;\n      n.y += Math.cos(t*0.5 + n.phase)*0.06 + n.vy;\n      // wrap\n      if(n.x < -40) n.x = w + 40;\n      if(n.x > w + 40) n.x = -40;\n      if(n.y < -40) n.y = h + 40;\n      if(n.y > h + 40) n.y = -40;\n      // draw soft dot\n      const gr = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, Math.max(16, n.r*6));\n      gr.addColorStop(0, 'rgba(255,255,255,0.06)');\n      gr.addColorStop(0.3, 'rgba(255,255,255,0.02)');\n      gr.addColorStop(1, 'rgba(255,255,255,0)');\n      ctx.fillStyle = gr;\n      ctx.beginPath();\n      ctx.arc(n.x, n.y, Math.max(16, n.r*6), 0, Math.PI*2);\n      ctx.fill();\n    });\n\n    // threads\n    threads.forEach((thread, idx)=>{\n      const base = center();\n      const pts = [];\n      const phase = thread.phase + t * thread.speed * 0.6;\n      for(let i=0;i<thread.points.length;i++){\n        const p = thread.points[i];\n        const ip = i / (thread.points.length - 1);\n        // angle rotates slowly; each point has slight offset for smoother weave\n        const angle = p.angle + Math.sin(phase * (0.8 + p.offset*0.6) + i*0.7) * 0.8 * p.wiggle;\n        const radialJitter = thread.radius * (0.5 + ip*0.9) * (1 + Math.sin(phase*1.2 + i*0.6)*0.08 + Math.cos(-t * 0.6 + i*0.9)*0.06);\n        const x = base.x + Math.cos(angle) * radialJitter;\n        const y = base.y + Math.sin(angle) * radialJitter * (0.7 + Math.sin(t*0.2 + i)*0.03);\n        pts.push({x,y,ip});\n      }\n\n      // create gradient stroke for thread\n      const grad = ctx.createLinearGradient(pts[0].x, pts[0].y, pts[pts.length-1].x, pts[pts.length-1].y);\n      const c0 = thread.colors[Math.floor(Math.random()*thread.colors.length)];\n      const c1 = thread.colors[(Math.floor(Math.random()*thread.colors.length)+1)%thread.colors.length];\n      grad.addColorStop(0, c0);\n      grad.addColorStop(0.5, c1);\n      grad.addColorStop(1, 'rgba(255,255,255,0.06)');\n\n      // shadow and glow\n      ctx.lineWidth = 2.6 + (1.4 * (idx / threads.length));\n      ctx.lineCap = 'round';\n      ctx.lineJoin = 'round';\n      ctx.strokeStyle = grad;\n      ctx.shadowBlur = 16 + (idx * 2.2);\n      ctx.shadowColor = 'rgba(126,231,255,0.12)';\n\n      // motion trail: draw path in multiple strokes for depth\n      // Path via Catmull-Rom to bezier conversion for smoothness\n      function catmullLoop(ptsArr){\n        const res = [];\n        // pad endpoints\n        const p0 = ptsArr[0];\n        const pN = ptsArr[ptsArr.length-1];\n        const extended = [p0, ...ptsArr, pN];\n        for(let i=0; i<ptsArr.length-1; i++){\n          const pA = extended[i];\n          const pB = extended[i+1];\n          const pC = extended[i+2];\n          const pD = extended[i+3] || pC;\n          // control points\n          const cp1x = pB.x + (pC.x - pA.x) / 6;\n          const cp1y = pB.y + (pC.y - pA.y) / 6;\n          const cp2x = pC.x - (pD.x - pB.x) / 6;\n          const cp2y = pC.y - (pD.y - pB.y) / 6;\n          res.push({ from: pB, cp1: {x:cp1x,y:cp1y}, cp2: {x:cp2x,y:cp2y}, to: pC });\n        }\n        return res;\n      }\n\n      const segs = catmullLoop(pts);\n\n      // draw subtle layered strokes for each thread to create depth\n      for(let pass=0; pass<3; pass++){\n        ctx.beginPath();\n        // varying width and alpha\n        const alpha = 0.18 + (0.24 * (2-pass)/3);\n        ctx.globalAlpha = alpha;\n        if(pass===0){\n          ctx.lineWidth = ctx.lineWidth * 1.6;\n        } else if(pass===1){\n          ctx.lineWidth = ctx.lineWidth * 1.05;\n        } else {\n          ctx.lineWidth = ctx.lineWidth * 0.7;\n        }\n        // start from first point\n        const start = pts[0];\n        ctx.moveTo(start.x, start.y);\n        segs.forEach(seg=>{\n          ctx.bezierCurveTo(seg.cp1.x, seg.cp1.y, seg.cp2.x, seg.cp2.y, seg.to.x, seg.to.y);\n        });\n        ctx.stroke();\n      }\n\n      // draw luminous nodes along the thread\n      ctx.globalAlpha = 1.0;\n      for(let i=0;i<pts.length;i+=Math.max(1, Math.floor(2 + idx/2))){\n        const p = pts[i];\n        const radius = 1.2 + (1.8 * (1 - Math.abs(0.5 - p.ip)));\n        const glow = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, Math.max(10, radius*10));\n        glow.addColorStop(0, 'rgba(255,255,255,0.9)');\n        glow.addColorStop(0.16, 'rgba(255,255,255,0.3)');\n        glow.addColorStop(1, 'rgba(255,255,255,0)');\n        ctx.fillStyle = glow;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, Math.max(6, radius*6), 0, Math.PI*2);\n        ctx.fill();\n      }\n\n      ctx.shadowBlur = 0;\n      ctx.globalAlpha = 1.0;\n    });\n\n    // faint overlay to give trailing effect\n    ctx.globalCompositeOperation = 'source-over';\n    // tiny vignette inner\n    //ctx.fillStyle = 'rgba(0,0,0,0.02)';\n    //ctx.fillRect(0,0,w,h);\n\n    requestAnimationFrame(draw);\n  }\n\n  // Start animator\n  requestAnimationFrame(draw);\n\n  // initial subtle animation to encourage attention\n  let wiggle = true;\n  setTimeout(()=>{ wiggle = false; }, 3000);\n\n  // Ensure canvas resized initially for DPR\n  const resizeObserver = new ResizeObserver(resize);\n  resizeObserver.observe(document.body);\n\n  // Accessibility: space toggles pause\n  window.addEventListener('keydown', (e) => {\n    if(e.code === 'Space' || e.key === ' ') {\n      e.preventDefault();\n      btn.click();\n    }\n  });\n})();\n</script>\n</body>\n</html>"
  },
