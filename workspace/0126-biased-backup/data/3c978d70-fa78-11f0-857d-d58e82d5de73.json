    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Depth-First Search (DFS) Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap');\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #1f2235, #2d3246);\n    font-family: 'Poppins', sans-serif;\n    color: #e6eaf3;\n    overflow: hidden;\n    user-select: none;\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* Title */\n  header {\n    padding: 2rem 3rem 1rem 3rem;\n    text-align: center;\n    position: relative;\n    z-index: 20;\n  }\n  header h1 {\n    font-weight: 700;\n    font-size: 3rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #aaccec;\n    filter: drop-shadow(0 0 6px #3ca4ff88);\n    margin: 0;\n  }\n  header p {\n    font-weight: 400;\n    font-size: 1.1rem;\n    margin-top: 0.3rem;\n    color: #abb7d1;\n    letter-spacing: 0.07em;\n  }\n\n  /* Main container */\n  main {\n    flex: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n  }\n\n  /* Graph container */\n  #graph {\n    position: relative;\n    width: 650px;\n    height: 600px;\n    background: radial-gradient(circle at center, #2e364d 50%, #212837 90%);\n    border-radius: 28px;\n    box-shadow:\n      0 0 15px 4px #1456d680,\n      inset 0 0 25px #4169e1cc;\n    overflow: visible;\n  }\n\n  /* SVG styling */\n  svg {\n    width: 100%;\n    height: 100%;\n  }\n\n  /* Edges */\n  .edge {\n    stroke: #374785;\n    stroke-width: 3;\n    fill: none;\n    filter: drop-shadow(0 0 1.5px #2a3aeb88);\n    transition: stroke 0.4s ease;\n    stroke-linecap: round;\n  }\n\n  .edge.visited {\n    stroke: #3ca4ff;\n    stroke-width: 5;\n    filter: drop-shadow(0 0 8px #3ca4ffcc);\n    transition: stroke 0.6s ease, stroke-width 0.6s ease, filter 0.6s ease;\n  }\n\n  /* Nodes */\n  .node {\n    cursor: default;\n    transition: transform 0.4s ease;\n    filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.2));\n  }\n\n  /* Circles */\n  .node circle {\n    fill: #344a97;\n    stroke: #24365b;\n    stroke-width: 4;\n    filter: drop-shadow(0 0 13px #3766ffaa);\n    transition: fill 0.5s ease, filter 0.5s ease, stroke-width 0.5s ease;\n  }\n\n  .node.visited circle {\n    fill: #3ca4ff;\n    stroke: #75baff;\n    stroke-width: 6;\n    filter: drop-shadow(0 0 20px #3ca4ffdd);\n  }\n\n  /* Node labels */\n  .node text {\n    fill: #cfd8fa;\n    font-size: 1.15rem;\n    font-weight: 700;\n    pointer-events: none;\n    user-select: none;\n    filter: drop-shadow(0 0 2px #1f2837);\n    transition: fill 0.4s ease;\n  }\n\n  .node.visited text {\n    fill: #d2e8ff;\n  }\n\n  /* Highlight pulsing effect for current node */\n  .node.current circle {\n    animation: pulseGlow 2s infinite alternate ease-in-out;\n  }\n\n  @keyframes pulseGlow {\n    0% {\n      filter: drop-shadow(0 0 20px #3ca4ffdd);\n      stroke-width: 8;\n    }\n    100% {\n      filter: drop-shadow(0 0 36px #3ca4ffee);\n      stroke-width: 9;\n    }\n  }\n\n  /* Info panel */\n  #infoPanel {\n    position: absolute;\n    top: 2rem;\n    right: 3rem;\n    width: 300px;\n    background: rgba(30,40,60,0.85);\n    padding: 1.5rem 2rem;\n    border-radius: 20px;\n    box-shadow:\n      0 0 15px 3px #3ca4ffaa,\n      inset 0 0 10px #3ca4ffbb;\n    font-weight: 400;\n    color: #b6c5e2dd;\n    line-height: 1.5;\n    user-select: none;\n    font-size: 1.05rem;\n  }\n  #infoPanel h2 {\n    font-weight: 700;\n    font-size: 1.6rem;\n    margin-bottom: 0.6rem;\n    color: #a8c6ffcc;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    text-align: center;\n    text-shadow: 0 0 8px #3ca4ffcc;\n  }\n\n  /* Footer controls */\n  footer {\n    padding: 1.3rem 3rem;\n    text-align: center;\n    background: #1f223537;\n    backdrop-filter: blur(8px);\n    border-top: 1px solid #3ca4ff44;\n    user-select: none;\n  }\n  button {\n    background: #3ca4ffcc;\n    border: none;\n    border-radius: 50px;\n    padding: 0.85rem 2.6rem;\n    color: #e4f0ff;\n    font-size: 1.1rem;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    cursor: pointer;\n    box-shadow: 0 0 22px 3px #3ca4ffbb;\n    transition: background 0.4s ease;\n    outline-offset: 3px;\n    outline-color: #6db9ff77;\n  }\n  button:hover {\n    background: #72b9ffee;\n  }\n  button:focus-visible {\n    outline: 3.5px solid #72b9ffdd;\n  }\n  button:disabled {\n    background: #3ca4ff88;\n    cursor: default;\n    box-shadow: none;\n  }\n\n  @media (max-width: 720px) {\n    #graph {\n      width: 90vw;\n      height: 90vw;\n      max-height: 90vw;\n    }\n    #infoPanel {\n      position: static;\n      width: 100%;\n      margin: 1rem auto 0 auto;\n      border-radius: 16px;\n      box-shadow: none;\n      background: transparent;\n      color: #aec8ffcc;\n      font-size: 1rem;\n      text-align: center;\n      padding: 0.7rem 1rem;\n    }\n    main {\n      flex-direction: column;\n      padding-bottom: 0.7rem;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Depth-First Search (DFS)</h1>\n  <p>Visual demonstration of DFS traversal on a graph with a solitary control</p>\n</header>\n<main>\n  <div id=\"graph\" aria-label=\"Depth First Search graph visualization\" role=\"img\">\n    <svg viewBox=\"0 0 650 600\" aria-hidden=\"true\" focusable=\"false\">\n      <!-- Edges defined dynamically -->\n    </svg>\n  </div>\n\n  <div id=\"infoPanel\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"text\">\n    <h2>Traversal Info</h2>\n    <p><strong>Current Node:</strong> <span id=\"currentNode\">-</span></p>\n    <p><strong>Visited Order:</strong></p>\n    <ol id=\"visitedList\" style=\"max-height: 220px; overflow-y: auto; padding-left: 1.2rem; color:#9db9ffcc; font-size:0.95rem;\"></ol>\n  </div>\n</main>\n<footer>\n  <button id=\"startBtn\" aria-label=\"Start DFS traversal\">Start DFS</button>\n</footer>\n\n<script>\n  (() => {\n    /** Graph data (nodes and edges), positions for nice layout **/\n    const nodes = [\n      { id: 'A', x: 320, y: 60 },\n      { id: 'B', x: 160, y: 150 },\n      { id: 'C', x: 480, y: 150 },\n      { id: 'D', x: 110, y: 320 },\n      { id: 'E', x: 270, y: 310 },\n      { id: 'F', x: 370, y: 310 },\n      { id: 'G', x: 530, y: 320 },\n      { id: 'H', x: 260, y: 470 },\n      { id: 'I', x: 380, y: 470 }\n    ];\n\n    /** Adjacency list describing graph edges **/\n    const adjacency = {\n      'A': ['B', 'C'],\n      'B': ['A', 'D', 'E'],\n      'C': ['A', 'F', 'G'],\n      'D': ['B', 'H'],\n      'E': ['B', 'H', 'I'],\n      'F': ['C', 'I'],\n      'G': ['C'],\n      'H': ['D', 'E'],\n      'I': ['E', 'F']\n    };\n\n    const svg = document.querySelector('svg');\n    const currentNodeEl = document.getElementById('currentNode');\n    const visitedListEl = document.getElementById('visitedList');\n    const startBtn = document.getElementById('startBtn');\n    const graphDiv = document.getElementById('graph');\n\n    /** Create edges as lines and append to SVG **/\n    const edgesElements = [];\n    for (const u in adjacency) {\n      const fromNode = nodes.find(n => n.id === u);\n      adjacency[u].forEach(v => {\n        // To prevent duplicated edges, draw only if u<v lex order\n        if (u < v) {\n          const toNode = nodes.find(n => n.id === v);\n          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n          line.setAttribute('class', 'edge');\n          line.setAttribute('x1', fromNode.x);\n          line.setAttribute('y1', fromNode.y);\n          line.setAttribute('x2', toNode.x);\n          line.setAttribute('y2', toNode.y);\n          line.setAttribute('data-from', u);\n          line.setAttribute('data-to', v);\n          svg.appendChild(line);\n          edgesElements.push(line);\n        }\n      });\n    }\n\n    /** Create nodes as groups with circle and text and append to SVG **/\n    const nodeElements = {};\n    nodes.forEach(({ id, x, y }) => {\n      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n      g.setAttribute('class', 'node');\n      g.setAttribute('transform', `translate(${x},${y})`);\n      g.setAttribute('data-id', id);\n\n      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('r', 28);\n\n      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      text.setAttribute('text-anchor', 'middle');\n      text.setAttribute('dominant-baseline', 'middle');\n      text.textContent = id;\n\n      g.appendChild(circle);\n      g.appendChild(text);\n      svg.appendChild(g);\n      nodeElements[id] = g;\n    });\n\n    /** Helper: highlight edge between nodes **/\n    function highlightEdge(u, v, add) {\n      // find line matching the edge\n      const edge = edgesElements.find(line => {\n        const f = line.getAttribute('data-from'),\n              t = line.getAttribute('data-to');\n        return (f === u && t === v) || (f === v && t === u);\n      });\n      if (!edge) return;\n      if (add) {\n        edge.classList.add('visited');\n      } else {\n        edge.classList.remove('visited');\n      }\n    }\n\n    /** DFS traversal variables **/\n    let visitedOrder = [];\n    let visitedSet = new Set();\n    let stack = [];\n\n    /** Clear all highlights **/\n    function resetStyles() {\n      visitedOrder = [];\n      visitedSet.clear();\n      stack = [];\n      Object.values(nodeElements).forEach(n => {\n        n.classList.remove('visited');\n        n.classList.remove('current');\n      });\n      edgesElements.forEach(line => {\n        line.classList.remove('visited');\n      });\n      currentNodeEl.textContent = '-';\n      visitedListEl.innerHTML = '';\n      startBtn.disabled = false;\n    }\n\n    /** Animate DFS traversal recursively with async delay **/\n    const delay = ms => new Promise(res => setTimeout(res, ms));\n\n    async function dfs(startId) {\n      startBtn.disabled = true;\n      resetStyles();\n      stack.push(startId);\n\n      while (stack.length > 0) {\n        const nodeId = stack.pop();\n\n        if (!visitedSet.has(nodeId)) {\n          // Mark current node\n          nodeElements[nodeId].classList.add('current');\n          currentNodeEl.textContent = nodeId;\n\n          // Animate delay for current selection\n          await delay(1200);\n\n          // Mark as visited\n          visitedSet.add(nodeId);\n          visitedOrder.push(nodeId);\n          updateVisitedList();\n\n          nodeElements[nodeId].classList.add('visited');\n          nodeElements[nodeId].classList.remove('current');\n\n          // Highlight edges to neighbors visited next\n          const neighbors = adjacency[nodeId]\n            .filter(n => !visitedSet.has(n))\n            .sort((a,b) => a.localeCompare(b)); // keep lex order for consistent traversal\n\n          // Push neighbors in reverse order so DFS stack pops them in lex order\n          neighbors.reverse().forEach(nb => {\n            stack.push(nb);\n            highlightEdge(nodeId, nb, true);\n          });\n\n          // Remove highlight from edges to already visited or skipped neighbors\n          adjacency[nodeId].forEach(nb => {\n            if (visitedSet.has(nb)) {\n              highlightEdge(nodeId, nb, true);\n            }\n          });\n        }\n      }\n\n      currentNodeEl.textContent = 'Completed';\n      startBtn.disabled = false;\n    }\n\n    /** Update visited nodes list display **/\n    function updateVisitedList() {\n      visitedListEl.innerHTML = '';\n      visitedOrder.forEach((nodeId, i) => {\n        const li = document.createElement('li');\n        li.textContent = `${nodeId} (${i + 1})`;\n        visitedListEl.appendChild(li);\n      });\n      // Autoscroll to bottom\n      visitedListEl.scrollTop = visitedListEl.scrollHeight;\n    }\n\n    /** Initialize button */\n    startBtn.addEventListener('click', () => {\n      dfs('A');\n    });\n\n  })();\n</script>\n</body>\n</html>"
