  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Kruskal's Algorithm Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    line-height: 1.3;\n  }\n  input[type=\"number\"], input[type=\"text\"] {\n    width: 50px;\n  }\n  textarea {\n    width: 100%;\n    height: 60px;\n    font-family: monospace;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 5px;\n  }\n  td, th {\n    border: 1px solid black;\n    padding: 2px 5px;\n    text-align: center;\n  }\n  label {\n    user-select: none;\n  }\n  [disabled] {\n    color: graytext;\n  }\n  button {\n    min-width: 90px;\n  }\n  #log {\n    width: 100%;\n    height: 120px;\n    font-family: monospace;\n    resize: vertical;\n    overflow-y: auto;\n  }\n  .small-input {\n    width: 25px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Kruskal's Algorithm Interactive Demo</h1>\n\n<p>\nThis tool lets you build, edit, and explore Kruskal's algorithm for minimum spanning trees step-by-step.\nYou can add vertices and weighted edges, run Kruskal's algorithm with full control, inspect union-find states,\nand experiment with your graph.\n</p>\n\n<hr />\n\n<h2>1. Setup Graph</h2>\n<div>\n  <label for=\"vertex-input\">Add Vertex (name): </label>\n  <input type=\"text\" id=\"vertex-input\" maxlength=\"3\" />\n  <button id=\"add-vertex-btn\">Add Vertex</button>\n</div>\n<div>\n  <label for=\"edge-u-input\">Add Edge from:</label>\n  <input type=\"text\" id=\"edge-u-input\" maxlength=\"3\" />\n  <label for=\"edge-v-input\">to:</label>\n  <input type=\"text\" id=\"edge-v-input\" maxlength=\"3\" />\n  <label for=\"edge-weight-input\">Weight:</label>\n  <input type=\"number\" id=\"edge-weight-input\" value=\"1\" min=\"1\" />\n  <button id=\"add-edge-btn\">Add Edge</button>\n</div>\n<div>\n  <button id=\"clear-graph-btn\">Clear Graph</button>\n</div>\n\n<h3>Vertices (click to remove):</h3>\n<div id=\"vertices-list\" style=\"max-height: 80px; overflow-y: auto;\"></div>\n\n<h3>Edges (click to remove):</h3>\n<div id=\"edges-list\" style=\"max-height: 120px; overflow-y: auto;\"></div>\n\n<hr/>\n\n<h2>2. Run Kruskal's Algorithm</h2>\n<div>\n  <button id=\"prepare-kruskal-btn\" disabled>Initialize Kruskal</button>\n  <button id=\"step-kruskal-btn\" disabled>Next Step</button>\n  <button id=\"auto-run-btn\" disabled>Auto Run</button>\n  <button id=\"pause-auto-btn\" disabled>Pause Auto</button>\n  <button id=\"reset-kruskal-btn\" disabled>Reset Kruskal</button>\n</div>\n<div>\n  <label for=\"auto-interval-slider\">Auto-run Interval (ms):</label>\n  <input type=\"range\" id=\"auto-interval-slider\" min=\"100\" max=\"3000\" step=\"50\" value=\"800\" />\n  <span id=\"auto-interval-display\">800</span>\n</div>\n\n<h3>Algorithm State:</h3>\n<div>\n  <p><b>Current Edge Index:</b> <span id=\"current-edge-index\">-</span> / <span id=\"total-edges\">-</span></p>\n  <p><b>Current Edge:</b> <span id=\"current-edge\">-</span></p>\n  <p><b>Edges included in MST:</b></p>\n  <div id=\"mst-edges-list\" style=\"max-height: 100px; overflow-y: auto;\"></div>\n</div>\n\n<h3>Union-Find Structure (Disjoint Sets):</h3>\n<div>\n  <table id=\"uf-table\" style=\"width:100%; max-width: 600px;\">\n    <thead><tr><th>Vertex</th><th>Parent</th><th>Rank</th></tr></thead>\n    <tbody></tbody>\n  </table>\n</div>\n\n<hr/>\n\n<h2>3. Explore & Inspect</h2>\n<div>\n  <button id=\"show-graph-state-btn\">Show Current Graph State</button>\n  <button id=\"show-sorted-edges-btn\">Show Edges Sorted By Weight</button>\n  <button id=\"show-uf-state-btn\">Show Union-Find Sets Groups</button>\n</div>\n<div>\n  <textarea id=\"info-output\" readonly></textarea>\n</div>\n\n<hr/>\n\n<h2>4. Manual Union-Find Commands (Advanced)</h2>\n<div>\n  <label for=\"uf-find-input\">Find (vertex): </label>\n  <input type=\"text\" id=\"uf-find-input\" maxlength=\"3\" />\n  <button id=\"uf-find-btn\">Find</button>\n  <span id=\"uf-find-result\"></span>\n</div>\n<div>\n  <label for=\"uf-union-u\">Union (u): </label>\n  <input type=\"text\" id=\"uf-union-u\" maxlength=\"3\" />\n  <label for=\"uf-union-v\">v: </label>\n  <input type=\"text\" id=\"uf-union-v\" maxlength=\"3\" />\n  <button id=\"uf-union-btn\">Union</button>\n  <span id=\"uf-union-result\"></span>\n</div>\n\n<hr/>\n\n<h2>5. Logs & Notes</h2>\n<textarea id=\"log\" readonly></textarea>\n\n<script>\n(function(){\n  // --- Data Structures ---\n  // Graph structure: vertices: Set(string), edges: Array({u,v,weight})\n  // Union-Find: parent, rank maps\n  let vertices = new Set();\n  let edges = [];\n\n  // Kruskal state\n  let kruskalPrepared = false;\n  let kruskalEdgesSorted = [];\n  let kruskalCurrentIndex = 0;\n  let mstEdges = [];\n  let ufParent = {};\n  let ufRank = {};\n  let autoTimer = null;\n\n  // DOM references\n  const vertexInput = document.getElementById('vertex-input');\n  const addVertexBtn = document.getElementById('add-vertex-btn');\n  const edgeUInput = document.getElementById('edge-u-input');\n  const edgeVInput = document.getElementById('edge-v-input');\n  const edgeWeightInput = document.getElementById('edge-weight-input');\n  const addEdgeBtn = document.getElementById('add-edge-btn');\n  const clearGraphBtn = document.getElementById('clear-graph-btn');\n\n  const verticesListDiv = document.getElementById('vertices-list');\n  const edgesListDiv = document.getElementById('edges-list');\n\n  const prepareKruskalBtn = document.getElementById('prepare-kruskal-btn');\n  const stepKruskalBtn = document.getElementById('step-kruskal-btn');\n  const autoRunBtn = document.getElementById('auto-run-btn');\n  const pauseAutoBtn = document.getElementById('pause-auto-btn');\n  const resetKruskalBtn = document.getElementById('reset-kruskal-btn');\n  const autoIntervalSlider = document.getElementById('auto-interval-slider');\n  const autoIntervalDisplay = document.getElementById('auto-interval-display');\n\n  const currentEdgeIndexSpan = document.getElementById('current-edge-index');\n  const totalEdgesSpan = document.getElementById('total-edges');\n  const currentEdgeSpan = document.getElementById('current-edge');\n  const mstEdgesListDiv = document.getElementById('mst-edges-list');\n\n  const ufTableBody = document.querySelector('#uf-table tbody');\n\n  const showGraphStateBtn = document.getElementById('show-graph-state-btn');\n  const showSortedEdgesBtn = document.getElementById('show-sorted-edges-btn');\n  const showUfStateBtn = document.getElementById('show-uf-state-btn');\n  const infoOutput = document.getElementById('info-output');\n\n  const ufFindInput = document.getElementById('uf-find-input');\n  const ufFindBtn = document.getElementById('uf-find-btn');\n  const ufFindResultSpan = document.getElementById('uf-find-result');\n\n  const ufUnionUInput = document.getElementById('uf-union-u');\n  const ufUnionVInput = document.getElementById('uf-union-v');\n  const ufUnionBtn = document.getElementById('uf-union-btn');\n  const ufUnionResultSpan = document.getElementById('uf-union-result');\n\n  const logArea = document.getElementById('log');\n\n  // --- Helper Functions ---\n\n  // Append log line and scroll to bottom\n  function log(msg) {\n    const time = new Date().toLocaleTimeString();\n    logArea.value += `[${time}] ${msg}\\n`;\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  // Update vertices list display\n  function updateVerticesList() {\n    verticesListDiv.innerHTML = '';\n    const sortedVert = Array.from(vertices).sort();\n    sortedVert.forEach(v => {\n      const btn = document.createElement('button');\n      btn.textContent = v;\n      btn.title = 'Click to remove vertex \"' + v + '\" and its edges';\n      btn.onclick = function(){\n        if(confirm('Remove vertex \"'+v+'\" and all connected edges?')){\n          removeVertex(v);\n        }\n      };\n      verticesListDiv.appendChild(btn);\n      verticesListDiv.appendChild(document.createTextNode(' '));\n    });\n    updatePrepareButtonState();\n  }\n\n  // Update edges list display\n  function updateEdgesList() {\n    edgesListDiv.innerHTML = '';\n    edges.forEach((e,i) => {\n      const btn = document.createElement('button');\n      btn.textContent = `${e.u} - ${e.v} (w:${e.weight})`;\n      btn.title = 'Click to remove this edge';\n      btn.onclick = function() {\n        if(confirm(`Remove edge ${e.u} - ${e.v} (weight ${e.weight})?`)){\n          removeEdge(i);\n        }\n      };\n      edgesListDiv.appendChild(btn);\n      edgesListDiv.appendChild(document.createTextNode(' '));\n    });\n    totalEdgesSpan.textContent = edges.length;\n    updatePrepareButtonState();\n  }\n\n  // Remove a vertex and all connected edges\n  function removeVertex(v){\n    if(!vertices.has(v)) return;\n    vertices.delete(v);\n    edges = edges.filter(e => e.u !== v && e.v !== v);\n    updateVerticesList();\n    updateEdgesList();\n    resetKruskalState();\n  }\n\n  // Remove edge by index\n  function removeEdge(i) {\n    if(i < 0 || i >= edges.length) return;\n    edges.splice(i,1);\n    updateEdgesList();\n    resetKruskalState();\n  }\n\n  // Validate vertex name input\n  function isValidVertexName(name){\n    if(!name) return false;\n    if(name.length > 3) return false;\n    // Alphanumeric and no spaces\n    return /^[A-Za-z0-9]+$/.test(name);\n  }\n\n  // Union-Find functions\n  function ufMakeSet() {\n    ufParent = {};\n    ufRank = {};\n    for(const v of vertices) {\n      ufParent[v] = v;\n      ufRank[v] = 0;\n    }\n  }\n\n  function ufFind(v) {\n    if(ufParent[v] !== v) {\n      ufParent[v] = ufFind(ufParent[v]);\n    }\n    return ufParent[v];\n  }\n\n  function ufUnion(u,v) {\n    let rootU = ufFind(u);\n    let rootV = ufFind(v);\n    if(rootU === rootV) return false;\n    if(ufRank[rootU] < ufRank[rootV]){\n      ufParent[rootU] = rootV;\n    } else if(ufRank[rootU] > ufRank[rootV]){\n      ufParent[rootV] = rootU;\n    } else {\n      ufParent[rootV] = rootU;\n      ufRank[rootU]++;\n    }\n    return true;\n  }\n\n  // Initialize Kruskal state\n  function prepareKruskal() {\n    if(vertices.size === 0) {\n      alert(\"No vertices defined.\");\n      return;\n    }\n    kruskalEdgesSorted = edges.slice();\n    kruskalEdgesSorted.sort((a,b) => a.weight - b.weight);\n    kruskalCurrentIndex = 0;\n    mstEdges = [];\n    ufMakeSet();\n    kruskalPrepared = true;\n    log(\"Kruskal initialized: sorted edges by weight.\");\n    updateAlgorithmStateDisplay();\n    enableStepControls(true);\n    updateUnionFindTable();\n  }\n\n  // Update algorithm state display\n  function updateAlgorithmStateDisplay() {\n    currentEdgeIndexSpan.textContent = kruskalCurrentIndex;\n    totalEdgesSpan.textContent = kruskalEdgesSorted.length;\n    if(kruskalCurrentIndex < kruskalEdgesSorted.length) {\n      const e = kruskalEdgesSorted[kruskalCurrentIndex];\n      currentEdgeSpan.textContent = `${e.u} - ${e.v} (w:${e.weight})`;\n    } else {\n      currentEdgeSpan.textContent = '-';\n    }\n\n    mstEdgesListDiv.innerHTML = '';\n    mstEdges.forEach(e=>{\n      const span = document.createElement('span');\n      span.textContent = `${e.u} - ${e.v} (w:${e.weight})`;\n      mstEdgesListDiv.appendChild(span);\n      mstEdgesListDiv.appendChild(document.createTextNode(' '));\n    });\n  }\n\n  // Step Kruskal algorithm once\n  function stepKruskal() {\n    if(!kruskalPrepared) return;\n    if(kruskalCurrentIndex >= kruskalEdgesSorted.length){\n      log(\"Kruskal complete: no more edges to process.\");\n      enableStepControls(false);\n      return;\n    }\n    const edge = kruskalEdgesSorted[kruskalCurrentIndex];\n    const uRoot = ufFind(edge.u);\n    const vRoot = ufFind(edge.v);\n    log(`Process edge ${edge.u}-${edge.v} (w:${edge.weight}): roots ${uRoot} & ${vRoot}`);\n    if(uRoot !== vRoot){\n      ufUnion(edge.u, edge.v);\n      mstEdges.push(edge);\n      log(`Edge ${edge.u}-${edge.v} added to MST.`);\n    } else {\n      log(`Edge ${edge.u}-${edge.v} creates cycle, skipped.`);\n    }\n    kruskalCurrentIndex++;\n    updateAlgorithmStateDisplay();\n    updateUnionFindTable();\n\n    if(kruskalCurrentIndex >= kruskalEdgesSorted.length) {\n      log(\"Kruskal complete: all edges processed.\");\n      enableStepControls(false);\n      stopAutoRun();\n    }\n  }\n\n  // Enable or disable step controls\n  function enableStepControls(state) {\n    stepKruskalBtn.disabled = !state;\n    autoRunBtn.disabled = !state;\n    pauseAutoBtn.disabled = true;\n    resetKruskalBtn.disabled = !kruskalPrepared;\n  }\n\n  // Reset Kruskal state fully\n  function resetKruskalState() {\n    kruskalPrepared = false;\n    kruskalEdgesSorted = [];\n    kruskalCurrentIndex = 0;\n    mstEdges = [];\n    ufParent = {};\n    ufRank = {};\n    updateAlgorithmStateDisplay();\n    updateUnionFindTable();\n    enableStepControls(false);\n    prepareKruskalBtn.disabled = vertices.size===0||edges.length===0;\n    stopAutoRun();\n    ufFindResultSpan.textContent = '';\n    ufUnionResultSpan.textContent = '';\n    log(\"Kruskal reset.\");\n  }\n\n  // Update union-find table display\n  function updateUnionFindTable() {\n    ufTableBody.innerHTML = '';\n    const sortedVert = Array.from(vertices).sort();\n    sortedVert.forEach(v=>{\n      const tr = document.createElement('tr');\n      const tdV = document.createElement('td');\n      tdV.textContent = v;\n      const tdP = document.createElement('td');\n      tdP.textContent = ufParent[v] || '-';\n      const tdR = document.createElement('td');\n      tdR.textContent = ufRank[v] !== undefined ? ufRank[v] : '-';\n      tr.appendChild(tdV);\n      tr.appendChild(tdP);\n      tr.appendChild(tdR);\n      ufTableBody.appendChild(tr);\n    });\n  }\n\n  // Show current graph state in info output\n  function showGraphState(){\n    let out = '';\n    out += 'Vertices:\\n';\n    Array.from(vertices).sort().forEach(v=>{\n      out += '  ' + v + '\\n';\n    });\n    out += '\\nEdges:\\n';\n    edges.forEach(e=>{\n      out += `  ${e.u} - ${e.v} (weight: ${e.weight})\\n`;\n    });\n    infoOutput.value = out;\n  }\n\n  // Show edges sorted by weight\n  function showSortedEdges(){\n    if(edges.length===0){\n      infoOutput.value = 'No edges.';\n      return;\n    }\n    const sorted = edges.slice().sort((a,b)=>a.weight-b.weight);\n    let out = 'Edges Sorted by Weight:\\n';\n    sorted.forEach(e=>{\n      out += `  ${e.u} - ${e.v} (weight: ${e.weight})\\n`;\n    });\n    infoOutput.value = out;\n  }\n\n  // Show union-find sets groups\n  function showUfState(){\n    if(!kruskalPrepared){\n      infoOutput.value = 'Kruskal not initialized.\\nUnion-Find state unavailable.';\n      return;\n    }\n    // Find groups\n    const groups = {};\n    for(const v of vertices){\n      const p = ufFind(v);\n      if(!(p in groups)){\n        groups[p] = [];\n      }\n      groups[p].push(v);\n    }\n    let out = 'Union-Find Sets Groups:\\n';\n    Object.entries(groups).forEach(([root,members])=>{\n      out += `  Root ${root}: ${members.sort().join(', ')}\\n`;\n    });\n    infoOutput.value = out;\n  }\n\n  // Stop auto run\n  function stopAutoRun(){\n    if(autoTimer){\n      clearInterval(autoTimer);\n      autoTimer = null;\n    }\n    autoRunBtn.disabled = false;\n    pauseAutoBtn.disabled = true;\n  }\n\n  // Start auto run\n  function startAutoRun(){\n    if(!kruskalPrepared || autoTimer) return;\n    stepKruskalBtn.disabled = true;\n    autoRunBtn.disabled = true;\n    pauseAutoBtn.disabled = false;\n    const interval = parseInt(autoIntervalSlider.value, 10);\n    autoTimer = setInterval(()=>{\n      if(kruskalCurrentIndex >= kruskalEdgesSorted.length){\n        stopAutoRun();\n      } else {\n        stepKruskal();\n      }\n    }, interval);\n  }\n\n  // Enable or disable Prepare button\n  function updatePrepareButtonState(){\n    prepareKruskalBtn.disabled = (vertices.size === 0 || edges.length === 0);\n  }\n\n  // --- Event Listeners ---\n\n  addVertexBtn.addEventListener('click', () => {\n    const v = vertexInput.value.trim();\n    if(!isValidVertexName(v)){\n      alert('Invalid vertex name. Use 1-3 alphanumeric characters, no spaces.');\n      return;\n    }\n    if(vertices.has(v)){\n      alert('Vertex \"'+v+'\" already exists.');\n      return;\n    }\n    vertices.add(v);\n    vertexInput.value = '';\n    updateVerticesList();\n    updatePrepareButtonState();\n    log(`Vertex added: ${v}`);\n  });\n\n  addEdgeBtn.addEventListener('click', () => {\n    const u = edgeUInput.value.trim();\n    const v = edgeVInput.value.trim();\n    const w = parseInt(edgeWeightInput.value,10);\n    if(!isValidVertexName(u) || !isValidVertexName(v)){\n      alert('Edge vertices must be valid vertex names.');\n      return;\n    }\n    if(!vertices.has(u) || !vertices.has(v)) {\n      alert('Both vertices must exist in the graph.');\n      return;\n    }\n    if(u === v) {\n      alert('No loops allowed (edge must connect two distinct vertices).');\n      return;\n    }\n    if(isNaN(w) || w < 1) {\n      alert('Weight must be a positive integer.');\n      return;\n    }\n    // Check if edge already exists (undirected)\n    if(edges.some(e=> (e.u === u && e.v === v) || (e.u === v && e.v === u))){\n      alert('Edge already exists between these vertices.');\n      return;\n    }\n    edges.push({u,v,weight:w});\n    edgeUInput.value = '';\n    edgeVInput.value = '';\n    edgeWeightInput.value = '1';\n    updateEdgesList();\n    updatePrepareButtonState();\n    log(`Edge added: ${u}-${v} (weight ${w})`);\n  });\n\n  clearGraphBtn.addEventListener('click', () => {\n    if(confirm('Clear all vertices and edges?')){\n      vertices.clear();\n      edges = [];\n      updateVerticesList();\n      updateEdgesList();\n      resetKruskalState();\n      log('Graph cleared.');\n    }\n  });\n\n  prepareKruskalBtn.addEventListener('click', () => {\n    prepareKruskal();\n  });\n\n  stepKruskalBtn.addEventListener('click', () => {\n    stepKruskal();\n  });\n\n  autoRunBtn.addEventListener('click', () => {\n    startAutoRun();\n  });\n\n  pauseAutoBtn.addEventListener('click', () => {\n    stopAutoRun();\n  });\n\n  resetKruskalBtn.addEventListener('click', () => {\n    resetKruskalState();\n  });\n\n  autoIntervalSlider.addEventListener('input', () => {\n    autoIntervalDisplay.textContent = autoIntervalSlider.value;\n    if(autoTimer){\n      stopAutoRun();\n      startAutoRun();\n    }\n  });\n\n  showGraphStateBtn.addEventListener('click', () => {\n    showGraphState();\n  });\n\n  showSortedEdgesBtn.addEventListener('click', () => {\n    showSortedEdges();\n  });\n\n  showUfStateBtn.addEventListener('click', () => {\n    showUfState();\n  });\n\n  ufFindBtn.addEventListener('click', () => {\n    const v = ufFindInput.value.trim();\n    if(!vertices.has(v)){\n      ufFindResultSpan.textContent = 'Vertex not found';\n      return;\n    }\n    if(!kruskalPrepared){\n      ufFindResultSpan.textContent = 'Kruskal not initialized';\n      return;\n    }\n    const root = ufFind(v);\n    ufFindResultSpan.textContent = `Root: ${root}`;\n    log(`Find(${v}) = ${root}`);\n  });\n\n  ufUnionBtn.addEventListener('click', () => {\n    const u = ufUnionUInput.value.trim();\n    const v = ufUnionVInput.value.trim();\n    if(!vertices.has(u) || !vertices.has(v)) {\n      ufUnionResultSpan.textContent = 'Invalid vertices';\n      return;\n    }\n    if(!kruskalPrepared){\n      ufUnionResultSpan.textContent = 'Kruskal not initialized';\n      return;\n    }\n    const merged = ufUnion(u,v);\n    updateUnionFindTable();\n    if(merged) {\n      ufUnionResultSpan.textContent = `Union succeeded`;\n      log(`Union(${u}, ${v}): sets merged.`);\n    } else {\n      ufUnionResultSpan.textContent = `Already in same set`;\n      log(`Union(${u}, ${v}): already same set.`);\n    }\n  });\n\n  // Initialize empty states on page load\n  updateVerticesList();\n  updateEdgesList();\n  resetKruskalState();\n\n  // Accessibility note: slider value label sync is on input above\n\n})();\n</script>\n</body>\n</html>"
  },
