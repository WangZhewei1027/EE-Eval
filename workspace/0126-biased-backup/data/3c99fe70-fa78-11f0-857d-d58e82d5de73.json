    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>HTTP - HyperText Transfer Protocol</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=JetBrains+Mono&display=swap');\n\n  :root {\n    /* Color Palette */\n    --dark-bg: #0b0f1a;\n    --deep-indigo: #2a2f65;\n    --electric-blue: #00d8ff;\n    --neon-purple: #c084fc;\n    --vapor-pink: #ff87bf;\n    --white: #f9f9f9;\n    --glass-bg: rgba(255 255 255 / 0.05);\n    --accent: #4ade80;\n    --shadow-glow: rgba(0, 216, 255, 0.35);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, var(--deep-indigo) 10%, var(--dark-bg) 90%);\n    color: var(--white);\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1rem 4rem;\n  }\n\n  h1 {\n    font-weight: 700;\n    font-size: 4rem;\n    letter-spacing: 0.20em;\n    text-transform: uppercase;\n    color: var(--electric-blue);\n    text-shadow:\n      0 0 6px var(--electric-blue),\n      0 0 12px var(--electric-blue),\n      0 0 18px var(--neon-purple);\n    margin-bottom: 0.2em;\n    user-select: none;\n  }\n\n  h2 {\n    font-weight: 600;\n    font-size: 1.25rem;\n    color: var(--vapor-pink);\n    letter-spacing: 0.1em;\n    margin-top: 0;\n    margin-bottom: 2rem;\n    user-select: none;\n  }\n\n  main {\n    max-width: 960px;\n    width: 100%;\n    background: var(--glass-bg);\n    border-radius: 2rem;\n    backdrop-filter: blur(18px);\n    box-shadow: 0 0 30px 5px var(--shadow-glow);\n    padding: 3rem 4rem 4rem;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 3rem 5rem;\n  }\n\n  /* Left side: textual explanation */\n  section.info {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  p {\n    font-size: 1.125rem;\n    line-height: 1.7;\n    letter-spacing: 0.01em;\n    color: #dce9ffcc;\n    margin-bottom: 1.75rem;\n    user-select: text;\n  }\n\n  p strong {\n    color: var(--electric-blue);\n  }\n\n  /* Code block styled box */\n  pre {\n    font-family: 'JetBrains Mono', monospace;\n    background: rgba(255 255 255 / 0.08);\n    border-radius: 1rem;\n    padding: 1.5rem 2rem;\n    font-size: 1rem;\n    color: var(--neon-purple);\n    box-shadow:\n      inset 0 0 20px 2px rgba(200 132 252 / 0.4),\n      0 0 16px 0 rgba(200 132 252 / 0.3);\n    overflow-x: auto;\n    user-select: all;\n    margin-top: 0;\n  }\n\n  /* Right side: graphic illustration */\n  section.diagram {\n    position: relative;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    perspective: 1100px;\n  }\n\n  .http-graphic {\n    position: relative;\n    width: 320px;\n    height: 320px;\n    border-radius: 2rem;\n    background: linear-gradient(145deg, #121a3c, #1f2766);\n    box-shadow:\n      0 0 15px 3px var(--electric-blue),\n      inset 0 0 30px 3px rgba(0, 216, 255, 0.6);\n    filter: drop-shadow(0 0 10px var(--electric-blue));\n    transform-style: preserve-3d;\n    animation: pulseGlow 4s infinite ease-in-out;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n        0 0 15px 3px var(--electric-blue),\n        inset 0 0 30px 3px rgba(0, 216, 255, 0.6);\n    }\n    50% {\n      box-shadow:\n        0 0 28px 6px var(--vapor-pink),\n        inset 0 0 56px 5px rgba(255, 135, 191, 0.8);\n    }\n  }\n\n  /* Layered elements inside the graphic */\n  .http-graphic .layer {\n    position: absolute;\n    border-radius: 1rem;\n    background: linear-gradient(145deg, var(--accent), var(--neon-purple));\n    box-shadow:\n      0 0 12px 2px var(--neon-purple),\n      inset 0 0 16px 3px var(--accent);\n    opacity: 0.82;\n    transition: opacity 0.6s ease;\n  }\n\n  .layer-1 {\n    top: 20%;\n    left: 18%;\n    width: 100px;\n    height: 180px;\n    transform: rotateY(20deg) rotateX(12deg);\n  }\n\n  .layer-2 {\n    top: 30%;\n    left: 48%;\n    width: 140px;\n    height: 140px;\n    background: linear-gradient(145deg, var(--vapor-pink), var(--neon-purple));\n    box-shadow:\n      0 0 18px 4px var(--vapor-pink),\n      inset 0 0 20px 4px rgba(255, 135, 191,0.9);\n    transform: rotateY(-15deg) rotateX(-8deg);\n  }\n\n  .layer-3 {\n    top: 58%;\n    left: 12%;\n    width: 180px;\n    height: 100px;\n    background: linear-gradient(135deg, var(--electric-blue), var(--accent));\n    box-shadow:\n      0 0 22px 4px var(--electric-blue),\n      inset 0 0 28px 4px var(--accent);\n    transform: rotateY(25deg) rotateX(-10deg);\n  }\n\n  /* Label text inside graphic */\n  .http-graphic .label {\n    position: absolute;\n    font-family: 'JetBrains Mono', monospace;\n    font-weight: 700;\n    color: var(--white);\n    text-shadow:\n      0 0 4px var(--electric-blue);\n    user-select: none;\n    pointer-events: none;\n  }\n\n  .label-request {\n    top: 18%;\n    left: 22%;\n    font-size: 1.1rem;\n    letter-spacing: 0.1em;\n  }\n\n  .label-response {\n    top: 36%;\n    left: 52%;\n    font-size: 1.1rem;\n    letter-spacing: 0.1em;\n  }\n\n  .label-server {\n    top: 66%;\n    left: 16%;\n    font-size: 1.1rem;\n    letter-spacing: 0.1em;\n  }\n\n  /* Buttons */\n  .buttons {\n    grid-column: 1 / -1;\n    margin-top: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n  }\n\n  button {\n    background: linear-gradient(135deg, var(--electric-blue), var(--neon-purple));\n    color: var(--white);\n    border: none;\n    border-radius: 3rem;\n    padding: 0.75rem 2rem;\n    font-size: 1.125rem;\n    font-weight: 600;\n    font-family: 'Inter', sans-serif;\n    cursor: pointer;\n    box-shadow:\n      0 0 12px var(--electric-blue);\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);\n    user-select: none;\n  }\n\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, var(--vapor-pink), var(--neon-purple));\n    box-shadow:\n      0 0 24px var(--vapor-pink),\n      0 0 36px var(--neon-purple);\n    outline: none;\n    transform: scale(1.08);\n  }\n\n  button:active {\n    transform: scale(0.96);\n  }\n\n  /* Tooltip for sticky overlay text */\n  .tooltip {\n    position: fixed;\n    bottom: 2rem;\n    right: 2rem;\n    background: var(--glass-bg);\n    padding: 1rem 1.75rem;\n    border-radius: 2rem;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 1rem;\n    color: var(--electric-blue);\n    text-shadow: 0 0 3px var(--electric-blue);\n    backdrop-filter: blur(12px);\n    pointer-events: none;\n    user-select: none;\n    opacity: 0;\n    transition: opacity 0.6s ease;\n  }\n\n  .tooltip.visible {\n    opacity: 1;\n    pointer-events: auto;\n  }\n\n  /* Responsive */\n  @media (max-width: 840px) {\n    main {\n      grid-template-columns: 1fr;\n      padding: 2.5rem 2rem 3rem;\n    }\n    .http-graphic {\n      margin: 0 auto;\n      width: 85vw;\n      height: 85vw;\n      max-width: 320px;\n      max-height: 320px;\n    }\n    .label-request, .label-response, .label-server {\n      display: none;\n    }\n    .buttons {\n      margin-top: 2rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>HTTP</h1>\n  <h2>HyperText Transfer Protocol</h2>\n  <main>\n    <section class=\"info\" aria-label=\"Explanation about HTTP\">\n      <p>\n        <strong>HTTP</strong> is the foundation of data communication for the World Wide Web. It defines how messages are formatted and transmitted, and what actions web servers and browsers should take in response to various commands.\n      </p>\n      <p>\n        When you enter a URL in your browser, an HTTP command is sent to the web server directing it to fetch and transmit the requested web page. This powerful protocol orchestrates the exchange between client and server—request and response—ensuring seamless browsing experiences.\n      </p>\n      <pre><code>\nGET /index.html HTTP/1.1\nHost: example.com\nUser-Agent: Mozilla/5.0\nAccept: text/html\n      </code></pre>\n    </section>\n    <section class=\"diagram\" aria-label=\"Visual diagram illustrating HTTP communication\">\n      <div class=\"http-graphic\" aria-hidden=\"true\">\n        <div class=\"layer layer-1\"></div>\n        <div class=\"layer layer-2\"></div>\n        <div class=\"layer layer-3\"></div>\n        <div class=\"label label-request\">Client Request</div>\n        <div class=\"label label-response\">Server Response</div>\n        <div class=\"label label-server\">Web Server</div>\n      </div>\n    </section>\n\n    <div class=\"buttons\" role=\"region\" aria-label=\"Simple HTTP protocol actions\">\n      <button id=\"btn-request\" type=\"button\" aria-pressed=\"false\" aria-label=\"Simulate sending an HTTP request\">\n        Send HTTP Request\n      </button>\n      <button id=\"btn-reset\" type=\"button\" aria-pressed=\"false\" aria-label=\"Reset the demonstration\">\n        Reset\n      </button>\n    </div>\n  </main>\n\n  <div id=\"tooltip\" class=\"tooltip\" role=\"status\" aria-live=\"polite\"></div>\n\n  <script>\n    (() => {\n      const btnRequest = document.getElementById('btn-request');\n      const btnReset = document.getElementById('btn-reset');\n      const tooltip = document.getElementById('tooltip');\n      const graphic = document.querySelector('.http-graphic');\n      let inRequest = false;\n\n      // Helper: show temporary messages\n      function showTooltip(message = '', duration = 2800) {\n        tooltip.textContent = message;\n        tooltip.classList.add('visible');\n        clearTimeout(tooltip._timeout);\n        tooltip._timeout = setTimeout(() => {\n          tooltip.classList.remove('visible');\n        }, duration);\n      }\n\n      // Animate layers to simulate request/response flow\n      function animateRequest() {\n        if (inRequest) return;\n        inRequest = true;\n        btnRequest.setAttribute('aria-pressed', 'true');\n        btnRequest.disabled = true;\n        showTooltip('HTTP Request sent – awaiting response...');\n\n        graphic.animate([\n          { transform: 'rotateY(0) rotateX(0)', boxShadow: '0 0 15px 3px var(--electric-blue), inset 0 0 30px 3px rgba(0, 216, 255, 0.6)' },\n          { transform: 'rotateY(15deg) rotateX(8deg) translateX(10px)', boxShadow: '0 0 28px 6px var(--vapor-pink), inset 0 0 56px 5px rgba(255, 135, 191, 0.8)' },\n          { transform: 'rotateY(-10deg) rotateX(-7deg) translateX(-14px)', boxShadow: '0 0 32px 7px var(--neon-purple), inset 0 0 60px 6px var(--neon-purple)'}\n        ], {\n          duration: 2800,\n          easing: 'ease-in-out',\n          fill: 'forwards'\n        });\n\n        // Animate individual layers with subtle delays\n        const layer1 = graphic.querySelector('.layer-1');\n        const layer2 = graphic.querySelector('.layer-2');\n        const layer3 = graphic.querySelector('.layer-3');\n        \n        layer1.animate([\n          { transform: 'rotateY(20deg) rotateX(12deg)', opacity: 0.82 },\n          { transform: 'rotateY(40deg) rotateX(20deg) translateX(6px)', opacity: 0.96 },\n          { transform: 'rotateY(20deg) rotateX(12deg)', opacity: 0.82 }\n        ], { duration: 2800, easing: 'ease-in-out' });\n\n        layer2.animate([\n          { transform: 'rotateY(-15deg) rotateX(-8deg)', opacity: 0.82 },\n          { transform: 'rotateY(15deg) rotateX(8deg) translateX(8px)', opacity: 1 },\n          { transform: 'rotateY(-15deg) rotateX(-8deg)', opacity: 0.82 }\n        ], { duration: 2800, easing: 'ease-in-out' });\n\n        layer3.animate([\n          { transform: 'rotateY(25deg) rotateX(-10deg)', opacity: 0.82 },\n          { transform: 'rotateY(5deg) rotateX(-5deg) translateX(-5px)', opacity: 0.94 },\n          { transform: 'rotateY(25deg) rotateX(-10deg)', opacity: 0.82 }\n        ], { duration: 2800, easing: 'ease-in-out' });\n\n        setTimeout(() => {\n          showTooltip('HTTP Response received – content ready!');\n          btnReset.disabled = false;\n        }, 2800);\n      }\n\n      function resetGraphic() {\n        inRequest = false;\n        btnRequest.setAttribute('aria-pressed', 'false');\n        btnReset.setAttribute('aria-pressed', 'false');\n        btnRequest.disabled = false;\n        btnReset.disabled = true;\n        tooltip.textContent = '';\n        tooltip.classList.remove('visible');\n        graphic.style.transform = '';\n        graphic.style.boxShadow = '';\n      }\n\n      btnRequest.addEventListener('click', () => animateRequest());\n      btnReset.addEventListener('click', () => resetGraphic());\n\n      // Initial state\n      btnReset.disabled = true;\n    })();\n  </script>\n</body>\n</html>"
