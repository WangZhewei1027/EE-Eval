    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interpolation Search - Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    color: #f0f0f3;\n    font-family: 'Montserrat', sans-serif;\n    overflow-x: hidden;\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n  }\n  h1, h2 {\n    font-family: 'Playfair Display', serif;\n    margin: 0;\n    user-select: none;\n  }\n  h1 {\n    font-size: 3.5rem;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    text-align: center;\n    margin-top: 1.5rem;\n    margin-bottom: 0.25rem;\n    color: #a0e9fd;\n    text-shadow:\n      0 1px 6px rgba(160, 233, 253, 0.7),\n      0 0 12px rgba(160, 233, 253, 0.4);\n  }\n  h2 {\n    color: #ddf4ffcc;\n    font-weight: 400;\n    font-size: 1.25rem;\n    letter-spacing: 0.05em;\n    user-select: none;\n    margin-bottom: 2rem;\n    text-align: center;\n    font-style: italic;\n    text-shadow: 0 0 7px rgba(223, 249, 255, 0.2);\n  }\n\n  /* Container and layout */\n  main {\n    flex: 1;\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    padding: 0 2rem 3rem 2rem;\n    perspective: 1200px;\n    user-select: none;\n  }\n  #visualization {\n    background: rgba(255 255 255 / 0.06);\n    border-radius: 1.3rem;\n    box-shadow: \n      inset 0 0 40px #41c3fb33,\n      0 0 40px #2c90ff88;\n    width: min(100vw, 860px);\n    max-width: 860px;\n    padding: 2.5rem 3rem 3.5rem 3rem;\n    position: relative;\n  }\n\n  /* Array container */\n  .array-container {\n    display: flex;\n    justify-content: center;\n    flex-wrap: nowrap;\n    gap: 0.7rem;\n    margin-bottom: 3rem;\n    overflow-x: auto;\n    padding-bottom: 8px;\n    scrollbar-width: thin;\n    scrollbar-color: #2aa1ff22 transparent;\n  }\n  .array-container::-webkit-scrollbar {\n    height: 8px;\n  }\n  .array-container::-webkit-scrollbar-thumb {\n    background: #2aa1ff33;\n    border-radius: 4px;\n  }\n\n  /* Array elements */\n  .element {\n    --size: 48px;\n    width: var(--size);\n    height: var(--size);\n    border-radius: 0.8rem;\n    background: linear-gradient(145deg, #1c2846, #2d4370);\n    box-shadow:\n      inset 3px 3px 7px #3a558d,\n      inset -3px -3px 7px #152542;\n    color: #a0e9fd;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 700;\n    font-size: 1.25rem;\n    letter-spacing: 0.04em;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n    position: relative;\n    cursor: default;\n    transition: \n      transform 0.45s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.45s ease,\n      background-color 0.45s ease;\n  }\n  .element.highlight-low {\n    box-shadow:\n      0 0 18px #5688ffcc,\n      inset 3px 3px 9px #2250c9;\n    background: linear-gradient(145deg, #1f49a1, #1150ee);\n    transform: scale(1.2) translateY(-6px);\n    color: #d2dfff;\n  }\n  .element.highlight-high {\n    box-shadow:\n      0 0 18px #ff9e57cc,\n      inset 3px 3px 9px #c97c11;\n    background: linear-gradient(145deg, #b36418, #f3a329);\n    transform: scale(1.2) translateY(-6px);\n    color: #fff2d6;\n  }\n  .element.highlight-mid {\n    box-shadow:\n      0 0 32px #51d8a4cc,\n      inset 3px 3px 12px #2ab477;\n    background: linear-gradient(145deg, #23b97a, #3bd49e);\n    transform: scale(1.35) translateY(-12px);\n    color: #e9fff9;\n  }\n  .element.found {\n    box-shadow:\n      0 0 38px #fefefe, \n      0 0 45px #51d8a4cc, \n      inset 0 0 20px #c8ffefcc;\n    background: linear-gradient(145deg, #89fff0, #51d8a4);\n    color: #051f17;\n    font-weight: 800;\n    transform: scale(1.5) translateY(-24px);\n    transition-timing-function: cubic-bezier(0.68, -0.55, 0.265, 1.55);\n  }\n  .element.excluded {\n    filter: grayscale(100%) brightness(0.38);\n    opacity: 0.3;\n    pointer-events: none;\n  }\n\n  /* Controls */\n  #controls {\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n    margin-top: -2rem;\n  }\n  button {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 1.15rem;\n    letter-spacing: 0.04em;\n    padding: 0.6rem 2.2rem;\n    border-radius: 2rem;\n    border: none;\n    cursor: pointer;\n    background: linear-gradient(145deg, #37a2ff, #0a64c8);\n    color: #e3f7ff;\n    box-shadow:\n      0 5px 15px #0a64c8bb,\n      inset 0 -2px 8px #115db8;\n    transition: \n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.2s ease;\n    user-select: none;\n  }\n  button:focus-visible {\n    outline-offset: 3px;\n    outline: 3px solid #c4edffcc;\n  }\n  button:hover:not(:disabled) {\n    background: linear-gradient(145deg, #1be1ff, #0389de);\n    box-shadow:\n      0 4px 22px #07aef0cc,\n      inset 0 -2px 6px #117ec9;\n    transform: translateY(-3px);\n  }\n  button:disabled {\n    background: #465A84;\n    box-shadow: none;\n    cursor: default;\n    transform: none;\n    color: #a5b1cb;\n  }\n\n  /* Explanation block */\n  #explanation {\n    max-width: 720px;\n    margin: 0 auto;\n    font-size: 1rem;\n    line-height: 1.65;\n    color: #b7d3f8cc;\n    text-align: center;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n    letter-spacing: 0.02em;\n  }\n  mark {\n    background: #51d8a4bb;\n    border-radius: 0.35rem;\n    padding: 0 6px;\n    font-weight: 600;\n    color: #013a2f;\n  }\n\n  /* Footer info */\n  footer {\n    text-align: center;\n    padding: 1rem 0 2rem 0;\n    font-size: 0.85rem;\n    font-style: italic;\n    color: #6f84a0cc;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n  }\n\n  /* Animations */\n  @keyframes pulse-glow {\n    0%, 100% {\n      box-shadow:\n        0 0 24px #51d8a499,\n        inset 3px 3px 12px #0ca472a6;\n    }\n    50% {\n      box-shadow:\n        0 0 38px #51d8a4cc,\n        inset 6px 6px 18px #12b67a;\n    }\n  }\n\n\n  /* Subtle background shapes */\n  body::before {\n    content: '';\n    position: fixed;\n    top: -10vh; left: -10vw;\n    width: 150vw;\n    height: 140vh;\n    background:\n      radial-gradient(circle at 10% 25%, #2a80ff88, transparent 60%),\n      radial-gradient(circle at 75% 70%, #03ffc488, transparent 65%),\n      repeating-radial-gradient(circle at 50% 40%, #1261e144 0 2px, transparent 3px 10px);\n    filter: blur(54px);\n    z-index: 0;\n    pointer-events: none;\n  }\n  #visualization::before {\n    content: '';\n    position: absolute;\n    inset: 3.5rem;\n    border-radius: 1.3rem;\n    pointer-events: none;\n    background:\n      repeating-conic-gradient(from 30deg, #2bc1e522 0deg 7deg, transparent 7deg 40deg),\n      linear-gradient(135deg, #344c83aa, #244172bb);\n    filter: drop-shadow(0 0 16px #29d8f8cc);\n    z-index: -1;\n    animation: pulse-glow 8s ease-in-out infinite alternate;\n  }\n</style>\n</head>\n<body>\n  <h1>Interpolation Search</h1>\n  <h2>beautifully illustrated step-by-step visualization</h2>\n  <main>\n    <section id=\"visualization\" aria-label=\"Visualization of Interpolation Search algorithm\">\n      <div class=\"array-container\" aria-live=\"polite\" aria-atomic=\"true\">\n        <!-- Array elements dynamically injected here -->\n      </div>\n      <div id=\"explanation\" aria-live=\"polite\" aria-atomic=\"true\">\n        <!-- Step explanation will be shown here -->\n      </div>\n      <div id=\"controls\" role=\"region\" aria-label=\"Control buttons for search steps\">\n        <button id=\"startBtn\" type=\"button\" aria-pressed=\"false\" title=\"Start / Restart the interpolation search\">Start Search</button>\n        <button id=\"nextBtn\" type=\"button\" disabled title=\"Advance to next step of the interpolation search\">Next Step</button>\n      </div>\n    </section>\n  </main>\n  <footer>© 2024 · Interpolation Search Visualization</footer>\n\n<script>\n(() => {\n  'use strict';\n\n  const arrayContainer = document.querySelector('.array-container');\n  const explanation = document.getElementById('explanation');\n  const startBtn = document.getElementById('startBtn');\n  const nextBtn = document.getElementById('nextBtn');\n\n  // Sorted array for demonstration (uniformly spaced-ish for aesthetic interpolation)\n  // We'll keep the array size reasonable for quick comprehension.\n  const sortedArray = [\n    12, 17, 23, 29, 34, 37, 41, 44, 47, 51, 56, 59, 63, 68, 72, 77, 81, 86, 90, 95\n  ];\n  const arrayLength = sortedArray.length;\n\n  // Target to search for demonstration (choose one existing value for nice found state)\n  let target = 63;\n\n  // State for the search\n  let low, high, mid;\n  let steps = [];\n  let stepIndex = -1;\n  let foundIndex = -1;\n\n  // Create elements\n  function renderArray(array) {\n    arrayContainer.innerHTML = '';\n    for (let i = 0; i < array.length; i++) {\n      const el = document.createElement('div');\n      el.className = 'element';\n      el.textContent = array[i];\n      el.dataset.index = i;\n      arrayContainer.appendChild(el);\n    }\n  }\n\n  // Reset styles and states\n  function resetArrayElements() {\n    const elements = arrayContainer.children;\n    for (let el of elements) {\n      el.className = 'element';\n    }\n  }\n\n  // Disable/Enable buttons helper\n  function toggleButtons(startDisabled, nextDisabled) {\n    startBtn.disabled = startDisabled;\n    nextBtn.disabled = nextDisabled;\n  }\n\n  // Explanation text generator with highlight\n  function generateExplanation(low, high, mid, array, target) {\n    const lowVal = array[low];\n    const highVal = array[high];\n    const midVal = array[mid];\n    let explanationText = `\n      Searching for <mark>${target}</mark> in the sorted array.<br>\n      Considering current <mark>low</mark> index <strong>${low}</strong> (value ${lowVal}) and <mark>high</mark> index <strong>${high}</strong> (value ${highVal}).<br>\n      Calculated <mark>mid</mark> index <strong>${mid}</strong> (estimated position), with value ${midVal}.\n    `;\n\n    if (midVal === target) {\n      explanationText += `<br>Value at mid matches target <mark>${target}</mark>, <strong>search successful!</strong>`;\n    } else if (midVal < target) {\n      explanationText += `<br>Value at mid is less than target, so we move <mark>low</mark> to <strong>${mid + 1}</strong>.`;\n    } else {\n      explanationText += `<br>Value at mid is greater than target, so we move <mark>high</mark> to <strong>${mid - 1}</strong>.`;\n    }\n    return explanationText;\n  }\n\n  // Interpolation formula for mid\n  function calculateMid(low, high, array, target) {\n    const lowVal = array[low];\n    const highVal = array[high];\n    if (lowVal === highVal) return low; // Avoid divide by zero; fallback to low\n\n    // Interpolation formula: mid = low + ((target - array[low]) * (high - low)) / (array[high] - array[low])\n    const numerator = target - lowVal;\n    const denominator = highVal - lowVal;\n    let pos = low + Math.floor((numerator * (high - low)) / denominator);\n    if (pos > high) pos = high;\n    if (pos < low) pos = low;\n    return pos;\n  }\n\n  // Generate all steps upfront for simplicity and smooth control\n  function generateSteps() {\n    steps = [];\n    low = 0;\n    high = arrayLength - 1;\n    foundIndex = -1;\n\n    while (low <= high && target >= sortedArray[low] && target <= sortedArray[high]) {\n      mid = calculateMid(low, high, sortedArray, target);\n      steps.push({low, high, mid, found: false});\n      if (sortedArray[mid] === target) {\n        foundIndex = mid;\n        steps.push({low, high, mid, found: true});\n        break;\n      } else if (sortedArray[mid] < target) {\n        low = mid + 1;\n      } else {\n        high = mid - 1;\n      }\n    }\n\n    if (foundIndex === -1) {\n      // Not found, add final step showing failure\n      steps.push({low, high, mid: null, found: false, failed: true});\n    }\n  }\n\n  // Visual update: highlight elements at low, mid, high and exclude impossible indices\n  function renderStep(step) {\n    resetArrayElements();\n    const elems = arrayContainer.children;\n    const {low, high, mid, found, failed} = step;\n\n    for (let i = 0; i < elems.length; i++) {\n      const el = elems[i];\n      if (i < low || i > high) {\n        el.classList.add('excluded');\n      }\n    }\n    if (low !== null && low !== undefined) {\n      elems[low].classList.add('highlight-low');\n    }\n    if (high !== null && high !== undefined) {\n      elems[high].classList.add('highlight-high');\n    }\n    if (mid !== null && mid !== undefined && !failed) {\n      // Mid highlight stronger\n      elems[mid].classList.add(found ? 'found' : 'highlight-mid');\n    }\n\n    if (found) {\n      explanation.innerHTML = generateExplanation(low, high, mid, sortedArray, target);\n      nextBtn.disabled = true;\n      startBtn.disabled = false;\n      startBtn.textContent = 'Restart';\n      startBtn.setAttribute('aria-pressed', 'false');\n    } else if (failed) {\n      explanation.innerHTML = `\n        Unable to locate <mark>${target}</mark> in the array.<br>\n        Search space exhausted between <mark>low=${low}</mark> and <mark>high=${high}</mark>.<br>\n        <strong>Value not found.</strong>\n      `;\n      nextBtn.disabled = true;\n      startBtn.disabled = false;\n      startBtn.textContent = 'Restart';\n      startBtn.setAttribute('aria-pressed', 'false');\n    } else {\n      explanation.innerHTML = generateExplanation(low, high, mid, sortedArray, target);\n      nextBtn.disabled = false;\n      startBtn.disabled = true;\n    }\n  }\n\n  // Initialize array and UI\n  function initialize() {\n    renderArray(sortedArray);\n    explanation.innerHTML = `Press <mark>Start Search</mark> to begin visualizing the Interpolation Search algorithm.`;\n    nextBtn.disabled = true;\n    startBtn.disabled = false;\n    startBtn.textContent = 'Start Search';\n    startBtn.setAttribute('aria-pressed', 'false');\n    stepIndex = -1;\n    foundIndex = -1;\n    resetArrayElements();\n  }\n\n  // Step forward in visualization\n  function nextStep() {\n    stepIndex++;\n    if (stepIndex >= steps.length) {\n      nextBtn.disabled = true;\n      return;\n    }\n    const step = steps[stepIndex];\n    renderStep(step);\n  }\n\n  // Start or restart the visualization\n  function start() {\n    // Reset target if needed.\n    // For aesthetic consistent demo, keep same target. Could randomize optionally.\n    generateSteps();\n    stepIndex = -1;\n    nextBtn.disabled = false;\n    startBtn.disabled = true;\n    startBtn.textContent = 'Restart';\n    startBtn.setAttribute('aria-pressed', 'true');\n    nextStep(); // Show first step immediately\n  }\n\n  // Button event bindings\n  startBtn.addEventListener('click', start);\n  nextBtn.addEventListener('click', nextStep);\n\n  // Initialize on page load\n  initialize();\n})();\n</script>\n</body>\n</html>"
