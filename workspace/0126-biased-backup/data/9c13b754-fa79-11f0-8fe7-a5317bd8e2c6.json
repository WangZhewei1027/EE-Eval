  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Selection Sort Interactive Explorer</title>\n  <style>\n    /* Extremely minimal styling to keep layout readable.\n       Default browser styles are otherwise used. */\n    body { background: white; color: black; font-family: Arial, sans-serif; margin: 10px; }\n    .row { margin: 6px 0; }\n    .array-button { margin: 2px; padding: 6px; }\n    textarea { width: 100%; height: 120px; }\n    select,input,button { margin-right: 6px; }\n    .pseudocode { font-family: monospace; white-space: pre; }\n    .controls { margin-bottom: 8px; }\n    .small { font-size: 0.9em; }\n  </style>\n</head>\n<body>\n  <h2>Selection Sort — Interactive Explorer</h2>\n\n  <div class=\"controls\">\n    Array size:\n    <input id=\"sizeRange\" type=\"range\" min=\"2\" max=\"20\" value=\"8\">\n    <input id=\"sizeNumber\" type=\"number\" min=\"2\" max=\"100\" value=\"8\" style=\"width:50px\">\n    Generate:\n    <button id=\"randomBtn\">Random</button>\n    <button id=\"sortedBtn\">Sorted</button>\n    <button id=\"reverseBtn\">Reverse</button>\n    Custom array (comma separated):\n    <input id=\"customArray\" type=\"text\" placeholder=\"e.g. 5,3,7,1\" size=\"20\">\n    <button id=\"setCustomBtn\">Set</button>\n  </div>\n\n  <div class=\"controls\">\n    Value range min:\n    <input id=\"valMin\" type=\"number\" value=\"0\" style=\"width:60px\">\n    max:\n    <input id=\"valMax\" type=\"number\" value=\"20\" style=\"width:60px\">\n    Random seed (optional):\n    <input id=\"seedInput\" type=\"text\" size=\"10\">\n    <button id=\"randomWithSeed\">Random w/ seed</button>\n  </div>\n\n  <div class=\"controls\">\n    Comparator:\n    <select id=\"comparator\">\n      <option value=\"asc\">Ascending (a < b)</option>\n      <option value=\"desc\">Descending (a > b)</option>\n    </select>\n\n    Granularity:\n    <select id=\"granularity\">\n      <option value=\"atomic\">Atomic step (compare/min/advance/swap)</option>\n      <option value=\"operation\">Operation step (complete one i: inner loop + swap)</option>\n    </select>\n\n    Manual swap mode:\n    <label><input id=\"manualSwap\" type=\"checkbox\"> require manual confirmation for swaps</label>\n\n    Auto-play speed (ms):\n    <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"350\">\n    <span id=\"speedLabel\">350</span>\n  </div>\n\n  <div class=\"controls\">\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"opStepBtn\">Step Operation</button>\n    <button id=\"playBtn\">Play</button>\n    <button id=\"pauseBtn\">Pause</button>\n    <button id=\"runToSwapBtn\">Run to next swap</button>\n    <button id=\"runToCompareBtn\">Run to next comparison</button>\n    <button id=\"runToEndBtn\">Run to end</button>\n    <button id=\"resetBtn\">Reset</button>\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n  </div>\n\n  <div class=\"row\">\n    Array (click elements for manual swap when enabled):\n    <div id=\"arrayContainer\" class=\"small\"></div>\n  </div>\n\n  <div class=\"row\">\n    State summary:\n    <span id=\"stateSummary\"></span>\n  </div>\n\n  <div class=\"row\">\n    Pseudocode:\n    <div id=\"pseudocode\" class=\"pseudocode small\"></div>\n  </div>\n\n  <div class=\"row\">\n    Actions log (toggle):\n    <label><input id=\"traceToggle\" type=\"checkbox\" checked> record trace</label>\n    <button id=\"clearLogBtn\">Clear log</button>\n    <textarea id=\"logArea\" readonly></textarea>\n  </div>\n\n  <div class=\"row\">\n    Step timeline:\n    Current step index: <input id=\"stepIndex\" type=\"number\" value=\"0\" style=\"width:70px\">\n    <button id=\"gotoStepBtn\">Go to step</button>\n    Total recorded steps: <span id=\"totalSteps\">0</span>\n  </div>\n\n  <div class=\"row small\">\n    Advanced learning controls:\n    <button id=\"verifyManualSwap\">Verify manual swap</button>\n    <button id=\"forceSwapBtn\">Force swap now</button>\n    Select two indices for manual swap (click array items) — selection state shown inline. Incorrect manual swaps are reported.\n  </div>\n\n  <script>\n    // Selection Sort Interactive Explorer\n    (function(){\n      // Utility random with optional seed (xorshift-ish)\n      function makeRNG(seed) {\n        let x = 0x9e3779b9;\n        if (typeof seed === 'number') x = seed | 0;\n        else if (typeof seed === 'string') {\n          for (let i=0;i<seed.length;i++) x ^= seed.charCodeAt(i) + ((x<<5)-(x>>2));\n        }\n        return function() {\n          x ^= x << 13; x ^= x >>> 17; x ^= x << 5; return (x >>> 0) / 4294967295;\n        };\n      }\n\n      // DOM references\n      const sizeRange = document.getElementById('sizeRange');\n      const sizeNumber = document.getElementById('sizeNumber');\n      const randomBtn = document.getElementById('randomBtn');\n      const sortedBtn = document.getElementById('sortedBtn');\n      const reverseBtn = document.getElementById('reverseBtn');\n      const setCustomBtn = document.getElementById('setCustomBtn');\n      const customArray = document.getElementById('customArray');\n      const valMin = document.getElementById('valMin');\n      const valMax = document.getElementById('valMax');\n      const seedInput = document.getElementById('seedInput');\n      const randomWithSeed = document.getElementById('randomWithSeed');\n\n      const comparatorSelect = document.getElementById('comparator');\n      const granularitySelect = document.getElementById('granularity');\n      const manualSwapCheckbox = document.getElementById('manualSwap');\n      const speed = document.getElementById('speed');\n      const speedLabel = document.getElementById('speedLabel');\n\n      const stepBtn = document.getElementById('stepBtn');\n      const opStepBtn = document.getElementById('opStepBtn');\n      const playBtn = document.getElementById('playBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const runToSwapBtn = document.getElementById('runToSwapBtn');\n      const runToCompareBtn = document.getElementById('runToCompareBtn');\n      const runToEndBtn = document.getElementById('runToEndBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const undoBtn = document.getElementById('undoBtn');\n      const redoBtn = document.getElementById('redoBtn');\n\n      const arrayContainer = document.getElementById('arrayContainer');\n      const stateSummary = document.getElementById('stateSummary');\n      const pseudocodeDiv = document.getElementById('pseudocode');\n\n      const traceToggle = document.getElementById('traceToggle');\n      const clearLogBtn = document.getElementById('clearLogBtn');\n      const logArea = document.getElementById('logArea');\n\n      const stepIndex = document.getElementById('stepIndex');\n      const gotoStepBtn = document.getElementById('gotoStepBtn');\n      const totalSteps = document.getElementById('totalSteps');\n\n      const verifyManualSwapBtn = document.getElementById('verifyManualSwap');\n      const forceSwapBtn = document.getElementById('forceSwapBtn');\n\n      // Pseudocode lines (plain text)\n      const pseudocodeLines = [\n        \"1: for i = 0 to n-2\",\n        \"2:     min = i\",\n        \"3:     for j = i+1 to n-1\",\n        \"4:         if arr[j] < arr[min] then min = j\",\n        \"5:     if min != i then swap arr[i], arr[min]\",\n        \"6: end\"\n      ];\n\n      // State model and history\n      let state = null;\n      let history = []; // array of snapshots\n      let historyPtr = 0; // current index in history (0..history.length-1)\n      let autoTimer = null;\n      let pendingPlayMode = null; // \"runToSwap\", \"runToCompare\", \"runToEnd\", or null\n      let rng = Math.random;\n\n      // For manual selection\n      let manualSelection = [];\n\n      // Initialize default array\n      function initialArray(n, minV, maxV, rngFunc) {\n        const arr = [];\n        for (let i=0;i<n;i++) {\n          arr.push(Math.floor(rngFunc()*(maxV-minV+1))+minV);\n        }\n        return arr;\n      }\n\n      function cloneState(s) {\n        return {\n          arr: s.arr.slice(),\n          i: s.i,\n          j: s.j,\n          minIndex: s.minIndex,\n          micro: s.micro,\n          comparisons: s.comparisons,\n          swaps: s.swaps,\n          event: s.event,\n          phaseNote: s.phaseNote,\n          comparator: s.comparator,\n          manualAwaitingSwap: s.manualAwaitingSwap\n        };\n      }\n\n      function pushHistorySnapshot(snap) {\n        // When pushing after having undone steps, drop future\n        if (historyPtr < history.length - 1) {\n          history = history.slice(0, historyPtr+1);\n        }\n        history.push(cloneState(snap));\n        historyPtr = history.length - 1;\n        updateTimelineUI();\n      }\n\n      function restoreFromHistory(index) {\n        if (index < 0 || index >= history.length) return;\n        const snap = history[index];\n        state = cloneState(snap);\n        historyPtr = index;\n        renderAll();\n      }\n\n      // Create initial state and push snapshot\n      function initialize(arr) {\n        state = {\n          arr: arr.slice(),\n          i: 0,\n          j: arr.length > 1 ? 1 : 0,\n          minIndex: 0,\n          micro: 'compare', // micro phases: 'compare','maybeUpdate','advance','endScan','swap','done'\n          comparisons: 0,\n          swaps: 0,\n          event: 'init',\n          phaseNote: 'initialized',\n          comparator: comparatorSelect.value,\n          manualAwaitingSwap: false\n        };\n        history = [];\n        pushHistorySnapshot(state);\n        manualSelection = [];\n        log('Initialized array: ['+state.arr.join(', ')+']');\n        renderAll();\n      }\n\n      // Basic logging\n      function log(msg) {\n        if (!traceToggle.checked) return;\n        const time = new Date().toLocaleTimeString();\n        logArea.value += \"[\"+time+\"] \"+msg+\"\\n\";\n        logArea.scrollTop = logArea.scrollHeight;\n      }\n\n      function clearLog() {\n        logArea.value = '';\n      }\n\n      // Rendering functions\n      function renderArray() {\n        arrayContainer.innerHTML = '';\n        const n = state.arr.length;\n        for (let idx=0; idx<n; idx++) {\n          const btn = document.createElement('button');\n          btn.className = 'array-button small';\n          btn.textContent = state.arr[idx];\n          // append simple labels in parentheses to denote roles (no colors)\n          const labels = [];\n          if (idx === state.i) labels.push('i');\n          if (idx === state.j) labels.push('j');\n          if (idx === state.minIndex) labels.push('min');\n          if (idx < state.i) labels.push('sorted');\n          if (state.manualAwaitingSwap && manualSelection.indexOf(idx) !== -1) labels.push('sel');\n          if (labels.length) btn.textContent += ' ('+labels.join(',')+')';\n          btn.dataset.index = idx;\n          btn.addEventListener('click', onArrayElementClick);\n          arrayContainer.appendChild(btn);\n        }\n      }\n\n      function renderStateSummary() {\n        const n = state.arr.length;\n        const leftSorted = state.i;\n        stateSummary.textContent = \"i=\"+state.i+\"  j=\"+state.j+\"  min=\"+state.minIndex+\"  comparisons=\"+state.comparisons+\"  swaps=\"+state.swaps+\"  sortedPrefix=\"+leftSorted+\"/\"+n+\"  micro=\"+state.micro + (state.manualAwaitingSwap ? \" (awaiting manual swap)\" : \"\");\n      }\n\n      function renderPseudocode() {\n        // Decide which line to highlight by mapping micro/phase to pseudocode line\n        let highlight = null;\n        if (state.i >= state.arr.length-1) {\n          highlight = 6;\n        } else {\n          // basic mapping\n          if (state.micro === 'compare' || state.micro === 'maybeUpdate') highlight = 4;\n          else if (state.micro === 'advance') highlight = 3;\n          else if (state.micro === 'endScan' || state.micro === 'swap' || state.micro === 'manualSwap') highlight = 5;\n          else highlight = 1;\n        }\n        let out = '';\n        for (let i=0;i<pseudocodeLines.length;i++) {\n          if (i+1 === highlight) out += '>> ' + pseudocodeLines[i] + '\\n';\n          else out += '   ' + pseudocodeLines[i] + '\\n';\n        }\n        pseudocodeDiv.textContent = out;\n      }\n\n      function renderAll() {\n        renderArray();\n        renderStateSummary();\n        renderPseudocode();\n        stepIndex.value = historyPtr;\n        totalSteps.textContent = history.length;\n      }\n\n      // Comparator function\n      function compare(a,b) {\n        if (comparatorSelect.value === 'asc') return a < b;\n        else return a > b;\n      }\n\n      // Micro-step engine: performs exactly one micro action per call\n      function microStep() {\n        if (state.i >= state.arr.length - 1) {\n          state.micro = 'done';\n          state.event = 'done';\n          state.phaseNote = 'fully sorted';\n          pushHistorySnapshot(state);\n          log('Sorting complete.');\n          return;\n        }\n\n        // If manual awaiting swap is true, microStep should not auto-step swap; just set event\n        if (state.micro === 'compare') {\n          // Ensure j valid\n          if (state.j >= state.arr.length) {\n            state.micro = 'endScan';\n            state.event = 'endScan';\n            state.phaseNote = 'finished inner loop';\n            pushHistorySnapshot(state);\n            log('End of inner loop (i='+state.i+'). minIndex='+state.minIndex);\n            return;\n          }\n          // perform compare\n          const a = state.arr[state.j];\n          const b = state.arr[state.minIndex];\n          state.comparisons++;\n          state.event = 'compare';\n          state.phaseNote = 'compared arr['+state.j+'] ('+a+') vs arr['+state.minIndex+'] ('+b+')';\n          state.lastComparisonResult = compare(a,b);\n          state.micro = 'maybeUpdate';\n          pushHistorySnapshot(state);\n          log('Compare: arr['+state.j+']='+a+' vs arr['+state.minIndex+']='+b+' => '+(state.lastComparisonResult ? 'update min' : 'no update'));\n          return;\n        }\n\n        if (state.micro === 'maybeUpdate') {\n          if (state.lastComparisonResult) {\n            state.minIndex = state.j;\n            state.event = 'minUpdate';\n            state.phaseNote = 'minIndex updated to '+state.minIndex;\n            pushHistorySnapshot(state);\n            log('Min updated: minIndex='+state.minIndex);\n            // prepare to advance j next\n            state.micro = 'advance';\n            return;\n          } else {\n            state.event = 'noUpdate';\n            state.phaseNote = 'no min change';\n            pushHistorySnapshot(state);\n            state.micro = 'advance';\n            return;\n          }\n        }\n\n        if (state.micro === 'advance') {\n          state.j++;\n          state.event = 'advanceJ';\n          state.phaseNote = 'j advanced to '+state.j;\n          pushHistorySnapshot(state);\n          return;\n        }\n\n        if (state.micro === 'endScan') {\n          // handle swap\n          if (state.minIndex === state.i) {\n            state.event = 'noSwap';\n            state.phaseNote = 'min==i; no swap';\n            state.micro = 'afterSwap';\n            pushHistorySnapshot(state);\n            log('No swap needed for i='+state.i);\n            return;\n          }\n          // if manual swap is allowed and toggled: pause and await manual confirmation\n          if (manualSwapCheckbox.checked) {\n            state.event = 'awaitingManualSwap';\n            state.phaseNote = 'manual swap required for i='+state.i+' (min='+state.minIndex+')';\n            state.manualAwaitingSwap = true;\n            state.micro = 'manualSwap';\n            pushHistorySnapshot(state);\n            log('Manual swap required: swap arr['+state.i+'] and arr['+state.minIndex+']');\n            return;\n          } else {\n            // perform swap automatically\n            const tmp = state.arr[state.i];\n            state.arr[state.i] = state.arr[state.minIndex];\n            state.arr[state.minIndex] = tmp;\n            state.swaps++;\n            state.event = 'swap';\n            state.phaseNote = 'swapped i='+state.i+' with min='+state.minIndex;\n            state.micro = 'afterSwap';\n            pushHistorySnapshot(state);\n            log('Swapped arr['+state.i+'] and arr['+state.minIndex+']');\n            return;\n          }\n        }\n\n        if (state.micro === 'manualSwap') {\n          // waiting for user; microStep does nothing automatically\n          // But pushing a snapshot is handled when entering manualSwap\n          return;\n        }\n\n        if (state.micro === 'afterSwap') {\n          // finalize pass: increment i and reset for next pass\n          state.i++;\n          state.j = Math.max(0, state.i+1);\n          state.minIndex = state.i;\n          state.event = 'nextI';\n          state.phaseNote = 'advance to i='+state.i;\n          state.manualAwaitingSwap = false;\n          state.micro = 'compare';\n          pushHistorySnapshot(state);\n          log('Advance to next i='+state.i);\n          return;\n        }\n\n        if (state.micro === 'done') {\n          // nothing to do\n          return;\n        }\n      }\n\n      // Operation-level step: perform full inner loop and swap for current i as one \"operation\"\n      function operationStep() {\n        if (state.i >= state.arr.length - 1) {\n          state.micro = 'done';\n          state.event = 'done';\n          pushHistorySnapshot(state);\n          log('OperationStep: already done');\n          return;\n        }\n        // Run inner loop fully\n        while (state.j < state.arr.length) {\n          // perform compare\n          state.comparisons++;\n          if (compare(state.arr[state.j], state.arr[state.minIndex])) {\n            state.minIndex = state.j;\n          }\n          state.j++;\n        }\n        // swap if needed\n        if (state.minIndex !== state.i) {\n          if (manualSwapCheckbox.checked) {\n            // similar behavior: await manual swap then stop here; don't auto-swap\n            state.manualAwaitingSwap = true;\n            state.event = 'awaitingManualSwap';\n            state.micro = 'manualSwap';\n            pushHistorySnapshot(state);\n            log('OperationStep: awaiting manual swap for i='+state.i);\n            return;\n          } else {\n            const tmp = state.arr[state.i];\n            state.arr[state.i] = state.arr[state.minIndex];\n            state.arr[state.minIndex] = tmp;\n            state.swaps++;\n            state.event = 'swap';\n            pushHistorySnapshot(state);\n            log('OperationStep: swapped i='+state.i+' and min='+state.minIndex);\n          }\n        } else {\n          state.event = 'noSwap';\n          pushHistorySnapshot(state);\n          log('OperationStep: no swap needed for i='+state.i);\n        }\n        // prepare next i\n        state.i++;\n        state.j = state.i+1;\n        state.minIndex = state.i;\n        state.micro = 'compare';\n        pushHistorySnapshot(state);\n      }\n\n      // Step forward: respects history redo if possible, else computes new step\n      function stepForward() {\n        // if there is a future snapshot, move forward to it (redo)\n        if (historyPtr < history.length - 1) {\n          historyPtr++;\n          restoreFromHistory(historyPtr);\n          return;\n        }\n        if (granularitySelect.value === 'atomic') {\n          microStep();\n        } else {\n          operationStep();\n        }\n        renderAll();\n      }\n\n      // Step backward (undo): move back in history if possible\n      function stepBackward() {\n        if (historyPtr > 0) {\n          historyPtr--;\n          restoreFromHistory(historyPtr);\n          log('Undo: moved to step '+historyPtr);\n        } else {\n          log('Undo: already at beginning');\n        }\n      }\n\n      // Auto play setup\n      function startAutoPlay(mode) {\n        if (autoTimer) clearInterval(autoTimer);\n        pendingPlayMode = mode || null;\n        autoTimer = setInterval(function() {\n          // Stop if done\n          if (state.micro === 'done' || state.i >= state.arr.length-1) {\n            stopAutoPlay();\n            return;\n          }\n          // If we have future snapshots, just advance\n          if (historyPtr < history.length - 1) {\n            historyPtr++;\n            restoreFromHistory(historyPtr);\n            return;\n          }\n          // Run one step\n          if (granularitySelect.value === 'atomic') microStep();\n          else operationStep();\n\n          renderAll();\n\n          // Check pending modes\n          if (pendingPlayMode === 'runToSwap') {\n            if (state.event === 'swap' || state.event === 'noSwap' || state.event === 'awaitingManualSwap') {\n              stopAutoPlay();\n              return;\n            }\n          } else if (pendingPlayMode === 'runToCompare') {\n            // stop when we just did a compare micro event\n            if (state.event === 'compare') {\n              stopAutoPlay();\n              return;\n            }\n          } else if (pendingPlayMode === 'runToEnd') {\n            if (state.micro === 'done') {\n              stopAutoPlay();\n              return;\n            }\n          }\n        }, parseInt(speed.value,10));\n      }\n\n      function stopAutoPlay() {\n        if (autoTimer) {\n          clearInterval(autoTimer);\n          autoTimer = null;\n          pendingPlayMode = null;\n          log('Auto-play stopped.');\n        }\n      }\n\n      // Run to target events\n      function runToNextSwap() {\n        startAutoPlay('runToSwap');\n      }\n\n      function runToNextCompare() {\n        startAutoPlay('runToCompare');\n      }\n\n      function runToEnd() {\n        startAutoPlay('runToEnd');\n      }\n\n      // Manual swap handling\n      function onArrayElementClick(e) {\n        const idx = parseInt(e.currentTarget.dataset.index,10);\n        if (!state) return;\n        if (state.manualAwaitingSwap) {\n          // Allow selection of indices to attempt manual swap\n          if (manualSelection.indexOf(idx) === -1) {\n            manualSelection.push(idx);\n            if (manualSelection.length > 2) manualSelection.shift();\n          } else {\n            // deselect\n            manualSelection = manualSelection.filter(x => x !== idx);\n          }\n          renderAll();\n          return;\n        }\n\n        // If not awaiting manual swap, but user may still want to edit array via clicks:\n        // clicking an element prompts for a new value (via prompt)\n        const newVal = prompt('Change value at index '+idx+' (current '+state.arr[idx]+'):', ''+state.arr[idx]);\n        if (newVal !== null) {\n          const parsed = parseInt(newVal,10);\n          if (!isNaN(parsed)) {\n            state.arr[idx] = parsed;\n            // pushing snapshot after change\n            state.event = 'edit';\n            state.phaseNote = 'edited index '+idx;\n            pushHistorySnapshot(state);\n            log('Edited arr['+idx+'] to '+parsed);\n            renderAll();\n          } else {\n            alert('Invalid number.');\n          }\n        }\n      }\n\n      // Verify manual swap selection: user clicks \"Verify manual swap\"\n      function verifyManualSwap() {\n        if (!state.manualAwaitingSwap) {\n          alert('Not currently awaiting manual swap.');\n          return;\n        }\n        if (manualSelection.length !== 2) {\n          alert('Select two indices first by clicking array elements (they will be marked sel).');\n          return;\n        }\n        const a = manualSelection[0], b = manualSelection[1];\n        // Accept if they are exactly (i, minIndex) in any order\n        if ((a === state.i && b === state.minIndex) || (b === state.i && a === state.minIndex)) {\n          // perform swap\n          const tmp = state.arr[state.i];\n          state.arr[state.i] = state.arr[state.minIndex];\n          state.arr[state.minIndex] = tmp;\n          state.swaps++;\n          state.event = 'swap';\n          state.phaseNote = 'manual swap performed';\n          state.manualAwaitingSwap = false;\n          state.micro = 'afterSwap';\n          pushHistorySnapshot(state);\n          log('Manual swap successful: swapped '+a+' and '+b);\n          manualSelection = [];\n          renderAll();\n        } else {\n          // incorrect attempt\n          state.event = 'badManualSwap';\n          state.phaseNote = 'incorrect manual swap attempt: ('+a+','+b+')';\n          pushHistorySnapshot(state);\n          log('Incorrect manual swap attempt: ('+a+','+b+'); expected ('+state.i+','+state.minIndex+')');\n          // keep awaiting\n        }\n      }\n\n      function forceSwapNow() {\n        if (!state.manualAwaitingSwap) {\n          alert('Not awaiting manual swap.');\n          return;\n        }\n        // perform swap automatically (force)\n        const tmp = state.arr[state.i];\n        state.arr[state.i] = state.arr[state.minIndex];\n        state.arr[state.minIndex] = tmp;\n        state.swaps++;\n        state.event = 'forceSwap';\n        state.phaseNote = 'forced swap';\n        state.manualAwaitingSwap = false;\n        state.micro = 'afterSwap';\n        pushHistorySnapshot(state);\n        log('Forced swap executed for i='+state.i);\n        manualSelection = [];\n        renderAll();\n      }\n\n      // UI event hookups\n      sizeRange.addEventListener('input', function(){ sizeNumber.value = sizeRange.value; });\n      sizeNumber.addEventListener('input', function(){ sizeRange.value = sizeNumber.value; });\n\n      randomBtn.addEventListener('click', function(){\n        rng = Math.random;\n        const n = parseInt(sizeNumber.value,10);\n        const minV = parseInt(valMin.value,10);\n        const maxV = parseInt(valMax.value,10);\n        initialize(initialArray(n,minV,maxV,Math.random));\n      });\n\n      randomWithSeed.addEventListener('click', function(){\n        const seed = seedInput.value;\n        if (!seed) {\n          alert('Enter a seed string/number first.');\n          return;\n        }\n        rng = makeRNG(seed);\n        const n = parseInt(sizeNumber.value,10);\n        const minV = parseInt(valMin.value,10);\n        const maxV = parseInt(valMax.value,10);\n        initialize(initialArray(n,minV,maxV,rng));\n      });\n\n      sortedBtn.addEventListener('click', function(){\n        const n = parseInt(sizeNumber.value,10);\n        const arr = [];\n        const minV = parseInt(valMin.value,10);\n        for (let i=0;i<n;i++) arr.push(minV+i);\n        initialize(arr);\n      });\n\n      reverseBtn.addEventListener('click', function(){\n        const n = parseInt(sizeNumber.value,10);\n        const arr = [];\n        const maxV = parseInt(valMax.value,10);\n        for (let i=0;i<n;i++) arr.push(maxV - i);\n        initialize(arr);\n      });\n\n      setCustomBtn.addEventListener('click', function(){\n        const text = customArray.value.trim();\n        if (!text) { alert('Enter comma-separated numbers.'); return; }\n        const parts = text.split(',').map(s=>s.trim()).filter(s=>s.length>0);\n        const arr = [];\n        for (let p of parts) {\n          const v = parseInt(p,10);\n          if (isNaN(v)) { alert('Invalid number: '+p); return; }\n          arr.push(v);\n        }\n        initialize(arr);\n      });\n\n      comparatorSelect.addEventListener('change', function(){\n        state.comparator = comparatorSelect.value;\n        state.event = 'comparatorChange';\n        state.phaseNote = 'comparator set to '+comparatorSelect.value;\n        pushHistorySnapshot(state);\n        log('Comparator changed to '+comparatorSelect.value);\n        renderAll();\n      });\n\n      speed.addEventListener('input', function(){ speedLabel.textContent = speed.value; });\n\n      stepBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        stepForward();\n      });\n\n      opStepBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        // operation step does more; ensure history redo logic preserved:\n        if (historyPtr < history.length - 1) {\n          historyPtr++;\n          restoreFromHistory(historyPtr);\n          return;\n        }\n        operationStep();\n        renderAll();\n      });\n\n      playBtn.addEventListener('click', function(){\n        startAutoPlay(null);\n        log('Auto-play started.');\n      });\n\n      pauseBtn.addEventListener('click', function(){\n        stopAutoPlay();\n      });\n\n      runToSwapBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        runToNextSwap();\n        log('Running to next swap...');\n      });\n\n      runToCompareBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        runToNextCompare();\n        log('Running to next comparison...');\n      });\n\n      runToEndBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        runToEnd();\n        log('Running to end...');\n      });\n\n      resetBtn.addEventListener('click', function(){\n        if (!history.length) return;\n        restoreFromHistory(0);\n        log('Reset to initial state.');\n      });\n\n      undoBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        stepBackward();\n      });\n\n      redoBtn.addEventListener('click', function(){\n        stopAutoPlay();\n        if (historyPtr < history.length - 1) {\n          historyPtr++;\n          restoreFromHistory(historyPtr);\n          log('Redo to step '+historyPtr);\n        } else {\n          log('Redo: no future steps');\n        }\n      });\n\n      clearLogBtn.addEventListener('click', function(){\n        