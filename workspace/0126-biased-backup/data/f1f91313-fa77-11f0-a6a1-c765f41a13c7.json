    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Logistic Regression — Elegant Visualization</title>\n\n  <!-- Google Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600;700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071028;\n      --glass: rgba(255,255,255,0.04);\n      --muted: rgba(255,255,255,0.65);\n      --accent1: #7ee7c0;\n      --accent2: #6aa8ff;\n      --accent3: #9b7dff;\n      --card: rgba(255,255,255,0.02);\n      --glass-border: rgba(255,255,255,0.04);\n      --glass-highlight: rgba(255,255,255,0.02);\n      --shadow: 0 10px 40px rgba(2,6,23,0.6);\n      --glass-radius: 20px;\n    }\n\n    html,body{\n      height:100%;\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(123,63,255,0.08), transparent 8%),\n                  radial-gradient(1000px 500px at 90% 90%, rgba(66,189,255,0.06), transparent 10%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      color: #eaf4ff;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:40px;\n      box-sizing:border-box;\n    }\n\n    .frame{\n      width: min(1200px, 96vw);\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius: var(--glass-radius);\n      box-shadow: var(--shadow);\n      border: 1px solid rgba(255,255,255,0.03);\n      overflow: hidden;\n      display:grid;\n      grid-template-columns: 420px 1fr;\n      gap: 28px;\n      padding: 30px;\n      align-items:stretch;\n      backdrop-filter: blur(8px) saturate(1.02);\n      position:relative;\n    }\n\n    /* Left card - Info */\n    .info {\n      padding: 28px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border-radius: 16px;\n      border: 1px solid var(--glass-border);\n    }\n\n    .brand {\n      display:flex;\n      gap:14px;\n      align-items:center;\n    }\n    .logo {\n      width:56px;\n      height:56px;\n      border-radius:12px;\n      background: conic-gradient(from 180deg at 50% 50%, var(--accent1), var(--accent2), var(--accent3), var(--accent1));\n      box-shadow: 0 6px 18px rgba(99,110,255,0.12), inset 0 -6px 18px rgba(255,255,255,0.06);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color:#001018;\n      font-weight:700;\n      font-family:\"Playfair Display\", serif;\n      font-size:18px;\n      letter-spacing:0.6px;\n    }\n\n    h1 {\n      font-family: \"Playfair Display\", serif;\n      margin:0;\n      font-weight:700;\n      color: #f6fbff;\n      font-size:22px;\n      letter-spacing:0.2px;\n    }\n\n    .subtitle {\n      font-size:13px;\n      color:var(--muted);\n      line-height:1.45;\n      margin-top:4px;\n    }\n\n    .equation {\n      margin-top:8px;\n      padding:14px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.014), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.02);\n      display:flex;\n      gap:10px;\n      align-items:center;\n      box-shadow: 0 6px 18px rgba(8,12,25,0.35);\n    }\n\n    .pill {\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:8px 12px;\n      border-radius:12px;\n      border: 1px solid rgba(255,255,255,0.02);\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    .equation .sig {\n      font-family: \"Playfair Display\", serif;\n      font-weight:700;\n      color:#ffffff;\n      font-size:16px;\n    }\n\n    .explain {\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n      margin-top:4px;\n    }\n\n    .meta {\n      display:flex;\n      gap:8px;\n      margin-top:auto;\n      align-items:center;\n      justify-content:space-between;\n    }\n\n    .legend {\n      display:flex;\n      gap:8px;\n      align-items:center;\n    }\n\n    .legend .item {\n      display:flex;\n      gap:10px;\n      align-items:center;\n      font-size:13px;\n      color:var(--muted);\n    }\n\n    .dot {\n      width:14px;\n      height:14px;\n      border-radius:50%;\n      box-shadow: 0 6px 14px rgba(0,0,0,0.35), inset 0 -4px 8px rgba(255,255,255,0.03);\n    }\n    .dot.a { background: linear-gradient(180deg, #7ff1bf, #24c58a); border: 1px solid rgba(255,255,255,0.06); }\n    .dot.b { background: linear-gradient(180deg, #7fafff, #346bf2); border: 1px solid rgba(255,255,255,0.06); }\n\n    .controls {\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n\n    .toggle-btn {\n      background: linear-gradient(90deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      padding:10px 16px;\n      border-radius:12px;\n      color:#e8f6ff;\n      font-weight:600;\n      font-size:13px;\n      cursor:pointer;\n      transition: transform 220ms ease, box-shadow 220ms ease, opacity 200ms ease;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      box-shadow: 0 6px 18px rgba(41,52,81,0.22);\n    }\n    .toggle-btn:hover { transform: translateY(-3px); }\n    .toggle-btn.paused {\n      background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      opacity:0.95;\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n\n    /* Right: visualization area */\n    .viz {\n      position:relative;\n      border-radius:14px;\n      overflow:hidden;\n      padding:18px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n      background:\n        radial-gradient(800px 400px at 30% 10%, rgba(123,63,255,0.04), transparent 8%),\n        linear-gradient(180deg, rgba(255,255,255,0.01), rgba(2,6,23,0.02));\n      border: 1px solid rgba(255,255,255,0.02);\n    }\n\n    .viz-top {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n      color:var(--muted);\n      font-size:13px;\n      padding:6px 6px;\n    }\n    .viz-canvas-wrap {\n      position:relative;\n      flex:1 1 auto;\n      min-height:380px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    canvas, svg {\n      width:100%;\n      height:100%;\n      display:block;\n      border-radius:12px;\n    }\n\n    .overlay-info {\n      position:absolute;\n      right:20px;\n      top:20px;\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n      align-items:flex-end;\n      pointer-events:none;\n    }\n\n    .metric {\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:8px 12px;\n      border-radius:10px;\n      font-size:13px;\n      color:var(--muted);\n      border: 1px solid rgba(255,255,255,0.02);\n      backdrop-filter: blur(4px);\n      min-width:120px;\n      text-align:right;\n    }\n\n    .decision {\n      stroke: #ffffff;\n      stroke-width:1.6;\n      stroke-linecap:round;\n      filter: drop-shadow(0 6px 16px rgba(154,126,255,0.12));\n    }\n\n    .dot-point {\n      stroke: rgba(0,0,0,0.18);\n      stroke-width:1.2;\n      transition: transform 240ms cubic-bezier(.2,.9,.3,1), opacity 240ms;\n    }\n\n    .sig-pane {\n      display:flex;\n      align-items:center;\n      gap:12px;\n      padding:10px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.006));\n      border: 1px solid rgba(255,255,255,0.02);\n      width:320px;\n    }\n\n    .sig-canvas {\n      width:120px;\n      height:56px;\n      border-radius:8px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.02);\n      box-shadow: 0 8px 20px rgba(15,25,50,0.25);\n    }\n\n    .sig-text {\n      font-size:12px;\n      color:var(--muted);\n    }\n\n    .footer-note {\n      color: rgba(255,255,255,0.06);\n      font-size:12px;\n      margin-top:8px;\n    }\n\n    /* small responsiveness */\n    @media (max-width:980px){\n      .frame{\n        grid-template-columns: 1fr;\n        padding:18px;\n      }\n      .info { order:2; }\n      .viz { order:1; }\n      .sig-pane { width:100%; justify-content:space-between; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"frame\" role=\"application\" aria-label=\"Logistic Regression visualization\">\n    <div class=\"info\" aria-hidden=\"false\">\n      <div class=\"brand\">\n        <div class=\"logo\">LR</div>\n        <div>\n          <h1>Logistic Regression</h1>\n          <div class=\"subtitle\">Binary classification visualized as a probability field</div>\n        </div>\n      </div>\n\n      <div class=\"equation\" title=\"sigmoid\">\n        <div class=\"pill\">σ(z)</div>\n        <div style=\"flex:1\">\n          <div class=\"sig\">σ(z) = 1 / (1 + e⁻ᶻ)</div>\n          <div style=\"font-size:12px;color:var(--muted);margin-top:6px\">Maps linear model output z = w·x + b to probability in (0,1)</div>\n        </div>\n      </div>\n\n      <div class=\"explain\">\n        Logistic regression models the probability that a point belongs to one of two classes using a logistic (sigmoid) transformation applied to a linear combination of features. In this view, the background shows the predicted probability field, points are samples, and the decision boundary is where probability = 0.5.\n      </div>\n\n      <div style=\"display:flex;gap:10px;margin-top:4px;align-items:center;\">\n        <div class=\"legend\">\n          <div class=\"item\"><div class=\"dot a\"></div> Class A</div>\n          <div class=\"item\"><div class=\"dot b\"></div> Class B</div>\n        </div>\n\n        <div style=\"flex:1\"></div>\n\n        <div class=\"controls\">\n          <button id=\"toggle\" class=\"toggle-btn\" aria-pressed=\"false\" title=\"Start/Stop animation\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"filter:drop-shadow(0 6px 8px rgba(46,64,255,0.12))\">\n              <path d=\"M5 3v18l15-9L5 3z\" fill=\"url(#g)\"></path>\n            </svg>\n            <span id=\"toggleLabel\">Pause</span>\n          </button>\n        </div>\n      </div>\n\n      <div style=\"margin-top:16px;display:flex;gap:10px;align-items:center;\">\n        <div class=\"pill\" style=\"font-size:12px\">\n          <strong style=\"font-weight:700;color:#fff;margin-right:8px\">Visual</strong>\n          Probabilities • Decision boundary • Sigmoid\n        </div>\n      </div>\n\n      <div class=\"meta\">\n        <div style=\"display:flex;flex-direction:column;\">\n          <div style=\"font-size:12px;color:var(--muted)\">Demo</div>\n          <div style=\"font-weight:700\">Animated field</div>\n        </div>\n        <div style=\"text-align:right\">\n          <div style=\"font-size:12px;color:var(--muted)\">Points</div>\n          <div style=\"font-weight:700\">160 samples</div>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"viz\">\n      <div class=\"viz-top\">\n        <div style=\"display:flex;gap:12px;align-items:center;\">\n          <div style=\"font-weight:700;font-size:15px\">Probability field</div>\n          <div style=\"font-size:13px;color:var(--muted)\">Heatmap shows σ(w·x + b)</div>\n        </div>\n\n        <div class=\"sig-pane\" aria-hidden=\"true\">\n          <canvas id=\"sigCanvas\" class=\"sig-canvas\" width=\"160\" height=\"80\"></canvas>\n          <div>\n            <div style=\"font-weight:700\">σ(z) — Sigmoid</div>\n            <div class=\"sig-text\">Smoothly maps linear score to probability</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"viz-canvas-wrap\" id=\"vizWrap\">\n        <!-- layered canvases for performance -->\n        <canvas id=\"heatmap\" style=\"position:absolute;inset:18px;border-radius:10px;filter:blur(8px) saturate(1.05);\"></canvas>\n        <canvas id=\"points\" style=\"position:absolute;inset:18px;border-radius:10px\"></canvas>\n\n        <!-- SVG Overlay for crisp decision boundary and highlights -->\n        <svg id=\"overlay\" viewBox=\"0 0 1000 600\" preserveAspectRatio=\"xMidYMid meet\" style=\"position:absolute;inset:18px;padding:0;margin:0;overflow:visible\">\n          <defs>\n            <linearGradient id=\"gline\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#9b7dff\"/>\n              <stop offset=\"1\" stop-color=\"#6aa8ff\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"></feGaussianBlur>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\" />\n                <feMergeNode in=\"SourceGraphic\" />\n              </feMerge>\n            </filter>\n          </defs>\n\n          <g id=\"dec-line\" filter=\"url(#glow)\"></g>\n        </svg>\n\n        <div class=\"overlay-info\" style=\"pointer-events:none\">\n          <div class=\"metric\" id=\"metric-p\">Average p: —</div>\n          <div class=\"metric\" id=\"metric-margin\">Margin: —</div>\n        </div>\n      </div>\n\n      <div class=\"footer-note\">Presentation-focused demo • Minimal controls • Observe how the linear model induces a smooth probabilistic field via the sigmoid</div>\n    </div>\n  </div>\n\n  <script>\n    // Logistic Regression visual demo — aesthetic-first, minimal controls\n    (function(){\n      const toggle = document.getElementById('toggle');\n      const toggleLabel = document.getElementById('toggleLabel');\n      let running = true;\n\n      // Canvas references\n      const heatmap = document.getElementById('heatmap');\n      const pointsCanvas = document.getElementById('points');\n      const overlaySVG = document.getElementById('overlay');\n      const decLineGroup = document.getElementById('dec-line');\n      const sigCanvas = document.getElementById('sigCanvas');\n      const metricP = document.getElementById('metric-p');\n      const metricMargin = document.getElementById('metric-margin');\n\n      // Responsive sizing\n      function resize() {\n        const wrap = document.getElementById('vizWrap');\n        const stylePad = 36; // due to inset padding\n        const rect = wrap.getBoundingClientRect();\n        // ensure 2:1 aspect ratio similar to SVG viewBox 1000x600\n        const w = Math.max(300, rect.width - stylePad);\n        const h = Math.max(220, rect.height - stylePad);\n        [heatmap, pointsCanvas].forEach(c => {\n          c.width = Math.floor(w);\n          c.height = Math.floor(h);\n          c.style.width = w + 'px';\n          c.style.height = h + 'px';\n        });\n        // Update overlay viewBox to match\n        overlaySVG.setAttribute('viewBox', `0 0 ${w} ${h}`);\n        overlaySVG.style.width = w + 'px';\n        overlaySVG.style.height = h + 'px';\n        drawSig(); // redraw sigmoid to fit if needed\n      }\n\n      window.addEventListener('resize', () => {\n        resize();\n        drawAll(forceHeat=true);\n      });\n\n      // Data generation: two Gaussian clusters\n      const N = 160;\n      let data = [];\n      function genData(){\n        data = [];\n        const r = () => (Math.random()*2 -1);\n        // Means for two classes\n        const mA = {x:-0.7, y:-0.3};\n        const mB = {x:0.6, y:0.5};\n        for(let i=0;i<N;i++){\n          const cls = i < N/2 ? 0 : 1;\n          const mean = cls===0 ? mA : mB;\n          const sx = 0.35*(0.9 + Math.random()*0.9);\n          const sy = 0.35*(0.85 + Math.random()*0.6);\n          const x = mean.x + gaussian()*sx;\n          const y = mean.y + gaussian()*sy;\n          data.push({x,y,label:cls});\n        }\n      }\n\n      // Box-Muller gaussian\n      function gaussian(){\n        let u=0,v=0;\n        while(u===0) u=Math.random();\n        while(v===0) v=Math.random();\n        return Math.sqrt(-2.0*Math.log(u)) * Math.cos(2.0*Math.PI*v);\n      }\n\n      // Logical coordinate system maps to canvas coordinates\n      function coordToPixel(pt, width, height){\n        // logical domain: x and y in about [-1.8,1.8]\n        const span = 3.6;\n        const cx = (pt.x + span/2) / span * width;\n        // invert y (canvas y down)\n        const cy = height - (pt.y + span/2) / span * height;\n        return {x: cx, y: cy};\n      }\n\n      function pixelToCoord(px, width, height){\n        const span = 3.6;\n        const x = (px / width) * span - span/2;\n        const y = ((height - px) / height) * span - span/2;\n      }\n\n      // Sigmoid\n      function sigmoid(z){ return 1/(1+Math.exp(-z)); }\n\n      // model: w (2D) and bias b. We'll animate angle and offset.\n      let t = 0;\n      let lastTime = performance.now();\n\n      // Animation control\n      toggle.addEventListener('click', ()=>{\n        running = !running;\n        toggle.setAttribute('aria-pressed', String(!running));\n        toggle.classList.toggle('paused', !running);\n        toggleLabel.textContent = running ? 'Pause' : 'Play';\n      });\n\n      // initial\n      genData();\n      resize();\n\n      // Draw Sigmoid small canvas\n      function drawSig(){\n        const c = sigCanvas;\n        const ctx = c.getContext('2d');\n        const w = c.width;\n        const h = c.height;\n        ctx.clearRect(0,0,w,h);\n        // background\n        ctx.fillStyle = 'rgba(255,255,255,0.01)';\n        ctx.fillRect(0,0,w,h);\n\n        // draw axes\n        ctx.strokeStyle = 'rgba(255,255,255,0.06)';\n        ctx.lineWidth = 1;\n        ctx.beginPath();\n        ctx.moveTo(6,h-18);\n        ctx.lineTo(w-6,h-18);\n        ctx.stroke();\n\n        // draw curve from z:-6..6\n        ctx.lineWidth = 2.2;\n        const grad = ctx.createLinearGradient(0,0,w,0);\n        grad.addColorStop(0,'#9b7dff');\n        grad.addColorStop(1,'#6aa8ff');\n        ctx.strokeStyle = grad;\n        ctx.beginPath();\n        const samples = 160;\n        for(let i=0;i<=samples;i++){\n          const z = -6 + (i/samples)*12;\n          const p = sigmoid(z);\n          const x = 6 + (i/samples)*(w-12);\n          const y = 6 + (1-p)*(h-22);\n          if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n        }\n        ctx.stroke();\n\n        // small moving dot to indicate current mapping for z=sin(t)*3\n        const zpos = Math.sin(t*0.7)*3.2;\n        const ppos = sigmoid(zpos);\n        const xp = 6 + ((zpos+6)/12)*(w-12);\n        const yp = 6 + (1-ppos)*(h-22);\n        ctx.fillStyle = '#fff';\n        ctx.beginPath();\n        ctx.arc(xp,yp,4,0,Math.PI*2);\n        ctx.fill();\n        ctx.fillStyle = 'rgba(255,255,255,0.06)';\n        ctx.beginPath();\n        ctx.arc(xp,yp,9,0,Math.PI*2);\n        ctx.fill();\n      }\n\n      // Color interpolation for heatmap: blue to green\n      function colorForProb(p){\n        // nice gradient: green (class A) to blue (class B), with purple midglow\n        // p in [0,1] probability of class B\n        const c1 = [34,197,139]; // greenish\n        const c2 = [52,107,242]; // blue\n        const cx = [155,125,255]; // purple blend around mid\n        // combine with smoothstep\n        const mid = Math.exp(-Math.pow((p-0.5)/0.18,2));\n        const r = Math.round((1-p)*c1[0] + p*c2[0] + 0.45*mid*cx[0]);\n        const g = Math.round((1-p)*c1[1] + p*c2[1] + 0.45*mid*cx[1]);\n        const b = Math.round((1-p)*c1[2] + p*c2[2] + 0.45*mid*cx[2]);\n        return `rgb(${r},${g},${b})`;\n      }\n\n      let heatCtx = heatmap.getContext('2d');\n      let ptsCtx = pointsCanvas.getContext('2d');\n\n      // Draw everything: heatmap background + points + decision boundary\n      let lastHeatW = 0, lastHeatH = 0;\n      function drawAll(forceHeat=false){\n        const w = heatmap.width;\n        const h = heatmap.height;\n        if(w===0||h===0) return;\n        heatCtx = heatmap.getContext('2d');\n        ptsCtx = pointsCanvas.getContext('2d');\n\n        // compute model parameters based on t\n        // let angle rotate slowly; bias oscillate\n        const angle = t * 0.28;\n        const wmag = 2.4; // strength\n        const wx = Math.cos(angle) * wmag;\n        const wy = Math.sin(angle) * wmag;\n        const bias = Math.sin(t*0.9)*0.6;\n\n        // Only recompute heatmap at lower frequency for perf, or if size changed\n        if(forceHeat || lastHeatW !== w || lastHeatH !== h){\n          lastHeatW = w; lastHeatH = h;\n          // draw heatmp by sampling every 'step' px\n          const step = Math.max(3, Math.floor(Math.min(w,h)/120));\n          for(let iy=0; iy<h; iy += step){\n            for(let ix=0; ix<w; ix += step){\n              // map pixel to logical coordinate\n              const span = 3.6;\n              const lx = (ix/w)*span - span/2;\n              const ly = ((h-iy)/h)*span - span/2;\n              const z = wx*lx + wy*ly + bias;\n              const p = sigmoid(z);\n              heatCtx.fillStyle = colorForProb(p);\n              heatCtx.fillRect(ix, iy, step, step);\n            }\n          }\n          // overlay subtle radial vignette for depth\n          const g = heatCtx.createRadialGradient(w*0.18, h*0.2, Math.min(w,h)*0.05, w*0.5, h*0.6, Math.max(w,h)*1.1);\n          g.addColorStop(0, 'rgba(255,255,255,0.02)');\n          g.addColorStop(1, 'rgba(0,0,0,0.18)');\n          heatCtx.globalCompositeOperation = 'multiply';\n          heatCtx.fillStyle = g;\n          heatCtx.fillRect(0,0,w,h);\n          heatCtx.globalCompositeOpera