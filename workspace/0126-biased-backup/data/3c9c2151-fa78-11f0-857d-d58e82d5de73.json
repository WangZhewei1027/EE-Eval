    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Nearest Neighbors – Illustrated Concept</title>\n<style>\n  /* Reset and base */\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n  * {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    color: #ffffff;\n    font-family: 'Montserrat', sans-serif;\n    overflow: hidden;\n    user-select: none;\n  }\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 2rem;\n    min-height: 100vh;\n  }\n  h1 {\n    font-weight: 700;\n    font-size: 3.25rem;\n    letter-spacing: 0.1em;\n    margin-bottom: 0.25em;\n    background: linear-gradient(90deg, #a1c4fd, #c2e9fb);\n    background-clip: text;\n    -webkit-background-clip: text;\n    color: transparent;\n    text-transform: uppercase;\n    text-align: center;\n  }\n  h2 {\n    font-weight: 400;\n    font-size: 1.25rem;\n    margin-top: 0;\n    margin-bottom: 3rem;\n    color: #a1c4fddd;\n    font-style: italic;\n    text-align: center;\n    letter-spacing: 0.05em;\n  }\n\n  /* Container for visualization */\n  #visualization {\n    position: relative;\n    width: 760px;\n    height: 580px;\n    border-radius: 32px;\n    background: radial-gradient(circle at top left, #1e2a38, #15202b 80%);\n    box-shadow:\n      inset 0 0 50px #4e91fc55,\n      0 12px 48px rgba(9,109,255,0.6);\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Canvas scaling for crisp graphics */\n  canvas {\n    display: block;\n    border-radius: 32px;\n    width: 760px;\n    height: 580px;\n    image-rendering: optimizeSpeed;\n    image-rendering: crisp-edges;\n    image-rendering: pixelated;\n  }\n\n  /* Controls */\n  #controls {\n    margin-top: 2.8rem;\n    display: flex;\n    gap: 1.6rem;\n  }\n  button {\n    background: linear-gradient(145deg, #2d99ff, #0580f2);\n    border: none;\n    border-radius: 12px;\n    padding: 0.9rem 2rem;\n    font-size: 1rem;\n    font-weight: 700;\n    color: #f0f7ff;\n    font-family: 'Montserrat', sans-serif;\n    cursor: pointer;\n    transition:\n      background 0.3s cubic-bezier(0.4, 0, 0.2, 1),\n      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.35s ease;\n    box-shadow:\n      0 4px 12px rgb(5 128 242 / 0.7);\n    user-select: none;\n  }\n  button:hover, button:focus {\n    background: linear-gradient(145deg, #4fa9ff, #3a99ff);\n    box-shadow:\n      0 6px 18px rgb(40 148 255 / 0.85);\n    transform: translateY(-2.5px);\n    outline: none;\n  }\n\n  /* Caption */\n  #caption {\n    margin-top: 3rem;\n    max-width: 760px;\n    font-size: 1.1rem;\n    line-height: 1.65;\n    color: #a1c4fddd;\n    text-align: center;\n    letter-spacing: 0.04em;\n    user-select: none;\n  }\n\n  /* Tooltip for nodes - subtle */\n  #tooltip {\n    position: absolute;\n    padding: 0.38rem 0.8rem;\n    background: rgba(255 255 255 / 0.12);\n    backdrop-filter: blur(8px);\n    border-radius: 0.6rem;\n    pointer-events: none;\n    opacity: 0;\n    color: #eff8ffee;\n    font-size: 0.85rem;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    transition: opacity 0.25s ease;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n  <h1>K-Nearest Neighbors</h1>\n  <h2>Visualizing Machine Learning's Nearest-Neighbor Method</h2>\n  <div id=\"visualization\">\n    <canvas id=\"knnCanvas\" width=\"760\" height=\"580\" aria-label=\"K-Nearest Neighbors visualization\"></canvas>\n    <div id=\"tooltip\" aria-hidden=\"true\"></div>\n  </div>\n  <div id=\"controls\" aria-label=\"K-Nearest Neighbors simulation controls\">\n    <button id=\"toggleAnimation\" aria-pressed=\"true\" title=\"Play or pause the animation\">Pause Animation</button>\n  </div>\n  <div id=\"caption\">\n    Observe a new data point (white glow) being classified by its closest neighbors (colored points). The edges highlight the <em>k</em> = 5 nearest neighbors influencing the decision. The color of the new point’s glow animates gently as the nearest neighbors shift, illustrating how local data structure determines classification.\n  </div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('knnCanvas');\n  const ctx = canvas.getContext('2d');\n  const tooltip = document.getElementById('tooltip');\n  const toggleBtn = document.getElementById('toggleAnimation');\n\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Color palette - harmonious and subtle yet vivid\n  const classColors = {\n    A: 'hsl(215, 75%, 57%)',  // Blue\n    B: 'hsl(20, 85%, 55%)',   // Coral Red\n    C: 'hsl(120, 65%, 47%)'   // Green\n  };\n\n  // Stylish pastel tinted versions for points' glows\n  const pastelColors = {\n    A: 'hsl(215, 85%, 75%)',\n    B: 'hsl(20, 85%, 75%)',\n    C: 'hsl(120, 75%, 75%)'\n  };\n\n  // Configuration\n  const k = 5; // number of neighbors\n  const pointRadius = 10;\n  const newPointRadius = 14;\n  const edgeWidth = 2.8;\n\n  // Generate stylish scattered dataset with three classes\n  // The points are clustered nicely with slight shape variation\n  class DataPoint {\n    constructor(x, y, cls, id) {\n      this.x = x;\n      this.y = y;\n      this.cls = cls;\n      this.id = id;\n    }\n  }\n\n  let dataset = [];\n\n  function generateCluster(centerX, centerY, cls, count, shape = 'circle', angleOffset = 0) {\n    // Generates points roughly in circular/elliptical patterns with noise\n    const cluster = [];\n    for (let i = 0; i < count; i++) {\n      const angle = Math.random() * Math.PI * 2;\n      const radius = 40 + (Math.random() * 30);\n      let x = centerX + Math.cos(angle + angleOffset) * radius + (Math.random() * 12 - 6);\n      let y = centerY + Math.sin(angle + angleOffset) * radius + (Math.random() * 12 - 6);\n      cluster.push(new DataPoint(x, y, cls, `${cls}-${i}`));\n    }\n    return cluster;\n  }\n\n  dataset = [\n    ...generateCluster(220, 170, 'A', 15),\n    ...generateCluster(520, 200, 'B', 15, 'circle'),\n    ...generateCluster(380, 420, 'C', 15),\n  ];\n\n  // The new point moves slowly along an elegant parametric path\n  let animationTime = 0;\n  let animationPlaying = true;\n\n  // Calculate Euclidean distance squared for efficiency\n  function distanceSq(p1, p2) {\n    const dx = p1.x - p2.x;\n    const dy = p1.y - p2.y;\n    return dx * dx + dy * dy;\n  }\n\n  // Find k nearest neighbors\n  function findKNearestNeighbors(point, dataset, k) {\n    const distances = dataset.map(d => {\n      return {point: d, dist: distanceSq(point, d)};\n    });\n    distances.sort((a, b) => a.dist - b.dist);\n    return distances.slice(0, k).map(d => d.point);\n  }\n\n  // Determine majority class in neighbors, with tie-breaking by nearest\n  function majorityClass(neighbors) {\n    const counts = {};\n    neighbors.forEach(n => {\n      counts[n.cls] = (counts[n.cls] || 0) + 1;\n    });\n    // find max count\n    let maxCount = 0;\n    let winner = null;\n    for (const cls in counts) {\n      if (counts[cls] > maxCount) {\n        maxCount = counts[cls];\n        winner = cls;\n      }\n    }\n    // If tie, pick class of closest neighbor\n    const tieCount = Object.values(counts).filter(c => c === maxCount).length;\n    if (tieCount > 1) {\n      for (const n of neighbors) {\n        if (counts[n.cls] === maxCount) {\n          return n.cls;\n        }\n      }\n    }\n    return winner;\n  }\n\n  // Draw a subtle glow for a circle\n  function drawGlowCircle(cx, cy, radius, color, intensity = 0.3, blur = 30) {\n    ctx.save();\n    ctx.shadowColor = color;\n    ctx.shadowBlur = blur;\n    ctx.globalAlpha = intensity;\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    ctx.arc(cx, cy, radius, 0, Math.PI * 2);\n    ctx.fill();\n    ctx.restore();\n  }\n\n  // Draw a point node\n  function drawPoint(p, radius, color, glowIntensity = 0.4) {\n    drawGlowCircle(p.x, p.y, radius + 10, color, glowIntensity * 0.7, 22);\n    ctx.shadowColor = color;\n    ctx.shadowBlur = 14;\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    ctx.ellipse(p.x, p.y, radius * 1.4, radius, 0, 0, Math.PI * 2);\n    ctx.fill();\n\n    // Inner white highlight ellipse for polish\n    let gradHighlight = ctx.createRadialGradient(p.x - radius * 0.4, p.y - radius * 0.3, radius * 0.2, p.x, p.y, radius * 1.1);\n    gradHighlight.addColorStop(0, 'rgba(255,255,255,0.65)');\n    gradHighlight.addColorStop(1, 'rgba(255,255,255,0)');\n    ctx.fillStyle = gradHighlight;\n    ctx.beginPath();\n    ctx.ellipse(p.x - radius * 0.4, p.y - radius * 0.3, radius * 0.85, radius * 0.6, -0.3, 0, Math.PI * 2);\n    ctx.fill();\n\n    // Outer ring - subtle border\n    ctx.shadowColor = 'transparent';\n    ctx.lineWidth = 1.6;\n    ctx.strokeStyle = 'rgba(255 255 255 / 0.24)';\n    ctx.beginPath();\n    ctx.ellipse(p.x, p.y, radius * 1.43, radius * 1.02, 0, 0, Math.PI * 2);\n    ctx.stroke();\n  }\n\n  // Draw edges (lines) between new point and neighbors with subtle glow\n  function drawEdge(p1, p2, color) {\n    const grad = ctx.createLinearGradient(p1.x, p1.y, p2.x, p2.y);\n    grad.addColorStop(0, color);\n    grad.addColorStop(1, 'rgba(255 255 255 / 0.2)');\n    ctx.strokeStyle = grad;\n    ctx.lineWidth = edgeWidth;\n    ctx.shadowColor = color;\n    ctx.shadowBlur = 12;\n    ctx.beginPath();\n    ctx.moveTo(p1.x, p1.y);\n    ctx.lineTo(p2.x, p2.y);\n    ctx.stroke();\n    ctx.shadowColor = 'transparent';\n  }\n\n  // Draw new point with dynamic glow color (animated)\n  function drawNewPoint(p, baseColor, progress) {\n    // Animate glow pulsation and color saturation\n    const baseHsl = hslStringToObject(baseColor);\n    const glowColor = `hsl(${baseHsl.h}, ${Math.min(baseHsl.s + 25, 95)}%, ${baseHsl.l + 8}%)`;\n    const alpha = 0.3 + 0.3 * Math.sin(progress * Math.PI * 2);\n    drawGlowCircle(p.x, p.y, newPointRadius + 16, glowColor, alpha * 0.6, 38);\n    drawGlowCircle(p.x, p.y, newPointRadius + 7, glowColor, alpha * 0.45, 16);\n\n    ctx.shadowColor = glowColor;\n    ctx.shadowBlur = 22;\n    ctx.fillStyle = `hsl(${baseHsl.h}, ${baseHsl.s}%, ${baseHsl.l + 4}%)`;\n\n    ctx.beginPath();\n    ctx.ellipse(p.x, p.y, newPointRadius * 1.62, newPointRadius * 1.12, 0, 0, Math.PI * 2);\n    ctx.fill();\n\n    // Inner pearl white highlight\n    let pearlGrad = ctx.createRadialGradient(p.x - newPointRadius * 0.4, p.y - newPointRadius * 0.3, newPointRadius * 0.28, p.x, p.y, newPointRadius * 1.28);\n    pearlGrad.addColorStop(0, 'rgba(255 255 255 / 0.87)');\n    pearlGrad.addColorStop(1, 'rgba(255 255 255 / 0)');\n    ctx.fillStyle = pearlGrad;\n    ctx.beginPath();\n    ctx.ellipse(p.x - newPointRadius * 0.4, p.y - newPointRadius * 0.3, newPointRadius * 0.85, newPointRadius * 0.60, -0.3, 0, Math.PI * 2);\n    ctx.fill();\n\n    ctx.shadowColor = 'transparent';\n  }\n\n  // Utility: parse HSL string \"hsl(h, s%, l%)\" to object {h,s,l}\n  function hslStringToObject(hslString) {\n    const parts = hslString.match(/hsl\\((\\d+),\\s*(\\d+)%,\\s*(\\d+)%\\)/);\n    if (parts) {\n      return {\n        h: +parts[1],\n        s: +parts[2],\n        l: +parts[3]\n      };\n    }\n    return {h: 0, s: 0, l: 0};\n  }\n\n  // Generate a smooth cyclic path for new point around center area\n  function newPointPosition(t) {\n    // Elegant Lissajous-like figure for fluid motion\n    const cx = width / 2;\n    const cy = height / 2 + 20;\n    const amplitudeX = 170;\n    const amplitudeY = 130;\n    const x = cx + amplitudeX * Math.sin(t * 1.6 + 0.7);\n    const y = cy + amplitudeY * Math.sin(t * 1.1);\n    return {x, y};\n  }\n\n  // Tooltip management\n  function showTooltip(x, y, text) {\n    tooltip.textContent = text;\n    tooltip.style.opacity = '1';\n    tooltip.style.left = `${x + 14}px`;\n    tooltip.style.top = `${y + 14}px`;\n  }\n  function hideTooltip() {\n    tooltip.style.opacity = '0';\n  }\n\n  // Main render function\n  function render(t) {\n    ctx.clearRect(0, 0, width, height);\n\n    // Calculate new point position (animated)\n    const pt = newPointPosition(t);\n\n    // Find k nearest neighbors\n    const neighbors = findKNearestNeighbors(pt, dataset, k);\n    const majorityCls = majorityClass(neighbors);\n    const glowBaseColor = pastelColors[majorityCls];\n\n    // Draw all dataset points behind\n    for (const dp of dataset) {\n      drawPoint(dp, pointRadius, classColors[dp.cls], 0.32);\n    }\n\n    // Draw edges from new point to neighbors with color coding by neighbor class\n    for (const n of neighbors) {\n      drawEdge(pt, n, classColors[n.cls]);\n    }\n\n    // Draw nearest neighbor points brighter with a ring\n    for (const n of neighbors) {\n      drawPoint(n, pointRadius + 2.6, classColors[n.cls], 0.8);\n    }\n\n    // Draw new data point with animated glow of majority class\n    drawNewPoint(pt, glowBaseColor, t);\n\n    // Outline new point with a subtle transparent ring to separate\n    ctx.lineWidth = 2.2;\n    ctx.strokeStyle = 'rgba(255 255 255 / 0.18)';\n    ctx.beginPath();\n    ctx.ellipse(pt.x, pt.y, newPointRadius * 1.62, newPointRadius * 1.15, 0, 0, Math.PI * 2);\n    ctx.stroke();\n\n    // Tiny sparkling accent on new point for elegance (flickering)\n    const sparkleAlpha = 0.25 + 0.18 * Math.sin(t * 24 + Math.PI);\n    ctx.fillStyle = `rgba(255 255 255, ${sparkleAlpha})`;\n    const sparkleX = pt.x + newPointRadius * 0.8 * Math.cos(t * 8);\n    const sparkleY = pt.y - newPointRadius * 0.6 * Math.sin(t * 8);\n    ctx.beginPath();\n    ctx.ellipse(sparkleX, sparkleY, 3.2, 5.8, t % (Math.PI * 2), 0, Math.PI * 2);\n    ctx.fill();\n\n    // Draw subtle gridlines and axis for style (behind points)\n    drawGrid();\n\n    // Accessibility: no text overlays on canvas; semantics conveyed in HTML\n  }\n\n  // Draw subtle grid lines in background\n  function drawGrid() {\n    const gridSpacing = 47;\n    ctx.save();\n    ctx.strokeStyle = 'rgba(255 255 255 / 0.07)';\n    ctx.lineWidth = 1;\n    ctx.setLineDash([6, 14]);\n    for (let x = 0; x <= width; x += gridSpacing) {\n      ctx.beginPath();\n      ctx.moveTo(x, 0);\n      ctx.lineTo(x, height);\n      ctx.stroke();\n    }\n    for (let y = 0; y <= height; y += gridSpacing) {\n      ctx.beginPath();\n      ctx.moveTo(0, y);\n      ctx.lineTo(width, y);\n      ctx.stroke();\n    }\n    ctx.restore();\n\n    // Draw axis lines\n    ctx.save();\n    ctx.strokeStyle = 'rgba(255 255 255 / 0.15)';\n    ctx.lineWidth = 1.8;\n    ctx.beginPath();\n    ctx.moveTo(width / 2, 0);\n    ctx.lineTo(width / 2, height);\n    ctx.moveTo(0, height / 2);\n    ctx.lineTo(width, height / 2);\n    ctx.stroke();\n    ctx.restore();\n  }\n\n  // Animation loop\n  let lastTimestamp = 0;\n  function animate(timestamp = 0) {\n    if (!lastTimestamp) lastTimestamp = timestamp;\n    const delta = (timestamp - lastTimestamp) / 1000;\n    if (animationPlaying) {\n      animationTime += delta * 0.7;\n      if (animationTime > 1000) animationTime -= 1000;\n    }\n    render(animationTime);\n    lastTimestamp = timestamp;\n    requestAnimationFrame(animate);\n  }\n\n  // Interactivity is very limited: toggle animation play/pause\n  toggleBtn.addEventListener('click', () => {\n    animationPlaying = !animationPlaying;\n    toggleBtn.textContent = animationPlaying ? 'Pause Animation' : 'Play Animation';\n    toggleBtn.setAttribute('aria-pressed', animationPlaying);\n  });\n\n  // No pointer interaction required - but add subtle tooltip on hover for neighbors\n  canvas.addEventListener('mousemove', (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n\n    // Check if mouse is near any dataset point or neighbors\n    let hovered = null;\n    function dist(p) {\n      return Math.hypot(p.x - mx, p.y - my);\n    }\n\n    // Consider points within a radius\n    const radiusHover = 18;\n    // Check neighbors first, show class name\n    const pt = newPointPosition(animationTime);\n    const neighbors = findKNearestNeighbors(pt, dataset, k);\n    for (const n of neighbors) {\n      if (dist(n) < radiusHover) {\n        hovered = n;\n        break;\n      }\n    }\n    // Else check all points for tooltip\n    if (!hovered) {\n      for (const pnt of dataset) {\n        if (dist(pnt) < radiusHover) {\n          hovered = pnt;\n          break;\n        }\n      }\n    }\n\n    if (hovered) {\n      showTooltip(hovered.x, hovered.y, `Class ${hovered.cls}`);\n    } else {\n      hideTooltip();\n    }\n  });\n\n  canvas.addEventListener('mouseleave', () => {\n    hideTooltip();\n  });\n\n  // Initial call\n  requestAnimationFrame(animate);\n\n})();\n</script>\n</body>\n</html>"
