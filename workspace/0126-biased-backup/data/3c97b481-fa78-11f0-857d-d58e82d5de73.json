    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Floyd-Warshall Algorithm - Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset, base */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0; height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f0;\n    overflow: hidden;\n    user-select: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  /* Container & Layout */\n  .container {\n    display: flex;\n    flex-direction: column;\n    height: 100vh;\n    width: 100vw;\n    padding: 2rem 3rem;\n    backdrop-filter: saturate(180%) blur(15px);\n    background: rgba(28, 43, 66, 0.75);\n    border-radius: 20px;\n    box-shadow: 0 30px 50px -10px rgba(10, 40, 80, 0.8);\n  }\n\n  header {\n    flex-shrink: 0;\n    text-align: center;\n    margin-bottom: 1.8rem;\n  }\n\n  header h1 {\n    font-weight: 600;\n    letter-spacing: 0.15em;\n    font-size: 2.8rem;\n    color: #f0f5fc;\n    text-shadow:\n      0 0 20px #3ddc97aa,\n      0 0 30px #3ddc97aa,\n      0 0 40px #3ddc97aa;\n    margin-bottom: 0.15rem;\n  }\n\n  header p {\n    font-weight: 300;\n    font-size: 1.1rem;\n    color: #9fcdfcaa;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n  }\n\n  /* Graph Container */\n  main {\n    flex-grow: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    perspective: 1400px;\n  }\n\n  /* Board for matrix and nodes */\n  #graph {\n    position: relative;\n    width: 620px;\n    height: 620px;\n    border-radius: 30px;\n    background:\n      radial-gradient(circle at center, #042233 0%, #01121d 85%),\n      linear-gradient(45deg, #0b2541 50%, transparent 50%);\n    box-shadow:\n      inset 0 0 40px #093254,\n      0 0 70px #04b575aa,\n      0 8px 30px -4px #03a364aa;\n    transition: box-shadow 0.6s ease;\n    transform-style: preserve-3d;\n  }\n\n  /* Nodes on the circle */\n  .node {\n    position: absolute;\n    width: 48px;\n    height: 48px;\n    background: linear-gradient(145deg, #0aed98, #0f9e6a);\n    box-shadow:\n      0 6px 10px #04b575bb,\n      inset 0 -3px 5px #13d6a1,\n      inset 0 5px 8px #0a5f3b;\n    border-radius: 50%;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    font-weight: 600;\n    font-size: 1.2rem;\n    color: #e0f7ee;\n    text-shadow: 0 0 6px #03b66899;\n    cursor: default;\n    user-select: none;\n    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  .node:hover {\n    transform: scale(1.28);\n    filter: drop-shadow(0 0 12px #00ffbcdd);\n    z-index: 11;\n  }\n\n  /* Edges */\n  svg {\n    position: absolute;\n    top: 0; left: 0;\n    width: 620px;\n    height: 620px;\n    pointer-events: none;\n    overflow: visible;\n  }\n\n  line.edge {\n    stroke: #04b575dd;\n    stroke-width: 2;\n    stroke-linecap: round;\n  }\n  line.edge.highlighted {\n    stroke: #03ffb6ff;\n    stroke-width: 3;\n    filter: drop-shadow(0 0 10px #20f7b8);\n    transition: stroke 0.5s, stroke-width 0.5s;\n  }\n\n  /* Edge label (weight) */\n  .weight-label {\n    position: absolute;\n    pointer-events: none;\n    user-select: none;\n    font-size: 0.8rem;\n    font-weight: 600;\n    color: #afffffcc;\n    text-shadow:\n      0 0 6px #03f1d6aa;\n    transform: translate(-50%, -50%);\n    font-family: 'Poppins', sans-serif;\n  }\n\n  /* Matrix display */\n  #matrix-container {\n    margin-top: 2rem;\n    width: 100%;\n    max-width: 620px;\n    margin-left: auto;\n    margin-right: auto;\n    background: #0a3949dd;\n    border-radius: 20px;\n    overflow: hidden;\n    box-shadow:\n      inset 0 0 50px #00d2a3aa,\n      0 8px 40px -20px #00ce9ebb;\n    user-select: none;\n  }\n  #matrix-container h2 {\n    margin: 1rem 0 0.5rem;\n    font-weight: 600;\n    font-size: 1.4rem;\n    color: #b9ffe7;\n    text-align: center;\n    font-family: 'Poppins', sans-serif;\n    text-shadow: 0 0 8px #0ff5dccc;\n    letter-spacing: 0.15em;\n  }\n  #matrix {\n    width: 100%;\n    border-collapse: collapse;\n    margin-bottom: 1rem;\n  }\n  #matrix thead tr {\n    background: linear-gradient(45deg, #06a36e, #00ffa5);\n  }\n  #matrix thead th {\n    padding: 0.65rem 0.3rem;\n    font-weight: 600;\n    font-size: 1rem;\n    color: #daf7f2;\n    border-right: 1px solid #00ffbaa0;\n    text-shadow:\n      0 0 4px #12f7ceaa;\n  }\n  #matrix thead th:last-child {\n    border-right: none;\n  }\n  #matrix tbody td {\n    padding: 0.65rem 0.4rem;\n    text-align: center;\n    font-weight: 600;\n    font-size: 1.05rem;\n    color: #a2f7d1cc;\n    border-top: 1px solid #00885c8a;\n    border-right: 1px solid #00ffbb90;\n    transition: background-color 0.4s ease, color 0.4s ease;\n    font-family: 'Poppins', sans-serif;\n  }\n  #matrix tbody td:last-child {\n    border-right: none;\n  }\n  #matrix tbody tr.highlight td {\n    background-color: #0bf2bc88;\n    color: #001a0e;\n  }\n\n  /* Button Panel */\n  #controls {\n    display: flex;\n    justify-content: center;\n    margin-top: 1rem;\n    gap: 1.3rem;\n  }\n  button {\n    background: linear-gradient(135deg, #05c37f, #00ffa9);\n    border: none;\n    padding: 0.75rem 2.2rem;\n    border-radius: 25px;\n    font-weight: 600;\n    font-size: 1.05rem;\n    color: white;\n    letter-spacing: 0.1em;\n    cursor: pointer;\n    box-shadow:\n      0 0 18px #0fffbbcc,\n      0 8px 28px -4px #03e19fbb;\n    transition: all 0.3s ease;\n    font-family: 'Poppins', sans-serif;\n    user-select: none;\n    filter: drop-shadow(0 0 5px #07ffaeaa);\n  }\n  button:hover:not(:disabled),\n  button:focus:not(:disabled) {\n    filter: drop-shadow(0 0 22px #00ffbdcc);\n    background: linear-gradient(135deg, #00ffa9, #05c37f);\n    outline: none;\n  }\n  button:disabled {\n    opacity: 0.45;\n    cursor: default;\n    filter: none;\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 1.7rem;\n    text-align: center;\n    font-weight: 300;\n    font-size: 0.9rem;\n    color: #658f9f88;\n    font-family: 'Poppins', sans-serif;\n    user-select: none;\n  }\n\n  /* Scrollbar hidden for matrix container */\n  #matrix-container::-webkit-scrollbar {\n    display: none;\n  }\n  #matrix-container {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\" role=\"main\" aria-label=\"Floyd-Warshall algorithm visualization\">\n  <header>\n    <h1>FLOYD&#8209;WARSHALL</h1>\n    <p>All-Pairs Shortest Path Algorithm</p>\n  </header>\n  <main>\n    <div id=\"graph\" aria-label=\"Graph visualization of nodes and edges with weights\">\n      <svg aria-hidden=\"true\" id=\"edges-svg\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n    </div>\n  </main>\n  <div id=\"matrix-container\" aria-label=\"Current distance matrix table\">\n    <h2>Distance Matrix</h2>\n    <table id=\"matrix\" aria-live=\"polite\" aria-relevant=\"all\" aria-atomic=\"true\" role=\"grid\">\n      <thead></thead>\n      <tbody></tbody>\n    </table>\n  </div>\n  <div id=\"controls\" aria-label=\"Controls for Floyd-Warshall visualization\">\n    <button id=\"nextStepBtn\" type=\"button\" aria-describedby=\"desc-next\">Next Step</button>\n    <button id=\"resetBtn\" type=\"button\" aria-describedby=\"desc-reset\">Reset Visualization</button>\n  </div>\n  <footer>\n    &copy; 2024 &bull; Crafted with care &bull; Visualization inspired by graph theory\n  </footer>\n</div>\n\n<script>\n(() => {\n  'use strict';\n\n  /*\n  Floyd-Warshall Algorithm Visual Concept\n  Graph:\n    6 nodes labeled 0 to 5 in a circle\n    Weighted edges (directed)\n  Show distance matrix updates step-by-step with highlight on updating edges\n  */\n\n  const N = 6;\n\n  // Graph data: adjacency matrix with distances, -1 means no direct edge\n  // Symmetric or directed, some edges missing\n  const INF = 9999;\n  const graphWeights = [\n    /* 0 */ [0, 3, 8, INF, -4, INF],\n    /* 1 */ [INF, 0, INF, 1, 7, INF],\n    /* 2 */ [INF, 4, 0, INF, INF, INF],\n    /* 3 */ [2, INF, -5, 0, INF, INF],\n    /* 4 */ [INF, INF, INF, 6, 0, 9],\n    /* 5 */ [INF, INF, INF, INF, INF, 0],\n  ];\n\n  // Elements\n  const graphEl = document.getElementById('graph');\n  const edgesSvg = document.getElementById('edges-svg');\n  const matrixTable = document.getElementById('matrix');\n  const matrixHead = matrixTable.querySelector('thead');\n  const matrixBody = matrixTable.querySelector('tbody');\n  const nextStepBtn = document.getElementById('nextStepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Positions for nodes in circle\n  const radius = 260;\n  const centerX = 310;\n  const centerY = 310;\n\n  // Nodes data {id, x, y, el}\n  let nodes = [];\n\n  // Create nodes (circles with labels)\n  function createNodes() {\n    nodes = [];\n    for(let i=0; i<N; i++) {\n      const angle = (2 * Math.PI * i) / N - Math.PI / 2; // start top\n      let x = centerX + radius * Math.cos(angle);\n      let y = centerY + radius * Math.sin(angle);\n\n      const nodeEl = document.createElement('div');\n      nodeEl.className = 'node';\n      nodeEl.textContent = i;\n      nodeEl.style.left = `${x - 24}px`;\n      nodeEl.style.top = `${y - 24}px`;\n      nodeEl.setAttribute('aria-label', `Node ${i}`);\n      graphEl.appendChild(nodeEl);\n\n      nodes.push({ id: i, x, y, el: nodeEl });\n    }\n  }\n\n  // Create edges as SVG lines and weight labels\n  // Keep them in arrays to update style and highlights\n  let edgeElements = [];\n  let weightLabels = [];\n\n  function clearEdges() {\n    edgesSvg.innerHTML = '';\n    edgeElements = [];\n    weightLabels.forEach(label => label.remove());\n    weightLabels = [];\n  }\n  function createEdges() {\n    clearEdges();\n\n    for(let i=0; i<N; i++) {\n      for(let j=0; j<N; j++) {\n        let w = graphWeights[i][j];\n        if(w !== INF && i !== j) {\n          const start = nodes[i];\n          const end = nodes[j];\n          // Draw a curved edge for non-adjacent nodes to prevent overlap\n          let dx = end.x - start.x;\n          let dy = end.y - start.y;\n          let dist = Math.hypot(dx, dy);\n\n          // SVG line or path? We want smooth curves for edges between nodes, especially for reverse of edges\n          // We'll use quadratic Bezier paths between nodes with slight offset\n\n          const midX = (start.x + end.x) / 2;\n          const midY = (start.y + end.y) / 2;\n\n          // Calculate perpendicular offset vector for curve control point\n          const offsetAmount = 30;\n          const normX = -dy / dist;\n          const normY = dx / dist;\n          // To prevent reverse edges overlapping same curve, add offset direction by order of nodes\n          const direction = (i < j) ? 1 : -1;\n          const ctrlX = midX + normX * offsetAmount * direction;\n          const ctrlY = midY + normY * offsetAmount * direction;\n\n          // Create path element\n          const path = document.createElementNS(\"http://www.w3.org/2000/svg\",\"path\");\n\n          const pathD = `M${start.x},${start.y} Q${ctrlX},${ctrlY} ${end.x},${end.y}`;\n          path.setAttribute('d', pathD);\n          path.setAttribute('stroke', '#04b575dd');\n          path.setAttribute('stroke-width', '2');\n          path.setAttribute('fill', 'none');\n          path.setAttribute('class', 'edge');\n          edgesSvg.appendChild(path);\n\n          // For accessibility & data linkage\n          path.dataset.from = i;\n          path.dataset.to = j;\n\n          edgeElements.push(path);\n\n          // Create weight label element as div, positioned near control point\n          const weightLabel = document.createElement('div');\n          weightLabel.className = 'weight-label';\n          weightLabel.textContent = w < INF ? w : '∞';\n\n          // Position label slightly away from curve control point toward mid point\n          // Weighted midpoint closer to control point, but shifted slightly so not exactly on curve\n          // We'll shift it toward ctrl point by 0.6 and mid point by 0.4\n          const labelX = ctrlX * 0.6 + midX * 0.4;\n          const labelY = ctrlY * 0.6 + midY * 0.4;\n          // Offset up for negative weights to avoid overlap with the path\n          const finalX = labelX;\n          const finalY = (w < 0) ? labelY - 12 : labelY + 12;\n\n          weightLabel.style.left = `${finalX}px`;\n          weightLabel.style.top = `${finalY}px`;\n\n          graphEl.appendChild(weightLabel);\n          weightLabels.push(weightLabel);\n        }\n      }\n    }\n  }\n\n\n  // Distance matrix displayed & updated\n  // Copy of current distances in algorithm progress\n  let dist;\n\n  // k-step index:\n  let kStep = -1;\n\n  // Initialize distance matrix copy\n  function initDist() {\n    dist = graphWeights.map(row => row.slice());\n  }\n\n  // Render matrix table (thead, tbody)\n  function renderMatrix(highlightRow=-1) {\n    matrixHead.innerHTML = '';\n    matrixBody.innerHTML = '';\n\n    // Header row for matrix 0..N-1\n    const trHead = document.createElement('tr');\n    // Empty corner cell\n    trHead.appendChild(document.createElement('th'));\n    for(let c=0; c<N; c++) {\n      const th = document.createElement('th');\n      th.textContent = c;\n      th.setAttribute('scope', 'col');\n      trHead.appendChild(th);\n    }\n    matrixHead.appendChild(trHead);\n\n    // Rows\n    for(let r=0; r<N; r++) {\n      const tr = document.createElement('tr');\n      if(r === highlightRow) tr.classList.add('highlight');\n      const th = document.createElement('th');\n      th.textContent = r;\n      th.setAttribute('scope', 'row');\n      tr.appendChild(th);\n\n      for(let c=0; c<N; c++) {\n        const td = document.createElement('td');\n        let val = dist[r][c];\n        if(val === INF) {\n          td.textContent = \"∞\";\n        } else {\n          td.textContent = val;\n        }\n        tr.appendChild(td);\n      }\n\n      matrixBody.appendChild(tr);\n    }\n  }\n\n  // Highlight edges that are used/updated on step k\n  // We'll highlight edges that change based on Floyd-Warshall update step\n  // Floyd-Warshall: for all i,j: dist[i][j] = min(dist[i][j], dist[i][k] + dist[k][j])\n  // Each step fixes k and tries to improve all i,j using k as intermediary\n\n  // On each step k, show update animation for all i,j changed by using k\n\n  // We'll keep track of animations so they're smooth\n\n  // Clear all highlights from edges and nodes\n  function clearHighlights() {\n    edgeElements.forEach(el => {\n      el.classList.remove('highlighted');\n      el.style.transition = 'stroke 0.5s ease, stroke-width 0.5s ease';\n    });\n  }\n\n  // Animate edge highlight for edge i->j, then revert\n  // We'll chain all changes on the same step with small delay per updated cell\n  // Also highlight the row k (as intermediary) in matrix\n\n  // Keep array of updates for current step, each: {i, j, oldVal, newVal}\n  let currentStepUpdates = [];\n\n  function floydWarshallSteps() {\n    // Prepare list of all updates at k step\n    if (kStep >= N) return false;\n\n    currentStepUpdates = [];\n\n    const k = kStep;\n\n    for (let i=0; i<N; i++) {\n      for(let j=0; j<N; j++) {\n        if(dist[i][k] === INF || dist[k][j] === INF) continue;\n\n        let newDist = dist[i][k] + dist[k][j];\n        if(newDist < dist[i][j]) {\n          currentStepUpdates.push({ i, j, oldVal: dist[i][j], newVal: newDist });\n          dist[i][j] = newDist;\n        }\n      }\n    }\n    return true;\n  }\n\n  // Animate step with highlights & matrix update\n  // Highlights edges from i->k and k->j, and updates i->j distance cell in matrix\n\n  async function animateStep() {\n    if(kStep >= N) {\n      nextStepBtn.disabled = true;\n      return;\n    }\n\n    clearHighlights();\n\n    // Show highlight of k's row in matrix, k column in nodes maybe\n    renderMatrix(kStep);\n\n    if(kStep === -1) {\n      kStep++;\n      return;\n    }\n\n    const k = kStep;\n\n    // Prepare updates for this step\n    floydWarshallSteps();\n\n    if(currentStepUpdates.length === 0) {\n      // Nothing updated this step\n      highlightNode(k);\n      kStep++;\n      return;\n    }\n\n    // We'll animate each update with delay:\n\n    // Highlight node k strongly\n    highlightNode(k);\n\n    for(let u=0; u<currentStepUpdates.length; u++) {\n      const upd = currentStepUpdates[u];\n      const {i,j, oldVal, newVal} = upd;\n\n      clearHighlights();\n\n      // Edges: i->k and k->j\n      highlightEdge(i, k, true);\n      highlightEdge(k, j, true);\n\n      // Highlight updating edge (i->j) to show new path\n      highlightEdge(i, j, false, 300);\n\n      // Update matrix visually, highlight row i and column j\n      renderMatrix(i);\n\n      // Update the particular cell after short delay, fade in new value\n      // We'll do a subtle flicker effect on the updating cell\n\n      await delay(1000);\n    }\n\n    kStep++;\n    if(kStep >= N) nextStepBtn.disabled = true;\n  }\n\n  // Simple highlight edges by adding CSS class\n  // strong highlight: true = edges used directly to improve path\n  // fade highlight time (ms) optional on updated path edge\n  function highlightEdge(i,j,strong = true, fade = 0) {\n    for(const el of edgeElements) {\n      if(+el.dataset.from === i && +el.dataset.to === j) {\n        if(strong) {\n          el.classList.add('highlighted');\n          if(fade > 0) {\n            el.style.transition = `stroke 0.3s ease ${fade}ms, stroke-width 0.3s ease ${fade}ms`;\n          } else {\n            el.style.transition = 'stroke 0.45s ease, stroke-width 0.45s ease';\n          }\n        }\n      }\n    }\n  }\n\n  // Highlight a node by glowing border for current k\n  function highlightNode(k) {\n    nodes.forEach((n, idx) => {\n      if(idx === k) {\n        n.el.style.boxShadow = `\n          0 0 12px 3px #00ffc0cc,\n          inset 0 0 14px 5px #0fffeea7,\n          0 0 25px #05f7b9`;\n        n.el.style.transition = 'box-shadow 0.8s ease';\n      } else {\n        n.el.style.boxShadow = '';\n      }\n    });\n  }\n\n  // Reset visual state for start\n  function resetVisuals() {\n    clearHighlights();\n    nodes.forEach(n => n.el.style.boxShadow = '');\n    nextStepBtn.disabled = false;\n    kStep = 0;\n    initDist();\n    renderMatrix();\n  }\n\n  // Delay helper\n  function delay(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Initialize graph on page load\n  function init() {\n    createNodes();\n    createEdges();\n    initDist();\n    renderMatrix();\n    nextStepBtn.disabled = false;\n  }\n\n  // Attach events:\n  nextStepBtn.addEventListener('click', async () => {\n    nextStepBtn.disabled = true;\n    await animateStep();\n    if(kStep < N) nextStepBtn.disabled = false;\n  });\n\n  resetBtn.addEventListener('click', () => {\n    resetVisuals();\n  });\n\n  window.addEventListener('load', () => {\n    init();\n  });\n})();\n</script>\n</body>\n</html>"
  },
