  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>PageRank Interactive Demonstration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    white-space: pre-wrap;\n  }\n  button, input, select {\n    font-family: monospace, monospace;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 5px;\n  }\n  td, th {\n    border: 1px solid black;\n    padding: 3px 5px;\n    min-width: 25px;\n    text-align: center;\n  }\n  .small-input {\n    width: 3em;\n    font-size: 1em;\n  }\n  #graph-area, #pagerank-area, #workflow-area {\n    margin-top: 15px;\n  }\n</style>\n</head>\n<body>\n\n<h2>PageRank Interactive Demonstration</h2>\n\n<div id=\"instructions\">\nType nodes and edges, setup damping factor, customize iterations or convergence threshold, and run PageRank calculations interactively.<br/>\nMultiple workflows let you: build graph, view adjacency matrix, edit links, run steps or auto-converge, compare vectors, export/import. <br/>\nUse the controls below to explore deeply.\n</div>\n\n<hr />\n\n<div id=\"workflow-area\">\n<b>Workflow Mode:</b>\n<select id=\"workflow-select\" aria-label=\"Select workflow mode\">\n  <option value=\"build\">Graph Build & Edit</option>\n  <option value=\"matrix\">Adjacency & Transition Matrices</option>\n  <option value=\"pagerank-step\">Step-by-step PageRank</option>\n  <option value=\"pagerank-auto\">Auto PageRank Converge</option>\n  <option value=\"compare\">Compare Runs & Versions</option>\n  <option value=\"export-import\">Export / Import Graph & States</option>\n</select>\n<button id=\"workflow-reset-btn\">Reset Current Workflow</button>\n</div>\n\n<div id=\"build-workflow\" style=\"display:none;\">\n<h3>1. Graph Build & Edit</h3>\n\n<label for=\"node-count-input\">Number of Nodes (1 to 20): </label>\n<input type=\"number\" id=\"node-count-input\" min=\"1\" max=\"20\" value=\"5\" aria-label=\"Number of nodes\"/>\n<button id=\"build-nodes-btn\">Build Nodes</button>\n<p>Nodes will be labeled 1 to N.</p>\n\n<div id=\"links-editor\" style=\"margin-top:10px; max-height:200px; overflow:auto; border:1px solid black; padding:5px;\">\n <b>Edit Links:</b> (Check boxes to create links from row node to column node)\n <div style=\"overflow-x: auto;\">\n  <table id=\"links-table\" aria-label=\"Links editor table\">\n  </table>\n </div>\n</div>\n<button id=\"save-links-btn\">Save Links</button>\n<p><i>Note: Self-links allowed, but can be toggled on/off by user.</i></p>\n\n</div>\n\n<div id=\"matrix-workflow\" style=\"display:none;\">\n<h3>2. Adjacency & Transition Matrices</h3>\n<button id=\"show-adj-btn\">Show Adjacency Matrix</button>\n<button id=\"show-trans-btn\">Show Transition Matrix (Column stochastic)</button>\n<button id=\"show-linkinfo-btn\">Show Link Info</button>\n<div id=\"matrix-display\" style=\"margin-top:10px; max-height: 300px; overflow:auto; border:1px solid black; padding:5px; white-space: nowrap;\"></div>\n</div>\n\n<div id=\"pagerank-step-workflow\" style=\"display:none;\">\n<h3>3. Step-by-step PageRank</h3>\n<label for=\"damping-input-step\">Damping Factor (0.0 to 1.0): </label>\n<input type=\"number\" step=\"0.01\" min=\"0\" max=\"1\" id=\"damping-input-step\" value=\"0.85\" aria-label=\"Damping factor\"/>\n<br/>\n<label for=\"init-value-type\">Initial Vector: </label>\n<select id=\"init-value-type\" aria-label=\"Choose initial vector type\">\n  <option value=\"uniform\">Uniform (equal)</option>\n  <option value=\"random\">Random</option>\n  <option value=\"custom\">Custom</option>\n</select>\n<div id=\"custom-init-div\" style=\"display:none; margin-top:5px;\">\n  <label>Custom initial vector (comma-separated for each node): </label><br/>\n  <input type=\"text\" id=\"custom-init-input\" style=\"width: 90%;\" aria-label=\"Custom initial vector\"/>\n  <p><i>Sum need not be 1; vector will be normalized automatically.</i></p>\n</div>\n\n<button id=\"init-pagerank-btn\">Initialize PageRank Vector</button>\n\n<div id=\"pagerank-iteration-controls\" style=\"margin-top:10px; display:none;\">\n  <button id=\"step-btn\" aria-label=\"Perform one PageRank iteration\">Step</button>\n  <button id=\"run-steps-btn\" aria-label=\"Run multiple iterations\">Run N Steps</button>\n  <input type=\"number\" id=\"run-steps-count\" min=\"1\" max=\"1000\" value=\"10\" class=\"small-input\" aria-label=\"Number of steps to run\"/>\n  <button id=\"reset-pagerank-btn\" aria-label=\"Reset PageRank iteration\">Reset</button>\n  <button id=\"show-prev-rank-btn\" aria-label=\"Show previous PageRank vector\">Previous Vector</button>\n  <button id=\"show-current-rank-btn\" aria-label=\"Show current PageRank vector\">Current Vector</button>\n  <button id=\"show-diff-rank-btn\" aria-label=\"Show difference vector\">Difference Vector</button>\n</div>\n\n<div id=\"pagerank-output\" style=\"margin-top:10px; white-space:pre;\"></div>\n</div>\n\n<div id=\"pagerank-auto-workflow\" style=\"display:none;\">\n<h3>4. Auto PageRank Converge</h3>\n<label for=\"damping-input-auto\">Damping Factor (0.0 to 1.0): </label>\n<input type=\"number\" step=\"0.01\" min=\"0\" max=\"1\" id=\"damping-input-auto\" value=\"0.85\" aria-label=\"Damping factor for auto\"/>\n<br/>\n<label for=\"convergence-epsilon\">Convergence Threshold ε (e.g. 0.0001): </label>\n<input type=\"number\" step=\"0.00001\" min=\"0\" max=\"1\" id=\"convergence-epsilon\" value=\"0.0001\" aria-label=\"Convergence threshold\"/>\n<br/>\n<button id=\"init-pagerank-auto-btn\">Initialize</button>\n<button id=\"run-pagerank-auto-btn\" disabled>Run Until Converged</button>\n<button id=\"stop-pagerank-auto-btn\" disabled>Stop</button>\n<button id=\"show-current-rank-auto-btn\" disabled>Show Current Vector</button>\n<button id=\"show-steps-auto-btn\" disabled>Show Iterations Count</button>\n\n<div id=\"pagerank-auto-output\" style=\"margin-top:10px; white-space:pre;\"></div>\n</div>\n\n<div id=\"compare-workflow\" style=\"display:none;\">\n<h3>5. Compare Runs & Versions</h3>\n<p>Save and name vectors from any PageRank run here, then compare differences or rankings.</p>\n\n<label for=\"compare-save-name\">Save Current Vector As: </label>\n<input type=\"text\" id=\"compare-save-name\" aria-label=\"Name to save current PageRank vector\" />\n<button id=\"compare-save-btn\">Save Vector</button>\n\n<div id=\"compare-list\" style=\"margin-top:10px; max-height: 150px; overflow-y: auto; border:1px solid black; padding:5px;\">\n <b>Saved Vectors:</b>\n <ul id=\"compare-saved-list\"></ul>\n</div>\n\n<label for=\"compare-select-1\">Vector 1: </label>\n<select id=\"compare-select-1\" aria-label=\"Select first vector for comparison\"></select>\n<label for=\"compare-select-2\"> Vector 2: </label>\n<select id=\"compare-select-2\" aria-label=\"Select second vector for comparison\"></select>\n<button id=\"compare-diff-btn\">Show Differences (L1 norm & per node)</button>\n<button id=\"compare-rankdiff-btn\">Show Ranking Differences</button>\n\n<div id=\"compare-output\" style=\"margin-top:10px; white-space:pre;\"></div>\n</div>\n\n<div id=\"export-import-workflow\" style=\"display:none;\">\n<h3>6. Export / Import Graph & States</h3>\n<p>Export graph and saved vectors to JSON; import to restore.</p>\n\n<button id=\"export-btn\">Export Current Graph & Saved Vectors</button><br/>\n\n<textarea id=\"export-textarea\" style=\"width:100%; height:100px; margin-top:5px;\" aria-label=\"Exported JSON data\"></textarea><br/>\n\n<label for=\"import-textarea\">Paste JSON to Import:</label><br/>\n<textarea id=\"import-textarea\" style=\"width:100%; height:100px;\" aria-label=\"JSON data to import\"></textarea><br/>\n<button id=\"import-btn\">Import Data</button>\n<div id=\"import-msg\" style=\"color:red; margin-top:5px;\"></div>\n</div>\n\n<hr />\n\n<div id=\"status\" aria-live=\"polite\" style=\"height: 3em; overflow-y: auto;\"></div>\n\n<script>\n(function () {\n  // INTERNAL STATE\n  let nodesCount = 5;\n  let adjacencyMatrix = []; // adjacencyMatrix[src][dst] = 0 or 1\n  let selfLinksAllowed = true;\n  // Cached transition matrix (column stochastic)\n  let transitionMatrix = null;\n\n  // PageRank iteration state\n  let prVectorCurrent = null;\n  let prVectorPrevious = null;\n  let dampingFactor = 0.85;\n  let iterationCount = 0;\n\n  // Auto PageRank states\n  let autoRunning = false;\n  let autoIntervalId = null;\n  let convergenceEpsilon = 0.0001;\n\n  // Saved vectors for comparison\n  let savedVectors = {};\n\n  /* HELPERS */\n  function logStatus(msg) {\n    let statusEl = document.getElementById(\"status\");\n    statusEl.textContent = msg;\n  }\n\n  function createEmptyAdjacency(n) {\n    let m = [];\n    for(let i=0; i<n; i++) {\n      let row = [];\n      for(let j=0; j<n; j++) {\n        row.push(0);\n      }\n      m.push(row);\n    }\n    return m;\n  }\n\n  function normalizeVector(v) {\n    let sum = v.reduce((a,b)=>a+b,0);\n    if(sum === 0) return v.map(()=>1/v.length);\n    return v.map(x => x/sum);\n  }\n\n  function vectorDiffL1(v1, v2) {\n    if(!v1 || !v2 || v1.length!==v2.length) return null;\n    let diff = 0;\n    for(let i=0;i<v1.length;i++) {\n      diff += Math.abs(v1[i]-v2[i]);\n    }\n    return diff;\n  }\n  // Return vector of absolute differences\n  function vectorDiffVector(v1,v2){\n    if(!v1 || !v2 || v1.length!==v2.length) return null;\n    let diffv = [];\n    for(let i=0;i<v1.length;i++){\n      diffv.push(Math.abs(v1[i]-v2[i]));\n    }\n    return diffv;\n  }\n\n  // Compute PageRank iteration once\n  // prNext = damping*(M * prCurrent) + (1-damping)/N\n  // M is transition matrix (column stochastic)\n  // prCurrent and prNext are arrays of length N\n  function pagerankIteration(prCurrent, transition, damping){\n    let n = prCurrent.length;\n    let prNext = new Array(n).fill((1-damping)/n);\n    for(let i=0; i<n; i++){\n      for(let j=0; j<n; j++){\n        prNext[i] += damping * transition[i][j] * prCurrent[j];\n      }\n    }\n    return prNext;\n  }\n\n  // Build transition matrix (column stochastic) from adjacency matrix:\n  // For each column: if links out > 0, normalize; else treat as dangling -> equal links to all\n  // transitionMatrix[to][from]\n  function buildTransitionMatrix(adj, n){\n    let trans = [];\n    for(let i=0; i<n; i++){\n      trans.push(new Array(n).fill(0));\n    }\n    for(let j=0; j<n; j++){\n      let outlinks = 0;\n      for(let i=0; i<n; i++){\n        outlinks += adj[j][i];\n      }\n      if(outlinks===0){\n        // Dangling node: distribute uniformly to all nodes\n        for(let i=0; i<n; i++){\n          trans[i][j] = 1/n;\n        }\n      } else {\n        for(let i=0; i<n; i++){\n          trans[i][j] = adj[j][i] / outlinks;\n        }\n      }\n    }\n    return trans;\n  }\n\n  // Formats a vector with 4 decimals\n  function formatVector(v){\n    if(!v) return \"\";\n    return v.map(x => x.toFixed(4)).join(\", \");\n  }\n\n  // Ranking = indices sorted by descending values\n  // Returns array of [nodeIndex, value]\n  function rankVectorWithIndex(v){\n    if(!v) return [];\n    let arr = v.map((val,i)=>[i,val]);\n    arr.sort((a,b) => b[1] - a[1]); // Descending\n    return arr;\n  }\n\n  // Build links table for editing adjacency\n  function buildLinksTable(){\n    let container = document.getElementById(\"links-table\");\n    container.innerHTML = \"\";\n\n    // Header row\n    let thead = document.createElement(\"thead\");\n    let tr = document.createElement(\"tr\");\n    tr.appendChild(document.createElement(\"th\")); // Blank corner cell\n    for(let c=0; c<nodesCount; c++){\n      let th = document.createElement(\"th\");\n      th.textContent = (c+1);\n      tr.appendChild(th);\n    }\n    thead.appendChild(tr);\n    container.appendChild(thead);\n\n    // Body rows\n    let tbody = document.createElement(\"tbody\");\n    for(let r=0; r < nodesCount; r++){\n      let tr = document.createElement(\"tr\");\n      let rowHeader = document.createElement(\"th\");\n      rowHeader.textContent = (r+1);\n      tr.appendChild(rowHeader);\n      for(let c=0; c < nodesCount; c++){\n        let td = document.createElement(\"td\");\n        let checkbox = document.createElement(\"input\");\n        checkbox.type = \"checkbox\";\n        checkbox.dataset.src = r;\n        checkbox.dataset.dst = c;\n        checkbox.id = `link-checkbox-${r}-${c}`;\n        if(adjacencyMatrix[r][c] === 1) checkbox.checked = true;\n        if(!selfLinksAllowed && r === c){\n          checkbox.checked = false;\n          checkbox.disabled = true;\n        }\n        td.appendChild(checkbox);\n        tr.appendChild(td);\n      }\n      tbody.appendChild(tr);\n    }\n    container.appendChild(tbody);\n  }\n\n  // Initialize adjacency matrix with current node count\n  function initializeAdjacencyMatrix(){\n    adjacencyMatrix = createEmptyAdjacency(nodesCount);\n    for(let i=0; i<nodesCount; i++){\n      adjacencyMatrix[i][i] = selfLinksAllowed ? 1 : 0;\n    }\n  }\n\n  // Save links from checkboxes back into adjacencyMatrix\n  function saveLinksFromUI(){\n    for(let r=0; r<nodesCount; r++){\n      for(let c=0; c<nodesCount; c++){\n        let cb = document.getElementById(`link-checkbox-${r}-${c}`);\n        adjacencyMatrix[r][c] = cb.checked ? 1 : 0;\n      }\n    }\n    transitionMatrix = buildTransitionMatrix(adjacencyMatrix, nodesCount);\n    logStatus(`Links saved. Graph with ${nodesCount} nodes updated.`);\n  }\n\n  // Display adjacency matrix nicely\n  function displayMatrix(matrix){\n    if(!matrix) return \"No matrix to display.\";\n    let n = matrix.length;\n    let lines = [];\n\n    // header\n    let hdr = [\" \"].concat([...Array(n).keys()].map(i=>i+1));\n    lines.push(hdr.join(\"  \"));\n    for(let r=0; r<n; r++){\n      let row = [r+1];\n      for(let c=0; c<n; c++){\n        let val = matrix[r][c];\n        if(typeof val === \"number\") val = val.toFixed ? val.toFixed(4) : val;\n        row.push(val);\n      }\n      lines.push(row.join(\"  \"));\n    }\n    return lines.join(\"\\n\");\n  }\n\n  // Show link info summary\n  function showLinkInfo(){\n    let n = nodesCount;\n    let lines = [];\n    lines.push(`Graph with ${n} nodes:`);\n    for(let i=0; i<n; i++){\n      let outLinks = 0;\n      let inLinks = 0;\n      for(let j=0; j<n; j++){\n        outLinks += adjacencyMatrix[i][j];\n        inLinks += adjacencyMatrix[j][i];\n      }\n      lines.push(`Node ${i+1}: Outlinks = ${outLinks}, Inlinks = ${inLinks}`);\n    }\n    return lines.join(\"\\n\");\n  }\n\n  // Initialize PageRank vector according to selected init type\n  function initializePageRankVector(type, customStr){\n    let v = new Array(nodesCount);\n    if(type === \"uniform\"){\n      for(let i=0; i<nodesCount; i++) v[i] = 1/nodesCount;\n    }\n    else if(type === \"random\"){\n      for(let i=0; i<nodesCount; i++) v[i] = Math.random();\n      v = normalizeVector(v);\n    }\n    else if(type === \"custom\"){\n      let parts = customStr.split(\",\").map(x => parseFloat(x.trim()));\n      if(parts.length !== nodesCount) return null;\n      for(let i=0; i<nodesCount; i++){\n        if(isNaN(parts[i])) return null;\n      }\n      v = normalizeVector(parts);\n    } else {\n      v = new Array(nodesCount).fill(1/nodesCount);\n    }\n    return v;\n  }\n\n  // Updates UI visibility based on selected workflow\n  function updateWorkflowVisibility(){\n    let wf = document.getElementById(\"workflow-select\").value;\n    const workflows = [\"build\",\"matrix\",\"pagerank-step\",\"pagerank-auto\",\"compare\",\"export-import\"];\n    workflows.forEach(w=>{\n      let el = document.getElementById(`${w}-workflow`);\n      if(el) el.style.display = (w === wf) ? \"block\" : \"none\";\n    });\n\n    // Clear status and outputs on workflow switch\n    document.getElementById(\"status\").textContent = \"\";\n    if(wf !== \"pagerank-step\"){\n      prVectorCurrent = null;\n      prVectorPrevious = null;\n      iterationCount = 0;\n      document.getElementById(\"pagerank-output\").textContent = \"\";\n      document.getElementById(\"pagerank-iteration-controls\").style.display = \"none\";\n    }\n    if(wf !== \"pagerank-auto\"){\n      autoRunning = false;\n      if(autoIntervalId) clearInterval(autoIntervalId);\n      autoIntervalId = null;\n      document.getElementById(\"pagerank-auto-output\").textContent = \"\";\n      document.getElementById(\"run-pagerank-auto-btn\").disabled = true;\n      document.getElementById(\"stop-pagerank-auto-btn\").disabled = true;\n      document.getElementById(\"show-current-rank-auto-btn\").disabled = true;\n      document.getElementById(\"show-steps-auto-btn\").disabled = true;\n    }\n    if(wf !== \"compare\"){\n      document.getElementById(\"compare-output\").textContent = \"\";\n    }\n  }\n\n  // Render saved vectors list UI and selects\n  function refreshSavedVectorsList(){\n    let list = document.getElementById(\"compare-saved-list\");\n    list.innerHTML = \"\";\n    let sel1 = document.getElementById(\"compare-select-1\");\n    let sel2 = document.getElementById(\"compare-select-2\");\n    sel1.innerHTML = \"\";\n    sel2.innerHTML = \"\";\n    let keys = Object.keys(savedVectors);\n    if(keys.length===0){\n      list.textContent = \"(No saved vectors)\";\n    } else {\n      for(let name of keys){\n        let li = document.createElement(\"li\");\n        li.textContent = `${name} [${savedVectors[name].length} elements]`;\n        list.appendChild(li);\n\n        let option1 = document.createElement(\"option\");\n        option1.value = name;\n        option1.textContent = name;\n        sel1.appendChild(option1);\n\n        let option2 = document.createElement(\"option\");\n        option2.value = name;\n        option2.textContent = name;\n        sel2.appendChild(option2);\n      }\n    }\n  }\n\n  // Show vector in output div (with node indices)\n  function showVectorOutput(containerId, vector){\n    let container = document.getElementById(containerId);\n    if(!vector){\n      container.textContent = \"(No vector)\";\n      return;\n    }\n    let lines = vector.map((val,i)=>`Node ${i+1}: ${val.toFixed(6)}`);\n    container.textContent = lines.join(\"\\n\");\n  }\n\n  /* EVENT SETUP */\n\n  // Workflow selector\n  document.getElementById(\"workflow-select\").addEventListener(\"change\", e=>{\n    updateWorkflowVisibility();\n  });\n\n  // Workflow reset button resets current workflow states minimally\n  document.getElementById(\"workflow-reset-btn\").addEventListener(\"click\", e=>{\n    let wf = document.getElementById(\"workflow-select\").value;\n    if(wf === \"build\"){\n      nodesCount = 5;\n      selfLinksAllowed = true;\n      initializeAdjacencyMatrix();\n      buildLinksTable();\n      logStatus(\"Graph reset to 5 nodes with self-links.\");\n    } else if(wf === \"matrix\"){\n      logStatus(\"No state to reset in matrix workflow.\");\n    } else if(wf === \"pagerank-step\"){\n      prVectorCurrent = null;\n      prVectorPrevious = null;\n      iterationCount = 0;\n      document.getElementById(\"pagerank-output\").textContent = \"\";\n      document.getElementById(\"pagerank-iteration-controls\").style.display = \"none\";\n      logStatus(\"PageRank step-by-step reset.\");\n    } else if(wf === \"pagerank-auto\"){\n      autoRunning = false;\n      if(autoIntervalId) clearInterval(autoIntervalId);\n      autoIntervalId = null;\n      document.getElementById(\"pagerank-auto-output\").textContent = \"\";\n      document.getElementById(\"run-pagerank-auto-btn\").disabled = true;\n      document.getElementById(\"stop-pagerank-auto-btn\").disabled = true;\n      document.getElementById(\"show-current-rank-auto-btn\").disabled = true;\n      document.getElementById(\"show-steps-auto-btn\").disabled = true;\n      logStatus(\"Auto PageRank reset.\");\n    } else if(wf === \"compare\"){\n      savedVectors = {};\n      refreshSavedVectorsList();\n      document.getElementById(\"compare-output\").textContent = \"\";\n      logStatus(\"Saved vectors cleared.\");\n    } else if(wf === \"export-import\"){\n      document.getElementById(\"export-textarea\").value = \"\";\n      document.getElementById(\"import-textarea\").value = \"\";\n      document.getElementById(\"import-msg\").textContent = \"\";\n      logStatus(\"Export/Import cleared.\");\n    }\n  });\n\n  // Build nodes button - creates adjacency matrix and links table\n  document.getElementById(\"build-nodes-btn\").addEventListener(\"click\", e=>{\n    let cnt = parseInt(document.getElementById(\"node-count-input\").value);\n    if(isNaN(cnt) || cnt < 1 || cnt > 20){\n      alert(\"Node count must be an integer between 1 and 20.\");\n      return;\n    }\n    nodesCount = cnt;\n    initializeAdjacencyMatrix();\n    buildLinksTable();\n    transitionMatrix = buildTransitionMatrix(adjacencyMatrix, nodesCount);\n    logStatus(`Built graph with ${nodesCount} nodes and default self-links.`);\n  });\n\n  // Save links button saves all checkboxes state into adjacency matrix and rebuilds transition matrix\n  document.getElementById(\"save-links-btn\").addEventListener(\"click\", e=>{\n    saveLinksFromUI();\n  });\n\n  // Show adjacency matrix button\n  document.getElementById(\"show-adj-btn\").addEventListener(\"click\", e=>{\n    if(!adjacencyMatrix) {\n      logStatus(\"No adjacency matrix to show.\");\n      return;\n    }\n    document.getElementById(\"matrix-display\").textContent = displayMatrix(adjacencyMatrix);\n    logStatus(\"Adjacency matrix displayed.\");\n  });\n\n  // Show transition matrix button\n  document.getElementById(\"show-trans-btn\").addEventListener(\"click\", e=>{\n    if(!transitionMatrix){\n      logStatus(\"No transition matrix. Save links first.\");\n      return;\n    }\n    document.getElementById(\"matrix-display\").textContent = displayMatrix(transitionMatrix);\n    logStatus(\"Transition matrix (column stochastic) displayed.\");\n  });\n\n  // Show link info button\n  document.getElementById(\"show-linkinfo-btn\").addEventListener(\"click\", e=>{\n    let lines = showLinkInfo();\n    document.getElementById(\"matrix-display\").textContent = lines;\n    logStatus(\"Link info displayed.\");\n  });\n\n  // For step-by-step PageRank: sync show/hide custom init vector input\n  document.getElementById(\"init-value-type\").addEventListener(\"change\", e=>{\n    let val = e.target.value;\n    let customDiv = document.getElementById(\"custom-init-div\");\n    if(val === \"custom\"){\n      customDiv.style.display = \"block\";\n    } else {\n      customDiv.style.display = \"none\";\n    }\n  });\n\n  // Init PageRank vector (step)\n  document.getElementById(\"init-pagerank-btn\").addEventListener(\"click\", e=>{\n    if(!adjacencyMatrix){\n      alert(\"No graph constructed. Build graph first.\");\n      return;\n    }\n    let d = parseFloat(document.getElementById(\"damping-input-step\").value);\n    if(isNaN(d) || d<0 || d>1){\n      alert(\"Damping factor must be between 0 and 1.\");\n      return;\n    }\n    dampingFactor = d;\n\n    let initType = document.getElementById(\"init-value-type\").value;\n    let customVecStr = document.getElementById(\"custom-init-input\").value;\n\n    let v = initializePageRankVector(initType, customVecStr);\n    if(v === null){\n      alert(\"Invalid custom initial vector. Check values and length.\");\n      return;\n    }\n    prVectorCurrent = v;\n    prVectorPrevious = null;\n    iterationCount = 0;\n    transitionMatrix = buildTransitionMatrix(adjacencyMatrix, nodesCount);\n\n    document.getElementById(\"pagerank-iteration-controls\").style.display = \"block\";\n    showVectorOutput(\"pagerank-output\", prVectorCurrent);\n    logStatus(`PageRank vector initialized (damping=${d}). Ready to step.`);\n  });\n\n  // Step button (one iteration)\n  document.getElementById(\"step-btn\").addEventListener(\"click\", e=>{\n    if(!prVectorCurrent){\n      alert(\"Initialize PageRank vector first.\");\n      return;\n    }\n    prVectorPrevious = prVectorCurrent;\n    prVectorCurrent = pagerankIteration(prVectorCurrent, transitionMatrix, dampingFactor);\n    iterationCount++;\n    showVectorOutput(\"pagerank-output\", prVectorCurrent);\n    logStatus(`Iteration ${iterationCount} completed.`);\n  });\n\n  // Run N steps button\n  document.getElementById(\"run-steps-btn\").addEventListener(\"click\", e=>{\n    if(!prVectorCurrent){\n      alert(\"Initialize PageRank vector first.\");\n      return;\n    }\n    let steps = parseInt(document.getElementById(\"run-steps-count\").value);\n    if(isNaN(steps) || steps < 1 || steps > 1000){\n      alert(\"Enter a valid number of steps (1-1000).\");\n      return;\n    }\n    for(let i=0; i<steps; i++){\n      prVectorPrevious = prVectorCurrent;\n      prVectorCurrent = pagerankIteration(prVectorCurrent, transitionMatrix, dampingFactor);\n      iterationCount++;\n    }\n    showVectorOutput(\"pagerank-output\", prVectorCurrent);\n    logStatus(`Ran ${steps} iterations, now at iteration ${iterationCount}.`);\n  });\n\n  // Reset PageRank button\n  document.getElementById(\"reset-pagerank-btn\").addEventListener(\"click\", e=>{\n    prVectorCurrent = null;\n    prVectorPrevious = null;\n    document.getElementById(\"pagerank-output\").textContent = \"\";\n    document.getElementById(\"pagerank-iteration-controls\").style.display = \"none\";\n    iterationCount = 0;\n    logStatus(\"PageRank iteration reset.\");\n  });\n\n  // Show previous vector button\n  document.getElementById(\"show-prev-rank-btn\").addEventListener(\"click\", e=>{\n    if(!prVectorPrevious){\n      alert(\"No previous vector to show.\");\n      return;\n    }\n    showVectorOutput(\"pagerank-output\", prVectorPrevious);\n    logStatus(\"Previous PageRank vector displayed.\");\n  });\n\n  // Show current vector button\n  document.getElementById(\"show-current-rank-btn\").addEventListener(\"click\", e=>{\n    if(!prVectorCurrent){\n      alert(\"No current vector to show.\");\n      return;\n    }\n    showVectorOutput(\"pagerank-output\", prVectorCurrent);\n    logStatus(\"Current PageRank vector displayed.\");\n  });\n\n  // Show difference vector button\n  document.getElementById(\"show-diff-rank-btn\").addEventListener(\"click\", e=>{\n    if(!prVectorCurrent || !prVectorPrevious){\n      alert(\"Both current and previous vectors are needed for difference.\");\n      return;\n    }\n    let diffv = vectorDiffVector(prVectorCurrent, prVectorPrevious);\n    showVectorOutput(\"pagerank-output\", diffv);\n    logStatus(\"Difference vector displayed (abs(current - previous)).\");\n  });\n\n  // Auto PageRank workflow: initialize\n  document.getElementById(\"init-pagerank-auto-btn\").addEventListener(\"click\", e=>{\n    if(!adjacencyMatrix){\n      alert(\"Build graph first.\");\n      return;\n    }\n    let d = parseFloat(document.getElementById(\"damping-input-auto\").value);\n    if(isNaN(d) || d<0 || d>1){\n      alert(\"Damping factor must be between 0 and 1.\");\n      return;\n    }\n    dampingFactor = d;\n    convergenceEpsilon = parseFloat(document.getElementById(\"convergence-epsilon\").value);\n    if(isNaN(convergenceEpsilon) || convergenceEpsilon<=0){\n      alert(\"Convergence epsilon must be a positive number.\");\n      return;\n    }\n\n    prVectorCurrent = new Array(nodesCount).fill(1/nodesCount);\n    prVectorPrevious = null;\n    iterationCount = 0;\n    transitionMatrix = buildTransitionMatrix(adjacencyMatrix, nodesCount);\n\n    document.getElementById(\"run-pagerank-auto-btn\").disabled = false;\n    document.getElementById(\"stop-pagerank-auto-btn\").disabled = true;\n    document.getElementById(\"show-current-rank-auto-btn\").disabled = false;\n    document.getElementById(\"show-steps-auto-btn\").disabled = false;\n    document.getElementById(\"pagerank-auto-output\").textContent = \"Initialized PageRank vector.\";\n    logStatus(`Auto PageRank initialized with damping=${d} and ε=${convergenceEpsilon}.`);\n  });\n\n  // Run until convergence (Auto PageRank)\n  document.getElementById(\"run-pagerank-auto-btn\").addEventListener(\"click\", e=>{\n    if(autoRunning) return;\n    if(!prVectorCurrent){\n      alert(\"Initialize first.\");\n      return;\n    }\n    autoRunning = true;\n    document.getElementById(\"run-pagerank-auto-btn\").disabled = true;\n    document.getElementById(\"stop-pagerank-auto-btn\").disabled = false;\n    logStatus(\"Auto PageRank running...\");\n\n    function stepAuto(){\n      prVectorPrevious = prVectorCurrent;\n      prVectorCurrent = pagerankIteration(prVectorCurrent, transitionMatrix, dampingFactor);\n      iterationCount++;\n      let diff = vectorDiffL1(prVectorCurrent, prVectorPrevious);\n      document.getElementById(\"pagerank-auto-output\").textContent = `Iteration ${iterationCount}\\nL1 diff: ${diff.toExponential(4)}`;\n      if(diff < convergenceEpsilon){\n        logStatus(`Converged after ${iterationCount} iterations. L1 diff = ${diff.toExponential(4)}`);\n        clearInterval(autoIntervalId);\n        autoIntervalId = null;\n        autoRunning = false;\n        document.getElementById(\"run-pagerank-auto-btn\").disabled = false;\n        document.getElementById(\"stop-pagerank-auto-btn\").disabled = true;\n      }\n    }\n    stepAuto();\n    autoIntervalId = setInterval(()=>{\n      if(autoRunning) stepAuto();\n      else {\n        clearInterval(autoIntervalId);\n        autoIntervalId = null;\n      }\n    }, 100);\n  });\n\n  // Stop auto PageRank run\n  document.getElementById(\"stop-pagerank-auto-btn\").addEventListener(\"click\", e=>{\n    if(autoIntervalId){\n      clearInterval(autoIntervalId);\n      autoIntervalId = null;\n    }\n    autoRunning = false;\n    document.getElementById(\"run-pagerank-auto-btn\").disabled = false;\n    document.getElementById(\"stop-pagerank-auto-btn\").disabled = true;\n    logStatus(\"Auto PageRank run stopped by user.\");\n  });\n\n  // Show current vector auto\n  document.getElementById(\"show-current-rank-auto-btn\").addEventListener(\"click\", e=>{\n    if(!prVectorCurrent){\n      alert(\"No vector initialized.\");\n      return;\n    }\n    let lines = prVectorCurrent.map((v,i)=>`Node ${i+1}: ${v.toFixed(6)}`);\n    document.getElementById(\"pagerank-auto-output\").textContent = lines.join(\"\\n\");\n    logStatus(\"Current PageRank vector displayed.\");\n  });\n\n  // Show iterations count auto\n  document.getElementById(\"show-steps-auto-btn\").addEventListener(\"click\", e=>{\n    document.getElementById(\"pagerank-auto-output\").textContent = `Iterations run: ${iterationCount}`;\n    logStatus(\"Current iteration count displayed.\");\n  });\n\n  // Compare workflow: Save vector button\n  document.getElementById(\"compare-save-btn\").addEventListener(\"click\", e=>{\n    let name = document.getElementById(\"compare-save-name\").value.trim();\n    if(name.length === 0){\n      alert(\"Enter a name to save the vector.\");\n      return;\n    }\n    if(!prVectorCurrent){\n      alert(\"No PageRank vector available to save.\");\n      return;\n    }\n    if(savedVectors[name]){\n      if(!confirm(`Overwrite existing saved vector \"${name}\"?`)){\n        return;\n      }\n    }\n    savedVectors[name] = prVectorCurrent.slice();\n    refreshSavedVectorsList();\n    document.getElementById(\"compare-save-name\").value = \"\";\n    logStatus(`Vector saved as \"${name}\".`);\n  });\n\n  // Compare: Show differences (L1 + per node)\n  document.getElementById(\"compare-diff-btn\").addEventListener(\"click\", e=>{\n    let v1name = document.getElementById(\"compare-select-1\").value;\n    let v2name = document.getElementById(\"compare-select-2\").value;\n    if(!v1name || !v2name){\n      alert(\"Select two vectors to compare.\");\n      return;\n    }\n    if(v1name === v2name){\n      alert(\"Select two different vectors.\");\n      return;\n    }\n    let v1 = savedVectors[v1name];\n    let v2 = savedVectors[v2name];\n    if(!v1 || !v2 || v1.length !== v2.length){\n      alert(\"Vectors incompatible or not found.\");\n      return;\n    }\n    let l1 = vectorDiffL1(v1,v2);\n    let diffVec = vectorDiffVector(v1,v2);\n    let lines = [`L1 difference between \"${v1name}\" and \"${v2name}\": ${l1.toFixed(6)}`];\n    lines.push(\"Per node absolute differences:\");\n    for(let i=0; i<diffVec.length; i++){\n      lines.push(`Node ${i+1}: ${diffVec[i].toFixed(6)}`);\n    }\n    document.getElementById(\"compare-output\").textContent = lines.join(\"\\n\");\n    logStatus(\"Displayed vector differences.\");\n  });\n\n  // Compare: Show ranking differences\n  document.getElementById(\"compare-rankdiff-btn\").addEventListener(\"click\", e=>{\n    let v1name = document.getElementById(\"compare-select-1\").value;\n    let v2name = document.getElementById(\"compare-select-2\").value;\n    if(!v1name || !v2name){\n      alert(\"Select two vectors to compare.\");\n      return;\n    }\n    if(v1name === v2name){\n      alert(\"Select two different vectors.\");\n      return;\n    }\n    let v1 = savedVectors[v1name];\n    let v2 = savedVectors[v2name];\n    if(!v1 || !v2 || v1.length !== v2.length){\n      alert(\"Vectors incompatible or not found.\");\n      return;\n    }\n    // Rankings: sorted by descending values\n    let rank1 = rankVectorWithIndex(v1);\n    let rank2 = rankVectorWithIndex(v2);\n    let pos1 = new Array(v1.length);\n    let pos2 = new Array(v2.length);\n    // pos1[node] = rank position (0-based)\n    for(let i=0; i<rank1.length; i++){\n      pos1[rank1[i][0]] = i;\n      pos2[rank2[i][0]] = i;\n    }\n    let lines = [`Ranking differences between \"${v1name}\" and \"${v2name}\":`];\n    lines.push(\"Node\\tRank in V1\\tRank in V2\\tRank Difference\");\n    for(let i=0; i<v1.length; i++){\n      let diffRank = Math.abs(pos1[i] - pos2[i]);\n      lines.push(`${i+1}\\t${pos1[i]+1}\\t\\t${pos2[i]+1}\\t\\t${diffRank}`);\n    }\n    document.getElementById(\"compare-output\").textContent = lines.join(\"\\n\");\n    logStatus(\"Displayed ranking differences.\");\n  });\n\n  // Export button\n  document.getElementById(\"export-btn\").addEventListener(\"click\", e=>{\n    if(!adjacencyMatrix){\n      alert(\"Graph not built yet.\");\n      return;\n    }\n    let exportObj = {\n      nodesCount: nodesCount,\n      adjacencyMatrix: adjacencyMatrix,\n      selfLinksAllowed: selfLinksAllowed,\n      savedVectors: savedVectors\n    };\n    document.getElementById(\"export-textarea\").value = JSON.stringify(exportObj, null, 2);\n    logStatus(\"Exported current graph and saved vectors as JSON.\");\n  });\n\n  // Import button\n  document.getElementById(\"import-btn\").addEventListener(\"click\", e=>{\n    let text = document.getElementById(\"import-textarea\").value.trim();\n    if(text.length === 0){\n      alert(\"Paste JSON data to import.\");\n      return;\n    }\n    let obj = null;\n    try {\n      obj = JSON.parse(text);\n    } catch(ex) {\n      document.getElementById(\"import-msg\").textContent = \"Invalid JSON: \" + ex.message;\n      logStatus(\"Failed JSON import.\");\n      return;\n    }\n    if(!obj.nodesCount || !obj.adjacencyMatrix){\n      document.getElementById(\"import-msg\").textContent = \"JSON missing mandatory fields.\";\n      logStatus(\"Import JSON missing fields.\");\n      return;\n    }\n    nodesCount = obj.nodesCount;\n    adjacencyMatrix = obj.adjacencyMatrix;\n    selfLinksAllowed = !!obj.selfLinksAllowed;\n\n    transitionMatrix = buildTransitionMatrix(adjacencyMatrix, nodesCount);\n\n    // Rebuild UI for build workflow links\n    document.getElementById(\"node-count-input\").value = nodesCount;\n    buildLinksTable();\n\n    // Restore saved vectors\n    savedVectors = {};\n    if(obj.savedVectors && typeof obj.savedVectors === 'object'){\n      for(let k in obj.savedVectors){\n        if(Array.isArray(obj.savedVectors[k]) && obj.savedVectors[k].length === nodesCount){\n          savedVectors[k] = obj.savedVectors[k].slice();\n        }\n      }\n    }\n    refreshSavedVectorsList();\n    document.getElementById(\"import-msg\").textContent = \"Import successful.\";\n    logStatus(\"Import completed: Graph and saved vectors restored.\");\n  });\n\n  /* INIT */\n  // Initialize default graph on load\n  nodesCount = 5;\n  selfLinksAllowed = true;\n  initializeAdjacencyMatrix();\n  buildLinksTable();\n  transitionMatrix = buildTransitionMatrix(adjacencyMatrix, nodesCount);\n  updateWorkflowVisibility();\n  refreshSavedVectorsList();\n  logStatus(\"Ready. Build your graph and start exploring PageRank.\");\n})();\n</script>\n\n</body>\n</html>"
