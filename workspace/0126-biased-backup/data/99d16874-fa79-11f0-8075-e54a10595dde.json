    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Digital Signature Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        input, button, textarea {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h2>Digital Signature Demo</h2>\n\n<h3>1. Document Input</h3>\n<textarea id=\"documentInput\" rows=\"4\" cols=\"50\" placeholder=\"Type your document here...\"></textarea><br>\n<button onclick=\"loadDocument()\">Load Document</button>\n\n<h3>2. Signature Key Generation</h3>\n<button onclick=\"generateKeys()\">Generate Key Pair</button>\n<div>\n    <h4>Public Key:</h4>\n    <textarea id=\"publicKey\" rows=\"2\" cols=\"50\" readonly></textarea>\n    \n    <h4>Private Key:</h4>\n    <textarea id=\"privateKey\" rows=\"2\" cols=\"50\" readonly></textarea>\n</div>\n\n<h3>3. Sign Document</h3>\n<button onclick=\"signDocument()\">Sign Document</button>\n<h4>Signature:</h4>\n<textarea id=\"signature\" rows=\"2\" cols=\"50\" readonly></textarea>\n\n<h3>4. Verify Signature</h3>\n<input type=\"text\" id=\"signatureInput\" placeholder=\"Enter Signature to verify...\">\n<button onclick=\"verifySignature()\">Verify Signature</button>\n<p id=\"verificationResult\"></p>\n\n<h3>5. Change Keys</h3>\n<label for=\"keyChange\">Change RSA Key Size:</label>\n<input type=\"range\" id=\"keyChange\" min=\"512\" max=\"4096\" step=\"128\" value=\"2048\" onchange=\"updateKeySize()\">\n<p>Current Key Size: <span id=\"keySizeDisplay\">2048</span></p>\n\n<script>\n    let publicKey, privateKey, currentKeySize = 2048;\n\n    function loadDocument() {\n        const documentInput = document.getElementById(\"documentInput\").value;\n        alert(\"Document Loaded: \" + documentInput);\n    }\n\n    function generateKeys() {\n        // Simulated key generation (replace with actual cryptographic library in practice)\n        publicKey = \"MockPublicKey_\" + currentKeySize;\n        privateKey = \"MockPrivateKey_\" + currentKeySize;\n        document.getElementById(\"publicKey\").value = publicKey;\n        document.getElementById(\"privateKey\").value = privateKey;\n        alert(\"Key Pair Generated\");\n    }\n\n    function signDocument() {\n        // Simulated signing (this would require actual cryptographic implementations)\n        const documentText = document.getElementById(\"documentInput\").value;\n        if (documentText === \"\") {\n            alert(\"Please load a document first.\");\n            return;\n        }\n        if (!privateKey) {\n            alert(\"Please generate a key pair first.\");\n            return;\n        }\n        const signature = \"Signature_\" + btoa(documentText);\n        document.getElementById(\"signature\").value = signature;\n        alert(\"Document Signed\");\n    }\n\n    function verifySignature() {\n        const signatureInput = document.getElementById(\"signatureInput\").value;\n        const expectedSignature = document.getElementById(\"signature\").value;\n        const result = expectedSignature === signatureInput ? \"Signature Valid\" : \"Signature Invalid\";\n        document.getElementById(\"verificationResult\").textContent = result;\n    }\n\n    function updateKeySize() {\n        currentKeySize = document.getElementById(\"keyChange\").value;\n        document.getElementById(\"keySizeDisplay\").textContent = currentKeySize;\n    }\n</script>\n\n</body>\n</html>"
