    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linked List Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #2c3e50;\n            color: #ecf0f1;\n            margin: 0;\n            padding: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            position: relative;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: background 0.5s;\n            border-radius: 12px;\n            padding: 20px;\n            background: linear-gradient(135deg, #3498db, #8e44ad);\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n            overflow: hidden;\n            width: 80%;\n            max-width: 800px;\n        }\n        .node {\n            background: #e74c3c;\n            border-radius: 10px;\n            padding: 15px;\n            margin: 10px;\n            text-align: center;\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);\n            position: relative;\n        }\n        .node:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);\n        }\n        .arrow {\n            font-size: 24px;\n            color: #ecf0f1;\n            opacity: 0;\n            transition: opacity 0.5s ease;\n        }\n        .visible {\n            opacity: 1;\n        }\n        button {\n            background-color: #16a085;\n            border: none;\n            color: white;\n            padding: 10px 20px;\n            text-align: center;\n            text-decoration: none;\n            display: inline-block;\n            font-size: 16px;\n            margin: 20px 2px;\n            cursor: pointer;\n            border-radius: 5px;\n            transition: background 0.3s;\n        }\n        button:hover {\n            background-color: #1abc9c;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"node\">Node 1</div>\n        <div class=\"arrow\" id=\"arrow1\">➔</div>\n        <div class=\"node\">Node 2</div>\n        <div class=\"arrow\" id=\"arrow2\">➔</div>\n        <div class=\"node\">Node 3</div>\n    </div>\n    <button id=\"showArrows\">Show Connections</button>\n\n    <script>\n        document.getElementById('showArrows').addEventListener('click', function () {\n            document.getElementById('arrow1').classList.toggle('visible');\n            document.getElementById('arrow2').classList.toggle('visible');\n            this.textContent = this.textContent === 'Show Connections' ? 'Hide Connections' : 'Show Connections';\n        });\n    </script>\n</body>\n</html>"
