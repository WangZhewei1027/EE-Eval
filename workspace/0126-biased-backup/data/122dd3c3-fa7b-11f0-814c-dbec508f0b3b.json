    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Static Typing</title>\n    <style>\n        body {\n            background-color: white;\n            font-family: monospace;\n        }\n        input, select, textarea {\n            font-size: 16px;\n            padding: 10px;\n            margin-bottom: 20px;\n            width: 100%;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n        .error {\n            color: red;\n        }\n    </style>\n</head>\n<body>\n    <h1>Static Typing</h1>\n    <p id=\"error-message\"></p>\n    <input id=\"input-field\" type=\"text\" placeholder=\"Type something\">\n    <button id=\"submit-button\">Submit</button>\n    <button id=\"clear-button\">Clear</button>\n    <div id=\"output-container\"></div>\n    <script>\n        let inputField = document.getElementById('input-field');\n        let submitButton = document.getElementById('submit-button');\n        let clearButton = document.getElementById('clear-button');\n        let outputContainer = document.getElementById('output-container');\n        let errorMessage = document.getElementById('error-message');\n        let inputFieldContent = '';\n        let submitButtonContent = '';\n        let clearButtonContent = '';\n\n        let inputFieldHandler = (e) => {\n            inputFieldContent = inputField.value;\n            if (inputFieldContent.length > 100) {\n                errorMessage.textContent = 'Input too long!';\n            } else {\n                errorMessage.textContent = '';\n            }\n            updateOutput();\n        };\n\n        let submitButtonHandler = () => {\n            if (inputFieldContent) {\n                // TO DO: implement some logic here\n                console.log('Submit button clicked!');\n            } else {\n                errorMessage.textContent = 'Please type something!';\n            }\n            updateOutput();\n        };\n\n        let clearButtonHandler = () => {\n            inputFieldContent = '';\n            errorMessage.textContent = '';\n            updateOutput();\n        };\n\n        submitButton.addEventListener('click', submitButtonHandler);\n        clearButton.addEventListener('click', clearButtonHandler);\n\n        function updateOutput() {\n            outputContainer.innerHTML = '';\n            if (inputFieldContent) {\n                outputContainer.insertAdjacentHTML('beforeend', `<p>Input: ${inputFieldContent}</p>`);\n            } else {\n                outputContainer.insertAdjacentHTML('beforeend', `<p>Error: Please type something!</p>`);\n            }\n        }\n    </script>\n</body>\n</html>"
