  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>CPU Scheduling Simulator</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { display: flex; gap: 20px; }\n        .control-panel { width: 300px; }\n        .visualization { flex-grow: 1; }\n        table { border-collapse: collapse; width: 100%; }\n        th, td { border: 1px solid #000; padding: 5px; text-align: left; }\n        .gantt-chart { display: flex; margin-top: 20px; height: 60px; }\n        .gantt-block { border: 1px solid #000; text-align: center; padding: 5px 0; }\n        .process-form { margin-bottom: 20px; }\n        .process-form input { width: 50px; margin-right: 10px; }\n        .stats { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>CPU Scheduling Simulator</h1>\n    \n    <div class=\"container\">\n        <div class=\"control-panel\">\n            <div>\n                <h2>Controls</h2>\n                <div>\n                    <label>Algorithm:</label>\n                    <select id=\"algorithm\">\n                        <option value=\"fcfs\">First-Come First-Served (FCFS)</option>\n                        <option value=\"sjf\">Shortest Job First (Non-preemptive)</option>\n                        <option value=\"srtf\">Shortest Remaining Time First (Preemptive)</option>\n                        <option value=\"rr\">Round Robin</option>\n                        <option value=\"priority\">Priority (Non-preemptive)</option>\n                        <option value=\"priority_p\">Priority (Preemptive)</option>\n                    </select>\n                </div>\n                <div id=\"quantum-control\" style=\"display: none;\">\n                    <label>Time Quantum:</label>\n                    <input type=\"number\" id=\"quantum\" min=\"1\" value=\"2\">\n                </div>\n                <button id=\"run\">Run Simulation</button>\n                <button id=\"reset\">Reset</button>\n            </div>\n\n            <div class=\"process-form\">\n                <h2>Add Process</h2>\n                <div>\n                    <label>ID:</label>\n                    <input type=\"text\" id=\"pid\" placeholder=\"P1\">\n                </div>\n                <div>\n                    <label>Arrival Time:</label>\n                    <input type=\"number\" id=\"arrival\" min=\"0\" value=\"0\">\n                </div>\n                <div>\n                    <label>Burst Time:</label>\n                    <input type=\"number\" id=\"burst\" min=\"1\" value=\"3\">\n                </div>\n                <div>\n                    <label>Priority:</label>\n                    <input type=\"number\" id=\"priority\" min=\"1\" value=\"1\">\n                </div>\n                <button id=\"add-process\">Add Process</button>\n            </div>\n\n            <div>\n                <h2>Process Table</h2>\n                <table id=\"process-table\">\n                    <thead>\n                        <tr>\n                            <th>Process</th>\n                            <th>Arrival</th>\n                            <th>Burst</th>\n                            <th>Priority</th>\n                            <th>Action</th>\n                        </tr>\n                    </thead>\n                    <tbody></tbody>\n                </table>\n            </div>\n        </div>\n\n        <div class=\"visualization\">\n            <h2>Simulation</h2>\n            <div id=\"output\"></div>\n            <div id=\"gantt-chart\" class=\"gantt-chart\"></div>\n            \n            <div class=\"stats\">\n                <h2>Statistics</h2>\n                <div id=\"stats-output\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let processes = [];\n        let simulationResults = null;\n        \n        // DOM elements\n        const algorithmSelect = document.getElementById('algorithm');\n        const quantumControl = document.getElementById('quantum-control');\n        const quantumInput = document.getElementById('quantum');\n        const runButton = document.getElementById('run');\n        const resetButton = document.getElementById('reset');\n        const addProcessButton = document.getElementById('add-process');\n        const processTable = document.getElementById('process-table').querySelector('tbody');\n        const outputDiv = document.getElementById('output');\n        const ganttChart = document.getElementById('gantt-chart');\n        const statsOutput = document.getElementById('stats-output');\n        \n        // Event listeners\n        algorithmSelect.addEventListener('change', () => {\n            quantumControl.style.display = algorithmSelect.value === 'rr' ? 'block' : 'none';\n        });\n        \n        addProcessButton.addEventListener('click', addProcess);\n        runButton.addEventListener('click', runSimulation);\n        resetButton.addEventListener('click', resetSimulation);\n        \n        function addProcess() {\n            const pid = document.getElementById('pid').value || `P${processes.length + 1}`;\n            const arrival = parseInt(document.getElementById('arrival').value);\n            const burst = parseInt(document.getElementById('burst').value);\n            const priority = parseInt(document.getElementById('priority').value);\n            \n            if (isNaN(arrival) || isNaN(burst) || isNaN(priority)) {\n                alert('Please enter valid numbers');\n                return;\n            }\n            \n            const process = { pid, arrival, burst, remaining: burst, priority };\n            processes.push(process);\n            updateProcessTable();\n            \n            // Reset form\n            document.getElementById('pid').value = '';\n            document.getElementById('arrival').value = arrival + 1;\n            document.getElementById('burst').value = 3;\n        }\n        \n        function updateProcessTable() {\n            processTable.innerHTML = '';\n            processes.forEach((process, index) => {\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${process.pid}</td>\n                    <td>${process.arrival}</td>\n                    <td>${process.burst}</td>\n                    <td>${process.priority}</td>\n                    <td><button onclick=\"removeProcess(${index})\">Remove</button></td>\n                `;\n                processTable.appendChild(row);\n            });\n        }\n        \n        function removeProcess(index) {\n            processes.splice(index, 1);\n            updateProcessTable();\n        }\n        \n        function runSimulation() {\n            if (processes.length === 0) {\n                alert('Please add at least one process');\n                return;\n            }\n            \n            const algorithm = algorithmSelect.value;\n            const quantum = algorithm === 'rr' ? parseInt(quantumInput.value) : null;\n            \n            // Reset remaining time for all processes\n            processes.forEach(p => p.remaining = p.burst);\n            \n            switch (algorithm) {\n                case 'fcfs':\n                    simulationResults = fcfs();\n                    break;\n                case 'sjf':\n                    simulationResults = sjf();\n                    break;\n                case 'srtf':\n                    simulationResults = srtf();\n                    break;\n                case 'rr':\n                    simulationResults = roundRobin(quantum);\n                    break;\n                case 'priority':\n                    simulationResults = priorityNonPreemptive();\n                    break;\n                case 'priority_p':\n                    simulationResults = priorityPreemptive();\n                    break;\n            }\n            \n            displayResults();\n        }\n        \n        function fcfs() {\n            const results = {\n                timeline: [],\n                processes: {},\n                stats: {}\n            };\n            \n            // Initialize process data\n            processes.forEach(p => {\n                results.processes[p.pid] = {\n                    arrival: p.arrival,\n                    burst: p.burst,\n                    start: null,\n                    finish: null,\n                    waiting: 0,\n                    turnaround: 0\n                };\n            });\n            \n            // Sort by arrival time\n            const sortedProcesses = [...processes].sort((a, b) => a.arrival - b.arrival);\n            \n            let currentTime = 0;\n            \n            for (const process of sortedProcesses) {\n                if (currentTime < process.arrival) {\n                    results.timeline.push({ time: currentTime, process: 'Idle', duration: process.arrival - currentTime });\n                    currentTime = process.arrival;\n                }\n                \n                const startTime = currentTime;\n                const finishTime = startTime + process.burst;\n                \n                results.timeline.push({ time: startTime, process: process.pid, duration: process.burst });\n                \n                results.processes[process.pid].start = startTime;\n                results.processes[process.pid].finish = finishTime;\n                results.processes[process.pid].waiting = startTime - process.arrival;\n                results.processes[process.pid].turnaround = finishTime - process.arrival;\n                \n                currentTime = finishTime;\n            }\n            \n            calculateStats(results);\n            return results;\n        }\n        \n        function sjf() {\n            const results = {\n                timeline: [],\n                processes: {},\n                stats: {}\n            };\n            \n            // Initialize process data\n            processes.forEach(p => {\n                results.processes[p.pid] = {\n                    arrival: p.arrival,\n                    burst: p.burst,\n                    start: null,\n                    finish: null,\n                    waiting: 0,\n                    turnaround: 0\n                };\n            });\n            \n            let currentTime = 0;\n            const readyQueue = [];\n            const allProcesses = [...processes].map(p => ({ ...p }));\n            \n            while (allProcesses.length > 0 || readyQueue.length > 0) {\n                // Add arrived processes to ready queue\n                for (let i = 0; i < allProcesses.length; i++) {\n                    if (allProcesses[i].arrival <= currentTime) {\n                        readyQueue.push(allProcesses.splice(i, 1)[0]);\n                        i--;\n                    }\n                }\n                \n                if (readyQueue.length === 0) {\n                    // No processes ready, advance time\n                    const nextArrival = Math.min(...allProcesses.map(p => p.arrival));\n                    const idleTime = nextArrival - currentTime;\n                    results.timeline.push({ time: currentTime, process: 'Idle', duration: idleTime });\n                    currentTime = nextArrival;\n                    continue;\n                }\n                \n                // Sort ready queue by burst time\n                readyQueue.sort((a, b) => a.burst - b.burst);\n                \n                const process = readyQueue.shift();\n                const startTime = currentTime;\n                const finishTime = startTime + process.burst;\n                \n                results.timeline.push({ time: startTime, process: process.pid, duration: process.burst });\n                \n                results.processes[process.pid].start = startTime;\n                results.processes[process.pid].finish = finishTime;\n                results.processes[process.pid].waiting = startTime - process.arrival;\n                results.processes[process.pid].turnaround = finishTime - process.arrival;\n                \n                currentTime = finishTime;\n            }\n            \n            calculateStats(results);\n            return results;\n        }\n        \n        function srtf() {\n            const results = {\n                timeline: [],\n                processes: {},\n                stats: {}\n            };\n            \n            // Initialize process data\n            processes.forEach(p => {\n                results.processes[p.pid] = {\n                    arrival: p.arrival,\n                    burst: p.burst,\n                    start: null,\n                    finish: null,\n                    waiting: 0,\n                    turnaround: 0,\n                    remaining: p.burst\n                };\n            });\n            \n            let currentTime = 0;\n            const allProcesses = [...processes].map(p => ({ ...p }));\n            const readyQueue = [];\n            let currentProcess = null;\n            let lastSwitchTime = 0;\n            \n            while (allProcesses.length > 0 || readyQueue.length > 0 || currentProcess) {\n                // Add arrived processes to ready queue\n                for (let i = 0; i < allProcesses.length; i++) {\n                    if (allProcesses[i].arrival <= currentTime) {\n                        const process = allProcesses.splice(i, 1)[0];\n                        readyQueue.push(process);\n                        i--;\n                    }\n                }\n                \n                // Sort ready queue by remaining time\n                readyQueue.sort((a, b) => a.remaining - b.remaining);\n                \n                // Get the process with shortest remaining time\n                const nextProcess = readyQueue.length > 0 ? readyQueue[0] : null;\n                \n                if (currentProcess) {\n                    // Check if we should preempt\n                    if (nextProcess && nextProcess.remaining < currentProcess.remaining) {\n                        // Preempt current process\n                        const duration = currentTime - lastSwitchTime;\n                        if (duration > 0) {\n                            results.timeline.push({ \n                                time: lastSwitchTime, \n                                process: currentProcess.pid, \n                                duration: duration \n                            });\n                            \n                            // Update remaining time\n                            currentProcess.remaining -= duration;\n                            results.processes[currentProcess.pid].remaining = currentProcess.remaining;\n                            \n                            // Put back to ready queue\n                            readyQueue.push(currentProcess);\n                        }\n                        \n                        currentProcess = nextProcess;\n                        readyQueue.shift();\n                        lastSwitchTime = currentTime;\n                    }\n                } else {\n                    if (nextProcess) {\n                        currentProcess = nextProcess;\n                        readyQueue.shift();\n                        lastSwitchTime = currentTime;\n                    }\n                }\n                \n                if (!currentProcess) {\n                    // No processes ready, advance time\n                    if (allProcesses.length > 0) {\n                        const nextArrival = Math.min(...allProcesses.map(p => p.arrival));\n                        const idleTime = nextArrival - currentTime;\n                        results.timeline.push({ time: currentTime, process: 'Idle', duration: idleTime });\n                        currentTime = nextArrival;\n                        continue;\n                    } else {\n                        break;\n                    }\n                }\n                \n                // Determine next event time\n                let nextEventTime = currentTime + 1;\n                \n                // Check if a new process arrives before we finish current\n                if (allProcesses.length > 0) {\n                    nextEventTime = Math.min(nextEventTime, Math.min(...allProcesses.map(p => p.arrival)));\n                }\n                \n                // Check if current process will finish\n                const timeToFinish = currentProcess.remaining;\n                if (timeToFinish <= (nextEventTime - currentTime)) {\n                    nextEventTime = currentTime + timeToFinish;\n                }\n                \n                // Execute until next event\n                const duration = nextEventTime - currentTime;\n                \n                // Record start time if this is the first time process runs\n                if (results.processes[currentProcess.pid].start === null) {\n                    results.processes[currentProcess.pid].start = currentTime;\n                }\n                \n                // Update remaining time\n                currentProcess.remaining -= duration;\n                results.processes[currentProcess.pid].remaining = currentProcess.remaining;\n                \n                if (currentProcess.remaining <= 0) {\n                    // Process finished\n                    results.timeline.push({ \n                        time: lastSwitchTime, \n                        process: currentProcess.pid, \n                        duration: duration \n                    });\n                    \n                    results.processes[currentProcess.pid].finish = nextEventTime;\n                    results.processes[currentProcess.pid].turnaround = \n                        nextEventTime - currentProcess.arrival;\n                    results.processes[currentProcess.pid].waiting = \n                        results.processes[currentProcess.pid].turnaround - currentProcess.burst;\n                    \n                    currentProcess = null;\n                }\n                \n                currentTime = nextEventTime;\n            }\n            \n            calculateStats(results);\n            return results;\n        }\n        \n        function roundRobin(quantum) {\n            const results = {\n                timeline: [],\n                processes: {},\n                stats: {}\n            };\n            \n            // Initialize process data\n            processes.forEach(p => {\n                results.processes[p.pid] = {\n                    arrival: p.arrival,\n                    burst: p.burst,\n                    start: null,\n                    finish: null,\n                    waiting: 0,\n                    turnaround: 0,\n                    remaining: p.burst\n                };\n            });\n            \n            let currentTime = 0;\n            const allProcesses = [...processes].map(p => ({ ...p }));\n            const readyQueue = [];\n            let currentProcess = null;\n            let remainingQuantum = 0;\n            let lastSwitchTime = 0;\n            \n            while (allProcesses.length > 0 || readyQueue.length > 0 || currentProcess) {\n                // Add arrived processes to ready queue\n                for (let i = 0; i < allProcesses.length; i++) {\n                    if (allProcesses[i].arrival <= currentTime) {\n                        readyQueue.push(allProcesses.splice(i, 1)[0]);\n                        i--;\n                    }\n                }\n                \n                if (currentProcess) {\n                    if (remainingQuantum <= 0 || currentProcess.remaining <= 0) {\n                        // Time quantum expired or process finished\n                        const duration = currentTime - lastSwitchTime;\n                        \n                        if (duration > 0) {\n                            results.timeline.push({ \n                                time: lastSwitchTime, \n                                process: currentProcess.pid, \n                                duration: duration \n                            });\n                            \n                            // Update remaining time\n                            currentProcess.remaining -= duration;\n                            results.processes[currentProcess.pid].remaining = currentProcess.remaining;\n                            \n                            if (currentProcess.remaining > 0) {\n                                // Put back to ready queue\n                                readyQueue.push(currentProcess);\n                            } else {\n                                // Process finished\n                                results.processes[currentProcess.pid].finish = currentTime;\n                                results.processes[currentProcess.pid].turnaround = \n                                    currentTime - currentProcess.arrival;\n                                results.processes[currentProcess.pid].waiting = \n                                    results.processes[currentProcess.pid].turnaround - currentProcess.burst;\n                            }\n                        }\n                        \n                        currentProcess = null;\n                    }\n                }\n                \n                if (!currentProcess && readyQueue.length > 0) {\n                    currentProcess = readyQueue.shift();\n                    remainingQuantum = quantum;\n                    // Record start time if this is the first time process runs\n                    if (results.processes[currentProcess.pid].start === null) {\n                        results.processes[currentProcess.pid].start = currentTime;\n                    }\n                    lastSwitchTime = currentTime;\n                }\n                \n                if (!currentProcess) {\n                    // No processes ready, advance time\n                    if (allProcesses.length > 0) {\n                        const nextArrival = Math.min(...allProcesses.map(p => p.arrival));\n                        const idleTime = nextArrival - currentTime;\n                        results.timeline.push({ time: currentTime, process: 'Idle', duration: idleTime });\n                        currentTime = nextArrival;\n                        continue;\n                    } else {\n                        break;\n                    }\n                }\n                \n                // Determine next event time\n                let nextEventTime = currentTime + 1;\n                \n                // Check if a new process arrives before quantum expires\n                if (allProcesses.length > 0) {\n                    nextEventTime = Math.min(nextEventTime, Math.min(...allProcesses.map(p => p.arrival)));\n                }\n                \n                // Check if quantum will expire\n                if (remainingQuantum <= (nextEventTime - currentTime)) {\n                    nextEventTime = currentTime + remainingQuantum;\n                }\n                \n                // Check if process will finish\n                if (currentProcess.remaining <= (nextEventTime - currentTime)) {\n                    nextEventTime = currentTime + currentProcess.remaining;\n                }\n                \n                // Execute until next event\n                const duration = nextEventTime - currentTime;\n                remainingQuantum -= duration;\n                currentTime = nextEventTime;\n            }\n            \n            calculateStats(results);\n            return results;\n        }\n        \n        function priorityNonPreemptive() {\n            const results = {\n                timeline: [],\n                processes: {},\n                stats: {}\n            };\n            \n            // Initialize process data\n            processes.forEach(p => {\n                results.processes[p.pid] = {\n                    arrival: p.arrival,\n                    burst: p.burst,\n                    start: null,\n                    finish: null,\n                    waiting: 0,\n                    turnaround: 0\n                };\n            });\n            \n            let currentTime = 0;\n            const readyQueue = [];\n            const allProcesses = [...processes].map(p => ({ ...p }));\n            \n            while (allProcesses.length > 0 || readyQueue.length > 0) {\n                // Add arrived processes to ready queue\n                for (let i = 0; i < allProcesses.length; i++) {\n                    if (allProcesses[i].arrival <= currentTime) {\n                        readyQueue.push(allProcesses.splice(i, 1)[0]);\n                        i--;\n                    }\n                }\n                \n                if (readyQueue.length === 0) {\n                    // No processes ready, advance time\n                    const nextArrival = Math.min(...allProcesses.map(p => p.arrival));\n                    const idleTime = nextArrival - currentTime;\n                    results.timeline.push({ time: currentTime, process: 'Idle', duration: idleTime });\n                    currentTime = nextArrival;\n                    continue;\n                }\n                \n                // Sort ready queue by priority (lower number = higher priority)\n                readyQueue.sort((a, b) => a.priority - b.priority);\n                \n                const process = readyQueue.shift();\n                const startTime = currentTime;\n                const finishTime = startTime + process.burst;\n                \n                results.timeline.push({ time: startTime, process: process.pid, duration: process.burst });\n                \n                results.processes[process.pid].start = startTime;\n                results.processes[process.pid].finish = finishTime;\n                results.processes[process.pid].waiting = startTime - process.arrival;\n                results.processes[process.pid].turnaround = finishTime - process.arrival;\n                \n                currentTime = finishTime;\n            }\n            \n            calculateStats(results);\n            return results;\n        }\n        \n        function priorityPreemptive() {\n            const results = {\n                timeline: [],\n                processes: {},\n                stats: {}\n            };\n            \n            // Initialize process data\n            processes.forEach(p => {\n                results.processes[p.pid] = {\n                    arrival: p.arrival,\n                    burst: p.burst,\n                    start: null,\n                    finish: null,\n                    waiting: 0,\n                    turnaround: 0,\n                    remaining: p.burst,\n                    priority: p.priority\n                };\n            });\n            \n            let currentTime = 0;\n            const allProcesses = [...processes].map(p => ({ ...p }));\n            const readyQueue = [];\n            let currentProcess = null;\n            let lastSwitchTime = 0;\n            \n            while (allProcesses.length > 0 || readyQueue.length > 0 || currentProcess) {\n                // Add arrived processes to ready queue\n                for (let i = 0; i < allProcesses.length; i++) {\n                    if (allProcesses[i].arrival <= currentTime) {\n                        const process = allProcesses.splice(i, 1)[0];\n                        readyQueue.push(process);\n                        i--;\n                    }\n                }\n                \n                // Sort ready queue by priority (lower number = higher priority)\n                readyQueue.sort((a, b) => a.priority - b.priority);\n                \n                // Get the highest priority process\n                const nextProcess = readyQueue.length > 0 ? readyQueue[0] : null;\n                \n                if (currentProcess) {\n                    // Check if we should preempt\n                    if (nextProcess && nextProcess.priority < currentProcess.priority) {\n                        // Preempt current process\n                        const duration = currentTime - lastSwitchTime;\n                        if (duration > 0) {\n                            results.timeline.push({ \n                                time: lastSwitchTime, \n                                process: currentProcess.pid, \n                                duration: duration \n                            });\n                            \n                            // Update remaining time\n                            currentProcess.remaining -= duration;\n                            results.processes[currentProcess.pid].remaining = currentProcess.remaining;\n                            \n                            // Put back to ready queue\n                            readyQueue.push(currentProcess);\n                        }\n                        \n                        currentProcess = nextProcess;\n                        readyQueue.shift();\n                        lastSwitchTime = currentTime;\n                    }\n                } else {\n                    if (nextProcess) {\n                        currentProcess = nextProcess;\n                        readyQueue.shift();\n                        lastSwitchTime = currentTime;\n                    }\n                }\n                \n                if (!currentProcess) {\n                    // No processes ready, advance time\n                    if (allProcesses.length > 0) {\n                        const nextArrival = Math.min(...allProcesses.map(p => p.arrival));\n                        const idleTime = nextArrival - currentTime;\n                        results.timeline.push({ time: currentTime, process: 'Idle', duration: idleTime });\n                        currentTime = nextArrival;\n                        continue;\n                    } else {\n                        break;\n                    }\n                }\n                \n                // Determine next event time\n                let nextEventTime = currentTime + 1;\n                \n                // Check if a new process arrives before we finish current\n                if (allProcesses.length > 0) {\n                    nextEventTime = Math.min(nextEventTime, Math.min(...allProcesses.map(p => p.arrival)));\n                }\n                \n                // Check if current process will finish\n                const timeToFinish = currentProcess.remaining;\n                if (timeToFinish <= (nextEventTime - currentTime)) {\n                    nextEventTime = currentTime + timeToFinish;\n                }\n                \n                // Execute until next event\n                const duration = nextEventTime - currentTime;\n                \n                // Record start time if this is the first time process runs\n                if (results.processes[currentProcess.pid].start === null) {\n                    results.processes[currentProcess.pid].start = currentTime;\n                }\n                \n                // Update remaining time\n                currentProcess.remaining -= duration;\n                results.processes[currentProcess.pid].remaining = currentProcess.remaining;\n                \n                if (currentProcess.remaining <= 0) {\n                    // Process finished\n                    results.timeline.push({ \n                        time: lastSwitchTime, \n                        process: currentProcess.pid, \n                        duration: duration \n                    });\n                    \n                    results.processes[currentProcess.pid].finish = nextEventTime;\n                    results.processes[currentProcess.pid].turnaround = \n                        nextEventTime - currentProcess.arrival;\n                    results.processes[currentProcess.pid].waiting = \n                        results.processes[currentProcess.pid].turnaround - currentProcess.burst;\n                    \n                    currentProcess = null;\n                }\n                \n                currentTime = nextEventTime;\n            }\n            \n            calculateStats(results);\n            return results;\n        }\n        \n        function calculateStats(results) {\n            let totalWaiting = 0;\n            let totalTurnaround = 0;\n            let count = 0;\n            \n            for (const pid in results.processes) {\n                totalWaiting += results.processes[pid].waiting;\n                totalTurnaround += results.processes[pid].turnaround;\n                count++;\n            }\n            \n            results.stats.avgWaiting = totalWaiting / count;\n            results.stats.avgTurnaround = totalTurnaround / count;\n        }\n        \n        function displayResults() {\n            if (!simulationResults) return;\n            \n            // Display timeline\n            outputDiv.innerHTML = '<h3>Execution Timeline</h3>';\n            const timelineTable = document.createElement('table');\n            timelineTable.innerHTML = `\n                <thead>\n                    <tr>\n                        <th>Time</th>\n                        <th>Process</th>\n                        <th>Duration</th>\n                    </tr>\n                </thead>\n                <tbody></tbody>\n            `;\n            \n            const timelineBody = timelineTable.querySelector('tbody');\n            simulationResults.timeline.forEach(entry => {\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${entry.time}</td>\n                    <td>${entry.process}</td>\n                    <td>${entry.duration}</td>\n                `;\n                timelineBody.appendChild(row);\n            });\n            \n            outputDiv.appendChild(timelineTable);\n            \n            // Display Gantt chart\n            ganttChart.innerHTML = '<h3>Gantt Chart</h3>';\n            const ganttContainer = document.createElement('div');\n            ganttContainer.className = 'gantt-chart';\n            \n            simulationResults.timeline.forEach(entry => {\n                const block = document.createElement('div');\n                block.className = 'gantt-block';\n                block.style.width = `${entry.duration * 30}px`;\n                block.textContent = entry.process;\n                ganttContainer.appendChild(block);\n            });\n            \n            ganttChart.appendChild(ganttContainer);\n            \n            // Display process details\n            const processDetails = document.createElement('div');\n            processDetails.innerHTML = '<h3>Process Details</h3>';\n            const detailsTable = document.createElement('table');\n            detailsTable.innerHTML = `\n                <thead>\n                    <tr>\n                        <th>Process</th>\n                        <th>Arrival</th>\n                        <th>Burst</th>\n                        <th>Start</th>\n                        <th>Finish</th>\n                        <th>Waiting</th>\n                        <th>Turnaround</th>\n                    </tr>\n                </thead>\n                <tbody></tbody>\n            `;\n            \n            const detailsBody = detailsTable.querySelector('tbody');\n            for (const pid in simulationResults.processes) {\n                const p = simulationResults.processes[pid];\n                const row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${pid}</td>\n                    <td>${p.arrival}</td>\n                    <td>${p.burst}</td>\n                    <td>${p.start}</td>\n                    <td>${p.finish}</td>\n                    <td>${p.waiting}</td>\n                    <td>${p.turnaround}</td>\n                `;\n                detailsBody.appendChild(row);\n            }\n            \n            processDetails.appendChild(detailsTable);\n            outputDiv.appendChild(processDetails);\n            \n            // Display statistics\n            statsOutput.innerHTML = `\n                <h3>Performance Metrics</h3>\n                <p>Average Waiting Time: ${simulationResults.stats.avgWaiting.toFixed(2)}</p>\n                <p>Average Turnaround Time: ${simulationResults.stats.avgTurnaround.toFixed(2)}</p>\n            `;\n        }\n        \n        function resetSimulation() {\n            processes = [];\n            simulationResults = null;\n            processTable.innerHTML = '';\n            outputDiv.innerHTML = '';\n            ganttChart.innerHTML = '';\n            statsOutput.innerHTML = '';\n            document.getElementById('pid').value = '';\n            document.getElementById('arrival').value = '0';\n            document.getElementById('burst').value = '3';\n            document.getElementById('priority').value = '1';\n        }\n    </script>\n</body>\n</html>"
