    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Interpreter Demo</title>\n    <style>\n        body { font-family: monospace; }\n        #output { white-space: pre; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive Interpreter</h1>\n<div>\n    <textarea id=\"input\" placeholder=\"Enter commands here...\" rows=\"4\" cols=\"50\"></textarea><br>\n    <button onclick=\"executeCommand()\">Execute</button>\n    <button onclick=\"clearOutput()\">Clear Output</button>\n</div>\n\n<div>\n    <label for=\"slider\">Adjust Value:</label>\n    <input type=\"range\" id=\"slider\" min=\"0\" max=\"100\" value=\"50\" onchange=\"updateSliderValue()\">\n    <span id=\"sliderValue\">50</span>\n</div>\n\n<div>\n    <input type=\"text\" id=\"variableKey\" placeholder=\"Variable Key\">\n    <input type=\"text\" id=\"variableValue\" placeholder=\"Variable Value\">\n    <button onclick=\"setVariable()\">Set Variable</button>\n</div>\n\n<h2>Variables</h2>\n<div id=\"variablesOutput\"></div>\n\n<h2>Output</h2>\n<div id=\"output\"></div>\n\n<script>\n    let variables = {};\n\n    function executeCommand() {\n        const input = document.getElementById(\"input\").value;\n        const output = document.getElementById(\"output\");\n        let result = '';\n\n        if (input.startsWith(\"print \")) {\n            const variable = input.split(\" \")[1];\n            result = variables[variable] || `Variable \"${variable}\" not found.`;\n        } else if (input.startsWith(\"set \")) {\n            const [_, key, value] = input.split(\" \");\n            variables[key] = value;\n            result = `Set \"${key}\" to \"${value}\".`;\n            updateVariablesOutput();\n        } else {\n            result = \"Unknown command.\";\n        }\n\n        output.textContent += result + \"\\n\";\n        document.getElementById(\"input\").value = '';\n    }\n\n    function clearOutput() {\n        document.getElementById(\"output\").textContent = '';\n    }\n\n    function updateSliderValue() {\n        const sliderValue = document.getElementById(\"slider\").value;\n        document.getElementById(\"sliderValue\").textContent = sliderValue;\n    }\n\n    function setVariable() {\n        const key = document.getElementById(\"variableKey\").value;\n        const value = document.getElementById(\"variableValue\").value;\n        variables[key] = value;\n        updateVariablesOutput();\n        document.getElementById(\"variableKey\").value = '';\n        document.getElementById(\"variableValue\").value = '';\n    }\n\n    function updateVariablesOutput() {\n        const output = document.getElementById(\"variablesOutput\");\n        output.textContent = JSON.stringify(variables, null, 2);\n    }\n</script>\n\n</body>\n</html>"
