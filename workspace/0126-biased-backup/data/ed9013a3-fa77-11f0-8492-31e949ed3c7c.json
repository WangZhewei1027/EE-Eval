sform: translateY(0);\n                opacity: 1;\n            }\n        }\n\n        .hide {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            opacity: 0;\n            transition: opacity 1s;\n        }\n\n        .show {\n            opacity: 1;\n        }\n\n        button {\n            padding: 10px 20px;\n            font-size: 1em;\n            background-color: #00BFFF;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            outline: none;\n            margin-top: 20px;\n            transition: background-color 0.3s;\n        }\n\n        button:hover {\n            background-color: #1E90FF;\n        }\n\n        footer {\n            margin-top: 30px;\n            font-size: 0.8em;\n            color: rgba(255, 255, 255, 0.7);\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <h1>Logistic Regression Visualizer</h1>\n        <p>Observe how logistic regression classifies data points with a sigmoid curve.</p>\n        <div class=\"chart\" id=\"chart\">\n            <div class=\"hide\" id=\"overlay\">Data classification in progress...</div>\n        </div>\n        <button id=\"showDataButton\">Show Data</button>\n        <footer>© 2023 Logistic Regression Visualization Project</footer>\n    </div>\n\n    <script>\n        const overlay = document.getElementById('overlay');\n        const showDataButton = document.getElementById('showDataButton');\n\n        showDataButton.addEventListener('click', () => {\n            overlay.classList.toggle('show');\n            if (overlay.classList.contains('show')) {\n                showDataButton.textContent = 'Hide Data';\n            } else {\n                showDataButton.textContent = 'Show Data';\n            }\n        });\n    </script>\n</body>\n\n</html>"
