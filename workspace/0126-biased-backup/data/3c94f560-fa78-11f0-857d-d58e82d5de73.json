    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>The Array • Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Code&family=Open+Sans:wght@400;700&display=swap');\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);\n    color: #f0f0f5;\n    font-family: 'Open Sans', sans-serif;\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n  }\n\n  header {\n    text-align: center;\n    padding: 3rem 1rem 1.5rem;\n  }\n  header h1 {\n    font-size: 3.2rem;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    margin: 0 0 0.2rem;\n    color: #ffeb3b;\n    text-shadow:\n      0 0 8px #ffd600,\n      0 0 20px #fff176;\n  }\n  header p {\n    font-size: 1.15rem;\n    max-width: 420px;\n    margin: 0 auto;\n    line-height: 1.5;\n    color: #bbdefb;\n  }\n\n  main {\n    flex-grow: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding-bottom: 4rem;\n    position: relative;\n  }\n\n  /* Array container */\n  .array-container {\n    position: relative;\n    display: flex;\n    gap: 1.25rem;\n    padding: 2rem 1rem 3rem;\n    background: rgba(255,255,255,0.07);\n    border-radius: 1.25rem;\n    box-shadow:\n      inset 0 0 15px #59baff40,\n      0 0 25px #0288d1cc;\n    backdrop-filter: blur(20px);\n    max-width: 90vw;\n    width: 730px;\n  }\n\n  /* Array item boxes */\n  .array-item {\n    flex: 1 1 50px;\n    background: linear-gradient(145deg, #2f99ff 0%, #0077ff 100%);\n    border-radius: 0.8rem;\n    box-shadow:\n      0 4px 12px rgba(0,120,255,0.6),\n      0 0 8px #0077ff;\n    color: #e3f2fd;\n    font-family: 'Fira Code', monospace;\n    font-size: 2rem;\n    font-weight: 700;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    position: relative;\n    height: 90px;\n    cursor: default;\n    user-select: none;\n    text-shadow:\n      0 0 6px #a2cdffbb;\n    transition:\n      transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.5s ease;\n  }\n\n  .array-item::before {\n    content: attr(data-index);\n    position: absolute;\n    top: 8px;\n    left: 12px;\n    font-size: 0.85rem;\n    font-weight: 600;\n    color: #bbdefbcc;\n    text-shadow:\n      0 0 3px #82b1ffcc;\n  }\n\n  .array-item:hover {\n    transform: translateY(-16px) scale(1.12);\n    box-shadow:\n      0 10px 30px #4a90e2cc,\n      0 0 20px #54a0ffcc;\n  }\n\n  /* Connecting lines */\n  .array-connector {\n    position: absolute;\n    height: 3px;\n    background: linear-gradient(90deg, #80d8ff, #2962ff);\n    border-radius: 1.5px;\n    top: 60px;\n    filter: drop-shadow(0 0 4px #4dabf7aa);\n    transition: width 0.6s cubic-bezier(0.4,0,0.2,1);\n  }\n\n  /* Label below array */\n  .label {\n    position: absolute;\n    bottom: 4px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-family: 'Fira Code', monospace;\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: #90caf9;\n    text-shadow:\n      0 0 8px #64b5f6bb;\n  }\n\n  /* Code snippet container */\n  .code-container {\n    background: #0d47a1;\n    max-width: 730px;\n    margin: 0 auto 3rem;\n    border-radius: 1rem;\n    box-shadow:\n      0 6px 20px #2196f3aa;\n    padding: 1.5rem 2rem;\n    font-family: 'Fira Code', monospace;\n    font-weight: 600;\n    font-size: 1.15rem;\n    color: #bbdefb;\n    user-select: none;\n    line-height: 1.6;\n    position: relative;\n  }\n\n  .code-container .keyword {\n    color: #ffca28;\n    font-weight: 700;\n  }\n  .code-container .function {\n    color: #80d8ff;\n  }\n  .code-container .number {\n    color: #ff8a65;\n  }\n  .code-container .string {\n    color: #a5d6a7;\n  }\n  .code-container .comment {\n    color: #78909c;\n    font-style: italic;\n  }\n\n  /* Buttons */\n  .controls {\n    text-align: center;\n    margin-top: 1rem;\n  }\n\n  button {\n    background: linear-gradient(145deg, #2979ff, #1c54b2);\n    border: none;\n    padding: 0.6rem 1.4rem;\n    border-radius: 2rem;\n    color: #bbdefb;\n    font-weight: 700;\n    font-family: 'Fira Code', monospace;\n    font-size: 1.1rem;\n    cursor: pointer;\n    user-select: none;\n    box-shadow:\n      0 4px 12px #1565c0cc;\n    transition:\n      background 0.3s ease,\n      box-shadow 0.3s ease,\n      transform 0.2s ease;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #64b5f6, #0d47a1);\n    box-shadow:\n      0 6px 18px #64b5f6dd;\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(1px);\n  }\n\n  /* Footer */\n  footer {\n    font-size: 0.85rem;\n    text-align: center;\n    color: #90caf9bb;\n    margin-bottom: 1rem;\n  }\n  footer a {\n    color: #bbdefbcc;\n    text-decoration: none;\n    border-bottom: 1px solid transparent;\n    transition: border-color 0.3s ease;\n  }\n  footer a:hover {\n    border-color: #64b5f6;\n  }\n\n  /* Animations for decorating circles */\n  .decor-circles {\n    position: fixed;\n    pointer-events: none;\n    top: 50%;\n    left: 50%;\n    width: 700px;\n    height: 700px;\n    transform: translate(-50%, -50%);\n    user-select: none;\n    z-index: 0;\n  }\n\n  .circle {\n    position: absolute;\n    border: 2px solid transparent;\n    border-radius: 50%;\n    box-shadow:\n      0 0 30px rgba(255 255 255 / 0.12),\n      inset 0 0 18px rgba(64 196 255 / 0.3);\n    animation-timing-function: ease-in-out;\n    animation-iteration-count: infinite;\n  }\n\n  .circle1 {\n    top: 50%;\n    left: 50%;\n    width: 510px;\n    height: 510px;\n    margin: -255px 0 0 -255px;\n    border-color: #64b5f6;\n    animation-name: pulse-scale;\n    animation-duration: 7.5s;\n  }\n  .circle2 {\n    top: 50%;\n    left: 50%;\n    width: 390px;\n    height: 390px;\n    margin: -195px 0 0 -195px;\n    border-color: #42a5f5;\n    animation-name: pulse-scale-rev;\n    animation-duration: 5.8s;\n    animation-delay: 1.3s;\n  }\n  .circle3 {\n    top: 50%;\n    left: 50%;\n    width: 275px;\n    height: 275px;\n    margin: -137.5px 0 0 -137.5px;\n    border-color: #2196f3;\n    animation-name: pulse-scale;\n    animation-duration: 6.9s;\n    animation-delay: 2.9s;\n  }\n  .circle4 {\n    top: 50%;\n    left: 50%;\n    width: 180px;\n    height: 180px;\n    margin: -90px 0 0 -90px;\n    border-color: #1976d2;\n    animation-name: pulse-scale-rev;\n    animation-duration: 4.6s;\n    animation-delay: 1.7s;\n  }\n\n  @keyframes pulse-scale {\n    0%, 100% {\n      transform: translate(-50%, -50%) scale(1);\n      opacity: 0.26;\n    }\n    50% {\n      transform: translate(-50%, -50%) scale(1.045);\n      opacity: 0.46;\n    }\n  }\n  @keyframes pulse-scale-rev {\n    0%, 100% {\n      transform: translate(-50%, -50%) scale(1.05);\n      opacity: 0.24;\n    }\n    50% {\n      transform: translate(-50%, -50%) scale(0.985);\n      opacity: 0.48;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Array</h1>\n  <p>A visual demonstration of the fundamental <strong>Array</strong> concept: an ordered, indexed collection of values.</p>\n</header>\n\n<main aria-label=\"Visual representation of an array data structure\">\n  <div class=\"array-container\" role=\"list\" aria-label=\"Array of numbers\">\n    <div class=\"array-item\" data-index=\"0\" role=\"listitem\" aria-label=\"Index 0, value 7\">7</div>\n    <div class=\"array-item\" data-index=\"1\" role=\"listitem\" aria-label=\"Index 1, value 12\">12</div>\n    <div class=\"array-item\" data-index=\"2\" role=\"listitem\" aria-label=\"Index 2, value 5\">5</div>\n    <div class=\"array-item\" data-index=\"3\" role=\"listitem\" aria-label=\"Index 3, value 23\">23</div>\n    <div class=\"array-item\" data-index=\"4\" role=\"listitem\" aria-label=\"Index 4, value 8\">8</div>\n    <div class=\"array-item\" data-index=\"5\" role=\"listitem\" aria-label=\"Index 5, value 31\">31</div>\n    <div class=\"array-item\" data-index=\"6\" role=\"listitem\" aria-label=\"Index 6, value 14\">14</div>\n  </div>\n  <div class=\"label\" aria-hidden=\"true\">Indices 0 to 6</div>\n</main>\n\n<section class=\"code-container\" aria-label=\"Example JavaScript code for array creation and access\" tabindex=\"0\">\n  <pre><code><span class=\"comment\">// Declare an array of numbers</span>\n<span class=\"keyword\">const</span> <span class=\"function\">numbers</span> = [<span class=\"number\">7</span>, <span class=\"number\">12</span>, <span class=\"number\">5</span>, <span class=\"number\">23</span>, <span class=\"number\">8</span>, <span class=\"number\">31</span>, <span class=\"number\">14</span>];\n\n<span class=\"comment\">// Access element by index</span>\n<span class=\"keyword\">const</span> <span class=\"function\">thirdElement</span> = numbers[<span class=\"number\">2</span>];\n<span class=\"comment\">// thirdElement = 5</span>\n  </code></pre>\n</section>\n\n<div class=\"controls\" aria-label=\"Array display controls\">\n  <button id=\"highlight-btn\" type=\"button\" aria-pressed=\"false\" aria-label=\"Highlight middle element in array\">Highlight middle element</button>\n</div>\n\n<footer>\n  &copy; 2024 &mdash; Array visualization inspired by data structures <a href=\"https://en.wikipedia.org/wiki/Array_data_structure\" target=\"_blank\" rel=\"noopener\">Wikipedia</a>\n</footer>\n\n<!-- Decorative animated circles -->\n<div class=\"decor-circles\" aria-hidden=\"true\">\n  <div class=\"circle circle1\"></div>\n  <div class=\"circle circle2\"></div>\n  <div class=\"circle circle3\"></div>\n  <div class=\"circle circle4\"></div>\n</div>\n\n<script>\n  (() => {\n    const btn = document.getElementById('highlight-btn');\n    const arrayItems = [...document.querySelectorAll('.array-item')];\n    const midIndex = Math.floor(arrayItems.length / 2);\n    let highlighted = false;\n\n    btn.addEventListener('click', () => {\n      highlighted = !highlighted;\n      btn.setAttribute('aria-pressed', highlighted.toString());\n      if (highlighted) {\n        arrayItems[midIndex].style.background = 'linear-gradient(145deg, #ff6f61 0%, #ff3d3d 100%)';\n        arrayItems[midIndex].style.boxShadow = '0 8px 25px #ff3d3dcc, 0 0 25px #ff6f6188';\n        arrayItems[midIndex].style.color = '#fff0f0';\n        btn.textContent = 'Remove highlight';\n      } else {\n        arrayItems[midIndex].style.background = 'linear-gradient(145deg, #2f99ff 0%, #0077ff 100%)';\n        arrayItems[midIndex].style.boxShadow = '0 4px 12px rgba(0,120,255,0.6), 0 0 8px #0077ff';\n        arrayItems[midIndex].style.color = '#e3f2fd';\n        btn.textContent = 'Highlight middle element';\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
