 solve this problem by recursively dividing the problem into smaller sub-problems and combining the solutions to find the optimal solution.\n            `;\n            document.getElementById(\"example\").innerHTML = exampleText;\n        }\n\n        // Demonstration\n        function demonstration() {\n            var demonstrationText = `\n                Demonstration:\n                The Branch and Bound algorithm works by recursively dividing the problem into smaller sub-problems and combining the solutions to find the optimal solution.\n                For the 3-SAT problem, the algorithm starts by dividing the problem into smaller sub-problems, such as the clause ¬x ∧ y.\n                It then recursively divides the sub-problems into smaller sub-sub-problems and combines the solutions to find the optimal solution.\n                The algorithm continues to divide and combine the solutions until it finds the optimal solution.\n            `;\n            document.getElementById(\"demonstration\").innerHTML = demonstrationText;\n        }\n\n        // Button event handler\n        document.getElementById(\"demonstration-button\").addEventListener(\"click\", demonstration);\n\n        // Initialize the algorithm\n        explanation();\n        example();\n        demonstration();\n    </script>\n</body>\n</html>"
