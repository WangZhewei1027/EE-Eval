    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NP-Completeness Interactive Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; line-height: 1.6; }\n        .control { margin-top: 10px; }\n    </style>\n</head>\n<body>\n    <h1>NP-Completeness Interactive Demonstration</h1>\n    <p>Select an NP-complete problem to explore:</p>\n    <select id=\"problem-selector\" class=\"control\">\n        <option value=\"knapsack\">0/1 Knapsack Problem</option>\n        <option value=\"vertex_cover\">Vertex Cover Problem</option>\n        <option value=\"subset_sum\">Subset Sum Problem</option>\n    </select>\n\n    <div id=\"knapsack-controls\" class=\"control\" style=\"display: none;\">\n        <h3>0/1 Knapsack Problem</h3>\n        Item weights (comma-separated): <input type=\"text\" id=\"knapsack-weights\" />\n        Item values (comma-separated): <input type=\"text\" id=\"knapsack-values\" />\n        Knapsack capacity: <input type=\"number\" id=\"knapsack-capacity\" />\n        <button onclick=\"solveKnapsack()\">Solve Knapsack</button>\n        <p id=\"knapsack-output\"></p>\n    </div>\n\n    <div id=\"vertex-cover-controls\" class=\"control\" style=\"display: none;\">\n        <h3>Vertex Cover Problem</h3>\n        Graph edges (format: node1-node2, e.g. 1-2,2-3): <input type=\"text\" id=\"vertex-cover-edges\" />\n        Total vertices: <input type=\"number\" id=\"vertex-cover-vertices\" />\n        <button onclick=\"solveVertexCover()\">Solve Vertex Cover</button>\n        <p id=\"vertex-cover-output\"></p>\n    </div>\n\n    <div id=\"subset-sum-controls\" class=\"control\" style=\"display: none;\">\n        <h3>Subset Sum Problem</h3>\n        Numbers (comma-separated): <input type=\"text\" id=\"subset-sum-numbers\" />\n        Target sum: <input type=\"number\" id=\"subset-sum-target\" />\n        <button onclick=\"solveSubsetSum()\">Solve Subset Sum</button>\n        <p id=\"subset-sum-output\"></p>\n    </div>\n\n    <script>\n        document.getElementById('problem-selector').addEventListener('change', function() {\n            document.getElementById('knapsack-controls').style.display = 'none';\n            document.getElementById('vertex-cover-controls').style.display = 'none';\n            document.getElementById('subset-sum-controls').style.display = 'none';\n\n            if (this.value === 'knapsack') {\n                document.getElementById('knapsack-controls').style.display = 'block';\n            } else if (this.value === 'vertex_cover') {\n                document.getElementById('vertex-cover-controls').style.display = 'block';\n            } else if (this.value === 'subset_sum') {\n                document.getElementById('subset-sum-controls').style.display = 'block';\n            }\n        });\n\n        function solveKnapsack() {\n            const weights = document.getElementById('knapsack-weights').value.split(',').map(Number);\n            const values = document.getElementById('knapsack-values').value.split(',').map(Number);\n            const capacity = Number(document.getElementById('knapsack-capacity').value);\n            const n = weights.length;\n\n            const dp = Array.from({ length: n + 1 }, () => Array(capacity + 1).fill(0));\n\n            for (let i = 1; i <= n; i++) {\n                for (let w = 0; w <= capacity; w++) {\n                    if (weights[i - 1] <= w) {\n                        dp[i][w] = Math.max(dp[i - 1][w], dp[i - 1][w - weights[i - 1]] + values[i - 1]);\n                    } else {\n                        dp[i][w] = dp[i - 1][w];\n                    }\n                }\n            }\n\n            document.getElementById('knapsack-output').innerText = `Maximum value in knapsack: ${dp[n][capacity]}`;\n        }\n\n        function solveVertexCover() {\n            const edgesInput = document.getElementById('vertex-cover-edges').value.split(',');\n            const vertices = Number(document.getElementById('vertex-cover-vertices').value);\n            const edges = edgesInput.map(edge => edge.split('-').map(Number));\n\n            const cover = new Set(), visited = new Set();\n            edges.forEach(([u, v]) => {\n                if (!visited.has(u) && !visited.has(v)) {\n                    cover.add(u);\n                    cover.add(v);\n                    visited.add(u);\n                    visited.add(v);\n                }\n            });\n\n            document.getElementById('vertex-cover-output').innerText = `A possible vertex cover is: ${Array.from(cover).join(', ')}`;\n        }\n\n        function solveSubsetSum() {\n            const numbers = document.getElementById('subset-sum-numbers').value.split(',').map(Number);\n            const target = Number(document.getElementById('subset-sum-target').value);\n            const n = numbers.length;\n\n            const dp = Array.from({ length: target + 1 }, () => false);\n            dp[0] = true;\n\n            for (let num of numbers) {\n                for (let j = target; j >= num; j--) {\n                    dp[j] = dp[j] || dp[j - num];\n                }\n            }\n\n            document.getElementById('subset-sum-output').innerText = dp[target] ? \"A subset with the target sum exists.\" : \"No subset with the target sum exists.\";\n        }\n    </script>\n</body>\n</html>"
