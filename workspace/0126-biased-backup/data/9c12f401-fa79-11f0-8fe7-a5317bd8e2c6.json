  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Stack Playground</title>\n<style>\n/* Intentionally minimal styling - plain, unpolished */\nbody { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 12px; }\nbutton,input,select,textarea { margin: 4px 0; }\n.stack-panel { border: 1px solid #000; padding: 6px; margin: 6px 0; }\n.controls-row { margin: 6px 0; }\n.small { font-size: 12px; }\n.codebox { width: 100%; height: 120px; }\n.stack-items { font-family: monospace; white-space: pre; }\n</style>\n</head>\n<body>\n\n<h2>Stack Playground</h2>\n<p>Plain interface to explore stacks. Multiple stacks, macros, batch operations, move/copy, undo/redo, snapshots, search, transform. Keyboard shortcuts: Ctrl+Enter run macro, P push, O pop, U undo, R redo.</p>\n\n<!-- Stack creation and selection -->\n<div>\n  <div class=\"controls-row\">\n    <label>Create new stack name: <input id=\"newStackName\" placeholder=\"StackName\" /></label>\n    <button id=\"createStackBtn\">Create Stack</button>\n    <label> or create random: <button id=\"createRandomStackBtn\">Random Stack</button></label>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Active stack:\n      <select id=\"activeStackSelect\"></select>\n    </label>\n    <label>Target stack:\n      <select id=\"targetStackSelect\"></select>\n    </label>\n    <button id=\"renameStackBtn\">Rename</button>\n    <input id=\"renameInput\" placeholder=\"New name\" />\n    <button id=\"deleteStackBtn\">Delete</button>\n  </div>\n</div>\n\n<hr>\n\n<!-- Primary stack operations -->\n<div>\n  <div class=\"controls-row\">\n    <label>Push value: <input id=\"pushInput\" placeholder='e.g. 42 or \"hello\" or {\"x\":1}' /></label>\n    <label>Type parse:\n      <select id=\"pushParseMode\">\n        <option value=\"auto\">Auto (try JSON)</option>\n        <option value=\"string\">String</option>\n        <option value=\"number\">Number</option>\n        <option value=\"json\">JSON</option>\n        <option value=\"raw\">Raw text (no parse)</option>\n      </select>\n    </label>\n    <label>Repeat:\n      <input id=\"pushRepeat\" type=\"range\" min=\"1\" max=\"20\" value=\"1\" />\n      <span id=\"pushRepeatVal\">1</span>\n    </label>\n    <button id=\"pushBtn\">PUSH</button>\n    <button id=\"popBtn\">POP</button>\n    <button id=\"peekBtn\">PEEK</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <button id=\"dupBtn\">DUP (duplicate top)</button>\n    <button id=\"swapBtn\">SWAP (top two)</button>\n    <label>Rotate:\n      <input id=\"rotateN\" type=\"number\" value=\"1\" style=\"width:60px\" />\n    </label>\n    <button id=\"rotateBtn\">ROTATE</button>\n    <button id=\"clearBtn\">CLEAR</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Move to target count:\n      <input id=\"moveCount\" type=\"number\" value=\"1\" style=\"width:70px\" />\n    </label>\n    <button id=\"moveBtn\">MOVE -></button>\n    <button id=\"copyBtn\">COPY -></button>\n    <button id=\"concatBtn\">CONCAT -> (append all)</button>\n    <button id=\"reverseBtn\">REVERSE (create new stack)</button>\n    <button id=\"sortBtn\">SORT (create new stack)</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Batch push (newline separated values):</label>\n    <textarea id=\"batchPush\" class=\"codebox\" placeholder='one value per line. Values parsed by \"Auto\" mode'></textarea>\n    <button id=\"batchPushBtn\">Batch PUSH</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Random generator:\n      <select id=\"randKind\">\n        <option value=\"num\">Number</option>\n        <option value=\"int\">Int</option>\n        <option value=\"str\">String</option>\n        <option value=\"json\">JSON object</option>\n      </select>\n    </label>\n    <label>Count: <input id=\"randCount\" type=\"number\" value=\"5\" style=\"width:60px\" /></label>\n    <button id=\"randPushBtn\">Generate & PUSH</button>\n  </div>\n</div>\n\n<hr>\n\n<!-- Advanced transform and filter -->\n<div>\n  <h3>Transform / Filter / Search</h3>\n  <div class=\"controls-row\">\n    <label>Find substring or regex: <input id=\"searchInput\" placeholder=\"text or /regex/flags\" /></label>\n    <button id=\"searchBtn\">Find</button>\n    <button id=\"removeMatchesBtn\">Remove matches</button>\n    <button id=\"keepMatchesBtn\">Keep only matches</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Map expression (x represents item value): <input id=\"mapExpr\" placeholder=\"x.toString().toUpperCase()\" style=\"width:60%\" /></label>\n    <button id=\"mapReplaceBtn\">MAP & Replace</button>\n    <button id=\"mapPushBtn\">MAP -> Push results</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Flatten nested arrays (if items are arrays) <button id=\"flattenBtn\">FLATTEN -> push to target</button></label>\n  </div>\n</div>\n\n<hr>\n\n<!-- Macro scripting -->\n<div>\n  <h3>Macro / Script</h3>\n  <textarea id=\"macroTextarea\" class=\"codebox\" placeholder=\"Simple macro language. Example:\nPUSH 1\nPUSH 2\nDUP\nMOVE A B 2\nREPEAT 3 [\n  PUSH \\\"loop\\\"\n  POP\n]\nIF TOP MATCH /\\\\d+/ THEN PUSH \\\"digit\\\" ELSE PUSH \\\"no\\\"\"></textarea>\n  <div class=\"controls-row\">\n    <button id=\"runMacroBtn\">Run Macro</button>\n    <button id=\"stepMacroBtn\">Step Macro</button>\n    <button id=\"stopMacroBtn\">Stop Macro</button>\n    <label>Step delay ms: <input id=\"macroDelay\" type=\"number\" value=\"200\" style=\"width:80px\" /></label>\n  </div>\n  <div class=\"controls-row\">\n    <label>Macro pointer: <span id=\"macroPointer\">0</span> / <span id=\"macroTotal\">0</span></label>\n  </div>\n</div>\n\n<hr>\n\n<!-- History / Undo Redo -->\n<div>\n  <h3>History & Snapshots</h3>\n  <div class=\"controls-row\">\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <button id=\"clearHistoryBtn\">Clear History</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Snapshot name: <input id=\"snapshotName\" /></label>\n    <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n    <button id=\"listSnapshotsBtn\">List Snapshots</button>\n  </div>\n  <div id=\"snapshotsList\"></div>\n</div>\n\n<hr>\n\n<!-- Serialization -->\n<div>\n  <h3>Export / Import</h3>\n  <div class=\"controls-row\">\n    <button id=\"exportBtn\">Export JSON (copy below)</button>\n    <button id=\"loadFromJsonBtn\">Load from JSON (replace stacks)</button>\n  </div>\n  <textarea id=\"exportArea\" class=\"codebox\" placeholder=\"Exported JSON will appear here\"></textarea>\n  <label>Paste JSON into above box to load into workspace.</label>\n</div>\n\n<hr>\n\n<!-- Status / stats -->\n<div>\n  <h3>Status</h3>\n  <div>\n    <strong>Active Stack:</strong> <span id=\"activeStackLabel\">-</span>\n    &nbsp;&nbsp;\n    <strong>Size:</strong> <span id=\"activeStackSize\">0</span>\n    &nbsp;&nbsp;\n    <strong>Top:</strong> <span id=\"activeStackTop\">-</span>\n  </div>\n  <div>\n    <strong>Global stacks:</strong> <span id=\"globalStacksCount\">0</span>\n  </div>\n  <div>\n    <strong>History length:</strong> <span id=\"historyLen\">0</span>\n  </div>\n</div>\n\n<hr>\n\n<!-- Stacks display -->\n<div id=\"stacksContainer\"></div>\n\n<!-- Action log -->\n<h3>Action Log</h3>\n<div id=\"actionLog\" class=\"stack-items\" style=\"max-height:200px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n\n<script>\n/*\n  Stack Playground - interactive rich demo\n  Plain visual design, extensive controls.\n*/\n\n(function(){\n  // State\n  let stacks = [];\n  let history = []; // snapshots of stacks state\n  let historyIndex = -1;\n  let actionLog = [];\n  let macroState = { running: false, steps: [], pointer: 0, timer: null };\n\n  // Helpers\n  const el = id => document.getElementById(id);\n  const log = (...a) => {\n    const s = a.map(x => (typeof x === 'object' ? JSON.stringify(x) : String(x))).join(' ');\n    actionLog.unshift((new Date()).toISOString() + ' - ' + s);\n    if (actionLog.length>500) actionLog.pop();\n    renderActionLog();\n  };\n\n  function deepCloneStacks(s) { return JSON.parse(JSON.stringify(s)); }\n\n  // History management\n  function pushHistory(reason) {\n    // Save deep clone\n    const snap = deepCloneStacks(stacks);\n    // If we undid and then new action, drop future\n    if (historyIndex < history.length - 1) {\n      history = history.slice(0, historyIndex + 1);\n    }\n    history.push({snap, reason, time: Date.now()});\n    historyIndex = history.length - 1;\n    updateHistoryDisplay();\n  }\n  function undo() {\n    if (historyIndex <= 0) return;\n    historyIndex--;\n    const snap = deepCloneStacks(history[historyIndex].snap);\n    stacks = snap;\n    log('UNDO to', history[historyIndex].reason || 'state');\n    renderAll();\n    updateHistoryDisplay();\n  }\n  function redo() {\n    if (historyIndex >= history.length - 1) return;\n    historyIndex++;\n    const snap = deepCloneStacks(history[historyIndex].snap);\n    stacks = snap;\n    log('REDO to', history[historyIndex].reason || 'state');\n    renderAll();\n    updateHistoryDisplay();\n  }\n  function clearHistory() {\n    history = [];\n    historyIndex = -1;\n    updateHistoryDisplay();\n  }\n  function updateHistoryDisplay() {\n    el('historyLen').textContent = history.length;\n  }\n\n  // Utility: find stack by id or name\n  function getStackById(id) {\n    return stacks.find(s => s.id === id);\n  }\n  function getActiveStack() {\n    const sel = el('activeStackSelect').value;\n    return getStackById(sel) || stacks[0];\n  }\n\n  // ID generation\n  function uid(prefix='S') { return prefix + Math.random().toString(36).slice(2,9); }\n\n  // Rendering\n  function renderAll() {\n    renderStackSelectors();\n    renderStacks();\n    renderStatus();\n  }\n  function renderStackSelectors() {\n    const a = el('activeStackSelect');\n    const t = el('targetStackSelect');\n    const prevA = a.value;\n    const prevT = t.value;\n    a.innerHTML = '';\n    t.innerHTML = '';\n    stacks.forEach(s => {\n      const o = document.createElement('option'); o.value = s.id; o.textContent = s.name;\n      a.appendChild(o);\n      const o2 = o.cloneNode(true);\n      t.appendChild(o2);\n    });\n    if (stacks.length === 0) {\n      const nothing = document.createElement('option'); nothing.textContent = '(no stacks)'; nothing.value = '';\n      a.appendChild(nothing); t.appendChild(nothing.cloneNode(true));\n    } else {\n      if ([...a.options].some(o => o.value === prevA)) a.value = prevA;\n      if ([...t.options].some(o => o.value === prevT)) t.value = prevT;\n    }\n  }\n\n  function renderStacks() {\n    const container = el('stacksContainer');\n    container.innerHTML = '';\n    stacks.forEach(s => {\n      const panel = document.createElement('div');\n      panel.className = 'stack-panel';\n      const heading = document.createElement('div');\n      heading.textContent = s.name + ' (id:' + s.id + ') - size: ' + s.items.length;\n      panel.appendChild(heading);\n      const items = document.createElement('div');\n      items.className = 'stack-items';\n      // Show top at leftmost line\n      const lines = s.items.map((it, idx) => {\n        const label = '[' + (s.items.length - idx - 1) + '] ';\n        return label + stringifyItem(it);\n      });\n      // Show top first\n      items.textContent = lines.reverse().join('\\\\n');\n      panel.appendChild(items);\n\n      // Quick controls per stack\n      const controls = document.createElement('div');\n      controls.className = 'controls-row small';\n      const pushBtn = document.createElement('button'); pushBtn.textContent = 'Push value';\n      pushBtn.onclick = () => {\n        el('activeStackSelect').value = s.id;\n        el('pushBtn').click();\n      };\n      const popBtn = document.createElement('button'); popBtn.textContent = 'Pop';\n      popBtn.onclick = () => {\n        el('activeStackSelect').value = s.id;\n        el('popBtn').click();\n      };\n      controls.appendChild(pushBtn);\n      controls.appendChild(popBtn);\n      panel.appendChild(controls);\n      container.appendChild(panel);\n    });\n    el('globalStacksCount').textContent = stacks.length;\n    renderStatus();\n  }\n\n  function renderStatus() {\n    const active = getActiveStack();\n    el('activeStackLabel').textContent = active ? active.name : '(none)';\n    el('activeStackSize').textContent = active ? active.items.length : '0';\n    el('activeStackTop').textContent = active && active.items.length ? stringifyItem(active.items[active.items.length-1]) : '-';\n    el('pushRepeatVal').textContent = el('pushRepeat').value;\n    el('macroTotal').textContent = macroState.steps.length;\n    el('macroPointer').textContent = macroState.pointer;\n  }\n\n  function renderActionLog() {\n    el('actionLog').textContent = actionLog.slice(0,200).join('\\\\n');\n  }\n\n  // Item representation\n  function createItemFromInput(inputText, mode) {\n    mode = mode || 'auto';\n    let val = inputText;\n    let type = 'string';\n    try {\n      if (mode === 'raw') {\n        val = inputText;\n        type = 'raw';\n      } else if (mode === 'string') {\n        val = String(inputText);\n        type = 'string';\n      } else if (mode === 'number') {\n        const num = parseFloat(inputText);\n        if (isNaN(num)) { val = inputText; type='string'; } else { val = num; type='number'; }\n      } else if (mode === 'json') {\n        val = JSON.parse(inputText);\n        type = typeof val;\n      } else { // auto\n        // Try JSON then number then fallback to string\n        try {\n          val = JSON.parse(inputText);\n          type = typeof val;\n        } catch(e) {\n          const num = parseFloat(inputText);\n          if (!isNaN(num) && inputText.trim() !== '') { val = num; type='number'; }\n          else { val = String(inputText); type='string'; }\n        }\n      }\n    } catch(e) {\n      val = inputText;\n      type = 'string';\n    }\n    return { value: val, type: type };\n  }\n  function stringifyItem(it) {\n    try {\n      if (typeof it.value === 'string') return '\"' + it.value + '\"';\n      return JSON.stringify(it.value);\n    } catch(e) {\n      return String(it.value);\n    }\n  }\n\n  // Basic stack operations\n  function pushToStack(stackId, item) {\n    const s = getStackById(stackId);\n    if (!s) return;\n    s.items.push(item);\n    pushHistory('push to ' + s.name);\n    renderAll();\n    log('PUSH', stringifyItem(item), '->', s.name);\n  }\n  function popFromStack(stackId) {\n    const s = getStackById(stackId);\n    if (!s || s.items.length === 0) return null;\n    const popped = s.items.pop();\n    pushHistory('pop from ' + s.name);\n    renderAll();\n    log('POP', stringifyItem(popped), '<-', s.name);\n    return popped;\n  }\n  function peekStack(stackId) {\n    const s = getStackById(stackId);\n    if (!s || s.items.length === 0) return null;\n    return s.items[s.items.length-1];\n  }\n  function duplicateTop(stackId) {\n    const top = peekStack(stackId);\n    if (!top) return;\n    const copy = deepCloneStacks([{items:[top]}])[0].items[0]; // clone object\n    getStackById(stackId).items.push(copy);\n    pushHistory('dup ' + stackId);\n    renderAll();\n    log('DUP', stringifyItem(top), 'on', getStackById(stackId).name);\n  }\n  function swapTop(stackId) {\n    const s = getStackById(stackId);\n    if (!s || s.items.length < 2) return;\n    const n = s.items.length;\n    [s.items[n-1], s.items[n-2]] = [s.items[n-2], s.items[n-1]];\n    pushHistory('swap ' + s.name);\n    renderAll();\n    log('SWAP', s.name);\n  }\n  function rotate(stackId, n) {\n    const s = getStackById(stackId);\n    if (!s || s.items.length === 0) return;\n    n = Math.floor(Number(n) || 0);\n    const len = s.items.length;\n    // positive n: move top to bottom repeatedly n times\n    for (let i=0;i<Math.abs(n);i++){\n      if (n>0) {\n        const top = s.items.pop();\n        s.items.unshift(top);\n      } else {\n        const bottom = s.items.shift();\n        s.items.push(bottom);\n      }\n    }\n    pushHistory('rotate ' + s.name + ' ' + n);\n    renderAll();\n    log('ROTATE', s.name, n);\n  }\n  function clearStack(stackId) {\n    const s = getStackById(stackId);\n    if (!s) return;\n    s.items = [];\n    pushHistory('clear ' + s.name);\n    renderAll();\n    log('CLEAR', s.name);\n  }\n\n  // Move items between stacks\n  function moveItems(srcId, dstId, count) {\n    const src = getStackById(srcId), dst = getStackById(dstId);\n    if (!src || !dst) return;\n    count = Math.max(0, Math.floor(Number(count)||0));\n    const moved = [];\n    for (let i=0;i<count;i++){\n      if (src.items.length===0) break;\n      moved.push(src.items.pop());\n    }\n    // push to dst preserving order (first popped becomes top last)\n    for (let i=moved.length-1;i>=0;i--){\n      dst.items.push(moved[i]);\n    }\n    pushHistory('move ' + moved.length + ' from ' + src.name + ' to ' + dst.name);\n    renderAll();\n    log('MOVE', moved.length, 'from', src.name, 'to', dst.name);\n  }\n\n  function copyItems(srcId, dstId, count) {\n    const src = getStackById(srcId), dst = getStackById(dstId);\n    if (!src || !dst) return;\n    count = Math.max(0, Math.floor(Number(count)||0));\n    const start = Math.max(0, src.items.length - count);\n    const slice = src.items.slice(start).map(it => JSON.parse(JSON.stringify(it)));\n    // preserve order: append same order so the last of slice becomes top\n    for (const it of slice) dst.items.push(it);\n    pushHistory('copy ' + slice.length + ' from ' + src.name + ' to ' + dst.name);\n    renderAll();\n    log('COPY', slice.length, 'from', src.name, 'to', dst.name);\n  }\n\n  function concatStacks(srcId, dstId) {\n    const src = getStackById(srcId), dst = getStackById(dstId);\n    if (!src || !dst) return;\n    const slice = src.items.map(it => JSON.parse(JSON.stringify(it)));\n    for (const it of slice) dst.items.push(it);\n    pushHistory('concat ' + src.name + ' to ' + dst.name);\n    renderAll();\n    log('CONCAT', src.name, '->', dst.name);\n  }\n\n  function createStack(name) {\n    const s = { id: uid('S'), name: name || ('Stack ' + (stacks.length + 1)), items: [] };\n    stacks.push(s);\n    pushHistory('create ' + s.name);\n    renderAll();\n    log('CREATE_STACK', s.name);\n    return s;\n  }\n\n  function deleteStackById(id) {\n    const idx = stacks.findIndex(s => s.id === id);\n    if (idx === -1) return;\n    const name = stacks[idx].name;\n    stacks.splice(idx,1);\n    pushHistory('delete ' + name);\n    renderAll();\n    log('DELETE_STACK', name);\n  }\n\n  // Transformations\n  function mapReplace(stackId, expr) {\n    const s = getStackById(stackId);\n    if (!s) return;\n    // We provide x as value and it as original item. Use Function to evaluate expression.\n    let fn;\n    try {\n      fn = new Function('x','it','return (' + expr + ')');\n    } catch(e) { alert('Invalid map expression'); return; }\n    for (let i=0;i<s.items.length;i++) {\n      try {\n        const newVal = fn(s.items[i].value, s.items[i]);\n        s.items[i] = { value: newVal, type: typeof newVal };\n      } catch(e) {\n        // leave unchanged on error\n      }\n    }\n    pushHistory('mapReplace ' + s.name);\n    renderAll();\n    log('MAP_REPLACE', s.name, expr);\n  }\n\n  function mapPush(stackId, expr, dstId) {\n    const s = getStackById(stackId);\n    const dst = getStackById(dstId);\n    if (!s || !dst) return;\n    let fn;\n    try { fn = new Function('x','it','return (' + expr + ')'); } catch(e) { alert('Invalid expression'); return; }\n    for (let it of s.items) {\n      try {\n        const newVal = fn(it.value, it);\n        dst.items.push({ value: newVal, type: typeof newVal });\n      } catch(e) {}\n    }\n    pushHistory('mapPush from ' + s.name + ' to ' + dst.name);\n    renderAll();\n    log('MAP_PUSH', s.name, '->', dst.name, expr);\n  }\n\n  function flattenToTarget(stackId, dstId) {\n    const s = getStackById(stackId);\n    const dst = getStackById(dstId);\n    if (!s || !dst) return;\n    // take items that are arrays and push their elements\n    for (let it of s.items) {\n      if (Array.isArray(it.value)) {\n        for (let v of it.value) dst.items.push({ value: v, type: typeof v });\n      } else {\n        dst.items.push(JSON.parse(JSON.stringify(it)));\n      }\n    }\n    pushHistory('flatten ' + s.name + ' -> ' + dst.name);\n    renderAll();\n    log('FLATTEN', s.name, '->', dst.name);\n  }\n\n  function removeMatches(stackId, patternText, keep=false) {\n    const s = getStackById(stackId);\n    if (!s) return;\n    const matcher = buildMatcher(patternText);\n    const before = s.items.length;\n    s.items = s.items.filter(it => {\n      const pass = matcher(String(it.value));\n      return keep ? pass : !pass;\n    });\n    pushHistory((keep ? 'keepMatches ' : 'removeMatches ') + s.name);\n    renderAll();\n    log(keep ? 'KEEP_MATCHES' : 'REMOVE_MATCHES', s.name, patternText, '->', before - s.items.length, 'removed');\n  }\n\n  function buildMatcher(text) {\n    if (!text) return () => false;\n    text = text.trim();\n    if (text.startsWith('/') && text.lastIndexOf('/')>0) {\n      // regex\n      const lastSlash = text.lastIndexOf('/');\n      const body = text.slice(1,lastSlash);\n      const flags = text.slice(lastSlash+1);\n      const re = new RegExp(body, flags);\n      return (x) => re.test(x);\n    } else {\n      const lower = text.toLowerCase();\n      return (x) => (String(x).toLowerCase().indexOf(lower) !== -1);\n    }\n  }\n\n  // Search\n  function findMatches(stackId, patternText) {\n    const s = getStackById(stackId);\n    if (!s) return [];\n    const m = buildMatcher(patternText);\n    const matches = [];\n    for (let i=0;i<s.items.length;i++){\n      if (m(String(s.items[i].value))) matches.push({index:i, item:s.items[i]});\n    }\n    log('FIND', matches.length, 'matches in', s.name);\n    return matches;\n  }\n\n  // Sorting and reverse -> create new stack\n  function reverseCreateNew(stackId, newName) {\n    const s = getStackById(stackId);\n    if (!s) return;\n    const out = { id: uid('S'), name: newName || (s.name + ' (reversed)'), items: JSON.parse(JSON.stringify(s.items)).reverse() };\n    stacks.push(out);\n    pushHistory('reverse create ' + out.name);\n    renderAll();\n    log('REVERSE_CREATED', out.name);\n  }\n  function sortCreateNew(stackId, newName, numeric=false, desc=false) {\n    const s = getStackById(stackId);\n    if (!s) return;\n    const copy = JSON.parse(JSON.stringify(s.items));\n    copy.sort((a,b) => {\n      const av = a.value, bv = b.value;\n      if (numeric) {\n        const an = Number(av), bn = Number(bv);\n        if (isNaN(an) || isNaN(bn)) return String(av).localeCompare(String(bv));\n        return an - bn;\n      } else {\n        return String(av).localeCompare(String(bv));\n      }\n    });\n    if (desc) copy.reverse();\n    const out = { id: uid('S'), name: newName || (s.name + ' (sorted)'), items: copy };\n    stacks.push(out);\n    pushHistory('sort create ' + out.name);\n    renderAll();\n    log('SORT_CREATED', out.name);\n  }\n\n  // Random generator\n  function pushRandom(kind, count, dstId) {\n    const dst = getStackById(dstId);\n    if (!dst) return;\n    count = Math.max(1, Math.min(200, Math.floor(Number(count)||1)));\n    for (let i=0;i<count;i++) {\n      if (kind === 'num') {\n        dst.items.push({ value: Math.random(), type: 'number' });\n      } else if (kind === 'int') {\n        dst.items.push({ value: Math.floor(Math.random()*1000), type: 'number' });\n      } else if (kind === 'str') {\n        dst.items.push({ value: Math.random().toString(36).slice(2,10), type: 'string' });\n      } else if (kind === 'json') {\n        dst.items.push({ value: {r:Math.random(), i:i, t:Date.now()}, type: 'object' });\n      }\n    }\n    pushHistory('rand push ' + count);\n    renderAll();\n    log('RAND_PUSH', kind, count, '->', dst.name);\n  }\n\n  // Export / Import\n  function exportJson() {\n    const out = { stacks: deepCloneStacks(stacks), history: history.map(h => ({reason:h.reason,time:h.time})) };\n    el('exportArea').value = JSON.stringify(out, null, 2);\n    log('EXPORT_JSON');\n  }\n  function loadFromJson(jsonText) {\n    try {\n      const parsed = JSON.parse(jsonText);\n      if (!parsed.stacks || !Array.isArray(parsed.stacks)) throw new Error('No stacks array');\n      stacks = parsed.stacks.map(s => ({ id: s.id || uid('S'), name: s.name || 'Stack', items: s.items || [] }));\n      pushHistory('load from json');\n      renderAll();\n      log('LOADED_JSON');\n    } catch(e) {\n      alert('Invalid JSON: ' + e.message);\n    }\n  }\n\n  // Snapshots\n  function saveSnapshot(name) {\n    const snap = deepCloneStacks(stacks);\n    const key = 'stack_snap_' + (name || Date.now());\n    try {\n      localStorage.setItem(key, JSON.stringify({ name: key, time: Date.now(), stacks: snap }));\n      log('SNAPSHOT_SAVED', key);\n      renderSnapshotsList();\n    } catch(e) {\n      alert('Failed to save snapshot: ' + e.message);\n    }\n  }\n  function renderSnapshotsList() {\n    const list = el('snapshotsList');\n    list.innerHTML = '';\n    for (let i=0;i<localStorage.length;i++){\n      const k = localStorage.key(i);\n      if (k && k.startsWith('stack_snap_')) {\n        const v = JSON.parse(localStorage.getItem(k));\n        const div = document.createElement('div');\n        div.textContent = k + ' - ' + new Date(v.time).toLocaleString();\n        const restoreBtn = document.createElement('button'); restoreBtn.textContent = 'Restore';\n        restoreBtn.onclick = () => {\n          stacks = v.stacks;\n          pushHistory('restore ' + k);\n          renderAll();\n          log('SNAP_RESTORE', k);\n        };\n        const delBtn = document.createElement('button'); delBtn.textContent = 'Delete';\n        delBtn.onclick = () => { localStorage.removeItem(k); renderSnapshotsList(); log('SNAP_DELETE', k); };\n        div.appendChild(restoreBtn); div.appendChild(delBtn);\n        list.appendChild(div);\n      }\n    }\n  }\n\n  // Macro scripting - simple language\n  function parseMacro(text) {\n    const lines = text.split('\\\\n').map(l => l.trim()).filter(l=>l.length>0 && !l.startsWith('#'));\n    // Basic tokens; support REPEAT n [ ... ] blocks by expanding into repeated lines\n    const out = [];\n    const stack = [];\n    for (let i=0;i<lines.length;i++){\n      const line = lines[i];\n      if (/^REPEAT\\\\s+\\\\d+\\\\s*\\\\[\\\\s*$/i.test(line)) {\n        // begin block\n        const m = line.match(/^REPEAT\\\\s+(\\\\d+)\\\\s*\\\\[\\\\s*$/i);\n        const count = Number(m[1]);\n        // find closing bracket\n        const block = [];\n        let depth=1;\n        let j=i+1;\n        for (;j<lines.length;j++){\n          const L = lines[j];\n          if (L.endsWith('[')) depth++;\n          if (L === ']' || L.endsWith(']')) {\n            depth--;\n            if (depth===0) { break; }\n          }\n          block.push(L);\n        }\n        i = j; // jump to closing\n        for (let k=0;k<count;k++) {\n          out.push(...block);\n        }\n      } else {\n        out.push(line);\n      }\n    }\n    return out;\n  }\n\n  function executeMacroStep(step) {\n    // step is a single command line\n    const parts = step.split(/\\s+/);\n    const cmd = parts[0].toUpperCase();\n    try {\n      if (cmd === 'PUSH') {\n        const rest = step.slice(5).trim();\n        const item = createItemFromInput(rest, 'auto');\n        const target = getActiveStack();\n        if (!target) { alert('No active stack'); return; }\n        target.items.push(item);\n        pushHistory('macro PUSH');\n        log('MACRO PUSH', stringifyItem(item), '->', target.name);\n      } else if (cmd === 'PUSHRAW' || cmd === 'PUSH_RAW') {\n        const rest = step.split(/\\s+/).slice(1).join(' ');\n        const item = createItemFromInput(rest, 'raw');\n        getActiveStack().items.push(item);\n        pushHistory('macro PUSHRAW');\n      } else if (cmd === 'POP') {\n        popFromStack(getActiveStack().id);\n      } else if (cmd === 'PEEK') {\n        const p = peekStack(getActiveStack().id);\n        log('PEEK', p ? stringifyItem(p) : '(empty)');\n      } else if (cmd === 'DUP') {\n        duplicateTop(getActiveStack().id);\n      } else if (cmd === 'SWAP') {\n        swapTop(getActiveStack().id);\n      } else if (cmd === 'ROTATE' || cmd === 'ROT') {\n        const n = Number(parts[1] || 1);\n        rotate(getActiveStack().id, n);\n      } else if (cmd === 'MOVE') {\n        // MOVE srcName dstName count\n        const srcName = parts[1], dstName = parts[2], count = Number(parts[3] || 1);\n        const src = stacks.find(s => s.name === srcName || s.id === srcName) || getStackById(srcName);\n        const dst = stacks.find(s => s.name === dstName || s.id === dstName) || getStackById(dstName);\n        if (!src || !dst) { log('MOVE failed - stack not found', srcName, dstName); return; }\n        moveItems(src.id, dst.id, count);\n      } else if (cmd === 'COPY') {\n        const srcName = parts[1], dstName = parts[2], count = Number(parts[3] || 99999);\n        const src = stacks.find(s => s.name === srcName || s.id === srcName);\n        const dst = stacks.find(s => s.name === dstName || s.id === dstName);\n        if (!src || !dst) return;\n        copyItems(src.id, dst.id, count);\n      } else if (cmd === 'IF') {\n        // IF TOP MATCH /regex/ THEN PUSH X ELSE PUSH Y\n        // very simple parse\n        const rest = step.slice(3).trim();\n        const m = rest.match(/^TOP\\\\s+MATCH\\\\s+(\\\\/.*\\\\/\\\\w*)\\\\s+THEN\\\\s+(.+?)(?:\\\\s+ELSE\\\\s+(.+))?$/i);\n        if (m) {\n          const pattern = m[1];\n          const thenCmd = m[2].trim();\n          const elseCmd = m[3] ? m[3].trim() : null;\n          const top = peekStack(getActiveStack().id);\n          const matcher = buildMatcher(pattern);\n          if (top && matcher(String(top.value))) {\n            executeMacroStep(thenCmd);\n          } else if (elseCmd) {\n            executeMacroStep(elseCmd);\n          }\n        }\n      } else if (cmd === 'REPLACE') {\n        // REPLACE expr  - replace top with expression evaluation\n        const expr = step.slice(8).trim();\n        const top = peekStack(getActiveStack().id);\n        if (top) {\n          let fn = new Function('x','it','return ('+expr+')');\n          const newVal = fn(top.value, top);\n          const s = getActiveStack();\n          s.items[s.items.length-1] = { value: newVal, type: typeof newVal };\n          pushHistory('macro replace');\n          log('MACRO REPLACE', stringifyItem({value:newVal}));\n        }\n      } else {\n        // unknown, try interpret as PUSH of the whole line\n        const item = createItemFromInput(step, 'auto');\n        const target = getActiveStack();\n        if (target) {\n          target.items.push(item);\n          pushHistory('macro implicit push');\n          log('MACRO IMPLICIT PUSH', stringifyItem(item));\n        }\n      }\n    } catch(e) {\n      log('Macro step failed:', e.message);\n    }\n  }\n\n  function runMacro(text, stepCallback, doneCallback) {\n    if (!text.trim()) return;\n    const steps = parseMacro(text);\n    macroState.steps = steps;\n    macroState.pointer = 0;\n    el('macroTotal').textContent = steps.length;\n    function next() {\n      if (!macroState.running) return;\n      if (macroState.pointer >= macroState.steps.length) {\n        macroState.running = false;\n        if (doneCallback) doneCallback();\n        return;\n      }\n      const step = macroState.steps[macroState.pointer];\n      stepCallback && stepCallback(macroState.pointer, step);\n      executeMacroStep(step);\n      macroState.pointer++;\n      renderStatus();\n      if (!macroState.running) return;\n      const delay = Math.max(0, Number(el('macroDelay').value) || 0);\n      if (delay <= 0) {\n        // continue syncing until done\n        setTimeout(next, 0);\n      } else {\n        macroState.timer = setTimeout(next, delay);\n      }\n    }\n    macroState.running = true;\n    next();\n  }\n\n  function stopMacro() {\n    macroState.running = false;\n    if (macroState.timer) { clearTimeout(macroState.timer); macroState.timer = null; }\n    log('MACRO_STOP');\n    renderStatus();\n  }\n\n  // UI Wiring\n  function wire() {\n    el('createStackBtn').onclick = () => {\n      const name = el('newStackName').value || ('Stack ' + (stacks.length+1));\n      createStack(name);\n      el('newStackName').value = '';\n    };\n    el('createRandomStackBtn').onclick = () => {\n      const s = createStack('Stack_' + Math.random().toString(36).slice(2,7));\n      // fill with some random values\n      pushRandom('int', 5, s.id);\n    };\n    el('renameStackBtn').onclick = () => {\n      const id = el('activeStackSelect').value;\n      const s = getStackById(id);\n      if (!s) return;\n      const newName = el('renameInput').value.trim();\n      if (!newName) { alert('Enter name'); return; }\n      s.name = newName;\n      pushHistory('rename ' + s.name);\n      renderAll();\n      el('renameInput').value = '';\n      log('RENAME', s.id, newName);\n    };\n    el('deleteStackBtn').onclick = () => {\n      const id = el('activeStackSelect').value;\n      if (!id) return;\n      if (!confirm('Delete selected stack?')) return;\n      deleteStackById(id);\n    };\n\n    el('pushBtn').onclick = () => {\n      const text = el('pushInput').value;\n      const mode = el('pushParseMode').value;\n      const repeat = Number(el('pushRepeat').value) || 1;\n      const target = getActiveStack();\n      if (!target) { alert('No active stack'); return; }\n      if (text === '') { alert('Enter a value to push'); return; }\n      for (let i=0;i<repeat;i++) {\n        const it = createItemFromInput(text, mode);\n        target.items.push(it);\n      }\n      pushHistory('push batch');\n      renderAll();\n      log('PUSH', text, 'x'+repeat, '->', target.name);\n    };\n\n    el('popBtn').onclick = () => {\n      const target = getActiveStack();\n      if (!target) return;\n      const popped = popFromStack(target.id);\n      if (popped) alert('Popped: ' + stringifyItem(popped));\n    };\n    el('peekBtn').onclick = () => {\n      const target = getActiveStack();\n      if (!target) return;\n      const p = peekStack(target.id);\n      alert('Peek: ' + (p ? stringifyItem(p) : '(empty)'));\n    };\n    el('dupBtn').onclick = () => {\n      const t = getActiveStack();\n      if (!t) return;\n      duplicateTop(t.id);\n    };\n    el('swapBtn').onclick = () => {\n      const t = getActiveStack();\n      if (!t) return;\n      swapTop(t.id);\n    };\n    el('rotateBtn').onclick = () => {\n      const n = Number(el('rotateN').value) || 1;\n      const t = getActiveStack();\n      rotate(t.id, n);\n    };\n    el('clearBtn').onclick = () => {\n      const t = getActiveStack();\n      if (!t) return;\n      if (!confirm('Clear stack ' + t.name + '?')) return;\n      clearStack(t.id);\n    };\n\n    el('moveBtn').onclick = () => {\n      const src = el('activeStackSelect').value;\n      const dst = el('targetStackSelect').value;\n      const count = Number(el('moveCount').value) || 1;\n      if (!src || !dst) { alert('Select stacks'); return; }\n      moveItems(src, dst, count);\n    };\n    el('copyBtn').onclick = () => {\n      const src = el('activeStackSelect').value;\n      const dst = el('targetStackSelect').value;\n      const count = Number(el('moveCount').value) || 999999;\n      if (!src || !dst) return;\n      copyItems(src, dst, count);\n    };\n    el('concatBtn').onclick = () => {\n      const src = el('activeStackSelect').value;\n      const dst = el('targetStackSelect').value;\n      if (!src || !dst) return;\n      concatStacks(src, dst);\n    };\n    el('reverseBtn').onclick = () => {\n      const s = el('activeStackSelect').value;\n      reverseCreateNew(s);\n    };\n    el('sortBtn').onclick = () => {\n      const s = el('activeStackSelect').value;\n      const numeric = confirm('Sort numeric? (OK=Yes, Cancel=No)');\n      const desc = confirm('Descending? (OK=Yes, Cancel=No)');\n      sortCreateNew(s, null, numeric, desc);\n    };\n\n    el('batchPushBtn').onclick = () => {\n      const lines = el('batchPush').value.split('\\\\n').map(l=>l.trim()).filter(l=>l!=='');\n      const mode = el('pushParseMode').value;\n      const t = getActiveStack();\n      if (!t) return;\n      for (const line of lines) {\n        t.items.push(createItemFromInput(line, mode));\n      }\n      pushHistory('batch push');\n      renderAll();\n      log('BATCH_PUSH', lines.length, '->', t.name);\n    };\n\n    el('randPushBtn').onclick = () => {\n      const kind = el('randKind').value;\n      const count = Number(el('randCount').value) || 1;\n      const t = getActiveStack();\n      if (!t) return;\n      pushRandom(kind, count, t.id);\n    };\n\n    el('searchBtn').onclick = () => {\n      const pat = el('searchInput').value;\n      const t = getActiveStack();\n      if (!t) return;\n      const matches = findMatches(t.id, pat);\n      alert('Found ' + matches.length + ' matches (see log for details).');\n      log('SEARCH', matches.length, 'in', t.name, 'pattern', pat);\n    };\n    el('removeMatchesBtn').onclick = () => {\n      const pat = el('searchInput').value;\n      const t = getActiveStack();\n      if (!t) return;\n      removeMatches(t.id, pat, false);\n    };\n    el('keepMatchesBtn').onclick = () => {\n      const pat = el('searchInput').value;\n      const t = getActiveStack();\n      if (!t) return;\n      removeMatches(t.id, pat, true);\n    };\n\n    el('mapReplaceBtn').onclick = () => {\n      const expr = el('mapExpr').value;\n      const t = getActiveStack();\n      if (!t) return;\n      if (!expr) { alert('Enter expression'); return; }\n      if (!confirm('This will replace all items in active stack. Continue?')) return;\n      mapReplace(t.id, expr);\n    };\n    el('mapPushBtn').onclick = () => {\n      const expr = el('mapExpr').value;\n      const t = getActiveStack();\n      const dst = getStackById(el('targetStackSelect').value);\n      if (!t || !dst) { alert('Select active and target'); return; }\n      if (!expr) { alert('Enter expression'); return; }\n      mapPush(t.id, expr, dst.id);\n    };\n    el('flattenBtn').onclick = () => {\n      const t = getActiveStack();\n      const dst = getStackById(el('targetStackSelect').value);\n      if (!t || !dst) return;\n      flattenToTarget(t.id, dst.id);\n    };\n\n    el('undoBtn').onclick = () => undo();\n    el('redoBtn').onclick = () => redo();\n    el('clearHistoryBtn').onclick = () => { if (confirm('Clear history?')) clearHistory(); };\n\n    el('saveSnapshotBtn').onclick = () => {\n      const name = el('snapshotName').value || ('snap_' + Date.now());\n      saveSnapshot(name);\n      el('snapshotName').value = '';\n    };\n    el('listSnapshotsBtn').onclick = renderSnapshotsList;\n\n    el('exportBtn').onclick = exportJson;\n    el('loadFromJsonBtn').onclick = () => {\n      const t = el('exportArea').value;\n      if (!t) { alert('Paste JSON into box first'); return; }\n      if (!confirm('Loading JSON will replace current stacks. Continue?')) return;\n      loadFromJson(t);\n    };\n\n    // Macro\n    el('runMacroBtn').onclick = () => {\n      if (macroState.running) { alert('Macro already running'); return; }\n      const text = el('macroTextarea').value;\n      runMacro(text, (ptr, step) => {\n        el('macroPointer').textContent = ptr;\n      }, () => {\n        log('MACRO_DONE');\n      });\n    };\n    el('stepMacroBtn').onclick = () => {\n      if (!macroState.running) {\n        // initialize\n        macroState.steps = parseMacro(el('macroTextarea').value);\n        macroState.pointer = 0;\n        macroState.running = false;\n      }\n      if (macroState.pointer >= macroState.steps.length) { alert('No more steps'); return; }\n      const step = macroState.steps[macroState.pointer];\n      executeMacroStep(step);\n      macroState.pointer++;\n      renderStatus();\n    };\n    el('stopMacroBtn').onclick = stopMacro;\n\n    el('pushRepeat').oninput = () => { renderStatus(); };\n\n    // Snapshots initial render\n    renderSnapshotsList();\n\n    el('activeStackSelect').onchange = renderStatus;\n    el('targetStackSelect').onchange = renderStatus;\n\n    // keyboard shortcuts\n    window.addEventListener('keydown', (ev) => {\n      if (ev.ctrlKey && ev.key === 'Enter') {\n        ev.preventDefault();\n        el('runMacroBtn').click();\n      } else if (!ev.ctrlKey && ev.key.toLowerCase() === 'p') {\n        el('pushBtn').click();\n      } else if (!ev.ctrlKey && ev.key.toLowerCase() === 'o') {\n        el('popBtn').click();\n      } else if (!ev.ctrlKey && ev.key.toLowerCase() === 'u') {\n        undo();\n      } else if (!ev.ctrlKey && ev.key.toLowerCase() === 'r') {\n        redo();\n      }\n    });\n  }\n\n  // Initialize with some stacks for exploration\n  function seed() {\n    stacks = [];\n    const s1 = createStack('A');\n    const s2 = createStack('B');\n    const s3 = createStack('C');\n    // push some varied items\n    s1.items.push({value:1,type:'number'});\n    s1.items.push({value:\"hello\",type:'string'});\n    s1.items.push({value:[1,2,3],type:'object'});\n    s2.items.push({value:42,type:'number'});\n    s2.items.push({value:{x:9},type:'object'});\n    s3.items.push({value:'apple',type:'string'});\n    // record history initial\n    pushHistory('initial seed');\n    renderAll();\n  }\n\n  // Wire and seed\n  wire();\n  seed();\n\n  // Expose for console debugging (optional)\n  window.StackPlayground = {\n    get state(){ return {stacks: deepCloneStacks(stacks), history: history}; },\n    pushItem: (v, parse='auto') => {\n      const t = getActiveStack();\n      if (!t) return;\n      t.items.push(createItemFromInput(String(v), parse));\n      pushHistory('external push');\n      renderAll();\n    }\n  };\n\n})();\n</script>\n</body>\n</html>"
