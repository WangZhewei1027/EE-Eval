  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Big-Omega Notation Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  textarea, input[type=number], input[type=text] {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  button {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n  }\n  #console {\n    width: 100%;\n    height: 10em;\n    white-space: pre;\n    overflow-y: scroll;\n    border: 1px solid black;\n    margin-top: 1em;\n    background: white;\n    padding: 0.5em;\n  }\n  fieldset {\n    margin-top: 1em;\n  }\n  legend {\n    font-weight: bold;\n  }\n  .grid {\n    display: grid;\n    grid-template-columns: auto auto auto auto;\n    gap: 0.3em 1em;\n    align-items: center;\n  }\n  .grid > * {\n    margin: 0;\n  }\n  .num-input-small {\n    width: 5em;\n  }\n</style>\n</head>\n<body>\n<h1>Big-Omega Notation Interactive Explorer</h1>\n\n<p>\nBig-Omega notation, Ω(g(n)), describes the asymptotic lower bound of a function f(n). Formally, <i>f(n) = Ω(g(n))</i> if there exist constants c > 0 and n<sub>0</sub> such that for all n ≥ n<sub>0</sub>, f(n) ≥ c·g(n).\n</p>\n\n<section>\n  <fieldset>\n    <legend>Step 1: Define Your Function f(n)</legend>\n    <label for=\"fn-raw\">Enter a function f(n) using 'n' as variable (e.g. 3*n*n + 5*n - 10):</label>\n    <textarea id=\"fn-raw\" aria-label=\"Function f of n\">3*n*n + 5*n - 10</textarea>\n    <button id=\"btn-parse-fn\">Parse f(n)</button>\n    <div id=\"fn-parse-msg\" aria-live=\"polite\"></div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Step 2: Define Your Comparison Function g(n)</legend>\n    <label for=\"gn-raw\">Enter a function g(n) using 'n' as variable (e.g. n*n):</label>\n    <textarea id=\"gn-raw\" aria-label=\"Function g of n\">n*n</textarea>\n    <button id=\"btn-parse-gn\">Parse g(n)</button>\n    <div id=\"gn-parse-msg\" aria-live=\"polite\"></div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Step 3: Choose Constants for Big-Omega Check</legend>\n    <label for=\"const-c\">Constant c (positive):</label>\n    <input id=\"const-c\" type=\"number\" step=\"any\" min=\"0.0001\" value=\"1\" />\n    <label for=\"const-n0\">Threshold n₀ (integer ≥ 1):</label>\n    <input id=\"const-n0\" type=\"number\" min=\"1\" step=\"1\" value=\"10\" />\n    <button id=\"btn-check-omega\">Check Big-Omega Condition f(n) ≥ c·g(n) for all n ≥ n₀</button>\n    <div id=\"omega-check-result\" aria-live=\"polite\"></div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Step 4: Explore Behavior for Various n</legend>\n    <label for=\"slider-n\">Choose n (≥ 1):</label>\n    <input type=\"range\" id=\"slider-n\" min=\"1\" max=\"1000\" value=\"10\" />\n    <output id=\"out-n\">10</output>\n    <div>\n      <button id=\"btn-decrease-n\">-</button>\n      <button id=\"btn-increase-n\">+</button>\n    </div>\n    <button id=\"btn-eval-functions\">Evaluate f(n) and c·g(n)</button>\n    <div id=\"eval-result\" aria-live=\"polite\"></div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Step 5: Automatic Search of Suitable c and n₀</legend>\n    <label for=\"search-c-max\">Max c to search (≥ 0.1):</label>\n    <input id=\"search-c-max\" type=\"number\" min=\"0.1\" step=\"any\" value=\"10\" />\n    <label for=\"search-n0-max\">Max n₀ to search (integer ≥ 1):</label>\n    <input id=\"search-n0-max\" type=\"number\" min=\"1\" step=\"1\" value=\"100\" />\n    <label for=\"search-step-n\">Step for n between n₀ and n₀+50 (integer ≥ 1):</label>\n    <input id=\"search-step-n\" type=\"number\" min=\"1\" step=\"1\" value=\"1\" />\n    <button id=\"btn-auto-search\">Find suitable c, n₀ automatically</button>\n    <div id=\"auto-search-result\" aria-live=\"polite\" style=\"white-space: pre-wrap;\"></div>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Step 6: Visual Function Evaluation (Text Table)</legend>\n    <label for=\"table-start-n\">Start n (integer ≥ 1):</label>\n    <input id=\"table-start-n\" type=\"number\" min=\"1\" step=\"1\" value=\"1\" />\n    <label for=\"table-end-n\">End n (integer ≥ start n):</label>\n    <input id=\"table-end-n\" type=\"number\" min=\"1\" step=\"1\" value=\"20\" />\n    <label for=\"table-step-n\">Step n (integer ≥ 1):</label>\n    <input id=\"table-step-n\" type=\"number\" min=\"1\" step=\"1\" value=\"1\" />\n    <button id=\"btn-generate-table\">Generate evaluation table</button>\n    <textarea id=\"eval-table\" readonly></textarea>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Step 7: Function Plot Data Export (CSV)</legend>\n    <label for=\"plot-start-n\">Start n (integer ≥ 1):</label>\n    <input id=\"plot-start-n\" type=\"number\" min=\"1\" step=\"1\" value=\"1\" />\n    <label for=\"plot-end-n\">End n (integer ≥ start n):</label>\n    <input id=\"plot-end-n\" type=\"number\" min=\"1\" step=\"1\" value=\"20\" />\n    <label for=\"plot-step-n\">Step n (integer ≥ 1):</label>\n    <input id=\"plot-step-n\" type=\"number\" min=\"1\" step=\"1\" value=\"1\" />\n    <label for=\"plot-c\">Value of constant c:</label>\n    <input id=\"plot-c\" type=\"number\" step=\"any\" min=\"0.0001\" value=\"1\" />\n    <button id=\"btn-export-csv\">Export CSV of n, f(n), c·g(n)</button>\n    <textarea id=\"csv-output\" readonly style=\"height:6em\"></textarea>\n  </fieldset>\n</section>\n\n<section>\n  <fieldset>\n    <legend>Console (Logs & Info)</legend>\n    <div id=\"console\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n    <button id=\"btn-clear-console\">Clear console</button>\n  </fieldset>\n</section>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // Simple safe math expression evaluator using Function constructor with restricted input\n  // Only arithmetic operators and 'n' variable allowed.\n  // We reject unsafe characters. This is minimal, for demo purpose.\n  function parseFunction(fnStr){\n    // Allowed chars: digits, n, whitespace, + - * / ^ % ( ), decimal point\n    // Replace ^ with ** for exponentiation\n    const safePattern = /^[0-9n+\\-*/%^().\\s]+$/i;\n    if(!safePattern.test(fnStr)){\n      throw new Error(\"Invalid characters detected. Only digits, n, + - * / % ^ ( ) and whitespace allowed.\");\n    }\n    // Replace ^ with ** for exponentiation (JS ES6+)\n    let jsExpr = fnStr.replace(/\\^/g,\"**\");\n    // Build function of n\n    // Extra protection: disallow consecutive operators like '**' except for exponentiation\n    // Here we trust the user minimally, so just create function:\n    let f;\n    try {\n      f = new Function(\"n\",\"return \"+jsExpr+\";\");\n      // Test if f runs on sample n:\n      let testv = f(1);\n      if(typeof testv !== \"number\" || isNaN(testv) || !isFinite(testv)){\n        throw new Error(\"Function evaluation did not return a valid number.\");\n      }\n    } catch(e) {\n      throw new Error(\"Invalid function expression: \"+e.message);\n    }\n    return f;\n  }\n\n  // Variables to store parsed functions\n  let f_of_n = null, g_of_n = null;\n\n  // DOM elements\n  const elFnRaw = document.getElementById(\"fn-raw\");\n  const elGnRaw = document.getElementById(\"gn-raw\");\n  const elBtnParseFn = document.getElementById(\"btn-parse-fn\");\n  const elBtnParseGn = document.getElementById(\"btn-parse-gn\");\n  const elFnMsg = document.getElementById(\"fn-parse-msg\");\n  const elGnMsg = document.getElementById(\"gn-parse-msg\");\n  const elConstC = document.getElementById(\"const-c\");\n  const elConstN0 = document.getElementById(\"const-n0\");\n  const elBtnCheckOmega = document.getElementById(\"btn-check-omega\");\n  const elOmegaResult = document.getElementById(\"omega-check-result\");\n  const elSliderN = document.getElementById(\"slider-n\");\n  const elOutN = document.getElementById(\"out-n\");\n  const elBtnDecN = document.getElementById(\"btn-decrease-n\");\n  const elBtnIncN = document.getElementById(\"btn-increase-n\");\n  const elBtnEvalFuns = document.getElementById(\"btn-eval-functions\");\n  const elEvalResult = document.getElementById(\"eval-result\");\n  const elSearchCMax = document.getElementById(\"search-c-max\");\n  const elSearchN0Max = document.getElementById(\"search-n0-max\");\n  const elSearchStepN = document.getElementById(\"search-step-n\");\n  const elBtnAutoSearch = document.getElementById(\"btn-auto-search\");\n  const elAutoSearchResult = document.getElementById(\"auto-search-result\");\n  const elTableStartN = document.getElementById(\"table-start-n\");\n  const elTableEndN = document.getElementById(\"table-end-n\");\n  const elTableStepN = document.getElementById(\"table-step-n\");\n  const elBtnGenTable = document.getElementById(\"btn-generate-table\");\n  const elEvalTable = document.getElementById(\"eval-table\");\n  const elPlotStartN = document.getElementById(\"plot-start-n\");\n  const elPlotEndN = document.getElementById(\"plot-end-n\");\n  const elPlotStepN = document.getElementById(\"plot-step-n\");\n  const elPlotC = document.getElementById(\"plot-c\");\n  const elBtnExportCSV = document.getElementById(\"btn-export-csv\");\n  const elCsvOutput = document.getElementById(\"csv-output\");\n  const elConsole = document.getElementById(\"console\");\n  const elBtnClearConsole = document.getElementById(\"btn-clear-console\");\n\n  // Helpers for console log\n  function logConsole(msg){\n    let now = new Date();\n    let timestamp = now.toLocaleTimeString();\n    elConsole.textContent += `[${timestamp}] ${msg}\\n`;\n    elConsole.scrollTop = elConsole.scrollHeight;\n  }\n  function clearConsole(){\n    elConsole.textContent = \"\";\n  }\n\n  // Parse f(n) input\n  elBtnParseFn.addEventListener(\"click\", () => {\n    const input = elFnRaw.value.trim();\n    if(!input){\n      elFnMsg.textContent = \"Input cannot be empty.\";\n      f_of_n = null;\n      logConsole(\"f(n) parse failed: empty input\");\n      return;\n    }\n    try {\n      let ffunc = parseFunction(input);\n      f_of_n = ffunc;\n      elFnMsg.textContent = \"f(n) parsed successfully.\";\n      logConsole(\"f(n) parsed: \" + input);\n    } catch(e){\n      elFnMsg.textContent = \"Error parsing f(n): \" + e.message;\n      f_of_n = null;\n      logConsole(\"f(n) parse error: \" + e.message);\n    }\n  });\n\n  // Parse g(n) input\n  elBtnParseGn.addEventListener(\"click\", () => {\n    const input = elGnRaw.value.trim();\n    if(!input){\n      elGnMsg.textContent = \"Input cannot be empty.\";\n      g_of_n = null;\n      logConsole(\"g(n) parse failed: empty input\");\n      return;\n    }\n    try {\n      let gfunc = parseFunction(input);\n      g_of_n = gfunc;\n      elGnMsg.textContent = \"g(n) parsed successfully.\";\n      logConsole(\"g(n) parsed: \" + input);\n    } catch(e){\n      elGnMsg.textContent = \"Error parsing g(n): \" + e.message;\n      g_of_n = null;\n      logConsole(\"g(n) parse error: \" + e.message);\n    }\n  });\n\n  // Update slider output\n  elSliderN.addEventListener(\"input\", () => {\n    let v = Number(elSliderN.value);\n    elOutN.value = v;\n  });\n  elOutN.value = elSliderN.value;\n\n  // Buttons + / - for n\n  elBtnDecN.addEventListener(\"click\", () => {\n    let v = Number(elSliderN.value);\n    if(v > Number(elSliderN.min)) {\n      elSliderN.value = v - 1;\n      elOutN.value = elSliderN.value;\n    }\n  });\n  elBtnIncN.addEventListener(\"click\", () => {\n    let v = Number(elSliderN.value);\n    if(v < Number(elSliderN.max)) {\n      elSliderN.value = v + 1;\n      elOutN.value = elSliderN.value;\n    }\n  });\n\n  // Check Big-Omega condition on interval n≥n0 for given c\n  elBtnCheckOmega.addEventListener(\"click\", () => {\n    elOmegaResult.textContent = \"\";\n    if(!f_of_n || !g_of_n){\n      elOmegaResult.textContent = \"Please parse valid functions f(n) and g(n) first.\";\n      logConsole(\"Big-Omega check aborted: functions not parsed\");\n      return;\n    }\n    let c = Number(elConstC.value);\n    let n0 = Number(elConstN0.value);\n    if(!(c > 0)){\n      elOmegaResult.textContent = \"Constant c must be a positive number.\";\n      logConsole(\"Big-Omega check aborted: invalid constant c\");\n      return;\n    }\n    if(!(Number.isInteger(n0) && n0 >= 1)){\n      elOmegaResult.textContent = \"Threshold n₀ must be an integer ≥ 1.\";\n      logConsole(\"Big-Omega check aborted: invalid n0\");\n      return;\n    }\n    // We'll sample many n values from n0 up to n0+200 for faster testing\n    // and verify f(n) >= c*g(n)\n    let allHold = true;\n    let violatedAt = null;\n    let maxCheck = n0 + 200;\n    for(let n = n0; n <= maxCheck; n++){\n      let fv, gv;\n      try {\n        fv = f_of_n(n);\n        gv = g_of_n(n);\n      } catch(e) {\n        elOmegaResult.textContent = \"Error evaluating functions at n=\"+n+\": \"+e.message;\n        logConsole(\"Evaluation error at n=\"+n+\": \"+e.message);\n        return;\n      }\n      if(typeof fv !== \"number\" || !isFinite(fv) ||\n         typeof gv !== \"number\" || !isFinite(gv)){\n        elOmegaResult.textContent = \"Non-finite number encountered at n=\"+n+\".\";\n        logConsole(\"Non-finite number at n=\"+n);\n        return;\n      }\n      if(fv < c*gv){\n        allHold = false;\n        violatedAt = n;\n        break;\n      }\n    }\n    if(allHold){\n      elOmegaResult.textContent = `Condition satisfied for all n in [${n0}, ${maxCheck}]: f(n) ≥ c·g(n)`;\n      logConsole(`Big-Omega condition holds for c=${c} and n₀=${n0} in tested range`);\n    } else {\n      elOmegaResult.textContent = `Condition fails at n = ${violatedAt}: f(n) < c·g(n)`;\n      logConsole(`Big-Omega condition fails at n=${violatedAt} for c=${c} and n₀=${n0}`);\n    }\n  });\n\n  // Evaluate f(n) and c*g(n) at user selected n\n  elBtnEvalFuns.addEventListener(\"click\", () => {\n    elEvalResult.textContent = \"\";\n    if(!f_of_n || !g_of_n){\n      elEvalResult.textContent = \"Please parse valid functions f(n) and g(n) first.\";\n      logConsole(\"Evaluation aborted: functions not parsed\");\n      return;\n    }\n    let n = Number(elSliderN.value);\n    let c = Number(elConstC.value);\n    if(n < 1 || !Number.isFinite(n)){\n      elEvalResult.textContent = \"Invalid value of n.\";\n      logConsole(\"Evaluation aborted: invalid n\");\n      return;\n    }\n    if(!(c > 0)){\n      elEvalResult.textContent = \"Constant c must be a positive number.\";\n      logConsole(\"Evaluation aborted: invalid c\");\n      return;\n    }\n    let fv, gv;\n    try {\n      fv = f_of_n(n);\n      gv = g_of_n(n);\n    } catch(e){\n      elEvalResult.textContent = \"Error evaluating functions at n=\"+n+\": \"+e.message;\n      logConsole(\"Evaluation error at n=\"+n+\": \"+e.message);\n      return;\n    }\n    if(typeof fv !== \"number\" || !isFinite(fv) ||\n       typeof gv !== \"number\" || !isFinite(gv)){\n      elEvalResult.textContent = \"Non-finite number encountered.\";\n      logConsole(\"Non-finite number at evaluation n=\"+n);\n      return;\n    }\n    elEvalResult.textContent = `At n = ${n}:\\nf(n) = ${fv}\\nc·g(n) = ${c} * ${gv} = ${c*gv}\\n`+\n                             (fv >= c*gv ? \"f(n) ≥ c·g(n) holds.\" : \"f(n) < c·g(n) FAILS.\");\n    logConsole(`Evaluated at n=${n}, f(n)=${fv}, c·g(n)=${c*gv}`);\n  });\n\n  // Auto search for suitable c and n0:\n  // For c from 0.1 to cMax (step 0.1)\n  // For n0 from 1 to n0Max\n  // For n from n0 to n0+50 stepping by stepN\n  // check if f(n) ≥ c*g(n) always holds\n  elBtnAutoSearch.addEventListener(\"click\", () => {\n    elAutoSearchResult.textContent = \"\";\n    if(!f_of_n || !g_of_n){\n      elAutoSearchResult.textContent = \"Please parse valid functions f(n) and g(n) first.\";\n      logConsole(\"Auto-search aborted: functions not parsed\");\n      return;\n    }\n    const cMax = Number(elSearchCMax.value);\n    const n0Max = Number(elSearchN0Max.value);\n    const stepN = Number(elSearchStepN.value);\n    if(!(cMax >= 0.1)){\n      elAutoSearchResult.textContent = \"Max c to search must be ≥ 0.1.\";\n      logConsole(\"Auto-search aborted: invalid cMax\");\n      return;\n    }\n    if(!(Number.isInteger(n0Max) && n0Max >= 1)){\n      elAutoSearchResult.textContent = \"Max n₀ to search must be an integer ≥ 1.\";\n      logConsole(\"Auto-search aborted: invalid n0Max\");\n      return;\n    }\n    if(!(Number.isInteger(stepN) && stepN >=1)){\n      elAutoSearchResult.textContent = \"Step for n must be integer ≥ 1.\";\n      logConsole(\"Auto-search aborted: invalid stepN\");\n      return;\n    }\n    // Disable button during processing\n    elBtnAutoSearch.disabled = true;\n    logConsole(\"Auto searching suitable constants...\");\n    setTimeout(() => {\n      let foundSolutions = [];\n      // We try c from 0.1 to cMax step 0.1\n      // Optimized: try only one decimal digit for c to limit output\n      const cStep = 0.1;\n      outerLoop:\n      for(let c = cStep; c <= cMax; c = +(c + cStep).toFixed(1)){\n        for(let n0 = 1; n0 <= n0Max; n0++){\n          let allHold = true;\n          for(let n = n0; n <= n0+50; n += stepN){\n            let fv, gv;\n            try {\n              fv = f_of_n(n);\n              gv = g_of_n(n);\n            } catch(e) {\n              allHold = false;\n              break;\n            }\n            if(typeof fv !== \"number\" || !isFinite(fv) ||\n               typeof gv !== \"number\" || !isFinite(gv)){\n              allHold = false;\n              break;\n            }\n            if(fv < c*gv){\n              allHold = false;\n              break;\n            }\n          }\n          if(allHold){\n            foundSolutions.push({c: +c.toFixed(2), n0});\n            // For rich exploration, don't break. Continue finding all pairs.\n            // We limit amount later or user can explore.\n            if(foundSolutions.length >= 20) break outerLoop;\n          }\n        }\n      }\n\n      if(foundSolutions.length === 0){\n        elAutoSearchResult.textContent = \"No suitable pairs (c, n₀) found in given search ranges.\";\n        logConsole(\"Auto-search found no solutions.\");\n      } else {\n        // Format result\n        let txt = \"Suitable (c, n₀) pairs found:\\n\";\n        for(let i=0;i<foundSolutions.length;i++) {\n          txt += `  c = ${foundSolutions[i].c}, n₀ = ${foundSolutions[i].n0}\\n`;\n        }\n        if(foundSolutions.length === 20){\n          txt += \"\\n[Showing first 20 results only]\";\n        }\n        elAutoSearchResult.textContent = txt;\n        logConsole(`Auto-search found ${foundSolutions.length} solutions.`);\n      }\n      elBtnAutoSearch.disabled = false;\n    }, 10);\n  });\n\n  // Generate evaluation text table for range of n\n  elBtnGenTable.addEventListener(\"click\", () => {\n    elEvalTable.value = \"\";\n    if(!f_of_n || !g_of_n){\n      elEvalTable.value = \"Please parse valid functions f(n) and g(n) first.\";\n      logConsole(\"Generate table aborted: functions not parsed\");\n      return;\n    }\n    let startN = Number(elTableStartN.value);\n    let endN = Number(elTableEndN.value);\n    let stepN = Number(elTableStepN.value);\n    if(!(Number.isInteger(startN) && startN >= 1)){\n      elEvalTable.value = \"Start n must be integer ≥ 1.\";\n      logConsole(\"Generate table aborted: invalid start n\");\n      return;\n    }\n    if(!(Number.isInteger(endN) && endN >= startN)){\n      elEvalTable.value = \"End n must be integer ≥ start n.\";\n      logConsole(\"Generate table aborted: invalid end n\");\n      return;\n    }\n    if(!(Number.isInteger(stepN) && stepN >= 1)){\n      elEvalTable.value = \"Step n must be integer ≥ 1.\";\n      logConsole(\"Generate table aborted: invalid step n\");\n      return;\n    }\n    let c = Number(elConstC.value);\n    if(!(c > 0)){\n      elEvalTable.value = \"Constant c must be positive.\";\n      logConsole(\"Generate table aborted: invalid c\");\n      return;\n    }\n    let lines = [];\n    lines.push(`n\\tf(n)\\tc·g(n)\\tf(n) ≥ c·g(n)?`);\n    for(let n=startN; n<=endN; n+=stepN){\n      let fv, gv;\n      try {\n        fv = f_of_n(n);\n        gv = g_of_n(n);\n      } catch(e) {\n        lines.push(`${n}\\tERROR\\tERROR\\tERROR`);\n        continue;\n      }\n      let isValid = (typeof fv === \"number\" && isFinite(fv)) &&\n                    (typeof gv === \"number\" && isFinite(gv));\n      if(!isValid){\n        lines.push(`${n}\\tNaN\\tNaN\\tNaN`);\n        continue;\n      }\n      let lhs = fv;\n      let rhs = c*gv;\n      let pass = (lhs >= rhs);\n      lines.push(`${n}\\t${lhs}\\t${rhs}\\t${pass ? \"YES\" : \"NO\"}`);\n    }\n    elEvalTable.value = lines.join(\"\\n\");\n    logConsole(`Generated evaluation table for n in [${startN},${endN}] step ${stepN}`);\n  });\n\n  // Export CSV text for plot data\n  elBtnExportCSV.addEventListener(\"click\", () => {\n    elCsvOutput.value = \"\";\n    if(!f_of_n || !g_of_n){\n      elCsvOutput.value = \"Please parse valid functions f(n) and g(n) first.\";\n      logConsole(\"CSV export aborted: functions not parsed\");\n      return;\n    }\n    let startN = Number(elPlotStartN.value);\n    let endN = Number(elPlotEndN.value);\n    let stepN = Number(elPlotStepN.value);\n    let c = Number(elPlotC.value);\n    if(!(Number.isInteger(startN) && startN >= 1)){\n      elCsvOutput.value = \"Start n must be integer ≥ 1.\";\n      logConsole(\"CSV export aborted: invalid start n\");\n      return;\n    }\n    if(!(Number.isInteger(endN) && endN >= startN)){\n      elCsvOutput.value = \"End n must be integer ≥ start n.\";\n      logConsole(\"CSV export aborted: invalid end n\");\n      return;\n    }\n    if(!(Number.isInteger(stepN) && stepN >= 1)){\n      elCsvOutput.value = \"Step n must be integer ≥ 1.\";\n      logConsole(\"CSV export aborted: invalid step n\");\n      return;\n    }\n    if(!(c > 0)){\n      elCsvOutput.value = \"Constant c must be positive.\";\n      logConsole(\"CSV export aborted: invalid c\");\n      return;\n    }\n    let lines = [];\n    lines.push(\"n,f(n),c*g(n)\");\n    for(let n=startN; n<=endN; n+=stepN){\n      let fv, gv;\n      try{\n        fv = f_of_n(n);\n        gv = g_of_n(n);\n      } catch(e){\n        lines.push(`${n},ERROR,ERROR`);\n        continue;\n      }\n      if(!(typeof fv === \"number\" && isFinite(fv) && typeof gv === \"number\" && isFinite(gv))){\n        lines.push(`${n},NaN,NaN`);\n        continue;\n      }\n      lines.push(`${n},${fv},${(c*gv)}`);\n    }\n    elCsvOutput.value = lines.join(\"\\n\");\n    logConsole(`Exported CSV plot data for n in [${startN},${endN}] step ${stepN}`);\n  });\n\n  // Clear console button\n  elBtnClearConsole.addEventListener(\"click\", () => {\n    clearConsole();\n  });\n\n  // Initial parse defaults\n  elBtnParseFn.click();\n  elBtnParseGn.click();\n})();\n</script>\n</body>\n</html>"
  },
  "messages": [
