    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Process — Elegant Visual Demonstration</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071026;\n    --accent1: #6ee7b7;\n    --accent2: #60a5fa;\n    --muted: #9aa7b2;\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --card-glow: rgba(96,165,250,0.12);\n    --glass-border: rgba(255,255,255,0.06);\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\",\n                 Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  /* Basic reset */\n  * { box-sizing: border-box; }\n  html,body { height:100%; margin:0; background: radial-gradient(1200px 600px at 10% 10%, rgba(96,165,250,0.06), transparent 6%),\n                                                radial-gradient(900px 500px at 90% 90%, rgba(110,231,183,0.03), transparent 6%),\n                                                linear-gradient(180deg,var(--bg1),var(--bg2)); color:#e6f0f6; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }\n  .scene {\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Decorative floating shapes */\n  .float-shape {\n    position:absolute;\n    filter: blur(28px) saturate(110%);\n    opacity:0.18;\n    transform-origin:center;\n    mix-blend-mode:screen;\n    will-change:transform;\n  }\n  .float-1{ width:420px; height:420px; left:-80px; top:-60px; background:linear-gradient(135deg,#2dd4bf,#60a5fa); border-radius:40%; animation: drift 14s ease-in-out infinite; }\n  .float-2{ width:320px; height:320px; right:-90px; bottom:-70px; background:linear-gradient(135deg,#7c3aed,#06b6d4); border-radius:45%; animation: drift 18s ease-in-out infinite reverse; opacity:0.12; }\n  @keyframes drift { 0%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-28px) rotate(12deg)} 100%{transform:translateY(0) rotate(0deg)} }\n\n  /* Main card */\n  .card {\n    width:100%;\n    max-width:1180px;\n    border-radius:20px;\n    padding:36px;\n    background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid var(--glass-border);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:visible;\n  }\n\n  .card::before{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    border-radius:20px;\n    pointer-events:none;\n    box-shadow: 0 40px 120px var(--card-glow);\n    mix-blend-mode:screen;\n    opacity:0.6;\n    transform:translateY(18px) scale(0.96);\n  }\n\n  /* Header */\n  .header {\n    display:flex;\n    align-items:flex-start;\n    gap:16px;\n    margin-bottom:22px;\n  }\n  .brand {\n    width:68px;\n    height:68px;\n    background: linear-gradient(135deg, rgba(110,231,183,0.14), rgba(96,165,250,0.18));\n    border-radius:14px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 6px 18px rgba(8,10,20,0.6), inset 0 1px 0 rgba(255,255,255,0.03);\n    border:1px solid rgba(255,255,255,0.04);\n  }\n  .brand svg { width:38px; height:38px; filter:drop-shadow(0 8px 20px rgba(36,74,120,0.12)); }\n\n  .title {\n    flex:1;\n  }\n  .title h1 {\n    margin:0;\n    font-size:20px;\n    letter-spacing:-0.02em;\n    color: #e9f9ff;\n    font-weight:600;\n  }\n  .title p {\n    margin:6px 0 0 0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Process layout */\n  .process-wrap {\n    display:flex;\n    gap:28px;\n    align-items:center;\n  }\n\n  .visual {\n    flex:1.2;\n    min-height:360px;\n    position:relative;\n    padding:26px;\n  }\n  .visual .stage-legend {\n    position:absolute;\n    right:28px;\n    top:26px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    width:220px;\n  }\n\n  .legend-item {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .legend-dot {\n    width:14px; height:14px; border-radius:50%;\n    background:linear-gradient(180deg,#0f1724,#173047);\n    box-shadow: 0 2px 8px rgba(3,10,18,0.6), inset 0 2px 4px rgba(255,255,255,0.02);\n    display:inline-flex; align-items:center; justify-content:center;\n  }\n  .legend-dot[data-color=\"1\"]{ background:linear-gradient(180deg,#6ee7b7,#2dd4bf); box-shadow:0 6px 18px rgba(46,204,183,0.12); }\n  .legend-dot[data-color=\"2\"]{ background:linear-gradient(180deg,#60a5fa,#3b82f6); box-shadow:0 6px 18px rgba(96,165,250,0.12); }\n  .legend-dot[data-color=\"3\"]{ background:linear-gradient(180deg,#a78bfa,#7c3aed); box-shadow:0 6px 18px rgba(124,58,237,0.12); }\n  .legend-dot[data-color=\"4\"]{ background:linear-gradient(180deg,#f472b6,#fb7185); box-shadow:0 6px 18px rgba(245,130,160,0.12); }\n  .legend-dot[data-color=\"5\"]{ background:linear-gradient(180deg,#facc15,#f97316); box-shadow:0 6px 18px rgba(249,115,22,0.12); }\n\n  /* Right panel (info) */\n  .info {\n    width:320px;\n    min-height:280px;\n    padding:22px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n    justify-content:space-between;\n  }\n  .info h3 { margin:0; font-size:15px; color:#e9f9ff; }\n  .info p { margin:0; color:var(--muted); font-size:13px; line-height:1.45; }\n\n  .progress-meta {\n    display:flex; gap:10px; align-items:center; color:var(--muted); font-size:13px;\n  }\n\n  /* Controls */\n  .controls {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:6px;\n  }\n  .btn {\n    appearance:none;\n    border:0;\n    cursor:pointer;\n    color:#e9f9ff;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:10px 14px;\n    border-radius:10px;\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n    box-shadow: 0 6px 18px rgba(2,8,20,0.5);\n    transition:transform .18s cubic-bezier(.2,.9,.2,1), box-shadow .18s;\n    border:1px solid rgba(255,255,255,0.03);\n    font-size:13px;\n  }\n  .btn:hover{ transform:translateY(-4px); box-shadow:0 14px 34px rgba(2,8,20,0.6); }\n  .btn:active{ transform:translateY(-1px); }\n\n  .btn-icon {\n    width:18px; height:18px; display:inline-block;\n  }\n\n  /* SVG visuals */\n  svg.process-svg { width:100%; height:360px; overflow:visible; }\n  .path-layer { fill:none; stroke: rgba(255,255,255,0.04); stroke-width:8; filter:drop-shadow(0 8px 30px rgba(2,10,30,0.4)); stroke-linecap:round; }\n  .path-glow { fill:none; stroke: url(#gradStroke); stroke-width:12; opacity:0.9; filter:blur(10px); stroke-linecap:round; mix-blend-mode:screen; }\n  .stage-node { cursor:default; }\n  .node-outer { fill:rgba(255,255,255,0.02); stroke:rgba(255,255,255,0.03); stroke-width:1; }\n  .node-inner { fill:var(--bg2); }\n  .node-ring { fill:none; stroke:rgba(255,255,255,0.03); stroke-width:2; }\n  .node-accent { stroke-width:3; stroke-linecap:round; }\n  .label { font-size:12px; fill:#e6f7ff; font-weight:600; }\n\n  /* Dot and trail */\n  .dot { pointer-events:none; transform-origin:center; filter:drop-shadow(0 12px 30px rgba(3,30,55,0.5)); }\n  .trail { opacity:0.9; mix-blend-mode:screen; }\n\n  /* Stage highlight animation */\n  .pulse {\n    transform-origin:center;\n    animation: pulseScale 1.1s cubic-bezier(.16,.9,.3,1) forwards;\n  }\n  @keyframes pulseScale {\n    0%{ transform:scale(1); opacity:1; }\n    40%{ transform:scale(1.14); opacity:1; }\n    100%{ transform:scale(1); opacity:0.98; }\n  }\n\n  /* Small micro-animations */\n  .sparkle {\n    position:absolute;\n    width:6px; height:6px;\n    border-radius:50%;\n    background:radial-gradient(circle at 30% 30%,#fff, rgba(255,255,255,0.2) 40%, transparent 60%);\n    transform:translate(-50%,-50%) scale(0.9);\n    opacity:0;\n    pointer-events:none;\n  }\n\n  /* Footer tip */\n  .foot {\n    margin-top:18px;\n    color:var(--muted);\n    font-size:13px;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .process-wrap { flex-direction:column; }\n    .info { width:100%; }\n    .visual .stage-legend { display:none; }\n    .card { padding:22px; }\n  }\n\n</style>\n</head>\n<body>\n<div class=\"scene\">\n  <div class=\"float-shape float-1\" aria-hidden=\"true\"></div>\n  <div class=\"float-shape float-2\" aria-hidden=\"true\"></div>\n\n  <div class=\"card\" role=\"region\" aria-label=\"Visual demonstration of a process\">\n    <div class=\"header\">\n      <div class=\"brand\" aria-hidden=\"true\">\n        <!-- abstract brand icon -->\n        <svg viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"b\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#6ee7b7\"/>\n              <stop offset=\"1\" stop-color=\"#60a5fa\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"6\" y=\"10\" width=\"52\" height=\"44\" rx=\"10\" fill=\"url(#b)\"/>\n          <path d=\"M18 30c6-10 20-10 26 0\" stroke=\"rgba(255,255,255,0.92)\" stroke-width=\"2.5\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <circle cx=\"28\" cy=\"26\" r=\"3.6\" fill=\"rgba(255,255,255,0.96)\"/>\n        </svg>\n      </div>\n\n      <div class=\"title\">\n        <h1>Process</h1>\n        <p>A graceful visualization of a process flow — discover, design, build, test, deploy. Observe the journey.</p>\n      </div>\n\n      <div style=\"width:86px; display:flex; flex-direction:column; gap:8px; align-items:flex-end;\">\n        <div class=\"progress-meta\" title=\"State\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9; transform:translateY(-2px);\">\n            <circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"2\" fill=\"none\"/>\n            <path d=\"M7 12.5L10 15l6-6\" stroke=\"url(#checkGrad)\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <defs>\n              <linearGradient id=\"checkGrad\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#6ee7b7\"/>\n                <stop offset=\"1\" stop-color=\"#60a5fa\"/>\n              </linearGradient>\n            </defs>\n          </svg>\n          <div style=\"margin-left:6px; font-size:13px; color:var(--muted);\">Autoplay</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"process-wrap\">\n      <div class=\"visual\">\n        <!-- SVG Visual -->\n        <svg class=\"process-svg\" viewBox=\"0 0 1100 380\" preserveAspectRatio=\"xMidYMid meet\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"gradStroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#6ee7b7\"/>\n              <stop offset=\"0.45\" stop-color=\"#60a5fa\"/>\n              <stop offset=\"0.75\" stop-color=\"#a78bfa\"/>\n              <stop offset=\"1\" stop-color=\"#f97316\"/>\n            </linearGradient>\n\n            <filter id=\"softDrop\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"18\" result=\"blur\"/>\n              <feMerge><feMergeNode in=\"blur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n            </filter>\n\n            <filter id=\"innerGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n              <feComposite in=\"SourceGraphic\" in2=\"b\" operator=\"over\"/>\n            </filter>\n          </defs>\n\n          <!-- path base -->\n          <path id=\"mainPath\" d=\"M90 260 C 250 60, 430 60, 520 260 C 610 460, 800 460, 980 260\"\n                class=\"path-layer\" />\n\n          <!-- glow overlay -->\n          <path d=\"M90 260 C 250 60, 430 60, 520 260 C 610 460, 800 460, 980 260\"\n                class=\"path-glow\" opacity=\"0.18\" />\n\n          <!-- stage nodes -->\n          <!-- positions computed to match path; we will sample in JS too -->\n          <g id=\"stages\">\n            <g class=\"stage-node\" data-id=\"0\" transform=\"translate(90,260)\">\n              <circle class=\"node-outer\" r=\"36\"></circle>\n              <circle class=\"node-inner\" r=\"28\"></circle>\n              <circle cx=\"0\" cy=\"0\" r=\"20\" class=\"node-ring\" />\n              <circle cx=\"-0.5\" cy=\"-0.5\" r=\"8\" fill=\"url(#g1)\" stroke=\"#6ee7b7\" stroke-width=\"2\" class=\"node-accent\" />\n              <text x=\"0\" y=\"62\" class=\"label\" text-anchor=\"middle\">Discover</text>\n            </g>\n\n            <g class=\"stage-node\" data-id=\"1\" transform=\"translate(280,120)\">\n              <circle class=\"node-outer\" r=\"36\"></circle>\n              <circle class=\"node-inner\" r=\"28\"></circle>\n              <circle cx=\"0\" cy=\"0\" r=\"20\" class=\"node-ring\" />\n              <circle cx=\"-0.5\" cy=\"-0.5\" r=\"8\" fill=\"url(#g2)\" stroke=\"#60a5fa\" stroke-width=\"2\" class=\"node-accent\" />\n              <text x=\"0\" y=\"62\" class=\"label\" text-anchor=\"middle\">Design</text>\n            </g>\n\n            <g class=\"stage-node\" data-id=\"2\" transform=\"translate(430,100)\">\n              <circle class=\"node-outer\" r=\"36\"></circle>\n              <circle class=\"node-inner\" r=\"28\"></circle>\n              <circle cx=\"0\" cy=\"0\" r=\"20\" class=\"node-ring\" />\n              <circle cx=\"-0.5\" cy=\"-0.5\" r=\"8\" fill=\"url(#g3)\" stroke=\"#a78bfa\" stroke-width=\"2\" class=\"node-accent\" />\n              <text x=\"0\" y=\"62\" class=\"label\" text-anchor=\"middle\">Build</text>\n            </g>\n\n            <g class=\"stage-node\" data-id=\"3\" transform=\"translate(640,220)\">\n              <circle class=\"node-outer\" r=\"36\"></circle>\n              <circle class=\"node-inner\" r=\"28\"></circle>\n              <circle cx=\"0\" cy=\"0\" r=\"20\" class=\"node-ring\" />\n              <circle cx=\"-0.5\" cy=\"-0.5\" r=\"8\" fill=\"url(#g4)\" stroke=\"#fb7185\" stroke-width=\"2\" class=\"node-accent\" />\n              <text x=\"0\" y=\"62\" class=\"label\" text-anchor=\"middle\">Test</text>\n            </g>\n\n            <g class=\"stage-node\" data-id=\"4\" transform=\"translate(980,260)\">\n              <circle class=\"node-outer\" r=\"36\"></circle>\n              <circle class=\"node-inner\" r=\"28\"></circle>\n              <circle cx=\"0\" cy=\"0\" r=\"20\" class=\"node-ring\" />\n              <circle cx=\"-0.5\" cy=\"-0.5\" r=\"8\" fill=\"url(#g5)\" stroke=\"#f97316\" stroke-width=\"2\" class=\"node-accent\" />\n              <text x=\"0\" y=\"62\" class=\"label\" text-anchor=\"middle\">Deploy</text>\n            </g>\n          </g>\n\n          <!-- moving dot & trail -->\n          <g id=\"moving\">\n            <!-- trails will be injected dynamically -->\n            <g id=\"trailLayer\" class=\"trail\"></g>\n            <g class=\"dot\" id=\"leadDot\">\n              <defs>\n                <radialGradient id=\"dotGrad\" cx=\"35%\" cy=\"30%\">\n                  <stop offset=\"0%\" stop-color=\"#fff\"/>\n                  <stop offset=\"35%\" stop-color=\"#dffcff\"/>\n                  <stop offset=\"100%\" stop-color=\"#60a5fa\"/>\n                </radialGradient>\n              </defs>\n              <circle r=\"10\" fill=\"url(#dotGrad)\" stroke=\"rgba(255,255,255,0.18)\" stroke-width=\"1.5\"></circle>\n              <circle r=\"5.6\" fill=\"rgba(255,255,255,0.06)\"></circle>\n            </g>\n          </g>\n\n          <!-- defs for small node accents -->\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#6ee7b7\"/><stop offset=\"1\" stop-color=\"#2dd4bf\"/>\n            </linearGradient>\n            <linearGradient id=\"g2\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#60a5fa\"/><stop offset=\"1\" stop-color=\"#3b82f6\"/>\n            </linearGradient>\n            <linearGradient id=\"g3\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#a78bfa\"/><stop offset=\"1\" stop-color=\"#7c3aed\"/>\n            </linearGradient>\n            <linearGradient id=\"g4\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#fb7185\"/><stop offset=\"1\" stop-color=\"#f472b6\"/>\n            </linearGradient>\n            <linearGradient id=\"g5\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#facc15\"/><stop offset=\"1\" stop-color=\"#f97316\"/>\n            </linearGradient>\n          </defs>\n        </svg>\n\n        <!-- stage legend (for reference) -->\n        <div class=\"stage-legend\" aria-hidden=\"true\">\n          <div class=\"legend-item\"><div class=\"legend-dot\" data-color=\"1\"></div><div>Discover</div></div>\n          <div class=\"legend-item\"><div class=\"legend-dot\" data-color=\"2\"></div><div>Design</div></div>\n          <div class=\"legend-item\"><div class=\"legend-dot\" data-color=\"3\"></div><div>Build</div></div>\n          <div class=\"legend-item\"><div class=\"legend-dot\" data-color=\"4\"></div><div>Test</div></div>\n          <div class=\"legend-item\"><div class=\"legend-dot\" data-color=\"5\"></div><div>Deploy</div></div>\n        </div>\n\n        <!-- micro sparkles (decorative) -->\n        <div class=\"sparkle\" id=\"spark1\" style=\"left:220px; top:78px;\"></div>\n        <div class=\"sparkle\" id=\"spark2\" style=\"left:620px; top:120px;\"></div>\n        <div class=\"sparkle\" id=\"spark3\" style=\"left:830px; top:220px;\"></div>\n\n      </div>\n\n      <div class=\"info\" aria-hidden=\"false\">\n        <div>\n          <h3>Pipeline — Stages & Motion</h3>\n          <p>Watch a single element traverse an elegant, curved path connecting five thoughtfully designed stages. Each stage softly pulses as the element passes — representing milestones in a process.</p>\n        </div>\n\n        <div>\n          <div class=\"controls\" role=\"group\" aria-label=\"Playback controls\">\n            <button id=\"playBtn\" class=\"btn\" title=\"Pause animation (space)\" aria-pressed=\"false\">\n              <svg class=\"btn-icon\" viewBox=\"0 0 24 24\"><path id=\"playIcon\" d=\"M6 4l14 8-14 8V4z\" fill=\"currentColor\"></path></svg>\n              <span style=\"font-size:13px; color:var(--muted);\">Pause</span>\n            </button>\n\n            <button id=\"resetBtn\" class=\"btn\" title=\"Reset animation\" aria-pressed=\"false\">\n              <svg class=\"btn-icon\" viewBox=\"0 0 24 24\"><path d=\"M12 6V3L8 7l4 4V8c2.76 0 5 2.24 5 5s-2.24 5-5 5a5 5 0 0 1-4.9-4H5.1a7 7 0 1 0 7-7z\" fill=\"currentColor\" opacity=\"0.92\"/></svg>\n              <span style=\"font-size:13px; color:var(--muted);\">Reset</span>\n            </button>\n          </div>\n        </div>\n\n        <div style=\"display:flex; justify-content:space-between; align-items:center; gap:6px;\">\n          <div style=\"font-size:13px; color:var(--muted);\">Animation speed: <strong id=\"speedVal\" style=\"color:#e9f9ff\">1x</strong></div>\n          <div style=\"font-size:12px; color:var(--muted);\">Minimal controls — mostly view only.</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"foot\">\n      <div>Refined visualization • Smooth transitions • Focused clarity</div>\n      <div style=\"opacity:0.6; font-size:13px;\">© Visual Design</div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Grab elements\n  const svg = document.querySelector('.process-svg');\n  const pathEl = svg.querySelector('#mainPath');\n  const leadDot = svg.querySelector('#leadDot');\n  const trailLayer = svg.querySelector('#trailLayer');\n  const stageNodes = Array.from(svg.querySelectorAll('.stage-node'));\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const speedVal = document.getElementById('speedVal');\n  const spark1 = document.getElementById('spark1');\n  const spark2 = document.getElementById('spark2');\n  const spark3 = document.getElementById('spark3');\n\n  // Prepare path and positions\n  const pathLength = pathEl.getTotalLength();\n  const stages = [];\n  // For each stage element, get its position relative to path by mapping its transform translate\n  stageNodes.forEach(node => {\n    const t = node.getAttribute('transform'); // e.g. translate(x,y)\n    const match = /translate\\(([^,]+),\\s*([^)]+)\\)/.exec(t);\n    if(match){\n      const x = parseFloat(match[1]), y = parseFloat(match[2]);\n      // Find closest point along path by sampling\n      let best = {d:Infinity, len:0};\n      const samples = 200;\n      for(let i=0;i<=samples;i++){\n        const l = i/samples * pathLength;\n        const p = pathEl.getPointAtLength(l);\n        const d = Math.hypot(p.x - x, p.y - y);\n        if(d < best.d){ best = {d, len:l}; }\n      }\n      stages.push({node, x,y, offset: best.len});\n    } else {\n      stages.push({node, x:0,y:0, offset:0});\n    }\n  });\n\n  // Sort stages by offset to ensure order\n  stages.sort((a,b) => a.offset - b.offset);\n\n  // Animation variables\n  let startTime = null;\n  let paused = false;\n  let progress = 0; // 0 to 1 (normalized)\n  let speed = 1; // multiplier\n  const duration = 9000; // ms for full loop at 1x\n  let lastStageIndex = -1;\n\n  // Create trail elements (fading ghost copies)\n  const TRAIL_COUNT = 8;\n  const trailEls = [];\n  for(let i=0;i<TRAIL_COUNT;i++){\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('opacity', String((1 - i/TRAIL_COUNT) * 0.9));\n    const c = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    c.setAttribute('r', String(10 - i*0.9));\n    c.setAttribute('fill', 'url(#dotGrad)');\n    c.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n    c.setAttribute('stroke-width', '1');\n    g.appendChild(c);\n    trailLayer.appendChild(g);\n    trailEls.push(g);\n  }\n\n  // micro sparkles helper\n  function fireSpark(el){\n    el.style.opacity = 1;\n    el.style.transform = 'translate(-50%,-50%) scale(1)';\n    el.animate([\n      { transform: 'translate(-50%,-50%) scale(.75)', opacity: 0.0 },\n      { transform: 'translate(-50%,-50%) scale(1.0)', opacity: 1 },\n      { transform: 'translate(-50%,-50%) translateY(-10px) scale(.6)', opacity: 0 }\n    ], { duration: 1200, easing: 'cubic-bezier(.2,.8,.2,1)'});\n    setTimeout(()=>{ el.style.opacity=0; }, 1100);\n  }\n\n  // Animation loop\n  function tick(ts){\n    if(startTime === null) startTime = ts;\n    if(!paused){\n      const elapsed = (ts - startTime) * speed;\n      progress = (elapsed % (duration)) / duration;\n    } else {\n      // slightly increment to keep micro motion minimal\n      progress += 0;\n    }\n\n    // compute length along path (with easing to slow in/out nicely)\n    const easedProgress = easeInOutCubic(progress);\n    const length = easedProgress * pathLength;\n    const p = pathEl.getPointAtLength(length);\n    leadDot.setAttribute('transform', `translate(${p.x}, ${p.y})`);\n\n    // trail positions (lagged progress)\n    for(let i=0;i<trailEls.length;i++){\n      const lag = (i+1) * 0.012 * (1 + 0.25 * i);\n      let tprog = progress - lag;\n      if(tprog < 0) tprog += 1;\n      const tlen = easeInOutCubic(tprog) * pathLength;\n      const pt = pathEl.getPointAtLength(tlen);\n      trailEls[i].setAttribute('transform', `translate(${pt.x}, ${pt.y})`);\n      // subtle scale for tail\n      const scale = 1 - i * 0.06;\n      trailEls[i].firstChild.setAttribute('r', String(10 * scale));\n      trailEls[i].setAttribute('opacity', String((1 - i/trailEls.length) * 0.9));\n    }\n\n    // Stage hit detection — find closest stage by offset and trigger pulse if crossed\n    let currentStageIndex = -1;\n    for(let i=0;i<stages.length;i++){\n      const s = stages[i];\n      const stProg = s.offset / pathLength;\n      // consider it reached if progress within small window\n      const diff = Math.abs(normalizeProgress(progress - stProg));\n      if(diff < 0.03) {\n        currentStageIndex = i;\n        break;\n      }\n    }\n    if(currentStageIndex !== -1 && currentStageIndex !== lastStageIndex){\n      // pulse effect\n      const el = stages[currentStageIndex].node;\n      animatePulse(el);\n      fireSpark(document.getElementById('spark' + ((currentStageIndex % 3) + 1)));\n      lastStageIndex = currentStageIndex;\n    }\n    if(currentStageIndex === -1){\n      lastStageIndex = -1;\n    }\n\n    // mild parallax on background floats\n    const floats = document.querySelectorAll('.float-shape');\n    floats.forEach((f, idx) => {\n      const r = Math.sin((ts/6000) + idx) * 12;\n      f.style.transform = `translateY(${r}px) rotate(${r*0.7}deg)`;\n    });\n\n    requestAnimationFrame(tick);\n  }\n\n  // helpers\n  function easeInOutCubic(t){\n    return t<0.5 ? 4*t*t*t : 1 - Math.pow(-2*t + 2, 3)/2;\n  }\n  function normalizeProgress(p){\n    // ensure within -0.5..0.5\n    let v = ((p + 0.5) % 1) - 0.5;\n    return v;\n  }\n\n  function animatePulse(node){\n    const inner = node.querySelector('.node-inner');\n    const ring = node.querySelector('.node-ring');\n    // add pulse class for subtle scale\n    node.classList.add('pulse');\n    inner.animate([\n      { r: 28, transform: 'scale(1)' },\n      { transform: 'scale(1.06)' },\n      { transform: 'scale(1)' }\n    ], { duration: 700, easing: 'cubic-bezier(.2,.9,.3,1)' });\n    // accent glow\n    const accent = node.querySelector('.node-accent');\n    if(accent){\n      accent.animate([\n        { transform: 'scale(1)', opacity: 1 },\n        { transform: 'scale(1.8)', opacity: 0.0 }\n      ], { duration: 900, easing: 'cubic-bezier(.2,.9,.3,1)' });\n    }\n    setTimeout(()=>{ node.classList.remove('pulse'); }, 900);\n  }\n\n  // Play/pause control\n  playBtn.addEventListener('click', () => {\n    paused = !paused;\n    playBtn.setAttribute('aria-pressed', String(paused));\n    const icon = playBtn.querySelector('#playIcon');\n    const label = playBtn.querySelector('span');\n    if(paused){\n      // show play icon\n      icon.setAttribute('d','M6 4l14 8-14 8V4z');\n      label.textContent = 'Play';\n    } else {\n      // show pause icon\n      icon.setAttribute('d','M6 5h4v14H6zM14 5h4v14h-4z');\n      label.textContent = 'Pause';\n    }\n  });\n\n  // Keyboard space toggles\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space' || e.key === ' '){\n      e.preventDefault();\n      playBtn.click();\n    }\n    if(e.code === 'ArrowUp'){\n      // increase speed\n      speed = Math.min(3, speed + 0.25);\n      speedVal.textContent = speed.toFixed(2).replace(/\\.00$/, 'x');\n    }\n    if(e.code === 'ArrowDown'){\n      speed = Math.max(0.25, speed - 0.25);\n      speedVal.textContent = speed.toFixed(2).replace(/\\.00$/, 'x');\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    startTime = performance.now();\n    progress = 0;\n    lastStageIndex = -1;\n    // small reset animation\n    leadDot.animate([{ transform: 'translate(90px,260px) scale(.9)' }, { transform: 'translate(90px,260px) scale(1)' }], { duration: 450, easing: 'cubic-bezier(.2,.9,.3,1)'});\n  });\n\n  // Initialize UI icons for pause state (autoplay initial: not paused)\n  (function initIcons(){\n    const icon = playBtn.querySelector('#playIcon');\n    icon.setAttribute('d','M6 5h4v14H6zM14 5h4v14h-4z'); // pause\n    playBtn.querySelector('span').textContent = 'Pause';\n    speedVal.textContent = speed.toFixed(2).replace(/\\.00$/, 'x');\n  })();\n\n  // Kick off\n  requestAnimationFrame(tick);\n\n  // Small aesthetic entrance (stages fade up)\n  setTimeout(() => {\n    stageNodes.forEach((n, i) => {\n      n.style.opacity = 0;\n      n.animate([{ transform: 'translateY(12px)', opacity: 0 }, { transform: 'translateY(0)', opacity: 1 }], { duration: 700, delay: i*80, easing: 'cubic-bezier(.2,.9,.3,1)', fill: 'forwards' });\n    });\n  }, 220);\n\n})();\n</script>\n</body>\n</html>"
  },
