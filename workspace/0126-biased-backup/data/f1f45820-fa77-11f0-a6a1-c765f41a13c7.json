    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Linked List — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071025;\n      --glass: rgba(255,255,255,0.04);\n      --card: rgba(255,255,255,0.03);\n      --muted: rgba(255,255,255,0.6);\n      --accent: #6EE7B7;\n      --accent-2: #7C5CFF;\n      --highlight: #FFD166;\n      --soft-shadow: 0 10px 30px rgba(2,6,23,0.6);\n      --glass-border: rgba(255,255,255,0.06);\n      --node-bg: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.12), transparent 10%),\n                  radial-gradient(900px 500px at 95% 90%, rgba(110,231,183,0.06), transparent 10%),\n                  linear-gradient(180deg,var(--bg1),var(--bg2));\n      color: #E9F0F6;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    .app {\n      width: min(1180px, 94vw);\n      margin: 48px auto;\n      padding: 28px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius: 18px;\n      box-shadow: var(--soft-shadow);\n      border: 1px solid var(--glass-border);\n      backdrop-filter: blur(8px) saturate(120%);\n      position: relative;\n      overflow: hidden;\n    }\n\n    /* Decorative corner gradients */\n    .app::before, .app::after {\n      content: \"\";\n      position: absolute;\n      width: 380px;\n      height: 380px;\n      filter: blur(60px);\n      pointer-events: none;\n      opacity: 0.9;\n    }\n    .app::before {\n      right: -120px;\n      top: -160px;\n      background: conic-gradient(from 200deg at 50% 50%, rgba(124,92,255,0.18), rgba(110,231,183,0.06));\n      transform: rotate(8deg);\n    }\n    .app::after {\n      left: -160px;\n      bottom: -120px;\n      background: conic-gradient(from 20deg at 50% 50%, rgba(110,231,183,0.06), rgba(255,209,102,0.04));\n      transform: rotate(-8deg);\n    }\n\n    header {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:20px;\n      margin-bottom: 22px;\n    }\n    .title {\n      display:flex;\n      gap:18px;\n      align-items:center;\n    }\n    .logo {\n      width:64px;\n      height:64px;\n      border-radius:12px;\n      background: linear-gradient(135deg, rgba(124,92,255,0.12), rgba(110,231,183,0.06));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      border: 1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 6px 20px rgba(124,92,255,0.08), inset 0 -6px 18px rgba(0,0,0,0.25);\n    }\n    .logo svg { width:44px; height:44px; filter: drop-shadow(0 6px 18px rgba(0,0,0,0.45)); }\n\n    h1 {\n      font-family: \"Playfair Display\", serif;\n      font-weight:700;\n      margin:0;\n      font-size:20px;\n      letter-spacing: -0.02em;\n      color: #FFF;\n    }\n    p.lead {\n      margin:0;\n      color: var(--muted);\n      font-size:13px;\n      max-width:640px;\n    }\n\n    .controls {\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n    .btn {\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.04);\n      color: #fff;\n      padding:10px 14px;\n      border-radius:12px;\n      cursor:pointer;\n      font-weight:600;\n      font-size:13px;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      transition: transform .18s cubic-bezier(.2,.9,.2,1), box-shadow .18s;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n      backdrop-filter: blur(6px);\n    }\n    .btn:active { transform: translateY(1px) scale(.997); }\n    .btn.secondary {\n      background: linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.008));\n      color: var(--muted);\n      border: 1px solid rgba(255,255,255,0.03);\n      font-weight:600;\n    }\n    .btn .dot {\n      width:10px;height:10px;border-radius:50%;\n      background: linear-gradient(180deg, var(--accent), var(--accent-2));\n      box-shadow: 0 6px 16px rgba(124,92,255,0.16), 0 0 10px rgba(110,231,183,0.06);\n    }\n\n    /* Visualization area */\n    .visual {\n      margin-top:18px;\n      display:flex;\n      gap:20px;\n      align-items:center;\n      justify-content:center;\n      padding:34px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border: 1px solid rgba(255,255,255,0.02);\n      position:relative;\n      min-height:240px;\n      overflow:visible;\n    }\n\n    .list {\n      display:flex;\n      align-items:center;\n      gap:28px;\n      position:relative;\n      z-index:2;\n    }\n\n    .node {\n      width:160px;\n      height:72px;\n      border-radius:14px;\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      padding:12px 12px 12px 18px;\n      box-shadow: 0 8px 28px rgba(2,6,23,0.5), inset 0 -4px 12px rgba(255,255,255,0.01);\n      background: var(--node-bg);\n      border: 1px solid rgba(255,255,255,0.04);\n      transition: transform .36s cubic-bezier(.2,.9,.2,1), box-shadow .28s, filter .28s;\n      transform-origin: center;\n      position:relative;\n      overflow:visible;\n      backdrop-filter: blur(6px) saturate(120%);\n      opacity:0;\n      transform: translateY(22px) scale(.98);\n    }\n    .node.enter {\n      opacity:1;\n      transform: translateY(0) scale(1);\n    }\n\n    .payload {\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n    }\n    .payload .value {\n      font-weight:700;\n      font-size:20px;\n      letter-spacing:-0.02em;\n      color: #fff;\n    }\n    .payload .meta {\n      font-size:12px;\n      color:var(--muted);\n      display:flex;\n      gap:8px;\n      align-items:center;\n    }\n\n    .ptr {\n      width:46px;\n      height:46px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n      border-radius:10px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      border: 1px solid rgba(255,255,255,0.04);\n      font-size:18px;\n      color: var(--muted);\n      position:relative;\n      transition: background .22s, transform .18s;\n    }\n\n    .node.active {\n      box-shadow: 0 18px 40px rgba(124,92,255,0.12), 0 4px 30px rgba(2,6,23,0.6);\n      transform: translateY(-6px) scale(1.02);\n      z-index:5;\n      filter: saturate(1.08);\n    }\n\n    .node .halo {\n      position:absolute;\n      inset: -12px;\n      border-radius: 18px;\n      pointer-events:none;\n      background: radial-gradient(ellipse at center, rgba(124,92,255,0.14), rgba(110,231,183,0.03) 30%, transparent 40%);\n      opacity:0;\n      transform: scale(.98);\n      transition: opacity .28s, transform .28s;\n      mix-blend-mode: screen;\n    }\n    .node.active .halo {\n      opacity:1;\n      transform: scale(1);\n    }\n\n    /* Arrow SVG overlay */\n    .arrows {\n      position:absolute;\n      left:0;right:0;top:0;bottom:0;\n      pointer-events:none;\n      z-index:1;\n    }\n    svg { overflow:visible; }\n\n    /* Stroke reveal animation control class */\n    .reveal {\n      stroke-dasharray: 300;\n      stroke-dashoffset: 300;\n      animation: dash 600ms cubic-bezier(.2,.9,.2,1) forwards;\n      animation-delay: 0s;\n    }\n    @keyframes dash {\n      to { stroke-dashoffset: 0; }\n    }\n\n    /* Traversal pulse */\n    .pulse {\n      position:absolute;\n      width:82px;height:82px;border-radius:50%;\n      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.06), transparent 30%);\n      pointer-events:none;\n      top:0;left:0;\n      transform: translate(-8px,-8px) scale(.6);\n      opacity:0;\n      transition: opacity .28s, transform .5s;\n      box-shadow: 0 12px 28px rgba(124,92,255,0.12);\n    }\n    .node.active .pulse { opacity:1; transform: translate(-8px,-24px) scale(1); }\n\n    /* Footer / league */\n    .legend {\n      margin-top:22px;\n      display:flex;\n      gap:18px;\n      align-items:center;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    /* Responsive */\n    @media (max-width:920px){\n      .list { gap:18px; flex-wrap:wrap; justify-content:center; }\n      .node { width:140px; height:64px; padding:10px; }\n      .visual { padding:20px; min-height:320px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\" role=\"main\" aria-label=\"Linked List visualization\">\n    <header>\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7C5CFF\"/>\n                <stop offset=\"1\" stop-color=\"#6EE7B7\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"8\" width=\"52\" height=\"48\" rx=\"10\" fill=\"url(#g1)\" opacity=\"0.18\"/>\n            <path d=\"M20 36c4-8 12-8 16 0\" stroke=\"url(#g1)\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <circle cx=\"22\" cy=\"28\" r=\"3.8\" fill=\"#fff\" opacity=\"0.88\"/>\n            <circle cx=\"38\" cy=\"28\" r=\"3.8\" fill=\"#fff\" opacity=\"0.88\"/>\n          </svg>\n        </div>\n        <div>\n          <h1>Linked List — Conceptual Flow</h1>\n          <p class=\"lead\">A minimal, refined exploration of a singly linked list. Observe nodes, pointers, and traversal — thoughtfully animated for clarity and aesthetic delight.</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"playBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Play / Pause traversal\">\n          <span class=\"dot\" id=\"playDot\" style=\"background:linear-gradient(180deg,#FFD166,#FF9F1C);\"></span>\n          <span id=\"playLabel\">Play</span>\n        </button>\n        <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset visualization\">Reset</button>\n      </div>\n    </header>\n\n    <div class=\"visual\" aria-hidden=\"false\">\n      <div class=\"list\" id=\"list\">\n        <!-- Nodes will be injected -->\n      </div>\n\n      <svg class=\"arrows\" id=\"arrows\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <defs>\n          <marker id=\"arrow\" viewBox=\"0 0 10 10\" refX=\"9.5\" refY=\"5\" markerWidth=\"8\" markerHeight=\"8\" orient=\"auto-start-reverse\">\n            <path d=\"M0 0 L10 5 L0 10 z\" fill=\"#9AE6B4\" opacity=\"0.95\"></path>\n          </marker>\n          <marker id=\"arrow-dark\" viewBox=\"0 0 10 10\" refX=\"9.5\" refY=\"5\" markerWidth=\"8\" markerHeight=\"8\" orient=\"auto-start-reverse\">\n            <path d=\"M0 0 L10 5 L0 10 z\" fill=\"#7C5CFF\" opacity=\"0.92\"></path>\n          </marker>\n        </defs>\n        <!-- Paths inserted by JS -->\n      </svg>\n    </div>\n\n    <div class=\"legend\">\n      <div style=\"display:flex;align-items:center;gap:10px;\">\n        <div style=\"width:12px;height:12px;border-radius:3px;background:linear-gradient(180deg,#7C5CFF,#6EE7B7);box-shadow:0 6px 16px rgba(124,92,255,0.08)\"></div>\n        Node (value + pointer)\n      </div>\n      <div style=\"display:flex;align-items:center;gap:10px;\">\n        <svg width=\"18\" height=\"10\" viewBox=\"0 0 50 12\"><path d=\"M2 6h40\" stroke=\"#9AE6B4\" stroke-width=\"2.6\" stroke-linecap=\"round\"/></svg>\n        Link (pointer to next)\n      </div>\n      <div style=\"display:flex;align-items:center;gap:10px;\">\n        <div style=\"width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.06)\"></div>\n        Null / End\n      </div>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      /* Data */\n      const values = [13, 27, 31, 42, 58, 73];\n      const container = document.getElementById('list');\n      const svg = document.getElementById('arrows');\n      const playBtn = document.getElementById('playBtn');\n      const playLabel = document.getElementById('playLabel');\n      const playDot = document.getElementById('playDot');\n      const resetBtn = document.getElementById('resetBtn');\n\n      let nodes = [];\n      let paths = [];\n      let idx = -1;\n      let running = false;\n      let tickTimer = null;\n\n      /* Build nodes */\n      function createNode(val, i) {\n        const el = document.createElement('div');\n        el.className = 'node';\n        el.dataset.index = i;\n\n        el.innerHTML = `\n          <div class=\"halo\"></div>\n          <div class=\"pulse\"></div>\n          <div class=\"payload\">\n            <div class=\"value\">${val}</div>\n            <div class=\"meta\">address: <span style=\"font-weight:700;color:#DFF8EA\">0x${(1000+i).toString(16)}</span></div>\n          </div>\n          <div class=\"ptr\">${i === values.length -1 ? '⊘' : '→'}</div>\n        `;\n        return el;\n      }\n\n      function mount() {\n        container.innerHTML = '';\n        svg.querySelectorAll('path.link').forEach(n=>n.remove());\n        nodes = [];\n        paths = [];\n        values.forEach((v,i) => {\n          const n = createNode(v,i);\n          container.appendChild(n);\n          nodes.push(n);\n        });\n\n        // Add staggered enter animation\n        nodes.forEach((n,i)=>{\n          setTimeout(()=> n.classList.add('enter'), 80 * i);\n        });\n\n        // Wait for layout then draw arrows\n        requestAnimationFrame(drawArrows);\n      }\n\n      function drawArrows(){\n        // Clear old paths\n        svg.innerHTML = svg.querySelector('defs')?.outerHTML || svg.innerHTML;\n        const defs = svg.querySelector('defs') || null;\n        // compute positions\n        const rect = container.getBoundingClientRect();\n        nodes.forEach((n,i)=>{\n          const r = n.getBoundingClientRect();\n          // end of arrow from right edge center of node to left edge center of next node\n          if (i < nodes.length -1) {\n            const r2 = nodes[i+1].getBoundingClientRect();\n            // compute relative positions inside svg coordinates\n            const x1 = r.right - rect.left - 8;\n            const y1 = r.top - rect.top + r.height/2;\n            const x2 = r2.left - rect.left + 8;\n            const y2 = r2.top - rect.top + r2.height/2;\n            // create elegant curved path\n            const dx = Math.min(120, Math.abs(x2 - x1));\n            const controlX = x1 + dx * 0.55;\n            const controlX2 = x2 - dx * 0.55;\n            const d = `M ${x1} ${y1} C ${controlX} ${y1} ${controlX2} ${y2} ${x2} ${y2}`;\n            const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n            path.setAttribute('d', d);\n            path.setAttribute('fill','none');\n            path.setAttribute('stroke','#94F0CB');\n            path.setAttribute('stroke-width','2.6');\n            path.setAttribute('stroke-linecap','round');\n            path.setAttribute('class','link');\n            path.setAttribute('marker-end','url(#arrow)');\n            svg.appendChild(path);\n            paths.push(path);\n          }\n        });\n        // subtle path opacity and shadow\n        svg.querySelectorAll('path.link').forEach((p,i)=>{\n          p.style.opacity = 0.9;\n          p.style.filter = 'drop-shadow(0 6px 18px rgba(16,24,40,0.6))';\n        });\n      }\n\n      /* Traversal state */\n      function step() {\n        // move to next index in list\n        const prev = idx;\n        idx = (idx + 1) % nodes.length;\n        if (prev >=0) {\n          nodes[prev].classList.remove('active');\n        }\n        nodes[idx].classList.add('active');\n\n        // animate link from prev to current\n        if (prev >= 0 && paths[prev]) {\n          // clone and re-animate for a bright reveal\n          const p = paths[prev];\n          p.classList.remove('reveal');\n          // force reflow\n          void p.getBoundingClientRect();\n          p.classList.add('reveal');\n          // small color accent\n          p.setAttribute('stroke','#7C5CFF');\n          p.style.transition = 'stroke 220ms';\n          setTimeout(()=> {\n            p.setAttribute('stroke','#94F0CB');\n          }, 420);\n        }\n\n        // subtle pointer emphasis\n        nodes.forEach((n,i)=>{\n          const ptr = n.querySelector('.ptr');\n          if (i === idx) {\n            ptr.style.transform = 'translateX(2px) translateY(-2px) scale(1.02)';\n            ptr.style.background = 'linear-gradient(180deg, rgba(255,255,255,0.018), rgba(255,255,255,0.005))';\n            ptr.style.color = '#E6FFEF';\n          } else {\n            ptr.style.transform = '';\n            ptr.style.background = '';\n            ptr.style.color = '';\n          }\n        });\n      }\n\n      function start() {\n        if (running) return;\n        running = true;\n        playBtn.setAttribute('aria-pressed','true');\n        playLabel.textContent = 'Pause';\n        playDot.style.background = 'linear-gradient(180deg,#6EE7B7,#7C5CFF)';\n        // immediate step to show\n        step();\n        tickTimer = setInterval(()=>{\n          step();\n        }, 1100);\n      }\n\n      function pause() {\n        running = false;\n        playBtn.setAttribute('aria-pressed','false');\n        playLabel.textContent = 'Play';\n        playDot.style.background = 'linear-gradient(180deg,#FFD166,#FF9F1C)';\n        clearInterval(tickTimer);\n        tickTimer = null;\n      }\n\n      function reset() {\n        pause();\n        idx = -1;\n        nodes.forEach(n=>{\n          n.classList.remove('active');\n          const p = n.querySelector('.ptr');\n          if (p) { p.style.transform=''; p.style.background=''; p.style.color=''; }\n        });\n        // re-run an elegant entrance\n        nodes.forEach((n,i)=>{\n          n.classList.remove('enter');\n          void n.offsetWidth;\n          setTimeout(()=> n.classList.add('enter'), 40 * i);\n        });\n\n        // clear path reveal animations\n        paths.forEach(p=>{\n          p.classList.remove('reveal');\n        });\n      }\n\n      /* Event bindings */\n      playBtn.addEventListener('click', ()=>{\n        if (running) pause(); else start();\n      });\n      resetBtn.addEventListener('click', reset);\n\n      // Recalculate on resize (throttled)\n      let rt;\n      window.addEventListener('resize', ()=> {\n        clearTimeout(rt);\n        rt = setTimeout(drawArrows, 120);\n      });\n\n      // Setup & initial mount\n      mount();\n\n      // gentle auto-start after a short pause for cinematic effect (not too interactive)\n      setTimeout(()=> {\n        // play briefly once for demonstration then pause automatically\n        start();\n        setTimeout(()=> {\n          pause();\n        }, 3800);\n      }, 900);\n\n      // ensure SVG adjusts if fonts/metrics change\n      setTimeout(drawArrows, 1200);\n    })();\n  </script>\n</body>\n</html>"
  },
